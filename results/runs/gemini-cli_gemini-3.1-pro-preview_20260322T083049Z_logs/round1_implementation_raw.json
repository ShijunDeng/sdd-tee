package workloadmanager

import (
	"context"
	"fmt"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"github.com/gin-gonic/gin"
	"github.com/volcano-sh/agentcube/pkg/store"
	"golang.org/x/net/http2"
	"golang.org/x/net/http2/h2c"
)

type Server interface {
	Start(ctx context.Context) error
}

type server struct {
	config Config
	store  store.Store
	engine *gin.Engine
	k8s    K8sClient
	gc     GarbageCollector
    tokenCache TokenCache
}

func NewServer(cfg Config, store store.Store, k8s K8sClient, gc GarbageCollector, tc TokenCache) Server {
	engine := gin.New()
	s := &server{
		config: cfg,
		store:  store,
		engine: engine,
		k8s:    k8s,
		gc:     gc,
        tokenCache: tc,
	}
	s.setupRoutes()
	return s
}

func (s *server) setupRoutes() {
	s.engine.GET("/health", s.healthHandler)

	v1 := s.engine.Group("/v1")
	v1.Use(s.loggingMiddleware())
	v1.Use(s.authMiddleware())

	v1.POST("/agent-runtime", s.createAgentRuntime)
	v1.DELETE("/agent-runtime/sessions/:sessionId", s.deleteAgentRuntime)
	v1.POST("/code-interpreter", s.createCodeInterpreter)
	v1.DELETE("/code-interpreter/sessions/:sessionId", s.deleteCodeInterpreter)
}

func (s *server) Start(ctx context.Context) error {
	if s.config.EnableTLS && (s.config.CertPath == "" || s.config.KeyPath == "") {
		return fmt.Errorf("TLS is enabled but cert/key not provided")
	}

	if err := s.store.Ping(ctx); err != nil {
		return fmt.Errorf("failed to ping store: %w", err)
	}

	syncCtx, cancelSync := context.WithTimeout(ctx, time.Minute)
	defer cancelSync()
	if err := s.k8s.SyncInformers(syncCtx); err != nil {
		return fmt.Errorf("failed to sync informers: %w", err)
	}

	s.gc.Start(ctx)

	srv := &http.Server{
		Addr:        fmt.Sprintf(":%d", s.config.Port),
		Handler:     h2c.NewHandler(s.engine, &http2.Server{}),
		ReadTimeout: 15 * time.Second,
		IdleTimeout: 90 * time.Second,
	}

	errChan := make(chan error, 1)
	go func() {
		if s.config.EnableTLS {
			errChan <- srv.ListenAndServeTLS(s.config.CertPath, s.config.KeyPath)
		} else {
			errChan <- srv.ListenAndServe()
		}
	}()

	quit := make(chan os.Signal, 1)
	signal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)
	select {
	case <-ctx.Done():
	case <-quit:
    case err := <-errChan:
        if err != nil && err != http.ErrServerClosed {
            return err
        }
	}

	shutdownCtx, cancel := context.WithTimeout(context.Background(), 15*time.Second)
	defer cancel()

	s.gc.Stop()
	if err := srv.Shutdown(shutdownCtx); err != nil {
		return fmt.Errorf("failed to shutdown server: %w", err)
	}
	return s.store.Close()
}
