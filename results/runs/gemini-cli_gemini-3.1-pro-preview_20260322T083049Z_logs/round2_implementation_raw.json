func TestResolveOrCreateSandbox_OtherKindsAndErrors(t *testing.T) {
	ts := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		if r.URL.Path == "/v1/code-interpreter" {
			resp := types.CreateSandboxResponse{
				SessionID:   "new-sess-ci",
				SandboxName: "my-ci",
			}
			json.NewEncoder(w).Encode(resp)
			return
		}
		if r.URL.Path == "/v1/sandbox" {
			w.WriteHeader(http.StatusInternalServerError)
			w.Write([]byte("internal error"))
			return
		}
		t.Errorf("unexpected path: %s", r.URL.Path)
	}))
	defer ts.Close()

	sm, _ := NewSessionManager(ts.URL, nil)

	// Test CodeInterpreter
	info, err := sm.ResolveOrCreateSandbox(context.Background(), "CodeInterpreter", "default", "my-agent", "")
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}
	if info.SessionID != "new-sess-ci" {
		t.Fatalf("expected new-sess-ci, got %s", info.SessionID)
	}

	// Test Fallback
	_, err = sm.ResolveOrCreateSandbox(context.Background(), "UnknownKind", "default", "my-agent", "")
	if err == nil {
		t.Fatal("expected error")
	}
	if !strings.Contains(err.Error(), "workload manager returned status 500") {
		t.Fatalf("unexpected error message: %v", err)
	}
}

