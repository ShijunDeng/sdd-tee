{"type":"tool_use","timestamp":1775848285380,"sessionID":"ses_28731db20ffeapDDhzVx7gaQDp","part":{"id":"prt_d78ce6139001C4s71E6QtYk6QS","messageID":"msg_d78ce5579001J3814IMRYccTBY","sessionID":"ses_28731db20ffeapDDhzVx7gaQDp","type":"tool","tool":"read","callID":"toolu_0b975a75b38640ca8dfd3890","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"os\"\n8: \t\"os/signal\"\n9: \t\"syscall\"\n10: \t\"time\"\n11: )\n12: \n13: type Router struct {\n14: \tconfig        *Config\n15: \tserver        *http.Server\n16: \tpool          *BackendPool\n17: \tproxy         *Proxy\n18: \trouteHandler  *RouteHandler\n19: \thealthChecker *HealthChecker\n20: \trateLimiter   *RateLimiter\n21: \tauthenticator *Authenticator\n22: \tlogger        *Logger\n23: \tmetrics       *Metrics\n24: }\n25: \n26: func NewRouter(config *Config) *Router {\n27: \tif config == nil {\n28: \t\tconfig = DefaultConfig()\n29: \t}\n30: \n31: \tpool := NewBackendPool()\n32: \tproxy := NewProxy(config.BackendTimeout, config.IdleTimeout, config.MaxConnsPerBackend)\n33: \trouteHandler := NewRouteHandler(pool, []string{\"X-Backend\", \"Content-Type\"})\n34: \thealthChecker := NewHealthChecker(pool, config.HealthCheckInterval, config.HealthCheckTimeout, 3)\n35: \trateLimiter := NewRateLimiter(config.RateLimitRPS, config.RateLimitRPS*2, config.RateLimitEnabled)\n36: \tauthenticator := NewAuthenticator(config.AuthToken, config.AuthEnabled)\n37: \tlogger := NewLogger(nil)\n38: \tmetrics := NewMetrics()\n39: \n40: \trouter := &Router{\n41: \t\tconfig:        config,\n42: \t\tpool:          pool,\n43: \t\tproxy:         proxy,\n44: \t\trouteHandler:  routeHandler,\n45: \t\thealthChecker: healthChecker,\n46: \t\trateLimiter:   rateLimiter,\n47: \t\tauthenticator: authenticator,\n48: \t\tlogger:        logger,\n49: \t\tmetrics:       metrics,\n50: \t}\n51: \n52: \tmux := http.NewServeMux()\n53: \tmux.HandleFunc(\"/\", router.handleRequest)\n54: \n55: \thandler := logger.Middleware(mux)\n56: \thandler = rateLimiter.Middleware(handler)\n57: \thandler = authenticator.Middleware(handler)\n58: \n59: \trouter.server = &http.Server{\n60: \t\tAddr:         config.ListenAddress,\n61: \t\tHandler:      handler,\n62: \t\tReadTimeout:  config.BackendTimeout,\n63: \t\tWriteTimeout: config.BackendTimeout,\n64: \t\tIdleTimeout:  config.IdleTimeout,\n65: \t}\n66: \n67: \treturn router\n68: }\n69: \n70: func (r *Router) Start() error {\n71: \tgo func() {\n72: \t\tfmt.Printf(\"Starting router on %s\\n\", r.config.ListenAddress)\n73: \t\tif err := r.server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n74: \t\t\tfmt.Printf(\"Server error: %v\\n\", err)\n75: \t\t}\n76: \t}()\n77: \n78: \tr.healthChecker.Start()\n79: \n80: \treturn nil\n81: }\n82: \n83: func (r *Router) Shutdown(ctx context.Context) error {\n84: \tr.healthChecker.Stop()\n85: \n86: \tfmt.Println(\"Shutting down router...\")\n87: \treturn r.server.Shutdown(ctx)\n88: }\n89: \n90: func (r *Router) handleRequest(w http.ResponseWriter, req *http.Request) {\n91: \tstart := time.Now()\n92: \n93: \tbackend := r.routeHandler.GetBackendForRequest(req)\n94: \tif backend == nil {\n95: \t\tr.metrics.IncErrors(\"not_found\")\n96: \t\tw.WriteHeader(http.StatusNotFound)\n97: \t\treturn\n98: \t}\n99: \n100: \tr.proxy.ServeHTTP(w, req, backend)\n101: \n102: \tduration := time.Since(start).Seconds()\n103: \tr.metrics.RecordRequestDuration(req.Method, req.URL.Path, backend.Name, duration)\n104: \tr.metrics.IncBackendRequests(backend.Name, \"success\")\n105: }\n106: \n107: func (r *Router) GetPool() *BackendPool {\n108: \treturn r.pool\n109: }\n110: \n111: func (r *Router) GetConfig() *Config {\n112: \treturn r.config\n113: }\n114: \n115: func (r *Router) GetHealthChecker() *HealthChecker {\n116: \treturn r.healthChecker\n117: }\n118: \n119: func (r *Router) GetMetrics() *Metrics {\n120: \treturn r.metrics\n121: }\n122: \n123: func (r *Router) AddBackend(key, endpoint, pathPrefix, name string) error {\n124: \treturn r.pool.AddBackend(key, endpoint, pathPrefix, name)\n125: }\n126: \n127: func (r *Router) RemoveBackend(key string) {\n128: \tr.pool.RemoveBackend(key)\n129: }\n130: \n131: func (r *Router) SetHeaderRoute(headerName, headerValue, backendKey string) {\n132: \tr.pool.SetHeaderRoute(headerName, headerValue, backendKey)\n133: }\n134: \n135: func RunWithSignal(cfg *Config) error {\n136: \trouter := NewRouter(cfg)\n137: \n138: \tif err := router.Start(); err != nil {\n139: \t\treturn err\n140: \t}\n141: \n142: \tsigCh := make(chan os.Signal, 1)\n143: \tsignal.Notify(sigCh, syscall.SIGINT, syscall.SIGTERM)\n144: \n145: \t<-sigCh\n146: \tfmt.Println(\"\\nReceived shutdown signal\")\n147: \n148: \tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n149: \tdefer cancel()\n150: \n151: \treturn router.Shutdown(ctx)\n152: }\n\n(End of file - total 152 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\t\"time\"\n)\n\ntype Router struct {\n\tconfig        *Config\n\tserver        *http.Server\n\tpool          *BackendPool\n\tproxy         *Proxy\n\trouteHandler  *RouteHandler\n\thealthChecker *HealthChecker\n\trateLimiter   *RateLimiter","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server.go","time":{"start":1775848285368,"end":1775848285377}}}}
