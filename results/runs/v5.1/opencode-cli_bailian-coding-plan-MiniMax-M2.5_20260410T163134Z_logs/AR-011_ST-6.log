: \n537: \thandler.ServeHTTP(rec, req)\n538: \n539: \tif rec.Code != http.StatusOK {\n540: \t\tt.Errorf(\"Expected status %d, got %d. Body: %s\", http.StatusOK, rec.Code, rec.Body.String())\n541: \t}\n542: \n543: \tvar response map[string]interface{}\n544: \tif err := json.NewDecoder(rec.Body).Decode(&response); err != nil {\n545: \t\tt.Fatalf(\"Failed to decode response: %v\", err)\n546: \t}\n547: \n548: \tif response[\"access_token\"] == nil {\n549: \t\tt.Error(\"access_token should be in response\")\n550: \t}\n551: }\n552: \n553: func TestRefreshHandler_ExpiredToken(t *testing.T) {\n554: \tvalidator := newMockUserValidator()\n555: \tconfig := &JWTConfig{\n556: \t\tAlgorithm:         \"HS256\",\n557: \t\tSecret:            \"test-secret-key\",\n558: \t\tIssuer:            \"agentcube\",\n559: \t\tExpiration:        1 * time.Hour,\n560: \t\tRefreshExpiration: -1 * time.Hour,\n561: \t}\n562: \n563: \tmanager, _ := NewJWTManager(config, validator)\n564: \n565: \tuser := &UserClaims{\n566: \t\tUsername: \"testuser\",\n567: \t\tRoles:    []string{\"user\"},\n568: \t}\n569: \trefreshToken, _ := manager.IssueRefreshToken(user)\n570: \n571: \thandler := NewRefreshHandler(manager)\n572: \n573: \tbody := `{\"refresh_token\":\"` + refreshToken + `\"}`\n574: \treq := httptest.NewRequest(\"POST\", \"/refresh\", strings.NewReader(body))\n575: \treq.Header.Set(\"Content-Type\", \"application/json\")\n576: \trec := httptest.NewRecorder()\n577: \n578: \thandler.ServeHTTP(rec, req)\n579: \n580: \tif rec.Code != http.StatusUnauthorized {\n581: \t\tt.Errorf(\"Expected status %d, got %d\", http.StatusUnauthorized, rec.Code)\n582: \t}\n583: }\n584: \n585: func TestConfig_DefaultValues(t *testing.T) {\n586: \tcfg := DefaultConfig()\n587: \n588: \tif cfg.JWTEnabled != false {\n589: \t\tt.Errorf(\"JWTEnabled = %v, want false\", cfg.JWTEnabled)\n590: \t}\n591: \tif cfg.JWTAlgorithm != \"HS256\" {\n592: \t\tt.Errorf(\"JWTAlgorithm = %v, want HS256\", cfg.JWTAlgorithm)\n593: \t}\n594: \tif cfg.JWTIssuer != \"agentcube\" {\n595: \t\tt.Errorf(\"JWTIssuer = %v, want agentcube\", cfg.JWTIssuer)\n596: \t}\n597: \tif cfg.JWTExpiration != 1*time.Hour {\n598: \t\tt.Errorf(\"JWTExpiration = %v, want 1h\", cfg.JWTExpiration)\n599: \t}\n600: \tif cfg.JWTRefreshExpiration != 24*time.Hour {\n601: \t\tt.Errorf(\"JWTRefreshExpiration = %v, want 24h\", cfg.JWTRefreshExpiration)\n602: \t}\n603: \tif cfg.JWTClockSkew != 30*time.Second {\n604: \t\tt.Errorf(\"JWTClockSkew = %v, want 30s\", cfg.JWTClockSkew)\n605: \t}\n606: }\n607: \n608: func TestJWTManager_WithRS256(t *testing.T) {\n609: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n610: \tif err != nil {\n611: \t\tt.Fatalf(\"Failed to generate RSA key: %v\", err)\n612: \t}\n613: \n614: \t_ = privateKey\n615: \n616: \tconfig := &JWTConfig{\n617: \t\tAlgorithm:  \"RS256\",\n618: \t\tSecret:     \"\",\n619: \t\tIssuer:     \"agentcube\",\n620: \t\tExpiration: 1 * time.Hour,\n621: \t}\n622: \n623: \tmanager, err := NewJWTManager(config, nil)\n624: \tif err != nil {\n625: \t\tt.Logf(\"RS256 without keys returns error as expected: %v\", err)\n626: \t\treturn\n627: \t}\n628: \n629: \tif manager != nil {\n630: \t\tuser := &UserClaims{\n631: \t\t\tUsername: \"testuser\",\n632: \t\t\tRoles:    []string{\"user\"},\n633: \t\t}\n634: \t\t_, err = manager.IssueToken(user)\n635: \t\tif err != nil {\n636: \t\t\tt.Logf(\"RS256 without keys cannot issue token: %v\", err)\n637: \t\t}\n638: \t}\n639: }\n640: \n641: func TestGetClaimsFromContext(t *testing.T) {\n642: \tclaims := &Claims{\n643: \t\tRegisteredClaims: jwt.RegisteredClaims{\n644: \t\t\tSubject: \"testuser\",\n645: \t\t},\n646: \t\tRoles: []string{\"admin\"},\n647: \t}\n648: \n649: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n650: \tctx := req.Context()\n651: \tctx = context.WithValue(ctx, ContextKeyClaims, claims)\n652: \n653: \tretrievedClaims := ctx.Value(ContextKeyClaims)\n654: \tif retrievedClaims == nil {\n655: \t\tt.Error(\"Claims should be available in context\")\n656: \t}\n657: \t_ = retrievedClaims\n658: }\n659: \n660: func TestGetUsernameFromContext(t *testing.T) {\n661: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n662: \tusername := GetUsernameFromContext(req)\n663: \tif username != \"\" {\n664: \t\tt.Errorf(\"Expected empty username, got %s\", username)\n665: \t}\n666: }\n667: \n668: func TestJWTMetrics(t *testing.T) {\n669: \tmetrics := NewJWTMetrics()\n670: \tif metrics == nil {\n671: \t\tt.Error(\"NewJWTMetrics() returned nil\")\n672: \t}\n673: \n674: \tmetrics.IncValidated(\"success\")\n675: \tmetrics.IncIssued()\n676: \tmetrics.IncRefreshed(\"success\")\n677: \tmetrics.IncValidationError(ErrCodeTokenExpired)\n678: }\n\n(End of file - total 678 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\ntype mockUserValidator struct {\n\tusers map[string]string\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_test.go","time":{"start":1775850138854,"end":1775850138872}}}}
