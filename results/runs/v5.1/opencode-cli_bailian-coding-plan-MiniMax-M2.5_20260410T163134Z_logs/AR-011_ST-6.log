{"type":"tool_use","timestamp":1775850103094,"sessionID":"ses_287163125ffevnuWP4ITQKsGQG","part":{"id":"prt_d78ea1cf1001DxdaOG5zobCKBh","messageID":"msg_d78ea1009001EU7O3hsvGLCYe7","sessionID":"ses_287163125ffevnuWP4ITQKsGQG","type":"tool","tool":"read","callID":"toolu_e8db9983dd87483fb2c1b1bd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"crypto/rsa\"\n5: \t\"encoding/json\"\n6: \t\"encoding/pem\"\n7: \t\"errors\"\n8: \t\"fmt\"\n9: \t\"io\"\n10: \t\"net/http\"\n11: \t\"os\"\n12: \t\"strings\"\n13: \t\"time\"\n14: \n15: \t\"github.com/golang-jwt/jwt/v5\"\n16: )\n17: \n18: var (\n19: \tErrMalformedToken      = errors.New(\"malformed token\")\n20: \tErrInvalidSignature    = errors.New(\"invalid signature\")\n21: \tErrTokenExpired        = errors.New(\"token has expired\")\n22: \tErrInvalidAudience     = errors.New(\"invalid audience\")\n23: \tErrInvalidIssuer       = errors.New(\"invalid issuer\")\n24: \tErrUnauthorized        = errors.New(\"unauthorized\")\n25: \tErrInvalidCredentials  = errors.New(\"invalid credentials\")\n26: \tErrInvalidRefreshToken = errors.New(\"invalid or expired refresh token\")\n27: \tErrInvalidTokenType    = errors.New(\"invalid token type\")\n28: \tErrMissingKey          = errors.New(\"missing key configuration\")\n29: )\n30: \n31: const (\n32: \tErrCodeMalformedToken      = \"MALFORMED_TOKEN\"\n33: \tErrCodeInvalidSignature    = \"INVALID_SIGNATURE\"\n34: \tErrCodeTokenExpired        = \"TOKEN_EXPIRED\"\n35: \tErrCodeInvalidAudience     = \"INVALID_AUDIENCE\"\n36: \tErrCodeInvalidIssuer       = \"INVALID_ISSUER\"\n37: \tErrCodeUnauthorized        = \"UNAUTHORIZED\"\n38: \tErrCodeInvalidCredentials  = \"INVALID_CREDENTIALS\"\n39: \tErrCodeInvalidRefreshToken = \"INVALID_REFRESH_TOKEN\"\n40: \tErrCodeInvalidTokenType    = \"INVALID_TOKEN_TYPE\"\n41: )\n42: \n43: type JWTConfig struct {\n44: \tAlgorithm         string\n45: \tSecret            string\n46: \tPrivateKeyPath    string\n47: \tPublicKeyPath     string\n48: \tIssuer            string\n49: \tAudience          []string\n50: \tExpiration        time.Duration\n51: \tRefreshExpiration time.Duration\n52: \tClockSkew         time.Duration\n53: \tAllowQueryParam   bool\n54: }\n55: \n56: type Claims struct {\n57: \tjwt.RegisteredClaims\n58: \tRoles     []string `json:\"roles,omitempty\"`\n59: \tTenantID  string   `json:\"tenant_id,omitempty\"`\n60: \tNamespace string   `json:\"namespace,omitempty\"`\n61: }\n62: \n63: type UserCredentials struct {\n64: \tUsername string `json:\"username\" binding:\"required\"`\n65: \tPassword string `json:\"password\" binding:\"required\"`\n66: }\n67: \n68: type LoginResponse struct {\n69: \tAccessToken  string `json:\"access_token\"`\n70: \tRefreshToken string `json:\"refresh_token,omitempty\"`\n71: \tTokenType    string `json:\"token_type\"`\n72: \tExpiresIn    int    `json:\"expires_in\"`\n73: }\n74: \n75: type TokenRefreshRequest struct {\n76: \tRefreshToken string `json:\"refresh_token\" binding:\"required\"`\n77: }\n78: \n79: type UserValidator interface {\n80: \tValidate(username, password string) (*UserClaims, error)\n81: }\n82: \n83: type UserClaims struct {\n84: \tUsername  string\n85: \tRoles     []string\n86: \tTenantID  string\n87: \tNamespace string\n88: }\n89: \n90: type JWTManager struct {\n91: \tconfig        *JWTConfig\n92: \tsecret        []byte\n93: \tprivateKey    interface{}\n94: \tpublicKey     interface{}\n95: \tmetrics       *JWTMetrics\n96: \tuserValidator UserValidator\n97: }\n98: \n99: func NewJWTManager(config *JWTConfig, validator UserValidator) (*JWTManager, error) {\n100: \tif config == nil {\n101: \t\tconfig = &JWTConfig{\n102: \t\t\tAlgorithm:         \"HS256\",\n103: \t\t\tIssuer:            \"agentcube\",\n104: \t\t\tExpiration:        1 * time.Hour,\n105: \t\t\tRefreshExpiration: 24 * time.Hour,\n106: \t\t\tClockSkew:         30 * time.Second,\n107: \t\t}\n108: \t}\n109: \n110: \tmanager := &JWTManager{\n111: \t\tconfig:        config,\n112: \t\tmetrics:       NewJWTMetrics(),\n113: \t\tuserValidator: validator,\n114: \t}\n115: \n116: \tif err := manager.loadKeys(); err != nil {\n117: \t\treturn nil, err\n118: \t}\n119: \n120: \treturn manager, nil\n121: }\n122: \n123: func (j *JWTManager) loadKeys() error {\n124: \talgorithm := strings.ToUpper(j.config.Algorithm)\n125: \n126: \tswitch algorithm {\n127: \tcase \"HS256\", \"HS384\", \"HS512\":\n128: \t\tif j.config.Secret == \"\" {\n129: \t\t\treturn ErrMissingKey\n130: \t\t}\n131: \t\tj.secret = []byte(j.config.Secret)\n132: \n133: \tcase \"RS256\", \"RS384\", \"RS512\":\n134: \t\tif j.config.PrivateKeyPath != \"\" {\n135: \t\t\tprivateKey, err := loadPrivateKey(j.config.PrivateKeyPath)\n136: \t\t\tif err != nil {\n137: \t\t\t\treturn fmt.Errorf(\"failed to load private key: %w\", err)\n138: \t\t\t}\n139: \t\t\tj.privateKey = privateKey\n140: \t\t}\n141: \n142: \t\tif j.config.PublicKeyPath != \"\" {\n143: \t\t\tpublicKey, err := loadPublicKey(j.config.PublicKeyPath)\n144: \t\t\tif err != nil {\n145: \t\t\t\treturn fmt.Errorf(\"failed to load public key: %w\", err)\n146: \t\t\t}\n147: \t\t\tj.publicKey = publicKey\n148: \t\t}\n149: \n150: \t\tif j.privateKey == nil && j.publicKey == nil {\n151: \t\t\treturn ErrMissingKey\n152: \t\t}\n153: \n154: \tdefault:\n155: \t\treturn fmt.Errorf(\"unsupported algorithm: %s\", algorithm)\n156: \t}\n157: \n158: \treturn nil\n159: }\n160: \n161: func loadPrivateKey(path string) (interface{}, error) {\n162: \tdata, err := os.ReadFile(path)\n163: \tif err != nil {\n164: \t\treturn nil, err\n165: \t}\n166: \n167: \tblock, _ := pem.Decode(data)\n168: \tif block == nil {\n169: \t\treturn nil, errors.New(\"failed to parse PEM block\")\n170: \t}\n171: \n172: \tif block.Type == \"RSA PRIVATE KEY\" {\n173: \t\treturn jwt.ParseRSAPrivateKeyFromPEM(data)\n174: \t}\n175: \tif block.Type == \"EC PRIVATE KEY\" {\n176: \t\treturn jwt.ParseECPrivateKeyFromPEM(data)\n177: \t}\n178: \n179: \treturn nil, fmt.Errorf(\"unsupported private key type: %s\", block.Type)\n180: }\n181: \n182: func loadPublicKey(path string) (interface{}, error) {\n183: \tdata, err := os.ReadFile(path)\n184: \tif err != nil {\n185: \t\treturn nil, err\n186: \t}\n187: \n188: \tblock, _ := pem.Decode(data)\n189: \tif block == nil {\n190: \t\treturn nil, errors.New(\"failed to parse PEM block\")\n191: \t}\n192: \n193: \tif block.Type == \"RSA PUBLIC KEY\" || block.Type == \"PUBLIC KEY\" {\n194: \t\treturn jwt.ParseRSAPublicKeyFromPEM(data)\n195: \t}\n196: \tif block.Type == \"EC PUBLIC KEY\" {\n197: \t\treturn jwt.ParseECPublicKeyFromPEM(data)\n198: \t}\n199: \n200: \treturn nil, fmt.Errorf(\"unsupported public key type: %s\", block.Type)\n201: }\n202: \n203: func (j *JWTManager) ValidateToken(tokenString string) (*Claims, error) {\n204: \ttoken, err := jwt.ParseWithClaims(tokenString, &Claims{}, func(token *jwt.Token) (interface{}, error) {\n205: \t\treturn j.getSigningKey(token)\n206: \t}, jwt.WithIssuer(j.config.Issuer),\n207: \t\tjwt.WithAudience(j.config.Audience...),\n208: \t\tjwt.WithClockSkew(j.config.ClockSkew),\n209: \t\tjwt.WithInvalidKeyAs(false),\n210: \t)\n211: \n212: \tif err != nil {\n213: \t\treturn j.handleValidationError(err)\n214: \t}\n215: \n216: \tif !token.Valid {\n217: \t\tj.metrics.IncValidationError(ErrCodeMalformedToken)\n218: \t\treturn nil, ErrMalformedToken\n219: \t}\n220: \n221: \tclaims, ok := token.Claims.(*Claims)\n222: \tif !ok {\n223: \t\tj.metrics.IncValidationError(ErrCodeMalformedToken)\n224: \t\treturn nil, ErrMalformedToken\n225: \t}\n226: \n227: \tj.metrics.IncValidated(\"success\")\n228: \treturn claims, nil\n229: }\n230: \n231: func (j *JWTManager) getSigningKey(token *jwt.Token) (interface{}, error) {\n232: \talg := token.Method.Alg()\n233: \n234: \tswitch strings.ToUpper(alg) {\n235: \tcase \"HS256\", \"HS384\", \"HS512\":\n236: \t\treturn j.secret, nil\n237: \tcase \"RS256\", \"RS384\", \"RS512\":\n238: \t\tif j.publicKey != nil {\n239: \t\t\treturn j.publicKey, nil\n240: \t\t}\n241: \t\treturn nil, ErrMissingKey\n242: \tcase \"ES256\", \"ES384\":\n243: \t\tif j.publicKey != nil {\n244: \t\t\treturn j.publicKey, nil\n245: \t\t}\n246: \t\treturn nil, ErrMissingKey\n247: \t}\n248: \n249: \treturn nil, fmt.Errorf(\"unsupported algorithm: %s\", alg)\n250: }\n251: \n252: func (j *JWTManager) getSigningKeyForIssuance() (interface{}, error) {\n253: \talg := strings.ToUpper(j.config.Algorithm)\n254: \n255: \tswitch alg {\n256: \tcase \"HS256\", \"HS384\", \"HS512\":\n257: \t\treturn j.secret, nil\n258: \tcase \"RS256\", \"RS384\", \"RS512\":\n259: \t\tif j.privateKey != nil {\n260: \t\t\treturn j.privateKey, nil\n261: \t\t}\n262: \t\treturn nil, ErrMissingKey\n263: \tcase \"ES256\", \"ES384\":\n264: \t\tif j.privateKey != nil {\n265: \t\t\treturn j.privateKey, nil\n266: \t\t}\n267: \t\treturn nil, ErrMissingKey\n268: \t}\n269: \n270: \treturn nil, fmt.Errorf(\"unsupported algorithm: %s\", alg)\n271: }\n272: \n273: func (j *JWTManager) handleValidationError(err error) (*Claims, error) {\n274: \tvar validationErr *jwt.ValidationError\n275: \tif errors.As(err, &validationErr) {\n276: \t\tif validationErr.Errors&jwt.ValidationErrorMalformed != 0 {\n277: \t\t\tj.metrics.IncValidationError(ErrCodeMalformedToken)\n278: \t\t\treturn nil, ErrMalformedToken\n279: \t\t}\n280: \t\tif validationErr.Errors&jwt.ValidationErrorExpired != 0 {\n281: \t\t\tj.metrics.IncValidationError(ErrCodeTokenExpired)\n282: \t\t\treturn nil, ErrTokenExpired\n283: \t\t}\n284: \t\tif validationErr.Errors&jwt.ValidationErrorSignatureInvalid != 0 {\n285: \t\t\tj.metrics.IncValidationError(ErrCodeInvalidSignature)\n286: \t\t\treturn nil, ErrInvalidSignature\n287: \t\t}\n288: \t\tif validationErr.Errors&jwt.ValidationErrorAudience != 0 {\n289: \t\t\tj.metrics.IncValidationError(ErrCodeInvalidAudience)\n290: \t\t\treturn nil, ErrInvalidAudience\n291: \t\t}\n292: \t\tif validationErr.Errors&jwt.ValidationErrorIssuer != 0 {\n293: \t\t\tj.metrics.IncValidationError(ErrCodeInvalidIssuer)\n294: \t\t\treturn nil, ErrInvalidIssuer\n295: \t\t}\n296: \t}\n297: \n298: \tj.metrics.IncValidationError(ErrCodeUnauthorized)\n299: \treturn nil, ErrUnauthorized\n300: }\n301: \n302: func (j *JWTManager) IssueToken(user *UserClaims) (string, error) {\n303: \tnow := time.Now()\n304: \n305: \tclaims := &Claims{\n306: \t\tRegisteredClaims: jwt.RegisteredClaims{\n307: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(j.config.Expiration)),\n308: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n309: \t\t\tNotBefore: jwt.NewNumericDate(now),\n310: \t\t\tIssuer:    j.config.Issuer,\n311: \t\t\tSubject:   user.Username,\n312: \t\t\tAudience:  jwt.ClaimStrings(j.config.Audience),\n313: \t\t},\n314: \t\tRoles:     user.Roles,\n315: \t\tTenantID:  user.TenantID,\n316: \t\tNamespace: user.Namespace,\n317: \t}\n318: \n319: \tkey, err := j.getSigningKeyForIssuance()\n320: \tif err != nil {\n321: \t\treturn \"\", err\n322: \t}\n323: \n324: \ttoken := jwt.NewWithClaims(jwt.GetSigningMethod(j.config.Algorithm), claims)\n325: \tsignedToken, err := token.SignedString(key)\n326: \tif err != nil {\n327: \t\treturn \"\", fmt.Errorf(\"failed to sign token: %w\", err)\n328: \t}\n329: \n330: \tj.metrics.IncIssued()\n331: \treturn signedToken, nil\n332: }\n333: \n334: func (j *JWTManager) IssueRefreshToken(user *UserClaims) (string, error) {\n335: \tnow := time.Now()\n336: \n337: \tclaims := &Claims{\n338: \t\tRegisteredClaims: jwt.RegisteredClaims{\n339: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(j.config.RefreshExpiration)),\n340: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n341: \t\t\tNotBefore: jwt.NewNumericDate(now),\n342: \t\t\tIssuer:    j.config.Issuer,\n343: \t\t\tSubject:   user.Username,\n344: \t\t\tID:        \"refresh\",\n345: \t\t\tAudience:  jwt.ClaimStrings(j.config.Audience),\n346: \t\t},\n347: \t\tRoles:     user.Roles,\n348: \t\tTenantID:  user.TenantID,\n349: \t\tNamespace: user.Namespace,\n350: \t}\n351: \n352: \tkey, err := j.getSigningKeyForIssuance()\n353: \tif err != nil {\n354: \t\treturn \"\", err\n355: \t}\n356: \n357: \ttoken := jwt.NewWithClaims(jwt.GetSigningMethod(j.config.Algorithm), claims)\n358: \tsignedToken, err := token.SignedString(key)\n359: \tif err != nil {\n360: \t\treturn \"\", fmt.Errorf(\"failed to sign refresh token: %w\", err)\n361: \t}\n362: \n363: \treturn signedToken, nil\n364: }\n365: \n366: func (j *JWTManager) ValidateRefreshToken(tokenString string) (*Claims, error) {\n367: \tclaims, err := j.ValidateToken(tokenString)\n368: \tif err != nil {\n369: \t\treturn nil, err\n370: \t}\n371: \n372: \tif claims.ID != \"refresh\" {\n373: \t\treturn nil, ErrInvalidTokenType\n374: \t}\n375: \n376: \treturn claims, nil\n377: }\n378: \n379: func (j *JWTManager) GetMetrics() *JWTMetrics {\n380: \treturn j.metrics\n381: }\n382: \n383: func (j *JWTManager) IsRefreshToken(tokenString string) bool {\n384: \tclaims, err := j.ValidateToken(tokenString)\n385: \tif err != nil {\n386: \t\treturn false\n387: \t}\n388: \treturn claims.ID == \"refresh\"\n389: }\n390: \n391: func ParseJWTFromBody(body io.Reader) (*Claims, error) {\n392: \tvar claims Claims\n393: \tif err := json.NewDecoder(body).Decode(&claims); err != nil {\n394: \t\treturn nil, err\n395: \t}\n396: \treturn &claims, nil\n397: }\n398: \n399: func GetClaimsFromContext(req *http.Request) *Claims {\n400: \tval := req.Context().Value(ContextKeyClaims)\n401: \tif claims, ok := val.(*Claims); ok {\n402: \t\treturn claims\n403: \t}\n404: \treturn nil\n405: }\n406: \n407: func GetUsernameFromContext(req *http.Request) string {\n408: \tval := req.Context().Value(ContextKeyUsername)\n409: \tif username, ok := val.(string); ok {\n410: \t\treturn username\n411: \t}\n412: \treturn \"\"\n413: 