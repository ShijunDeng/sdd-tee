t\th.sendError(w, \"invalid credentials\", http.StatusUnauthorized, ErrCodeInvalidCredentials)\n43: \t\treturn\n44: \t}\n45: \n46: \taccessToken, err := h.jwtManager.IssueToken(userClaims)\n47: \tif err != nil {\n48: \t\th.sendError(w, \"failed to issue token\", http.StatusInternalServerError, ErrCodeUnauthorized)\n49: \t\treturn\n50: \t}\n51: \n52: \trefreshToken, err := h.jwtManager.IssueRefreshToken(userClaims)\n53: \tif err != nil {\n54: \t\th.sendError(w, \"failed to issue refresh token\", http.StatusInternalServerError, ErrCodeUnauthorized)\n55: \t\treturn\n56: \t}\n57: \n58: \texpiresIn := int(h.jwtManager.config.Expiration.Seconds())\n59: \n60: \tresponse := LoginResponse{\n61: \t\tAccessToken:  accessToken,\n62: \t\tRefreshToken: refreshToken,\n63: \t\tTokenType:    \"Bearer\",\n64: \t\tExpiresIn:    expiresIn,\n65: \t}\n66: \n67: \tw.Header().Set(\"Content-Type\", \"application/json\")\n68: \tw.WriteHeader(http.StatusOK)\n69: \tjson.NewEncoder(w).Encode(response)\n70: }\n71: \n72: func (h *LoginHandler) sendError(w http.ResponseWriter, message string, statusCode int, errorCode string) {\n73: \tw.Header().Set(\"Content-Type\", \"application/json\")\n74: \tw.WriteHeader(statusCode)\n75: \n76: \terrorResponse := map[string]string{\n77: \t\t\"error\":       message,\n78: \t\t\"error_code\":  errorCode,\n79: \t\t\"status_code\": string(rune(statusCode)),\n80: \t}\n81: \n82: \tjson.NewEncoder(w).Encode(errorResponse)\n83: }\n84: \n85: type RefreshHandler struct {\n86: \tjwtManager *JWTManager\n87: }\n88: \n89: func NewRefreshHandler(jwtManager *JWTManager) *RefreshHandler {\n90: \treturn &RefreshHandler{\n91: \t\tjwtManager: jwtManager,\n92: \t}\n93: }\n94: \n95: func (h *RefreshHandler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n96: \tif r.Method != http.MethodPost {\n97: \t\thttp.Error(w, \"method not allowed\", http.StatusMethodNotAllowed)\n98: \t\treturn\n99: \t}\n100: \n101: \tvar refreshReq TokenRefreshRequest\n102: \tif err := json.NewDecoder(r.Body).Decode(&refreshReq); err != nil {\n103: \t\th.sendError(w, \"invalid request body\", http.StatusBadRequest, ErrCodeMalformedToken)\n104: \t\treturn\n105: \t}\n106: \n107: \tif refreshReq.RefreshToken == \"\" {\n108: \t\th.sendError(w, \"refresh token is required\", http.StatusBadRequest, ErrCodeInvalidRefreshToken)\n109: \t\treturn\n110: \t}\n111: \n112: \tif h.jwtManager == nil {\n113: \t\th.sendError(w, \"authentication not configured\", http.StatusInternalServerError, ErrCodeUnauthorized)\n114: \t\treturn\n115: \t}\n116: \n117: \tclaims, err := h.jwtManager.ValidateRefreshToken(refreshReq.RefreshToken)\n118: \tif err != nil {\n119: \t\th.sendError(w, \"invalid or expired refresh token\", http.StatusUnauthorized, ErrCodeInvalidRefreshToken)\n120: \t\treturn\n121: \t}\n122: \n123: \tuserClaims := &UserClaims{\n124: \t\tUsername:  claims.Subject,\n125: \t\tRoles:     claims.Roles,\n126: \t\tTenantID:  claims.TenantID,\n127: \t\tNamespace: claims.Namespace,\n128: \t}\n129: \n130: \taccessToken, err := h.jwtManager.IssueToken(userClaims)\n131: \tif err != nil {\n132: \t\th.sendError(w, \"failed to issue token\", http.StatusInternalServerError, ErrCodeUnauthorized)\n133: \t\treturn\n134: \t}\n135: \n136: \th.jwtManager.metrics.IncRefreshed(\"success\")\n137: \n138: \texpiresIn := int(h.jwtManager.config.Expiration.Seconds())\n139: \n140: \tresponse := map[string]interface{}{\n141: \t\t\"access_token\": accessToken,\n142: \t\t\"token_type\":   \"Bearer\",\n143: \t\t\"expires_in\":   expiresIn,\n144: \t}\n145: \n146: \tw.Header().Set(\"Content-Type\", \"application/json\")\n147: \tw.WriteHeader(http.StatusOK)\n148: \tjson.NewEncoder(w).Encode(response)\n149: }\n150: \n151: func (h *RefreshHandler) sendError(w http.ResponseWriter, message string, statusCode int, errorCode string) {\n152: \tw.Header().Set(\"Content-Type\", \"application/json\")\n153: \tw.WriteHeader(statusCode)\n154: \n155: \tif h.jwtManager != nil && h.jwtManager.metrics != nil {\n156: \t\th.jwtManager.metrics.IncRefreshed(\"failure\")\n157: \t}\n158: \n159: \terrorResponse := map[string]string{\n160: \t\t\"error\":       message,\n161: \t\t\"error_code\":  errorCode,\n162: \t\t\"status_code\": string(rune(statusCode)),\n163: \t}\n164: \n165: \tjson.NewEncoder(w).Encode(errorResponse)\n166: }\n167: \n168: func HandleLogin(jwtManager *JWTManager) http.HandlerFunc {\n169: \thandler := NewLoginHandler(jwtManager)\n170: \treturn handler.ServeHTTP\n171: }\n172: \n173: func HandleRefresh(jwtManager *JWTManager) http.HandlerFunc {\n174: \thandler := NewRefreshHandler(jwtManager)\n175: \treturn handler.ServeHTTP\n176: }\n\n(End of file - total 176 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n)\n\ntype LoginHandler struct {\n\tjwtManager *JWTManager\n}\n\nfunc NewLoginHandler(jwtManager *JWTManager) *LoginHandler {\n\treturn &LoginHandler{\n\t\tjwtManager: jwtManager,\n\t}\n}\n\nfunc (h *LoginHandler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tif r.Method != http.MethodPost {\n\t\thttp.Error(w, \"method not allowed\", http.StatusMethodNotAllowed)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_handler.go","time":{"start":1775850119258,"end":1775850119274}}}}
