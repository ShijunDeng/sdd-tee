{"type":"tool_use","timestamp":1775850138874,"sessionID":"ses_287163125ffevnuWP4ITQKsGQG","part":{"id":"prt_d78eaa95a001PQrIERqOtaahhQ","messageID":"msg_d78ea8959001CFbGnw0hfvffHx","sessionID":"ses_287163125ffevnuWP4ITQKsGQG","type":"tool","tool":"read","callID":"toolu_16a8648df519484484de8523","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"encoding/json\"\n8: \t\"net/http\"\n9: \t\"net/http/httptest\"\n10: \t\"strings\"\n11: \t\"testing\"\n12: \t\"time\"\n13: \n14: \t\"github.com/golang-jwt/jwt/v5\"\n15: )\n16: \n17: type mockUserValidator struct {\n18: \tusers map[string]string\n19: }\n20: \n21: func newMockUserValidator() *mockUserValidator {\n22: \treturn &mockUserValidator{\n23: \t\tusers: map[string]string{\n24: \t\t\t\"admin\":    \"password\",\n25: \t\t\t\"testuser\": \"testpass\",\n26: \t\t},\n27: \t}\n28: }\n29: \n30: func (m *mockUserValidator) Validate(username, password string) (*UserClaims, error) {\n31: \tif storedPass, ok := m.users[username]; ok && storedPass == password {\n32: \t\troles := []string{\"user\"}\n33: \t\tif username == \"admin\" {\n34: \t\t\troles = []string{\"admin\", \"user\"}\n35: \t\t}\n36: \t\treturn &UserClaims{\n37: \t\t\tUsername:  username,\n38: \t\t\tRoles:     roles,\n39: \t\t\tTenantID:  \"default\",\n40: \t\t\tNamespace: \"default\",\n41: \t\t}, nil\n42: \t}\n43: \treturn nil, ErrInvalidCredentials\n44: }\n45: \n46: func TestNewJWTManager(t *testing.T) {\n47: \ttests := []struct {\n48: \t\tname    string\n49: \t\tconfig  *JWTConfig\n50: \t\twantErr bool\n51: \t\twantAlg string\n52: \t}{\n53: \t\t{\n54: \t\t\tname: \"default config\",\n55: \t\t\tconfig: &JWTConfig{\n56: \t\t\t\tAlgorithm: \"HS256\",\n57: \t\t\t\tSecret:    \"test-secret\",\n58: \t\t\t},\n59: \t\t\twantErr: false,\n60: \t\t\twantAlg: \"HS256\",\n61: \t\t},\n62: \t\t{\n63: \t\t\tname: \"missing secret\",\n64: \t\t\tconfig: &JWTConfig{\n65: \t\t\t\tAlgorithm: \"HS256\",\n66: \t\t\t},\n67: \t\t\twantErr: true,\n68: \t\t},\n69: \t\t{\n70: \t\t\tname:    \"default nil config\",\n71: \t\t\tconfig:  nil,\n72: \t\t\twantErr: false,\n73: \t\t\twantAlg: \"HS256\",\n74: \t\t},\n75: \t}\n76: \n77: \tfor _, tt := range tests {\n78: \t\tt.Run(tt.name, func(t *testing.T) {\n79: \t\t\tvalidator := newMockUserValidator()\n80: \t\t\tmanager, err := NewJWTManager(tt.config, validator)\n81: \t\t\tif (err != nil) != tt.wantErr {\n82: \t\t\t\tt.Errorf(\"NewJWTManager() error = %v, wantErr %v\", err, tt.wantErr)\n83: \t\t\t\treturn\n84: \t\t\t}\n85: \t\t\tif !tt.wantErr && manager == nil {\n86: \t\t\t\tt.Error(\"NewJWTManager() returned nil manager\")\n87: \t\t\t}\n88: \t\t})\n89: \t}\n90: }\n91: \n92: func TestJWTManager_IssueToken(t *testing.T) {\n93: \tvalidator := newMockUserValidator()\n94: \tconfig := &JWTConfig{\n95: \t\tAlgorithm:  \"HS256\",\n96: \t\tSecret:     \"test-secret-key\",\n97: \t\tIssuer:     \"agentcube\",\n98: \t\tAudience:   []string{\"agentcube-api\"},\n99: \t\tExpiration: 1 * time.Hour,\n100: \t}\n101: \n102: \tmanager, err := NewJWTManager(config, validator)\n103: \tif err != nil {\n104: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n105: \t}\n106: \n107: \tuser := &UserClaims{\n108: \t\tUsername:  \"testuser\",\n109: \t\tRoles:     []string{\"user\", \"admin\"},\n110: \t\tTenantID:  \"tenant1\",\n111: \t\tNamespace: \"ns1\",\n112: \t}\n113: \n114: \ttoken, err := manager.IssueToken(user)\n115: \tif err != nil {\n116: \t\tt.Fatalf(\"IssueToken() error = %v\", err)\n117: \t}\n118: \n119: \tif token == \"\" {\n120: \t\tt.Error(\"IssueToken() returned empty token\")\n121: \t}\n122: \n123: \tparts := strings.Split(token, \".\")\n124: \tif len(parts) != 3 {\n125: \t\tt.Errorf(\"IssueToken() returned invalid token format, got %d parts\", len(parts))\n126: \t}\n127: }\n128: \n129: func TestJWTManager_ValidateToken(t *testing.T) {\n130: \tvalidator := newMockUserValidator()\n131: \tconfig := &JWTConfig{\n132: \t\tAlgorithm:  \"HS256\",\n133: \t\tSecret:     \"test-secret-key\",\n134: \t\tIssuer:     \"agentcube\",\n135: \t\tAudience:   []string{\"agentcube-api\"},\n136: \t\tExpiration: 1 * time.Hour,\n137: \t}\n138: \n139: \tmanager, err := NewJWTManager(config, validator)\n140: \tif err != nil {\n141: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n142: \t}\n143: \n144: \tuser := &UserClaims{\n145: \t\tUsername: \"testuser\",\n146: \t\tRoles:    []string{\"user\"},\n147: \t}\n148: \n149: \ttoken, err := manager.IssueToken(user)\n150: \tif err != nil {\n151: \t\tt.Fatalf(\"Failed to issue token: %v\", err)\n152: \t}\n153: \n154: \tclaims, err := manager.ValidateToken(token)\n155: \tif err != nil {\n156: \t\tt.Errorf(\"ValidateToken() error = %v\", err)\n157: \t\treturn\n158: \t}\n159: \n160: \tif claims.Subject != \"testuser\" {\n161: \t\tt.Errorf(\"ValidateToken() subject = %v, want testuser\", claims.Subject)\n162: \t}\n163: \n164: \tif len(claims.Roles) != 1 || claims.Roles[0] != \"user\" {\n165: \t\tt.Errorf(\"ValidateToken() roles = %v, want [user]\", claims.Roles)\n166: \t}\n167: }\n168: \n169: func TestJWTManager_ValidateExpiredToken(t *testing.T) {\n170: \tvalidator := newMockUserValidator()\n171: \tconfig := &JWTConfig{\n172: \t\tAlgorithm: \"HS256\",\n173: \t\tSecret:    \"test-secret-key\",\n174: \t\tIssuer:    \"agentcube\",\n175: \t}\n176: \n177: \tmanager, err := NewJWTManager(config, validator)\n178: \tif err != nil {\n179: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n180: \t}\n181: \n182: \tnow := time.Now()\n183: \tclaims := &Claims{\n184: \t\tRegisteredClaims: jwt.RegisteredClaims{\n185: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(-1 * time.Hour)),\n186: \t\t\tIssuedAt:  jwt.NewNumericDate(now.Add(-2 * time.Hour)),\n187: \t\t\tIssuer:    \"agentcube\",\n188: \t\t},\n189: \t}\n190: \n191: \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n192: \texpiredToken, _ := token.SignedString([]byte(\"test-secret-key\"))\n193: \n194: \t_, err = manager.ValidateToken(expiredToken)\n195: \tif err != ErrTokenExpired {\n196: \t\tt.Errorf(\"ValidateToken() error = %v, want ErrTokenExpired\", err)\n197: \t}\n198: }\n199: \n200: func TestJWTManager_ValidateInvalidSignature(t *testing.T) {\n201: \tvalidator := newMockUserValidator()\n202: \tconfig := &JWTConfig{\n203: \t\tAlgorithm: \"HS256\",\n204: \t\tSecret:    \"test-secret-key\",\n205: \t\tIssuer:    \"agentcube\",\n206: \t}\n207: \n208: \tmanager, err := NewJWTManager(config, validator)\n209: \tif err != nil {\n210: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n211: \t}\n212: \n213: \tuser := &UserClaims{\n214: \t\tUsername: \"testuser\",\n215: \t\tRoles:    []string{\"user\"},\n216: \t}\n217: \n218: \ttoken, _ := manager.IssueToken(user)\n219: \ttoken = token + \"invalid\"\n220: \n221: \t_, err = manager.ValidateToken(token)\n222: \tif err != ErrMalformedToken && err != ErrInvalidSignature {\n223: \t\tt.Errorf(\"ValidateToken() error = %v, want ErrMalformedToken or ErrInvalidSignature\", err)\n224: \t}\n225: }\n226: \n227: func TestJWTManager_ValidateMalformedToken(t *testing.T) {\n228: \tvalidator := newMockUserValidator()\n229: \tconfig := &JWTConfig{\n230: \t\tAlgorithm: \"HS256\",\n231: \t\tSecret:    \"test-secret-key\",\n232: \t\tIssuer:    \"agentcube\",\n233: \t}\n234: \n235: \tmanager, err := NewJWTManager(config, validator)\n236: \tif err != nil {\n237: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n238: \t}\n239: \n240: \t_, err = manager.ValidateToken(\"not-a-valid-jwt-token\")\n241: \tif err != ErrMalformedToken {\n242: \t\tt.Errorf(\"ValidateToken() error = %v, want ErrMalformedToken\", err)\n243: \t}\n244: }\n245: \n246: func TestJWTManager_IssueAndRefreshToken(t *testing.T) {\n247: \tvalidator := newMockUserValidator()\n248: \tconfig := &JWTConfig{\n249: \t\tAlgorithm:         \"HS256\",\n250: \t\tSecret:            \"test-secret-key\",\n251: \t\tIssuer:            \"agentcube\",\n252: \t\tExpiration:        1 * time.Hour,\n253: \t\tRefreshExpiration: 24 * time.Hour,\n254: \t}\n255: \n256: \tmanager, err := NewJWTManager(config, validator)\n257: \tif err != nil {\n258: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n259: \t}\n260: \n261: \tuser := &UserClaims{\n262: \t\tUsername: \"testuser\",\n263: \t\tRoles:    []string{\"user\"},\n264: \t}\n265: \n266: \trefreshToken, err := manager.IssueRefreshToken(user)\n267: \tif err != nil {\n268: \t\tt.Fatalf(\"IssueRefreshToken() error = %v\", err)\n269: \t}\n270: \n271: \tclaims, err := manager.ValidateRefreshToken(refreshToken)\n272: \tif err != nil {\n273: \t\tt.Errorf(\"ValidateRefreshToken() error = %v\", err)\n274: \t\treturn\n275: \t}\n276: \n277: \tif claims.ID != \"refresh\" {\n278: \t\tt.Errorf(\"ValidateRefreshToken() ID = %v, want refresh\", claims.ID)\n279: \t}\n280: \n281: \tif claims.Subject != \"testuser\" {\n282: \t\tt.Errorf(\"ValidateRefreshToken() subject = %v, want testuser\", claims.Subject)\n283: \t}\n284: }\n285: \n286: func TestJWTMiddleware_ExtractFromHeader(t *testing.T) {\n287: \tvalidator := newMockUserValidator()\n288: \tconfig := &JWTConfig{\n289: \t\tAlgorithm: \"HS256\",\n290: \t\tSecret:    \"test-secret-key\",\n291: \t\tIssuer:    \"agentcube\",\n292: \t}\n293: \n294: \tmanager, _ := NewJWTManager(config, validator)\n295: \tmiddleware := NewJWTMiddleware(manager, nil, false)\n296: \n297: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n298: \treq.Header.Set(\"Authorization\", \"Bearer test-token\")\n299: \n300: \ttoken, err := middleware.extractToken(req)\n301: \tif err != nil {\n302: \t\tt.Errorf(\"extractToken() error = %v\", err)\n303: \t}\n304: \tif token != \"test-token\" {\n305: \t\tt.Errorf(\"extractToken() token = %v, want test-token\", token)\n306: \t}\n307: }\n308: \n309: func TestJWTMiddleware_ExtractFromQueryParam(t *testing.T) {\n310: \tvalidator := newMockUserValidator()\n311: \tconfig := &JWTConfig{\n312: \t\tAlgorithm: \"HS256\",\n313: \t\tSecret:    \"test-secret-key\",\n314: \t\tIssuer:    \"agentcube\",\n315: \t}\n316: \n317: \tmanager, _ := NewJWTManager(config, validator)\n318: \tmiddleware := NewJWTMiddleware(manager, nil, true)\n319: \n320: \treq := httptest.NewRequest(\"GET\", \"/test?token=query-token\", nil)\n321: \n322: \ttoken, err := middleware.extractToken(req)\n323: \tif err != nil {\n324: \t\tt.Errorf(\"extractToken() error = %v\", err)\n325: \t}\n326: \tif token != \"query-token\" {\n327: \t\tt.Errorf(\"extractToken() token = %v, want query-token\", token)\n328: \t}\n329: }\n330: \n331: func TestJWTMiddleware_PublicPathBypass(t *testing.T) {\n332: \tvalidator := newMockUserValidator()\n333: \tconfig := &JWTConfig{\n334: \t\tAlgorithm: \"HS256\",\n335: \t\tSecret:    \"test-secret-key\",\n336: \t\tIssuer:    \"agentcube\",\n337: \t}\n338: \n339: \tmanager, _ := NewJWTManager(config, validator)\n340: \tpublicPaths := []string{\"/health\", \"/login\", \"/metrics\"}\n341: \tmiddleware := NewJWTMiddleware(manager, publicPaths, false)\n342: \n343: \ttests := []struct {\n344: \t\tpath     string\n345: \t\texpected bool\n346: \t}{\n347: \t\t{\"/health/live\", true},\n348: \t\t{\"/health/ready\", true},\n349: \t\t{\"/login\", true},\n350: \t\t{\"/metrics\", true},\n351: \t\t{\"/api/test\", false},\n352: \t\t{\"/protected\", false},\n353: \t}\n354: \n355: \tfor _, tt := range tests {\n356: \t\tresult := middleware.isPublicPath(tt.path)\n357: \t\tif result != tt.expected {\n358: \t\t\tt.Errorf(\"isPublicPath(%s) = %v, want %v\", tt.path, result, tt.expected)\n359: \t\t}\n360: \t}\n361: }\n362: \n363: func TestJWTMiddleware_ProtectedEndpointRejectsNoToken(t *testing.T) {\n364: \tvalidator := newMockUserValidator()\n365: \tconfig := &JWTConfig{\n366: \t\tAlgorithm: \"HS256\",\n367: \t\tSecret:    \"test-secret-key\",\n368: \t\tIssuer:    \"agentcube\",\n369: \t}\n370: \n371: \tmanager, _ := NewJWTManager(config, validator)\n372: \tmiddleware := NewJWTMiddleware(manager, []string{\"/health\"}, false)\n373: \n374: \tnext := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n375: \t\tw.WriteHeader(http.StatusOK)\n376: \t})\n377: \n378: \thandler := middleware.Middleware(next)\n379: \n380: \treq := httptest.NewRequest(\"GET\", \"/api/protected\", nil)\n381: \trec := httptest.NewRecorder()\n382: \n383: \thandler.ServeHTTP(rec, req)\n384: \n385: \tif rec.Code != http.StatusUnauthorized {\n386: \t\tt.Errorf(\"Expected status %d, got %d\", http.StatusUnauthorized, rec.Code)\n387: \t}\n388: }\n389: \n390: func TestJWTMiddleware_ValidTokenPasses(t *testing.T) {\n391: \tvalidator := newMockUserValidator()\n392: \tconfig := &JWTConfig{\n393: \t\tAlgorithm: \"HS256\",\n394: \t\tSecret:    \"test-secret-key\",\n395: \t\tIssuer:    \"agentcube\",\n396: \t}\n397: \n398: \tmanager, _ := NewJWTManager(config, validator)\n399: \tmiddleware := NewJWTMiddleware(manager, []string{\"/health\"}, false)\n400: \n401: \tuser := &UserClaims{\n402: \t\tUsername: \"testuser\",\n403: \t\tRoles:    []string{\"user\"},\n404: \t}\n405: \ttoken, _ := manager.IssueToken(user)\n406: \n407: \tnext := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n408: \t\tclaims := GetClaimsFromContext(r)\n409: \t\tif claims == nil {\n410: \t\t\tt.Error(\"Claims should be available in context\")\n411: \t\t}\n412: \t\tw.WriteHeader(http.StatusOK)\n413: \t})\n414: \n415: \thandler := middleware.Middleware(next)\n416: \n417: \treq := httptest.NewRequest(\"GET\", \"/api/protected\", nil)\n418: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n419: \trec := httptest.NewRecorder()\n420: \n421: \thandler.ServeHTTP(rec, req)\n422: \n423: \tif rec.Code != http.StatusOK {\n424: \t\tt.Errorf(\"Expected status %d, got %d\", http.StatusOK, rec.Code)\n425: \t}\n426: }\n427: \n428: func TestLoginHandler_ValidCredentials(t *testing.T) {\n429: \tvalidator := newMockUserValidator()\n430: \tconfig := &JWTConfig{\n431: \t\tAlgorithm:  \"HS256\",\n432: \t\tSecret:     \"test-secret-key\",\n433: \t\tIssuer:     \"agentcube\",\n434: \t\tExpiration: 1 * time.Hour,\n435: \t}\n436: \n437: \tmanager, _ := NewJWTManager(config, validator)\n438: \thandler := NewLoginHandler(manager)\n439: \n440: \tbody := `{\"username\":\"admin\",\"password\":\"password\"}`\n441: \treq := httptest.NewRequest(\"POST\", \"/login\", strings.NewReader(body))\n442: \treq.Header.Set(\"Content-Type\", \"application/json\")\n443: \trec := httptest.NewRecorder()\n444: \n445: \thandler.ServeHTTP(rec, req)\n446: \n447: \tif rec.Code != http.StatusOK {\n448: \t\tt.Errorf(\"Expected status %d, got %d. Body: %s\", http.StatusOK, rec.Code, rec.Body.String())\n449: \t}\n450: \n451: \tvar response LoginResponse\n452: \tif err := json.NewDecoder(rec.Body).Decode(&response); err != nil {\n453: \t\tt.Fatalf(\"Failed to decode response: %v\", err)\n454: \t}\n455: \n456: \tif response.AccessToken == \"\" {\n457: \t\tt.Error(\"AccessToken should not be empty\")\n458: \t}\n459: \tif response.RefreshToken == \"\" {\n460: \t\tt.Error(\"RefreshToken should not be empty\")\n461: \t}\n462: \tif response.TokenType != \"Bearer\" {\n463: \t\tt.Errorf(\"TokenType = %v, want Bearer\", response.TokenType)\n464: \t}\n465: }\n466: \n467: func TestLoginHandler_InvalidCredentials(t *testing.T) {\n468: \tvalidator := newMockUserValidator()\n469: \tconfig := &JWTConfig{\n470: \t\tAlgorithm: \"HS256\",\n471: \t\tSecret:    \"test-secret-key\",\n472: \t\tIssuer:    \"agentcube\",\n473: \t}\n474: \n475: \tmanager, _ := NewJWTManager(config, validator)\n476: \thandler := NewLoginHandler(manager)\n477: \n478: \tbody := `{\"username\":\"admin\",\"password\":\"wrongpassword\"}`\n479: \treq := httptest.NewRequest(\"POST\", \"/login\", strings.NewReader