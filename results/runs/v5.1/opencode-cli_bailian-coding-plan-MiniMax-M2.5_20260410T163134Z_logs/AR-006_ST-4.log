{"type":"tool_use","timestamp":1775843873346,"sessionID":"ses_287754c6affeh2db39Jghf8MDv","part":{"id":"prt_d788b0eb8001h6V5xLz69gMeU6","messageID":"msg_d788b006a0017hv6M33QYTEnfa","sessionID":"ses_287754c6affeh2db39Jghf8MDv","type":"tool","tool":"read","callID":"toolu_469796246b79405d9b7db1dc","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/server.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"fmt\"\n7: \t\"net\"\n8: \t\"net/http\"\n9: \t\"os\"\n10: \t\"os/signal\"\n11: \t\"sync\"\n12: \t\"time\"\n13: \n14: \t\"github.com/gin-gonic/gin\"\n15: \tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n16: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n17: \t\"k8s.io/apimachinery/pkg/types\"\n18: \t\"k8s.io/klog/v2\"\n19: \n20: \tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n21: )\n22: \n23: const (\n24: \tDefaultPort = 8080\n25: )\n26: \n27: type Config struct {\n28: \tPort            int\n29: \tKubeconfig      string\n30: \tShutdownTimeout time.Duration\n31: \tEnableMetrics   bool\n32: \tEnableLogging   bool\n33: }\n34: \n35: type Server struct {\n36: \tconfig      *Config\n37: \thttpServer  *http.Server\n38: \tworkloadMgr WorkloadManager\n39: \tready       bool\n40: \tmu          sync.RWMutex\n41: \tstopCh      chan struct{}\n42: }\n43: \n44: func NewServer(cfg *Config, workloadMgr WorkloadManager) *Server {\n45: \tif cfg.Port == 0 {\n46: \t\tcfg.Port = DefaultPort\n47: \t}\n48: \tif cfg.ShutdownTimeout == 0 {\n49: \t\tcfg.ShutdownTimeout = 30 * time.Second\n50: \t}\n51: \n52: \tgin.SetMode(gin.ReleaseMode)\n53: \trouter := gin.New()\n54: \n55: \tserver := &Server{\n56: \t\tconfig:      cfg,\n57: \t\tworkloadMgr: workloadMgr,\n58: \t\tstopCh:      make(chan struct{}),\n59: \t}\n60: \n61: \trouter.Use(gin.Recovery())\n62: \trouter.Use(server.loggingMiddleware())\n63: \trouter.Use(server.corsMiddleware())\n64: \n65: \trouter.GET(\"/healthz\", server.handleHealthz)\n66: \trouter.GET(\"/readyz\", server.handleReadyz)\n67: \n68: \tapi := router.Group(\"/api/v1\")\n69: \t{\n70: \t\tapi.GET(\"/namespaces/:namespace/agentruntimes\", server.handleListAgentRuntimes)\n71: \t\tapi.POST(\"/namespaces/:namespace/agentruntimes\", server.handleCreateAgentRuntime)\n72: \t\tapi.GET(\"/namespaces/:namespace/agentruntimes/:name\", server.handleGetAgentRuntime)\n73: \t\tapi.PUT(\"/namespaces/:namespace/agentruntimes/:name\", server.handleUpdateAgentRuntime)\n74: \t\tapi.DELETE(\"/namespaces/:namespace/agentruntimes/:name\", server.handleDeleteAgentRuntime)\n75: \t\tapi.GET(\"/namespaces/:namespace/agentruntimes/:name/status\", server.handleGetAgentRuntimeStatus)\n76: \t\tapi.PATCH(\"/namespaces/:namespace/agentruntimes/:name/status\", server.handlePatchAgentRuntimeStatus)\n77: \n78: \t\tapi.GET(\"/namespaces/:namespace/codeinterpreters\", server.handleListCodeInterpreters)\n79: \t\tapi.POST(\"/namespaces/:namespace/codeinterpreters\", server.handleCreateCodeInterpreter)\n80: \t\tapi.GET(\"/namespaces/:namespace/codeinterpreters/:name\", server.handleGetCodeInterpreter)\n81: \t\tapi.PUT(\"/namespaces/:namespace/codeinterpreters/:name\", server.handleUpdateCodeInterpreter)\n82: \t\tapi.DELETE(\"/namespaces/:namespace/codeinterpreters/:name\", server.handleDeleteCodeInterpreter)\n83: \t\tapi.GET(\"/namespaces/:namespace/codeinterpreters/:name/status\", server.handleGetCodeInterpreterStatus)\n84: \t\tapi.PATCH(\"/namespaces/:namespace/codeinterpreters/:name/status\", server.handlePatchCodeInterpreterStatus)\n85: \t}\n86: \n87: \tserver.httpServer = &http.Server{\n88: \t\tAddr:    fmt.Sprintf(\":%d\", cfg.Port),\n89: \t\tHandler: router,\n90: \t}\n91: \n92: \treturn server\n93: }\n94: \n95: func (s *Server) Start() error {\n96: \tklog.InfoS(\"Starting HTTP server\", \"port\", s.config.Port)\n97: \n98: \tln, err := net.Listen(\"tcp\", fmt.Sprintf(\":%d\", s.config.Port))\n99: \tif err != nil {\n100: \t\treturn fmt.Errorf(\"failed to listen on port %d: %w\", s.config.Port, err)\n101: \t}\n102: \n103: \tgo func() {\n104: \t\tif err := s.httpServer.Serve(ln); err != nil && err != http.ErrServerClosed {\n105: \t\t\tklog.ErrorS(err, \"HTTP server error\")\n106: \t\t}\n107: \t}()\n108: \n109: \ts.SetReady(true)\n110: \tklog.InfoS(\"HTTP server started\", \"port\", s.config.Port)\n111: \treturn nil\n112: }\n113: \n114: func (s *Server) Stop() error {\n115: \tklog.Info(\"Shutting down HTTP server...\")\n116: \ts.SetReady(false)\n117: \n118: \tctx, cancel := context.WithTimeout(context.Background(), s.config.ShutdownTimeout)\n119: \tdefer cancel()\n120: \n121: \tif err := s.httpServer.Shutdown(ctx); err != nil {\n122: \t\treturn fmt.Errorf(\"failed to shutdown HTTP server: %w\", err)\n123: \t}\n124: \n125: \tif s.workloadMgr != nil {\n126: \t\ts.workloadMgr.Close()\n127: \t}\n128: \n129: \tklog.Info(\"HTTP server stopped\")\n130: \treturn nil\n131: }\n132: \n133: func (s *Server) Run() error {\n134: \tif err := s.Start(); err != nil {\n135: \t\treturn err\n136: \t}\n137: \n138: \tsigCh := make(chan os.Signal, 1)\n139: \tsignal.Notify(sigCh, os.Interrupt, os.Kill)\n140: \n141: \t<-sigCh\n142: \tklog.Info(\"Received shutdown signal\")\n143: \n144: \treturn s.Stop()\n145: }\n146: \n147: func (s *Server) SetReady(ready bool) {\n148: \ts.mu.Lock()\n149: \tdefer s.mu.Unlock()\n150: \ts.ready = ready\n151: }\n152: \n153: func (s *Server) IsReady() bool {\n154: \ts.mu.RLock()\n155: \tdefer s.mu.RUnlock()\n156: \treturn s.ready\n157: }\n158: \n159: func (s *Server) loggingMiddleware() gin.HandlerFunc {\n160: \treturn func(c *gin.Context) {\n161: \t\tstart := time.Now()\n162: \t\tpath := c.Request.URL.Path\n163: \t\tmethod := c.Request.Method\n164: