turns a non-zero exit code.\"\"\"\n\n    def __init__(\n        self,\n        message: str,\n        exit_code: Optional[int] = None,\n        stderr: Optional[str] = None,\n        command: Optional[str] = None,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/exceptions.py","time":{"start":1775869493629,"end":1775869493644}}}}
