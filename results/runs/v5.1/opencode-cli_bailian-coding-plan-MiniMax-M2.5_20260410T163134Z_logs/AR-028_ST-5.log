variable must be set\"\n            )\n\n        self.agent_name = agent_name\n        self.namespace = namespace\n        self.verbose = verbose\n        self.timeout = timeout\n        self.connect_timeout = connect_timeout\n        self.pool_connections = pool_connections\n        self.pool_maxsize = pool_maxsize\n\n        self._session: requests.Session = create_session(\n            pool_connections=pool_connections,\n            pool_maxsize=pool_maxsize,\n        )\n\n        if session_id:\n            self._session_id = session_id\n            logger.info(f\"Reusing existing session: {session_id}\")\n        else:\n            self._session_id = self._bootstrap_session()\n\n        self.dp_client = AgentRuntimeDataPlaneClient(\n            router_url=self.router_url,\n            namespace=self.namespace,\n            agent_name=self.agent_name,\n            session_id=self._session_id,\n            timeout=self.timeout,\n            connect_timeout=self.connect_timeout,\n            pool_connections=self.pool_connections,\n            pool_maxsize=self.pool_maxsize,\n        )\n\n        logger.info(f\"AgentRuntimeClient initialized with session: {self._session_id}\")\n\n    def _bootstrap_session(self) -> str:\n        \"\"\"\n        Bootstrap a new session via GET request to the invocation endpoint.\n\n        Returns:\n            The session ID from the response header.\n\n        Raises:\n            ValueError: If the session header is missing from the response.\n        \"\"\"\n        base_url = f\"{self.router_url}/v1/namespaces/{self.namespace}/agent-runtimes/{self.agent_name}/invocations/\"\n\n        try:\n            response = self._session.get(\n                base_url,\n                timeout=(self.connect_timeout, self.timeout),\n            )\n            response.raise_for_status()\n\n            session_id = response.headers.get(\"x-agentcube-session-id\")\n            if not session_id:\n                raise ValueError(\"Missing required response header: x-agentcube-session-id\")\n\n            logger.info(f\"Bootstrapped new session: {session_id}\")\n            return session_id\n\n        except requests.RequestException as e:\n            logger.error(f\"Session bootstrap failed: {e}\")\n            raise SessionError(f\"Session bootstrap failed: {e}\") from e\n\n    def invoke(\n        self,\n        payload: Dict,\n        timeout: Optional[Union[int, Tuple[float, float]]] = None,\n    ) -> Dict:\n        \"\"\"\n        Invoke the Agent Runtime with the given payload.\n\n        Args:\n            payload: The JSON payload to send to the Agent Runtime.\n            timeout: Timeout in seconds or tuple of (connect_timeout, read_timeout).\n                    If None, uses the default timeout tuple (connect_timeout, self.timeout).\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            ValueError: If session_id is not initialized.\n            DataPlaneError: If the invocation fails.\n        \"\"\"\n        if not self._session_id:\n            raise ValueError(\"AgentRuntime session_id is not initialized\")\n\n        effective_timeout = timeout\n        if timeout is None:\n            effective_timeout = (self.connect_timeout, self.timeout)\n\n        return self.dp_client.invoke(payload, timeout=effective_timeout)\n\n    def close(self) -> None:\n        \"\"\"Close the client and release resources.\"\"\"\n        if self.dp_client:\n            try:\n                self.dp_client.close()\n            except Exception as e:\n                logger.warning(f\"Error closing data plane client: {e}\")\n            finally:\n                self.dp_client = None\n\n        if self._session:\n            try:\n                self._session.close()\n            except Exception as e:\n                logger.warning(f\"Error closing session: {e}\")\n            finally:\n                self._session = None\n\n        logger.info(\"AgentRuntimeClient closed\")\n\n    def __enter__(self) -> \"AgentRuntimeClient\":\n        \"\"\"Enter the context manager.\"\"\"\n        return self\n\n    def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n        \"\"\"Exit the context manager.\"\"\"\n        self.close()\n\n    @property\n    def session_id(self) -> Optional[str]:\n        \"\"\"Get the current session ID.\"\"\"\n        return self._session_id\n","after":"\"\"\"AgentRuntimeClient for AgentCube SDK.\"\"\"\n\nimport os\nfrom typing import Dict, Optional, Tuple, Union, TYPE_CHECKING\n\nimport requests\n\nfrom agentcube.clients import AgentRuntimeDataPlaneClient\nfrom agentcube.exceptions import DataPlaneError, SessionError\nfrom agentcube.utils.http import (\n    DEFAULT_CONNECT_TIMEOUT,\n    DEFAULT_POOL_CONNECTIONS,\n    DEFAULT_POOL_MAXSIZE,\n    DEFAULT_TIMEOUT,\n    create_session,\n)\nfrom agentcube.utils.log import get_logger\n\nlogger = get_logger(__name__)\n\n\nclass AgentRuntimeClient:\n    \"\"\"Client for interacting with Agent Runtime through the Router.\"\"\"\n\n    def __init__(\n        self,\n        agent_name: str = \"my-agent\",\n        namespace: str = \"default\",\n        router_url: Optional[str] = None,\n        verbose: bool = False,\n        session_id: Optional[str] = None,\n        timeout: int = DEFAULT_TIMEOUT,\n        connect_timeout: float = DEFAULT_CONNECT_TIMEOUT,\n        pool_connections: int = DEFAULT_POOL_CONNECTIONS,\n        pool_maxsize: int = DEFAULT_POOL_MAXSIZE,\n    ):\n        \"\"\"\n        Initialize the AgentRuntimeClient.\n\n        Args:\n            agent_name: Name of the Agent Runtime (default: \"my-agent\").\n            namespace: Kubernetes namespace (default: \"default\").\n            router_url: Base URL of the Router service. If None, uses ROUTER_URL env var.\n            verbose: Enable verbose logging (default: False).\n            session_id: Existing session ID to reuse. If None, a new session\n                       will be bootstrapped via GET request.\n            timeout: Default read timeout in seconds (default: 120).\n            connect_timeout: Connection timeout in seconds (default: 5.0).\n            pool_connections: Number of connection pools to cache (default: 10).\n            pool_maxsize: Maximum number of connections per pool (default: 10).\n\n        Raises:\n            ValueError: If router_url is not provided and ROUTER_URL env var is not set.\n        \"\"\"\n        self.router_url = router_url or os.environ.get(\"ROUTER_URL\")\n        if not self.router_url:\n            raise ValueError(\n                \"router_url must be provided via argument or \"\n                \"ROUTER_URL environment variable must be set\"\n            )\n\n        self.agent_name = agent_name\n        self.namespace = namespace\n        self.verbose = verbose\n        self.timeout = timeout\n        self.connect_timeout = connect_timeout\n        self.pool_connections = pool_connections\n        self.pool_maxsize = pool_maxsize\n\n        self._session: requests.Session = create_session(\n            pool_connections=pool_connections,\n            pool_maxsize=pool_maxsize,\n        )\n\n        if session_id:\n            self._session_id = session_id\n            logger.info(f\"Reusing existing session: {session_id}\")\n        else:\n            self._session_id = self._bootstrap_session()\n\n        self.dp_client = AgentRuntimeDataPlaneClient(\n            router_url=self.router_url,\n            namespace=self.namespace,\n            agent_name=self.agent_name,\n            session_id=self._session_id,\n            timeout=self.timeout,\n            connect_timeout=self.connect_timeout,\n            pool_connections=self.pool_connections,\n            pool_maxsize=self.pool_maxsize,\n        )\n\n        logger.info(f\"AgentRuntimeClient initialized with session: {self._session_id}\")\n\n    def _bootstrap_session(self) -> str:\n        \"\"\"\n        Bootstrap a new session via GET request to the invocation endpoint.\n\n        Returns:\n            The session ID from the response header.\n\n        Raises:\n            ValueError: If the session header is missing from the response.\n        \"\"\"\n        base_url = f\"{self.router_url}/v1/namespaces/{self.namespace}/agent-runtimes/{self.agent_name}/invocations/\"\n\n        try:\n            response = self._session.get(\n                base_url,\n                timeout=(self.connect_timeout, self.timeout),\n            )\n            response.raise_for_status()\n\n            session_id = response.headers.get(\"x-agentcube-session-id\")\n            if not session_id:\n                raise ValueError(\"Missing required response header: x-agentcube-session-id\")\n\n            logger.info(f\"Bootstrapped new session: {session_id}\")\n            return session_id\n\n        except requests.RequestException as e:\n            logger.error(f\"Session bootstrap failed: {e}\")\n            raise SessionError(f\"Session bootstrap failed: {e}\") from e\n\n    def invoke(\n        self,\n        payload: Dict,\n        timeout: Optional[Union[int, Tuple[float, float]]] = None,\n    ) -> Dict:\n        \"\"\"\n        Invoke the Agent Runtime with the given payload.\n\n        Args:\n            payload: The JSON payload to send to the Agent Runtime.\n            timeout: Timeout in seconds or tuple of (connect_timeout, read_timeout).\n                    If None, uses the default timeout tuple (connect_timeout, self.timeout).\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            ValueError: If session_id is not initialized.\n            DataPlaneError: If the invocation fails.\n        \"\"\"\n        if not self._session_id:\n            raise ValueError(\"AgentRuntime session_id is not initialized\")\n\n        effective_timeout = timeout\n        if timeout is None:\n            effective_timeout = (self.connect_timeout, self.timeout)\n\n        return self.dp_client.invoke(payload, timeout=effective_timeout)\n\n    def close(self) -> None:\n        \"\"\"Close the client and release resources.\"\"\"\n        if self.dp_client:\n            try:\n                self.dp_client.close()\n            except Exception as e:\n                logger.warning(f\"Error closing data plane client: {e}\")\n            finally:\n                self.dp_client = None\n\n        if self._session:\n            try:\n                self._session.close()\n            except Exception as e:\n                logger.warning(f\"Error closing session: {e}\")\n            finally:\n                self._session = None\n\n        logger.info(\"AgentRuntimeClient closed\")\n\n    def __enter__(self) -> \"AgentRuntimeClient\":\n        \"\"\"Enter the context manager.\"\"\"\n        return self\n\n    def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n        \"\"\"Exit the context manager.\"\"\"\n        self.close()\n\n    @property\n    def session_id(self) -> Optional[str]:\n        \"\"\"Get the current session ID.\"\"\"\n        return self._session_id\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/agent_runtime.py","time":{"start":1775869563165,"end":1775869563648}}}}
