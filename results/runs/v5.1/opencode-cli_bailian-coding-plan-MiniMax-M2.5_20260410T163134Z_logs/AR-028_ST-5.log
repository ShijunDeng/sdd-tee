n            timeout: Default read timeout in seconds.\n            connect_timeout: Connection timeout in seconds.\n            pool_connections: Number of connection pools to cache.\n            pool_maxsize: Maximum number of connections per pool.\n        \"\"\"\n        self.timeout = timeout\n        self.connect_timeout = connect_timeout\n\n        if base_url:\n            self.base_url = base_url\n        else:\n            self.base_url = urljoin(\n                router_url,\n                f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\",\n            )\n\n        self._session_id = session_id\n        self._headers: dict[str, str] = {}\n        if session_id:\n            self._headers[self.SESSION_HEADER] = session_id\n\n        self._session = create_session(\n            pool_connections=pool_connections,\n            pool_maxsize=pool_maxsize,\n        )\n\n        logger.debug(\n            f\"AgentRuntimeDataPlaneClient initialized with \"\n            f\"base_url={self.base_url}, session_id={session_id}\"\n        )\n\n    def _request(\n        self,\n        method: str,\n        path: str,\n        **kwargs,\n    ) -> requests.Response:\n        \"\"\"\n        Make an HTTP request to the data plane.\n\n        Args:\n            method: HTTP method (GET, POST, etc.)\n            path: API path (appended to base_url)\n            **kwargs: Additional arguments passed to requests.Session.request\n\n        Returns:\n            The response object.\n\n        Raises:\n            DataPlaneError: If the request fails.\n        \"\"\"\n        url = urljoin(self.base_url, path)\n\n        headers = dict(self._headers)\n        headers.update(kwargs.pop(\"headers\", {}))\n\n        timeout = kwargs.pop(\"timeout\", None)\n        if timeout is None:\n            timeout = (self.connect_timeout, self.timeout)\n        elif isinstance(timeout, tuple):\n            pass\n        else:\n            timeout = (self.connect_timeout, timeout)\n\n        try:\n            response = self._session.request(\n                method,\n                url,\n                headers=headers,\n                timeout=timeout,\n                **kwargs,\n            )\n            response.raise_for_status()\n            return response\n\n        except requests.RequestException as e:\n            logger.error(f\"Data plane request failed: {e}\")\n            raise DataPlaneError(f\"Data plane request failed: {e}\") from e\n\n    def invoke(\n        self,\n        payload: dict,\n        timeout: Optional[Union[int, tuple[float, float]]] = None,\n    ) -> dict:\n        \"\"\"\n        Invoke an Agent Runtime with the given payload.\n\n        Args:\n            payload: The JSON payload to send to the Agent Runtime.\n            timeout: Timeout in seconds or tuple of (connect_timeout, read_timeout).\n                    If None, uses the default timeout.\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            DataPlaneError: If the invocation fails.\n        \"\"\"\n        effective_timeout = timeout\n        if timeout is None:\n            effective_timeout = (self.connect_timeout, self.timeout)\n        elif isinstance(timeout, int):\n            effective_timeout = (self.connect_timeout, timeout)\n\n        response = self._request(\n            \"POST\",\n            \"\",\n            json=payload,\n            timeout=effective_timeout,\n        )\n\n        return response.json()\n\n    def close(self) -> None:\n        \"\"\"Close the HTTP session.\"\"\"\n        self._session.close()\n        logger.debug(\"AgentRuntimeDataPlaneClient session closed\")","oldString":"\"\"\"Agent Runtime Data Plane client for AgentCube SDK.\"\"\"\n\nfrom typing import Dict, Optional, Tuple, Union\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom agentcube.exceptions import DataPlaneError\nfrom agentcube.utils.http import (\n    DEFAULT_CONNEC