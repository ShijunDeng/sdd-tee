t.mock import Mock, patch\n\nimport pytest\nimport requests\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom agentcube.exceptions import SessionError\n\n\nclass TestAgentRuntimeClient:\n    \"\"\"Test cases for AgentRuntimeClient.\"\"\"\n\n    def test_constructor_requires_router_url(self):\n        \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n        with pytest.raises(ValueError) as exc_info:\n            AgentRuntimeClient()\n        assert \"router_url\" in str(exc_info.value).lower()\n        assert \"ROUTER_URL\" in str(exc_info.value)\n\n    def test_constructor_with_env_var(self):\n        \"\"\"Test Router URL can be set via environment variable.\"\"\"\n        with patch.dict(\"os.environ\", {\"ROUTER_URL\": \"http://router:8080\"}):\n            with patch(\"agentcube.agent_runtime.create_session\") as mock_create_session:\n                mock_session = Mock()\n                mock_response = Mock()\n                mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n                mock_response.raise_for_status = Mock()\n                mock_session.get.return_value = mock_response\n                mock_create_session.return_value = mock_session\n\n                client = AgentRuntimeClient()\n                assert client.router_url == \"http://router:8080\"\n                client.close()\n\n    def test_constructor_with_explicit_url(self):\n        \"\"\"Test Router URL can be set explicitly.\"\"\"\n        with patch(\"agentcube.agent_runtime.create_session\") as mock_create_session:\n            mock_session = Mock()\n            mock_response = Mock()\n            mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n            mock_response.raise_for_status = Mock()\n            mock_session.get.return_value = mock_response\n            mock_create_session.return_value = mock_session\n\n            client = AgentRuntimeClient(router_url=\"http://router:8080\")\n            assert client.router_url == \"http://router:8080\"\n            client.close()\n\n    def test_constructor_default_values(self):\n        \"\"\"Test constructor sets default values correctly.\"\"\"\n        with patch(\"agentcube.agent_runtime.create_session\") as mock_create_session:\n            mock_session = Mock()\n            mock_response = Mock()\n            mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n            mock_response.raise_for_status = Mock()\n            mock_session.get.return_value = mock_response\n            mock_create_session.return_value = mock_session\n\n            client = AgentRuntimeClient(router_url=\"http://router:8080\")\n            assert client.agent_name == \"my-agent\"\n            assert client.namespace == \"default\"\n            assert client.timeout == 120\n            assert client.connect_timeout == 5.0\n            client.close()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_bootstrap_session(self, mock_create_session):\n        \"\"\"Test session is bootstrapped via GET when session_id not provided.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {\"x-agentcube-session-id\": \"bootstrapped-session-123\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeClient(router_url=\"http://router:8080\")\n\n        mock_session.get.assert_called_once()\n        call_args = mock_session.get.call_args\n        assert \"invocations/\" in call_args[0][0]\n        assert client.session_id == \"bootstrapped-session-123\"\n        client.close()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_bootstrap_session_missing_header_raises_error(self, mock_create_session):\n        \"\"\"Test ValueError is raised when session header is missing.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        try:\n            with pytest.raises(ValueError) as exc_info:\n                AgentRuntimeClient(router_url=\"http://router:8080\")\n            assert \"x-agentcube-session-id\" in str(exc_info.value)\n        finally:\n            pass\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_reuse_provided_session_id(self, mock_create_session):\n        \"\"\"Test provided session_id is used directly without bootstrap.\"\"\"\n        mock_session = Mock()\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeClient(\n            router_url=\"http://router:8080\", session_id=\"existing-session-456\"\n        )\n\n        mock_session.get.assert_not_called()\n        assert client.session_id == \"existing-session-456\"\n        client.close()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_init_data_plane_client(self, mock_create_session):\n        \"\"\"Test data plane client is initialized after session bootstrap.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeClient(router_url=\"http://router:8080\")\n\n        assert client.dp_client is not None\n        assert hasattr(client.dp_client, \"invoke\")\n        client.close()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_context_manager(self, mock_create_session):\n        \"\"\"Test context manager protocol.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        with AgentRuntimeClient(router_url=\"http://router:8080\") as client:\n            assert client.session_id == \"session-123\"\n\n        mock_session.close.assert_called_once()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_invoke_raises_when_session_not_initialized(self, mock_create_session):\n        \"\"\"Test invoke raises ValueError when session_id is falsy.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeClient(router_url=\"http://router:8080\")\n        client._session_id = None\n\n        with pytest.raises(ValueError) as exc_info:\n            client.invoke({\"tool\": \"test\"})\n        assert \"session_id is not initialized\" in str(exc_info.value)\n        client.close()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_invoke_delegates_to_data_plane(self, mock_create_session):\n        \"\"\"Test invoke delegates to dp_client correctly.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        with patch.object(\n            AgentRuntimeDataPlaneClient, \"invoke\", return_value={\"result\": \"ok\"}\n        ) as mock_invoke:\n            client = AgentRuntimeClient(router_url=\"http://router:8080\")\n\n            payload = {\"tool\": \"calculator\", \"input\": {\"expression\": \"2+2\"}}\n            result = client.invoke(payload)\n\n            mock_invoke.assert_called_once()\n            assert result == {\"result\": \"ok\"}\n            client.close()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_invoke_timeout_tuple(self, mock_create_session):\n        \"\"\"Test invoke uses timeout tuple (connect_timeout, self.timeout) when timeout=None.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeClient(\n            router_url=\"http://router:8080\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n\n        with patch.object(client.dp_client, \"invoke\", return_value={\"result\": \"ok\"}) as mock_invoke:\n            client.invoke({\"tool\": \"test\"}, timeout=None)\n\n            call_kwargs = mock_invoke.call_args[1]\n            assert call_kwargs[\"timeout\"] == (5.0, 120)\n            client.close()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_invoke_custom_timeout(self, mock_create_session):\n        \"\"\"Test invoke uses custom timeout when provided.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeClient(\n            router_url=\"http://router:8080\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n\n        with patch.object(client.dp_client, \"invoke\", return_value={\"result\": \"ok\"}) as mock_invoke:\n            client.invoke({\"tool\": \"test\"}, timeout=60)\n\n            call_kwargs = mock_invoke.call_args[1]\n            assert call_kwargs[\"timeout\"] == (5.0, 60)\n            client.close()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_close(self, mock_create_session):\n        \"\"\"Test close releases resources.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeClient(router_url=\"http://router:8080\")\n\n        with patch.object(client.dp_client, \"close\") as mock_dp_close:\n            client.close()\n            mock_dp_close.assert_called_once()\n\n        mock_session.close.assert_called_once()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_session_id_property(self, mock_create_session):\n        \"\"\"Test session_id property returns correct value.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.get.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeClient(\n            router_url=\"http://router:8080\",\n            session_id=\"custom-session\",\n        )\n\n        assert client.session_id == \"custom-session\"\n        client.close()\n\n    @patch(\"agentcube.agent_runtime.create_session\")\n    def test_bootstrap_session_network_error(self, mock_create_session):\n        \"\"\"Test SessionError is raised on network failure during bootstrap.\"\"\"\n        mock_session = Mock()\n        mock_session.get.side_effect = requests.RequestException(\"Connection failed\")\n        mock_create_session.return_value = mock_session\n\n        with pytest.raises(SessionError) as exc_info:\n            AgentRuntimeClient(router_url=\"http://router:8080\")\n        assert \"Session bootstrap failed\" in str(exc_info.value)\n","after":"\"\"\"Tests for AgentRuntimeClient.\"\"\"\n\nfrom unittest.mock import Mock, patch\n\nimport pytest\nimport requests\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom agentcube.exceptions import SessionError\n\n\nclass TestAgentRuntimeClient:\n    \"\"\"Test cases for AgentRuntimeClient.\"\"\"\n\n    def test_constructor_requires_router_url(self):\n        \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n        with pytest.raises(ValueError) as exc_info:\n            AgentRuntimeClient()\n        assert \"router_url\" in str(exc_info.value).lower()\n        assert \"ROUTER_URL\" in str(exc_info.value)\n\n    def test_constructor_with_env_var(self):\n        \"\"\"Test Router URL can be set via environment variable.\"\"\"\n        with (\n            patch.dict(\"os.environ\", {\"ROUTER_URL\": \"http://router:8080\"}),\n            patch(\"agentcube.agent_runtime.create_session\") as mock_create_session,\n        ):\n            mock_session = Mock()\n            mock_response = Mock()\n            mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n            mock_response.raise_for_status = Mock()\n            mock_session.get.return_value = mock_response\n            mock_create_session.return_value = mock_session\n\n            client = AgentRuntimeClient()\n            assert client.router_url == \"http://router:8080\"\n            client.close()\n\n    def test_constructor_with_explicit_url(self):\n        \"\"\"Test Router URL can be set explicitly.\"\"\"\n        with patch(\"agen