ValueError(\"AgentRuntime session_id is not initialized\")\n\n        effective_timeout: Union[int, tuple[float, float]] = timeout\n        if timeout is None:\n            effective_timeout = (self.connect_timeout, self.timeout)\n        elif isinstance(timeout, int):\n            effective_timeout = (self.connect_timeout, timeout)\n\n        return self.dp_client.invoke(payload, timeout=effective_timeout)\n\n    def close(self) -> None:\n        \"\"\"Close the client and release resources.\"\"\"\n        if self.dp_client:\n            try:\n                self.dp_client.close()\n            except Exception as e:\n                logger.warning(f\"Error closing data plane client: {e}\")\n            finally:\n                self.dp_client = None\n\n        if self._session:\n            try:\n                self._session.close()\n            except Exception as e:\n                logger.warning(f\"Error closing session: {e}\")\n            finally:\n                self._session = None\n\n        logger.info(\"AgentRuntimeClient closed\")\n\n    def __enter__(self) -> \"AgentRuntimeClient\":\n        \"\"\"Enter the context manager.\"\"\"\n        return self\n\n    def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n        \"\"\"Exit the context manager.\"\"\"\n        self.close()\n\n    @property\n    def session_id(self) -> Optional[str]:\n        \"\"\"Get the current session ID.\"\"\"\n        return self._session_id\n","additions":5,"deletions":5},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/agent_runtime.py","time":{"start":1775869872367,"end":1775869873066}}}}
