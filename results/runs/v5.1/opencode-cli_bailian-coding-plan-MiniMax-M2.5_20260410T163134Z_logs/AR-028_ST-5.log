nes)\n</content>","metadata":{"preview":"\"\"\"HTTP client utilities for AgentCube SDK.\"\"\"\n\nimport requests\nfrom requests.adapters import HTTPAdapter\nfrom urllib3.util.retry import Retry\nfrom typing import Optional\n\nDEFAULT_TIMEOUT = 120\nDEFAULT_CONNECT_TIMEOUT = 5.0\nDEFAULT_POOL_CONNECTIONS = 10\nDEFAULT_POOL_MAXSIZE = 10\n\n\ndef create_session(\n    pool_connections: int = DEFAULT_POOL_CONNECTIONS,\n    pool_maxsize: int = DEFAULT_POOL_MAXSIZE,\n) -> requests.Session:\n    \"\"\"\n    Create a requests Session with connection pooling.\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/utils/http.py","time":{"start":1775869488493,"end":1775869488508}}}}
