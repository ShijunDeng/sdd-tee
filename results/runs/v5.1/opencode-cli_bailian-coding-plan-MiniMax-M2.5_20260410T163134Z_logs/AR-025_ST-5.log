):\n37:         \"\"\"Test fallback to agent.yaml.\"\"\"\n38:         with tempfile.TemporaryDirectory() as tmpdir:\n39:             workspace = Path(tmpdir)\n40:             metadata_data = {\"agent_name\": \"fallback-agent\", \"entrypoint\": \"python app.py\"}\n41: \n42:             with open(workspace / \"agent.yaml\", \"w\") as f:\n43:                 yaml.safe_dump(metadata_data, f)\n44: \n45:             metadata = MetadataService.load_metadata(workspace)\n46: \n47:             assert metadata.agent_name == \"fallback-agent\"\n48: \n49:     def test_falls_back_to_metadata_yaml(self):\n50:         \"\"\"Test fallback to metadata.yaml.\"\"\"\n51:         with tempfile.TemporaryDirectory() as tmpdir:\n52:             workspace = Path(tmpdir)\n53:             metadata_data = {\"agent_name\": \"metadata-agent\", \"entrypoint\": \"python run.py\"}\n54: \n55:             with open(workspace / \"metadata.yaml\", \"w\") as f:\n56:                 yaml.safe_dump(metadata_data, f)\n57: \n58:             metadata = MetadataService.load_metadata(workspace)\n59: \n60:             assert metadata.agent_name == \"metadata-agent\"\n61: \n62:     def test_raises_error_when_no_metadata_file(self):\n63:         \"\"\"Test error when no metadata file found.\"\"\"\n64:         with tempfile.TemporaryDirectory() as tmpdir:\n65:             workspace = Path(tmpdir)\n66: \n67:             with pytest.raises(FileNotFoundError):\n68:                 MetadataService.load_metadata(workspace)\n69: \n70: \n71: class TestMetadataServiceSave:\n72:     \"\"\"Tests for MetadataService.save_metadata method.\"\"\"\n73: \n74:     def test_saves_to_agent_metadata_yaml(self):\n75:         \"\"\"Test saving metadata to agent_metadata.yaml.\"\"\"\n76:         with tempfile.TemporaryDirectory() as tmpdir:\n77:             workspace = Path(tmpdir)\n78: \n79:             metadata = AgentMetadata(\n80:                 agent_name=\"saved-agent\",\n81:                 language=\"python\",\n82:                 entrypoint=\"python main.py\",\n83:                 port=9000,\n84:                 build_mode=\"cloud\",\n85:             )\n86: \n87:             saved_path = MetadataService.save_metadata(workspace, metadata)\n88: \n89:             assert saved_path == workspace / \"agent_metadata.yaml\"\n90:             assert saved_path.exists()\n91: \n92:             with open(saved_path, \"r\") as f:\n93:                 saved_data = yaml.safe_load(f)\n94: \n95:             assert saved_data[\"agent_name\"] == \"saved-agent\"\n96:             assert saved_data[\"port\"] == 9000\n97: \n98: \n99: class TestMetadataServiceValidate:\n100:     \"\"\"Tests for MetadataService.validate_workspace method.\"\"\"\n101: \n102:     def test_valid_workspace_returns_true(self):\n103:         \"\"\"Test valid workspace returns True.\"\"\"\n104:         with tempfile.TemporaryDirectory() as tmpdir:\n105:             workspace = Path(tmpdir)\n106: \n107:             result = MetadataService.validate_workspace(workspace)\n108: \n109:             assert result is True\n110: \n111:     def test_nonexistent_workspace_raises_value_error(self):\n112:         \"\"\"Test nonexistent workspace raises ValueError.\"\"\"\n113:         with pytest.raises(ValueError, match=\"does not exist\"):\n114:             MetadataService.validate_workspace(\"/nonexistent/path\")\n115: \n116:     def test_file_raises_value_error(self):\n117:         \"\"\"Test file path raises ValueError.\"\"\"\n118:         with tempfile.NamedTemporaryFile() as tmpfile:\n119:             with pytest.raises(ValueError, match=\"not a directory\"):\n120:                 MetadataService.validate_workspace(tmpfile.name)\n121: \n122: \n123: class TestAgentMetadataFields:\n124:     \"\"\"Tests for AgentMetadata field defaults.\"\"\"\n125: \n126:     def test_default_values(self):\n127:         \"\"\"Test default field values.\"\"\"\n128:         metadata = AgentMetadata(\n129:             agent_name=\"test\",\n130:             entrypoint=\"python main.py\",\n131:         )\n132: \n133:         assert metadata.language == \"python\"\n134:         assert metadata.port == 8080\n135:         assert metadata.build_mode == \"local\"\n136:         assert metadata.requirements_file == \"requirements.txt\"\n137: \n138:     def test_optional_description(self):\n139:         \"\"\"Test optional description field.\"\"\"\n140:         metadata = AgentMetadata(\n141:             agent_name=\"test\",\n142:             entrypoint=\"python main.py\",\n143:             description=None,\n144:         )\n145: \n146:         assert metadata.description is None\n\n(End of file - total 146 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for MetadataService.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\n\nimport pytest\nimport yaml\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass TestMetadataServiceLoad:\n    \"\"\"Tests for MetadataService.load_metadata method.\"\"\"\n\n    def test_loads_agent_metadata_yaml(self):\n        \"\"\"Test loading agent_metadata.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\n                \"agent_name\": \"my-agent\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_metadata_service.py","time":{"start":1775866175516,"end":1775866175533}}}}
