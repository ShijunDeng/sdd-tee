{"type":"tool_use","timestamp":1775866367081,"sessionID":"ses_28620f443ffeOwB10PccdNhCR2","part":{"id":"prt_d79e1806e001zeTX4lq0Zl4wOn","messageID":"msg_d79e17814001a5IXFzmTHaNifM","sessionID":"ses_28620f443ffeOwB10PccdNhCR2","type":"tool","tool":"write","callID":"toolu_d7257c3af5b74de4b93d2d54","state":{"status":"completed","input":{"content":"\"\"\"Unit tests for MetadataService.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\n\nimport pytest\nimport yaml\n\nfrom agentcube.models import AgentMetadata\nfrom agentcube.models.pack_models import MetadataOptions\nfrom agentcube.services.metadata_service import MetadataService\n\n\nclass TestMetadataServiceLoad:\n    \"\"\"Tests for MetadataService.load_metadata method.\"\"\"\n\n    def test_loads_agent_metadata_yaml(self):\n        \"\"\"Test loading agent_metadata.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\n                \"agent_name\": \"my-agent\",\n                \"language\": \"python\",\n                \"entrypoint\": \"python main.py\",\n                \"port\": 8080,\n                \"build_mode\": \"local\",\n                \"description\": \"Test agent\",\n            }\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata_data, f)\n\n            metadata = MetadataService.load_metadata(workspace)\n\n            assert metadata.agent_name == \"my-agent\"\n            assert metadata.language == \"python\"\n            assert metadata.port == 8080\n\n    def test_falls_back_to_agent_yaml(self):\n        \"\"\"Test fallback to agent.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\"agent_name\": \"fallback-agent\", \"entrypoint\": \"python app.py\"}\n\n            with open(workspace / \"agent.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata_data, f)\n\n            metadata = MetadataService.load_metadata(workspace)\n\n            assert metadata.agent_name == \"fallback-agent\"\n\n    def test_falls_back_to_metadata_yaml(self):\n        \"\"\"Test fallback to metadata.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\"agent_name\": \"metadata-agent\", \"entrypoint\": \"python run.py\"}\n\n            with open(workspace / \"metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata_data, f)\n\n            metadata = MetadataService.load_metadata(workspace)\n\n            assert metadata.agent_name == \"metadata-agent\"\n\n    def test_raises_error_when_no_metadata_file(self):\n        \"\"\"Test error when no metadata file found.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            with pytest.raises(FileNotFoundError):\n                MetadataService.load_metadata(workspace)\n\n\nclass TestMetadataServiceSave:\n    \"\"\"Tests for MetadataService.save_metadata method.\"\"\"\n\n    def test_saves_to_agent_metadata_yaml(self):\n        \"\"\"Test saving metadata to agent_metadata.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"saved-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=9000,\n                build_mode=\"cloud\",\n            )\n\n            saved_path = MetadataService.save_metadata(workspace, metadata)\n\n            assert saved_path == workspace / \"agent_metadata.yaml\"\n            assert saved_path.exists()\n\n            with open(saved_path, \"r\") as f:\n                saved_data = yaml.safe_load(f)\n\n            assert saved_data[\"agent_name\"] == \"saved-agent\"\n            assert saved_data[\"port\"] == 9000\n\n    def test_save_uses_exclude_none(self):\n        \"\"\"Test that save_metadata excludes None values.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                description=None,\n            )\n\n            saved_path = MetadataService.save_metadata(workspace, metadata)\n\n            with open(saved_path, \"r\") as f:\n                saved_data = yaml.safe_load(f)\n\n            assert \"description\" not in saved_data\n\n\nclass TestMetadataServiceUpdate:\n    \"\"\"Tests for MetadataService.update_metadata method.\"\"\"\n\n    def test_updates_metadata_fields(self):\n        \"\"\"Test updating metadata fields.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\n                \"agent_name\": \"original-agent\",\n                \"language\": \"python\",\n                \"entrypoint\": \"python main.py\",\n                \"port\": 8080,\n            }\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata_data, f)\n\n            updated = MetadataService.update_metadata(workspace, {\"port\": 9000, \"description\": \"Updated\"})\n\n            assert updated.port == 9000\n            assert updated.description == \"Updated\"\n            assert updated.agent_name == \"original-agent\"\n\n            with open(workspace / \"agent_metadata.yaml\", \"r\") as f:\n                saved_data = yaml.safe_load(f)\n\n            assert saved_data[\"port\"] == 9000\n            assert saved_data[\"description\"] == \"Updated\"\n\n\nclass TestMetadataServiceValidate:\n    \"\"\"Tests for MetadataService.validate_workspace method.\"\"\"\n\n    def test_valid_workspace_returns_true(self):\n        \"\"\"Test valid workspace returns True.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            result = MetadataService.validate_workspace(workspace)\n\n            assert result is True\n\n    def test_nonexistent_workspace_raises_value_error(self):\n        \"\"\"Test nonexistent workspace raises ValueError.\"\"\"\n        with pytest.raises(ValueError, match=\"does not exist\"):\n            MetadataService.validate_workspace(\"/nonexistent/path\")\n\n    def test_file_raises_value_error(self):\n        \"\"\"Test file path raises ValueError.\"\"\"\n        with tempfile.NamedTemporaryFile() as tmpfile:\n            with pytest.raises(ValueError, match=\"not a directory\"):\n                MetadataService.validate_workspace(tmpfile.name)\n\n\nclass TestMetadataServiceValidateLanguage:\n    \"\"\"Tests for language-specific workspace validation.\"\"\"\n\n    def test_validate_python_workspace_with_py_files(self):\n        \"\"\"Test Python workspace validation passes with .py files.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").touch()\n            (workspace / \"utils.py\").touch()\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n            )\n\n            MetadataService._validate_python_workspace(workspace, metadata)\n\n    def test_validate_python_workspace_without_py_files(self):\n        \"\"\"Test Python workspace validation fails without .py files.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n            )\n\n            with pytest.raises(ValueError, match=\"No Python files found\"):\n                MetadataService._validate_python_workspace(workspace, metadata)\n\n    def test_validate_python_workspace_ignores_java(self):\n        \"\"\"Test Python validation ignores Java workspace.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"java\",\n                entrypoint=\"java Main\",\n            )\n\n            MetadataService._validate_python_workspace(workspace, metadata)\n\n    def test_validate_java_workspace_with_pom(self):\n        \"\"\"Test Java workspace validation passes with pom.xml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"pom.xml\").touch()\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"java\",\n                entrypoint=\"java -jar target/app.jar\",\n            )\n\n            MetadataService._validate_java_workspace(workspace, metadata)\n\n    def test_validate_java_workspace_without_pom(self):\n        \"\"\"Test Java workspace validation fails without pom.xml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"java\",\n                entrypoint=\"java -jar target/app.jar\",\n            )\n\n            with pytest.raises(ValueError, match=\"No pom.xml found\"):\n                MetadataService._validate_java_workspace(workspace, metadata)\n\n    def test_validate_java_workspace_ignores_python(self):\n        \"\"\"Test Java validation ignores Python workspace.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").touch()\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n            )\n\n            MetadataService._validate_java_workspace(workspace, metadata)\n\n\nclass TestAgentMetadataFields:\n    \"\"\"Tests for AgentMetadata field defaults.\"\"\"\n\n    def test_default_values(self):\n        \"\"\"Test default field values.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            entrypoint=\"python main.py\",\n        )\n\n        assert metadata.language == \"python\"\n        assert metadata.port == 8080\n        assert metadata.build_mode == \"local\"\n        assert metadata.requirements_file == \"requirements.txt\"\n\n    def test_optional_description(self):\n        \"\"\"Test optional description field.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            entrypoint=\"python main.py\",\n            description=None,\n        )\n\n        assert metadata.description is None\n\n\nclass TestAgentMetadataValidators:\n    \"\"\"Tests for AgentMetadata validators.\"\"\"\n\n    def test_language_validator_accepts_python(self):\n        \"\"\"Test language validator accepts python.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n        )\n        assert metadata.language == \"python\"\n\n    def test_language_validator_accepts_java(self):\n        \"\"\"Test language validator accepts java.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            language=\"java\",\n            entrypoint=\"java Main\",\n        )\n        assert metadata.language == \"java\"\n\n    def test_language_validator_accepts_uppercase(self):\n        \"\"\"Test language validator accepts uppercase.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            language=\"PYTHON\",\n            entrypoint=\"python main.py\",\n        )\n        assert metadata.language == \"python\"\n\n    def test_language_validator_rejects_invalid(self):\n        \"\"\"Test language validator rejects invalid values.\"\"\"\n        with pytest.raises(ValueError, match=\"Language must be 'python' or 'java'\"):\n            AgentMetadata(\n                agent_name=\"test\",\n                language=\"invalid\",\n                entrypoint=\"main\",\n            )\n\n    def test_build_mode_validator_accepts_local(self):\n        \"\"\"Test build_mode validator accepts local.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            build_mode=\"local\",\n        )\n        assert metadata.build_mode == \"local\"\n\n    def test_build_mode_validator_accepts_cloud(self):\n        \"\"\"Test build_mode validator accepts cloud.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            build_mode=\"cloud\",\n        )\n        assert metadata.build_mode == \"cloud\"\n\n    def test_build_mode_validator_rejects_invalid(self):\n        \"\"\"Test build_mode validator rejects invalid values.\"\"\"\n        with pytest.raises(ValueError, match=\"Build mode must be 'local' or 'cloud'\"):\n            AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                build_mode=\"invalid\",\n            )\n\n    def test_port_validator_accepts_valid_port(self):\n        \"\"\"Test port validator accepts valid ports.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=8080,\n        )\n        assert metadata.port == 8080\n\n    def test_port_validator_rejects_port_zero(self):\n        \"\"\"Test port validator rejects port 0.\"\"\"\n        with pytest.raises(ValueError, match=\"Port must be between 1 and 65535\"):\n            AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=0,\n            )\n\n    def test_port_validator_rejects_port_above_range(self):\n        \"\"\"Test port validator rejects port above 65535.\"\"\"\n        with pytest.raises(ValueError, match=\"Port must be between 1 and 65535\"):\n            AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=70000,\n            )\n\n    def test_port_validator_rejects_non_integer(self):\n        \"\"\"Test port validator rejects non-integer.\"\"\"\n        with pytest.raises(ValueError, match=\"Port must be an integer\"):\n            AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=\"8080\",\n            )\n\n\nclass TestMetadataOptionsFromOptions:\n    \"\"\"Tests for MetadataOptions.from_options method.\"\"\"\n\n    def test_from_options_creates_instance(self):\n        \"\"\"Test from_options creates instance from dict.\"\"\"\n        options_dict = {\n            \"agent_name\": \"test-agent\",\n            \"language\": \"python\",\n            \"port\": 9000,\n            \"verbose\": True,\n        }\n\n        options = MetadataOptions.from_options(options_dict)\n\n        assert options.agent_name == \"test-agent\"\n        assert options.language == \"python\"\n        assert options.port == 9000\n        assert options.verbose is True\n\n    def test_from_options_filters_invalid_fields(self):\n        \"\"\"Test from_options filters out invalid fields.\"\"\"\n        options_dict = {\n            \"agent_name\": \"test-agent\",\n            \"invalid_field\": \"value\",\n        }\n\n        options = MetadataOptions.from_options(options_dict)\n\n        assert options.agent_name == \"test-agent\"\n        assert not hasattr(options, \"invalid_field\")\n\n    def test_from_options_uses_defaults_for_missing(self):\n        \"\"\"Test from_options uses default values for missing fields.\"\"\"\n        options_dict = {}\n\n        options = MetadataOptions.from_options(options_dict)\n\n        assert options.language == \"python\"\n        assert options.port == 8080\n        assert options.build_mode == \"local\"\n        assert options.verbose is False\n\n\nclass TestAgentMetadataImportPath:\n    \"\"\"Tests for AgentMetadata import from models package.\"\"\"\n\n    def test_import_from_models(self):\n        \"\"\"Test AgentMetadata can be imported from models package.\"\"\"\n        from agentcube.models import AgentMetadata as ImportedAgentMetadata\n\n        metadata = ImportedAgentMetadata(\n            agent_name=\"test\",\n            entrypoint=\"python main.py\",\n        )\n        assert metadata.agent_name == \"test\"\n\n    def test_import_from_services_backward_compatible(self):\n        \"\"\"Test AgentMetadata can still be imported from services for backward compatibility.\"\"\"\n        from agentcube.services import AgentMetadata as ServiceAgentMetadata\n\n        metadata = ServiceAgentMetadata(\n            agent_name=\"test\",\n            entrypoint=\"python main.py\",\n        )\n        assert metadata.agent_name == \"test\"","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_metadata_service.py"},"output":"Wrote file successfully.\n\nLSP errors detected in this file, please fix:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_metadata_service.py\">\nERROR [395:22] Argument of type \"Literal['8080']\" cannot be assigned to parameter \"port\" of type \"int\" in function \"__ini