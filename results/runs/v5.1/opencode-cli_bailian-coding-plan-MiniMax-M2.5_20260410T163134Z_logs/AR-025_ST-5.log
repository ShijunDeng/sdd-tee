x-M2.5_20260410T163134Z/agentcube/services/metadata_service.py","before":"\"\"\"Metadata service for AgentCube - handles agent metadata loading, saving, and validation.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport yaml\nfrom pydantic import BaseModel\n\nfrom agentcube.models.agent_models import AgentMetadata\n\n\nclass MetadataService:\n    \"\"\"Service for managing agent metadata in workspace.\"\"\"\n\n    METADATA_FILES = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n\n    @staticmethod\n    def load_metadata(workspace_path: str | Path) -> AgentMetadata:\n        \"\"\"\n        Load metadata from workspace with fallback chain.\n\n        Searches for metadata files in order: agent_metadata.yaml -> agent.yaml -> metadata.yaml\n        Raises FileNotFoundError if none found.\n        \"\"\"\n        workspace = Path(workspace_path)\n\n        for filename in MetadataService.METADATA_FILES:\n            metadata_file = workspace / filename\n            if metadata_file.exists():\n                with open(metadata_file, \"r\", encoding=\"utf-8\") as f:\n                    data = yaml.safe_load(f)\n                    if data:\n                        return AgentMetadata(**data)\n\n        raise FileNotFoundError(\n            f\"No metadata file found in {workspace}. \"\n            f\"Expected one of: {', '.join(MetadataService.METADATA_FILES)}\"\n        )\n\n    @staticmethod\n    def save_metadata(workspace_path: str | Path, metadata: AgentMetadata) -> Path:\n        \"\"\"\n        Save metadata to workspace as agent_metadata.yaml.\n\n        Returns the path to the saved file.\n        Uses exclude_none=True to exclude None values from the output.\n        \"\"\"\n        workspace = Path(workspace_path)\n        metadata_file = workspace / \"agent_metadata.yaml\"\n\n        with open(metadata_file, \"w\", encoding=\"utf-8\") as f:\n            yaml.safe_dump(\n                metadata.model_dump(exclude_none=True),\n                f,\n                default_flow_style=False,\n                sort_keys=False,\n            )\n\n        return metadata_file\n\n    @staticmethod\n    def update_metadata(workspace_path: str | Path, updates: Dict[str, Any]) -> AgentMetadata:\n        \"\"\"\n        Load metadata, merge updates, save, and return updated metadata.\n\n        Args:\n            workspace_path: Path to the workspace directory\n            updates: Dictionary of fields to update\n\n        Returns:\n            The updated AgentMetadata object\n        \"\"\"\n        metadata = MetadataService.load_metadata(workspace_path)\n        updated = metadata.model_copy(update=updates)\n        MetadataService.save_metadata(workspace_path, updated)\n        return updated\n\n    @staticmethod\n    def validate_workspace(workspace_path: str | Path) -> bool:\n        \"\"\"\n        Basic validation that workspace path exists and is a directory.\n\n        Returns True if valid.\n        Raises ValueError if not valid.\n        \"\"\"\n        workspace = Path(workspace_path)\n\n        if not workspace.exists():\n            raise ValueError(f\"Workspace path does not exist: {workspace}\")\n\n        if not workspace.is_dir():\n            raise ValueError(f\"Workspace path is not a directory: {workspace}\")\n\n        return True\n\n    @staticmethod\n    def _validate_python_workspace(workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"\n        Validate that a Python workspace contains at least one .py file.\n\n        Args:\n            workspace_path: Path to the workspace directory\n            metadata: AgentMetadata object (language must be 'python')\n\n        Raises:\n            ValueError: If no .py files found in workspace\n        \"\"\"\n        if metadata.language.lower() != \"python\":\n            return\n\n        py_files = list(workspace_path.glob(\"*.py\"))\n        if not py_files:\n            raise ValueError(\"No Python files found in workspace\")\n\n    @staticmethod\n    def _validate_java_workspace(workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"\n        Validate that a Java workspace contains pom.xml.\n\n        Args:\n            workspace_path: Path to the workspace directory\n            metadata: AgentMetadata object (language must be 'java')\n\n        Raises:\n            ValueError: If no pom.xml found in workspace\n        \"\"\"\n        if metadata.language.lower() != \"java\":\n            return\n\n        pom_file = workspace_path / \"pom.xml\"\n        if not pom_file.exists():\n            raise ValueError(\"No pom.xml found in workspace\")\n\n\nAgentMetadata = BaseModel.model_rebuild(AgentMetadata)\n","after":"\"\"\"Metadata service for AgentCube - handles agent metadata loading, saving, and validation.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional, Union\n\nimport yaml\n\nfrom agentcube.models.agent_models import AgentMetadata\n\n\nclass MetadataService:\n    \"\"\"Service for managing agent metadata in workspace.\"\"\"\n\n    METADATA_FILES = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n\n    @staticmethod\n    def load_metadata(workspace_path: Union[str, Path]) -> AgentMetadata:\n        \"\"\"\n        Load metadata from workspace with fallback chain.\n\n        Searches for metadata files in order: agent_metadata.yaml -> agent.yaml -> metadata.yaml\n        Raises FileNotFoundError if none found.\n        \"\"\"\n        workspace = Path(workspace_path)\n\n        for filename in MetadataService.METADATA_FILES:\n            metadata_file = workspace / filename\n            if metadata_file.exists():\n                with open(metadata_file, \"r\", encoding=\"utf-8\") as f:\n                    data = yaml.safe_load(f)\n                    if data:\n                        return AgentMetadata(**data)\n\n        raise FileNotFoundError(\n            f\"No metadata file found in {workspace}. \"\n            f\"Expected one of: {', '.join(MetadataService.METADATA_FILES)}\"\n        )\n\n    @staticmethod\n    def save_metadata(workspace_path: str | Path, metadata: AgentMetadata) -> Path:\n        \"\"\"\n        Save metadata to workspace as agent_metadata.yaml.\n\n        Returns the path to the saved file.\n        Uses exclude_none=True to exclude None values from the output.\n        \"\"\"\n        workspace = Path(workspace_path)\n        metadata_file = workspace / \"agent_metadata.yaml\"\n\n        with open(metadata_file, \"w\", encoding=\"utf-8\") as f:\n            yaml.safe_dump(\n                metadata.model_dump(exclude_none=True),\n                f,\n                default_flow_style=False,\n                sort_keys=False,\n            )\n\n        return metadata_file\n\n    @staticmethod\n    def update_metadata(workspace_path: str | Path, updates: Dict[str, Any]) -> AgentMetadata:\n        \"\"\"\n        Load metadata, merge updates, save, and return updated metadata.\n\n        Args:\n            workspace_path: Path to the workspace directory\n            updates: Dictionary of fields to update\n\n        Returns:\n            The updated AgentMetadata object\n        \"\"\"\n        metadata = MetadataService.load_metadata(workspace_path)\n        updated = metadata.model_copy(update=updates)\n        MetadataService.save_metadata(workspace_path, updated)\n        return updated\n\n    @staticmethod\n    def validate_workspace(workspace_path: str | Path) -> bool:\n        \"\"\"\n        Basic validation that workspace path exists and is a directory.\n\n        Returns True if valid.\n        Raises ValueError if not valid.\n        \"\"\"\n        workspace = Path(workspace_path)\n\n        if not workspace.exists():\n            raise ValueError(f\"Workspace path does not exist: {workspace}\")\n\n        if not workspace.is_dir():\n            raise ValueError(f\"Workspace path is not a directory: {workspace}\")\n\n        return True\n\n    @staticmethod\n    def _validate_python_workspace(workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"\n        Validate that a Python workspace contains at least one .py file.\n\n        Args:\n            workspace_path: Path to the workspace directory\n            metadata: AgentMetadata object (language must be 'python')\n\n        Raises:\n            ValueError: If no .py files found in workspace\n        \"\"\"\n        if metadata.language.lower() != \"python\":\n            return\n\n        py_files = list(workspace_path.glob(\"*.py\"))\n        if not py_files:\n            raise ValueError(\"No Python files found in workspace\")\n\n    @staticmethod\n    def _validate_java_workspace(workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"\n        Validate that a Java workspace contains pom.xml.\n\n        Args:\n            workspace_path: Path to the workspace directory\n            metadata: AgentMetadata object (language must be 'java')\n\n        Raises:\n            ValueError: If no pom.xml found in workspace\n        \"\"\"\n        if metadata.language.lower() != \"java\":\n            return\n\n        pom_file = workspace_path / \"pom.xml\"\n        if not pom_file.exists():\n            raise ValueError(\"No pom.xml found in workspace\")\n\n\nAgentMetadata = BaseModel.model_rebuild(AgentMetadata)\n","additions":2,"deletions":3},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/metadata_service.py","time":{"start":1775866254796,"end":1775866255533}}}}
