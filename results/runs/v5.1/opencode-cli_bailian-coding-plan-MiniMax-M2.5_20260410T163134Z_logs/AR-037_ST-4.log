{"type":"tool_use","timestamp":1775880036799,"sessionID":"ses_2854d6db7ffe29XaN17T01Ck5i","part":{"id":"prt_d7ab2dce9001p1C1AW5074kHVD","messageID":"msg_d7ab2c889001kHsozBE6tWSr2q","sessionID":"ses_2854d6db7ffe29XaN17T01Ck5i","type":"tool","tool":"read","callID":"toolu_9c8b269cbc804fddb157c0ad","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/example/pcap-analyzer/pcap_analyzer.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/example/pcap-analyzer/pcap_analyzer.py</path>\n<type>file</type>\n<content>\n1: import os\n2: import sys\n3: import tempfile\n4: from pathlib import Path\n5: from typing import Any, Dict, List, Optional\n6: \n7: from fastapi import FastAPI, File, HTTPException, UploadFile, Form\n8: from fastapi.responses import JSONResponse\n9: from pydantic import BaseModel\n10: \n11: # Add the parent directory to the path for agentcube SDK imports\n12: sys.path.insert(0, str(Path(__file__).parent.parent / \"..\" / \"..\"))\n13: \n14: from agentcube import CodeInterpreterClient\n15: \n16: \n17: # Configuration defaults\n18: OPENAI_API_KEY = os.environ.get(\"OPENAI_API_KEY\")\n19: OPENAI_API_BASE = os.environ.get(\"OPENAI_API_BASE\", \"https://api.siliconflow.cn/v1\")\n20: OPENAI_MODEL = os.environ.get(\"OPENAI_MODEL\", \"Qwen/QwQ-32B\")\n21: CODEINTERPRETER_NAME = os.environ.get(\"CODEINTERPRETER_NAME\", \"my-interpreter\")\n22: SANDBOX_NAMESPACE = os.environ.get(\"SANDBOX_NAMESPACE\", \"default\")\n23: SANDBOX_WARMUP_SEC = int(os.environ.get(\"SANDBOX_WARMUP_SEC\", \"5\"))\n24: ROUTER_URL = os.environ.get(\"ROUTER_URL\")\n25: WORKLOAD_MANAGER_URL = os.environ.get(\"WORKLOAD_MANAGER_URL\")\n26: \n27: app = FastAPI(\n28:     title=\"PCAP Analyzer\", description=\"Network traffic analysis using AgentCube Code Interpreter\"\n29: )\n30: \n31: \n32: class AnalyzeResponse(BaseModel):\n33:     script: str\n34:     results: str\n35:     report: str\n36: \n37: \n38: class SandboxRunner:\n39:     \"\"\"Manages AgentCube sandbox execution for PCAP analysis.\"\"\"\n40: \n41:     def __init__(\n42:         self,\n43:         name: str = CODEINTERPRETER_NAME,\n44:         namespace: str = SANDBOX_NAMESPACE,\n45:         warmup_sec: int = SANDBOX_WARMUP_SEC,\n46:     ):\n47:         self.name = name\n48:         self.namespace = namespace\n49:         self.warmup_sec = warmup_sec\n50:         self.client: Optional[CodeInterpreterClient] = None\n51: \n52:     def start(self) -> None:\n53:         \"\"\"Initialize the sandbox client.\"\"\"\n54:         if not ROUTER_URL:\n55:             raise ValueError(\"ROUTER_URL environment variable is not set\")\n56:         if not WORKLOAD_MANAGER_URL:\n57:             raise ValueError(\"WORKLOAD_MANAGER_URL environment variable is not set\")\n58: \n59:         self.client = CodeInterpreterClient(\n60:             router_url=ROUTER_URL,\n61:             workload_manager_url=WORKLOAD_MANAGER_URL,\n62:             name=self.name,\n63:             namespace=self.namespace,\n64:         )\n65: \n66:     def upload_file(self, local_path: str, remote_path: str) -> Dict[str, Any]:\n67:         \"\"\"Upload a file to the sandbox.\"\"\"\n68:         if not self.client:\n69:             raise RuntimeError(\"Sandbox not started\")\n70:         return self.client.upload_file(local_path, remote_path)\n71: \n72:     def upload_bytes(self, data: bytes, remote_path: str) -> Dict[str, Any]:\n73:         \"\"\"Upload bytes to the sandbox as a file.\"\"\"\n74:         if not self.client:\n75:             raise RuntimeError(\"Sandbox not started\")\n76: \n77:         with tempfile.NamedTemporaryFile(delete=False, mode=\"wb\") as f:\n78:             f.write(data)\n79:             local_path = f.name\n80: \n81:         try:\n82:             return self.client.upload_file(local_path, remote_path)\n83:         finally:\n84:             os.unlink(local_path)\n85: \n86:     def run(self, command: str, timeout: Optional[int] = None) -> Dict[str, Any]:\n87:         \"\"\"Execute a command in the sandbox.\"\"\"\n88:         if not self.client:\n89:             raise RuntimeError(\"Sandbox not started\")\n90:         return self.client.execute_command(command, timeout=timeout)\n91: \n92:     def stop(self) -> None:\n93:         \"\"\"Stop and cleanup the sandbox client.\"\"\"\n94:         if self.client:\n95:             self.client.stop()\n96:             self.client = None\n97: \n98: \n99: class ReActAgent:\n100:     \"\"\"ReAct (Reasoning + Acting) agent for PCAP analysis.\"\"\"\n101: \n102:     def __init__(self, llm: Any):\n103:         self.llm = llm\n104: \n105:     def analyze(self, pcap_path: str, question: str) -> str:\n106:         \"\"\"Run ReAct-style analysis on the PCAP file.\"\"\"\n107:         prompt = f\"\"\"You are a network traffic analysis expert.\n108: Analyze the PCAP file at {pcap_path}.\n109: \n110: Question: {question}\n111: \n112: Use the following format:\n113: Thought: <your reasoning>\n114: Action: <command to execute>\n115: Observation: <result of the action>\n116: ... (repeat as needed)\n117: Final Answer: <your final analysis>\n118: \"\"\"\n119:         response = self.llm.invoke(prompt)\n120:         return response.content\n121: \n122: \n123: class Planner:\n124:     \"\"\"Planner agent that generates analysis scripts.\"\"\"\n125: \n126:     SYSTEM_PROMPT = \"\"\"You are a PCAP analysis planning agent.\n127: Given a question about network traffic, generate a Python script to analyze the PCAP file.\n128: \n129: The script should:\n130: 1. Use scapy or pyshark to parse the PCAP file\n131: 2. Extract relevant information\n132: 3. Generate statistics and insights\n133: \n134: Return ONLY the Python script code, no explanations.\"\"\"\n135: \n136:     def __init__(self, llm: Any):\n137:         self.llm = llm\n138: \n139:     def generate_script(self, question: str) -> str:\n140:         \"\"\"Generate a Python script for the analysis question.\"\"\"\n141:         prompt = f\"{self.SYSTEM_PROMPT}\\n\\nQuestion: {question}\\n\\nScript:\"\n142:         response = self.llm.invoke(prompt)\n143:         return response.content\n144: \n145: \n146: class Reporter:\n147:     \"\"\"Reporter agent that generates human-readable reports.\"\"\"\n148: \n149:     SYSTEM_PROMPT = \"\"\"You are a network traffic analysis reporting agent.\n150: Given analysis results from a PCAP file, generate a clear, concise report.\n151: \n152: The report should:\n153: - Summarize key findings\n154: - Highlight important insights\n155: - Use bullet points for clarity\n156: - Be technical but accessible\"\"\"\n157: \n158:     def __init__(self, llm: Any):\n159:         self.llm = llm\n160: \n161:     def generate_report(self, question: str, results: str) -> str:\n162:         \"\"\"Generate a report from analysis results.\"\"\"\n163:         prompt = f\"{self.SYSTEM_PROMPT}\\n\\nQuestion: {question}\\n\\nResults:\\n{results}\\n\\nReport:\"\n164:         response = self.llm.invoke(prompt)\n165:         return response.content\n166: \n167: \n168: # Global LLM instances (initialized on startup)\n169: PLANNER: Optional[Planner] = None\n170: REPORTER: Optional[Reporter] = None\n171: \n172: \n173: @app.on_event(\"startup\")\n174: async def startup_event():\n175:     \"\"\"Initialize the application on startup.\"\"\"\n176:     global PLANNER, REPORTER\n177: \n178:     if not OPENAI_API_KEY:\n179:         raise ValueError(\n180:             \"OPENAI_API_KEY environment variable is not set. \"\n181:             \"Please provide a valid OpenAI-compatible API key.\"\n182:         )\n183: \n184:     try:\n185:         from langchain_openai import ChatOpenAI\n186:     except ImportError:\n187:         raise ImportError(\n188:             \"langchain-openai is required. Install with: pip install langchain-openai\"\n189:         )\n190: \n191:     llm = ChatOpenAI(\n192:         model=OPENAI_MODEL,\n193:         api_key=OPENAI_API_KEY,\n194:         base_url=OPENAI_API_BASE,\n195:         temperature=0.7,\n196:     )\n197: \n198:     PLANNER = Planner(llm)\n199:     REPORTER = Reporter(llm)\n200: \n201: \n202: @app.get(\"/\")\n203: async def root():\n204:     \"\"\"Root endpoint.\"\"\"\n205:     return {\n206:         \"service\": \"PCAP Analyzer\",\n207:         \"version\": \"1.0.0\",\n208:         \"description\": \"Network traffic analysis using AgentCube Code Interpreter\",\n209:         \"endpoints\": {\n210:             \"analyze\": \"POST /analyze - Analyze a PCAP file\",\n211:             \"health\": \"GET /health - Health check\",\n212:         },\n213:     }\n214: \n215: \n216: @app.get(\"/health\")\n217: async def health():\n218:     \"\"\"Health check endpoint.\"\"\"\n219:     return {\"status\": \"healthy\"}\n220: \n221: \n222: @app.post(\"/analyze\", response_model=AnalyzeResponse)\n223: async def analyze_pcap(\n224:     pcap_file: UploadFile = File(None),\n225:     pcap_path: str = Form(None),\n226:     question: str = Form(\"Summarize the network traffic in this PCAP file\"),\n227: ):\n228:     \"\"\"Analyze a PCAP file using LLM orchestration.\"\"\"\n229: \n230:     if not PLANNER or not REPORTER:\n231:         raise HTTPException(status_code=500, detail=\"Application not initialized\")\n232: \n233:     if not pcap_file and not pcap_path:\n234:         raise HTTPException(\n235:             status_code=400,\n236:             detail=\"Either pcap_file or pcap_path must be provided\",\n237:         )\n238: \n239:     local_pcap_path = None\n240:     try:\n241:         if pcap_file:\n242:             with tempfile.NamedTemporaryFile(delete=False, suffix=\".pcap\") as f:\n243:                 content = await pcap_file.read()\n244:                 f.write(content)\n245:                 local_pcap_path = f.name\n246: \n247:             remote_pcap_path = \"/tmp/capture.pcap\"\n248:         elif pcap_path:\n249:             local_pcap_path = pcap_path\n250:             remote_pcap_path = \"/tmp/capture.pcap\"\n251:         else:\n252:             raise HTTPException(\n253:                 status_code=400,\n254:                 detail=\"Invalid input: provide either pcap_file or pcap_path\",\n255:             )\n256: \n257:         script = PLANNER.generate_script(question)\n258: \n259:         runner = SandboxRunner()\n260:         runner.start()\n261: \n262:         try:\n263:             if local_pcap_path:\n264:                 runner.upload_file(local_pcap_path, remote_pcap_path)\n265: \n266:             runner.run(f\"pip install scapy -q\", timeout=60)\n267: \n268:             result = runner.run(f\"python3 -c '''{script}'''\", timeout=300)\n269: \n270:             results = result.get(\"stdout\", \"\")\n271:             if not results:\n272:                 results = result.get(\"stderr\", \"\")\n273: \n274:             report = REPORTER.generate_report(question, results)\n275: \n276:             return AnalyzeResponse(\n277:                 script=script,\n278:                 results=results,\n279:                 report=report,\n280:             )\n281:         finally:\n282:             runner.stop()\n283: \n284:     except ValueError as e:\n285:         raise HTTPException(status_code=500, detail=str(e))\n286:     except Exception as e:\n287:         raise HTTPException(status_code=500, detail=f\"Analysis failed: {str(e)}\")\n288:     finally:\n289:         if local_pcap_path and pcap_file:\n290:             try:\n291:                 os.unlink(local_pcap_path)\n292:             except OSError:\n293:                 pass\n294: \n295: \n296: if __name__ == \"__main__\":\n297:     import uvicorn\n298: \n299:     if not OPENAI_API_KEY:\n300:         print(\"ERROR: OPENAI_API_KEY environment variable is not set\")\n301:         sys.exit(1)\n302: \n303:     uvicorn.run(app, host=\"0.0.0.0\", port=8000)\n\n(End of file - total 303 lines)\n</content>","metadata":{"preview":"import os\nimport sys\nimport tempfile\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nfrom fastapi import FastAPI, File, HTTPException, UploadFile, Form\nfrom fastapi.responses import JSONResponse\nfrom pydantic import BaseModel\n\n# Add the parent directory to the path for agentcube SDK imports\nsys.path.insert(0, str(Path(__file__).parent.parent / \"..\" / \"..\"))\n\nfrom agentcube import CodeInterpreterClient\n\n\n# Configuration defaults\nOPENAI_API_KEY = os.environ.get(\"OPENAI_API_KEY\")\nOPENAI_API_BASE = os.environ.get(\"OPENAI_API_BASE\", \"https://api.siliconflow.cn/v1\")\nOPENAI_MODEL = os.environ.get(\"OPENAI_MODEL\", \"Qwen/QwQ-32B\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/example/pcap-analyzer/pcap_analyzer.py","time":{"start":1775880036788,"end":1775880036796}}}}
