service info.\"\"\"\n168:         try:\n169:             from example.pcap_analyzer.pcap_analyzer import app\n170:             from fastapi.testclient import TestClient\n171: \n172:             with patch.dict(os.environ, {\"OPENAI_API_KEY\": \"test-key\"}):\n173:                 with patch(\"example.pcap_analyzer.pcap_analyzer.startup_event\"):\n174:                     client = TestClient(app)\n175:                     response = client.get(\"/\")\n176:                     assert response.status_code == 200\n177:                     data = response.json()\n178:                     assert data[\"service\"] == \"PCAP Analyzer\"\n179:                     assert \"endpoints\" in data\n180:         except ImportError as e:\n181:             pytest.skip(f\"Missing dependency: {e}\")\n182: \n183:     def test_app_health_endpoint(self):\n184:         \"\"\"Test health check endpoint.\"\"\"\n185:         try:\n186:             from example.pcap_analyzer.pcap_analyzer import app\n187:             from fastapi.testclient import TestClient\n188: \n189:             client = TestClient(app)\n190:             response = client.get(\"/health\")\n191:             assert response.status_code == 200\n192:             assert response.json()[\"status\"] == \"healthy\"\n193:         except ImportError as e:\n194:             pytest.skip(f\"Missing dependency: {e}\")\n195: \n196: \n197: class TestPlannerAndReporterAgents:\n198:     \"\"\"Test cases for Planner and Reporter agents.\"\"\"\n199: \n200:     def test_planner_initialization(self):\n201:         \"\"\"Test Planner can be initialized.\"\"\"\n202:         try:\n203:             from example.pcap_analyzer.pcap_analyzer import Planner\n204: \n205:             mock_llm = Mock()\n206:             planner = Planner(mock_llm)\n207:             assert planner.llm is mock_llm\n208:         except ImportError:\n209:             pytest.skip(\"agent not available\")\n210: \n211:     def test_reporter_initialization(self):\n212:         \"\