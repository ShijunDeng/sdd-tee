{"type":"tool_use","timestamp":1775846990768,"sessionID":"ses_28745be05ffeTzMz0TdWYlVggx","part":{"id":"prt_d78ba9ed6001sr0ksY2XsF142R","messageID":"msg_d78ba9117001rdq4VOlQq5PkZD","sessionID":"ses_28745be05ffeTzMz0TdWYlVggx","type":"tool","tool":"read","callID":"toolu_6512c89dbd3c4dcaa46c6256","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"sync\"\n7: \t\"time\"\n8: \n9: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: \t\"k8s.io/apimachinery/pkg/labels\"\n12: \t\"k8s.io/client-go/kubernetes\"\n13: \t\"k8s.io/klog/v2\"\n14: \n15: \tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n16: \tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n17: )\n18: \n19: const (\n20: \tDefaultGCInterval  = 5 * time.Minute\n21: \tDefaultGCBatchSize = 50\n22: \tDefaultGracePeriod = 30 * time.Second\n23: \tStaleGracePeriod   = 0 * time.Second\n24: )\n25: \n26: type GCConfig struct {\n27: \tGCEnabled   bool          `json:\"gcEnabled\"`\n28: \tGCInterval  time.Duration `json:\"gcInterval\"`\n29: \tGCBatchSize int           `json:\"gcBatchSize\"`\n30: }\n31: \n32: func DefaultGCConfig() *GCConfig {\n33: \treturn &GCConfig{\n34: \t\tGCEnabled:   true,\n35: \t\tGCInterval:  DefaultGCInterval,\n36: \t\tGCBatchSize: DefaultGCBatchSize,\n37: \t}\n38: }\n39: \n40: type GCResult struct {\n41: \tScannedCount     int           `json:\"scannedCount\"`\n42: \tExpiredCount     int           `json:\"expiredCount\"`\n43: \tDeletedCount     int           `json:\"deletedCount\"`\n44: \tFailedCount      int           `json:\"failedCount\"`\n45: \tDuration         time.Duration `json:\"duration\"`\n46: \tErrors           []string      `json:\"errors,omitempty\"`\n47: \tCleanedResources []string      `json:\"cleanedResources,omitempty\"`\n48: }\n49: \n50: type GCStats struct {\n51: \tTotalCycles  int64     `json:\"totalCycles\"`\n52: \tTotalDeleted int64     `json:\"totalDeleted\"`\n53: \tTotalFailed  int64     `json:\"totalFailed\"`\n54: \tLastRunTime  time.Time `json:\"lastRunTime\"`\n55: \tLastResult   *GCResult `json:\"lastResult,omitempty\"`\n56: }\n57: \n58: type GCWorker struct {\n59: \tclient            versioned.Interface\n60: \tk8sClient         *kubernetes.Clientset\n61: \tconfig            *GCConfig\n62: \tstopCh            chan struct{}\n63: \tcleanupMgr        *CleanupManager\n64: \texpirationChecker *ExpirationChecker\n65: \tstats             GCStats\n66: \tstatsMu           sync.RWMutex\n67: \tisRunning         bool\n68: \trunningMu         sync.RWMutex\n69: }\n70: \n71: func NewGCWorker(client versioned.Interface, k8sClient *kubernetes.Clientset, config *GCConfig) *GCWorker {\n72: \tif config == nil {\n73: \t\tconfig = DefaultGCConfig()\n74: \t}\n75: \n76: \treturn &GCWorker{\n77: \t\tclient:            client,\n78: \t\tk8sClient:         k8sClient,\n79: \t\tconfig:            config,\n80: \t\tstopCh:            make(chan struct{}),\n81: \t\tcleanupMgr:        NewCleanupManager(k8sClient),\n82: \t\texpirationChecker: NewExpirationChecker(nil),\n83: \t}\n84: }\n85: \n86: func (g *GCWorker) Start(ctx context.Context) {\n87: \tif !g.config.GCEnabled {\n88: \t\tklog.InfoS(\"GC worker is disabled by configuration\")\n89: \t\treturn\n90: \t}\n91: \n92: \tg.setRunning(true)\n93: \tklog.InfoS(\"Starting GC worker\", \"interval\", g.config.GCInterval)\n94: \n95: \tticker := time.NewTicker(g.config.GCInterval)\n96: \tdefer ticker.Stop()\n97: \n98: \tfor {\n99: \t\tselect {\n100: \t\tcase <-ctx.Done():\n101: \t\t\tklog.InfoS(\"GC worker stopping due to context cancellation\")\n102: \t\t\tg.setRunning(false)\n103: \t\t\treturn\n104: \t\tcase <-g.stopCh:\n105: \t\t\tklog.InfoS(\"GC worker stopping\")\n106: \t\t\tg.setRunning(false)\n107: \t\t\treturn\n108: \t\tcase <-ticker.C:\n109: \t\t\tg.runGCCycle(ctx)\n110: \t\t}\n111: \t}\n112: }\n113: \n114: func (g *GCWorker) Stop() {\n115: \tclose(g.stopCh)\n116: \tg.setRunning(false)\n117: }\n118: \n119: func (g *GCWorker) IsRunning() bool {\n120: \tg.runningMu.RLock()\n121: \tdefer g.runningMu.RUnlock()\n122: \treturn g.isRunning\n123: }\n124: \n125: func (g *GCWorker) setRunning(running bool) {\n126: \tg.runningMu.Lock()\n127: \tdefer g.runningMu.Unlock()\n128: \tg.isRunning = running\n129: }\n130: \n131: func (g *GCWorker) GetConfig() *GCConfig {\n132: \treturn g.config\n133: }\n134: \n135: func (g *GCWorker) GetStats() GCStats {\n136: \tg.statsMu.RLock()\n137: \tdefer g.statsMu.RUnlock()\n138: \treturn g.stats\n139: }\n140: \n141: func (g *GCWorker) runGCCycle(ctx context.Context) {\n142: \tstartTime := time.Now()\n143: \tresult := &GCResult{}\n144: \n145: \tklog.V(4).InfoS(\"Starting GC cycle\")\n146: \n147: \tnamespaces, err := g.getNamespaces(ctx)\n148: \tif err != nil {\n149: \t\tklog.ErrorS(err, \"Failed to get namespaces\")\n150: \t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"failed to get namespaces: %v\", err))\n151: \t\tg.recordGCResult(result, startTime)\n152: \t\treturn\n153: \t}\n154: \n155: \tresult.ScannedCount = len(namespaces)\n156: \n157: \tfor _, ns := range namespaces {\n158: \t\tselect {\n159: \t\tcase <-ctx.Done():\n160: \t\t\tklog.InfoS(\"GC cycle cancelled\")\n161: \t\t\tbreak\n162: \t\tcase <-g.stopCh:\n163: \t\t\tklog.InfoS(\"GC cycle stopped\")\n164: \t\t\tbreak\n165: \t\tdefault:\n166: \t\t}\n167: \n168: \t\tif err := g.processNamespace(ctx, ns, result); err != nil {\n169: \t\t\tklog.ErrorS(err, \"Failed to process namespace\", \"namespace\", ns)\n170: \t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"%s: %v\", ns, err))\n171: \t\t}\n172: \n173: \t\tif result.ScannedCount >= g.config.GCBatchSize {\n174: \t\t\tklog.V(4).InfoS(\"Batch size reached\", \"scanned\", result.ScannedCount)\n175: \t\t\tbreak\n176: \t\t}\n177: \t}\n178: \n179: \tresult.Duration = time.Since(startTime)\n180: \tg.recordGCResult(result, startTime)\n181: \n182: \tklog.InfoS(\"GC cycle completed\",\n183: \t\t\"scanned\", result.ScannedCount,\n184: \t\t\"expired\", result.ExpiredCount,\n185: \t\t\"deleted\", result.DeletedCount,\n186: \t\t\"failed\", result.FailedCount,\n187: \t\t\"duration\", result.Duration)\n188: }\n189: \n190: func (g *GCWorker) getNamespaces(ctx context.Context) ([]string, error) {\n191: \tnsList, err := g.k8sClient.CoreV1().Namespaces().List(ctx, metav1.ListOptions{})\n192: \tif err != nil {\n193: \t\treturn nil, fmt.Errorf(\"failed to list namespaces: %w\", err)\n194: \t}\n195: \n196: \tnamespaces := make([]string, 0, len(nsList.Items))\n197: \tfor _, ns := range nsList.Items {\n198: \t\tnamespaces = append(namespaces, ns.Name)\n199: \t}\n200: \n201: \treturn namespaces, nil\n202: }\n203: \n204: func (g *GCWorker) processNamespace(ctx context.Context, namespace string, result *GCResult) error {\n205: \tarList, err := g.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{})\n206: \tif err != nil {\n207: \t\treturn fmt.Errorf(\"failed to list agentruntimes: %w\", err)\n208: \t}\n209: \n210: \tciList, err := g.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{})\n211: \tif err != nil {\n212: \t\treturn fmt.Errorf(\"failed to list codeinterpreters: %w\", err)\n213: \t}\n214: \n215: \tfor i := range arList.Items {\n216: \t\tar := &arList.Items[i]\n217: \t\tresult.ScannedCount++\n218: \n219: \t\tif g.isAgentRuntimeExpired(ar) {\n220: \t\t\tresult.ExpiredCount++\n221: \t\t\tcleaned, err := g.deleteAgentRuntime(ctx, namespace, ar.Name, ar)\n222: \t\t\tresult.CleanedResources = append(result.CleanedResources, cleaned...)\n223: \t\t\tif err != nil {\n224: \t\t\t\tresult.FailedCount++\n225: \t\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"agentruntime/%s: %v\", ar.Name, err))\n226: \t\t\t\tklog.ErrorS(err, \"Failed to delete expired agentruntime\", \"name\", ar.Name)\n227: \t\t\t} else {\n228: \t\t\t\tresult.DeletedCount++\n229: \t\t\t}\n230: \t\t}\n231: \n232: \t\tif result.ScannedCount >= g.config.GCBatchSize {\n233: \t\t\tbreak\n234: \t\t}\n235: \t}\n236: \n237: \tfor i := range ciList.Items {\n238: \t\tci := &ciList.Items[i]\n239: \t\tresult.ScannedCount++\n240: \n241: \t\tif g.isCodeInterpreterExpired(ci) {\n242: \t\t\tresult.ExpiredCount++\n243: \t\t\tcleaned, err := g.deleteCodeInterpreter(ctx, namespace, ci.Name, ci)\n244: \t\t\tresult.CleanedResources = append(result.CleanedResources, cleaned...)\n245: \t\t\tif err != nil {\n246: \t\t\t\tresult.FailedCount++\n247: \t\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"codeinterpreter/%s: %v\", ci.Name, err))\n248: \t\t\t\tklog.ErrorS(err, \"Failed to delete expired codeinterpreter\", \"name\", ci.Name)\n249: \t\t\t} else {\n250: \t\t\t\tresult.DeletedCount++\n251: \t\t\t}\n252: \t\t}\n253: \n254: \t\tif result.ScannedCount >= g.config.GCBatchSize {\n255: \t\t\tbreak\n256: \t\t}\n257: \t}\n258: \n259: \treturn nil\n260: }\n261: \n262: func (g *GCWorker) isAgentRuntimeExpired(ar *agentcubev1alpha1.AgentRuntime) bool {\n263: \tif ar.DeletionTimestamp != nil {\n264: \t\treturn true\n265: \t}\n266: \n267: \tsandbox := &Sandbox{\n268: \t\tName:           ar.Name,\n269: \t\tNamespace:      ar.Namespace,\n270: \t\tSessionID:      ar.Labels[\"sessionId\"],\n271: \t\tState:          g.getAgentRuntimeState(ar),\n272: \t\tCreatedAt:      ar.CreationTimestamp.Time,\n273: \t\tLastActivityAt: g.getLastActivityTime(ar),\n274: \t\tLabels:         ar.Labels,\n275: \t\tAnnotations:    ar.Annotations,\n276: \t}\n277: \n278: \treturn isExpired(sandbox)\n279: }\n280: \n281: func (g *GCWorker) isCodeInterpreterExpired(ci *agentcubev1alpha1.CodeInterpreter) bool {\n282: \tif ci.DeletionTimestamp != nil {\n283: \t\treturn true\n284: \t}\n285: \n286: \tsandbox := &Sandbox{\n287: \t\tName:           ci.Name,\n288: \t\tNamespace:      ci.Namespace,\n289: \t\tSessionID:      ci.Labels[\"sessionId\"],\n290: \t\tState:          g.getCodeInterpreterState(ci),\n291: \t\tCreatedAt:      ci.CreationTimestamp.Time,\n292: \t\tLastActivityAt: g.getLastActivityTime(ci),\n293: \t\tLabels:         ci.Labels,\n294: \t\tAnnotations:    ci.Annotations,\n295: \t}\n296: \n297: \treturn isExpired(sandbox)\n298: }\n299: \n300: func (g *GCWorker) getAgentRuntimeState(ar *agentcubev1alpha1.AgentRuntime) SandboxState {\n301: \tstate := SandboxStateUnknown\n302: \tif len(ar.Status.Conditions) > 0 {\n303: \t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n304: \t\tif lastCondition.Status == \"True\" {\n305: \t\t\tif lastCondition.Reason == \"Running\" {\n306: \t\t\t\tstate = SandboxStateRunning\n307: \t\t\t} else if lastCondition.Reason == \"Failed\" {\n308: \t\t\t\tstate = SandboxStateFailed\n309: \t\t\t}\n310: \t\t}\n311: \t}\n312: \tif ar.DeletionTimestamp != nil {\n313: \t\tstate = SandboxStateDeleting\n314: \t}\n315: \treturn state\n316: }\n317: \n318: func (g *GCWorker) getCodeInterpreterState(ci *agentcubev1alpha1.CodeInterpreter) SandboxState {\n319: \tstate := SandboxStateUnknown\n320: \tif ci.Status.Ready {\n321: \t\tstate = SandboxStateRunning\n322: \t}\n323: \tif len(ci.Status.Conditions) > 0 {\n324: \t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n325: \t\tif lastCondition.Status == \"True\" {\n326: \t\t\tif lastCondition.Reason == \"Failed\" {\n327: \t\t\t\tstate = SandboxStateFailed\n328: \t\t\t}\n329: \t\t}\n330: \t}\n331: \tif ci.DeletionTimestamp != nil {\n332: \t\tstate = SandboxStateDeleting\n333: \t}\n334: \treturn state\n335: }\n336: \n337: func (g *GCWorker) getLastActivityTime(obj metav1.Object) *time.Time {\n338: \tannotations := obj.GetAnnotations()\n339: \tif annotations == nil {\n340: \t\treturn nil\n341: \t}\n342: \n343: \tlastActivityStr := annotations[\"last-activity-time\"]\n344: \tif lastActivityStr == \"\" {\n345: \t\treturn nil\n346: \t}\n347: \n348: \tt, err := time.Parse(time.RFC3339, lastActivityStr)\n349: \tif err != nil {\n350: \t\treturn nil\n351: \t}\n352: \n353: \treturn &t\n354: }\n355: \n356: func (g *GCWorker) deleteAgentRuntime(ctx context.Context, namespace, name string, ar *agentcubev1alpha1.AgentRuntime) ([]string, error) {\n357: \tcleaned := make([]string, 0)\n358: \n359: \townerRef := metav1.OwnerReference{\n360: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n361: \t\tKind:       \"AgentRuntime\",\n362: \t\tName:       ar.Name,\n363: \t\tUID:        ar.UID,\n364: \t}\n365: \n366: \tsvcCleaned, err := g.cleanupMgr.cleanupServices(namespace, ownerRef)\n367: \tif err != nil {\n368: \t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n369: \t}\n370: \tcleaned = append(cleaned, svcCleaned...)\n371: \n372: \tcmCleaned, err := g.cleanupMgr.cleanupConfigMaps(namespace, ownerRef)\n373: \tif err != nil {\n374: \t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n375: \t}\n376: \tcleaned = append(cleaned, cmCleaned...)\n377: \n378: \tpvcCleaned, err := g.cleanupMgr.cleanupPVCs(namespace, ownerRef)\n379: \tif err != nil {\n380: \t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n381: \t}\n382: \tcleaned = append(cleaned, pvcCleaned...)\n383: \n384: \tdeleteOpts := metav1.DeleteOptions{}\n385: \tstate := g.getAgentRuntimeState(ar)\n386: \tif state == SandboxStateUnknown || state == SandboxStateFailed {\n387: \t\tgracePeriodSeconds := int64(StaleGracePeriod.Seconds())\n388: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n389: \t\tklog.InfoS(\"Force deleting stale sandbox\", \"name\", name, \"namespace\", namespace)\n390: \t} else {\n391: \t\tgracePeriodSeconds := int64(DefaultGracePeriod.Seconds())\n392: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n393: \t}\n394: \n395: \terr = g.client.RuntimeV1alpha1().AgentRuntimes(namespace).Delete(ctx, name, deleteOpts)\n396: \tif err != nil {\n397: \t\tif apierrors.IsNotFound(err) {\n398: \t\t\tklog.V(4).InfoS(\"AgentRuntime already deleted\", \"name\", name, \"namespace\", namespace)\n399: \t\t\treturn cleaned, nil\n400: \t\t}\n401: \t\treturn cleaned, fmt.Errorf(\"failed to delete agentruntime: %w\", err)\n402: \t}\n403: \n404: \tklog.InfoS(\"Deleted expired agentruntime\", \"name\", name, \"namespace\", namespace,\n405: \t\t\"cleanedResources\", len(cleaned))\n406: \n407: \treturn cleaned, nil\n408: }\n409: \n410: func (g *GCWorker) deleteCodeInterpreter(ctx context.Context, namespace, name string, ci *agentcubev1alpha1.CodeInterpreter) ([]string, error) {\n411: \tcleaned := make([]string, 0)\n412: \n413: \townerRef := metav1.OwnerReference{\n414: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n415: \t\tKind:       \"CodeInterpreter\",\n416: \t\tName:       ci.Name,\n417: \t\tUID:        ci.UID,\n418: \t}\n419: \n420: \tsvcCleaned, err := g.cleanupMgr.cleanupServices(namespace, ownerRef)\n421: \tif err != nil {\n422: \t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n423: \t}\n424: \tcleaned = append(cleaned, svcCleaned...)\n425: \n426: \tcmCleaned, err := g.cleanupMgr.cleanupConfigMaps(namespace, ownerRef)\n427: \tif err != nil {\n428: \t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n429: \t}\n430: \tcleaned = append(cleaned, cmCleaned...)\n431: \n432: \tpvcCleaned, err := g.cleanupMgr.cleanupPVCs(namespace, ownerRef)\n433: \tif err != nil {\n434: \t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n435: \t}\n436: \tcleaned = append(cleaned, pvcCleaned...)\n437: \n438: \tdeleteOpts := metav1.DeleteOptions{}\n439: \tstate := g.getCodeInterpreterState(ci)\n440: \tif state == SandboxStateUnknown || state == SandboxStateFailed {\n441: \t\tgracePeriodSeconds := int64(StaleGracePeriod.Seconds())\n442: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n443: \t\tklog.InfoS(\"Force deleting stale sandbox\", \"name\", name, \"namespace\", namespace)\n444: \t} else {\n445: \t\tgracePeriodSeconds := int64(DefaultGracePeriod.Seconds())\n446: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n447: \t}\n448: \n449: \terr = g.client.RuntimeV1alpha1().CodeInterpreters(namespace).Delete(ctx, name, deleteOpts)\n450: \tif err != nil {\n451: \t\tif apierrors.IsNotFound(err) {\n452: \t\t\tklog.V(4).InfoS(\"CodeInterpreter already deleted\", \"name\", name, \"namespace\", namespace)\n453: \t\t\treturn cleaned, nil\n454: \t\t}\n455: \t\treturn cleaned, fmt.Errorf(\"failed to delete codeinterpreter: %w\", err)\n456: \t}\n457: \n458: \tklog.InfoS(\"Deleted expired codeinterpreter\", \"name\", name, \"namespace\", namespace,\n459: \t\t\"cleanedResources\", len(cleaned))\n460: \n461: \treturn cleaned, nil\n462: }\n463: \n464: func (g *GCWorker) recordGCResult(result *GCResult, startTime time.Time) {\n465: \tg.statsMu.Lock()\n466: \tdefer g.statsMu.Unlock()\n467: \n468: \tg.stats.TotalCycles++\n469: \tg.stats.TotalDeleted += int64(result.DeletedCount)\n470: \tg.stats.TotalFailed += int64(result.FailedCount)\n471: \tg.stats.LastRunTime = startTime\n472: \tg.stats.LastResult = result\n473: }\n474: \n475: func (g *GCWorker) TriggerGCCycle(ctx context.Context) *GCResult {\n476: \tresult := &GCResult{}\n477: \n478: \tklog.InfoS(\"Manually triggering GC cycle\")\n479: \n480: \tnamespaces, err := g.getNamespaces(ctx)\n481: \tif err != nil {\n482: \t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"failed to get namespaces: %v\", err))\n483: \t\treturn result\n484: \t}\n485: \n486: \tresult.ScannedCount = len(namespaces)\n487: \tstartTime := time.Now()\n488: \n489: \tfor _, ns := range namespaces {\n490: \t\tif err := g.processNamespace(ctx, ns, result); err != nil {\n491: \t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"%s: %v\", ns, err))\n492: \t\t}\n493: \t}\n494: \n495: \tresult.Duration = time.Since(startTime)\n496: \tg.recordGCResult(result, startTime)\n497: \n498: \tklog.InfoS(\"Manual GC cycle completed\",\n499: \t\t\"scanned\", result.ScannedCount,\n500: \t\t\"expired\", result.ExpiredCount,\n501: \t\t\"deleted\", result.DeletedCount,\n502: \t\t\"failed\", result.FailedCount)\n503: \n504: \treturn result\n505: }\n506: \n507: func (g *GCWorker) UpdateConfig(config *GCConfig) {\n508: \tif config == nil {\n509: \t\treturn\n510: \t}\n511: \n512: \tg.config.GCEnabled = config.GCEnabled\n513: \tif config.GCInterval > 0 {\n514: \t\tg.config.GCInterval = config.GCInterval\n515: \t}\n516: \tif config.GCBatchSize > 0 {\n517: \t\tg.config.GCBatchSize = config.GCBatchSize\n518: \t}\n519: \n520: \tklog.InfoS(\"GC config updated\", \"gcEnabled\", g.config.GCEnabled,\n521: \t\t\"gcInterval\", g.config.GCInterval, \"gcBatchSize\", g.config.GCBatchSize)\n522: }\n523: \n524: type GCHandler struct {\n525: \tworker *GCWorker\n526: }\n527: \n528: func NewGCHandler(worker *GCWorker) *GCHandler {\n529: \treturn &GCHandler{\n530: \t\tworker: worker,\n531: \t}\n532: }\n533: \n534: func (h *GCHandler) TriggerGC() map[string]interface{} {\n535: \tresult := h.worker.TriggerGCCycle(context.Background())\n536: \treturn map[string]interface{}{\n537: \t\t\"started\":      true,\n538: \t\t\"scannedCount\": result.ScannedCount,\n539: \t\t\"expiredCount\": result.ExpiredCount,\n540: \t\t\"deletedCount\": result.DeletedCount,\n541: \t\t\"failedCount\":  result.FailedCount,\n542: \t\t\"duration\":     result.Duration.String(),\n543: \t\t\"message\":      \"GC cycle triggered\",\n544: \t}\n545: }\n546: \n547: func (h *GCHandler) GetStatus() map[string]interface{} {\n548: \tstats := h.worker.GetStats()\n549: \tconfig := h.worker.GetConfig()\n550: \n551: \treturn map[string]interface{}{\n552: \t\t\"running\":      h.worker.IsRunning(),\n553: \t\t\"gcEnabled\":    config.GCEnabled,\n554: \t\t\"gcInterval\":   config.GCInterval.String(),\n555: \t\t\"gcBatchSize\":  config.GCBatchSize,\n556: \t\t\"totalCycles\":  stats.TotalCycles,\n557: \t\t\"totalDeleted\": stats.TotalDeleted,\n558: \t\t\"totalFailed\":  stats.TotalFailed,\n559: \t\t\"lastRunTime\":  stats.LastRunTime.Format(time.RFC3339),\n560: \t}\n561: }\n562: \n563: func (h *GCHandler) UpdateConfig(config *GCConfig) map[string]interface{} {\n564: \th.worker.UpdateConfig(config)\n565: \treturn map[string]interface{}{\n566: \t\t\"message\": \"GC configuration updated\",\n567: \t}\n568: }\n569: \n570: func ListExpiredSandboxes(ctx context.Context, client versioned.Interface, namespace string) ([]*Sandbox, error) {\n571: \texpired := make([]*Sandbox, 0)\n572: \n573: \tarList, err := client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{\n574: \t\tLabelSelector: labels.Everything().String(),\n575: \t})\n576: \tif err != nil {\n577: \t\treturn nil, fmt.Errorf(\"failed to list agentruntimes: %w\", err)\n578: \t}\n579: \n580: \tfor i := range arList.Items {\n581: \t\tar := &arList.Items[i]\n582: \t\tsandbox := &Sandbox{\n583: \t\t\tName:           ar.Name,\n584: \t\t\tNamespace:      ar.Namespace,\n585: \t\t\tSessionID:      ar.Labels[\"sessionId\"],\n586: \t\t\tState:          getAgentRuntimeState(ar),\n587: \t\t\tCreatedAt:      ar.CreationTimestamp.Time,\n588: \t\t\tLastActivityAt: getLastActivityTimeFromAnnotations(ar.Annotations),\n589: \t\t\tLabels:         ar.Labels,\n590: \t\t\tAnnotations:    ar.Annotations,\n591: \t\t}\n592: \t\tif isExpired(sandbox) {\n593: \t\t\texpired = append(expired, sandbox)\n594: \t\t}\n595: \t}\n596: \n597: \tciList, err := client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{\n598: \t\tLabelSelector: labels.Everything().String(),\n599: \t})\n600: \tif err != nil {\n601: \t\treturn nil, fmt.Errorf(\"failed to list codeinterpreters: %w\", err)\n602: \t}\n603: \n604: \tfor i := range ciList.Items {\n605: \t\tci := &ciList.Items[i]\n606: \t\tsandbox := &Sandbox{\n607: \t\t\tName:           ci.Name,\n608: \t\t\tNamespace:      ci.Namespace,\n609: \t\t\tSessionID:      ci.Labels[\"sessionId\"],\n610: \t\t\tState:          getCodeInterpreterState(ci),\n611: \t\t\tCreatedAt:      ci.CreationTimestamp.Time,\n612: \t\t\tLastActivityAt: getLastActivityTimeFromAnnotations(ci.Annotations),\n613: \t\t\tLabels:         ci.Labels,\n614: \t\t\tAnnotations:    ci.Annotations,\n615: \t\t}\n616: \t\tif isExpired(sandbox) {\n617: \t\t\texpired = append(expired, sandbox)\n618: \t\t}\n619: \t}\n620: \n621: \treturn expired, nil\n622: }\n623: \n624: func getAgentRuntimeState(ar *agentcubev1alpha1.AgentRuntime) SandboxState {\n625: \tstate := SandboxStateUnknown\n626: \tif len(ar.Status.Conditions) > 0 {\n627: \t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n628: \t\tif lastCondition.Status == \"True\" {\n629: \t\t\tif lastCondition.Reason == \"Running\" {\n630: \t\t\t\tstate = SandboxStateRunning\n631: \t\t\t} else if lastCondition.Reason == \"Failed\" {\n632: \t\t\t\tstate = SandboxStateFailed\n633: \t\t\t}\n634: \t\t}\n635: \t}\n636: \tif ar.DeletionTimestamp != nil {\n637: \t\tstate = SandboxStateDeleting\n638: \t}\n639: \treturn state\n640: }\n641: \n642: func getCodeInterpreterState(ci *agentcubev1alpha1.CodeInterpreter) SandboxState {\n643: \tstate := SandboxStateUnknown\n644: \tif ci.Status.Ready {\n645: \t\tstate = SandboxStateRunning\n646: \t}\n647: \tif len(ci.Status.Conditions) > 0 {\n648: \t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n649: \t\tif lastCondition.Status == \"True\" {\n650: \t\t\tif lastCondition.Reason == \"Failed\" {\n651: \t\t\t\tstate = SandboxStateFailed\n652: \t\t\t}\n653: \t\t}\n654: \t}\n655: \tif ci.DeletionTimestamp != nil {\n656: \t\tstate = SandboxStateDeleting\n657: \t}\n658: \treturn state\n659: }\n660: \n661: func getLastActivityTimeFromAnnotations(annotations map[string]string) *time.Time {\n662: \tif annotations == nil {\n663: \t\treturn nil\n664: \t}\n665: \n666: \tlastActivityStr := annotations[\"last-activity-time\"]\n667: \tif lastActivityStr == \"\" {\n668: \t\treturn nil\n669: \t}\n670: \n671: \tt, err := time.Parse(time.RFC3339, lastActivityStr)\n672: \tif err != nil {\n673: \t\treturn nil\n674: \t}\n675: \n676: \treturn &t\n677: }\n\n(End of file - total 677 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n)\n\nconst (\n\tDefaultGCInterval  = 5 * time.Minute","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc.go","time":{"start":1775846990749,"end":1775846990765}}}}
