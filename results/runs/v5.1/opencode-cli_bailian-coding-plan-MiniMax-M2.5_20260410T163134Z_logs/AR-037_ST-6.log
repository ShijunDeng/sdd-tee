        router_url: Base URL of the Router service.\n43:             namespace: Kubernetes namespace.\n44:             agent_name: Name of the Agent Runtime.\n45:             session_id: The session ID for this Agent Runtime.\n46:             base_url: Explicit base URL for API calls. If None, constructed\n47:                      from router_url, namespace, and agent_name.\n48:             timeout: Default read timeout in seconds.\n49:             connect_timeout: Connection timeout in seconds.\n50:             pool_connections: Number of connection pools to cache.\n51:             pool_maxsize: Maximum number of connections per pool.\n52:         \"\"\"\n53:         self.timeout = timeout\n54:         self.connect_timeout = connect_timeout\n55: \n56:         if base_url:\n57:             self.base_url = base_url\n58:         else:\n59:             self.base_url = urljoin(\n60:                 router_url,\n61:                 f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\",\n62:             )\n63: \n64:         self._session_id = session_id\n65:         self._headers: Dict[str, str] = {}\n66:         if session_id:\n67:             self._headers[self.SESSION_HEADER] = session_id\n68: \n69:         self._session = create_session(\n70:             pool_connections=pool_connections,\n71:             pool_maxsize=pool_maxsize,\n72:         )\n73: \n74:         logger.debug(\n75:             f\"AgentRuntimeDataPlaneClient initialized with \"\n76:             f\"base_url={self.base_url}, session_id={session_id}\"\n77:         )\n78: \n79:     def _request(\n80:         self,\n81:         method: str,\n82:         path: str,\n83:         **kwargs,\n84:     ) -> requests.Response:\n85:         \"\"\"\n86:         Make an HTTP request to the data plane.\n87: \n88:         Args:\n89:             method: HTTP method (GET, POST, etc.)\n90:             path: API path (appended to base_url)\n91:             **kwargs: Additional arguments passed to requests.Session.request\n92: \n93:         Returns:\n94:             The response object.\n95: \n96:         Raises:\n97:             DataPlaneError: If the request fails.\n98:         \"\"\"\n99:         url = urljoin(self.base_url, path)\n100: \n101:         headers = dict(self._headers)\n102:         headers.update(kwargs.pop(\"headers\", {}))\n103: \n104:         timeout = kwargs.pop(\"timeout\", None)\n105:         if timeout is None:\n106:             timeout = (self.connect_timeout, self.timeout)\n107:         elif isinstance(timeout, tuple):\n108:             pass\n109:         else:\n110:             timeout = (self.connect_timeout, timeout)\n111: \n112:         try:\n113:             response = self._session.request(\n114:                 method,\n115:                 url,\n116:                 headers=headers,\n117:                 timeout=timeout,\n118:                 **kwargs,\n119:             )\n120:             response.raise_for_status()\n121:             return response\n122: \n123:         except requests.RequestException as e:\n124:             logger.error(f\"Data plane request failed: {e}\")\n125:             raise DataPlaneError(f\"Data plane request failed: {e}\") from e\n126: \n127:     def bootstrap_session_id(self) -> str:\n128:         \"\"\"\n129:         Bootstrap a new session ID by making a GET request.\n130: \n131:         The server should set the x-agentcube-session-id header in the response.\n132: \n133:         Returns:\n134:             The session ID from the response headers.\n135: \n136:         Raises:\n137:             DataPlaneError: If the request fails or session ID is not in headers.\n138:         \"\"\"\n139:         response = self._request(\"GET\", \"\")\n140: \n141:         session_id = response.headers.get(self.SESSION_HEADER)\n142:         if not session_id:\n143:             raise DataPlaneError(\n144:                 f\"Bootstrap failed: {self.SESSION_HEADER} not found in response headers\"\n145:             )\n146: \n147:         self._session_id = session_id\n148:         self._headers[self.SESSION_HEADER] = session_id\n149:         logger.info(f\"Bootstrapped session ID: {session_id}\")\n150:         return session_id\n151: \n152:     def invoke(\n153:         self,\n154:         session_id: str,\n155:         payload: Dict[str, Any],\n156:         timeout: Optional[Union[int, float]] = None,\n157:     ) -> requests.Response:\n158:         \"\"\"\n159:         Invoke an Agent Runtime with the given payload.\n160: \n161:         Args:\n162:             session_id: The session ID to use for this invocation.\n163:             payload: The JSON payload to send to the Agent Runtime.\n164:             timeout: Timeout in seconds. If None, uses the default timeout.\n165: \n166:         Returns:\n167:             The response object from the Agent Runtime.\n168: \n169:         Raises:\n170:             DataPlaneError: If the invocation fails.\n171:         \"\"\"\n172:         headers = dict(self._headers)\n173:         headers[self.SESSION_HEADER] = session_id\n174: \n175:         effective_timeout = timeout\n176:         if timeout is None:\n177:             effective_timeout = (self.connect_timeout, self.timeout)\n178:         elif isinstance(timeout, (int, float)):\n179:             effective_timeout = (self.connect_timeout, timeout)\n180: \n181:         response = self._request(\n182:             \"POST\",\n183:             \"\",\n184:             json=payload,\n185:             headers=headers,\n186:             timeout=effective_timeout,\n187:         )\n188: \n189:         return response\n190: \n191:     def close(self) -> None:\n192:         \"\"\"Close the HTTP session.\"\"\"\n193:         self._session.close()\n194:         logger.debug(\"AgentRuntimeDataPlaneClient session closed\")\n\n(End of file - total 194 lines)\n</content>","metadata":{"preview":"\"\"\"Agent Runtime Data Plane client for AgentCube SDK.\"\"\"\n\nfrom typing import Any, Dict, Optional, Union\nfrom 