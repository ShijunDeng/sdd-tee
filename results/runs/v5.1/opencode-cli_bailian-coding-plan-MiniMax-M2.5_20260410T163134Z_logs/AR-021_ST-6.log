             header_list=header_list,\n444:                 provider=provider,\n445:                 verbose=verbose,\n446:             )\n447: \n448:             progress.update(task, completed=True)\n449: \n450:         console.print(\n451:             Panel(\n452:                 f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n453:                 f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n454:                 f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n455:                 f\"[bold]Response:[/bold]\",\n456:                 title=\"Invoke Complete\",\n457:                 style=\"green\",\n458:             )\n459:         )\n460: \n461:         import json\n462: \n463:         console.print_json(json.dumps(result[\"response\"], indent=2))\n464: \n465:     except Exception as e:\n466:         _handle_error(e, \"invoke\", verbose)\n467:         raise typer.Exit(code=1)\n468: \n469: \n470: @app.command()\n471: def status(\n472:     workspace: str = typer.Option(\n473:         \".\",\n474:         \"-f\",\n475:         \"--workspace\",\n476:         help=\"Path to the agent workspace directory\",\n477:     ),\n478:     provider: str = typer.Option(\n479:         \"agentcube\",\n480:         \"--provider\",\n481:         help=\"Target provider: 'agentcube' or 'k8s'\",\n482:     ),\n483:     verbose: bool = typer.Option(\n484:         False,\n485:         \"--verbose\",\n486:         help=\"Enable detailed logging\",\n487:     ),\n488: ) -> None:\n489:     \"\"\"\n490:     Check the status of a published agent.\n491: \n492:     Loads workspace metadata and displays agent status in a table.\n493:     \"\"\"\n494:     try:\n495:         if verbose:\n496:             logging.basicConfig(level=logging.DEBUG)\n497: \n498:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n499: \n500:         result = runtime.get_status(\n501:             workspace_path=workspace,\n502:             provider=provider,\n503:         )\n504: