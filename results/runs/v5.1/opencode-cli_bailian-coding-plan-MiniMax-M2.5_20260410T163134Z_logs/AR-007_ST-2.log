      cfg,\n57: \t\tworkloadMgr: workloadMgr,\n58: \t\tstopCh:      make(chan struct{}),\n59: \t}\n60: \n61: \trouter.Use(gin.Recovery())\n62: \trouter.Use(server.loggingMiddleware())\n63: \trouter.Use(server.corsMiddleware())\n64: \n65: \trouter.GET(\"/healthz\", server.handleHealthz)\n66: \trouter.GET(\"/readyz\", server.handleReadyz)\n67: \n68: \tapi := router.Group(\"/api/v1\")\n69: \t{\n70: \t\tapi.GET(\"/namespaces/:namespace/agentruntimes\", server.handleListAgentRuntimes)\n71: \t\tapi.POST(\"/namespaces/:namespace/agentruntimes\", server.handleCreateAgentRuntime)\n72: \t\tapi.GET(\"/namespaces/:namespace/agentruntimes/:name\", server.handleGetAgentRuntime)\n73: \t\tapi.PUT(\"/namespaces/:namespace/agentruntimes/:name\", server.handleUpdateAgentRuntime)\n74: \t\tapi.DELETE(\"/namespaces/:namespace/agentruntimes/:name\", server.handleDeleteAgentRuntime)\n75: \t\tapi.GET(\"/namespaces/:namespace/agentruntimes/:name/status\", server.handleGetAgentRuntimeStatus)\n76: \t\tapi.PATCH(\"/namespaces/:namespace/agentruntimes/:name/status\", server.handlePatchAgentRuntimeStatus)\n77: \n78: \t\tapi.GET(\"/namespaces/:namespace/codeinterpreters\", server.handleListCodeInterpreters)\n79: \t\tapi.POST(\"/namespaces/:namespace/codeinterpreters\", server.handleCreateCodeInterpreter)\n80: \t\tapi.GET(\"/namespaces/:namespace/codeinterpreters/:name\", server.handleGetCodeInterpreter)\n81: \t\tapi.PUT(\"/namespaces/:namespace/codeinterpreters/:name\", server.handleUpdateCodeInterpreter)\n82: \t\tapi.DELETE(\"/namespaces/:namespace/codeinterpreters/:name\", server.handleDeleteCodeInterpreter)\n83: \t\tapi.GET(\"/namespaces/:namespace/codeinterpreters/:name/status\", server.handleGetCodeInterpreterStatus)\n84: \t\tapi.PATCH(\"/namespaces/:namespace/codeinterpreters/:name/status\", server.handlePatchCodeInterpreterStatus)\n85: \n86: \t\tapi.GET(\"/namespaces/:namespace/sandboxes\", server.handleListSandboxes)\n87: \t\tapi.DELETE(\"/namespaces/:namespace/sandboxes\", server.handleDeleteAllSandboxes)\n88: \t\tapi.DELETE(\"/namespaces/:namespace/sandboxes/:sessionId\", server.handleDeleteSandbox)\n89: \t}\n90: \n91: \tserver.httpServer = &http.Server{\n92: \t\tAddr:    fmt.Sprintf(\":%d\", cfg.Port),\n93: \t\tHandler: router,\n94: \t}\n95: \n96: \treturn server\n97: }\n98: \n99: func (s *Server) Start() error {\n100: \tklog.InfoS(\"Starting HTTP server\", \"port\", s.config.Port)\n101: \n102: \tln, err := net.Listen(\"tcp\", fmt.Sprintf(\":%d\", s.config.Port))\n103: \tif err != nil {\n104: \t\treturn fmt.Errorf(\"failed to listen on port %d: %w\", s.config.Port, err)\n105: \t}\n106: \n107: \tgo func() {\n108: \t\tif err := s.httpServer.Serve(ln); err != nil && err != http.ErrServerClosed {\n109: \t\t\tklog.ErrorS(err, \"HTTP server error\")\n110: \t\t}\n111: \t}()\n112: \n113: \ts.SetReady(true)\n114: \tklog.InfoS(\"HTTP server started\", \"port\", s.config.Port)\n115: \treturn nil\n116: }\n117: \n118: func (s *Server) Stop() error {\n119: \tklog.Info(\"Shutting down HTTP server...\")\n120: \ts.SetReady(false)\n121: \n122: \tctx, cancel := context.WithTimeout(context.Background(), s.config.ShutdownTimeout)\n123: \tdefer cancel()\n124: \n125: \tif err := s.httpServer.Shutdown(ctx); err != nil {\n126: \t\treturn fmt.Errorf(\"failed to shutdown HTTP server: %w\", err)\n127: \t}\n128: \n129: \tif s.workloadMgr != nil {\n130: \t\ts.workloadMgr.Close()\n131: \t}\n132: \n133: \tklog.Info(\"HTTP server stopped\")\n134: \treturn nil\n135: }\n136: \n137: func (s *Server) Run() error {\n138: \tif err := s.Start(); err != nil {\n139: \t\treturn err\n140: \t}\n141: \n142: \tsigCh := make(chan os.Signal, 1)\n143: \tsignal.Notify(sigCh, os.Interrupt, os.Kill)\n144: \n145: \t<-sigCh\n146: \tklog.Info(\"Received shutdown signal\")\n147: \n148: \treturn s.Stop()\n149: }\n150: \n151: func (s *Server) SetReady(ready bool) {\n152: \ts.mu.Lock()\n153: \tdefer s.mu.Unlock()\n154: \ts.ready = ready\n155: }\n156: \n157: func (s *Server) IsReady() bool {\n158: \ts.mu.RLock()\n159: \tdefer s.mu.RUnlock()\n160: \treturn s.ready\n161: }\n162: \n163: func (s *Server) loggingMiddleware() gin.HandlerFunc {\n164: \treturn func(c *gin.Context) {\n165: \t\tstart := time.Now()\n166: \t\tpath := c.Request.URL.Path\n167: \t\tmethod := c.Request.Method\n168: \n169: \t\tc.Next()\n170: \n171: \t\tlatency := time.Since(start)\n172: \t\tstatus := c.Writer.Status()\n173: \n174: \t\tif status >= 500 {\n175: \t\t\tklog.ErrorS(nil, \"Request completed with error\",\n176: \t\t\t\t\"method\", method,\n177: \t\t\t\t\"path\", path,\n178: \t\t\t\t\"status\", status,\n179: \t\t\t\t\"latency\", latency)\n180: \t\t} else {\n181: \t\t\tklog.V(4).InfoS(\"Request completed\",\n182: \t\t\t\t\"method\", method,\n183: \t\t\t\t\"path\", path,\n184: \t\t\t\t\"status\", status,\n185: \t\t\t\t\"latency\", latency)\n186: \t\t}\n187: \t}\n188: }\n189: \n190: func (s *Server) corsMiddleware() gin.HandlerFunc {\n191: \treturn func(c *gin.Context) {\n192: \t\tc.Header(\"Access-Control-Allow-Origin\", \"*\")\n193: \t\tc.Header(\"Access-Control-Allow-Methods\", \"GET, POST, PUT, DELETE, PATCH, OPTIONS\")\n194: \t\tc.Header(\"Access-Control-Allow-Headers\", \"Content-Type, Authorization\")\n195: \n196: \t\tif c.Request.Method == \"OPTIONS\" {\n197: \t\t\tc.AbortWithStatus(http.StatusNoContent)\n198: \t\t\treturn\n199: \t\t}\n200: \n201: \t\tc.Next()\n202: \t}\n203: }\n204: \n205: func (s *Server) handleHealthz(c *gin.Context) {\n206: \tc.String(http.StatusOK, \"ok\")\n207: }\n208: \n209: func (s *Server) handleReadyz(c *gin.Context) {\n210: \tif s.IsReady() {\n211: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n212: \t} else {\n213: \t\tc.JSON(http.StatusServiceUnavailable, gin.H{\"status\": \"not ready\"})\n214: \t}\n215: }\n216: \n217: func (s *Server) handleListAgentRuntimes(c *gin.Context) {\n218: \tnamespace := c.Param(\"namespace\")\n219: \n220: \topts := metav1.ListOptions{}\n221: \tif err := c.ShouldBindQuery(&opts); err != nil {\n222: \t\tc.JSON(http.StatusBadR