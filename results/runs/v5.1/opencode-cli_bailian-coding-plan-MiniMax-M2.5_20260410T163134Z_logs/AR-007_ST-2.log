\t}\n399: }\n400: \n401: func TestWorkloadManagerWatchAgentRuntimes(t *testing.T) {\n402: \twm := newTestWorkloadManager()\n403: \tctx := context.Background()\n404: \n405: \twatcher, err := wm.WatchAgentRuntimes(ctx, \"default\", metav1.ListOptions{})\n406: \tif err != nil {\n407: \t\tt.Errorf(\"WatchAgentRuntimes failed: %v\", err)\n408: \t}\n409: \n410: \tif watcher == nil {\n411: \t\tt.Error(\"Expected watcher to be non-nil\")\n412: \t}\n413: }\n414: \n415: func TestWorkloadManagerCreateCodeInterpreter(t *testing.T) {\n416: \twm := newTestWorkloadManager()\n417: \tctx := context.Background()\n418: \n419: \tci := &agentcubev1alpha1.CodeInterpreter{\n420: \t\tObjectMeta: metav1.ObjectMeta{\n421: \t\t\tName:      \"test-ci\",\n422: \t\t\tNamespace: \"default\",\n423: \t\t},\n424: \t\tSpec: agentcubev1alpha1.CodeInterpreterSpec{\n425: \t\t\tMaxSessionDuration: \"8h\",\n426: \t\t\tSessionTimeout:     \"15m\",\n427: \t\t\tTemplate: agentcubev1alpha1.ContainerTemplateSpec{\n428: \t\t\t\tImage: \"python:3.9\",\n429: \t\t\t},\n430: \t\t},\n431: \t}\n432: \n433: \tresult, err := wm.CreateCodeInterpreter(ctx, \"default\", ci, metav1.CreateOptions{})\n434: \tif err != nil {\n435: \t\tt.Errorf(\"CreateCodeInterpreter failed: %v\", err)\n436: \t}\n437: \n438: \tif result.Name != \"test-ci\" {\n439: \t\tt.Errorf(\"Expected name test-ci, got %s\", result.Name)\n440: \t}\n441: }\n442: \n443: func TestWorkloadManagerGetCodeInterpreter(t *testing.T) {\n444: \twm := newTestWorkloadManager()\n445: \tctx := context.Background()\n446: \n447: \tci := &agentcubev1alpha1.CodeInterpreter{\n448: \t\tObjectMeta: metav1.ObjectMeta{\n449: \t\t\tName:      \"test-ci\",\n450: \t\t\tNamespace: \"default\",\n451: \t\t},\n452: \t\tSpec: agentcubev1alpha1.CodeInterpreterSpec{\n453: \t\t\tTemplate: agentcubev1alpha1.ContainerTemplateSpec{\n454: \t\t\t\tImage: \"python:3.9\",\n455: \t\t\t},\n456: \t\t},\n457: \t}\n458: \n459: \t_, err := wm.CreateCodeInterpreter(ctx, \"default\", ci, metav1.CreateOpti