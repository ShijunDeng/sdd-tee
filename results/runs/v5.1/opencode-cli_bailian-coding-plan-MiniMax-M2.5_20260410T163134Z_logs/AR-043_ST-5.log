ion token for the Workload Manager.\n42:             name: Name of the session/agent (default: \"my-interpreter\").\n43:             namespace: Kubernetes namespace (default: \"default\").\n44:             ttl: Time to live in seconds (default: 3600).\n45:             verbose: Enable verbose logging (default: False).\n46:             session_id: Existing session ID to reuse. If None, a new session\n47:                        will be created.\n48: \n49:         Raises:\n50:             ValueError: If router_url is not provided and ROUTER_URL env var\n51:                        is not set.\n52:         \"\"\"\n53:         self.router_url = router_url or os.environ.get(\"ROUTER_URL\")\n54:         if not self.router_url:\n55:             raise ValueError(\n56:                 \"router_url must be provided via argument or \"\n57:                 \"ROUTER_URL environment variable must be set\"\n58:             )\n59: \n60:         self.workload_manager_url = workload_manager_url\n61:         self.auth_token = auth_token\n62:         self.name = name\n63:         self.namespace = namespace\n64:         self.ttl = ttl\n65:         self.verbose = verbose\n66:         self._session_id_provided = session_id is not None\n67: \n68:         self._control_plane_client: Optional[ControlPlaneClient] = None\n69:         self._data_plane_client: Optional[CodeInterpreterDataPlaneClient] = None\n70: \n71:         if session_id:\n72:             self._session_id = session_id\n73:             logger.info(f\"Reusing existing session: {session_id}\")\n74:             self._init_data_plane()\n75:         else:\n76:             self._session_id = self._create_session()\n77: \n78:     def _create_session(self) -> str:\n79:         \"\"\"Create a new session via the control plane.\"\"\"\n80:         self._control_plane_client = ControlPlaneClient(\n81:             workload_manager_url=self.workload_manager_url,\n82:             auth_token=self.auth_token,\n83:         )\n84: \n85:         session_id = self._control_plane_client.create_session(\n86:             name=self.name,\n87:             namespace=self.namespace,\n88:             ttl=self.ttl,\n89:         )\n90: \n91:         return session_id\n92: \n93:     def _init_data_plane(self) -> None:\n94:         \"\"\"Initialize the data plane client.\"\"\"\n95:         try:\n96:             self._data_plane_client = CodeInterpreterDataPlaneClient(\n97:                 router_url=self.router_url,\n98:                 namespace=self.namespace,\n99:                 cr_name=self.name,\n100:                 session_id=self._session_id,\n101:             )\n102:             logger.info(f\"Data plane initialized for session: {self._session_id}\")\n103:         except Exception as e:\n104:             logger.error(f\"Failed to initialize data plane: {e}\")\n105:             if not self._session_id_provided and self._control_plane_client:\n106:                 logger.warning(f\"Data plane init failed, cleaning up session {self._session_id}\")\n107:                 self._control_plane_client.delete_session(self._session_id)\n108:                 self._session_id = None\n109:             raise\n110: \n111:     def execute_command(\n112:         self,\n113:         command: str,\n114:         timeout: Optional[int] = None,\n115:     ) -> Dict:\n116:         \"\"\"\n117:         Execute a command in the Code Interpreter.\n118: \n119:         Args:\n120:             command: The command to execute.\n121:             timeout: Timeout in seconds. If None, uses the default.\n122: \n123:         Returns:\n124:             A dictionary containing the response data.\n125: \n126:         Raises:\n127:             CommandExecutionError: If the command returns a non-zero exit code.\n128:             DataPlaneError: If the execution fails.\n129:         \"\"\"\n130:         if not self._data_plane_client:\n131:             raise DataPlaneError(\"Data plane not initialized\")\n132: \n133:         response = self._data_plane_client.execute_command(command, timeout=timeout)\n134: \n135:         exit_code = response.get(\"exit_code\")\n136:         if exit_code != 0:\n137:             stderr = response.get(\"stderr\", \"\")\n138:             raise CommandExecutionError(\n139:                 f\"Command failed with exit code {exit_code}\",\n140:                 exit_code=exit_code,\n141:                 stderr=stderr,\n142:                 command=command,\n143:             )\n144: \n145:         return response\n146: \n147:     def run_code(\n148:         self,\n149:         code: str,\n150:         language: str = \"python\",\n151:         timeout: Optional[int] = None,\n152:     ) -> Dict:\n153:         \"\"\"\n154:         Run code in the Code Interpreter.\n155: \n156:         For Python, writes a timestamped .py file and executes it.\n157: \n158:         Args:\n159:             code: The code to run.\n160:             language: Programming language (python, py, python3, etc.)\n161:             timeout: Timeout in seconds.\n162: \n163:         Returns:\n164:             A dictionary containing the response data.\n165: \n166:         Raises:\n167:             CommandExecutionError: If the code returns a non-zero exit code.\n168:             DataPlaneError: If the execution fails.\n169:         \"\"\"\n170:         normalized_lang = language.lower()\n171:         if normalized_lang in (\"python\", \"py\", \"python3\"):\n172:             timestamp = int(time.time() * 1000)\n173:             remote_path = f\"/tmp/script_{timestamp}.py\"\n174: \n175:             self.write_file(code, remote_path)\n176: \n177:             command = f\"python3 {remote_path}\"\n178:             return self.execute_command(command, timeout=timeout)\n179:         else:\n180:             raise ValueError(f\"Unsupported language: {language}\")\n181: \n182:     def write_file(\n183:         self,\n184:         content: str,\n185:         remote_path: str,\n186:         mode: str = \"0644\",\n187:     ) -> Dict:\n188:         \"\"\"\n189:         Write a file to the Code Interpreter.\n190: \n191:         Args:\n192:             content: The file content.\n193:             remote_path: The remote path where the file will be written.\n194:             mode: File permissions (default: 0644).\n195: \n196:         Returns:\n197:             A dictionary containing the response data.\n198: \n199:         Raises:\n200:             DataPlaneError: If the write fails.\n201:         \"\"\"\n202:         if not self._data_plane_client:\n203:             raise DataPlaneError(\"Data plane not initialized\")\n204: \n205:         return self._data_plane_client.write_file(content, remote_path, mode)\n206: \n207:     def upload_file(\n208:         self,\n209:         local_path: str,\n210:         remote_path: str,\n211:     ) -> Dict:\n212:         \"\"\"\n213:         Upload a file to the Code Interpreter.\n214: \n215:         Args:\n216:             local_path: Path to the local file.\n217:             remote_path: The remote path where the file will be written.\n218: \n219:         Returns:\n220:             A dictionary containing the response data.\n221: \n222:         Raises:\n223:             DataPlaneError: If the upload fails.\n224:         \"\"\"\n225:         if not self._data_plane_client:\n226:             raise DataPlaneError(\"Data plane not initialized\")\n227: \n228:         return self._data_plane_client.upload_file(local_path, remote_path)\n229: \n230:     def download_file(\n231:         self,\n232:         remote_path: str,\n233:         local_path: str,\n234:     ) -> None:\n235:         \"\"\"\n236:         Download a file from the Code Interpreter.\n237: \n238:         Args:\n239:             remote_path: The remote path of the file to download.\n240:             local_path: The local path where the file will be saved.\n241: \n242:         Raises:\n243:             DataPlaneError: If the download fails.\n244:         \"\"\"\n245:         if not self._data_plane_client:\n246:             raise DataPlaneError(\"Data plane not initialized\")\n247: \n248:         self._data_plane_client.download_file(remote_path, local_path)\n249: \n250:     def list_files(self, path: str = \".\") -> Dict:\n251:         \"\"\"\n252:         List files in the Code Interpreter.\n253: \n254:         Args:\n255:             path: The path to list (default: \".\").\n256: \n257:         Returns:\n258:             A dictionary containing the file listing.\n259: \n260:         Raises:\n261:             DataPlaneError: If the list fails.\n262:         \"\"\"\n263:         if not self._data_plane_client:\n264:             raise DataPlaneError(\"Data plane not initialized\")\n265: \n266:         return self._data_plane_client.list_files(path)\n267: \n268:     def stop(self) -> None:\n269:         \"\"\"\n270:         Stop the Code Interpreter session.\n271: \n272:         Closes the data plane and deletes the control plane session\n273:         if a new session was created.\n274:         \"\"\"\n275:         if self._data_plane_client:\n276:             try:\n277:                 self._data_plane_client.close()\n278:             except Exception as e:\n279:                 logger.warning(f\"Error closing data plane: {e}\")\n280:             finally:\n281:                 self._data_plane_client = None\n282: \n283:         if self._control_plane_client and self._session_id:\n284:             if self._session_id_provided:\n285:                 logger.info(\"Session was provided by user, not deleting\")\n286:             else:\n287:                 try:\n288:                     self._control_plane_client.delete_session(self._session_id)\n289:                 except Exception as e:\n290:                     logger.warning(f\"Error deleting session: {e}\")\n291:                 finally:\n292:                     self._session_id = None\n293: \n294:         if self._control_plane_client:\n295:             try:\n296:                 self._control_plane_client.close()\n297:             except Exception as e:\n298:                 logger.warning(f\"Error closing control plane: {e}\")\n299:             finally:\n300:                 self._control_plane_client = None\n301: \n302:         logger.info(\"CodeInterpreterClient stopped\")\n303: \n304:     def __enter__(self) -> \"CodeInterpreterClient\":\n305:         \"\"\"Enter the context manager.\"\"\"\n306:         return self\n307: \n308:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n309:         \"\"\"Exit the context manager.\"\"\"\n310:         self.stop()\n311: \n312:     @property\n313:     def session_id(self) -> Optional[str]:\n314:         \"\"\"Get the current session ID.\"\"\"\n315:         return self._session_id\n\n(End of file - total 315 lines)\n</content>","metadata":{"preview":"\"\"\"CodeInterpreterClient for AgentCube SDK.\"\"\"\n\nimport os\nimport time\nfrom typing import Dict, Optional\n\nfrom agentcube.clients import (\n    CodeInterpreterDataPlaneClient,\n    ControlPlaneClient,\n)\nfrom agentcube.exceptions import (\n    CommandExecutionError,\n    DataPlaneError,\n)\nfrom agentcube.utils.log import get_logger\n\nlogger = get_logger(__name__)\n\n\nclass CodeInterpreterClient:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/code_interpreter.py","time":{"start":1775887572152,"end":1775887572165}}}}
