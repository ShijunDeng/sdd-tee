163134Z/agentcube/services/agentcube_provider.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/exceptions.py":[]},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/docs/docs/api/sdk-services.md","exists":false,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/docs/docs/api/sdk-services.md","time":{"start":1775887908607,"end":1775887908612}}}}
