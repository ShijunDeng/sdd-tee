callback for global options.\"\"\"\n45:     if verbose:\n46:         logging.basicConfig(level=logging.DEBUG)\n47: \n48:     if version:\n49:         console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n50:         raise typer.Exit()\n51: \n52: \n53: def version_callback(value: bool) -> None:\n54:     \"\"\"Callback for --version option.\"\"\"\n55:     if value:\n56:         console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n57:         raise typer.Exit()\n58: \n59: \n60: def _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n61:     \"\"\"\n62:     Handle and format error output.\n63: \n64:     Args:\n65:         e: Exception that was raised\n66:         command_name: Name of the command\n67:         verbose: Enable verbose error output\n68:     \"\"\"\n69:     error_msg = str(e)\n70: \n71:     if verbose:\n72:         import traceback\n73: \n74:         console.print(\n75:             Panel(\n76:                 f\"[bold red]Error in {command_name}:[/bold red]\\n\\n{error_msg}\\n\\n[red]{traceback.format_exc()}[/red]\",\n77:                 style=\"red\",\n78:             )\n79:         )\n80:     else:\n81:         console.print(f\"[bold red]Error:[/bold red] {error_msg}\")\n82: \n83: \n84: @app.command()\n85: def pack(\n86:     workspace: str = typer.Option(\n87:         \".\",\n88:         \"-f\",\n89:         \"--workspace\",\n90:         help=\"Path to agent workspace\",\n91:     ),\n92:     agent_name: Optional[str] = typer.Option(\n93:         None,\n94:         \"--agent-name\",\n95:         help=\"Override agent name\",\n96:     ),\n97:     language: Optional[str] = typer.Option(\n98:         None,\n99:         \"--language\",\n100:         help=\"Programming language (python, java)\",\n101:     ),\n102:     entrypoint: Optional[str] = typer.Option(\n103:         None,\n104:         \"--entrypoint\",\n105:         help=\"Override entrypoint command\",\n106:     ),\n107:     port: Optional[int] = typer.Option(\n108:         None,\n109:         \"--port\",\n110:         help=\"Port to expose (default: 8080)\",\n111:     ),\n112:     build_mode: Optional[str] = typer.Option(\n113:         None,\n114:         \"--build-mode\",\n115:         help=\"Build strategy (local, cloud)\",\n116:     ),\n117:     description: Optional[str] = typer.Option(\n118:         None,\n119:         \"--description\",\n120:         help=\"Agent description\",\n121:     ),\n122:     output: Optional[str] = typer.Option(\n123:         None,\n124:         \"--output\",\n125:         help=\"Output path for packaged workspace\",\n126:     ),\n127:     verbose: bool = typer.Option(\n128:         False,\n129:         \"--verbose\",\n130:         help=\"Enable detailed logging\",\n131:     ),\n132:     version: bool = typer.Option(\n133:         None,\n134:         \"--version\",\n135:         help=\"Show version information\",\n136:         callback=version_callback,\n137:         is_eager=True,\n138:     ),\n139: ) -> None:\n140:     \"\"\"\n141:     Pack an agent workspace for deployment.\n142: \n143:     Validates the workspace structure, loads or creates agent metadata,\n144:     processes dependencies, optionally generates a Dockerfile, and\n145:     prepares the workspace for subsequent build and publish steps.\n146:     \"\"\"\n147:     try:\n148:         if verbose:\n149:             logging.basicConfig(level=logging.DEBUG)\n150: \n151:         with Progress(\n152:             SpinnerColumn(),\n153:             TextColumn(\"[progress.description]{task.description}\"),\n154:             console=console,\n155:         ) as progress:\n156:             task = progress.add_task(\"Packing agent workspace...\", total=None)\n157: \n158:             runtime = PackRuntime(verbose=verbose)\n159: \n160:             result = runtime.pack(\n161:                 workspace_path=workspace,\n162:                 agent_name=agent_name,\n163:                 language=language,\n164:                 entrypoint=entrypoint,\n165:                 port=port,\n166:                 build_mode=build_mode,\n167:                 description=description,\n168:                 output=output,\n169:                 verbose=verbose,\n170:             )\n171: \n172:             progress.update(task, completed=True)\n173: \n174:         console.print(\n175:             Panel(\n176:                 f\"[bold green]Agent packed successfully![/bold green]\\n\\n\"\n177:                 f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n178:                 f\"[bold]Workspace:[/bold] {result['workspace_path']}\\n\"\n179:                 f\"[bold]Output:[/bold] {result['output_path']}\\n\"\n180:                 f\"[bold]Metadata:[/bold] {result['metadata_file']}\\n\"\n181:                 f\"[bold]Dockerfile:[/bold] {'Generated' if result['dockerfile_generated'] else 'Existing'}\",\n182:                 title=\"Pack Complete\",\n183:                 style=\"green\",\n184:             )\n185:         )\n186: \n187:     except Exception as e:\n188:         _handle_error(e, \"pack\", verbose)\n189:         raise typer.Exit(code=1)\n190: \n191: \n192: @app.command()\n193: def build(\n194:     workspace: str = typer.Option(\n195:         \".\",\n196:         \"-f\",\n197:         \"--workspace\",\n198:         help=\"Path to the agent workspace directory\",\n199:     ),\n200:     proxy: Optional[str] = typer.Option(\n201:         None,\n202:         \"-p\",\n203:         \"--proxy\",\n204:         help=\"Custom proxy URL for dependency resolution\",\n205:     ),\n206:     cloud_provider: Optional[str] = typer.Option(\n207:         None,\n208:         \"--cloud-provider\",\n209:         help=\"Cloud provider name (e.g., huawei)\",\n210:     ),\n211:     output: Optional[str] = typer.Option(\n212:         None,\n213:         \"--output\",\n214:         help=\"Output path for build artifacts\",\n215:     ),\n216:     verbose: bool = typer.Option(\n217:         False,\n218:         \"--verbose\",\n219:         help=\"Enable detailed logging\",\n220:     ),\n221: ) -> None:\n222:     \"\"\"\n223:     Build a container image from a packed workspace.\n224: \n225:     Builds a Docker image from the packed workspace using local Docker\n226:     when build_mode is local, or cloud build when build_mode is cloud.\n227:     \"\"\"\n228:     try:\n229:         if verbose:\n230:             logging.basicConfig(level=logging.DEBUG)\n231: \n232:         with Progress(\n233:             SpinnerColumn(),\n234:             TextColumn(\"[progress.description]{task.description}\"),\n235:             console=console,\n236:         ) as progress:\n237:             task = progress.add_task(\"Building agent image...\", total=None)\n238: \n239:             runtime = BuildRuntime(verbose=verbose)\n240: \n241:             result = runtime.build(\n242:                 workspace_path=workspace,\n243:                 proxy=proxy,\n244:                 cloud_provider=cloud_provider,\n245:                 output=output,\n246:                 verbose=verbose,\n247:             )\n248: \n249:             progress.update(task, completed=True)\n250: \n251:         console.print(\n252:             Panel(\n253:                 f\"[bold green]Agent built successfully![/bold green]\\n\\n\"\n254:                 f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n255:                 f\"[bold]Image:[/bold] {result['image_name']}:{result['image_tag']}\\n\"\n256:                 f\"[bold]Image ID:[/bold] {result['image_id'][:12]}\\n\"\n257:                 f\"[bold]Version:[/bold] {result['version']}\",\n258:                 title=\"Build Complete\",\n259:                 style=\"green\",\n260:             )\n261:         )\n262: \n263:     except Exception as e:\n264:         _handle_error(e, \"build\", verbose)\n265:         raise typer.Exit(code=1)\n266: \n267: \n268: @app.command()\n269: def publish(\n270:     workspace: str = typer.Option(\n271:         \".\",\n272:         \"-f\",\n273:         \"--workspace\",\n274:         help=\"Path to the agent workspace directory\",\n275:     ),\n276:     version: Optional[str] = typer.Option(\n277:         None,\n278:         \"--version\",\n279:         help=\"Semantic version string (e.g., v1.0.0)\",\n280:     ),\n281:     image_url: Optional[str] = typer.Option(\n282:         None,\n283:         \"--image-url\",\n284:         help=\"Image repository URL\",\n285:     ),\n286:     image_username: Optional[str] = typer.Option(\n287:         None,\n288:         \"--image-username\",\n289:         help=\"Username for image repository\",\n290:     ),\n291:     image_password: Optional[str] = typer.Option(\n292:         None,\n293:         \"--image-password\",\n294:         help=\"Password for image repository\",\n295:     ),\n296:     description: Optional[str] = typer.Option(\n297:         None,\n298:         \"--description\",\n299:         help=\"Agent description\",\n300:     ),\n301:     region: Optional[str] = typer.Option(\n302:         None,\n303:         \"--region\",\n304:         help=\"Deployment region\",\n305:     ),\n306:     cloud_provider: Optional[str] = typer.Option(\n307:         None,\n308:         \"--cloud-provider\",\n309:         help=\"Cloud provider name\",\n310:     ),\n311:     provider: str = typer.Option(\n312:         \"agentcube\",\n313:         \"--provider\",\n314:         help=\"Target provider: 'agentcube' or 'k8s'\",\n315:     ),\n316:     node_port: Optional[int] = typer.Option(\n317:         None,\n318:         \"--node-port\",\n319:         help=\"NodePort (30000-32767)\",\n320:     ),\n321:     replicas: Optional[int] = typer.Option(\n322:         None,\n323:         \"--replicas\",\n324:         help=\"Number of replicas\",\n325:     ),\n326:     namespace: Optional[str] = typer.Option(\n327:         None,\n328:         \"--namespace\",\n329:         help=\"Deployment namespace\",\n330:     ),\n331:     verbose: bool = typer.Option(\n332:         False,\n333:         \"--verbose\",\n334:         help=\"Enable detailed logging\",\n335:     ),\n336: ) -> None:\n337:     \"\"\"\n338:     Publish/deploy an agent to the target provider.\n339: \n340:     Deploys the agent to AgentCube (AgentRuntime CR) or Kubernetes\n341:     (Deployment + NodePort Service).\n342:     \"\"\"\n343:     try:\n344:         if verbose:\n345:             logging.basicConfig(level=logging.DEBUG)\n346: \n347:         with Progress(\n348:             SpinnerColumn(),\n349:             TextColumn(\"[progress.description]{task.description}\"),\n350:             console=console,\n351:         ) as progress:\n352:             task = progress.add_task(\"Publishing agent...\", total=None)\n353: \n354:             runtime = PublishRuntime(verbose=verbose, provider=provider)\n355: \n356:             result = runtime.publish(\n357:                 workspace_path=workspace,\n358:                 version=version,\n359:                 image_url=image_url,\n360:                 image_username=image_username,\n361:                 image_password=image_password,\n362:                 description=description,\n363:                 region=region,\n364:                 cloud_provider=cloud_provider,\n365:                 provider=provider,\n366:                 node_port=node_port,\n367:                 replicas=replicas,\n368:                 namespace=namespace,\n369:                 verbose=verbose,\n370:             )\n371: \n372:             progress.update(task, completed=True)\n373: \n374:         console.print(\n375:             Panel(\n376:                 f\"[bold green]Agent published successfully![/bold green]\\n\\n\"\n377:                 f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n378:                 f\"[bold]Provider:[/bold] {result['provider']}\\n\"\n379:                 f\"[bold]Endpoint:[/bold] {result['endpoint']}\\n\"\n380:                 f\"[bold]Status:[/bold] {result['status']}\",\n381:                 title=\"Publish Complete\",\n382:                 style=\"green\",\n383:             )\n384:         )\n385: \n386:     except Exception as e:\n387:         _handle_error(e, \"publish\", verbose)\n388:         raise typer.Exit(code=1)\n389: \n390: \n391: @app.command()\n392: def invoke(\n393:     workspace: str = typer.Option(\n394:         \".\",\n395:         \"-f\",\n396:         \"--workspace\",\n397:         help=\"Path to the agent workspace directory\",\n398:     ),\n399:     payload: str = typer.Option(\n400:         \"{}\",\n401:         \"--payload\",\n402:         help=\"JSON-formatted input passed to the agent\",\n403:     ),\n404:     header_list: Optional[list[str]] = typer.Option(\n405:         None,\n406:         \"--header\",\n407:         help=\"Custom HTTP headers (key:value format)\",\n408:     ),\n409:     provider: str = typer.Option(\n410:         \"agentcube\",\n411:         \"--provider\",\n412:         help=\"Target provider: 'agentcube' or 'k8s'\",\n413:     ),\n414:     verbose: bool = typer.Option(\n415:         False,\n416:         \"--verbose\",\n417:         help=\"Enable detailed logging\",\n418:     ),\n419: ) -> None:\n420:     \"\"\"\n421:     Invoke a published agent.\n422: \n423:     Posts JSON to the published agent endpoint and returns the response.\n424:     \"\"\"\n425:     try:\n426:         if verbose:\n427:             logging.basicConfig(level=logging.DEBUG)\n428: \n429:         with Progress(\n430:             SpinnerColumn(),\n431:             TextColumn(\"[progress.description]{task.description}\"),\n432:             console=console,\n433:         ) as progress:\n434:             task = progress.add_task(\"Invoking agent...\", total=None)\n435: \n436:             runtime = InvokeRuntime(verbose=verbose, provider=provider)\n437: \n438:             result = runtime.invoke(\n439:                 workspace_path=workspace,\n440:                 payload=payload,\n441:                 header_list=header_list,\n442:                 provider=provider,\n443:                 verbose=verbose,\n444:             )\n445: \n446:             progress.update(task, completed=True)\n447: \n448:         console.print(\n449:             Panel(\n450:                 f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n451:                 f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n452:                 f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n453:                 f\"[bold]Response:[/bold]\",\n454:                 title=\"Invoke Complete\",\n455:                 style=\"green\",\n456:             )\n457:         )\n458: \n459:         import json\n460: \n461:         console.print_json(json.dumps(result[\"response\"], indent=2))\n462: \n463:     except Exception as e:\n464:         _handle_error(e, \"invoke\", verbose)\n465:         raise typer.Exit(code=1)\n466: \n467: \n468: @app.command()\n469: def status(\n470:     workspace: str = typer.Option(\n471:         \".\",\n472:         \"-f\",\n473:         \"--workspace\",\n474:         help=\"Path to the agent workspace directory\",\n475:     ),\n476:     provider: str = typer.Option(\n477:         \"agentcube\",\n478:         \"--provider\",\n479:         help=\"Target provider: 'agentcube' or 'k8s'\",\n480:     ),\n481:     verbose: bool = typer.Option(\n482:         False,\n483:         \"--verbose\",\n484:         help=\"Enable detailed logging\",\n485:     ),\n486: ) -> None:\n487:     \"\"\"\n488:     Check the status of a published agent.\n489: \n490:     Loads workspace metadata and displays agent status in a table.\n491:     \"\"\"\n492:     try:\n493:         if verbose:\n494:             logging.basicConfig(level=logging.DEBUG)\n495: \n496:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n497: \n498:         result = runtime.get_status(\n499:             workspace_path=workspace,\n500:             provider=provider,\n501:         )\n502: \n503:         table = Table(title=f\"Agent Status: {result.get('agent_name', 'Unknown')}\")\n504: \n505:         table.add_column(\"Field\", style=\"cyan\")\n506:         table.add_column(\"Value\", style=\"green\")\n507: \n508:         table.add_row(\"Agent Name\", result.get(\"agent_name\", \"N/A\"))\n509:         table.add_row(\"Agent ID\", result.get(\"agent_id\", \"N/A\"))\n510:         table.add_row(\"Provider\", result.get(\"provider\", \"N/A\"))\n511:         table.add_row(\"Status\", result.get(\"status\", \"unknown\"))\n512:         table.add_row(\"Endpoint\", result.get(\"endpoint\", \"N/A\"))\n513:         table.add_row(\"Namespace\", result.get(\"namespace\", \"N/A\"))\n514: \n515:         if \"error\" in result:\n516:             table.add_row(\"Error\", result[\"error\"])\n517: \n518:         console.print(table)\n519: \n520:         if result.get(\"status\") in [\"not_published\", \"error\"]:\n521:             raise typer.Exit(code=1)\n522: \n523:     except Exception as e:\n524:         _handle_error(e, \"status\", verbose)\n525:         raise typer.Exit(code=1)\n526: \n527: \n528: @app.command()\n529: def version() -> None:\n530:     \"\"\"Show version information.\"\"\"\n531:     console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n532: \n533: \n534: if __name__ == \"__main__\":\n535:     app()\n\n(End of file - total 535 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube CLI - Main entry point for kubectl-agentcube.\"\"\"\n\nimport logging\nfrom typing import Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\nfrom rich.panel import Panel\nfrom rich.table import Table\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.runtime.invoke_runtime import InvokeRuntime\nfrom agentcube.runtime.status_runtime import StatusRuntime\n\napp = typer.Typer(\n    name=\"kubectl-agentcube\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py","time":{"start":1775887576250,"end":1775887576270}}}}
