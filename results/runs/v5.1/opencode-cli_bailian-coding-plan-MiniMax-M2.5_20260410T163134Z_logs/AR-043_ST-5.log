on.md#reportAttributeAccessIssue"}},{"range":{"start":{"line":144,"character":15},"end":{"line":144,"character":23}},"message":"Type \"str\" is not assignable to return type \"Dict[Unknown, Unknown]\"\n  \"str\" is not assignable to \"Dict[Unknown, Unknown]\"","severity":1,"code":"reportReturnType","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportReturnType"}}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/agentcube_provider.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/exceptions.py":[]},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/docs/docs/architecture/system-design.md","exists":false,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/docs/docs/architecture/system-design.md","time":{"start":1775887622503,"end":1775887622511}}}}
