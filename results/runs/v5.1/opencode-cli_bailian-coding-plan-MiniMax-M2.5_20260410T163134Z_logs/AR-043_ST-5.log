e/data-flow.md\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Create api/sdk-agent-runtime.md\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Create api/sdk-code-interpreter.md\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Create api/sdk-services.md\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Create api/sdk-runtime.md\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Create api/sdk-exceptions.md\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Create api/sdk-cli.md\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Update sidebars.ts with new sections\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Run tests to verify documentation structure\",\n    \"status\": \"pending\",\n    \"priority\": \"medium\"\n  }\n]","metadata":{"todos":[{"content":"Create architecture/system-design.md","status":"in_progress","priority":"high"},{"content":"Create architecture/client-sdk.md","status":"pending","priority":"high"},{"content":"Create architecture/services.md","status":"pending","priority":"high"},{"content":"Create architecture/runtime.md","status":"pending","priority":"high"},{"content":"Create architecture/data-flow.md","status":"pending","priority":"high"},{"content":"Create api/sdk-agent-runtime.md","status":"pending","priority":"high"},{"content":"Create api/sdk-code-interpreter.md","status":"pending","priority":"high"},{"content":"Create api/sdk-services.md","status":"pending","priority":"high"},{"content":"Create api/sdk-runtime.md","status":"pending","priority":"high"},{"content":"Create api/sdk-exceptions.md","status":"pending","priority":"high"},{"content":"Create api/sdk-cli.md","status":"pending","priority":"high"},{