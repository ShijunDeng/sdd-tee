{"type":"tool_use","timestamp":1775884145648,"sessionID":"ses_2850f95faffe2QPCyQtVTJLk1n","part":{"id":"prt_d7af18f230016UrQFjj5viscQK","messageID":"msg_d7af184ae001sX30EdqQ2z7voT","sessionID":"ses_2850f95faffe2QPCyQtVTJLk1n","type":"tool","tool":"read","callID":"toolu_5f351c5dab6948b69148060a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/agent_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/agent_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"AgentRuntimeClient for AgentCube SDK.\"\"\"\n2: \n3: import os\n4: from typing import Optional, Union\n5: \n6: import requests\n7: \n8: from agentcube.clients import AgentRuntimeDataPlaneClient\n9: from agentcube.exceptions import SessionError\n10: from agentcube.utils.http import (\n11:     DEFAULT_CONNECT_TIMEOUT,\n12:     DEFAULT_POOL_CONNECTIONS,\n13:     DEFAULT_POOL_MAXSIZE,\n14:     DEFAULT_TIMEOUT,\n15:     create_session,\n16: )\n17: from agentcube.utils.log import get_logger\n18: \n19: logger = get_logger(__name__)\n20: \n21: \n22: class AgentRuntimeClient:\n23:     \"\"\"Client for interacting with Agent Runtime through the Router.\"\"\"\n24: \n25:     def __init__(\n26:         self,\n27:         agent_name: str = \"my-agent\",\n28:         namespace: str = \"default\",\n29:         router_url: Optional[str] = None,\n30:         verbose: bool = False,\n31:         session_id: Optional[str] = None,\n32:         timeout: int = DEFAULT_TIMEOUT,\n33:         connect_timeout: float = DEFAULT_CONNECT_TIMEOUT,\n34:         pool_connections: int = DEFAULT_POOL_CONNECTIONS,\n35:         pool_maxsize: int = DEFAULT_POOL_MAXSIZE,\n36:     ):\n37:         \"\"\"\n38:         Initialize the AgentRuntimeClient.\n39: \n40:         Args:\n41:             agent_name: Name of the Agent Runtime (default: \"my-agent\").\n42:             namespace: Kubernetes namespace (default: \"default\").\n43:             router_url: Base URL of the Router service. If None, uses ROUTER_URL env var.\n44:             verbose: Enable verbose logging (default: False).\n45:             session_id: Existing session ID to reuse. If None, a new session\n46:                        will be bootstrapped via GET request.\n47:             timeout: Default read timeout in seconds (default: 120).\n48:             connect_timeout: Connection timeout in seconds (default: 5.0).\n49:             pool_connections: Number of connection pools to cache (default: 10).\n50:             pool_maxsize: Maximum number of connections per pool (default: 10).\n51: \n52:         Raises:\n53:             ValueError: If router_url is not provided and ROUTER_URL env var is not set.\n54:         \"\"\"\n55:         self.router_url = router_url or os.environ.get(\"ROUTER_URL\")\n56:         if not self.router_url:\n57:             raise ValueError(\n58:                 \"router_url must be provided via argument or \"\n59:                 \"ROUTER_URL environment variable must be set\"\n60:             )\n61: \n62:         self.agent_name = agent_name\n63:         self.namespace = namespace\n64:         self.verbose = verbose\n65:         self.timeout = timeout\n66:         self.connect_timeout = connect_timeout\n67:         self.pool_connections = pool_connections\n68:         self.pool_maxsize = pool_maxsize\n69: \n70:         self._session: requests.Session = create_session(\n71:             pool_connections=pool_connections,\n72:             pool_maxsize=pool_maxsize,\n73:         )\n74: \n75:         if session_id:\n76:             self._session_id = session_id\n77:             logger.info(f\"Reusing existing session: {session_id}\")\n78:         else:\n79:             self._session_id = self._bootstrap_session()\n80: \n81:         self.dp_client = AgentRuntimeDataPlaneClient(\n82:             router_url=self.router_url,\n83:             namespace=self.namespace,\n84:             agent_name=self.agent_name,\n85:             session_id=self._session_id,\n86:             timeout=self.timeout,\n87:             connect_timeout=self.connect_timeout,\n88:             pool_connections=self.pool_connections,\n89:             pool_maxsize=self.pool_maxsize,\n90:         )\n91: \n92:         logger.info(f\"AgentRuntimeClient initialized with session: {self._session_id}\")\n93: \n94:     def _bootstrap_session(self) -> str:\n95:         \"\"\"\n96:         Bootstrap a new session via GET request to the invocation endpoint.\n97: \n98:         Returns:\n99:             The session ID from the response header.\n100: \n101:         Raises:\n102:             ValueError: If the session header is missing from the response.\n103:         \"\"\"\n104:         base_url = f\"{self.router_url}/v1/namespaces/{self.namespace}/agent-runtimes/{self.agent_name}/invocations/\"\n105: \n106:         try:\n107:             response = self._session.get(\n108:                 base_url,\n109:                 timeout=(self.connect_timeout, self.timeout),\n110:             )\n111:             response.raise_for_status()\n112: \n113:             session_id = response.headers.get(\"x-agentcube-session-id\")\n114:             if not session_id:\n115:                 raise ValueError(\"Missing required response header: x-agentcube-session-id\")\n116: \n117:             logger.info(f\"Bootstrapped new session: {session_id}\")\n118:             return session_id\n119: \n120:         except requests.RequestException as e:\n121:             logger.error(f\"Session bootstrap failed: {e}\")\n122:             raise SessionError(f\"Session bootstrap failed: {e}\") from e\n123: \n124:     def invoke(\n125:         self,\n126:         payload: dict,\n127:         timeout: Optional[Union[int, tuple[float, float]]] = None,\n128:     ) -> dict:\n129:         \"\"\"\n130:         Invoke the Agent Runtime with the given payload.\n131: \n132:         Args:\n133:             payload: The JSON payload to send to the Agent Runtime.\n134:             timeout: Timeout in seconds or tuple of (connect_timeout, read_timeout).\n135:                     If None, uses the default timeout tuple (connect_timeout, self.timeout).\n136: \n137:         Returns:\n138:             A dictionary containing the response data.\n139: \n140:         Raises:\n141:             ValueError: If session_id is not initialized.\n142:             DataPlaneError: If the invocation fails.\n143:         \"\"\"\n144:         if not self._session_id:\n145:             raise ValueError(\"AgentRuntime session_id is not initialized\")\n146: \n147:         effective_timeout: Union[int, tuple[float, float]] = timeout\n148:         if timeout is None:\n149:             effective_timeout = (self.connect_timeout, self.timeout)\n150:         elif isinstance(timeout, int):\n151:             effective_timeout = (self.connect_timeout, timeout)\n152: \n153:         return self.dp_client.invoke(payload, timeout=effective_timeout)\n154: \n155:     def close(self) -> None:\n156:         \"\"\"Close the client and release resources.\"\"\"\n157:         if self.dp_client:\n158:             try:\n159:                 self.dp_client.close()\n160:             except Exception as e:\n161:                 logger.warning(f\"Error closing data plane client: {e}\")\n162:             finally:\n163:                 self.dp_client = None\n164: \n165:         if self._session:\n166:             try:\n167:                 self._session.close()\n168:             except Exception as e:\n169:                 logger.warning(f\"Error closing session: {e}\")\n170:             finally:\n171:                 self._session = None\n172: \n173:         logger.info(\"AgentRuntimeClient closed\")\n174: \n175:     def __enter__(self) -> \"AgentRuntimeClient\":\n176:         \"\"\"Enter the context manager.\"\"\"\n177:         return self\n178: \n179:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n180:         \"\"\"Exit the context manager.\"\"\"\n181:         self.close()\n182: \n183:     @property\n184:     def session_id(self) -> Optional[str]:\n185:         \"\"\"Get the current session ID.\"\"\"\n186:         return self._session_id\n\n(End of file - total 186 lines)\n</content>","metadata":{"preview":"\"\"\"AgentRuntimeClient for AgentCube SDK.\"\"\"\n\nimport os\nfrom typing import Optional, Union\n\nimport requests\n\nfrom agentcube.clients import AgentRuntimeDataPlaneClient\nfrom agentcube.exceptions import SessionError\nfrom agentcube.utils.http import (\n    DEFAULT_CONNECT_TIMEOUT,\n    DEFAULT_POOL_CONNECTIONS,\n    DEFAULT_POOL_MAXSIZE,\n    DEFAULT_TIMEOUT,\n    create_session,\n)\nfrom agentcube.utils.log import get_logger\n\nlogger = get_logger(__name__)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/agent_runtime.py","time":{"start":1775884145629,"end":1775884145645}}}}
