hmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/clients/code_interpreter_data_plane.py","before":"\"\"\"Code Interpreter Data Plane client for AgentCube SDK.\"\"\"\n\nimport base64\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional, Union\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom agentcube.exceptions import DataPlaneError\nfrom agentcube.utils.http import (\n    DEFAULT_CONNECT_TIMEOUT,\n    DEFAULT_POOL_CONNECTIONS,\n    DEFAULT_POOL_MAXSIZE,\n    DEFAULT_TIMEOUT,\n    create_session,\n)\nfrom agentcube.utils.log import get_logger\n\nlogger = get_logger(__name__)\n\n\nclass CodeInterpreterDataPlaneClient:\n    \"\"\"Client for interacting with the Router (data plane) for Code Interpreter.\"\"\"\n\n    def __init__(\n        self,\n        router_url: str,\n        namespace: str,\n        cr_name: str,\n        session_id: str,\n        base_url: Optional[str] = None,\n        timeout: int = DEFAULT_TIMEOUT,\n        connect_timeout: float = DEFAULT_CONNECT_TIMEOUT,\n        pool_connections: int = DEFAULT_POOL_CONNECTIONS,\n        pool_maxsize: int = DEFAULT_POOL_MAXSIZE,\n    ):\n        \"\"\"\n        Initialize the CodeInterpreterDataPlaneClient.\n\n        Args:\n            router_url: Base URL of the Router service.\n            namespace: Kubernetes namespace.\n            cr_name: Custom Resource name.\n            session_id: The session ID for this Code Interpreter.\n            base_url: Explicit base URL for API calls. If None, constructed\n                     from router_url, namespace, and cr_name.\n            timeout: Default read timeout in seconds.\n            connect_timeout: Connection timeout in seconds.\n            pool_connections: Number of connection pools to cache.\n            pool_maxsize: Maximum number of connections per pool.\n        \"\"\"\n        self.timeout = timeout\n        self.connect_timeout = connect_timeout\n\n        if base_url:\n            self.base_url = base_url\n        else:\n            self.base_url = urljoin(\n                router_url,\n                f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\",\n            )\n\n        self._session_id = session_id\n        self._headers: Dict[str, str] = {\n            \"x-agentcube-session-id\": session_id,\n        }\n\n        self._session = create_session(pool_connections=pool_connections, pool_maxsize=pool_maxsize)\n\n        logger.debug(\n            f\"CodeInterpreterDataPlaneClient initialized with \"\n            f\"base_url={self.base_url}, session_id={session_id}\"\n        )\n\n    def _request(\n        self,\n        method: str,\n        path: str,\n        **kwargs,\n    ) -> requests.Response:\n        \"\"\"\n        Make an HTTP request to the data plane.\n\n        Args:\n            method: HTTP method (GET, POST, etc.)\n            path: API path (appended to base_url)\n            **kwargs: Additional arguments passed to requests.Session.request\n\n        Returns:\n            The response object.\n\n        Raises:\n            DataPlaneError: If the request fails.\n        \"\"\"\n        url = urljoin(self.base_url, path)\n\n        headers = dict(self._headers)\n        headers.update(kwargs.pop(\"headers\", {}))\n\n        try:\n            response = self._session.request(\n                method,\n                url,\n                headers=headers,\n                timeout=(self.connect_timeout, self.timeout),\n                **kwargs,\n            )\n            response.raise_for_status()\n            return response\n\n        except requests.RequestException as e:\n            logger.error(f\"Data plane request failed: {e}\")\n            raise DataPlaneError(f\"Data plane request failed: {e}\") from e\n\n    def execute_command(\n        self,\n        command: Union[str, List[str]],\n        timeout: Optional[float] = None,\n    ) -> str:\n        \"\"\"\n        Execute a command in the Code Interpreter.\n\n        Args:\n            command: The command to execute (can be string or list of args).\n            timeout: Timeout in seconds. If None, uses the default.\n\n        Returns:\n            The stdout from the command execution.\n\n        Raises:\n            DataPlaneError: If the execution fails.\n        \"\"\"\n        effective_timeout = timeout if timeout is not None else self.timeout\n\n        if isinstance(command, str):\n            cmd_list = command.split()\n        else:\n            cmd_list = command\n\n        body = {\n            \"command\": cmd_list,\n            \"timeout\": f\"{effective_timeout}s\",\n        }\n\n        read_timeout = effective_timeout + 2.0\n\n        response = self._request(\n            \"POST\",\n            \"api/execute\",\n            json=body,\n            timeout=(self.connect_timeout, read_timeout),\n        )\n\n        data = response.json()\n        return data.get(\"stdout\", \"\")\n\n    def run_code(\n        self,\n        language: str,\n        code: str,\n        timeout: Optional[float] = None,\n    ) -> str:\n        \"\"\"\n        Run code in the Code Interpreter.\n\n        Args:\n            language: Programming language (e.g., \"python\", \"javascript\").\n            code: The code to run.\n            timeout: Timeout in seconds. If None, uses the default.\n\n        Returns:\n            The stdout from the code execution.\n\n        Raises:\n            DataPlaneError: If the execution fails.\n        \"\"\"\n        effective_timeout = timeout if timeout is not None else self.timeout\n\n        command = [language, \"-c\", code]\n        body = {\n            \"command\": command,\n            \"timeout\": f\"{effective_timeout}s\",\n        }\n\n        read_timeout = effective_timeout + 2.0\n\n        response = self._request(\n            \"POST\",\n            \"api/execute\",\n            json=body,\n            timeout=(self.connect_timeout, read_timeout),\n        )\n\n        data = response.json()\n        return data.get(\"stdout\", \"\")\n\n    def write_file(\n        self,\n        content: str,\n        remote_path: str,\n        mode: str = \"0644\",\n    ) -> Dict:\n        \"\"\"\n        Write a file to the Code Interpreter.\n\n        Args:\n            content: The file content (will be base64 encoded).\n            remote_path: The remote path where the file will be written.\n            mode: File permissions (default: 0644).\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            DataPlaneError: If the write fails.\n        \"\"\"\n        body = {\n            \"content\": base64.b64encode(content.encode()).decode(),\n            \"path\": remote_path,\n            \"mode\": mode,\n        }\n\n        response = self._request(\n            \"POST\",\n            \"api/files\",\n            json=body,\n        )\n\n        return response.json()\n\n    def upload_file(\n        self,\n        local_path: str,\n        remote_path: str,\n    ) -> Dict:\n        \"\"\"\n        Upload a file to the Code Interpreter.\n\n        Args:\n            local_path: Path to the local file.\n            remote_path: The remote path where the file will be written.\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            DataPlaneError: If the upload fails.\n        \"\"\"\n        local_file = Path(local_path)\n        if not local_file.exists():\n            raise DataPlaneError(f\"Local file not found: {local_path}\")\n\n        with open(local_file, \"rb\") as f:\n            files = {\"file\": (local_file.name, f)}\n            headers = dict(self._headers)\n            headers[\"x-agentcube-session-id\"] = self._session_id\n\n            url = urljoin(self.base_url, \"api/files\")\n\n            try:\n                response = self._session.post(\n                    url,\n                  