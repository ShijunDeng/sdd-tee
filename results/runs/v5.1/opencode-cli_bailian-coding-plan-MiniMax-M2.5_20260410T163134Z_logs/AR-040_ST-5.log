  router_url: Base URL of the Router service.\n43:             namespace: Kubernetes namespace.\n44:             cr_name: Custom Resource name.\n45:             session_id: The session ID for this Code Interpreter.\n46:             base_url: Explicit base URL for API calls. If None, constructed\n47:                      from router_url, namespace, and cr_name.\n48:             timeout: Default read timeout in seconds.\n49:             connect_timeout: Connection timeout in seconds.\n50:             pool_connections: Number of connection pools to cache.\n51:             pool_maxsize: Maximum number of connections per pool.\n52:         \"\"\"\n53:         self.timeout = timeout\n54:         self.connect_timeout = connect_timeout\n55: \n56:         if base_url:\n57:             self.base_url = base_url\n58:         else:\n59:             self.base_url = urljoin(\n60:                 router_url,\n61:                 f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\",\n62:             )\n63: \n64:         self._session_id = session_id\n65:         self._headers: Dict[str, str] = {\n66:             \"x-agentcube-session-id\": session_id,\n67:         }\n68: \n69:         self._session = create_session(pool_connections=pool_connections, pool_maxsize=pool_maxsize)\n70: \n71:         logger.debug(\n72:             f\"CodeInterpreterDataPlaneClient initialized with \"\n73:             f\"base_url={self.base_url}, session_id={session_id}\"\n74:         )\n75: \n76:     def _request(\n77:         self,\n78:         method: str,\n79:         path: str,\n80:         **kwargs,\n81:     ) -> requests.Response:\n82:         \"\"\"\n83:         Make an HTTP request to the data plane.\n84: \n85:         Args:\n86:             method: HTTP method (GET, POST, etc.)\n87:             path: API path (appended to base_url)\n88:             **kwargs: Additional arguments passed to requests.Session.request\n89: \n90:         Returns:\n91:             The response object.\n92: \n93:         Raises:\n94:             DataPlaneError: If the request fails.\n95:         \"\"\"\n96:         url = urljoin(self.base_url, path)\n97: \n98:         headers = dict(self._headers)\n99:         headers.update(kwargs.pop(\"headers\", {}))\n100: \n101:         try:\n102:             response = self._session.request(\n103:                 method,\n104:                 url,\n105:                 headers=headers,\n106:                 timeout=(self.connect_timeout, self.timeout),\n107:                 **kwargs,\n108:             )\n109:             response.raise_for_status()\n110:             return response\n111: \n112:         except requests.RequestException as e:\n113:             logger.error(f\"Data plane request failed: {e}\")\n114:             raise DataPlaneError(f\"Data plane request failed: {e}\") from e\n115: \n116:     def execute_command(\n117:         self,\n118:         command: Union[str, List[str]],\n119:         timeout: Optional[float] = None,\n120:     ) -> str:\n121:         \"\"\"\n122:         Execute a command in the Code Interpreter.\n123: \n124:         Args:\n125:             command: The command to execute (can be string or list of args).\n126:             timeout: Timeout in seconds. If None, uses the default.\n127: \n128:         Returns:\n129:             The stdout from the command execution.\n130: \n131:         Raises:\n132:             DataPlaneError: If the execution fails.\n133:         \"\"\"\n134:         effective_timeout = timeout if timeout is not None else self.timeout\n135: \n136:         if isinstance(command, str):\n137:             cmd_list = command.split()\n138:         else:\n139:             cmd_list = command\n140: \n141:         body = {\n142:             \"command\": cmd_list,\n143:             \"timeout\": f\"{effective_timeout}s\",\n144:         }\n145: \n146:         read_timeout = effective_timeout + 2.0\n147: \n148:         response = self._request(\n149:             \"POST\",\n150:             \"api/execute\",\n151:             json=body,\n152:             timeout=(self.connect_timeout, read_timeout),\n153:         )\n154: \n155:         data = response.json()\n156:         return data.get(\"stdout\", \"\")\n157: \n158:     def run_code(\n159:         self,\n160:         language: str,\n161:         code: str,\n162:         timeout: Optional[float] = None,\n163:     ) -> str:\n164:         \"\"\"\n165:         Run code in the Code Interpreter.\n166: \n167:         Args:\n168:             language: Programming language (e.g., \"python\", \"javascript\").\n169:             code: The code to run.\n170:             timeout: Timeout in seconds. If None, uses the default.\n171: \n172:         Returns:\n173:             The stdout from the code execution.\n174: \n175:         Raises:\n176:             DataPlaneError: If the execution fails.\n177:         \"\"\"\n178:         effective_timeout = timeout if timeout is not None else self.timeout\n179: \n180:         command = [language, \"-c\", code]\n181:         body = {\n182:             \"command\": command,\n183:             \"timeout\": f\"{effective_timeout}s\",\n184:         }\n185: \n186:         read_timeout = effective_timeout + 2.0\n187: \n188:         response = self._request(\n189:             \"POST\",\n190:             \"api/execute\",\n191:             json=body,\n192:             timeout=(self.connect_timeout, read_timeout),\n193:         )\n194: \n195:         data = response.json()\n196:         return data.get(\"stdout\", \"\")\n197: \n198:     def write_file(\n199:         self,\n200:         content: str,\n201:         remote_path: str,\n202:         mode: str = \"0644\",\n203:     ) -> Dict:\n204:         \"\"\"\n205:         Write a file to the Code Interpreter.\n206: \n207:         Args:\n208:             content: The file content (will be base64 encoded).\n209:             remote_path: The remote path where the file will be written.\n210:             mode: File permissions (default: 0644).\n211: \n212:         Returns:\n213:             A dictionary containing the response data.\n214: \n215:         Raises:\n216:             DataPlaneError: If the write fails.\n217:         \"\"\"\n218:         body = {\n219:             \"content\": base64.b64encode(content.encode()).decode(),\n220:             \"path\": remote_path,\n221:             \"mode\": mode,\n222:         }\n223: \n224:         response = self._request(\n225:             \"POST\",\n226:             \"api/files\",\n227:             json=body,\n228:         )\n229: \n230:         return response.json()\n231: \n232:     def upload_file(\n233:         self,\n234:         local_path: str,\n235:         remote_path: str,\n236:     ) -> Dict:\n237:         \"\"\"\n238:         Upload a file to the Code Interpreter.\n239: \n240:         Args:\n241:             local_path: Path to the local file.\n242:             remote_path: The remote path where the file will be written.\n243: \n244:         Returns:\n245:             A dictionary containing the response data.\n246: \n247:         Raises:\n248:             DataPlaneError: If the upload fails.\n249:         \"\"\"\n250:         local_file = Path(local_path)\n251:         if not local_file.exists():\n252:             raise DataPlaneError(f\"Local file not found: {local_path}\")\n253: \n254:         with open(local_file, \"rb\") as f:\n255:             files = {\"file\": (local_file.name, f)}\n256:             headers = dict(self._headers)\n257:             headers[\"x-agentcube-session-id\"] = self._session_id\n258: \n259:             url = urljoin(self.base_url, \"api/files\")\n260: \n261:             try:\n262:                 response = self._session.post(\n263:                     url,\n264:                     files=files,\n265:                     data={\"path\": remote_path},\n266:                     headers=headers,\n267:                     timeout=(self.connect_timeout, self.timeout),\n268:                 )\n269:                 response.raise_for_status()\n270:                 return response.json()\n271: \n272:             except requests.RequestException as e:\n273:                 logger.error(f\"File upload failed: {e}\")\n274:                 raise DataPlaneError(f\"File upload failed: {e}\") from e\n275: \n276:     def download_file(\n277:         self,\n278:         remote_path: str,\n279:         local_path: str,\n280:     ) -> None:\n281:         \"\"\"\n282:         Download a file from the Code Interpreter.\n283: \n284:         Args:\n285:             remote_path: The remote path of the file to download.\n286:             local_path: The local path where the file will be saved.\n287: \n288:         Raises:\n289:             DataPlaneError: If the download fails.\n290:         \"\"\"\n291:         clean_path = remote_path.lstrip(\"/\")\n292: \n293:         response = self._request(\n294:             \"GET\",\n295:             f\"api/files/{clean_path}\",\n296:             stream=True,\n297:         )\n298: \n299:         local_file = Path(local_path)\n300:         local_file.parent.mkdir(parents=True, exist_ok=True)\n301: \n302:         with open(local_file, \"wb\") as f:\n303:             for chunk in response.iter_content(chunk_size=8192):\n304:                 if chunk:\n305:                     f.write(chunk)\n306: \n307:         logger.info(f\"Downloaded {remote_path} to {local_path}\")\n308: \n309:     def list_files(self, path: str = \".\") -> Dict:\n310:         \"\"\"\n311:         List files in the Code Interpreter.\n312: \n313:         Args:\n314:             path: The path to list (default: \".\").\n315: \n316:         Returns:\n317:             A dictionary containing the file listing.\n318: \n319:         Raises:\n320:             DataPlaneError: If the list fails.\n321:         \"\"\"\n322:         response = self._request(\n323:             \"GET\",\n324:             \"api/files\",\n325:             params={\"path\": path},\n326:         )\n327: \n328:         return response.json()\n329: \n330:     def close(self) -> None:\n331:         \"\"\"Close the HTTP session.\"\"\"\n332:         self._session.close()\n333:         logger.debug(\"CodeInterpreterDataPlaneClient session closed\")\n\n(End of file - total 333 lines)\n</content>","metadata":{"preview":"\"\"\"Code Interpreter Data Plane client for AgentCube SDK.\"\"\"\n\nimport base64\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional, Union\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom agentcube.exceptions import DataPlaneError\nfrom agentcube.utils.http import (\n    DEFAULT_CONNECT_TIMEOUT,\n    DEFAULT_POOL_CONNECTIONS,\n    DEFAULT_POOL_MAXSIZE,\n    DEFAULT_TIMEOUT,\n    create_session,\n)\nfrom agentcube.utils.log import get_logger\n\nlogger = get_logger(__name__)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/clients/code_interpreter_data_plane.py","time":{"start":1775884179797,"end":1775884179812}}}}
