{"type":"tool_use","timestamp":1775884149399,"sessionID":"ses_2850f95faffe2QPCyQtVTJLk1n","part":{"id":"prt_d7af19e9d001cuZfEUNrXKt2aL","messageID":"msg_d7af19424001WXBu0vTwv3V1EO","sessionID":"ses_2850f95faffe2QPCyQtVTJLk1n","type":"tool","tool":"read","callID":"toolu_e3d0bd6d6a9f4b21b47e98c5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_agent_runtime_client.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_agent_runtime_client.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for AgentRuntimeClient.\"\"\"\n2: \n3: from unittest.mock import Mock, patch\n4: \n5: import pytest\n6: import requests\n7: \n8: from agentcube.agent_runtime import AgentRuntimeClient\n9: from agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n10: from agentcube.exceptions import SessionError\n11: \n12: \n13: class TestAgentRuntimeClient:\n14:     \"\"\"Test cases for AgentRuntimeClient.\"\"\"\n15: \n16:     def test_constructor_requires_router_url(self):\n17:         \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n18:         with pytest.raises(ValueError) as exc_info:\n19:             AgentRuntimeClient()\n20:         assert \"router_url\" in str(exc_info.value).lower()\n21:         assert \"ROUTER_URL\" in str(exc_info.value)\n22: \n23:     def test_constructor_with_env_var(self):\n24:         \"\"\"Test Router URL can be set via environment variable.\"\"\"\n25:         with (\n26:             patch.dict(\"os.environ\", {\"ROUTER_URL\": \"http://router:8080\"}),\n27:             patch(\"agentcube.agent_runtime.create_session\") as mock_create_session,\n28:         ):\n29:             mock_session = Mock()\n30:             mock_response = Mock()\n31:             mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n32:             mock_response.raise_for_status = Mock()\n33:             mock_session.get.return_value = mock_response\n34:             mock_create_session.return_value = mock_session\n35: \n36:             client = AgentRuntimeClient()\n37:             assert client.router_url == \"http://router:8080\"\n38:             client.close()\n39: \n40:     def test_constructor_with_explicit_url(self):\n41:         \"\"\"Test Router URL can be set explicitly.\"\"\"\n42:         with patch(\"agentcube.agent_runtime.create_session\") as mock_create_session:\n43:             mock_session = Mock()\n44:             mock_response = Mock()\n45:             mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n46:             mock_response.raise_for_status = Mock()\n47:             mock_session.get.return_value = mock_response\n48:             mock_create_session.return_value = mock_session\n49: \n50:             client = AgentRuntimeClient(router_url=\"http://router:8080\")\n51:             assert client.router_url == \"http://router:8080\"\n52:             client.close()\n53: \n54:     def test_constructor_default_values(self):\n55:         \"\"\"Test constructor sets default values correctly.\"\"\"\n56:         with patch(\"agentcube.agent_runtime.create_session\") as mock_create_session:\n57:             mock_session = Mock()\n58:             mock_response = Mock()\n59:             mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n60:             mock_response.raise_for_status = Mock()\n61:             mock_session.get.return_value = mock_response\n62:             mock_create_session.return_value = mock_session\n63: \n64:             client = AgentRuntimeClient(router_url=\"http://router:8080\")\n65:             assert client.agent_name == \"my-agent\"\n66:             assert client.namespace == \"default\"\n67:             assert client.timeout == 120\n68:             assert client.connect_timeout == 5.0\n69:             client.close()\n70: \n71:     @patch(\"agentcube.agent_runtime.create_session\")\n72:     def test_bootstrap_session(self, mock_create_session):\n73:         \"\"\"Test session is bootstrapped via GET when session_id not provided.\"\"\"\n74:         mock_session = Mock()\n75:         mock_response = Mock()\n76:         mock_response.headers = {\"x-agentcube-session-id\": \"bootstrapped-session-123\"}\n77:         mock_response.raise_for_status = Mock()\n78:         mock_session.get.return_value = mock_response\n79:         mock_create_session.return_value = mock_session\n80: \n81:         client = AgentRuntimeClient(router_url=\"http://router:8080\")\n82: \n83:         mock_session.get.assert_called_once()\n84:         call_args = mock_session.get.call_args\n85:         assert \"invocations/\" in call_args[0][0]\n86:         assert client.session_id == \"bootstrapped-session-123\"\n87:         client.close()\n88: \n89:     @patch(\"agentcube.agent_runtime.create_session\")\n90:     def test_bootstrap_session_missing_header_raises_error(self, mock_create_session):\n91:         \"\"\"Test ValueError is raised when session header is missing.\"\"\"\n92:         mock_session = Mock()\n93:         mock_response = Mock()\n94:         mock_response.headers = {}\n95:         mock_response.raise_for_status = Mock()\n96:         mock_session.get.return_value = mock_response\n97:         mock_create_session.return_value = mock_session\n98: \n99:         try:\n100:             with pytest.raises(ValueError) as exc_info:\n101:                 AgentRuntimeClient(router_url=\"http://router:8080\")\n102:             assert \"x-agentcube-session-id\" in str(exc_info.value)\n103:         finally:\n104:             pass\n105: \n106:     @patch(\"agentcube.agent_runtime.create_session\")\n107:     def test_reuse_provided_session_id(self, mock_create_session):\n108:         \"\"\"Test provided session_id is used directly without bootstrap.\"\"\"\n109:         mock_session = Mock()\n110:         mock_create_session.return_value = mock_session\n111: \n112:         client = AgentRuntimeClient(\n113:             router_url=\"http://router:8080\", session_id=\"existing-session-456\"\n114:         )\n115: \n116:         mock_session.get.assert_not_called()\n117:         assert client.session_id == \"existing-session-456\"\n118:         client.close()\n119: \n120:     @patch(\"agentcube.agent_runtime.create_session\")\n121:     def test_init_data_plane_client(self, mock_create_session):\n122:         \"\"\"Test data plane client is initialized after session bootstrap.\"\"\"\n123:         mock_session = Mock()\n124:         mock_response = Mock()\n125:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n126:         mock_response.raise_for_status = Mock()\n127:         mock_session.get.return_value = mock_response\n128:         mock_create_session.return_value = mock_session\n129: \n130:         client = AgentRuntimeClient(router_url=\"http://router:8080\")\n131: \n132:         assert client.dp_client is not None\n133:         assert hasattr(client.dp_client, \"invoke\")\n134:         client.close()\n135: \n136:     @patch(\"agentcube.agent_runtime.create_session\")\n137:     def test_context_manager(self, mock_create_session):\n138:         \"\"\"Test context manager protocol.\"\"\"\n139:         mock_session = Mock()\n140:         mock_response = Mock()\n141:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n142:         mock_response.raise_for_status = Mock()\n143:         mock_session.get.return_value = mock_response\n144:         mock_create_session.return_value = mock_session\n145: \n146:         with AgentRuntimeClient(router_url=\"http://router:8080\") as client:\n147:             assert client.session_id == \"session-123\"\n148: \n149:         mock_session.close.assert_called_once()\n150: \n151:     @patch(\"agentcube.agent_runtime.create_session\")\n152:     def test_invoke_raises_when_session_not_initialized(self, mock_create_session):\n153:         \"\"\"Test invoke raises ValueError when session_id is falsy.\"\"\"\n154:         mock_session = Mock()\n155:         mock_response = Mock()\n156:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n157:         mock_response.raise_for_status = Mock()\n158:         mock_session.get.return_value = mock_response\n159:         mock_create_session.return_value = mock_session\n160: \n161:         client = AgentRuntimeClient(router_url=\"http://router:8080\")\n162:         client._session_id = None\n163: \n164:         with pytest.raises(ValueError) as exc_info:\n165:             client.invoke({\"tool\": \"test\"})\n166:         assert \"session_id is not initialized\" in str(exc_info.value)\n167:         client.close()\n168: \n169:     @patch(\"agentcube.agent_runtime.create_session\")\n170:     def test_invoke_delegates_to_data_plane(self, mock_create_session):\n171:         \"\"\"Test invoke delegates to dp_client correctly.\"\"\"\n172:         mock_session = Mock()\n173:         mock_response = Mock()\n174:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n175:         mock_response.raise_for_status = Mock()\n176:         mock_session.get.return_value = mock_response\n177:         mock_create_session.return_value = mock_session\n178: \n179:         with patch.object(\n180:             AgentRuntimeDataPlaneClient, \"invoke\", return_value={\"result\": \"ok\"}\n181:         ) as mock_invoke:\n182:             client = AgentRuntimeClient(router_url=\"http://router:8080\")\n183: \n184:             payload = {\"tool\": \"calculator\", \"input\": {\"expression\": \"2+2\"}}\n185:             result = client.invoke(payload)\n186: \n187:             mock_invoke.assert_called_once()\n188:             assert result == {\"result\": \"ok\"}\n189:             client.close()\n190: \n191:     @patch(\"agentcube.agent_runtime.create_session\")\n192:     def test_invoke_timeout_tuple(self, mock_create_session):\n193:         \"\"\"Test invoke uses timeout tuple (connect_timeout, self.timeout) when timeout=None.\"\"\"\n194:         mock_session = Mock()\n195:         mock_response = Mock()\n196:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n197:         mock_response.raise_for_status = Mock()\n198:         mock_session.get.return_value = mock_response\n199:         mock_create_session.return_value = mock_session\n200: \n201:         client = AgentRuntimeClient(\n202:             router_url=\"http://router:8080\",\n203:             timeout=120,\n204:             connect_timeout=5.0,\n205:         )\n206: \n207:         with patch.object(client.dp_client, \"invoke\", return_value={\"result\": \"ok\"}) as mock_invoke:\n208:             client.invoke({\"tool\": \"test\"}, timeout=None)\n209: \n210:             call_kwargs = mock_invoke.call_args[1]\n211:             assert call_kwargs[\"timeout\"] == (5.0, 120)\n212:             client.close()\n213: \n214:     @patch(\"agentcube.agent_runtime.create_session\")\n215:     def test_invoke_custom_timeout(self, mock_create_session):\n216:         \"\"\"Test invoke uses custom timeout when provided.\"\"\"\n217:         mock_session = Mock()\n218:         mock_response = Mock()\n219:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n220:         mock_response.raise_for_status = Mock()\n221:         mock_session.get.return_value = mock_response\n222:         mock_create_session.return_value = mock_session\n223: \n224:         client = AgentRuntimeClient(\n225:             router_url=\"http://router:8080\",\n226:             timeout=120,\n227:             connect_timeout=5.0,\n228:         )\n229: \n230:         with patch.object(client.dp_client, \"invoke\", return_value={\"result\": \"ok\"}) as mock_invoke:\n231:             client.invoke({\"tool\": \"test\"}, timeout=60)\n232: \n233:             call_kwargs = mock_invoke.call_args[1]\n234:             assert call_kwargs[\"timeout\"] == (5.0, 60)\n235:             client.close()\n236: \n237:     @patch(\"agentcube.agent_runtime.create_session\")\n238:     def test_close(self, mock_create_session):\n239:         \"\"\"Test close releases resources.\"\"\"\n240:         mock_session = Mock()\n241:         mock_response = Mock()\n242:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n243:         mock_response.raise_for_status = Mock()\n244:         mock_session.get.return_value = mock_response\n245:         mock_create_session.return_value = mock_session\n246: \n247:         client = AgentRuntimeClient(router_url=\"http://router:8080\")\n248: \n249:         with patch.object(client.dp_client, \"close\") as mock_dp_close:\n250:             client.close()\n251:             mock_dp_close.assert_called_once()\n252: \n253:         mock_session.close.assert_called_once()\n254: \n255:     @patch(\"agentcube.agent_runtime.create_session\")\n256:     def test_session_id_property(self, mock_create_session):\n257:         \"\"\"Test session_id property returns correct value.\"\"\"\n258:         mock_session = Mock()\n259:         mock_response = Mock()\n260:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n261:         mock_response.raise_for_status = Mock()\n262:         mock_session.get.return_value = mock_response\n263:         mock_create_session.return_value = mock_session\n264: \n265:         client = AgentRuntimeClient(\n266:             router_url=\"http://router:8080\",\n267:             session_id=\"custom-session\",\n268:         )\n269: \n270:         assert client.session_id == \"custom-session\"\n271:         client.close()\n272: \n273:     @patch(\"agentcube.agent_runtime.create_session\")\n274:     def test_bootstrap_session_network_error(self, mock_create_session):\n275:         \"\"\"Test SessionError is raised on network failure during bootstrap.\"\"\"\n276:         mock_session = Mock()\n277:         mock