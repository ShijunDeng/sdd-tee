outer_url: Optional[str] = None,\n        workload_manager_url: Optional[str] = None,\n        auth_token: Optional[str] = None,\n        name: str = \"my-interpreter\",\n        namespace: str = \"default\",\n        ttl: int = 3600,\n        verbose: bool = False,\n        session_id: Optional[str] = None,\n    ):\n        \"\"\"\n        Initialize the CodeInterpreterClient.\n\n        Args:\n            router_url: URL of the Router service. If None, uses ROUTER_URL env var.\n            workload_manager_url: URL of the Workload Manager service.\n                                 If None, uses WORKLOAD_MANAGER_URL env var.\n            auth_token: Authentication token for the Workload Manager.\n            name: Name of the session/agent (default: \"my-interpreter\").\n            namespace: Kubernetes namespace (default: \"default\").\n            ttl: Time to live in seconds (default: 3600).\n            verbose: Enable verbose logging (default: False).\n            session_id: Existing session ID to reuse. If None, a new session\n                       will be created.\n\n        Raises:\n            ValueError: If router_url is not provided and ROUTER_URL env var\n                       is not set.\n        \"\"\"\n        self.router_url = router_url or os.environ.get(\"ROUTER_URL\")\n        if not self.router_url:\n            raise ValueError(\n                \"router_url must be provided via argument or \"\n                \"ROUTER_URL environment variable must be set\"\n            )\n\n        self.workload_manager_url = workload_manager_url\n        self.auth_token = auth_token\n        self.name = name\n        self.namespace = namespace\n        self.ttl = ttl\n        self.verbose = verbose\n        self._session_id_provided = session_id is not None\n\n        self._control_plane_client: Optional[ControlPlaneClient] = None\n        self._data_plane_client: Optional[CodeInterpreterDataPlaneClient] = None\n\n        if session_id:\n            self._session_id = session_id\n            logger.info(f\"Reusing existing session: {session_id}\")\n            self._init_data_plane()\n        else:\n            self._session_id = self._create_session()\n\n    def _create_session(self) -> str:\n        \"\"\"Create a new session via the control plane.\"\"\"\n        self._control_plane_client = ControlPlaneClient(\n            workload_manager_url=self.workload_manager_url,\n            auth_token=self.auth_token,\n        )\n\n        session_id = self._control_plane_client.create_session(\n            name=self.name,\n            namespace=self.namespace,\n            ttl=self.ttl,\n        )\n\n        return session_id\n\n    def _init_data_plane(self) -> None:\n        \"\"\"Initialize the data plane client.\"\"\"\n        try:\n            self._data_plane_client = CodeInterpreterDataPlaneClient(\n                router_url=self.router_url,\n                namespace=self.namespace,\n                cr_name=self.name,\n                session_id=self._session_id,\n            )\n            logger.info(f\"Data plane initialized for session: {self._session_id}\")\n        except Exception as e:\n            logger.error(f\"Failed to initialize data plane: {e}\")\n            if not self._session_id_provided and self._control_plane_client:\n                logger.warning(f\"Data plane init failed, cleaning up session {self._session_id}\")\n                self._control_plane_client.delete_session(self._session_id)\n                self._session_id = None\n            raise\n\n    def execute_command(\n        self,\n        command: str,\n        timeout: Optional[int] = None,\n    ) -> Dict:\n        \"\"\"\n        Execute a command in the Code Interpreter.\n\n        Args:\n            command: The command to execute.\n            timeout: Timeout in seconds. If None, uses the default.\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            CommandExecutionError: If the command returns a non-zero exit code.\n            DataPlaneError: If the execution fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        response = self._data_plane_client.execute_command(command, timeout=timeout)\n\n        exit_code = response.get(\"exit_code\")\n        if exit_code != 0:\n            stderr = response.get(\"stderr\", \"\")\n            raise CommandExecutionError(\n                f\"Command failed with exit code {exit_code}\",\n                exit_code=exit_code,\n                stderr=stderr,\n                command=command,\n            )\n\n        return response\n\n    def run_code(\n        self,\n        code: str,\n        language: str = \"python\",\n        timeout: Optional[int] = None,\n    ) -> Dict:\n        \"\"\"\n        Run code in the Code Interpreter.\n\n        For Python, writes a timestamped .py file and executes it.\n\n        Args:\n            code: The code to run.\n            language: Programming language (python, py, python3, etc.)\n            timeout: Timeout in seconds.\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            CommandExecutionError: If the code returns a non-zero exit code.\n            DataPlaneError: If the execution fails.\n        \"\"\"\n        normalized_lang = language.lower()\n        if normalized_lang in (\"python\", \"py\", \"python3\"):\n            timestamp = int(time.time() * 1000)\n            remote_path = f\"/tmp/script_{timestamp}.py\"\n\n            self.write_file(code, remote_path)\n\n            command = f\"python3 {remote_path}\"\n            return self.execute_command(command, timeout=timeout)\n        else:\n            raise ValueError(f\"Unsupported language: {language}\")\n\n    def write_file(\n        self,\n        content: str,\n        remote_path: str,\n        mode: str = \"0644\",\n    ) -> Dict:\n        \"\"\"\n        Write a file to the Code Interpreter.\n\n        Args:\n            content: The file content.\n            remote_path: The remote path where the file will be written.\n            mode: File permissions (default: 0644).\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            DataPlaneError: If the write fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        return self._data_plane_client.write_file(content, remote_path, mode)\n\n    def upload_file(\n        self,\n        local_path: str,\n        remote_path: str,\n    ) -> Dict:\n        \"\"\"\n        Upload a file to the Code Interpreter.\n\n        Args:\n            local_path: Path to the local file.\n            remote_path: The remote path where the file will be written.\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            DataPlaneError: If the upload fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        return self._data_plane_client.upload_file(local_path, remote_path)\n\n    def download_file(\n        self,\n        remote_path: str,\n        local_path: str,\n    ) -> None:\n        \"\"\"\n        Download a file from the Code Interpreter.\n\n        Args:\n            remote_path: The remote path of the file to download.\n            local_path: The local path where the file will be saved.\n\n        Raises:\n            DataPlaneError: If the download fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        self._data_plane_client.download_file(remote_path, local_path)\n\n    def list_files(self, path: str = \".\") -> Dict:\n        \"\"\"\n        List files in the Code Interpreter.\n\n        Args:\n            path: The path to list (default: \".\").\n\n        Returns:\n            A dictionary containing the file listing.\n\n        Raises:\n            DataPlaneError: If the list fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        return self._data_plane_client.list_files(path)\n\n    def stop(self) -> None:\n        \"\"\"\n        Stop the Code Interpreter session.\n\n        Closes the data plane and deletes the control plane session\n        if a new session was created.\n        \"\"\"\n        if self._data_plane_client:\n            try:\n                self._data_plane_client.close()\n            except Exception as e:\n                logger.warning(f\"Error closing data plane: {e}\")\n            finally:\n                self._data_plane_client = None\n\n        if self._control_plane_client and self._session_id:\n            if self._session_id_provided:\n                logger.info(\"Session was provided by user, not deleting\")\n            else:\n                try:\n                    self._control_plane_client.delete_session(self._session_id)\n                except Exception as e:\n                    logger.warning(f\"Error deleting session: {e}\")\n                finally:\n                    self._session_id = None\n\n        if self._control_plane_client:\n            try:\n                self._control_plane_client.close()\n            except Exception as e:\n                logger.warning(f\"Error closing control plane: {e}\")\n            finally:\n                self._control_plane_client = None\n\n        logger.info(\"CodeInterpreterClient stopped\")\n\n    def __enter__(self) -> \"CodeInterpreterClient\":\n        \"\"\"Enter the context manager.\"\"\"\n        return self\n\n    def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n        \"\"\"Exit the context manager.\"\"\"\n        self.stop()\n\n    @property\n    def session_id(self) -> Optional[str]:\n        \"\"\"Get the current session ID.\"\"\"\n        return self._session_id\n","after":"\"\"\"CodeInterpreterClient for AgentCube SDK.\"\"\"\n\nimport os\nimport time\nfrom typing import Dict, Optional\n\nfrom agentcube.clients import (\n    CodeInterpreterDataPlaneClient,\n    ControlPlaneClient,\n)\nfrom agentcube.exceptions import (\n    CommandExecutionError,\n    DataPlaneError,\n)\nfrom agentcube.utils.log import get_logger\n\nlogger = get_logger(__name__)\n\n\nclass CodeInterpreterClient:\n    \"\"\"Client for Code Interpreter sessions.\"\"\"\n\n    def __init__(\n        self,\n        router_url: Optional[str] = None,\n        workload_manager_url: Optional[str] = None,\n        auth_token: Optional[str] = None,\n        name: str = \"my-interpreter\",\n        namespace: str = \"default\",\n        ttl: int = 3600,\n        verbose: bool = False,\n        session_id: Optional[str] = None,\n    ):\n        \"\"\"\n        Initialize the CodeInterpreterClient.\n\n        Args:\n            router_url: URL of the Router service. If None, uses ROUTER_URL env var.\n            workload_manager_url: URL of the Workload Manager service.\n                                 If None, uses WORKLOAD_MANAGER_URL env var.\n            auth_token: Authentication token for the Workload Manager.\n            name: Name of the session/agent (default: \"my-interpreter\").\n            namespace: Kubernetes namespace (default: \"default\").\n            ttl: Time to live in seconds (default: 3600).\n            verbose: Enable verbose logging (default: False).\n            session_id: Existing session ID to reuse. If None, a new session\n                       will be created.\n\n        Raises:\n            ValueError: If router_url is not provided and ROUTER_URL env var\n                       is not set.\n        \"\"\"\n        self.router_url = router_url or os.environ.get(\"ROUTER_URL\")\n        if not self.router_url:\n            raise ValueError(\n                \"router_url must be provided via argument or \"\n                \"ROUTER_URL environment variable must be set\"\n            )\n\n        self.workload_manager_url = workload_manager_url\n        self.auth_token = auth_token\n        self.name = name\n        self.namespace = namespace\n        self.ttl = ttl\n        self.verbose = verbose\n        self._session_id_provided = session_id is not None\n\n        self._control_plane_client: Optional[ControlPlaneClient] = None\n        self._data_plane_client: Optional[CodeInterpreterDataPlaneClient] = None\n\n        if session_id:\n            self._session_id = session_id\n            logger.info(f\"Reusing existing session: {session_id}\")\n            self._init_data_plane()\n        else:\n            self._session_id = self._create_session()\n\n    def _create_session(self) -> str:\n        \"\"\"Create a new session via the control plane.\"\"\"\n        self._control_plane_client = ControlPlaneClient(\n            workload_manager_url=self.workload_manager_url,\n            auth_token=self.auth_token,\n        )\n\n        session_id = self._control_plane_client.create_session(\n            name=self.name,\n            namespace=self.namespace,\n            ttl=self.ttl,\n        )\n\n        return session_id\n\n    def _init_data_plane(self) -> None:\n        \"\"\"Initialize the data plane client.\"\"\"\n        try:\n            self._data_plane_client = CodeInterpreterDataPlaneClient(\n                router_url=self.router_url,\n                namespace=self.namespace,\n                cr_name=self.name,\n                session_id=self._session_id,\n            )\n            logger.info(f\"Data plane initialized for session: {self._session_id}\")\n        except Exception as e:\n            logger.error(f\"Failed to initialize data plane: {e}\")\n            if not self._session_id_provided and self._control_plane_client:\n                logger.warning(f\"Data plane init failed, cleaning up session {self._session_id}\")\n                self._control_plane_client.delete_session(self._session_id)\n                self._session_id = None\n            raise\n\n    def execute_command(\n        self,\n        command: str,\n        timeout: Optional[int] = None,\n    ) -> Dict:\n        \"\"\"\n        Execute a command in the Code Interpreter.\n\n        Args:\n            command: The command to execute.\n            timeout: Timeout in seconds. If None, uses the default.\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            CommandExecutionError: If the command returns a non-zero exit code.\n            DataPlaneError: If the execution fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        response = self._data_plane_client.execute_command(command, timeout=timeout)\n\n        exit_code = response.get(\"exit_code\")\n        if exit_code != 0:\n            stderr = response.get(\"stderr\", \"\")\n            raise CommandExecutionError(\n                f\"Command failed with exit code {exit_code}\",\n                exit_code=exit_code,\n                stderr=stderr,\n                command=command,\n            )\n\n        return response\n\n    def run_code(\n        self,\n        code: str,\n        language: str = \"python\",\n        timeout: Optional[int] = None,\n    ) -> Dict:\n        \"\"\"\n        Run code in the Code Interpreter.\n\n        For Python, writes a timestamped .py file and executes it.\n\n        Args:\n            code: The code to run.\n            language: Programming language (python, py, python3, etc.)\n            timeout: Timeout in seconds.\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            CommandExecutionError: If the code returns a non-zero exit code.\n            DataPlaneError: If the execution fails.\n        \"\"\"\n        normalized_lang = language.lower()\n        if normalized_lang in (\"python\", \"py\", \"python3\"):\n            timestamp = int(time.time() * 1000)\n            remote_path = f\"/tmp/script_{timestamp}.py\"\n\n            self.write_file(code, remote_path)\n\n            command = f\"python3 {remote_path}\"\n            return self.execute_command(command, timeout=timeout)\n        else:\n            raise ValueError(f\"Unsupported language: {language}\")\n\n    def write_file(\n        self,\n        content: str,\n        remote_path: str,\n        mode: str = \"0644\",\n    ) -> Dict:\n        \"\"\"\n        Write a file to the Code Interpreter.\n\n        Args:\n            content: The file content.\n            remote_path: The remote path where the file will be written.\n            mode: File permissions (default: 0644).\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            DataPlaneError: If the write fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        return self._data_plane_client.write_file(content, remote_path, mode)\n\n    def upload_file(\n        self,\n        local_path: str,\n        remote_path: str,\n    ) -> Dict:\n        \"\"\"\n        Upload a file to the Code Interpreter.\n\n        Args:\n            local_path: Path to the local file.\n            remote_path: The remote path where the file will be written.\n\n        Returns:\n            A dictionary containing the response data.\n\n        Raises:\n            DataPlaneError: If the upload fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        return self._data_plane_client.upload_file(local_path, remote_path)\n\n    def download_file(\n        self,\n        remote_path: str,\n        local_path: str,\n    ) -> None:\n        \"\"\"\n        Download a file from the Code Interpreter.\n\n        Args:\n            remote_path: The remote path of the file to download.\n            local_path: The local path where the file will be saved.\n\n        Raises:\n            DataPlaneError: If the download fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        self._data_plane_client.download_file(remote_path, local_path)\n\n    def list_files(self, path: str = \".\") -> Dict:\n        \"\"\"\n        List files in the Code Interpreter.\n\n        Args:\n            path: The path to list (default: \".\").\n\n        Returns:\n            A dictionary containing the file listing.\n\n        Raises:\n            DataPlaneError: If the list fails.\n        \"\"\"\n        if not self._data_plane_client:\n            raise DataPlaneError(\"Data plane not initialized\")\n\n        return self._data_plane_client.list_files(path)\n\n    def stop(self) -> None:\n        \"\"\"\n        Stop the Code Interpreter session.\n\n        Closes the data plane and deletes the control plane session\n        if a new session was created.\n        \"\"\"\n        if self._data_plane_client:\n            try:\n                self._data_plane_client.close()\n            except Exception as e:\n                logger.warning(f\"Error closing data plane: {e}\")\n            finally:\n                self._data_plane_client = None\n\n        if self._control_plane_client and self._session_id:\n            if self._session_id_provided:\n                logger.info(\"Session was provided by user, not deleting\")\n            else:\n                try:\n                    self._control_plane_client.delete_session(self._session_id)\n                except Exception as e:\n                    logger.warning(f\"Error deleting session: {e}\")\n                finally:\n                    self._session_id = None\n\n        if self._control_plane_client:\n            try:\n                self._control_plane_client.close()\n            except Exception as e:\n                logger.warning(f\"Error closing control plane: {e}\")\n            finally:\n                self._control_plane_client = None\n\n        logger.info(\"CodeInterpreterClient stopped\")\n\n    def __enter__(self) -> \"CodeInterpreterClient\":\n        \"\"\"Enter the context manager.\"\"\"\n        return self\n\n    def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n        \"\"\"Exit the context manager.\"\"\"\n        self.stop()\n\n    @property\n    def session_id(self) -> Optional[str]:\n        \"\"\"Get the current session ID.\"\"\"\n        return self._session_id\n","additions":0,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/code_interpreter.py","time":{"start":1775884197400,"end":1775884198007}}}}
