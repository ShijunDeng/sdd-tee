ence != \"test-audience\" {\n44: \t\tt.Errorf(\"expected JWTAudience 'test-audience', got %s\", config.JWTAudience)\n45: \t}\n46: }\n47: \n48: func TestLoadAuthConfigFromEnv_DefaultPublicPaths(t *testing.T) {\n49: \tos.Setenv(EnvPublicKeyPath, \"test-key-data\")\n50: \tos.Unsetenv(EnvPublicPaths)\n51: \tdefer os.Unsetenv(EnvPublicKeyPath)\n52: \n53: \tconfig, err := LoadAuthConfigFromEnv()\n54: \tif err != nil {\n55: \t\tt.Fatalf(\"expected no error, got %v\", err)\n56: \t}\n57: \n58: \tif len(config.PublicPaths) != 1 || config.PublicPaths[0] != DefaultPublicPath {\n59: \t\tt.Errorf(\"expected default public path %s, got %v\", DefaultPublicPath, config.PublicPaths)\n60: \t}\n61: }\n62: \n63: func TestLoadAuthConfigFromEnv_MissingRequiredField(t *testing.T) {\n64: \tos.Unsetenv(EnvPublicKeyPath)\n65: \tos.Unsetenv(EnvPublicPaths)\n66: \n67: \t_, err := LoadAuthConfigFromEnv()\n68: \tif err == nil {\n69: \t\tt.Error(\"expected error for missing required fields\")\n70: \t}\n71: }\n72: \n73: func TestGetPublicPathsFromEnv(t *testing.T) {\n74: \ttests := []struct {\n75: \t\tname     string\n76: \t\tenvValue string\n77: \t\texpected []string\n78: \t}{\n79: \t\t{\n80: \t\t\tname:     \"single path\",\n81: \t\t\tenvValue: \"/health\",\n82: \t\t\texpected: []string{\"/health\"},\n83: \t\t},\n84: \t\t{\n85: \t\t\tname:     \"multiple paths\",\n86: \t\t\tenvValue: \"/health,/api/public,/api/docs\",\n87: \t\t\texpected: []string{\"/health\", \"/api/public\", \"/api/docs\"},\n88: \t\t},\n89: \t\t{\n90: \t\t\tname:     \"paths with spaces\",\n91: \t\t\tenvValue: \"/health , /api/public \",\n92: \t\t\texpected: []string{\"/health\", \"/api/public\"},\n93: \t\t},\n94: \t\t{\n95: \t\t\tname:     \"empty value returns default\",\n96: \t\t\tenvValue: \"\",\n97: \t\t\texpected: []string{DefaultPublicPath},\n98: \t\t},\n99: \t\t{\n100: \t\t\tname:     \"empty string in middle\",\n101: \t\t\tenvValue: \"/health,,/api/public\",\n102: \t\t\texpected: []string{\"/health\", \"/api/public\"},\n103: \t\t},\n104: \t}\n105: \n106: \tfor _, tt := range tests {\n107: \t\tt.Run(tt.name, func(t *testing.T) {\n108: \t\t\tif tt.envValue == \"\" {\n109: \t\t\t\tos.Unsetenv(EnvPublicPaths)\n110: \t\t\t} else {\n111: \t\t\t\tos.Setenv(EnvPublicPaths, tt.envValue)\n112: \t\t\t}\n113: \t\t\tdefer os.Unsetenv(EnvPublicPaths)\n114: \n115: \t\t\tresult := GetPublicPathsFromEnv()\n116: \t\t\tif len(result) != len(tt.expected) {\n117: \t\t\t\tt.Errorf(\"expected %d paths, got %d\", len(tt.expected), len(result))\n118: \t\t\t\treturn\n119: \t\t\t}\n120: \t\t\tfor i, exp := range tt.expected {\n121: \t\t\t\tif result[i] != exp {\n122: \t\t\t\t\tt.Errorf(\"expected path %d to be %s, got %s\", i, exp, result[i])\n123: \t\t\t\t}\n124: \t\t\t}\n125: \t\t})\n126: \t}\n127: }\n128: \n129: func TestGetBoolEnv(t *testing.T) {\n130: \ttests := []struct {\n131: \t\tname       string\n132: \t\tenvValue   string\n133: \t\tdefaultVal bool\n134: \t\texpected   bool\n135: \t}{\n136: \t\t{\"true value\", \"true\", false, true},\n137: \t\t{\"True value\", \"True\", false, true},\n138: \t\t{\"TRUE value\", \"TRUE\", false, true},\n139: \t\t{\"false value\", \"false\", true, false},\n140: \t\t{\"False value\", \"False\", true, false},\n141: \t\t{\"FALSE value\", \"FALSE\", true, false},\n142: \t\t{\"1 value\", \"1\", false, true},\n143: \t\t{\"0 value\", \"0\", true, false},\n144: \t\t{\"empty uses default\", \"\", true, true},\n145: \t\t{\"random string uses default\", \"invalid\", true, false},\n146: \t}\n147: \n148: \tfor _, tt := range tests {\n149: \t\tt.Run(tt.name, func(t *testing.T) {\n150: \t\t\tif tt.envValue == \"\" {\n151: \t\t\t\tos.Unsetenv(\"TEST_BOOL_ENV\")\n152: \t\t\t} else {\n153: \t\t\t\tos.Setenv(\"TEST_BOOL_ENV\", tt.envValue)\n154: \t\t\t}\n155: \t\t\tdefer os.Unsetenv(\"TEST_BOOL_ENV\")\n156: \n157: \t\t\tresult := GetBoolEnv(\"TEST_BOOL_ENV\", tt.defaultVal)\n158: \t\t\tif result != tt.expected {\n159: \t\t\t\tt.Errorf(\"expected %v, got %v\", tt.expected, result)\n160: \t\t\t}\n161: \t\t})\n162: \t}\n163: }\n164: \n165: func TestAuthConfig_Validate(t *testing.T) {\n166: \ttests := []struct {\n167: \t\tname    string\n168: \t\tconfig  AuthConfig\n169: \t\twantErr bool\n170: \t}{\n171: \t\t{\n172: \t\t\tname: \"valid with public key path\",\n173: \t\t\tconfig: AuthConfig{\n174: \t\t\t\tPublicKeyPath: \"test-key\",\n175: \t\t\t},\n176: \t\t\twantErr: false,\n177: \t\t},\n178: \t\t{\n179: \t\t\tname: \"valid with public paths\",\n180: \t\t\tconfig: AuthConfig{\n181: \t\t\t\tPublicPaths: []string{\"/health\"},\n182: \t\t\t},\n183: \t\t\twantErr: false,\n184: \t\t},\n185: \t\t{\n186: \t\t\tname: \"invalid - no key and no paths\",\n187: \t\t\tconfig: AuthConfig{\n188: \t\t\t\tPublicKeyPath: \"\",\n189: \t\t\t\tPublicPaths:   []string{},\n190: \t\t\t},\n191: \t\t\twantErr: true,\n192: \t\t},\n193: \t}\n194: \n195: \tfor _, tt := range tests {\n196: \t\tt.Run(tt.name, func(t *testing.T) {\n197: \t\t\terr := tt.config.Validate()\n198: \t\t\tif (err != nil) != tt.wantErr {\n199: \t\t\t\tt.Errorf(\"Validate() error = %v, wantErr %v\", err, tt.wantErr)\n200: \t\t\t}\n201: \t\t})\n202: \t}\n203: }\n\n(End of file - total 203 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"os\"\n\t\"testing\"\n)\n\nfunc TestLoadAuthConfigFromEnv_ValidConfig(t *testing.T) {\n\tos.Setenv(EnvPublicKeyPath, \"test-key-data\")\n\tos.Setenv(EnvPublicPaths, \"/health,/api/public\")\n\tos.Setenv(EnvAllowQueryParam, \"true\")\n\tos.Setenv(EnvJWTIssuer, \"test-issuer\")\n\tos.Setenv(EnvJWTAudience, \"test-audience\")\n\tdefer func() {\n\t\tos.Unsetenv(EnvPublicKeyPath)\n\t\tos.Unsetenv(EnvPublicPaths)\n\t\tos.Unsetenv(EnvAllowQueryParam)\n\t\tos.Unsetenv(EnvJWTIssuer)\n\t\tos.Unsetenv(EnvJWTAudience)\n\t}()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_config_test.go","time":{"start":1775882966755,"end":1775882966765}}}}
