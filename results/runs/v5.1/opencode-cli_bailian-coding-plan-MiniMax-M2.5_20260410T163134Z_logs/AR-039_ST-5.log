tcher()\n53: \t}\n54: \n55: \tif err := s.setWorkspace(config.Workspace); err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to set workspace: %w\", err)\n57: \t}\n58: \n59: \ts.registerRoutes(publicPaths)\n60: \n61: \treturn s, nil\n62: }\n63: \n64: func (s *Server) setWorkspace(workspace string) error {\n65: \tvar err error\n66: \tvar absWorkspace string\n67: \n68: \tif workspace != \"\" {\n69: \t\tabsWorkspace, err = filepath.Abs(workspace)\n70: \t\tif err != nil {\n71: \t\t\tabsWorkspace = workspace\n72: \t\t}\n73: \t} else {\n74: \t\tabsWorkspace, err = os.Getwd()\n75: \t\tif err != nil {\n76: \t\t\treturn fmt.Errorf(\"failed to get current working directory: %w\", err)\n77: \t\t}\n78: \t}\n79: \n80: \tresolved, err := filepath.EvalSymlinks(absWorkspace)\n81: \tif err != nil {\n82: \t\tresolved, _ = filepath.Abs(absWorkspace)\n83: \t\tif resolved == \"\" {\n84: \t\t\tresolved = filepath.Clean(absWorkspace)\n85: \t\t}\n86: \t}\n87: \n88: \ts.workspaceDir = filepath.Clean(resolved)\n89: \n90: \tif err := os.MkdirAll(s.workspaceDir, 0755); err != nil {\n91: \t\treturn fmt.Errorf(\"failed to create workspace directory: %w\", err)\n92: \t}\n93: \n94: \treturn nil\n95: }\n96: \n97: func (s *Server) sanitizePath(p string) (string, error) {\n98: \tif s.workspaceDir == \"\" {\n99: \t\treturn \"\", errors.New(\"workspace directory not initialized\")\n100: \t}\n101: \n102: \tresolvedWorkspace := s.workspaceDir\n103: \tif evalSym, err := filepath.EvalSymlinks(s.workspaceDir); err == nil {\n104: \t\tresolvedWorkspace = evalSym\n105: \t}\n106: \tresolvedWorkspace = filepath.Clean(resolvedWorkspace)\n107: \n108: \tcleanPath := filepath.Clean(p)\n109: \tif filepath.IsAbs(cleanPath) {\n110: \t\tcleanPath = strings.TrimPrefix(cleanPath, string(os.PathSeparator))\n111: \t}\n112: \n113: \tfullPathCandidate := filepath.Clean(filepath.Join(resolvedWorkspace, cleanPath))\n114: \n115: \trelPath, relErr := filepath.Rel(resolvedWorkspace, fullPathCandidate)\n116: \tif relErr != nil {\n117: \t\treturn \"\", errors.New(\"access denied: path resolution failed\")\n118: \t}\n119: \n120: \tsep := string(os.PathSeparator)\n121: \tif strings.HasPrefix(relPath, \"..\"+sep) || relPath == \"..\" {\n122: \t\treturn \"\", errors.New(\"access denied: path escapes workspace\")\n123: \t}\n124: \n125: \tresolvedFinalPath, err := filepath.EvalSymlinks(fullPathCandidate)\n126: \tif err != nil {\n127: \t\treturn fullPathCandidate, nil\n128: \t}\n129: \n130: \tcheckRel, checkErr := filepath.Rel(resolvedWorkspace, resolvedFinalPath)\n131: \tif checkErr != nil {\n132: \t\treturn \"\", errors.New(\"access denied: path escape detected\")\n133: \t}\n134: \n135: \tif strings.HasPrefix(checkRel, \"..\"+sep) || checkRel == \"..\" {\n136: \t\treturn \"\", errors.New(\"access denied: path escapes workspace\")\n137: \t}\n138: \n139: \treturn resolvedFinalPath, nil\n140: }\n141: \n142: func (s *Server) registerRoutes(publicPaths []string) {\n143: \tallowQueryParam := false\n144: \tjwtIssuer := \"\"\n145: \tjwtAudience := \"\"\n146: \tif s.authConfig != nil {\n147: \t\tallowQueryParam = s.authConfig.AllowQueryParam\n148: \t\tjwtIssuer = s.authConfig.JWTIssuer\n149: \t\tjwtAudience = s.authConfig.JWTAudience\n150: \t}\n151: \n152: \tapi := s.engine.Group(\"/api\")\n153: \tapi.Use(s.authManager.Middleware(publicPaths, allowQueryParam, jwtIssuer, jwtAudience))\n154: \t{\n155: \t\tapi.POST(\"/execute\", s.ExecuteHandler)\n156: \t\tapi.POST(\"/files\", s.UploadFileHandler)\n157: \t\tapi.GET(\"/files\", s.ListFilesHandler)\n158: \t\tapi.GET(\"/files/*path\", s.DownloadFileHandler)\n159: \t}\n160: \n161: \ts.engine.GET(\"/health\", s.HealthCheckHandler)\n162: }\n163: \n164: func (s *Server) Run() error {\n165: \tserver := &http.Server{\n166: \t\tAddr:              fmt.Sprintf(\":%d\", s.config.Port),\n167: \t\tHandler:           s.engine,\n168: \t\tReadHeaderTimeout: 10 * time.Second,\n169: \t}\n170: \n171: \tklog.Infof(\"Starting PicoD server on port %d\", s.config.Port)\n172: \treturn server.ListenAndServe()\n173: }\n174: \n175: func (s *Server) GetEngine() *gin.Engine {\n176: \treturn s.engine\n177: }\n178: \n179: func (s *Server) GetWorkspaceDir() string {\n180: \treturn s.workspaceDir\n181: }\n182: \n183: func (s *Server) GetConfig() Config {\n184: \treturn s.config\n185: }\n186: \n187: func LoadRSAPublicKey(pemData string) (*rsa.PublicKey, error) {\n188: \tblock, _ := pem.Decode([]byte(pemData))\n189: \tif block == nil {\n190: \t\treturn nil, errors.New(\"failed to decode PEM block\")\n191: \t}\n192: \n193: \tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n194: \tif err != nil {\n195: \t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n196: \t}\n197: \n198: \trsaPubKey, ok := pubKey.(*rsa.PublicKey)\n199: \tif !ok {\n200: \t\treturn nil, errors.New(\"public key is not an RSA key\")\n201: \t}\n202: \n203: \treturn rsaPubKey, nil\n204: }\n\n(End of file - total 204 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tengine       *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/server.go","time":{"start":1775882944105,"end":1775882944125}}}}
