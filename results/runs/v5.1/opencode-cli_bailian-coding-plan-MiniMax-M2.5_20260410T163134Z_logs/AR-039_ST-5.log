63134Z/pkg/store/singleton.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/errors.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/common/types/types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_test.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/files.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_manager_test.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_manager_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_manager_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_manager_test.go\n@@ -6,8 +6,9 @@\n \"crypto/x509\"\n \"encoding/base64\"\n \"net/http\"\n \"net/http/httptest\"\n+\"os\"\n \"testing\"\n \"time\"\n \n \"github.com/gin-gonic/gin\"\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_manager_test.go","before":"package picod\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nfunc init() {\n\tgin.SetMode(gin.TestMode)\n}\n\nfunc TestAuthManager_NewAuthManager(t *testing.T) {\n\tam := NewAuthManager()\n\tif am == nil {\n\t\tt.Error(\"expected AuthManager to be created\")\n\t}\n\tif am.publicKey != nil {\n\t\tt.Error(\"expected public key to be nil initially\")\n\t}\n}\n\nfunc TestAuthManager_GetPublicKey(t *testing.T) {\n\tam := NewAuthManager()\n\tkey := am.GetPublicKey()\n\tif key != nil {\n\t\tt.Error(\"expected nil public key\")\n\t}\n}\n\nfunc TestAuthManager_LoadPublicKeyFromEnv_Empty(t *testing.T) {\n\tos.Unsetenv(PublicKeyEnvVar)\n\tam := NewAuthManager()\n\terr := am.LoadPublicKeyFromEnv()\n\tif err == nil {\n\t\tt.Error(\"expected error for empty env var\")\n\t}\n}\n\nfunc TestAuthManager_ReloadPublicKey(t *testing.T) {\n\ttestKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate test key: %v\", err)\n\t}\n\n\tpubKeyBytes, err := x509.MarshalPKIXPublicKey(&testKey.PublicKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to marshal public key: %v\", err)\n\t}\n\tpemData := base64.StdEncoding.EncodeToString(pubKeyBytes)\n\tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n\tfor i := 0; i < len(pemData); i += 64 {\n\t\tend := i + 64\n\t\tif end > len(pemData) {\n\t\t\tend = len(pemData)\n\t\t}\n\t\tpemBlock += pemData[i:end] + \"\\n\"\n\t}\n\tpemBlock += \"-----END PUBLIC KEY-----\"\n\n\tos.Setenv(PublicKeyEnvVar, pemBlock)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tam := NewAuthManager()\n\terr = am.ReloadPublicKey()\n\tif err != nil {\n\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t}\n\n\tif am.GetPublicKey() == nil {\n\t\tt.Error(\"expected public key to be set\")\n\t}\n}\n\nfunc TestAuthManager_Middleware_MissingHeader(t *testing.T) {\n\tam := NewAuthManager()\n\tam.publicKey = &testRSAKey.PublicKey\n\n\tw := httptest.NewRecorder()\n\tc, _ := gin.CreateTestContext(w)\n\tc.Request = httptest.NewRequest(\"GET\", \"/test\", nil)\n\n\tam.AuthMiddleware()(c)\n\n\tif c.IsAborted() {\n\t\tif w.Code != http.StatusUnauthorized {\n\t\t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n\t\t}\n\t}\n}\n\nfunc TestAuthManager_Middleware_InvalidFormat(t *testing.T) {\n\tam := NewAuthManager()\n\tam.publicKey = &testRSAKey.PublicKey\n\n\tw := httptest.NewRecorder()\n\tc, _ := gin.CreateTestContext(w)\n\tc.Request = httptest.NewRequest(\"GET\", \"/test\", nil)\n\tc.Request.Header.Set(\"Authorization\", \"InvalidFormat\")\n\n\tam.AuthMiddleware()(c)\n\n\tif c.IsAborted() {\n\t\tif w.Code != http.StatusUnauthorized {\n\t\t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n\t\t}\n\t}\n}\n\nfunc TestAuthManager_Middleware_NoPublicKey(t *testing.T) {\n\tam := NewAuthManager()\n\n\tw := httptest.NewRecorder()\n\tc, _ := gin.CreateTestContext(w)\n\tc.Request = httptest.NewRequest(\"GET\", \"/test\", nil)\n\tc.Request.Header.Set(\"Authorization\", \"Bearer token\")\n\n\tam.AuthMiddleware()(c)\n\n\tif c.IsAborted() {\n\t\tif w.Code != http.StatusUnauthorized {\n\t\t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n\t\t}\n\t}\n}\n\nfunc TestAuthManager_Middleware_ValidToken(t *testing.T) {\n\ttestKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate test key: %v\", err)\n\t}\n\n\tpubKeyBytes, _ := x509.MarshalPKIXPublicKey(&testKey.PublicKey)\n\tpemData := base64.StdEncoding.EncodeToString(pubKeyBytes)\n\tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n\tfor i := 0; i < len(pemData); i += 64 {\n\t\tend := i + 64\n\t\tif end > len(pemData) {\n\t\t\tend = len(pemData)\n\t\t}\n\t\tpemBlock += pemData[i:end] + \"\\n\"\n\t}\n\tpemBlock += \"-----END PUBLIC KEY-----\"\n\n\tos.Setenv(PublicKeyEnvVar, pemBlock)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tclaims := jwt.MapClaims{\n\t\t\"exp\": time.Now().Add(time.Hour).Unix(),\n\t\t\"iat\": time.Now().Unix(),\n\t}\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, _ := token.SignedString(testKey)\n\n\tam := NewAuthManager()\n\tam.LoadPublicKeyFromEnv()\n\n\tw := httptest.NewRecorder()\n\tc, _ := gin.CreateTestContext(w)\n\tc.Request = httptest.NewRequest(\"GET\", \"/test\", nil)\n\tc.Request.Header.Set(\"Authorization\", \"Bearer \"+tokenString)\n\n\tam.AuthMiddleware()(c)\n\n\tif c.IsAborted() {\n\t\tt.Error(\"request should not be aborted for valid token\")\n\t}\n\tif w.Code != http.StatusOK && w.Code != 0 {\n\t\tt.Errorf(\"expected status 0 or 200, got %d\", w.Code)\n\t}\n}\n\nfunc TestAuthManager_Middleware_ExpiredToken(t *testing.T) {\n\ttestKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate test key: %v\", err)\n\t}\n\n\tpubKeyBytes, _ := x509.MarshalPKIXPublicKey(&testKey.PublicKey)\n\tpemData := base64.StdEncoding.EncodeToString(pubKeyBytes)\n\tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n\tfor i := 0; i < len(pemData); i += 64 {\n\t\tend := i + 64\n\t\tif end > len(pemData) {\n\t\t\tend = len(pemData)\n\t\t}\n\t\tpemBlock += pemData[i:end] + \"\\n\"\n\t}\n\tpemBlock += \"-----END PUBLIC KEY-----\"\n\n\tos.Setenv(PublicKeyEnvVar, pemBlock)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tclaims := jwt.MapClaims{\n\t\t\"exp\": time.Now().Add(-time.Hour).Unix(),\n\t\t\"iat\": time.Now().Add(-2 * time.Hour).Unix(),\n\t}\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, _ := token.SignedString(testKey)\n\n\tam := NewAuthManager()\n\tam.LoadPublicKeyFromEnv()\n\n\tw := httptest.NewRecorder()\n\tc, _ := gin.CreateTestContext(w)\n\tc.Request = httptest.NewRequest(\"GET\", \"/test\", nil)\n\tc.Request.Header.Set(\"Authorization\", \"Bearer \"+tokenString)\n\n\tam.AuthMiddleware()(c)\n\n\tif !c.IsAborted() {\n\t\tt.Error(\"request should be aborted for expired token\")\n\t}\n}\n\nfunc TestAuthManager_Middleware_InvalidToken(t *testing.T) {\n\tam := NewAuthManager()\n\tam.publicKey = &testRSAKey.PublicKey\n\n\tw := httptest.NewRecorder()\n\tc, _ := gin.CreateTestContext(w)\n\tc.Request = httptest.NewRequest(\"GET\", \"/test\", nil)\n\tc.Request.Header.Set(\"Authorization\", \"Bearer invalidtoken\")\n\n\tam.AuthMiddleware()(c)\n\n\tif !c.IsAborted() {\n\t\tt.Error(\"request should be aborted for invalid token\")\n\t}\n}\n\nfunc TestAuthManager_RequireAuth(t *testing.T) {\n\ttestKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate test key: %v\", err)\n\t}\n\n\tpubKeyBytes, _ := x509.MarshalPKIXPublicKey(&testKey.PublicKey)\n\tpemData := base64.StdEncoding.EncodeToString(pubKeyBytes)\n\tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n\tfor i := 0; i < len(pemData); i += 64 {\n\t\tend := i + 64\n\t\tif end > len(pemData) {\n\t\t\tend = len(pemData)\n\t\t}\n\t\tpemBlock += pemData[i:end] + \"\\n\"\n\t}\n\tpemBlock += \"-----END PUBLIC KEY-----\"\n\n\tos.Setenv(PublicKeyEnvVar, pemBlock)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tam := NewAuthManager()\n\tam.RequireAuth()\n}\n\nfunc TestAuthErrorCodes(t *testing.T) {\n\tif ErrCodeMissingHeader != \"AUTH_MISSING_HEADER\" {\n\t\tt.Errorf(\"unexpected ErrCodeMissingHeader: %s\", ErrCodeMissingHeader)\n\t}\n\tif ErrCodeInvalidFormat != \"AUTH_INVALID_FORMAT\" {\n\t\tt.Errorf(\"unexpected ErrCodeInvalidFormat: %s\", ErrCodeInvalidFormat)\n\t}\n\tif ErrCodeInvalidToken != \"AUTH_INVALID_TOKEN\" {\n\t\tt.Errorf(\"unexpected ErrCodeInvalidToken: %s\", ErrCodeInvalidToken)\n\t}\n\tif ErrCodeTokenExpired != \"AUTH_TOKEN_EXPIRED\" {\n\t\tt.Errorf(\"unexpected ErrCodeTokenExpired: %s\", ErrCodeTokenExpired)\n\t}\n\tif ErrCodeKeyNotConfigured != \"AUTH_KEY_NOT_CONFIGURED\" {\n\t\tt.Errorf(\"unexpected ErrCodeKeyNotConfigured: %s\", ErrCodeKeyNotConfigured)\n\t}\n}\n\nfunc TestMaxBodySize(t *testing.T) {\n\tif MaxBodySize != 32<<20 {\n\t\tt.Errorf(\"unexpected MaxBodySize: %d\", MaxBodySize)\n\t}\n}\n\nfunc TestLoadRSAPublicKey_InvalidPEM(t *testing.T) {\n\t_, err := LoadRSAPublicKey(\"invalid pem data\")\n\tif err == nil {\n\t\tt.Error(\"expected error for invalid PEM\")\n\t}\n}\n\nfunc TestLoadRSAPublicKey_Valid(t *testing.T) {\n\ttestKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate test key: %v\", err)\n\t}\n\n\tpub