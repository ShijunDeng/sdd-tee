{"type":"tool_use","timestamp":1775882959396,"sessionID":"ses_28521088effewq5bKneqHzbGUF","part":{"id":"prt_d7adf725a001ctxlacwdYFdwLp","messageID":"msg_d7adf5c48001dsWKHAGDrbpMON","sessionID":"ses_28521088effewq5bKneqHzbGUF","type":"tool","tool":"read","callID":"toolu_79f5c8d739aa4a5e9047a93c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/backend.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/backend.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"net/url\"\n5: \t\"sync\"\n6: \t\"time\"\n7: )\n8: \n9: type Backend struct {\n10: \tURL                 *url.URL\n11: \tPathPrefix          string\n12: \tName                string\n13: \tHealthy             bool\n14: \tConsecutiveFailures int\n15: \tLastHealthyCheck    time.Time\n16: \tmu                  sync.RWMutex\n17: }\n18: \n19: type BackendPool struct {\n20: \tbackends       map[string]*Backend\n21: \theaderRoutes   map[string]map[string]string // header name -> header value -> backend key\n22: \tdefaultBackend string\n23: \tmu             sync.RWMutex\n24: }\n25: \n26: func NewBackendPool() *BackendPool {\n27: \treturn &BackendPool{\n28: \t\tbackends:       make(map[string]*Backend),\n29: \t\theaderRoutes:   make(map[string]map[string]string),\n30: \t\tdefaultBackend: \"\",\n31: \t}\n32: }\n33: \n34: func (bp *BackendPool) AddBackend(key, endpoint, pathPrefix, name string) error {\n35: \tbp.mu.Lock()\n36: \tdefer bp.mu.Unlock()\n37: \n38: \tparsedURL, err := url.Parse(endpoint)\n39: \tif err != nil {\n40: \t\treturn err\n41: \t}\n42: \n43: \tbp.backends[key] = &Backend{\n44: \t\tURL:              parsedURL,\n45: \t\tPathPrefix:       pathPrefix,\n46: \t\tName:             name,\n47: \t\tHealthy:          true,\n48: \t\tLastHealthyCheck: time.Now(),\n49: \t}\n50: \n51: \tif bp.defaultBackend == \"\" {\n52: \t\tbp.defaultBackend = key\n53: \t}\n54: \n55: \treturn nil\n56: }\n57: \n58: func (bp *BackendPool) RemoveBackend(key string) {\n59: \tbp.mu.Lock()\n60: \tdefer bp.mu.Unlock()\n61: \n62: \tdelete(bp.backends, key)\n63: \n64: \tif bp.defaultBackend == key {\n65: \t\tbp.defaultBackend = \"\"\n66: \t\tfor k := range bp.backends {\n67: \t\t\tbp.defaultBackend = k\n68: \t\t\tbreak\n69: \t\t}\n70: \t}\n71: \n72: \tfor _, routeMap := range bp.headerRoutes {\n73: \t\tdelete(routeMap, key)\n74: \t}\n75: }\n76: \n77: func (bp *BackendPool) UpdateBackend(key, endpoint, pathPrefix string) error {\n78: \tbp.mu.Lock()\n79: \tdefer bp.mu.Unlock()\n80: \n81: \tbackend, exists := bp.backends[key]\n82: \tif !exists {\n83: \t\treturn nil\n84: \t}\n85: \n86: \tparsedURL, err := url.Parse(endpoint)\n87: \tif err != nil {\n88: \t\treturn err\n89: \t}\n90: \n91: \tbackend.URL = parsedURL\n92: \tbackend.PathPrefix = pathPrefix\n93: \n94: \treturn nil\n95: }\n96: \n97: func (bp *BackendPool) GetBackendByPath(path string) *Backend {\n98: \tbp.mu.RLock()\n99: \tdefer bp.mu.RUnlock()\n100: \n101: \tfor _, backend := range bp.backends {\n102: \t\tif backend.Healthy && len(backend.PathPrefix) > 0 &&\n103: \t\t\t(path == backend.PathPrefix ||\n104: \t\t\t\t(len(path) > len(backend.PathPrefix) && path[:len(backend.PathPrefix)] == backend.PathPrefix)) {\n105: \t\t\treturn backend\n106: \t\t}\n107: \t}\n108: \n109: \tif bp.defaultBackend != \"\" {\n110: \t\treturn bp.backends[bp.defaultBackend]\n111: \t}\n112: \n113: \treturn nil\n114: }\n115: \n116: func (bp *BackendPool) GetBackendByHeader(headerName, headerValue string) *Backend {\n117: \tbp.mu.RLock()\n118: \tdefer bp.mu.RUnlock()\n119: \n120: \trouteMap, exists := bp.headerRoutes[headerName]\n121: \tif !exists {\n122: \t\treturn nil\n123: \t}\n124: \n125: \tbackendKey, exists := routeMap[headerValue]\n126: \tif !exists {\n127: \t\treturn nil\n128: \t}\n129: \n130: \tbackend, exists := bp.backends[backendKey]\n131: \tif exists && backend.Healthy {\n132: \t\treturn backend\n133: \t}\n134: \n135: \treturn nil\n136: }\n137: \n138: func (bp *BackendPool) SetHeaderRoute(headerName, headerValue, backendKey string) {\n139: \tbp.mu.Lock()\n140: \tdefer bp.mu.Unlock()\n141: \n142: \tif _, exists := bp.backends[backendKey]; !exists {\n143: \t\treturn\n144: \t}\n145: \n146: \tif _, exists := bp.headerRoutes[headerName]; !exists {\n147: \t\tbp.headerRoutes[headerName] = make(map[string]string)\n148: \t}\n149: \n150: \tbp.headerRoutes[headerName][headerValue] = backendKey\n151: }\n152: \n153: func (bp *BackendPool) SetDefaultBackend(key string) {\n154: \tbp.mu.Lock()\n155: \tdefer bp.mu.Unlock()\n156: \n157: \tif _, exists := bp.backends[key]; exists {\n158: \t\tbp.defaultBackend = key\n159: \t}\n160: }\n161: \n162: func (bp *BackendPool) GetAllBackends() map[string]*Backend {\n163: \tbp.mu.RLock()\n164: \tdefer bp.mu.RUnlock()\n165: \n166: \tresult := make(map[string]*Backend)\n167: \tfor k, v := range bp.backends {\n168: \t\tresult[k] = v\n169: \t}\n170: \n171: \treturn result\n172: }\n173: \n174: func (b *Backend) SetHealthy(healthy bool) {\n175: \tb.mu.Lock()\n176: \tdefer b.mu.Unlock()\n177: \n178: \tb.Healthy = healthy\n179: \tif healthy {\n180: \t\tb.ConsecutiveFailures = 0\n181: \t} else {\n182: \t\tb.ConsecutiveFailures++\n183: \t}\n184: \tb.LastHealthyCheck = time.Now()\n185: }\n186: \n187: func (b *Backend) IsHealthy() bool {\n188: \tb.mu.RLock()\n189: \tdefer b.mu.RUnlock()\n190: \n191: \treturn b.Healthy\n192: }\n193: \n194: func (b *Backend) GetConsecutiveFailures() int {\n195: \tb.mu.RLock()\n196: \tdefer b.mu.RUnlock()\n197: \n198: \treturn b.ConsecutiveFailures\n199: }\n200: \n201: func (b *Backend) RecordFailure() {\n202: \tb.mu.Lock()\n203: \tdefer b.mu.Unlock()\n204: \n205: \tb.ConsecutiveFailures++\n206: \tb.Healthy = b.ConsecutiveFailures < 3\n207: }\n208: \n209: func (b *Backend) RecordSuccess() {\n210: \tb.mu.Lock()\n211: \tdefer b.mu.Unlock()\n212: \n213: \tb.ConsecutiveFailures = 0\n214: \tb.Healthy = true\n215: \tb.LastHealthyCheck = time.Now()\n216: }\n\n(End of file - total 216 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/url\"\n\t\"sync\"\n\t\"time\"\n)\n\ntype Backend struct {\n\tURL                 *url.URL\n\tPathPrefix          string\n\tName                string\n\tHealthy             bool\n\tConsecutiveFailures int\n\tLastHealthyCheck    time.Time\n\tmu                  sync.RWMutex\n}\n\ntype BackendPool struct {\n\tbackends       map[string]*Backend","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/backend.go","time":{"start":1775882959382,"end":1775882959395}}}}
