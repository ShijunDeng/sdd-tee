{"type":"tool_use","timestamp":1775883051719,"sessionID":"ses_28521088effewq5bKneqHzbGUF","part":{"id":"prt_d7adfffee001zh7aJC6kXXlSrn","messageID":"msg_d7adff68e001hQvdpqi4oTi3v0","sessionID":"ses_28521088effewq5bKneqHzbGUF","type":"tool","tool":"write","callID":"toolu_7f78e945e4bd454cb94a80f0","state":{"status":"completed","input":{"content":"package store\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype mockStore struct {\n\tsessions map[string]*types.SandboxInfo\n\texpiryIndex map[string]time.Time\n\tlastActivityIndex map[string]time.Time\n}\n\nfunc newMockStore() *mockStore {\n\treturn &mockStore{\n\t\tsessions: make(map[string]*types.SandboxInfo),\n\t\texpiryIndex: make(map[string]time.Time),\n\t\tlastActivityIndex: make(map[string]time.Time),\n\t}\n}\n\nfunc (m *mockStore) Ping(ctx context.Context) error {\n\treturn nil\n}\n\nfunc (m *mockStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\tif sandbox, ok := m.sessions[sessionID]; ok {\n\t\treturn sandbox, nil\n\t}\n\treturn nil, ErrNotFound\n}\n\nfunc (m *mockStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn errors.New(\"sandbox is nil\")\n\t}\n\tif sandboxStore.ExpiresAt.IsZero() {\n\t\treturn errors.New(\"invalid expiry: ExpiresAt is zero\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn errors.New(\"session ID is required\")\n\t}\n\tm.sessions[sandboxStore.SessionID] = sandboxStore\n\tm.expiryIndex[sandboxStore.SessionID] = sandboxStore.ExpiresAt\n\tm.lastActivityIndex[sandboxStore.SessionID] = time.Now()\n\treturn nil\n}\n\nfunc (m *mockStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn errors.New(\"sandbox is nil\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn errors.New(\"session ID is required\")\n\t}\n\tif _, ok := m.sessions[sandboxStore.SessionID]; !ok {\n\t\treturn errors.New(\"key not exists\")\n\t}\n\tm.sessions[sandboxStore.SessionID] = sandboxStore\n\treturn nil\n}\n\nfunc (m *mockStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\tdelete(m.sessions, sessionID)\n\tdelete(m.expiryIndex, sessionID)\n\tdelete(m.lastActivityIndex, sessionID)\n\treturn nil\n}\n\nfunc (m *mockStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tif limit <= 0 {\n\t\treturn nil, nil\n\t}\n\tvar result []*types.SandboxInfo\n\tcount := int64(0)\n\tfor sessionID, expiry := range m.expiryIndex {\n\t\tif count >= limit {\n\t\t\tbreak\n\t\t}\n\t\tif expiry.Before(before) {\n\t\t\tif sandbox, ok := m.sessions[sessionID]; ok {\n\t\t\t\tresult = append(result, sandbox)\n\t\t\t\tcount++\n\t\t\t}\n\t\t}\n\t}\n\treturn result, nil\n}\n\nfunc (m *mockStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tif limit <= 0 {\n\t\treturn nil, nil\n\t}\n\tvar result []*types.SandboxInfo\n\tcount := int64(0)\n\tfor sessionID, lastActivity := range m.lastActivityIndex {\n\t\tif count >= limit {\n\t\t\tbreak\n\t\t}\n\t\tif lastActivity.Before(before) {\n\t\t\tif sandbox, ok := m.sessions[sessionID]; ok {\n\t\t\t\tresult = append(result, sandbox)\n\t\t\t\tcount++\n\t\t\t}\n\t\t}\n\t}\n\treturn result, nil\n}\n\nfunc (m *mockStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n\tif sessionID == \"\" {\n\t\treturn errors.New(\"session ID is required\")\n\t}\n\tif _, ok := m.sessions[sessionID]; !ok {\n\t\treturn ErrNotFound\n\t}\n\tm.lastActivityIndex[sessionID] = at\n\treturn nil\n}\n\nfunc (m *mockStore) Close() error {\n\treturn nil\n}\n\nfunc TestStoreInterface(t *testing.T) {\n\tctx := context.Background()\n\tstore := newMockStore()\n\n\tt.Run(\"Ping\", func(t *testing.T) {\n\t\terr := store.Ping(ctx)\n\t\tif err != nil {\n\t\t\tt.Errorf(\"unexpected error: %v\", err)\n\t\t}\n\t})\n\n\tt.Run(\"StoreSandbox_Nil\", func(t *testing.T) {\n\t\terr := store.StoreSandbox(ctx, nil)\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for nil sandbox\")\n\t\t}\n\t})\n\n\tt.Run(\"StoreSandbox_ZeroExpiry\", func(t *testing.T) {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tSessionID: \"test-session\",\n\t\t\tExpiresAt: time.Time{},\n\t\t}\n\t\terr := store.StoreSandbox(ctx, sandbox)\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for zero expiry\")\n\t\t}\n\t})\n\n\tt.Run(\"StoreSandbox_EmptySessionID\", func(t *testing.T) {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tSessionID: \"\",\n\t\t\tExpiresAt: time.Now().Add(time.Hour),\n\t\t}\n\t\terr := store.StoreSandbox(ctx, sandbox)\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for empty session ID\")\n\t\t}\n\t})\n\n\tt.Run(\"StoreAndGet\", func(t *testing.T) {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tSessionID: \"test-session-1\",\n\t\t\tSandboxID: \"sandbox-1\",\n\t\t\tName:      \"test-sandbox\",\n\t\t\tExpiresAt: time.Now().Add(time.Hour),\n\t\t\tStatus:    \"running\",\n\t\t}\n\t\terr := store.StoreSandbox(ctx, sandbox)\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\n\t\tretrieved, err := store.GetSandboxBySessionID(ctx, \"test-session-1\")\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\t\tif retrieved.SessionID != sandbox.SessionID {\n\t\t\tt.Errorf(\"expected session ID %s, got %s\", sandbox.SessionID, retrieved.SessionID)\n\t\t}\n\t\tif retrieved.SandboxID != sandbox.SandboxID {\n\t\t\tt.Errorf(\"expected sandbox ID %s, got %s\", sandbox.SandboxID, retrieved.SandboxID)\n\t\t}\n\t})\n\n\tt.Run(\"Get_NotFound\", func(t *testing.T) {\n\t\t_, err := store.GetSandboxBySessionID(ctx, \"non-existent\")\n\t\tif !errors.Is(err, ErrNotFound) {\n\t\t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n\t\t}\n\t})\n\n\tt.Run(\"UpdateSandbox_Nil\", func(t *testing.T) {\n\t\terr := store.UpdateSandbox(ctx, nil)\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for nil sandbox\")\n\t\t}\n\t})\n\n\tt.Run(\"UpdateSandbox_EmptySessionID\", func(t *testing.T) {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tSessionID: \"\",\n\t\t}\n\t\terr := store.UpdateSandbox(ctx, sandbox)\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for empty session ID\")\n\t\t}\n\t})\n\n\tt.Run(\"UpdateSandbox_NotFound\", func(t *testing.T) {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tSessionID: \"non-existent\",\n\t\t\tSandboxID: \"sandbox-2\",\n\t\t}\n\t\terr := store.UpdateSandbox(ctx, sandbox)\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for non-existent session\")\n\t\t}\n\t})\n\n\tt.Run(\"UpdateSandbox_Success\", func(t *testing.T) {\n\t\tstore.sessions[\"test-session-2\"] = &types.SandboxInfo{\n\t\t\tSessionID: \"test-session-2\",\n\t\t\tSandboxID: \"sandbox-2\",\n\t\t\tStatus:    \"running\",\n\t\t}\n\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tSessionID: \"test-session-2\",\n\t\t\tSandboxID: \"sandbox-2-updated\",\n\t\t\tStatus:    \"stopped\",\n\t\t}\n\t\terr := store.UpdateSandbox(ctx, sandbox)\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\n\t\tretrieved, _ := store.GetSandboxBySessionID(ctx, \"test-session-2\")\n\t\tif retrieved.Status != \"stopped\" {\n\t\t\tt.Errorf(\"expected status 'stopped', got %s\", retrieved.Status)\n\t\t}\n\t})\n\n\tt.Run(\"DeleteSandbox\", func(t *testing.T) {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tSessionID: \"test-session-3\",\n\t\t\tSandboxID: \"sandbox-3\",\n\t\t\tExpiresAt: time.Now().Add(time.Hour),\n\t\t}\n\t\tstore.StoreSandbox(ctx, sandbox)\n\n\t\terr := store.DeleteSandboxBySessionID(ctx, \"test-session-3\")\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\n\t\t_, err = store.GetSandboxBySessionID(ctx, \"test-session-3\")\n\t\tif !errors.Is(err, ErrNotFound) {\n\t\t\tt.Errorf(\"expected ErrNotFound after deletion\")\n\t\t}\n\t})\n\n\tt.Run(\"ListExpiredSandboxes_ZeroLimit\", func(t *testing.T) {\n\t\tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\t\tif result != nil {\n\t\t\tt.Error(\"expected nil for zero limit\")\n\t\t}\n\t})\n\n\tt.Run(\"ListExpiredSandboxes_NegativeLimit\", func(t *testing.T) {\n\t\tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\t\tif result != nil {\n\t\t\tt.Error(\"expected nil for negative limit\")\n\t\t}\n\t})\n\n\tt.Run(\"ListExpiredSandboxes_Success\", func(t *testing.T) {\n\t\tpastTime := time.Now().Add(-time.Hour)\n\t\tfutureTime := time.Now().Add(time.Hour)\n\n\t\tstore.StoreSandbox(ctx, &types.SandboxInfo{\n\t\t\tSessionID: \"expired-session\",\n\t\t\tSandboxID: \"sandbox-expired\",\n\t\t\tExpiresAt: pastTime,\n\t\t})\n\t\tstore.StoreSandbox(ctx, &types.SandboxInfo{\n\t\t\tSessionID: \"active-session\",\n\t\t\tSandboxID: \"sandbox-active\",\n\t\t\tExpiresAt: futureTime,\n\t\t})\n\n\t\tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), 10)\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\n\t\tif len(result) != 1 {\n\t\t\tt.Errorf(\"expected 1 expired sandbox, got %d\", len(result))\n\t\t}\n\t\tif result[0].SessionID != \"expired-session\" {\n\t\t\tt.Errorf(\"expected expired-session, got %s\", result[0].SessionID)\n\t\t}\n\t})\n\n\tt.Run(\"ListInactiveSandboxes_Success\", func(t *testing.T) {\n\t\tnow := time.Now()\n\t\tpastTime := now.Add(-time.Hour)\n\t\tfutureTime := now.Add(time.Hour)\n\n\t\tstore.lastActivityIndex[\"inactive-session\"] = pastTime\n\t\tstore.sessions[\"inactive-session\"] = &types.SandboxInfo{\n\t\t\tSessionID: \"inactive-session\",\n\t\t\tSandboxID: \"sandbox-inactive\",\n\t\t}\n\t\tstore.lastActivityIndex[\"active-session-2\"] = futureTime\n\t\tstore.sessions[\"active-session-2\"] = &types.SandboxInfo{\n\t\t\tSessionID: \"active-session-2\",\n\t\t\tSandboxID: \"sandbox-active-2\",\n\t\t}\n\n\t\tresult, err := store.ListInactiveSandboxes(ctx, now, 10)\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\n\t\tif len(result) != 1 {\n\t\t\tt.Errorf(\"expected 1 inactive sandbox, got %d\", len(result))\n\t\t}\n\t\tif result[0].SessionID != \"inactive-session\" {\n\t\t\tt.Errorf(\"expected inactive-session, got %s\", result[0].SessionID)\n\t\t}\n\t})\n\n\tt.Run(\"UpdateSessionLastActivity_EmptySessionID\", func(t *testing.T) {\n\t\terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for empty session ID\")\n\t\t}\n\t})\n\n\tt.Run(\"UpdateSessionLastActivity_NotFound\", func(t *testing.T) {\n\t\terr := store.UpdateSessionLastActivity(ctx, \"non-existent-session\", time.Now())\n\t\tif !errors.Is(err, ErrNotFound) {\n\t\t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n\t\t}\n\t})\n\n\tt.Run(\"UpdateSessionLastActivity_Success\", func(t *testing.T) {\n\t\tstore.sessions[\"test-session-4\"] = &types.SandboxInfo{\n\t\t\tSessionID: \"test-session-4\",\n\t\t\tSandboxID: \"sandbox-4\",\n\t\t}\n\n\t\tnewTime := time.Now().Add(-time.Minute)\n\t\terr := store.UpdateSessionLastActivity(ctx, \"test-session-4\", newTime)\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\n\t\tif store.lastActivityIndex[\"test-session-4\"] != newTime {\n\t\t\tt.Errorf(\"expected last activity to be updated\")\n\t\t}\n\t})\n\n\tt.Run(\"Close\", func(t *testing.T) {\n\t\terr := store.Close()\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t\t}\n\t})\n}\n\nfunc TestStoreSandboxWithEntryPoints(t *testing.T) {\n\tctx := context.Background()\n\tstore := newMockStore()\n\n\tsandbox := &types.SandboxInfo{\n\t\tSessionID: \"session-with-endpoints\",\n\t\tSandboxID: \"sandbox-endpoints\",\n\t\tName:      \"test-sandbox\",\n\t\tEntryPoints: []types.SandboxEntryPoint{\n\t\t\t{\n\t\t\t\tPath:     \"/agent/api\",\n\