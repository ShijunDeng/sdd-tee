 func makeRedisOptions() (*redis.Options, error) {\n53: \tredisAddr := os.Getenv(\"REDIS_ADDR\")\n54: \tif redisAddr == \"\" {\n55: \t\treturn nil, errors.New(\"REDIS_ADDR is required\")\n56: \t}\n57: \n58: \tredisPasswordRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n59: \tredisPassword := os.Getenv(\"REDIS_PASSWORD\")\n60: \n61: \tpasswordRequired := true\n62: \tif strings.EqualFold(redisPasswordRequired, \"false\") {\n63: \t\tpasswordRequired = false\n64: \t}\n65: \n66: \tif passwordRequired && redisPassword == \"\" {\n67: \t\treturn nil, errors.New(\"REDIS_PASSWORD is required\")\n68: \t}\n69: \n70: \treturn &redis.Options{\n71: \t\tAddr:     redisAddr,\n72: \t\tPassword: redisPassword,\n73: \t}, nil\n74: }\n75: \n76: func (rs *redisStore) Ping(ctx context.Context) error {\n77: \tresult, err := rs.cli.Ping(ctx).Result()\n78: \tif err != nil {\n79: \t\treturn err\n80: \t}\n81: \tif result != \"PONG\" {\n82: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n83: \t}\n84: \treturn nil\n85: }\n86: \n87: func (rs *redisStore) sessionKey(sessionID string) string {\n88: \treturn rs.sessionPrefix + sessionID\n89: }\n90: \n91: func (rs *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n92: \tkey := rs.sessionKey(sessionID)\n93: \tdata, err := rs.cli.Get(ctx, key).Bytes()\n94: \tif err != nil {\n95: \t\tif errors.Is(err, redis.Nil) {\n96: \t\t\treturn nil, ErrNotFound\n97: \t\t}\n98: \t\treturn nil, err\n99: \t}\n100: \n101: \tvar sandbox types.SandboxInfo\n102: \tif err := json.Unmarshal(data, &sandbox); err != nil {\n103: \t\treturn nil, err\n104: \t}\n105: \n106: \treturn &sandbox, nil\n107: }\n108: \n109: func (rs *redisStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n110: \tif sandboxStore == nil {\n111: \t\treturn errors.New(\"sandbox is nil\")\n112: \t}\n113: \tif sandboxStore.ExpiresAt.IsZero() {\n114: \t\treturn errors.New(\"invalid expiry: ExpiresAt is zero\")\n115: \t}\n116: \n117: \tif sandboxStore.SessionID == \"\" {\n118: \t\treturn errors.New(\"session ID is required\")\n119: \t}\n120: \n121: \tkey := rs.sessionKey(sandboxStore.SessionID)\n122: \tdata, err := json.Marshal(sandboxStore)\n123: \tif err != nil {\n124: \t\treturn err\n125: \t}\n126: \n127: \tnow := time.Now().Unix()\n128: \texpiryScore := float64(sandboxStore.ExpiresAt.Unix())\n129: \tlastActivityScore := float64(now)\n130: \n131: \tpipe := rs.cli.Pipeline()\n132: \tpipe.SetNX(ctx, key, data, 0)\n133: \tpipe.ZAdd(ctx, rs.expiryIndexKey, redis.Z{Score: expiryScore, Member: sandboxStore.SessionID})\n134: \tpipe.ZAdd(ctx, rs.lastActivityIndexKey, redis.Z{Score: lastActivityScore, Member: sandboxStore.SessionID})\n135: \n136: \t_, err = pipe.Exec(ctx)\n137: \tif err != nil {\n138: \t\treturn err\n139: \t}\n140: \n141: \treturn nil\n142: }\n143: \n144: func (rs *redisStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n145: \tif sandboxStore == nil {\n146: \t\treturn errors.New(\"sandbox is nil\")\n147: \t}\n148: \tif sandboxStore.SessionID == \"\" {\n149: \t\treturn errors.New(\"session ID is required\")\n150: \t}\n151: \n152: \tkey := rs.sessionKey(sandboxStore.SessionID)\n153: \tdata, err := json.Marshal(sandboxStore)\n154: \tif err != nil {\n155: \t\treturn err\n156: \t}\n157: \n158: \tsuccess, err := rs.cli.SetXX(ctx, key, data, 0).Result()\n159: \tif err != nil {\n160: \t\treturn err\n161: \t}\n162: \tif !success {\n163: \t\treturn errors.New(\"key not exists\")\n164: \t}\n165: \n166: \treturn nil\n167: }\n168: \n169: func (rs *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n170: \tkey := rs.sessionKey(sessionID)\n171: \n172: \tpipe := rs.cli.Pipeline()\n173: \tpipe.Del(ctx, key)\n174: \tpipe.ZRem(ctx, rs.expiryIndexKey, sessionID)\n175: \tpipe.ZRem(ctx, rs.lastActivityIndexKey, sessionID)\n176: \n177: \t_, err := pipe.Exec(ctx)\n178: \tif err != nil {\n179: \t\treturn err\n180: \t}\n181: \n182: \treturn nil\n183: }\n184: \n185: func (rs *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n186: \tif limit <= 0 {\n187: \t\treturn nil, nil\n188: \t}\n189: \n190: \tsessionIDs, err := rs.cli.ZRangeByScore(ctx, rs.expiryIndexKey, &redis.ZRangeBy{\n191: \t\tMin:    \"-inf\",\n192: \t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n193: \t\tOffset: 0,\n194: \t\tCount:  limit,\n195: \t}).Result()\n196: \tif err != nil {\n197: \t\treturn nil, err\n198: \t}\n199: \n200: \treturn rs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n201: }\n202: \n203: func (rs *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n204: \tif limit <= 0 {\n205: \t\treturn nil, nil\n206: \t}\n207: \n208: \tsessionIDs, err := rs.cli.ZRangeByScore(ctx, rs.lastActivityIndexKey, &redis.ZRangeBy{\n209: \t\tMin:    \"-inf\",\n210: \t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n211: \t\tOffset: 0,\n212: \t\tCount:  limit,\n213: \t}).Result()\n214: \tif err != nil {\n215: \t\treturn nil, err\n216: \t}\n217: \n218: \treturn rs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n219: }\n220: \n221: func (rs *redisStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n222: \tif len(sessionIDs) == 0 {\n223: \t\treturn nil, nil\n224: \t}\n225: \n226: \tkeys := make([]string, len(sessionIDs))\n227: \tfor i, sid := range sessionIDs {\n228: \t\tkeys[i] = rs.sessionKey(sid)\n229: \t}\n230: \n231: \tresults, err := rs.cli.MGet(ctx, keys...).Result()\n232: \tif err != nil {\n233: \t\treturn nil, err\n234: \t}\n235: \n236: \tvar sandboxes []*types.SandboxInfo\n237: \tfor i, data := range results {\n238: \t\tif data == nil {\n239: \t\t\tcontinue\n240: \t\t}\n241: \t\tstr, ok := data.(string)\n242: \t\tif !ok || str == \"\" {\n243: \t\t\tcontinue\n244: \t\t}\n245: \t\tvar sandbox types.SandboxInfo\n246: \t\tif err := json.Unmarshal([]byte(str), &sandbox); err != nil {\n247: \t\t\tklog.V(4).Infof(\"failed to unmarshal sandbox %s: %v\", sessionIDs[i], err)\n248: \t\t\tcontinue\n249: \t\t}\n250: \t\tsandboxes = append(sandboxes, &sandbox)\n251: \t}\n252: \n253: \treturn sandboxes, nil\n254: }\n255: \n256: func (rs *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n257: \tif sessionID == \"\" {\n258: \t\treturn errors.New(\"session ID is required\")\n259: \t}\n260: \n261: \tkey := rs.sessionKey(sessionID)\n262: \texists, err := rs.cli.Exists(ctx, key).Result()\n263: \tif err != nil {\n264: \t\treturn err\n265: \t}\n266: \tif exists != 1 {\n267: \t\treturn ErrNotFound\n268: \t}\n269: \n270: \ttimestamp := at\n271: \tif timestamp.IsZero() {\n272: \t\ttimestamp = time.Now()\n273: \t}\n274: \n275: \tscore := float64(timestamp.Unix())\n276: \t_, err = rs.cli.ZAdd(ctx, rs.lastActivityIndexKey, redis.Z{Score: score, Member: sessionID}).Result()\n277: \tif err != nil {\n278: \t\treturn err\n279: \t}\n280: \n281: \treturn nil\n282: }\n283: \n284: func (rs *redisStore) Close() error {\n285: \treturn rs.cli.Close()\n286: }\n\n(End of file - total 286 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  *redis.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_redis.go","time":{"start":1775882951671,"end":1775882951687}}}}
