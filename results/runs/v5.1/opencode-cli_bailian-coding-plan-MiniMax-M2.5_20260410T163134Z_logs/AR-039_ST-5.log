.String())\n422: \t}\n423: \n424: \tvar resp ListFilesResponse\n425: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n426: \n427: \tif len(resp.Files) == 0 {\n428: \t\tt.Error(\"expected files in response, got empty\")\n429: \t}\n430: }\n431: \n432: func TestListFilesHandler_MissingPath(t *testing.T) {\n433: \tserver := setupTestServer(t, \"\")\n434: \n435: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n436: \n437: \treq := httptest.NewRequest(\"GET\", \"/api/files\", nil)\n438: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n439: \tw := httptest.NewRecorder()\n440: \n441: \tserver.GetEngine().ServeHTTP(w, req)\n442: \n443: \tif w.Code != http.StatusBadRequest {\n444: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n445: \t}\n446: }\n447: \n448: func TestListFilesHandler_NotFound(t *testing.T) {\n449: \tserver := setupTestServer(t, \"\")\n450: \n451: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n452: \n453: \treq := httptest.NewRequest(\"GET\", \"/api/files?path=nonexistent\", nil)\n454: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n455: \tw := httptest.NewRecorder()\n456: \n457: \tserver.GetEngine().ServeHTTP(w, req)\n458: \n459: \tif w.Code != http.StatusNotFound {\n460: \t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n461: \t}\n462: }\n463: \n464: func TestUploadFileHandler_JSON_Success(t *testing.T) {\n465: \ttmpDir := t.TempDir()\n466: \tserver := setupTestServer(t, tmpDir)\n467: \n468: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n469: \n470: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"hello world\"))\n471: \treqBody := UploadFileRequest{\n472: \t\tPath:    \"test.txt\",\n473: \t\tContent: content,\n474: \t}\n475: \n476: \tjsonBody, _ := json.Marshal(reqBody)\n477: \treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n478: \treq.Header.Set(\"Content-Type\", \"application/json\")\n479: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n480: \tw := httptest.NewRecorder()\n481: \n482: \tserver.GetEngine().ServeHTTP(w, req)\n483: \n484: \tif w.Code != http.StatusOK {\n485: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n486: \t}\n487: \n488: \tvar resp FileInfo\n489: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n490: \n491: \tif resp.Path != \"test.txt\" {\n492: \t\tt.Errorf(\"expected path 'test.txt', got %s\", resp.Path)\n493: \t}\n494: }\n495: \n496: func TestUploadFileHandler_JSON_InvalidBase64(t *testing.T) {\n497: \tserver := setupTestServer(t, \"\")\n498: \n499: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n500: \n501: \treqBody := UploadFileRequest{\n502: \t\tPath:    \"test.txt\",\n503: \t\tContent: \"not-valid-base64!!!\",\n504: \t}\n505: \n506: \tjsonBody, _ := json.Marshal(reqBody)\n507: \treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n508: \treq.Header.Set(\"Content-Type\", \"application/json\")\n509: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n510: \tw := httptest.NewRecorder()\n511: \n512: \tserver.GetEngine().ServeHTTP(w, req)\n513: \n514: \tif w.Code != http.StatusBadRequest {\n515: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n516: \t}\n517: }\n518: \n519: func TestUploadFileHandler_Multipart_Success(t *testing.T) {\n520: \ttmpDir := t.TempDir()\n521: \tserver := setupTestServer(t, tmpDir)\n522: \n523: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n524: \n525: \tvar b bytes.Buffer\n526: \twr := multipart.NewWriter(&b)\n527: \twr.WriteField(\"path\", \"test.txt\")\n528: \tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n529: \tfw.Write([]byte(\"hello world\"))\n530: \twr.Close()\n531: \n532: \treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n533: \treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n534: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n535: \tw := httptest.NewRecorder()\n536: \n537: \tserver.GetEngine().ServeHTTP(w, req)\n538: \n539: \tif w.Code != http.StatusOK {\n540: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n541: \t}\n542: }\n543: \n544: func TestUploadFileHandler_Multipart_MissingPath(t *testing.T) {\n545: \tserver := setupTestServer(t, \"\")\n546: \n547: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n548: \n549: \tvar b bytes.Buffer\n550: \twr := multipart.NewWriter(&b)\n551: \tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n552: \tfw.Write([]byte(\"hello world\"))\n553: \twr.Close()\n554: \n555: \treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n556: \treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n557: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n558: \tw := httptest.NewRecorder()\n559: \n560: \tserver.GetEngine().ServeHTTP(w, req)\n561: \n562: \tif w.Code != http.StatusBadRequest {\n563: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n564: \t}\n565: }\n566: \n567: func TestDownloadFileHandler_Success(t *testing.T) {\n568: \ttmpDir := t.TempDir()\n569: \tos.WriteFile(filepath.Join(tmpDir, \"test.txt\"), []byte(\"hello world\"), 0644)\n570: \n571: \tserver := setupTestServer(t, tmpDir)\n572: \n573: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n574: \n575: \treq := httptest.NewRequest(\"GET\", \"/api/files/test.txt\", nil)\n576: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n577: \tw := httptest.NewRecorder()\n578: \n579: \tserver.GetEngine().ServeHTTP(w, req)\n580: \n581: \tif w.Code != http.StatusOK {\n582: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n583: \t}\n584: \n585: \tif w.Body.String() != \"hello world\" {\n586: \t\tt.Errorf(\"expected 'hello world', got %s\", w.Body.String())\n587: \t}\n588: }\n589: \n590: func TestDownloadFileHandler_NotFound(t *testing.T) {\n591: \tserver := setupTestServer(t, \"\")\n592: \n593: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n594: \n595: \treq := httptest.NewRequest(\"GET\", \"/api/files/nonexistent.txt\", nil)\n596: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n597: \tw := httptest.NewRecorder()\n598: \n599: \tserver.GetEngine().ServeHTTP(w, req)\n600: \n601: \tif w.Code != http.StatusNotFound {\n602: \t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n603: \t}\n604: }\n605: \n606: func TestDownloadFileHandler_Directory(t *testing.T) {\n607: \ttmpDir := t.TempDir()\n608: \tos.MkdirAll(filepath.Join(tmpDir, \"mydir\"), 0755)\n609: \n610: \tserver := setupTestServer(t, tmpDir)\n611: \n612: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n613: \n614: \treq := httptest.NewRequest(\"GET\", \"/api/files/mydir\", nil)\n615: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n616: \tw := httptest.NewRecorder()\n617: \n618: \tserver.GetEngine().ServeHTTP(w, req)\n619: \n620: \tif w.Code != http.StatusBadRequest {\n621: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n622: \t}\n623: }\n624: \n625: func TestDownloadFileHandler_EscapeWorkspace(t *testing.T) {\n626: \tserver := setupTestServer(t, \"\")\n627: \n628: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n629: \n630: \treq := httptest.NewRequest(\"GET\", \"/api/files/../../../etc/passwd\", nil)\n631: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n632: \tw := httptest.NewRecorder()\n633: \n634: \tserver.GetEngine().ServeHTTP(w, req)\n635: \n636: \tif w.Code != http.StatusBadRequest {\n637: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n638: \t}\n639: }\n640: \n641: func TestSanitizePath(t *testing.T) {\n642: \ttmpDir := t.TempDir()\n643: \tos.MkdirAll(filepath.Join(tmpDir, \"subdir\"), 0755)\n644: \n645: \tserver := setupTestServer(t, tmpDir)\n646: \n647: \ttests := []struct {\n648: \t\tname    string\n649: \t\tinput   string\n650: \t\twantErr bool\n651: \t}{\n652: \t\t{\"valid relative\", \"subdir\", false},\n653: \t\t{\"valid nested\", \"subdir/nested\", false},\n654: \t\t{\"escape attempt\", \"../etc\", true},\n655: \t\t{\"absolute path\", \"/etc/passwd\", false},\n656: \t}\n657: \n658: \tfor _, tt := range tests {\n659: \t\tt.Run(tt.name, func(t *testing.T) {\n660: \t\t\t_, err := server.sanitizePath(tt.input)\n661: \t\t\tif (err != nil) != tt.wantErr {\n662: \t\t\t\tt.Errorf(\"sanitizePath() error = %v, wantErr %v\", err, tt.wantErr)\n663: \t\t\t}\n664: \t\t})\n665: \t}\n666: }\n667: \n668: func TestParseFileMode(t *testing.T) {\n669: \ttests := []struct {\n670: \t\tinput    string\n671: \t\texpected os.FileMode\n672: \t}{\n673: \t\t{\"\", 0644},\n674: \t\t{\"0777\", 0777},\n675: \t\t{\"0644\", 0644},\n676: \t\t{\"invalid\", 0644},\n677: \t\t{\"09999\", 0644},\n678: \t}\n679: \n680: \tfor _, tt := range tests {\n681: \t\tresult := parseFileMode(tt.input)\n682: \t\tif result != tt.expected {\n683: \t\t\tt.Errorf(\"parseFileMode(%q) = %o, expected %o\", tt.input, result, tt.expected)\n684: \t\t}\n685: \t}\n686: }\n687: \n688: func TestConfig_Validate(t *testing.T) {\n689: \ttests := []struct {\n690: \t\tconfig  Config\n691: \t\twantErr bool\n692: \t}{\n693: \t\t{Config{Port: 8080}, false},\n694: \t\t{Config{Port: 0}, true},\n695: \t\t{Config{Port: 70000}, true},\n696: \t\t{Config{Port: 8080, AuthMode: \"picod\", SessionTimeout: 15 * time.Minute, MaxSessionDuration: 8 * time.Hour}, false},\n697: \t\t{Config{Port: 8080, AuthMode: \"\", SessionTimeout: 0, MaxSessionDuration: 0}, false},\n698: \t\t{Config{Port: 1}, false},\n699: \t\t{Config{Port: 65535}, false},\n700: \t}\n701: \n702: \tfor _, tt := range tests {\n703: \t\terr := tt.config.Validate()\n704: \t\tif (err != nil) != tt.wantErr {\n705: \t\t\tt.Errorf(\"Config.Validate() error = %v, wantErr %v\", err, tt.wantErr)\n706: \t\t}\n707: \t}\n708: }\n709: \n710: func TestConfig_ValidateSetsDefaults(t *testing.T) {\n711: \tcfg := &Config{\n712: \t\tPort: 9000,\n713: \t}\n714: \n715: \terr := cfg.Validate()\n716: \tif err != nil {\n717: \t\tt.Fatalf(\"Unexpected error: %v\", err)\n718: \t}\n719: \n720: \tif cfg.Port != 9000 {\n721: \t\tt.Errorf(\"Port should remain 9000, got %d\", cfg.Port)\n722: \t}\n723: \tif cfg.AuthMode != \"picod\" {\n724: \t\tt.Errorf(\"AuthMode should default to 'picod', got %s\", cfg.AuthMode)\n725: \t}\n726: \tif cfg.SessionTimeout != 15*time.Minute {\n727: \t\tt.Errorf(\"SessionTimeout should default to 15m, got %v\", cfg.SessionTimeout)\n728: \t}\n729: \tif cfg.MaxSessionDuration != 8*time.Hour {\n730: \t\tt.Errorf(\"MaxSessionDuration should default to 8h, got %v\", cfg.MaxSessionDuration)\n731: \t}\n732: }\n733: \n734: func TestDefaultConfig(t *testing.T) {\n735: \tcfg := DefaultConfig()\n736: \n737: \tif cfg.Port != 8080 {\n738: \t\tt.Errorf(\"Expected port 8080, got %d\", cfg.Port)\n739: \t}\n740: \tif cfg.Workspace != \"\" {\n741: \t\tt.Errorf(\"Expected empty workspace, got %s\", cfg.Workspace)\n742: \t}\n743: \tif cfg.AuthMode != \"picod\" {\n744: \t\tt.Errorf(\"Expected auth mode 'picod', got %s\", cfg.AuthMode)\n745: \t}\n746: \tif cfg.SessionTimeout != 15*time.Minute {\n747: \t\tt.Errorf(\"Expected session timeout 15m, got %v\", cfg.SessionTimeout)\n748: \t}\n749: \tif cfg.MaxSessionDuration != 8*time.Hour {\n750: \t\tt.Errorf(\"Expected max session duration 8h, got %v\", cfg.MaxSessionDuration)\n751: \t}\n752: }\n753: \n754: func TestNewAuthManager_LoadPublicKeyFromEnv(t *testing.T) {\n755: \tpubKey := &testRSAKey.PublicKey\n756: \n757: \tderBytes, _ := x509.MarshalPKIXPublicKey(pubKey)\n758: \tpemData := base64.StdEncoding.EncodeToString(derBytes)\n759: \tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n760: \tfor i := 0; i < len(pemData); i += 64 {\n761: \t\tend := i + 64\n762: \t\tif end > len(pemData) {\n763: \t\t\tend = len(pemData)\n764: \t\t}\n765: \t\tpemBlock += pemData[i:end] + \"\\n\"\n766: \t}\n767: \tpemBlock += \"-----END PUBLIC KEY-----\"\n768: \n769: \tos.Setenv(PublicKeyEnvVar, pemBlock)\n770: \tdefer os.Unsetenv(PublicKeyEnvVar)\n771: \n772: \tam := NewAuthManager()\n773: \terr := am.LoadPublicKeyFromEnv()\n774: \tif err != nil {\n775: \t\tt.Errorf(\"LoadPublicKeyFromEnv() error = %v\", err)\n776: \t}\n777: \n778: \tif am.GetPublicKey() == nil {\n779: \t\tt.Error(\"expected public key to be loaded\")\n780: \t}\n781: }\n782: \n783: func TestNewAuthManager_LoadPublicKeyFromEnv_Empty(t *testing.T) {\n784: \tos.Unsetenv(PublicKeyEnvVar)\n785: \n786: \tam := NewAuthManager()\n787: \terr := am.LoadPublicKeyFromEnv()\n788: \n789: \tif err == nil {\n790: \t\tt.Error(\"expected error for empty env var\")\n791: \t}\n792: }\n793: \n794: func TestExecuteContext_TimeoutExitCode(t *testing.T) {\n795: \tif TimeoutExitCode != 124 {\n796: \t\tt.Errorf(\"expected TimeoutExitCode to be 124, got %d\", TimeoutExitCode)\n797: \t}\n798: }\n799: \n800: func TestDefaultTimeout(t *testing.T) {\n801: \texpected := 60 * time.Second\n802: \tif DefaultTimeout != expected {\n803: \t\tt.Errorf(\"expected DefaultTimeout to be %v, got %v\", expected, DefaultTimeout)\n804: \t}\n805: }\n806: \n807: func TestAuthManager_InvalidPublicKey(t *testing.T) {\n808: \tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n809: \tdefer os.Unsetenv(PublicKeyEnvVar)\n810: \n811: \tam := NewAuthManager()\n812: \terr := am.LoadPublicKeyFromEnv()\n813: \n814: \tif err == nil {\n815: \t\tt.Error(\"expected error for invalid PEM data\")\n816: \t}\n817: }\n818: \n819: func TestServer_Run_GracefulShutdown(t *testing.T) {\n820: \ttmpDir := t.TempDir()\n821: \tserver := setupTestServer(t, tmpDir)\n822: \n823: \tserver.config.Port = 18080\n824: \n825: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n826: \tw := httptest.NewRecorder()\n827: \n828: \tserver.GetEngine().ServeHTTP(w, req)\n829: \n830: \tif w.Code != http.StatusOK {\n831: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n832: \t}\n833: }\n\n(End of file - total 833 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"bytes\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go","time":{"start":1775882966752,"end":1775882966762}}}}
