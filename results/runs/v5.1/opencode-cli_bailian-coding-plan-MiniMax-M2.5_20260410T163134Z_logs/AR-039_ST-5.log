*Server) handleMultipartUpload(c *gin.Context) {\n56: \tpath := c.PostForm(\"path\")\n57: \tif path == \"\" {\n58: \t\tc.JSON(400, gin.H{\n59: \t\t\t\"error\": \"path is required\",\n60: \t\t\t\"code\":  400,\n61: \t\t})\n62: \t\treturn\n63: \t}\n64: \n65: \tfile, header, err := c.Request.FormFile(\"file\")\n66: \tif err != nil {\n67: \t\tc.JSON(400, gin.H{\n68: \t\t\t\"error\": \"file is required and must be readable\",\n69: \t\t\t\"code\":  400,\n70: \t\t})\n71: \t\treturn\n72: \t}\n73: \tdefer file.Close()\n74: \n75: \tsanitizedPath, err := s.sanitizePath(path)\n76: \tif err != nil {\n77: \t\tc.JSON(400, gin.H{\n78: \t\t\t\"error\": fmt.Sprintf(\"Invalid path: %v\", err),\n79: \t\t\t\"code\":  400,\n80: \t\t})\n81: \t\treturn\n82: \t}\n83: \n84: \tdir := filepath.Dir(sanitizedPath)\n85: \tif err := os.MkdirAll(dir, 0755); err != nil {\n86: \t\tc.JSON(500, gin.H{\n87: \t\t\t\"error\": fmt.Sprintf(\"Failed to create directory: %v\", err),\n88: \t\t\t\"code\":  500,\n89: \t\t})\n90: \t\treturn\n91: \t}\n92: \n93: \tmodeStr := c.PostForm(\"mode\")\n94: \tmode := parseFileMode(modeStr)\n95: \n96: \toutFile, err := os.OpenFile(sanitizedPath, os.O_WRONLY|os.O_CREATE|os.O_TRUNC, mode)\n97: \tif err != nil {\n98: \t\tc.JSON(500, gin.H{\n99: \t\t\t\"error\": fmt.Sprintf(\"Failed to create file: %v\", err),\n100: \t\t\t\"code\":  500,\n101: \t\t})\n102: \t\treturn\n103: \t}\n104: \tdefer outFile.Close()\n105: \n106: \tif _, err := io.Copy(outFile, file); err != nil {\n107: \t\tc.JSON(500, gin.H{\n108: \t\t\t\"error\": fmt.Sprintf(\"Failed to write file: %v\", err),\n109: \t\t\t\"code\":  500,\n110: \t\t})\n111: \t\treturn\n112: \t}\n113: \n114: \trelPath, err := filepath.Rel(s.workspaceDir, sanitizedPath)\n115: \tif err != nil {\n116: \t\trelPath = sanitizedPath\n117: \t}\n118: \n119: \tinfo, _ := os.Stat(sanitizedPath)\n120: \tsize := header.Size\n121: \tmodified := time.Now()\n122: \tif info != nil {\n123: \t\tmodified = info.ModTime()\n124: \t}\n125: \n126: \tc.JSON(200, FileInfo{\n127: \t\tPath:     relPath,\n128: \t\tSize:     size,\n129: \t\tMode:     fmt.Sprintf(\"%o\", mode),\n130: \t\tModified: modified,\n131: \t})\n132: }\n133: \n134: func (s *Server) handleJSONBase64Upload(c *gin.Context) {\n135: \tvar req UploadFileRequest\n136: \tif err := c.ShouldBindJSON(&req); err != nil {\n137: \t\tc.JSON(400, gin.H{\n138: \t\t\t\"error\": err.Error(),\n139: \t\t\t\"code\":  400,\n140: \t\t})\n141: \t\treturn\n142: \t}\n143: \n144: \tcontent, err := base64.StdEncoding.DecodeString(req.Content)\n145: \tif err != nil {\n146: \t\tc.JSON(400, gin.H{\n147: \t\t\t\"error\": fmt.Sprintf(\"invalid base64 content: %v\", err),\n148: \t\t\t\"code\":  400,\n149: \t\t})\n150: \t\treturn\n151: \t}\n152: \n153: \tsanitizedPath, err := s.sanitizePath(req.Path)\n154: \tif err != nil {\n155: \t\tc.JSON(400, gin.H{\n156: \t\t\t\"error\": fmt.Sprintf(\"Invalid path: %v\", err),\n157: \t\t\t\"code\":  400,\n158: \t\t})\n159: \t\treturn\n160: \t}\n161: \n162: \tdir := filepath.Dir(sanitizedPath)\n163: \tif err := os.MkdirAll(dir, 0755); err != nil {\n164: \t\tc.JSON(500, gin.H{\n165: \t\t\t\"error\": fmt.Sprintf(\"Failed to create directory: %v\", err),\n166: \t\t\t\"code\":  500,\n167: \t\t})\n168: \t\treturn\n169: \t}\n170: \n171: \tmode := parseFileMode(req.Mode)\n172: \n173: \tif err := os.WriteFile(sanitizedPath, content, mode); err != nil {\n174: \t\tc.JSON(500, gin.H{\n175: \t\t\t\"error\": fmt.Sprintf(\"Failed to write file: %v\", err),\n176: \t\t\t\"code\":  500,\n177: \t\t})\n178: \t\treturn\n179: \t}\n180: \n181: \trelPath, err := filepath.Rel(s.workspaceDir, sanitizedPath)\n182: \tif err != nil {\n183: \t\trelPath = sanitizedPath\n184: \t}\n185: \n186: \tinfo, _ := os.Stat(sanitizedPath)\n187: \tmodified := time.Now()\n188: \tif info != nil {\n189: \t\tmodified = info.ModTime()\n190: \t}\n191: \n192: \tc.JSON(200, FileInfo{\n193: \t\tPath:     relPath,\n194: \t\tSize:     int64(len(content)),\n195: \t\tMode:     fmt.Sprintf(\"%o\", mode),\n196: \t\tModified: modified,\n197: \t})\n198: }\n199: \n200: func (s *Server) ListFilesHandler(c *gin.Context) {\n201: \tpath := c.Query(\"path\")\n202: \tif path == \"\" {\n203: \t\tc.JSON(400, gin.H{\n204: \t\t\t\"error\": \"Missing 'path' query parameter\",\n205: \t\t\t\"code\":  400,\n206: \t\t})\n207: \t\treturn\n208: \t}\n209: \n210: \tsanitizedPath, err := s.sanitizePath(path)\n211: \tif err != nil {\n212: \t\tc.JSON(400, gin.H{\n213: \t\t\t\"error\": fmt.Sprintf(\"Invalid path: %v\", err),\n214: \t\t\t\"code\":  400,\n215: \t\t})\n216: \t\treturn\n217: \t}\n218: \n219: \tentries, err := os.ReadDir(sanitizedPath)\n220: \tif err != nil {\n221: \t\tif os.IsNotExist(err) {\n222: \t\t\tc.JSON(404, gin.H{\n223: \t\t\t\t\"error\": \"Directory not found\",\n224: \t\t\t\t\"code\":  404,\n225: \t\t\t})\n226: \t\t\treturn\n227: \t\t}\n228: \t\tc.JSON(500, gin.H{\n229: \t\t\t\"error\": fmt.Sprintf(\"Failed to read directory: %v\", err),\n230: \t\t\t\"code\":  500,\n231: \t\t})\n232: \t\treturn\n233: \t}\n234: \n235: \tvar files []FileEntry\n236: \tfor _, entry := range entries {\n237: \t\tinfo, err := entry.Info()\n238: \t\tif err != nil {\n239: \t\t\tcontinue\n240: \t\t}\n241: \n242: \t\tfiles = append(files, FileEntry{\n243: \t\t\tName:     entry.Name(),\n244: \t\t\tSize:     info.Size(),\n245: \t\t\tModified: info.ModTime(),\n246: \t\t\tMode:     fmt.Sprintf(\"%o\", info.Mode().Perm()),\n247: \t\t\tIsDir:    entry.IsDir(),\n248: \t\t})\n249: \t}\n250: \n251: \tc.JSON(200, ListFilesResponse{\n252: \t\tFiles: files,\n253: \t})\n254: }\n255: \n256: func (s *Server) DownloadFileHandler(c *gin.Context) {\n257: \tpath := c.Param(\"path\")\n258: \tpath = strings.TrimPrefix(path, \"/\")\n259: \n260: \tif path == \"\" {\n261: \t\tc.JSON(400, gin.H{\n262: \t\t\t\"error\": \"path is required\",\n263: \t\t\t\"code\":  400,\n264: \t\t})\n265: \t\treturn\n266: \t}\n267: \n268: \tsanitizedPath, err := s.sanitizePath(path)\n269: \tif err != nil {\n270: \t\tc.JSON(400, gin.H{\n271: \t\t\t\"error\": fmt.Sprintf(\"Access denied: %v\", err),\n272: \t\t\t\"code\":  400,\n273: \t\t})\n274: \t\treturn\n275: \t}\n276: \n277: \tinfo, err := os.Stat(sanitizedPath)\n278: \tif err != nil {\n279: \t\tif os.IsNotExist(err) {\n280: \t\t\tc.JSON(404, gin.H{\n281: \t\t\t\t\"error\": \"File not found\",\n282: \t\t\t\t\"code\":  404,\n283: \t\t\t})\n284: \t\t\treturn\n285: \t\t}\n286: \t\tc.JSON(500, gin.H{\n287: \t\t\t\"error\": fmt.Sprintf(\"Failed to stat file: %v\", err),\n288: \t\t\t\"code\":  500,\n289: \t\t})\n290: \t\treturn\n291: \t}\n292: \n293: \tif info.IsDir() {\n294: \t\tc.JSON(400, gin.H{\n295: \t\t\t\"error\": \"Path is a directory, not a file\",\n296: \t\t\t\"code\":  400,\n297: \t\t})\n298: \t\treturn\n299: \t}\n300: \n301: \tfilename := filepath.Base(sanitizedPath)\n302: \tcontentType := mime.TypeByExtension(filepath.Ext(sanitizedPath))\n303: \tif contentType == \"\" {\n304: \t\tcontentType = \"application/octet-stream\"\n305: \t}\n306: \n307: \tc.Header(\"Content-Description\", \"File Transfer\")\n308: \tc.Header(\"Content-Transfer-Encoding\", \"binary\")\n309: \tc.Header(\"Content-Disposition\", fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filename))\n310: \tc.Header(\"Content-Type\", contentType)\n311: \n312: \tc.File(sanitizedPath)\n313: }\n314: \n315: func parseFileMode(modeStr string) os.FileMode {\n316: \tif modeStr == \"\" {\n317: \t\treturn 0644\n318: \t}\n319: \n320: \tmode, err := strconv.ParseUint(modeStr, 8, 32)\n321: \tif err != nil {\n322: \t\treturn 0644\n323: \t}\n324: \n325: \tif mode > uint64(maxFileMode) {\n326: \t\treturn 0644\n327: \t}\n328: \n329: \treturn os.FileMode(mode)\n330: }\n\n(End of file - total 330 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"encoding/base64\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nconst (\n\tmaxFileMode = 0777\n)\n","truncated":false,"loaded":[]},"title":"wor