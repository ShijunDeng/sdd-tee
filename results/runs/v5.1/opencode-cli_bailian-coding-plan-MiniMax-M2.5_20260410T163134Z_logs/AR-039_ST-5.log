 TestExecuteHandler_Env(t *testing.T) {\n306: \tserver := setupTestServer(t, \"\")\n307: \n308: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n309: \n310: \treqBody := ExecuteRequest{\n311: \t\tCommand: []string{\"sh\", \"-c\", \"echo $TEST_VAR\"},\n312: \t\tEnv:     map[string]string{\"TEST_VAR\": \"hello\"},\n313: \t}\n314: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n315: \tw := httptest.NewRecorder()\n316: \n317: \tserver.GetEngine().ServeHTTP(w, req)\n318: \n319: \tif w.Code != http.StatusOK {\n320: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n321: \t}\n322: \n323: \tvar resp ExecuteResponse\n324: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n325: \n326: \tif !strings.Contains(resp.Stdout, \"hello\") {\n327: \t\tt.Errorf(\"expected 'hello' in stdout, got: %s\", resp.Stdout)\n328: \t}\n329: }\n330: \n331: func TestHealthCheckHandler(t *testing.T) {\n332: \tserver := setupTestServer(t, \"\")\n333: \n334: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n335: \tw := httptest.NewRecorder()\n336: \n337: \tserver.GetEngine().ServeHTTP(w, req)\n338: \n339: \tif w.Code != http.StatusOK {\n340: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n341: \t}\n342: \n343: \tvar resp map[string]interface{}\n344: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n345: \n346: \tif resp[\"status\"] != \"ok\" {\n347: \t\tt.Errorf(\"expected status 'ok', got %v\", resp[\"status\"])\n348: \t}\n349: \tif resp[\"service\"] != \"PicoD\" {\n350: \t\tt.Errorf(\"expected service 'PicoD', got %v\", resp[\"service\"])\n351: \t}\n352: \tif resp[\"version\"] != \"0.0.1\" {\n353: \t\tt.Errorf(\"expected version '0.0.1', got %v\", resp[\"version\"])\n354: \t}\n355: }\n356: \n357: func TestAuthMiddleware_MissingHeader(t *testing.T) {\n358: \tserver := setupTestServer(t, \"\")\n359: \n360: \treqBody := ExecuteRequest{\n361: \t\tCommand: []string{\"echo\", \"hello\"},\n362: \t}\n363: \treq := createTestRequest(t, \"POST\", \"/api/