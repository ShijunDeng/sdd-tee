nv var.\n43:             auth_token: Authentication token for the Workload Manager.\n44:             name: Name of the session/agent (default: \"my-interpreter\").\n45:             namespace: Kubernetes namespace (default: \"default\").\n46:             ttl: Time to live in seconds (default: 3600).\n47:             verbose: Enable verbose logging (default: False).\n48:             session_id: Existing session ID to reuse. If None, a new session\n49:                        will be created.\n50: \n51:         Raises:\n52:             ValueError: If router_url is not provided and ROUTER_URL env var\n53:                        is not set.\n54:         \"\"\"\n55:         self.router_url = router_url or os.environ.get(\"ROUTER_URL\")\n56:         if not self.router_url:\n57:             raise ValueError(\n58:                 \"router_url must be provided via argument or \"\n59:                 \"ROUTER_URL environment variable must be set\"\n60:             )\n61: \n62:         self.workload_manager_url = workload_manager_url\n63:         self.auth_token = auth_token\n64:         self.name = name\n65:         self.namespace = namespace\n66:         self.ttl = ttl\n67:         self.verbose = verbose\n68:         self._session_id_provided = session_id is not None\n69: \n70:         self._control_plane_client: Optional[ControlPlaneClient] = None\n71:         self._data_plane_client: Optional[CodeInterpreterDataPlaneClient] = None\n72: \n73:         if session_id:\n74:             self._session_id = session_id\n75:             logger.info(f\"Reusing existing session: {session_id}\")\n76:             self._init_data_plane()\n77:         else:\n78:             self._session_id = self._create_session()\n79: \n80:     def _create_session(self) -> str:\n81:         \"\"\"Create a new session via the control plane.\"\"\"\n82:         self._control_plane_client = ControlPlaneClient(\n83:             workload_manager_url=self.workload_manager_url,\n84:             auth_token=self.auth_token,\n85:         )\n86: \n87:         session_id = self._control_plane_client.create_session(\n88:             name=self.name,\n89:             namespace=self.namespace,\n90:             ttl=self.ttl,\n91:         )\n92: \n93:         return session_id\n94: \n95:     def _init_data_plane(self) -> None:\n96:         \"\"\"Initialize the data plane client.\"\"\"\n97:         try:\n98:             self._data_plane_client = CodeInterpreterDataPlaneClient(\n99:                 router_url=self.router_url,\n100:                 namespace=self.namespace,\n101:                 cr_name=self.name,\n102:                 session_id=self._session_id,\n103:             )\n104:             logger.info(f\"Data plane initialized for session: {self._session_id}\")\n105:         except Exception as e:\n106:             logger.error(f\"Failed to initialize data plane: {e}\")\n107:             if not self._session_id_provided and self._control_plane_client:\n108:                 logger.warning(f\"Data plane init failed, cleaning up session {self._session_id}\")\n109:                 self._control_plane_client.delete_session(self._session_id)\n110:                 self._session_id = None\n111:             raise\n112: \n113:     def execute_command(\n114:         self,\n115:         command: str,\n116:         timeout: Optional[int] = None,\n117:     ) -> Dict:\n118:         \"\"\"\n119:         Execute a command in the Code Interpreter.\n120: \n121:         Args:\n122:             command: The command to execute.\n123:             timeout: Timeout in seconds. If None, uses the default.\n124: \n125:         Returns:\n126:             A dictionary containing the response data.\n127: \n128:         Raises:\n129:             CommandExecutionError: If the command returns a non-zero exit code.\n130:             DataPlaneError: If the execution fails.\n131:         \"\"\"\n132:         if not self._data_plane_client:\n133:             raise DataPlaneError(\"Data plane not initialized\")\n134: \n135:         response = self._data_plane_client.execute_command(command, timeout=timeout)\n136: \n137:         exit_code = response.get(\"exit_code\")\n138:         if exit_code != 0:\n139:             stderr = response.get(\"stderr\", \"\")\n140:             raise CommandExecutionError(\n141:                 f\"Command failed with exit code {exit_code}\",\n142:                 exit_code=exit_code,\n143:                 stderr=stderr,\n144:                 command=command,\n145:             )\n146: \n147:         return response\n148: \n149:     def run_code(\n150:         self,\n151:         code: str,\n152:         language: str = \"python\",\n153:         timeout: Optional[int] = None,\n154:     ) -> Dict:\n155:         \"\"\"\n156:         Run code in the Code Interpreter.\n157: \n158:         For Python, writes a timestamped .py file and executes it.\n159: \n160:         Args:\n161:             code: The code to run.\n162:             language: Programming language (python, py, python3, etc.)\n163:             timeout: Timeout in seconds.\n164: \n165:         Returns:\n166:             A dictionary containing the response data.\n167: \n168:         Raises:\n169:             CommandExecutionError: If the code returns a non-zero exit code.\n170:             DataPlaneError: If the execution fails.\n171:         \"\"\"\n172:         normalized_lang = language.lower()\n173:         if normalized_lang in (\"python\", \"py\", \"python3\"):\n174:             timestamp = int(time.time() * 1000)\n175:             remote_path = f\"/tmp/script_{timestamp}.py\"\n176: \n177:             self.write_file(code, remote_path)\n178: \n179:             command = f\"python3 {remote_path}\"\n180:             return self.execute_command(command, timeout=timeout)\n181:         else:\n182:             raise ValueError(f\"Unsupported language: {language}\")\n183: \n184:     def write_file(\n185:         self,\n186:         content: str,\n187:         remote_path: str,\n188:         mode: str = \"0644\",\n189:     ) -> Dict:\n190:         \"\"\"\n191:         Write a file to the Code Interpreter.\n192: \n193:         Args:\n194:             content: The file content.\n195:             remote_path: The remote path where the file will be written.\n196:             mode: File permissions (default: 0644).\n197: \n198:         Returns:\n199:             A dictionary containing the response data.\n200: \n201:         Raises:\n202:             DataPlaneError: If the write fails.\n203:         \"\"\"\n204:         if not self._data_plane_client:\n205:             raise DataPlaneError(\"Data plane not initialized\")\n206: \n207:         return self._data_plane_client.write_file(content, remote_path, mode)\n208: \n209:     def upload_file(\n210:         self,\n211:         local_path: str,\n212:         remote_path: str,\n213:     ) -> Dict:\n214:         \"\"\"\n215:         Upload a file to the Code Interpreter.\n216: \n217:         Args:\n218:             local_path: Path to the local file.\n219:             remote_path: The remote path where the file will be written.\n220: \n221:         Returns:\n222:             A dictionary containing the response data.\n223: \n224:         Raises:\n225:             DataPlaneError: If the upload fails.\n226:         \"\"\"\n227:         if not self._data_plane_client:\n228:             raise DataPlaneError(\"Data plane not initialized\")\n229: \n230:         return self._data_plane_client.upload_file(local_path, remote_path)\n231: \n232:     def download_file(\n233:         self,\n234:         remote_path: str,\n235:         local_path: str,\n236:     ) -> None:\n237:         \"\"\"\n238:         Download a file from the Code Interpreter.\n239: \n240:         Args:\n241:             remote_path: The remote path of the file to download.\n242:             local_path: The local path where the file will be saved.\n243: \n244:         Raises:\n245:             DataPlaneError: If the download fails.\n246:         \"\"\"\n247:         if not self._data_plane_client:\n248:             raise DataPlaneError(\"Data plane not initialized\")\n249: \n250:         self._data_plane_client.download_file(remote_path, local_path)\n251: \n252:     def list_files(self, path: str = \".\") -> Dict:\n253:         \"\"\"\n254:         List files in the Code Interpreter.\n255: \n256:         Args:\n257:             path: The path to list (default: \".\").\n258: \n259:         Returns:\n260:             A dictionary containing the file listing.\n261: \n262:         Raises:\n263:             DataPlaneError: If the list fails.\n264:         \"\"\"\n265:         if not self._data_plane_client:\n266:             raise DataPlaneError(\"Data plane not initialized\")\n267: \n268:         return self._data_plane_client.list_files(path)\n269: \n270:     def stop(self) -> None:\n271:         \"\"\"\n272:         Stop the Code Interpreter session.\n273: \n274:         Closes the data plane and deletes the control plane session\n275:         if a new session was created.\n276:         \"\"\"\n277:         if self._data_plane_client:\n278:             try:\n279:                 self._data_plane_client.close()\n280:             except Exception as e:\n281:                 logger.warning(f\"Error closing data plane: {e}\")\n282:             finally:\n283:                 self._data_plane_client = None\n284: \n285:         if self._control_plane_client and self._session_id:\n286:             if self._session_id_provided:\n287:                 logger.info(\"Session was provided by user, not deleting\")\n288:             else:\n289:                 try:\n290:                     self._control_plane_client.delete_session(self._session_id)\n291:                 except Exception as e:\n292:                     logger.warning(f\"Error deleting session: {e}\")\n293:                 finally:\n294:                     self._session_id = None\n295: \n296:         if self._control_plane_client:\n297:             try:\n298:                 self._control_plane_client.close()\n299:             except Exception as e:\n300:                 logger.warning(f\"Error closing control plane: {e}\")\n301:             finally:\n302:                 self._control_plane_client = None\n303: \n304:         logger.info(\"CodeInterpreterClient stopped\")\n305: \n306:     def __enter__(self) -> \"CodeInterpreterClient\":\n307:         \"\"\"Enter the context manager.\"\"\"\n308:         return self\n309: \n310:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n311:         \"\"\"Exit the context manager.\"\"\"\n312:         self.stop()\n313: \n314:     @property\n315:     def session_id(self) -> Optional[str]:\n316:         \"\"\"Get the current session ID.\"\"\"\n317:         return self._session_id\n\n(End of file - total 317 lines)\n</content>","metadata":{"preview":"\"\"\"CodeInterpreterClient for AgentCube SDK.\"\"\"\n\nimport os\nimport time\nfrom typing import Dict, Optional\n\nfrom agentcube.clients import (\n    CodeInterpreterDataPlaneClient,\n    ControlPlaneClient,\n)\nfrom agentcube.exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    DataPlaneError,\n    SessionError,\n)\nfrom agentcube.utils.log import get_logger\n\nlogger = get_logger(__name__)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/code_interpreter.py","time":{"start":1775870000179,"end":1775870000205}}}}
