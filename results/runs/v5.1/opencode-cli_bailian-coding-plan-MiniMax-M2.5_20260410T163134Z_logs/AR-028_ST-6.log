"\n+    \"\"\"Test cases for AgentRuntimeClient.\"\"\"\n \n-    def test_not_implemented(self):\n-        \"\"\"Test AgentRuntimeClient raises NotImplementedError.\"\"\"\n-        with pytest.raises(NotImplementedError):\n-            AgentRuntimeClient(router_url=\"http://router:8080\")\n+    def test_requires_router_url(self):\n+        \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n+        with pytest.raises(ValueError) as exc_info:\n+            AgentRuntimeClient()\n+        assert \"router_url\" in str(exc_info.value).lower()\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter.py","before":"\"\"\"Tests for CodeInterpreterClient.\"\"\"\n\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.exceptions import (\n    CommandExecutionError,\n    DataPlaneError,\n)\n\n\nclass TestCodeInterpreterClient:\n    \"\"\"Test cases for CodeInterpreterClient.\"\"\"\n\n    def test_constructor_requires_router_url(self):\n        \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n        with pytest.raises(ValueError) as exc_info:\n            CodeInterpreterClient()\n        assert \"router_url\" in str(exc_info.value).lower()\n\n    def test_constructor_with_env_var(self):\n        \"\"\"Test Router URL can be set via environment variable.\"\"\"\n        with patch.dict(\"os.environ\", {\"ROUTER_URL\": \"http://router:8080\"}):\n            with pytest.raises(Exception):\n                CodeInterpreterClient()\n\n    def test_constructor_with_explicit_url(self):\n        \"\"\"Test Router URL can be set explicitly.\"\"\"\n        with patch(\"agentcube.code_interpreter.CodeInterpreterClient._create_session\"):\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            assert client.router_url == \"http://router:8080\"\n            client.stop()\n\n    def test_constructor_default_values(self):\n        \"\"\"Test constructor sets default values.\"\"\"\n        with patch(\"agentcube.code_interpreter.CodeInterpreterClient._create_session\"):\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            assert client.name == \"my-interpreter\"\n            assert client.namespace == \"default\"\n            assert client.ttl == 3600\n            assert client.verbose is False\n            client.stop()\n\n    def test_constructor_with_session_id(self):\n        \"\"\"Test constructor reuses existing session_id.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._init_data_plane\"\n        ) as mock_init:\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n                session_id=\"existing-session-123\",\n            )\n            assert client._session_id == \"existing-session-123\"\n            assert client._session_id_provided is True\n            mock_init.assert_called_once()\n\n    def test_context_manager(self):\n        \"\"\"Test context manager protocol.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_cp_client = Mock()\n            mock_create_session.return_value = mock_cp_client\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            mock_dp_client = Mock()\n            client._data_plane_client = mock_dp_client\n\n            with client:\n                assert client.session_id == mock_cp_client\n                mock_dp_client.close.assert_not_called()\n\n            mock_dp_client.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    @patch.object(CodeInterpreterClient, \"_create_session\")\n    def test_data_plane_init_failure_cleanup(self, mock_create_session, mock_dp_class):\n        \"\"\"Test data plane init failure triggers session cleanup.\"\"\"\n        mock_cp_client = Mock()\n        mock_cp_client.delete_session.return_value = True\n        mock_create_session.return_value = \"session-123\"\n\n        mock_dp_class.side_effect = DataPlaneError(\"Init failed\")\n\n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n        )\n        client._control_plane_client = mock_cp_client\n\n        with pytest.raises(DataPlaneError):\n            client._init_data_plane()\n\n        mock_cp_client.delete_session.assert_called_once_with(\"session-123\")\n\n    def test_execute_command_raises_on_non_zero_exit(self):\n        \"\"\"Test execute_command raises CommandExecutionError on non-zero exit.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_dp_client = Mock()\n            mock_dp_client.execute_command.return_value = {\n                \"exit_code\": 1,\n                \"stderr\": \"Command not found\",\n                \"command\": \"ls /nonexistent\",\n            }\n            mock_create_session.return_value = Mock()\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            client._data_plane_client = mock_dp_client\n\n            with pytest.raises(CommandExecutionError) as exc_info:\n                client.execute_command(\"ls /nonexistent\")\n\n            assert exc_info.value.exit_code == 1\n            assert exc_info.value.stderr == \"Command not found\"\n            client.stop()\n\n    def test_run_code_python(self):\n        \"\"\"Test run_code with Python language.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_dp_client = Mock()\n            mock_dp_client.execute_command.return_value = {\n                \"exit_code\": 0,\n                \"stdout\": \"hello\",\n            }\n            mock_dp_client.write_file.return_value = {\"success\": True}\n            mock_create_session.return_value = Mock()\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            client._data_plane_client = mock_dp_client\n\n            result = client.run_code(\"print('hello')\", language=\"python\")\n\n            assert result[\"exit_code\"] == 0\n            mock_dp_client.write_file.assert_called_once()\n            mock_dp_client.execute_command.assert_called_once()\n            client.stop()\n\n    def test_run_code_unsupported_language(self):\n        \"\"\"Test run_code raises ValueError for unsupported language.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_dp_client = Mock()\n            mock_create_session.return_value = Mock()\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            client._data_plane_client = mock_dp_client\n\n            with pytest.raises(ValueError) as exc_info:\n                client.run_code(\"code\", language=\"unsupported\")\n\n            assert \"Unsupported language\" in str(exc_info.value)\n            client.stop()\n\n    def test_stop_closes_clients(self):\n        \"\"\"Test stop closes both data plane and control plane.\"\"\"\n        mock_dp_client = Mock()\n        mock_cp_client = Mock()\n\n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n            session_id=\"test-session\",\n        )\n        client._data_plane_client = mock_dp_client\n        client._control_plane_client = mock_cp_client\n        client._session_id_provided = False\n\n        client.stop()\n\n        mock_dp_client.close.assert_called_once()\n        mock_cp_client.delete_session.assert_called_once_with(\"test-session\")\n        mock_cp_client.close.assert_called_once()\n        assert client._data_plane_client is None\n\n    def test_session_id_property(self):\n        \"\"\"Test session_id property returns the session ID.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_create_session.return_value = \"test-id\"\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            assert client.session_id == \"test-id\"\n            client.stop()\n\n\nclass TestAgentRuntimeClient:\n    \"\"\"Test cases for AgentRuntimeClient (placeholder).\"\"\"\n\n    def test_not_implemented(self):\n        \"\"\"Test AgentRuntimeClient raises NotImplementedError.\"\"\"\n        with pytest.raises(NotImplementedError):\n            AgentRuntimeClient(router_url=\"http://router:8080\")\n","after":"\"\"\"Tests for CodeInterpreterClient.\"\"\"\n\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.exceptions import (\n    CommandExecutionError,\n    DataPlaneError,\n)\n\n\nclass TestCodeInterpreterClient:\n    \"\"\"Test cases for CodeInterpreterClient.\"\"\"\n\n    def test_constructor_requires_router_url(self):\n        \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n        with pytest.raises(ValueError) as exc_info:\n            CodeInterpreterClient()\n        assert \"router_url\" in str(exc_info.value).lower()\n\n    def test_constructor_with_env_var(self):\n        \"\"\"Test Router URL can be set via environment variable.\"\"\"\n        with patch.dict(\"os.environ\", {\"ROUTER_URL\": \"http://router:8080\"}):\n            with pytest.raises(Exception):\n                CodeInterpreterClient()\n\n    def test_constructor_with_explicit_url(self):\n        \"\"\"Test Router URL can be set explicitly.\"\"\"\n        with patch(\"agentcube.code_interpreter.CodeInterpreterClient._create_session\"):\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            assert client.router_url == \"http://router:8080\"\n            client.stop()\n\n    def test_constructor_default_values(self):\n        \"\"\"Test constructor sets default values.\"\"\"\n        with patch(\"agentcube.code_interpreter.CodeInterpreterClient._create_session\"):\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            assert client.name == \"my-interpreter\"\n            assert client.namespace == \"default\"\n            assert client.ttl == 3600\n            assert client.verbose is False\n            client.stop()\n\n    def test_constructor_with_session_id(self):\n        \"\"\"Test constructor reuses existing session_id.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._init_data_plane\"\n        ) as mock_init:\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n                session_id=\"existing-session-123\",\n            )\n            assert client._session_id == \"existing-session-123\"\n            assert client._session_id_provided is True\n            mock_init.assert_called_once()\n\n    def test_context_manager(self):\n        \"\"\"Test context manager protocol.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_cp_client = Mock()\n            mock_create_session.return_value = mock_cp_client\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            mock_dp_client = Mock()\n            client._data_plane_client = mock_dp_client\n\n            with client:\n                assert client.session_id == mock_cp_client\n                mock_dp_client.close.assert_not_called()\n\n            mock_dp_client.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    @patch.object(CodeInterpreterClient, \"_create_session\")\n    def test_data_plane_init_failure_cleanup(self, mock_create_session, mock_dp_class):\n        \"\"\"Test data plane init failure triggers session cleanup.\"\"\"\n        mock_cp_client = Mock()\n        mock_cp_client.delete_session.return_value = True\n        mock_create_session.return_value = \"session-123\"\n\n        mock_dp_class.side_effect = DataPlaneError(\"Init failed\")\n\n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n        )\n        client._control_plane_client = mock_cp_client\n\n        with pytest.raises(DataPlaneError):\n            client._init_data_plane()\n\n        mock_cp_client.delete_session.assert_called_once_with(\"session-123\")\n\n    def test_execute_command_raises_on_non_zero_exit(self):\n        \"\"\"Test execute_command raises CommandExecutionError on non-zero exit.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_dp_client = Mock()\n            mock_dp_client.execute_command.return_value = {\n                \"exit_code\": 1,\n                \"stderr\": \"Command not found\",\n                \"command\": \"ls /nonexistent\",\n            }\n            mock_create_session.return_value = Mock()\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            client._data_plane_client = mock_dp_client\n\n            with pytest.raises(CommandExecutionError) as exc_info:\n                client.execute_command(\"ls /nonexistent\")\n\n            assert exc_info.value.exit_code == 1\n            assert exc_info.value.stderr == \"Command not found\"\n            client.stop()\n\n    def test_run_code_python(self):\n        \"\"\"Test run_code with Python language.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_dp_client = Mock()\n            mock_dp_client.execute_command.return_value = {\n                \"exit_code\": 0,\n                \"stdout\": \"hello\",\n            }\n            mock_dp_client.write_file.return_value = {\"success\": True}\n            mock_create_session.return_value = Mock()\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            client._data_plane_client = mock_dp_client\n\n            result = client.run_code(\"print('hello')\", language=\"python\")\n\n            assert result[\"exit_code\"] == 0\n            mock_dp_client.write_file.assert_called_once()\n            mock_dp_client.execute_command.assert_called_once()\n            client.stop()\n\n    def test_run_code_unsupported_language(self):\n        \"\"\"Test run_code raises ValueError for unsupported language.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_dp_client = Mock()\n            mock_create_session.return_value = Mock()\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            client._data_plane_client = mock_dp_client\n\n            with pytest.raises(ValueError) as exc_info:\n                client.run_code(\"code\", language=\"unsupported\")\n\n            assert \"Unsupported language\" in str(exc_info.value)\n            client.stop()\n\n    def test_stop_closes_clients(self):\n        \"\"\"Test stop closes both data plane and control plane.\"\"\"\n        mock_dp_client = Mock()\n        mock_cp_client = Mock()\n\n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n            session_id=\"test-session\",\n        )\n        client._data_plane_client = mock_dp_client\n        client._control_plane_client = mock_cp_client\n        client._session_id_provided = False\n\n        client.stop()\n\n        mock_dp_client.close.assert_called_once()\n        mock_cp_client.delete_session.assert_called_once_with(\"test-session\")\n        mock_cp_client.close.assert_called_once()\n        assert client._data_plane_client is None\n\n    def test_session_id_property(self):\n        \"\"\"Test session_id property returns the session ID.\"\"\"\n        with patch(\n            \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n        ) as mock_create_session:\n            mock_create_session.return_value = \"test-id\"\n\n            client = CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=\"http://wm:8080\",\n            )\n            assert client.session_id == \"test-id\"\n            client.stop()\n\n\nclass TestAgentRuntimeClient:\n    \"\"\"Test cases for AgentRuntimeClient.\"\"\"\n\n    def test_requires_router_url(self):\n        \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n        with pytest.raises(ValueError) as exc_info:\n            AgentRuntimeClient()\n        assert \"router_url\" in str(exc_info.value).lower()\n","additions":6,"deletions":5},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter.py","time":{"start":1775870062881,"end":1775870063422}}}}
