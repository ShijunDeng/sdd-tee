nterpreter.\n266: \n267:         Args:\n268:             path: The path to list (default: \".\").\n269: \n270:         Returns:\n271:             A dictionary containing the file listing.\n272: \n273:         Raises:\n274:             DataPlaneError: If the list fails.\n275:         \"\"\"\n276:         response = self._request(\n277:             \"GET\",\n278:             \"api/files\",\n279:             params={\"path\": path},\n280:         )\n281: \n282:         return response.json()\n283: \n284:     def close(self) -> None:\n285:         \"\"\"Close the HTTP session.\"\"\"\n286:         self._session.close()\n287:         logger.debug(\"CodeInterpreterDataPlaneClient session closed\")\n\n(End of file - total 287 lines)\n</content>","metadata":{"preview":"\"\"\"Code Interpreter Data Plane client for AgentCube SDK.\"\"\"\n\nimport base64\nfrom pathlib import Path\nfrom typing import Dict, Optional\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom agentcube.exceptions import DataPlaneError\nfrom agentcube.utils.http import (\n    DEFAULT_CONNECT_TIMEOUT,\n    DEFAULT_POOL_CONNECTIONS,\n    DEFAULT_POOL_MAXSIZE,\n    DEFAULT_TIMEOUT,\n    create_session,\n)\nfrom agentcube.utils.log import get_logger\n\nlogger = get_logger(__name__)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/clients/code_interpreter_data_plane.py","time":{"start":1775870007282,"end":1775870007295}}}}
