 \"\"\"Stop and cleanup the sandbox client.\"\"\"\n        if self.client:\n            self.client.stop()\n            self.client = None\n\n    def __enter__(self) -> \"SandboxRunner\":\n        \"\"\"Enter the context manager.\"\"\"\n        self.start()\n        return self\n\n    def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n        \"\"\"Exit the context manager and clean up resources.\"\"\"\n        self.stop()\n\n\nclass ReActAgent:\n    \"\"\"ReAct (Reasoning + Acting) agent for PCAP analysis.\"\"\"","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/example/pcap-analyzer/pcap_analyzer.py","time":{"start":1775880558414,"end":1775880558421}}}}
