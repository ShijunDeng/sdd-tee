\"\n48:             - name: CODEINTERPRETER_NAME\n49:               value: \"my-interpreter\"\n50:             - name: SANDBOX_NAMESPACE\n51:               value: \"default\"\n52:             - name: SANDBOX_WARMUP_SEC\n53:               value: \"5\"\n54:           resources:\n55:             requests:\n56:               cpu: 200m\n57:               memory: 100Mi\n58:             limits:\n59:               cpu: \"1\"\n60:               memory: 1Gi\n61:           command: [\"uv\"]\n62:           args: [\"run\", \"pcap_analyzer.py\"]\n63: \n64: \n65: ---\n66: apiVersion: v1\n67: kind: Service\n68: metadata:\n69:   name: pcap-analyzer\n70: spec:\n71:   selector:\n72:     app: pcap-analyzer\n73:   ports:\n74:     - port: 8000\n75:       targetPort: 8000\n76:       protocol: TCP\n77:   type: ClusterIP\n\n(End of file - total 77 lines)\n</content>","metadata":{"preview":"apiVersion: v1\nkind: Secret\nmetadata:\n  name: pcap-analyzer-secrets\ntype: Opaque\nstringData:\n  openai-api-key: \"\"\n\n\n---\napiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: pcap-analyzer\n  labels:\n    app: pcap-analyzer\nspec:\n  replicas: 1\n  selector:\n    matchLabels:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/example/pcap-analyzer/deployment.yaml","time":{"start":1775880158613,"end":1775880158626}}}}
