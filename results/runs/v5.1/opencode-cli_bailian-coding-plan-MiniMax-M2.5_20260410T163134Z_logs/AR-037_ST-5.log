{"type":"tool_use","timestamp":1775880165299,"sessionID":"ses_2854c1212ffe5mg15gx9q7QRtB","part":{"id":"prt_d7ab4d37f001tbc9XWQ4G5GNZi","messageID":"msg_d7ab4ca34001R0c6fdZNMQBvHG","sessionID":"ses_2854c1212ffe5mg15gx9q7QRtB","type":"tool","tool":"read","callID":"toolu_c9938495cda343349cba5d8c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pcap_analyzer.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pcap_analyzer.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for PCAP Analyzer application components.\"\"\"\n2: \n3: import pytest\n4: import os\n5: import sys\n6: from pathlib import Path\n7: from unittest.mock import Mock, patch, MagicMock\n8: \n9: \n10: class TestPCAPAnalyzerConfiguration:\n11:     \"\"\"Test cases for PCAP analyzer configuration.\"\"\"\n12: \n13:     def test_default_configuration_values(self):\n14:         \"\"\"Test that default configuration values are set correctly.\"\"\"\n15:         os.environ.pop(\"OPENAI_API_KEY\", None)\n16:         os.environ.pop(\"OPENAI_API_BASE\", None)\n17:         os.environ.pop(\"OPENAI_MODEL\", None)\n18:         os.environ.pop(\"CODEINTERPRETER_NAME\", None)\n19:         os.environ.pop(\"SANDBOX_NAMESPACE\", None)\n20:         os.environ.pop(\"SANDBOX_WARMUP_SEC\", None)\n21:         os.environ.pop(\"ROUTER_URL\", None)\n22:         os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n23: \n24:         if \"example.pcap_analyzer.pcap_analyzer\" in sys.modules:\n25:             del sys.modules[\"example.pcap_analyzer.pcap_analyzer\"]\n26:         if \"pcap_analyzer\" in sys.modules:\n27:             del sys.modules[\"pcap_analyzer\"]\n28: \n29:         import example.pcap_analyzer.pcap_analyzer as pcap_analyzer\n30: \n31:         assert pcap_analyzer.OPENAI_API_BASE == \"https://api.siliconflow.cn/v1\"\n32:         assert pcap_analyzer.OPENAI_MODEL == \"Qwen/QwQ-32B\"\n33:         assert pcap_analyzer.CODEINTERPRETER_NAME == \"my-interpreter\"\n34:         assert pcap_analyzer.SANDBOX_NAMESPACE == \"default\"\n35:         assert pcap_analyzer.SANDBOX_WARMUP_SEC == 5\n36: \n37:     def test_environment_variable_overrides(self):\n38:         \"\"\"Test that environment variables override defaults.\"\"\"\n39:         os.environ[\"OPENAI_API_BASE\"] = \"https://custom.api.com/v1\"\n40:         os.environ[\"OPENAI_MODEL\"] = \"custom/model\"\n41:         os.environ[\"CODEINTERPRETER_NAME\"] = \"custom-interpreter\"\n42:         os.environ[\"SANDBOX_NAMESPACE\"] = \"custom-namespace\"\n43:         os.environ[\"SANDBOX_WARMUP_SEC\"] = \"10\"\n44: \n45:         for mod_name in list(sys.modules.keys()):\n46:             if \"pcap_analyzer\" in mod_name:\n47:                 del sys.modules[mod_name]\n48: \n49:         try:\n50:             import importlib\n51:             import example.pcap_analyzer.pcap_analyzer as pcap_analyzer\n52: \n53:             importlib.reload(pcap_analyzer)\n54: \n55:             assert pcap_analyzer.OPENAI_API_BASE == \"https://custom.api.com/v1\"\n56:             assert pcap_analyzer.OPENAI_MODEL == \"custom/model\"\n57:             assert pcap_analyzer.CODEINTERPRETER_NAME == \"custom-interpreter\"\n58:             assert pcap_analyzer.SANDBOX_NAMESPACE == \"custom-namespace\"\n59:             assert pcap_analyzer.SANDBOX_WARMUP_SEC == 10\n60:         finally:\n61:             os.environ.pop(\"OPENAI_API_BASE\", None)\n62:             os.environ.pop(\"OPENAI_MODEL\", None)\n63:             os.environ.pop(\"CODEINTERPRETER_NAME\", None)\n64:             os.environ.pop(\"SANDBOX_NAMESPACE\", None)\n65:             os.environ.pop(\"SANDBOX_WARMUP_SEC\", None)\n66: \n67: \n68: class TestSandboxRunner:\n69:     \"\"\"Test cases for SandboxRunner class.\"\"\"\n70: \n71:     def test_sandbox_runner_initialization(self):\n72:         \"\"\"Test SandboxRunner can be initialized with defaults.\"\"\"\n73:         try:\n74:             from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n75: \n76:             runner = SandboxRunner()\n77:             assert runner.name == \"my-interpreter\"\n78:             assert runner.namespace == \"default\"\n79:             assert runner.warmup_sec == 5\n80:             assert runner.client is None\n81:         except ImportError:\n82:             pytest.skip(\"agentcube not in path\")\n83: \n84:     def test_sandbox_runner_custom_parameters(self):\n85:         \"\"\"Test SandboxRunner can be initialized with custom parameters.\"\"\"\n86:         try:\n87:             from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n88: \n89:             runner = SandboxRunner(\n90:                 name=\"custom-runner\",\n91:                 namespace=\"custom-ns\",\n92:                 warmup_sec=10,\n93:             )\n94:             assert runner.name == \"custom-runner\"\n95:             assert runner.namespace == \"custom-ns\"\n96:             assert runner.warmup_sec == 10\n97:         except ImportError:\n98:             pytest.skip(\"agentcube not in path\")\n99: \n100:     def test_sandbox_runner_start_requires_router_url(self):\n101:         \"\"\"Test that start raises error without ROUTER_URL.\"\"\"\n102:         try:\n103:             from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n104: \n105:             os.environ.pop(\"ROUTER_URL\", None)\n106:             os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n107: \n108:             runner = SandboxRunner()\n109:             with pytest.raises(ValueError) as exc_info:\n110:                 runner.start()\n111:             assert \"ROUTER_URL\" in str(exc_info.value)\n112:         except ImportError:\n113:             pytest.skip(\"agentcube not in path\")\n114: \n115:     def test_sandbox_runner_stop_when_not_started(self):\n116:         \"\"\"Test that stop handles unstarted runner gracefully.\"\"\"\n117:         try:\n118:             from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n119: \n120:             runner = SandboxRunner()\n121:             runner.stop()\n122:             assert runner.client is None\n123:         except ImportError:\n124:             pytest.skip(\"agentcube not in path\")\n125: \n126: \n127: class TestAnalyzeResponse:\n128:     \"\"\"Test cases for AnalyzeResponse model.\"\"\"\n129: \n130:     def test_analyze_response_creation(self):\n131:         \"\"\"Test AnalyzeResponse can be created with valid data.\"\"\"\n132:         try:\n133:             from example.pcap_analyzer.pcap_analyzer import AnalyzeResponse\n134: \n135:             response = AnalyzeResponse(\n136:                 script=\"print('test')\",\n137:                 results=\"test output\",\n138:                 report=\"Test report\",\n139:             )\n140:             assert response.script == \"print('test')\"\n141:             assert response.results == \"test output\"\n142:             assert response.report == \"Test report\"\n143:         except ImportError:\n144:             pytest.skip(\"pydantic not available\")\n145: \n146:     def test_analyze_response_default_values(self):\n147:         \"\"\"Test AnalyzeResponse default values.\"\"\"\n148:         try:\n149:             from example.pcap_analyzer.pcap_analyzer import AnalyzeResponse\n150: \n151:             response = AnalyzeResponse(\n152:                 script=\"\",\n153:                 results=\"\",\n154:                 report=\"\",\n155:             )\n156:             assert response.script == \"\"\n157:             assert response.results == \"\"\n158:             assert response.report == \"\"\n159:         except ImportError:\n160:             pytest.skip(\"pydantic not available\")\n161: \n162: \n163: class TestPCAPAnalyzerApp:\n164:     \"\"\"Test cases for FastAPI application.\"\"\"\n165: \n166:     def test_app_root_endpoint(self):\n167:         \"\"\"Test root endpoint returns service info.\"\"\"\n168:         try:\n169:             from example.pcap_analyzer.pcap_analyzer import app\n170:             from fastapi.testclient import TestClient\n171: \n172:             with patch.dict(os.environ, {\"OPENAI_API_KEY\": \"test-key\"}):\n173:                 with patch(\"example.pcap_analyzer.pcap_analyzer.startup_event\"):\n174:                     client = TestClient(app)\n175:                     response = client.get(\"/\")\n176:                     assert response.status_code == 200\n177:                     data = response.json()\n178:                     assert data[\"service\"] == \"PCAP Analyzer\"\n179:                     assert \"endpoints\" in data\n180:         except ImportError as e:\n181:             pytest.skip(f\"Missing dependency: {e}\")\n182: \n183:     def test_app_health_endpoint(self):\n184:         \"\"\"Test health check endpoint.\"\"\"\n185:         try:\n186:             from example.pcap_analyzer.pcap_analyzer import app\n187:             from fastapi.testclient import TestClient\n188: \n189:             client = TestClient(app)\n190:             response = client.get(\"/health\")\n191:             assert response.status_code == 200\n192:             assert response.json()[\"status\"] == \"healthy\"\n193:         except ImportError as e:\n194:             pytest.skip(f\"Missing dependency: {e}\")\n195: \n196: \n197: class TestPlannerAndReporterAgents:\n198:     \"\"\"Test cases for Planner and Reporter agents.\"\"\"\n199: \n200:     def test_planner_initialization(self):\n201:         \"\"\"Test Planner can be initialized.\"\"\"\n202:         try:\n203:             from example.pcap_analyzer.pcap_analyzer import Planner\n204: \n205:             mock_llm = Mock()\n206:             planner = Planner(mock_llm)\n207:             assert planner.llm is mock_llm\n208:         except ImportError:\n209:             pytest.skip(\"agent not available\")\n210: \n211:     def test_reporter_initialization(self):\n212:         \"\"\"Test Reporter can be initialized.\"\"\"\n213:         try:\n214:             from example.pcap_analyzer.pcap_analyzer import Reporter\n215: \n216:             mock_llm = Mock()\n217:             reporter = Reporter(mock_llm)\n218:             assert reporter.llm is mock_llm\n219:         except ImportError:\n220:             pytest.skip(\"agent not available\")\n221: \n222:     def test_planner_system_prompt(self):\n223:         \"\"\"Test Planner has correct system prompt.\"\"\"\n224:         try:\n225:             from example.pcap_analyzer.pcap_analyzer import Planner\n226: \n227:             mock_llm = Mock()\n228:             planner = Planner(mock_llm)\n229:             assert \"PCAP analysis planning\" in planner.SYSTEM_PROMPT\n230:             assert \"scapy\" in planner.SYSTEM_PROMPT or \"pyshark\" in planner.SYSTEM_PROMPT\n231:         except ImportError:\n232:             pytest.skip(\"agent not available\")\n233: \n234:     def test_reporter_system_prompt(self):\n235:         \"\"\"Test Reporter has correct system prompt.\"\"\"\n236:         try:\n237:             from example.pcap_analyzer.pcap_analyzer import Reporter\n238: \n239:             mock_llm = Mock()\n240:             reporter = Reporter(mock_llm)\n241:             assert \"reporting agent\" in reporter.SYSTEM_PROMPT.lower()\n242:             assert \"bullet points\" in reporter.SYSTEM_PROMPT.lower()\n243:         except ImportError:\n244:             pytest.skip(\"agent not available\")\n\n(End of file - total 244 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for PCAP Analyzer application components.\"\"\"\n\nimport pytest\nimport os\nimport sys\nfrom pathlib import Path\nfrom unittest.mock import Mock, patch, MagicMock\n\n\nclass TestPCAPAnalyzerConfiguration:\n    \"\"\"Test cases for PCAP analyzer configuration.\"\"\"\n\n    def test_default_configuration_values(self):\n        \"\"\"Test that default configuration values are set correctly.\"\"\"\n        os.environ.pop(\"OPEN