k/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pcap_analyzer.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pcap_analyzer.py\n@@ -129,14 +129,18 @@\n \n def test_sandbox_runner_context_manager(self):\n     \"\"\"Test SandboxRunner context manager protocol.\"\"\"\n     try:\n-        from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n-        from unittest.mock import patch, MagicMock\n+        for mod_name in list(sys.modules.keys()):\n+            if \"pcap_analyzer\" in mod_name:\n+                del sys.modules[mod_name]\n \n         os.environ[\"ROUTER_URL\"] = \"http://localhost:8080\"\n         os.environ[\"WORKLOAD_MANAGER_URL\"] = \"http://localhost:8080\"\n \n+        from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n+        from unittest.mock import patch, MagicMock\n+\n         with patch(\"example.pcap_analyzer.pcap_analyzer.CodeInterpreterClient\") as mock_client:\n             mock_instance = MagicMock()\n             mock_client.return_value = mock_instance\n \n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pcap_analyzer.py","before":"\"\"\"Tests for PCAP Analyzer application components.\"\"\"\n\nimport pytest\nimport os\nimport sys\nfrom pathlib import Path\nfrom unittest.mock import Mock, patch, MagicMock\n\n\nclass TestPCAPAnalyzerConfiguration:\n    \"\"\"Test cases for PCAP analyzer configuration.\"\"\"\n\n    def test_default_configuration_values(self):\n        \"\"\"Test that default configuration values are set correctly.\"\"\"\n        os.environ.pop(\"OPENAI_API_KEY\", None)\n        os.environ.pop(\"OPENAI_API_BASE\", None)\n        os.environ.pop(\"OPENAI_MODEL\", None)\n        os.environ.pop(\"CODEINTERPRETER_NAME\", None)\n        os.environ.pop(\"SANDBOX_NAMESPACE\", None)\n        os.environ.pop(\"SANDBOX_WARMUP_SEC\", None)\n        os.environ.pop(\"ROUTER_URL\", None)\n        os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n\n        if \"example.pcap_analyzer.pcap_analyzer\" in sys.modules:\n            del sys.modules[\"example.pcap_analyzer.pcap_analyzer\"]\n        if \"pcap_analyzer\" in sys.modules:\n            del sys.modules[\"pcap_analyzer\"]\n\n        import example.pcap_analyzer.pcap_analyzer as pcap_analyzer\n\n        assert pcap_analyzer.OPENAI_API_BASE == \"https://api.siliconflow.cn/v1\"\n        assert pcap_analyzer.OPENAI_MODEL == \"Qwen/QwQ-32B\"\n        assert pcap_analyzer.CODEINTERPRETER_NAME == \"my-interpreter\"\n        assert pcap_analyzer.SANDBOX_NAMESPACE == \"default\"\n        assert pcap_analyzer.SANDBOX_WARMUP_SEC == 5\n\n    def test_environment_variable_overrides(self):\n        \"\"\"Test that environment variables override defaults.\"\"\"\n        os.environ[\"OPENAI_API_BASE\"] = \"https://custom.api.com/v1\"\n        os.environ[\"OPENAI_MODEL\"] = \"custom/model\"\n        os.environ[\"CODEINTERPRETER_NAME\"] = \"custom-interpreter\"\n        os.environ[\"SANDBOX_NAMESPACE\"] = \"custom-namespace\"\n        os.environ[\"SANDBOX_WARMUP_SEC\"] = \"10\"\n\n        for mod_name in list(sys.modules.keys()):\n            if \"pcap_analyzer\" in mod_name:\n                del sys.modules[mod_name]\n\n        try:\n            import importlib\n            import example.pcap_analyzer.pcap_analyzer as pcap_analyzer\n\n            importlib.reload(pcap_analyzer)\n\n            assert pcap_analyzer.OPENAI_API_BASE == \"https://custom.api.com/v1\"\n            assert pcap_analyzer.OPENAI_MODEL == \"custom/model\"\n            assert pcap_analyzer.CODEINTERPRETER_NAME == \"custom-interpreter\"\n            assert pcap_analyzer.SANDBOX_NAMESPACE == \"custom-namespace\"\n            assert pcap_analyzer.SANDBOX_WARMUP_SEC == 10\n        finally:\n            os.environ.pop(\"OPENAI_API_BASE\", None)\n            os.environ.pop(\"OPENAI_MODEL\", None)\n            os.environ.pop(\"CODEINTERPRETER_NAME\", None)\n            os.environ.pop(\"SANDBOX_NAMESPACE\", None)\n            os.environ.pop(\"SANDBOX_WARMUP_SEC\", None)\n\n\nclass TestSandboxRunner:\n    \"\"\"Test cases for SandboxRunner class.\"\"\"\n\n    def test_sandbox_runner_initialization(self):\n        \"\"\"Test SandboxRunner can be initialized with defaults.\"\"\"\n        try:\n            for mod_name in list(sys.modules.keys()):\n                if \"pcap_analyzer\" in mod_name:\n                    del sys.modules[mod_name]\n\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n\n            runner = SandboxRunner()\n            assert runner.name == \"my-interpreter\"\n            assert runner.namespace == \"default\"\n            assert runner.warmup_sec == 5\n            assert runner.client is None\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n\n    def test_sandbox_runner_custom_parameters(self):\n        \"\"\"Test SandboxRunner can be initialized with custom parameters.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n\n            runner = SandboxRunner(\n                name=\"custom-runner\",\n                namespace=\"custom-ns\",\n                warmup_sec=10,\n            )\n            assert runner.name == \"custom-runner\"\n            assert runner.namespace == \"custom-ns\"\n            assert runner.warmup_sec == 10\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n\n    def test_sandbox_runner_start_requires_router_url(self):\n        \"\"\"Test that start raises error without ROUTER_URL.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n\n            os.environ.pop(\"ROUTER_URL\", None)\n            os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n\n            runner = SandboxRunner()\n            with pytest.raises(ValueError) as exc_info:\n                runner.start()\n            assert \"ROUTER_URL\" in str(exc_info.value)\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n\n    def test_sandbox_runner_stop_when_not_started(self):\n        \"\"\"Test that stop handles unstarted runner gracefully.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n\n            runner = SandboxRunner()\n            runner.stop()\n            assert runner.client is None\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n\n    def test_sandbox_runner_context_manager(self):\n        \"\"\"Test SandboxRunner context manager protocol.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n            from unittest.mock import patch, MagicMock\n\n            os.environ[\"ROUTER_URL\"] = \"http://localhost:8080\"\n            os.environ[\"WORKLOAD_MANAGER_URL\"] = \"http://localhost:8080\"\n\n            with patch(\"example.pcap_analyzer.pcap_analyzer.CodeInterpreterClient\") as mock_client:\n                mock_instance = MagicMock()\n                mock_client.return_value = mock_instance\n\n                with SandboxRunner() as runner:\n                    assert runner.client is not None\n                    mock_client.assert_called_once()\n\n                mock_instance.stop.assert_called_once()\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n        finally:\n            os.environ.pop(\"ROUTER_URL\", None)\n            os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n\n\nclass TestAnalyzeResponse:\n    \"\"\"Test cases for AnalyzeResponse model.\"\"\"\n\n    def test_analyze_response_creation(self):\n        \"\"\"Test AnalyzeResponse can be created with valid data.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import AnalyzeResponse\n\n            response = AnalyzeResponse(\n                script=\"print('test')\",\n                results=\"test output\",\n                report=\"Test report\",\n            )\n            assert response.script == \"print('test')\"\n            assert response.results == \"test output\"\n            assert response.report == \"Test report\"\n        except ImportError:\n            pytest.skip(\"pydantic not available\")\n\n    def test_analyze_response_default_values(self):\n        \"\"\"Test AnalyzeResponse default values.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import AnalyzeResponse\n\n            response = AnalyzeResponse(\n                script=\"\",\n                results=\"\",\n                report=\"\",\n            )\n            assert response.script == \"\"\n            assert response.results == \"\"\n            assert response.report == \"\"\n        except ImportError:\n            pytest.skip(\"pydantic not available\")\n\n\nclass TestPCAPAnalyzerApp:\n    \"\"\"Test cases for FastAPI application.\"\"\"\n\n    def test_app_root_endpoint(self):\n        \"\"\"Test root endpoint returns service info.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import app\n            from fastapi.testclient import TestClient\n\n            with patch.dict(os.environ, {\"OPENAI_API_KEY\": \"test-key\"}):\n                with patch(\"example.pcap_analyzer.pcap_analyzer.startup_event\"):\n                    client = TestClient(app)\n                    response = client.get(\"/\")\n                    assert response.status_code == 200\n                    data = response.json()\n                    assert data[\"service\"] == \"PCAP Analyzer\"\n                    assert \"endpoints\" in data\n        except ImportError as e:\n            pytest.skip(f\"Missing dependency: {e}\")\n\n    def test_app_health_endpoint(self):\n        \"\"\"Test health check endpoint.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import app\n            from fastapi.testclient import TestClient\n\n            client = TestClient(app)\n            response = client.get(\"/health\")\n            assert response.status_code == 200\n            assert response.json()[\"status\"] == \"healthy\"\n        except ImportError as e:\n            pytest.skip(f\"Missing dependency: {e}\")\n\n\nclass TestPlannerAndReporterAgents:\n    \"\"\"Test cases for Planner and Reporter agents.\"\"\"\n\n    def test_planner_initialization(self):\n        \"\"\"Test Planner can be initialized.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import Planner\n\n            mock_llm = Mock()\n            planner = Planner(mock_llm)\n            assert planner.llm is mock_llm\n        except ImportError:\n            pytest.skip(\"agent not available\")\n\n    def test_reporter_initialization(self):\n        \"\"\"Test Reporter can be initialized.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import Reporter\n\n            mock_llm = Mock()\n            reporter = Reporter(mock_llm)\n            assert reporter.llm is mock_llm\n        except ImportError:\n            pytest.skip(\"agent not available\")\n\n    def test_planner_system_prompt(self):\n        \"\"\"Test Planner has correct system prompt.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import Planner\n\n            mock_llm = Mock()\n            planner = Planner(mock_llm)\n            assert \"PCAP analysis planning\" in planner.SYSTEM_PROMPT\n            assert \"scapy\" in planner.SYSTEM_PROMPT or \"pyshark\" in planner.SYSTEM_PROMPT\n        except ImportError:\n            pytest.skip(\"agent not available\")\n\n    def test_reporter_system_prompt(self):\n        \"\"\"Test Reporter has correct system prompt.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import Reporter\n\n            mock_llm = Mock()\n            reporter = Reporter(mock_llm)\n            assert \"reporting agent\" in reporter.SYSTEM_PROMPT.lower()\n            assert \"bullet points\" in reporter.SYSTEM_PROMPT.lower()\n        except ImportError:\n            pytest.skip(\"agent not available\")\n","after":"\"\"\"Tests for PCAP Analyzer application components.\"\"\"\n\nimport pytest\nimport os\nimport sys\nfrom pathlib import Path\nfrom unittest.mock import Mock, patch, MagicMock\n\n\nclass TestPCAPAnalyzerConfiguration:\n    \"\"\"Test cases for PCAP analyzer configuration.\"\"\"\n\n    def test_default_configuration_values(self):\n        \"\"\"Test that default configuration values are set correctly.\"\"\"\n        os.environ.pop(\"OPENAI_API_KEY\", None)\n        os.environ.pop(\"OPENAI_API_BASE\", None)\n        os.environ.pop(\"OPENAI_MODEL\", None)\n        os.environ.pop(\"CODEINTERPRETER_NAME\", None)\n        os.environ.pop(\"SANDBOX_NAMESPACE\", None)\n        os.environ.pop(\"SANDBOX_WARMUP_SEC\", None)\n        os.environ.pop(\"ROUTER_URL\", None)\n        os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n\n        if \"example.pcap_analyzer.pcap_analyzer\" in sys.modules:\n            del sys.modules[\"example.pcap_analyzer.pcap_analyzer\"]\n        if \"pcap_analyzer\" in sys.modules:\n            del sys.modules[\"pcap_analyzer\"]\n\n        import example.pcap_analyzer.pcap_analyzer as pcap_analyzer\n\n        assert pcap_analyzer.OPENAI_API_BASE == \"https://api.siliconflow.cn/v1\"\n        assert pcap_analyzer.OPENAI_MODEL == \"Qwen/QwQ-32B\"\n        assert pcap_analyzer.CODEINTERPRETER_NAME == \"my-interpreter\"\n        assert pcap_analyzer.SANDBOX_NAMESPACE == \"default\"\n        assert pcap_analyzer.SANDBOX_WARMUP_SEC == 5\n\n    def test_environment_variable_overrides(self):\n        \"\"\"Test that environment variables override defaults.\"\"\"\n        os.environ[\"OPENAI_API_BASE\"] = \"https://custom.api.com/v1\"\n        os.environ[\"OPENAI_MODEL\"] = \"custom/model\"\n        os.environ[\"CODEINTERPRETER_NAME\"] = \"custom-interpreter\"\n        os.environ[\"SANDBOX_NAMESPACE\"] = \"custom-namespace\"\n        os.environ[\"SANDBOX_WARMUP_SEC\"] = \"10\"\n\n        for mod_name in list(sys.modules.keys()):\n            if \"pcap_analyzer\" in mod_name:\n                del sys.modules[mod_name]\n\n        try:\n            import importlib\n            import example.pcap_analyzer.pcap_analyzer as pcap_analyzer\n\n            importlib.reload(pcap_analyzer)\n\n            assert pcap_analyzer.OPENAI_API_BASE == \"https://custom.api.com/v1\"\n            assert pcap_analyzer.OPENAI_MODEL == \"custom/model\"\n            assert pcap_analyzer.CODEINTERPRETER_NAME == \"custom-interpreter\"\n            assert pcap_analyzer.SANDBOX_NAMESPACE == \"custom-namespace\"\n            assert pcap_analyzer.SANDBOX_WARMUP_SEC == 10\n        finally:\n            os.environ.pop(\"OPENAI_API_BASE\", None)\n            os.environ.pop(\"OPENAI_MODEL\", None)\n            os.environ.pop(\"CODEINTERPRETER_NAME\", None)\n            os.environ.pop(\"SANDBOX_NAMESPACE\", None)\n            os.environ.pop(\"SANDBOX_WARMUP_SEC\", None)\n\n\nclass TestSandboxRunner:\n    \"\"\"Test cases for SandboxRunner class.\"\"\"\n\n    def test_sandbox_runner_initialization(self):\n        \"\"\"Test SandboxRunner can be initialized with defaults.\"\"\"\n        try:\n            for mod_name in list(sys.modules.keys()):\n                if \"pcap_analyzer\" in mod_name:\n                    del sys.modules[mod_name]\n\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n\n            runner = SandboxRunner()\n            assert runner.name == \"my-interpreter\"\n            assert runner.namespace == \"default\"\n            assert runner.warmup_sec == 5\n            assert runner.client is None\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n\n    def test_sandbox_runner_custom_parameters(self):\n        \"\"\"Test SandboxRunner can be initialized with custom parameters.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n\n            runner = SandboxRunner(\n                name=\"custom-runner\",\n                namespace=\"custom-ns\",\n                warmup_sec=10,\n            )\n            assert runner.name == \"custom-runner\"\n            assert runner.namespace == \"custom-ns\"\n            assert runner.warmup_sec == 10\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n\n    def test_sandbox_runner_start_requires_router_url(self):\n        \"\"\"Test that start raises error without ROUTER_URL.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n\n            os.environ.pop(\"ROUTER_URL\", None)\n            os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n\n            runner = SandboxRunner()\n            with pytest.raises(ValueError) as exc_info:\n                runner.start()\n            assert \"ROUTER_URL\" in str(exc_info.value)\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n\n    def test_sandbox_runner_stop_when_not_started(self):\n        \"\"\"Test that stop handles unstarted runner gracefully.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n\n            runner = SandboxRunner()\n            runner.stop()\n            assert runner.client is None\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n\n    def test_sandbox_runner_context_manager(self):\n        \"\"\"Test SandboxRunner context manager protocol.\"\"\"\n        try:\n            for mod_name in list(sys.modules.keys()):\n                if \"pcap_analyzer\" in mod_name:\n                    del sys.modules[mod_name]\n\n            os.environ[\"ROUTER_URL\"] = \"http://localhost:8080\"\n            os.environ[\"WORKLOAD_MANAGER_URL\"] = \"http://localhost:8080\"\n\n            from example.pcap_analyzer.pcap_analyzer import SandboxRunner\n            from unittest.mock import patch, MagicMock\n\n            with patch(\"example.pcap_analyzer.pcap_analyzer.CodeInterpreterClient\") as mock_client:\n                mock_instance = MagicMock()\n                mock_client.return_value = mock_instance\n\n                with SandboxRunner() as runner:\n                    assert runner.client is not None\n                    mock_client.assert_called_once()\n\n                mock_instance.stop.assert_called_once()\n        except ImportError:\n            pytest.skip(\"agentcube not in path\")\n        finally:\n            os.environ.pop(\"ROUTER_URL\", None)\n            os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n\n\nclass TestAnalyzeResponse:\n    \"\"\"Test cases for AnalyzeResponse model.\"\"\"\n\n    def test_analyze_response_creation(self):\n        \"\"\"Test AnalyzeResponse can be created with valid data.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import AnalyzeResponse\n\n            response = AnalyzeResponse(\n                script=\"print('test')\",\n                results=\"test output\",\n                report=\"Test report\",\n            )\n            assert response.script == \"print('test')\"\n            assert response.results == \"test output\"\n            assert response.report == \"Test report\"\n        except ImportError:\n            pytest.skip(\"pydantic not available\")\n\n    def test_analyze_response_default_values(self):\n        \"\"\"Test AnalyzeResponse default values.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import AnalyzeResponse\n\n            response = AnalyzeResponse(\n                script=\"\",\n                results=\"\",\n                report=\"\",\n            )\n            assert response.script == \"\"\n            assert response.results == \"\"\n            assert response.report == \"\"\n        except ImportError:\n            pytest.skip(\"pydantic not available\")\n\n\nclass TestPCAPAnalyzerApp:\n    \"\"\"Test cases for FastAPI application.\"\"\"\n\n    def test_app_root_endpoint(self):\n        \"\"\"Test root endpoint returns service info.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import app\n            from fastapi.testclient import TestClient\n\n            with patch.dict(os.environ, {\"OPENAI_API_KEY\": \"test-key\"}):\n                with patch(\"example.pcap_analyzer.pcap_analyzer.startup_event\"):\n                    client = TestClient(app)\n                    response = client.get(\"/\")\n                    assert response.status_code == 200\n                    data = response.json()\n                    assert data[\"service\"] == \"PCAP Analyzer\"\n                    assert \"endpoints\" in data\n        except ImportError as e:\n            pytest.skip(f\"Missing dependency: {e}\")\n\n    def test_app_health_endpoint(self):\n        \"\"\"Test health check endpoint.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import app\n            from fastapi.testclient import TestClient\n\n            client = TestClient(app)\n            response = client.get(\"/health\")\n            assert response.status_code == 200\n            assert response.json()[\"status\"] == \"healthy\"\n        except ImportError as e:\n            pytest.skip(f\"Missing dependency: {e}\")\n\n\nclass TestPlannerAndReporterAgents:\n    \"\"\"Test cases for Planner and Reporter agents.\"\"\"\n\n    def test_planner_initialization(self):\n        \"\"\"Test Planner can be initialized.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import Planner\n\n            mock_llm = Mock()\n            planner = Planner(mock_llm)\n            assert planner.llm is mock_llm\n        except ImportError:\n            pytest.skip(\"agent not available\")\n\n    def test_reporter_initialization(self):\n        \"\"\"Test Reporter can be initialized.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import Reporter\n\n            mock_llm = Mock()\n            reporter = Reporter(mock_llm)\n            assert reporter.llm is mock_llm\n        except ImportError:\n            pytest.skip(\"agent not available\")\n\n    def test_planner_system_prompt(self):\n        \"\"\"Test Planner has correct system prompt.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import Planner\n\n            mock_llm = Mock()\n            planner = Planner(mock_llm)\n            assert \"PCAP analysis planning\" in planner.SYSTEM_PROMPT\n            assert \"scapy\" in planner.SYSTEM_PROMPT or \"pyshark\" in planner.SYSTEM_PROMPT\n        except ImportError:\n            pytest.skip(\"agent not available\")\n\n    def test_reporter_system_prompt(self):\n        \"\"\"Test Reporter has correct system prompt.\"\"\"\n        try:\n            from example.pcap_analyzer.pcap_analyzer import Reporter\n\n            mock_llm = Mock()\n            reporter = Reporter(mock_llm)\n            assert \"reporting agent\" in reporter.SYSTEM_PROMPT.lower()\n            assert \"bullet points\" in reporter.SYSTEM_PROMPT.lower()\n        except ImportError:\n            pytest.skip(\"agent not available\")\n","additions":6,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pcap_analyzer.py","time":{"start":1775880535996,"end":1775880536540}}}}
