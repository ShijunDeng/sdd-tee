Ready\" {\n+\t\tt.Errorf(\"ConditionTypeReady has wrong value\")\n+\t}\n+\tif ConditionTypeValid != \"Valid\" {\n+\t\tt.Errorf(\"ConditionTypeValid has wrong value\")\n+\t}\n+}\n+\n+func TestTargetPortValidation(t *testing.T) {\n+\ttests := []struct {\n+\t\tname    string\n+\t\tport    TargetPort\n+\t\twantErr bool\n+\t}{\n+\t\t{\n+\t\t\tname: \"valid HTTP port\",\n+\t\t\tport: TargetPort{\n+\t\t\t\tPort:     8080,\n+\t\t\t\tProtocol: ProtocolHTTP,\n+\t\t\t},\n+\t\t\twantErr: false,\n+\t\t},\n+\t\t{\n+\t\t\tname: \"valid HTTPS port\",\n+\t\t\tport: TargetPort{\n+\t\t\t\tPort:     8443,\n+\t\t\t\tProtocol: ProtocolHTTPS,\n+\t\t\t},\n+\t\t\twantErr: false,\n+\t\t},\n+\t\t{\n+\t\t\tname: \"port with name\",\n+\t\t\tport: TargetPort{\n+\t\t\t\tPort:     8080,\n+\t\t\t\tProtocol: ProtocolHTTP,\n+\t\t\t\tName:     \"http\",\n+\t\t\t},\n+\t\t\twantErr: false,\n+\t\t},\n+\t\t{\n+\t\t\tname: \"port with path prefix\",\n+\t\t\tport: TargetPort{\n+\t\t\t\tPort:       8080,\n+\t\t\t\tProtocol:   ProtocolHTTP,\n+\t\t\t\tPathPrefix: \"/api\",\n+\t\t\t},\n+\t\t\twantErr: false,\n+\t\t},\n+\t}\n+\n+\tfor _, tt := range tests {\n+\t\tt.Run(tt.name, func(t *testing.T) {\n+\t\t\tif tt.port.Port < MinPort || tt.port.Port > MaxPort {\n+\t\t\t\tt.Errorf(\"Port %d is out of valid range\", tt.port.Port)\n+\t\t\t}\n+\t\t\tvalidProtocol := false\n+\t\t\tfor _, p := range SupportedProtocols {\n+\t\t\t\tif tt.port.Protocol == p {\n+\t\t\t\t\tvalidProtocol = true\n+\t\t\t\t\tbreak\n+\t\t\t\t}\n+\t\t\t}\n+\t\t\tif !validProtocol && !tt.wantErr {\n+\t\t\t\tt.Errorf(\"Protocol %s is not supported\", tt.port.Protocol)\n+\t\t\t}\n+\t\t})\n+\t}\n+}\n+\n+func TestPodTemplateSpecWithNilSpec(t *testing.T) {\n+\toriginal := &PodTemplateSpec{\n+\t\tObjectMeta: metav1.ObjectMeta{\n+\t\t\tName:      \"test-pod\",\n+\t\t\tNamespace: \"default\",\n+\t\t},\n+\t\tSpec: nil,\n+\t}\n+\n+\tcopied := original.DeepCopy()\n+\n+\tif !reflect.DeepEqual(original, copied) {\n+\t\tt.Errorf(\"DeepCopy returned different object\")\n+\t}\n+\n+\tif copied.Spec != nil {\n+\t\tt.Errorf(\"DeepCopy should preserve nil Spec\")\n+\t}\n+\n+\tcopied.Spec = &PodSpec{\n+\t\tContainers: []ContainerSpec{{Name: \"main\", Image: \"nginx\"}},\n+\t}\n+\tif original.Spec != nil {\n+\t\tt.Errorf(\"DeepCopy did not create independent copy of Spec\")\n+\t}\n+}\n+\n+func TestContainerTemplateSpecWithNilRuntimeClass(t *testing.T) {\n+\toriginal := &ContainerTemplateSpec{\n+\t\tImage:            \"python:3.9\",\n+\t\tRuntimeClassName: nil,\n+\t}\n+\n+\tcopied := original.DeepCopy()\n+\n+\tif !reflect.DeepEqual(original, copied) {\n+\t\tt.Errorf(\"DeepCopy returned different object\")\n+\t}\n+\n+\tif copied.RuntimeClassName != nil {\n+\t\tt.Errorf(\"DeepCopy should preserve nil RuntimeClassName\")\n+\t}\n+\n+\truntimeClassName := \"test-class\"\n+\tcopied.RuntimeClassName = &runtimeClassName\n+\tif original.RuntimeClassName != nil {\n+\t\tt.Errorf(\"DeepCopy did not create independent copy of RuntimeClassName\")\n+\t}\n+}\n+\n+func TestPodSpecWithNilFields(t *testing.T) {\n+\toriginal := &PodSpec{\n+\t\tContainers:     nil,\n+\t\tVolumes:        nil,\n+\t\tNodeSelector:   nil,\n+\t\tAffinity:       nil,\n+\t\tTolerations:    nil,\n+\t\tPriority:       nil,\n+\t\tInitContainers: nil,\n+\t}\n+\n+\tcopied := original.DeepCopy()\n+\n+\tif !reflect.DeepEqual(original, copied) {\n+\t\tt.Errorf(\"DeepCopy returned different object\")\n+\t}\n+\n+\tif copied.Containers != nil {\n+\t\tt.Errorf(\"DeepCopy should preserve nil Containers\")\n+\t}\n+\tif copied.Volumes != nil {\n+\t\tt.Errorf(\"DeepCopy should preserve nil Volumes\")\n+\t}\n+\tif copied.NodeSelector != nil {\n+\t\tt.Errorf(\"DeepCopy should preserve nil NodeSelector\")\n+\t}\n+}\n+\n+func TestAgentRuntimeSpecDefaults(t *testing.T) {\n+\tspec := AgentRuntimeSpec{\n+\t\tMaxSessionDuration: DefaultMaxSessionDuration,\n+\t\tSessionTimeout:     DefaultSessionTimeout,\n+\t\tTargetPorts: []TargetPort{\n+\t\t\t{Port: 8080, Protocol: ProtocolHTTP},\n+\t\t},\n+\t}\n+\n+\tif spec.MaxSessionDuration != DefaultMaxSessionDuration {\n+\t\tt.Errorf(\"MaxSessionDuration should match default\")\n+\t}\n+\tif spec.SessionTimeout != DefaultSessionTimeout {\n+\t\tt.Errorf(\"SessionTimeout should match default\")\n+\t}\n+}\n+\n+func TestCodeInterpreterSpecDefaults(t *testing.T) {\n+\tspec := CodeInterpreterSpec{\n+\t\tAuthMode:           DefaultAuthMode,\n+\t\tMaxSessionDuration: DefaultMaxSessionDuration,\n+\t\tSessionTimeout:     DefaultSessionTimeout,\n+\t\tWarmPoolSize:       DefaultWarmPoolSize,\n+\t\tTemplate: ContainerTemplateSpec{\n+\t\t\tImage: \"python:3.9\",\n+\t\t},\n+\t}\n+\n+\tif spec.AuthMode != DefaultAuthMode {\n+\t\tt.Errorf(\"AuthMode should match default\")\n+\t}\n+\tif spec.WarmPoolSize != DefaultWarmPoolSize {\n+\t\tt.Errorf(\"WarmPoolSize should match default\")\n+\t}\n+}\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/types_test.go","before":"package v1alpha1\n\nimport (\n\t\"reflect\"\n\t\"testing\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tkresource \"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestAgentRuntimeDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntime{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tMaxSessionDuration: \"8h\",\n\t\t\tSessionTimeout:     \"15m\",\n\t\t\tTargetPorts: []TargetPort{\n\t\t\t\t{Port: 8080, Protocol: \"HTTP\"},\n\t\t\t},\n\t\t\tPodTemplate: &PodTemplateSpec{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\t\t},\n\t\t\t\tSpec: &PodSpec{\n\t\t\t\t\tContainers: []ContainerSpec{\n\t\t\t\t\t\t{Name: \"main\", Image: \"nginx:latest\"},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tConditions: []metav1.Condition{\n\t\t\t\t{Type: \"Ready\", Status: metav1.ConditionTrue},\n\t\t\t},\n\t\t\tObservedGeneration: 1,\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tcopied.Name = \"modified\"\n\tif original.Name == copied.Name {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Name\")\n\t}\n\n\tcopied.Spec.MaxSessionDuration = \"4h\"\n\tif original.Spec.MaxSessionDuration == copied.Spec.MaxSessionDuration {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Spec\")\n\t}\n\n\tif copied.Status.Conditions[0].Type != original.Status.Conditions[0].Type {\n\t\tt.Errorf(\"DeepCopy did not copy Status correctly\")\n\t}\n}\n\nfunc TestAgentRuntimeListDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntimeList\",\n\t\t},\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"123\",\n\t\t},\n\t\tItems: []AgentRuntime{\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"runtime-1\"}},\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"runtime-2\"}},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif len(copied.Items) != len(original.Items) {\n\t\tt.Errorf(\"DeepCopyList did not copy all items\")\n\t}\n\n\tcopied.Items[0].Name = \"modified\"\n\tif original.Items[0].Name == copied.Items[0].Name {\n\t\tt.Errorf(\"DeepCopyList did not create independent copy of items\")\n\t}\n}\n\nfunc TestCodeInterpreterDeepCopy(t *testing.T) {\n\truntimeClassName := \"test-class\"\n\toriginal := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-ci\",\n\t\t\tNamespace: \"default\",\n\t\t},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tAuthMode:           AuthModePicod,\n\t\t\tMaxSessionDuration: \"8h\",\n\t\t\tSessionTimeout:     \"15m\",\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{Port: 9000, Protocol: \"HTTP\"},\n\t\t\t},\n\t\t\tTemplate: ContainerTemplateSpec{\n\t\t\t\tImage:            \"python:3.9\",\n\t\t\t\tCommand:          []string{\"python\"},\n\t\t\t\tArgs:             []string{\"-m\", \"http.server\"},\n\t\t\t\tRuntimeClassName: &runtimeClassName,\n\t\t\t},\n\t\t\tWarmPoolSize: 2,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tReady: true,\n\t\t\tConditions: []metav1.Condition{\n\t\t\t\t{Type: \"Ready\", Status: metav1.ConditionTrue},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.Spec.AuthMode != AuthModePicod {\n\t\tt.Errorf(\"AuthMode not copied correctly\")\n\t}\n\n\tif *copied.Spec.Template.RuntimeClassName != *original.Spec.Template.RuntimeClassName {\n\t\tt.Errorf(\"RuntimeClassName not copied correctly\")\n\t}\n}\n\nfunc TestCodeInterpreterListDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreterList\",\n\t\t},\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"456\",\n\t\t},\n\t\tItems: []CodeInterpreter{\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci-1\"}},\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci-2\"}},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif len(copied.Items) != len(original.Items) {\n\t\tt.Errorf(\"DeepCopyList did not copy all items\")\n\t}\n}\n\nfunc TestTargetPortDeepCopy(t *testing.T) {\n\toriginal := &TargetPort{\n\t\tPort:       8080,\n\t\tProtocol:   \"HTTP\",\n\t\tName:       \"http-port\",\n\t\tPathPrefix: \"/api\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tcopied.Port = 9000\n\tif original.Port == copied.Port {\n\t\tt.Errorf(\"DeepCopy did not create independent copy\")\n\t}\n}\n\nfunc TestPodTemplateSpecDeepCopy(t *testing.T) {\n\toriginal := &PodTemplateSpec{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-pod\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels:    map[string]string{\"app\": \"test\"},\n\t\t},\n\t\tSpec: &PodSpec{\n\t\t\tContainers: []ContainerSpec{\n\t\t\t\t{\n\t\t\t\t\tName:  \"main\",\n\t\t\t\t\tImage: \"nginx:latest\",\n\t\t\t\t\tEnv: []corev1.EnvVar{\n\t\t\t\t\t\t{Name: \"ENV\", Value: \"test\"},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\tNodeSelector: map[string]string{\"zone\": \"us-east\"},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tcopied.Spec.NodeSelector[\"zone\"] = \"us-west\"\n\tif original.Spec.NodeSelector[\"zone\"] == \"us-west\" {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of NodeSelector\")\n\t}\n\n\tcopied.Spec.Containers[0].Image = \"alpine\"\n\tif original.Spec.Containers[0].Image == \"alpine\" {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Containers\")\n\t}\n}\n\nfunc TestContainerTemplateSpecDeepCopy(t *testing.T) {\n\truntimeClassName := \"test-class\"\n\tmemLimit := kresource.NewQuantity(1024, \"Mi\")\n\toriginal := &ContainerTemplateSpec{\n\t\tImage:   \"python:3.9\",\n\t\tCommand: []string{\"python\"},\n\t\tArgs:    []string{\"-m\", \"http.server\"},\n\t\tEnv: []corev1.EnvVar{\n\t\t\t{Name: \"PYTHON_ENV\", Value: \"production\"},\n\t\t},\n\t\tResources: corev1.ResourceRequirements{\n\t\t\tLimits: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceMemory: *memLimit,\n\t\t\t},\n\t\t},\n\t\tRuntimeClassName: &runtimeClassName,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif *copied.RuntimeClassName != *original.RuntimeClassName {\n\t\tt.Errorf(\"RuntimeClassName not copied correctly\")\n\t}\n}\n\nfunc TestPodSpecDeepCopy(t *testing.T) {\n\tpriority := int32(100)\n\toriginal := &PodSpec{\n\t\tContainers: []ContainerSpec{\n\t\t\t{Name: \"main\", Image: \"nginx:latest\"},\n\t\t},\n\t\tVolumes: []corev1.Volume{\n\t\t\t{Name: \"config\"},\n\t\t},\n\t\tRestartPolicy: corev1.RestartPolicyAlways,\n\t\tNodeSelector: map[string]string{\n\t\t\t\"zone\": \"us-east\",\n\t\t},\n\t\tPriority: &priority,\n\t\tTolerations: []corev1.Toleration{\n\t\t\t{Key: \"key\", Operator: \"Equal\", Value: \"value\"},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif *copied.Priority != *original.Priority {\n\t\tt.Errorf(\"Priority not copied correctly\")\n\t}\n\n\tcopied.NodeSelector[\"zone\"] = \"us-west\"\n\tif original.NodeSelector[\"zone\"] == \"us-west\" {\n\t\tt.Errorf(\"DeepCopy did not create independent copy\")\n\t}\n}\n\nfunc TestContainerSpecDeepCopy(t *testing.T) {\n\tcpuLimit := kresource.NewMilliQuantity(1000, \"m\")\n\toriginal := &ContainerSpec{\n\t\tName:    \"main\",\n\t\tImage:   \"nginx:latest\",\n\t\tCommand: []string{\"/bin/sh\"},\n\t\tArgs:    []string{\"-c\", \"echo hello\"},\n\t\tEnv: []corev1.EnvVar{\n\t\t\t{Name: \"FOO\", Value: \"bar\"},\n\t\t},\n\t\tResources: corev1.ResourceRequirements{\n\t\t\tLimits: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceCPU: *cpuLimit,\n\t\t\t},\n\t\t},\n\t\tLivenessProbe: &corev1.Probe{\n\t\t\tInitialDelaySeconds: 10,\n\t\t},\n\t\tSecurityContext: &corev1.SecurityContext{\n\t\t\tRunAsNonRoot: newBool(false),\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.LivenessProbe.InitialDelaySeconds != original.LivenessProbe.InitialDelaySeconds {\n\t\tt.Errorf(\"LivenessProbe not copied correctly\")\n\t}\n\n\tcopied.Env[0].Value = \"modified\"\n\tif original.Env[0].Value == \"modified\" {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Env\")\n\t}\n}\n\nfunc newBool(b bool) *bool {\n\treturn &b\n}\n\nfunc TestAgentRuntimeSpecDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeSpec{\n\t\tMaxSessionDuration: \"8h\",\n\t\tSessionTimeout:     \"15m\",\n\t\tTargetPorts: []TargetPort{\n\t\t\t{Port: 8080, Protocol: \"HTTP\"},\n\t\t\t{Port: 8443, Protocol: \"HTTPS\", Name: \"https\"},\n\t\t},\n\t\tPodTemplate: &PodTemplateSpec{\n\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\tName: \"test-template\",\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif len(copied.TargetPorts) != len(original.TargetPorts) {\n\t\tt.Errorf(\"TargetPorts not copied correctly\")\n\t}\n\n\tcopied.TargetPorts[0].Port = 9000\n\tif original.TargetPorts[0].Port == 9000 {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of TargetPorts\")\n\t}\n\n\tcopied.PodTemplate.Name = \"modified\"\n\tif original.PodTemplate.Name == \"modified\" {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of PodTemplate\")\n\t}\n}\n\nfunc TestAgentRuntimeStatusDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeStatus{\n\t\tConditions: []metav1.Condition{\n\t\t\t{\n\t\t\t\tType:               \"Ready\",\n\t\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\t\tLastTransitionTime: metav1.Now(),\n\t\t\t\tReason:             \"Ready\",\n\t\t\t\tMessage:            \"Runtime is ready\",\n\t\t\t},\n\t\t},\n\t\tObservedGeneration: 1,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tcopied.Conditions[0].Status = metav1.ConditionFalse\n\tif original.Conditions[0].Status == metav1.ConditionFalse {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Conditions\")\n\t}\n}\n\nfunc TestCodeInterpreterSpecDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterSpec{\n\t\tAuthMode:           AuthModePicod,\n\t\tMaxSessionDuration: \"8h\",\n\t\tSessionTimeout:     \"15m\",\n\t\tPorts:              []TargetPort{{Port: 9000, Protocol: \"HTTP\"}},\n\t\tTemplate: 