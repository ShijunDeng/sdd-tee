TestAgentRuntimeStatusDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeStatus{\n\t\tConditions: []metav1.Condition{\n\t\t\t{\n\t\t\t\tType:               \"Ready\",\n\t\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\t\tLastTransitionTime: metav1.Now(),\n\t\t\t\tReason:             \"Ready\",\n\t\t\t\tMessage:            \"Runtime is ready\",\n\t\t\t},\n\t\t},\n\t\tObservedGeneration: 1,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tcopied.Conditions[0].Status = metav1.ConditionFalse\n\tif original.Conditions[0].Status == metav1.ConditionFalse {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Conditions\")\n\t}\n}\n\nfunc TestCodeInterpreterSpecDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterSpec{\n\t\tAuthMode:           AuthModePicod,\n\t\tMaxSessionDuration: \"8h\",\n\t\tSessionTimeout:     \"15m\",\n\t\tPorts:              []TargetPort{{Port: 9000, Protocol: \"HTTP\"}},\n\t\tTemplate:           ContainerTemplateSpec{Image: \"python:3.9\"},\n\t\tWarmPoolSize:       2,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.AuthMode != AuthModePicod {\n\t\tt.Errorf(\"AuthMode not copied correctly\")\n\t}\n\n\tif copied.WarmPoolSize != 2 {\n\t\tt.Errorf(\"WarmPoolSize not copied correctly\")\n\t}\n\n\tcopied.Ports[0].Port = 8080\n\tif original.Ports[0].Port == 8080 {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Ports\")\n\t}\n}\n\nfunc TestCodeInterpreterStatusDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterStatus{\n\t\tReady: true,\n\t\tConditions: []metav1.Condition{\n\t\t\t{Type: \"Ready\", Status: metav1.ConditionTrue},\n\t\t},\n\t\tObservedGeneration: 1,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.Ready != true {\n\t\tt.Errorf(\"Ready not copied correctly\")\n\t}\n\n\tcopied.Ready = false\n\tif original.Ready == false {\n\t\tt.Errorf(\"DeepCopy did not create independent copy\")\n\t}\n}\n\nfunc TestSchemeGroupVersion(t *testing.T) {\n\tif SchemeGroupVersion.Group != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"SchemeGroupVersion has wrong group: %s\", SchemeGroupVersion.Group)\n\t}\n\tif SchemeGroupVersion.Version != \"v1alpha1\" {\n\t\tt.Errorf(\"SchemeGroupVersion has wrong version: %s\", SchemeGroupVersion.Version)\n\t}\n}\n\nfunc TestResource(t *testing.T) {\n\tresource := Resource(\"agentruntimes\")\n\tif resource.Group != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"Resource has wrong group\")\n\t}\n\tif resource.Resource != \"agentruntimes\" {\n\t\tt.Errorf(\"Resource has wrong resource name\")\n\t}\n}\n\nfunc TestAuthMode(t *testing.T) {\n\tif AuthModePicod != \"picod\" {\n\t\tt.Errorf(\"AuthModePicod has wrong value\")\n\t}\n\tif AuthModeNone != \"none\" {\n\t\tt.Errorf(\"AuthModeNone has wrong value\")\n\t}\n}\n\nfunc TestConstants(t *testing.T) {\n\tif DefaultMaxSessionDuration != \"8h\" {\n\t\tt.Errorf(\"DefaultMaxSessionDuration has wrong value\")\n\t}\n\tif DefaultSessionTimeout != \"15m\" {\n\t\tt.Errorf(\"DefaultSessionTimeout has wrong value\")\n\t}\n\tif DefaultWarmPoolSize != 0 {\n\t\tt.Errorf(\"DefaultWarmPoolSize has wrong value\")\n\t}\n\tif DefaultAuthMode != AuthModePicod {\n\t\tt.Errorf(\"DefaultAuthMode has wrong value\")\n\t}\n\tif MinPort != 1 {\n\t\tt.Errorf(\"MinPort has wrong value\")\n\t}\n\tif MaxPort != 65535 {\n\t\tt.Errorf(\"MaxPort has wrong value\")\n\t}\n}\n\nfunc TestSupportedProtocols(t *testing.T) {\n\tif len(SupportedProtocols) != 2 {\n\t\tt.Errorf(\"SupportedProtocols has wrong length\")\n\t}\n\tif SupportedProtocols[0] != ProtocolHTTP {\n\t\tt.Errorf(\"SupportedProtocols[0] should be HTTP\")\n\t}\n\tif SupportedProtocols[1] != ProtocolHTTPS {\n\t\tt.Errorf(\"SupportedProtocols[1] should be HTTPS\")\n\t}\n}\n\nfunc TestSupportedAuthModes(t *testing.T) {\n\tif len(SupportedAuthModes) != 2 {\n\t\tt.Errorf(\"SupportedAuthModes has wrong length\")\n\t}\n\tif SupportedAuthModes[0] != AuthModePicod {\n\t\tt.Errorf(\"SupportedAuthModes[0] should be AuthModePicod\")\n\t}\n\tif SupportedAuthModes[1] != AuthModeNone {\n\t\tt.Errorf(\"SupportedAuthModes[1] should be AuthModeNone\")\n\t}\n}\n\nfunc TestConditionConstants(t *testing.T) {\n\tif ConditionTypeReady != \"Ready\" {\n\t\tt.Errorf(\"ConditionTypeReady has wrong value\")\n\t}\n\tif ConditionTypeValid != \"Valid\" {\n\t\tt.Errorf(\"ConditionTypeValid has wrong value\")\n\t}\n}\n\nfunc TestTargetPortValidation(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tport    TargetPort\n\t\twantErr bool\n\t}{\n\t\t{\n\t\t\tname: \"valid HTTP port\",\n\t\t\tport: TargetPort{\n\t\t\t\tPort:     8080,\n\t\t\t\tProtocol: ProtocolHTTP,\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname: \"valid HTTPS port\",\n\t\t\tport: TargetPort{\n\t\t\t\tPort:     8443,\n\t\t\t\tProtocol: ProtocolHTTPS,\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname: \"port with name\",\n\t\t\tport: TargetPort{\n\t\t\t\tPort:     8080,\n\t\t\t\tProtocol: ProtocolHTTP,\n\t\t\t\tName:     \"http\",\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname: \"port with path prefix\",\n\t\t\tport: TargetPort{\n\t\t\t\tPort:       8080,\n\t\t\t\tProtocol:   ProtocolHTTP,\n\t\t\t\tPathPrefix: \"/api\",\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.port.Port < MinPort || tt.port.Port > MaxPort {\n\t\t\t\tt.Errorf(\"Port %d is out of valid range\", tt.port.Port)\n\t\t\t}\n\t\t\tvalidProtocol := false\n\t\t\tfor _, p := range SupportedProtocols {\n\t\t\t\tif tt.port.Protocol == p {\n\t\t\t\t\tvalidProtocol = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !validProtocol && !tt.wantErr {\n\t\t\t\tt.Errorf(\"Protocol %s is not supported\", tt.port.Protocol)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestPodTemplateSpecWithNilSpec(t *testing.T) {\n\toriginal := &PodTemplateSpec{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-pod\",\n\t\t\tNamespace: \"default\",\n\t\t},\n\t\tSpec: nil,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.Spec != nil {\n\t\tt.Errorf(\"DeepCopy should preserve nil Spec\")\n\t}\n\n\tcopied.Spec = &PodSpec{\n\t\tContainers: []ContainerSpec{{Name: \"main\", Image: \"nginx\"}},\n\t}\n\tif original.Spec != nil {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Spec\")\n\t}\n}\n\nfunc TestContainerTemplateSpecWithNilRuntimeClass(t *testing.T) {\n\toriginal := &ContainerTemplateSpec{\n\t\tImage:            \"python:3.9\",\n\t\tRuntimeClassName: nil,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.RuntimeClassName != nil {\n\t\tt.Errorf(\"DeepCopy should preserve nil RuntimeClassName\")\n\t}\n\n\truntimeClassName := \"test-class\"\n\tcopied.RuntimeClassName = &runtimeClassName\n\tif original.RuntimeClassName != nil {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of RuntimeClassName\")\n\t}\n}\n\nfunc TestPodSpecWithNilFields(t *testing.T) {\n\toriginal := &PodSpec{\n\t\tContainers:     nil,\n\t\tVolumes:        nil,\n\t\tNodeSelector:   nil,\n\t\tAffinity:       nil,\n\t\tTolerations:    nil,\n\t\tPriority:       nil,\n\t\tInitContainers: nil,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.Containers != nil {\n\t\tt.Errorf(\"DeepCopy should preserve nil Containers\")\n\t}\n\tif copied.Volumes != nil {\n\t\tt.Errorf(\"DeepCopy should preserve nil Volumes\")\n\t}\n\tif copied.NodeSelector != nil {\n\t\tt.Errorf(\"DeepCopy should preserve nil NodeSelector\")\n\t}\n}\n\nfunc TestAgentRuntimeSpecDefaults(t *testing.T) {\n\tspec := AgentRuntimeSpec{\n\t\tMaxSessionDuration: DefaultMaxSessionDuration,\n\t\tSessionTimeout:     DefaultSessionTimeout,\n\t\tTargetPorts: []TargetPort{\n\t\t\t{Port: 8080, Protocol: ProtocolHTTP},\n\t\t},\n\t}\n\n\tif spec.MaxSessionDuration != DefaultMaxSessionDuration {\n\t\tt.Errorf(\"MaxSessionDuration should match default\")\n\t}\n\tif spec.SessionTimeout != DefaultSessionTimeout {\n\t\tt.Errorf(\"SessionTimeout should match default\")\n\t}\n}\n\nfunc TestCodeInterpreterSpecDefaults(t *testing.T) {\n\tspec := CodeInterpreterSpec{\n\t\tAuthMode:           DefaultAuthMode,\n\t\tMaxSessionDuration: DefaultMaxSessionDuration,\n\t\tSessionTimeout:     DefaultSessionTimeout,\n\t\tWarmPoolSize:       DefaultWarmPoolSize,\n\t\tTemplate: ContainerTemplateSpec{\n\t\t\tImage: \"python:3.9\",\n\t\t},\n\t}\n\n\tif spec.AuthMode != DefaultAuthMode {\n\t\tt.Errorf(\"AuthMode should match default\")\n\t}\n\tif spec.WarmPoolSize != DefaultWarmPoolSize {\n\t\tt.Errorf(\"WarmPoolSize should match default\")\n\t}\n}\n","additions":229,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/types_test.go","time":{"start":1775841070373,"end":1775841070576}}}}
