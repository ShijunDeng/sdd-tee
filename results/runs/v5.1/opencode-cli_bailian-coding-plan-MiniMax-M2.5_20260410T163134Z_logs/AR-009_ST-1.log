an-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/client/clientset/versioned/typed/runtime/v1alpha1/codeinterpreter.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/client/clientset/versioned/typed/runtime/v1alpha1/agentruntime.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/client/clientset/versioned/clientset.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/client/clientset/versioned/scheme/scheme.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/client/clientset/versioned/typed/runtime/v1alpha1/runtime_client.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/types_test.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/constants.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/zz_generated.deepcopy.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/types.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/doc.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/register.go","metadata":{"count":37,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z","time":{"start":1775847094646,"end":1775847094661}}}}
{"type":"tool_use","timestamp":1775847094672,"sessionID":"ses_28744045fffezd1wEfQExmvKdi","part":{"id":"prt_d78bc344d001FWlz1WdwOQFt6H","messageID":"msg_d78bc2740001xmhaTWIUxBe7wP","sessionID":"ses_28744045fffezd1wEfQExmvKdi","type":"tool","tool":"read","callID":"toolu_db6981f9008b4b33938d0fb3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/proposal.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/proposal.md</path>\n<type>file</type>\n<content>\n1: # Proposal: AR-008 — Sandbox GC 定时清理机制\n2: \n3: ## Summary\n4: \n5: Implement a scheduled garbage collection (GC) mechanism in `pkg/workloadmanager` to automatically clean up stale, expired, or orphaned sandbox resources managed by the AgentRuntime and CodeInterpreter controllers. This ensures resource efficiency and prevents storage/memory leaks from accumulating unused sandboxes.\n6: \n7: ## Purpose\n8: \n9: ### Background\n10: \n11: The AR-007 controller creates and manages sandboxes (Pods, Services, PVCs) based on AgentRuntime and CodeInterpreter CRs. In production environments:\n12: \n13: - **Stale resources accumulate**: Sandboxes that complete execution or exceed time limits remain in the cluster\n14: - **Resource exhaustion**: Orphaned PVCs, ConfigMaps, and Services consume cluster resources\n15: - **Manual cleanup is error-prone**: Operators must track and delete resources manually\n16: - **Compliance requirements**: Data retention policies require automatic cleanup of sensitive workloads\n17: \n18: ### Goal\n19: \n20: Provide an automated GC mechanism that:\n21: - Periodically scans for expired or stale sandboxes based on TTL policies\n22: - Cleans up associated resources (Pods, Services, PVCs, ConfigMaps)\n23: - Updates CR status to reflect GC state\n24: - Supports configurable cleanup policies per namespace or resource type\n25: - Integrates with the existing controller for consistent lifecycle management\n26: \n27: ### Value\n28: - Prevents resource accumulation and cluster bloat\n29: - Automates compliance with data retention policies\n30: - Reduces operational overhead for sandbox management\n31: - Improves cluster stability by reclaiming compute and storage resources\n32: \n33: ---\n34: \n35: ## Scope\n36: \n37: ### In-Scope\n38: \n39: | Deliverable | Description |\n40: |-------------|-------------|\n41: | GC Controller | Background controller for periodic cleanup scanning |\n42: | TTL Policy Engine | Evaluate time-based expiration for sandbox resources |\n43: | Resource Cleanup | Delete associated Pods, Services, PVCs, ConfigMaps |\n44: | Finalizer Integration | Coordinate with AR-007 finalizers for graceful cleanup |\n45: | Configuration | TTL defaults, namespace filters, cleanup interval |\n46: | Metrics | GC execution counts, cleanup latency, resource freed |\n47: | Unit Tests | GC logic coverage >60% |\n48: \n49: ### Code Structure\n50: \n51: ```\n52: pkg/workloadmanager/\n53: ├── server.go                           # HTTP server (existing)\n54: ├── service.go                          # WorkloadManager interface (existing)\n55: ├── types.go                            # API types (existing)\n56: ├── client.go                           # Kubernetes client (existing)\n57: ├── controller/                        # AR-007 (existing)\n58: ├── gc/\n59: │   ├── gc_controller.go               # Main GC loop and coordination\n60: │   ├── gc_policy.go                   # TTL policy evaluation\n61: │   ├── gc_cleaner.go                  # Resource deletion logic\n62: │   ├── gc_metrics.go                  # Prometheus metrics\n63: │   ├── gc_config.go                   # Configuration defaults\n64: │   └── gc_test.go                     # Unit tests\n65: └── events/\n66:     ├── recorder.go                    # Event recording\n67:     └── events.go                      # Event types\n68: ```\n69: \n70: ### Configuration\n71: \n72: The GC mechanism supports these configuration options:\n73: \n74: | Option | Type | Default | Description |\n75: |--------|------|---------|-------------|\n76: | enabled | bool | true | Enable/disable GC |\n77: | interval | duration | 5m | Scan interval |\n78: | defaultTTL | duration | 24h | Default TTL for sandboxes |\n79: | maxRetries | int | 3 | Cleanup retry attempts |\n80: | dryRun | bool | false | Preview cleanup without deletion |\n81: \n82: ### Out-of-Scope\n83: - Real-time cleanup on CR deletion (handled by AR-007 finalizers)\n84: - Multi-cluster GC coordination (future enhancement)\n85: - Custom webhook for GC events (separate module)\n86: - Resource quota enforcement (separate feature)\n87: \n88: ---\n89: \n90: ## Impact Analysis\n91: \n92: ### Dependencies\n93: \n94: | Dependency | Source | Purpose |\n95: |------------|--------|---------|\n96: | github.com/volcano-sh/agentcube/client-go | local | Kubernetes typed client for listing resources |\n97: | github.com/volcano-sh/agentcube/pkg/workloadmanager | local | Existing WorkloadManager |\n98: | github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1 | local | AgentRuntime/CodeInterpreter types |\n99: | k8s.io/client-go/informers | ^0.34 | Cached list/watch for resources |\n100: | k8s.io/client-go/util/workqueue | ^0.34 | Rate-limited cleanup queue |\n101: \n102: ### Upstream Dependencies\n103: \n104: - **AR-007 K8s Reconciler** — GC operates on resources created by the controller\n105: - **AR-005/AR-006 Sandbox Creation** — GC cleans up sandboxes from these APIs\n106: \n107: ### Downstream Consumers\n108: \n109: 1. **Kubernetes Cluster** — Reclaimed resources available for new workloads\n110: 2. **Operators** — Reduced manual cleanup burden\n111: 3. **Monitoring** — GC metrics for operational visibility\n112: 4. **Compliance** — Automated data retention enforcement\n113: \n114: ### Risks\n115: \n116: | Risk | Severity | Mitigation |\n117: |------|----------|------------|\n118: | Data loss | High | Dry-run mode, TTL defaults to 24h, configurable |\n119: | Resource conflicts | Medium | OwnerReference-based cleanup, finalizer coordination |\n120: | GC storms | Medium | Rate-limited queue, batch cleanup limits |\n121: | Clock skew | Low | Use monotonic clock for TTL calculations |\n122: | Incomplete cleanup | Medium | Retry logic with exponential backoff |\n123: \n124: ---\n125: \n126: ## Alternatives Considered\n127: \n128: ### Option 1: TTL Controller with Lease Resources (Selected)\n129: \n130: **Approach**: Use Kubernetes Lease resources to track sandbox creation time, with a controller evaluating TTL and triggering cleanup.\n131: \n132: **Pros**:\n133: - Kubernetes-native pattern for TTL management\n134: - Leader-elected to prevent duplicate cleanup\n135: - Reuses existing informer infrastructure\n136: \n137: **Cons**:\n138: - Additional Lease resource per sandbox\n139: - Requires embedding creation timestamp\n140: \n141: **Decision**: Selected — provides reliable TTL tracking with K8s-native patterns.\n142: \n143: ---\n144: \n145: ### Option 2: TTL Annotations on CR\n146: \n147: **Approach**: Store TTL as an annotation on AgentRuntime/CodeInterpreter CRs, evaluate during reconciliation.\n148: \n149: **Pros**:\n150: - No additional resources\n151: - Simple implementation\n152: \n153: **Cons**:\n154: - Tied to AR-007 reconciliation cycle (may delay cleanup)\n155: - Mixed concerns in reconciliation logic\n156: \n157: **Decision**: Rejected — couples GC to reconciliation, reducing independence and control.\n158: \n159: ---\n160: \n161: ### Option 3: External CronJob\n162: \n163: **Approach**: Deploy a CronJob that runs periodic cleanup scripts.\n164: \n165: **Pros**:\n166: - Simple deployment\n167: - No embedded controller code\n168: \n169: **Cons**:\n170: - No real-time response to resource changes\n171: - Limited visibility into cleanup status\n172: - Separate deployment and management\n173: \n174: **Decision**: Rejected — lacks integration with controller and real-time cleanup.\n175: \n176: ---\n177: \n178: ### Option 4: TTL Controller with Custom Resource\n179: \n180: **Approach**: Create a new `SandboxGC` CRD to define cleanup policies.\n181: \n182: **Pros**:\n183: - Declarative policy management\n184: - Multiple policies per namespace\n185: \n186: **Cons**:\n187: - Additional CRD complexity\n188: - Over-engineered for single-cluster use case\n189: \n190: **Decision**: Rejected — unnecessary API complexity for the current scope.\n191: \n192: ---\n193: \n194: ## Implementation Plan\n195: \n196: ### Phase 1: GC Foundation\n197: - [ ] Add GC package to pkg/workloadmanager/gc/\n198: - [ ] Implement GC config with defaults and CLI flags\n199: - [ ] Create GC controller struct with client dependencies\n200: - [ ] Add informer factories for AgentRuntime/CodeInterpreter\n201: \n202: ### Phase 2: TTL Policy Engine\n203: - [ ] Implement TTL evaluation logic\n204: - [ ] Parse creationTimestamp from CR status\n205: - [ ] Handle edge cases (missing timestamp, future timestamps)\n206: - [ ] Add unit tests for TTL calculations\n207: \n208: ### Phase 3: Resource Cleanup\n209: - [ ] Implement Pod cleanup with graceful period\n210: - [ ] Implement Service cleanup\n211: - [ ] Implement PVC cleanup with reclaim policy\n212: - [ ] Implement ConfigMap cleanup\n213: - [ ] Coordinate with AR-007 finalizers\n214: \n215: ### Phase 4: GC Controller Loop\n216: - [ ] Implement periodic scan with configurable interval\n217: - [ ] Add workqueue for rate-limited cleanup\n218: - [ ] Implement retry logic with exponential backoff\n219: - [ ] Add leader election for HA\n220: \n221: ### Phase 5: Observability\n222: - [ ] Add Prometheus metrics for GC operations\n223: - [ ] Record events for cleanup actions\n224: - [ ] Add logging for debugging\n225: \n226: ### Phase 6: Testing\n227: - [ ] Unit tests for TTL policy evaluation\n228: - [ ] Mock tests for cleanup operations\n229: - [ ] Integration tests with mock API server\n230: - [ ] Dry-run mode validation\n231: \n232: ---\n233: \n234: ## Acceptance Criteria\n235: \n236: - [ ] GC controller starts with configurable interval\n237: - [ ] Expired sandboxes are detected and cleaned up\n238: - [ ] All associated resources (Pod, Service, PVC, ConfigMap) are removed\n239: - [ ] GC respects namespace boundaries\n240: - [ ] Dry-run mode shows pending cleanups without deletion\n241: - [ ] Failed cleanups are retried with exponential backoff\n242: - [ ] Metrics accurately reflect GC operations\n243: - [ ] Events are recorded for cleanup actions\n244: - [ ] Unit tests pass with >60% coverage\n245: - [ ] GC integrates with AR-007 controller for consistent lifecycle\n\n(End of file - total 245 lines)\n</content>","metadata":{"preview":"# Proposal: AR-008 — Sandbox GC 定时清理机制\n\n## Summary\n\nImplement a scheduled garbage collection (GC) mechanism in `pkg/workloadmanager` to automatically clean up stale, expired, or orphaned sandbox resources managed by the AgentRuntime and CodeInterpreter controllers. This ensures resource efficiency and prevents storage/memory leaks from accumulating unused sandboxes.\n\n## Purpose\n\n### Background\n\nThe AR-007 controller creates and manages sandboxes (Pods, Services, PVCs) based on AgentRuntime and CodeInterpreter CRs. In production environments:\n\n- **Stale resources accumulate**: Sandboxes that complete execution or exceed time limits remain in the cluster\n- **Resource exhaustion**: Orphaned PVCs, ConfigMaps, and Services consume cluster resources\n- **Manual cleanup is error-prone**: Operators must track and delete resources manually\n- **Compliance requirements**: Data retention policies require automatic cleanup of sensitive workloads\n\n### Goal\n\nProvide an automated GC mechanism that:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/proposal.md","time":{"start":1775847094643,"end":1775847094670}}}}
