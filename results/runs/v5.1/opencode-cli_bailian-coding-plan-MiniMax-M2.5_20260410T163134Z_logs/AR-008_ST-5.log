ace, name string, ci *agentcubev1alpha1.CodeInterpreter) ([]string, error) {\n \tcleaned := make([]string, 0)\n \n-\tsandbox := &Sandbox{\n-\t\tName:      ci.Name,\n-\t\tNamespace: ci.Namespace,\n-\t\tSessionID: ci.Labels[\"sessionId\"],\n-\t}\n-\n \townerRef := metav1.OwnerReference{\n \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n \t\tKind:       \"CodeInterpreter\",\n \t\tName:       ci.Name,\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc.go","before":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n)\n\nconst (\n\tDefaultGCInterval  = 5 * time.Minute\n\tDefaultGCBatchSize = 50\n\tDefaultGracePeriod = 30 * time.Second\n\tStaleGracePeriod   = 0 * time.Second\n)\n\ntype GCConfig struct {\n\tGCEnabled   bool          `json:\"gcEnabled\"`\n\tGCInterval  time.Duration `json:\"gcInterval\"`\n\tGCBatchSize int           `json:\"gcBatchSize\"`\n}\n\nfunc DefaultGCConfig() *GCConfig {\n\treturn &GCConfig{\n\t\tGCEnabled:   true,\n\t\tGCInterval:  DefaultGCInterval,\n\t\tGCBatchSize: DefaultGCBatchSize,\n\t}\n}\n\ntype GCResult struct {\n\tScannedCount     int           `json:\"scannedCount\"`\n\tExpiredCount     int           `json:\"expiredCount\"`\n\tDeletedCount     int           `json:\"deletedCount\"`\n\tFailedCount      int           `json:\"failedCount\"`\n\tDuration         time.Duration `json:\"duration\"`\n\tErrors           []string      `json:\"errors,omitempty\"`\n\tCleanedResources []string      `json:\"cleanedResources,omitempty\"`\n}\n\ntype GCStats struct {\n\tTotalCycles  int64     `json:\"totalCycles\"`\n\tTotalDeleted int64     `json:\"totalDeleted\"`\n\tTotalFailed  int64     `json:\"totalFailed\"`\n\tLastRunTime  time.Time `json:\"lastRunTime\"`\n\tLastResult   *GCResult `json:\"lastResult,omitempty\"`\n}\n\ntype GCWorker struct {\n\tclient            versioned.Interface\n\tk8sClient         *kubernetes.Clientset\n\tconfig            *GCConfig\n\tstopCh            chan struct{}\n\tcleanupMgr        *CleanupManager\n\texpirationChecker *ExpirationChecker\n\tstats             GCStats\n\tstatsMu           sync.RWMutex\n\tisRunning         bool\n\trunningMu         sync.RWMutex\n}\n\nfunc NewGCWorker(client versioned.Interface, k8sClient *kubernetes.Clientset, config *GCConfig) *GCWorker {\n\tif config == nil {\n\t\tconfig = DefaultGCConfig()\n\t}\n\n\treturn &GCWorker{\n\t\tclient:            client,\n\t\tk8sClient:         k8sClient,\n\t\tconfig:            config,\n\t\tstopCh:            make(chan struct{}),\n\t\tcleanupMgr:        NewCleanupManager(k8sClient),\n\t\texpirationChecker: NewExpirationChecker(nil),\n\t}\n}\n\nfunc (g *GCWorker) Start(ctx context.Context) {\n\tif !g.config.GCEnabled {\n\t\tklog.InfoS(\"GC worker is disabled by configuration\")\n\t\treturn\n\t}\n\n\tg.setRunning(true)\n\tklog.InfoS(\"Starting GC worker\", \"interval\", g.config.GCInterval)\n\n\tticker := time.NewTicker(g.config.GCInterval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\tklog.InfoS(\"GC worker stopping due to context cancellation\")\n\t\t\tg.setRunning(false)\n\t\t\treturn\n\t\tcase <-g.stopCh:\n\t\t\tklog.InfoS(\"GC worker stopping\")\n\t\t\tg.setRunning(false)\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tg.runGCCycle(ctx)\n\t\t}\n\t}\n}\n\nfunc (g *GCWorker) Stop() {\n\tclose(g.stopCh)\n\tg.setRunning(false)\n}\n\nfunc (g *GCWorker) IsRunning() bool {\n\tg.runningMu.RLock()\n\tdefer g.runningMu.RUnlock()\n\treturn g.isRunning\n}\n\nfunc (g *GCWorker) setRunning(running bool) {\n\tg.runningMu.Lock()\n\tdefer g.runningMu.Unlock()\n\tg.isRunning = running\n}\n\nfunc (g *GCWorker) GetConfig() *GCConfig {\n\treturn g.config\n}\n\nfunc (g *GCWorker) GetStats() GCStats {\n\tg.statsMu.RLock()\n\tdefer g.statsMu.RUnlock()\n\treturn g.stats\n}\n\nfunc (g *GCWorker) runGCCycle(ctx context.Context) {\n\tstartTime := time.Now()\n\tresult := &GCResult{}\n\n\tklog.V(4).InfoS(\"Starting GC cycle\")\n\n\tnamespaces, err := g.getNamespaces(ctx)\n\tif err != nil {\n\t\tklog.ErrorS(err, \"Failed to get namespaces\")\n\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"failed to get namespaces: %v\", err))\n\t\tg.recordGCResult(result, startTime)\n\t\treturn\n\t}\n\n\tresult.ScannedCount = len(namespaces)\n\n\tfor _, ns := range namespaces {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\tklog.InfoS(\"GC cycle cancelled\")\n\t\t\tbreak\n\t\tcase <-g.stopCh:\n\t\t\tklog.InfoS(\"GC cycle stopped\")\n\t\t\tbreak\n\t\tdefault:\n\t\t}\n\n\t\tif err := g.processNamespace(ctx, ns, result); err != nil {\n\t\t\tklog.ErrorS(err, \"Failed to process namespace\", \"namespace\", ns)\n\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"%s: %v\", ns, err))\n\t\t}\n\n\t\tif result.ScannedCount >= g.config.GCBatchSize {\n\t\t\tklog.V(4).InfoS(\"Batch size reached\", \"scanned\", result.ScannedCount)\n\t\t\tbreak\n\t\t}\n\t}\n\n\tresult.Duration = time.Since(startTime)\n\tg.recordGCResult(result, startTime)\n\n\tklog.InfoS(\"GC cycle completed\",\n\t\t\"scanned\", result.ScannedCount,\n\t\t\"expired\", result.ExpiredCount,\n\t\t\"deleted\", result.DeletedCount,\n\t\t\"failed\", result.FailedCount,\n\t\t\"duration\", result.Duration)\n}\n\nfunc (g *GCWorker) getNamespaces(ctx context.Context) ([]string, error) {\n\tnsList, err := g.k8sClient.CoreV1().Namespaces().List(ctx, metav1.ListOptions{})\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to list namespaces: %w\", err)\n\t}\n\n\tnamespaces := make([]string, 0, len(nsList.Items))\n\tfor _, ns := range nsList.Items {\n\t\tnamespaces = append(namespaces, ns.Name)\n\t}\n\n\treturn namespaces, nil\n}\n\nfunc (g *GCWorker) processNamespace(ctx context.Context, namespace string, result *GCResult) error {\n\tarList, err := g.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list agentruntimes: %w\", err)\n\t}\n\n\tciList, err := g.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list codeinterpreters: %w\", err)\n\t}\n\n\tfor i := range arList.Items {\n\t\tar := &arList.Items[i]\n\t\tresult.ScannedCount++\n\n\t\tif g.isAgentRuntimeExpired(ar) {\n\t\t\tresult.ExpiredCount++\n\t\t\tcleaned, err := g.deleteAgentRuntime(ctx, namespace, ar.Name, ar)\n\t\t\tresult.CleanedResources = append(result.CleanedResources, cleaned...)\n\t\t\tif err != nil {\n\t\t\t\tresult.FailedCount++\n\t\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"agentruntime/%s: %v\", ar.Name, err))\n\t\t\t\tklog.ErrorS(err, \"Failed to delete expired agentruntime\", \"name\", ar.Name)\n\t\t\t} else {\n\t\t\t\tresult.DeletedCount++\n\t\t\t}\n\t\t}\n\n\t\tif result.ScannedCount >= g.config.GCBatchSize {\n\t\t\tbreak\n\t\t}\n\t}\n\n\tfor i := range ciList.Items {\n\t\tci := &ciList.Items[i]\n\t\tresult.ScannedCount++\n\n\t\tif g.isCodeInterpreterExpired(ci) {\n\t\t\tresult.ExpiredCount++\n\t\t\tcleaned, err := g.deleteCodeInterpreter(ctx, namespace, ci.Name, ci)\n\t\t\tresult.CleanedResources = append(result.CleanedResources, cleaned...)\n\t\t\tif err != nil {\n\t\t\t\tresult.FailedCount++\n\t\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"codeinterpreter/%s: %v\", ci.Name, err))\n\t\t\t\tklog.ErrorS(err, \"Failed to delete expired codeinterpreter\", \"name\", ci.Name)\n\t\t\t} else {\n\t\t\t\tresult.DeletedCount++\n\t\t\t}\n\t\t}\n\n\t\tif result.ScannedCount >= g.config.GCBatchSize {\n\t\t\tbreak\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (g *GCWorker) isAgentRuntimeExpired(ar *agentcubev1alpha1.AgentRuntime) bool {\n\tif ar.DeletionTimestamp != nil {\n\t\treturn true\n\t}\n\n\tsandbox := &Sandbox{\n\t\tName:           ar.Name,\n\t\tNamespace:      ar.Namespace,\n\t\tSessionID:      ar.Labels[\"sessionId\"],\n\t\tState:          g.getAgentRuntimeState(ar),\n\t\tCreatedAt:      ar.CreationTimestamp.Time,\n\t\tLastActivityAt: g.getLastActivityTime(ar),\n\t\tLabels:         ar.Labels,\n\t\tAnnotations:    ar.Annotations,\n\t}\n\n\treturn isExpired(sandbox)\n}\n\nfunc (g *GCWorker) isCodeInterpreterExpired(ci *agentcubev1alpha1.CodeInterpreter) bool {\n\tif ci.DeletionTimestamp != nil {\n\t\treturn true\n\t}\n\n\tsandbox := &Sandbox{\n\t\tName:           ci.Name,\n\t\tNamespace:      ci.Namespace,\n\t\tSessionID:      ci.Labels[\"sessionId\"],\n\t\tState:          g.getCodeInterpreterState(ci),\n\t\tCreatedAt:      ci.CreationTimestamp.Time,\n\t\tLastActivityAt: g.getLastActivityTime(ci),\n\t\tLabels:         ci.Labels,\n\t\tAnnotations:    ci.Annotations,\n\t}\n\n\treturn isExpired(sandbox)\n}\n\nfunc (g *GCWorker) getAgentRuntimeState(ar *agentcubev1alpha1.AgentRuntime) SandboxState {\n\tstate := SandboxStateUnknown\n\tif len(ar.Status.Conditions) > 0 {\n\t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n\t\tif lastCondition.Status == \"True\" {\n\t\t\tif lastCondition.Reason == \"Running\" {\n\t\t\t\tstate = SandboxStateRunning\n\t\t\t} else if lastCondition.Reason == \"Failed\" {\n\t\t\t\tstate = SandboxStateFailed\n\t\t\t}\n\t\t}\n\t}\n\tif ar.DeletionTimestamp != nil {\n\t\tstate = SandboxStateDeleting\n\t}\n\treturn state\n}\n\nfunc (g *GCWorker) getCodeInterpreterState(ci *agentcubev1alpha1.CodeInterpreter) SandboxState {\n\tstate := SandboxStateUnknown\n\tif ci.Status.Ready {\n\t\tstate = SandboxStateRunning\n\t}\n\tif len(ci.Status.Conditions) > 0 {\n\t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n\t\tif lastCondition.Status == \"True\" {\n\t\t\tif lastCondition.Reason == \"Failed\" {\n\t\t\t\tstate = SandboxStateFailed\n\t\t\t}\n\t\t}\n\t}\n\tif ci.DeletionTimestamp != nil {\n\t\tstate = SandboxStateDeleting\n\t}\n\treturn state\n}\n\nfunc (g *GCWorker) getLastActivityTime(obj metav1.Object) *time.Time {\n\tannotations := obj.GetAnnotations()\n\tif annotations == nil {\n\t\treturn nil\n\t}\n\n\tlastActivityStr := annotations[\"last-activity-time\"]\n\tif lastActivityStr == \"\" {\n\t\treturn nil\n\t}\n\n\tt, err := time.Parse(time.RFC3339, lastActivityStr)\n\tif err != nil {\n\t\treturn nil\n\t}\n\n\treturn &t\n}\n\nfunc (g *GCWorker) deleteAgentRuntime(ctx context.Context, namespace, name string, ar *agentcubev1alpha1.AgentRuntime) ([]string, error) {\n\tcleaned := make([]string, 0)\n\n\townerRef := metav1.OwnerReference{\n\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\tKind:       \"AgentRuntime\",\n\t\tName:       ar.Name,\n\t\tUID:        ar.UID,\n\t}\n\n\tsvcCleaned, err := g.cleanupMgr.cleanupServices(namespace, ownerRef)\n\tif err != nil {\n\t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n\t}\n\tcleaned = append(cleaned, svcCleaned...)\n\n\tcmCleaned, err := g.cleanupMgr.cleanupConfigMaps(namespace, ownerRef)\n\tif err != nil {\n\t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n\t}\n\tcleaned = append(cleaned, cmCleaned...)\n\n\tpvcCleaned, err := g.cleanupMgr.cleanupPVCs(namespace, ownerRef)\n\tif err != nil {\n\t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n\t}\n\tcleaned = append(cleaned, pvcCleaned...)\n\n\tdeleteOpts := metav1.DeleteOptions{}\n\tstate := g.getAgentRuntimeState(ar)\n\tif state == SandboxStateUnknown || state == SandboxStateFailed {\n\t\tgracePeriodSeconds := int64(StaleGracePeriod.Seconds())\n\t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n\t\tklog.InfoS(\"Force deleting stale sandbox\", \"name\", name, \"namespace\", namespace)\n\t} else {\n\t\tgracePeriodSeconds := int64(DefaultGracePeriod.Seconds())\n\t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n\t}\n\n\terr = g.client.RuntimeV1alpha1().AgentRuntimes(namespace).Delete(ctx, name, deleteOpts)\n\tif err != nil {\n\t\tif apierrors.IsNotFound(err) {\n\t\t\tklog.V(4).InfoS(\"AgentRuntime already deleted\", \"name\", name, \"namespace\", namespace)\n\t\t\treturn cleaned, nil\n\t\t}\n\t\treturn cleaned, fmt.Errorf(\"failed to delete agentruntime: %w\", err)\n\t}\n\n\tklog.InfoS(\"Deleted expired agentruntime\", \"name\", name, \"namespace\", namespace,\n\t\t\"cleanedResources\", len(cleaned))\n\n\treturn cleaned, nil\n}\n\nfunc (g *GCWorker) deleteCodeInterpreter(ctx context.Context, namespace, name string, ci *agentcubev1alpha1.CodeInterpreter) ([]string, error) {\n\tcleaned := make([]string, 0)\n\n\tsandbox := &Sandbox{\n\t\tName:      ci.Name,\n\t\tNamespace: ci.Namespace,\n\t\tSessionID: ci.Labels[\"sessionId\"],\n\t}\n\n\townerRef := metav1.OwnerReference{\n\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\tKind:       \"CodeInterpreter\",\n\t\tName:       ci.Name,\n\t\tUID:        ci.UID,\n\t}\n\n\tsvcCleaned, err := g.cleanupMgr.cleanupServices(namespace, ownerRef)\n\tif err != nil {\n\t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n\t}\n\tcleaned = append(cleaned, svcCleaned...)\n\n\tcmCleaned, err := g.cleanupMgr.cleanupConfigMaps(namespace, ownerRef)\n\tif err != nil {\n\t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n\t}\n\tcleaned = append(cleaned, cmCleaned...)\n\n\tpvcCleaned, err := g.cleanupMgr.cleanupPVCs(namespace, ownerRef)\n\tif err != nil {\n\t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n\t}\n\tcleaned = append(cleaned, pvcCleaned...)\n\n\tdeleteOpts := metav1.DeleteOptions{}\n\tstate := g.getCodeInterpreterState(ci)\n\tif state == SandboxStateUnknown || state == SandboxStateFailed {\n\t\tgracePeriodSeconds := int64(StaleGracePeriod.Seconds())\n\t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n\t\tklog.InfoS(\"Force deleting stale sandbox\", \"name\", name, \"namespace\", namespace)\n\t} else {\n\t\tgracePeriodSeconds := int64(DefaultGracePeriod.Seconds())\n\t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n\t}\n\n\terr = g.client.RuntimeV1alpha1().CodeInterpreters(namespace).Delete(ctx, name, deleteOpts)\n\tif err != nil {\n\t\tif apierrors.IsNotFound(err) {\n\t\t\tklog.V(4).InfoS(\"CodeInterpreter already deleted\", \"name\", name, \"namespace\", namespace)\n\t\t\treturn cleaned, nil\n\t\t}\n\t\treturn cleaned, fmt.Errorf(\"failed to delete codeinterpreter: %w\", err)\n\t}\n\n\tklog.InfoS(\"Deleted expired codeinterpreter\", \"name\", name, \"namespace\", namespace,\n\t\t\"cleanedResources\", len(cleaned))\n\n\treturn cleaned, nil\n}\n\nfunc (g *GCWorker) recordGCResult(result *GCResult, startTime time.Time) {\n\tg.statsMu.Lock()\n\tdefer g.statsMu.Unlock()\n\n\tg.stats.TotalCycles++\n\tg.stats.TotalDeleted += int64(result.DeletedCount)\n\tg.stats.TotalFailed += int64(result.FailedCount)\n\tg.stats.LastRunTime = startTime\n\tg.stats.LastResult = result\n}\n\nfunc (g *GCWorker) TriggerGCCycle(ctx context.Context) *GCResult {\n\tresult := &GCResult{}\n\n\tklog.InfoS(\"Manually triggering GC cycle\")\n\n\tnamespaces, err := g.getNamespaces(ctx)\n\tif err != nil {\n\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"failed to get namespaces: %v\", err))\n\t\treturn result\n\t}\n\n\tresult.ScannedCount = len(namespaces)\n\tstartTime := time.Now()\n\n\tfor _, ns := range namespaces {\n\t\tif err := g.processNamespace(ctx, ns, result); err != nil {\n\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"%s: %v\", ns, err))\n\t\t}\n\t}\n\n\tresult.Duration = time.Since(startTime)\n\tg.recordGCResult(result, startTime)\n\n\tklog.InfoS(\"Manual GC cycle completed\",\n\t\t\"scanned\", result.ScannedCount,\n\t\t\"expired\", result.ExpiredCount,\n\t\t\"deleted\", result.DeletedCount,\n\t\t\"failed\", result.FailedCount)\n\n\treturn result\n}\n\nfunc (g *GCWorker) UpdateConfig(config *GCConfig) {\n\tif config == nil {\n\t\treturn\n\t}\n\n\tg.config.GCEnabled = config.GCEnabled\n\tif config.GCInterval > 0 {\n\t\tg.config.GCInterval = config.GCInterval\n\t}\n\tif config.GCBatchSize > 0 {\n\t\tg.config.GCBatchSize = config.GCBatchSize\n\t}\n\n\tklog.InfoS(\"GC config updated\", \"gcEnabled\", g.config.GCEnabled,\n\t\t\"gcInterval\", g.config.GCInterval, \"gcBatchSize\", g.config.GCBatchSize)\n}\n\ntype GCHandler struct {\n\tworker *GCWorker\n}\n\nfunc NewGCHandler(worker *GCWorker) *GCHandler {\n\treturn &GCHandler{\n\t\tworker: worker,\n\t}\n}\n\nfunc (h *GCHandler) TriggerGC() map[string]interface{} {\n\tresult := h.worker.TriggerGCCycle(context.Background())\n\treturn map[string]interface{}{\n\t\t\"started\":      true,\n\t\t\"scannedCount\": result.ScannedCount,\n\t\t\"expiredCount\": result.ExpiredCount,\n\t\t\"deletedCount\": result.DeletedCount,\n\t\t\"failedCount\":  result.FailedCount,\n\t\t\"duration\":     result.Duration.String(),\n\t\t\"message\":      \"GC cycle triggered\",\n\t}\n}\n\nfunc (h *GCHandler) GetStatus() map[string]interface{} {\n\tstats := h.worker.GetStats()\n\tconfig := h.worker.GetConfig()\n\n\treturn map[string]interface{}{\n\t\t\"running\":      h.worker.IsRunning(),\n\t\t\"gcEnabled\":    config.GCEnabled,\n\t\t\"gcInterval\":   config.GCInterval.String(),\n\t\t\"gcBatchSize\":  config.GCBatchSize,\n\t\t\"totalCycles\":  stats.TotalCycles,\n\t\t\"totalDeleted\": stats.TotalDeleted,\n\t\t\"totalFailed\":  stats.TotalFailed,\n\t\t\"lastRunTime\":  stats.LastRunTime.Format(time.RFC3339),\n\t}\n}\n\nfunc (h *GCHandler) UpdateConfig(config *GCConfig) map[string]interface{} {\n\th.worker.UpdateConfig(config)\n\treturn map[string]interface{}{\n\t\t\"message\": \"GC configuration updated\",\n\t}\n}\n\nfunc ListExpiredSandboxes(ctx context.Context, client versioned.Interface, namespace string) ([]*Sandbox, error) {\n\texpired := make([]*Sandbox, 0)\n\n\tarList, err := client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{\n\t\tLabelSelector: labels.Everything().String(),\n\t})\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to list agentruntimes: %w\", err)\n\t}\n\n\tfor i := range arList.Items {\n\t\tar := &arList.Items[i]\n\t\tsandbox := &Sandbox{\n\t\t\tName:           ar.Name,\n\t\t\tNamespace:      ar.Namespace,\n\t\t\tSessionID:      ar.Labels[\"sessionId\"],\n\t\t\tState:          getAgentRuntimeState(ar),\n\t\t\tCreatedAt:      ar.CreationTimestamp.Time,\n\t\t\tLastActivityAt: getLastActivityTimeFromAnnotations(ar.Annotations),\n\t\t\tLabels:         ar.Labels,\n\t\t\tAnnotations:    ar.Annotations,\n\t\t}\n\t\tif isExpired(sandbox) {\n\t\t\texpired = append(expired, sandbox)\n\t\t}\n\t}\n\n\tciList, err := client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{\n\t\tLabelSelector: labels.Everything().String(),\n\t})\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to list codeinterpreters: %w\", err)\n\t}\n\n\tfor i := range ciList.Items {\n\t\tci := &ciList.Items[i]\n\t\tsandbox := &Sandbox{\n\t\t\tName:           ci.Name,\n\t\t\tNamespace:      ci.Namespace,\n\t\t\tSessionID:      ci.Labels[\"sessionId\"],\n\t\t\tState:          getCodeInterpreterState(ci),\n\t\t\tCreatedAt:      ci.CreationTimestamp.Time,\n\t\t\tLastActivityAt: getLastActivityTimeFromAnnotations(ci.Annotations),\n\t\t\tLabels:         ci.Labels,\n\t\t\tAnnotations:    ci.Annotations,\n\t\t}\n\t\tif isExpired(sandbox) {\n\t\t\texpired = append(expired, sandbox)\n\t\t}\n\t}\n\n\treturn expired, nil\n}\n\nfunc getAgentRuntimeState(ar *agentcubev1alpha1.AgentRuntime) SandboxState {\n\tstate := SandboxStateUnknown\n\tif len(ar.Status.Conditions) > 0 {\n\t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n\t\tif lastCondition.Status == \"True\" {\n\t\t\tif lastCondition.Reason == \"Running\" {\n\t\t\t\tstate = SandboxStateRunning\n\t\t\t} else if lastCondition.Reason == \"Failed\" {\n\t\t\t\tstate = SandboxStateFailed\n\t\t\t}\n\t\t}\n\t}\n\tif ar.DeletionTimestamp != nil {\n\t\tstate = SandboxStateDeleting\n\t}\n\treturn state\n}\n\nfunc getCodeInterpreterState(ci *agentcubev1alpha1.CodeInterpreter) SandboxState {\n\tstate := SandboxStateUnknown\n\tif ci.Status.Ready {\n\t\tstate = SandboxStateRunning\n\t}\n\tif len(ci.Status.Conditions) > 0 {\n\t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n\t\tif lastCondition.Status == \"True\" {\n\t\t\tif lastCondition.Reason == \"Failed\" {\n\t\t\t\tstate = SandboxStateFailed\n\t\t\t}\n\t\t}\n\t}\n\tif ci.DeletionTimestamp != nil {\n\t\tstate = SandboxStateDeleting\n\t}\n\treturn state\n}\n\nfunc getLastActivityTimeFromAnnotations(annotations map[string]string) *time.Time {\n\tif annotations == nil {\n\t\treturn nil\n\t}\n\n\tlastActivityStr := annotations[\"last-activity-time\"]\n\tif lastActivityStr == \"\" {\n\t\treturn nil\n\t}\n\n\tt, err := time.Parse(time.RFC3339, lastActivityStr)\n\tif err != nil {\n\t\treturn nil\n\t}\n\n\treturn &t\n}\n","after":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n)\n\nconst (\n\tDefaultGCInterval  = 5 * time.Minute\n\tDefaultGCBatchSize = 50\n\tDefaultGracePeriod = 30 * time.Second\n\tStaleGracePeriod   = 0 * time.Second\n)\n\ntype GCConfig struct {\n\tGCEnabled   bool          `json:\"gcEnabled\"`\n\tGCInterval  time.Duration `json:\"gcInterval\"`\n\tGCBatchSize int           `json:\"gcBatchSize\"`\n}\n\nfunc DefaultGCConfig() *GCConfig {\n\treturn &GCConfig{\n\t\tGCEnabled:   true,\n\t\tGCInterval:  DefaultGCInterval,\n\t\tGCBatchSize: DefaultGCBatchSize,\n\t}\n}\n\ntype GCResult struct {\n\tScannedCount     int           `json:\"scannedCount\"`\n\tExpiredCount     int           `json:\"expiredCount\"`\n\tDeletedCount     int           `json:\"deletedCount\"`\n\tFailedCount      int           `json:\"failedCount\"`\n\tDuration         time.Duration `json:\"duration\"`\n\tErrors           []string      `json:\"errors,omitempty\"`\n\tCleanedResources []string      `json:\"cleanedResources,omitempty\"`\n}\n\ntype GCStats struct {\n\tTotalCycles  int64     `json:\"totalCycles\"`\n\tTotalDeleted int64     `json:\"totalDeleted\"`\n\tTotalFailed  int64     `json:\"totalFailed\"`\n\tLastRunTime  time.Time `json:\"lastRunTime\"`\n\tLastResult   *GCResult `json:\"lastResult,omitempty\"`\n}\n\ntype GCWorker struct {\n\tclient            versioned.Interface\n\tk8sClient         *kubernetes.Clientset\n\tconfig            *GCConfig\n\tstopCh            chan struct{}\n\tcleanupMgr        *CleanupManager\n\texpirationChecker *ExpirationChecker\n\tstats             GCStats\n\tstatsMu           sync.RWMutex\n\tisRunning         bool\n\trunningMu         sync.RWMutex\n}\n\nfunc NewGCWorker(client versioned.Interface, k8sClient *kubernetes.Clientset, config *GCConfig) *GCWorker {\n\tif config == nil {\n\t\tconfig = DefaultGCConfig()\n\t}\n\n\treturn &GCWorker{\n\t\tclient:            client,\n\t\tk8sClient:         k8sClient,\n\t\tconfig:            config,\n\t\tstopCh:            make(chan struct{}),\n\t\tcleanupMgr:        NewCleanupManager(k8sClient),\n\t\texpirationChecker: NewExpirationChecker(nil),\n\t}\n}\n\nfunc (g *GCWorker) Start(ctx context.Context) {\n\tif !g.config.GCEnabled {\n\t\tklog.InfoS(\"GC worker is disabled by configuration\")\n\t\treturn\n\t}\n\n\tg.setRunning(true)\n\tklog.InfoS(\"Starting GC worker\", \"interval\", g.config.GCInterval)\n\n\tticker := time.NewTicker(g.config.GCInterval)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\tklog.InfoS(\"GC worker stopping due to context cancellation\")\n\t\t\tg.setRunning(false)\n\t\t\treturn\n\t\tcase <-g.stopCh:\n\t\t\tklog.InfoS(\"GC worker stopping\")\n\t\t\tg.setRunning(false)\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tg.runGCCycle(ctx)\n\t\t}\n\t}\n}\n\nfunc (g *GCWorker) Stop() {\n\tclose(g.stopCh)\n\tg.setRunning(false)\n}\n\nfunc (g *GCWorker) IsRunning() bool {\n\tg.runningMu.RLock()\n\tdefer g.runningMu.RUnlock()\n\treturn g.isRunning\n}\n\nfunc (g *GCWorker) setRunning(running bool) {\n\tg.runningMu.Lock()\n\tdefer g.runningMu.Unlock()\n\tg.isRunning = running\n}\n\nfunc (g *GCWorker) GetConfig() *GCConfig {\n\treturn g.config\n}\n\nfunc (g *GCWorker) GetStats() GCStats {\n\tg.statsMu.RLock()\n\tdefer g.statsMu.RUnlock()\n\treturn g.stats\n}\n\nfunc (g *GCWorker) runGCCycle(ctx context.Context) {\n\tstartTime := time.Now()\n\tresult := &GCResult{}\n\n\tklog.V(4).InfoS(\"Starting GC cycle\")\n\n\tnamespaces, err := g.getNamespaces(ctx)\n\tif err != nil {\n\t\tklog.ErrorS(err, \"Failed to get namespaces\")\n\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"failed to get namespaces: %v\", err))\n\t\tg.recordGCResult(result, startTime)\n\t\treturn\n\t}\n\n\tresult.ScannedCount = len(namespaces)\n\n\tfor _, ns := range namespaces {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\tklog.InfoS(\"GC cycle cancelled\")\n\t\t\tbreak\n\t\tcase <-g.stopCh:\n\t\t\tklog.InfoS(\"GC cycle stopped\")\n\t\t\tbreak\n\t\tdefault:\n\t\t}\n\n\t\tif err := g.processNamespace(ctx, ns, result); err != nil {\n\t\t\tklog.ErrorS(err, \"Failed to process namespace\", \"namespace\", ns)\n\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"%s: %v\", ns, err))\n\t\t}\n\n\t\tif result.ScannedCount >= g.config.GCBatchSize {\n\t\t\tklog.V(4).InfoS(\"Batch size reached\", \"scanned\", result.ScannedCount)\n\t\t\tbreak\n\t\t}\n\t}\n\n\tresult.Duration = time.Since(startTime)\n\tg.recordGCResult(result, startTime)\n\n\tklog.InfoS(\"GC cycle completed\",\n\t\t\"scanned\", result.ScannedCount,\n\t\t\"expired\", result.ExpiredCount,\n\t\t\"deleted\", result.DeletedCount,\n\t\t\"failed\", result.FailedCount,\n\t\t\"duration\", result.Duration)\n}\n\nfunc (g *GCWorker) getNamespaces(ctx context.Context) ([]string, error) {\n\tnsList, err := g.k8sClient.CoreV1().Namespaces().List(ctx, metav1.ListOptions{})\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to list namespaces: %w\", err)\n\t}\n\n\tnamespaces := make([]string, 0, len(nsList.Items))\n\tfor _, ns := range nsList.Items {\n\t\tnamespaces = append(namespaces, ns.Name)\n\t}\n\n\treturn namespaces, nil\n}\n\nfunc (g *GCWorker) processNamespace(ctx context.Context, namespace string, result *GCResult) error {\n\tarList, err := g.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list agentruntimes: %w\", err)\n\t}\n\n\tciList, err := g.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list codeinterpreters: %w\", err)\n\t}\n\n\tfor i := range arList.Items {\n\t\tar := &arList.Items[i]\n\t\tresult.ScannedCount++\n\n\t\tif g.isAgentRuntimeExpired(ar) {\n\t\t\tresult.ExpiredCount++\n\t\t\tcleaned, err := g.deleteAgentRuntime(ctx, namespace, ar.Name, ar)\n\t\t\tresult.CleanedResources = append(result.CleanedResources, cleaned...)\n\t\t\tif err != nil {\n\t\t\t\tresult.FailedCount++\n\t\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"agentruntime/%s: %v\", ar.Name, err))\n\t\t\t\tklog.ErrorS(err, \"Failed to delete expired agentruntime\", \"name\", ar.Name)\n\t\t\t} else {\n\t\t\t\tresult.DeletedCount++\n\t\t\t}\n\t\t}\n\n\t\tif result.ScannedCount >= g.config.GCBatchSize {\n\t\t\tbreak\n\t\t}\n\t}\n\n\tfor i := range ciList.Items {\n\t\tci := &ciList.Items[i]\n\t\tresult.ScannedCount++\n\n\t\tif g.isCodeInterpreterExpired(ci) {\n\t\t\tresult.ExpiredCount++\n\t\t\tcleaned, err := g.deleteCodeInterpreter(ctx, namespace, ci.Name, ci)\n\t\t\tresult.CleanedResources = append(result