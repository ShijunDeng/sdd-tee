leteAllSandboxes)\n88: \t\tapi.DELETE(\"/namespaces/:namespace/sandboxes/:sessionId\", server.handleDeleteSandbox)\n89: \t}\n90: \n91: \tserver.httpServer = &http.Server{\n92: \t\tAddr:    fmt.Sprintf(\":%d\", cfg.Port),\n93: \t\tHandler: router,\n94: \t}\n95: \n96: \treturn server\n97: }\n98: \n99: func (s *Server) Start() error {\n100: \tklog.InfoS(\"Starting HTTP server\", \"port\", s.config.Port)\n101: \n102: \tln, err := net.Listen(\"tcp\", fmt.Sprintf(\":%d\", s.config.Port))\n103: \tif err != nil {\n104: \t\treturn fmt.Errorf(\"failed to listen on port %d: %w\", s.config.Port, err)\n105: \t}\n106: \n107: \tgo func() {\n108: \t\tif err := s.httpServer.Serve(ln); err != nil && err != http.ErrServerClosed {\n109: \t\t\tklog.ErrorS(err, \"HTTP server error\")\n110: \t\t}\n111: \t}()\n112: \n113: \ts.SetReady(true)\n114: \tklog.InfoS(\"HTTP server started\", \"port\", s.config.Port)\n115: \treturn nil\n116: }\n117: \n118: func (s *Server) Stop() error {\n119: \tklog.Info(\"Shutting down HTTP server...\")\n120: \ts.SetReady(false)\n121: \n122: \tctx, cancel := context.WithTimeout(context.Background(), s.config.ShutdownTimeout)\n123: \tdefer cancel()\n124: \n125: \tif err := s.httpServer.Shutdown(ctx); err != nil {\n126: \t\treturn fmt.Errorf(\"failed to shutdown HTTP server: %w\", err)\n127: \t}\n128: \n129: \tif s.workloadMgr != nil {\n130: \t\ts.workloadMgr.Close()\n131: \t}\n132: \n133: \tklog.Info(\"HTTP server stopped\")\n134: \treturn nil\n135: }\n136: \n137: func (s *Server) Run() error {\n138: \tif err := s.Start(); err != nil {\n139: \t\treturn err\n140: \t}\n141: \n142: \tsigCh := make(chan os.Signal, 1)\n143: \tsignal.Notify(sigCh, os.Interrupt, os.Kill)\n144: \n145: \t<-sigCh\n146: \tklog.Info(\"Received shutdown signal\")\n147: \n148: \treturn s.Stop()\n149: }\n150: \n151: func (s *Server) SetReady(ready bool) {\n152: \ts.mu.Lock()\n153: \tdefer s.mu.Unlock()\n154: \ts.ready = ready\n155: }\n156: \n157: func (s *Server) IsReady() bool {\n158: \ts.mu.RL