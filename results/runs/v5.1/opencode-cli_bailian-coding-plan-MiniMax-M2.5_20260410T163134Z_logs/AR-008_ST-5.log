.StatusBadRequest, NewAPIError(\"missing deleteAll query parameter\", \"BadRequest\", http.StatusBadRequest))\n747: \t\treturn\n748: \t}\n749: \n750: \tvar opts DeleteOptions\n751: \tif err := c.ShouldBindQuery(&opts); err != nil {\n752: \t\tc.JSON(http.StatusBadRequest, NewAPIError(err.Error(), \"BadRequest\", http.StatusBadRequest))\n753: \t\treturn\n754: \t}\n755: \n756: \tlist, err := s.workloadMgr.ListSandboxes(c.Request.Context(), namespace, ListOptions{\n757: \t\tLabelSelector: opts.LabelSelector,\n758: \t})\n759: \tif err != nil {\n760: \t\ts.handleError(c, err)\n761: \t\treturn\n762: \t}\n763: \n764: \tdeletedCount := 0\n765: \tfor _, sandbox := range list.Items {\n766: \t\terr := s.workloadMgr.DeleteSandbox(c.Request.Context(), namespace, sandbox.SessionID, opts)\n767: \t\tif err == nil {\n768: \t\t\tdeletedCount++\n769: \t\t}\n770: \t}\n771: \n772: \tc.JSON(http.StatusOK, BatchDeleteResponse{\n773: \t\tDeletedCount: deletedCount,\n774: \t\tFailedCount:  len(list.Items) - deletedCount,\n775: \t})\n776: }\n\n(End of file - total 776 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/server.go","time":{"start":1775846442465,"end":1775846442484}}}}
