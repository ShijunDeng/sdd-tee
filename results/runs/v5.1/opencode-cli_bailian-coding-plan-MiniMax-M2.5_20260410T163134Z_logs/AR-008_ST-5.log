ing-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc_test.go\n@@ -243,11 +243,11 @@\n func TestGCWorkerUpdateConfig(t *testing.T) {\n \tworker := NewGCWorker(nil, nil, nil)\n \n \tnewConfig := &GCConfig{\n-\t\tGCEnabled:    false,\n-\t\tGCInterval:   20 * time.Minute,\n-\t\tGCCBatchSize: 150,\n+\t\tGCEnabled:   false,\n+\t\tGCInterval:  20 * time.Minute,\n+\t\tGCBatchSize: 150,\n \t}\n \n \tworker.UpdateConfig(newConfig)\n \n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc_test.go","before":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nfunc TestDefaultGCConfig(t *testing.T) {\n\tconfig := DefaultGCConfig()\n\n\tif config == nil {\n\t\tt.Error(\"Expected non-nil GCConfig\")\n\t}\n\n\tif !config.GCEnabled {\n\t\tt.Error(\"Expected GCEnabled to be true by default\")\n\t}\n\n\tif config.GCInterval != DefaultGCInterval {\n\t\tt.Errorf(\"Expected GCInterval to be %v, got %v\", DefaultGCInterval, config.GCInterval)\n\t}\n\n\tif config.GCBatchSize != DefaultGCBatchSize {\n\t\tt.Errorf(\"Expected GCBatchSize to be %d, got %d\", DefaultGCBatchSize, config.GCBatchSize)\n\t}\n}\n\nfunc TestGCConfigValues(t *testing.T) {\n\ttests := []struct {\n\t\tname        string\n\t\tgcEnabled   bool\n\t\tgcInterval  time.Duration\n\t\tgcBatchSize int\n\t\texpectedErr bool\n\t}{\n\t\t{\n\t\t\tname:        \"default values\",\n\t\t\tgcEnabled:   true,\n\t\t\tgcInterval:  5 * time.Minute,\n\t\t\tgcBatchSize: 50,\n\t\t\texpectedErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"disabled GC\",\n\t\t\tgcEnabled:   false,\n\t\t\tgcInterval:  5 * time.Minute,\n\t\t\tgcBatchSize: 50,\n\t\t\texpectedErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"custom interval\",\n\t\t\tgcEnabled:   true,\n\t\t\tgcInterval:  10 * time.Minute,\n\t\t\tgcBatchSize: 100,\n\t\t\texpectedErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"custom batch size\",\n\t\t\tgcEnabled:   true,\n\t\t\tgcInterval:  5 * time.Minute,\n\t\t\tgcBatchSize: 200,\n\t\t\texpectedErr: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tconfig := &GCConfig{\n\t\t\t\tGCEnabled:   tt.gcEnabled,\n\t\t\t\tGCInterval:  tt.gcInterval,\n\t\t\t\tGCBatchSize: tt.gcBatchSize,\n\t\t\t}\n\n\t\t\tif config.GCEnabled != tt.gcEnabled {\n\t\t\t\tt.Errorf(\"Expected GCEnabled to be %v, got %v\", tt.gcEnabled, config.GCEnabled)\n\t\t\t}\n\n\t\t\tif config.GCInterval != tt.gcInterval {\n\t\t\t\tt.Errorf(\"Expected GCInterval to be %v, got %v\", tt.gcInterval, config.GCInterval)\n\t\t\t}\n\n\t\t\tif config.GCBatchSize != tt.gcBatchSize {\n\t\t\t\tt.Errorf(\"Expected GCBatchSize to be %d, got %d\", tt.gcBatchSize, config.GCBatchSize)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGCWorkerNewGCWorker(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tif worker == nil {\n\t\tt.Error(\"Expected non-nil GCWorker\")\n\t}\n\n\tif worker.config == nil {\n\t\tt.Error(\"Expected non-nil config\")\n\t}\n\n\tif worker.cleanupMgr == nil {\n\t\tt.Error(\"Expected non-nil cleanupMgr\")\n\t}\n\n\tif worker.expirationChecker == nil {\n\t\tt.Error(\"Expected non-nil expirationChecker\")\n\t}\n\n\tif worker.stopCh == nil {\n\t\tt.Error(\"Expected non-nil stopCh\")\n\t}\n}\n\nfunc TestGCWorkerWithCustomConfig(t *testing.T) {\n\tconfig := &GCConfig{\n\t\tGCEnabled:   false,\n\t\tGCInterval:  10 * time.Minute,\n\t\tGCBatchSize: 100,\n\t}\n\n\tworker := NewGCWorker(nil, nil, config)\n\n\tif worker.config.GCEnabled != false {\n\t\tt.Error(\"Expected GCEnabled to be false\")\n\t}\n\n\tif worker.config.GCInterval != 10*time.Minute {\n\t\tt.Errorf(\"Expected GCInterval to be 10m, got %v\", worker.config.GCInterval)\n\t}\n\n\tif worker.config.GCBatchSize != 100 {\n\t\tt.Errorf(\"Expected GCBatchSize to be 100, got %d\", worker.config.GCBatchSize)\n\t}\n}\n\nfunc TestGCWorkerIsRunning(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tif worker.IsRunning() {\n\t\tt.Error(\"Expected GCWorker to not be running initially\")\n\t}\n\n\tworker.setRunning(true)\n\n\tif !worker.IsRunning() {\n\t\tt.Error(\"Expected GCWorker to be running after setRunning(true)\")\n\t}\n\n\tworker.setRunning(false)\n\n\tif worker.IsRunning() {\n\t\tt.Error(\"Expected GCWorker to not be running after setRunning(false)\")\n\t}\n}\n\nfunc TestGCWorkerGetConfig(t *testing.T) {\n\tconfig := &GCConfig{\n\t\tGCEnabled:   true,\n\t\tGCInterval:  15 * time.Minute,\n\t\tGCBatchSize: 75,\n\t}\n\n\tworker := NewGCWorker(nil, nil, config)\n\n\treturnedConfig := worker.GetConfig()\n\n\tif returnedConfig.GCEnabled != config.GCEnabled {\n\t\tt.Errorf(\"Expected GCEnabled to be %v, got %v\", config.GCEnabled, returnedConfig.GCEnabled)\n\t}\n\n\tif returnedConfig.GCInterval != config.GCInterval {\n\t\tt.Errorf(\"Expected GCInterval to be %v, got %v\", config.GCInterval, returnedConfig.GCInterval)\n\t}\n\n\tif returnedConfig.GCBatchSize != config.GCBatchSize {\n\t\tt.Errorf(\"Expected GCBatchSize to be %d, got %d\", config.GCBatchSize, returnedConfig.GCBatchSize)\n\t}\n}\n\nfunc TestGCWorkerGetStats(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tstats := worker.GetStats()\n\n\tif stats.TotalCycles != 0 {\n\t\tt.Errorf(\"Expected TotalCycles to be 0, got %d\", stats.TotalCycles)\n\t}\n\n\tif stats.TotalDeleted != 0 {\n\t\tt.Errorf(\"Expected TotalDeleted to be 0, got %d\", stats.TotalDeleted)\n\t}\n\n\tif stats.TotalFailed != 0 {\n\t\tt.Errorf(\"Expected TotalFailed to be 0, got %d\", stats.TotalFailed)\n\t}\n}\n\nfunc TestGCWorkerRecordGCResult(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tresult := &GCResult{\n\t\tScannedCount: 10,\n\t\tExpiredCount: 5,\n\t\tDeletedCount: 4,\n\t\tFailedCount:  1,\n\t\tDuration:     100 * time.Millisecond,\n\t}\n\n\tstartTime := time.Now()\n\tworker.recordGCResult(result, startTime)\n\n\tstats := worker.GetStats()\n\n\tif stats.TotalCycles != 1 {\n\t\tt.Errorf(\"Expected TotalCycles to be 1, got %d\", stats.TotalCycles)\n\t}\n\n\tif stats.TotalDeleted != 4 {\n\t\tt.Errorf(\"Expected TotalDeleted to be 4, got %d\", stats.TotalDeleted)\n\t}\n\n\tif stats.TotalFailed != 1 {\n\t\tt.Errorf(\"Expected TotalFailed to be 1, got %d\", stats.TotalFailed)\n\t}\n\n\tif stats.LastRunTime.IsZero() {\n\t\tt.Error(\"Expected LastRunTime to be set\")\n\t}\n\n\tif stats.LastResult == nil {\n\t\tt.Error(\"Expected LastResult to be set\")\n\t}\n\n\tif stats.LastResult.DeletedCount != 4 {\n\t\tt.Errorf(\"Expected LastResult.DeletedCount to be 4, got %d\", stats.LastResult.DeletedCount)\n\t}\n}\n\nfunc TestGCWorkerUpdateConfig(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tnewConfig := &GCConfig{\n\t\tGCEnabled:    false,\n\t\tGCInterval:   20 * time.Minute,\n\t\tGCCBatchSize: 150,\n\t}\n\n\tworker.UpdateConfig(newConfig)\n\n\tif worker.config.GCEnabled != false {\n\t\tt.Error(\"Expected GCEnabled to be false after update\")\n\t}\n\n\tif worker.config.GCInterval != 20*time.Minute {\n\t\tt.Errorf(\"Expected GCInterval to be 20m, got %v\", worker.config.GCInterval)\n\t}\n\n\tworker.UpdateConfig(&GCConfig{\n\t\tGCEnabled:   false,\n\t\tGCInterval:  20 * time.Minute,\n\t\tGCBatchSize: 150,\n\t})\n\n\tif worker.config.GCEnabled != false {\n\t\tt.Error(\"Expected GCEnabled to be false after update\")\n\t}\n\n\tworker.UpdateConfig(nil)\n\n\tif worker.config.GCInterval != 20*time.Minute {\n\t\tt.Errorf(\"Expected GCInterval to remain 20m after nil update, got %v\", worker.config.GCInterval)\n\t}\n}\n\nfunc TestGCWorkerTriggerGCCycle(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tctx := context.Background()\n\tresult := worker.TriggerGCCycle(ctx)\n\n\tif result == nil {\n\t\tt.Error(\"Expected non-nil result\")\n\t}\n\n\tif result.ScannedCount != 0 {\n\t\tt.Errorf(\"Expected ScannedCount to be 0 with nil client, got %d\", result.ScannedCount)\n\t}\n}\n\nfunc TestIsAgentRuntimeExpired(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname        string\n\t\tar          *agentcubev1alpha1.AgentRuntime\n\t\texpectedExp bool\n\t}{\n\t\t{\n\t\t\tname: \"not expired - recently created\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: false,\n\t\t},\n\t\t{\n\t\t\tname: \"expired by TTL\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-10 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t\tAnnotations:       map[string]string{\"expires-at\": time.Now().Add(-1 * time.Hour).Format(time.RFC3339)},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"marked for deletion\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"stale state - Unknown with old creation\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-2 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"False\",\n\t\t\t\t\t\t\tReason: \"Unknown\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"stale state - Failed with old creation\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-2 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"False\",\n\t\t\t\t\t\t\tReason: \"Failed\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\texpired := worker.isAgentRuntimeExpired(tt.ar)\n\t\t\tif expired != tt.expectedExp {\n\t\t\t\tt.Errorf(\"Expected expired=%v, got %v\", tt.expectedExp, expired)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestIsCodeInterpreterExpired(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname        string\n\t\tci          *agentcubev1alpha1.CodeInterpreter\n\t\texpectedExp bool\n\t}{\n\t\t{\n\t\t\tname: \"not expired - recently created\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: false,\n\t\t},\n\t\t{\n\t\t\tname: \"expired by TTL\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-10 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t\tAnnotations:       map[string]string{\"expires-at\": time.Now().Add(-1 * time.Hour).Format(time.RFC3339)},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"marked for deletion\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"stale state - Failed with old creation\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-2 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: false,\n\t\t\t\t\tConditions: []agentcubev1alpha1.CodeInterpreterCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"False\",\n\t\t\t\t\t\t\tReason: \"Failed\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\texpired := worker.isCodeInterpreterExpired(tt.ci)\n\t\t\tif expired != tt.expectedExp {\n\t\t\t\tt.Errorf(\"Expected expired=%v, got %v\", tt.expectedExp, expired)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetAgentRuntimeState(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname          string\n\t\tar            *agentcubev1alpha1.AgentRuntime\n\t\texpectedState SandboxState\n\t}{\n\t\t{\n\t\t\tname: \"Unknown state - no conditions\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ar\",\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateUnknown,\n\t\t},\n\t\t{\n\t\t\tname: \"Running state\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ar\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"True\",\n\t\t\t\t\t\t\tReason: \"Running\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateRunning,\n\t\t},\n\t\t{\n\t\t\tname: \"Failed state\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ar\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"True\",\n\t\t\t\t\t\t\tReason: \"Failed\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateFailed,\n\t\t},\n\t\t{\n\t\t\tname: \"Deleting state\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateDeleting,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstate := worker.getAgentRuntimeState(tt.ar)\n\t\t\tif state != tt.expectedState {\n\t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetCodeInterpreterState(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname          string\n\t\tci            *agentcubev1alpha1.CodeInterpreter\n\t\texpectedState SandboxState\n\t}{\n\t\t{\n\t\t\tname: \"Unknown state - not ready\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ci\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: false,\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateUnknown,\n\t\t},\n\t\t{\n\t\t\tname: \"Running state - ready\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ci\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: true,\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateRunning,\n\t\t},\n\t\t{\n\t\t\tname: \"Failed state\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ci\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: false,\n\t\t\t\t\tConditions: []agentcubev1alpha1.CodeInterpreterCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"True\",\n\t\t\t\t\t\t\tReason: \"Failed\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateFailed,\n\t\t},\n\t\t{\n\t\t\tname: \"Deleting state\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateDeleting,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstate := worker.getCodeInterpreterState(tt.ci)\n\t\t\tif state != tt.expectedState {\n\t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetLastActivityTime(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname         string\n\t\tannotations  map[string]string\n\t\texpectedTime *time.Time\n\t}{\n\t\t{\n\t\t\tname:         \"nil annotations\",\n\t\t\tannotations:  nil,\n\t\t\texpectedTime: nil,\n\t\t},\n\t\t{\n\t\t\tname:         \"empty annotations\",\n\t\t\tannotations:  map[string]string{},\n\t\t\texpectedTime: nil,\n\t\t},\n\t\t{\n\t\t\tname:         \"no last-activity-time\",\n\t\t\tannotations:  map[string]string{\"other\": \"value\"},\n\t\t\texpectedTime: nil,\n\t\t},\n\t\t{\n\t\t\tname:         \"valid last-activity-time\",\n\t\t\tannotations:  map[string]string{\"last-activity-time\": \"2024-01-15T10:30:00Z\"},\n\t\t\texpectedTime: nil, // Will be non-nil, just checking parsing works\n\t\t},\n\t\t{\n\t\t\tname:         \"invalid last-activity-time\",\n\t\t\tannotations:  map[string]string{\"last-activity-time\": \"invalid\"},\n\t\t\texpectedTime: nil,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tobj := &metav1.ObjectMeta{\n\t\t\t\tAnnotations: tt.annotations,\n\t\t\t}\n\t\t\tresult := worker.getLastActivityTime(obj)\n\n\t\t\tif tt.expectedTime == nil && result != nil {\n\t\t\t\tt.Error(\"Expected nil result, got non-nil\")\n\t\t\t}\n\n\t\t\tif tt.expectedTime != nil && result == nil {\n\t\t\t\tt.Error(\"Expected non-nil result, got nil\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGCHandler(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\thandler := NewGCHandler(worker)\n\n\tif handler == nil {\n\t\tt.Error(\"Expected non-nil GCHandler\")\n\t}\n\n\tif handler.worker == nil {\n\t\tt.Error(\"Expected non-nil worker in handler\")\n\t}\n}\n\nfunc TestGCHandlerTriggerGC(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\thandler := NewGCHandler(worker)\n\n\tresult := handler.TriggerGC()\n\n\tif result == nil {\n\t\tt.Error(\"Expected non-nil result\")\n\t}\n\n\tif result[\"started\"] != true {\n\t\tt.Error(\"Expected started to be true\")\n\t}\n\n\tif result[\"scannedCount\"] != 0 {\n\t\tt.Errorf(\"Expected scannedCount to be 0, got %v\", result[\"scannedCount\"])\n\t}\n}\n\nfunc TestGCHandlerGetStatus(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\thandler := NewGCHandler(worker)\n\n\tstatus := handler.GetStatus()\n\n\tif status == nil {\n\t\tt.Error(\"Expected non-nil status\")\n\t}\n\n\tif status[\"running\"] != false {\n\t\tt.Error(\"Expected running to be false\")\n\t}\n\n\tif status[\"gcEnabled\"] != true {\n\t\tt.Error(\"Expected gcEnabled to be true\")\n\t}\n\n\tif status[\"gcBatchSize\"] != DefaultGCBatchSize {\n\t\tt.Errorf(\"Expected gcBatchSize to be %d, got %v\", DefaultGCBatchSize, status[\"gcBatchSize\"])\n\t}\n}\n\nfunc TestGCHandlerUpdateConfig(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\thandler := NewGCHandler(worker)\n\n\tnewConfig := &GCConfig{\n\t\tGCEnabled:  false,\n\t\tGCInterval: 30 * time.Minute,\n\t}\n\n\tresult := handler.UpdateConfig(newConfig)\n\n\tif result == nil {\n\t\tt.Error(\"Expected non-nil result\")\n\t}\n\n\tif result[\"message\"] != \"GC configuration updated\" {\n\t\tt.Errorf(\"Expected message 'GC configuration updated', got %v\", result[\"message\"])\n\t}\n\n\tif worker.config.GCEnabled != false {\n\t\tt.Error(\"Expected GCEnabled to be false after update\")\n\t}\n}\n\nfunc TestGCResult(t *testing.T) {\n\tresult := &GCResult{\n\t\tScannedCount:     100,\n\t\tExpiredCount:     50,\n\t\tDeletedCount:     45,\n\t\tFailedCount:      5,\n\t\tDuration:         5 * time.Second,\n\t\tErrors:           []string{\"error1\", \"error2\"},\n\t\tCleanedResources: []string{\"Service/svc1\", \"ConfigMap/cm1\"},\n\t}\n\n\tif result.ScannedCount != 100 {\n\t\tt.Errorf(\"Expected ScannedCount=100, got %d\", result.ScannedCount)\n\t}\n\n\tif result.ExpiredCount != 50 {\n\t\tt.Errorf(\"Expected ExpiredCount=50, got %d\", result.ExpiredCount)\n\t}\n\n\tif result.DeletedCount != 45 {\n\t\tt.Errorf(\"Expected DeletedCount=45, got %d\", result.DeletedCount)\n\t}\n\n\tif result.FailedCount != 5 {\n\t\tt.Errorf(\"Expected FailedCount=5, got %d\", result.FailedCount)\n\t}\n\n\tif len(result.Errors) != 2 {\n\t\tt.Errorf(\"Expected 2 errors, got %d\", len(result.Errors))\n\t}\n\n\tif len(result.CleanedResources) != 2 {\n\t\tt.Errorf(\"Expected 2 cleaned resources, got %d\", len(result.CleanedResources))\n\t}\n}\n\nfunc TestGCStats(t *testing.T) {\n\tstats := GCStats{\n\t\tTotalCycles:  10,\n\t\tTotalDeleted: 100,\n\t\tTotalFailed:  5,\n\t\tLastRunTime:  time.Now(),\n\t\tLastResult: &GCResult{\n\t\t\tDeletedCount: 10,\n\t\t},\n\t}\n\n\tif stats.TotalCycles != 10 {\n\t\tt.Errorf(\"Expected TotalCycles=10, got %d\", stats.TotalCycles)\n\t}\n\n\tif stats.TotalDeleted != 100 {\n\t\tt.Errorf(\"Expected TotalDeleted=100, got %d\", stats.TotalDeleted)\n\t}\n\n\tif stats.TotalFailed != 5 {\n\t\tt.Errorf(\"Expected TotalFailed=5, got %d\", stats.TotalFailed)\n\t}\n\n\tif stats.LastResult == nil {\n\t\tt.Error(\"Expected non-nil LastResult\")\n\t}\n\n\tif stats.LastResult.DeletedCount != 10 {\n\t\tt.Errorf(\"Expected LastResult.DeletedCount=10, got %d\", stats.LastResult.DeletedCount)\n\t}\n}\n\nfunc TestGetAgentRuntimeStateStandalone(t *testing.T) {\n\ttests := []struct {\n\t\tname          string\n\t\tar            *agentcubev1alpha1.AgentRuntime\n\t\texpectedState SandboxState\n\t}{\n\t\t{\n\t\t\tname: \"Unknown with DeletionTimestamp\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test\",\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateDeleting,\n\t\t},\n\t\t{\n\t\t\tname: \"Running\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{Type: \"Ready\", Status: \"True\", Reason: \"Running\"},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateRunning,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstate := getAgentRuntimeState(tt.ar)\n\t\t\tif state != tt.expectedState {\n\t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetCodeInterpreterStateStandalone(t *testing.T) {\n\ttests := []struct {\n\t\tname          string\n\t\tci            *agentcubev1alpha1.CodeInterpreter\n\t\texpectedState SandboxState\n\t}{\n\t\t{\n\t\t\tname: \"Unknown\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: false,\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateUnknown,\n\t\t},\n\t\t{\n\t\t\tname: \"Running\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: true,\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateRunning,\n\t\t},\n\t\t{\n\t\t\tname: \"Deleting\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test\",\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateDeleting,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstate := getCodeInterpreterState(tt.ci)\n\t\t\tif state != tt.expectedState {\n\t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetLastActivityTimeFromAnnotations(t *testing.T) {\n\ttests := []struct {\n\t\tname        string\n\t\tannotations map[string]string\n\t\texpectNil   bool\n\t}{\n\t\t{\n\t\t\tname:        \"nil annotations\",\n\t\t\tannotations: nil,\n\t\t\texpectNil:   true,\n\t\t},\n\t\t{\n\t\t\tname:        \"empty annotations\",\n\t\t\tannotations: map[string]string{},\n\t\t\texpectNil:   true,\n\t\t},\n\t\t{\n\t\t\tname:        \"valid time\",\n\t\t\tannotations: map[string]string{\"last-activity-time\": \"2024-01-15T10:30:00Z\"},\n\t\t\texpectNil:   false,\n\t\t},\n\t\t{\n\t\t\tname:        \"invalid time\",\n\t\t\tannotations: map[string]string{\"last-activity-time\": \"invalid\"},\n\t\t\texpectNil:   true,\n\t\t},\n\t\t{\n\t\t\tname:        \"no key\",\n\t\t\tannotations: map[string]string{\"other\": \"value\"},\n\t\t\texpectNil:   true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tresult := getLastActivityTimeFromAnnotations(tt.annotations)\n\t\t\tif tt.expectNil && result != nil {\n\t\t\t\tt.Error(\"Expected nil result\")\n\t\t\t}\n\t\t\tif !tt.expectNil && result == nil {\n\t\t\t\tt.Error(\"Expected non-nil result\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGCWorkerStartDisabled(t *testing.T) {\n\tconfig := &GCConfig{\n\t\tGCEnabled:  false,\n\t\tGCInterval: 5 * time.Minute,\n\t}\n\n\tworker := NewGCWorker(nil, nil, config)\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tcancel()\n\n\tworker.Start(ctx)\n\n\tif worker.IsRunning() {\n\t\tt.Error(\"Expected GC worker to not be running when disabled\")\n\t}\n}\n\nfunc TestGCWorkerStop(t *testing.T) {\n\tconfig := &GCConfig{\n\t\tGCEnabled:  true,\n\t\tGCInterval: 1 * time.Second,\n\t}\n\n\tworker := NewGCWorker(nil, nil, config)\n\n\tworker.Stop()\n\n\tif worker.IsRunning() {\n\t\tt.Error(\"Expected GC worker to not be running after Stop\")\n\t}\n}\n","after":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nfunc TestDefaultGCConfig(t *testing.T) {\n\tconfig := DefaultGCConfig()\n\n\tif config == nil {\n\t\tt.Error(\"Expected non-nil GCConfig\")\n\t}\n\n\tif !config.GCEnabled {\n\t\tt.Error(\"Expected GCEnabled to be true by default\")\n\t}\n\n\tif config.GCInterval != DefaultGCInterval {\n\t\tt.Errorf(\"Expected GCInterval to be %v, got %v\", DefaultGCInterval, config.GCInterval)\n\t}\n\n\tif config.GCBatchSize != DefaultGCBatchSize {\n\t\tt.Errorf(\"Expected GCBatchSize to be %d, got %d\", DefaultGCBatchSize, config.GCBatchSize)\n\t}\n}\n\nfunc TestGCConfigValues(t *testing.T) {\n\ttests := []struct {\n\t\tname        string\n\t\tgcEnabled   bool\n\t\tgcInterval  time.Duration\n\t\tgcBatchSize int\n\t\texpectedErr bool\n\t}{\n\t\t{\n\t\t\tname:        \"default values\",\n\t\t\tgcEnabled:   true,\n\t\t\tgcInterval:  5 * time.Minute,\n\t\t\tgcBatchSize: 50,\n\t\t\texpectedErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"disabled GC\",\n\t\t\tgcEnabled:   false,\n\t\t\tgcInterval:  5 * time.Minute,\n\t\t\tgcBatchSize: 50,\n\t\t\texpectedErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"custom interval\",\n\t\t\tgcEnabled:   true,\n\t\t\tgcInterval:  10 * time.Minute,\n\t\t\tgcBatchSize: 100,\n\t\t\texpectedErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"custom batch size\",\n\t\t\tgcEnabled:   true,\n\t\t\tgcInterval:  5 * time.Minute,\n\t\t\tgcBatchSize: 200,\n\t\t\texpectedErr: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tconfig := &GCConfig{\n\t\t\t\tGCEnabled:   tt.gcEnabled,\n\t\t\t\tGCInterval:  tt.gcInterval,\n\t\t\t\tGCBatchSize: tt.gcBatchSize,\n\t\t\t}\n\n\t\t\tif config.GCEnabled != tt.gcEnabled {\n\t\t\t\tt.Errorf(\"Expected GCEnabled to be %v, got %v\", tt.gcEnabled, config.GCEnabled)\n\t\t\t}\n\n\t\t\tif config.GCInterval != tt.gcInterval {\n\t\t\t\tt.Errorf(\"Expected GCInterval to be %v, got %v\", tt.gcInterval, config.GCInterval)\n\t\t\t}\n\n\t\t\tif config.GCBatchSize != tt.gcBatchSize {\n\t\t\t\tt.Errorf(\"Expected GCBatchSize to be %d, got %d\", tt.gcBatchSize, config.GCBatchSize)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGCWorkerNewGCWorker(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tif worker == nil {\n\t\tt.Error(\"Expected non-nil GCWorker\")\n\t}\n\n\tif worker.config == nil {\n\t\tt.Error(\"Expected non-nil config\")\n\t}\n\n\tif worker.cleanupMgr == nil {\n\t\tt.Error(\"Expected non-nil cleanupMgr\")\n\t}\n\n\tif worker.expirationChecker == nil {\n\t\tt.Error(\"Expected non-nil expirationChecker\")\n\t}\n\n\tif worker.stopCh == nil {\n\t\tt.Error(\"Expected non-nil stopCh\")\n\t}\n}\n\nfunc TestGCWorkerWithCustomConfig(t *testing.T) {\n\tconfig := &GCConfig{\n\t\tGCEnabled:   false,\n\t\tGCInterval:  10 * time.Minute,\n\t\tGCBatchSize: 100,\n\t}\n\n\tworker := NewGCWorker(nil, nil, config)\n\n\tif worker.config.GCEnabled != false {\n\t\tt.Error(\"Expected GCEnabled to be false\")\n\t}\n\n\tif worker.config.GCInterval != 10*time.Minute {\n\t\tt.Errorf(\"Expected GCInterval to be 10m, got %v\", worker.config.GCInterval)\n\t}\n\n\tif worker.config.GCBatchSize != 100 {\n\t\tt.Errorf(\"Expected GCBatchSize to be 100, got %d\", worker.config.GCBatchSize)\n\t}\n}\n\nfunc TestGCWorkerIsRunning(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tif worker.IsRunning() {\n\t\tt.Error(\"Expected GCWorker to not be running initially\")\n\t}\n\n\tworker.setRunning(true)\n\n\tif !worker.IsRunning() {\n\t\tt.Error(\"Expected GCWorker to be running after setRunning(true)\")\n\t}\n\n\tworker.setRunning(false)\n\n\tif worker.IsRunning() {\n\t\tt.Error(\"Expected GCWorker to not be running after setRunning(false)\")\n\t}\n}\n\nfunc TestGCWorkerGetConfig(t *testing.T) {\n\tconfig := &GCConfig{\n\t\tGCEnabled:   true,\n\t\tGCInterval:  15 * time.Minute,\n\t\tGCBatchSize: 75,\n\t}\n\n\tworker := NewGCWorker(nil, nil, config)\n\n\treturnedConfig := worker.GetConfig()\n\n\tif returnedConfig.GCEnabled != config.GCEnabled {\n\t\tt.Errorf(\"Expected GCEnabled to be %v, got %v\", config.GCEnabled, returnedConfig.GCEnabled)\n\t}\n\n\tif returnedConfig.GCInterval != config.GCInterval {\n\t\tt.Errorf(\"Expected GCInterval to be %v, got %v\", config.GCInterval, returnedConfig.GCInterval)\n\t}\n\n\tif returnedConfig.GCBatchSize != config.GCBatchSize {\n\t\tt.Errorf(\"Expected GCBatchSize to be %d, got %d\", config.GCBatchSize, returnedConfig.GCBatchSize)\n\t}\n}\n\nfunc TestGCWorkerGetStats(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tstats := worker.GetStats()\n\n\tif stats.TotalCycles != 0 {\n\t\tt.Errorf(\"Expected TotalCycles to be 0, got %d\", stats.TotalCycles)\n\t}\n\n\tif stats.TotalDeleted != 0 {\n\t\tt.Errorf(\"Expected TotalDeleted to be 0, got %d\", stats.TotalDeleted)\n\t}\n\n\tif stats.TotalFailed != 0 {\n\t\tt.Errorf(\"Expected TotalFailed to be 0, got %d\", stats.TotalFailed)\n\t}\n}\n\nfunc TestGCWorkerRecordGCResult(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tresult := &GCResult{\n\t\tScannedCount: 10,\n\t\tExpiredCount: 5,\n\t\tDeletedCount: 4,\n\t\tFailedCount:  1,\n\t\tDuration:     100 * time.Millisecond,\n\t}\n\n\tstartTime := time.Now()\n\tworker.recordGCResult(result, startTime)\n\n\tstats := worker.GetStats()\n\n\tif stats.TotalCycles != 1 {\n\t\tt.Errorf(\"Expected TotalCycles to be 1, got %d\", stats.TotalCycles)\n\t}\n\n\tif stats.TotalDeleted != 4 {\n\t\tt.Errorf(\"Expected TotalDeleted to be 4, got %d\", stats.TotalDeleted)\n\t}\n\n\tif stats.TotalFailed != 1 {\n\t\tt.Errorf(\"Expected TotalFailed to be 1, got %d\", stats.TotalFailed)\n\t}\n\n\tif stats.LastRunTime.IsZero() {\n\t\tt.Error(\"Expected LastRunTime to be set\")\n\t}\n\n\tif stats.LastResult == nil {\n\t\tt.Error(\"Expected LastResult to be set\")\n\t}\n\n\tif stats.LastResult.DeletedCount != 4 {\n\t\tt.Errorf(\"Expected LastResult.DeletedCount to be 4, got %d\", stats.LastResult.DeletedCount)\n\t}\n}\n\nfunc TestGCWorkerUpdateConfig(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tnewConfig := &GCConfig{\n\t\tGCEnabled:   false,\n\t\tGCInterval:  20 * time.Minute,\n\t\tGCBatchSize: 150,\n\t}\n\n\tworker.UpdateConfig(newConfig)\n\n\tif worker.config.GCEnabled != false {\n\t\tt.Error(\"Expected GCEnabled to be false after update\")\n\t}\n\n\tif worker.config.GCInterval != 20*time.Minute {\n\t\tt.Errorf(\"Expected GCInterval to be 20m, got %v\", worker.config.GCInterval)\n\t}\n\n\tworker.UpdateConfig(&GCConfig{\n\t\tGCEnabled:   false,\n\t\tGCInterval:  20 * time.Minute,\n\t\tGCBatchSize: 150,\n\t})\n\n\tif worker.config.GCEnabled != false {\n\t\tt.Error(\"Expected GCEnabled to be false after update\")\n\t}\n\n\tworker.UpdateConfig(nil)\n\n\tif worker.config.GCInterval != 20*time.Minute {\n\t\tt.Errorf(\"Expected GCInterval to remain 20m after nil update, got %v\", worker.config.GCInterval)\n\t}\n}\n\nfunc TestGCWorkerTriggerGCCycle(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\tctx := context.Background()\n\tresult := worker.TriggerGCCycle(ctx)\n\n\tif result == nil {\n\t\tt.Error(\"Expected non-nil result\")\n\t}\n\n\tif result.ScannedCount != 0 {\n\t\tt.Errorf(\"Expected ScannedCount to be 0 with nil client, got %d\", result.ScannedCount)\n\t}\n}\n\nfunc TestIsAgentRuntimeExpired(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname        string\n\t\tar          *agentcubev1alpha1.AgentRuntime\n\t\texpectedExp bool\n\t}{\n\t\t{\n\t\t\tname: \"not expired - recently created\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: false,\n\t\t},\n\t\t{\n\t\t\tname: \"expired by TTL\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-10 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t\tAnnotations:       map[string]string{\"expires-at\": time.Now().Add(-1 * time.Hour).Format(time.RFC3339)},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"marked for deletion\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"stale state - Unknown with old creation\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-2 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"False\",\n\t\t\t\t\t\t\tReason: \"Unknown\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"stale state - Failed with old creation\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-2 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"False\",\n\t\t\t\t\t\t\tReason: \"Failed\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\texpired := worker.isAgentRuntimeExpired(tt.ar)\n\t\t\tif expired != tt.expectedExp {\n\t\t\t\tt.Errorf(\"Expected expired=%v, got %v\", tt.expectedExp, expired)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestIsCodeInterpreterExpired(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname        string\n\t\tci          *agentcubev1alpha1.CodeInterpreter\n\t\texpectedExp bool\n\t}{\n\t\t{\n\t\t\tname: \"not expired - recently created\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: false,\n\t\t},\n\t\t{\n\t\t\tname: \"expired by TTL\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-10 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t\tAnnotations:       map[string]string{\"expires-at\": time.Now().Add(-1 * time.Hour).Format(time.RFC3339)},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"marked for deletion\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t\t{\n\t\t\tname: \"stale state - Failed with old creation\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tNamespace:         \"default\",\n\t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-2 * time.Hour)},\n\t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: false,\n\t\t\t\t\tConditions: []agentcubev1alpha1.CodeInterpreterCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"False\",\n\t\t\t\t\t\t\tReason: \"Failed\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedExp: true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\texpired := worker.isCodeInterpreterExpired(tt.ci)\n\t\t\tif expired != tt.expectedExp {\n\t\t\t\tt.Errorf(\"Expected expired=%v, got %v\", tt.expectedExp, expired)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetAgentRuntimeState(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname          string\n\t\tar            *agentcubev1alpha1.AgentRuntime\n\t\texpectedState SandboxState\n\t}{\n\t\t{\n\t\t\tname: \"Unknown state - no conditions\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ar\",\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateUnknown,\n\t\t},\n\t\t{\n\t\t\tname: \"Running state\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ar\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"True\",\n\t\t\t\t\t\t\tReason: \"Running\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateRunning,\n\t\t},\n\t\t{\n\t\t\tname: \"Failed state\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ar\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"True\",\n\t\t\t\t\t\t\tReason: \"Failed\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateFailed,\n\t\t},\n\t\t{\n\t\t\tname: \"Deleting state\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ar\",\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateDeleting,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstate := worker.getAgentRuntimeState(tt.ar)\n\t\t\tif state != tt.expectedState {\n\t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetCodeInterpreterState(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname          string\n\t\tci            *agentcubev1alpha1.CodeInterpreter\n\t\texpectedState SandboxState\n\t}{\n\t\t{\n\t\t\tname: \"Unknown state - not ready\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ci\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: false,\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateUnknown,\n\t\t},\n\t\t{\n\t\t\tname: \"Running state - ready\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ci\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: true,\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateRunning,\n\t\t},\n\t\t{\n\t\t\tname: \"Failed state\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test-ci\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: false,\n\t\t\t\t\tConditions: []agentcubev1alpha1.CodeInterpreterCondition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: \"True\",\n\t\t\t\t\t\t\tReason: \"Failed\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateFailed,\n\t\t},\n\t\t{\n\t\t\tname: \"Deleting state\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test-ci\",\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateDeleting,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstate := worker.getCodeInterpreterState(tt.ci)\n\t\t\tif state != tt.expectedState {\n\t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetLastActivityTime(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\n\ttests := []struct {\n\t\tname         string\n\t\tannotations  map[string]string\n\t\texpectedTime *time.Time\n\t}{\n\t\t{\n\t\t\tname:         \"nil annotations\",\n\t\t\tannotations:  nil,\n\t\t\texpectedTime: nil,\n\t\t},\n\t\t{\n\t\t\tname:         \"empty annotations\",\n\t\t\tannotations:  map[string]string{},\n\t\t\texpectedTime: nil,\n\t\t},\n\t\t{\n\t\t\tname:         \"no last-activity-time\",\n\t\t\tannotations:  map[string]string{\"other\": \"value\"},\n\t\t\texpectedTime: nil,\n\t\t},\n\t\t{\n\t\t\tname:         \"valid last-activity-time\",\n\t\t\tannotations:  map[string]string{\"last-activity-time\": \"2024-01-15T10:30:00Z\"},\n\t\t\texpectedTime: nil, // Will be non-nil, just checking parsing works\n\t\t},\n\t\t{\n\t\t\tname:         \"invalid last-activity-time\",\n\t\t\tannotations:  map[string]string{\"last-activity-time\": \"invalid\"},\n\t\t\texpectedTime: nil,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tobj := &metav1.ObjectMeta{\n\t\t\t\tAnnotations: tt.annotations,\n\t\t\t}\n\t\t\tresult := worker.getLastActivityTime(obj)\n\n\t\t\tif tt.expectedTime == nil && result != nil {\n\t\t\t\tt.Error(\"Expected nil result, got non-nil\")\n\t\t\t}\n\n\t\t\tif tt.expectedTime != nil && result == nil {\n\t\t\t\tt.Error(\"Expected non-nil result, got nil\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGCHandler(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\thandler := NewGCHandler(worker)\n\n\tif handler == nil {\n\t\tt.Error(\"Expected non-nil GCHandler\")\n\t}\n\n\tif handler.worker == nil {\n\t\tt.Error(\"Expected non-nil worker in handler\")\n\t}\n}\n\nfunc TestGCHandlerTriggerGC(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\thandler := NewGCHandler(worker)\n\n\tresult := handler.TriggerGC()\n\n\tif result == nil {\n\t\tt.Error(\"Expected non-nil result\")\n\t}\n\n\tif result[\"started\"] != true {\n\t\tt.Error(\"Expected started to be true\")\n\t}\n\n\tif result[\"scannedCount\"] != 0 {\n\t\tt.Errorf(\"Expected scannedCount to be 0, got %v\", result[\"scannedCount\"])\n\t}\n}\n\nfunc TestGCHandlerGetStatus(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\thandler := NewGCHandler(worker)\n\n\tstatus := handler.GetStatus()\n\n\tif status == nil {\n\t\tt.Error(\"Expected non-nil status\")\n\t}\n\n\tif status[\"running\"] != false {\n\t\tt.Error(\"Expected running to be false\")\n\t}\n\n\tif status[\"gcEnabled\"] != true {\n\t\tt.Error(\"Expected gcEnabled to be true\")\n\t}\n\n\tif status[\"gcBatchSize\"] != DefaultGCBatchSize {\n\t\tt.Errorf(\"Expected gcBatchSize to be %d, got %v\", DefaultGCBatchSize, status[\"gcBatchSize\"])\n\t}\n}\n\nfunc TestGCHandlerUpdateConfig(t *testing.T) {\n\tworker := NewGCWorker(nil, nil, nil)\n\thandler := NewGCHandler(worker)\n\n\tnewConfig := &GCConfig{\n\t\tGCEnabled:  false,\n\t\tGCInterval: 30 * time.Minute,\n\t}\n\n\tresult := handler.UpdateConfig(newConfig)\n\n\tif result == nil {\n\t\tt.Error(\"Expected non-nil result\")\n\t}\n\n\tif result[\"message\"] != \"GC configuration updated\" {\n\t\tt.Errorf(\"Expected message 'GC configuration updated', got %v\", result[\"message\"])\n\t}\n\n\tif worker.config.GCEnabled != false {\n\t\tt.Error(\"Expected GCEnabled to be false after update\")\n\t}\n}\n\nfunc TestGCResult(t *testing.T) {\n\tresult := &GCResult{\n\t\tScannedCount:     100,\n\t\tExpiredCount:     50,\n\t\tDeletedCount:     45,\n\t\tFailedCount:      5,\n\t\tDuration:         5 * time.Second,\n\t\tErrors:           []string{\"error1\", \"error2\"},\n\t\tCleanedResources: []string{\"Service/svc1\", \"ConfigMap/cm1\"},\n\t}\n\n\tif result.ScannedCount != 100 {\n\t\tt.Errorf(\"Expected ScannedCount=100, got %d\", result.ScannedCount)\n\t}\n\n\tif result.ExpiredCount != 50 {\n\t\tt.Errorf(\"Expected ExpiredCount=50, got %d\", result.ExpiredCount)\n\t}\n\n\tif result.DeletedCount != 45 {\n\t\tt.Errorf(\"Expected DeletedCount=45, got %d\", result.DeletedCount)\n\t}\n\n\tif result.FailedCount != 5 {\n\t\tt.Errorf(\"Expected FailedCount=5, got %d\", result.FailedCount)\n\t}\n\n\tif len(result.Errors) != 2 {\n\t\tt.Errorf(\"Expected 2 errors, got %d\", len(result.Errors))\n\t}\n\n\tif len(result.CleanedResources) != 2 {\n\t\tt.Errorf(\"Expected 2 cleaned resources, got %d\", len(result.CleanedResources))\n\t}\n}\n\nfunc TestGCStats(t *testing.T) {\n\tstats := GCStats{\n\t\tTotalCycles:  10,\n\t\tTotalDeleted: 100,\n\t\tTotalFailed:  5,\n\t\tLastRunTime:  time.Now(),\n\t\tLastResult: &GCResult{\n\t\t\tDeletedCount: 10,\n\t\t},\n\t}\n\n\tif stats.TotalCycles != 10 {\n\t\tt.Errorf(\"Expected TotalCycles=10, got %d\", stats.TotalCycles)\n\t}\n\n\tif stats.TotalDeleted != 100 {\n\t\tt.Errorf(\"Expected TotalDeleted=100, got %d\", stats.TotalDeleted)\n\t}\n\n\tif stats.TotalFailed != 5 {\n\t\tt.Errorf(\"Expected TotalFailed=5, got %d\", stats.TotalFailed)\n\t}\n\n\tif stats.LastResult == nil {\n\t\tt.Error(\"Expected non-nil LastResult\")\n\t}\n\n\tif stats.LastResult.DeletedCount != 10 {\n\t\tt.Errorf(\"Expected LastResult.DeletedCount=10, got %d\", stats.LastResult.DeletedCount)\n\t}\n}\n\nfunc TestGetAgentRuntimeStateStandalone(t *testing.T) {\n\ttests := []struct {\n\t\tname          string\n\t\tar            *agentcubev1alpha1.AgentRuntime\n\t\texpectedState SandboxState\n\t}{\n\t\t{\n\t\t\tname: \"Unknown with DeletionTimestamp\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test\",\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateDeleting,\n\t\t},\n\t\t{\n\t\t\tname: \"Running\",\n\t\t\tar: &agentcubev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n\t\t\t\t\tConditions: []agentcubev1alpha1.AgentRuntimeCondition{\n\t\t\t\t\t\t{Type: \"Ready\", Status: \"True\", Reason: \"Running\"},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateRunning,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstate := getAgentRuntimeState(tt.ar)\n\t\t\tif state != tt.expectedState {\n\t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetCodeInterpreterStateStandalone(t *testing.T) {\n\ttests := []struct {\n\t\tname          string\n\t\tci            *agentcubev1alpha1.CodeInterpreter\n\t\texpectedState SandboxState\n\t}{\n\t\t{\n\t\t\tname: \"Unknown\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: false,\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateUnknown,\n\t\t},\n\t\t{\n\t\t\tname: \"Running\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"test\",\n\t\t\t\t},\n\t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n\t\t\t\t\tReady: true,\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateRunning,\n\t\t},\n\t\t{\n\t\t\tname: \"Deleting\",\n\t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:              \"test\",\n\t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n\t\t\t\t},\n\t\t\t},\n\t\t\texpectedState: SandboxStateDeleting,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstate := getCodeInterpreterState(tt.ci)\n\t\t\tif state != tt.expectedState {\n\t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGetLastActivityTimeFromAnnotations(t *testing.T) {\n\ttests := []struct {\n\t\tname        string\n\t\tannotations map[string]string\n\t\texpectNil   bool\n\t}{\n\t\t{\n\t\t\tname:        \"nil annotations\",\n\t\t\tannotations: nil,\n\t\t\texpectNil:   true,\n\t\t},\n\t\t{\n\t\t\tname:        \"empty annotations\",\n\t\t\tannotations: map[string]string{},\n\t\t\texpectNil:   true,\n\t\t},\n\t\t{\n\t\t\tname:        \"valid time\",\n\t\t\tannotations: map[string]string{\"last-activity-time\": \"2024-01-15T10:30:00Z\"},\n\t\t\texpectNil:   false,\n\t\t},\n\t\t{\n\t\t\tname:        \"invalid time\",\n\t\t\tannotations: map[string]string{\"last-activity-time\": \"invalid\"},\n\t\t\texpectNil:   true,\n\t\t},\n\t\t{\n\t\t\tname:        \"no key\",\n\t\t\tannotations: map[string]string{\"other\": \"value\"},\n\t\t\texpectNil:   true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tresult := getLastActivityTimeFromAnnotations(tt.annotations)\n\t\t\tif tt.expectNil && result != nil {\n\t\t\t\tt.Error(\"Expected nil result\")\n\t\t\t}\n\t\t\tif !tt.expectNil && result == nil {\n\t\t\t\tt.Error(\"Expected non-nil result\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestGCWorkerStartDisabled(t *testing.T) {\n\tconfig := &GCConfig{\n\t\tGCEnabled:  false,\n\t\tGCInterval: 5 * time.Minute,\n\t}\n\n\tworker := NewGCWorker(nil, nil, config)\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tcancel()\n\n\tworker.Start(ctx)\n\n\tif worker.IsRunning() {\n\t\tt.Error(\"Expected GC worker to not be running when disabled\")\n\t}\n}\n\nfunc TestGCWorkerStop(t *testing.T) {\n\tconfig := &GCConfig{\n\t\tGCEnabled:  true,\n\t\tGCInterval: 1 * time.Second,\n\t}\n\n\tworker := NewGCWorker(nil, nil, config)\n\n\tworker.Stop()\n\n\tif worker.IsRunning() {\n\t\tt.Error(\"Expected GC worker to not be running after Stop\")\n\t}\n}\n","additions":3,"deletions":3},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc_test.go","time":{"start":1775846722349,"end":1775846722578}}}}
