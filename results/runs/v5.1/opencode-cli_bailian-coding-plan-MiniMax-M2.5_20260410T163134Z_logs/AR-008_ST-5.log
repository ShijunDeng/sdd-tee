T) {\n\tconfig := &GCConfig{\n\t\tGCEnabled:  true,\n\t\tGCInterval: 1 * time.Second,\n\t}\n\n\tworker := NewGCWorker(nil, nil, config)\n\n\tworker.Stop()\n\n\tif worker.IsRunning() {\n\t\tt.Error(\"Expected GC worker to not be running after Stop\")\n\t}\n}\n","additions":5,"deletions":6},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc_test.go","time":{"start":1775846696251,"end":1775846696459}}}}
