ents_file} .\")\n42:             lines.append(f\"RUN pip install --no-cache-dir -r {metadata.requirements_file}\")\n43:             lines.append(\"\")\n44: \n45:         lines.append(\"COPY . .\")\n46:         lines.append(\"\")\n47:         lines.append(f\"EXPOSE {metadata.port}\")\n48:         lines.append(\"\")\n49: \n50:         if metadata.entrypoint:\n51:             entrypoint_cmd = metadata.entrypoint\n52:         else:\n53:             entrypoint_cmd = \"python main.py\"\n54: \n55:         lines.append(f\"CMD {entrypoint_cmd}\")\n56: \n57:         return \"\\n\".join(lines)\n58: \n59:     @staticmethod\n60:     def generate_java_dockerfile(metadata: AgentMetadata) -> str:\n61:         \"\"\"\n62:         Generate Dockerfile content for Java agents.\n63: \n64:         Args:\n65:             metadata: AgentMetadata with agent configuration\n66: \n67:         Returns:\n68:             Dockerfile content as string\n69:         \"\"\"\n70:         lines = [\n71:             \"FROM maven:3.9-eclipse-temurin-17 AS build\",\n72:             \"\",\n73:             \"WORKDIR /app\",\n74:             \"\",\n75:             \"COPY pom.xml .\",\n76:             \"RUN mvn dependency:go-offline -B\",\n77:             \"\",\n78:             \"COPY src ./src\",\n79:             \"RUN mvn package -DskipTests\",\n80:             \"\",\n81:             \"FROM eclipse-temurin:17-jre\",\n82:             \"\",\n83:             \"WORKDIR /app\",\n84:             \"\",\n85:             \"COPY --from=build /app/target/*.jar app.jar\",\n86:             \"\",\n87:             f\"EXPOSE {metadata.port}\",\n88:             \"\",\n89:         ]\n90: \n91:         if metadata.entrypoint:\n92:             entrypoint_cmd = metadata.entrypoint\n93:         else:\n94:             entrypoint_cmd = \"java -jar app.jar\"\n95: \n96:         lines.append(f'CMD [\"{entrypoint_cmd}\"]')\n97: \n98:         return \"\\n\".join(lines)\n99: \n100:     @staticmethod\n101:     def write_dockerfile(workspace_path: Path, content: str) -> Path:\n102:         \"\"\"\n103:         Write Dockerfile content to workspace.\n104: \n105:         Args:\n106:             workspace_path: Path to workspace directory\n107:             content: Dockerfile content\n108: \n109:         Returns:\n110:             Path to the written Dockerfile\n111:         \"\"\"\n112:         dockerfile_path = workspace_path / \"Dockerfile\"\n113: \n114:         with open(dockerfile_path, \"w\", encoding=\"utf-8\") as f:\n115:             f.write(content)\n116: \n117:         return dockerfile_path\n118: \n119:     def check_docker_available(self) -> bool:\n120:         \"\"\"\n121:         Check if Docker is available and running.\n122: \n123:         Returns:\n124:             True if Docker is available, False otherwise\n125:         \"\"\"\n126:         try:\n127:             client = docker.from_env()\n128:             client.ping()\n129:             self.logger.debug(\"Docker is available\")\n130:             return True\n131:         except docker.errors.DockerException:\n132:             self.logger.warning(\"Docker is not available\")\n133:             return False\n134: \n135:     def build_image(\n136:         self,\n137:         dockerfile_path: Path,\n138:         context_path: Path,\n139:         image_name: str,\n140:         tag: str = \"latest\",\n141:         build_args: Optional[Dict[str, str]] = None,\n142:     ) -> Dict[str, str]:\n143:         \"\"\"\n144:         Build a Docker image from a Dockerfile.\n145: \n146:         Args:\n147:             dockerfile_path: Path to the Dockerfile\n148:             context_path: Build context path\n149:             image_name: Name for the image\n150:             tag: Tag for the image\n151:             build_args: Build arguments for docker build\n152: \n153:         Returns:\n154:             Dictionary with image info (image_id, tags)\n155:         \"\"\"\n156:         try:\n157:             client = docker.from_env()\n158:             image_tag = f\"{image_name}:{tag}\"\n159: \n160:             self.logger.debug(f\"Building image: {image_tag}\")\n161: \n162:             build_output = client.images.build(\n163:                 path=str(context_path),\n164:                 dockerfile=str(dockerfile_path),\n165:                 tag=image_tag,\n166:                 buildargs=build_args or {},\n167:                 rm=True,\n168:             )\n169: \n170:             image = build_output[0]\n171:             self.logger.debug(f\"Image built successfully: {image.id}\")\n172: \n173:             return {\n174:                 \"image_id\": image.id,\n175:                 \"tags\": [image_tag],\n176:             }\n177:         except docker.errors.BuildError as e:\n178:             self.logger.error(f\"Build failed: {e}\")\n179:             raise ValueError(f\"Docker build failed: {e}\")\n180:         except docker.errors.APIError as e:\n181:             self.logger.error(f\"Docker API error: {e}\")\n182:             raise ValueError(f\"Docker API error: {e}\")\n183: \n184:     def get_image_info(self, image_name: str) -> Dict[str, str]:\n185:         \"\"\"\n186:         Get information about a Docker image.\n187: \n188:         Args:\n189:             image_name: Name of the image\n190: \n191:         Returns:\n192:             Dictionary with image info\n193:         \"\"\"\n194:         try:\n195:             client = docker.from_env()\n196:             image = client.images.get(image_name)\n197:             return {\n198:                 \"id\": image.id,\n199:                 \"tags\": image.tags,\n200:                 \"size\": str(image.attrs.get(\"Size\", 0)),\n201:             }\n202:         except docker.errors.NotFound:\n203:             raise ValueError(f\"Image not found: {image_name}\")\n204:         except docker.errors.APIError as e:\n205:             raise ValueError(f\"Docker API error: {e}\")\n206: \n207:     def push_image(\n208:         self,\n209:         image_name: str,\n210:         registry_url: Optional[str] = None,\n211:         username: Optional[str] = None,\n212:         password: Optional[str] = None,\n213:     ) -> Dict[str, str]:\n214:         \"\"\"\n215:         Push a Docker image to a registry.\n216: \n217:         Args:\n218:             image_name: Name of the image to push\n219:             registry_url: Registry URL\n220:             username: Username for authentication\n221:             password: Password for authentication\n222: \n223:         Returns:\n224:             Dictionary with push status\n225:         \"\"\"\n226:         try:\n227:             client = docker.from_env()\n228: \n229:             if registry_url and username and password:\n230:                 client.login(username=username, password=password, registry=registry_url)\n231: \n232:             self.logger.debug(f\"Pushing image: {image_name}\")\n233:             image = client.images.get(image_name)\n234:             for line in image.push(stream=True, decode=True):\n235:                 if \"status\" in line:\n236:                     self.logger.debug(line[\"status\"])\n237: \n238:             return {\"status\": \"success\", \"image\": image_name}\n239:         except docker.errors.NotFound:\n240:             raise ValueError(f\"Image not found: {image_name}\")\n241:         except docker.errors.APIError as e:\n242:             raise ValueError(f\"Docker API error: {e}\")\n243: \n244:     def remove_image(self, image_name: str) -> bool:\n245:         \"\"\"\n246:         Remove a Docker image.\n247: \n248:         Args:\n249:             image_name: Name of the image to remove\n250: \n251:         Returns:\n252:             True if successful\n253:         \"\"\"\n254:         try:\n255:             client = docker.from_env()\n256:             client.images.remove(image_name)\n257:             self.logger.debug(f\"Image removed: {image_name}\")\n258:             return True\n259:         except docker.errors.NotFound:\n260:             raise ValueError(f\"Image not found: {image_name}\")\n261:         except docker.errors.APIError as e:\n262:             raise ValueError(f\"Docker API error: {e}\")\n\n(End of file - total 262 lines)\n</content>","metadata":{"preview":"\"\"\"Docker service for AgentCube - handles Dockerfile generation and Docker operations.\"\"\"\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport docker\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass DockerService:\n    \"\"\"Service for Docker-related operations.\"\"\"\n\n    def __init__(self, verbose: bool = False):\n        self.verbose = verbose\n        self.logger = logging.getLogger(__name__)\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        else:\n            logging.basicConfig(level=logging.INFO)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/docker_service.py","time":{"start":1775863413533,"end":1775863413559}}}}
