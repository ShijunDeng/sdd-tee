er for Kubernetes deployments using native resources.\"\"\"\n\n    def __init__(\n        self,\n        namespace: str = \"default\",\n        verbose: bool = False,\n        kubeconfig: Optional[str] = None,\n    ):\n        \"\"\"\n        Initialize the KubernetesProvider.\n\n        Args:\n            namespace: Kubernetes namespace\n            verbose: Enable verbose logging\n            kubeconfig: Path to kubeconfig file\n        \"\"\"\n        self.namespace = namespace\n        self.verbose = verbose\n        self.kubeconfig = kubeconfig\n        self.logger = logging.getLogger(__name__)\n\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        else:\n            logging.basicConfig(level=logging.INFO)\n\n        self._client = None\n\n    def _get_client(self) -> Any:\n        \"\"\"Get Kubernetes client (lazy initialization).\"\"\"\n        if self._client is not None:\n            return self._client\n\n        try:\n            from kubernetes import client, config\n\n            if self.kubeconfig:\n                config.load_kube_config(config_file=self.kubeconfig)\n            else:\n                try:\n                    config.load_kube_config()\n                except Exception:\n                    config.load_incluster_config()\n\n            self._client = client\n            return self._client\n        except ImportError:\n            self.logger.warning(\"kubernetes library not available, using mock mode\")\n            return None\n\n    def deploy_agent(\n        self,\n        agent_name: str,\n        image_url: str,\n        port: int,\n        entrypoint: Optional[str] = None,\n        replicas: int = 1,\n        node_port: Optional[int] = None,\n        env_vars: Optional[Dict[str, str]] = None,\n    ) -> Dict[str, Any]:\n        \"\"\"\n        Deploy an agent to Kubernetes.\n\n        Args:\n            agent_name: Name of the agent\n            image_url: Container image URL\n            port: Port to expose\n            entrypoint: Entrypoint command\n            replicas: Number of replicas\n            node_port: NodePort for service (30000-32767)\n            env_vars: Environment variables\n\n        Returns:\n            Dictionary with deployment info\n        \"\"\"\n        client = self._get_client()\n\n        if client is None:\n            self.logger.warning(\"Using mock Kubernetes deployment\")\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"service\": f\"{agent_name}-service\",\n                \"endpoint\": f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\",\n            }\n\n        try:\n            k8s = client\n            apps_v1 = k8s.AppsV1Api()\n            core_v1 = k8s.CoreV1Api()\n\n            deployment = k8s.V1Deployment(\n                metadata=k8s.V1ObjectMeta(\n                    name=agent_name,\n                    namespace=self.namespace,\n                    labels={\"app\": agent_name, \"agentcube agent\": \"true\"},\n                ),\n                spec=k8s.V1DeploymentSpec(\n                    replicas=replicas,\n                    selector=k8s.V1LabelSelector(match_labels={\"app\": agent_name}),\n                    template=k8s.V1PodTemplateSpec(\n                        metadata=k8s.V1ObjectMeta(labels={\"app\": agent_name}),\n                        spec=k8s.V1PodSpec(\n                            containers=[\n                                k8s.V1Container(\n                                    name=\"agent\",\n                                    image=image_url,\n                                    ports=[k8s.V1ContainerPort(container_port=port, name=\"http\")],\n                                    env=[\n                                        k8s.V1EnvVar(name=k, value=v)\n                                        for k, v in (env_vars or {}).items()\n                                    ]\n                                    if env_vars\n                                    else [],\n                                    image_pull_policy=\"IfNotPresent\",\n                                )\n                            ]\n                        ),\n                    ),\n                ),\n            )\n\n            apps_v1.create_namespaced_deployment(namespace=self.namespace, body=deployment)\n\n            service_type = \"NodePort\" if node_port else \"ClusterIP\"\n            service = k8s.V1Service(\n                metadata=k8s.V1ObjectMeta(\n                    name=f\"{agent_name}-service\",\n                    namespace=self.namespace,\n                ),\n                spec=k8s.V1ServiceSpec(\n                    type=service_type,\n                    selector={\"app\": agent_name},\n                    ports=[\n                        k8s.V1ServicePort(\n                            port=port,\n                            target_port=port,\n                            name=\"http\",\n                            node_port=node_port,\n                        )\n                    ],\n                ),\n            )\n\n            core_v1.create_namespaced_service(namespace=self.namespace, body=service)\n\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"service\": f\"{agent_name}-service\",\n                \"endpoint\": f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\",\n            }\n\n        except Exception as e:\n            self.logger.error(f\"Failed to deploy to Kubernetes: {e}\")\n            raise ValueError(f\"Kubernetes deployment failed: {e}\")\n\n    def wait_for_deployment_ready(self, name: str, timeout: int = 120) -> None:\n        \"\"\"\n        Wait for deployment to be ready.\n\n        Args:\n            name: Deployment name\n            timeout: Timeout in seconds\n\n        Raises:\n            ValueError: If timeout\n        \"\"\"\n        client = self._get_client()\n\n        if client is None:\n            self.logger.debug(\"Mock: deployment ready\")\n            return\n\n        import time\n\n        k8s = client.AppsV1Api()\n        start_time = time.time()\n\n        while time.time() - start_time < timeout:\n            try:\n                deployment = k8s.read_namespaced_deployment(name=name, namespace=self.namespace)\n\n                if deployment.status.ready_replicas == deployment.spec.replicas:\n                    self.logger.debug(f\"Deployment {name} is ready\")\n                    return\n\n            except Exception:\n                pass\n\n            time.sleep(2)\n\n        raise ValueError(f\"Deployment {name} not ready within {timeout}s\")\n\n    def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n        \"\"\"\n        Get agent status from Kubernetes.\n\n        Args:\n            agent_name: Name of the agent\n\n        Returns:\n            Dictionary with status info\n        \"\"\"\n        client = self._get_client()\n\n        if client is None:\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"status\": \"running\",\n                \"ready_replicas\": 1,\n            }\n\n        try:\n            k8s = client.AppsV1Api()\n            deployment = k8s.read_namespaced_deployment(name=agent_name, namespace=self.namespace)\n\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"status\": \"running\" if deployment.status.ready_replicas else \"pending\",\n                \"ready_replicas\": deployment.status.ready_replicas or 0,\n                \"replicas\": deployment.spec.replicas,\n            }\n\n        except Exception as e:\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"status\": \"not_found\",\n                \"error\": str(e),\n            }\n\n    def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n        \"\"\"\n        Delete an agent from Kubernetes.\n\n        Args:\n            agent_name: Name of the agent\n\n        Returns:\n            Dictionary with deletion result\n        \"\"\"\n        client = self._get_client()\n\n        if client is None:\n            return {\n                \"name\": agent_name,\n                \"status\": \"deleted\",\n            }\n\n        try:\n            k8s = client\n            apps_v1 = k8s.AppsV1Api()\n            core_v1 = k8s.CoreV1Api()\n\n            try:\n                apps_v1.delete_namespaced_deployment(\n                    name=agent_name, namespace=self.namespace, body=k8s.V1DeleteOptions()\n                )\n            except Exception:\n                pass\n\n            try:\n                core_v1.delete_namespaced_service(\n                    name=f\"{agent_name}-service\",\n                    namespace=self.namespace,\n                    body=k8s.V1DeleteOptions(),\n                )\n            except Exception:\n                pass\n\n            return {\n                \"name\": agent_name,\n                \"status\": \"deleted\",\n            }\n\n        except Exception as e:\n            raise ValueError(f\"Failed to delete agent: {e}\")\n","after":"\"\"\"Kubernetes provider for AgentCube - handles K8s deployments.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom typing import Any, Dict, Optional\n\n\nclass KubernetesProvider:\n    \"\"\"Provider for Kubernetes deployments using native resources.\"\"\"\n\n    def __init__(\n        self,\n        namespace: str = \"default\",\n        verbose: bool = False,\n        kubeconfig: Optional[str] = None,\n    ):\n        \"\"\"\n        Initialize the KubernetesProvider.\n\n        Args:\n            namespace: Kubernetes namespace\n            verbose: Enable verbose logging\n            kubeconfig: Path to kubeconfig file\n        \"\"\"\n        self.namespace = namespace\n        self.verbose = verbose\n        self.kubeconfig = kubeconfig\n        self.logger = logging.getLogger(__name__)\n\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        else:\n            logging.basicConfig(level=logging.INFO)\n\n        self._client = None\n\n    def _get_client(self) -> Any:\n        \"\"\"Get Kubernetes client (lazy initialization).\"\"\"\n        if self._client is not None:\n            return self._client\n\n        try:\n            from kubernetes import client, config\n        except ImportError:\n            self.logger.warning(\"kubernetes library not available, using mock mode\")\n            return None\n\n        try:\n            if self.kubeconfig:\n                config.load_kube_config(config_file=self.kubeconfig)\n            else:\n                try:\n                    config.load_kube_config()\n                except Exception:\n                    config.load_incluster_config()\n\n            self._client = client\n            return self._client\n        except Exception as e:\n            self.logger.warning(f\"Could not load k8s config: {e}, using mock mode\")\n            return None\n\n    def deploy_agent(\n        self,\n        agent_name: str,\n        image_url: str,\n        port: int,\n        entrypoint: Optional[str] = None,\n        replicas: int = 1,\n        node_port: Optional[int] = None,\n        env_vars: Optional[Dict[str, str]] = None,\n    ) -> Dict[str, Any]:\n        \"\"\"\n        Deploy an agent to Kubernetes.\n\n        Args:\n            agent_name: Name of the agent\n            image_url: Container image URL\n            port: Port to expose\n            entrypoint: Entrypoint command\n            replicas: Number of replicas\n            node_port: NodePort for service (30000-32767)\n            env_vars: Environment variables\n\n        Returns:\n            Dictionary with deployment info\n        \"\"\"\n        client = self._get_client()\n\n        if client is None:\n            self.logger.warning(\"Using mock Kubernetes deployment\")\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"service\": f\"{agent_name}-service\",\n                \"endpoint\": f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\",\n            }\n\n        try:\n            k8s = client\n            apps_v1 = k8s.AppsV1Api()\n            core_v1 = k8s.CoreV1Api()\n\n            deployment = k8s.V1Deployment(\n                metadata=k8s.V1ObjectMeta(\n                    name=agent_name,\n                    namespace=self.namespace,\n                    labels={\"app\": agent_name, \"agentcube agent\": \"true\"},\n                ),\n                spec=k8s.V1DeploymentSpec(\n                    replicas=replicas,\n                    selector=k8s.V1LabelSelector(match_labels={\"app\": agent_name}),\n                    template=k8s.V1PodTemplateSpec(\n                        metadata=k8s.V1ObjectMeta(labels={\"app\": agent_name}),\n                        spec=k8s.V1PodSpec(\n                            containers=[\n                                k8s.V1Container(\n                                    name=\"agent\",\n                                    image=image_url,\n                                    ports=[k8s.V1ContainerPort(container_port=port, name=\"http\")],\n                                    env=[\n                                        k8s.V1EnvVar(name=k, value=v)\n                                        for k, v in (env_vars or {}).items()\n                                    ]\n                                    if env_vars\n                                    else [],\n                                    image_pull_policy=\"IfNotPresent\",\n                                )\n                            ]\n                        ),\n                    ),\n                ),\n            )\n\n            apps_v1.create_namespaced_deployment(namespace=self.namespace, body=deployment)\n\n            service_type = \"NodePort\" if node_port else \"ClusterIP\"\n            service = k8s.V1Service(\n                metadata=k8s.V1ObjectMeta(\n                    name=f\"{agent_name}-service\",\n                    namespace=self.namespace,\n                ),\n                spec=k8s.V1ServiceSpec(\n                    type=service_type,\n                    selector={\"app\": agent_name},\n                    ports=[\n                        k8s.V1ServicePort(\n                            port=port,\n                            target_port=port,\n                            name=\"http\",\n                            node_port=node_port,\n                        )\n                    ],\n                ),\n            )\n\n            core_v1.create_namespaced_service(namespace=self.namespace, body=service)\n\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"service\": f\"{agent_name}-service\",\n                \"endpoint\": f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\",\n            }\n\n        except Exception as e:\n            self.logger.error(f\"Failed to deploy to Kubernetes: {e}\")\n            raise ValueError(f\"Kubernetes deployment failed: {e}\")\n\n    def wait_for_deployment_ready(self, name: str, timeout: int = 120) -> None:\n        \"\"\"\n        Wait for deployment to be ready.\n\n        Args:\n            name: Deployment name\n            timeout: Timeout in seconds\n\n        Raises:\n            ValueError: If timeout\n        \"\"\"\n        client = self._get_client()\n\n        if client is None:\n            self.logger.debug(\"Mock: deployment ready\")\n            return\n\n        import time\n\n        k8s = client.AppsV1Api()\n        start_time = time.time()\n\n        while time.time() - start_time < timeout:\n            try:\n                deployment = k8s.read_namespaced_deployment(name=name, namespace=self.namespace)\n\n                if deployment.status.ready_replicas == deployment.spec.replicas:\n                    self.logger.debug(f\"Deployment {name} is ready\")\n                    return\n\n            except Exception:\n                pass\n\n            time.sleep(2)\n\n        raise ValueError(f\"Deployment {name} not ready within {timeout}s\")\n\n    def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n        \"\"\"\n        Get agent status from Kubernetes.\n\n        Args:\n            agent_name: Name of the agent\n\n        Returns:\n            Dictionary with status info\n        \"\"\"\n        client = self._get_client()\n\n        if client is None:\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"status\": \"running\",\n                \"ready_replicas\": 1,\n            }\n\n        try:\n            k8s = client.AppsV1Api()\n            deployment = k8s.read_namespaced_deployment(name=agent_name, namespace=self.namespace)\n\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"status\": \"running\" if deployment.status.ready_replicas else \"pending\",\n                \"ready_replicas\": deployment.status.ready_replicas or 0,\n                \"replicas\": deployment.spec.replicas,\n            }\n\n        except Exception as e:\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"status\": \"not_found\",\n                \"error\": str(e),\n            }\n\n    def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n        \"\"\"\n        Delete an agent from Kubernetes.\n\n        Args:\n            agent_name: Name of the agent\n\n        Returns:\n     