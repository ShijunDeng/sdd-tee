             header_list=header_list,\n444:                 provider=provider,\n445:                 verbose=verbose,\n446:             )\n447: \n448:             progress.update(task, completed=True)\n449: \n450:         console.print(\n451:             Panel(\n452:                 f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n453:                 f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n454:                 f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n455:                 f\"[bold]Response:[/bold]\",\n456:                 title=\"Invoke Complete\",\n457:                 style=\"green\",\n458:             )\n459:         )\n460: \n461:         import json\n462: \n463:         console.print_json(json.dumps(result[\"response\"], indent=2))\n464: \n465:     except Exception as e:\n466:         _handle_error(e, \"invoke\", verbose)\n467:         raise typer.Exit(code=1)\n468: \n469: \n470: @app.command()\n471: def status(\n472:     workspace: str = typer.Option(\n473:         \".\",\n474:         \"-f\",\n475:         \"--workspace\",\n476:         help=\"Path to the agent workspace directory\",\n477:     ),\n478:     provider: str = typer.Option(\n479:         \"agentcube\",\n480:         \"--provider\",\n481:         help=\"Target provider: 'agentcube' or 'k8s'\",\n482:     ),\n483:     verbose: bool = typer.Option(\n484:         False,\n485:         \"--verbose\",\n486:         help=\"Enable detailed logging\",\n487:     ),\n488: ) -> None:\n489:     \"\"\"\n490:     Check the status of a published agent.\n491: \n492:     Loads workspace metadata and displays agent status in a table.\n493:     \"\"\"\n494:     try:\n495:         if verbose:\n496:             logging.basicConfig(level=logging.DEBUG)\n497: \n498:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n499: \n500:         result = runtime.get_status(\n501:             workspace_path=workspace,\n502:             provider=provider,\n503:         )\n504: \n505:         table = Table(title=f\"Agent Status: {result.get('agent_name', 'Unknown')}\")\n506: \n507:         table.add_column(\"Field\", style=\"cyan\")\n508:         table.add_column(\"Value\", style=\"green\")\n509: \n510:         table.add_row(\"Agent Name\", result.get(\"agent_name\", \"N/A\"))\n511:         table.add_row(\"Agent ID\", result.get(\"agent_id\", \"N/A\"))\n512:         table.add_row(\"Provider\", result.get(\"provider\", \"N/A\"))\n513:         table.add_row(\"Status\", result.get(\"status\", \"unknown\"))\n514:         table.add_row(\"Endpoint\", result.get(\"endpoint\", \"N/A\"))\n515:         table.add_row(\"Namespace\", result.get(\"namespace\", \"N/A\"))\n516: \n517:         if \"error\" in result:\n518:             table.add_row(\"Error\", result[\"error\"])\n519: \n520:         console.print(table)\n521: \n522:         if result.get(\"status\") in [\"not_published\", \"error\"]:\n523:             raise typer.Exit(code=1)\n524: \n525:     except Exception as e:\n526:         _handle_error(e, \"status\", verbose)\n527:         raise typer.Exit(code=1)\n528: \n529: \n530: @app.command()\n531: def version() -> None:\n532:     \"\"\"Show version information.\"\"\"\n533:     console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n534: \n535: \n536: if __name__ == \"__main__\":\n537:     app()\n\n(End of file - total 537 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube CLI - Main entry point for kubectl-agentcube.\"\"\"\n\nimport logging\nfrom typing import List, Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\nfrom rich.panel import Panel\nfrom rich.table import Table\nfrom rich import print as rprint\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.runtime.in