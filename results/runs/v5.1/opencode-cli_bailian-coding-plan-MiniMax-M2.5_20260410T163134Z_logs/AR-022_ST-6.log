None:\n96:             self.logger.warning(\"Using mock AgentRuntime deployment\")\n97:             return {\n98:                 \"name\": agent_name,\n99:                 \"namespace\": self.namespace,\n100:                 \"endpoint\": f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\",\n101:             }\n102: \n103:         try:\n104:             k8s = client\n105:             custom_objects = k8s.CustomObjectsApi()\n106: \n107:             agent_runtime = {\n108:                 \"apiVersion\": f\"{self.CR_GROUP}/{self.CR_VERSION}\",\n109:                 \"kind\": \"AgentRuntime\",\n110:                 \"metadata\": {\n111:                     \"name\": agent_name,\n112:                     \"namespace\": self.namespace,\n113:                 },\n114:                 \"spec\": {\n115:                     \"maxSessionDuration\": \"8h\",\n116:                     \"sessionTimeout\": \"15m\",\n117:                     \"targetPorts\": [\n118:                         {\n119:                             \"port\": port,\n120:                             \"protocol\": \"HTTP\",\n121:                             \"name\": \"http\",\n122:                         }\n123:                     ],\n124:                     \"podTemplate\": {\n125:                         \"spec\": {\n126:                             \"containers\": [\n127:                                 {\n128:                                     \"name\": \"agent\",\n129:                                     \"image\": image_url,\n130:                                     \"resources\": {\n131:                                         \"limits\": {\n132:                                             \"cpu\": \"1\",\n133:                                             \"memory\": \"1Gi\",\n134:                                         }\n135:                                     },\n136:                                 }\n137:                             ]\n138:                         }\n139:   