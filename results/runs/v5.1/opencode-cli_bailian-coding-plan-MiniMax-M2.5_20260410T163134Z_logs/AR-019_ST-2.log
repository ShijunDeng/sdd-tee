o create controller: %v\\n\", err)\n47: \t\tos.Exit(1)\n48: \t}\n49: \n50: \tklog.InfoS(\"Starting agentd controller\")\n51: \tif err := mgr.Start(ctrl.SetupSignalHandler()); err != nil {\n52: \t\tfmt.Fprintf(os.Stderr, \"Failed to start manager: %v\\n\", err)\n53: \t\tos.Exit(1)\n54: \t}\n55: }\n\n(End of file - total 55 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tutilruntime \"k8s.io/apimachinery/pkg/util/runtime\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/metrics/server\"\n\n\t\"sigs.k8s.io/agent-sandbox/api/v1alpha1\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/agentd\"\n\t\"k8s.io/klog/v2\"\n)\n\nvar schemeBuilder = runtime.NewScheme()\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/cmd/agentd/main.go","time":{"start":1775858860458,"end":1775858860481}}}}
