{"type":"tool_use","timestamp":1775858917289,"sessionID":"ses_286908c7bffegIYbqmZvCSrsLL","part":{"id":"prt_d79709be0001uNVfX4G547m0xy","messageID":"msg_d797089850019z5tOqV5LZI1AB","sessionID":"ses_286908c7bffegIYbqmZvCSrsLL","type":"tool","tool":"read","callID":"toolu_3b058791e8524041911ef0b8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/config.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/config.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"time\"\n5: )\n6: \n7: type Config struct {\n8: \tListenAddress       string        // Listen address for the HTTP server (default: \":8080\")\n9: \tBackendTimeout      time.Duration // Timeout for backend requests (default: 30s)\n10: \tIdleTimeout         time.Duration // Idle connection timeout (default: 60s)\n11: \tHealthCheckInterval time.Duration // Health check interval (default: 10s)\n12: \tHealthCheckTimeout  time.Duration // Health check request timeout (default: 5s)\n13: \tMaxConnsPerBackend  int           // Max connections per backend (default: 100)\n14: \tRateLimitEnabled    bool          // Enable rate limiting (default: false)\n15: \tRateLimitRPS        int           // Requests per second for rate limiting (default: 10)\n16: \tAuthEnabled         bool          // Enable authentication (default: false)\n17: \tAuthToken           string        // Bearer token for authentication\n18: \tWatchNamespaces     []string      // Namespaces to watch for CRs (empty = all)\n19: \n20: \t// Session management\n21: \tSessionEnabled         bool          // Enable session management (default: false)\n22: \tSessionTimeout         time.Duration // Session timeout (default: 30m)\n23: \tSessionCookieName      string        // Session cookie name (default: \"AGENTSESSIONID\")\n24: \tSessionMaxActive       int           // Max active sessions (default: 10000)\n25: \tSessionCookieSecure    bool          // Set cookie Secure flag (default: true)\n26: \tSessionCookieHTTPOnly  bool          // Set cookie HttpOnly flag (default: true)\n27: \tSessionCookieDomain    string        // Cookie domain (optional)\n28: \tSessionCleanupInterval time.Duration // Session cleanup interval (default: 5m)\n29: \n30: \t// JWT authentication\n31: \tJWTEnabled           bool          // Enable JWT authentication (default: false)\n32: \tJWTAlgorithm         string        // JWT algorithm: HS256, RS256 (default: \"HS256\")\n33: \tJWTSecret            string        // JWT secret for HS256 (default: \"\")\n34: \tJWTPrivateKeyPath    string        // Path to private key file for RS256\n35: \tJWTPublicKeyPath     string        // Path to public key file for RS256\n36: \tJWTIssuer            string        // JWT issuer (default: \"agentcube\")\n37: \tJWTAudience          []string      // JWT audience (default: nil)\n38: \tJWTExpiration        time.Duration // JWT token expiration (default: 1h)\n39: \tJWTRefreshExpiration time.Duration // JWT refresh token expiration (default: 24h)\n40: \tJWTClockSkew         time.Duration // Clock skew tolerance (default: 30s)\n41: \tJWTAllowQueryParam   bool          // Allow JWT in query parameter (default: false)\n42: }\n43: \n44: func DefaultConfig() *Config {\n45: \treturn &Config{\n46: \t\tListenAddress:          \":8080\",\n47: \t\tBackendTimeout:         30 * time.Second,\n48: \t\tIdleTimeout:            60 * time.Second,\n49: \t\tHealthCheckInterval:    10 * time.Second,\n50: \t\tHealthCheckTimeout:     5 * time.Second,\n51: \t\tMaxConnsPerBackend:     100,\n52: \t\tRateLimitEnabled:       false,\n53: \t\tRateLimitRPS:           10,\n54: \t\tAuthEnabled:            false,\n55: \t\tAuthToken:              \"\",\n56: \t\tWatchNamespaces:        nil,\n57: \t\tSessionEnabled:         false,\n58: \t\tSessionTimeout:         30 * time.Minute,\n59: \t\tSes