{"type":"tool_use","timestamp":1775863672671,"sessionID":"ses_286474d8fffeKqLRB2b8M5keEa","part":{"id":"prt_d79b92bf1001E4fPqM5XS5hOuE","messageID":"msg_d79b92322001vPsaccVfctkozb","sessionID":"ses_286474d8fffeKqLRB2b8M5keEa","type":"tool","tool":"read","callID":"toolu_6c05e2de1d0c4682856e6275","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/status_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/status_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Status runtime for AgentCube - orchestrates the status command workflow.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: from pathlib import Path\n7: from typing import Any, Dict, Optional\n8: \n9: from agentcube.services.metadata_service import MetadataService\n10: from agentcube.services.k8s_provider import KubernetesProvider\n11: from agentcube.services.agentcube_provider import AgentCubeProvider\n12: \n13: \n14: class StatusRuntime:\n15:     \"\"\"\n16:     Core runtime for checking agent status.\n17: \n18:     Retrieves and displays agent status from the target provider.\n19:     \"\"\"\n20: \n21:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\"):\n22:         \"\"\"\n23:         Initialize the StatusRuntime.\n24: \n25:         Args:\n26:             verbose: Enable verbose logging\n27:             provider: Target provider (agentcube or k8s)\n28:         \"\"\"\n29:         self.verbose = verbose\n30:         self.provider = provider\n31:         self.logger = logging.getLogger(__name__)\n32:         if verbose:\n33:             logging.basicConfig(level=logging.DEBUG)\n34:         else:\n35:             logging.basicConfig(level=logging.INFO)\n36: \n37:         self.metadata_service = MetadataService()\n38: \n39:     def _get_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n40:         \"\"\"\n41:         Get status from Kubernetes deployment.\n42: \n43:         Args:\n44:             metadata: Agent metadata\n45: \n46:         Returns:\n47:             Status dictionary\n48:         \"\"\"\n49:         namespace = \"default\"\n50:         if metadata.k8s_deployment and metadata.k8s_deployment.get(\"namespace\"):\n51:             namespace = metadata.k8s_deployment[\"namespace\"]\n52: \n53:         k8s_provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n54: \n55:         agent_name = metadata.agent_id or metadata.agent_name\n56:         status = k8s_provider.get_agent_status(agent_name)\n57: \n58:         return status\n59: \n60:     def _get_cr_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n61:         \"\"\"\n62:         Get status from AgentRuntime CR.\n63: \n64:         Args:\n65:             metadata: Agent metadata\n66: \n67:         Returns:\n68:             Status dictionary\n69:         \"\"\"\n70:         namespace = \"default\"\n71:         if metadata.k8s_deployment and metadata.k8s_deployment.get(\"namespace\"):\n72:             namespace = metadata.k8s_deployment[\"namespace\"]\n73: \n74:         agentcube_provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n75: \n76:         agent_name = metadata.agent_id or metadata.agent_name\n77:         cr = agentcube_provider.get_agent_runtime(agent_name, namespace)\n78: \n79:         if cr:\n80:             return {\n81:                 \"name\": cr.get(\"metadata\", {}).get(\"name\"),\n82:                 \"namespace\": cr.get(\"metadata\", {}).get(\"namespace\"),\n83:                 \"status\": cr.get(\"status\", {}).get(\"phase\", \"Unknown\"),\n84:                 \"endpoint\": cr.get(\"status\", {}).get(\"endpoint\"),\n85:             }\n86: \n87:         return {\n88:             \"name\": agent_name,\n89:             \"namespace\": namespace,\n90:             \"status\": \"not_found\",\n91:         }\n92: \n93:     def get_status(\n94:         self,\n95:         workspace_path: str,\n96:         provider: Optional[str] = None,\n97:     ) -> dict:\n98:         \"\"\"\n99:         Get agent status from the target provider.\n100: \n101:         Args:\n102:             workspace_path: Path to agent workspace\n103:             provider: Target provider (agentcube or k8s)\n104: \n105:         Returns:\n106:             Dictionary with status information\n107: \n108:         Raises:\n109:             ValueError: If agent not published\n110:         \"\"\"\n111:         workspace = Path(workspace_path).resolve()\n112:         provider = provider or self.provider\n113: \n114:         metadata = self.metadata_service.load_metadata(workspace)\n115: \n116:         if not metadata.agent_id and not metadata.agent_endpoint:\n117:             return {\n118:                 \"agent_name\": metadata.agent_name,\n119:                 \"status\": \"not_published\",\n120:                 \"message\": \"Agent not published. Run 'publish' first.\",\n121:             }\n122: \n123:         try:\n124:             if provider == \"agentcube\":\n125:                 status = self._get_cr_k8s_status(metadata)\n126:             else:\n127:                 status = self._get_k8s_status(metadata)\n128: \n129:             return {\n130:                 \"agent_name\": metadata.agent_name,\n131:                 \"agent_id\": metadata.agent_id,\n132:                 \"provider\": provider,\n133:                 \"status\": status.get(\"status\", \"unknown\"),\n134:                 \"endpoint\": status.get(\"endpoint\") or metadata.agent_endpoint,\n135:                 \"namespace\": status.get(\"namespace\", \"default\"),\n136:             }\n137: \n138:         except Exception as e:\n139:             return {\n140:                 \"agent_name\": metadata.agent_name,\n141:                 \"status\": \"error\",\n142:                 \"error\": str(e),\n143:             }\n\n(End of file - total 143 lines)\n</content>","metadata":{"preview":"\"\"\"Status runtime for AgentCube - orchestrates the status command workflow.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import MetadataService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nclass StatusRuntime:\n    \"\"\"\n    Core runtime for checking agent status.\n\n    Retrieves and displays agent status from the target provider.\n    \"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/status_runtime.py","time":{"start":1775863672658,"end":1775863672668}}}}
