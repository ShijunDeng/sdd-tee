{"type":"tool_use","timestamp":1775862886719,"sessionID":"ses_2865360c9ffeeizJyse5h090bT","part":{"id":"prt_d79ad2d98001VWlyy00QPTE4oQ","messageID":"msg_d79ad1e82001kmSBpBsRm0bvCq","sessionID":"ses_2865360c9ffeeizJyse5h090bT","type":"tool","tool":"read","callID":"toolu_44b0e12771094e93ab4a0fd3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Publish runtime for AgentCube - orchestrates the publish command workflow.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: from pathlib import Path\n7: from typing import Any, Dict, Optional\n8: \n9: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n10: from agentcube.services.k8s_provider import KubernetesProvider\n11: from agentcube.services.agentcube_provider import AgentCubeProvider\n12: \n13: \n14: class PublishRuntime:\n15:     \"\"\"\n16:     Core runtime for publishing agent runtimes.\n17: \n18:     Handles deployment to either AgentCube or Kubernetes provider.\n19:     \"\"\"\n20: \n21:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\"):\n22:         \"\"\"\n23:         Initialize the PublishRuntime.\n24: \n25:         Args:\n26:             verbose: Enable verbose logging\n27:             provider: Target provider (agentcube or k8s)\n28:         \"\"\"\n29:         self.verbose = verbose\n30:         self.provider = provider\n31:         self.logger = logging.getLogger(__name__)\n32:         if verbose:\n33:             logging.basicConfig(level=logging.DEBUG)\n34:         else:\n35:             logging.basicConfig(level=logging.INFO)\n36: \n37:         self.metadata_service = MetadataService()\n38: \n39:     def _prepare_image_for_publishing(\n40:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n41:     ) -> str:\n42:         \"\"\"\n43:         Prepare image URL for publishing.\n44: \n45:         Args:\n46:             workspace_path: Path to workspace\n47:             metadata: Agent metadata\n48:             options: Publish options\n49: \n50:         Returns:\n51:             Image URL to use\n52:         \"\"\"\n53:         if options.get(\"image_url\"):\n54:             return options[\"image_url\"]\n55: \n56:         image_name = metadata.agent_name\n57:         tag = metadata.version or \"latest\"\n58: \n59:         registry_url = options.get(\"registry_url\") or metadata.registry_url or \"docker.io\"\n60:         registry_username = options.get(\"registry_username\") or metadata.registry_username\n61: \n62:         if registry_username:\n63:             image_url = f\"{registry_url}/{image_name}:{tag}\"\n64:         else:\n65:             image_url = f\"{image_name}:{tag}\"\n66: \n67:         self.logger.debug(f\"Prepared image URL: {image_url}\")\n68:         return image_url\n69: \n70:     def _publish_cr_to_k8s(\n71:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n72:     ) -> Dict[str, Any]:\n73:         \"\"\"\n74:         Publish using AgentRuntime CR to Kubernetes.\n75: \n76:         Args:\n77:             workspace_path: Path to workspace\n78:             metadata: Agent metadata\n79:             **options: Additional options\n80: \n81:         Returns:\n82:             Dictionary with publish result\n83:         \"\"\"\n84:         agentcube_provider = AgentCubeProvider(\n85:             namespace=options.get(\"namespace\", \"default\"),\n86:             verbose=self.verbose,\n87:         )\n88: \n89:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n90: \n91:         self.logger.debug(f\"Deploying agent runtime: {metadata.agent_name}\")\n92: \n93:         result = agentcube_provider.deploy_agent_runtime(\n94:             agent_name=metadata.agent_name,\n95:             image_url=image_url,\n96:             port=metadata.port,\n97:             entrypoint=metadata.entrypoint,\n98:             env_vars=options.get(\"env_vars\"),\n99:             workload_manager_url=metadata.workload_manager_url,\n100:             router_url=metadata.router_url,\n101:             readiness_probe_path=metadata.readiness_probe_path,\n102:             readiness_probe_port=metadata.readiness_probe_port,\n103:         )\n104: \n105:         return {\n106:             \"agent_name\": metadata.agent_name,\n107:             \"provider\": \"agentcube\",\n108:             \"agent_id\": result.get(\"name\"),\n109:             \"endpoint\": result.get(\"endpoint\"),\n110:             \"status\": \"deployed\",\n111:         }\n112: \n113:     def _publish_k8s(\n114:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n115:     ) -> Dict[str, Any]:\n116:         \"\"\"\n117:         Publish using native Kubernetes Deployment + Service.\n118: \n119:         Args:\n120:             workspace_path: Path to workspace\n121:             metadata: Agent metadata\n122:             **options: Additional options\n123: \n124:         Returns:\n125:             Dictionary with publish result\n126:         \"\"\"\n127:         k8s_provider = KubernetesProvider(\n128:             namespace=options.get(\"namespace\", \"default\"),\n129:             verbose=self.verbose,\n130:         )\n131: \n132:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n133: \n134:         replicas = options.get(\"replicas\", 1)\n135:         node_port = options.get(\"node_port\")\n136: \n137:         if node_port and (node_port < 30000 or node_port > 32767):\n138:             raise ValueError(\"NodePort must be between 30000 and 32767\")\n139: \n140:         self.logger.debug(f\"Deploying to Kubernetes: {metadata.agent_name}\")\n141: \n142:         result = k8s_provider.deploy_agent(\n143:             agent_name=metadata.agent_name,\n144:             image_url=image_url,\n145:             port=metadata.port,\n146:             entrypoint=metadata.entrypoint,\n147:             replicas=replicas,\n148:             node_port=node_port,\n149:             env_vars=options.get(\"env_vars\"),\n150:         )\n151: \n152:         return {\n153:             \"agent_name\": metadata.agent_name,\n154:             \"provider\": \"k8s\",\n155:             \"deployment\": result.get(\"name\"),\n156:             \"service\": result.get(\"service\"),\n157:             \"endpoint\": result.get(\"endpoint\"),\n158:             \"status\": \"deployed\",\n159:         }\n160: \n161:     def publish(\n162:         self,\n163:         workspace_path: str,\n164:         version: Optional[str] = None,\n165:         image_url: Optional[str] = None,\n166:         image_username: Optional[str] = None,\n167:         image_password: Optional[str] = None,\n168:         description: Optional[str] = None,\n169:         region: Optional[str] = None,\n170:         cloud_provider: Optional[str] = None,\n171:         provider: str = \"agentcube\",\n172:         node_port: Optional[int] = None,\n173:         replicas: Optional[int] = None,\n174:         namespace: Optional[str] = None,\n175:         verbose: bool = False,\n176:     ) -> dict:\n177:         \"\"\"\n178:         Publish an agent to the target provider.\n179: \n180:         Args:\n181:             workspace_path: Path to agent workspace\n182:             version: Semantic version string\n183:             image_url: Image repository URL\n184:             image_username: Username for image repository\n185:             image_password: Password for image repository\n186:             description: Agent description\n187:             region: Deployment region\n188:             cloud_provider: Cloud provider name\n189:             provider: Target provider (agentcube or k8s)\n190:             node_port: NodePort (30000-32767)\n191:             replicas: Number of replicas\n192:             namespace: Deployment namespace\n193:             verbose: Enable verbose logging\n194: \n195:         Returns:\n196:             Dictionary with publish result\n197: \n198:         Raises:\n199:             ValueError: If publish fails\n200:         \"\"\"\n201:         workspace = Path(workspace_path).resolve()\n202: \n203:         metadata = self.metadata_service.load_metadata(workspace)\n204: \n205:         if version:\n206:             metadata.version = version\n207:         if description:\n208:             metadata.description = description\n209:         if region:\n210:             metadata.region = region\n211:         if image_url:\n212:             metadata.image = metadata.image or {}\n213:             metadata.image[\"url\"] = image_url\n214: \n215:         options = {\n216:             \"image_url\": image_url,\n217:             \"image_username\": image_username,\n218:             \"image_password\": image_password,\n219:             \"region\": region,\n220:             \"cloud_provider\": cloud_provider,\n221:             \"node_port\": node_port,\n222:             \"replicas\": replicas,\n223:             \"namespace\": namespace,\n224:             \"registry_url\": metadata.registry_url,\n225:             \"registry_username\": metadata.registry_username,\n226:             \"registry_password\": metadata.registry_password,\n227:         }\n228: \n229:         try:\n230:             if provider == \"agentcube\":\n231:                 result = self._publish_cr_to_k8s(workspace, metadata, **options)\n232:             else:\n233:                 result = self._publish_k8s(workspace, metadata, **options)\n234: \n235:             metadata.agent_id = result.get(\"agent_id\") or result.get(\"deployment\")\n236:             metadata.agent_endpoint = result.get(\"endpoint\")\n237: \n238:             if result.get(\"status\") == \"deployed\":\n239:                 metadata.k8s_deployment = {\n240:                     \"name\": result.get(\"deployment\") or result.get(\"agent_id\"),\n241:                     \"provider\": provider,\n242:                     \"namespace\": namespace or \"default\",\n243:                 }\n244: \n245:             self.metadata_service.save_metadata(workspace, metadata)\n246: \n247:             return {\n248:                 \"agent_name\": metadata.agent_name,\n249:                 \"provider\": provider,\n250:                 \"endpoint\": result.get(\"endpoint\"),\n251:                 \"status\": result.get(\"status\"),\n252:             }\n253: \n254:         except Exception as e:\n255:             raise ValueError(f\"Publish failed: {e}\")\n\n(End of file - total 255 lines)\n</content>","metadata":{"preview":"\"\"\"Publish runtime for AgentCube - orchestrates the publish command workflow.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nclass PublishRuntime:\n    \"\"\"\n    Core runtime for publishing agent runtimes.\n\n    Handles deployment to either AgentCube or Kubernetes provider.\n    \"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py","time":{"start":1775862886711,"end":1775862886717}}}}
