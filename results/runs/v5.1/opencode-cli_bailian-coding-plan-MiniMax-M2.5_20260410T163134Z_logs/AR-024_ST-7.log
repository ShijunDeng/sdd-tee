ython:3.11-slim\")\n222: \n223:             service = DockerService(verbose=False)\n224:             result = service.build_image(\n225:                 dockerfile_path=dockerfile,\n226:                 context_path=workspace,\n227:                 image_name=\"myagent\",\n228:             )\n229: \n230:             assert \"image_name\" in result\n231:             assert \"image_id\" in result\n232:             assert \"image_size\" in result\n233:             assert \"build_time\" in result\n234: \n235:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n236:     def test_build_image_with_custom_tag(self, mock_from_env):\n237:         \"\"\"Test building image with custom tag (AR-024-002-B).\"\"\"\n238:         mock_image = MagicMock()\n239:         mock_image.id = \"sha256:abc123\"\n240:         mock_image.attrs = {\"Size\": 1024000}\n241: \n242:         mock_build_output = (mock_image,)\n243:         mock_client = MagicMock()\n244:         mock_client.images.build.return_value = mock_build_output\n245:         mock_from_env.return_value = mock_client\n246: \n247:         with tempfile.TemporaryDirectory() as tmpdir:\n248:             workspace = Path(tmpdir)\n249:             dockerfile = workspace / \"Dockerfile\"\n250:             dockerfile.write_text(\"FROM python:3.11-slim\")\n251: \n252:             service = DockerService(verbose=False)\n253:             result = service.build_image(\n254:                 dockerfile_path=dockerfile,\n255:                 context_path=workspace,\n256:                 image_name=\"myagent\",\n257:                 tag=\"v1.0.0\",\n258:             )\n259: \n260:             assert result[\"image_name\"] == \"myagent:v1.0.0\"\n261: \n262:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n263:     def test_build_image_with_build_args(self, mock_from_env):\n264:         \"\"\"Test building image with build args (AR-024-002-C).\"\"\"\n265:         mock_image = MagicMock()\n266:         mock_image.id = \"sha256:abc123\"\n267:         mock_image.attrs = {\"Size\": 1024000}\n268: \n269:         mock_build_output = (mock_image,)\n270:         mock_client = MagicMock()\n271:         mock_client.images.build.return_value = mock_build_output\n272:         mock_from_env.return_value = mock_client\n273: \n274:         with tempfile.TemporaryDirectory() as tmpdir:\n275:             workspace = Path(tmpdir)\n276:             dockerfile = workspace / \"Dockerfile\"\n277:             dockerfile.write_text(\"FROM python:3.11-slim\")\n278: \n279:             service = DockerService(verbose=False)\n280:             build_args = {\"PROXY\": \"http://proxy:8080\"}\n281:             result = service.build_image(\n282:                 dockerfile_path=dockerfile,\n283:                 context_path=workspace,\n284:                 image_name=\"myagent\",\n285:                 build_args=build_args,\n286:             )\n287: \n288:             mock_client.images.build.assert_called_once()\n289:             call_kwargs = mock_client.images.build.call_args.kwargs\n290:             assert call_kwargs[\"buildargs\"] == build_args\n291: \n292: \n293: class TestDockerServiceGetImageInfo:\n294:     \"\"\"Tests for DockerService.get_image_info method.\"\"\"\n295: \n296:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n297:     def test_get_image_info_existing(self, mock_from_env):\n298:         \"\"\"Test getting image info for existing image (AR-024-003-A).\"\"\"\n299:         mock_image = MagicMock()\n300:         mock_image.id = \"sha256:abc123\"\n301:         mock_image.tags = [\"myagent:latest\", \"myagent:v1.0.0\"]\n302:         mock_image.attrs = {\"Size\": 1024000, \"Created\": \"2024-01-01T00:00:00Z\"}\n303: \n304:         mock_client = MagicMock()\n305:         mock_client.images.get.return_value = mock_image\n306:         mock_from_env.return_value = mock_client\n307: \n308:         service = DockerService(verbose=False)\n309:         result = service.get_image_info(\"myagent:latest\")\n310: \n311:         assert \"id\" in result\n312:         assert \"tags\" in result\n313:         assert \"size\" in result\n314:         assert \"created\" in result\n315: \n316:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n317:     def test_get_image_info_not_found(self, mock_from_env):\n318:         \"\"\"Test getting image info for non-existent image (AR-024-003-B).\"\"\"\n319:         from docker.errors import NotFound\n320: \n321:         mock_client = MagicMock()\n322:         mock_client.images.get.side_effect = NotFound(\"Image not found\")\n323:         mock_from_env.return_value = mock_client\n324: \n325:         service = DockerService(verbose=False)\n326: \n327:         with pytest.raises(ValueError, match=\"Image not found\"):\n328:             service.get_image_info(\"nonexistent:latest\")\n329: \n330: \n331: class TestDockerServicePushImage:\n332:     \"\"\"Tests for DockerService.push_image method.\"\"\"\n333: \n334:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n335:     def test_push_image_without_auth(self, mock_from_env):\n336:         \"\"\"Test pushing image without authentication (AR-024-004-A).\"\"\"\n337:         mock_image = MagicMock()\n338:         mock_client = MagicMock()\n339:         mock_client.images.get.return_value = mock_image\n340:         mock_from_env.return_value = mock_client\n341: \n342:         service = DockerService(verbose=False)\n343:         result = service.push_image(\"myagent:latest\", registry_url=\"registry.example.com\")\n344: \n345:         assert \"pushed_image\" in result\n346:         assert \"push_time\" in result\n347: \n348:     @patch(\"agentcube.services.docker_service.DockerService._docker_login_sdk\")\n349:     @patch(\"agentcube.services.docker_service.DockerService._tag_image_sdk\")\n350:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n351:     def test_push_image_with_auth(self, mock_from_env, mock_tag, mock_login):\n352:         \"\"\"Test pushing image with authentication (AR-024-004-B).\"\"\"\n353:         mock_image = MagicMock()\n354:         mock_client = MagicMock()\n355:         mock_client.images.get.return_value = mock_image\n356:         mock_client.api.push.return_value = iter([])\n357:         mock_from_env.return_value = mock_client\n358: \n359:         service = DockerService(verbose=False)\n360:         result = service.push_image(\n361:             \"myagent:latest\",\n362:             registry_url=\"registry.example.com\",\n363:             username=\"user\",\n364:             password=\"pass\",\n365:         )\n366: \n367:         mock_login.assert_called_once_with(\"registry.example.com\", \"user\", \"pass\")\n368:         mock_tag.assert_called_once()\n369:         assert \"pushed_image\" in result\n370:         assert \"push_time\" in result\n371: \n372: \n373: class TestDockerServiceRemoveImage:\n374:     \"\"\"Tests for DockerService.remove_image method.\"\"\"\n375: \n376:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n377:     def test_remove_existing_image(self, mock_from_env):\n378:         \"\"\"Test removing existing image (AR-024-005-A).\"\"\"\n379:         mock_client = MagicMock()\n380:         mock_from_env.return_value = mock_client\n381: \n382:         service = DockerService(verbose=False)\n383:         result = service.remove_image(\"myagent:latest\")\n384: \n385:         assert result is True\n386:         mock_client.images.remove.assert_called_once_with(\"myagent:latest\")\n387: \n388:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n389:     def test_remove_non_existent_image(self, mock_from_env):\n390:         \"\"\"Test removing non-existent image (AR-024-005-B).\"\"\"\n391:         from docker.errors import NotFound\n392: \n393:         mock_client = MagicMock()\n394:         mock_client.images.remove.side_effect = NotFound(\"Image not found\")\n395:         mock_from_env.return_value = mock_client\n396: \n397:         service = DockerService(verbose=False)\n398:         result = service.remove_image(\"nonexistent:latest\")\n399: \n400:         assert result is False\n401: \n402: \n403: class TestDockerServiceVerboseLogging:\n404:     \"\"\"Tests for DockerService verbose logging support.\"\"\"\n405: \n406:     def test_verbose_mode_sets_verbose_flag(self):\n407:         \"\"\"Test verbose mode sets verbose flag (AR-024-009-A).\"\"\"\n408:         service = DockerService(verbose=True)\n409:         assert service.verbose is True\n410: \n411:     def test_non_verbose_mode_sets_verbose_flag(self):\n412:         \"\"\"Test non-verbose mode sets verbose flag.\"\"\"\n413:         service = DockerService(verbose=False)\n414:         assert service.verbose is False\n415: \n416: \n417: class TestDockerServiceErrorHandling:\n418:     \"\"\"Tests for DockerService error handling.\"\"\"\n419: \n420:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n421:     def test_handle_generic_docker_exception(self, mock_from_env):\n422:         \"\"\"Test handling generic Docker exception (AR-024-011-A).\"\"\"\n423:         mock_from_env.side_effect = Exception(\"Unexpected error\")\n424: \n425:         service = DockerService(verbose=False)\n426:         result = service.check_docker_available()\n427: \n428:         assert result is False\n\n(End of file - total 428 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for DockerService.\"\"\"\n\nimport logging\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestDockerServicePython:\n    \"\"\"Tests for DockerService.generate_python_dockerfile method.\"\"\"\n\n    def test_generates_python_dockerfile(self):\n        \"\"\"Test generating Python Dockerfile.\"\"\"\n        metadata = AgentMetadata(\n            a