{"type":"tool_use","timestamp":1775865569205,"sessionID":"ses_2862a2595ffenlv6DmPZBvKGaP","part":{"id":"prt_d79d61b66001xah38v8Jt419xZ","messageID":"msg_d79d61141001sB8orryL3P6AY3","sessionID":"ses_2862a2595ffenlv6DmPZBvKGaP","type":"tool","tool":"read","callID":"toolu_9615d92d42774b63878be043","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Docker service for AgentCube - handles Dockerfile generation and Docker operations.\"\"\"\n2: \n3: import logging\n4: import time\n5: from pathlib import Path\n6: from typing import Any, Dict, Optional\n7: \n8: import docker\n9: from docker.errors import APIError as DockerAPIError\n10: from docker.errors import BuildError, DockerException, NotFound\n11: \n12: from agentcube.services.metadata_service import AgentMetadata\n13: \n14: \n15: class DockerService:\n16:     \"\"\"Service for Docker-related operations.\"\"\"\n17: \n18:     def __init__(self, verbose: bool = False):\n19:         self.verbose = verbose\n20:         self.logger = logging.getLogger(__name__)\n21:         if verbose:\n22:             logging.basicConfig(level=logging.DEBUG)\n23:         else:\n24:             logging.basicConfig(level=logging.INFO)\n25: \n26:     @staticmethod\n27:     def generate_python_dockerfile(metadata: AgentMetadata) -> str:\n28:         \"\"\"\n29:         Generate Dockerfile content for Python agents.\n30: \n31:         Args:\n32:             metadata: AgentMetadata with agent configuration\n33: \n34:         Returns:\n35:             Dockerfile content as string\n36:         \"\"\"\n37:         lines = [\n38:             \"FROM python:3.11-slim\",\n39:             \"\",\n40:             \"WORKDIR /app\",\n41:             \"\",\n42:         ]\n43: \n44:         if metadata.requirements_file:\n45:             lines.append(f\"COPY {metadata.requirements_file} .\")\n46:             lines.append(f\"RUN pip install --no-cache-dir -r {metadata.requirements_file}\")\n47:             lines.append(\"\")\n48: \n49:         lines.append(\"COPY . .\")\n50:         lines.append(\"\")\n51:         lines.append(f\"EXPOSE {metadata.port}\")\n52:         lines.append(\"\")\n53: \n54:         if metadata.entrypoint:\n55:             entrypoint_cmd = metadata.entrypoint\n56:         else:\n57:             entrypoint_cmd = \"python main.py\"\n58: \n59:         lines.append(f\"CMD {entrypoint_cmd}\")\n60: \n61:         return \"\\n\".join(lines)\n62: \n63:     @staticmethod\n64:     def generate_java_dockerfile(metadata: AgentMetadata) -> str:\n65:         \"\"\"\n66:         Generate Dockerfile content for Java agents.\n67: \n68:         Args:\n69:             metadata: AgentMetadata with agent configuration\n70: \n71:         Returns:\n72:             Dockerfile content as string\n73:         \"\"\"\n74:         lines = [\n75:             \"FROM maven:3.9-eclipse-temurin-17 AS build\",\n76:             \"\",\n77:             \"WORKDIR /app\",\n78:             \"\",\n79:             \"COPY pom.xml .\",\n80:             \"RUN mvn dependency:go-offline -B\",\n81:             \"\",\n82:             \"COPY src ./src\",\n83:             \"RUN mvn package -DskipTests\",\n84:             \"\",\n85:             \"FROM eclipse-temurin:17-jre\",\n86:             \"\",\n87:             \"WORKDIR /app\",\n88:             \"\",\n89:             \"COPY --from=build /app/target/*.jar app.jar\",\n90:             \"\",\n91:             f\"EXPOSE {metadata.port}\",\n92:             \"\",\n93:         ]\n94: \n95:         if metadata.entrypoint:\n96:             entrypoint_cmd = metadata.entrypoint\n97:         else:\n98:             entrypoint_cmd = \"java -jar app.jar\"\n99: \n100:         lines.append(f'CMD [\"{entrypoint_cmd}\"]')\n101: \n102:         return \"\\n\".join(lines)\n103: \n104:     @staticmethod\n105:     def write_dockerfile(workspace_path: Path, content: str) -> Path:\n106:         \"\"\"\n107:         Write Dockerfile content to workspace.\n108: \n109:         Args:\n110:             workspace_path: Path to workspace directory\n111:             content: Dockerfile content\n112: \n113:         Returns:\n114:             Path to the written Dockerfile\n115:         \"\"\"\n116:         dockerfile_path = workspace_path / \"Dockerfile\"\n117: \n118:         with open(dockerfile_path, \"w\", encoding=\"utf-8\") as f:\n119:             f.write(content)\n120: \n121:         return dockerfile_path\n122: \n123:     @staticmethod\n124:     def _format_size(size_bytes: int) -> str:\n125:         \"\"\"\n126:         Format byte size to human-readable string.\n127: \n128:         Args:\n129:             size_bytes: Size in bytes\n130: \n131:         Returns:\n132:             Formatted size string (e.g., \"1.00 KB\", \"10.00 MB\", \"1.00 GB\")\n133:         \"\"\"\n134:         if size_bytes < 1024:\n135:             return f\"{size_bytes} B\"\n136:         elif size_bytes < 1024 * 1024:\n137:             return f\"{size_bytes / 1024:.2f} KB\"\n138:         elif size_bytes < 1024 * 1024 * 1024:\n139:             return f\"{size_bytes / (1024 * 1024):.2f} MB\"\n140:         else:\n141:             return f\"{size_bytes / (1024 * 1024 * 1024):.2f} GB\"\n142: \n143:     def _get_image_info(self, image_name: str) -> Dict[str, Any]:\n144:         \"\"\"\n145:         Get image info with formatted size (internal method).\n146: \n147:         Args:\n148:             image_name: Name of the image\n149: \n150:         Returns:\n151:             Dictionary with image info including formatted size\n152:         \"\"\"\n153:         client = docker.from_env()\n154:         image = client.images.get(image_name)\n155:         size_bytes = image.attrs.get(\"Size\", 0)\n156: \n157:         return {\n158:             \"id\": image.id,\n159:             \"tags\": image.tags,\n160:             \"size\": self._format_size(size_bytes),\n161:             \"size_bytes\": size_bytes,\n162:         }\n163: \n164:     def _docker_login_sdk(self, registry: Optional[str], username: str, password: str) -> None:\n165:         \"\"\"\n166:         Login to Docker registry using SDK.\n167: \n168:         Args:\n169:             registry: Registry URL\n170:             username: Username for authentication\n171:             password: Password for authentication\n172: \n173:         Raises:\n174:             DockerAPIError: If login fails\n175:         \"\"\"\n176:         try:\n177:             client = docker.from_env()\n178:             client.login(username=username, password=password, registry=registry)\n179:             if self.verbose:\n180:                 self.logger.debug(f\"Successfully logged in to registry: {registry}\")\n181:         except DockerAPIError as e:\n182:             self.logger.error(f\"Failed to login to registry {registry}: {e}\")\n183:             raise\n184: \n185:     def _tag_image_sdk(self, source_image: str, target_image: str) -> None:\n186:         \"\"\"\n187:         Tag an image with a new tag using SDK.\n188: \n189:         Args:\n190:             source_image: Source image name\n191:             target_image: Target image name with tag\n192: \n193:         Raises:\n194:             DockerAPIError: If tagging fails\n195:         \"\"\"\n196:         try:\n197:             client = docker.from_env()\n198:             image = client.images.get(source_image)\n199:             image.tag(target_image)\n200:             if self.verbose:\n201:                 self.logger.debug(f\"Tagged image {source_image} as {target_image}\")\n202:         except (NotFound, DockerAPIError) as e:\n203:             self.logger.error(f\"Failed to tag image {source_image}: {e}\")\n204:             raise\n205: \n206:     def check_docker_available(self) -> bool:\n207:         \"\"\"\n208:         Check if Docker is available and running.\n209: \n210:         Returns:\n211:             True if Docker is available, False otherwise\n212:         \"\"\"\n213:         try:\n214:             client = docker.from_env()\n215:             client.ping()\n216:             self.logger.debug(\"Docker is available\")\n217:             return True\n218:         except DockerException:\n219:             self.logger.warning(\"Docker is not available\")\n220:             return False\n221:         except (ConnectionError, FileNotFoundError):\n222:             self.logger.warning(\"Docker socket not available\")\n223:             return False\n224:         except Exception as e:\n225:             self.logger.warning(f\"Docker availability check failed: {e}\")\n226:             return False\n227: \n228:     def build_image(\n229:         self,\n230:         dockerfile_path: Path,\n231:         context_path: Path,\n232:         image_name: str,\n233:         tag: str = \"latest\",\n234:         build_args: Optional[Dict[str, str]] = None,\n235:     ) -> Dict[str, Any]:\n236:         \"\"\"\n237:         Build a Docker image from a Dockerfile.\n238: \n239:         Args:\n240:             dockerfile_path: Path to the Dockerfile\n241:             context_path: Build context path\n242:             image_name: Name for the image\n243:             tag: Tag for the image\n244:             build_args: Build arguments for docker build\n245: \n246:         Returns:\n247:             Dictionary with image info (image_name, image_id, image_size, build_time)\n248:         \"\"\"\n249:         try:\n250:             client = docker.from_env()\n251:             image_tag = f\"{image_name}:{tag}\"\n252: \n253:             if self.verbose:\n254:                 self.logger.debug(f\"Building image: {image_tag}\")\n255: \n256:             start_time = time.time()\n257:             build_output = client.images.build(\n258:                 path=str(context_path),\n259:                 dockerfile=str(dockerfile_path),\n260:                 tag=image_tag,\n261:                 buildargs=build_args or {},\n262:                 rm=True,\n263:             )\n264:             build_time = time.time() - start_time\n265: \n266:             image = build_output[0]\n267:             size_bytes = image.attrs.get(\"Size\", 0)\n268: \n269:             if self.verbose:\n270:                 self.logger.debug(f\"Image built successfully: {image.id}\")\n271: \n272:             return {\n273:                 \"image_name\": image_tag,\n274:                 \"image_id\": image.id,\n275:                 \"image_size\": self._format_size(size_bytes),\n276:                 \"image_size_bytes\": size_bytes,\n277:                 \"build_time\": f\"{build_time:.2f}s\",\n278:             }\n279:         except BuildError as e:\n280:             self.logger.error(f\"Build failed: {e}\")\n281:             raise ValueError(f\"Docker build failed: {e}\")\n282:         except DockerAPIError as e:\n283:             self.logger.error(f\"Docker API error: {e}\")\n284:             raise ValueError(f\"Docker API error: {e}\")\n285:         except Exception as e:\n286:             self.logger.error(f\"Unexpected error during build: {e}\")\n287:             raise\n288: \n289:     def get_image_info(self, image_name: str) -> Dict[str, Any]:\n290:         \"\"\"\n291:         Get information about a Docker image.\n292: \n293:         Args:\n294:             image_name: Name of the image\n295: \n296:         Returns:\n297:             Dictionary with image info (id, tags, size, created)\n298:         \"\"\"\n299:         try:\n300:             client = docker.from_env()\n301:             image = client.images.get(image_name)\n302:             size_bytes = image.attrs.get(\"Size\", 0)\n303:             created = image.attrs.get(\"Created\", \"\")\n304: \n305:             return {\n306:                 \"id\": image.id,\n307:                 \"tags\": image.tags,\n308:                 \"size\": self._format_size(size_bytes),\n309:                 \"size_bytes\": size_bytes,\n310:                 \"created\": created,\n311:             }\n312:         except NotFound:\n313:             raise ValueError(f\"Image not found: {image_name}\")\n314:         except DockerAPIError as e:\n315:             raise ValueError(f\"Docker API error: {e}\")\n316:         except Exception as e:\n317:             self.logger.error(f\"Unexpected error getting image info: {e}\")\n318:             raise\n319: \n320:     def push_image(\n321:         self,\n322:         image_name: str,\n323:         registry_url: Optional[str] = None,\n324:         username: Optional[str] = None,\n325:         password: Optional[str] = None,\n326:     ) -> Dict[str, str]:\n327:         \"\"\"\n328:         Push a Docker image to a registry.\n329: \n330:         Args:\n331:             image_name: Name of the image to push\n332:             registry_url: Registry URL\n333:             username: Username for authentication\n334:             password: Password for authentication\n335: \n336:         Returns:\n337:             Dictionary with push status (pushed_image, push_time)\n338:         \"\"\"\n339:         try:\n340:             client = docker.from_env()\n341:             target_image = image_name\n342: \n343:             if registry_url and username and password:\n344:                 self._docker_login_sdk(registry_url, username, password)\n345: \n346:                 if registry_url not in image_name:\n347:                     target_image = f\"{registry_url}/{image_name}\"\n348:                     self._tag_image_sdk(image_name, target_image)\n349:                     if self.verbose:\n350:                         self.logger.debug(f\"Retagged image to: {target_image}\")\n351: \n352:             if self.verbose:\n353:                 self.logger.debug(f\"Pushing image: {target_image}\")\n354: \n355:             start_time = time.time()\n356:             client.api.push(target_image, stream=True, decode=True)\n357:             for line in client.api.push(target_image, stream=True, decode=True):\n358:                 if \"status\" in line and self.verbose:\n359:                     self.logger.debug(line[\"status\"])\n360: \n361:             push_time = time.time() - start_time\n362: \n363:             return {\n364:                 \"pushed_image\": target_image,\n365:                 \"push_time\": f\"{push_time:.2f}s\",\n366:             }\n367:         except NotFound:\n368:             raise ValueError(f\"Image not found: {image_name}\")\n369:         except DockerAPIError as e:\n370:             raise ValueError(f\"Docker API error: {e}\")\n371:         except Exception as e:\n372:             self.logger.error(f\"Unexpected error during push: {e}\")\n373:             raise\n374: \n375:     def remove_image(self, image_name: str) -> bool:\n376:         \"\"\"\n377:         Remove a Docker image.\n378: \n379:         Args:\n380:             image_name: Name of the image to remove\n381: \n382:         Returns:\n383:             True if successful, False if image doesn't exist or removal fails\n384:         \"\"\"\n385:         try:\n386:             client = docker.from_env()\n387:             client.images.remove(image_name)\n388:             if self.verbose:\n389:                 self.logger.debug(f\"Image removed: {image_name}\")\n390:             return True\n391:         except NotFound:\n392:             self.logger.warning(f\"Image not found: {image_name}\")\n393:             return False\n394:         except DockerAPIError as e:\n395:             self.logger.warning(f\"Failed to remove image {image_name}: {e}\")\n396:             return False\n397:         except Exception as e:\n398:             self.logger.warning(f\"Unexpected error removing image {image_name}: {e}\")\n399:             return False\n\n(End of file - total 399 lines)\n</content>","metadata":{"preview":"\"\"\"Docker service for AgentCube - handles Dockerfile generation and Docker operations.\"\"\"\n\nimport logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport docker\nfrom docker.errors import APIError as DockerAPIError\nfrom docker.errors import BuildError, DockerException, NotFound\n\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass DockerService:\n    \"\"\"Service for Docker-related operations.\"\"\"\n\n    def __init__(self, verbose: bool = False):\n        self.verbose = verbose\n        self.logger = logging.getLogger(__name__)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/docker_service.py","time":{"start":1775865569195,"end":1775865569203}}}}
