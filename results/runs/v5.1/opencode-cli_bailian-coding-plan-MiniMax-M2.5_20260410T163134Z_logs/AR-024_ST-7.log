{"type":"tool_use","timestamp":1775865579672,"sessionID":"ses_2862a2595ffenlv6DmPZBvKGaP","part":{"id":"prt_d79d645d6001C5PwFbJEvtt78b","messageID":"msg_d79d61ff00010vaWf42Nzzn754","sessionID":"ses_2862a2595ffenlv6DmPZBvKGaP","type":"tool","tool":"read","callID":"toolu_483ed650b41546dcba910cd8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/pack_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/pack_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Pack runtime for AgentCube - orchestrates the pack command workflow.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: import os\n7: from pathlib import Path\n8: from typing import Optional\n9: \n10: from agentcube.models.pack_models import MetadataOptions\n11: from agentcube.services.docker_service import DockerService\n12: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n13: \n14: \n15: class PackRuntime:\n16:     \"\"\"\n17:     Core runtime for packing agent workspaces.\n18: \n19:     Orchestrates validation, metadata loading, dependency processing,\n20:     Dockerfile generation, and output preparation.\n21:     \"\"\"\n22: \n23:     def __init__(self, verbose: bool = False):\n24:         \"\"\"\n25:         Initialize the PackRuntime.\n26: \n27:         Args:\n28:             verbose: Enable verbose logging\n29:         \"\"\"\n30:         self.verbose = verbose\n31:         self.logger = logging.getLogger(__name__)\n32:         if verbose:\n33:             logging.basicConfig(level=logging.DEBUG)\n34:         else:\n35:             logging.basicConfig(level=logging.INFO)\n36: \n37:         self.metadata_service = MetadataService()\n38:         self.docker_service = DockerService()\n39: \n40:     def _validate_workspace_structure(self, workspace_path: Path) -> None:\n41:         \"\"\"\n42:         Validate that workspace path exists and is a directory.\n43: \n44:         Args:\n45:             workspace_path: Path to validate\n46: \n47:         Raises:\n48:             ValueError: If workspace doesn't exist or isn't a directory\n49:         \"\"\"\n50:         if not workspace_path.exists():\n51:             raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n52: \n53:         if not workspace_path.is_dir():\n54:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n55: \n56:         self.logger.debug(f\"Workspace structure validated: {workspace_path}\")\n57: \n58:     def _load_or_create_metadata(\n59:         self, workspace_path: Path, options: MetadataOptions\n60:     ) -> AgentMetadata:\n61:         \"\"\"\n62:         Load existing metadata or create with defaults.\n63: \n64:         Args:\n65:             workspace_path: Path to workspace\n66:             options: CLI options\n67: \n68:         Returns:\n69:             AgentMetadata object\n70: \n71:         Raises:\n72:             FileNotFoundError: If no metadata file exists and agent_name not provided\n73:         \"\"\"\n74:         try:\n75:             metadata = self.metadata_service.load_metadata(workspace_path)\n76:             self.logger.debug(f\"Loaded existing metadata: {metadata.agent_name}\")\n77:         except FileNotFoundError:\n78:             agent_name = options.agent_name or workspace_path.name\n79:             self.logger.debug(f\"Creating new metadata with defaults for: {agent_name}\")\n80:             metadata = AgentMetadata(\n81:                 agent_name=agent_name,\n82:                 language=\"python\",\n83:                 entrypoint=\"python main.py\",\n84:                 port=8080,\n85:                 build_mode=\"local\",\n86:                 requirements_file=\"requirements.txt\",\n87:             )\n88: \n89:         return metadata\n90: \n91:     def _apply_option_overrides(\n92:         self, metadata: AgentMetadata, options: MetadataOptions\n93:     ) -> AgentMetadata:\n94:         \"\"\"\n95:         Apply CLI option overrides to metadata.\n96: \n97:         Args:\n98:             metadata: Base metadata\n99:             options: CLI options\n100: \n101:         Returns:\n102:             Updated AgentMetadata\n103:         \"\"\"\n104:         update_data = {}\n105: \n106:         if options.agent_name is not None:\n107:             update_data[\"agent_name\"] = options.agent_name\n108:         if options.language is not None:\n109:             update_data[\"language\"] = options.language\n110:         if options.entrypoint is not None:\n111:             update_data[\"entrypoint\"] = options.entrypoint\n112:         if options.port is not None:\n113:             update_data[\"port\"] = options.port\n114:         if options.build_mode is not None:\n115:             update_data[\"build_mode\"] = options.build_mode\n116:         if options.description is not None:\n117:             update_data[\"description\"] = options.description\n118:         if options.requirements_file is not None:\n119:             update_data[\"requirements_file\"] = options.requirements_file\n120: \n121:         if update_data:\n122:             metadata = AgentMetadata(**{**metadata.model_dump(), **update_data})\n123:             self.logger.debug(f\"Applied option overrides: {update_data}\")\n124: \n125:         return metadata\n126: \n127:     def _validate_language_compatibility(\n128:         self, workspace_path: Path, metadata: AgentMetadata\n129:     ) -> None:\n130:         \"\"\"\n131:         Validate that the specified language is compatible with workspace contents.\n132: \n133:         Args:\n134:             workspace_path: Path to workspace\n135:             metadata: Agent metadata\n136: \n137:         Raises:\n138:             ValueError: If language doesn't match workspace contents\n139:         \"\"\"\n140:         if metadata.language == \"python\":\n141:             self._validate_python_compatibility(workspace_path)\n142:         elif metadata.language == \"java\":\n143:             self._validate_java_compatibility(workspace_path)\n144: \n145:     def _validate_python_compatibility(self, workspace_path: Path) -> None:\n146:         \"\"\"\n147:         Validate that workspace contains Python files.\n148: \n149:         Args:\n150:             workspace_path: Path to workspace\n151: \n152:         Raises:\n153:             ValueError: If no Python files found\n154:         \"\"\"\n155:         py_files = list(workspace_path.glob(\"*.py\"))\n156:         if not py_files:\n157:             raise ValueError(\"No Python files found in workspace\")\n158: \n159:         self.logger.debug(f\"Found {len(py_files)} Python files\")\n160: \n161:     def _validate_java_compatibility(self, workspace_path: Path) -> None:\n162:         \"\"\"\n163:         Validate that workspace contains pom.xml.\n164: \n165:         Args:\n166:             workspace_path: Path to workspace\n167: \n168:         Raises:\n169:             ValueError: If pom.xml not found\n170:         \"\"\"\n171:         pom_file = workspace_path / \"pom.xml\"\n172:         if not pom_file.exists():\n173:             raise ValueError(\"No pom.xml found in workspace\")\n174: \n175:         self.logger.debug(f\"Found pom.xml\")\n176: \n177:     def _process_dependencies(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n178:         \"\"\"\n179:         Process dependencies based on language.\n180: \n181:         Args:\n182:             workspace_path: Path to workspace\n183:             metadata: Agent metadata\n184:         \"\"\"\n185:         if metadata.language == \"python\":\n186:             self._process_python_dependencies(workspace_path)\n187:         elif metadata.language == \"java\":\n188:             self._process_java_dependencies(workspace_path)\n189: \n190:     def _process_python_dependencies(self, workspace_path: Path) -> None:\n191:         \"\"\"\n192:         Validate Python requirements.txt if it exists.\n193: \n194:         Args:\n195:             workspace_path: Path to workspace\n196:         \"\"\"\n197:         requirements_file = workspace_path / \"requirements.txt\"\n198:         if requirements_file.exists():\n199:             self.logger.debug(f\"Found requirements.txt\")\n200:         else:\n201:             self.logger.warning(\"No requirements.txt found (optional)\")\n202: \n203:     def _process_java_dependencies(self, workspace_path: Path) -> None:\n204:         \"\"\"\n205:         Validate Java pom.xml exists.\n206: \n207:         Args:\n208:             workspace_path: Path to workspace\n209:         \"\"\"\n210:         pom_file = workspace_path / \"pom.xml\"\n211:         if pom_file.exists():\n212:             self.logger.debug(f\"Found pom.xml\")\n213:         else:\n214:             raise ValueError(\"pom.xml is required for Java agents\")\n215: \n216:     def _generate_dockerfile(self, workspace_path: Path, metadata: AgentMetadata) -> Optional[Path]:\n217:         \"\"\"\n218:         Generate Dockerfile if it doesn't exist.\n219: \n220:         Args:\n221:             workspace_path: Path to workspace\n222:             metadata: Agent metadata\n223: \n224:         Returns:\n225:             Path to Dockerfile if generated, None if skipped\n226:         \"\"\"\n227:         dockerfile_path = workspace_path / \"Dockerfile\"\n228: \n229:         if dockerfile_path.exists():\n230:             self.logger.debug(\"Dockerfile already exists, skipping generation\")\n231:             return None\n232: \n233:         if metadata.language == \"python\":\n234:             content = self.docker_service.generate_python_dockerfile(metadata)\n235:         elif metadata.language == \"java\":\n236:             content = self.docker_service.generate_java_dockerfile(metadata)\n237:         else:\n238:             self.logger.warning(f\"Dockerfile generation not supported for {metadata.language}\")\n239:             return None\n240: \n241:         result = self.docker_service.write_dockerfile(workspace_path, content)\n242:         self.logger.debug(f\"Generated Dockerfile at {result}\")\n243:         return result\n244: \n245:     def _prepare_output_path(self, workspace_path: Path, output_path: Optional[str]) -> Path:\n246:         \"\"\"\n247:         Prepare output path for packaged workspace.\n248: \n249:         Args:\n250:             workspace_path: Original workspace path\n251:             output_path: Optional custom output path\n252: \n253:         Returns:\n254:             Output path to use\n255:         \"\"\"\n256:         if output_path:\n257:             output = Path(output_path)\n258:             output.mkdir(parents=True, exist_ok=True)\n259:             self.logger.debug(f\"Using custom output path: {output}\")\n260:             return output\n261: \n262:         return workspace_path\n263: \n264:     def _update_pack_metadata(\n265:         self, workspace_path: Path, metadata: AgentMetadata, dockerfile_path: Optional[Path]\n266:     ) -> Path:\n267:         \"\"\"\n268:         Save final metadata to output path.\n269: \n270:         Args:\n271:             workspace_path: Output workspace path\n272:             metadata: Final metadata\n273:             dockerfile_path: Path to generated Dockerfile\n274: \n275:         Returns:\n276:             Path to saved metadata file\n277:         \"\"\"\n278:         metadata_file = self.metadata_service.save_metadata(workspace_path, metadata)\n279:         self.logger.debug(f\"Saved metadata to {metadata_file}\")\n280:         return metadata_file\n281: \n282:     def _infer_entrypoint(self, workspace_path: Path, language: str) -> Optional[str]:\n283:         \"\"\"\n284:         Infer entrypoint if not explicitly provided.\n285: \n286:         Args:\n287:             workspace_path: Path to workspace\n288:             language: Programming language\n289: \n290:         Returns:\n291:             Inferred entrypoint command or None\n292:         \"\"\"\n293:         if language == \"python\":\n294:             main_py = workspace_path / \"main.py\"\n295:             if main_py.exists():\n296:                 self.logger.debug(\"Inferred entrypoint: python main.py\")\n297:                 return \"python main.py\"\n298: \n299:         elif language == \"java\":\n300:             target_dir = workspace_path / \"target\"\n301:             if target_dir.exists():\n302:                 jars = list(target_dir.glob(\"*.jar\"))\n303:                 if jars:\n304:                     entrypoint = f\"java -jar {jars[0].name}\"\n305:                     self.logger.debug(f\"Inferred entrypoint: {entrypoint}\")\n306:                     return entrypoint\n307: \n308:         return None\n309: \n310:     def pack(\n311:         self,\n312:         workspace_path: str,\n313:         agent_name: Optional[str] = None,\n314:         language: Optional[str] = None,\n315:         entrypoint: Optional[str] = None,\n316:         port: Optional[int] = None,\n317:         build_mode: Optional[str] = None,\n318:         description: Optional[str] = None,\n319:         requirements_file: Optional[str] = None,\n320:         output: Optional[str] = None,\n321:         verbose: bool = False,\n322:     ) -> dict:\n323:         \"\"\"\n324:         Pack an agent workspace for deployment.\n325: \n326:         Args:\n327:             workspace_path: Path to agent workspace\n328:             agent_name: Override agent name\n329:             language: Programming language (python/java)\n330:             entrypoint: Override entrypoint command\n331:             port: Override port\n332:             build_mode: Override build mode (local/cloud)\n333:             description: Override description\n334:             requirements_file: Override requirements file\n335:             output: Custom output path\n336:             verbose: Enable verbose logging\n337: \n338:         Returns:\n339:             Dictionary with pack result details\n340: \n341:         Raises:\n342:             ValueError: If validation fails\n343:             FileNotFoundError: If workspace not found\n344:         \"\"\"\n345:         workspace = Path(workspace_path).resolve()\n346: \n347:         options = MetadataOptions(\n348:             agent_name=agent_name,\n349:             language=language,\n350:             entrypoint=entrypoint,\n351:             port=port,\n352:             build_mode=build_mode,\n353:             description=description,\n354:             requirements_file=requirements_file,\n355:             output=output,\n356:             verbose=verbose,\n357:         )\n358: \n359:         self._validate_workspace_structure(workspace)\n360: \n361:         metadata = self._load_or_create_metadata(workspace, options)\n362: \n363:         if not metadata.entrypoint and not options.entrypoint:\n364:             inferred = self._infer_entrypoint(workspace, metadata.language)\n365:             if inferred:\n366:                 metadata.entrypoint = inferred\n367:                 self.logger.debug(f\"Set inferred entrypoint: {inferred}\")\n368: \n369:         metadata = self._apply_option_overrides(metadata, options)\n370: \n371:         self._validate_language_compatibility(workspace, metadata)\n372: \n373:         self._process_dependencies(workspace, metadata)\n374: \n375:         if metadata.build_mode == \"local\":\n376:             if not self.docker_service.check_docker_available():\n377:                 raise RuntimeError(\"Docker is not available or not running\")\n378: \n379:         dockerfile_path = self._generate_dockerfile(workspace, metadata)\n380: \n381:         output_path = self._prepare_output_path(workspace, output)\n382: \n383:         metadata_file = self._update_pack_metadata(output_path, metadata, dockerfile_path)\n384: \n385:         return {\n386:             \"agent_name\": metadata.agent_name,\n387:             \"workspace_path\": str(workspace),\n388:             \"output_path\": str(output_path),\n389:             \"metadata_file\": str(metadata_file),\n390:             \"dockerfile_generated\": dockerfile_path is not None,\n391:         }\n\n(End of file - total 391 lines)\n</content>","metadata":{"preview":"\"\"\"Pack runtime for AgentCube - orchestrates the pack command workflow.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport os\nfrom pathlib import Path\nfrom typing import Optional\n\nfrom agentcube.models.pack_models import MetadataOptions\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass PackRuntime:\n    \"\"\"\n    Core runtime for packing agent workspaces.\n\n    Orchestrates validation, metadata loading, dependency processing,\n    Dockerfile generation, and output preparation.","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/pack_runtime.py","time":{"start":1775865579654,"end":1775865579669}}}}
