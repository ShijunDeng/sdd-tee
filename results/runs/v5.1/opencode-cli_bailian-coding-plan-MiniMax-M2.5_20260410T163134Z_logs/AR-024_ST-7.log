            assert result == workspace / \"Dockerfile\"\n87:             assert result.exists()\n88:             assert result.read_text() == content\n89: \n90: \n91: class TestDockerServiceFormatSize:\n92:     \"\"\"Tests for DockerService._format_size method.\"\"\"\n93: \n94:     def test_format_bytes_to_kb(self):\n95:         \"\"\"Test formatting bytes to KB (AR-024-006-A).\"\"\"\n96:         result = DockerService._format_size(1024)\n97:         assert result == \"1.00 KB\"\n98: \n99:     def test_format_bytes_to_mb(self):\n100:         \"\"\"Test formatting bytes to MB (AR-024-006-B).\"\"\"\n101:         result = DockerService._format_size(10485760)\n102:         assert result == \"10.00 MB\"\n103: \n104:     def test_format_bytes_to_gb(self):\n105:         \"\"\"Test formatting bytes to GB (AR-024-006-C).\"\"\"\n106:         result = DockerService._format_size(1073741824)\n107:         assert result == \"1.00 GB\"\n108: \n109:     def test_format_bytes_to_b(self):\n110:         \"\"\"Test formatting bytes less than 1KB.\"\"\"\n111:         result = DockerService._format_size(512)\n112:         assert result == \"512 B\"\n113: \n114: \n115: class TestDockerServiceCheckDockerAvailable:\n116:     \"\"\"Tests for DockerService.check_docker_available method.\"\"\"\n117: \n118:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n119:     def test_docker_running_returns_true(self, mock_from_env):\n120:         \"\"\"Test Docker running returns true (AR-024-001-A).\"\"\"\n121:         mock_client = MagicMock()\n122:         mock_client.ping.return_value = True\n123:         mock_from_env.return_value = mock_client\n124: \n125:         service = DockerService(verbose=False)\n126:         result = service.check_docker_available()\n127: \n128:         assert result is True\n129: \n130:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n131:     def test_docker_not_running_returns_false(self, mock_from_env):\n132:         \"\"\"Test Docker not running returns false (AR-024-001-B).\"\"\"\n133:         from docker.errors import DockerException\n134: \n135:         mock_client = MagicMock()\n136:         mock_client.ping.side_effect = DockerException(\"Docker not running\")\n137:         mock_from_env.return_value = mock_client\n138: \n139:         service = DockerService(verbose=False)\n140:         result = service.check_docker_available()\n141: \n142:         assert result is False\n143: \n144:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n145:     def test_docker_not_installed_returns_false(self, mock_from_env):\n146:         \"\"\"Test Docker not installed returns false (AR-024-001-C).\"\"\"\n147:         mock_from_env.side_effect = FileNotFoundError(\"Docker socket not found\")\n148: \n149:         service = DockerService(verbose=False)\n150:         result = service.check_docker_available()\n151: \n152:         assert result is False\n153: \n154: \n155: class TestDockerServiceDockerLogin:\n156:     \"\"\"Tests for DockerService._docker_login_sdk method.\"\"\"\n157: \n158:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n159:     def test_login_to_registry(self, mock_from_env):\n160:         \"\"\"Test login to registry (AR-024-007-A).\"\"\"\n161:         mock_client = MagicMock()\n162:         mock_from_env.return_value = mock_client\n163: \n164:         service = DockerService(verbose=False)\n165:         service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n166: \n167:         mock_client.login.assert_called_once_with(\n168:             username=\"user\", password=\"pass\", registry=\"registry.example.com\"\n169:         )\n170: \n171:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n172:     def test_login_failure(self, mock_from_env):\n173:         \"\"\"Test login failure (AR-024-007-B).\"\"\"\n174:         from docker.errors import APIError\n175: \n176:         mock_client = MagicMock()\n177:         mock_client.logi