{"type":"tool_use","timestamp":1775860774659,"sessionID":"ses_286781ae9ffePQH7omh0Z6i6A3","part":{"id":"prt_d798cf2e3001n7WDXU5ss9kQDJ","messageID":"msg_d798ce88e001ielDy78ZWZ3Hai","sessionID":"ses_286781ae9ffePQH7omh0Z6i6A3","type":"tool","tool":"read","callID":"toolu_2d3dbbd86bd046f8813c82db","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/pack_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/pack_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Pack runtime for AgentCube - orchestrates the pack command workflow.\"\"\"\n2: \n3: import logging\n4: import os\n5: from pathlib import Path\n6: from typing import Optional\n7: \n8: from agentcube.models.pack_models import MetadataOptions\n9: from agentcube.services.docker_service import DockerService\n10: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n11: \n12: \n13: class PackRuntime:\n14:     \"\"\"\n15:     Core runtime for packing agent workspaces.\n16: \n17:     Orchestrates validation, metadata loading, dependency processing,\n18:     Dockerfile generation, and output preparation.\n19:     \"\"\"\n20: \n21:     def __init__(self, verbose: bool = False):\n22:         \"\"\"\n23:         Initialize the PackRuntime.\n24: \n25:         Args:\n26:             verbose: Enable verbose logging\n27:         \"\"\"\n28:         self.verbose = verbose\n29:         self.logger = logging.getLogger(__name__)\n30:         if verbose:\n31:             logging.basicConfig(level=logging.DEBUG)\n32:         else:\n33:             logging.basicConfig(level=logging.INFO)\n34: \n35:         self.metadata_service = MetadataService()\n36:         self.docker_service = DockerService()\n37: \n38:     def _validate_workspace_structure(self, workspace_path: Path) -> None:\n39:         \"\"\"\n40:         Validate that workspace path exists and is a directory.\n41: \n42:         Args:\n43:             workspace_path: Path to validate\n44: \n45:         Raises:\n46:             ValueError: If workspace doesn't exist or isn't a directory\n47:         \"\"\"\n48:         if not workspace_path.exists():\n49:             raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n50: \n51:         if not workspace_path.is_dir():\n52:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n53: \n54:         self.logger.debug(f\"Workspace structure validated: {workspace_path}\")\n55: \n56:     def _load_or_create_metadata(\n57:         self, workspace_path: Path, options: MetadataOptions\n58:     ) -> AgentMetadata:\n59:         \"\"\"\n60:         Load existing metadata or create with defaults.\n61: \n62:         Args:\n63:             workspace_path: Path to workspace\n64:             options: CLI options\n65: \n66:         Returns:\n67:             AgentMetadata object\n68: \n69:         Raises:\n70:             FileNotFoundError: If no metadata file exists and agent_name not provided\n71:         \"\"\"\n72:         try:\n73:             metadata = self.metadata_service.load_metadata(workspace_path)\n74:             self.logger.debug(f\"Loaded existing metadata: {metadata.agent_name}\")\n75:         except FileNotFoundError:\n76:             agent_name = options.agent_name or workspace_path.name\n77:             self.logger.debug(f\"Creating new metadata with defaults for: {agent_name}\")\n78:             metadata = AgentMetadata(\n79:                 agent_name=agent_name,\n80:                 language=\"python\",\n81:                 entrypoint=\"python main.py\",\n82:                 port=8080,\n83:                 build_mode=\"local\",\n84:                 requirements_file=\"requirements.txt\",\n85:             )\n86: \n87:         return metadata\n88: \n89:     def _apply_option_overrides(\n90:         self, metadata: AgentMetadata, options: MetadataOptions\n91:     ) -> AgentMetadata:\n92:         \"\"\"\n93:         Apply CLI option overrides to metadata.\n94: \n95:         Args:\n96:             metadata: Base metadata\n97:             options: CLI options\n98: \n99:         Returns:\n100:             Updated AgentMetadata\n101:         \"\"\"\n102:         update_data = {}\n103: \n104:         if options.agent_name is not None:\n105:             update_data[\"agent_name\"] = options.agent_name\n106:         if options.language is not None:\n107:             update_data[\"language\"] = options.language\n108:         if options.entrypoint is not None:\n109:             update_data[\"entrypoint\"] = options.entrypoint\n110:         if options.port is not None:\n111:             update_data[\"port\"] = options.port\n112:         if options.build_mode is not None:\n113:             update_data[\"build_mode\"] = options.build_mode\n114:         if options.description is not None:\n115:             update_data[\"description\"] = options.description\n116:         if options.requirements_file is not None:\n117:             update_data[\"requirements_file\"] = options.requirements_file\n118: \n119:         if update_data:\n120:             metadata = AgentMetadata(**{**metadata.model_dump(), **update_data})\n121:             self.logger.debug(f\"Applied option overrides: {update_data}\")\n122: \n123:         return metadata\n124: \n125:     def _validate_language_compatibility(\n126:         self, workspace_path: Path, metadata: AgentMetadata\n127:     ) -> None:\n128:         \"\"\"\n129:         Validate that the specified language is compatible with workspace contents.\n130: \n131:         Args:\n132:             workspace_path: Path to workspace\n133:             metadata: Agent metadata\n134: \n135:         Raises:\n136:             ValueError: If language doesn't match workspace contents\n137:         \"\"\"\n138:         if metadata.language == \"python\":\n139:             self._validate_python_compatibility(workspace_path)\n140:         elif metadata.language == \"java\":\n141:             self._validate_java_compatibility(workspace_path)\n142: \n143:     def _validate_python_compatibility(self, workspace_path: Path) -> None:\n144:         \"\"\"\n145:         Validate that workspace contains Python files.\n146: \n147:         Args:\n148:             workspace_path: Path to workspace\n149: \n150:         Raises:\n151:             ValueError: If no Python files found\n152:         \"\"\"\n153:         py_files = list(workspace_path.glob(\"*.py\"))\n154:         if not py_files:\n155:             raise ValueError(\"No Python files found in workspace\")\n156: \n157:         self.logger.debug(f\"Found {len(py_files)} Python files\")\n158: \n159:     def _validate_java_compatibility(self, workspace_path: Path) -> None:\n160:         \"\"\"\n161:         Validate that workspace contains pom.xml.\n162: \n163:         Args:\n164:             workspace_path: Path to workspace\n165: \n166:         Raises:\n167:             ValueError: If pom.xml not found\n168:         \"\"\"\n169:         pom_file = workspace_path / \"pom.xml\"\n170:         if not pom_file.exists():\n171:             raise ValueError(\"No pom.xml found in workspace\")\n172: \n173:         self.logger.debug(f\"Found pom.xml\")\n174: \n175:     def _process_dependencies(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n176:         \"\"\"\n177:         Process dependencies based on language.\n178: \n179:         Args:\n180:             workspace_path: Path to workspace\n181:             metadata: Agent metadata\n182:         \"\"\"\n183:         if metadata.language == \"python\":\n184:             self._process_python_dependencies(workspace_path)\n185:         elif metadata.language == \"java\":\n186:             self._process_java_dependencies(workspace_path)\n187: \n188:     def _process_python_dependencies(self, workspace_path: Path) -> None:\n189:         \"\"\"\n190:         Validate Python requirements.txt if it exists.\n191: \n192:         Args:\n193:             workspace_path: Path to workspace\n194:         \"\"\"\n195:         requirements_file = workspace_path / \"requirements.txt\"\n196:         if requirements_file.exists():\n197:             self.logger.debug(f\"Found requirements.txt\")\n198:         else:\n199:             self.logger.warning(\"No requirements.txt found (optional)\")\n200: \n201:     def _process_java_dependencies(self, workspace_path: Path) -> None:\n202:         \"\"\"\n203:         Validate Java pom.xml exists.\n204: \n205:         Args:\n206:             workspace_path: Path to workspace\n207:         \"\"\"\n208:         pom_file = workspace_path / \"pom.xml\"\n209:         if pom_file.exists():\n210:             self.logger.debug(f\"Found pom.xml\")\n211:         else:\n212:             raise ValueError(\"pom.xml is required for Java agents\")\n213: \n214:     def _generate_dockerfile(self, workspace_path: Path, metadata: AgentMetadata) -> Optional[Path]:\n215:         \"\"\"\n216:         Generate Dockerfile if it doesn't exist.\n217: \n218:         Args:\n219:             workspace_path: Path to workspace\n220:             metadata: Agent metadata\n221: \n222:         Returns:\n223:             Path to Dockerfile if generated, None if skipped\n224:         \"\"\"\n225:         dockerfile_path = workspace_path / \"Dockerfile\"\n226: \n227:         if dockerfile_path.exists():\n228:             self.logger.debug(\"Dockerfile already exists, skipping generation\")\n229:             return None\n230: \n231:         if metadata.language == \"python\":\n232:             content = self.docker_service.generate_python_dockerfile(metadata)\n233:         elif metadata.language == \"java\":\n234:             content = self.docker_service.generate_java_dockerfile(metadata)\n235:         else:\n236:             self.logger.warning(f\"Dockerfile generation not supported for {metadata.language}\")\n237:             return None\n238: \n239:         result = self.docker_service.write_dockerfile(workspace_path, content)\n240:         self.logger.debug(f\"Generated Dockerfile at {result}\")\n241:         return result\n242: \n243:     def _prepare_output_path(self, workspace_path: Path, output_path: Optional[str]) -> Path:\n244:         \"\"\"\n245:         Prepare output path for packaged workspace.\n246: \n247:         Args:\n248:             workspace_path: Original workspace path\n249:             output_path: Optional custom output path\n250: \n251:         Returns:\n252:             Output path to use\n253:         \"\"\"\n254:         if output_path:\n255:             output = Path(output_path)\n256:             output.mkdir(parents=True, exist_ok=True)\n257:             self.logger.debug(f\"Using custom output path: {output}\")\n258:             return output\n259: \n260:         return workspace_path\n261: \n262:     def _update_pack_metadata(\n263:         self, workspace_path: Path, metadata: AgentMetadata, dockerfile_path: Optional[Path]\n264:     ) -> Path:\n265:         \"\"\"\n266:         Save final metadata to output path.\n267: \n268:         Args:\n269:             workspace_path: Output workspace path\n270:             metadata: Final metadata\n271:             dockerfile_path: Path to generated Dockerfile\n272: \n273:         Returns:\n274:             Path to saved metadata file\n275:         \"\"\"\n276:         metadata_file = self.metadata_service.save_metadata(workspace_path, metadata)\n277:         self.logger.debug(f\"Saved metadata to {metadata_file}\")\n278:         return metadata_file\n279: \n280:     def _infer_entrypoint(self, workspace_path: Path, language: str) -> Optional[str]:\n281:         \"\"\"\n282:         Infer entrypoint if not explicitly provided.\n283: \n284:         Args:\n285:             workspace_path: Path to workspace\n286:             language: Programming language\n287: \n288:         Returns:\n289:             Inferred entrypoint command or None\n290:         \"\"\"\n291:         if language == \"python\":\n292:             main_py = workspace_path / \"main.py\"\n293:             if main_py.exists():\n294:                 self.logger.debug(\"Inferred entrypoint: python main.py\")\n295:                 return \"python main.py\"\n296: \n297:         elif language == \"java\":\n298:             target_dir = workspace_path / \"target\"\n299:             if target_dir.exists():\n300:                 jars = list(target_dir.glob(\"*.jar\"))\n301:                 if jars:\n302:                     entrypoint = f\"java -jar {jars[0].name}\"\n303:                     self.logger.debug(f\"Inferred entrypoint: {entrypoint}\")\n304:                     return entrypoint\n305: \n306:         return None\n307: \n308:     def pack(\n309:         self,\n310:         workspace_path: str,\n311:         agent_name: Optional[str] = None,\n312:         language: Optional[str] = None,\n313:         entrypoint: Optional[str] = None,\n314:         port: Optional[int] = None,\n315:         build_mode: Optional[str] = None,\n316:         description: Optional[str] = None,\n317:         requirements_file: Optional[str] = None,\n318:         output: Optional[str] = None,\n319:         verbose: bool = False,\n320:     ) -> dict:\n321:         \"\"\"\n322:         Pack an agent workspace for deployment.\n323: \n324:         Args:\n325:             workspace_path: Path to agent workspace\n326:             agent_name: Override agent name\n327:             language: Programming language (python/java)\n328:             entrypoint: Override entrypoint command\n329:             port: Override port\n330:             build_mode: Override build mode (local/cloud)\n331:             description: Override description\n332:             requirements_file: Override requirements file\n333:             output: Custom output path\n334:             verbose: Enable verbose logging\n335: \n336:         Returns:\n337:             Dictionary with pack result details\n338: \n339:         Raises:\n340:             ValueError: If validation fails\n341:             FileNotFoundError: If workspace not found\n342:         \"\"\"\n343:         workspace = Path(workspace_path).resolve()\n344: \n345:         options = MetadataOptions(\n346:             agent_name=agent_name,\n347:             language=language,\n348:             entrypoint=entrypoint,\n349:             port=port,\n350:             build_mode=build_mode,\n351:             description=description,\n352:             requirements_file=requirements_file,\n353:             output=output,\n354:             verbose=verbose,\n355:         )\n356: \n357:         self._validate_workspace_structure(workspace)\n358: \n359:         metadata = self._load_or_create_metadata(workspace, options)\n360: \n361:         if not metadata.entrypoint and not options.entrypoint:\n362:             inferred = self._infer_entrypoint(workspace, metadata.language)\n363:             if inferred:\n364:                 metadata.entrypoint = inferred\n365:                 self.logger.debug(f\"Set inferred entrypoint: {inferred}\")\n366: \n367:         metadata = self._apply_option_overrides(metadata, options)\n368: \n369:         self._validate_language_compatibility(workspace, metadata)\n370: \n371:         self._process_dependencies(workspace, metadata)\n372: \n373:         dockerfile_path = self._generate_dockerfile(workspace, metadata)\n374: \n375:         output_path = self._prepare_output_path(workspace, output)\n376: \n377:         metadata_file = self._update_pack_metadata(output_path, metadata, dockerfile_path)\n378: \n379:         return {\n380:             \"agent_name\": metadata.agent_name,\n381:             \"workspace_path\": str(workspace),\n382:             \"output_path\": str(output_path),\n383:             \"metadata_file\": str(metadata_file),\n384:             \"dockerfile_generated\": dockerfile_path is not None,\n385:         }\n\n(End of file - total 385 lines)\n</content>","metadata":{"preview":"\"\"\"Pack runtime for AgentCube - orchestrates the pack command workflow.\"\"\"\n\nimport logging\nimport os\nfrom pathlib import Path\nfrom typing import Optional\n\nfrom agentcube.models.pack_models import MetadataOptions\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass PackRuntime:\n    \"\"\"\n    Core runtime for packing agent workspaces.\n\n    Orchestrates validation, metadata loading, dependency processing,\n    Dockerfile generation, and output preparation.\n    \"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/pack_runtime.py","time":{"start":1775860774639,"end":1775860774656}}}}
