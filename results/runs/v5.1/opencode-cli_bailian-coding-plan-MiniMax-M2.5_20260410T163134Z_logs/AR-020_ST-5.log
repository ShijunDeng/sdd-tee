ne:\n111:     \"\"\"\n112:     Pack an agent workspace for deployment.\n113: \n114:     Validates the workspace structure, loads or creates agent metadata,\n115:     processes dependencies, optionally generates a Dockerfile, and\n116:     prepares the workspace for subsequent build and publish steps.\n117:     \"\"\"\n118:     try:\n119:         with Progress(\n120:             SpinnerColumn(),\n121:             TextColumn(\"[progress.description]{task.description}\"),\n122:             console=console,\n123:         ) as progress:\n124:             task = progress.add_task(\"Packing agent workspace...\", total=None)\n125: \n126:             runtime = PackRuntime(verbose=verbose)\n127: \n128:             result = runtime.pack(\n129:                 workspace_path=workspace,\n130:                 agent_name=agent_name,\n131:                 language=language,\n132:                 entrypoint=entrypoint,\n133:                 port=port,\n134:                 build_mode=build_mode,\n135:                 description=description,\n136:                 output=output,\n137:                 verbose=verbose,\n138:             )\n139: \n140:             progress.update(task, completed=True)\n141: \n142:         console.print(\n143:             Panel(\n144:                 f\"[bold green]Agent packed successfully![/bold green]\\n\\n\"\n145:                 f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n146:                 f\"[bold]Workspace:[/bold] {result['workspace_path']}\\n\"\n147:                 f\"[bold]Output:[/bold] {result['output_path']}\\n\"\n148:                 f\"[bold]Metadata:[/bold] {result['metadata_file']}\\n\"\n149:                 f\"[bold]Dockerfile:[/bold] {'Generated' if result['dockerfile_generated'] else 'Existing'}\",\n150:                 title=\"Pack Complete\",\n151:                 style=\"green\",\n152:             )\n153:         )\n154: \n155:     except Exception as e:\n156:         _handle_error(e, \"pack\", verbose)\n157:       