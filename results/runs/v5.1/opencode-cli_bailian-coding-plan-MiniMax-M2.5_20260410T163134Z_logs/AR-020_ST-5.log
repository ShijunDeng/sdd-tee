f):\n        \"\"\"Test fallback to agent.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\"agent_name\": \"fallback-agent\", \"entrypoint\": \"python app.py\"}\n\n            with open(workspace / \"agent.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata_data, f)\n\n            metadata = MetadataService.load_metadata(workspace)\n\n            assert metadata.agent_name == \"fallback-agent\"\n\n    def test_falls_back_to_metadata_yaml(self):\n        \"\"\"Test fallback to metadata.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\"name\": \"metadata-agent\", \"entrypoint\": \"python run.py\"}\n\n            with open(workspace / \"metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata_data, f)\n\n            metadata = MetadataService.load_metadata(workspace)\n\n            assert metadata.agent_name == \"metadata-agent\"\n\n    def test_raises_error_when_no_metadata_file(self):\n        \"\"\"Test error when no metadata file found.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            with pytest.raises(FileNotFoundError):\n                MetadataService.load_metadata(workspace)\n\n\nclass TestMetadataServiceSave:\n    \"\"\"Tests for MetadataService.save_metadata method.\"\"\"\n\n    def test_saves_to_agent_metadata_yaml(self):\n        \"\"\"Test saving metadata to agent_metadata.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"saved-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=9000,\n                build_mode=\"cloud\",\n            )\n\n            saved_path = MetadataService.save_metadata(workspace, metadata)\n\n            assert saved_path == workspace / \"agent_metadata.yaml\"\n            assert saved_path.exists()\n\n            with open(saved_path, \"r\") as f:\n                saved_data = yaml.safe_load(f)\n\n            assert saved_data[\"agent_name\"] == \"saved-agent\"\n            assert saved_data[\"port\"] == 9000\n\n\nclass TestMetadataServiceValidate:\n    \"\"\"Tests for MetadataService.validate_workspace method.\"\"\"\n\n    def test_valid_workspace_returns_true(self):\n        \"\"\"Test valid workspace returns True.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            result = MetadataService.validate_workspace(workspace)\n\n            assert result is True\n\n    def test_nonexistent_workspace_raises_value_error(self):\n        \"\"\"Test nonexistent workspace raises ValueError.\"\"\"\n        with pytest.raises(ValueError, match=\"does not exist\"):\n            MetadataService.validate_workspace(\"/nonexistent/path\")\n\n    def test_file_raises_value_error(self):\n        \"\"\"Test file path raises ValueError.\"\"\"\n        with tempfile.NamedTemporaryFile() as tmpfile:\n            with pytest.raises(ValueError, match=\"not a directory\"):\n                MetadataService.validate_workspace(tmpfile.name)\n\n\nclass TestAgentMetadataFields:\n    \"\"\"Tests for AgentMetadata field defaults.\"\"\"\n\n    def test_default_values(self):\n        \"\"\"Test default field values.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            entrypoint=\"python main.py\",\n        )\n\n        assert metadata.language == \"python\"\n        assert metadata.port == 8080\n        assert metadata.build_mode == \"local\"\n        assert metadata.requirements_file == \"requirements.txt\"\n\n    def test_optional_description(self):\n        \"\"\"Test optional description field.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            entrypoint=\"python main.py\",\n            description=None,\n        )\n\n        assert metadata.description is None\n","after":"\"\"\"Unit tests for MetadataService.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\n\nimport pytest\nimport yaml\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass TestMetadataServiceLoad:\n    \"\"\"Tests for MetadataService.load_metadata method.\"\"\"\n\n    def test_loads_agent_metadata_yaml(self):\n        \"\"\"Test loading agent_metadata.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\n                \"agent_name\": \"my-agent\",\n                \"language\": \"python\",\n                \"entrypoint\": \"python main.py\",\n                \"port\": 8080,\n                \"build_mode\": \"local\",\n                \"description\": \"Test agent\",\n            }\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata_data, f)\n\n            metadata = MetadataService.load_metadata(workspace)\n\n            assert metadata.agent_name == \"my-agent\"\n            assert metadata.language == \"python\"\n            assert metadata.port == 8080\n\n    def test_falls_back_to_agent_yaml(self):\n        \"\"\"Test fallback to agent.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\"agent_name\": \"fallback-agent\", \"entrypoint\": \"python app.py\"}\n\n            with open(workspace / \"agent.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata_data, f)\n\n            metadata = MetadataService.load_metadata(workspace)\n\n            assert metadata.agent_name == \"fallback-agent\"\n\n    def test_falls_back_to_metadata_yaml(self):\n        \"\"\"Test fallback to metadata.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n         