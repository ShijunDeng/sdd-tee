ack()\n+def main_callback(\n+    version: bool = typer.Option(\n+        None,\n+        \"--version\",\n+        help=\"Show version information\",\n+        is_eager=True,\n+    ),\n+) -> None:\n+    \"\"\"Main callback for global options.\"\"\"\n+    if version:\n+        console.print(f\"kubectl-agentcube version {__version__}\")\n+        raise typer.Exit()\n+\n+\n def version_callback(value: bool) -> None:\n     \"\"\"Callback for --version option.\"\"\"\n     if value:\n         console.print(f\"kubectl-agentcube version {__version__}\")\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py","before":"\"\"\"AgentCube CLI - Main entry point for kubectl-agentcube.\"\"\"\n\nfrom typing import Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\nfrom rich.panel import Panel\nfrom rich import print as rprint\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\n\napp = typer.Typer(\n    name=\"kubectl-agentcube\",\n    help=\"AgentCube CLI - Package and manage agent runtimes\",\n    add_completion=False,\n)\n\nconsole = Console()\n\n\ndef version_callback(value: bool) -> None:\n    \"\"\"Callback for --version option.\"\"\"\n    if value:\n        console.print(f\"kubectl-agentcube version {__version__}\")\n        raise typer.Exit()\n\n\ndef _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n    \"\"\"\n    Handle and format error output.\n\n    Args:\n        e: Exception that was raised\n        command_name: Name of the command\n        verbose: Enable verbose error output\n    \"\"\"\n    error_msg = str(e)\n\n    if verbose:\n        import traceback\n\n        console.print(\n            Panel(\n                f\"[bold red]Error in {command_name}:[/bold red]\\n\\n{error_msg}\\n\\n[red]{traceback.format_exc()}[/red]\",\n                style=\"red\",\n            )\n        )\n    else:\n        console.print(f\"[bold red]Error:[/bold red] {error_msg}\")\n\n\n@app.command()\ndef pack(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        \"-f\",\n        help=\"Path to agent workspace\",\n    ),\n    agent_name: Optional[str] = typer.Option(\n        None,\n        \"--agent-name\",\n        help=\"Override agent name\",\n    ),\n    language: Optional[str] = typer.Option(\n        None,\n        \"--language\",\n        help=\"Programming language (python, java)\",\n    ),\n    entrypoint: Optional[str] = typer.Option(\n        None,\n        \"--entrypoint\",\n        help=\"Override entrypoint command\",\n    ),\n    port: Optional[int] = typer.Option(\n        None,\n        \"--port\",\n        help=\"Port to expose (default: 8080)\",\n    ),\n    build_mode: Optional[str] = typer.Option(\n        None,\n        \"--build-mode\",\n        help=\"Build strategy (local, cloud)\",\n    ),\n    description: Optional[str] = typer.Option(\n        None,\n        \"--description\",\n        help=\"Agent description\",\n    ),\n    output: Optional[str] = typer.Option(\n        None,\n        \"--output\",\n        help=\"Output path for packaged workspace\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n    version: bool = typer.Option(\n        None,\n        \"--version\",\n        help=\"Show version information\",\n        callback=version_callback,\n        is_eager=True,\n    ),\n) -> None:\n    \"\"\"\n    Pack an agent workspace for deployment.\n\n    Validates the workspace structure, loads or creates agent metadata,\n    processes dependencies, optionally generates a Dockerfile, and\n    prepares the workspace for subsequent build and publish steps.\n    \"\"\"\n    try:\n        with Progress(\n            SpinnerColumn(),\n            TextColumn(\"[progress.description]{task.description}\"),\n            console=console,\n        ) as progress:\n            task = progress.add_task(\"Packing agent workspace...\", total=None)\n\n            runtime = PackRuntime(verbose=verbose)\n\n            result = runtime.pack(\n                workspace_path=workspace,\n                agent_name=agent_name,\n                language=language,\n                entrypoint=entrypoint,\n                port=port,\n                build_mode=build_mode,\n                description=description,\n                output=output,\n                verbose=verbose,\n            )\n\n            progress.update(task, completed=True)\n\n        console.print(\n            Panel(\n                f\"[bold green]Agent packed successfully![/bold green]\\n\\n\"\n                f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n                f\"[bold]Workspace:[/bold] {result['workspace_path']}\\n\"\n                f\"[bold]Output:[/bold] {result['output_path']}\\n\"\n                f\"[bold]Metadata:[/bold] {result['metadata_file']}\\n\"\n                f\"[bold]Dockerfile:[/bold] {'Generated' if result['dockerfile_generated'] else 'Existing'}\",\n                title=\"Pack Complete\",\n                style=\"green\",\n            )\n        )\n\n    except Exception as e:\n        _handle_error(e, \"pack\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef version() -> None:\n    \"\"\"Show version information.\"\"\"\n    console.print(f\"kubectl-agentcube version {__version__}\")\n\n\nif __name__ == \"__main__\":\n    app()\n","after":"\"\"\"AgentCube CLI - Main entry point for kubectl-agentcube.\"\"\"\n\nfrom typing import Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\nfrom rich.panel import Panel\nfrom rich import print as rprint\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\n\napp = typer.Typer(\n    name=\"kubectl-agentcube\",\n    help=\"AgentCube CLI - Package and manage agent runtimes\",\n    add_completion=False,\n    invoke_without_command=True,\n)\n\nconsole = Console()\n\n\n@app.callback()\ndef main_callback(\n    version: bool = typer.Option(\n        None,\n        \"--version\",\n        help=\"Show version information\",\n        is_eager=True,\n    ),\n) -> None:\n    \"\"\"Main callback for global options.\"\"\"\n    if version:\n        console.print(f\"kubectl-agentcube version {__version__}\")\n        raise typer.Exit()\n\n\ndef version_callback(value: bool) -> None:\n    \"\"\"Callback for --version option.\"\"\"\n    if value:\n        console.print(f\"kubectl-agentcube version {__version__}\")\n        raise typer.Exit()\n\n\ndef _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n    \"\"\"\n    Handle and format error output.\n\n    Args:\n        e: Exception that was raised\n        command_name: Name of the command\n        verbose: Enable verbose error output\n    \"\"\"\n    error_msg = str(e)\n\n    if verbose:\n        import traceback\n\n        console.print(\n            Panel(\n                f\"[bold red]Error in {command_name}:[/bold red]\\n\\n{error_msg}\\n\\n[red]{traceback.format_exc()}[/red]\",\n                style=\"red\",\n            )\n        )\n    else:\n        console.print(f\"[bold red]Error:[/bold red] {error_msg}\")\n\n\n@app.command()\ndef pack(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        \"-f\",\n        help=\"Path to agent workspace\",\n    ),\n    agent_name: Optional[str] = typer.Option(\n        None,\n        \"--agent-name\",\n        help=\"Override agent name\",\n    ),\n    language: Optional[str] = typer.Option(\n        None,\n        \"--language\",\n        help=\"Programming language (python, java)\",\n    ),\n    entrypoint: Optional[str] = typer.Option(\n        None,\n        \"--entrypoint\",\n        help=\"Override entrypoint command\",\n    ),\n    port: Optional[int] = typer.Option(\n        None,\n        \"--port\",\n        help=\"Port to expose (default: 8080)\",\n    ),\n    build_mode: Optional[str] = typer.Option(\n        None,\n        \"--build-mode\",\n        help=\"Build strategy (local, cloud)\",\n    ),\n    description: Optional[str] = typer.Option(\n        None,\n        \"--description\",\n        help=\"Agent description\",\n    ),\n    output: Optional[str] = typer.Option(\n        None,\n        \"--output\",\n        help=\"Output path for packaged workspace\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n    version: bool = typer.Option(\n        None,\n        \"--version\",\n        help=\"Show version information\",\n        callback=version_callback,\n        is_eager=True,\n    ),\n) -> None:\n    \"\"\"\n    Pack an agent workspace for deployment.\n\n    Validates the workspace structure, loads or creates agent metadata,\n    processes dependencies, optionally generates a Dockerfile, and\n    prepares the workspace for subsequent build and publish steps.\n    \"\"\"\n    try:\n        with Progress(\n            SpinnerColumn(),\n            TextColumn(\"[progress.description]{task.description}\"),\n            console=console,\n        ) as progress:\n            task = progress.add_task(\"Packing agent workspace...\", total=None)\n\n            runtime = PackRuntime(verbose=verbose)\n\n            result = runtime.pack(\n                workspace_path=workspace,\n                agent_name=agent_name,\n                language=language,\n                entrypoint=entrypoint,\n                port=port,\n                build_mode=build_mode,\n                description=description,\n                output=output,\n                verbose=verbose,\n            )\n\n            progress.update(task, completed=True)\n\n        console.print(\n            Panel(\n                f\"[bold green]Agent packed successfully![/bold green]\\n\\n\"\n                f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n                f\"[bold]Workspace:[/bold] {result['workspace_path']}\\n\"\n                f\"[bold]Output:[/bold] {result['output_path']}\\n\"\n                f\"[bold]Metadata:[/bold] {result['metadata_file']}\\n\"\n                f\"[bold]Dockerfile:[/bold] {'Generated' if result['dockerfile_generated'] else 'Existing'}\",\n                title=\"Pack Complete\",\n                style=\"green\",\n            )\n        )\n\n    except Exception as e:\n        _handle_error(e, \"pack\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef version() -> None:\n    \"\"\"Show version information.\"\"\"\n    console.print(f\"kubectl-agentcube version {__version__}\")\n\n\nif __name__ == \"__main__\":\n    app()\n","additions":16,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py","time":{"start":1775860815534,"end":1775860816100}}}}
