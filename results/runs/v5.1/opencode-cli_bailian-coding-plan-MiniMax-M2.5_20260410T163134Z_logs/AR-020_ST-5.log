 result = MetadataService.validate_workspace(workspace)\n\n            assert result is True\n\n    def test_nonexistent_workspace_raises_value_error(self):\n        \"\"\"Test nonexistent workspace raises ValueError.\"\"\"\n        with pytest.raises(ValueError, match=\"does not exist\"):\n            MetadataService.validate_workspace(\"/nonexistent/path\")\n\n    def test_file_raises_value_error(self):\n        \"\"\"Test file path raises ValueError.\"\"\"\n        with tempfile.NamedTemporaryFile() as tmpfile:\n            with pytest.raises(ValueError, match=\"not a directory\"):\n                MetadataService.validate_workspace(tmpfile.name)\n\n\nclass TestAgentMetadataFields:\n    \"\"\"Tests for AgentMetadata field defaults.\"\"\"\n\n    def test_default_values(self):\n        \"\"\"Test default field values.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            entrypoint=\"python main.py\",\n        )\n\n        assert metadata.language == \"python\"\n        assert metadata.port == 8080\n        assert metadata.build_mode == \"local\"\n        assert metadata.requirements_file == \"requirements.txt\"\n\n    def test_optional_description(self):\n        \"\"\"Test optional description field.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test\",\n            entrypoint=\"python main.py\",\n            description=None,\n        )\n\n        assert metadata.description is None\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_metadata_service.py","time":{"start":1775860827753,"end":1775860828423}}}}
