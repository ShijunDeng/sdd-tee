ring      `json:\"sandboxId\"`\n39: \tNamespace        string      `json:\"namespace\"`\n40: \tReason           string      `json:\"reason\"`\n41: \tInitiator        string      `json:\"initiator\"`\n42: \tDuration         int64       `json:\"duration\"`\n43: \tResourcesCleaned []string    `json:\"resourcesCleaned\"`\n44: \tTimestamp        metav1.Time `json:\"timestamp\"`\n45: }\n46: \n47: type DeletionEvent struct {\n48: \tType           string      `json:\"type\"`\n49: \tReason         string      `json:\"reason\"`\n50: \tMessage        string      `json:\"message\"`\n51: \tInvolvedObject string      `json:\"involvedObject\"`\n52: \tTimestamp      metav1.Time `json:\"timestamp\"`\n53: }\n54: \n55: type Sandbox struct {\n56: \tName           string            `json:\"name\"`\n57: \tNamespace      string            `json:\"namespace\"`\n58: \tSessionID      string            `json:\"sessionId\"`\n59: \tState          SandboxState      `json:\"state\"`\n60: \tCreatedAt      time.Time         `json:\"createdAt\"`\n61: \tExpiresAt      *time.Time        `json:\"expiresAt,omitempty\"`\n62: \tLastActivityAt *time.Time        `json:\"lastActivityAt,omitempty\"`\n63: \tLabels         map[string]string `json:\"labels,omitempty\"`\n64: \tAnnotations    map[string]string `json:\"annotations,omitempty\"`\n65: }\n66: \n67: type SandboxState string\n68: \n69: const (\n70: \tSandboxStateUnknown  SandboxState = \"Unknown\"\n71: \tSandboxStatePending  SandboxState = \"Pending\"\n72: \tSandboxStateRunning  SandboxState = \"Running\"\n73: \tSandboxStateFailed   SandboxState = \"Failed\"\n74: \tSandboxStateDeleting SandboxState = \"Deleting\"\n75: )\n76: \n77: type SandboxList struct {\n78: \tItems []Sandbox `json:\"items\"`\n79: }\n80: \n81: type ListOptions struct {\n82: \tLabelSelector string `form:\"labelSelector\"`\n83: \tFieldSelector string `form:\"fieldSelector\"`\n84: \tLimit         int64  `form:\"limit\"`\n85: \tContinue      string `form:\"continue\"`\n86: }\n87: \n88: ty