rOpts{\n37: \t\tName: \"router_sessions_created_total\",\n38: \t\tHelp: \"Total number of sessions created\",\n39: \t})\n40: \n41: \tsessionsExpiredTotal = promauto.NewCounter(prometheus.CounterOpts{\n42: \t\tName: \"router_sessions_expired_total\",\n43: \t\tHelp: \"Total number of sessions expired\",\n44: \t})\n45: \n46: \tsessionDuration = promauto.NewHistogram(prometheus.HistogramOpts{\n47: \t\tName:    \"router_session_duration_seconds\",\n48: \t\tHelp:    \"Session lifetime in seconds\",\n49: \t\tBuckets: prometheus.DefBuckets,\n50: \t})\n51: )\n52: \n53: type Metrics struct {\n54: \tmu sync.RWMutex\n55: }\n56: \n57: func NewMetrics() *Metrics {\n58: \treturn &Metrics{}\n59: }\n60: \n61: func (m *Metrics) RecordRequestDuration(method, path, backend string, duration float64) {\n62: \trequestDuration.WithLabelValues(method, path, backend).Observe(duration)\n63: }\n64: \n65: func (m *Metrics) IncBackendRequests(backend string, status string) {\n66: \tbackendRequests.WithLabelValues(backend, status).Inc()\n67: }\n68: \n69: func (m *Metrics) SetBackendHealth(backend string, healthy bool) {\n70: \tvalue := 0.0\n71: \tif healthy {\n72: \t\tvalue = 1.0\n73: \t}\n74: \tbackendHealthy.WithLabelValues(backend).Set(value)\n75: }\n76: \n77: func (m *Metrics) IncErrors(errType string) {\n78: \terrorsTotal.WithLabelValues(errType).Inc()\n79: }\n80: \n81: func (m *Metrics) GetRequestDuration() *prometheus.HistogramVec {\n82: \treturn requestDuration\n83: }\n84: \n85: func (m *Metrics) GetBackendRequests() *prometheus.CounterVec {\n86: \treturn backendRequests\n87: }\n88: \n89: func (m *Metrics) GetBackendHealthy() *prometheus.GaugeVec {\n90: \treturn backendHealthy\n91: }\n92: \n93: func (m *Metrics) GetErrors() *prometheus.CounterVec {\n94: \treturn errorsTotal\n95: }\n96: \n97: func (m *Metrics) SetSessionsActive(count int) {\n98: \tsessionsActive.Set(float64(count))\n99: }\n100: \n101: func (m *Metrics) IncSessionsCreated() {\n102: \tsessionsCreatedTotal.Inc()\n103: }\n104: \n105: func (m *Metrics) IncSessionsExpired() {\n106: \tsessionsExpiredTotal.Inc()\n107: }\n108: \n109: func (m *Metrics) RecordSessionDuration(duration float64) {\n110: \tsessionDuration.Observe(duration)\n111: }\n112: \n113: func (m *Metrics) GetSessionsActive() prometheus.Gauge {\n114: \treturn sessionsActive\n115: }\n\n(End of file - total 115 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"github.com/prometheus/client_golang/prometheus\"\n\t\"github.com/prometheus/client_golang/prometheus/promauto\"\n\t\"sync\"\n)\n\nvar (\n\trequestDuration = promauto.NewHistogramVec(prometheus.HistogramOpts{\n\t\tName:    \"router_request_duration_seconds\",\n\t\tHelp:    \"Time spent processing requests\",\n\t\tBuckets: prometheus.DefBuckets,\n\t}, []string{\"method\", \"path\", \"backend\"})\n\n\tbackendRequests = promauto.NewCounterVec(prometheus.CounterOpts{\n\t\tName: \"router_backend_requests_total\",\n\t\tHelp: \"Total number of requests to backends\",\n\t}, []string{\"backend\", \"status\"})\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/metrics.go","time":{"start":1775849139540,"end":1775849139547}}}}
