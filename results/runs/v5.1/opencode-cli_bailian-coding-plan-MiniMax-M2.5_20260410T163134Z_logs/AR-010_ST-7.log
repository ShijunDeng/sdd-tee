{"type":"tool_use","timestamp":1775849129801,"sessionID":"ses_28725112effeLv38OgxzcMAJ8A","part":{"id":"prt_d78db433c001d8o7ndS86rep53","messageID":"msg_d78db35b2001VmI7enO2UtA5jk","sessionID":"ses_28725112effeLv38OgxzcMAJ8A","type":"tool","tool":"read","callID":"toolu_a983aaef4e0b456ba072d4a7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/session.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/session.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"errors\"\n5: \t\"sync\"\n6: \t\"time\"\n7: \n8: \t\"github.com/google/uuid\"\n9: )\n10: \n11: var (\n12: \tErrMaxSessionsExceeded = errors.New(\"maximum number of sessions exceeded\")\n13: \tErrSessionNotFound     = errors.New(\"session not found\")\n14: )\n15: \n16: type Session struct {\n17: \tID           string            // Unique session identifier\n18: \tBackendKey   string            // Associated backend key for sticky sessions\n19: \tCreatedAt    time.Time         // Session creation time\n20: \tLastActivity time.Time         // Last activity timestamp\n21: \tExpiresAt    time.Time         // Session expiration time\n22: \tMetadata     map[string]string // Additional session metadata\n23: }\n24: \n25: type SessionStore interface {\n26: \tCreate(backendKey string, metadata map[string]string) (*Session, error)\n27: \tGet(sessionID string) *Session\n28: \tUpdate(sessionID string) error\n29: \tDelete(sessionID string) error\n30: \tList() []*Session\n31: \tCleanup() int\n32: \tGetActiveCount() int\n33: \tSetMaxSessions(max int)\n34: }\n35: \n36: type MemorySessionStore struct {\n37: \tsessions       map[string]*Session\n38: \tmaxSessions    int\n39: \tsessionTimeout time.Duration\n40: \tmu             sync.RWMutex\n41: }\n42: \n43: func NewMemorySessionStore(maxSessions int) *MemorySessionStore {\n44: \tif maxSessions <= 0 {\n45: \t\tmaxSessions = 10000\n46: \t}\n47: \treturn &MemorySessionStore{\n48: \t\tsessions:       make(map[string]*Session),\n49: \t\tmaxSessions:    maxSessions,\n50: \t\tsessionTimeout: 30 * time.Minute,\n51: \t}\n52: }\n53: \n54: func NewMemorySessionStoreWithTimeout(maxSessions int, timeout time.Duration) *MemorySessionStore {\n55: \tif maxSessions <= 0 {\n56: \t\tmaxSessions = 10000\n57: \t}\n58: \tif timeout <= 0 {\n59: \t\ttimeout = 30 * time.Minute\n60: \t}\n61: \treturn &MemorySessionStore{\n62: \t\tsessions:       make(map[string]*Session),\n63: \t\tmaxSessions:    maxSessions,\n64: \t\tsessionTimeout: timeout,\n65: \t}\n66: }\n67: \n68: func GenerateSessionID() string {\n69: \treturn uuid.New().String()\n70: }\n71: \n72: func (ms *MemorySessionStore) Create(backendKey string, metadata map[string]string) (*Session, error) {\n73: \tms.mu.Lock()\n74: \tdefer ms.mu.Unlock()\n75: \n76: \tif len(ms.sessions) >= ms.maxSessions {\n77: \t\treturn nil, ErrMaxSessionsExceeded\n78: \t}\n79: \n80: \tnow := time.Now()\n81: \tsession := &Session{\n82: \t\tID:           GenerateSessionID(),\n83: \t\tBackendKey:   backendKey,\n84: \t\tCreatedAt:    now,\n85: \t\tLastActivity: now,\n86: \t\tExpiresAt:    now.Add(ms.sessionTimeout),\n87: \t\tMetadata:     metadata,\n88: \t}\n89: \n90: \tms.sessions[session.ID] = session\n91: \treturn session, nil\n92: }\n93: \n94: func (ms *MemorySessionStore) Get(sessionID string) *Session {\n95: \tms.mu.RLock()\n96: \tdefer ms.mu.RUnlock()\n97: \n98: \tsession, exists := ms.sessions[sessionID]\n99: \tif !exists {\n100: \t\treturn nil\n101: \t}\n102: \n103: \tif time.Now().After(session.ExpiresAt) {\n104: \t\treturn nil\n105: \t}\n106: \n107: \treturn session\n108: }\n109: \n110: func (ms *MemorySessionStore) Update(sessionID string) error {\n111: \tms.mu.Lock()\n112: \tdefer ms.mu.Unlock()\n113: \n114: \tsession, exists := ms.sessions[sessionID]\n115: \tif !exists {\n116: \t\treturn ErrSessionNotFound\n117: \t}\n118: \n119: \tsession.LastActivity = time.Now()\n120: \tsession.ExpiresAt = time.Now().Add(ms.sessionTimeout)\n121: \treturn nil\n122: }\n123: \n124: func (ms *MemorySessionStore) Delete(sessionID string) error {\n125: \tms.mu.Lock()\n126: \tdefer ms.mu.Unlock()\n127: \n128: \tif _, exists := ms.sessions[sessionID]; !exists {\n129: \t\treturn ErrSessionNotFound\n130: \t}\n131: \n132: \tdelete(ms.sessions, sessionID)\n133: \treturn nil\n134: }\n135: \n136: func (ms *MemorySessionStore) List() []*Session {\n137: \tms.mu.RLock()\n138: \tdefer ms.mu.RUnlock()\n139: \n140: \tsessions := make([]*Session, 0, len(ms.sessions))\n141: \tfor _, session := range ms.sessions {\n142: \t\tif time.Now().Before(session.ExpiresAt) {\n143: \t\t\tsessions = append(sessions, session)\n144: \t\t}\n145: \t}\n146: \n147: \treturn sessions\n148: }\n149: \n150: func (ms *MemorySessionStore) Cleanup() int {\n151: \tms.mu.Lock()\n152: \tdefer ms.mu.Unlock()\n153: \n154: \tnow := time.Now()\n155: \tcleaned := 0\n156: \n157: \tfor id, session := range ms.sessions {\n158: \t\tif now.After(session.ExpiresAt) {\n159: \t\t\tdelete(ms.sessions, id)\n160: \t\t\tcleaned++\n161: \t\t}\n162: \t}\n163: \n164: \treturn cleaned\n165: }\n166: \n167: func (ms *MemorySessionStore) GetActiveCount() int {\n168: \tms.mu.RLock()\n169: \tdefer ms.mu.RUnlock()\n170: \n171: \tcount := 0\n172: \tnow := time.Now()\n173: \tfor _, session := range ms.sessions {\n174: \t\tif now.Before(session.ExpiresAt) {\n175: \t\t\tcount++\n176: \t\t}\n177: \t}\n178: \n179: \treturn count\n180: }\n181: \n182: func (ms *MemorySessionStore) SetMaxSessions(max int) {\n183: \tms.mu.Lock()\n184: \tdefer ms.mu.Unlock()\n185: \n186: \tms.maxSessions = max\n187: }\n188: \n189: func (ms *MemorySessionStore) InvalidateBackend(backendKey string) int {\n190: \tms.mu.Lock()\n191: \tdefer ms.mu.Unlock()\n192: \n193: \tcleaned := 0\n194: \tfor id, session := range ms.sessions {\n195: \t\tif session.BackendKey == backendKey {\n196: \t\t\tdelete(ms.sessions, id)\n197: \t\t\tcleaned++\n198: \t\t}\n199: \t}\n200: \n201: \treturn cleaned\n202: }\n\n(End of file - total 202 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"errors\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n)\n\nvar (\n\tErrMaxSessionsExceeded = errors.New(\"maximum number of sessions exceeded\")\n\tErrSessionNotFound     = errors.New(\"session not found\")\n)\n\ntype Session struct {\n\tID           string            // Unique session identifier\n\tBackendKey   string            // Associated backend key for sticky sessions\n\tCreatedAt    time.Time         // Session creation time\n\tLastActivity time.Time         // Last activity timestamp","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/session.go","time":{"start":1775849129784,"end":1775849129798}}}}
