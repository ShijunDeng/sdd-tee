{"type":"tool_use","timestamp":1775849134634,"sessionID":"ses_28725112effeLv38OgxzcMAJ8A","part":{"id":"prt_d78db54aa001HT2927BXigTyx3","messageID":"msg_d78db4783001urNd4aUgbSZsYV","sessionID":"ses_28725112effeLv38OgxzcMAJ8A","type":"tool","tool":"read","callID":"toolu_a07efd4c6d084a7691fc962e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/session_middleware.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/session_middleware.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"net/http\"\n6: \t\"strings\"\n7: \t\"time\"\n8: )\n9: \n10: type SessionManager struct {\n11: \tstore     SessionStore\n12: \tconfig    *Config\n13: \tcleanupCh chan struct{}\n14: }\n15: \n16: func NewSessionManager(config *Config) *SessionManager {\n17: \tstore := NewMemorySessionStoreWithTimeout(config.SessionMaxActive, config.SessionTimeout)\n18: \tstore.SetMaxSessions(config.SessionMaxActive)\n19: \n20: \treturn &SessionManager{\n21: \t\tstore:     store,\n22: \t\tconfig:    config,\n23: \t\tcleanupCh: make(chan struct{}),\n24: \t}\n25: }\n26: \n27: func (sm *SessionManager) Middleware(next http.Handler) http.Handler {\n28: \treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n29: \t\tif !sm.config.SessionEnabled {\n30: \t\t\tnext.ServeHTTP(w, r)\n31: \t\t\treturn\n32: \t\t}\n33: \n34: \t\tsessionID := sm.extractSessionID(r)\n35: \t\tvar session *Session\n36: \n37: \t\tif sessionID != \"\" {\n38: \t\t\tsession = sm.store.Get(sessionID)\n39: \t\t}\n40: \n41: \t\tif session == nil {\n42: \t\t\tbackendKey := r.Header.Get(\"X-Backend-Key\")\n43: \t\t\tif backendKey == \"\" {\n44: \t\t\t\tbackendKey = \"\"\n45: \t\t\t}\n46: \n47: \t\t\tvar err error\n48: \t\t\tsession, err = sm.store.Create(backendKey, nil)\n49: \t\t\tif err != nil {\n50: \t\t\t\thttp.Error(w, \"Failed to create session\", http.StatusServiceUnavailable)\n51: \t\t\t\treturn\n52: \t\t\t}\n53: \n54: \t\t\tsm.setSessionCookie(w, session.ID)\n55: \t\t} else {\n56: \t\t\t_ = sm.store.Update(session.ID)\n57: \t\t}\n58: \n59: \t\tr.Header.Set(\"X-Session-ID\", session.ID)\n60: \t\tif session.BackendKey != \"\" {\n61: \t\t\tr.Header.Set(\"X-Session-Backend\", session.BackendKey)\n62: \t\t}\n63: \n64: \t\tnext.ServeHTTP(w, r)\n65: \t})\n66: }\n67: \n68: func (sm *SessionManager) extractSessionID(r *http.Request) string {\n69: \tcookie, err := r.Cookie(sm.config.SessionCookieName)\n70: \tif err == nil && cookie != nil && cookie.Value != \"\" {\n71: \t\treturn cookie.Value\n72: \t}\n73: \n74: \tsessionID := r.Header.Get(\"X-Session-ID\")\n75: \tif sessionID != \"\" {\n76: \t\treturn sessionID\n77: \t}\n78: \n79: \treturn \"\"\n80: }\n81: \n82: func (sm *SessionManager) setSessionCookie(w http.ResponseWriter, sessionID string) {\n83: \tcookie := &http.Cookie{\n84: \t\tName:     sm.config.SessionCookieName,\n85: \t\tValue:    sessionID,\n86: \t\tPath:     \"/\",\n87: \t\tHttpOnly: sm.config.SessionCookieHTTPOnly,\n88: \t\tSecure:   sm.config.SessionCookieSecure,\n89: \t\tExpires:  time.Now().Add(sm.config.SessionTimeout),\n90: \t\tSameSite: http.SameSiteLaxMode,\n91: \t}\n92: \n93: \tif sm.config.SessionCookieDomain != \"\" {\n94: \t\tcookie.Domain = sm.config.SessionCookieDomain\n95: \t}\n96: \n97: \thttp.SetCookie(w, cookie)\n98: }\n99: \n100: func (sm *SessionManager) StartCleanup() {\n101: \tticker := time.NewTicker(sm.config.SessionCleanupInterval)\n102: \tgo func() {\n103: \t\tfor {\n104: \t\t\tselect {\n105: \t\t\tcase <-ticker.C:\n106: \t\t\t\tsm.store.Cleanup()\n107: \t\t\tcase <-sm.cleanupCh:\n108: \t\t\t\tticker.Stop()\n109: \t\t\t\treturn\n110: \t\t\t}\n111: \t\t}\n112: \t}()\n113: }\n114: \n115: func (sm *SessionManager) StopCleanup() {\n116: \tclose(sm.cleanupCh)\n117: }\n118: \n119: func (sm *SessionManager) GetStore() SessionStore {\n120: \treturn sm.store\n121: }\n122: \n123: func (sm *SessionManager) GetSession(r *http.Request) *Session {\n124: \tsessionID := sm.extractSessionID(r)\n125: \tif sessionID == \"\" {\n126: \t\treturn nil\n127: \t}\n128: \treturn sm.store.Get(sessionID)\n129: }\n130: \n131: func (sm *SessionManager) InvalidateSession(w http.ResponseWriter, sessionID string) error {\n132: \terr := sm.store.Delete(sessionID)\n133: \tif err != nil {\n134: \t\treturn err\n135: \t}\n136: \n137: \tcookie := &http.Cookie{\n138: \t\tName:     sm.config.SessionCookieName,\n139: \t\tValue:    \"\",\n140: \t\tPath:     \"/\",\n141: \t\tHttpOnly: sm.config.SessionCookieHTTPOnly,\n142: \t\tSecure:   sm.config.SessionCookieSecure,\n143: \t\tMaxAge:   -1,\n144: \t\tExpires:  time.Now().Add(-1 * time.Hour),\n145: \t}\n146: \thttp.SetCookie(w, cookie)\n147: \n148: \treturn nil\n149: }\n150: \n151: func (sm *SessionManager) IsEnabled() bool {\n152: \treturn sm.config.SessionEnabled\n153: }\n154: \n155: type SessionHandler struct {\n156: \tmanager *SessionManager\n157: }\n158: \n159: func NewSessionHandler(manager *SessionManager) *SessionHandler {\n160: \treturn &SessionHandler{manager: manager}\n161: }\n162: \n163: func (sh *SessionHandler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n164: \tpath := r.URL.Path\n165: \n166: \tif strings.HasPrefix(path, \"/v1/sessions\") {\n167: \t\tswitch r.Method {\n168: \t\tcase http.MethodGet:\n169: \t\t\tsh.listSessions(w, r)\n170: \t\t\treturn\n171: \t\tcase http.MethodDelete:\n172: \t\t\tsh.deleteSession(w, r)\n173: \t\t\treturn\n174: \t\t}\n175: \t}\n176: \n177: \tw.WriteHeader(http.StatusNotFound)\n178: }\n179: \n180: func (sh *SessionHandler) listSessions(w http.ResponseWriter, r *http.Request) {\n181: \tsessions := sh.manager.GetStore().List()\n182: \n183: \ttype sessionOutput struct {\n184: \t\tID           string    `json:\"id\"`\n185: \t\tBackendKey   string    `json:\"backendKey,omitempty\"`\n186: \t\tCreatedAt    time.Time `json:\"createdAt\"`\n187: \t\tLastActivity time.Time `json:\"lastActivity\"`\n188: \t\tExpiresAt    time.Time `json:\"expiresAt\"`\n189: \t}\n190: \n191: \toutput := make([]sessionOutput, len(sessions))\n192: \tfor i, s := range sessions {\n193: \t\toutput[i] = sessionOutput{\n194: \t\t\tID:           s.ID,\n195: \t\t\tBackendKey:   s.BackendKey,\n196: \t\t\tCreatedAt:    s.CreatedAt,\n197: \t\t\tLastActivity: s.LastActivity,\n198: \t\t\tExpiresAt:    s.ExpiresAt,\n199: \t\t}\n200: \t}\n201: \n202: \tresp := struct {\n203: \t\tSessions []sessionOutput `json:\"sessions\"`\n204: \t}{\n205: \t\tSessions: output,\n206: \t}\n207: \n208: \tdata, err := json.Marshal(resp)\n209: \tif err != nil {\n210: \t\thttp.Error(w, \"Failed to marshal sessions\", http.StatusInternalServerError)\n211: \t\treturn\n212: \t}\n213: \n214: \tw.Header().Set(\"Content-Type\", \"application/json\")\n215: \tw.WriteHeader(http.StatusOK)\n216: \tw.Write(data)\n217: }\n218: \n219: func (sh *SessionHandler) deleteSession(w http.ResponseWriter, r *http.Request) {\n220: \tsessionID := extractSessionIDFromPath(r.URL.Path)\n221: \tif sessionID == \"\" {\n222: \t\thttp.Error(w, \"session ID required\", http.StatusBadRequest)\n223: \t\treturn\n224: \t}\n225: \n226: \terr := sh.manager.GetStore().Delete(sessionID)\n227: \tif err != nil {\n228: \t\thttp.Error(w, err.Error(), http.StatusNotFound)\n229: \t\treturn\n230: \t}\n231: \n232: \tw.WriteHeader(http.StatusNoContent)\n233: }\n234: \n235: func extractSessionIDFromPath(path string) string {\n236: \tparts := strings.Split(path, \"/\")\n237: \tif len(parts) >= 4 && parts[1] == \"v1\" && parts[2] == \"sessions\" {\n238: \t\treturn parts[3]\n239: \t}\n240: \treturn \"\"\n241: }\n\n(End of file - total 241 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"strings\"\n\t\"time\"\n)\n\ntype SessionManager struct {\n\tstore     SessionStore\n\tconfig    *Config\n\tcleanupCh chan struct{}\n}\n\nfunc NewSess