st=header_list,\n443:                 provider=provider,\n444:                 verbose=verbose,\n445:             )\n446: \n447:             progress.update(task, completed=True)\n448: \n449:         console.print(\n450:             Panel(\n451:                 f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n452:                 f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n453:                 f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n454:                 f\"[bold]Response:[/bold]\",\n455:                 title=\"Invoke Complete\",\n456:                 style=\"green\",\n457:             )\n458:         )\n459: \n460:         import json\n461: \n462:         console.print_json(json.dumps(result[\"response\"], indent=2))\n463: \n464:     except Exception as e:\n465:         _handle_error(e, \"invoke\", verbose)\n466:         raise typer.Exit(code=1)\n467: \n468: \n469: @app.command()\n470: def status(\n471:     workspace: str = typer.Option(\n472:         \".\",\n473:         \"-f\",\n474:         \"--workspace\",\n475:         help=\"Path to the agent workspace directory\",\n476:     ),\n477:     provider: str = typer.Option(\n478:         \"agentcube\",\n479:         \"--provider\",\n480:         help=\"Target provider: 'agentcube' or 'k8s'\",\n481:     ),\n482:     verbose: bool = typer.Option(\n483:         False,\n484:         \"--verbose\",\n485:         help=\"Enable detailed logging\",\n486:     ),\n487: ) -> None:\n488:     \"\"\"\n489:     Check the status of a published agent.\n490: \n491:     Loads workspace metadata and displays agent status in a table.\n492:     \"\"\"\n493:     try:\n494:         if verbose:\n495:             logging.basicConfig(level=logging.DEBUG)\n496: \n497:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n498: \n499:         result = runtime.get_status(\n500:             workspace_path=workspace,\n501:             provider=provider,\n502:         )\n503: \n504:         table = Table(title=f\"Agent Status: {result.get('agent_name', 'Unknown')}\")\n505: \n506:         table.add_column(\"Field\", style=\"cyan\")\n507:         table.add_column(\"Value\", style=\"green\")\n508: \n509:         table.add_row(\"Agent Name\", result.get(\"agent_name\", \"N/A\"))\n510:         table.add_row(\"Agent ID\", result.get(\"agent_id\", \"N/A\"))\n511:         table.add_row(\"Provider\", result.get(\"provider\", \"N/A\"))\n512:         table.add_row(\"Status\", result.get(\"status\", \"unknown\"))\n513:         table.add_row(\"Endpoint\", result.get(\"endpoint\", \"N/A\"))\n514:         table.add_row(\"Namespace\", result.get(\"namespace\", \"N/A\"))\n515: \n516:         if \"error\" in result:\n517:             table.add_row(\"Error\", result[\"error\"])\n518: \n519:         console.print(table)\n520: \n521:         if result.get(\"status\") in [\"not_published\", \"error\"]:\n522:             raise typer.Exit(code=1)\n523: \n524:     except Exception as e:\n525:         _handle_error(e, \"status\", verbose)\n526:         raise typer.Exit(code=1)\n527: \n528: \n529: @app.command()\n530: def version() -> None:\n531:     \"\"\"Show version information.\"\"\"\n532:     console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n533: \n534: \n535: if __name__ == \"__main__\":\n536:     app()\n\n(End of file - total 536 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube CLI - Main entry point for kubectl-agentcube.\"\"\"\n\nimport logging\nfrom typing import List, Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\nfrom rich.panel import Panel\nfrom rich.table import Table\nfrom rich import print as rprint\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.runtime.invoke_runtime import In