{"type":"tool_use","timestamp":1775863989815,"sessionID":"ses_286429a63ffemovC7eb4MkAGfC","part":{"id":"prt_d79be0220001AgxrtUiUgJqM4M","messageID":"msg_d79bdea7e001ejnTWCabHELyXH","sessionID":"ses_286429a63ffemovC7eb4MkAGfC","type":"tool","tool":"read","callID":"toolu_c607c15e227a4ce4b11bbd38","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Metadata service for AgentCube - handles agent metadata loading, saving, and validation.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import os\n6: from pathlib import Path\n7: from typing import Any, Dict, Optional\n8: \n9: import yaml\n10: from pydantic import BaseModel, Field, field_validator\n11: \n12: \n13: class AgentMetadata(BaseModel):\n14:     \"\"\"Pydantic model for agent metadata configuration.\"\"\"\n15: \n16:     agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n17:     description: Optional[str] = Field(default=None, description=\"Human-readable summary\")\n18:     language: str = Field(default=\"python\", description=\"Programming language used\")\n19:     entrypoint: str = Field(..., description=\"Command to launch the agent\")\n20:     port: int = Field(default=8080, description=\"Port exposed by the agent runtime\")\n21:     build_mode: str = Field(default=\"local\", description=\"Build strategy: local or cloud\")\n22:     region: Optional[str] = Field(default=None, description=\"Deployment region\")\n23:     version: Optional[str] = Field(\n24:         default=None, description=\"Semantic version string for publishing\"\n25:     )\n26:     image: Optional[Dict[str, Any]] = Field(default=None, description=\"Container image information\")\n27:     auth: Optional[Dict[str, Any]] = Field(default=None, description=\"Authentication configuration\")\n28:     requirements_file: Optional[str] = Field(\n29:         default=\"requirements.txt\", description=\"Python dependency file\"\n30:     )\n31:     registry_url: Optional[str] = Field(default=\"\", description=\"Registry URL for image publishing\")\n32:     registry_username: Optional[str] = Field(default=\"\", description=\"Registry username\")\n33:     registry_password: Optional[str] = Field(default=\"\", description=\"Registry password\")\n34:     agent_endpoint: Optional[str] = Field(default=None, description=\"Agent endpoint URL\")\n35:     workload_manager_url: Optional[str] = Field(\n36:         default=None, description=\"URL for the Workload Manager\"\n37:     )\n38:     router_url: Optional[str] = Field(default=None, description=\"URL for the Router\")\n39:     readiness_probe_path: Optional[str] = Field(\n40:         default=None, description=\"Path for the readiness probe\"\n41:     )\n42:     readiness_probe_port: Optional[int] = Field(\n43:         default=None, description=\"Port for the readiness probe\"\n44:     )\n45:     agent_id: Optional[str] = Field(default=None, description=\"Agent ID assigned by AgentCube\")\n46:     session_id: Optional[str] = Field(default=None, description=\"The session ID for the agent\")\n47:     k8s_deployment: Optional[Dict[str, Any]] = Field(\n48:         default=None, description=\"Kubernetes deployment information\"\n49:     )\n50: \n51:     @field_validator(\"language\")\n52:     @classmethod\n53:     def validate_language(cls, v: str) -> str:\n54:         \"\"\"Validate that language is either python or java.\"\"\"\n55:         v_lower = v.lower()\n56:         if v_lower not in (\"python\", \"java\"):\n57:             raise ValueError(\"Language must be 'python' or 'java'\")\n58:         return v_lower\n59: \n60:     @field_validator(\"build_mode\")\n61:     @classmethod\n62:     def validate_build_mode(cls, v: str) -> str:\n63:         \"\"\"Validate that build_mode is either local or cloud.\"\"\"\n64:         v_lower = v.lower()\n65:         if v_lower not in (\"local\", \"cloud\"):\n66:             raise ValueError(\"Build mode must be 'local' or 'cloud'\")\n67:         return v_lower\n68: \n69:     @field_validator(\"port\")\n70:     @classmethod\n71:     def validate_port(cls, v: int) -> int:\n72:         \"\"\"Validate that port is in valid range (1-65535).\"\"\"\n73:         if not isinstance(v, int):\n74:             raise ValueError(\"Port must be an integer\")\n75:         if v < 1 or v > 65535:\n76:             raise ValueError(\"Port must be between 1 and 65535\")\n77:         return v\n78: \n79: \n80: class MetadataService:\n81:     \"\"\"Service for managing agent metadata in workspace.\"\"\"\n82: \n83:     METADATA_FILES = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n84: \n85:     @staticmethod\n86:     def load_metadata(workspace_path: str | Path) -> AgentMetadata:\n87:         \"\"\"\n88:         Load metadata from workspace with fallback chain.\n89: \n90:         Searches for metadata files in order: agent_metadata.yaml -> agent.yaml -> metadata.yaml\n91:         Raises FileNotFoundError if none found.\n92:         \"\"\"\n93:         workspace = Path(workspace_path)\n94: \n95:         for filename in MetadataService.METADATA_FILES:\n96:             metadata_file = workspace / filename\n97:             if metadata_file.exists():\n98:                 with open(metadata_file, \"r\", encoding=\"utf-8\") as f:\n99:                     data = yaml.safe_load(f)\n100:                     if data:\n101:                         return AgentMetadata(**data)\n102: \n103:         raise FileNotFoundError(\n104:             f\"No metadata file found in {workspace}. \"\n105:             f\"Expected one of: {', '.join(MetadataService.METADATA_FILES)}\"\n106:         )\n107: \n108:     @staticmethod\n109:     def save_metadata(workspace_path: str | Path, metadata: AgentMetadata) -> Path:\n110:         \"\"\"\n111:         Save metadata to workspace as agent_metadata.yaml.\n112: \n113:         Returns the path to the saved file.\n114:         \"\"\"\n115:         workspace = Path(workspace_path)\n116:         metadata_file = workspace / \"agent_metadata.yaml\"\n117: \n118:         with open(metadata_file, \"w\", encoding=\"utf-8\") as f:\n119:             yaml.safe_dump(metadata.model_dump(), f, default_flow_style=False, sort_keys=False)\n120: \n121:         return metadata_file\n122: \n123:     @staticmethod\n124:     def validate_workspace(workspace_path: str | Path) -> bool:\n125:         \"\"\"\n126:         Basic validation that workspace path exists and is a directory.\n127: \n128:         Returns True if valid.\n129:         Raises ValueError if not valid.\n130:         \"\"\"\n131:         workspace = Path(workspace_path)\n132: \n133:         if not workspace.exists():\n134:             raise ValueError(f\"Workspace path does not exist: {workspace}\")\n135: \n136:         if not workspace.is_dir():\n137:             raise ValueError(f\"Workspace path is not a directory: {workspace}\")\n138: \n139:         return True\n\n(End of file - total 139 lines)\n</content>","metadata":{"preview":"\"\"\"Metadata service for AgentCube - handles agent metadata loading, saving, and validation.\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Pydantic model for agent metadata configuration.\"\"\"\n\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: Optional[str] = Field(default=None, description=\"Human-readable summary\")\n    language: str = Field(default=\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(default=8080, description=\"Port exposed by the agent runtime\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/metadata_service.py","time":{"start":1775863989799,"end":1775863989813}}}}
