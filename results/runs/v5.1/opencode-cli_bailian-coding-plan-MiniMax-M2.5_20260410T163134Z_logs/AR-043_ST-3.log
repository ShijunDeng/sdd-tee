',\n56:     },\n57:     {\n58:       type: 'doc',\n59:       id: 'api/code-interpreter',\n60:       label: 'Code Interpreter',\n61:     },\n62:     {\n63:       type: 'doc',\n64:       id: 'api/cli',\n65:       label: 'CLI',\n66:     },\n67:   ],\n68: };\n69: \n70: export default sidebars;\n\n(End of file - total 70 lines)\n</content>","metadata":{"preview":"import type {SidebarsConfig} from '@docusaurus/plugin-content-docs';\n\nconst sidebars: SidebarsConfig = {\n  docs: [\n    {\n      type: 'doc',\n      id: 'intro',\n      label: 'Introduction',\n    },\n    {\n      type: 'category',\n      label: 'Getting Started',\n      collapsed: false,\n      items: [\n        'getting-started/installation',\n        'getting-started/quickstart',\n      ],\n    },\n    {\n      type: 'category',","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/docs/sidebars.ts","time":{"start":1775887273504,"end":1775887273509}}}}
