h Complete\",\n382:                 style=\"green\",\n383:             )\n384:         )\n385: \n386:     except Exception as e:\n387:         _handle_error(e, \"publish\", verbose)\n388:         raise typer.Exit(code=1)\n389: \n390: \n391: @app.command()\n392: def invoke(\n393:     workspace: str = typer.Option(\n394:         \".\",\n395:         \"-f\",\n396:         \"--workspace\",\n397:         help=\"Path to the agent workspace directory\",\n398:     ),\n399:     payload: str = typer.Option(\n400:         \"{}\",\n401:         \"--payload\",\n402:         help=\"JSON-formatted input passed to the agent\",\n403:     ),\n404:     header_list: Optional[list[str]] = typer.Option(\n405:         None,\n406:         \"--header\",\n407:         help=\"Custom HTTP headers (key:value format)\",\n408:     ),\n409:     provider: str = typer.Option(\n410:         \"agentcube\",\n411:         \"--provider\",\n412:         help=\"Target provider: 'agentcube' or 'k8s'\",\n413:     ),\n414:     verbose: bool = typer.Option(\n415:         False,\n416:         \"--verbose\",\n417:         help=\"Enable detailed logging\",\n418:     ),\n419: ) -> None:\n420:     \"\"\"\n421:     Invoke a published agent.\n422: \n423:     Posts JSON to the published agent endpoint and returns the response.\n424:     \"\"\"\n425:     try:\n426:         if verbose:\n427:             logging.basicConfig(level=logging.DEBUG)\n428: \n429:         with Progress(\n430:             SpinnerColumn(),\n431:             TextColumn(\"[progress.description]{task.description}\"),\n432:             console=console,\n433:         ) as progress:\n434:             task = progress.add_task(\"Invoking agent...\", total=None)\n435: \n436:             runtime = InvokeRuntime(verbose=verbose, provider=provider)\n437: \n438:             result = runtime.invoke(\n439:                 workspace_path=workspace,\n440:                 payload=payload,\n441:                 header_list=header_list,\n442:                 provider=provider,\n443:                 verbose=verbose,\n444:             )\n445: \n446:             progress.update(task, completed=True)\n447: \n448:         console.print(\n449:             Panel(\n450:                 f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n451:                 f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n452:                 f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n453:                 f\"[bold]Response:[/bold]\",\n454:                 title=\"Invoke Complete\",\n455:                 style=\"green\",\n456:             )\n457:         )\n458: \n459:         import json\n460: \n461:         console.print_json(json.dumps(result[\"response\"], indent=2))\n462: \n463:     except Exception as e:\n464:         _handle_error(e, \"invoke\", verbose)\n465:         raise typer.Exit(code=1)\n466: \n467: \n468: @app.command()\n469: def status(\n470:     workspace: str = typer.Option(\n471:         \".\",\n472:         \"-f\",\n473:         \"--workspace\",\n474:         help=\"Path to the agent workspace directory\",\n475:     ),\n476:     provider: str = typer.Option(\n477:         \"agentcube\",\n478:         \"--provider\",\n479:         help=\"Target provider: 'agentcube' or 'k8s'\",\n480:     ),\n481:     verbose: bool = typer.Option(\n482:         False,\n483:         \"--verbose\",\n484:         help=\"Enable detailed logging\",\n485:     ),\n486: ) -> None:\n487:     \"\"\"\n488:     Check the status of a published agent.\n489: \n490:     Loads workspace metadata and displays agent status in a table.\n491:     \"\"\"\n492:     try:\n493:         if verbose:\n494:             logging.basicConfig(level=logging.DEBUG)\n495: \n496:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n497: \n498:         result = runtime.get_status(\n499:             workspace_path=workspace,\n500:             provider=provider,\n501:         )\n502: \n503:         table = Table(title=f\"Agent Status: {result.get('agent_name', 'Unknown')}\")\n504: \n505:         table.add_column(\"Field\", style=\"cyan\")\n506:         table.add_column(\"Value\", style=\"green\")\n507: \n508:         table.add_row(\"Agent Name\", result.get(\"agent_name\", \"N/A\"))\n509:         table.add_row(\"Agent ID\", result.get(\"agent_id\", \"N/A\"))\n510:         table.add_row(\"Provider\", result.get(\"provider\", \"N/A\"))\n511:         table.add_row(\"Status\", result.get(\"status\", \"unknown\"))\n512:         table.add_row(\"Endpoint\", result.get(\"endpoint\", \"N/A\"))\n513:         table.add_row(\"Namespace\", result.get(\"namespace\", \"N/A\"))\n514: \n515:         if \"error\" in result:\n516:             table.add_row(\"Error\", result[\"error\"])\n517: \n518:         console.print(table)\n519: \n520:         if result.get(\"status\") in [\"not_published\", \"error\"]:\n521:             raise typer.Exit(code=1)\n522: \n523:     except Exception as e:\n524:         _handle_error(e, \"status\", verbose)\n525:         raise typer.Exit(code=1)\n526: \n527: \n528: @app.command()\n529: def version() -> None:\n530:     \"\"\"Show version information.\"\"\"\n531:     console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n532: \n533: \n534: if __name__ == \"__main__\":\n535:     app()\n\n(End of file - total 535 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube CLI - Main entry point for kubectl-agentcube.\"\"\"\n\nimport logging\nfrom typing import Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\nfrom rich.panel import Panel\nfrom rich.table import Table\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.runtime.invoke_runtime import InvokeRuntime\nfrom agentcube.runtime.status_runtime import StatusRuntime\n\napp = type