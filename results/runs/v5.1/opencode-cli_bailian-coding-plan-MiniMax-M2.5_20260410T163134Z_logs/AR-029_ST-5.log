{"type":"tool_use","timestamp":1775870669477,"sessionID":"ses_285dcc333ffeZVqrA2P99LeKx6","part":{"id":"prt_d7a23eaf3001gfe2D0sMvOo604","messageID":"msg_d7a23d868001riZOYh0du2AKMU","sessionID":"ses_285dcc333ffeZVqrA2P99LeKx6","type":"tool","tool":"read","callID":"toolu_143f978c1a7c4e58a643e455","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter_data_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter_data_plane.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n2: \n3: import pytest\n4: from unittest.mock import Mock, patch, MagicMock\n5: from pathlib import Path\n6: \n7: from agentcube.clients.code_interpreter_data_plane import (\n8:     CodeInterpreterDataPlaneClient,\n9: )\n10: from agentcube.exceptions import DataPlaneError\n11: \n12: \n13: class TestCodeInterpreterDataPlaneClient:\n14:     \"\"\"Test cases for CodeInterpreterDataPlaneClient.\"\"\"\n15: \n16:     def test_constructor_with_base_url(self):\n17:         \"\"\"Test constructor with explicit base_url.\"\"\"\n18:         client = CodeInterpreterDataPlaneClient(\n19:             router_url=\"http://router:8080\",\n20:             namespace=\"default\",\n21:             cr_name=\"my-interpreter\",\n22:             session_id=\"test-session\",\n23:             base_url=\"http://router:8080/api\",\n24:         )\n25:         assert client.base_url == \"http://router:8080/api\"\n26:         client.close()\n27: \n28:     def test_constructor_without_base_url(self):\n29:         \"\"\"Test constructor builds base_url from components.\"\"\"\n30:         client = CodeInterpreterDataPlaneClient(\n31:             router_url=\"http://router:8080\",\n32:             namespace=\"test-ns\",\n33:             cr_name=\"my-agent\",\n34:             session_id=\"test-session\",\n35:         )\n36:         assert \"test-ns\" in client.base_url\n37:         assert \"my-agent\" in client.base_url\n38:         assert \"invocations\" in client.base_url\n39:         client.close()\n40: \n41:     def test_constructor_session_header(self):\n42:         \"\"\"Test constructor sets x-agentcube-session-id header.\"\"\"\n43:         client = CodeInterpreterDataPlaneClient(\n44:             router_url=\"http://router:8080\",\n45:             namespace=\"default\",\n46:             cr_name=\"my-interpreter\",\n47:             session_id=\"test-session-123\",\n48:         )\n49:         assert client._headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n50:         client.close()\n51: \n52:     def test_constructor_default_values(self):\n53:         \"\"\"Test constructor sets default values.\"\"\"\n54:         client = CodeInterpreterDataPlaneClient(\n55:             router_url=\"http://router:8080\",\n56:             namespace=\"default\",\n57:             cr_name=\"my-interpreter\",\n58:             session_id=\"test-session\",\n59:         )\n60:         assert client.timeout == 120\n61:         assert client.connect_timeout == 5.0\n62:         client.close()\n63: \n64:     def test_execute_command(self):\n65:         \"\"\"Test execute_command makes POST request.\"\"\"\n66:         client = CodeInterpreterDataPlaneClient(\n67:             router_url=\"http://router:8080\",\n68:             namespace=\"default\",\n69:             cr_name=\"my-interpreter\",\n70:             session_id=\"test-session\",\n71:         )\n72: \n73:         mock_response = Mock()\n74:         mock_response.json.return_value = {\n75:             \"exit_code\": 0,\n76:             \"stdout\": \"hello\",\n77:             \"stderr\": \"\",\n78:         }\n79: \n80:         with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n81:             result = client.execute_command(\"ls -la\")\n82: \n83:             assert result[\"exit_code\"] == 0\n84:             mock_request.assert_called_once()\n85:         client.close()\n86: \n87:     def test_execute_command_with_timeout(self):\n88:         \"\"\"Test execute_command uses custom timeout.\"\"\"\n89:         client = CodeInterpreterDataPlaneClient(\n90:             router_url=\"http://router:8080\",\n91:             namespace=\"default\",\n92:             cr_name=\"my-interpreter\",\n93:             session_id=\"test-session\",\n94:             timeout=60,\n95:         )\n96: \n97:         mock_response = Mock()\n98:         mock_response.json.return_value = {\"exit_code\": 0}\n99: \n100:         with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n101:             client.execute_command(\"ls\", timeout=30)\n102: \n103:             call_kwargs = mock_request.call_args.kwargs\n104:             assert call_kwargs[\"timeout\"] == (5.0, 32.0)  # 30 + 2\n105:         client.close()\n106: \n107:     @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n108:     def test_write_file(self, mock_session_class):\n109:         \"\"\"Test write_file makes POST request with base64 content.\"\"\"\n110:         mock_response = Mock()\n111:         mock_response.json.return_value = {\"success\": True}\n112: \n113:         mock_session = Mock()\n114:         mock_session.request.return_value = mock_response\n115:         mock_session_class.return_value = mock_session\n116: \n117:         client = CodeInterpreterDataPlaneClient(\n118:             router_url=\"http://router:8080\",\n119:             namespace=\"default\",\n120:             cr_name=\"my-interpreter\",\n121:             session_id=\"test-session\",\n122:         )\n123:         client._session = mock_session\n124: \n125:         import base64\n126: \n127:         result = client.write_file(\"Hello World\", \"/tmp/test.txt\")\n128: \n129:         assert result[\"success\"] is True\n130:         call_kwargs = mock_session.request.call_args.kwargs\n131:         body = call_kwargs[\"json\"]\n132:         assert \"content\" in body\n133:         assert base64.b64decode(body[\"content\"]).decode() == \"Hello World\"\n134:         assert body[\"path\"] == \"/tmp/test.txt\"\n135:         client.close()\n136: \n137:     @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n138:     def test_list_files(self, mock_session_class):\n139:         \"\"\"Test list_files makes GET request with path param.\"\"\"\n140:         mock_response = Mock()\n141:         mock_response.json.return_value = {\"files\": [\"a.txt\", \"b.txt\"]}\n142: \n143:         mock_session = Mock()\n144:         mock_session.request.return_value = mock_response\n145:         mock_session_class.return_value = mock_session\n146: \n147:         client = CodeInterpreterDataPlaneClient(\n148:             router_url=\"http://router:8080\",\n149:             namespace=\"default\",\n150:             cr_name=\"my-interpreter\",\n151:             session_id=\"test-session\",\n152:         )\n153:         client._session = mock_session\n154: \n155:         result = client.list_files(\"/tmp\")\n156: \n157:         assert \"files\" in result\n158:         call_kwargs = mock_session.request.call_args.kwargs\n159:         assert call_kwargs[\"params\"][\"path\"] == \"/tmp\"\n160:         client.close()\n161: \n162:     @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n163:     def test_download_file(self, mock_session_class):\n164:         \"\"\"Test download_file streams to local file.\"\"\"\n165:         mock_response = Mock()\n166:         mock_response.iter_content = lambda chunk_size: [b\"test content\"]\n167: \n168:         mock_session = Mock()\n169:         mock_session.request.return_value = mock_response\n170:         mock_session_class.return_value = mock_session\n171: \n172:         client = CodeInterpreterDataPlaneClient(\n173:             router_url=\"http://router:8080\",\n174:             namespace=\"default\",\n175:             cr_name=\"my-interpreter\",\n176:             session_id=\"test-session\",\n177:         )\n178:         client._session = mock_session\n179: \n180:         with patch(\"pathlib.Path.open\", create=True) as mock_open:\n181:             mock_file = Mock()\n182:             mock_open.return_value.__enter__ = Mock(return_value=mock_file)\n183:             mock_open.return_value.__exit__ = Mock(return_value=False)\n184: \n185:             client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n186: \n187:         client.close()\n188: \n189:     def test_close(self):\n190:         \"\"\"Test close method closes the session.\"\"\"\n191:         client = CodeInterpreterDataPlaneClient(\n192:             router_url=\"http://router:8080\",\n193:             namespace=\"default\",\n194:             cr_name=\"my-interpreter\",\n195:             session_id=\"test-session\",\n196:         )\n197:         client._session.close = Mock()\n198:         client.close()\n199:         client._session.close.assert_called_once()\n\n(End of file - total 199 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nimport pytest\nfrom unittest.mock import Mock, patch, MagicMock\nfrom pathlib import Path\n\nfrom agentcube.clients.code_interpreter_data_plane import (\n    CodeInterpreterDataPlaneClient,\n)\nfrom agentcube.exceptions import DataPlaneError\n\n\nclass TestCodeInterpreterDataPlaneClient:\n    \"\"\"Test cases for CodeInterpreterDataPlaneClient.\"\"\"\n\n    def test_constructor_with_base_url(self):\n        \"\"\"Test constructor with explicit base_url.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter_data_plane.py","time":{"start":1775870669