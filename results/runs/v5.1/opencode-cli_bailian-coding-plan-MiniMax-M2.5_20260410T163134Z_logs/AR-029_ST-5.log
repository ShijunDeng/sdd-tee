efault\",\n34:             agent_name=\"my-agent\",\n35:             session_id=\"test-session-123\",\n36:         )\n37:         assert client._headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n38:         client.close()\n39: \n40:     def test_base_url_construction(self):\n41:         \"\"\"Test base URL is constructed from router components.\"\"\"\n42:         client = AgentRuntimeDataPlaneClient(\n43:             router_url=\"https://router.example.com\",\n44:             namespace=\"prod\",\n45:             agent_name=\"my-agent\",\n46:         )\n47:         assert (\n48:             client.base_url\n49:             == \"https://router.example.com/v1/namespaces/prod/agent-runtimes/my-agent/invocations/\"\n50:         )\n51:         client.close()\n52: \n53:     def test_base_url_explicit(self):\n54:         \"\"\"Test explicit base_url is used when provided.\"\"\"\n55:         client = AgentRuntimeDataPlaneClient(\n56:             router_url=\"http://router:8080\",\n57:             namespace=\"default\",\n58:             agent_name=\"my-agent\",\n59:             base_url=\"http://custom.example.com/api\",\n60:         )\n61:         assert client.base_url == \"http://custom.example.com/api\"\n62:         client.close()\n63: \n64:     @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n65:     def test_invoke_success(self, mock_create_session):\n66:         \"\"\"Test invoke makes correct POST request with JSON payload.\"\"\"\n67:         mock_session = Mock()\n68:         mock_response = Mock()\n69:         mock_response.json.return_value = {\"result\": \"success\"}\n70:         mock_response.raise_for_status = Mock()\n71:         mock_session.request.return_value = mock_response\n72:         mock_create_session.return_value = mock_session\n73: \n74:         client = AgentRuntimeDataPlaneClient(\n75:             router_url=\"http://router:8080\",\n76:             namespace=\"default\",\n77:             agent_name=\"my-agent\",\n78:             session_id=\"test-session-123\",\n79:         )\n80:         client._session = mock_session\n81: \n82:         result = client.invoke({\"tool\": \"calculator\", \"input\": {\"expression\": \"2+2\"}})\n83: \n84:         mock_session.request.assert_called_once()\n85:         call_args = mock_session.request.call_args\n86:         assert call_args[0][0] == \"POST\"\n87:         assert call_args[1][\"json\"] == {\"tool\": \"calculator\", \"input\": {\"expression\": \"2+2\"}}\n88:         assert call_args[1][\"headers\"][\"x-agentcube-session-id\"] == \"test-session-123\"\n89:         assert result == {\"result\": \"success\"}\n90:         client.close()\n91: \n92:     @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n93:     def test_invoke_with_timeout(self, mock_create_session):\n94:         \"\"\"Test invoke uses custom timeout when provided.\"\"\"\n95:         mock_session = Mock()\n96:         mock_response = Mock()\n97:         mock_response.json.return_value = {\"result\": \"success\"}\n98:         mock_response.raise_for_status = Mock()\n99:         mock_session.request.return_value = mock_response\n100:         mock_create_session.return_value = mock_session\n101: \n102:         client = AgentRuntimeDataPlaneClient(\n103:             router_url=\"http://router:8080\",\n104:             namespace=\"default\",\n105:             agent_name=\"my-agent\",\n106:             session_id=\"test-session-123\",\n107:         )\n108:         client._session = mock_session\n109: \n110:         client.invoke({\"tool\": \"test\"}, timeout=60)\n111: \n112:         call_args = mock_session.request.call_args\n113:         assert call_args[1][\"timeout\"] == (5.0, 60)\n114:         client.close()\n115: \n116:     @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n117:     def test_invoke_default_timeout(self, mock_create_session):\n118:         \"\"\"Test invoke uses default timeout tuple when timeout=None.\"\"\"\n119:       