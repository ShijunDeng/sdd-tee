{"type":"tool_use","timestamp":1775870662710,"sessionID":"ses_285dcc333ffeZVqrA2P99LeKx6","part":{"id":"prt_d7a23d47f0015arVrhJ6E2ceCH","messageID":"msg_d7a23c5e70015a2alaNgZxsTZX","sessionID":"ses_285dcc333ffeZVqrA2P99LeKx6","type":"tool","tool":"read","callID":"toolu_58650c2a31694ff79402c1ed","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_control_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_control_plane.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for ControlPlaneClient.\"\"\"\n2: \n3: import pytest\n4: from unittest.mock import Mock, patch, MagicMock\n5: \n6: from agentcube.clients.control_plane import ControlPlaneClient\n7: from agentcube.exceptions import SessionError\n8: \n9: \n10: class TestControlPlaneClient:\n11:     \"\"\"Test cases for ControlPlaneClient.\"\"\"\n12: \n13:     def test_constructor_requires_workload_manager_url(self):\n14:         \"\"\"Test ValueError is raised when workload_manager_url is not provided.\"\"\"\n15:         with pytest.raises(ValueError) as exc_info:\n16:             ControlPlaneClient()\n17:         assert \"workload_manager_url\" in str(exc_info.value).lower()\n18: \n19:     def test_constructor_with_env_var(self):\n20:         \"\"\"Test Workload Manager URL can be set via environment variable.\"\"\"\n21:         with patch.dict(\"os.environ\", {\"WORKLOAD_MANAGER_URL\": \"http://wm:8080\"}):\n22:             client = ControlPlaneClient()\n23:             assert client.base_url == \"http://wm:8080\"\n24:             client.close()\n25: \n26:     def test_constructor_with_explicit_url(self):\n27:         \"\"\"Test Workload Manager URL can be set explicitly.\"\"\"\n28:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n29:         assert client.base_url == \"http://wm:8080\"\n30:         client.close()\n31: \n32:     def test_constructor_with_auth_token(self):\n33:         \"\"\"Test auth token is set in headers.\"\"\"\n34:         client = ControlPlaneClient(\n35:             workload_manager_url=\"http://wm:8080\",\n36:             auth_token=\"test-token\",\n37:         )\n38:         assert \"Authorization\" in client._headers\n39:         assert client._headers[\"Authorization\"] == \"Bearer test-token\"\n40:         client.close()\n41: \n42:     def test_constructor_default_values(self):\n43:         \"\"\"Test constructor sets default values correctly.\"\"\"\n44:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n45:         assert client.timeout == 120\n46:         assert client.connect_timeout == 5.0\n47:         assert client.pool_connections == 10\n48:         assert client.pool_maxsize == 10\n49:         client.close()\n50: \n51:     @patch(\"agentcube.clients.control_plane.requests.Session\")\n52:     def test_create_session_success(self, mock_session_class):\n53:         \"\"\"Test create_session returns session ID on success.\"\"\"\n54:         mock_response = Mock()\n55:         mock_response.json.return_value = {\"sessionId\": \"test-session-123\"}\n56:         mock_response.raise_for_status = Mock()\n57: \n58:         mock_session = Mock()\n59:         mock_session.post.return_value = mock_response\n60:         mock_session_class.return_value = mock_session\n61: \n62:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n63:         client._session = mock_session\n64: \n65:         session_id = client.create_session(\n66:             name=\"test-agent\",\n67:             namespace=\"default\",\n68:             ttl=3600,\n69:         )\n70: \n71:         assert session_id == \"test-session-123\"\n72:         mock_session.post.assert_called_once()\n73:         client.close()\n74: \n75:     @patch(\"agentcube.clients.control_plane.requests.Session\")\n76:     def test_create_session_missing_session_id(self, mock_session_class):\n77:         \"\"\"Test create_session raises SessionError when sessionId is missing.\"\"\"\n78:         mock_response = Mock()\n79:         mock_response.json.return_value = {}\n80:         mock_response.raise_for_status = Mock()\n81: \n82:         mock_session = Mock()\n83:         mock_session.post.return_value = mock_response\n84:         mock_session_class.return_value = mock_session\n85: \n86:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n87:         client._session = mock_session\n88: \n89:         with pytest.raises(SessionError) as exc_info:\n90:             client.create_session(name=\"test\", namespace=\"default\")\n91:         assert \"sessionId\" in str(exc_info.value)\n92:         client.close()\n93: \n94:     @patch(\"agentcube.clients.control_plane.requests.Session\")\n95:     def test_delete_session_success(self, mock_session_class):\n96:         \"\"\"Test delete_session returns True on success.\"\"\"\n97:         mock_response = Mock()\n98:         mock_response.status_code = 200\n99:         mock_response.raise_for_status = Mock()\n100: \n101:         mock_session = Mock()\n102:         mock_session.delete.return_value = mock_response\n103:         mock_session_class.return_value = mock_session\n104: \n105:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n106:         client._session = mock_session\n107: \n108:         result = client.delete_session(\"test-session-123\")\n109:         assert result is True\n110:         client.close()\n111: \n112:     @patch(\"agentcube.clients.control_plane.requests.Session\")\n113:     def test_delete_session_not_found(self, mock_session_class):\n114:         \"\"\"Test delete_session returns True when session not found (404).\"\"\"\n115:         import requests\n116: \n117:         mock_response = Mock()\n118:         mock_response.status_code = 404\n119:         mock_response.raise_for_status = Mock(side_effect=requests.HTTPError())\n120: \n121:         mock_session = Mock()\n122:         mock_session.delete.return_value = mock_response\n123:         mock_session_class.return_value = mock_session\n124: \n125:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n126:         client._session = mock_session\n127: \n128:         result = client.delete_session(\"test-session-123\")\n129:         assert result is True\n130:         client.close()\n131: \n132:     def test_close(self):\n133:         \"\"\"Test close method closes the session.\"\"\"\n134:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n135:         client._session.close = Mock()\n136:         client.close()\n137:         client._session.close.assert_called_once()\n\n(End of file - total 137 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for ControlPlaneClient.\"\"\"\n\nimport pytest\nfrom unittest.mock import Mock, patch, MagicMock\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\nfrom agentcube.exceptions import SessionError\n\n\nclass TestControlPlaneClient:\n    \"\"\"Test cases for ControlPlaneClient.\"\"\"\n\n    def test_constructor_requires_workload_manager_url(self):\n        \"\"\"Test ValueError is raised when workload_manager_url is not provided.\"\"\"\n        with pytest.raises(ValueError) as exc_info:\n            ControlPlaneClient()\n        assert \"workload_manager_url\" in str(exc_info.value).lower()\n\n    def test_constructor_with_env_var(self):\n        \"\"\"Test Workload Manager URL can be set via environment variable.\"\"\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_control_plane.py","time":{"start":1775870662693,"end":1775870662708}}}}
