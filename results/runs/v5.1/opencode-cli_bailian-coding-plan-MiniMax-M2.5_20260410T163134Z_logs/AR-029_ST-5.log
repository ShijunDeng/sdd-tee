n     client.close()\n \n+def test_run_code(self):\n+    \"\"\"Test run_code makes POST request with language and code.\"\"\"\n+    client = CodeInterpreterDataPlaneClient(\n+        router_url=\"http://router:8080\",\n+        namespace=\"default\",\n+        cr_name=\"my-interpreter\",\n+        session_id=\"test-session\",\n+    )\n+\n+    mock_response = Mock()\n+    mock_response.json.return_value = {\n+        \"exit_code\": 0,\n+        \"stdout\": \"Hello World\",\n+        \"stderr\": \"\",\n+    }\n+\n+    with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n+        result = client.run_code(\"python\", \"print('Hello World')\")\n+\n+        assert result == \"Hello World\"\n+        call_kwargs = mock_request.call_args.kwargs\n+        assert call_kwargs[\"json\"][\"command\"] == [\"python\", \"-c\", \"print('Hello World')\"]\n+    client.close()\n+\n+def test_run_code_with_timeout(self):\n+    \"\"\"Test run_code uses custom timeout.\"\"\"\n+    client = CodeInterpreterDataPlaneClient(\n+        router_url=\"http://router:8080\",\n+        namespace=\"default\",\n+        cr_name=\"my-interpreter\",\n+        session_id=\"test-session\",\n+        timeout=60,\n+    )\n+\n+    mock_response = Mock()\n+    mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n+\n+    with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n+        client.run_code(\"python\", \"print('test')\", timeout=30)\n+\n+        call_kwargs = mock_request.call_args.kwargs\n+        assert call_kwargs[\"timeout\"] == (5.0, 32.0)  # 30 + 2\n+    client.close()\n+\n @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n def test_write_file(self, mock_session_class):\n     \"\"\"Test write_file makes POST request with base64 content.\"\"\"\n     mock_response = Mock()\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter_data_plane.py","before":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nimport pytest\nfrom unittest.mock import Mock, patch, MagicMock\nfrom pathlib import Path\n\nfrom agentcube.clients.code_interpreter_data_plane import (\n    CodeInterpreterDataPlaneClient,\n)\nfrom agentcube.exceptions import DataPlaneError\n\n\nclass TestCodeInterpreterDataPlaneClient:\n    \"\"\"Test cases for CodeInterpreterDataPlaneClient.\"\"\"\n\n    def test_constructor_with_base_url(self):\n        \"\"\"Test constructor with explicit base_url.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/api\",\n        )\n        assert client.base_url == \"http://router:8080/api\"\n        client.close()\n\n    def test_constructor_without_base_url(self):\n        \"\"\"Test constructor builds base_url from components.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"test-ns\",\n            cr_name=\"my-agent\",\n            session_id=\"test-session\",\n        )\n        assert \"test-ns\" in client.base_url\n        assert \"my-agent\" in client.base_url\n        assert \"invocations\" in client.base_url\n        client.close()\n\n    def test_constructor_session_header(self):\n        \"\"\"Test constructor sets x-agentcube-session-id header.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session-123\",\n        )\n        assert client._headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n        client.close()\n\n    def test_constructor_default_values(self):\n        \"\"\"Test constructor sets default values.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        client.close()\n\n    def test_execute_command(self):\n        \"\"\"Test execute_command makes POST request.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n\n        mock_response = Mock()\n        mock_response.json.return_value = {\n            \"exit_code\": 0,\n            \"stdout\": \"hello\",\n            \"stderr\": \"\",\n        }\n\n        with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n            result = client.execute_command(\"ls -la\")\n\n            assert result[\"exit_code\"] == 0\n            mock_request.assert_called_once()\n        client.close()\n\n    def test_execute_command_with_timeout(self):\n        \"\"\"Test execute_command uses custom timeout.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n            timeout=60,\n        )\n\n        mock_response = Mock()\n        mock_response.json.return_value = {\"exit_code\": 0}\n\n        with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n            client.execute_command(\"ls\", timeout=30)\n\n            call_kwargs = mock_request.call_args.kwargs\n            assert call_kwargs[\"timeout\"] == (5.0, 32.0)  # 30 + 2\n        client.close()\n\n    @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n    def test_write_file(self, mock_session_class):\n        \"\"\"Test write_file makes POST request with base64 content.\"\"\"\n        mock_response = Mock()\n        mock_response.json.return_value = {\"success\": True}\n\n        mock_session = Mock()\n        mock_session.request.return_value = mock_response\n        mock_session_class.return_value = mock_session\n\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        client._session = mock_session\n\n        import base64\n\n        result = client.write_file(\"Hello World\", \"/tmp/test.txt\")\n\n        assert result[\"success\"] is True\n        call_kwargs = mock_session.request.call_args.kwargs\n        body = call_kwargs[\"json\"]\n        assert \"content\" in body\n        assert base64.b64decode(body[\"content\"]).decode() == \"Hello World\"\n        assert body[\"path\"] == \"/tmp/test.txt\"\n        client.close()\n\n    @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n    def test_list_files(self, mock_session_class):\n        \"\"\"Test list_files makes GET request with path param.\"\"\"\n        mock_response = Mock()\n        mock_response.json.return_value = {\"files\": [\"a.txt\", \"b.txt\"]}\n\n        mock_session = Mock()\n        mock_session.request.return_value = mock_response\n        mock_session_class.return_value = mock_session\n\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        client._session = mock_session\n\n        result = client.list_files(\"/tmp\")\n\n        assert \"files\" in result\n        call_kwargs = mock_session.request.call_args.kwargs\n        assert call_kwargs[\"params\"][\"path\"] == \"/tmp\"\n        client.close()\n\n    @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n    def test_download_file(self, mock_session_class):\n        \"\"\"Test download_file streams to local file.\"\"\"\n        mock_response = Mock()\n        mock_response.iter_content = lambda chunk_size: [b\"test content\"]\n\n        mock_session = Mock()\n        mock_session.request.return_value = mock_response\n        mock_session_class.return_value = mock_session\n\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        client._session = mock_session\n\n        with patch(\"pathlib.Path.open\", create=True) as mock_open:\n            mock_file = Mock()\n            mock_open.return_value.__enter__ = Mock(return_value=mock_file)\n            mock_open.return_value.__exit__ = Mock(return_value=False)\n\n            client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n\n        client.close()\n\n    def test_close(self):\n        \"\"\"Test close method closes the session.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        client._session.close = Mock()\n        client.close()\n        client._session.close.assert_called_once()\n","after":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nimport pytest\nfrom unittest.mock import Mock, patch, MagicMock\nfrom pathlib import Path\n\nfrom agentcube.clients.code_interpreter_data_plane import (\n    CodeInterpreterDataPlaneClient,\n)\nfrom agentcube.exceptions import DataPlaneError\n\n\nclass TestCodeInterpreterDataPlaneClient:\n    \"\"\"Test cases for CodeInterpreterDataPlaneClient.\"\"\"\n\n    def test_constructor_with_base_url(self):\n        \"\"\"Test constructor with explicit base_url.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/api\",\n        )\n        assert client.base_url == \"http://router:8080/api\"\n        client.close()\n\n    def test_constructor_without_base_url(self):\n        \"\"\"Test constructor builds base_url from components.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"test-ns\",\n            cr_name=\"my-agent\",\n            session_id=\"test-session\",\n        )\n        assert \"test-ns\" in client.base_url\n        assert \"my-agent\" in client.base_url\n        assert \"invocations\" in client.base_url\n        client.close()\n\n    def test_constructor_session_header(self):\n        \"\"\"Test constructor sets x-agentcube-session-id header.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session-123\",\n        )\n        assert client._headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n        client.close()\n\n    def test_constructor_default_values(self):\n        \"\"\"Test constructor sets default values.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        client.close()\n\n    def test_execute_command(self):\n        \"\"\"Test execute_command makes POST request.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n\n        mock_response = Mock()\n        mock_response.json.return_value = {\n            \"exit_code\": 0,\n            \"stdout\": \"hello\",\n            \"stderr\": \"\",\n        }\n\n        with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n            result = client.execute_command(\"ls -la\")\n\n            assert result == \"hello\"\n            mock_request.assert_called_once()\n        client.close()\n\n    def test_execute_command_with_list(self):\n        \"\"\"Test execute_command works with list of arguments.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n\n        mock_response = Mock()\n        mock_response.json.return_value = {\n            \"exit_code\": 0,\n            \"stdout\": \"test output\",\n            \"stderr\": \"\",\n        }\n\n        with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n            result = client.execute_command([\"ls\", \"-la\", \"/tmp\"])\n\n            assert result == \"test output\"\n            call_kwargs = mock_request.call_args.kwargs\n            assert call_kwargs[\"json\"][\"command\"] == [\"ls\", \"-la\", \"/tmp\"]\n        client.close()\n\n    def test_execute_command_with_timeout(self):\n        \"\"\"Test execute_command uses custom timeout.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n            timeout=60,\n        )\n\n        mock_response = Mock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n\n        with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n            client.execute_command(\"ls\", timeout=30)\n\n            call_kwargs = mock_request.call_args.kwargs\n            assert call_kwargs[\"timeout\"] == (5.0, 32.0)  # 30 + 2\n        client.close()\n\n    def test_run_code(self):\n        \"\"\"Test run_code makes POST request with language and code.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n\n        mock_response = Mock()\n        mock_response.json.return_value = {\n            \"exit_code\": 0,\n            \"stdout\": \"Hello World\",\n            \"stderr\": \"\",\n        }\n\n        with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n            result = client.run_code(\"python\", \"print('Hello World')\")\n\n            assert result == \"Hello World\"\n            call_kwargs = mock_request.call_args.kwargs\n            assert call_kwargs[\"json\"][\"command\"] == [\"python\", \"-c\", \"print('Hello World')\"]\n        client.close()\n\n    def test_run_code_with_timeout(self):\n        \"\"\"Test run_code uses custom timeout.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n            timeout=60,\n        )\n\n        mock_response = Mock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n\n        with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n            client.run_code(\"python\", \"print('test')\", timeout=30)\n\n            call_kwargs = mock_request.call_args.kwargs\n            assert call_kwargs[\"timeout\"] == (5.0, 32.0)  # 30 + 2\n        client.close()\n\n    @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n    def test_write_file(self, mock_session_class):\n        \"\"\"Test write_file makes POST request with base64 content.\"\"\"\n        mock_response = Mock()\n        mock_response.json.return_value = {\"success\": True}\n\n        mock_session = Mock()\n        mock_session.request.return_value = mock_response\n        mock_session_class.return_value = mock_session\n\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        client._session = mock_session\n\n        import base64\n\n        result = client.write_file(\"Hello World\", \"/tmp/test.txt\")\n\n        assert result[\"success\"] is True\n        call_kwargs = mock_session.request.call_args.kwargs\n        body = call_kwargs[\"json\"]\n        assert \"content\" in body\n        assert base64.b64decode(body[\"content\"]).decode() == \"Hello World\"\n        assert body[\"path\"] == \"/tmp/test.txt\"\n        client.close()\n\n    @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n    def test_list_files(self, mock_session_class):\n        \"\"\"Test list_files makes GET request with path param.\"\"\"\n        mock_response = Mock()\n        mock_response.json.return_value = {\"files\": [\"a.txt\", \"b.txt\"]}\n\n        mock_session = Mock()\n        mock_session.request.return_value = mock_response\n        mock_session_class.return_value = mock_session\n\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        client._session = mock_session\n\n        result = client.list_files(\"/tmp\")\n\n        assert \"files\" in result\n        call_kwargs = mock_session.request.call_args.kwargs\n        assert call_kwargs[\"params\"][\"path\"] == \"/tmp\"\n        client.close()\n\n    @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n    def test_download_file(self, mock_session_class):\n        \"\"\"Test download_file streams to local file.\"\"\"\n        mock_response = Mock()\n        mock_response.iter_content = lambda chunk_size: [b\"test content\"]\n\n        mock_session = Mock()\n        mock_session.request.return_value = mock_response\n        mock_session_class.return_value = mock_session\n\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        client._session = mock_session\n\n        with patch(\"pathlib.Path.open\", create=True) as mock_open:\n            mock_file = Mock()\n            mock_open.return_value.__enter__ = Mock(return_value=mock_file)\n            mock_open.return_value.__exit__ = Mock(return_value=False)\n\n            client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n\n        client.close()\n\n    def test_close(self):\n        \"\"\"Test close method closes the session.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            cr_name=\"my-interpreter\",\n            session_id=\"test-session\",\n        )\n        client._session.close = Mock()\n        client.close()\n        client._session.close.assert_called_once()\n","additions":70,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter_data_plane.py","time":{"start":1775870793312,"end":1775870793864}}}}
