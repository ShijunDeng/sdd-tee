e)\n+    client.close()\n+\n+@patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n def test_invoke_raises_data_plane_error(self, mock_create_session):\n     \"\"\"Test invoke raises DataPlaneError on request failure.\"\"\"\n     import requests\n \n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_agent_runtime_data_plane.py","before":"\"\"\"Tests for AgentRuntimeDataPlaneClient.\"\"\"\n\nfrom unittest.mock import Mock, patch\n\nimport pytest\n\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom agentcube.exceptions import DataPlaneError\n\n\nclass TestAgentRuntimeDataPlaneClient:\n    \"\"\"Test cases for AgentRuntimeDataPlaneClient.\"\"\"\n\n    def test_session_header_constant(self):\n        \"\"\"Test SESSION_HEADER class constant.\"\"\"\n        assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n\n    def test_constructor_default_values(self):\n        \"\"\"Test constructor sets default values correctly.\"\"\"\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n        )\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        client.close()\n\n    def test_constructor_with_session_id(self):\n        \"\"\"Test constructor with session_id sets header correctly.\"\"\"\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n            session_id=\"test-session-123\",\n        )\n        assert client._headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n        client.close()\n\n    def test_base_url_construction(self):\n        \"\"\"Test base URL is constructed from router components.\"\"\"\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"prod\",\n            agent_name=\"my-agent\",\n        )\n        assert (\n            client.base_url\n            == \"https://router.example.com/v1/namespaces/prod/agent-runtimes/my-agent/invocations/\"\n        )\n        client.close()\n\n    def test_base_url_explicit(self):\n        \"\"\"Test explicit base_url is used when provided.\"\"\"\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n            base_url=\"http://custom.example.com/api\",\n        )\n        assert client.base_url == \"http://custom.example.com/api\"\n        client.close()\n\n    @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n    def test_invoke_success(self, mock_create_session):\n        \"\"\"Test invoke makes correct POST request with JSON payload.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.json.return_value = {\"result\": \"success\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.request.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n            session_id=\"test-session-123\",\n        )\n        client._session = mock_session\n\n        result = client.invoke({\"tool\": \"calculator\", \"input\": {\"expression\": \"2+2\"}})\n\n        mock_session.request.assert_called_once()\n        call_args = mock_session.request.call_args\n        assert call_args[0][0] == \"POST\"\n        assert call_args[1][\"json\"] == {\"tool\": \"calculator\", \"input\": {\"expression\": \"2+2\"}}\n        assert call_args[1][\"headers\"][\"x-agentcube-session-id\"] == \"test-session-123\"\n        assert result == {\"result\": \"success\"}\n        client.close()\n\n    @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n    def test_invoke_with_timeout(self, mock_create_session):\n        \"\"\"Test invoke uses custom timeout when provided.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.json.return_value = {\"result\": \"success\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.request.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n            session_id=\"test-session-123\",\n        )\n        client._session = mock_session\n\n        client.invoke({\"tool\": \"test\"}, timeout=60)\n\n        call_args = mock_session.request.call_args\n        assert call_args[1][\"timeout\"] == (5.0, 60)\n        client.close()\n\n    @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n    def test_invoke_default_timeout(self, mock_create_session):\n        \"\"\"Test invoke uses default timeout tuple when timeout=None.\"\"\"\n        mock_session = Mock()\n        mock_response = Mock()\n        mock_response.json.return_value = {\"result\": \"success\"}\n        mock_response.raise_for_status = Mock()\n        mock_session.request.return_value = mock_response\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n            session_id=\"test-session-123\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        client._session = mock_session\n\n        client.invoke({\"tool\": \"test\"}, timeout=None)\n\n        call_args = mock_session.request.call_args\n        assert call_args[1][\"timeout\"] == (5.0, 120)\n        client.close()\n\n    @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n    def test_invoke_raises_data_plane_error(self, mock_create_session):\n        \"\"\"Test invoke raises DataPlaneError on request failure.\"\"\"\n        import requests\n\n        mock_session = Mock()\n        mock_session.request.side_effect = requests.RequestException(\"Connection failed\")\n        mock_create_session.return_value = mock_session\n\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n            session_id=\"test-session-123\",\n        )\n        client._session = mock_session\n\n        with pytest.raises(DataPlaneError):\n            client.invoke({\"tool\": \"test\"})\n        client.close()\n\n    def test_close(self):\n        \"\"\"Test close method closes the session.\"\"\"\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n        )\n        client._session.close = Mock()\n        client.close()\n        client._session.close.assert_called_once()\n","after":"\"\"\"Tests for AgentRuntimeDataPlaneClient.\"\"\"\n\nfrom unittest.mock import Mock, patch\n\nimport pytest\n\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom agentcube.exceptions import DataPlaneError\n\n\nclass TestAgentRuntimeDataPlaneClient:\n    \"\"\"Test cases for AgentRuntimeDataPlaneClient.\"\"\"\n\n    def test_session_header_constant(self):\n        \"\"\"Test SESSION_HEADER class constant.\"\"\"\n        assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n\n    def test_constructor_default_values(self):\n        \"\"\"Test constructor sets default values correctly.\"\"\"\n        client = AgentRuntimeDataPla