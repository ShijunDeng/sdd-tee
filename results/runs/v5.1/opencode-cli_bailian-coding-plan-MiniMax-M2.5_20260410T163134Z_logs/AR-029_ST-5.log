on()\n151: \n152:     def write_file(\n153:         self,\n154:         content: str,\n155:         remote_path: str,\n156:         mode: str = \"0644\",\n157:     ) -> Dict:\n158:         \"\"\"\n159:         Write a file to the Code Interpreter.\n160: \n161:         Args:\n162:             content: The file content (will be base64 encoded).\n163:             remote_path: The remote path where the file will be written.\n164:             mode: File permissions (default: 0644).\n165: \n166:         Returns:\n167:             A dictionary containing the response data.\n168: \n169:         Raises:\n170:             DataPlaneError: If the write fails.\n171:         \"\"\"\n172:         body = {\n173:             \"content\": base64.b64encode(content.encode()).decode(),\n174:             \"path\": remote_path,\n175:             \"mode\": mode,\n176:         }\n177: \n178:         response = self._request(\n179:             \"POST\",\n180:             \"api/files\",\n181:             json=body,\n182:         )\n183: \n184:         return response.json()\n185: \n186:     def upload_file(\n187:         self,\n188:         local_path: str,\n189:         remote_path: str,\n190:     ) -> Dict:\n191:         \"\"\"\n192:         Upload a file to the Code Interpreter.\n193: \n194:         Args:\n195:             local_path: Path to the local file.\n196:             remote_path: The remote path where the file will be written.\n197: \n198:         Returns:\n199:             A dictionary containing the response data.\n200: \n201:         Raises:\n202:             DataPlaneError: If the upload fails.\n203:         \"\"\"\n204:         local_file = Path(local_path)\n205:         if not local_file.exists():\n206:             raise DataPlaneError(f\"Local file not found: {local_path}\")\n207: \n208:         with open(local_file, \"rb\") as f:\n209:             files = {\"file\": (local_file.name, f)}\n210:             headers = dict(self._headers)\n211:             headers[\"x-agentcub