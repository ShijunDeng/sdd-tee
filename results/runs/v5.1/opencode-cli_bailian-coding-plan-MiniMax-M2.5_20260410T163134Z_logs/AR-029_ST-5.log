he session.\"\"\"\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n        )\n        client._session.close = Mock()\n        client.close()\n        client._session.close.assert_called_once()\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_agent_runtime_data_plane.py","time":{"start":1775870836044,"end":1775870836561}}}}
