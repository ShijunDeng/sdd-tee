e-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/models/agent_models.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/conftest.py":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/agentcube_provider.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/agentcube_provider.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/agentcube_provider.py\n@@ -97,18 +97,30 @@\n client = self._get_client()\n \n if client is None:\n     self.logger.warning(\"Using mock AgentRuntime deployment\")\n+    final_env_vars = env_vars or {}\n+    if workload_manager_url and \"WORKLOAD_MANAGER_URL\" not in final_env_vars:\n+        final_env_vars[\"WORKLOAD_MANAGER_URL\"] = workload_manager_url\n+    if router_url and \"ROUTER_URL\" not in final_env_vars:\n+        final_env_vars[\"ROUTER_URL\"] = router_url\n     return {\n         \"name\": agent_name,\n         \"namespace\": self.namespace,\n         \"endpoint\": f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\",\n+        \"env_vars\": final_env_vars,\n     }\n \n try:\n     k8s = client\n     custom_objects = k8s.CustomObjectsApi()\n \n+    final_env_vars = env_vars or {}\n+    if workload_manager_url and \"WORKLOAD_MANAGER_URL\" not in final_env_vars:\n+        final_env_vars[\"WORKLOAD_MANAGER_URL\"] = workload_manager_url\n+    if router_url and \"ROUTER_URL\" not in final_env_vars:\n+        final_env_vars[\"ROUTER_URL\"] = router_url\n+\n     agent_runtime = {\n         \"apiVersion\": f\"{self.CR_GROUP}/{self.CR_VERSION}\",\n         \"kind\": \"AgentRuntime\",\n         \"metadata\": {\n@@ -117,8 +129,9 @@\n         },\n         \"spec\": {\n             \"maxSessionDuration\": \"8h\",\n             \"sessionTimeout\": \"15m\",\n+            \"imagePullSecrets\": [{\"name\": \"default-secret\"}],\n             \"targetPorts\": [\n                 {\n                     \"port\": port,\n                     \"protocol\": \"HTTP\",\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/agentcube_provider.py","before":"\"\"\"AgentCube provider for AgentCube - handles AgentRuntime CRD operations.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom typing import Any, Dict, Optional\n\n\nclass AgentCubeProvider:\n    \"\"\"Provider for AgentCube AgentRuntime CRD deployments.\"\"\"\n\n    CR_GROUP = \"runtime.agentcube.volcano.sh\"\n    CR_VERSION = \"v1alpha1\"\n    CR_PLURAL = \"agentruntimes\"\n\n    def __init__(\n        self,\n        namespace: str = \"default\",\n        verbose: bool = False,\n        kubeconfig: Optional[str] = None,\n    ):\n        \"\"\"\n        Initialize the AgentCubeProvider.\n\n        Args:\n            namespace: Kubernetes namespace\n            verbose: Enable verbose logging\n            kubeconfig: Path to kubeconfig file\n        \"\"\"\n        self.namespace = namespace\n        self.verbose = verbose\n        self.kubeconfig = kubeconfig\n        self.logger = logging.getLogger(__name__)\n\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        else:\n            logging.basicConfig(level=logging.INFO)\n\n        self._client = None\n\n    def _get_client(self) -> Any:\n        \"\"\"Get Kubernetes client (lazy initialization).\"\"\"\n        if self._client is not None:\n            return self._client\n\n        try:\n            from kubernetes import client, config\n        except ImportError:\n            self.logger.warning(\"kubernetes library not available, using mock mode\")\n            return None\n\n        try:\n            if self.kubeconfig:\n                config.load_kube_config(config_file=self.kubeconfig)\n            else:\n                try:\n                    config.load_kube_config()\n                except Exception:\n                    config.load_incluster_config()\n\n            self._client = client\n            return self._client\n        except Exception as e:\n            self.logger.warning(f\"Could not load k8s config: {e}, using mock mode\")\n            return None\n\n    def deploy_agent_runtime(\n        self,\n        agent_name: str,\n        image_url: str,\n        port: int,\n        entrypoint: Optional[str] = None,\n        env_vars: Optional[Dict[str, str]] = None,\n        workload_manager_url: Optional[str] = None,\n        router_url: Optional[str] = None,\n        readiness_probe_path: Optional[str] = None,\n        readiness_probe_port: Optional[int] = None,\n    ) -> Dict[str, Any]:\n        \"\"\"\n        Deploy an AgentRuntime to Kubernetes.\n\n        Args:\n            agent_name: Name of the agent\n            image_url: Container image URL\n            port: Port to expose\n            entrypoint: Entrypoint command\n            env_vars: Environment variables\n            workload_manager_url: URL for Workload Manager\n            router_url: URL for Router\n            readiness_probe_path: Path for readiness probe\n            readiness_probe_port: Port for readiness probe\n\n        Returns:\n            Dictionary with deployment info\n        \"\"\"\n        client = self._get_client()\n\n        if client is None:\n            self.logger.warning(\"Using mock AgentRuntime deployment\")\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"endpoint\": f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\",\n            }\n\n        try:\n            k8s = client\n            custom_objects = k8s.CustomObjectsApi()\n\n            agent_runtime = {\n                \"apiVersion\": f\"{self.CR_GROUP}/{self.CR_VERSION}\",\n                \"kind\": \"AgentRuntime\",\n                \"metadata\": {\n                    \"name\": agent_name,\n                    \"namespace\": self.namespace,\n                },\n                \"spec\": {\n                    \"maxSessionDuration\": \"8h\",\n                    \"sessionTimeout\": \"15m\",\n                    \"targetPorts\": [\n                        {\n                            \"port\": port,\n                            \"protocol\": \"HTTP\",\n                            \"name\": \"http\",\n                        }\n                    ],\n                    \"podTemplate\": {\n                        \"spec\": {\n                            \"containers\": [\n                                {\n                                    \"name\": \"agent\",\n                                    \"image\": image_url,\n                                    \"resources\": {\n                                        \"limits\": {\n                                            \"cpu\": \"1\",\n                                            \"memory\": \"1Gi\",\n                                        }\n                                    },\n                                }\n                            ]\n                        }\n                    },\n                },\n            }\n\n            if entrypoint:\n                agent_runtime[\"spec\"][\"podTemplate\"][\"spec\"][\"containers\"][0][\"command\"] = [\n                    \"sh\",\n                    \"-c\",\n                    entrypoint,\n                ]\n\n            if env_vars:\n                agent_runtime[\"spec\"][\"podTemplate\"][\"spec\"][\"containers\"][0][\"env\"] = [\n                    {\"name\": k, \"value\": v} for k, v in env_vars.items()\n                ]\n\n            custom_objects.create_namespaced_custom_object(\n                group=self.CR_GROUP,\n                version=self.CR_VERSION,\n                plural=self.CR_PLURAL,\n                namespace=self.namespace,\n                body=agent_runtime,\n            )\n\n            endpoint = f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\"\n\n            return {\n                \"name\": agent_name,\n                \"namespace\": self.namespace,\n                \"endpoint\": endpoint,\n            }\n\n        except Exception as e:\n            self.logger.error(f\"Failed to deploy AgentRuntime: {e}\")\n            raise ValueError(f\"AgentRuntime deployment failed: {e}\")\n\n    def get_agent_runtime(self, name: str, namespace: str) -> Optional[Dict[str, Any]]:\n        \"\"\"\n        Get an AgentRuntime resource.\n\n        Args:\n            name: Name of the AgentRuntime\n            namespace: Namespace\n\n        Returns:\n            Dictionary with AgentRuntime info or None\n        \"\"\"\n        client = self._get_client()\n\n        if client is None:\n            return {\n                \"name\": name,\n                \"namespace\": namespace,\n                \"status\": {\n                    \"phase\": \"Running\",\n                    \"endpoint\": f\"http://{name}.{namespace}.svc.cluster.local:8080\",\n                },\n            }\n\n        try:\n            k8s = client\n            custom_objects = k8s.CustomObjectsApi()\n\n            ar = custom_objects.get_namespaced_custom_object(\n                group=self.CR_GROUP,\n                version=self.CR_VERSION,\n                plural=self.CR_PLURAL,\n                namespace=namespace,\n                name=name,\n            )\n\n            return ar\n\n        except Exception as e:\n            self.logger.warning(f\"AgentRuntime not found: {e}\")\n            return None\n","after":"\"\"\"AgentCube provider for AgentCube - handles AgentRuntime CRD operations.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom typing import Any, Dict, Optional\n\n\nclass AgentCubeProvider:\n    \"\"\"Provider for AgentCube AgentRuntime CRD deployments.\"\"\"\n\n    CR_GROUP = \"runtime.agentcube.volcano.sh\"\n    CR_VERSION = \"v1alpha1\"\n    CR_PLURAL = \"agentruntimes\"\n\n    def __init__(\n        self,\n        namespace: str = \"default\",\n        verbose: bool = False,\n        kubeconfig: Optional[str] = None,\n    ):\n        \"\"\"\n        Initialize the AgentCubeProvider.\n\n        Args:\n            namespace: Kubernetes namespace\n            verbose: Enable verbose logging\n            kubeconfig: Path to kubeconfig file\n        \"\"\"\n        self.namespace = namespace\n        self.verbose = verbose\n        self.kubeconfig = kubeconfig\n        self.logger = logging.getLogger(__name__)\n\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        else:\n            logging.basicConfig(level=logging.INFO)\n\n        self._client = None\n\n    def _get_client(self) -> Any:\n        \"\"\"Get Kubernetes client (lazy initialization).\"\"\"\n        if self._client is not None:\n            return self._client\n\n        try:\n            from kubernetes import client, config\n        except ImportError:\n            self.logger.warning(\"kubernetes library not available, using mock mode\")\n            return None\n\n        try:\n            if self.kubeconfig:\n                config.load_kube_config(config_file=self.kubeconfig)\n            else:\n                try:\n                    config.load_kube_config()\n                except Exception:\n                    config.load_incluster_config()\n\n            self._client = client\n            return self._client\n        except Exception as e:\n            self.logger.warning(f\"Could not load k8s config: {e}, using mock mode\")\n            return None\n\n    def deploy_agent_runtime(\