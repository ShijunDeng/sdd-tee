us_with_k8s_provider(self, mock_provider):\n39:         \"\"\"Test status with K8s provider.\"\"\"\n40:         mock_instance = MagicMock()\n41:         mock_instance.get_agent_status.return_value = {\n42:             \"name\": \"test\",\n43:             \"status\": \"running\",\n44:             \"ready_replicas\": 1,\n45:         }\n46:         mock_provider.return_value = mock_instance\n47: \n48:         with tempfile.TemporaryDirectory() as tmpdir:\n49:             workspace = Path(tmpdir)\n50: \n51:             metadata = AgentMetadata(\n52:                 agent_name=\"test\",\n53:                 language=\"python\",\n54:                 entrypoint=\"python main.py\",\n55:                 agent_id=\"test-id\",\n56:                 agent_endpoint=\"http://test:8080\",\n57:             )\n58: \n59:             with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n60:                 yaml.safe_dump(metadata.model_dump(), f)\n61: \n62:             runtime = StatusRuntime(provider=\"k8s\")\n63:             result = runtime.get_status(str(workspace), provider=\"k8s\")\n64: \n65:             assert result[\"provider\"] == \"k8s\"\n66: \n67:     @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n68:     def test_status_with_agentcube_provider(self, mock_provider):\n69:         \"\"\"Test status with AgentCube provider.\"\"\"\n70:         mock_instance = MagicMock()\n71:         mock_instance.get_agent_runtime.return_value = {\n72:             \"metadata\": {\"name\": \"test\", \"namespace\": \"default\"},\n73:             \"status\": {\"phase\": \"Running\", \"endpoint\": \"http://test:8080\"},\n74:         }\n75:         mock_provider.return_value = mock_instance\n76: \n77:         with tempfile.TemporaryDirectory() as tmpdir:\n78:             workspace = Path(tmpdir)\n79: \n80:             metadata = AgentMetadata(\n81:                 agent_name=\"test\",\n82:                 language=\"python\",\n83:                 entrypoint=\"python main.py\",\n84:                 agent_id=\"test-id\",\n85:                 agent_endpoint=\"http://test:8080\",\n86:             )\n87: \n88:             with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n89:                 yaml.safe_dump(metadata.model_dump(), f)\n90: \n91:             runtime = StatusRuntime(provider=\"agentcube\")\n92:             result = runtime.get_status(str(workspace), provider=\"agentcube\")\n93: \n94:             assert result[\"provider\"] == \"agentcube\"\n95: \n96:     @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n97:     def test_status_error_handling(self, mock_provider):\n98:         \"\"\"Test status when error occurs.\"\"\"\n99:         mock_instance = MagicMock()\n100:         mock_instance.get_agent_runtime.side_effect = Exception(\"K8s cluster unavailable\")\n101:         mock_provider.return_value = mock_instance\n102: \n103:         with tempfile.TemporaryDirectory() as tmpdir:\n104:             workspace = Path(tmpdir)\n105: \n106:             metadata = AgentMetadata(\n107:                 agent_name=\"test\",\n108:                 language=\"python\",\n109:                 entrypoint=\"python main.py\",\n110:                 agent_id=\"test-id\",\n111:                 agent_endpoint=\"http://test:8080\",\n112:             )\n113: \n114:             with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n115:                 yaml.safe_dump(metadata.model_dump(), f)\n116: \n117:             runtime = StatusRuntime(provider=\"agentcube\")\n118:             result = runtime.get_status(str(workspace), provider=\"agentcube\")\n119: \n120:             assert result[\"status\"] == \"error\"\n121:             assert \"K8s cluster unavailable\" in result[\"error\"]\n122: \n123:     @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n124:     def test_status_custom_namespace(self, mock_provider):\n125:         \"\"\"Test status with custom namespace from k8s_deployment.\"\"\"\n126:         mock_instance = MagicMock()\n127:         mock_instance.get_agent_runtime.return_value = {\n128:             \"metadata\": {\"name\": \"test\", \"namespace\": \"custom-ns\"},\n129:             \"status\": {\"phase\": \"Running\", \"endpoint\": \"http://test:8080\"},\n130:         }\n131:         mock_provider.return_value = mock_instance\n132: \n133:         with tempfile.TemporaryDirectory() as tmpdir:\n134:             workspace = Path(tmpdir)\n135: \n136:             metadata = AgentMetadata(\n137:                 agent_name=\"test\",\n138:                 language=\"python\",\n139:                 entrypoint=\"python main.py\",\n140:                 agent_id=\"test-id\",\n141:                 agent_endpoint=\"http://test:8080\",\n142:                 k8s_deployment={\"namespace\": \"custom-ns\"},\n143:             )\n144: \n145:             with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n146:                 yaml.safe_dump(metadata.model_dump(), f)\n147: \n148:             runtime = StatusRuntime(provider=\"agentcube\")\n149:             result = runtime.get_status(str(workspace))\n150: \n151:             assert result[\"namespace\"] == \"custom-ns\"\n152: \n153: \n154: class TestStatusRuntimeK8sStatus:\n155:     \"\"\"Tests for _get_k8s_status method.\"\"\"\n156: \n157:     @patch(\"agentcube.services.k8s_provider.KubernetesProvider\")\n158:     def test_get_k8s_status(self, mock_provider):\n159:         \"\"\"Test getting K8s status.\"\"\"\n160:         mock_instance = MagicMock()\n161:         mock_instance.get_agent_status.return_value = {\n162:             \"status\": \"running\",\n163:             \"ready_replicas\": 1,\n164:         }\n165:         mock_provider.return_value = mock_instance\n166: \n167:         with tempfile.TemporaryDirectory() as tmpdir:\n168:             workspace = Path(tmpdir)\n169: \n170:             metadata = AgentMetadata(\n171:                 agent_name=\"test\",\n172:                 language=\"python\",\n173:                 entrypoint=\"python main.py\",\n174:             )\n175: \n176:             runtime = StatusRuntime()\n177:             result = runtime._get_k8s_status(metadata)\n178: \n179:             assert result[\"status\"] == \"running\"\n180: \n181: \n182: class TestStatusRuntimeCRStatus:\n183:     \"\"\"Tests for _get_cr_k8s_status method.\"\"\"\n184: \n185:     @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n186:     def test_get_cr_k8s_status(self, mock_provider):\n187:         \"\"\"Test getting CR K8s status.\"\"\"\n188:         mock_instance = MagicMock()\n189:         mock_instance.get_agent_runtime.return_value = {\n190:             \"metadata\": {\"name\": \"test\", \"namespace\": \"default\"},\n191:             \"status\": {\"phase\": \"Running\", \"endpoint\": \"http://test:8080\"},\n192:         }\n193:         mock_provider.return_value = mock_instance\n194: \n195:         with tempfile.TemporaryDirectory() as tmpdir:\n196:             workspace = Path(tmpdir)\n197: \n198:             metadata = AgentMetadata(\n199:                 agent_name=\"test\",\n200:                 language=\"python\",\n201:                 entrypoint=\"python main.py\",\n202:                 agent_id=\"test-id\",\n203:             )\n204: \n205:             runtime = StatusRuntime()\n206:             result = runtime._get_cr_k8s_status(metadata)\n207: \n208:             assert result[\"status\"] == \"Running\"\n209: \n210:     @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n211:     def test_get_cr_k8s_status_no_status_field(self, mock_provider):\n212:         \"\"\"Test getting CR K8s status when status field is empty.\"\"\"\n213:         mock_instance = MagicMock()\n214:         mock_instance.get_agent_runtime.return_value = {\n215:             \"metadata\": {\"name\": \"test\", \"namespace\": \"default\"},\n216:             \"status\": {},\n217:         }\n218:         mock_provider.return_value = mock_instance\n219: \n220:         with tempfile.TemporaryDirectory() as tmpdir:\n221:             workspace = Path(tmpdir)\n222: \n223:             metadata = AgentMetadata(\n224:                 agent_name=\"test\",\n225:                 language=\"python\",\n226:                 entrypoint=\"python main.py\",\n227:                 agent_id=\"test-id\",\n228:             )\n229: \n230:             runtime = StatusRuntime()\n231:             result = runtime._get_cr_k8s_status(metadata)\n232: \n233:             assert result[\"status\"] == \"created_no_status\"\n234: \n235:     @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n236:     def test_get_cr_k8s_status_not_found(self, mock_provider):\n237:         \"\"\"Test getting CR K8s status when agent not found.\"\"\"\n238:         mock_instance = MagicMock()\n239:         mock_instance.get_agent_runtime.return_value = None\n240:         mock_provider.return_value = mock_instance\n241: \n242:         with tempfile.TemporaryDirectory() as tmpdir:\n243:             workspace = Path(tmpdir)\n244: \n245:             metadata = AgentMetadata(\n246:                 agent_name=\"test\",\n247:                 language=\"python\",\n248:                 entrypoint=\"python main.py\",\n249:                 agent_id=\"test-id\",\n250:             )\n251: \n252:             runtime = StatusRuntime()\n253:             result = runtime._get_cr_k8s_status(metadata)\n254: \n255:             assert result[\"status\"] == \"not_found\"\n\n(End of file - total 255 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for StatusRuntime.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\nimport yaml\n\nfrom agentcube.runtime.status_runtime import StatusRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestStatusRuntimeGetStatus:\n    \"\"\"Tests for get_status method.\"\"\"\n\n    def test_status_not_published(self):\n        \"\"\"Test status when agent not published.\"\"