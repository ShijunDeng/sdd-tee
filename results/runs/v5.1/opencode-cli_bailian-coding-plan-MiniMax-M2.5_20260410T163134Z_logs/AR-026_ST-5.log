{"type":"tool_use","timestamp":1775867074818,"sessionID":"ses_286147b38ffe4yr2fwmnne0SgF","part":{"id":"prt_d79ed148f0012YUtb344wXeGjj","messageID":"msg_d79ecfd4b001nYH2Oxxhajy0pt","sessionID":"ses_286147b38ffe4yr2fwmnne0SgF","type":"tool","tool":"read","callID":"toolu_0c44d83bb94e422bb52d7dc6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/status_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/status_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Status runtime for AgentCube - orchestrates the status command workflow.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: from pathlib import Path\n7: from typing import Any, Dict, Optional\n8: \n9: from agentcube.services.metadata_service import MetadataService\n10: from agentcube.services.k8s_provider import KubernetesProvider\n11: from agentcube.services.agentcube_provider import AgentCubeProvider\n12: \n13: \n14: class StatusRuntime:\n15:     \"\"\"\n16:     Core runtime for checking agent status.\n17: \n18:     Retrieves and displays agent status from the target provider.\n19:     \"\"\"\n20: \n21:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\"):\n22:         \"\"\"\n23:         Initialize the StatusRuntime.\n24: \n25:         Args:\n26:             verbose: Enable verbose logging\n27:             provider: Target provider (agentcube or k8s)\n28:         \"\"\"\n29:         self.verbose = verbose\n30:         self.provider = provider\n31:         self.logger = logging.getLogger(__name__)\n32:         if verbose:\n33:             logging.basicConfig(level=logging.DEBUG)\n34:         else:\n35:             logging.basicConfig(level=logging.INFO)\n36: \n37:         self.metadata_service = MetadataService()\n38: \n39:     def _get_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n40:         \"\"\"\n41:         Get status from Kubernetes deployment.\n42: \n43:         Args:\n44:             metadata: Agent metadata\n45: \n46:         Returns:\n47:             Status dictionary\n48:         \"\"\"\n49:         namespace = \"default\"\n50:         if metadata.k8s_deployment and metadata.k8s_deployment.get(\"namespace\"):\n51:             namespace = metadata.k8s_deployment[\"namespace\"]\n52: \n53:         k8s_provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n54: \n55:         agent_name = metadata.agent_id or metadata.agent_name\n56:         status = k8s_provider.get_agent_status(agent_name)\n57: \n58:         return status\n59: \n60:     def _get_cr_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n61:         \"\"\"\n62:         Get status from AgentRuntime CR.\n63: \n64:         Args:\n65:             metadata: Agent metadata\n66: \n67:         Returns:\n68:             Status dictionary\n69:         \"\"\"\n70:         namespace = \"default\"\n71:         if metadata.k8s_deployment and metadata.k8s_deployment.get(\"namespace\"):\n72:             namespace = metadata.k8s_deployment[\"namespace\"]\n73: \n74:         agentcube_provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n75: \n76:         agent_name = metadata.agent_id or metadata.agent_name\n77:         cr = agentcube_provider.get_agent_runtime(agent_name, namespace)\n78: \n79:         if cr:\n80:             phase = cr.get(\"status\", {}).get(\"phase\")\n81:             if phase:\n82:                 return {\n83:                     \"name\": cr.get(\"metadata\", {}).get(\"name\"),\n84:                     \"namespace\": cr.get(\"metadata\", {}).get(\"namespace\"),\n85:                     \"status\": phase,\n86:                     \"endpoint\": cr.get(\"status\", {}).get(\"endpoint\"),\n87:                 }\n88:             return {\n89:                 \"name\": cr.get(\"metadata\", {}).get(\"name\"),\n90:                 \"namespace\": cr.get(\"metadata\", {}).get(\"namespace\"),\n91:                 \"status\": \"created_no_status\",\n92:                 \"endpoint\": cr.get(\"status\", {}).get(\"endpoint\"),\n93:             }\n94: \n95:         return {\n96:             \"name\": agent_name,\n97:             \"namespace\": namespace,\n98:             \"status\": \"not_found\",\n99:         }\n100: \n101:     def get_status(\n102:         self,\n103:         workspace_path: str,\n104:         provider: Optional[str] = None,\n105:     ) -> dict:\n106:         \"\"\"\n107:         Get agent status from the target provider.\n108: \n109:         Args:\n110:             workspace_path: Path to agent workspace\n111:             provider: Target provider (agentcube or k8s)\n112: \n113:         Returns:\n114:             Dictionary with status information\n115: \n116:         Raises:\n117:             ValueError: If agent not published\n118:         \"\"\"\n119:         workspace = Path(workspace_path).resolve()\n120:         provider = provider or self.provider\n121: \n122:         metadata = self.metadata_service.load_metadata(workspace)\n123: \n124:         if not metadata.agent_id and not metadata.agent_endpoint:\n125:             return {\n126:                 \"agent_name\": metadata.agent_name,\n127:                 \"status\": \"not_published\",\n128:                 \"message\": \"Agent not published. Run 'publish' first.\",\n129:             }\n130: \n131:         try:\n132:             if provider == \"agentcube\":\n133:                 status = self._get_cr_k8s_status(metadata)\n134:             else:\n135:                 status = self._get_k8s_status(metadata)\n136: \n137:             return {\n138:                 \"agent_name\": metadata.agent_name,\n139:                 \"agent_id\": metadata.agent_id,\n140:                 \"provider\": provider,\n141:                 \"status\": status.get(\"status\", \"unknown\"),\n142:                 \"endpoint\": status.get(\"endpoint\") or metadata.agent_endpoint,\n143:                 \"namespace\": status.get(\"namespace\", \"default\"),\n144:             }\n145: \n146:         except Exception as e:\n147:             return {\n148:                 \"agent_name\": metadata.agent_name,\n149:                 \"status\": \"error\",\n150:                 \"error\": str(e),\n151:             }\n\n(End of file - total 151 lines)\n</content>","metadata":{"preview":"\"\"\"Status runtime for AgentCube - orchestrates the status command workflow.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import MetadataService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nclass StatusRuntime:\n    \"\"\"\n    Core runtime for checking agent status.\n\n    Retrieves and displays agent status from the target provider.\n    \"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/status_runtime.py","time":{"start":1775867074800,"end":1775867074815}}}}
