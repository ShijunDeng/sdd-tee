son:\"sandboxId\"`\n39: \tNamespace        string      `json:\"namespace\"`\n40: \tReason           string      `json:\"reason\"`\n41: \tInitiator        string      `json:\"initiator\"`\n42: \tDuration         int64       `json:\"duration\"`\n43: \tResourcesCleaned []string    `json:\"resourcesCleaned\"`\n44: \tTimestamp        metav1.Time `json:\"timestamp\"`\n45: }\n46: \n47: type DeletionEvent struct {\n48: \tType           string      `json:\"type\"`\n49: \tReason         string      `json:\"reason\"`\n50: \tMessage        string      `json:\"message\"`\n51: \tInvolvedObject string      `json:\"involvedObject\"`\n52: \tTimestamp      metav1.Time `json:\"timestamp\"`\n53: }\n54: \n55: type Sandbox struct {\n56: \tName           string            `json:\"name\"`\n57: \tNamespace      string            `json:\"namespace\"`\n58: \tSessionID      string            `json:\"sessionId\"`\n59: \tState          SandboxState      `json:\"state\"`\n60: \tCreatedAt      time.Time         `json:\"createdAt\"`\n61: \tExpiresAt      *time.Time        `json:\"expiresAt,omitempty\"`\n62: \tLastActivityAt *time.Time        `json:\"lastActivityAt,omitempty\"`\n63: \tLabels         map[string]string `json:\"labels,omitempty\"`\n64: \tAnnotations    map[string]string `json:\"annotations,omitempty\"`\n65: }\n66: \n67: type SandboxState string\n68: \n69: const (\n70: \tSandboxStateUnknown  SandboxState = \"Unknown\"\n71: \tSandboxStatePending  SandboxState = \"Pending\"\n72: \tSandboxStateRunning  SandboxState = \"Running\"\n73: \tSandboxStateFailed   SandboxState = \"Failed\"\n74: \tSandboxStateDeleting SandboxState = \"Deleting\"\n75: )\n76: \n77: type SandboxList struct {\n78: \tItems []Sandbox `json:\"items\"`\n79: }\n80: \n81: type ListOptions struct {\n82: \tLabelSelector string `form:\"labelSelector\"`\n83: \tFieldSelector string `form:\"fieldSelector\"`\n84: \tLimit         int64  `form:\"limit\"`\n85: \tContinue      string `form:\"continue\"`\n86: }\n87: \n88: type DeleteResponse struct {\n89: \tName             string      `json:\"name\"`\n90: \tNamespace        string      `json:\"namespace\"`\n91: \tDeletedAt        metav1.Time `json:\"deletedAt\"`\n92: \tResourcesCleaned []string    `json:\"resourcesCleaned\"`\n93: }\n94: \n95: type BatchDeleteResponse struct {\n96: \tDeletedCount int      `json:\"deletedCount\"`\n97: \tFailedCount  int      `json:\"failedCount\"`\n98: \tErrors       []string `json:\"errors,omitempty\"`\n99: }\n100: \n101: type APIResponse struct {\n102: \tKind       string      `json:\"kind\"`\n103: \tAPIVersion string      `json:\"apiVersion\"`\n104: \tStatus     string      `json:\"status\"`\n105: \tData       interface{} `json:\"data,omitempty\"`\n106: \tMetadata   *ListMeta   `json:\"metadata,omitempty\"`\n107: }\n108: \n109: type ListMeta struct {\n110: \tContinue           string `json:\"continue,omitempty\"`\n111: \tRemainingItemCount *int64 `json:\"remainingItemCount,omitempty\"`\n112: \tResourceVersion    string `json:\"resourceVersion,omitempty\"`\n113: }\n114: \n115: type APIError struct {\n116: \tKind       string           `json:\"kind\"`\n117: \tAPIVersion string           `json:\"apiVersion\"`\n118: \tStatus     string           `json:\"status\"`\n119: \tMessage    string           `json:\"message\"`\n120: \tReason     string           `json:\"reason\"`\n121: \tCode       int              `json:\"code\"`\n122: \tDetails    *APIErrorDetails `json:\"details,omitempty\"`\n123: }\n124: \n125: type APIErrorDetails struct {\n126: \tName   string          `json:\"name,omitempty\"`\n127: \tGroup  string          `json:\"group,omitempty\"`\n128: \tKind   string          `json:\"kind,omitempty\"`\n129: \tUID    string          `json:\"uid,omitempty\"`\n130: \tCauses []APIErrorCause `json:\"causes,omitempty\"`\n131: }\n132: \n133: type APIErrorCause struct {\n134: \tMessage string `json:\"message\"`\n135: \tField   string `json:\"field\"`\n136: }\n137: \n138: type PaginationRequest struct {\n139: \tLimit    int64  `form:\"limit\"`\n140: \tContinue string `form:\"continue\"`\n141: }\n142: \n143: type PaginationResponse struct {\n144: \tItems              interface{} `json:\"items\"`\n145: \tListMeta           *ListMeta   `json:\"metadata\"`\n146: \tRemainingItemCount *int64      `json:\"remainingItemCount,omitempty\"`\n147: }\n148: \n149: type AgentRuntimeListResponse struct {\n150: \tKind       string             `json:\"kind\"`\n151: \tAPIVersion string             `json:\"apiVersion\"`\n152: \tItems      []AgentRuntimeItem `json:\"items\"`\n153: \t*ListMeta\n154: }\n155: \n156: type AgentRuntimeItem struct {\n157: \tmetav1.TypeMeta   `json:\",inline\"`\n158: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n159: \tSpec              interface{} `json:\"spec,omitempty\"`\n160: \tStatus            interface{} `json:\"status,omitempty\"`\n161: }\n162: \n163: type CodeInterpreterListResponse struct {\n164: \tKind       string                `json:\"kind\"`\n165: \tAPIVersion string                `json:\"apiVersion\"`\n166: \tItems      []CodeInterpreterItem `json:\"items\"`\n167: \t*ListMeta\n168: }\n169: \n170: type CodeInterpreterItem struct {\n171: \tmetav1.TypeMeta   `json:\",inline\"`\n172: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n173: \tSpec              interface{} `json:\"spec,omitempty\"`\n174: \tStatus            interface{} `json:\"status,omitempty\"`\n175: }\n176: \n177: type CreateAgentRuntimeRequest struct {\n178: \tmetav1.TypeMeta   `json:\",inline\"`\n179: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n180: \tSpec              interface{} `json:\"spec,omitempty\"`\n181: }\n182: \n183: type CreateCodeInterpreterRequest struct {\n184: \tmetav1.TypeMeta   `json:\",inline\"`\n185: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n186: \tSpec              interface{} `json:\"spec,omitempty\"`\n187: }\n188: \n189: type UpdateAgentRuntimeRequest struct {\n190: \tmetav1.TypeMeta   `json:\",inline\"`\n191: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n192: \tSpec              interface{} `json:\"spec,omitempty\"`\n193: }\n194: \n195: type UpdateCodeInterpreterRequest struct {\n196: \tmetav1.TypeMeta   `json:\",inline\"`\n197: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n198: \tSpec              interface{} `json:\"spec,omitempty\"`\n199: }\n200: \n201: type WatchEvent struct {\n202: \tType   string      `json:\"type\"`\n203: \tObject interface{} `json:\"object\"`\n204: }\n205: \n206: func NewAPIResponse(data interface{}, metadata *ListMeta) *APIResponse {\n207: \treturn &APIResponse{\n208: \t\tKind:       \"Status\",\n209: \t\tAPIVersion: \"v1\",\n210: \t\tStatus:     \"Success\",\n211: \t\tData:       data,\n212: \t\tMetadata:   metadata,\n213: \t}\n214: }\n215: \n216: func NewAPIError(message, reason string, code int) *APIError {\n217: \treturn &APIError{\n218: \t\tKind:       \"Status\",\n219: \t\tAPIVersion: \"v1\",\n220: \t\tStatus:     \"Failure\",\n221: \t\tMessage:    message,\n222: \t\tReason:     reason,\n223: \t\tCode:       code,\n224: \t}\n225: }\n\n(End of file - total 225 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"errors\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nvar (\n\tErrSandboxNotFound    = errors.New(\"sandbox not found\")\n\tErrDeletionFailed     = errors.New(\"deletion failed\")\n\tErrStaleFinalizer     = errors.New(\"stale finalizer\")\n\tErrOrphanedResource   = errors.New(\"orphaned resource\")\n\tErrResourceNotFound   = errors.New(\"resource not found\")\n\tErrResourceNotDeleted = errors.New(\"resource not deleted\")\n)\n\ntype DeleteOptions struct {\n\tGracePeriodSeconds *int64 `form:\"gracePeriodSeconds,omitempty\" json:\"gracePeriodSeconds,omitempty\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/types.go","time":{"start":1775844880385,"end":1775844880403}}}}
