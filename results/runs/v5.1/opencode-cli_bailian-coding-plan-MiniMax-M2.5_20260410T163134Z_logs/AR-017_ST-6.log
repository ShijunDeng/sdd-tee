{"type":"tool_use","timestamp":1775857410804,"sessionID":"ses_286a6b3f6ffeR9JuYfYvatljVo","part":{"id":"prt_d79599aa00016NDVUj7c3B4pbY","messageID":"msg_d79598b40001UVhfc4ExCKEG2g","sessionID":"ses_286a6b3f6ffeR9JuYfYvatljVo","type":"tool","tool":"read","callID":"toolu_fc3aefefd15d4181beb8bf09","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_middleware.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_middleware.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"strings\"\n6: \n7: \t\"github.com/gin-gonic/gin\"\n8: \t\"github.com/golang-jwt/jwt/v5\"\n9: )\n10: \n11: type AuthMiddleware struct {\n12: \tauthManager     *AuthManager\n13: \tpublicPaths     []string\n14: \tallowQueryParam bool\n15: \tjwtIssuer       string\n16: \tjwtAudience     string\n17: }\n18: \n19: func NewAuthMiddleware(authManager *AuthManager, publicPaths []string, allowQueryParam bool, jwtIssuer, jwtAudience string) *AuthMiddleware {\n20: \treturn &AuthMiddleware{\n21: \t\tauthManager:     authManager,\n22: \t\tpublicPaths:     publicPaths,\n23: \t\tallowQueryParam: allowQueryParam,\n24: \t\tjwtIssuer:       jwtIssuer,\n25: \t\tjwtAudience:     jwtAudience,\n26: \t}\n27: }\n28: \n29: func (am *AuthManager) Middleware(publicPaths []string, allowQueryParam bool, jwtIssuer, jwtAudience string) gin.HandlerFunc {\n30: \tmiddleware := NewAuthMiddleware(am, publicPaths, allowQueryParam, jwtIssuer, jwtAudience)\n31: \treturn middleware.Handler()\n32: }\n33: \n34: func (m *AuthMiddleware) Handler() gin.HandlerFunc {\n35: \treturn func(c *gin.Context) {\n36: \t\tif isPublicPath(c.Request.URL.Path, m.publicPaths) {\n37: \t\t\tc.Next()\n38: \t\t\treturn\n39: \t\t}\n40: \n41: \t\ttoken := m.extractToken(c)\n42: \t\tif token == \"\" {\n43: \t\t\tc.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{\n44: \t\t\t\t\"error\":      \"Missing authorization header\",\n45: \t\t\t\t\"code\":       401,\n46: \t\t\t\t\"error_code\": ErrCodeMissingHeader,\n47: \t\t\t\t\"detail\":     \"JWT required: Use Bearer <token>\",\n48: \t\t\t})\n49: \t\t\treturn\n50: \t\t}\n51: \n52: \t\tm.authManager.mutex.RLock()\n53: \t\tpubKey := m.authManager.publicKey\n54: \t\tm.authManager.mutex.RUnlock()\n55: \n56: \t\tif pubKey == nil {\n57: \t\t\tc.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{\n58: \t\t\t\t\"error\":      \"Invalid token\",\n59: \t\t\t\t\"code\":       401,\n60: \t\t\t\t\"error_code\": ErrCodeKeyNotConfigured,\n61: \t\t\t\t\"detail\":     \"Public key not configured\",\n62: \t\t\t})\n63: \t\t\treturn\n64: \t\t}\n65: \n66: \t\tparsedToken, err := jwt.Parse(token, func(token *jwt.Token) (interface{}, error) {\n67: \t\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n68: \t\t\t\treturn nil, ErrInvalidSigningMethod\n69: \t\t\t}\n70: \t\t\treturn pubKey, nil\n71: \t\t}, jwt.WithExpirationRequired(), jwt.WithIssuedAt(), jwt.WithLeeway(minute))\n72: \n73: \t\tif err != nil || !parsedToken.Valid {\n74: \t\t\tdetail := \"verification failed\"\n75: \t\t\tif err != nil {\n76: \t\t\t\tdetail = err.Error()\n77: \t\t\t}\n78: \t\t\terrorCode := ErrCodeInvalidToken\n79: \t\t\tif strings.Contains(detail, \"token is expired\") {\n80: \t\t\t\terrorCode = ErrCodeTokenExpired\n81: \t\t\t}\n82: \t\t\tc.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{\n83: \t\t\t\t\"error\":      \"Invalid token\",\n84: \t\t\t\t\"code\":       401,\n85: \t\t\t\t\"error_code\": errorCode,\n86: \t\t\t\t\"detail\":     detail,\n87: \t\t\t})\n88: \t\t\treturn\n89: \t\t}\n90: \n91: \t\tif m.jwtIssuer != \"\" || m.jwtAudience != \"\" {\n92: \t\t\tclaims, ok := parsedToken.Claims.(jwt.MapClaims)\n93: \t\t\tif !ok {\n94: \t\t\t\tc.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{\n95: \t\t\t\t\t\"error\":      \"Invalid token\",\n96: \t\t\t\t\t\"code\":       401,\n97: \t\t\t\t\t\"error_code\": ErrCodeInvalidToken,\n98: \t\t\t\t\t\"detail\":     \"invalid claims\",\n99: \t\t\t\t})\n100: \t\t\t\treturn\n101: \t\t\t}\n102: \n103: \t\t\tif m.jwtIssuer != \"\" {\n104: \t\t\t\tiss, _ := claims[\"iss\"].(string)\n105: \t\t\t\tif iss != m.jwtIssuer {\n106: \t\t\t\t\tc.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{\n107: \t\t\t\t\t\t\"error\":      \"Invalid token\",\n108: \t\t\t\t\t\t\"code\":       401,\n109: \t\t\t\t\t\t\"error_code\": ErrCodeInvalidToken,\n110: \t\t\t\t\t\t\"detail\":     \"invalid issuer\",\n111: \t\t\t\t\t})\n112: \t\t\t\t\treturn\n113: \t\t\t\t}\n114: \t\t\t}\n115: \n116: \t\t\tif m.jwtAudience != \"\" {\n117: \t\t\t\taudClaim, ok := claims[\"aud\"].(string)\n118: \t\t\t\tif !ok {\n119: \t\t\t\t\taudClaim = \"\"\n120: \t\t\t\t}\n121: \t\t\t\tif !strings.Contains(audClaim, m.jwtAudience) && audClaim != m.jwtAudience {\n122: \t\t\t\t\tc.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{\n123: \t\t\t\t\t\t\"error\":      \"Invalid token\",\n124: \t\t\t\t\t\t\"code\":       401,\n125: \t\t\t\t\t\t\"error_code\": ErrCodeInvalidToken,\n126: \t\t\t\t\t\t\"detail\":     \"invalid audience\",\n127: \t\t\t\t\t})\n128: \t\t\t\t\treturn\n129: \t\t\t\t}\n130: \t\t\t}\n131: \t\t}\n132: \n133: \t\tc.Request.Body = http.MaxBytesReader(c.Writer, c.Request.Body, MaxBodySize)\n134: \t\tc.Next()\n135: \t}\n136: }\n137: \n138: func (m *AuthMiddleware) extractToken(c *gin.Context) string {\n139: \tauthHeader := c.GetHeader(\"Authorization\")\n140: \tif authHeader != \"\" {\n141: \t\tparts := strings.Split(authHeader, \" \")\n142: \t\tif len(parts) == 2 && parts[0] == \"Bearer\" {\n143: \t\t\treturn parts[1]\n144: \t\t}\n145: \t}\n146: \n147: \tif m.allowQueryParam {\n148: \t\ttoken := c.Query(\"token\")\n149: \t\tif token != \"\" {\n150: \t\t\treturn token\n151: \t\t}\n152: \t}\n153: \n154: \treturn \"\"\n155: }\n156: \n157: func isPublicPath(path string, publicPaths []string) bool {\n158: \tfor _, p := range publicPaths {\n159: \t\tif p == path {\n160: \t\t\treturn true\n161: \t\t}\n162: \t\tif strings.HasSuffix(p, \"*\") {\n163: \t\t\tprefix := strings.TrimSuffix(p, \"*\")\n164: \t\t\tif strings.HasPrefix(path, prefix) {\n165: \t\t\t\treturn true\n166: \t\t\t}\n167: \t\t}\n168: \t}\n169: \treturn false\n170: }\n\n(End of file - total 170 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"net/http\"\n\t\"strings\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\ntype AuthMiddleware struct {\n\tauthManager     *AuthManager\n\tpublicPaths     []string\n\tallowQueryParam bool\n\tjwtIssuer       string\n\tjwtAudience     string\n}\n\nfunc NewAuthMiddleware(authManager *AuthManager, publicPaths []string, allowQueryParam bool, jwtIssuer, jwtAudience string) *AuthMiddleware {\n\treturn &AuthMiddleware{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_middleware.go","time":{"start":1775857410785,"end":1775857410802}}}}
{"type":"tool_use","timestamp":1775857410806,"sessionID":"ses_286a6b3f6ffeR9JuYfYvatljVo","part":{"id":"prt_d79599f1d001IYezA6zfRDASN5","messageID":"msg_d79598b40001UVhfc4ExCKEG2g","sessionID":"ses_286a6b3f6ffeR9JuYfYvatljVo","type":"tool","tool":"read","callID":"toolu_d4051876292c482cbdff6101","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"crypto/rsa\"\n5: \t\"crypto/x509\"\n6: \t\"encoding/pem\"\n7: \t\"errors\"\n8: \t\"fmt\"\n9: \t\"net/http\"\n10: \t\"os\"\n11: \t\"os/signal\"\n12: \t\"strings\"\n13: \t\"sync\"\n14: \t\"syscall\"\n15: \t\"time\"\n16: \n17: \t\"github.com/gin-gonic/gin\"\n18: \t\"github.com/golang-jwt/jwt/v5\"\n19: \t\"k8s.io/klog/v2\"\n20: )\n21: \n22: const (\n23: \tPublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"\n24: \tMaxBodySize     = 32 << 20\n25: \tminute          = time.Minute\n26: )\n27: \n28: var (\n29: \tErrCodeMissingHeader    = \"AUTH_MISSING_HEADER\"\n30: \tErrCodeInvalidFormat    = \"AUTH_INVALID_FORMAT\"\n31: \tErrCodeInvalidToken     = \"AUTH_INVALID_TOKEN\"\n32: \tErrCodeTokenExpired     = \"AUTH_TOKEN_EXPIRED\"\n33: \tErrCodeKeyNotConfigured = \"AUTH_KEY_NOT_CONFIGURED\"\n34: \tErrInvalidSigningMethod = errors.New(\"invalid signing method\")\n35: )\n36: \n37: type AuthManager struct {\n38: \tpublicKey *rsa.PublicKey\n39: \tmutex     sync.RWMutex\n40: }\n41: \n42: func NewAuthManager() *AuthManager {\n43: \treturn &AuthManager{}\n44: }\n45: \n46: func (am *AuthManager) LoadPublicKeyFromEnv() error {\n47: \tkeyData := os.Getenv(PublicKeyEnvVar)\n48: \tif keyData == \"\" {\n49: \t\treturn fmt.Errorf(\"environment variable %s is not set\", PublicKeyEnvVar)\n50: \t}\n51: \n52: \tblock, _ := pem.Decode([]byte(keyData))\n53: \tif block == nil {\n54: \t\treturn errors.New(\"failed to decode PEM block\")\n55: \t}\n56: \n57: \tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n58: \tif err != nil {\n59: \t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n60: \t}\n61: \n62: \trsaPubKey, ok := pubKey.(*rsa.PublicKey)\n63: \tif !ok {\n64: \t\treturn errors.New(\"public key is not an RSA key\")\n65: \t}\n66: \n67: \tam.mutex.Lock()\n68: \tam.publicKey = rsaPubKey\n69: \tam.mutex.Unlock()\n70: \n71: \treturn nil\n72: }\n73: \n74: func (am *AuthManager) GetPublicKey() *rsa.PublicKey {\n75: \tam.mutex.RLock()\n76: \tdefer am.mutex.RUnlock()\n77: \treturn am.publicKey\n78: }\n79: \n80: func (am *AuthManager) ReloadPublicKey() error {\n81: \tkeyData := os.Getenv(PublicKeyEnvVar)\n82: \tif keyData == \"\" {\n83: \t\treturn fmt.Errorf(\"environment variable %s is not set\", PublicKeyEnvVar)\n84: \t}\n85: \n86: \tblock, _ := pem.Decode([]byte(keyData))\n87: \tif block == nil {\n88: \t\treturn errors.New(\"failed to decode PEM block\")\n89: \t}\n90: \n91: \tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n92: \tif err != nil {\n93: \t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n94: \t}\n95: \n96: \trsaPubKey, ok := pubKey.(*rsa.PublicKey)\n97: \tif !ok {\n98: \t\treturn errors.New(\"public key is not an RSA key\")\n99: \t}\n100: \n101: \tam.mutex.Lock()\n102: \tam.publicKey = rsaPubKey\n103: \tam.mutex.Unlock()\n104: \n105: \tklog.Info(\"Public key reloaded successfully\")\n106: \treturn nil\n107: }\n108: \n109: func (am *AuthManager) StartKeyRotationWatcher() {\n110: \tsigChan := make(chan os.Signal, 1)\n111: \tsignal.Notify(sigChan, syscall.SIGHUP)\n112: \n113: \tgo func() {\n114: \t\tfor {\n115: \t\t\tsig := <-sigChan\n116: \t\t\tklog.Infof(\"Received signal: %v\", sig)\n117: \t\t\tif err := am.ReloadPublicKey(); err != nil {\n118: \t\t\t\tklog.Errorf(\"Failed to reload public key on SIGHUP: %v\", err)\n119: \t\t\t}\n120: \t\t}\n121: \t}()\n122: }\n123: \n124: func (am *AuthManager) AuthMiddleware() gin.HandlerFunc {\n125: \treturn func(c *gin.Context) {\n126: \t\tauthHeader := c.GetHeader(\"Authorization\")\n127: \t\tif authHeader == \"\" {\n128: \t\t\tc.AbortWithStatusJSON(401, gin.H{\n129: \t\t\t\t\"error\":  \"Missing authorization header\",\n130: \t\t\t\t\"code\":   401,\n131: \t\t\t\t\"detail\": \"JWT required: Use Bearer <token>\",\n132: \t\t\t})\n133: \t\t\treturn\n134: \t\t}\n135: \n136: \t\tparts := strings.Split(authHeader, \" \")\n137: \t\tif len(parts) != 2 || parts[0] != \"Bearer\" {\n138: \t\t\tc.AbortWithStatusJSON(401, gin.H{\n139: \t\t\t\t\"error\":  \"Invalid authorization header format\",\n140: \t\t\t\t\"code\":   401,\n141: \t\t\t\t\"detail\": \"Use Bearer <token>\",\n142: \t\t\t})\n143: \t\t\treturn\n144: \t\t}\n145: \n146: \t\ttokenString := parts[1]\n147: \n148: \t\tam.mutex.RLock()\n149: \t\tpubKey := am.publicKey\n150: \t\tam.mutex.RUnlock()\n151: \n152: \t\tif pubKey == nil {\n153: \t\t\tc.AbortWithStatusJSON(401, gin.H{\n154: \t\t\t\t\"error\":  \"Invalid token\",\n155: \t\t\t\t\"code\":   401,\n156: \t\t\t\t\"detail\": \"Public key not configured\",\n157: \t\t\t})\n158: \t\t\treturn\n159: \t\t}\n160: \n161: \t\ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n162: \t\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n163: \t\t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n164: \t\t\t}\n165: \t\t\treturn pubKey, nil\n166: \t\t}, jwt.WithExpirationRequired(), jwt.WithIssuedAt(), jwt.WithLeeway(time.Minute))\n167: \n168: \t\tif err != nil || !token.Valid {\n169: \t\t\tdetail := \"verification failed\"\n170: \t\t\tif err != nil {\n171: \t\t\t\tdetail = err.Error()\n172: \t\t\t}\n173: \t\t\tc.AbortWithStatusJSON(401, gin.H{\n174: \t\t\t\t\"error\":  \"Invalid token\",\n175: \t\t\t\t\"code\":   401,\n176: \t\t\t\t\"detail\": detail,\n177: \t\t\t})\n178: \t\t\treturn\n179: \t\t}\n180: \n181: \t\tc.Request.Body = http.MaxBytesReader(c.Writer, c.Request.Body, MaxBodySize)\n182: \t\tc.Next()\n183: \t}\n184: }\n185: \n186: func (am *AuthManager) RequireAuth() gin.HandlerFunc {\n187: \treturn func(c *gin.Context) {\n188: \t\tif err := am.LoadPublicKeyFromEnv(); err != nil {\n189: \t\t\tklog.Fatalf(\"Failed to load public key: %v\", err)\n190: \t\t}\n191: \t\tam.AuthMiddleware()(c)\n192: \t}\n193: }\n\n(End of file - total 193 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"strings\"\n\t\"sync\"\n\t\"syscall\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"k8s.io/klog/v2\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth.go","time":{"start":1775857410788,"end":1775857410804}}}}
