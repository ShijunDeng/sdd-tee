ty\"`\n192: \tSpec              interface{} `json:\"spec,omitempty\"`\n193: }\n194: \n195: type UpdateCodeInterpreterRequest struct {\n196: \tmetav1.TypeMeta   `json:\",inline\"`\n197: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n198: \tSpec              interface{} `json:\"spec,omitempty\"`\n199: }\n200: \n201: type WatchEvent struct {\n202: \tType   string      `json:\"type\"`\n203: \tObject interface{} `json:\"object\"`\n204: }\n205: \n206: func NewAPIResponse(data interface{}, metadata *ListMeta) *APIResponse {\n207: \treturn &APIResponse{\n208: \t\tKind:       \"Status\",\n209: \t\tAPIVersion: \"v1\",\n210: \t\tStatus:     \"Success\",\n211: \t\tData:       data,\n212: \t\tMetadata:   metadata,\n213: \t}\n214: }\n215: \n216: func NewAPIError(message, reason string, code int) *APIError {\n217: \treturn &APIError{\n218: \t\tKind:       \"Status\",\n219: \t\tAPIVersion: \"v1\",\n220: \t\tStatus:     \"Failure\",\n221: \t\tMessage:    message,\n222: \t\tReason:     reason,\n223: \t\tCode:       code,\n224: \t}\n225: }\n\n(End of file - total 225 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"errors\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nvar (\n\tErrSandboxNotFound    = errors.New(\"sandbox not found\")\n\tErrDeletionFailed     = errors.New(\"deletion failed\")\n\tErrStaleFinalizer     = errors.New(\"stale finalizer\")\n\tErrOrphanedResource   = errors.New(\"orphaned resource\")\n\tErrResourceNotFound   = errors.New(\"resource not found\")\n\tErrResourceNotDeleted = errors.New(\"resource not deleted\")\n)\n\ntype DeleteOptions struct {\n\tGracePeriodSeconds *int64 `form:\"gracePeriodSeconds,omitempty\" json:\"gracePeriodSeconds,omitempty\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/types.go","time":{"start":1775846024722,"end":1775846024734}}}}
