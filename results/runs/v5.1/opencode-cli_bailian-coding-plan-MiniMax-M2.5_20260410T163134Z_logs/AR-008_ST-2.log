{"type":"tool_use","timestamp":1775846014989,"sessionID":"ses_287548ae9ffe5DruKIg28I3WMR","part":{"id":"prt_d78abbce7001YHAlcTA7sNGJrI","messageID":"msg_d78abae080012uqq8SWC51TN1D","sessionID":"ses_287548ae9ffe5DruKIg28I3WMR","type":"tool","tool":"read","callID":"toolu_0c9a77b8450c4b0595b2a4d3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/cleanup.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/cleanup.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \n7: \tcorev1 \"k8s.io/api/core/v1\"\n8: \t\"k8s.io/apimachinery/pkg/api/errors\"\n9: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n10: \t\"k8s.io/apimachinery/pkg/labels\"\n11: \t\"k8s.io/client-go/kubernetes\"\n12: \t\"k8s.io/klog/v2\"\n13: )\n14: \n15: type CleanupManager struct {\n16: \tk8sClient *kubernetes.Clientset\n17: }\n18: \n19: func NewCleanupManager(k8sClient *kubernetes.Clientset) *CleanupManager {\n20: \treturn &CleanupManager{\n21: \t\tk8sClient: k8sClient,\n22: \t}\n23: }\n24: \n25: func (cm *CleanupManager) cleanupServices(namespace string, ownerRef metav1.OwnerReference) ([]string, error) {\n26: \tcleaned := make([]string, 0)\n27: \n28: \tservices, err := cm.k8sClient.CoreV1().Services(namespace).List(context.Background(), metav1.ListOptions{})\n29: \tif err != nil {\n30: \t\treturn cleaned, fmt.Errorf(\"failed to list services: %w\", err)\n31: \t}\n32: \n33: \tfor _, svc := range services.Items {\n34: \t\tfor _, owner := range svc.OwnerReferences {\n35: \t\t\tif owner.UID == ownerRef.UID && owner.Kind == ownerRef.Kind && owner.Name == ownerRef.Name {\n36: \t\t\t\terr := cm.k8sClient.CoreV1().Services(namespace).Delete(context.Background(), svc.Name, metav1.DeleteOptions{})\n37: \t\t\t\tif err != nil {\n38: \t\t\t\t\tif !errors.IsNotFound(err) {\n39: \t\t\t\t\t\tklog.V(2).InfoS(\"Failed to delete service\", \"service\", svc.Name, \"error\", err)\n40: \t\t\t\t\t\tcontinue\n41: \t\t\t\t\t}\n42: \t\t\t\t}\n43: \t\t\t\tcleaned = append(cleaned, fmt.Sprintf(\"Service/%s\", svc.Name))\n44: \t\t\t\tklog.InfoS(\"Deleted service\", \"service\", svc.Name, \"namespace\", namespace)\n45: \t\t\t\tbreak\n46: \t\t\t}\n47: \t\t}\n48: \t}\n49: \n50: \treturn cleaned, nil\n51: }\n52: \n53: func (cm *CleanupManager) cleanupConfigMaps(namespace string, ownerRef metav1.OwnerReference) ([]string, error) {\n54: \tcleaned := make([]string, 0)\n55: \n56: \tconfigMaps, err := cm.k8sClient.CoreV1().ConfigMaps(namespace).List(context.Background(), metav1.ListOptions{})\n57: \tif err != nil {\n58: \t\treturn cleaned, fmt.Errorf(\"failed to list configmaps: %w\", err)\n59: \t}\n60: \n61: \tfor _, cfgMap := range configMaps.Items {\n62: \t\tannotations := cfgMap.GetAnnotations()\n63: \t\tif annotations == nil {\n64: \t\t\tcontinue\n65: \t\t}\n66: \n67: \t\tif annotations[\"agentcube.volcano.sh/auto-delete\"] != \"true\" {\n68: \t\t\tcontinue\n69: \t\t}\n70: \n71: \t\tfor _, owner := range cfgMap.OwnerReferences {\n72: \t\t\tif owner.UID == ownerRef.UID && owner.Kind == ownerRef.Kind && owner.Name == ownerRef.Name {\n73: \t\t\t\terr := cm.k8sClient.CoreV1().ConfigMaps(namespace).Delete(context.Background(), cfgMap.Name, metav1.DeleteOptions{})\n74: \t\t\t\tif err != nil {\n75: \t\t\t\t\tif !errors.IsNotFound(err) {\n76: \t\t\t\t\t\tklog.V(2).InfoS(\"Failed to delete configmap\", \"configmap\", cfgMap.Name, \"error\", err)\n77: \t\t\t\t\t\tcontinue\n78: \t\t\t\t\t}\n79: \t\t\t\t}\n80: \t\t\t\tcleaned = append(cleaned, fmt.Sprintf(\"ConfigMap/%s\", cfgMap.Name))\n81: \t\t\t\tklog.InfoS(\"Deleted configmap\", \"configmap\", cfgMap.Name, \"namespace\", namespace)\n82: \t\t\t\tbreak\n83: \t\t\t}\n84: \t\t}\n85: \t}\n86: \n87: \treturn cleaned, nil\n88: }\n89: \n90: func (cm *CleanupManager) cleanupPVCs(namespace string, ownerRef metav1.OwnerReference) ([]string, error) {\n91: \tcleaned := make([]string, 0)\n92: \n93: \tpvcs, err := cm.k8sClient.CoreV1().PersistentVolumeClaims(namespace).List(context.Background(), metav1.ListOptions{})\n94: \tif err != nil {\n95: \t\treturn cleaned, fmt.Errorf(\"failed to list pvcs: %w\", err)\n96: \t}\n97: \n98: \tfor _, pvc := range pvcs.Items {\n99: \t\tfor _, owner := range pvc.OwnerReferences {\n100: \t\t\tif owner.UID == ownerRef.UID && owner.Kind == ownerRef.Kind && owner.Name == ownerRef.Name {\n101: \t\t\t\tpvName := pvc.Spec.VolumeName\n102: \t\t\t\tif pvName != \"\" {\n103: \t\t\t\t\tpv, err := cm.k8sClient.CoreV1().PersistentVolumes().Get(context.Background(), pvName, metav1.GetOptions{})\n104: \t\t\t\t\tif err == nil && pv.Spec.PersistentVolumeReclaimPolicy == corev1.PersistentVolumeReclaimRetain {\n105: \t\t\t\t\t\tklog.V(4).InfoS(\"Retaining PVC due to PV ReclaimPolicy\", \"pvc\", pvc.Name, \"namespace\", namespace)\n106: \t\t\t\t\t\tcontinue\n107: \t\t\t\t\t}\n108: \t\t\t\t}\n109: \n110: \t\t\t\terr := cm.k8sClient.CoreV1().PersistentVolumeClaims(namespace).Delete(context.Background(), pvc.Name, metav1.DeleteOptions{})\n111: \t\t\t\tif err != nil {\n112: \t\t\t\t\tif !errors.IsNotFound(err) {\n113: \t\t\t\t\t\tklog.V(2).InfoS(\"Failed to delete pvc\", \"pvc\", pvc.Name, \"error\", err)\n114: \t\t\t\t\t\tcontinue\n115: \t\t\t\t\t}\n116: \t\t\t\t}\n117: \t\t\t\tcleaned = append(cleaned, fmt.Sprintf(\"PVC/%s\", pvc.Name))\n118: \t\t\t\tklog.InfoS(\"Deleted pvc\", \"pvc\", pvc.Name, \"namespace\", namespace)\n119: \t\t\t\tbreak\n120: \t\t\t}\n121: \t\t}\n122: \t}\n123: \n124: \treturn cleaned, nil\n125: }\n126: \n127: func (cm *CleanupManager) cleanupOrphanedResources(sandbox *Sandbox) ([]string, error) {\n128: \tcleaned := make([]string, 0)\n129: \townerRef := metav1.OwnerReference{\n130: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n131: \t\tKind:       \"AgentRuntime\",\n132: \t\tName:       sandbox.Name,\n133: \t\tUID:        \"\",\n134: \t}\n135: \n136: \tsvcCleaned, err := cm.cleanupServices(sandbox.Namespace, ownerRef)\n137: \tif err != nil {\n138: \t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n139: \t}\n140: \tcleaned = append(cleaned, svcCleaned...)\n141: \n142: \tcmCleaned, err := cm.cleanupConfigMaps(sandbox.Namespace, ownerRef)\n143: \tif err != nil {\n144: \t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n145: \t}\n146: \tcleaned = append(cleaned, cmCleaned...)\n147: \n148: \tpvcCleaned, err := cm.cleanupPVCs(sandbox.Namespace, ownerRef)\n149: \tif err != nil {\n150: \t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n151: \t}\n152: \tcleaned = append(cleaned, pvcCleaned...)\n153: \n154: \tklog.InfoS(\"Cleaned orphaned resources\", \"sandboxId\", sandbox.SessionID, \"count\", len(cleaned))\n155: \treturn cleaned, nil\n156: }\n157: \n158: func (cm *CleanupManager) CleanupAllResources(ctx context.Context, sandbox *Sandbox) ([]string, error) {\n159: \tallCleaned := make([]string, 0)\n160: \n161: \tsvcList, err := cm.cleanupServices(sandbox.Namespace, metav1.OwnerReference{\n162: \t\tName: sandbox.Name,\n163: \t})\n164: \tif err != nil {\n165: \t\tklog.V(2).InfoS(\"Error during service cleanup\", \"error\", err)\n166: \t}\n167: \tallCleaned = append(allCleaned, svcList...)\n168: \n169: \tcmList, err := cm.cleanupConfigMaps(sandbox.Namespace, metav1.OwnerReference{\n170: \t\tName: sandbox.Name,\n171: \t})\n172: \tif err != nil {\n173: \t\tklog.V(2).InfoS(\"Error during configmap cleanup\", \"error\", err)\n174: \t}\n175: \tallCleaned = append(allCleaned, cmList...)\n176: \n177: \tpvcList, err := cm.cleanupPVCs(sandbox.Namespace, metav1.OwnerReference{\n178: \t\tName: sandbox.Name,\n179: \t})\n180: \tif err != nil {\n181: \t\tklog.V(2).InfoS(\"Error during pvc cleanup\", \"error\", err)\n182: \t}\n183: \tallCleaned = append(allCleaned, pvcList...)\n184: \n185: \treturn allCleaned, nil\n186: }\n187: \n188: func (cm *CleanupManager) FindOrphanedServices(ctx context.Context, namespace string, sessionID string) ([]string, error) {\n189: \tselector := labels.SelectorFromSet(labels.Set{\"sessionId\": sessionID})\n190: \tservices, err := cm.k8sClient.CoreV1().Services(namespace).List(ctx, metav1.ListOptions{\n191: \t\tLabelSelector: selector.String(),\n192: \t})\n193: \tif err != nil {\n194: \t\treturn nil, err\n195: \t}\n196: \n197: \tcleanable := make([]string, 0)\n198: \tfor _, svc := range services.Items {\n199: \t\tif len(svc.OwnerReferences) == 0 {\n200: \t\t\tcleanable = append(cleanable, svc.Name)\n201: \t\t}\n202: \t}\n203: \n204: \treturn cleanable, nil\n205: }\n\n(End of file - total 205 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype CleanupManager struct {\n\tk8sClient *kubernetes.Clientset\n}\n\nfunc NewCleanupManager(k8sClient *kubernetes.Clientset) *CleanupManager {\n\treturn &CleanupManager{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/cleanup.go","time":{"start":1775846014971,"end":1775846014986}}}}
