vs.lastActivityIndexKey).Score(float64(lastActivityScore)).Member(sandboxStore.SessionID).Build(),\n ).AsSlice()\n if err != nil {\n \treturn err\n }\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_valkey.go","before":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc newValkeyStore() (Store, error) {\n\topts, err := makeValkeyOptions()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tcli, err := valkey.NewClient(*opts)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n\t}\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\n\tresult := cli.B().Ping().Build()\n\tresp := cli.Do(ctx, result)\n\tpong, err := resp.ToString()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to ping valkey: %w\", err)\n\t}\n\tif pong != \"PONG\" {\n\t\treturn nil, fmt.Errorf(\"unexpected ping response: %s\", pong)\n\t}\n\n\treturn &valkeyStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        sessionKeyPrefix,\n\t\texpiryIndexKey:       sessionExpiryIndexKey,\n\t\tlastActivityIndexKey: sessionLastActivityKey,\n\t}, nil\n}\n\nfunc makeValkeyOptions() (*valkey.ClientOption, error) {\n\tvalkeyAddr := os.Getenv(\"VALKEY_ADDR\")\n\tif valkeyAddr == \"\" {\n\t\treturn nil, errors.New(\"VALKEY_ADDR is required\")\n\t}\n\n\tvalkeyPasswordRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tvalkeyPassword := os.Getenv(\"VALKEY_PASSWORD\")\n\n\tpasswordRequired := true\n\tif strings.EqualFold(valkeyPasswordRequired, \"false\") {\n\t\tpasswordRequired = false\n\t}\n\n\tif passwordRequired && valkeyPassword == \"\" {\n\t\treturn nil, errors.New(\"VALKEY_PASSWORD is required\")\n\t}\n\n\topts := valkey.ClientOption{\n\t\tInitAddress: strings.Split(valkeyAddr, \",\"),\n\t\tPassword:    valkeyPassword,\n\t}\n\n\tif disableCache, _ := os.LookupEnv(\"VALKEY_DISABLE_CACHE\"); strings.EqualFold(disableCache, \"true\") {\n\t\topts.DisableCache = true\n\t\tklog.Info(\"Valkey DisableCache is enabled\")\n\t}\n\n\tif forceSingle, _ := os.LookupEnv(\"VALKEY_FORCE_SINGLE\"); strings.EqualFold(forceSingle, \"true\") {\n\t\topts.ForceSingleClient = true\n\t\tklog.Info(\"Valkey ForceSingleClient is enabled\")\n\t}\n\n\treturn &opts, nil\n}\n\nfunc (vs *valkeyStore) Ping(ctx context.Context) error {\n\tresult := vs.cli.B().Ping().Build()\n\tresp := vs.cli.Do(ctx, result)\n\tpong, err := resp.ToString()\n\tif err != nil {\n\t\treturn err\n\t}\n\tif pong != \"PONG\" {\n\t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n\t}\n\treturn nil\n}\n\nfunc (vs *valkeyStore) sessionKey(sessionID string) string {\n\treturn vs.sessionPrefix + sessionID\n}\n\nfunc (vs *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\tkey := vs.sessionKey(sessionID)\n\tresult := vs.cli.B().Get().Key(key).Build()\n\tresp := vs.cli.Do(ctx, result)\n\n\tif valkey.IsValkeyNil(resp.Err()) {\n\t\treturn nil, ErrNotFound\n\t}\n\tif resp.Err() != nil {\n\t\treturn nil, resp.Err()\n\t}\n\n\tdata, err := resp.ToString()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar sandbox types.SandboxInfo\n\tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &sandbox, nil\n}\n\nfunc (vs *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn errors.New(\"sandbox is nil\")\n\t}\n\tif sandboxStore.ExpiresAt.IsZero() {\n\t\treturn errors.New(\"invalid expiry: ExpiresAt is zero\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn errors.New(\"session ID is required\")\n\t}\n\n\tkey := vs.sessionKey(sandboxStore.SessionID)\n\tdata, err := json.Marshal(sandboxStore)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tnow := time.Now().Unix()\n\texpiryScore := float64(sandboxStore.ExpiresAt.Unix())\n\tlastActivityScore := float64(now)\n\n\tresults, err := vs.cli.DoMulti(\n\t\tctx,\n\t\tvs.cli.B().Setnx().Key(key).Value(string(data)).Build(),\n\t\tvs.cli.B().Zadd().Key(vs.expiryIndexKey()).Score(float64(expiryScore)).Member(sandboxStore.SessionID).Build(),\n\t\tvs.cli.B().Zadd().Key(vs.lastActivityIndexKey()).Score(float64(lastActivityScore)).Member(sandboxStore.SessionID).Build(),\n\t).AsSlice()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor _, r := range results {\n\t\tif r, ok := r.(error); ok {\n\t\t\treturn r\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (vs *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn errors.New(\"sandbox is nil\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn errors.New(\"session ID is required\")\n\t}\n\n\tkey := vs.sessionKey(sandboxStore.SessionID)\n\tdata, err := json.Marshal(sandboxStore)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tresult := vs.cli.B().Set().Key(key).Value(string(data)).Xx(true).Build()\n\tresp := vs.cli.Do(ctx, result)\n\n\tif valkey.IsValkeyNil(resp.Err()) {\n\t\treturn errors.New(\"key not exists\")\n\t}\n\tif resp.Err() != nil {\n\t\treturn resp.Err()\n\t}\n\n\tok, err := resp.ToString()\n\tif err != nil {\n\t\treturn err\n\t}\n\tif ok != \"OK\" {\n\t\treturn errors.New(\"key not exists\")\n\t}\n\n\treturn nil\n}\n\nfunc (vs *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\tkey := vs.sessionKey(sessionID)\n\n\tresults, err := vs.cli.DoMulti(\n\t\tctx,\n\t\tvs.cli.B().Del().Keys(key).Build(),\n\t\tvs.cli.B().Zrem().Key(vs.expiryIndexKey()).Members(sessionID).Build(),\n\t\tvs.cli.