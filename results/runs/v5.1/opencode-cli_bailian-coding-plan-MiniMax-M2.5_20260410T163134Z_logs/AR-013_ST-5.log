1: \t\texpiryIndexKey:       sessionExpiryIndexKey,\n52: \t\tlastActivityIndexKey: sessionLastActivityKey,\n53: \t}, nil\n54: }\n55: \n56: func makeValkeyOptions() (*valkey.ClientOption, error) {\n57: \tvalkeyAddr := os.Getenv(\"VALKEY_ADDR\")\n58: \tif valkeyAddr == \"\" {\n59: \t\treturn nil, errors.New(\"VALKEY_ADDR is required\")\n60: \t}\n61: \n62: \tvalkeyPasswordRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n63: \tvalkeyPassword := os.Getenv(\"VALKEY_PASSWORD\")\n64: \n65: \tpasswordRequired := true\n66: \tif strings.EqualFold(valkeyPasswordRequired, \"false\") {\n67: \t\tpasswordRequired = false\n68: \t}\n69: \n70: \tif passwordRequired && valkeyPassword == \"\" {\n71: \t\treturn nil, errors.New(\"VALKEY_PASSWORD is required\")\n72: \t}\n73: \n74: \topts := valkey.ClientOption{\n75: \t\tInitAddress: strings.Split(valkeyAddr, \",\"),\n76: \t\tPassword:    valkeyPassword,\n77: \t}\n78: \n79: \tif disableCache, _ := os.LookupEnv(\"VALKEY_DISABLE_CACHE\"); strings.EqualFold(disableCache, \"true\") {\n80: \t\topts.DisableCache = true\n81: \t\tklog.Info(\"Valkey DisableCache is enabled\")\n82: \t}\n83: \n84: \tif forceSingle, _ := os.LookupEnv(\"VALKEY_FORCE_SINGLE\"); strings.EqualFold(forceSingle, \"true\") {\n85: \t\topts.ForceSingleClient = true\n86: \t\tklog.Info(\"Valkey ForceSingleClient is enabled\")\n87: \t}\n88: \n89: \treturn &opts, nil\n90: }\n91: \n92: func (vs *valkeyStore) Ping(ctx context.Context) error {\n93: \tresult := vs.cli.B().Ping().Build()\n94: \tresp := vs.cli.Do(ctx, result)\n95: \tpong, err := resp.ToString()\n96: \tif err != nil {\n97: \t\treturn err\n98: \t}\n99: \tif pong != \"PONG\" {\n100: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n101: \t}\n102: \treturn nil\n103: }\n104: \n105: func (vs *valkeyStore) sessionKey(sessionID string) string {\n106: \treturn vs.sessionPrefix + sessionID\n107: }\n108: \n109: func (vs *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n110: \tkey := vs.sessionKey(sessionID)\n111: \tresult := vs.cli.B().Get().Key(key).Build()\n112: \tresp := vs.cli.Do(ctx, result)\n113: \n114: \tif valkey.IsValkeyNil(resp.Err()) {\n115: \t\treturn nil, ErrNotFound\n116: \t}\n117: \tif resp.Err() != nil {\n118: \t\treturn nil, resp.Err()\n119: \t}\n120: \n121: \tdata, err := resp.ToString()\n122: \tif err != nil {\n123: \t\treturn nil, err\n124: \t}\n125: \n126: \tvar sandbox types.SandboxInfo\n127: \tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n128: \t\treturn nil, err\n129: \t}\n130: \n131: \treturn &sandbox, nil\n132: }\n133: \n134: func (vs *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n135: \tif sandboxStore == nil {\n136: \t\treturn errors.New(\"sandbox is nil\")\n137: \t}\n138: \tif sandboxStore.ExpiresAt.IsZero() {\n139: \t\treturn errors.New(\"invalid expiry: ExpiresAt is zero\")\n140: \t}\n141: \tif sandboxStore.SessionID == \"\" {\n142: \t\treturn errors.New(\"session ID is required\")\n143: \t}\n144: \n145: \tkey := vs.sessionKey(sandboxStore.SessionID)\n146: \tdata, err := json.Marshal(sandboxStore)\n147: \tif err != nil {\n148: \t\treturn err\n149: \t}\n150: \n151: \tnow := time.Now().Unix()\n152: \texpiryScore := float64(sandboxStore.ExpiresAt.Unix())\n153: \tlastActivityScore := float64(now)\n154: \n155: \tresults, err := vs.cli.DoMulti(\n156: \t\tctx,\n157: \t\tvs.cli.B().Setnx().Key(key).Value(string(data)).Build(),\n158: \t\tvs.cli.B().Zadd().Key(vs.expiryIndexKey()).Score(float64(expiryScore)).Member(sandboxStore.SessionID).Build(),\n159: \t\tvs.cli.B().Zadd().Key(vs.lastActivityIndexKey()).Score(float64(lastActivityScore)).Member(sandboxStore.SessionID).Build(),\n160: \t).AsSlice()\n161: \tif err != nil {\n162: \t\treturn err\n163: \t}\n164: \n165: \tfor _, r := range results {\n166: \t\tif r, ok := r.(error); ok {\n167: \t\t\treturn r\n168: \t\t}\n169: \t}\n170: \n171: \treturn nil\n172: }\n173: \n174: func (vs *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n175: \tif sandboxStore == nil {\n176: \t\treturn errors.New(\"sandbox is nil\")\n177: \t}\n178: \tif sandboxStore.SessionID == \"\" {\n179: \t\treturn errors.New(\"session ID is required\")\n180: \t}\n181: \n182: \tkey := vs.sessionKey(sandboxStore.SessionID)\n183: \tdata, err := json.Marshal(sandboxStore)\n184: \tif err != nil {\n185: \t\treturn err\n186: \t}\n187: \n188: \tresult := vs.cli.B().Set().Key(key).Value(string(data)).Xx(true).Build()\n189: \tresp := vs.cli.Do(ctx, result)\n190: \n191: \tif valkey.IsValkeyNil(resp.Err()) {\n192: \t\treturn errors.New(\"key not exists\")\n193: \t}\n194: \tif resp.Err() != nil {\n195: \t\treturn resp.Err()\n196: \t}\n197: \n198: \tok, err := resp.ToString()\n199: \tif err != nil {\n200: \t\treturn err\n201: \t}\n202: \tif ok != \"OK\" {\n203: \t\treturn errors.New(\"key not exists\")\n204: \t}\n205: \n206: \treturn nil\n207: }\n208: \n209: func (vs *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n210: \tkey := vs.sessionKey(sessionID)\n211: \n212: \tresults, err := vs.cli.DoMulti(\n213: \t\tctx,\n214: \t\tvs.cli.B().Del().Keys(key).Build(),\n215: \t\tvs.cli.B().Zrem().Key(vs.expiryIndexKey()).Members(sessionID).Build(),\n216: \t\tvs.cli.B().Zrem().Key(vs.lastActivityIndexKey()).Members(sessionID).Build(),\n217: \t).AsSlice()\n218: \tif err != nil {\n219: \t\treturn err\n220: \t}\n221: \n222: \tfor _, r := range results {\n223: \t\tif r, ok := r.(error); ok {\n224: \t\t\treturn r\n225: \t\t}\n226: \t}\n227: \n228: \treturn nil\n229: }\n230: \n231: func (vs *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n232: \tif limit <= 0 {\n233: \t\treturn nil, nil\n234: \t}\n235: \n236: \tresult := vs.cli.B().\n237: \t\tZrangebyscore().\n238: \t\tKey(vs.expiryIndexKey()).\n239: \t\tMin(\"-inf\").\n240: \t\tMax(fmt.Sprintf(\"%d\", before.Unix())).\n241: \t\tLimit(0, int(limit)).\n242: \t\tBuild()\n243: \tresp := vs.cli.Do(ctx, result)\n244: \tif resp.Err() != nil {\n245: \t\treturn nil, resp.Err()\n246: \t}\n247: \n248: \tsessionIDs, err := resp.AsStrSlice()\n249: \tif err != nil {\n250: \t\treturn nil, err\n251: \t}\n252: \n253: \treturn vs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n254: }\n255: \n256: func (vs *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n257: \tif limit <= 0 {\n258: \t\treturn nil, nil\n259: \t}\n260: \n261: \tresult := vs.cli.B().\n262: \t\tZrangebyscore().\n263: \t\tKey(vs.lastActivityIndexKey()).\n264: \t\tMin(\"-inf\").\n265: \t\tMax(fmt.Sprintf(\"%d\", before.Unix())).\n266: \t\tLimit(0, int(limit)).\n267: \t\tBuild()\n268: \tresp := vs.cli.Do(ctx, result)\n269: \tif resp.Err() != nil {\n270: \t\treturn nil, resp.Err()\n271: \t}\n272: \n273: \tsessionIDs, err := resp.AsStrSlice()\n274: \tif err != nil {\n275: \t\treturn nil, err\n276: \t}\n277: \n278: \treturn vs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n279: }\n280: \n281: func (vs *valkeyStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n282: \tif len(sessionIDs) == 0 {\n283: \t\treturn nil, nil\n284: \t}\n285: \n286: \tkeys := make([]string, len(sessionIDs))\n287: \tfor i, sid := range sessionIDs {\n288: \t\tkeys[i] = vs.sessionKey(sid)\n289: \t}\n290: \n291: \tresult := vs.cli.B().Mget().Keys(keys...).Build()\n292: \tresp := vs.cli.Do(ctx, result)\n293: \tif resp.Err() != nil {\n294: \t\treturn nil, resp.Err()\n295: \t}\n296: \n297: \tsliceResp, err := resp.AsSlice()\n298: \tif err != nil {\n299: \t\treturn nil, err\n300: \t}\n301: \n302: \tvar sandboxes []*types.SandboxInfo\n303: \tfor i, item := range sliceResp {\n304: \t\tif item == nil {\n305: \t\t\tcontinue\n306: \t\t}\n307: \n308: \t\tstr, ok := item.(string)\n309: \t\tif !ok || str == \"\" {\n310: \t\t\tcontinue\n311: \t\t}\n312: \n313: \t\tvar 