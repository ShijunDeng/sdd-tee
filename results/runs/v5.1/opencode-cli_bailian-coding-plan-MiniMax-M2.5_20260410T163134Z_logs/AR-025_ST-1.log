\"python main.py\",\n131:         )\n132: \n133:         assert metadata.language == \"python\"\n134:         assert metadata.port == 8080\n135:         assert metadata.build_mode == \"local\"\n136:         assert metadata.requirements_file == \"requirements.txt\"\n137: \n138:     def test_optional_description(self):\n139:         \"\"\"Test optional description field.\"\"\"\n140:         metadata = AgentMetadata(\n141:             agent_name=\"test\",\n142:             entrypoint=\"python main.py\",\n143:             description=None,\n144:         )\n145: \n146:         assert metadata.description is None\n\n(End of file - total 146 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for MetadataService.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\n\nimport pytest\nimport yaml\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass TestMetadataServiceLoad:\n    \"\"\"Tests for MetadataService.load_metadata method.\"\"\"\n\n    def test_loads_agent_metadata_yaml(self):\n        \"\"\"Test loading agent_metadata.yaml.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\n                \"agent_name\": \"my-agent\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_metadata_service.py","time":{"start":1775865747400,"end":1775865747417}}}}
