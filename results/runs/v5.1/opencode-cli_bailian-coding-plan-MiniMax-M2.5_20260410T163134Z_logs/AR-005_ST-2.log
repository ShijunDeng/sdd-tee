untimeStatus(ctx context.Context, namespace, name string, pt types.PatchType, data []byte, opts metav1.PatchOptions) (*agentcubev1alpha1.AgentRuntime, error)\n23: \tWatchAgentRuntimes(ctx context.Context, namespace string, opts metav1.ListOptions) (watch.Interface, error)\n24: \n25: \tCreateCodeInterpreter(ctx context.Context, namespace string, codeInterpreter *agentcubev1alpha1.CodeInterpreter, opts metav1.CreateOptions) (*agentcubev1alpha1.CodeInterpreter, error)\n26: \tGetCodeInterpreter(ctx context.Context, namespace, name string, opts metav1.GetOptions) (*agentcubev1alpha1.CodeInterpreter, error)\n27: \tListCodeInterpreters(ctx context.Context, namespace string, opts metav1.ListOptions) (*agentcubev1alpha1.CodeInterpreterList, error)\n28: \tUpdateCodeInterpreter(ctx context.Context, namespace string, codeInterpreter *agentcubev1alpha1.CodeInterpreter, opts metav1.UpdateOptions) (*agentcubev1alpha1.CodeInterpreter, error)\n29: \tDeleteCodeInterpreter(ctx context.Context, namespace, name string, opts metav1.DeleteOptions) error\n30: \tGetCodeInterpreterStatus(ctx context.Context, namespace, name string, opts metav1.GetOptions) (*agentcubev1alpha1.CodeInterpreterStatus, error)\n31: \tPatchCodeInterpreterStatus(ctx context.Context, namespace, name string, pt types.PatchType, data []byte, opts metav1.PatchOptions) (*agentcubev1alpha1.CodeInterpreter, error)\n32: \tWatchCodeInterpreters(ctx context.Context, namespace string, opts metav1.ListOptions) (watch.Interface, error)\n33: \n34: \tClose() error\n35: }\n36: \n37: type workloadManagerImpl struct {\n38: \tclient versioned.Interface\n39: }\n40: \n41: func NewWorkloadManager(client versioned.Interface) WorkloadManager {\n42: \treturn &workloadManagerImpl{\n43: \t\tclient: client,\n44: \t}\n45: }\n46: \n47: func (m *workloadManagerImpl) CreateAgentRuntime(ctx context.Context, namespace string, agentRuntime *agentcubev1alpha1.AgentRuntime, opts metav1.CreateOptions) (*agentcubev1alpha1.AgentRuntime, error) {\n48: \tre