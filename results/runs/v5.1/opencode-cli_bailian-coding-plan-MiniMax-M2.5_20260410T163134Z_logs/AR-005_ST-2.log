`\n36: \tCauses []APIErrorCause `json:\"causes,omitempty\"`\n37: }\n38: \n39: type APIErrorCause struct {\n40: \tMessage string `json:\"message\"`\n41: \tField   string `json:\"field\"`\n42: }\n43: \n44: type PaginationRequest struct {\n45: \tLimit    int64  `form:\"limit\"`\n46: \tContinue string `form:\"continue\"`\n47: }\n48: \n49: type PaginationResponse struct {\n50: \tItems              interface{} `json:\"items\"`\n51: \tListMeta           *ListMeta   `json:\"metadata\"`\n52: \tRemainingItemCount *int64      `json:\"remainingItemCount,omitempty\"`\n53: }\n54: \n55: type AgentRuntimeListResponse struct {\n56: \tKind       string             `json:\"kind\"`\n57: \tAPIVersion string             `json:\"apiVersion\"`\n58: \tItems      []AgentRuntimeItem `json:\"items\"`\n59: \t*ListMeta\n60: }\n61: \n62: type AgentRuntimeItem struct {\n63: \tmetav1.TypeMeta   `json:\",inline\"`\n64: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n65: \tSpec              interface{} `json:\"spec,omitempty\"`\n66: \tStatus            interface{} `json:\"status,omitempty\"`\n67: }\n68: \n69: type CodeInterpreterListResponse struct {\n70: \tKind       string                `json:\"kind\"`\n71: \tAPIVersion string                `json:\"apiVersion\"`\n72: \tItems      []CodeInterpreterItem `json:\"items\"`\n73: \t*ListMeta\n74: }\n75: \n76: type CodeInterpreterItem struct {\n77: \tmetav1.TypeMeta   `json:\",inline\"`\n78: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n79: \tSpec              interface{} `json:\"spec,omitempty\"`\n80: \tStatus            interface{} `json:\"status,omitempty\"`\n81: }\n82: \n83: type CreateAgentRuntimeRequest struct {\n84: \tmetav1.TypeMeta   `json:\",inline\"`\n85: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n86: \tSpec              interface{} `json:\"spec,omitempty\"`\n87: }\n88: \n89: type CreateCodeInterpreterRequest struct {\n90: \tmetav1.TypeMeta   `json:\",inline\"`\n91: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n92: \tSpec              interface{} `json:\"spec,omitempty\"`\n93: }\n94: \n95: type UpdateAgentRuntimeRequest struct {\n96: \tmetav1.TypeMeta   `json:\",inline\"`\n97: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n98: \tSpec              interface{} `json:\"spec,omitempty\"`\n99: }\n100: \n101: type UpdateCodeInterpreterRequest struct {\n102: \tmetav1.TypeMeta   `json:\",inline\"`\n103: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n104: \tSpec              interface{} `json:\"spec,omitempty\"`\n105: }\n106: \n107: type WatchEvent struct {\n108: \tType   string      `json:\"type\"`\n109: \tObject interface{} `json:\"object\"`\n110: }\n111: \n112: func NewAPIResponse(data interface{}, metadata *ListMeta) *APIResponse {\n113: \treturn &APIResponse{\n114: \t\tKind:       \"Status\",\n115: \t\tAPIVersion: \"v1\",\n116: \t\tStatus:     \"Success\",\n117: \t\tData:       data,\n118: \t\tMetadata:   metadata,\n119: \t}\n120: }\n121: \n122: func NewAPIError(message, reason string, code int) *APIError {\n123: \treturn &APIError{\n124: \t\tKind:       \"Status\",\n125: \t\tAPIVersion: \"v1\",\n126: \t\tStatus:     \"Failure\",\n127: \t\tMessage:    message,\n128: \t\tReason:     reason,\n129: \t\tCode:       code,\n130: \t}\n131: }\n\n(End of file - total 131 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\ntype APIResponse struct {\n\tKind       string      `json:\"kind\"`\n\tAPIVersion string      `json:\"apiVersion\"`\n\tStatus     string      `json:\"status\"`\n\tData       interface{} `json:\"data,omitempty\"`\n\tMetadata   *ListMeta   `json:\"metadata,omitempty\"`\n}\n\ntype ListMeta struct {\n\tContinue           string `json:\"continue,omitempty\"`\n\tRemainingItemCount *int64 `json:\"remainingItemCount,omitempty\"`\n\tResourceVersion    string `json:\"resourceVersion,omitempty\"`\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M