       output=output,\n                verbose=verbose,\n            )\n\n            progress.update(task, completed=True)\n\n        console.print(\n            Panel(\n                f\"[bold green]Agent built successfully![/bold green]\\n\\n\"\n                f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n                f\"[bold]Image:[/bold] {result['image_name']}:{result['image_tag']}\\n\"\n                f\"[bold]Image ID:[/bold] {result['image_id'][:12]}\\n\"\n                f\"[bold]Version:[/bold] {result['version']}\",\n                title=\"Build Complete\",\n                style=\"green\",\n            )\n        )\n\n    except Exception as e:\n        _handle_error(e, \"build\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef publish(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        help=\"Path to the agent workspace directory\",\n    ),\n    version: Optional[str] = typer.Option(\n        None,\n        \"--version\",\n        help=\"Semantic version string (e.g., v1.0.0)\",\n    ),\n    image_url: Optional[str] = typer.Option(\n        None,\n        \"--image-url\",\n        help=\"Image repository URL\",\n    ),\n    image_username: Optional[str] = typer.Option(\n        None,\n        \"--image-username\",\n        help=\"Username for image repository\",\n    ),\n    image_password: Optional[str] = typer.Option(\n        None,\n        \"--image-password\",\n        help=\"Password for image repository\",\n    ),\n    description: Optional[str] = typer.Option(\n        None,\n        \"--description\",\n        help=\"Agent description\",\n    ),\n    region: Optional[str] = typer.Option(\n        None,\n        \"--region\",\n        help=\"Deployment region\",\n    ),\n    cloud_provider: Optional[str] = typer.Option(\n        None,\n        \"--cloud-provider\",\n        help=\"Cloud provider name\",\n    ),\n    provider: str = typer.Option(\n        \"agentcube\",\n        \"--provider\",\n        help=\"Target provider: 'agentcube' or 'k8s'\",\n    ),\n    node_port: Optional[int] = typer.Option(\n        None,\n        \"--node-port\",\n        help=\"NodePort (30000-32767)\",\n    ),\n    replicas: Optional[int] = typer.Option(\n        None,\n        \"--replicas\",\n        help=\"Number of replicas\",\n    ),\n    namespace: Optional[str] = typer.Option(\n        None,\n        \"--namespace\",\n        help=\"Deployment namespace\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n) -> None:\n    \"\"\"\n    Publish/deploy an agent to the target provider.\n\n    Deploys the agent to AgentCube (AgentRuntime CR) or Kubernetes\n    (Deployment + NodePort Service).\n    \"\"\"\n    try:\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        with Progress(\n            SpinnerColumn(),\n            TextColumn(\"[progress.description]{task.description}\"),\n            console=console,\n        ) as progress:\n            task = progress.add_task(\"Publishing agent...\", total=None)\n\n            runtime = PublishRuntime(verbose=verbose, provider=provider)\n\n            result = runtime.publish(\n                workspace_path=workspace,\n                version=version,\n                image_url=image_url,\n                image_username=image_username,\n                image_password=image_password,\n                description=description,\n                region=region,\n                cloud_provider=cloud_provider,\n                provider=provider,\n                node_port=node_port,\n                replicas=replicas,\n                namespace=namespace,\n                verbose=verbose,\n            )\n\n            progress.update(task, completed=True)\n\n        console.print(\n            Panel(\n                f\"[bold green]Agent published successfully![/bold green]\\n\\n\"\n                f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n                f\"[bold]Provider:[/bold] {result['provider']}\\n\"\n                f\"[bold]Endpoint:[/bold] {result['endpoint']}\\n\"\n                f\"[bold]Status:[/bold] {result['status']}\",\n                title=\"Publish Complete\",\n                style=\"green\",\n            )\n        )\n\n    except Exception as e:\n        _handle_error(e, \"publish\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef invoke(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        help=\"Path to the agent workspace directory\",\n    ),\n    payload: str = typer.Option(\n        \"{}\",\n        \"--payload\",\n        help=\"JSON-formatted input passed to the agent\",\n    ),\n    header_list: Optional[list[str]] = typer.Option(\n        None,\n        \"--header\",\n        help=\"Custom HTTP headers (key:value format)\",\n    ),\n    provider: str = typer.Option(\n        \"agentcube\",\n        \"--provider\",\n        help=\"Target provider: 'agentcube' or 'k8s'\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n) -> None:\n    \"\"\"\n    Invoke a published agent.\n\n    Posts JSON to the published agent endpoint and returns the response.\n    \"\"\"\n    try:\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        with Progress(\n            SpinnerColumn(),\n            TextColumn(\"[progress.description]{task.description}\"),\n            console=console,\n        ) as progress:\n            task = progress.add_task(\"Invoking agent...\", total=None)\n\n            runtime = InvokeRuntime(verbose=verbose, provider=provider)\n\n            result = runtime.invoke(\n                workspace_path=workspace,\n                payload=payload,\n                header_list=header_list,\n                provider=provider,\n                verbose=verbose,\n            )\n\n            progress.update(task, completed=True)\n\n        console.print(\n            Panel(\n                f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n                f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n                f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n                f\"[bold]Response:[/bold]\",\n                title=\"Invoke Complete\",\n                style=\"green\",\n            )\n        )\n\n        import json\n\n        console.print_json(json.dumps(result[\"response\"], indent=2))\n\n    except Exception as e:\n        _handle_error(e, \"invoke\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef status(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        help=\"Path to the agent workspace directory\",\n    ),\n    provider: str = typer.Option(\n        \"agentcube\",\n        \"--provider\",\n        help=\"Target provider: 'agentcube' or 'k8s'\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n) -> None:\n    \"\"\"\n    Check the status of a published agent.\n\n    Loads workspace metadata and displays agent status in a table.\n    \"\"\"\n    try:\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        runtime = StatusRuntime(verbose=verbose, provider=provider)\n\n        result = runtime.get_status(\n            workspace_path=workspace,\n            provider=provider,\n        )\n\n        table = Table(title=f\"Agent Status: {result.get('agent_name', 'Unknown')}\")\n\n        table.add_column(\"Field\", style=\"cyan\")\n        table.add_column(\"Value\", style=\"green\")\n\n        table.add_row(\"Agent Name\", result.get(\"agent_name\", \"N/A\"))\n        table.add_row(\"Agent ID\", result.get(\"agent_id\", \"N/A\"))\n        table.add_row(\"Provider\", result.get(\"provider\", \"N/A\"))\n        table.add_row(\"Status\", result.get(\"status\", \"unknown\"))\n        table.add_row(\"Endpoint\", result.get(\"endpoint\", \"N/A\"))\n        table.add_row(\"Namespace\", result.get(\"namespace\", \"N/A\"))\n\n        if \"error\" in result:\n            table.add_row(\"Error\", result[\"error\"])\n\n        console.print(table)\n\n        if result.get(\"status\") in [\"not_published\", \"error\"]:\n            raise typer.Exit(code=1)\n\n    except Exception as e:\n        _handle_error(e, \"status\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef version() -> None:\n    \"\"\"Show version information.\"\"\"\n    console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n\n\nif __name__ == \"__main__\":\n    app()\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py","time":{"start":1775864446799,"end":1775864447414}}}}
