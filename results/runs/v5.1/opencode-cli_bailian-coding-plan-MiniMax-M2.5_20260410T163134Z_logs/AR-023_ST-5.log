st adds session header from metadata.\"\"\"\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"result\": \"ok\"}\n        mock_response.raise_for_status = MagicMock()\n\n        mock_instance = AsyncMock()\n        mock_instance.post.return_value = mock_response\n        mock_instance.__aenter__ = AsyncMock(return_value=mock_instance)\n        mock_instance.__aexit__ = AsyncMock(return_value=None)\n        mock_client.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_endpoint=\"http://test:8080\",\n                agent_id=\"test-id\",\n                session_id=\"session-123\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n            runtime.invoke(str(workspace), payload='{\"test\": true}')"},"output":"Edit applied successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/invoke_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/status_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/metadata_service.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_invoke_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/tes