th\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import MetadataService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nclass StatusRuntime:\n    \"\"\"\n    Core runtime for checking agent status.\n\n    Retrieves and displays agent status from the target provider.\n    \"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\"):\n        \"\"\"\n        Initialize the StatusRuntime.\n\n        Args:\n            verbose: Enable verbose logging\n            provider: Target provider (agentcube or k8s)\n        \"\"\"\n        self.verbose = verbose\n        self.provider = provider\n        self.logger = logging.getLogger(__name__)\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        else:\n            logging.basicConfig(level=logging.INFO)\n\n        self.metadata_service = MetadataService()\n\n    def _get_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n        \"\"\"\n        Get status from Kubernetes deployment.\n\n        Args:\n            metadata: Agent metadata\n\n        Returns:\n            Status dictionary\n        \"\"\"\n        namespace = \"default\"\n        if metadata.k8s_deployment and metadata.k8s_deployment.get(\"namespace\"):\n            namespace = metadata.k8s_deployment[\"namespace\"]\n\n        k8s_provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n\n        agent_name = metadata.agent_id or metadata.agent_name\n        status = k8s_provider.get_agent_status(agent_name)\n\n        return status\n\n    def _get_cr_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n        \"\"\"\n        Get status from AgentRuntime CR.\n\n        Args:\n            metadata: Agent metadata\n\n        Returns:\n            Status dictionary\n        \"\"\"\n        namespace = \"default\"\n        if metadata.k8s_deployment and metadata.k8s_deployment.get(\"namespace\"):\n            namespace = metadata.k8s_deployment[\"namespace\"]\n\n        agentcube_provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n\n        agent_name = metadata.agent_id or metadata.agent_name\n        cr = agentcube_provider.get_agent_runtime(agent_name, namespace)\n\n        if cr:\n            return {\n                \"name\": cr.get(\"metadata\", {}).get(\"name\"),\n                \"namespace\": cr.get(\"metadata\", {}).get(\"namespace\"),\n                \"status\": cr.get(\"status\", {}).get(\"phase\", \"Unknown\"),\n                \"endpoint\": cr.get(\"status\", {}).get(\"endpoint\"),\n            }\n\n        return {\n            \"name\": agent_name,\n            \"namespace\": namespace,\n            \"status\": \"not_found\",\n        }\n\n    def get_status(\n        self,\n        workspace_path: str,\n        provider: Optional[str] = None,\n    ) -> dict:\n        \"\"\"\n        Get agent status from the target provider.\n\n        Args:\n            workspace_path: Path to agent workspace\n            provider: Target provider (agentcube or k8s)\n\n        Returns:\n            Dictionary with status information\n\n        Raises:\n            ValueError: If agent not published\n        \"\"\"\n        workspace = Path(workspace_path).resolve()\n        provider = provider or self.provider\n\n        metadata = self.metadata_service.load_metadata(workspace)\n\n        if not metadata.agent_id and not metadata.agent_endpoint:\n            return {\n                \"agent_name\": metadata.agent_name,\n                \"status\": \"not_published\",\n                \"message\": \"Agent not published. Run 'publish' first.\",\n            }\n\n        try:\n            if provider == \"agentcube\":\n                status = self._get_cr_k8s_status(metadata)\n            else:\n                status = self._get_k8s_status(metadata)\n\n            return {\n                \"agent_name\": metadata.agent_name,\n                \"agent_id\": metadata.agent_id,\n                \"provider\": provider,\n                \"status\": status.get(\"status\", \"unknown\"),\n                \"endpoint\": status.get(\"endpoint\") or metadata.agent_endpoint,\n                \"namespace\": status.get(\"namespace\", \"default\"),\n            }\n\n        except Exception as e:\n            return {\n                \"agent_name\": metadata.agent_name,\n                \"status\": \"error\",\n                \"error\": str(e),\n            }\n","after":"\"\"\"Status runtime for AgentCube - orchestrates the status command workflow.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import MetadataService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nclass StatusRuntime:\n    \"\"\"\n    Core runtime for checking agent status.\n\n    Retrieves and displays agent status from the target provider.\n    \"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\"):\n        \"\"\"\n        Initialize the StatusRuntime.\n\n        Args:\n            verbose: Enable verbose logging\n            provider: Target provider (agentcube or k8s)\n        \"\"\"\n        self.verbose = verbose\n        self.provider = provider\n        self.logger = logging.getLogger(__name__)\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        else:\n            logging.basicConfig(level=logging.INFO)\n\n        self.metadata_service = MetadataService()\n\n    def _get_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n        \"\"\"\n        Get status from Kubernetes deployment.\n\n        Args:\n            metadata: Agent metadata\n\n        Returns:\n            Status dictionary\n        \"\"\"\n        namespace = \"default\"\n        if metadata.k8s_deployment and metadata.k8s_deployment.get(\"namespace\"):\n            namespace = metadata.k8s_deployment[\"namespace\"]\n\n        k8s_provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n\n        agent_name = metadata.agent_id or metadata.agent_name\n        status = k8s_provider.get_agent_status(agent_name)\n\n        return status\n\n    def _get_cr_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n        \"\"\"\n        Get status from AgentRuntime CR.\n\n        Args:\n            metadata: Agent metadata\n\n        Returns:\n            Status dictionary\n        \"\"\"\n        namespace = \"default\"\n        if metadata.k8s_deployment and metadata.k8s_deployment.get(\"namespace\"):\n            namespace = metadata.k8s_deployment[\"namespace\"]\n\n        agentcube_provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n\n        agent_name = metadata.agent_id or metadata.agent_name\n        cr = agentcube_provider.get_agent_runtime(agent_name, namespace)\n\n        if cr:\n            phase = cr.get(\"status\", {}).get(\"phase\")\n            if phase:\n                return {\n                    \"name\": cr.get(\"metadata\", {}).get(\"name\"),\n                    \"namespace\": cr.get(\"metadata\", {}).get(\"namespace\"),\n                    \"status\": phase,\n                    \"endpoint\": cr.get(\"status\", {}).get(\"endpoint\"),\n                }\n            return {\n                \"name\": cr.get(\"metadata\", {}).get(\"name\"),\n                \"namespace\": cr.get(\"metadata\", {}).get(\"namespace\"),\n                \"status\": \"created_no_status\",\n                \"endpoint\": cr.get(\"status\", {}).get(\"endpoint\"),\n            }\n\n        return {\n            \"name\": agent_name,\n            \"namespace\": namespace,\n            \"status\": \"not_found\",\n        }\n\n    def get_status(\n        self,\n        workspace_path: str,\n        provider: Optional[str] = None,\n    ) -> dict:\n        \"\"\"\n        Get agent status from the target provider.\n\n        Args:\n            workspace_path: Path to agent workspace\n            provider: Target provider (agentcube or k8s)\n\n        Returns:\n            Dictionary with status information\n\n        Raises:\n            ValueError: If agent not published\n        \"\"\"\n        workspace = Path(workspace_path).resolve()\n        provider = provider or self.provider\n\n        metadata = self.metadata_service.load_metadata(workspace)\n\n        if not metadata.agent_id and not metadata.agent_endpoint:\n            return {\n                \"agent_name\": metadata.agent_name,\n                \"status\": \"not_published\",\n                \"message\": \"Agent not published. Run 'publish' first.\",\n            }\n\n        try:\n            if provider == \"agentcube\":\n                status = self._get_cr_k8s_status(metadata)\n            else:\n                status = self._get_k8s_status(metadata)\n\n            return {\n                \"agent_name\": metadata.agent_name,\n                \"agent_id\": metadata.agent_id,\n                \"provider\": provider,\n                \"status\": status.get(\"status\", \"unknown\"),\n                \"endpoint\": status.get(\"endpoint\") or metadata.agent_endpoint,\n                \"namespace\": status.get(\"namespace\", \"default\"),\n            }\n\n        except Exception as e:\n            return {\n                \"agent_name\": metadata.agent_name,\n                \"status\": \"error\",\n                \"error\": str(e),\n            }\n","additions":9,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/status_runtime.py","time":{"start":1775864082892,"end":1775864083700}}}}
