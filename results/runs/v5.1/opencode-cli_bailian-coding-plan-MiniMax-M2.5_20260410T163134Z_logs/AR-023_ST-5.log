{"type":"tool_use","timestamp":1775864352579,"sessionID":"ses_286418634ffea8pAZ41CVyQMqj","part":{"id":"prt_d79c310a4001GoI1dH5ce68dLa","messageID":"msg_d79c2f0bb0019gesRKtY2eXy9e","sessionID":"ses_286418634ffea8pAZ41CVyQMqj","type":"tool","tool":"write","callID":"toolu_50ca7d90b30d4a3ca69ef6d9","state":{"status":"completed","input":{"content":"\"\"\"Unit tests for StatusRuntime.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\nimport yaml\n\nfrom agentcube.runtime.status_runtime import StatusRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestStatusRuntimeGetStatus:\n    \"\"\"Tests for get_status method.\"\"\"\n\n    def test_status_not_published(self):\n        \"\"\"Test status when agent not published.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = StatusRuntime()\n            result = runtime.get_status(str(workspace))\n\n            assert result[\"status\"] == \"not_published\"\n\n    @patch(\"agentcube.services.k8s_provider.KubernetesProvider\")\n    def test_status_with_k8s_provider(self, mock_provider):\n        \"\"\"Test status with K8s provider.\"\"\"\n        mock_instance = MagicMock()\n        mock_instance.get_agent_status.return_value = {\n            \"name\": \"test\",\n            \"status\": \"running\",\n            \"ready_replicas\": 1,\n        }\n        mock_provider.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_id=\"test-id\",\n                agent_endpoint=\"http://test:8080\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = StatusRuntime(provider=\"k8s\")\n            result = runtime.get_status(str(workspace), provider=\"k8s\")\n\n            assert result[\"provider\"] == \"k8s\"\n\n    @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n    def test_status_with_agentcube_provider(self, mock_provider):\n        \"\"\"Test status with AgentCube provider.\"\"\"\n        mock_instance = MagicMock()\n        mock_instance.get_agent_runtime.return_value = {\n            \"metadata\": {\"name\": \"test\", \"namespace\": \"default\"},\n            \"status\": {\"phase\": \"Running\", \"endpoint\": \"http://test:8080\"},\n        }\n        mock_provider.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_id=\"test-id\",\n                agent_endpoint=\"http://test:8080\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = StatusRuntime(provider=\"agentcube\")\n            result = runtime.get_status(str(workspace), provider=\"agentcube\")\n\n            assert result[\"provider\"] == \"agentcube\"\n\n    @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n    def test_status_error_handling(self, mock_provider):\n        \"\"\"Test status when error occurs.\"\"\"\n        mock_instance = MagicMock()\n        mock_instance.get_agent_runtime.side_effect = Exception(\"K8s cluster unavailable\")\n        mock_provider.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_id=\"test-id\",\n                agent_endpoint=\"http://test:8080\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = StatusRuntime(provider=\"agentcube\")\n            result = runtime.get_status(str(workspace), provider=\"agentcube\")\n\n            assert result[\"status\"] == \"error\"\n            assert \"K8s cluster unavailable\" in result[\"error\"]\n\n    def test_status_custom_namespace(self):\n        \"\"\"Test status with custom namespace from k8s_deployment.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_id=\"test-id\",\n                agent_endpoint=\"http://test:8080\",\n                k8s_deployment={\"namespace\": \"custom-ns\"},\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = StatusRuntime(provider=\"agentcube\")\n            result = runtime.get_status(str(workspace))\n\n            assert result[\"namespace\"] == \"custom-ns\"\n\n\nclass TestStatusRuntimeK8sStatus:\n    \"\"\"Tests for _get_k8s_status method.\"\"\"\n\n    @patch(\"agentcube.services.k8s_provider.KubernetesProvider\")\n    def test_get_k8s_status(self, mock_provider):\n        \"\"\"Test getting K8s status.\"\"\"\n        mock_instance = MagicMock()\n        mock_instance.get_agent_status.return_value = {\n            \"status\": \"running\",\n            \"ready_replicas\": 1,\n        }\n        mock_provider.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n            )\n\n            runtime = StatusRuntime()\n            result = runtime._get_k8s_status(metadata)\n\n            assert result[\"status\"] == \"running\"\n\n\nclass TestStatusRuntimeCRStatus:\n    \"\"\"Tests for _get_cr_k8s_status method.\"\"\"\n\n    @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n    def test_get_cr_k8s_status(self, mock_provider):\n        \"\"\"Test getting CR K8s status.\"\"\"\n        mock_instance = MagicMock()\n        mock_instance.get_agent_runtime.return_value = {\n            \"metadata\": {\"name\": \"test\", \"namespace\": \"default\"},\n            \"status\": {\"phase\": \"Running\", \"endpoint\": \"http://test:8080\"},\n        }\n        mock_provider.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_id=\"test-id\",\n            )\n\n            runtime = StatusRuntime()\n            result = runtime._get_cr_k8s_status(metadata)\n\n            assert result[\"status\"] == \"Running\"\n\n    @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n    def test_get_cr_k8s_status_no_status_field(self, mock_provider):\n        \"\"\"Test getting CR K8s status when status field is empty.\"\"\"\n        mock_instance = MagicMock()\n        mock_instance.get_agent_runtime.return_value = {\n            \"metadata\": {\"name\": \"test\", \"namespace\": \"default\"},\n            \"status\": {},\n        }\n        mock_provider.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_id=\"test-id\",\n            )\n\n            runtime = StatusRuntime()\n            result = runtime._get_cr_k8s_status(metadata)\n\n            assert result[\"status\"] == \"created_no_status\"\n\n    @patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\")\n    def test_get_cr_k8s_status_not_found(self, mock_provider):\n        \"\"\"Test getting CR K8s status when agent not found.\"\"\"\n        mock_instance = MagicMock()\n        mock_instance.get_agent_runtime.return_value = None\n        mock_provider.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_id=\"test-id\",\n            )\n\n            runtime = StatusRuntime()\n            result = runtime._get_cr_k8s_status(metadata)\n\n            assert result[\"status\"] == \"not_found\"","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_status_runtime.py"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/invoke_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_2