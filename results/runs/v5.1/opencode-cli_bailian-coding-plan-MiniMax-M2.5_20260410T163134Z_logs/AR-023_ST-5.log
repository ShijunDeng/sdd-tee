{"type":"tool_use","timestamp":1775864210234,"sessionID":"ses_286418634ffea8pAZ41CVyQMqj","part":{"id":"prt_d79c0720a001SBdjXcUMxa8Jsv","messageID":"msg_d79c0690d001VE273mk260iHJg","sessionID":"ses_286418634ffea8pAZ41CVyQMqj","type":"tool","tool":"edit","callID":"toolu_ddd12a739caf46518f83a280","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_invoke_runtime.py","newString":"\"\"\"Unit tests for InvokeRuntime.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import patch, MagicMock, AsyncMock\n\nimport pytest\nimport yaml\n\nfrom agentcube.runtime.invoke_runtime import InvokeRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestInvokeRuntimeResolveEndpoint:\n    \"\"\"Tests for _resolve_endpoint method.\"\"\"\n\n    def test_resolves_from_agent_endpoint(self):\n        \"\"\"Test resolves endpoint from metadata.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_endpoint=\"http://myagent:8080\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n            endpoint = runtime._resolve_endpoint(workspace, \"agentcube\")\n\n            assert endpoint == \"http://myagent:8080\"\n\n    def test_resolves_from_agent_id_with_namespace(self):\n        \"\"\"Test resolves endpoint from agent_id and namespace.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_id=\"my-agent\",\n                port=8080,\n                k8s_deployment={\"namespace\": \"custom-ns\"},\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n            endpoint = runtime._resolve_endpoint(workspace, \"agentcube\")\n\n            assert \"my-agent\" in endpoint\n            assert \"custom-ns\" in endpoint\n            assert \"8080\" in endpoint\n\n    def test_raises_when_not_published(self):\n        \"\"\"Test raises when agent not published.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n\n            with pytest.raises(ValueError, match=\"not published\"):\n                runtime._resolve_endpoint(workspace, \"agentcube\")\n\n\nclass TestInvokeRuntimeInvoke:\n    \"\"\"Tests for invoke method.\"\"\"\n\n    def test_invoke_with_invalid_json(self):\n        \"\"\"Test invoke with invalid JSON payload.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            runtime = InvokeRuntime()\n\n            with pytest.raises(ValueError, match=\"Invalid JSON\"):\n                runtime.invoke(str(workspace), payload=\"not valid json\")\n\n    def test_invoke_with_invalid_header_format(self):\n        \"\"\"Test invoke with invalid header format.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            runtime = InvokeRuntime()\n\n            with pytest.raises(ValueError, match=\"Invalid header format\"):\n                runtime.invoke(\n                    str(workspace),\n                    payload=\"{}\",\n                    header_list=[\"invalid-header\"],\n                )\n\n    def test_invoke_with_not_published(self):\n        \"\"\"Test invoke with not published agent.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n\n            with pytest.raises(ValueError, match=\"not published\"):\n                runtime.invoke(str(workspace), payload=\"{}\")\n\n    def test_invoke_with_valid_custom_headers(self):\n        \"\"\"Test invoke with valid custom headers.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_endpoint=\"http://test:8080\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n\n            with patch.object(runtime, \"_invoke_async\", return_value={\"result\": \"ok\"}) as mock_invoke:\n                result = runtime.invoke(\n                    str(workspace),\n                    payload='{\"key\": \"value\"}',\n                    header_list=[\"Authorization: Bearer token123\", \"X-Custom-Header: custom-value\"],\n                )\n                mock_invoke.assert_called_once()\n                call_kwargs = mock_invoke.call_args[1]\n                assert \"headers\" in call_kwargs\n                assert call_kwargs[\"headers\"][\"Authorization\"] == \"Bearer token123\"\n                assert call_kwargs[\"headers\"][\"X-Custom-Header\"] == \"custom-value\"\n\n    @patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\")\n    def test_invoke_successful_response(self, mock_client):\n        \"\"\"Test invoke successful response handling.\"\"\"\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"result\": \"ok\", \"message\": \"success\"}\n        mock_response.raise_for_status = MagicMock()\n\n        mock_instance = AsyncMock()\n        mock_instance.post.return_value = mock_response\n        mock_instance.__aenter__ = AsyncMock(return_value=mock_instance)\n        mock_instance.__aexit__ = AsyncMock(return_value=None)\n        mock_client.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_endpoint=\"http://test:8080\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n            result = runtime.invoke(str(workspace), payload='{\"test\": true}')\n\n            assert result[\"agent_name\"] == \"test\"\n            assert result[\"response\"][\"result\"] == \"ok\"\n\n    @patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\")\n    def test_invoke_http_error_response(self, mock_client):\n        \"\"\"Test invoke HTTP error response handling.\"\"\"\n        mock_response = MagicMock()\n        mock_response.status_code = 500\n        mock_response.text = \"Internal Server Error\"\n        mock_response.raise_for_status = MagicMock(side_effect=Exception(\"500 Error\"))\n\n        mock_instance = AsyncMock()\n        mock_instance.post.return_value = mock_response\n        mock_instance.__aenter__ = AsyncMock(return_value=mock_instance)\n        mock_instance.__aexit__ = AsyncMock(return_value=None)\n        mock_client.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_endpoint=\"http://test:8080\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n\n            with pytest.raises(ValueError, match=\"Invocation failed\"):\n                runtime.invoke(str(workspace), payload='{}')\n\n\nclass TestInvokeRuntimeSessionHeader:\n    \"\"\"Tests for session header handling.\"\"\"\n\n    @patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\")\n    def test_adds_session_header(self, mock_client):\n        \"\"\"Test adds session header from metadata.\"\"\"\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"result\": \"ok\"}\n        mock_response.raise_for_status = MagicMock()\n\n        mock_instance = AsyncMock()\n        mock_instance.post.return_value = mock_response\n        mock_instance.__aenter__ = AsyncMock(return_value=mock_instance)\n        mock_instance.__aexit__ = AsyncMock(return_value=None)\n        mock_client.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_endpoint=\"http://test:8080\",\n                agent_id=\"test-id\",\n                session_id=\"session-123\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n            runtime.invoke(str(workspace), payload='{\"test\": true}')\n\n            call_args = mock_instance.post.call_args\n            headers = call_args[1][\"headers\"]\n            assert \"X-Agentcube-Session-Id\" in headers\n            assert headers[\"X-Agentcube-Session-Id\"] == \"session-123\"\n\n    @patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\")\n    def test_no_session_header_when_not_present(self, mock_client):\n        \"\"\"Test no session header when session_id not in metadata.\"\"\"\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"result\": \"ok\"}\n        mock_response.raise_for_status = MagicMock()\n\n        mock_instance = AsyncMock()\n        mock_instance.post.return_value = mock_response\n        mock_instance.__aenter__ = AsyncMock(return_value=mock_instance)\n        mock_instance.__aexit__ = AsyncMock(return_value=None)\n        mock_client.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_endpoint=\"http://test:8080\",\n                agent_id=\"test-id\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n            runtime.invoke(str(workspace), payload='{\"test\": true}')\n\n            call_args = mock_instance.post.call_args\n            headers = call_args[1][\"headers\"]\n            assert \"X-Agentcube-Session-Id\" not in headers\n\n    @patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\")\n    def test_session_header_merges_with_custom_headers(self, mock_client):\n        \"\"\"Test session header merges with custom headers.\"\"\"\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"result\": \"ok\"}\n        mock_response.raise_for_status = MagicMock()\n\n        mock_instance = AsyncMock()\n        mock_instance.post.return_value = mock_response\n        mock_instance.__aenter__ = AsyncMock(return_value=mock_instance)\n        mock_instance.__aexit__ = AsyncMock(return_value=None)\n        mock_client.return_value = mock_instance\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                agent_endpoint=\"http://test:8080\",\n                agent_id=\"test-id\",\n                session_id=\"session-123\",\n            )\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = InvokeRuntime()\n            runtime.invoke(\n                str(workspace),\n                payload='{\"test\": true}',\n                header_list=[\"Authorization: Bearer token\"],\n            )\n\n            call_args = mock_instance.post.call_args\n            headers = call_args[1][\"headers\"]\n            assert headers[\"Authorization\"] == \"Bearer token\"\n            assert headers[\"X-Agentcube-Session-Id\"] == \"session-123\"","oldString":"\"\"\"Unit tests for Invoke