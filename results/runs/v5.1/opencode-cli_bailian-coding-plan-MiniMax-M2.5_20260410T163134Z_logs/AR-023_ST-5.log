I (kubectl agentcube) version: {__version__}\")\n        raise typer.Exit()\n\n\ndef version_callback(value: bool) -> None:\n    \"\"\"Callback for --version option.\"\"\"\n    if value:\n        console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n        raise typer.Exit()\n\n\ndef _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n    \"\"\"\n    Handle and format error output.\n\n    Args:\n        e: Exception that was raised\n        command_name: Name of the command\n        verbose: Enable verbose error output\n    \"\"\"\n    error_msg = str(e)\n\n    if verbose:\n        import traceback\n\n        console.print(\n            Panel(\n                f\"[bold red]Error in {command_name}:[/bold red]\\n\\n{error_msg}\\n\\n[red]{traceback.format_exc()}[/red]\",\n                style=\"red\",\n            )\n        )\n    else:\n        console.print(f\"[bold red]Error:[/bold red] {error_msg}\")\n\n\n@app.command()\ndef pack(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        help=\"Path to agent workspace\",\n    ),\n    agent_name: Optional[str] = typer.Option(\n        None,\n        \"--agent-name\",\n        help=\"Override agent name\",\n    ),\n    language: Optional[str] = typer.Option(\n        None,\n        \"--language\",\n        help=\"Programming language (python, java)\",\n    ),\n    entrypoint: Optional[str] = typer.Option(\n        None,\n        \"--entrypoint\",\n        help=\"Override entrypoint command\",\n    ),\n    port: Optional[int] = typer.Option(\n        None,\n        \"--port\",\n        help=\"Port to expose (default: 8080)\",\n    ),\n    build_mode: Optional[str] = typer.Option(\n        None,\n        \"--build-mode\",\n        help=\"Build strategy (local, cloud)\",\n    ),\n    description: Optional[str] = typer.Option(\n        None,\n        \"--description\",\n        help=\"Agent description\",\n    ),\n    output: Optional[str] = typer.Option(\n        None,\n        \"--output\",\n        help=\"Output path for packaged workspace\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n    version: bool = typer.Option(\n        None,\n        \"--version\",\n        help=\"Show version information\",\n        callback=version_callback,\n        is_eager=True,\n    ),\n) -> None:\n    \"\"\"\n    Pack an agent workspace for deployment.\n\n    Validates the workspace structure, loads or creates agent metadata,\n    processes dependencies, optionally generates a Dockerfile, and\n    prepares the workspace for subsequent build and publish steps.\n    \"\"\"\n    try:\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        with Progress(\n            SpinnerColumn(),\n            TextColumn(\"[progress.description]{task.description}\"),\n            console=console,\n        ) as progress:\n            task = progress.add_task(\"Packing agent workspace...\", total=None)\n\n            runtime = PackRuntime(verbose=verbose)\n\n            result = runtime.pack(\n                workspace_path=workspace,\n                agent_name=agent_name,\n                language=language,\n                entrypoint=entrypoint,\n                port=port,\n                build_mode=build_mode,\n                description=description,\n                output=output,\n                verbose=verbose,\n            )\n\n            progress.update(task, completed=True)\n\n        console.print(\n            Panel(\n                f\"[bold green]Agent packed successfully![/bold green]\\n\\n\"\n                f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n                f\"[bold]Workspace:[/bold] {result['workspace_path']}\\n\"\n                f\"[bold]Output:[/bold] {result['output_path']}\\n\"\n                f\"[bold]Metadata:[/bold] {result['metadata_file']}\\n\"\n                f\"[bold]Dockerfile:[/bold] {'Generated' if result['dockerfile_generated'] else 'Existing'}\",\n                title=\"Pack Complete\",\n                style=\"green\",\n            )\n        )\n\n    except Exception as e:\n        _handle_error(e, \"pack\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef build(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        help=\"Path to the agent workspace directory\",\n    ),\n    proxy: Optional[str] = typer.Option(\n        None,\n        \"-p\",\n        \"--proxy\",\n        help=\"Custom proxy URL for dependency resolution\",\n    ),\n    cloud_provider: Optional[str] = typer.Option(\n        None,\n        \"--cloud-provider\",\n        help=\"Cloud provider name (e.g., huawei)\",\n    ),\n    output: Optional[str] = typer.Option(\n        None,\n        \"--output\",\n        help=\"Output path for build artifacts\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n) -> None:\n    \"\"\"\n    Build a container image from a packed workspace.\n\n    Builds a Docker image from the packed workspace using local Docker\n    when build_mode is local, or cloud build when build_mode is cloud.\n    \"\"\"\n    try:\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        with Progress(\n            SpinnerColumn(),\n            TextColumn(\"[progress.description]{task.description}\"),\n            console=console,\n        ) as progress:\n            task = progress.add_task(\"Building agent image...\", total=None)\n\n            runtime = BuildRuntime(verbose=verbose)\n\n            result = runtime.build(\n                workspace_path=workspace,\n                proxy=proxy,\n                cloud_provider=cloud_provider,\n                output=output,\n                verbose=verbose,\n            )\n\n            progress.update(task, completed=True)\n\n        console.print(\n            Panel(\n                f\"[bold green]Agent built successfully![/bold green]\\n\\n\"\n                f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n                f\"[bold]Image:[/bold] {result['image_name']}:{result['image_tag']}\\n\"\n                f\"[bold]Image ID:[/bold] {result['image_id'][:12]}\\n\"\n                f\"[bold]Version:[/bold] {result['version']}\",\n                title=\"Build Complete\",\n                style=\"green\",\n            )\n        )\n\n    except Exception as e:\n        _handle_error(e, \"build\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef publish(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        help=\"Path to the agent workspace directory\",\n    ),\n    version: Optional[str] = typer.Option(\n        None,\n        \"--version\",\n        help=\"Semantic version string (e.g., v1.0.0)\",\n    ),\n    image_url: Optional[str] = typer.Option(\n        None,\n        \"--image-url\",\n        help=\"Image repository URL\",\n    ),\n    image_username: Optional[str] = typer.Option(\n        None,\n        \"--image-username\",\n        help=\"Username for image repository\",\n    ),\n    image_password: Optional[str] = typer.Option(\n        None,\n        \"--image-password\",\n        help=\"Password for image repository\",\n    ),\n    description: Optional[str] = typer.Option(\n        None,\n        \"--description\",\n        help=\"Agent description\",\n    ),\n    region: Optional[str] = typer.Option(\n        None,\n        \"--region\",\n        help=\"Deployment region\",\n    ),\n    cloud_provider: Optional[str] = typer.Option(\n        None,\n        \"--cloud-provider\",\n        help=\"Cloud provider name\",\n    ),\n    provider: str = typer.Option(\n        \"agentcube\",\n        \"--provider\",\n        help=\"Target provider: 'agentcube' or 'k8s'\",\n    ),\n    node_port: Optional[int] = typer.Option(\n        None,\n        \"--node-port\",\n        help=\"NodePort (30000-32767)\",\n    ),\n    replicas: Optional[int] = typer.Option(\n        None,\n        \"--replicas\",\n        help=\"Number of replicas\",\n    ),\n    namespace: Optional[str] = typer.Option(\n        None,\n        \"--namespace\",\n        help=\"Deployment namespace\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n) -> None:\n    \"\"\"\n    Publish/deploy an agent to the target provider.\n\n    Deploys the agent to AgentCube (AgentRuntime CR) or Kubernetes\n    (Deployment + NodePort Service).\n    \"\"\"\n    try:\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        with Progress(\n            SpinnerColumn(),\n            TextColumn(\"[progress.description]{task.description}\"),\n            console=console,\n        ) as progress:\n            task = progress.add_task(\"Publishing agent...\", total=None)\n\n            runtime = PublishRuntime(verbose=verbose, provider=provider)\n\n            result = runtime.publish(\n                workspace_path=workspace,\n                version=version,\n                image_url=image_url,\n                image_username=image_username,\n                image_password=image_password,\n                description=description,\n                region=region,\n                cloud_provider=cloud_provider,\n                provider=provider,\n                node_port=node_port,\n                replicas=replicas,\n                namespace=namespace,\n                verbose=verbose,\n            )\n\n            progress.update(task, completed=True)\n\n        console.print(\n            Panel(\n                f\"[bold green]Agent published successfully![/bold green]\\n\\n\"\n                f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n                f\"[bold]Provider:[/bold] {result['provider']}\\n\"\n                f\"[bold]Endpoint:[/bold] {result['endpoint']}\\n\"\n                f\"[bold]Status:[/bold] {result['status']}\",\n                title=\"Publish Complete\",\n                style=\"green\",\n            )\n        )\n\n    except Exception as e:\n        _handle_error(e, \"publish\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef invoke(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        help=\"Path to the agent workspace directory\",\n    ),\n    payload: str = typer.Option(\n        \"{}\",\n        \"--payload\",\n        help=\"JSON-formatted input passed to the agent\",\n    ),\n    header_list: Optional[List[str]] = typer.Option(\n        None,\n        \"--header\",\n        help=\"Custom HTTP headers (key:value format)\",\n    ),\n    provider: str = typer.Option(\n        \"agentcube\",\n        \"--provider\",\n        help=\"Target provider: 'agentcube' or 'k8s'\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n) -> None:\n    \"\"\"\n    Invoke a published agent.\n\n    Posts JSON to the published agent endpoint and returns the response.\n    \"\"\"\n    try:\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        with Progress(\n            SpinnerColumn(),\n            TextColumn(\"[progress.description]{task.description}\"),\n            console=console,\n        ) as progress:\n            task = progress.add_task(\"Invoking agent...\", total=None)\n\n            runtime = InvokeRuntime(verbose=verbose, provider=provider)\n\n            result = runtime.invoke(\n                workspace_path=workspace,\n                payload=payload,\n                header_list=header_list,\n                provider=provider,\n                verbose=verbose,\n            )\n\n            progress.update(task, completed=True)\n\n        console.print(\n            Panel(\n                f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n                f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n                f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n                f\"[bold]Response:[/bold]\",\n                title=\"Invoke Complete\",\n                style=\"green\",\n            )\n        )\n\n        import json\n\n        console.print_json(json.dumps(result[\"response\"], indent=2))\n\n    except Exception as e:\n        _handle_error(e, \"invoke\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef status(\n    workspace: str = typer.Option(\n        \".\",\n        \"-f\",\n        \"--workspace\",\n        help=\"Path to the agent workspace directory\",\n    ),\n    provider: str = typer.Option(\n        \"agentcube\",\n        \"--provider\",\n        help=\"Target provider: 'agentcube' or 'k8s'\",\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        help=\"Enable detailed logging\",\n    ),\n) -> None:\n    \"\"\"\n    Check the status of a published agent.\n\n    Loads workspace metadata and displays agent status in a table.\n    \"\"\"\n    try:\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        runtime = StatusRuntime(verbose=verbose, provider=provider)\n\n        result = runtime.get_status(\n            workspace_path=workspace,\n            provider=provider,\n        )\n\n        table = Table(title=f\"Agent Status: {result.get('agent_name', 'Unknown')}\")\n\n        table.add_column(\"Field\", style=\"cyan\")\n        table.add_column(\"Value\", style=\"green\")\n\n        table.add_row(\"Agent Name\", result.get(\"agent_name\", \"N/A\"))\n        table.add_row(\"Agent ID\", result.get(\"agent_id\", \"N/A\"))\n        table.add_row(\"Provider\", result.get(\"provider\", \"N/A\"))\n        table.add_row(\"Status\", result.get(\"status\", \"unknown\"))\n        table.add_row(\"Endpoint\", result.get(\"endpoint\", \"N/A\"))\n        table.add_row(\"Namespace\", result.get(\"namespace\", \"N/A\"))\n\n        if \"error\" in result:\n            table.add_row(\"Error\", result[\"error\"])\n\n        console.print(table)\n\n        if result.get(\"status\") in [\"not_published\", \"error\"]:\n            raise typer.Exit(code=1)\n\n    except Exception as e:\n        _handle_error(e, \"status\", verbose)\n        raise typer.Exit(code=1)\n\n\n@app.command()\ndef version() -> None:\n    \"\"\"Show version information.\"\"\"\n    console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n\n\nif __name__ == \"__main__\":\n    app()\n","after":"\"\"\"AgentCube CLI - Main entry point for kubectl-agentcube.\"\"\"\n\nimport logging\nfrom typing import Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\nfrom rich.panel import Panel\nfrom rich.table import Table\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.runtime.invoke_runtime import InvokeRuntime\nfrom agentcube.runtime.status_runtime import StatusRuntime\n\napp = typer.Typer(\n    name=\"kubectl-agentcube\",\n    help=\"AgentCube CLI - Package and manage agent runtimes\",\n    add_completion=False,\n    invoke_without_command=True,\n)\n\nconsole = Console()\n\n\n@app.callback()\ndef main_callback(\n    version: bool = typer.Option(\n        None,\n        \"--version\",\n        help=\"Show version information\",\n        is_eager=True,\n    ),\n    verbose: bool = typer.Option(\n        False,\n        \"--verbose\",\n        \"-v\",\n        help=\"Enable verbose output\",\n    ),\n) -> None:\n    \"\"\"Main callback for global options.\"\"\"\n    if verbose:\n        log