{"type":"tool_use","timestamp":1775862948827,"sessionID":"ses_2865226aaffes9rvCi52yAPwmp","part":{"id":"prt_d79ae1cb4001FOTAfdJYxZIitN","messageID":"msg_d79ae1182001EwVtBzZZM6x0sI","sessionID":"ses_2865226aaffes9rvCi52yAPwmp","type":"tool","tool":"read","callID":"toolu_bd011da2f6244793b489b0ba","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py</path>\n<type>file</type>\n<content>\n1: \"\"\"AgentCube CLI - Main entry point for kubectl-agentcube.\"\"\"\n2: \n3: import logging\n4: from typing import List, Optional\n5: \n6: import typer\n7: from rich.console import Console\n8: from rich.progress import Progress, SpinnerColumn, TextColumn\n9: from rich.panel import Panel\n10: from rich.table import Table\n11: from rich import print as rprint\n12: \n13: from agentcube import __version__\n14: from agentcube.runtime.pack_runtime import PackRuntime\n15: from agentcube.runtime.build_runtime import BuildRuntime\n16: from agentcube.runtime.publish_runtime import PublishRuntime\n17: from agentcube.runtime.invoke_runtime import InvokeRuntime\n18: from agentcube.runtime.status_runtime import StatusRuntime\n19: \n20: app = typer.Typer(\n21:     name=\"kubectl-agentcube\",\n22:     help=\"AgentCube CLI - Package and manage agent runtimes\",\n23:     add_completion=False,\n24:     invoke_without_command=True,\n25: )\n26: \n27: console = Console()\n28: \n29: \n30: @app.callback()\n31: def main_callback(\n32:     version: bool = typer.Option(\n33:         None,\n34:         \"--version\",\n35:         help=\"Show version information\",\n36:         is_eager=True,\n37:     ),\n38:     verbose: bool = typer.Option(\n39:         False,\n40:         \"--verbose\",\n41:         \"-v\",\n42:         help=\"Enable verbose output\",\n43:     ),\n44: ) -> None:\n45:     \"\"\"Main callback for global options.\"\"\"\n46:     if verbose:\n47:         logging.basicConfig(level=logging.DEBUG)\n48: \n49:     if version:\n50:         console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n51:         raise typer.Exit()\n52: \n53: \n54: def version_callback(value: bool) -> None:\n55:     \"\"\"Callback for --version option.\"\"\"\n56:     if value:\n57:         console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n58:         raise typer.Exit()\n59: \n60: \n61: def _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n62:     \"\"\"\n63:     Handle and format error output.\n64: \n65:     Args:\n66:         e: Exception that was raised\n67:         command_name: Name of the command\n68:         verbose: Enable verbose error output\n69:     \"\"\"\n70:     error_msg = str(e)\n71: \n72:     if verbose:\n73:         import traceback\n74: \n75:         console.print(\n76:             Panel(\n77:                 f\"[bold red]Error in {command_name}:[/bold red]\\n\\n{error_msg}\\n\\n[red]{traceback.format_exc()}[/red]\",\n78:                 style=\"red\",\n79:             )\n80:         )\n81:     else:\n82:         console.print(f\"[bold red]Error:[/bold red] {error_msg}\")\n83: \n84: \n85: @app.command()\n86: def pack(\n87:     workspace: str = typer.Option(\n88:         \".\",\n89:         \"-f\",\n90:         \"--workspace\",\n91:         \"-f\",\n92:         help=\"Path to agent workspace\",\n93:     ),\n94:     agent_name: Optional[str] = typer.Option(\n95:         None,\n96:         \"--agent-name\",\n97:         help=\"Override agent name\",\n98:     ),\n99:     language: Optional[str] = typer.Option(\n100:         None,\n101:         \"--language\",\n102:         help=\"Programming language (python, java)\",\n103:     ),\n104:     entrypoint: Optional[str] = typer.Option(\n105:         None,\n106:         \"--entrypoint\",\n107:         help=\"Override entrypoint command\",\n108:     ),\n109:     port: Optional[int] = typer.Option(\n110:         None,\n111:         \"--port\",\n112:         help=\"Port to expose (default: 8080)\",\n113:     ),\n114:     build_mode: Optional[str] = typer.Option(\n115:         None,\n116:         \"--build-mode\",\n117:         help=\"Build strategy (local, cloud)\",\n118:     ),\n119:     description: Optional[str] = typer.Option(\n120:         None,\n121:         \"--description\",\n122:         help=\"Agent description\",\n123:     ),\n124:     output: Optional[str] = typer.Option(\n125:         None,\n126:         \"--output\",\n127:         help=\"Output path for packaged workspace\",\n128:     ),\n129:     verbose: bool = typer.Option(\n130:         False,\n131:         \"--verbose\",\n132:         help=\"Enable detailed logging\",\n133:     ),\n134:     version: bool = typer.Option(\n135:         None,\n136:         \"--version\",\n137:         help=\"Show version information\",\n138:         callback=version_callback,\n139:         is_eager=True,\n140:     ),\n141: ) -> None:\n142:     \"\"\"\n143:     Pack an agent workspace for deployment.\n144: \n145:     Validates the workspace structure, loads or creates agent metadata,\n146:     processes dependencies, optionally generates a Dockerfile, and\n147:     prepares the workspace for subsequent build and publish steps.\n148:     \"\"\"\n149:     try:\n150:         if verbose:\n151:             logging.basicConfig(level=logging.DEBUG)\n152: \n153:         with Progress(\n154:             SpinnerColumn(),\n155:             TextColumn(\"[progress.description]{task.description}\"),\n156:             console=console,\n157:         ) as progress:\n158:             task = progress.add_task(\"Packing agent workspace...\", total=None)\n159: \n160:             runtime = PackRuntime(verbose=verbose)\n161: \n162:             result = runtime.pack(\n163:                 workspace_path=workspace,\n164:                 agent_name=agent_name,\n165:                 language=language,\n166:                 entrypoint=entrypoint,\n167:                 port=port,\n168:                 build_mode=build_mode,\n169:                 description=description,\n170:                 output=output,\n171:                 verbose=verbose,\n172:             )\n173: \n174:             progress.update(task, completed=True)\n175: \n176:         console.print(\n177:             Panel(\n178:                 f\"[bold green]Agent packed successfully![/bold green]\\n\\n\"\n179:                 f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n180:                 f\"[bold]Workspace:[/bold] {result['workspace_path']}\\n\"\n181:                 f\"[bold]Output:[/bold] {result['output_path']}\\n\"\n182:                 f\"[bold]Metadata:[/bold] {result['metadata_file']}\\n\"\n183:                 f\"[bold]Dockerfile:[/bold] {'Generated' if result['dockerfile_generated'] else 'Existing'}\",\n184:                 title=\"Pack Complete\",\n185:                 style=\"green\",\n186:             )\n187:         )\n188: \n189:     except Exception as e:\n190:         _handle_error(e, \"pack\", verbose)\n191:         raise typer.Exit(code=1)\n192: \n193: \n194: @app.command()\n195: def build(\n196:     workspace: str = typer.Option(\n197:         \".\",\n198:         \"-f\",\n199:         \"--workspace\",\n200:         help=\"Path to the agent workspace directory\",\n201:     ),\n202:     proxy: Optional[str] = typer.Option(\n203:         None,\n204:         \"-p\",\n205:         \"--proxy\",\n206:         help=\"Custom proxy URL for dependency resolution\",\n207:     ),\n208:     cloud_provider: Optional[str] = typer.Option(\n209:         None,\n210:         \"--cloud-provider\",\n211:         help=\"Cloud provider name (e.g., huawei)\",\n212:     ),\n213:     output: Optional[str] = typer.Option(\n214:         None,\n215:         \"--output\",\n216:         help=\"Output path for build artifacts\",\n217:     ),\n218:     verbose: bool = typer.Option(\n219:         False,\n220:         \"--verbose\",\n221:         help=\"Enable detailed logging\",\n222:     ),\n223: ) -> None:\n224:     \"\"\"\n225:     Build a container image from a packed workspace.\n226: \n227:     Builds a Docker image from the packed workspace using local Docker\n228:     when build_mode is local, or cloud build when build_mode is cloud.\n229:     \"\"\"\n230:     try:\n231:         if verbose:\n232:             logging.basicConfig(level=logging.DEBUG)\n233: \n234:         with Progress(\n235:             SpinnerColumn(),\n236:             TextColumn(\"[progress.description]{task.description}\"),\n237:             console=console,\n238:         ) as progress:\n239:             task = progress.add_task(\"Building agent image...\", total=None)\n240: \n241:             runtime = BuildRuntime(verbose=verbose)\n242: \n243:             result = runtime.build(\n244:                 workspace_path=workspace,\n245:                 proxy=proxy,\n246:                 cloud_provider=cloud_provider,\n247:                 output=output,\n248:                 verbose=verbose,\n249:             )\n250: \n251:             progress.update(task, completed=True)\n252: \n253:         console.print(\n254:             Panel(\n255:                 f\"[bold green]Agent built successfully![/bold green]\\n\\n\"\n256:                 f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n257:                 f\"[bold]Image:[/bold] {result['image_name']}:{result['image_tag']}\\n\"\n258:                 f\"[bold]Image ID:[/bold] {result['image_id'][:12]}\\n\"\n259:                 f\"[bold]Version:[/bold] {result['version']}\",\n260:                 title=\"Build Complete\",\n261:                 style=\"green\",\n262:             )\n263:         )\n264: \n265:     except Exception as e:\n266:         _handle_error(e, \"build\", verbose)\n267:         raise typer.Exit(code=1)\n268: \n269: \n270: @app.command()\n271: def publish(\n272:     workspace: str = typer.Option(\n273:         \".\",\n274:         \"-f\",\n275:         \"--workspace\",\n276:         help=\"Path to the agent workspace directory\",\n277:     ),\n278:     version: Optional[str] = typer.Option(\n279:         None,\n280:         \"--version\",\n281:         help=\"Semantic version string (e.g., v1.0.0)\",\n282:     ),\n283:     image_url: Optional[str] = typer.Option(\n284:         None,\n285:         \"--image-url\",\n286:         help=\"Image repository URL\",\n287:     ),\n288:     image_username: Optional[str] = typer.Option(\n289:         None,\n290:         \"--image-username\",\n291:         help=\"Username for image repository\",\n292:     ),\n293:     image_password: Optional[str] = typer.Option(\n294:         None,\n295:         \"--image-password\",\n296:         help=\"Password for image repository\",\n297:     ),\n298:     description: Optional[str] = typer.Option(\n299:         None,\n300:         \"--description\",\n301:         help=\"Agent description\",\n302:     ),\n303:     region: Optional[str] = typer.Option(\n304:         None,\n305:         \"--region\",\n306:         help=\"Deployment region\",\n307:     ),\n308:     cloud_provider: Optional[str] = typer.Option(\n309:         None,\n310:         \"--cloud-provider\",\n311:         help=\"Cloud provider name\",\n312:     ),\n313:     provider: str = typer.Option(\n314:         \"agentcube\",\n315:         \"--provider\",\n316:         help=\"Target provider: 'agentcube' or 'k8s'\",\n317:     ),\n318:     node_port: Optional[int] = typer.Option(\n319:         None,\n320:         \"--node-port\",\n321:         help=\"NodePort (30000-32767)\",\n322:     ),\n323:     replicas: Optional[int] = typer.Option(\n324:         None,\n325:         \"--replicas\",\n326:         help=\"Number of replicas\",\n327:     ),\n328:     namespace: Optional[str] = typer.Option(\n329:         None,\n330:         \"--namespace\",\n331:         help=\"Deployment namespace\",\n332:     ),\n333:     verbose: bool = typer.Option(\n334:         False,\n335:         \"--verbose\",\n336:         help=\"Enable detailed logging\",\n337:     ),\n338: ) -> None:\n339:     \"\"\"\n340:     Publish/deploy an agent to the target provider.\n341: \n342:     Deploys the agent to AgentCube (AgentRuntime CR) or Kubernetes\n343:     (Deployment + NodePort Service).\n344:     \"\"\"\n345:     try:\n346:         if verbose:\n347:             logging.basicConfig(level=logging.DEBUG)\n348: \n349:         with Progress(\n350:             SpinnerColumn(),\n351:             TextColumn(\"[progress.description]{task.description}\"),\n352:             console=console,\n353:         ) as progress:\n354:             task = progress.add_task(\"Publishing agent...\", total=None)\n355: \n356:             runtime = PublishRuntime(verbose=verbose, provider=provider)\n357: \n358:             result = runtime.publish(\n359:                 workspace_path=workspace,\n360:                 version=version,\n361:                 image_url=image_url,\n362:                 image_username=image_username,\n363:                 image_password=image_password,\n364:                 description=description,\n365:                 region=region,\n366:                 cloud_provider=cloud_provider,\n367:                 provider=provider,\n368:                 node_port=node_port,\n369:                 replicas=replicas,\n370:                 namespace=namespace,\n371:                 verbose=verbose,\n372:             )\n373: \n374:             progress.update(task, completed=True)\n375: \n376:         console.print(\n377:             Panel(\n378:                 f\"[bold green]Agent published successfully![/bold green]\\n\\n\"\n379:                 f\"[bold]Agent Name:[/bold] {result['agent_name']}\\n\"\n380:                 f\"[bold]Provider:[/bold] {result['provider']}\\n\"\n381:                 f\"[bold]Endpoint:[/bold] {result['endpoint']}\\n\"\n382:                 f\"[bold]Status:[/bold] {result['status']}\",\n383:                 title=\"Publish Complete\",\n384:                 style=\"green\",\n385:             )\n386:         )\n387: \n388:     except Exception as e:\n389:         _handle_error(e, \"publish\", verbose)\n390:         raise typer.Exit(code=1)\n391: \n392: \n393: @app.command()\n394: def invoke(\n395:     workspace: str = typer.Option(\n396:         \".\",\n397:         \"-f\",\n398:         \"--workspace\",\n399:         help=\"Path to the agent workspace directory\",\n400:     ),\n401:     payload: str = typer.Option(\n402:         \"{}\",\n403:         \"--payload\",\n404:         help=\"JSON-formatted input passed to the agent\",\n405:     ),\n406:     header_list: Optional[List[str]] = typer.Option(\n407:         None,\n408:         \"--header\",\n409:         help=\"Custom HTTP headers (key:value format)\",\n410:     ),\n411:     provider: str = typer.Option(\n412:         \"agentcube\",\n413:         \"--provider\",\n414:         help=\"Target provider: 'agentcube' or 'k8s'\",\n415:     ),\n416:     verbose: bool = typer.Option(\n417:         False,\n418:         \"--verbose\",\n419:         help=\"Enable detailed logging\",\n420:     ),\n421: ) -> None:\n422:     \"\"\"\n423:     Invoke a published agent.\n424: \n425:     Posts JSON to the published agent endpoint and returns the response.\n426:     \"\"\"\n427:     try:\n428:         if verbose:\n429:             logging.basicConfig(level=logging.DEBUG)\n430: \n431:         with Progress(\n432:             SpinnerColumn(),\n433:             TextColumn(\"[progress.description]{task.description}\"),\n434:             console=console,\n435:         ) as progress:\n436:             task = progress.add_task(\"Invoking agent...\", total=None)\n437: \n438:             runtime = InvokeRuntime(verbose=verbose, provider=provider)\n439: \n440:             result = runtime.invoke(\n441:                 workspace_path=workspace,\n442:                 payload=payload,\n443:                 header_list=header_list,\n444:                 provider=provider,\n445:                 verbose=verbose,\n446:             )\n447: \n448:             progress.update(task, completed=True)\n449: \n450:         console.print(\n451:             Panel(\n452:                 f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n453:                 f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n454:                 f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n455:                 f\"[bold]Response:[/bold]\",\n456:                 title=\"Invoke Complete\",\n457:                 style=\"green\",\n458:             )\n459:         )\n460: \n461:         import json\n462: \n463:         console.print_json(json.dumps(result[\"response\"], indent=2))\n464: \n465:     except Exception as e:\n466:         _handle_error(e, \"invoke\", verbose)\n467:         raise typer.Exit(code=1)\n468: \n469: \n470: @app.command()\n471: def status(\n472:     workspace: str = typer.Option(\n473:         \".\",\n474:         \"-f\",\n475:         \"--workspace\",\n476:         help=\"Path to the agent workspace directory\",\n477:     ),\n478:     provider: str = typer.Option(\n479:         \"agentcube\",\n480:         \"--provider\",\n481:         help=\"Target provider: 'agentcube' or 'k8s'\",\n482:     ),\n483:     verbose: bool = typer.Option(\n484:         False,\n485:         \"--verbose\",\n486:         help=\"Enable detailed logging\",\n487:     ),\n488: ) -> None:\n489:     \"\"\"\n490:     Check the status of a published agent.\n491: \n492:     Loads workspace metadata and displays agent status in a table.\n493:     \"\"\"\n494:     try:\n495:         if verbose:\n496:             logging.basicConfig(level=logging.DEBUG)\n497: \n498:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n499: \n500:         result = runtime.get_status(\n501:             workspace_path=workspace,\n502:             provider=provider,\n503:         )\n504: \n505:         table = Table(title=f\"Agent Status: {result.get('agent_name', 'Unknown')}\")\n506: \n507:         table.add_column(\"Field\", style=\"cyan\")\n508:         table.add_column(\"Value\", style=\"green\")\n509: \n510:         table.add_row(\"Agent Name\", result.get(\"agent_name\", \"N/A\"))\n511:         table.add_row(\"Agent ID\", result.get(\"agent_id\", \"N/A\"))\n512:         table.add_row(\"Provider\", result.get(\"provider\", \"N/A\"))\n513:         table.add_row(\"Status\", result.get(\"status\", \"unknown\"))\n514:         table.add_row(\"Endpoint\", result.get(\"endpoint\", \"N/A\"))\n515:         table.add_row(\"Namespace\", result.get(\"namespace\", \"N/A\"))\n516: \n517:         if \"error\" in result:\n518:             table.add_row(\"Error\", result[\"error\"])\n519: \n520:         console.print(table)\n521: \n522:         if result.get(\"status\") in [\"not_published\", \"error\"]:\n523:             raise typer.Exit(code=1)\n524: \n525:     except Exception as e:\n526:         _handle_error(e, \"status\", verbose)\n527:         raise typer.Exit(code=1)\n528: \n529: \n530: @app.command()\n531: def version() -> None:\n532:     \"\"\"Show version information.\"\"\"\n533:     console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n534: \n535: \n536: if __name__ == \"__main__\":\n537:     app()\n\n(End of file - total 537 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube CLI - Main entry point for kubectl-agentcube.\"\"\"\n\nimport logging\nfrom typing import List, Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\nfrom rich.panel import Panel\nfrom rich.table import Table\nfrom rich import print as rprint\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.runtime.invoke_runtime import InvokeRuntime\nfrom agentcube.runtime.status_runtime import StatusRuntime\n\napp = typer.Typer(","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/cli/main.py","time":{"start":1775862948814,"end":1775862948826}}}}
{"type":"tool_use","timestamp":1775862948830,"sessionID":"ses_2865226aaffes9rvCi52yAPwmp","part":{"id":"prt_d79ae2011001EtlYMmI00aYO6D","messageID":"msg_d79ae1182001EwVtBzZZM6x0sI","sessionID":"ses_2865226aaffes9rvCi52yAPwmp","type":"tool","tool":"read","callID":"toolu_d66f8b6b7f2e4a9989fd8350","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Publish runtime for AgentCube - orchestrates the publish command workflow.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: from pathlib import Path\n7: from typing import Any, Dict, Optional\n8: \n9: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n10: from agentcube.services.k8s_provider import KubernetesProvider\n11: from agentcube.services.agentcube_provider import AgentCubeProvider\n12: \n13: \n14: class PublishRuntime:\n15:     \"\"\"\n16:     Core runtime for publishing agent runtimes.\n17: \n18:     Handles deployment to either AgentCube or Kubernetes provider.\n19:     \"\"\"\n20: \n21:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\"):\n22:         \"\"\"\n23:         Initialize the PublishRuntime.\n24: \n25:         Args:\n26:             verbose: Enable verbose logging\n27:             provider: Target provider (agentcube or k8s)\n28:         \"\"\"\n29:         self.verbose = verbose\n30:         self.provider = provider\n31:         self.logger = logging.getLogger(__name__)\n32:         if verbose:\n33:             logging.basicConfig(level=logging.DEBUG)\n34:         else:\n35:             logging.basicConfig(level=logging.INFO)\n36: \n37:         self.metadata_service = MetadataService()\n38: \n39:     def _prepare_image_for_publishing(\n40:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n41:     ) -> str:\n42:         \"\"\"\n43:         Prepare image URL for publishing.\n44: \n45:         Args:\n46:             workspace_path: Path to workspace\n47:             metadata: Agent metadata\n48:             options: Publish options\n49: \n50:         Returns:\n51:             Image URL to use\n52:         \"\"\"\n53:         if options.get(\"image_url\"):\n54:             return options[\"image_url\"]\n55: \n56:         image_name = metadata.agent_name\n57:         tag = metadata.version or \"latest\"\n58: \n59:         registry_url = options.get(\"registry_url\") or metadata.registry_url or \"docker.io\"\n60:         registry_username = options.get(\"registry_username\") or metadata.registry_username\n61: \n62:         if registry_username:\n63:             image_url = f\"{registry_url}/{image_name}:{tag}\"\n64:         else:\n65:             image_url = f\"{image_name}:{tag}\"\n66: \n67:         self.logger.debug(f\"Prepared image URL: {image_url}\")\n68:         return image_url\n69: \n70:     def _publish_cr_to_k8s(\n71:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n72:     ) -> Dict[str, Any]:\n73:         \"\"\"\n74:         Publish using AgentRuntime CR to Kubernetes.\n75: \n76:         Args:\n77:             workspace_path: Path to workspace\n78:             metadata: Agent metadata\n79:             **options: Additional options\n80: \n81:         Returns:\n82:             Dictionary with publish result\n83:         \"\"\"\n84:         agentcube_provider = AgentCubeProvider(\n85:             namespace=options.get(\"namespace\", \"default\"),\n86:             verbose=self.verbose,\n87:         )\n88: \n89:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n90: \n91:         self.logger.debug(f\"Deploying agent runtime: {metadata.agent_name}\")\n92: \n93:         result = agentcube_provider.deploy_agent_runtime(\n94:             agent_name=metadata.agent_name,\n95:             image_url=image_url,\n96:             port=metadata.port,\n97:             entrypoint=metadata.entrypoint,\n98:             env_vars=options.get(\"env_vars\"),\n99:             workload_manager_url=metadata.workload_manager_url,\n100:             router_url=metadata.router_url,\n101:             readiness_probe_path=metadata.readiness_probe_path,\n102:             readiness_probe_port=metadata.readiness_probe_port,\n103:         )\n104: \n105:         return {\n106:             \"agent_name\": metadata.agent_name,\n107:             \"provider\": \"agentcube\",\n108:             \"agent_id\": result.get(\"name\"),\n109:             \"endpoint\": result.get(\"endpoint\"),\n110:             \"status\": \"deployed\",\n111:         }\n112: \n113:     def _publish_k8s(\n114:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n115:     ) -> Dict[str, Any]:\n116:         \"\"\"\n117:         Publish using native Kubernetes Deployment + Service.\n118: \n119:         Args:\n120:             workspace_path: Path to workspace\n121:             metadata: Agent metadata\n122:             **options: Additional options\n123: \n124:         Returns:\n125:             Dictionary with publish result\n126:         \"\"\"\n127:         k8s_provider = KubernetesProvider(\n128:             namespace=options.get(\"namespace\", \"default\"),\n129:             verbose=self.verbose,\n130:         )\n131: \n132:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n133: \n134:         replicas = options.get(\"replicas\", 1)\n135:         node_port = options.get(\"node_port\")\n136: \n137:         if node_port and (node_port < 30000 or node_port > 32767):\n138:             raise ValueError(\"NodePort must be between 30000 and 32767\")\n139: \n140:         self.logger.debug(f\"Deploying to Kubernetes: {metadata.agent_name}\")\n141: \n142:         result = k8s_provider.deploy_agent(\n143:             agent_name=metadata.agent_name,\n144:             image_url=image_url,\n145:             port=metadata.port,\n146:             entrypoint=metadata.entrypoint,\n147:             replicas=replicas,\n148:             node_port=node_port,\n149:             env_vars=options.get(\"env_vars\"),\n150:         )\n151: \n152:         return {\n153:             \"agent_name\": metadata.agent_name,\n154:             \"provider\": \"k8s\",\n155:             \"deployment\": result.get(\"name\"),\n156:             \"service\": result.get(\"service\"),\n157:             \"endpoint\": result.get(\"endpoint\"),\n158:             \"status\": \"deployed\",\n159:         }\n160: \n161:     def publish(\n162:         self,\n163:         workspace_path: str,\n164:         version: Optional[str] = None,\n165:         image_url: Optional[str] = None,\n166:         image_username: Optional[str] = None,\n167:         image_password: Optional[str] = None,\n168:         description: Optional[str] = None,\n169:         region: Optional[str] = None,\n170:         cloud_provider: Optional[str] = None,\n171:         provider: str = \"agentcube\",\n172:         node_port: Optional[int] = None,\n173:         replicas: Optional[int] = None,\n174:         namespace: Optional[str] = None,\n175:         verbose: bool = False,\n176:     ) -> dict:\n177:         \"\"\"\n178:         Publish an agent to the target provider.\n179: \n180:         Args:\n181:             workspace_path: Path to agent workspace\n182:             version: Semantic version string\n183:             image_url: Image repository URL\n184:             image_username: Username for image repository\n185:             image_password: Password for image repository\n186:             description: Agent description\n187:             region: Deployment region\n188:             cloud_provider: Cloud provider name\n189:             provider: Target provider (agentcube or k8s)\n190:             node_port: NodePort (30000-32767)\n191:             replicas: Number of replicas\n192:             namespace: Deployment namespace\n193:             verbose: Enable verbose logging\n194: \n195:         Returns:\n196:             Dictionary with publish result\n197: \n198:         Raises:\n199:             ValueError: If publish fails\n200:         \"\"\"\n201:         workspace = Path(workspace_path).resolve()\n202: \n203:         metadata = self.metadata_service.load_metadata(workspace)\n204: \n205:         if version:\n206:             metadata.version = version\n207:         if description:\n208:             metadata.description = description\n209:         if region:\n210:             metadata.region = region\n211:         if image_url:\n212:             metadata.image = metadata.image or {}\n213:             metadata.image[\"url\"] = image_url\n214: \n215:         options = {\n216:             \"image_url\": image_url,\n217:             \"image_username\": image_username,\n218:             \"image_password\": image_password,\n219:             \"region\": region,\n220:             \"cloud_provider\": cloud_provider,\n221:             \"node_port\": node_port,\n222:             \"replicas\": replicas,\n223:             \"namespace\": namespace,\n224:             \"registry_url\": metadata.registry_url,\n225:             \"registry_username\": metadata.registry_username,\n226:             \"registry_password\": metadata.registry_password,\n227:         }\n228: \n229:         try:\n230:             if provider == \"agentcube\":\n231:                 result = self._publish_cr_to_k8s(workspace, metadata, **options)\n232:             else:\n233:                 result = self._publish_k8s(workspace, metadata, **options)\n234: \n235:             metadata.agent_id = result.get(\"agent_id\") or result.get(\"deployment\")\n236:             metadata.agent_endpoint = result.get(\"endpoint\")\n237: \n238:             if result.get(\"status\") == \"deployed\":\n239:                 metadata.k8s_deployment = {\n240:                     \"name\": result.get(\"deployment\") or result.get(\"agent_id\"),\n241:                     \"provider\": provider,\n242:                     \"namespace\": namespace or \"default\",\n243:                 }\n244: \n245:             self.metadata_service.save_metadata(workspace, metadata)\n246: \n247:             return {\n248:                 \"agent_name\": metadata.agent_name,\n249:                 \"provider\": provider,\n250:                 \"endpoint\": result.get(\"endpoint\"),\n251:                 \"status\": result.get(\"status\"),\n252:             }\n253: \n254:         except Exception as e:\n255:             raise ValueError(f\"Publish failed: {e}\")\n\n(End of file - total 255 lines)\n</content>","metadata":{"preview":"\"\"\"Publish runtime for AgentCube - orchestrates the publish command workflow.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nclass PublishRuntime:\n    \"\"\"\n    Core runtime for publishing agent runtimes.\n\n    Handles deployment to either AgentCube or Kubernetes provider.\n    \"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py","time":{"start":1775862948817,"end":1775862948828}}}}
