tion.md#reportCallIssue"}},{"range":{"start":{"line":373,"character":58},"end":{"line":373,"character":60}},"message":"Expected 2 positional arguments","severity":1,"code":"reportCallIssue","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportCallIssue"}}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/agentcube_provider.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_cli.py":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py\n@@ -232,8 +232,9 @@\n     \"cloud_provider\": cloud_provider,\n     \"node_port\": node_port,\n     \"replicas\": replicas,\n     \"namespace\": namespace,\n+    \"timeout\": timeout,\n     \"registry_url\": metadata.registry_url,\n     \"registry_username\": metadata.registry_username,\n     \"registry_password\": metadata.registry_password,\n }\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py","before":"\"\"\"Publish runtime for AgentCube - orchestrates the publish command workflow.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nclass PublishRuntime:\n    \"\"\"\n    Core runtime for publishing agent runtimes.\n\n    Handles deployment to either AgentCube or Kubernetes provider.\n    \"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\"):\n        \"\"\"\n        Initialize the PublishRuntime.\n\n        Args:\n            verbose: Enable verbose logging\n            provider: Target provider (agentcube or k8s)\n        \"\"\"\n        self.verbose = verbose\n        self.provider = provider\n        self.logger = logging.getLogger(__name__)\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        else:\n            logging.basicConfig(level=logging.INFO)\n\n        self.metadata_service = MetadataService()\n\n    def _prepare_image_for_publishing(\n        self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n    ) -> str:\n        \"\"\"\n        Prepare image URL for publishing.\n\n        Args:\n            workspace_path: Path to workspace\n            metadata: Agent metadata\n            options: Publish options\n\n        Returns:\n            Image URL to use\n        \"\"\"\n        if options.get(\"image_url\"):\n            return options[\"image_url\"]\n\n        image_name = metadata.agent_name\n        tag = metadata.version or \"latest\"\n\n        registry_url = options.get(\"registry_url\") or metadata.registry_url or \"docker.io\"\n        registry_username = options.get(\"registry_username\") or metadata.registry_username\n\n        if registry_username:\n            image_url = f\"{registry_url}/{image_name}:{tag}\"\n        else:\n            image_url = f\"{image_name}:{tag}\"\n\n        self.logger.debug(f\"Prepared image URL: {image_url}\")\n        return image_url\n\n    def _publish_cr_to_k8s(\n        self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n    ) -> Dict[str, Any]:\n        \"\"\"\n        Publish using AgentRuntime CR to Kubernetes.\n\n        Args:\n            workspace_path: Path to workspace\n            metadata: Agent metadata\n            **options: Additional options\n\n        Returns:\n            Dictionary with publish result\n        \"\"\"\n        agentcube_provider = AgentCubeProvider(\n            namespace=options.get(\"namespace\", \"default\"),\n            verbose=self.verbose,\n        )\n\n        image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n\n        self.logger.debug(f\"Deploying agent runtime: {metadata.agent_name}\")\n\n        result = agentcube_provider.deploy_agent_runtime(\n            agent_name=metadata.agent_name,\n            image_url=image_url,\n            port=metadata.port,\n            entrypoint=metadata.entrypoint,\n            env_vars=options.get(\"env_vars\"),\n            workload_manager_url=metadata.workload_manager_url,\n            router_url=metadata.router_url,\n            readiness_probe_path=metadata.readiness_probe_path,\n            readiness_probe_port=metadata.readiness_probe_port,\n        )\n\n        return {\n            \"agent_name\": metadata.agent_name,\n            \"provider\": \"agentcube\",\n            \"agent_id\": result.get(\"name\"),\n            \"endpoint\": result.get(\"endpoint\"),\n            \"status\": \"deployed\",\n        }\n\n    def _publish_k8s(\n        self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n    ) -> Dict[str, Any]:\n        \"\"\"\n        Publish using native Kubernetes Deployment + Service.\n\n        Args:\n            workspace_path: Path to workspace\n            metadata: Agent metadata\n            **options: Additional options\n\n        Returns:\n            Dictionary with publish result\n        \"\"\"\n        k8s_provider = KubernetesProvider(\n            namespace=options.get(\"namespace\", \"default\"),\n            verbose=self.verbose,\n        )\n\n        image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n\n        replicas = options.get(\"replicas\", 1)\n        node_port = options.get(\"node_port\")\n\n        if node_port and (node_port < 30000 or node_port > 32767):\n            raise ValueError(\"NodePort must be between 30000 and 32767\")\n\n        self.logger.debug(f\"Deploying to Kubernetes: {metadata.agent_name}\")\n\n        result = k8s_provider.deploy_agent(\n            agent_name=metadata.agent_name,\n            image_url=image_url,\n            port=metadata.port,\n            entrypoint=metadata.entrypoint,\n            replicas=replicas,\n            node_port=node_port,\n            env_vars=options.get(\"env_vars\"),\n        )\n\n        try:\n            k8s_provider.wait_for_deployment_ready(\n                name=metadata.agent_name,\n                timeout=options.get(\"timeout\", 120),\n            )\n        except Exception as e:\n            metadata.k8s_deployment = metadata.k8s_deployment or {}\n            metadata.k8s_deployment[\"error\"] = str(e)\n            raise RuntimeError(f\"Deployment not ready: {e}\")\n\n        return {\n            \"agent_name\": metadata.agent_name,\n            \"provider\": \"k8s\",\n            \"deployment\": result.get(\"name\"),\n            \"service\": result.get(\"service\"),\n            \"endpoint\": result.get(\"endpoint\"),\n            \"status\": \"deployed\",\n        }\n\n    def publish(\n        self,\n        workspace_path: str,\n        version: Optional[str] = None,\n        image_url: Optional[str] = None,\n        image_username: Optional[str] = None,\n        image_password: Optional[str] = None,\n        description: Optional[str] = None,\n        region: Optional[str] = None,\n        cloud_provider: Optional[str] = None,\n        provider: str = \"agentcube\",\n        node_port: Optional[int] = None,\n        replicas: Optional[int] = None,\n        namespace: Optional[str] = None,\n        timeout: int = 120,\n        verbose: bool = False,\n    ) -> dict:\n        \"\"\"\n        Publish an agent to the target provider.\n\n        Args:\n            workspace_path: Path to agent workspace\n            version: Semantic version string\n            image_url: Image repository URL\n            image_username: Username for image repository\n            image_password: Password for image repository\n            description: Agent description\n            region: Deployment region\n            cloud_provider: Cloud provider name\n            provider: Target provider (agentcube or k8s)\n            node_port: NodePort (30000-32767)\n            replicas: Number of replicas\n            namespace: Deployment namespace\n            timeout: Timeout for deployment readiness in seconds\n            verbose: Enable verbose logging\n\n        Returns:\n            Dictionary with publish result\n\n        Raises:\n            ValueError: If publish fails\n        \"\"\"\n        workspace = Path(workspace_path).resolve()\n\n        metadata = self.metadata_service.load_metadata(workspace)\n\n        if version:\n            metadata.version = version\n        if description:\n            metadata.description = description\n        if region:\n            metadata.region = region\n        if image_url:\n            metadata.image = metadata.image or {}\n            metadata.image[\"url\"] = image_url\n\n        options = {\n            \"image_url\": image_url,\n            \"image_username\": image_username,\n            \"image_password\": image_password,\n            \"region\": region,\n            \"cloud_provider\": cloud_provider,\n            \"node_port\": node_port,\n            \"replicas\": replicas,\n            \"namespace\": namespace,\n            \"registry_url\": metadata.registry_url,\n            \"registry_username\": metadata.registry_username,\n            \"registry_password\": metadata.registry_password,\n        }\n\n        try:\n            if provider == \"agentcube\":\n                if not metadata.router_url or not metadata.workload_manager_url:\n                    raise ValueError(\n                        \"AgentCube provider requires both 'router_url' and 'workload_manager_url' in agent_metadata.yaml\"\n                    )\n                result = self._publish_cr_to_k8s(workspace, metadata, **options)\n            else:\n                result = self._publish_k8s(workspace, metadata, **options)\n\n            metadata.agent_id = result.get(\"agent_id\") or result.get(\"deployment\")\n            metadata.agent_endpoint = result.get(\"endpoint\")\n\n            if result.get(\"status\") == \"deployed\":\n                metadata.k8s_deployment = {\n                    \"name\": result.get(\"deployment\") or result.get(\"agent_id\"),\n                    \"provider\": provider,\n                    \"namespace\": namespace or \"default\",\n                }\n\n            self.metadata_service.save_metadata(workspace, metadata)\n\n            return {\n                \"agent_name\": metadata.agent_name,\n                \"provider\": provider,\n                \"endpoint\": result.get(\"endpoint\"),\n                \"status\": result.get(\"status\"),\n            }\n\n        except Exception as e:\n            raise ValueError(f\"Publish failed: {e}\")\n","after":"\"\"\"Publish runtime for AgentCube - orchestrates the publish command workflow.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nclass PublishRuntime:\n    \"\"\"\n    Core runtime for publishing agent runtimes.\n\n    Handles deployment to either AgentCube or Kubernetes provider.\n    \"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\"):\n        \"\"\"\n        Initialize the PublishRuntime.\n\n        Args:\n            verbose: Enable verbose logging\n            provider: Target provider (agentcube or k8s)\n        \"\"\"\n        self.verbose = verbose\n        self.provider = provider\n        self.logger = logging.getLogger(__name__)\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        else:\n            logging.basicConfig(level=logging.INFO)\n\n        self.metadata_service = MetadataService()\n\n    def _prepare_image_for_publishing(\n        self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n    ) -> str:\n        \"\"\"\n        Prepare image URL for publishing.\n\n        Args:\n            workspace_path: Path to workspace\n            metadata: Agent metadata\n            options: Publish options\n\n        Returns:\n            Image URL to use\n        \"\"\"\n        if options.get(\"image_url\"):\n            return options[\"image_url\"]\n\n        image_name = metadata.agent_name\n        tag = metadata.version or \"latest\"\n\n        registry_url = options.get(\"registry_url\") or metadata.registry_url or \"docker.io\"\n        registry_username = options.get(\"registry_username\") or metadata.registry_username\n\n        if registry_username:\n            image_url = f\"{registry_url}/{image_name}:{tag}\"\n        else:\n            image_url = f\"{image_name}:{tag}\"\n\n        self.logger.debug(f\"Prepared image URL: {image_url}\")\n        return image_url\n\n    def _publish_cr_to_k8s(\n        self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n    ) -> Dict[str, Any]:\n        \"\"\"\n        Publish using AgentRuntime CR to Kubernetes.\n\n        Args:\n            workspace_path: Path to workspace\n            metadata: Agent metadata\n            **options: Additional options\n\n        Returns:\n            Dictionary with publish result\n        \"\"\"\n        agentcube_provider = AgentCubeProvider(\n            namespace=options.get(\"namespace\", \"default\"),\n            verbose=self.verbose,\n        )\n\n        image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n\n        self.logger.debug(f\"Deploying agent runtime: {metadata.agent_name}\")\n\n        result = agentcube_provider.deploy_agent_runtime(\n            agent_name=metadata.agent_name,\n            image_url=image_url,\n            port=metadata.port,\n            entrypoint=metadata.entrypoint,\n            env_vars=options.get(\"env_vars\"),\n            workload_manager_url=metadata.workload_manager_url,\n            router_url=metadata.router_url,\n            readiness_probe_path=metadata.readiness_probe_path,\n            readiness_probe_port=metadata.readiness_probe_port,\n        )\n\n        return {\n            \"agent_name\": metadata.agent_name,\n            \"provider\": \"agentcube\",\n            \"agent_id\": result.get(\"name\"),\n            \"endpoint\": result.get(\"endpoint\"),\n            \"status\": \"deployed\",\n        }\n\n    def _publish_k8s(\n        self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n    ) -> Dict[str, Any]:\n        \"\"\"\n        Publish using native Kubernetes Deployment + Service.\n\n        Args:\n            workspace_path: Path to workspace\n            metadata: Agent metadata\n            **options: Additional options\n\n        Returns:\n            Dictionary with publish result\n        \"\"\"\n        k8s_provider = KubernetesProvider(\n            namespace=options.get(\"namespace\", \"default\"),\n            verbose=self.verbose,\n        )\n\n        image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n\n        replicas = options.get(\"replicas\", 1)\n        node_port = options.get(\"node_port\")\n\n        if node_port and (node_port < 30000 or node_port > 32767):\n            raise ValueError(\"NodePort must be between 30000 and 32767\")\n\n        self.logger.debug(f\"Deploying to Kubernetes: {metadata.agent_name}\")\n\n        result = k8s_provider.deploy_agent(\n            agent_name=metadata.agent_name,\n            image_url=image_url,\n            port=metadata.port,\n            entrypoint=metadata.entrypoint,\n            replicas=replicas,\n            node_port=node_port,\n            env_vars=options.get(\"env_vars\"),\n        )\n\n        try:\n            k8s_provider.wait_for_deployment_ready(\n                name=metadata.agent_name,\n                timeout=options.get(\"timeout\", 120),\n            )\n        except Exception as e:\n            metadata.k8s_deployment = metadata.k8s_deployment or {}\n            metadata.k8s_deployment[\"error\"] = str(e)\n            raise RuntimeError(f\"Deployment not ready: {e}\")\n\n        return {\n            \"agent_name\": metadata.agent_name,\n            \"provider\": \"k8s\",\n            \"deployment\": result.get(\"name\"),\n            \"service\": result.get(\"service\"),\n            \"endpoint\": result.get(\"endpoint\"),\n            \"status\": \"deployed\",\n        }\n\n    def publish(\n        self,\n        workspace_path: str,\n        version: Optional[str] = None,\n        image_url: Optional[str] = None,\n        image_username: Optional[str] = None,\n        image_password: Optional[str] = None,\n        description: Optional[str] = None,\n        region: Optional[str] = None,\n        cloud_provider: Optional[str] = None,\n        provider: str = \"agentcube\",\n        node_port: Optional[int] = None,\n        replicas: Optional[int] = None,\n        namespace: Optional[str] = None,\n        timeout: int = 120,\n        verbose: bool = False,\n    ) -> dict:\n        \"\"\"\n        Publish an agent to the target provider.\n\n        Args:\n            workspace_path: Path to agent workspace\n            version: Semantic version string\n            image_url: Image repository URL\n            image_username: Username for image repository\n            image_password: Password for image repository\n            description: Agent description\n            region: Deployment region\n            cloud_provider: Cloud provider name\n            provider: Target provider (agentcube or k8s)\n            node_port: NodePort (30000-32767)\n            replicas: Number of replicas\n            namespace: Deployment namespace\n            timeout: Timeout for deployment readiness in seconds\n            verbose: Enable verbose logging\n\n        Returns:\n            Dictionary with publish result\n\n        Raises:\n            ValueError: If publish fails\n        \"\"\"\n        workspace = Path(workspace_path).resolve()\n\n        metadata = self.metadata_service.load_metadata(workspace)\n\n        if version:\n            metadata.version = version\n        if description:\n            metadata.description = description\n        if region:\n            metadata.region = region\n        if image_url:\n            metadata.image = metadata.image or {}\n            metadata.image[\"url\"] = image_url\n\n        options = {\n            \"image_url\": image_url,\n            \"image_username\": image_username,\n            \"image_password\": image_password,\n            \"region\": region,\n            \"cloud_provider\": cloud_provider,\n            \"node_port\": node_port,\n            \"replicas\": replicas,\n            \"namespace\": namespace,\n            \"timeout\": timeout,\n            \"registry_url\": metadata.registry_url,\n            \"registry_username\": metadata.registry_username,\n            \"registry_password\": metadata.registry_password,\n        }\n\n        try:\n            if provider == \"agentcube\":\n                if not metadata.router_url or not metadata.workload_manager_url:\n                    raise ValueError(\n                        \"AgentCube provider requires both 'router_url' and 'workload_manager_url' in agent_metadata.yaml\"\n                    )\n                result = self._publish_cr_to_k8s(workspace, metadata, **options)\n            else:\n                result = self._publish_k8s(workspace, metadata, **options)\n\n            metadata.agent_id = result.get(\"agent_id\") or result.get(\"deployment\")\n            metadata.agent_endpoint = result.get(\"endpoint\")\n\n            if result.get(\"status\") == \"deployed\":\n                metadata.k8s_deployment = {\n                    \"name\": result.get(\"deployment\") or result.get(\"agent_id\"),\n                    \"provider\": provider,\n                    \"namespace\": namespace or \"default\",\n                }\n\n            self.metadata_service.save_metadata(workspace, metadata)\n\n            return {\n                \"agent_name\": metadata.agent_name,\n                \"provider\": provider,\n                \"endpoint\": result.get(\"endpoint\"),\n                \"status\": result.get(\"status\"),\n            }\n\n        except Exception as e:\n            raise ValueError(f\"Publish failed: {e}\")\n","additions":1,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py","time":{"start":1775863159619,"end":1775863160204}}}}
