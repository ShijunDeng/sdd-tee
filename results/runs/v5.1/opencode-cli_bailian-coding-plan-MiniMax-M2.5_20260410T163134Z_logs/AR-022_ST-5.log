e == 0\n40:             assert \"test-agent\" in result.stdout\n41:             assert \"packed successfully\" in result.stdout.lower()\n42: \n43:     def test_pack_with_missing_workspace(self):\n44:         \"\"\"Test pack with missing workspace.\"\"\"\n45:         result = runner.invoke(app, [\"pack\", \"-f\", \"/nonexistent/path\"])\n46: \n47:         assert result.exit_code == 1\n48:         assert \"Error\" in result.stdout\n49: \n50:     def test_pack_with_invalid_language(self):\n51:         \"\"\"Test pack with invalid language.\"\"\"\n52:         with tempfile.TemporaryDirectory() as tmpdir:\n53:             workspace = Path(tmpdir)\n54:             (workspace / \"main.py\").write_text(\"print('hello')\")\n55: \n56:             result = runner.invoke(app, [\"pack\", \"-f\", str(workspace), \"--language\", \"invalid\"])\n57: \n58:             assert result.exit_code == 1\n59: \n60: \n61: class TestBuildCommand:\n62:     \"\"\"Tests for the build command.\"\"\"\n63: \n64:     def test_build_help(self):\n65:         \"\"\"Test build --help displays options.\"\"\"\n66:         result = runner.invoke(app, [\"build\", \"--help\"])\n67: \n68:         assert result.exit_code == 0\n69:         assert \"--workspace\" in result.stdout\n70:         assert \"--proxy\" in result.stdout\n71:         assert \"--cloud-provider\" in result.stdout\n72: \n73: \n74: class TestPublishCommand:\n75:     \"\"\"Tests for the publish command.\"\"\"\n76: \n77:     def test_publish_help(self):\n78:         \"\"\"Test publish --help displays options.\"\"\"\n79:         result = runner.invoke(app, [\"publish\", \"--help\"])\n80: \n81:         assert result.exit_code == 0\n82:         assert \"--workspace\" in result.stdout\n83:         assert \"--provider\" in result.stdout\n84:         assert \"--version\" in result.stdout\n85:         assert \"--namespace\" in result.stdout\n86: \n87: \n88: class TestInvokeCommand:\n89:     \"\"\"Tests for the invoke command.\"\"\"\n90: \n91:     def test_invoke_help(self):\n92:         \"\"\"Test invoke --help displays options.\"\"\"\n93:         result = runner.invoke(app, [\"invoke\", \"--help\"])\n94: \n95:         assert result.exit_code == 0\n96:         assert \"--workspace\" in result.stdout\n97:         assert \"--payload\" in result.stdout\n98:         assert \"--header\" in result.stdout\n99:         assert \"--provider\" in result.stdout\n100: \n101: \n102: class TestStatusCommand:\n103:     \"\"\"Tests for the status command.\"\"\"\n104: \n105:     def test_status_help(self):\n106:         \"\"\"Test status --help displays options.\"\"\"\n107:         result = runner.invoke(app, [\"status\", \"--help\"])\n108: \n109:         assert result.exit_code == 0\n110:         assert \"--workspace\" in result.stdout\n111:         assert \"--provider\" in result.stdout\n112: \n113: \n114: class TestVersionCommand:\n115:     \"\"\"Tests for the version command.\"\"\"\n116: \n117:     def test_version_command(self):\n118:         \"\"\"Test version command displays version.\"\"\"\n119:         result = runner.invoke(app, [\"version\"])\n120: \n121:         assert result.exit_code == 0\n122:         assert \"0.1.0\" in result.stdout\n123: \n124:     def test_version_option(self):\n125:         \"\"\"Test --version option.\"\"\"\n126:         result = runner.invoke(app, [\"--version\"])\n127: \n128:         assert result.exit_code == 0\n129:         assert \"0.1.0\" in result.stdout\n\n(End of file - total 129 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for CLI commands.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import patch\n\nimport pytest\nfrom typer.testing import CliRunner\n\nfrom agentcube.cli.main import app\n\nrunner = CliRunner()\n\n\nclass TestPackCommand:\n    \"\"\"Tests for the pack command.\"\"\"\n\n    def test_pack_help(self):\n        \"\"\"Test pack --help displays options.\"\"\"\n        result = runner.invoke(app, [\"pack\", \"--help\"])","truncated":