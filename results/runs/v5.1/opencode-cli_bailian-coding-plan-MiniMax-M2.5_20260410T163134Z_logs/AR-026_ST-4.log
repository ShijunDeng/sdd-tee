{"type":"tool_use","timestamp":1775866893612,"sessionID":"ses_286162f0cffeY8t2DF73EoXM9P","part":{"id":"prt_d79ea5075001XUpZ2xLOmNBbor","messageID":"msg_d79ea4274001R65bhhcp6s6I5s","sessionID":"ses_286162f0cffeY8t2DF73EoXM9P","type":"tool","tool":"read","callID":"toolu_68aec084f4b94ee5b6532c5a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Publish runtime for AgentCube - orchestrates the publish command workflow.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: from pathlib import Path\n7: from typing import Any, Dict, Optional\n8: \n9: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n10: from agentcube.services.k8s_provider import KubernetesProvider\n11: from agentcube.services.agentcube_provider import AgentCubeProvider\n12: from agentcube.services.docker_service import DockerService\n13: \n14: \n15: class PublishRuntime:\n16:     \"\"\"\n17:     Core runtime for publishing agent runtimes.\n18: \n19:     Handles deployment to either AgentCube or Kubernetes provider.\n20:     \"\"\"\n21: \n22:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\"):\n23:         \"\"\"\n24:         Initialize the PublishRuntime.\n25: \n26:         Args:\n27:             verbose: Enable verbose logging\n28:             provider: Target provider (agentcube or k8s)\n29:         \"\"\"\n30:         self.verbose = verbose\n31:         self.provider = provider\n32:         self.logger = logging.getLogger(__name__)\n33:         if verbose:\n34:             logging.basicConfig(level=logging.DEBUG)\n35:         else:\n36:             logging.basicConfig(level=logging.INFO)\n37: \n38:         self.metadata_service = MetadataService()\n39:         self.docker_service = DockerService(verbose=verbose)\n40: \n41:     def _prepare_image_for_publishing(\n42:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n43:     ) -> str:\n44:         \"\"\"\n45:         Prepare image URL for publishing.\n46: \n47:         Args:\n48:             workspace_path: Path to workspace\n49:             metadata: Agent metadata\n50:             options: Publish options\n51: \n52:         Returns:\n53:             Image URL to use\n54:         \"\"\"\n55:         if options.get(\"image_url\"):\n56:             return options[\"image_url\"]\n57: \n58:         image_name = metadata.agent_name\n59:         tag = metadata.version or \"latest\"\n60: \n61:         registry_url = options.get(\"registry_url\") or metadata.registry_url or \"docker.io\"\n62:         registry_username = options.get(\"registry_username\") or metadata.registry_username\n63: \n64:         if registry_username:\n65:             image_url = f\"{registry_url}/{image_name}:{tag}\"\n66:         else:\n67:             image_url = f\"{image_name}:{tag}\"\n68: \n69:         self.logger.debug(f\"Prepared image URL: {image_url}\")\n70:         return image_url\n71: \n72:     def _prepare_local_image(\n73:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n74:     ) -> str:\n75:         \"\"\"\n76:         Prepare and push local image to registry.\n77: \n78:         Args:\n79:             workspace_path: Path to workspace\n80:             metadata: Agent metadata\n81:             options: Publish options\n82: \n83:         Returns:\n84:             Pushed image URL\n85: \n86:         Raises:\n87:             ValueError: If image push fails\n88:         \"\"\"\n89:         if not metadata.image:\n90:             raise ValueError(\"No image information available. Run 'build' first.\")\n91: \n92:         image_name = metadata.image.get(\"name\")\n93:         image_tag = metadata.image.get(\"tag\", \"latest\")\n94:         if not image_name:\n95:             raise ValueError(\"Image name not found in metadata\")\n96: \n97:         local_image = f\"{image_name}:{image_tag}\"\n98: \n99:         registry_url = options.get(\"registry_url\") or metadata.registry_url\n100:         username = options.get(\"registry_username\") or metadata.registry_username\n101:         password = options.get(\"registry_password\") or metadata.registry_password\n102: \n103:         if not registry_url:\n104:             self.logger.debug(\"No registry URL provided, returning local image\")\n105:             return local_image\n106: \n107:         self.logger.debug(f\"Preparing local image for registry: {registry_url}\")\n108: \n109:         push_result = self.docker_service.push_image(\n110:             image_name=local_image,\n111:             registry_url=registry_url,\n112:             username=username,\n113:             password=password,\n114:         )\n115: \n116:         self.logger.debug(f\"Image pushed: {push_result}\")\n117:         return push_result.get(\"pushed_image\", local_image)\n118: \n119:     def _publish_cr_to_k8s(\n120:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n121:     ) -> Dict[str, Any]:\n122:         \"\"\"\n123:         Publish using AgentRuntime CR to Kubernetes.\n124: \n125:         Args:\n126:             workspace_path: Path to workspace\n127:             metadata: Agent metadata\n128:             **options: Additional options\n129: \n130:         Returns:\n131:             Dictionary with publish result\n132:         \"\"\"\n133:         agentcube_provider = AgentCubeProvider(\n134:             namespace=options.get(\"namespace\", \"default\"),\n135:             verbose=self.verbose,\n136:         )\n137: \n138:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n139: \n140:         self.logger.debug(f\"Deploying agent runtime: {metadata.agent_name}\")\n141: \n142:         result = agentcube_provider.deploy_agent_runtime(\n143:             agent_name=metadata.agent_name,\n144:             image_url=image_url,\n145:             port=metadata.port,\n146:             entrypoint=metadata.entrypoint,\n147:             env_vars=options.get(\"env_vars\"),\n148:             workload_manager_url=metadata.workload_manager_url,\n149:             router_url=metadata.router_url,\n150:             readiness_probe_path=metadata.readiness_probe_path,\n151:             readiness_probe_port=metadata.readiness_probe_port,\n152:         )\n153: \n154:         return {\n155:             \"agent_name\": metadata.agent_name,\n156:             \"provider\": \"agentcube\",\n157:             \"agent_id\": result.get(\"name\"),\n158:             \"endpoint\": result.get(\"endpoint\"),\n159:             \"status\": \"deployed\",\n160:         }\n161: \n162:     def _publish_k8s(\n163:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n164:     ) -> Dict[str, Any]:\n165:         \"\"\"\n166:         Publish using native Kubernetes Deployment + Service.\n167: \n168:         Args:\n169:             workspace_path: Path to workspace\n170:             metadata: Agent metadata\n171:             **options: Additional options\n172: \n173:         Returns:\n174:             Dictionary with publish result\n175:         \"\"\"\n176:         k8s_provider = KubernetesProvider(\n177:             namespace=options.get(\"namespace\", \"default\"),\n178:             verbose=self.verbose,\n179:         )\n180: \n181:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n182: \n183:         replicas = options.get(\"replicas\", 1)\n184:         node_port = options.get(\"node_port\")\n185: \n186:         if node_port and (node_port < 30000 or node_port > 32767):\n187:             raise ValueError(\"NodePort must be between 30000 and 32767\")\n188: \n189:         self.logger.debug(f\"Deploying to Kubernetes: {metadata.agent_name}\")\n190: \n191:         result = k8s_provider.deploy_agent(\n192:             agent_name=metadata.agent_name,\n193:             image_url=image_url,\n194:             port=metadata.port,\n195:             entrypoint=metadata.entrypoint,\n196:             replicas=replicas,\n197:             node_port=node_port,\n198:             env_vars=options.get(\"env_vars\"),\n199:         )\n200: \n201:         try:\n202:             k8s_provider.wait_for_deployment_ready(\n203:                 name=metadata.agent_name,\n204:                 timeout=options.get(\"timeout\", 120),\n205:             )\n206:         except Exception as e:\n207:             metadata.k8s_deployment = metadata.k8s_deployment or {}\n208:             metadata.k8s_deployment[\"error\"] = str(e)\n209:             raise RuntimeError(f\"Deployment not ready: {e}\")\n210: \n211:         return {\n212:             \"agent_name\": metadata.agent_name,\n213:             \"provider\": \"k8s\",\n214:             \"deployment\": result.get(\"name\"),\n215:             \"service\": result.get(\"service\"),\n216:             \"endpoint\": result.get(\"endpoint\"),\n217:             \"status\": \"deployed\",\n218:         }\n219: \n220:     def publish(\n221:         self,\n222:         workspace_path: str,\n223:         version: Optional[str] = None,\n224:         image_url: Optional[str] = None,\n225:         image_username: Optional[str] = None,\n226:         image_password: Optional[str] = None,\n227:         description: Optional[str] = None,\n228:         region: Optional[str] = None,\n229:         cloud_provider: Optional[str] = None,\n230:         provider: str = \"agentcube\",\n231:         node_port: Optional[int] = None,\n232:         replicas: Optional[int] = None,\n233:         namespace: Optional[str] = None,\n234:         timeout: int = 120,\n235:         verbose: bool = False,\n236:     ) -> dict:\n237:         \"\"\"\n238:         Publish an agent to the target provider.\n239: \n240:         Args:\n241:             workspace_path: Path to agent workspace\n242:             version: Semantic version string\n243:             image_url: Image repository URL\n244:             image_username: Username for image repository\n245:             image_password: Password for image repository\n246:             description: Agent description\n247:             region: Deployment region\n248:             cloud_provider: Cloud provider name\n249:             provider: Target provider (agentcube or k8s)\n250:             node_port: NodePort (30000-32767)\n251:             replicas: Number of replicas\n252:             namespace: Deployment namespace\n253:             timeout: Timeout for deployment readiness in seconds\n254:             verbose: Enable verbose logging\n255: \n256:         Returns:\n257:             Dictionary with publish result\n258: \n259:         Raises:\n260:             ValueError: If publish fails\n261:         \"\"\"\n262:         workspace = Path(workspace_path).resolve()\n263: \n264:         metadata = self.metadata_service.load_metadata(workspace)\n265: \n266:         if version:\n267:             metadata.version = version\n268:         if description:\n269:             metadata.description = description\n270:         if region:\n271:             metadata.region = region\n272:         if image_url:\n273:             metadata.image = metadata.image or {}\n274:             metadata.image[\"url\"] = image_url\n275: \n276:         options = {\n277:             \"image_url\": image_url,\n278:             \"image_username\": image_username,\n279:             \"image_password\": image_password,\n280:             \"region\": region,\n281:             \"cloud_provider\": cloud_provider,\n282:             \"node_port\": node_port,\n283:             \"replicas\": replicas,\n284:             \"namespace\": namespace,\n285:             \"timeout\": timeout,\n286:             \"registry_url\": metadata.registry_url,\n287:             \"registry_username\": metadata.registry_username,\n288:             \"registry_password\": metadata.registry_password,\n289:         }\n290: \n291:         try:\n292:             if provider == \"agentcube\":\n293:                 if not metadata.router_url or not metadata.workload_manager_url:\n294:                     raise ValueError(\n295:                         \"AgentCube provider requires both 'router_url' and 'workload_manager_url' in agent_metadata.yaml\"\n296:                     )\n297:                 result = self._publish_cr_to_k8s(workspace, metadata, **options)\n298:             else:\n299:                 result = self._publish_k8s(workspace, metadata, **options)\n300: \n301:             metadata.agent_id = result.get(\"agent_id\") or result.get(\"deployment\")\n302:             metadata.agent_endpoint = result.get(\"endpoint\")\n303: \n304:             if result.get(\"status\") == \"deployed\":\n305:                 metadata.k8s_deployment = {\n306:                     \"name\": result.get(\"deployment\") or result.get(\"agent_id\"),\n307:                     \"provider\": provider,\n308:                     \"namespace\": namespace or \"default\",\n309:                 }\n310: \n311:             self.metadata_service.save_metadata(workspace, metadata)\n312: \n313:             return {\n314:                 \"agent_name\": metadata.agent_name,\n315:                 \"provider\": provider,\n316:                 \"endpoint\": result.get(\"endpoint\"),\n317:                 \"status\": result.get(\"status\"),\n318:             }\n319: \n320:         except Exception as e:\n321:             raise ValueError(f\"Publish failed: {e}\")\n\n(End of file - total 321 lines)\n</content>","metadata":{"preview":"\"\"\"Publish runtime for AgentCube - orchestrates the publish command workflow.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.docker_service import DockerService\n\n\nclass PublishRuntime:\n    \"\"\"\n    Core runtime for publishing agent runtimes.\n\n    Handles deployment to either AgentCube or Kubernetes provider.\n    \"\"\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/runtime/publish_runtime.py","time":{"start":1775866893592,"end":1775866893609}}}}
