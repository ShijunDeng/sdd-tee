imestamp   string\n298: \t\texpectError bool\n299: \t}{\n300: \t\t{\n301: \t\t\tname:        \"RFC3339 format\",\n302: \t\t\ttimestamp:   \"2024-01-15T10:30:00Z\",\n303: \t\t\texpectError: false,\n304: \t\t},\n305: \t\t{\n306: \t\t\tname:        \"RFC3339 with timezone\",\n307: \t\t\ttimestamp:   \"2024-01-15T10:30:00+05:30\",\n308: \t\t\texpectError: false,\n309: \t\t},\n310: \t\t{\n311: \t\t\tname:        \"invalid timestamp\",\n312: \t\t\ttimestamp:   \"not-a-timestamp\",\n313: \t\t\texpectError: true,\n314: \t\t},\n315: \t\t{\n316: \t\t\tname:        \"empty string\",\n317: \t\t\ttimestamp:   \"\",\n318: \t\t\texpectError: true,\n319: \t\t},\n320: \t\t{\n321: \t\t\tname:        \"Unix timestamp\",\n322: \t\t\ttimestamp:   \"1705315800\",\n323: \t\t\texpectError: true,\n324: \t\t},\n325: \t}\n326: \n327: \tfor _, tt := range tests {\n328: \t\tt.Run(tt.name, func(t *testing.T) {\n329: \t\t\t_, err := time.Parse(time.RFC3339, tt.timestamp)\n330: \t\t\tif tt.expectError && err == nil {\n331: \t\t\t\tt.Errorf(\"Expected error for timestamp %q\", tt.timestamp)\n332: \t\t\t}\n333: \t\t\tif !tt.expectError && err != nil {\n334: \t\t\t\tt.Errorf(\"Expected no error for timestamp %q, got %v\", tt.timestamp, err)\n335: \t\t\t}\n336: \t\t})\n337: \t}\n338: }\n339: \n340: func TestReconcile_SandboxObjectMeta(t *testing.T) {\n341: \treconciler := &Reconciler{\n342: \t\tClient: &mockClient{\n343: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n344: \t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n345: \t\t\t\tsandbox.ObjectMeta = metav1.ObjectMeta{\n346: \t\t\t\t\tName:      key.Name,\n347: \t\t\t\t\tNamespace: key.Namespace,\n348: \t\t\t\t\tAnnotations: map[string]string{\n349: \t\t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: time.Now().Add(-5 * time.Minute).Format(time.RFC3339),\n350: \t\t\t\t\t},\n351: \t\t\t\t}\n352: \t\t\t\treturn nil\n353: \t\t\t},\n354: \t\t},\n355: \t\tScheme: &runtime.Scheme{},\