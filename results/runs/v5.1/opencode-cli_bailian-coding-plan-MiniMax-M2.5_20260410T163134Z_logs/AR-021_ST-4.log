= metadata.entrypoint\n41:         else:\n42:             entrypoint_cmd = \"python main.py\"\n43: \n44:         lines.append(f\"CMD {entrypoint_cmd}\")\n45: \n46:         return \"\\n\".join(lines)\n47: \n48:     @staticmethod\n49:     def generate_java_dockerfile(metadata: AgentMetadata) -> str:\n50:         \"\"\"\n51:         Generate Dockerfile content for Java agents.\n52: \n53:         Args:\n54:             metadata: AgentMetadata with agent configuration\n55: \n56:         Returns:\n57:             Dockerfile content as string\n58:         \"\"\"\n59:         lines = [\n60:             \"FROM maven:3.9-eclipse-temurin-17 AS build\",\n61:             \"\",\n62:             \"WORKDIR /app\",\n63:             \"\",\n64:             \"COPY pom.xml .\",\n65:             \"RUN mvn dependency:go-offline -B\",\n66:             \"\",\n67:             \"COPY src ./src\",\n68:             \"RUN mvn package -DskipTests\",\n69:             \"\",\n70:             \"FROM eclipse-temurin:17-jre\",\n71:             \"\",\n72:             \"WORKDIR /app\",\n73:             \"\",\n74:             \"COPY --from=build /app/target/*.jar app.jar\",\n75:             \"\",\n76:             f\"EXPOSE {metadata.port}\",\n77:             \"\",\n78:         ]\n79: \n80:         if metadata.entrypoint:\n81:             entrypoint_cmd = metadata.entrypoint\n82:         else:\n83:             entrypoint_cmd = \"java -jar app.jar\"\n84: \n85:         lines.append(f'CMD [\"{entrypoint_cmd}\"]')\n86: \n87:         return \"\\n\".join(lines)\n88: \n89:     @staticmethod\n90:     def write_dockerfile(workspace_path: Path, content: str) -> Path:\n91:         \"\"\"\n92:         Write Dockerfile content to workspace.\n93: \n94:         Args:\n95:             workspace_path: Path to workspace directory\n96:             content: Dockerfile content\n97: \n98:         Returns:\n99:             Path to the written Dockerfile\n100:         \"\"\"\n101:         dockerfile_path = workspace_path / \"Dockerfile\"\n102: \n103:         with open(dockerfile_path, \"w\", encoding=\"utf-8\") as f:\n104:             f.write(content)\n105: \n106:         return dockerfile_path\n\n(End of file - total 106 lines)\n</content>","metadata":{"preview":"\"\"\"Docker service for AgentCube - handles Dockerfile generation and Docker operations.\"\"\"\n\nfrom pathlib import Path\n\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass DockerService:\n    \"\"\"Service for Docker-related operations.\"\"\"\n\n    @staticmethod\n    def generate_python_dockerfile(metadata: AgentMetadata) -> str:\n        \"\"\"\n        Generate Dockerfile content for Python agents.\n\n        Args:\n            metadata: AgentMetadata with agent configuration\n\n        Returns:\n            Dockerfile content as string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/docker_service.py","time":{"start":1775861319608,"end":1775861319623}}}}
