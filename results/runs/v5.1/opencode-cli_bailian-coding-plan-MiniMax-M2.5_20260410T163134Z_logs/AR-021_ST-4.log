{"type":"tool_use","timestamp":1775861323182,"sessionID":"ses_2866b12a8ffeIHii9DrS9i1fWL","part":{"id":"prt_d799551d4001nBzbw1vZsGXmWS","messageID":"msg_d799547f9001InvbKf0RZigFR2","sessionID":"ses_2866b12a8ffeIHii9DrS9i1fWL","type":"tool","tool":"read","callID":"toolu_b04b95df85574a7aa4f08612","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Metadata service for AgentCube - handles agent metadata loading, saving, and validation.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import os\n6: from pathlib import Path\n7: from typing import Optional\n8: \n9: import yaml\n10: from pydantic import BaseModel, Field, field_validator\n11: \n12: \n13: class AgentMetadata(BaseModel):\n14:     \"\"\"Pydantic model for agent metadata configuration.\"\"\"\n15: \n16:     agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n17:     language: str = Field(default=\"python\", description=\"Programming language used\")\n18:     entrypoint: str = Field(..., description=\"Command to launch the agent\")\n19:     port: int = Field(default=8080, description=\"Port exposed by the agent runtime\")\n20:     build_mode: str = Field(default=\"local\", description=\"Build strategy: local or cloud\")\n21:     description: Optional[str] = Field(default=None, description=\"Human-readable summary\")\n22:     requirements_file: Optional[str] = Field(\n23:         default=\"requirements.txt\", description=\"Python dependency file\"\n24:     )\n25: \n26:     @field_validator(\"language\")\n27:     @classmethod\n28:     def validate_language(cls, v: str) -> str:\n29:         \"\"\"Validate that language is either python or java.\"\"\"\n30:         v_lower = v.lower()\n31:         if v_lower not in (\"python\", \"java\"):\n32:             raise ValueError(\"Language must be 'python' or 'java'\")\n33:         return v_lower\n34: \n35:     @field_validator(\"build_mode\")\n36:     @classmethod\n37:     def validate_build_mode(cls, v: str) -> str:\n38:         \"\"\"Validate that build_mode is either local or cloud.\"\"\"\n39:         v_lower = v.lower()\n40:         if v_lower not in (\"local\", \"cloud\"):\n41:             raise ValueError(\"Build mode must be 'local' or 'cloud'\")\n42:         return v_lower\n43: \n44:     @field_validator(\"port\")\n45:     @classmethod\n46:     def validate_port(cls, v: int) -> int:\n47:         \"\"\"Validate that port is in valid range (1-65535).\"\"\"\n48:         if not isinstance(v, int):\n49:             raise ValueError(\"Port must be an integer\")\n50:         if v < 1 or v > 65535:\n51:             raise ValueError(\"Port must be between 1 and 65535\")\n52:         return v\n53: \n54: \n55: class MetadataService:\n56:     \"\"\"Service for managing agent metadata in workspace.\"\"\"\n57: \n58:     METADATA_FILES = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n59: \n60:     @staticmethod\n61:     def load_metadata(workspace_path: str | Path) -> AgentMetadata:\n62:         \"\"\"\n63:         Load metadata from workspace with fallback chain.\n64: \n65:         Searches for metadata files in order: agent_metadata.yaml -> agent.yaml -> metadata.yaml\n66:         Raises FileNotFoundError if none found.\n67:         \"\"\"\n68:         workspace = Path(workspace_path)\n69: \n70:         for filename in MetadataService.METADATA_FILES:\n71:             metadata_file = workspace / filename\n72:             if metadata_file.exists():\n73:                 with open(metadata_file, \"r\", encoding=\"utf-8\") as f:\n74:                     data = yaml.safe_load(f)\n75:                     if data:\n76:                         return AgentMetadata(**data)\n77: \n78:         raise FileNotFoundError(\n79:             f\"No metadata file found in {workspace}. \"\n80:             f\"Expected one of: {', '.join(MetadataService.METADATA_FILES)}\"\n81:         )\n82: \n83:     @staticmethod\n84:     def save_metadata(workspace_path: str | Path, metadata: AgentMetadata) -> Path:\n85:         \"\"\"\n86:         Save metadata to workspace as agent_metadata.yaml.\n87: \n88:         Returns the path to the saved file.\n89:         \"\"\"\n90:         workspace = Path(workspace_path)\n91:         metadata_file = workspace / \"agent_metadata.yaml\"\n92: \n93:         with open(metadata_file, \"w\", encoding=\"utf-8\") as f:\n94:             yaml.safe_dump(metadata.model_dump(), f, default_flow_style=False, sort_keys=False)\n95: \n96:         return metadata_file\n97: \n98:     @staticmethod\n99:     def validate_workspace(workspace_path: str | Path) -> bool:\n100:         \"\"\"\n101:         Basic validation that workspace path exists and is a directory.\n102: \n103:         Returns True if valid.\n104:         Raises ValueError if not valid.\n105:         \"\"\"\n106:         workspace = Path(workspace_path)\n107: \n108:         if not workspace.exists():\n109:             raise ValueError(f\"Workspace path does not exist: {workspace}\")\n110: \n111:         if not workspace.is_dir():\n112:             raise ValueError(f\"Workspace path is not a directory: {workspace}\")\n113: \n114:         return True\n\n(End of file - total 114 lines)\n</content>","metadata":{"preview":"\"\"\"Metadata service for AgentCube - handles agent metadata loading, saving, and validation.\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nfrom pathlib import Path\nfrom typing import Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Pydantic model for agent metadata configuration.\"\"\"\n\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    language: str = Field(default=\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(default=8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(default=\"local\", description=\"Build strategy: local or cloud\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/metadata_service.py","time":{"start":1775861323147,"end":1775861323178}}}}
