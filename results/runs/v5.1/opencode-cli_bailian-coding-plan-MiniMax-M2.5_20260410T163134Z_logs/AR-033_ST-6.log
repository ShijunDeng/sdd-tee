        Build all Docker images\"\n279: \t@echo \"  make docker-build-router     Build router Docker image\"\n280: \t@echo \"  make docker-build-workload-manager  Build workload-manager Docker image\"\n281: \t@echo \"  make docker-build-agentd     Build agentd Docker image\"\n282: \t@echo \"  make docker-push            Push all Docker images to registry\"\n283: \t@echo \"  make validate-dockerfiles   Validate all Dockerfiles\"\n284: \t@echo \"\"\n285: \t@echo \"=== Test ===\"\n286: \t@echo \"  make test                    Run unit tests (default)\"\n287: \t@echo \"  make test-unit              Run unit tests\"\n288: \t@echo \"  make test-cover             Run tests with coverage report\"\n289: \t@echo \"\"\n290: \t@echo \"=== Code Quality ===\"\n291: \t@echo \"  make lint                   Run linter\"\n292: \t@echo \"  make lint-fix               Run linter with auto-fix\"\n293: \t@echo \"  make fmt                    Format code\"\n294: \t@echo \"\"\n295: \t@echo \"=== Development ===\"\n296: \t@echo \"  make dev                    Start development environment\"\n297: \t@echo \"  make dev-docker             Start Docker Compose dev environment\"\n298: \t@echo \"\"\n299: \t@echo \"=== Cleanup ===\"\n300: \t@echo \"  make clean                  Clean build artifacts\"\n301: \t@echo \"  make docker-clean           Clean Docker images\"\n302: \t@echo \"\"\n303: \t@echo \"=== Utilities ===\"\n304: \t@echo \"  make help                   Show this help message\"\n305: \t@echo \"  make version                Show binary version\"\n306: \t@echo \"  make deps                   Check dependencies\"\n307: \t@echo \"\"\n308: \t@echo \"=== Configuration ===\"\n309: \t@echo \"  DOCKER_REGISTRY=$(DOCKER_REGISTRY)\"\n310: \t@echo \"  DOCKER_TAG=$(DOCKER_TAG)\"\n311: \t@echo \"  GO_VERSION=$(GO_VERSION)\"\n312: \t@echo \"  BINARY_VERSION=$(BINARY_VERSION)\"\n313: \t@echo \"\"\n314: \t@echo \"  Override: make DOCKER_REGISTRY=custom DOCKER_TAG=v1.0.0 build\"\n315: \n316: version:\