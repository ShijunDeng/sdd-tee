, err := rs.cli.ZRangeByScore(ctx, rs.lastActivityIndexKey, &redis.ZRangeBy{\n-\tMin:   \"-inf\",\n-\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n-\tLimit: limit,\n+\tMin:    \"-inf\",\n+\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n+\tOffset: 0,\n+\tCount:  int(limit),\n }).Result()\n if err != nil {\n \treturn nil, err\n }\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_redis.go","before":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  *redis.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nconst (\n\tsessionKeyPrefix       = \"session:\"\n\tsessionExpiryIndexKey  = \"session:expiry\"\n\tsessionLastActivityKey = \"session:last_activity\"\n)\n\nfunc newRedisStore() (Store, error) {\n\topts, err := makeRedisOptions()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tcli := redis.NewClient(opts)\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\n\tif err := cli.Ping(ctx).Err(); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to connect to redis: %w\", err)\n\t}\n\n\treturn &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        sessionKeyPrefix,\n\t\texpiryIndexKey:       sessionExpiryIndexKey,\n\t\tlastActivityIndexKey: sessionLastActivityKey,\n\t}, nil\n}\n\nfunc makeRedisOptions() (*redis.Options, error) {\n\tredisAddr := os.Getenv(\"REDIS_ADDR\")\n\tif redisAddr == \"\" {\n\t\treturn nil, errors.New(\"REDIS_ADDR is required\")\n\t}\n\n\tredisPasswordRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n\tredisPassword := os.Getenv(\"REDIS_PASSWORD\")\n\n\tpasswordRequired := true\n\tif strings.EqualFold(redisPasswordRequired, \"false\") {\n\t\tpasswordRequired = false\n\t}\n\n\tif passwordRequired && redisPassword == \"\" {\n\t\treturn nil, errors.New(\"REDIS_PASSWORD is required\")\n\t}\n\n\treturn &redis.Options{\n\t\tAddr:     redisAddr,\n\t\tPassword: redisPassword,\n\t}, nil\n}\n\nfunc (rs *redisStore) Ping(ctx context.Context) error {\n\tresult, err := rs.cli.Ping(ctx).Result()\n\tif err != nil {\n\t\treturn err\n\t}\n\tif result != \"PONG\" {\n\t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n\t}\n\treturn nil\n}\n\nfunc (rs *redisStore) sessionKey(sessionID string) string {\n\treturn rs.sessionPrefix + sessionID\n}\n\nfunc (rs *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\tkey := rs.sessionKey(sessionID)\n\tdata, err := rs.cli.Get(ctx, key).Bytes()\n\tif err != nil {\n\t\tif errors.Is(err, redis.Nil) {\n\t\t\treturn nil, ErrNotFound\n\t\t}\n\t\treturn nil, err\n\t}\n\n\tvar sandbox types.SandboxInfo\n\tif err := json.Unmarshal(data, &sandbox); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &sandbox, nil\n}\n\nfunc (rs *redisStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn errors.New(\"sandbox is nil\")\n\t}\n\tif sandboxStore.ExpiresAt.IsZero() {\n\t\treturn errors.New(\"invalid expiry: ExpiresAt is zero\")\n\t}\n\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn errors.New(\"session ID is required\")\n\t}\n\n\tkey := rs.sessionKey(sandboxStore.SessionID)\n\tdata, err := json.Marshal(sandboxStore)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tnow := time.Now().Unix()\n\texpiryScore := float64(sandboxStore.ExpiresAt.Unix())\n\tlastActivityScore := float64(now)\n\n\tpipe := rs.cli.Pipeline()\n\tpipe.SetNX(ctx, key, data, 0)\n\tpipe.ZAdd(ctx, rs.expiryIndexKey, redis.Z{Score: expiryScore, Member: sandboxStore.SessionID})\n\tpipe.ZAdd(ctx, rs.lastActivityIndexKey, redis.Z{Score: lastActivityScore, Member: sandboxStore.SessionID})\n\n\t_, err = pipe.Exec(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\nfunc (rs *redisStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn errors.New(\"sandbox is nil\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn errors.New(\"session ID is required\")\n\t}\n\n\tkey := rs.sessionKey(sandboxStore.SessionID)\n\tdata, err := json.Marshal(sandboxStore)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tsuccess, err := rs.cli.SetNX(ctx, key, data, 0).Result()\n\tif err != nil {\n\t\treturn err\n\t}\n\tif !success {\n\t\treturn errors.New(\"key not exists\")\n\t}\n\n\treturn nil\n}\n\nfunc (rs *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\tkey := rs.sessionKey(sessionID)\n\n\tpipe := rs.cli.Pipeline()\n\tpipe.Del(ctx, key)\n\tpipe.ZRem(ctx, rs.expiryIndexKey, sessionID)\n\tpipe.ZRem(ctx, rs.lastActivityIndexKey, sessionID)\n\n\t_, err := pipe.Exec(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\nfunc (rs *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tif limit <= 0 {\n\t\treturn nil, nil\n\t}\n\n\tsessionIDs, err := rs.cli.ZRangeByScore(ctx, rs.expiryIndexKey, &redis.ZRangeBy{\n\t\tMin:    \"-inf\",\n\t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n\t\tOffset: 0,\n\t\tCount:  int(limit),\n\t}).Result()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn rs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n}\n\nfunc (rs *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tif limit <= 0 {\n\t\treturn nil, nil\n\t}\n\n\tsessionIDs, err := rs.cli.ZRangeByScore(ctx, rs.lastActivityIndexKey, &redis.ZRangeBy{\n\t\tMin:   \"-inf\",\n\t\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n\t\tLimit: limit,\n\t}).Result()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn rs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n}\n\nfunc (rs *redisStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n\tif len(sessionIDs) == 0 {\n\t\treturn nil, nil\n\t}\n\n\tkeys := make([]string, len(sessionIDs))\n\tfor i, sid := range sessionIDs {\n\t\tkeys[i] = rs.sessionKey(sid)\n\t}\n\n\tresults, err := rs.cli.Mget(ctx, keys...).Result()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar sandboxes []*types.SandboxInfo\n\tfor i, data := range results {\n\t\tif data == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tvar sandbox types.SandboxInfo\n\t\tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n\t\t\tklog.V(4).Infof(\"failed to unmarshal sandbox %s: %v\", sessionIDs[i], err)\n\t\t\tcontinue\n\t\t}\n\t\tsandboxes = append(sandboxes, &sandbox)\n\t}\n\n\treturn sandboxes, nil\n}\n\nfunc (rs *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n\tif sessionID == \"\" {\n\t\treturn errors.New(\"session ID is required\")\n\t}\n\n\tkey := rs.sessionKey(sessionID)\n\texists, err := rs.cli.Exists(ctx, key).Result()\n\tif err != nil {\n\t\treturn err\n\t}\n\tif exists != 1 {\n\t\treturn ErrNotFound\n\t}\n\n\ttimestamp := at\n\tif timestamp.IsZero() {\n\t\ttimestamp = time.Now()\n\t}\n\n\tscore := float64(timestamp.Unix())\n\t_, err = rs.cli.ZAdd(ctx, rs.lastActivityIndexKey, redis.Z{Score: score, Member: sessionID}).Result()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\nfunc (rs *redisStore) Close() error {\n\treturn rs.cli.Close()\n}\n","after":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  *redis.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nconst (\n