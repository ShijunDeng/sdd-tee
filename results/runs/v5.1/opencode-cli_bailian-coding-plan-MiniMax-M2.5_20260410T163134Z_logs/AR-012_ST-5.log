 {\n\tif sessionID == \"\" {\n\t\treturn errors.New(\"session ID is required\")\n\t}\n\n\tkey := rs.sessionKey(sessionID)\n\texists, err := rs.cli.Exists(ctx, key).Result()\n\tif err != nil {\n\t\treturn err\n\t}\n\tif exists != 1 {\n\t\treturn ErrNotFound\n\t}\n\n\ttimestamp := at\n\tif timestamp.IsZero() {\n\t\ttimestamp = time.Now()\n\t}\n\n\tscore := float64(timestamp.Unix())\n\t_, err = rs.cli.ZAdd(ctx, rs.lastActivityIndexKey, redis.Z{Score: score, Member: sessionID}).Result()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\nfunc (rs *redisStore) Close() error {\n\treturn rs.cli.Close()\n}\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_redis.go","time":{"start":1775850770489,"end":1775850770691}}}}
