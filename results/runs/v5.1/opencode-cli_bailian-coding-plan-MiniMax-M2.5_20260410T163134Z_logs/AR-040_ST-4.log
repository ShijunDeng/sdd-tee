{"type":"tool_use","timestamp":1775883948510,"sessionID":"ses_285122fcdffeq8QOZEKmQA850l","part":{"id":"prt_d7aee8e970016JlNdEgsNTrBPF","messageID":"msg_d7aee85ea001DNwb1q2uBXT5oX","sessionID":"ses_285122fcdffeq8QOZEKmQA850l","type":"tool","tool":"read","callID":"toolu_6014a382409e45528ef5f059","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pack_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pack_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Unit tests for PackRuntime.\"\"\"\n2: \n3: import os\n4: import tempfile\n5: from pathlib import Path\n6: from unittest.mock import MagicMock, patch\n7: \n8: import pytest\n9: import yaml\n10: \n11: from agentcube.models.pack_models import MetadataOptions\n12: from agentcube.runtime.pack_runtime import PackRuntime\n13: from agentcube.services.metadata_service import AgentMetadata\n14: \n15: \n16: class TestValidateWorkspaceStructure:\n17:     \"\"\"Tests for _validate_workspace_structure method.\"\"\"\n18: \n19:     def test_missing_directory_raises_value_error(self):\n20:         \"\"\"T080: Missing directory raises ValueError.\"\"\"\n21:         runtime = PackRuntime()\n22:         with pytest.raises(ValueError, match=\"does not exist\"):\n23:             runtime._validate_workspace_structure(Path(\"/nonexistent/path\"))\n24: \n25:     def test_valid_python_workspace_passes(self):\n26:         \"\"\"T081: Valid Python workspace passes.\"\"\"\n27:         with tempfile.TemporaryDirectory() as tmpdir:\n28:             workspace = Path(tmpdir)\n29:             (workspace / \"main.py\").touch()\n30: \n31:             runtime = PackRuntime()\n32:             runtime._validate_workspace_structure(workspace)\n33: \n34:     def test_valid_java_workspace_passes(self):\n35:         \"\"\"T082: Valid Java workspace passes.\"\"\"\n36:         with tempfile.TemporaryDirectory() as tmpdir:\n37:             workspace = Path(tmpdir)\n38:             (workspace / \"pom.xml\").touch()\n39: \n40:             runtime = PackRuntime()\n41:             runtime._validate_workspace_structure(workspace)\n42: \n43: \n44: class TestValidatePythonCompatibility:\n45:     \"\"\"Tests for _validate_python_compatibility method.\"\"\"\n46: \n47:     def test_no_python_files_raises_value_error(self):\n48:         \"\"\"T083: No Python files raises ValueError.\"\"\"\n49:         with tempfile.TemporaryDirectory() as tmpdir:\n50:             workspace = Path(tmpdir)\n51: \n52:             runtime = PackRuntime()\n53:             with pytest.raises(ValueError, match=\"No Python files found\"):\n54:                 runtime._validate_python_compatibility(workspace)\n55: \n56: \n57: class TestValidateJavaCompatibility:\n58:     \"\"\"Tests for _validate_java_compatibility method.\"\"\"\n59: \n60:     def test_no_pom_xml_raises_value_error(self):\n61:         \"\"\"T084: No pom.xml raises ValueError.\"\"\"\n62:         with tempfile.TemporaryDirectory() as tmpdir:\n63:             workspace = Path(tmpdir)\n64: \n65:             runtime = PackRuntime()\n66:             with pytest.raises(ValueError, match=\"No pom.xml found\"):\n67:                 runtime._validate_java_compatibility(workspace)\n68: \n69: \n70: class TestLoadOrCreateMetadata:\n71:     \"\"\"Tests for _load_or_create_metadata method.\"\"\"\n72: \n73:     def test_loads_existing_metadata_file(self):\n74:         \"\"\"T085: Loads existing metadata file.\"\"\"\n75:         with tempfile.TemporaryDirectory() as tmpdir:\n76:             workspace = Path(tmpdir)\n77:             metadata_data = {\n78:                 \"agent_name\": \"test-agent\",\n79:                 \"language\": \"python\",\n80:                 \"entrypoint\": \"python main.py\",\n81:                 \"port\": 8080,\n82:                 \"build_mode\": \"local\",\n83:             }\n84:             with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n85:                 yaml.safe_dump(metadata_data, f)\n86: \n87:             runtime = PackRuntime()\n88:             metadata = runtime._load_or_create_metadata(workspace, MetadataOptions())\n89: \n90:             assert metadata.agent_name == \"test-agent\"\n91:             assert metadata.language == \"python\"\n92:             assert metadata.port == 8080\n93: \n94:     def test_creates_defaults_when_no_file(self):\n95:         \"\"\"T086: Creates defaults when no metadata file.\"\"\"\n96:         with tempfile.TemporaryDirectory() as tmpdir:\n97:             workspace = Path(tmpdir)\n98:             (workspace / \"main.py\").touch()\n99: \n100:             runtime = PackRuntime()\n101:             metadata = runtime._load_or_create_metadata(workspace, MetadataOptions())\n102: \n103:             assert metadata.language == \"python\"\n104:             assert metadata.port == 8080\n105:             assert metadata.build_mode == \"local\"\n106:             assert metadata.requirements_file == \"requirements.txt\"\n107: \n108: \n109: class TestApplyOptionOverrides:\n110:     \"\"\"Tests for _apply_option_overrides method.\"\"\"\n111: \n112:     def test_cli_options_override_metadata(self):\n113:         \"\"\"T087: CLI options override metadata.\"\"\"\n114:         runtime = PackRuntime()\n115:         metadata = AgentMetadata(\n116:             agent_name=\"original\",\n117:             language=\"python\",\n118:             entrypoint=\"python main.py\",\n119:             port=8080,\n120:             build_mode=\"local\",\n121:         )\n122: \n123:         options = MetadataOptions(\n124:             agent_name=\"override\",\n125:             port=9000,\n126:             description=\"New description\",\n127:         )\n128: \n129:         result = runtime._apply_option_overrides(metadata, options)\n130: \n131:         assert result.agent_name == \"override\"\n132:         assert result.port == 9000\n133:         assert result.description == \"New description\"\n134:         assert result.language == \"python\"\n135: \n136: \n137: class TestAgentMetadataValidators:\n138:     \"\"\"Tests for AgentMetadata validators.\"\"\"\n139: \n140:     def test_invalid_language_raises_validation_error(self):\n141:         \"\"\"T088: Invalid language raises ValidationError.\"\"\"\n142:         with pytest.raises(ValueError, match=\"Language must be 'python' or 'java'\"):\n143:             AgentMetadata(\n144:                 agent_name=\"test\",\n145:                 language=\"invalid\",\n146:                 entrypoint=\"python main.py\",\n147:             )\n148: \n149:     def test_invalid_port_raises_validation_error(self):\n150:         \"\"\"T089: Invalid port raises ValidationError.\"\"\"\n151:         with pytest.raises(ValueError, match=\"Port must be between 1 and 65535\"):\n152:             AgentMetadata(\n153:                 agent_name=\"test\",\n154:                 language=\"python\",\n155:                 entrypoint=\"python main.py\",\n156:                 port=70000,\n157:             )\n158: \n159:     def test_invalid_build_mode_raises_validation_error(self):\n160:         \"\"\"Test invalid build_mode raises ValidationError.\"\"\"\n161:         with pytest.raises(ValueError, match=\"Build mode must be 'local' or 'cloud'\"):\n162:             AgentMetadata(\n163:                 agent_name=\"test\",\n164:                 language=\"python\",\n165:                 entrypoint=\"python main.py\",\n166:                 build_mode=\"invalid\",\n167:             )\n168: \n169: \n170: class TestInferEntrypoint:\n171:     \"\"\"Tests for _infer_entrypoint method.\"\"\"\n172: \n173:     def test_finds_main_py_for_python(self):\n174:         \"\"\"T090: Finds main.py for Python.\"\"\"\n175:         with tempfile.TemporaryDirectory() as tmpdir:\n176:             workspace = Path(tmpdir)\n177:             (workspace / \"main.py\").touch()\n178: \n179:             runtime = PackRuntime()\n180:             entrypoint = runtime._infer_entrypoint(workspace, \"python\")\n181: \n182:             assert entrypoint == \"python main.py\"\n183: \n184:     def test_no_entrypoint_for_missing_main_py(self):\n185:         \"\"\"Test returns None for missing main.py.\"\"\"\n186:         with tempfile.TemporaryDirectory() as tmpdir:\n187:             workspace = Path(tmpdir)\n188: \n189:             runtime = PackRuntime()\n190:             entrypoint = runtime._infer_entrypoint(workspace, \"python\")\n191: \n192:             assert entrypoint is None\n193: \n194: \n195: class TestGenerateDockerfile:\n196:     \"\"\"Tests for _generate_dockerfile method.\"\"\"\n197: \n198:     def test_skips_when_dockerfile_exists(self):\n199:         \"\"\"T091: Skips when Dockerfile exists.\"\"\"\n200:         with tempfile.TemporaryDirectory() as tmpdir:\n201:             workspace = Path(tmpdir)\n202:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.11\")\n203: \n204:             runtime = PackRuntime()\n205:             metadata = AgentMetadata(\n206:                 agent_name=\"test\",\n207:                 language=\"python\",\n208:                 entrypoint=\"python main.py\",\n209:                 port=8080,\n210:             )\n211: \n212:             result = runtime._generate_dockerfile(workspace, metadata)\n213: \n214:             assert result is None\n215: \n216: \n217: class TestPackEndToEnd:\n218:     \"\"\"Tests for pack method end-to-end.\"\"\"\n219: \n220:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n221:     def test_pack_valid_python_workspace(self, mock_from_env):\n222:         \"\"\"T092: Pack end-to-end with valid workspace.\"\"\"\n223:         mock_client = MagicMock()\n224:         mock_client.ping.return_value = True\n225:         mock_from_env.return_value = mock_client\n226: \n227:         with tempfile.TemporaryDirectory() as tmpdir:\n228:             workspace = Path(tmpdir)\n229:             (workspace / \"main.py\").write_text(\"print('hello')\")\n230: \n231:             runtime = PackRuntime()\n232:             result = runtime.pack(\n233:                 workspace_path=str(workspace),\n234:                 agent_name=\"test-agent\",\n235:                 language=\"python\",\n236:                 entrypoint=\"python main.py\",\n237:                 port=8080,\n238:                 build_mode=\"local\",\n239:             )\n240: \n241:             assert result[\"agent_name\"] == \"test-agent\"\n242:             assert result[\"dockerfile_generated\"] is True\n243: \n244:             metadata_file = workspace / \"agent_metadata.yaml\"\n245:             assert metadata_file.exists()\n246: \n247:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n248:     def test_pack_java_workspace(self, mock_from_env):\n249:         \"\"\"Test pack Java workspace end-to-end.\"\"\"\n250:         mock_client = MagicMock()\n251:         mock_client.ping.return_value = True\n252:         mock_from_env.return_value = mock_client\n253: \n254:         with tempfile.TemporaryDirectory() as tmpdir:\n255:             workspace = Path(tmpdir)\n256:             (workspace / \"pom.xml\").write_text(\"<project></project>\")\n257: \n258:             runtime = PackRuntime()\n259:             result = runtime.pack(\n260:                 workspace_path=str(workspace),\n261:                 agent_name=\"java-agent\",\n262:                 language=\"java\",\n263:                 entrypoint=\"java -jar target/app.jar\",\n264:                 port=8080,\n265:                 build_mode=\"local\",\n266:             )\n267: \n268:             assert result[\"agent_name\"] == \"java-agent\"\n269:             assert result[\"dockerfile_generated\"] is True\n270: \n271:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n272:     def test_pack_with_existing_dockerfile(self, mock_from_env):\n273:         \"\"\"Test pack with existing Dockerfile skips generation.\"\"\"\n274:         mock_client = MagicMock()\n275:         mock_client.ping.return_value = True\n276:         mock_from_env.return_value = mock_client\n277: \n278:         with tempfile.TemporaryDirectory() as tmpdir:\n279:             workspace = Path(tmpdir)\n280:             (workspace / \"main.py\").write_text(\"print('hello')\")\n281:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.11-slim\")\n282: \n283:             runtime = PackRuntime()\n284:             result = runtime.pack(\n285:                 workspace_path=str(workspace),\n286:                 agent_name=\"test-agent\",\n287:             )\n288: \n289:             assert result[\"dockerfile_generated\"] is False\n290: \n291:     @patch(\"agentcube.services.docker_service.docker.from_env\")\n292:     def test_pack_with_custom_output(self, mock_from_env):\n293:         \"\"\"Test pack with custom output path.\"\"\"\n294:         mock_client = MagicMock()\n295:         mock_client.ping.return_value = True\n296:         mock_from_env.return_value = mock_client\n297: \n298:         with tempfile.TemporaryDirectory() as tmpdir:\n299:             workspace = Path(tmpdir)\n300:             (workspace / \"main.py\").write_text(\"print('hello')\")\n301: \n302:             runtime = PackRuntime()\n303:             custom_output = str(Path(tmpdir) / \"output\")\n304: \n305:             result = runtime.pack(\n306:                 workspace_path=str(workspace),\n307:                 agent_name=\"test-agent\",\n308:                 output=custom_output,\n309:             )\n310: \n311:             assert result[\"output_path\"] == custom_output\n312:             assert Path(custom_output).exists()\n\n(End of file - total 312 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for PackRuntime.\"\"\"\n\nimport os\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\nimport yaml\n\nfrom agentcube.models.pack_models 