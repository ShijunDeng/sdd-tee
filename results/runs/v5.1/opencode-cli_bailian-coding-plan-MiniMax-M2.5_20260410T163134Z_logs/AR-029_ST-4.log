 URL of the Router service.\n43:             namespace: Kubernetes namespace.\n44:             cr_name: Custom Resource name.\n45:             session_id: The session ID for this Code Interpreter.\n46:             base_url: Explicit base URL for API calls. If None, constructed\n47:                      from router_url, namespace, and cr_name.\n48:             timeout: Default read timeout in seconds.\n49:             connect_timeout: Connection timeout in seconds.\n50:             pool_connections: Number of connection pools to cache.\n51:             pool_maxsize: Maximum number of connections per pool.\n52:         \"\"\"\n53:         self.timeout = timeout\n54:         self.connect_timeout = connect_timeout\n55: \n56:         if base_url:\n57:             self.base_url = base_url\n58:         else:\n59:             self.base_url = urljoin(\n60:                 router_url,\n61:                 f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\",\n62:             )\n63: \n64:         self._session_id = session_id\n65:         self._headers: Dict[str, str] = {\n66:             \"x-agentcube-session-id\": session_id,\n67:         }\n68: \n69:         self._session = create_session(pool_connections=pool_connections, pool_maxsize=pool_maxsize)\n70: \n71:         logger.debug(\n72:             f\"CodeInterpreterDataPlaneClient initialized with \"\n73:             f\"base_url={self.base_url}, session_id={session_id}\"\n74:         )\n75: \n76:     def _request(\n77:         self,\n78:         method: str,\n79:         path: str,\n80:         **kwargs,\n81:     ) -> requests.Response:\n82:         \"\"\"\n83:         Make an HTTP request to the data plane.\n84: \n85:         Args:\n86:             method: HTTP method (GET, POST, etc.)\n87:             path: API path (appended to base_url)\n88:             **kwargs: Additional arguments passed to requests.Session.request\n89: \n90:         Returns:\n91:             The response object.\n92: \n93:         Raises:\n94:             DataPlaneError: If the request fails.\n95:         \"\"\"\n96:         url = urljoin(self.base_url, path)\n97: \n98:         headers = dict(self._headers)\n99:         headers.update(kwargs.pop(\"headers\", {}))\n100: \n101:         try:\n102:             response = self._session.request(\n103:                 method,\n104:                 url,\n105:                 headers=headers,\n106:                 timeout=(self.connect_timeout, self.timeout),\n107:                 **kwargs,\n108:             )\n109:             response.raise_for_status()\n110:             return response\n111: \n112:         except requests.RequestException as e:\n113:             logger.error(f\"Data plane request failed: {e}\")\n114:             raise DataPlaneError(f\"Data plane request failed: {e}\") from e\n115: \n116:     def execute_command(\n117:         self,\n118:         command: str,\n119:         timeout: Optional[int] = None,\n120:     ) -> Dict:\n121:         \"\"\"\n122:         Execute a command in the Code Interpreter.\n123: \n124:         Args:\n125:             command: The command to execute.\n126:             timeout: Timeout in seconds. If None, uses the default.\n127: \n128:         Returns:\n129:             A dictionary containing the response data.\n130: \n131:         Raises:\n132:             DataPlaneError: If the execution fails.\n133:         \"\"\"\n134:         effective_timeout = timeout if timeout is not None else self.timeout\n135: \n136:         body = {\n137:             \"command\": command.split() if isinstance(command, str) else command,\n138:             \"timeout\": f\"{effective_timeout}s\",\n139:         }\n140: \n141:         read_timeout = effective_timeout + 2.0\n142: \n143:         response = self._request(\n144:             \"POST\",\n145:             \"api/execute\",\n146:             json=body,\n147:             timeout=(self.connect_timeout, read_timeout),\n148:         )\n149: \n150:         return response.json()\n151: \n152:     def write_file(\n153:         self,\n154:         content: str,\n155:         remote_path: str,\n156:         mode: str = \"0644\",\n157:     ) -> Dict:\n158:         \"\"\"\n159:         Write a file to the Code Interpreter.\n160: \n161:         Args:\n162:             content: The file content (will be base64 encoded).\n163:             remote_path: The remote path where the file will be written.\n164:             mode: File permissions (default: 0644).\n165: \n166:         Returns:\n167:             A dictionary containing the response data.\n168: \n169:         Raises:\n170:             DataPlaneError: If the write fails.\n171:         \"\"\"\n172:         body = {\n173:             \"content\": base64.b64encode(content.encode()).decode(),\n174:             \"path\": remote_path,\n175:             \"mode\": mode,\n176:         }\n177: \n178:         response = self._request(\n179:             \"POST\",\n180:             \"api/files\",\n181:             json=body,\n182:         )\n183: \n184:         return response.json()\n185: \n186:     def upload_file(\n187:         self,\n188:         local_path: str,\n189:         remote_path: str,\n190:     ) -> Dict:\n191:         \"\"\"\n192:         Upload a file to the Code Interpreter.\n193: \n194:         Args:\n195:             local_path: Path to the local file.\n196:             remote_path: The remote path where the file will be written.\n197: \n198:         Returns:\n199:             A dictionary containing the response data.\n200: \n201:         Raises:\n202:             DataPlaneError: If the upload fails.\n203:         \"\"\"\n204:         local_file = Path(local_path)\n205:         if not local_file.exists():\n206:             raise DataPlaneError(f\"Local file not found: {local_path}\")\n207: \n208:         with open(local_file, \"rb\") as f:\n209:             files = {\"file\": (local_file.name, f)}\n210:             headers = dict(self._headers)\n211:             headers[\"x-agentcube-session-id\"] = self._session_id\n212: \n213:             url = urljoin(self.base_url, \"api/files\")\n214: \n215:             try:\n216:                 response = self._session.post(\n217:                     url,\n218:                     files=files,\n219:                     data={\"path\": remote_path},\n220:                     headers=headers,\n221:                     timeout=(self.connect_timeout, self.timeout),\n222:                 )\n223:                 response.raise_for_status()\n224:                 return response.json()\n225: \n226:             except requests.RequestException as e:\n227:                 logger.error(f\"File upload failed: {e}\")\n228:                 raise DataPlaneError(f\"File upload failed: {e}\") from e\n229: \n230:     def download_file(\n231:         self,\n232:         remote_path: str,\n233:         local_path: str,\n234:     ) -> None:\n235:         \"\"\"\n236:         Download a file from the Code Interpreter.\n237: \n238:         Args:\n239:             remote_path: The remote path of the file to download.\n240:             local_path: The local path where the file will be saved.\n241: \n242:         Raises:\n243:             DataPlaneError: If the download fails.\n244:         \"\"\"\n245:         clean_path = remote_path.lstrip(\"/\")\n246: \n247:         response = self._request(\n248:             \"GET\",\n249:             f\"api/files/{clean_path}\",\n250:             stream=True,\n251:         )\n252: \n253:         local_file = Path(local_path)\n254:         local_file.parent.mkdir(parents=True, exist_ok=True)\n255: \n256:         with open(local_file, \"wb\") as f:\n257:             for chunk in response.iter_content(chunk_size=8192):\n258:                 if chunk:\n259:                     f.write(chunk)\n260: \n261:         logger.info(f\"Downloaded {remote_path} to {local_path}\")\n262: \n263:     def list_files(self, path: str = \".\") -> Dict:\n264:         \"\"\"\n265:         List files in the Code Interpreter.\n266: \n267:         Args:\n268:             path: The path to list (default: \".\").\n269: \n270:         Returns:\n271:             A dictionary containing the file listing.\n272: \n273:         Raises:\n274:             DataPlaneError: If the list fails.\n275:         \"\"\"\n276:         response = self._request(\n277:             \"GET\",\n278:             \"api/files\",\n279:             params={\"path\": path},\n280:         )\n281: \n282:         return response.json()\n283: \n284:     def close(self) -> None:\n285:         \"\"\"Close the HTTP session.\"\"\"\n286:         self._session.close()\n287:         logger.debug(\"CodeInterpreterDataPlaneClient session closed\")\n\n(End of file - total 287 lines)\n</content>","metadata":{"preview":"\"\"\"Code Interpreter Data Plane client for AgentCube SDK.\"\"\"\n\nimport base64\nfrom pathlib import Path\nfrom typing import Dict, Optional\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom agentcube.exceptions import DataPlaneError\nfrom agentcube.utils.http import (\n    DEFAULT_CONNECT_TIMEOUT,\n    DEFAULT_POOL_CONNECTIONS,\n    DEFAULT_POOL_MAXSIZE,\n    DEFAULT_TIMEOUT,\n    create_session,\n)\nfrom agentcube.utils.log import get_logger\n\nlogger = get_logger(__name__)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/clients/code_interpreter_data_plane.py","time":{"start":1775870554598,"end":1775870554614}}}}
