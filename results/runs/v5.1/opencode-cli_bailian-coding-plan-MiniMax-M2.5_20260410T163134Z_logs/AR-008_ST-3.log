{"type":"tool_use","timestamp":1775846144738,"sessionID":"ses_28753027dffeVp68suk2dqdsjB","part":{"id":"prt_d78adb7190011VOQS1mV1MRHgG","messageID":"msg_d78ada8f1001twmjpxHVnzKOA2","sessionID":"ses_28753027dffeVp68suk2dqdsjB","type":"tool","tool":"read","callID":"toolu_886e909360f6407fb830d36a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration_test.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"testing\"\n5: \t\"time\"\n6: )\n7: \n8: func TestIsExpiredByTTL(t *testing.T) {\n9: \texpiredTime := time.Now().Add(-1 * time.Hour)\n10: \tsandbox := &Sandbox{\n11: \t\tSessionID: \"test-1\",\n12: \t\tExpiresAt: &expiredTime,\n13: \t\tCreatedAt: time.Now(),\n14: \t}\n15: \n16: \tif !isExpiredByTTL(sandbox) {\n17: \t\tt.Error(\"Expected sandbox to be expired by TTL\")\n18: \t}\n19: \n20: \tnotExpiredTime := time.Now().Add(1 * time.Hour)\n21: \tsandbox.ExpiresAt = &notExpiredTime\n22: \n23: \tif isExpiredByTTL(sandbox) {\n24: \t\tt.Error(\"Expected sandbox to not be expired by TTL\")\n25: \t}\n26: \n27: \tsandbox.ExpiresAt = nil\n28: \tif isExpiredByTTL(sandbox) {\n29: \t\tt.Error(\"Expected sandbox with nil ExpiresAt to not be expired\")\n30: \t}\n31: }\n32: \n33: func TestIsExpiredByIdleTimeout(t *testing.T) {\n34: \tsandbox := &Sandbox{\n35: \t\tSessionID:      \"test-2\",\n36: \t\tLastActivityAt: new(time.Time),\n37: \t\tCreatedAt:      time.Now().Add(-30 * time.Minute),\n38: \t}\n39: \n40: \toldActivity := time.Now().Add(-20 * time.Minute)\n41: \tsandbox.LastActivityAt = &oldActivity\n42: \n43: \tif !isExpiredByIdleTimeout(sandbox) {\n44: \t\tt.Error(\"Expected sandbox to be expired by idle timeout\")\n45: \t}\n46: }\n47: \n48: func TestIsExpiredByMaxLifetime(t *testing.T) {\n49: \tsandbox := &Sandbox{\n50: \t\tSessionID: \"test-3\",\n51: \t\tCreatedAt: time.Now().Add(-25 * time.Hour),\n52: \t}\n53: \n54: \tif !isExpiredByMaxLifetime(sandbox) {\n55: \t\tt.Error(\"Expected sandbox to be expired by max lifetime\")\n56: \t}\n57: \n58: \tsandbox.CreatedAt = time.Now()\n59: \tif isExpiredByMaxLifetime(sandbox) {\n60: \t\tt.Error(\"Expected sandbox to not be expired by max lifetime\")\n61: \t}\n62: }\n63: \n64: func TestIsExpiredByStaleState(t *testing.T) {\n65: \tsandbox := &Sandbox{\n66: \t\tSessionID: \"test-4\",\n67: \t\tState:     SandboxStateUnknown,\n68: \t\tCreatedAt: time.Now().Add(-2 * time.Hour),\n69: \t}\n70: \n71: \tif !isExpiredByStaleState(sandbox) {\n72: \t\tt.Error(\"Expected stale sandbox to be expired\")\n73: \t}\n74: \n75: \tsandbox.State = SandboxStateRunning\n76: \tif isExpiredByStaleState(sandbox) {\n77: \t\tt.Error(\"Expected running sandbox to not be expired\")\n78: \t}\n79: }\n80: \n81: func TestExpirationChecker(t *testing.T) {\n82: \tconfig := NewExpirationConfig()\n83: \tchecker := NewExpirationChecker(config)\n84: \n85: \tsandbox := &Sandbox{\n86: \t\tSessionID: \"test-5\",\n87: \t\tCreatedAt: time.Now().Add(-10 * time.Hour),\n88: \t}\n89: \n90: \tif !checker.IsExpired(sandbox) {\n91: \t\tt.Error(\"Expected old sandbox to be expired\")\n92: \t}\n93: \n94: \texpiryTime := metav1.NewTime(time.Now().Add(-1 * time.Hour))\n95: \tsandbox.ExpiresAt = &expiryTime\n96: \n97: \tif !checker.IsExpired(sandbox) {\n98: \t\tt.Error(\"Expected sandbox with past expiry time to be expired\")\n99: \t}\n100: }\n101: \n102: func TestGetExpirationTime(t *testing.T) {\n103: \tconfig := NewExpirationConfig()\n104: \tchecker := NewExpirationChecker(config)\n105: \n106: \tsandbox := &Sandbox{\n107: \t\tSessionID: \"test-6\",\n108: \t\tCreatedAt: time.Now(),\n109: \t}\n110: \n111: \texpiry := checker.GetExpirationTime(sandbox)\n112: \tif expiry == nil {\n113: \t\tt.Error(\"Expected non-nil expiry time\")\n114: \t}\n115: }\n116: \n117: func TestCalculateGracePeriod(t *testing.T) {\n118: \tresult := CalculateGracePeriod(nil)\n119: \tif result != 30*time.Second {\n120: \t\tt.Errorf(\"Expected 30s default, got %v\", result)\n121: \t}\n122: \n123: \tseconds := int64(60)\n124: \tresult = CalculateGracePeriod(&seconds)\n125: \tif result != 60*time.Second {\n126: \t\tt.Errorf(\"Expected 60s, got %v\", result)\n127: \t}\n128: \n129: \tzero := int64(0)\n130: \tresult = CalculateGracePeriod(&zero)\n131: \tif result != 0 {\n132: \t\tt.Errorf(\"Expected 0, got %v\", result)\n133: \t}\n134: }\n\n(End of file - total 134 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"testing\"\n\t\"time\"\n)\n\nfunc TestIsExpiredByTTL(t *testing.T) {\n\texpiredTime := time.Now().Add(-1 * time.Hour)\n\tsandbox := &Sandbox{\n\t\tSessionID: \"test-1\",\n\t\tExpiresAt: &expiredTime,\n\t\tCreatedAt: time.Now(),\n\t}\n\n\tif !isExpiredByTTL(sandbox) {\n\t\tt.Error(\"Expected sandbox to be expired by TTL\")\n\t}\n\n\tnotExpiredTime := time.Now().Add(1 * time.Hour)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration_test.go","time":{"start":1775846144726,"end":1775846144736}}}}
