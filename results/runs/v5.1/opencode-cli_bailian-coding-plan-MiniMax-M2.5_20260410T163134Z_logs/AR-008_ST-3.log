son:\"sandboxId\"`\n39: \tNamespace        string      `json:\"namespace\"`\n40: \tReason           string      `json:\"reason\"`\n41: \tInitiator        string      `json:\"initiator\"`\n42: \tDuration         int64       `json:\"duration\"`\n43: \tResourcesCleaned []string    `json:\"resourcesCleaned\"`\n44: \tTimestamp        metav1.Time `json:\"timestamp\"`\n45: }\n46: \n47: type DeletionEvent struct {\n48: \tType           string      `json:\"type\"`\n49: \tReason         string      `json:\"reason\"`\n50: \tMessage        string      `json:\"message\"`\n51: \tInvolvedObject string      `json:\"involvedObject\"`\n52: \tTimestamp      metav1.Time `json:\"timestamp\"`\n53: }\n54: \n55: type Sandbox struct {\n56: \tName           string            `json:\"name\"`\n57: \tNamespace      string            `json:\"namespace\"`\n58: \tSessionID      string            `json:\"sessionId\"`\n59: \tState          SandboxState      `json:\"state\"`\n60: \tCreatedAt      time.Time         `json:\"createdAt\"`\n61: \tExpiresAt      *time.Time        `json:\"expiresAt,omitempty\"`\n62: \tLastActivityAt *time.Time        `json:\"lastActivityAt,omitempty\"`\n63: \tLabels         map[string]string `json:\"labels,omitempty\"`\n64: \tAnnotations    map[string]string `json:\"annotations,omitempty\"`\n65: }\n66: \n67: type SandboxState string\n68: \n69: const (\n70: \tSandboxStateUnknown  SandboxState = \"Unknown\"\n71: \tSandboxStatePending  SandboxState = \"Pending\"\n72: \tSandboxStateRunning  SandboxState = \"Running\"\n73: \tSandboxStateFailed   SandboxState = \"Failed\"\n74: \tSandboxStateDeleting SandboxState = \"Deleting\"\n75: )\n76: \n77: type SandboxList struct {\n78: \tItems []Sandbox `json:\"items\"`\n79: }\n80: \n81: type ListOptions struct {\n82: \tLabelSelector string `form:\"labelSelector\"`\n83: \tFieldSelector string `form:\"fieldSelector\"`\n84: \tLimit         int64  `form:\"limit\"`\n85: \tContinue      string `form:\"continue\"`\n86: }\n87: \n88: type DeleteResponse struct {\n89: \tName             string      `json:\"name\"`\n90: \tNamespace        string      `json:\"namespace\"`\n91: \tDeletedAt        metav1.Time `json:\"deletedAt\"`\n92: \tResourcesCleaned []string    `json:\"resourcesCleaned\"`\n93: }\n94: \n95: type BatchDeleteResponse struct {\n96: \tDeletedCount int      `json:\"deletedCount\"`\n97: \tFailedCount  int      `json:\"failedCount\"`\n98: \tErrors       []string `json:\"errors,omitempty\"`\n99: }\n100: \n101: type APIResponse struct {\n102: \tKind       string      `json:\"kind\"`\n103: \tAPIVersion string      `json:\"apiVersion\"`\n104: \tStatus     string      `json:\"status\"`\n105: \tData       interface{} `json:\"data,omitempty\"`\n106: \tMetadata   *ListMeta   `json:\"metadata,omitempty\"`\n107: }\n108: \n109: type ListMeta struct {\n110: \tContinue           string `json:\"continue,omitempty\"`\n111: \tRemainingItemCount *int64 `json:\"remainingItemCount,omitempty\"`\n112: \tResourceVersion    string `json:\"resourceVersion,omitempty\"`\n113: }\n114: \n115: type APIError struct {\n116: \tKind       string           `json:\"kind\"`\n117: \tAPIVersion string           `json:\"apiVersion\"`\n118: \tStatus     string           `json:\"status\"`\n119: \tMessage    string           `json:\"message\"`\n120: \tReason     string           `json:\"reason\"`\n121: \tCode       int              `json:\"code\"`\n122: \tDetails    *APIErrorDetails `json:\"details,omitempty\"`\n123: }\n124: \n125: type APIErrorDetails struct {\n126: \tName   string          `json:\"name,omitempty\"`\n127: \tGroup  string          `json:\"group,omitempty\"`\n128: \tKind   string          `json:\"kind,omitempty\"`\n129: \tUID    string          `json:\"uid,omitempty\"`\n130: \tCauses []APIErrorCause `json:\"causes,omitempty\"`\n131: }\n132: \n133: type APIErrorCause struct {\n134: \tMessage string `json:\"message\"`\n135: \tField   string `json:\"field\"`\n136: }\n137: \n138: type PaginationRequest struct {\n139: \tLimit    int64  `form:\"limit\"`\n140: \tContinue string `form:\"continue\"`\n141: }\n142: \n143: type PaginationResponse struct {\n144: \tItems              interface{} `json:\"items\"`\n145: \tListMeta           *ListMeta   `json:\"metadata\"`\n146: \tRemainingItemCount *int64      `json:\"remainingItemCount,omitempty\"`\n147: }\n148: \n149: type AgentRuntimeListResponse struct {\n150: \tKind       string             `json:\"kind\"`\n151: \tAPIVersion string             `json:\"apiVersion\"`\n152: \tItems      []AgentRuntimeItem `json:\"items\"`\n153: \t*ListMeta\n154: }\n155: \n156: type AgentRuntimeItem struct {\n157: \tmetav1.TypeMeta   `json:\",inline\"`\n158: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n159: \tSpec              interface{} `json:\"spec,omitempty\"`\n160: \tStatus            interface{} `json:\"status,omitempty\"`\n161: }\n162: \n163: type CodeInterpreterListResponse struct {\n164: \tKind       string                `json:\"kind\"`\n165: \tAPIVersion string                `json:\"apiVersion\"`\n166: \tItems      []CodeInterpreterItem `json:\"items\"`\n167: \t*ListMeta\n168: }\n169: \n170: type CodeInterpreterItem struct {\n171: \tmetav1.TypeMeta   `json:\",inline\"`\n172: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n173: \tSpec              interface{} `json:\"spec,omitempty\"`\n174: \tStatus            interface{} `json:\"status,omitempty\"`\n175: }\n176: \n177: type CreateAgentRuntimeRequest struct {\n178: \tmetav1.TypeMeta   `json:\",inline\"`\n179: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n180: \tSpec              interface{} `json:\"spec,omitempty\"`\n181: }\n182: \n183: type CreateCodeInterpreterRequest struct {\n184: \tmetav1.TypeMeta   `json:\",inline\"`\n185: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n186: \tSpec              interface{} `json:\"spec,omitempty\"`\n187: }\n188: \n189: type UpdateAgentRuntimeRequest struct {\n190: \tmetav1.TypeMeta   `json:\",inline\"`\n191: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n192: \tSpec              interface{} `json:\"spec,omitempty\"`\n193: }\n194: \n195: type UpdateCodeInterpreterRequest struct {\n196: \tmetav1.TypeMeta   `json:\",inline\"`\n197: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n198: \tSpec              interface{} `json:\"spec,omitempty\"`\n199: }\n200: \n201: type WatchEvent struct {\n202: \tType   string      `json:\"type\"`\n203: \tObject interface{} `json:\"object\"`\n204: }\n205: \n206: func NewAPIResponse(data interface{}, metadata *ListMeta) *APIResponse {\n207: \treturn &APIResponse{\n208: \t\tKind:       \"Status\",\n209: \t\tAPIVersion: \"v1\",\n210: \t\tStatus:     \"Success\",\n211: \t\tData:       data,\n212: \t\tMetadata:   metadata,\n213: \t}\n214: }\n215: \n216: func NewAPIError(message, reason string, code int) *APIError {\n217: \treturn &APIError{\n218: \t\tKind:       \"Status\",\n219: \t\tAPIVersion: \"v1\",\n220: \t\tStatus:     \"Failure\",\n221: \t\tMessage:    message,\n222: \t\tReason:     reason,\n223: \t\tCode:       code,\n224: \t}\n225: }\n\n(End of file - total 225 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"errors\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nvar (\n\tErrSandboxNotFound    = errors.New(\"sandbox not found\")\n\tErrDeletionFailed     = errors.New(\"deletion failed\")\n\tErrStaleFinalizer     = errors.New(\"stale finalizer\")\n\tErrOrphanedResource   = errors.New(\"orphaned resource\")\n\tErrResourceNotFound   = errors.New(\"resource not found\")\n\tErrResourceNotDeleted = errors.New(\"resource not deleted\")\n)\n\ntype DeleteOptions struct {\n\tGracePeriodSeconds *int64 `form:\"gracePeriodSeconds,omitempty\" json:\"gracePeriodSeconds,omitempty\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/types.go","time":{"start":1775846118083,"end":1775846118109}}}}
{"type":"tool_use","timestamp":1775846118113,"sessionID":"ses_28753027dffeVp68suk2dqdsjB","part":{"id":"prt_d78ad4e10001VLdgnOfSyxUMmK","messageID":"msg_d78ad2e99001E5wMqKq5uNKIQ3","sessionID":"ses_28753027dffeVp68suk2dqdsjB","type":"tool","tool":"read","callID":"toolu_31a8e973324344c489c6f02d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/cleanup.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/cleanup.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \n7: \tcorev1 \"k8s.io/api/core/v1\"\n8: \t\"k8s.io/apimachinery/pkg/api/errors\"\n9: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n10: \t\"k8s.io/apimachinery/pkg/labels\"\n11: \t\"k8s.io/client-go/kubernetes\"\n12: \t\"k8s.io/klog/v2\"\n13: )\n14: \n15: type CleanupManager struct {\n16: \tk8sClient *kubernetes.Clientset\n17: }\n18: \n19: func NewCleanupManager(k8sClient *kubernetes.Clientset) *CleanupManager {\n20: \treturn &CleanupManager{\n21: \t\tk8sClient: k8sClient,\n22: \t}\n23: }\n24: \n25: func (cm *CleanupManager) cleanupServices(namespace string, ownerRef metav1.OwnerReference) ([]string, error) {\n26: \tcleaned := make([]string, 0)\n27: \n28: \tservices, err := cm.k8sClient.CoreV1().Services(namespace).List(context.Background(), metav1.ListOptions{})\n29: \tif err != nil {\n30: \t\treturn cleaned, fmt.Errorf(\"failed to list services: %w\", err)\n31: \t}\n32: \n33: \tfor _, svc := range services.Items {\n34: \t\tfor _, owner := range svc.OwnerReferences {\n35: \t\t\tif owner.UID == ownerRef.UID && owner.Kind == ownerRef.Kind && owner.Name == ownerRef.Name {\n36: \t\t\t\terr := cm.k8sClient.CoreV1().Services(namespace).Delete(context.Background(), svc.Name, metav1.DeleteOptions{})\n37: \t\t\t\tif err != nil {\n38: \t\t\t\t\tif !errors.IsNotFound(err) {\n39: \t\t\t\t\t\tklog.V(2).InfoS(\"Failed to delete service\", \"service\", svc.Name, \"error\", err)\n40: \t\t\t\t\t\tcontinue\n41: \t\t\t\t\t}\n42: \t\t\t\t}\n43: \t\t\t\tcleaned = append(cleaned, fmt.Sprintf(\"Service/%s\", svc.Name))\n44: \t\t\t\tklog.InfoS(\"Deleted service\", \"service\", svc.Name, \"namespace\", namespace)\n45: \t\t\t\tbreak\n46: \t\t\t}\n47: \t\t}\n48: \t}\n49: \n50: \treturn cleaned, nil\n51: }\n52: \n53: func (cm *CleanupManager) cleanupConfigMaps(namespace string, ownerRef metav1.OwnerReference) ([]string, error) {\n54: \tcleaned := make([]string, 0)\n55: \n56: \tconfigMaps, err := cm.k8sClient.CoreV1().ConfigMaps(namespace).List(context.Background(), metav1.ListOptions{})\n57: \tif err != nil {\n58: \t\treturn cleaned, fmt.Errorf(\"failed to list configmaps: %w\", err)\n59: \t}\n60: \n61: \tfor _, cfgMap := range configMaps.Items {\n62: \t\tannotations := cfgMap.GetAnnotations()\n63: \t\tif annotations == nil {\n64: \t\t\tcontinue\n65: \t\t}\n66: \n67: \t\tif annotations[\"agentcube.volcano.sh/auto-delete\"] != \"true\" {\n68: \t\t\tcontinue\n69: \t\t}\n70: \n71: \t\tfor _, owner := range cfgMap.OwnerReferences {\n72: \t\t\tif owner.UID == ownerRef.UID && owner.Kind == ownerRef.Kind && owner.Name == ownerRef.Name {\n73: \t\t\t\terr := cm.k8sClient.CoreV1().ConfigMaps(namespace).Delete(context.Background(), cfgMap.Name, metav1.DeleteOptions{})\n74: \t\t\t\tif err != nil {\n75: \t\t\t\t\tif !errors.IsNotFound(err) {\n76: \t\t\t\t\t\tklog.V(2).InfoS(\"Failed to delete configmap\", \"configmap\", cfgMap.Name, \"error\", err)\n77: \t\t\t\t\t\tcontinue\n78: \t\t\t\t\t}\n79: \t\t\t\t}\n80: \t\t\t\tcleaned = append(cleaned, fmt.Sprintf(\"ConfigMap/%s\", cfgMap.Name))\n81: \t\t\t\tklog.InfoS(\"Deleted configmap\", \"configmap\", cfgMap.Name, \"namespace\", namespace)\n82: \t\t\t\tbreak\n83: \t\t\t}\n84: \t\t}\n85: \t}\n86: \n87: \treturn cleaned, nil\n88: }\n89: \n90: func (cm *CleanupManager) cleanupPVCs(namespace string, ownerRef metav1.OwnerReference) ([]string, error) {\n91: \tcleaned := make([]string, 0)\n92: \n93: \tpvcs, err := cm.k8sClient.CoreV1().PersistentVolumeClaims(namespace).List(context.Background(), metav1.ListOptions{})\n94: \tif err != nil {\n95: \t\treturn cleaned, fmt.Errorf(\"failed to list pvcs: %w\", err)\n96: \t}\n97: \n98: \tfor _, pvc := range pvcs.Items {\n99: \t\tfor _, owner := range pvc.OwnerReferences {\n100: \t\t\tif owner.UID == ownerRef.UID && owner.Kind == ownerRef.Kind && owner.Name == ownerRef.Name {\n101: \t\t\t\tpvName := pvc.Spec.VolumeName\n102: \t\t\t\tif pvName != \"\" {\n103: \t\t\t\t\tpv, err := cm.k8sClient.CoreV1().PersistentVolumes().Get(context.Background(), pvName, metav1.GetOptions{})\n104: \t\t\t\t\tif err == nil && pv.Spec.PersistentVolumeReclaimPolicy == corev1.PersistentVolumeReclaimRetain {\n105: \t\t\t\t\t\tklog.V(4).InfoS(\"Retaining PVC due to PV ReclaimPolicy\", \"pvc\", pvc.Name, \"namespace\", namespace)\n106: \t\t\t\t\t\tcontinue\n107: \t\t\t\t\t}\n108: \t\t\t\t}\n109: \n110: \t\t\t\terr := cm.k8sClient.CoreV1().PersistentVolumeClaims(namespace).Delete(context.Background(), pvc.Name, metav1.DeleteOptions{})\n111: \t\t\t\tif err != nil {\n112: \t\t\t\t\tif !errors.IsNotFound(err) {\n113: \t\t\t\t\t\tklog.V(2).InfoS(\"Failed to delete pvc\", \"pvc\", pvc.Name, \"error\", err)\n114: \t\t\t\t\t\tcontinue\n115: \t\t\t\t\t}\n116: \t\t\t\t}\n117: \t\t\t\tcleaned = append(cleaned, fmt.Sprintf(\"PVC/%s\", pvc.Name))\n118: \t\t\t\tklog.InfoS(\"Deleted pvc\", \"pvc\", pvc.Name, \"namespace\", namespace)\n119: \t\t\t\tbreak\n120: \t\t\t}\n121: \t\t}\n122: \t}\n123: \n124: \treturn cleaned, nil\n125: }\n126: \n127: func (cm *CleanupManager) cleanupOrphanedResources(sandbox *Sandbox) ([]string, error) {\n128: \tcleaned := make([]string, 0)\n129: \townerRef := metav1.OwnerReference{\n130: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n131: \t\tKind:       \"AgentRuntime\",\n132: \t\tName:       sandbox.Name,\n133: \t\tUID:        \"\",\n134: \t}\n135: \n136: \tsvcCleaned, err := cm.cleanupServices(sandbox.Namespace, ownerRef)\n137: \tif err != nil {\n138: \t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n139: \t}\n140: \tcleaned = append(cleaned, svcCleaned...)\n141: \n142: \tcmCleaned, err := cm.cleanupConfigMaps(sandbox.Namespace, ownerRef)\n143: \tif err != nil {\n144: \t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n145: \t}\n146: \tcleaned = append(cleaned, cmCleaned...)\n147: \n148: \tpvcCleaned, err := cm.cleanupPVCs(sandbox.Namespace, ownerRef)\n149: \tif err != nil {\n150: \t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n151: \t}\n152: \tcleaned = append(cleaned, pvcCleaned...)\n153: \n154: \tklog.InfoS(\"Cleaned orphaned resources\", \"sandboxId\", sandbox.SessionID, \"count\", len(cleaned))\n155: \treturn cleaned, nil\n156: }\n157: \n158: func (cm *CleanupManager) CleanupAllResources(ctx context.Context, sandbox *Sandbox) ([]string, error) {\n159: \tallCleaned := make([]string, 0)\n160: \n161: \tsvcList, err := cm.cleanupServices(sandbox.Namespace, metav1.OwnerReference{\n162: \t\tName: sandbox.Name,\n163: \t})\n164: \tif err != nil {\n165: \t\tklog.V(2).InfoS(\"Error during service cleanup\", \"error\", err)\n166: \t}\n167: \tallCleaned = append(allCleaned, svcList...)\n168: \n169: \tcmList, err := cm.cleanupConfigMaps(sandbox.Namespace, metav1.OwnerReference{\n170: \t\tName: sandbox.Name,\n171: \t})\n172: \tif err != nil {\n173: \t\tklog.V(2).InfoS(\"Error during configmap cleanup\", \"error\", err)\n174: \t}\n175: \tallCleaned = append(allCleaned, cmList...)\n176: \n177: \tpvcList, err := cm.cleanupPVCs(sandbox.Namespace, metav1.OwnerReference{\n178: \t\tName: sandbox.Name,\n179: \t})\n180: \tif err != nil {\n181: \t\tklog.V(2).InfoS(\"Error during pvc cleanup\", \"error\", err)\n182: \t}\n183: \tallCleaned = append(allCleaned, pvcList...)\n184: \n185: \treturn allCleaned, nil\n186: }\n187: \n188: func (cm *CleanupManager) FindOrphanedServices(ctx context.Context, namespace string, sessionID string) ([]string, error) {\n189: \tselector := labels.SelectorFromSet(labels.Set{\"sessionId\": sessionID})\n190: \tservices, err := cm.k8sClient.CoreV1().Services(namespace).List(ctx, metav1.ListOptions{\n191: \t\tLabelSelector: selector.String(),\n192: \t})\n193: \tif err != nil {\n194: \t\treturn nil, err\n195: \t}\n196: \n197: \tcleanable := make([]string, 0)\n198: \tfor _, svc := range services.Items {\n199: \t\tif len(svc.OwnerReferences) == 0 {\n200: \t\t\tcleanable = append(cleanable, svc.Name)\n201: \t\t}\n202: \t}\n203: \n204: \treturn cleanable, nil\n205: }\n\n(End of file - total 205 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype CleanupManager struct {\n\tk8sClient *kubernetes.Clientset\n}\n\nfunc NewCleanupManager(k8sClient *kubernetes.Clientset) *CleanupManager {\n\treturn &CleanupManager{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/cleanup.go","time":{"start":1775846118089,"end":1775846118111}}}}
