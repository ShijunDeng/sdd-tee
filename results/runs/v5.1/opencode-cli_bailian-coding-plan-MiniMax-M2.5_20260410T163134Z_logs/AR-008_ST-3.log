: \t\t\tjson.Unmarshal(specBytes, &agentRuntime.Spec)\n340: \t\t}\n341: \t}\n342: \tif agentRuntime.Name == \"\" {\n343: \t\tagentRuntime.Name = name\n344: \t}\n345: \tif agentRuntime.Namespace == \"\" {\n346: \t\tagentRuntime.Namespace = namespace\n347: \t}\n348: \n349: \topts := metav1.UpdateOptions{}\n350: \tif err := c.ShouldBindQuery(&opts); err != nil {\n351: \t\tc.JSON(http.StatusBadRequest, NewAPIError(err.Error(), \"BadRequest\", http.StatusBadRequest))\n352: \t\treturn\n353: \t}\n354: \n355: \tresult, err := s.workloadMgr.UpdateAgentRuntime(c.Request.Context(), namespace, agentRuntime, opts)\n356: \tif err != nil {\n357: \t\ts.handleError(c, err)\n358: \t\treturn\n359: \t}\n360: \n361: \tc.JSON(http.StatusOK, AgentRuntimeItem{\n362: \t\tTypeMeta:   result.TypeMeta,\n363: \t\tObjectMeta: result.ObjectMeta,\n364: \t\tSpec:       result.Spec,\n365: \t\tStatus:     result.Status,\n366: \t})\n367: }\n368: \n369: func (s *Server) handleDeleteAgentRuntime(c *gin.Context) {\n370: \tnamespace := c.Param(\"namespace\")\n371: \tname := c.Param(\"name\")\n372: \n373: \topts := metav1.DeleteOptions{}\n374: \tif err := c.ShouldBindQuery(&opts); err != nil {\n375: \t\tc.JSON(http.StatusBadRequest, NewAPIError(err.Error(), \"BadRequest\", http.StatusBadRequest))\n376: \t\treturn\n377: \t}\n378: \n379: \terr := s.workloadMgr.DeleteAgentRuntime(c.Request.Context(), namespace, name, opts)\n380: \tif err != nil {\n381: \t\ts.handleError(c, err)\n382: \t\treturn\n383: \t}\n384: \n385: \tc.Status(http.StatusNoContent)\n386: }\n387: \n388: func (s *Server) handleGetAgentRuntimeStatus(c *gin.Context) {\n389: \tnamespace := c.Param(\"namespace\")\n390: \tname := c.Param(\"name\")\n391: \n392: \topts := metav1.GetOptions{}\n393: \tif err := c.ShouldBindQuery(&opts); err != nil {\n394: \t\tc.JSON(http.StatusBadRequest, NewAPIError(err.Error(), \"BadRequest\", http.StatusBadRequest))\n395: \t\treturn\n396: \t}\n397: \n398: \tstatus, err := s.workloadMgr.GetAgentRuntimeStatus(c.Reques