hOptions) (*agentcubev1alpha1.AgentRuntime, error) {\n80: \treturn m.client.RuntimeV1alpha1().AgentRuntimes(namespace).Patch(ctx, name, pt, data, opts, \"status\")\n81: }\n82: \n83: func (m *workloadManagerImpl) WatchAgentRuntimes(ctx context.Context, namespace string, opts metav1.ListOptions) (watch.Interface, error) {\n84: \topts.Watch = true\n85: \treturn m.client.RuntimeV1alpha1().AgentRuntimes(namespace).Watch(ctx, opts)\n86: }\n87: \n88: func (m *workloadManagerImpl) CreateCodeInterpreter(ctx context.Context, namespace string, codeInterpreter *agentcubev1alpha1.CodeInterpreter, opts metav1.CreateOptions) (*agentcubev1alpha1.CodeInterpreter, error) {\n89: \treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Create(ctx, codeInterpreter, opts)\n90: }\n91: \n92: func (m *workloadManagerImpl) GetCodeInterpreter(ctx context.Context, namespace, name string, opts metav1.GetOptions) (*agentcubev1alpha1.CodeInterpreter, error) {\n93: \treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Get(ctx, name, opts)\n94: }\n95: \n96: func (m *workloadManagerImpl) ListCodeInterpreters(ctx context.Context, namespace string, opts metav1.ListOptions) (*agentcubev1alpha1.CodeInterpreterList, error) {\n97: \treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, opts)\n98: }\n99: \n100: func (m *workloadManagerImpl) UpdateCodeInterpreter(ctx context.Context, namespace string, codeInterpreter *agentcubev1alpha1.CodeInterpreter, opts metav1.UpdateOptions) (*agentcubev1alpha1.CodeInterpreter, error) {\n101: \treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Update(ctx, codeInterpreter, opts)\n102: }\n103: \n104: func (m *workloadManagerImpl) DeleteCodeInterpreter(ctx context.Context, namespace, name string, opts metav1.DeleteOptions) error {\n105: \treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Delete(ctx, name, opts)\n106: }\n107: \n108: func (m *workloadManagerImpl) GetCodeInterpreterStatus(ctx context.Context, namespace, name string, opts metav1.GetOptions) (*agentcubev1alpha1.CodeInterpreterStatus, error) {\n109: \tci, err := m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Get(ctx, name, opts)\n110: \tif err != nil {\n111: \t\treturn nil, err\n112: \t}\n113: \treturn &ci.Status, nil\n114: }\n115: \n116: func (m *workloadManagerImpl) PatchCodeInterpreterStatus(ctx context.Context, namespace, name string, pt types.PatchType, data []byte, opts metav1.PatchOptions) (*agentcubev1alpha1.CodeInterpreter, error) {\n117: \treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Patch(ctx, name, pt, data, opts, \"status\")\n118: }\n119: \n120: func (m *workloadManagerImpl) WatchCodeInterpreters(ctx context.Context, namespace string, opts metav1.ListOptions) (watch.Interface, error) {\n121: \topts.Watch = true\n122: \treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Watch(ctx, opts)\n123: }\n124: \n125: func (m *workloadManagerImpl) Close() error {\n126: \tklog.Info(\"WorkloadManager closed\")\n127: \treturn nil\n128: }\n129: \n130: func (m *workloadManagerImpl) DeleteSandbox(ctx context.Context, namespace, sessionID string, opts DeleteOptions) error {\n131: \tdeleteOpts := metav1.DeleteOptions{}\n132: \tif opts.GracePeriodSeconds != nil {\n133: \t\tgracePeriodSeconds := *opts.GracePeriodSeconds\n134: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n135: \t}\n136: \tif opts.Force {\n137: \t\tdeleteOpts.GracePeriodSeconds = new(int64)\n138: \t\t*deleteOpts.GracePeriodSeconds = 0\n139: \t}\n140: \n141: \tlabelSelector := \"\"\n142: \tif opts.LabelSelector != \"\" {\n143: \t\tlabelSelector = opts.LabelSelector\n144: \t}\n145: \n146: \tars, err := m.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{\n147: \t\tLabelSelector: labelSelector,\n148: \t\tFieldSelector: \"\",\n149: \t})\n150: \tif err != nil {\n151: \t\treturn err\n152: \t}\n153: \n154: \tfor i := range ars.Items {\n155: \t\tar := &ars.Items[i]\n156: \t\tif ar.Labels != nil && ar.Labels[\"sessionId\"] == sessionID {\n157: \t\t\treturn m.client.RuntimeV1alpha1().AgentRuntimes(namespace).Delete(ctx, ar.Name, deleteOpts)\n158: \t\t}\n159: \t}\n160: \n161: \tcis, err := m.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{\n162: \t\tLabelSelector: labelSelector,\n163: \t\tFieldSelector: \"\",\n164: \t})\n165: \tif err != nil {\n166: \t\treturn err\n167: \t}\n168: \n169: \tfor i := range cis.Items {\n170: \t\tci := &cis.Items[i]\n171: \t\tif ci.Labels != nil && ci.Labels[\"sessionId\"] == sessionID {\n172: \t\t\treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Delete(ctx, ci.Name, deleteOpts)\n173: \t\t}\n174: \t}\n175: \n176: \treturn ErrSandboxNotFound\n177: }\n178: \n179: func (m *workloadManagerImpl) GetSandboxBySessionID(ctx context.Context, namespace, sessionID string) (*Sandbox, error) {\n180: \tars, err := m.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{})\n181: \tif err != nil {\n182: \t\treturn nil, err\n183: \t}\n184: \n185: \tfor i := range ars.Items {\n186: \t\tar := &ars.Items[i]\n187: \t\tif ar.Labels != nil && ar.Labels[\"sessionId\"] == sessionID {\n188: \t\t\treturn sandboxFromAgentRuntime(ar), nil\n189: \t\t}\n190: \t}\n191: \n192: \tcis, err := m.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{})\n193: \tif err != nil {\n194: \t\treturn nil, err\n195: \t}\n196: \n197: \tfor i := range cis.Items {\n198: \t\tci := &cis.Items[i]\n199: \t\tif ci.Labels != nil && ci.Labels[\"sessionId\"] == sessionID {\n200: \t\t\treturn sandboxFromCodeInterpreter(ci), nil\n201: \t\t}\n202: \t}\n203: \n204: \treturn nil, ErrSandboxNotFound\n205: }\n206: \n207: func (m *workloadManagerImpl) ListSandboxes(ctx context.Context, namespace string, opts ListOptions) (*SandboxList, error) {\n208: \tlist := &SandboxList{\n209: \t\tItems: make([]Sandbox, 0),\n210: \t}\n211: \n212: \tlabelSelector := \"\"\n213: \tif opts.LabelSelector != \"\" {\n214: \t\tlabelSelector = opts.LabelSelector\n215: \t}\n216: \n217: \tars, err := m.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{\n218: \t\tLabelSelector: labelSelector,\n219: \t\tFieldSelector: opts.FieldSelector,\n220: \t\tLimit:         opts.Limit,\n221: \t\tContinue:      opts.Continue,\n222: \t})\n223: \tif err != nil {\n224: \t\treturn nil, err\n225: \t}\n226: \n227: \tfor i := range ars.Items {\n228: \t\tlist.Items = append(list.Items, *sandboxFromAgentRuntime(&ars.Items[i]))\n229: \t}\n230: \n231: \tcis, err := m.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{\n232: \t\tLabelSelector: labelSelector,\n233: \t\tFieldSelector: opts.FieldSelector,\n234: \t\tLimit:         opts.Limit,\n235: \t\tContinue:      opts.Continue,\n236: \t})\n237: \tif err != nil {\n238: \t\treturn nil, err\n239: \t}\n240: \n241: \tfor i := range cis.Items {\n242: \t\tlist.Items = append(list.Items, *sandboxFromCodeInterpreter(&cis.Items[i]))\n243: \t}\n244: \n245: \treturn list, nil\n246: }\n247: \n248: func sandboxFromAgentRuntime(ar *agentcubev1alpha1.AgentRuntime) *Sandbox {\n249: \tstate := SandboxStateUnknown\n250: \tif len(ar.Status.Conditions) > 0 {\n251: \t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n252: \t\tif lastCondition.Status == \"True\" {\n253: \t\t\tif lastCondition.Reason == \"Running\" {\n254: \t\t\t\tstate = SandboxStateRunning\n255: \t\t\t} else if lastCondition.Reason == \"Failed\" {\n256: \t\t\t\tstate = SandboxStateFailed\n257: \t\t\t}\n258: \t\t}\n259: \t}\n260: \tif ar.DeletionTimestamp != nil {\n261: \t\tstate = SandboxStateDeleting\n262: \t}\n263: \n264: \treturn &Sandbox{\n265: \t\tName:        ar.Name,\n266: \t\tNamespace:   ar.Namespace,\n267: \t\tSessionID:   ar.Labels[\"sessionId\"],\n268: \t\tState:       state,\n269: \t\tCreatedAt:   ar.CreationTimestamp.Time,\n270: \t\tLabels:      ar.Labels,\n271: \t\tAnnotations: ar.Annotations,\n272: \t}\n273: }\n274: \n275: func sandboxFromCodeInterpreter(ci *agentcubev1alpha1.CodeInterpreter) *Sandbox {\n276: \tstate := SandboxStateUnknown\n277: \tif ci.Status.Ready {\n278: \t\tstate = SandboxStateRunning\n279: \t}\n280: \tif len(ci.Status.Conditions) > 0 {\n281: \t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n282: \t\tif lastCondition.Status == \"True\" {\n283: \t\t\tif lastCondition.Reason == \"Failed\" {\n284: \t\t\t\tstate = SandboxStateFailed\n285: \t\t\t}\n286: \t\t}\n287: \t}\n288: \tif ci.DeletionTimestamp != nil {\n289: \t\tstate = SandboxStateDeleting\n290: \t}\n291: \n292: \treturn &Sandbox{\n293: \t\tName:        ci.Name,\n294: \t\tNamespace:   ci.Namespace,\n295: \t\tSessionID:   ci.Labels[\"sessionId\"],\n296: \t\tState:       state,\n297: \t\tCreatedAt:   ci.CreationTimestamp.Time,\n298: \t\tLabels:      ci.Labels,\n299: \t\tAnnotations: ci.Annotations,\n300: \t}\n301: }\n\n(End of file - total 301 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"k8s.io/apimachinery/pkg/watch\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n)\n\ntype WorkloadManager interface {\n\tCreateAgentRuntime(ctx context.Context, namespace string, agentRuntime *agentcubev1alpha1.AgentRuntime, opts metav1.CreateOptions) (*agentcubev1alpha1.AgentRuntime, error)\n\tGetAgentRuntime(ctx context.Context, namespace, name string, opts metav1.GetOptions) (*agentcubev1alpha1.AgentRuntime, error)\n\tListAgentRuntimes(ctx context.Context, namespace string, opts metav1.ListOptions) (*agentcubev1alpha1.AgentRuntimeList, error)\n\tUpdateAgentRuntime(ctx context.Context, namespace string, agentRuntime *agentcubev1alpha1.AgentRuntime, opts metav1.UpdateOptions) (*agentcubev1alpha1.AgentRuntime, error)\n\tDeleteAgentRuntime(ctx context.Context, namespace, name string, opts metav1.DeleteOptions) error","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/service.go","time":{"start":1775846132483,"end":1775846132509}}}}
