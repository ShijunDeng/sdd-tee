ation\"`\n38: \n39: \t// +kubebuilder:validation:Required\n40: \t// +kubebuilder:validation:Pattern:=`^(\\d+m)|(\\d+h)(\\d+m)?$`\n41: \t// +kubebuilder:default:=\"15m\"\n42: \tSessionTimeout string `json:\"sessionTimeout\"`\n43: \n44: \t// +kubebuilder:validation:Required\n45: \t// +kubebuilder:validation:MinItems:=1\n46: \tTargetPorts []TargetPort `json:\"targetPorts\"`\n47: \n48: \t// +optional\n49: \tPodTemplate *PodTemplateSpec `json:\"podTemplate,omitempty\"`\n50: }\n51: \n52: // AgentRuntimeStatus defines the observed state of AgentRuntime.\n53: type AgentRuntimeStatus struct {\n54: \t// +optional\n55: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n56: \n57: \t// +optional\n58: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n59: }\n60: \n61: // +genclient\n62: // +kubebuilder:object:root=true\n63: // +kubebuilder:subresource:status\n64: // +kubebuilder:resource:shortName=ci\n65: \n66: // CodeInterpreter defines code execution environment specifications.\n67: type CodeInterpreter struct {\n68: \tmetav1.TypeMeta   `json:\",inline\"`\n69: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n70: \n71: \tSpec   CodeInterpreterSpec   `json:\"spec,omitempty\"`\n72: \tStatus CodeInterpreterStatus `json:\"status,omitempty\"`\n73: }\n74: \n75: // +kubebuilder:object:root=true\n76: \n77: // CodeInterpreterList contains a list of CodeInterpreter.\n78: type CodeInterpreterList struct {\n79: \tmetav1.TypeMeta `json:\",inline\"`\n80: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n81: \tItems           []CodeInterpreter `json:\"items\"`\n82: }\n83: \n84: // CodeInterpreterSpec defines the desired state of CodeInterpreter.\n85: type CodeInterpreterSpec struct {\n86: \t// +optional\n87: \t// +kubebuilder:validation:Enum=picod;none\n88: \t// +kubebuilder:default:=picod\n89: \tAuthMode AuthMode `json:\"authMode,omitempty\"`\n90: \n91: \t// +optional\n92: \t// +kubebuilder:validation:Pattern:=`^(\\d+h)(\\d+m)?$`\n93: \t// +kubebuilder:default:=\"8h\"\n94: \tMaxSessionDuration string `json:\"maxSessionDuration,omitempty\"`\n95: \n96: \t// +optional\n97: \t// +kubebuilder:validation:Pattern:=`^(\\d+m)|(\\d+h)(\\d+m)?$`\n98: \t// +kubebuilder:default:=\"15m\"\n99: \tSessionTimeout string `json:\"sessionTimeout,omitempty\"`\n100: \n101: \t// +optional\n102: \t// +kubebuilder:validation:MinItems:=0\n103: \tPorts []TargetPort `json:\"ports,omitempty\"`\n104: \n105: \t// +kubebuilder:validation:Required\n106: \tTemplate ContainerTemplateSpec `json:\"template\"`\n107: \n108: \t// +optional\n109: \t// +kubebuilder:default:=0\n110: \tWarmPoolSize int32 `json:\"warmPoolSize,omitempty\"`\n111: }\n112: \n113: // CodeInterpreterStatus defines the observed state of CodeInterpreter.\n114: type CodeInterpreterStatus struct {\n115: \t// +optional\n116: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n117: \n118: \t// +optional\n119: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n120: \n121: \t// +optional\n122: \tReady bool `json:\"ready\"`\n123: }\n124: \n125: // TargetPort defines port configuration for the runtime.\n126: type TargetPort struct {\n127: \t// +kubebuilder:validation:Required\n128: \t// +kubebuilder:validation:Minimum:=1\n129: \t// +kubebuilder:validation:Maximum:=65535\n130: \tPort int32 `json:\"port\"`\n131: \n132: \t// +kubebuilder:validation:Required\n133: \t// +kubebuilder:validation:Enum=HTTP;HTTPS\n134: \tProtocol string `json:\"protocol\"`\n135: \n136: \t// +optional\n137: \tName string `json:\"name,omitempty\"`\n138: \n139: \t// +optional\n140: \tPathPrefix string `json:\"pathPrefix,omitempty\"`\n141: }\n142: \n143: // PodTemplateSpec defines a custom pod template for the runtime.\n144: type PodTemplateSpec struct {\n145: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n146: \tSpec              *PodSpec `json:\"spec,omitempty\"`\n147: }\n148: \n149: // PodSpec is a selective subset of corev1.PodSpec.\n150: type PodSpec struct {\n151: \t// +optional\n152: \tContainers []ContainerSpec `json:\"containers,omitempty\"`\n153: \n154: \t// +optional\n155: \tVolumes []corev1.Volume `json:\" volumes,omitempty\"`\n156: \n157: \t// +optional\n158: \tRestartPolicy corev1.RestartPolicy `json:\"restartPolicy,omitempty\"`\n159: \n160: \t// +optional\n161: \tServiceAccountName string `json:\"serviceAccountName,omitempty\"`\n162: \n163: \t// +optional\n164: \tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n165: \n166: \t// +optional\n167: \tAffinity *corev1.Affinity `json:\"affinity,omitempty\"`\n168: \n169: \t// +optional\n170: \tTolerations []corev1.Toleration `json:\"tolerations,omitempty\"`\n171: \n172: \t// +optional\n173: \tPriorityClassName string `json:\"priorityClassName,omitempty\"`\n174: \n175: \t// +optional\n176: \tPriority *int32 `json:\"priority,omitempty\"`\n177: \n178: \t// +optional\n179: \tDNSPolicy corev1.DNSPolicy `json:\"dnsPolicy,omitempty\"`\n180: \n181: \t// +optional\n182: \tHostNetwork bool `json:\"hostNetwork,omitempty\"`\n183: \n184: \t// +optional\n185: \tHostPID bool `json:\"hostPID,omitempty\"`\n186: \n187: \t// +optional\n188: \tHostIPC bool `json:\"hostIPC,omitempty\"`\n189: \n190: \t// +optional\n191: \tSecurityContext *corev1.PodSecurityContext `json:\"securityContext,omitempty\"`\n192: \n193: \t// +optional\n194: \tImagePullSecrets []corev1.LocalObjectReference `json:\"imagePullSecrets,omitempty\"`\n195: \n196: \t// +optional\n197: \tInitContainers []ContainerSpec `json:\"initContainers,omitempty\"`\n198: }\n199: \n200: // ContainerSpec is a selective subset of corev1.Container.\n201: type ContainerSpec struct {\n202: \t// +kubebuilder:validation:Required\n203: \tName string `json:\"name\"`\n204: \n205: \t// +kubebuilder:validation:Required\n206: \tImage string `json:\"image\"`\n207: \n208: \t// +optional\n209: \tCommand []string `json:\"command,omitempty\"`\n210: \n211: \t// +optional\n212: \tArgs []string `json:\"args,omitempty\"`\n213: \n214: \t// +optional\n215: \tEnv []corev1.EnvVar `json:\"env,omitempty\"`\n216: \n217: \t// +optional\n218: \tResources corev1.ResourceRequirements `json:\"resources,omitempty\"`\n219: \n220: \t// +optional\n221: \tImagePullPolicy corev1.PullPolicy `json:\"imagePullPolicy,omitempty\"`\n222: \n223: \t// +optional\n224: \tPorts []corev1.ContainerPort `json:\"ports,omitempty\"`\n225: \n226: \t// +optional\n227: \tLivenessProbe *corev1.Probe `json:\"livenessProbe,omitempty\"`\n228: \n229: \t// +optional\n230: \tReadinessProbe *corev1.Probe `json:\"readinessProbe,omitempty\"`\n231: \n232: \t// +optional\n233: \tStartupProbe *corev1.Probe `json:\"startupProbe,omitempty\"`\n234: \n235: \t// +optional\n236: \tVolumeMounts []corev1.VolumeMount `json:\"volumeMounts,omitempty\"`\n237: \n238: \t// +optional\n239: \tSecurityContext *corev1.SecurityContext `json:\"securityContext,omitempty\"`\n240: }\n241: \n242: // ContainerTemplateSpec defines container specification for CodeInterpreter.\n243: type ContainerTemplateSpec struct {\n244: \t// +kubebuilder:validation:Required\n245: \tImage string `json:\"image\"`\n246: \n247: \t// +optional\n248: \tCommand []string `json:\"command,omitempty\"`\n249: \n250: \t// +optional\n251: \tArgs []string `json:\"args,omitempty\"`\n252: \n253: \t// +optional\n254: \tEnv []corev1.EnvVar `json:\"env,omitempty\"`\n255: \n256: \t// +optional\n257: \tResources corev1.ResourceRequirements `json:\"resources,omitempty\"`\n258: \n259: \t// +optional\n260: \tRuntimeClassName *string `json:\"runtimeClassName,omitempty\"`\n261: }\n262: \n263: // AuthMode defines the authentication mode for CodeInterpreter.\n264: type AuthMode string\n265: \n266: const (\n267: \t// AuthModePicod uses picod authentication.\n268: \tAuthModePicod AuthMode = \"picod\"\n269: \n270: \t// AuthModeNone means no authentication.\n271: \tAuthModeNone AuthMode = \"none\"\n272: )\n\n(End of file - total 272 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/