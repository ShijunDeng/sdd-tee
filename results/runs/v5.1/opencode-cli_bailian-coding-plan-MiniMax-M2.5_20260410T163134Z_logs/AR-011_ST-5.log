g struct {\n\tListenAddress       string        // Listen address for the HTTP server (default: \":8080\")\n\tBackendTimeout      time.Duration // Timeout for backend requests (default: 30s)\n\tIdleTimeout         time.Duration // Idle connection timeout (default: 60s)\n\tHealthCheckInterval time.Duration // Health check interval (default: 10s)\n\tHealthCheckTimeout  time.Duration // Health check request timeout (default: 5s)\n\tMaxConnsPerBackend  int           // Max connections per backend (default: 100)\n\tRateLimitEnabled    bool          // Enable rate limiting (default: false)\n\tRateLimitRPS        int           // Requests per second for rate limiting (default: 10)\n\tAuthEnabled         bool          // Enable authentication (default: false)\n\tAuthToken           string        // Bearer token for authentication\n\tWatchNamespaces     []string      // Namespaces to watch for CRs (empty = all)\n\n\t// Session management\n\tSessionEnabled         bool          // Enable session management (default: false)\n\tSessionTimeout         time.Duration // Session timeout (default: 30m)\n\tSessionCookieName      string        // Session cookie name (default: \"AGENTSESSIONID\")\n\tSessionMaxActive       int           // Max active sessions (default: 10000)\n\tSessionCookieSecure    bool          // Set cookie Secure flag (default: true)\n\tSessionCookieHTTPOnly  bool          // Set cookie HttpOnly flag (default: true)\n\tSessionCookieDomain    string        // Cookie domain (optional)\n\tSessionCleanupInterval time.Duration // Session cleanup interval (default: 5m)\n\n\t// JWT authentication\n\tJWTEnabled           bool          // Enable JWT authentication (default: false)\n\tJWTAlgorithm         string        // JWT algorithm: HS256, RS256 (default: \"HS256\")\n\tJWTSecret            string        // JWT secret for HS256 (default: \"\")\n\tJWTPrivateKeyPath    string        // Path to private key file for RS256\n\tJWTPublicKeyPath     string        // Path to public key file for RS256\n\tJWTIssuer            string        // JWT issuer (default: \"agentcube\")\n\tJWTAudience          []string      // JWT audience (default: nil)\n\tJWTExpiration        time.Duration // JWT token expiration (default: 1h)\n\tJWTRefreshExpiration time.Duration // JWT refresh token expiration (default: 24h)\n\tJWTClockSkew         time.Duration // Clock skew tolerance (default: 30s)\n\tJWTAllowQueryParam   bool          // Allow JWT in query parameter (default: false)\n}\n\nfunc DefaultConfig() *Config {\n\treturn &Config{\n\t\tListenAddress:          \":8080\",\n\t\tBackendTimeout:         30 * time.Second,\n\t\tIdleTimeout:            60 * time.Second,\n\t\tHealthCheckInterval:    10 * time.Second,\n\t\tHealthCheckTimeout:     5 * time.Second,\n\t\tMaxConnsPerBackend:     100,\n\t\tRateLimitEnabled:       false,\n\t\tRateLimitRPS:           10,\n\t\tAuthEnabled:            false,\n\t\tAuthToken:              \"\",\n\t\tWatchNamespaces:        nil,\n\t\tSessionEnabled:         false,\n\t\tSessionTimeout:         30 * time.Minute,\n\t\tSessionCookieName:      \"AGENTSESSIONID\",\n\t\tSessionMaxActive:       10000,\n\t\tSessionCookieSecure:    true,\n\t\tSessionCookieHTTPOnly:  true,\n\t\tSessionCookieDomain:    \"\",\n\t\tSessionCleanupInterval: 5 * time.Minute,\n\t}\n}\n","after":"package router\n\nimport (\n\t\"time\"\n)\n\ntype Config struct {\n\tListenAddress       string        // Listen address for the HTTP server (default: \":8080\")\n\tBackendTimeout      time.Duration // Timeout for backend requests (default: 30s)\n\tIdleTimeout         time.Duration // Idle connection timeout (default: 60s)\n\tHealthCheckInterval time.Duration // Health check interval (default: 10s)\n\tHealthCheckTimeout  time.Duration // Health check request timeout (default: 5s)\n\tMaxConnsPerBackend  int           // Max connections per backend (default: 100)\n\tRateLimitEnabled    bool          // Enable rate limiting (default: false)\n\tRateLimitRPS        int     