en\n54: }\n55: \n56: func (a *Authenticator) Enable() {\n57: \ta.enabled = true\n58: }\n59: \n60: func (a *Authenticator) Disable() {\n61: \ta.enabled = false\n62: }\n\n(End of file - total 62 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"strings\"\n)\n\ntype Authenticator struct {\n\ttoken   string\n\tenabled bool\n}\n\nfunc NewAuthenticator(token string, enabled bool) *Authenticator {\n\treturn &Authenticator{\n\t\ttoken:   token,\n\t\tenabled: enabled,\n\t}\n}\n\nfunc (a *Authenticator) Middleware(next http.Handler) http.Handler {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/auth.go","time":{"start":1775849648071,"end":1775849648084}}}}
