rity":1,"code":"UndeclaredImportedName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredImportedName"},"source":"compiler","message":"undefined: jwt.ValidationErrorExpired"},{"range":{"start":{"line":283,"character":30},"end":{"line":283,"character":61}},"severity":1,"code":"UndeclaredImportedName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredImportedName"},"source":"compiler","message":"undefined: jwt.ValidationErrorSignatureInvalid"},{"range":{"start":{"line":287,"character":30},"end":{"line":287,"character":53}},"severity":1,"code":"UndeclaredImportedName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredImportedName"},"source":"compiler","message":"undefined: jwt.ValidationErrorAudience"},{"range":{"start":{"line":291,"character":30},"end":{"line":291,"character":51}},"severity":1,"code":"UndeclaredImportedName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredImportedName"},"source":"compiler","message":"undefined: jwt.ValidationErrorIssuer"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_metrics.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_middleware.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_handler.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_test.go":[{"range":{"start":{"line":649,"character":7},"end":{"line":649,"character":14}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: context"}]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_test.go\n@@ -655,11 +655,8 @@\n \t}\n \t_ = retrievedClaims\n }\n \n-\t_ = ctx\n-}\n-\n func TestGetUsernameFromContext(t *testing.T) {\n \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n \tusername := GetUsernameFromContext(req)\n \tif username != \"\" {\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_test.go","before":"package router\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\ntype mockUserValidator struct {\n\tusers map[string]string\n}\n\nfunc newMockUserValidator() *mockUserValidator {\n\treturn &mockUserValidator{\n\t\tusers: map[string]string{\n\t\t\t\"admin\":    \"password\",\n\t\t\t\"testuser\": \"testpass\",\n\t\t},\n\t}\n}\n\nfunc (m *mockUserValidator) Validate(username, password string) (*UserClaims, error) {\n\tif storedPass, ok := m.users[username]; ok && storedPass == password {\n\t\troles := []string{\"user\"}\n\t\tif username == \"admin\" {\n\t\t\troles = []string{\"admin\", \"user\"}\n\t\t}\n\t\treturn &UserClaims{\n\t\t\tUsername:  username,\n\t\t\tRoles:     roles,\n\t\t\tTenantID:  \"default\",\n\t\t\tNamespace: \"default\",\n\t\t}, nil\n\t}\n\treturn nil, ErrInvalidCredentials\n}\n\nfunc TestNewJWTManager(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tconfig  *JWTConfig\n\t\twantErr bool\n\t\twantAlg string\n\t}{\n\t\t{\n\t\t\tname: \"default config\",\n\t\t\tconfig: &JWTConfig{\n\t\t\t\tAlgorithm: \"HS256\",\n\t\t\t\tSecret:    \"test-secret\",\n\t\t\t},\n\t\t\twantErr: false,\n\t\t\twantAlg: \"HS256\",\n\t\t},\n\t\t{\n\t\t\tname: \"missing secret\",\n\t\t\tconfig: &JWTConfig{\n\t\t\t\tAlgorithm: \"HS256\",\n\t\t\t},\n\t\t\twantErr: true,\n\t\t},\n\t\t{\n\t\t\tname:    \"default nil config\",\n\t\t\tconfig:  nil,\n\t\t\twantErr: false,\n\t\t\twantAlg: \"HS256\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tvalidator := newMockUserValidator()\n\t\t\tmanager, err := NewJWTManager(tt.config, validator)\n\t\t\tif (err != nil) != tt.wantErr {\n\t\t\t\tt.Errorf(\"NewJWTManager() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif !tt.wantErr && manager == nil {\n\t\t\t\tt.Error(\"NewJWTManager() returned nil manager\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestJWTManager_IssueToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:  \"HS256\",\n\t\tSecret:     \"test-secret-key\",\n\t\tIssuer:     \"agentcube\",\n\t\tAudience:   []string{\"agentcube-api\"},\n\t\tExpiration: 1 * time.Hour,\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tuser := &UserClaims{\n\t\tUsername:  \"testuser\",\n\t\tRoles:     []string{\"user\", \"admin\"},\n\t\tTenantID:  \"tenant1\",\n\t\tNamespace: \"ns1\",\n\t}\n\n\ttoken, err := manager.IssueToken(user)\n\tif err != nil {\n\t\tt.Fatalf(\"IssueToken() error = %v\", err)\n\t}\n\n\tif token == \"\" {\n\t\tt.Error(\"IssueToken() returned empty token\")\n\t}\n\n\tparts := strings.Split(token, \".\")\n\tif len(parts) != 3 {\n\t\tt.Errorf(\"IssueToken() returned invalid token format, got %d parts\", len(parts))\n\t}\n}\n\nfunc TestJWTManager_ValidateToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:  \"HS256\",\n\t\tSecret:     \"test-secret-key\",\n\t\tIssuer:     \"agentcube\",\n\t\tAudience:   []string{\"agentcube-api\"},\n\t\tExpiration: 1 * time.Hour,\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\n\ttoken, err := manager.IssueToken(user)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to issue token: %v\", err)\n\t}\n\n\tclaims, err := manager.ValidateToken(token)\n\tif err != nil {\n\t\tt.Errorf(\"ValidateToken() error = %v\", err)\n\t\treturn\n\t}\n\n\tif claims.Subject != \"testuser\" {\n\t\tt.Errorf(\"ValidateToken() subject = %v, want testuser\", claims.Subject)\n\t}\n\n\tif len(claims.Roles) != 1 || claims.Roles[0] != \"user\" {\n\t\tt.Errorf(\"ValidateToken() roles = %v, want [user]\", claims.Roles)\n\t}\n}\n\nfunc TestJWTManager_ValidateExpiredToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tnow := time.Now()\n\tclaims := &Claims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tExpiresAt: jwt.NewNumericDate(now.Add(-1 * time.Hour)),\n\t\t\tIssuedAt:  jwt.NewNumericDate(now.Add(-2 * time.Hour)),\n\t\t\tIssuer:    \"agentcube\",\n\t\t},\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n\texpiredToken, _ := token.SignedString([]byte(\"test-secret-key\"))\n\n\t_, err = manager.ValidateToken(expiredToken)\n\tif err != ErrTokenExpired {\n\t\tt.Errorf(\"ValidateToken() error = %v, want ErrTokenExpired\", err)\n\t}\n}\n\nfunc TestJWTManager_ValidateInvalidSignature(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\n\ttoken, _ := manager.IssueToken(user)\n\ttoken = token + \"invalid\"\n\n\t_, err = manager.ValidateToken(token)\n\tif err != ErrMalformedToken && err != ErrInvalidSignature {\n\t\tt.Errorf(\"ValidateToken() error = %v, want ErrMalformedToken or ErrInvalidSignature\", err)\n\t}\n}\n\nfunc TestJWTManager_ValidateMalformedToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\t_, err = manager.ValidateToken(\"not-a-valid-jwt-token\")\n\tif err != ErrMalformedToken {\n\t\tt.Errorf(\"ValidateToken() error = %v, want ErrMalformedToken\", err)\n\t}\n}\n\nfunc TestJWTManager_IssueAndRefreshToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:         \"HS256\",\n\t\tSecret:            \"test-secret-key\",\n\t\tIssuer:            \"agentcube\",\n\t\tExpiration:        1 * time.Hour,\n\t\tRefreshExpiration: 24 * time.Hour,\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\n\trefreshToken, err := manager.IssueRefreshToken(user)\n\tif err != nil {\n\t\tt.Fatalf(\"IssueRefreshToken() error = %v\", err)\n\t}\n\n\tclaims, err := manager.ValidateRefreshToken(refreshToken)\n\tif err != nil {\n\t\tt.Errorf(\"ValidateRefreshToken() error = %v\", err)\n\t\treturn\n\t}\n\n\tif claims.ID != \"refresh\" {\n\t\tt.Errorf(\"ValidateRefreshToken() ID = %v, want refresh\", claims.ID)\n\t}\n\n\tif claims.Subject != \"testuser\" {\n\t\tt.Errorf(\"ValidateRefreshToken() subject = %v, want testuser\", claims.Subject)\n\t}\n}\n\nfunc TestJWTMiddleware_ExtractFromHeader(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tmiddleware := NewJWTMiddleware(manager, nil, false)\n\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer test-token\")\n\n\ttoken, err := middleware.extractToken(req)\n\tif err != nil {\n\t\tt.Errorf(\"extractToken() error = %v\", err)\n\t}\n\tif token != \"test-token\" {\n\t\tt.Errorf(\"extractToken() token = %v, want test-token\", token)\n\t}\n}\n\nfunc TestJWTMiddleware_ExtractFromQueryParam(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tmiddleware := NewJWTMiddleware(manager, nil, true)\n\n\treq := httptest.NewRequest(\"GET\", \"/test?token=query-token\", nil)\n\n\ttoken, err := middleware.extractToken(req)\n\tif err != nil {\n\t\tt.Errorf(\"extractToken() error = %v\", err)\n\t}\n\tif token != \"query-token\" {\n\t\tt.Errorf(\"extractToken() token = %v, want query-token\", token)\n\t}\n}\n\nfunc TestJWTMiddleware_PublicPathBypass(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tpublicPaths := []string{\"/health\", \"/login\", \"/metrics\"}\n\tmiddleware := NewJWTMiddleware(manager, publicPaths, false)\n\n\ttests := []struct {\n\t\tpath     string\n\t\texpected bool\n\t}{\n\t\t{\"/health/live\", true},\n\t\t{\"/health/ready\", true},\n\t\t{\"/login\", true},\n\t\t{\"/metrics\", true},\n\t\t{\"/api/test\", false},\n\t\t{\"/protected\", false},\n\t}\n\n\tfor _, tt := range tests {\n\t\tresult := middleware.isPublicPath(tt.path)\n\t\tif result != tt.expected {\n\t\t\tt.Errorf(\"isPublicPath(%s) = %v, want %v\", tt.path, result, tt.expected)\n\t\t}\n\t}\n}\n\nfunc TestJWTMiddleware_ProtectedEndpointRejectsNoToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tmiddleware := NewJWTMiddleware(manager, []string{\"/health\"}, false)\n\n\tnext := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t})\n\n\thandler := middleware.Middleware(next)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/protected\", nil)\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusUnauthorized, rec.Code)\n\t}\n}\n\nfunc TestJWTMiddleware_ValidTokenPasses(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tmiddleware := NewJWTMiddleware(manager, []string{\"/health\"}, false)\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\ttoken, _ := manager.IssueToken(user)\n\n\tnext := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tclaims := GetClaimsFromContext(r)\n\t\tif claims == nil {\n\t\t\tt.Error(\"Claims should be available in context\")\n\t\t}\n\t\tw.WriteHeader(http.StatusOK)\n\t})\n\n\thandler := middleware.Middleware(next)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/protected\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusOK {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusOK, rec.Code)\n\t}\n}\n\nfunc TestLoginHandler_ValidCredentials(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:  \"HS256\",\n\t\tSecret:     \"test-secret-key\",\n\t\tIssuer:     \"agentcube\",\n\t\tExpiration: 1 * time.Hour,\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\thandler := NewLoginHandler(manager)\n\n\tbody := `{\"username\":\"admin\",\"password\":\"password\"}`\n\treq := httptest.NewRequest(\"POST\", \"/login\", strings.NewReader(body))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusOK {\n\t\tt.Errorf(\"Expected status %d, got %d. Body: %s\", http.StatusOK, rec.Code, rec.Body.String())\n\t}\n\n\tvar response LoginResponse\n\tif err := json.NewDecoder(rec.Body).Decode(&response); err != nil {\n\t\tt.Fatalf(\"Failed to decode response: %v\", err)\n\t}\n\n\tif response.AccessToken == \"\" {\n\t\tt.Error(\"AccessToken should not be empty\")\n\t}\n\tif response.RefreshToken == \"\" {\n\t\tt.Error(\"RefreshToken should not be empty\")\n\t}\n\tif response.TokenType != \"Bearer\" {\n\t\tt.Errorf(\"TokenType = %v, want Bearer\", response.TokenType)\n\t}\n}\n\nfunc TestLoginHandler_InvalidCredentials(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\thandler := NewLoginHandler(manager)\n\n\tbody := `{\"username\":\"admin\",\"password\":\"wrongpassword\"}`\n\treq := httptest.NewRequest(\"POST\", \"/login\", strings.NewReader(body))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusUnauthorized, rec.Code)\n\t}\n}\n\nfunc TestLoginHandler_InvalidBody(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\thandler := NewLoginHandler(manager)\n\n\treq := httptest.NewRequest(\"POST\", \"/login\", strings.NewReader(\"invalid json\"))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusBadRequest, rec.Code)\n\t}\n}\n\nfunc TestRefreshHandler_ValidToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:         \"HS256\",\n\t\tSecret:            \"test-secret-key\",\n\t\tIssuer:            \"agentcube\",\n\t\tExpiration:        1 * time.Hour,\n\t\tRefreshExpiration: 24 * time.Hour,\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\trefreshToken, _ := manager.IssueRefreshToken(user)\n\n\thandler := NewRefreshHandler(manager)\n\n\tbody := `{\"refresh_token\":\"` + refreshToken + `\"}`\n\treq := httptest.NewRequest(\"POST\", \"/refresh\", strings.NewReader(body))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusOK {\n\t\tt.Errorf(\"Expected status %d, got %d. Body: %s\", http.StatusOK, rec.Code, rec.Body.String())\n\t}\n\n\tvar response map[string]interface{}\n\tif err := json.NewDecoder(rec.Body).Decode(&response); err != nil {\n\t\tt.Fatalf(\"Failed to decode response: %v\", err)\n\t}\n\n\tif response[\"access_token\"] == nil {\n\t\tt.Error(\"access_token should be in response\")\n\t}\n}\n\nfunc TestRefreshHandler_ExpiredToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:         \"HS256\",\n\t\tSecret:            \"test-secret-key\",\n\t\tIssuer:            \"agentcube\",\n\t\tExpiration:        1 * time.Hour,\n\t\tRefreshExpiration: -1 * time.Hour,\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\trefreshToken, _ := manager.IssueRefreshToken(user)\n\n\thandler := NewRefreshHandler(manager)\n\n\tbody := `{\"refresh_token\":\"` + refreshToken + `\"}`\n\treq := httptest.NewRequest(\"POST\", \"/refresh\", strings.NewReader(body))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusUnauthorized, rec.Code)\n\t}\n}\n\nfunc TestConfig_DefaultValues(t *testing.T) {\n\tcfg := DefaultConfig()\n\n\tif cfg.JWTEnabled != false {\n\t\tt.Errorf(\"JWTEnabled = %v, want false\", cfg.JWTEnabled)\n\t}\n\tif cfg.JWTAlgorithm != \"HS256\" {\n\t\tt.Errorf(\"JWTAlgorithm = %v, want HS256\", cfg.JWTAlgorithm)\n\t}\n\tif cfg.JWTIssuer != \"agentcube\" {\n\t\tt.Errorf(\"JWTIssuer = %v, want agentcube\", cfg.JWTIssuer)\n\t}\n\tif cfg.JWTExpiration != 1*time.Hour {\n\t\tt.Errorf(\"JWTExpiration = %v, want 1h\", cfg.JWTExpiration)\n\t}\n\tif cfg.JWTRefreshExpiration != 24*time.Hour {\n\t\tt.Errorf(\"JWTRefreshExpiration = %v, want 24h\", cfg.JWTRefreshExpiration)\n\t}\n\tif cfg.JWTClockSkew != 30*time.Second {\n\t\tt.Errorf(\"JWTClockSkew = %v, want 30s\", cfg.JWTClockSkew)\n\t}\n}\n\nfunc TestJWTManager_WithRS256(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to generate RSA key: %v\", err)\n\t}\n\n\t_ = privateKey\n\n\tconfig := &JWTConfig{\n\t\tAlgorithm:  \"RS256\",\n\t\tSecret:     \"\",\n\t\tIssuer:     \"agentcube\",\n\t\tExpiration: 1 * time.Hour,\n\t}\n\n\tmanager, err := NewJWTManager(config, nil)\n\tif err != nil {\n\t\tt.Logf(\"RS256 without keys returns error as expected: %v\", err)\n\t\treturn\n\t}\n\n\tif manager != nil {\n\t\tuser := &UserClaims{\n\t\t\tUsername: \"testuser\",\n\t\t\tRoles:    []string{\"user\"},\n\t\t}\n\t\t_, err = manager.IssueToken(user)\n\t\tif err != nil {\n\t\t\tt.Logf(\"RS256 without keys cannot issue token: %v\", err)\n\t\t}\n\t}\n}\n\nfunc TestGetClaimsFromContext(t *testing.T) {\n\tclaims := &Claims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tSubject: \"testuser\",\n\t\t},\n\t\tRoles: []string{\"admin\"},\n\t}\n\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tctx := req.Context()\n\tctx = context.WithValue(ctx, ContextKeyClaims, claims)\n\n\tretrievedClaims := ctx.Value(ContextKeyClaims)\n\tif retrievedClaims == nil {\n\t\tt.Error(\"Claims should be available in context\")\n\t}\n\t_ = retrievedClaims\n}\n\n\t_ = ctx\n}\n\nfunc TestGetUsernameFromContext(t *testing.T) {\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tusername := GetUsernameFromContext(req)\n\tif username != \"\" {\n\t\tt.Errorf(\"Expected empty username, got %s\", username)\n\t}\n}\n\nfunc TestJWTMetrics(t *testing.T) {\n\tmetrics := NewJWTMetrics()\n\tif metrics == nil {\n\t\tt.Error(\"NewJWTMetrics() returned nil\")\n\t}\n\n\tmetrics.IncValidated(\"success\")\n\tmetrics.IncIssued()\n\tmetrics.IncRefreshed(\"success\")\n\tmetrics.IncValidationError(ErrCodeTokenExpired)\n}\n","after":"package router\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\ntype mockUserValidator struct {\n\tusers map[string]string\n}\n\nfunc newMockUserValidator() *mockUserValidator {\n\treturn &mockUserValidator{\n\t\tusers: map[string]string{\n\t\t\t\"admin\":    \"password\",\n\t\t\t\"testuser\": \"testpass\",\n\t\t},\n\t}\n}\n\nfunc (m *mockUserValidator) Validate(username, password string) (*UserClaims, error) {\n\tif storedPass, ok := m.users[username]; ok && storedPass == password {\n\t\troles := []string{\"user\"}\n\t\tif username == \"admin\" {\n\t\t\troles = []string{\"admin\", \"user\"}\n\t\t}\n\t\treturn &UserClaims{\n\t\t\tUsername:  username,\n\t\t\tRoles:     roles,\n\t\t\tTenantID:  \"default\",\n\t\t\tNamespace: \"default\",\n\t\t}, nil\n\t}\n\treturn nil, ErrInvalidCredentials\n}\n\nfunc TestNewJWTManager(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tconfig  *JWTConfig\n\t\twantErr bool\n\t\twantAlg string\n\t}{\n\t\t{\n\t\t\tname: \"default config\",\n\t\t\tconfig: &JWTConfig{\n\t\t\t\tAlgorithm: \"HS256\",\n\t\t\t\tSecret:    \"test-secret\",\n\t\t\t},\n\t\t\twantErr: false,\n\t\t\twantAlg: \"HS256\",\n\t\t},\n\t\t{\n\t\t\tname: \"missing secret\",\n\t\t\tconfig: &JWTConfig{\n\t\t\t\tAlgorithm: \"HS256\",\n\t\t\t},\n\t\t\twantErr: true,\n\t\t},\n\t\t{\n\t\t\tname:    \"default nil config\",\n\t\t\tconfig:  nil,\n\t\t\twantErr: false,\n\t\t\twantAlg: \"HS256\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tvalidator := newMockUserValidator()\n\t\t\tmanager, err := NewJWTManager(tt.config, validator)\n\t\t\tif (err != nil) != tt.wantErr {\n\t\t\t\tt.Errorf(\"NewJWTManager() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif !tt.wantErr && manager == nil {\n\t\t\t\tt.Error(\"NewJWTManager() returned nil manager\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestJWTManager_IssueToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:  \"HS256\",\n\t\tSecret:     \"test-secret-key\",\n\t\tIssuer:     \"agentcube\",\n\t\tAudience:   []string{\"agentcube-api\"},\n\t\tExpiration: 1 * time.Hour,\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tuser := &UserClaims{\n\t\tUsername:  \"testuser\",\n\t\tRoles:     []string{\"user\", \"admin\"},\n\t\tTenantID:  \"tenant1\",\n\t\tNamespace: \"ns1\",\n\t}\n\n\ttoken, err := manager.IssueToken(user)\n\tif err != nil {\n\t\tt.Fatalf(\"IssueToken() error = %v\", err)\n\t}\n\n\tif token == \"\" {\n\t\tt.Error(\"IssueToken() returned empty token\")\n\t}\n\n\tparts := strings.Split(token, \".\")\n\tif len(parts) != 3 {\n\t\tt.Errorf(\"IssueToken() returned invalid token format, got %d parts\", len(parts))\n\t}\n}\n\nfunc TestJWTManager_ValidateToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:  \"HS256\",\n\t\tSecret:     \"test-secret-key\",\n\t\tIssuer:     \"agentcube\",\n\t\tAudience:   []string{\"agentcube-api\"},\n\t\tExpiration: 1 * time.Hour,\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\n\ttoken, err := manager.IssueToken(user)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to issue token: %v\", err)\n\t}\n\n\tclaims, err := manager.ValidateToken(token)\n\tif err != nil {\n\t\tt.Errorf(\"ValidateToken() error = %v\", err)\n\t\treturn\n\t}\n\n\tif claims.Subject != \"testuser\" {\n\t\tt.Errorf(\"ValidateToken() subject = %v, want testuser\", claims.Subject)\n\t}\n\n\tif len(claims.Roles) != 1 || claims.Roles[0] != \"user\" {\n\t\tt.Errorf(\"ValidateToken() roles = %v, want [user]\", claims.Roles)\n\t}\n}\n\nfunc TestJWTManager_ValidateExpiredToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tnow := time.Now()\n\tclaims := &Claims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tExpiresAt: jwt.NewNumericDate(now.Add(-1 * time.Hour)),\n\t\t\tIssuedAt:  jwt.NewNumericDate(now.Add(-2 * time.Hour)),\n\t\t\tIssuer:    \"agentcube\",\n\t\t},\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n\texpiredToken, _ := token.SignedString([]byte(\"test-secret-key\"))\n\n\t_, err = manager.ValidateToken(expiredToken)\n\tif err != ErrTokenExpired {\n\t\tt.Errorf(\"ValidateToken() error = %v, want ErrTokenExpired\", err)\n\t}\n}\n\nfunc TestJWTManager_ValidateInvalidSignature(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\n\ttoken, _ := manager.IssueToken(user)\n\ttoken = token + \"invalid\"\n\n\t_, err = manager.ValidateToken(token)\n\tif err != ErrMalformedToken && err != ErrInvalidSignature {\n\t\tt.Errorf(\"ValidateToken() error = %v, want ErrMalformedToken or ErrInvalidSignature\", err)\n\t}\n}\n\nfunc TestJWTManager_ValidateMalformedToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\t_, err = manager.ValidateToken(\"not-a-valid-jwt-token\")\n\tif err != ErrMalformedToken {\n\t\tt.Errorf(\"ValidateToken() error = %v, want ErrMalformedToken\", err)\n\t}\n}\n\nfunc TestJWTManager_IssueAndRefreshToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:         \"HS256\",\n\t\tSecret:            \"test-secret-key\",\n\t\tIssuer:            \"agentcube\",\n\t\tExpiration:        1 * time.Hour,\n\t\tRefreshExpiration: 24 * time.Hour,\n\t}\n\n\tmanager, err := NewJWTManager(config, validator)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n\t}\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\n\trefreshToken, err := manager.IssueRefreshToken(user)\n\tif err != nil {\n\t\tt.Fatalf(\"IssueRefreshToken() error = %v\", err)\n\t}\n\n\tclaims, err := manager.ValidateRefreshToken(refreshToken)\n\tif err != nil {\n\t\tt.Errorf(\"ValidateRefreshToken() error = %v\", err)\n\t\treturn\n\t}\n\n\tif claims.ID != \"refresh\" {\n\t\tt.Errorf(\"ValidateRefreshToken() ID = %v, want refresh\", claims.ID)\n\t}\n\n\tif claims.Subject != \"testuser\" {\n\t\tt.Errorf(\"ValidateRefreshToken() subject = %v, want testuser\", claims.Subject)\n\t}\n}\n\nfunc TestJWTMiddleware_ExtractFromHeader(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tmiddleware := NewJWTMiddleware(manager, nil, false)\n\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer test-token\")\n\n\ttoken, err := middleware.extractToken(req)\n\tif err != nil {\n\t\tt.Errorf(\"extractToken() error = %v\", err)\n\t}\n\tif token != \"test-token\" {\n\t\tt.Errorf(\"extractToken() token = %v, want test-token\", token)\n\t}\n}\n\nfunc TestJWTMiddleware_ExtractFromQueryParam(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tmiddleware := NewJWTMiddleware(manager, nil, true)\n\n\treq := httptest.NewRequest(\"GET\", \"/test?token=query-token\", nil)\n\n\ttoken, err := middleware.extractToken(req)\n\tif err != nil {\n\t\tt.Errorf(\"extractToken() error = %v\", err)\n\t}\n\tif token != \"query-token\" {\n\t\tt.Errorf(\"extractToken() token = %v, want query-token\", token)\n\t}\n}\n\nfunc TestJWTMiddleware_PublicPathBypass(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tpublicPaths := []string{\"/health\", \"/login\", \"/metrics\"}\n\tmiddleware := NewJWTMiddleware(manager, publicPaths, false)\n\n\ttests := []struct {\n\t\tpath     string\n\t\texpected bool\n\t}{\n\t\t{\"/health/live\", true},\n\t\t{\"/health/ready\", true},\n\t\t{\"/login\", true},\n\t\t{\"/metrics\", true},\n\t\t{\"/api/test\", false},\n\t\t{\"/protected\", false},\n\t}\n\n\tfor _, tt := range tests {\n\t\tresult := middleware.isPublicPath(tt.path)\n\t\tif result != tt.expected {\n\t\t\tt.Errorf(\"isPublicPath(%s) = %v, want %v\", tt.path, result, tt.expected)\n\t\t}\n\t}\n}\n\nfunc TestJWTMiddleware_ProtectedEndpointRejectsNoToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tmiddleware := NewJWTMiddleware(manager, []string{\"/health\"}, false)\n\n\tnext := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t})\n\n\thandler := middleware.Middleware(next)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/protected\", nil)\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusUnauthorized, rec.Code)\n\t}\n}\n\nfunc TestJWTMiddleware_ValidTokenPasses(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\tmiddleware := NewJWTMiddleware(manager, []string{\"/health\"}, false)\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\ttoken, _ := manager.IssueToken(user)\n\n\tnext := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tclaims := GetClaimsFromContext(r)\n\t\tif claims == nil {\n\t\t\tt.Error(\"Claims should be available in context\")\n\t\t}\n\t\tw.WriteHeader(http.StatusOK)\n\t})\n\n\thandler := middleware.Middleware(next)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/protected\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusOK {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusOK, rec.Code)\n\t}\n}\n\nfunc TestLoginHandler_ValidCredentials(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:  \"HS256\",\n\t\tSecret:     \"test-secret-key\",\n\t\tIssuer:     \"agentcube\",\n\t\tExpiration: 1 * time.Hour,\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\thandler := NewLoginHandler(manager)\n\n\tbody := `{\"username\":\"admin\",\"password\":\"password\"}`\n\treq := httptest.NewRequest(\"POST\", \"/login\", strings.NewReader(body))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusOK {\n\t\tt.Errorf(\"Expected status %d, got %d. Body: %s\", http.StatusOK, rec.Code, rec.Body.String())\n\t}\n\n\tvar response LoginResponse\n\tif err := json.NewDecoder(rec.Body).Decode(&response); err != nil {\n\t\tt.Fatalf(\"Failed to decode response: %v\", err)\n\t}\n\n\tif response.AccessToken == \"\" {\n\t\tt.Error(\"AccessToken should not be empty\")\n\t}\n\tif response.RefreshToken == \"\" {\n\t\tt.Error(\"RefreshToken should not be empty\")\n\t}\n\tif response.TokenType != \"Bearer\" {\n\t\tt.Errorf(\"TokenType = %v, want Bearer\", response.TokenType)\n\t}\n}\n\nfunc TestLoginHandler_InvalidCredentials(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\thandler := NewLoginHandler(manager)\n\n\tbody := `{\"username\":\"admin\",\"password\":\"wrongpassword\"}`\n\treq := httptest.NewRequest(\"POST\", \"/login\", strings.NewReader(body))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusUnauthorized, rec.Code)\n\t}\n}\n\nfunc TestLoginHandler_InvalidBody(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm: \"HS256\",\n\t\tSecret:    \"test-secret-key\",\n\t\tIssuer:    \"agentcube\",\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\thandler := NewLoginHandler(manager)\n\n\treq := httptest.NewRequest(\"POST\", \"/login\", strings.NewReader(\"invalid json\"))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusBadRequest, rec.Code)\n\t}\n}\n\nfunc TestRefreshHandler_ValidToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:         \"HS256\",\n\t\tSecret:            \"test-secret-key\",\n\t\tIssuer:            \"agentcube\",\n\t\tExpiration:        1 * time.Hour,\n\t\tRefreshExpiration: 24 * time.Hour,\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\trefreshToken, _ := manager.IssueRefreshToken(user)\n\n\thandler := NewRefreshHandler(manager)\n\n\tbody := `{\"refresh_token\":\"` + refreshToken + `\"}`\n\treq := httptest.NewRequest(\"POST\", \"/refresh\", strings.NewReader(body))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusOK {\n\t\tt.Errorf(\"Expected status %d, got %d. Body: %s\", http.StatusOK, rec.Code, rec.Body.String())\n\t}\n\n\tvar response map[string]interface{}\n\tif err := json.NewDecoder(rec.Body).Decode(&response); err != nil {\n\t\tt.Fatalf(\"Failed to decode response: %v\", err)\n\t}\n\n\tif response[\"access_token\"] == nil {\n\t\tt.Error(\"access_token should be in response\")\n\t}\n}\n\nfunc TestRefreshHandler_ExpiredToken(t *testing.T) {\n\tvalidator := newMockUserValidator()\n\tconfig := &JWTConfig{\n\t\tAlgorithm:         \"HS256\",\n\t\tSecret:            \"test-secret-key\",\n\t\tIssuer:            \"agentcube\",\n\t\tExpiration:        1 * time.Hour,\n\t\tRefreshExpiration: -1 * time.Hour,\n\t}\n\n\tmanager, _ := NewJWTManager(config, validator)\n\n\tuser := &UserClaims{\n\t\tUsername: \"testuser\",\n\t\tRoles:    []string{\"user\"},\n\t}\n\trefreshToken, _ := manager.IssueRefreshToken(user)\n\n\thandler := NewRefreshHandler(manager)\n\n\tbody := `{\"refresh_token\":\"` + refreshToken + `\"}`\n\treq := httptest.NewRequest(\"POST\", \"/refresh\", strings.NewReader(body))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n\n\tif rec.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"Expected status %d, got %d\", http.StatusUnauthorized, rec.Code)\n\t}\n}\n\nfunc TestConfig_DefaultValues(t *testing.T) {\n\tcfg := DefaultConfig()\n\n\tif cfg.JWTEnabled != false {\n\t\tt.Errorf(\"JWTEnabled = %v, want false\", cfg.JWTEnabled)\n\t}\n\tif cfg.JWTAlgorithm != \"HS256\" {\n\t\tt.Errorf(\"JWTAlgorithm = %v, want HS256\", cfg.JWTAlgorithm)\n\t}\n\tif cfg.JWTIssuer != \"agentcube\" {\n\t\tt.Errorf(\"JWTIssuer = %v, want agentcube\", cfg.JWTIssuer)\n\t}\n\tif cfg.JWTExpiration != 1*time.Hour {\n\t\tt.Errorf(\"JWTExpiration = %v, want 1h\", cfg.JWTExpiration)\n\t}\n\tif cfg.JWTRefreshExpiration != 24*time.Hour {\n\t\tt.Errorf(\"JWTRefreshExpiration = %v, want 24h\", cfg.JWTRefreshExpiration)\n\t}\n\tif cfg.JWTClockSkew != 30*time.Second {\n\t\tt.Errorf(\"JWTClockSkew = %v, want 30s\", cfg.JWTClockSkew)\n\t}\n}\n\nfunc TestJWTManager_WithRS256(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to generate RSA key: %v\", err)\n\t}\n\n\t_ = privateKey\n\n\tconfig := &JWTConfig{\n\t\tAlgorithm:  \"RS256\",\n\t\tSecret:     \"\",\n\t\tIssuer:     \"agentcube\",\n\t\tExpiration: 1 * time.Hour,\n\t}\n\n\tmanager, err := NewJWTManager(config, nil)\n\tif err != nil {\n\t\tt.Logf(\"RS256 without keys returns error as expected: %v\", err)\n\t\treturn\n\t}\n\n\tif manager != nil {\n\t\tuser := &UserClaims{\n\t\t\tUsername: \"testuser\",\n\t\t\tRoles:    []string{\"user\"},\n\t\t}\n\t\t_, err = manager.IssueToken(user)\n\t\tif err != nil {\n\t\t\tt.Logf(\"RS256 without keys cannot issue token: %v\", err)\n\t\t}\n\t}\n}\n\nfunc TestGetClaimsFromContext(t *testing.T) {\n\tclaims := &Claims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tSubject: \"testuser\",\n\t\t},\n\t\tRoles: []string{\"admin\"},\n\t}\n\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tctx := req.Context()\n\tctx = context.WithValue(ctx, ContextKeyClaims, claims)\n\n\tretrievedClaims := ctx.Value(ContextKeyClaims)\n\tif retrievedClaims == nil {\n\t\tt.Error(\"Claims should be available in context\")\n\t}\n\t_ = retrievedClaims\n}\n\nfunc TestGetUsernameFromContext(t *testing.T) {\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tusername := GetUsernameFromContext(req)\n\tif username != \"\" {\n\t\tt.Errorf(\"Expected empty username, got %s\", username)\n\t}\n}\n\nfunc TestJWTMetrics(t *testing.T) {\n\tmetrics := NewJWTMetrics()\n\tif metrics == nil {\n\t\tt.Error(\"NewJWTMetrics() returned nil\")\n\t}\n\n\tmetrics.IncValidated(\"success\")\n\tmetrics.IncIssued()\n\tmetrics.IncRefreshed(\"success\")\n\tmetrics.IncValidationError(ErrCodeTokenExpired)\n}\n","additions":0,"deletions":3},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_test.go","time":{"start":1775849997789,"end":1775849997987}}}}
