,9 +1,8 @@\n package router\n \n import (\n \t\"encoding/json\"\n-\t\"errors\"\n \t\"net/http\"\n )\n \n type LoginHandler struct {\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_handler.go","before":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"net/http\"\n)\n\ntype LoginHandler struct {\n\tjwtManager *JWTManager\n}\n\nfunc NewLoginHandler(jwtManager *JWTManager) *LoginHandler {\n\treturn &LoginHandler{\n\t\tjwtManager: jwtManager,\n\t}\n}\n\nfunc (h *LoginHandler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tif r.Method != http.MethodPost {\n\t\thttp.Error(w, \"method not allowed\", http.StatusMethodNotAllowed)\n\t\treturn\n\t}\n\n\tvar credentials UserCredentials\n\tif err := json.NewDecoder(r.Body).Decode(&credentials); err != nil {\n\t\th.sendError(w, \"invalid request body\", http.StatusBadRequest, ErrCodeMalformedToken)\n\t\treturn\n\t}\n\n\tif credentials.Username == \"\" || credentials.Password == \"\" {\n\t\th.sendError(w, \"username and password are required\", http.StatusBadRequest, ErrCodeInvalidCredentials)\n\t\treturn\n\t}\n\n\tif h.jwtManager == nil || h.jwtManager.userValidator == nil {\n\t\th.sendError(w, \"authentication not configured\", http.StatusInternalServerError, ErrCodeUnauthorized)\n\t\treturn\n\t}\n\n\tuserClaims, err := h.jwtManager.userValidator.Validate(credentials.Username, credentials.Password)\n\tif err != nil {\n\t\th.sendError(w, \"invalid credentials\", http.StatusUnauthorized, ErrCodeInvalidCredentials)\n\t\treturn\n\t}\n\n\taccessToken, err := h.jwtManager.IssueToken(userClaims)\n\tif err != nil {\n\t\th.sendError(w, \"failed to issue token\", http.StatusInternalServerError, ErrCodeUnauthorized)\n\t\treturn\n\t}\n\n\trefreshToken, err := h.jwtManager.IssueRefreshToken(userClaims)\n\tif err != nil {\n\t\th.sendError(w, \"failed to issue refresh token\", http.StatusInternalServerError, ErrCodeUnauthorized)\n\t\treturn\n\t}\n\n\texpiresIn := int(h.jwtManager.config.Expiration.Seconds())\n\n\tresponse := LoginResponse{\n\t\tAccessToken:  accessToken,\n\t\tRefreshToken: refreshToken,\n\t\tTokenType:    \"Bearer\",\n\t\tExpiresIn:    expiresIn,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusOK)\n\tjson.NewEncoder(w).Encode(response)\n}\n\nfunc (h *LoginHandler) sendError(w http.ResponseWriter, message string, statusCode int, errorCode string) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(statusCode)\n\n\terrorResponse := map[string]string{\n\t\t\"error\":       message,\n\t\t\"error_code\":  errorCode,\n\t\t\"status_code\": string(rune(statusCode)),\n\t}\n\n\tjson.NewEncoder(w).Encode(errorResponse)\n}\n\ntype RefreshHandler struct {\n\tjwtManager *JWTManager\n}\n\nfunc NewRefreshHandler(jwtManager *JWTManager) *RefreshHandler {\n\treturn &RefreshHandler{\n\t\tjwtManager: jwtManager,\n\t}\n}\n\nfunc (h *RefreshHandler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tif r.Method != http.MethodPost {\n\t\thttp.Error(w, \"method not allowed\", http.StatusMethodNotAllowed)\n\t\treturn\n\t}\n\n\tvar refreshReq TokenRefreshRequest\n\tif err := json.NewDecoder(r.Body).Decode(&refreshReq); err != nil {\n\t\th.sendError(w, \"invalid request body\", http.StatusBadRequest, ErrCodeMalformedToken)\n\t\treturn\n\t}\n\n\tif refreshReq.RefreshToken == \"\" {\n\t\th.sendError(w, \"refresh token is required\", http.StatusBadRequest, ErrCodeInvalidRefreshToken)\n\t\treturn\n\t}\n\n\tif h.jwtManager == nil {\n\t\th.sendError(w, \"authentication not configured\", http.StatusInternalServerError, ErrCodeUnauthorized)\n\t\treturn\n\t}\n\n\tclaims, err := h.jwtManager.ValidateRefreshToken(refreshReq.RefreshToken)\n\tif err != nil {\n\t\th.sendError(w, \"invalid or expired refresh token\", http.StatusUnauthorized, ErrCodeInvalidRefreshToken)\n\t\treturn\n\t}\n\n\tuserClaims := &UserClaims{\n\t\tUsername:  claims.Subject,\n\t\tRoles:     claims.Roles,\n\t\tTenantID:  claims.TenantID,\n\t\tNamespace: claims.Namespace,\n\t}\n\n\taccessToken, err := h.jwtManager.IssueToken(userClaims)\n\tif err != nil {\n\t\th.sendError(w, \"failed to issue token\", http.StatusInternalServerError, ErrCodeUnauthorized)\n\t\treturn\n\t}\n\n\th.jwtManager.metrics.IncRefreshed(\"success\")\n\n\texpiresIn := int(h.jwtManager.config.Expiration.Seconds())\n\n\tresponse := map[string]interface{}{\n\t\t\"access_token\": accessToken,\n\t\t\"token_type\":   \"Bearer\",\n\t\t\"expires_in\":   expiresIn,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusOK)\n\tjson.NewEncoder(w).Encode(response)\n}\n\nfunc (h *RefreshHandler) sendError(w http.ResponseWriter, message string, statusCode int, errorCode string) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(statusCode)\n\n\tif h.jwtManager != nil && h.jwtManager.metrics != nil {\n\t\th.jwtManager.metrics.IncRefreshed(\"failure\")\n\t}\n\n\terrorResponse := map[string]string{\n\t\t\"error\":       message,\n\t\t\"error_code\":  errorCode,\n\t\t\"status_code\": string(rune(statusCode)),\n\t}\n\n\tjson.NewEncoder(w).Encode(errorResponse)\n}\n\nfunc HandleLogin(jwtManager *JWTManager) http.HandlerFunc {\n\thandler := NewLoginHandler(jwtManager)\n\treturn handler.ServeHTTP\n}\n\nfunc HandleRefresh(jwtManager *JWTManager) http.HandlerFunc {\n\thandler := NewRefreshHandler(jwtManager)\n\treturn handler.ServeHTTP\n}\n","after":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n)\n\ntype LoginHandler struct {\n\tjwtManager *JWTManager\n}\n\nfunc NewLoginHandler(jwtManager *JWTManager) *LoginHandler {\n\treturn &LoginHandler{\n\t\tjwtManager: jwtManager,\n\t}\n}\n\nfunc (h *LoginHandler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tif r.Method != http.MethodPost {\n\t\thttp.Error(w, \"method not allowed\", http.StatusMethodNotAllowed)\n\t\treturn\n\t}\n\n\tvar credentials UserCr