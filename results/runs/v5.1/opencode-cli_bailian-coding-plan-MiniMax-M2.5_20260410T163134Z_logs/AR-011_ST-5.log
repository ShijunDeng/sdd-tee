{"type":"tool_use","timestamp":1775849753853,"sessionID":"ses_2871d0c2fffeV7e35c0rS9T7Q1","part":{"id":"prt_d78e42b1e00174ydkZmS7EdhVn","messageID":"msg_d78e42033001W66c4RSPhsYctf","sessionID":"ses_2871d0c2fffeV7e35c0rS9T7Q1","type":"tool","tool":"write","callID":"toolu_e3167e548a984832b6ace314","state":{"status":"completed","input":{"content":"package router\n\nimport (\n\t\"crypto/ecdsa\"\n\t\"crypto/pem\"\n\t\"crypto/rsa\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nvar (\n\tErrMalformedToken       = errors.New(\"malformed token\")\n\tErrInvalidSignature     = errors.New(\"invalid signature\")\n\tErrTokenExpired         = errors.New(\"token has expired\")\n\tErrInvalidAudience      = errors.New(\"invalid audience\")\n\tErrInvalidIssuer        = errors.New(\"invalid issuer\")\n\tErrUnauthorized         = errors.New(\"unauthorized\")\n\tErrInvalidCredentials   = errors.New(\"invalid credentials\")\n\tErrInvalidRefreshToken  = errors.New(\"invalid or expired refresh token\")\n\tErrInvalidTokenType     = errors.New(\"invalid token type\")\n\tErrMissingKey           = errors.New(\"missing key configuration\")\n)\n\nconst (\n\tErrCodeMalformedToken       = \"MALFORMED_TOKEN\"\n\tErrCodeInvalidSignature     = \"INVALID_SIGNATURE\"\n\tErrCodeTokenExpired         = \"TOKEN_EXPIRED\"\n\tErrCodeInvalidAudience      = \"INVALID_AUDIENCE\"\n\tErrCodeInvalidIssuer        = \"INVALID_ISSUER\"\n\tErrCodeUnauthorized         = \"UNAUTHORIZED\"\n\tErrCodeInvalidCredentials   = \"INVALID_CREDENTIALS\"\n\tErrCodeInvalidRefreshToken  = \"INVALID_REFRESH_TOKEN\"\n\tErrCodeInvalidTokenType     = \"INVALID_TOKEN_TYPE\"\n)\n\ntype JWTConfig struct {\n\tAlgorithm          string\n\tSecret             string\n\tPrivateKeyPath     string\n\tPublicKeyPath      string\n\tIssuer             string\n\tAudience          []string\n\tExpiration         time.Duration\n\tRefreshExpiration time.Duration\n\tClockSkew          time.Duration\n\tAllowQueryParam    bool\n}\n\ntype Claims struct {\n\tjwt.RegisteredClaims\n\tRoles      []string `json:\"roles,omitempty\"`\n\tTenantID   string   `json:\"tenant_id,omitempty\"`\n\tNamespace string   `json:\"namespace,omitempty\"`\n}\n\ntype UserCredentials struct {\n\tUsername string `json:\"username\" binding:\"required\"`\n\tPassword string `json:\"password\" binding:\"required\"`\n}\n\ntype LoginResponse struct {\n\tAccessToken  string `json:\"access_token\"`\n\tRefreshToken string `json:\"refresh_token,omitempty\"`\n\tTokenType    string `json:\"token_type\"`\n\tExpiresIn    int    `json:\"expires_in\"`\n}\n\ntype TokenRefreshRequest struct {\n\tRefreshToken string `json:\"refresh_token\" binding:\"required\"`\n}\n\ntype UserValidator interface {\n\tValidate(username, password string) (*UserClaims, error)\n}\n\ntype UserClaims struct {\n\tUsername   string\n\tRoles      []string\n\tTenantID   string\n\tNamespace  string\n}\n\ntype JWTManager struct {\n\tconfig   *JWTConfig\n\tsecret   []byte\n\tprivateKey interface{}\n\tpublicKey interface{}\n\tmetrics  *JWTMetrics\n\tuserValidator UserValidator\n}\n\nfunc NewJWTManager(config *JWTConfig, validator UserValidator) (*JWTManager, error) {\n\tif config == nil {\n\t\tconfig = &JWTConfig{\n\t\t\tAlgorithm:          \"HS256\",\n\t\t\tIssuer:             \"agentcube\",\n\t\t\tExpiration:         1 * time.Hour,\n\t\t\tRefreshExpiration: 24 * time.Hour,\n\t\t\tClockSkew:          30 * time.Second,\n\t\t}\n\t}\n\n\tmanager := &JWTManager{\n\t\tconfig:        config,\n\t\tmetrics:       NewJWTMetrics(),\n\t\tuserValidator: validator,\n\t}\n\n\tif err := manager.loadKeys(); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn manager, nil\n}\n\nfunc (j *JWTManager) loadKeys() error {\n\talgorithm := strings.ToUpper(j.config.Algorithm)\n\n\tswitch algorithm {\n\tcase \"HS256\", \"HS384\", \"HS512\":\n\t\tif j.config.Secret == \"\" {\n\t\t\treturn ErrMissingKey\n\t\t}\n\t\tj.secret = []byte(j.config.Secret)\n\n\tcase \"RS256\", \"RS384\", \"RS512\":\n\t\tif j.config.PrivateKeyPath != \"\" {\n\t\t\tprivateKey, err := loadPrivateKey(j.config.PrivateKeyPath)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"failed to load private key: %w\", err)\n\t\t\t}\n\t\t\tj.privateKey = privateKey\n\t\t}\n\n\t\tif j.config.PublicKeyPath != \"\" {\n\t\t\tpublicKey, err := loadPublicKey(j.config.PublicKeyPath)\n\t\t\tif err != nil {\n\t\t\t\treturn fmt.Errorf(\"failed to load public key: %w\", err)\n\t\t\t}\n\t\t\tj.publicKey = publicKey\n\t\t}\n\n\t\tif j.privateKey == nil && j.publicKey == nil {\n\t\t\treturn ErrMissingKey\n\t\t}\n\n\tdefault:\n\t\treturn fmt.Errorf(\"unsupported algorithm: %s\", algorithm)\n\t}\n\n\treturn nil\n}\n\nfunc loadPrivateKey(path string) (interface{}, error) {\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tblock, _ := pem.Decode(data)\n\tif block == nil {\n\t\treturn nil, errors.New(\"failed to parse PEM block\")\n\t}\n\n\tif block.Type == \"RSA PRIVATE KEY\" {\n\t\treturn jwt.ParseRSAPrivateKeyFromPEM(data)\n\t}\n\tif block.Type == \"EC PRIVATE KEY\" {\n\t\treturn jwt.ParseECPrivateKeyFromPEM(data)\n\t}\n\n\treturn nil, fmt.Errorf(\"unsupported private key type: %s\", block.Type)\n}\n\nfunc loadPublicKey(path string) (interface{}, error) {\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tblock, _ := pem.Decode(data)\n\tif block == nil {\n\t\treturn nil, errors.New(\"failed to parse PEM block\")\n\t}\n\n\tif block.Type == \"RSA PUBLIC KEY\" || block.Type == \"PUBLIC KEY\" {\n\t\treturn jwt.ParseRSAPublicKeyFromPEM(data)\n\t}\n\tif block.Type == \"EC PUBLIC KEY\" {\n\t\treturn jwt.ParseECPublicKeyFromPEM(data)\n\t}\n\n\treturn nil, fmt.Errorf(\"unsupported public key type: %s\", block.Type)\n}\n\nfunc (j *JWTManager) ValidateToken(tokenString string) (*Claims, error) {\n\ttoken, err := jwt.ParseWithClaims(tokenString, &Claims{}, func(token *jwt.Token) (interface{}, error) {\n\t\treturn j.getSigningKey(token)\n\t}, jwt.WithIssuer(j.config.Issuer),\n\t\tj.WithAudience(j.config.Audience...),\n\t\tj.WithClockSkew(j.config.ClockSkew),\n\t\tj.WithInvalidKeyAs(false),\n\t)\n\n\tif err != nil {\n\t\treturn j.handleValidationError(err)\n\t}\n\n\tif !token.Valid {\n\t\tj.metrics.IncValidationError(ErrCodeMalformedToken)\n\t\treturn nil, ErrMalformedToken\n\t}\n\n\tclaims, ok := token.Claims.(*Claims)\n\tif !ok {\n\t\tj.metrics.IncValidationError(ErrCodeMalformedToken)\n\t\treturn nil, ErrMalformedToken\n\t}\n\n\tj.metrics.IncValidated(\"success\")\n\treturn claims, nil\n}\n\nfunc (j *JWTManager) getSigningKey(token *jwt.Token) (interface{}, error) {\n\talg := token.Method.Alg()\n\n\tswitch strings.ToUpper(alg) {\n\tcase \"HS256\", \"HS384\", \"HS512\":\n\t\treturn j.secret, nil\n\tcase \"RS256\", \"RS384\", \"RS512\":\n\t\tif j.publicKey != nil {\n\t\t\treturn j.publicKey, nil\n\t\t}\n\t\treturn nil, ErrMissingKey\n\tcase \"ES256\", \"ES384\":\n\t\tif j.publicKey != nil {\n\t\t\treturn j.publicKey, nil\n\t\t}\n\t\treturn nil, ErrMissingKey\n\t}\n\n\treturn nil, fmt.Errorf(\"unsupported algorithm: %s\", alg)\n}\n\nfunc (j *JWTManager) getSigningKeyForIssuance() (interface{}, error) {\n\talg := strings.ToUpper(j.config.Algorithm)\n\n\tswitch alg {\n\tcase \"HS256\", \"HS384\", \"HS512\":\n\t\treturn j.secret, nil\n\tcase \"RS256\", \"RS384\", \"RS512\":\n\t\tif j.privateKey != nil {\n\t\t\treturn j.privateKey, nil\n\t\t}\n\t\treturn nil, ErrMissingKey\n\tcase \"ES256\", \"ES384\":\n\t\tif j.privateKey != nil {\n\t\t\treturn j.privateKey, nil\n\t\t}\n\t\treturn nil, ErrMissingKey\n\t}\n\n\treturn nil, fmt.Errorf(\"unsupported algorithm: %s\", alg)\n}\n\nfunc (j *JWTManager) handleValidationError(err error) (*Claims, error) {\n\tvar validationErr *jwt.ValidationError\n\tif errors.As(err, &validationErr) {\n\t\tif validationErr.Errors&jwt.ValidationErrorMalformed != 0 {\n\t\t\tj.metrics.IncValidationError(ErrCodeMalformedToken)\n\t\t\treturn nil, ErrMalformedToken\n\t\t}\n\t\tif validationErr.Errors&jwt.ValidationErrorExpired != 0 {\n\t\t\tj.metrics.IncValidationError(ErrCodeTokenExpired)\n\t\t\treturn nil, ErrTokenExpired\n\t\t}\n\t\tif validationErr.Errors&jwt.ValidationErrorSignatureInvalid != 0 {\n\t\t\tj.metrics.IncValidationError(ErrCodeInvalidSignature)\n\t\t\treturn nil, ErrInvalidSignature\n\t\t}\n\t\tif validationErr.Errors&jwt.ValidationErrorAudience != 0 {\n\t\t\tj.metrics.IncValidationError(ErrCodeInvalidAudience)\n\t\t\treturn nil, ErrInvalidAudience\n\t\t}\n\t\tif validationErr.Errors&jwt.ValidationErrorIssuer != 0 {\n\t\t\tj.metrics.IncValidationError(ErrCodeInvalidIssuer)\n\t\t\treturn nil, ErrInvalidIssuer\n\t\t}\n\t}\n\n\tj.metrics.IncValidationError(ErrCodeUnauthorized)\n\treturn nil, ErrUnauthorized\n}\n\nfunc (j *JWTManager) IssueToken(user *UserClaims) (string, error) {\n\tnow := time.Now()\n\n\tclaims := &Claims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tExpiresAt: jwt.NewNumericDate(now.Add(j.config.Expiration)),\n\t\t\tIssuedAt:  jwt.NewNumericDate(now),\n\t\t\tNotBefore: jwt.NewNumericDate(now),\n\t\t\tIssuer:    j.config.Issuer,\n\t\t\tSubject:   user.Username,\n\t\t\tAudience:  jwt.ClaimStrings(j.config.Audience),\n\t\t},\n\t\tRoles:      user.Roles,\n\t\tTenantID:   user.TenantID,\n\t\tNamespace:  user.Namespace,\n\t}\n\n\tkey, err := j.getSigningKeyForIssuance()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.GetSigningMethod(j.config.Algorithm), claims)\n\tsignedToken, err := token.SignedString(key)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to sign token: %w\", err)\n\t}\n\n\tj.metrics.IncIssued()\n\treturn signedToken, nil\n}\n\nfunc (j *JWTManager) IssueRefreshToken(user *UserClaims) (string, error) {\n\tnow := time.Now()\n\n\tclaims := &Claims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tExpiresAt: jwt.NewNumericDate(now.Add(j.config.RefreshExpiration)),\n\t\t\tIssuedAt:  jwt.NewNumericDate(now),\n\t\t\tNotBefore: jwt.NewNumericDate(now),\n\t\t\tIssuer:    j.config.Issuer,\n\t\t\tSubject:   user.Username,\n\t\t\tID:        \"refresh\",\n\t\t\tAudience:  jwt.ClaimStrings(j.config.Audience),\n\t\t},\n\t\tRoles:      user.Roles,\n\t\tTenantID:   user.TenantID,\n\t\tNamespace:  user.Namespace,\n\t}\n\n\tkey, err := j.getSigningKeyForIssuance()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.GetSigningMethod(j.config.Algorithm), claims)\n\tsignedToken, err := token.SignedString(key)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to sign refresh token: %w\", err)\n\t}\n\n\treturn signedToken, nil\n}\n\nfunc (j *JWTManager) ValidateRefreshToken(tokenString string) (*Claims, error) {\n\tclaims, err := j.ValidateToken(tokenString)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif claims.ID != \"refresh\" {\n\t\treturn nil, ErrInvalidTokenType\n\t}\n\n\treturn claims, nil\n}\n\nfunc (j *JWTManager) GetMetrics() *JWTMetrics {\n\treturn j.metrics\n}\n\nfunc (j *JWTManager) IsRefreshToken(tokenString string) bool {\n\tclaims, err := j.ValidateToken(tokenString)\n\tif err != nil {\n\t\treturn false\n\t}\n\treturn claims.ID == \"refresh\"\n}\n\nfunc ParseJWTFromBody(body io.Reader) (*Claims, error) {\n\tvar claims Claims\n\tif err := json.NewDecoder(body).Decode(&claims); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &claims, nil\n}\n\nfunc GetClaimsFromContext(req *http.Request) *Claims {\n\tval := req.Context().Value(ContextKeyClaims)\n\tif claims, ok := val.(*Claims); ok {\n\t\treturn claims\n\t}\n\treturn nil\n}\n\nfunc GetUsernameFromContext(req *http.Request) string {\n\tval := req.Context().Value(ContextKeyUsername)\n\tif username, ok := val.(string); ok {\n\t\treturn username\n\t}\n\treturn \"\"\n}\n\nconst (\n\tContextKeyClaims  = \"jwt_claims\"\n\tContextKeyUsername = \"jwt_username\"\n)","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt.go"},"ou