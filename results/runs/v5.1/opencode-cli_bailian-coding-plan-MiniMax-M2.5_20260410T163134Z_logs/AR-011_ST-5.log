}\n\n\tsigCh := make(chan os.Signal, 1)\n\tsignal.Notify(sigCh, syscall.SIGINT, syscall.SIGTERM)\n\n\t<-sigCh\n\tfmt.Println(\"\\nReceived shutdown signal\")\n\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\treturn router.Shutdown(ctx)\n}\n","additions":4,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server.go","time":{"start":1775849869031,"end":1775849869219}}}}
