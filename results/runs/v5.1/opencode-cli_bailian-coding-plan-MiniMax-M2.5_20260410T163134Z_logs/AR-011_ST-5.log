{"type":"tool_use","timestamp":1775849803947,"sessionID":"ses_2871d0c2fffeV7e35c0rS9T7Q1","part":{"id":"prt_d78e55a380010TUwHLdYT8iyL6","messageID":"msg_d78e55263001Zk44YVzIHbvlat","sessionID":"ses_2871d0c2fffeV7e35c0rS9T7Q1","type":"tool","tool":"write","callID":"toolu_6deff6e820e34ca6937b03bc","state":{"status":"completed","input":{"content":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"net/http\"\n\t\"strings\"\n)\n\ntype JWTMiddleware struct {\n\tjwtManager    *JWTManager\n\tpublicPaths   []string\n\tallowQueryParam bool\n}\n\nfunc NewJWTMiddleware(jwtManager *JWTManager, publicPaths []string, allowQueryParam bool) *JWTMiddleware {\n\tif publicPaths == nil {\n\t\tpublicPaths = []string{\n\t\t\t\"/health/live\",\n\t\t\t\"/health/ready\",\n\t\t\t\"/metrics\",\n\t\t\t\"/login\",\n\t\t\t\"/refresh\",\n\t\t}\n\t}\n\n\treturn &JWTMiddleware{\n\t\tjwtManager:      jwtManager,\n\t\tpublicPaths:     publicPaths,\n\t\tallowQueryParam: allowQueryParam,\n\t}\n}\n\nfunc (m *JWTMiddleware) Middleware(next http.Handler) http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tif m.jwtManager == nil {\n\t\t\tnext.ServeHTTP(w, r)\n\t\t\treturn\n\t\t}\n\n\t\tif m.isPublicPath(r.URL.Path) {\n\t\t\tnext.ServeHTTP(w, r)\n\t\t\treturn\n\t\t}\n\n\t\ttoken, err := m.extractToken(r)\n\t\tif err != nil {\n\t\t\tm.sendError(w, ErrMalformedToken.Error(), http.StatusBadRequest, ErrCodeMalformedToken)\n\t\t\treturn\n\t\t}\n\n\t\tif token == \"\" {\n\t\t\tm.sendError(w, \"missing authorization token\", http.StatusUnauthorized, ErrCodeUnauthorized)\n\t\t\treturn\n\t\t}\n\n\t\tclaims, err := m.jwtManager.ValidateToken(token)\n\t\tif err != nil {\n\t\t\tstatusCode := http.StatusUnauthorized\n\t\t\terrorCode := ErrCodeUnauthorized\n\n\t\t\tif errors.Is(err, ErrTokenExpired) {\n\t\t\t\terrorCode = ErrCodeTokenExpired\n\t\t\t} else if errors.Is(err, ErrInvalidSignature) {\n\t\t\t\terrorCode = ErrCodeInvalidSignature\n\t\t\t} else if errors.Is(err, ErrInvalidAudience) {\n\t\t\t\terrorCode = ErrCodeInvalidAudience\n\t\t\t} else if errors.Is(err, ErrMalformedToken) {\n\t\t\t\terrorCode = ErrCodeMalformedToken\n\t\t\t\tstatusCode = http.StatusBadRequest\n\t\t\t}\n\n\t\t\tm.sendError(w, err.Error(), statusCode, errorCode)\n\t\t\treturn\n\t\t}\n\n\t\tctx := context.WithValue(r.Context(), ContextKeyClaims, claims)\n\t\tctx = context.WithValue(ctx, ContextKeyUsername, claims.Subject)\n\n\t\tnext.ServeHTTP(w, r.WithContext(ctx))\n\t})\n}\n\nfunc (m *JWTMiddleware) extractToken(r *http.Request) (string, error) {\n\tauthHeader := r.Header.Get(\"Authorization\")\n\tif authHeader != \"\" {\n\t\tparts := strings.SplitN(authHeader, \" \", 2)\n\t\tif len(parts) == 2 && strings.ToLower(parts[0]) == \"bearer\" {\n\t\t\treturn parts[1], nil\n\t\t}\n\t}\n\n\tif m.allowQueryParam {\n\t\ttoken := r.URL.Query().Get(\"token\")\n\t\tif token != \"\" {\n\t\t\treturn token, nil\n\t\t}\n\t}\n\n\tauthHeader = r.Header.Get(\"Authorization\")\n\tif authHeader == \"\" && !m.allowQueryParam {\n\t\treturn \"\", nil\n\t}\n\n\tif authHeader != \"\" && !strings.HasPrefix(strings.ToLower(authHeader), \"bearer \") {\n\t\treturn \"\", ErrMalformedToken\n\t}\n\n\treturn \"\", nil\n}\n\nfunc (m *JWTMiddleware) isPublicPath(path string) bool {\n\tfor _, publicPath := range m.publicPaths {\n\t\tif strings.HasPrefix(path, publicPath) {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\nfunc (m *JWTMiddleware) sendError(w http.ResponseWriter, message string, statusCode int, errorCode string) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(statusCode)\n\n\terrorResponse := map[string]string{\n\t\t\"error\":       message,\n\t\t\"error_code\":  errorCode,\n\t\t\"status_code\": string(rune(statusCode)),\n\t}\n\n\tjson.NewEncoder(w).Encode(errorResponse)\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt_middleware.go"},"output