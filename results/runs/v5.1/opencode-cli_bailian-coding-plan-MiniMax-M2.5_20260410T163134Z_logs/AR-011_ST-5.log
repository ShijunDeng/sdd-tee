 limiting (default: false)\n\tRateLimitRPS        int           // Requests per second for rate limiting (default: 10)\n\tAuthEnabled         bool          // Enable authentication (default: false)\n\tAuthToken           string        // Bearer token for authentication\n\tWatchNamespaces     []string      // Namespaces to watch for CRs (empty = all)\n\n\t// Session management","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/config.go","time":{"start":1775849648066,"end":1775849648081}}}}
{"type":"tool_use","timestamp":1775849648084,"sessionID":"ses_2871d0c2fffeV7e35c0rS9T7Q1","part":{"id":"prt_d78e328c6001414itHNwA7DaOs","messageID":"msg_d78e314bd001Pz6V6WFOjvyJ5S","sessionID":"ses_2871d0c2fffeV7e35c0rS9T7Q1","type":"tool","tool":"read","callID":"toolu_989a862ce32543649b26cb6d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"os\"\n8: \t\"os/signal\"\n9: \t\"syscall\"\n10: \t\"time\"\n11: )\n12: \n13: type Router struct {\n14: \tconfig         *Config\n15: \tserver         *http.Server\n16: \tpool           *BackendPool\n17: \tproxy          *Proxy\n18: \trouteHandler   *RouteHandler\n19: \thealthChecker  *HealthChecker\n20: \trateLimiter    *RateLimiter\n21: \tauthenticator  *Authenticator\n22: \tlogger         *Logger\n23: \tmetrics        *Metrics\n24: \tsessionManager *SessionManager\n25: \tsessionHandler *SessionHandler\n26: }\n27: \n28: func NewRouter(config *Config) *Router {\n29: \tif config == nil {\n30: \t\tconfig = DefaultConfig()\n31: \t}\n32: \n33: \tpool := NewBackendPool()\n34: \tproxy := NewProxy(config.BackendTimeout, config.IdleTimeout, config.MaxConnsPerBackend)\n35: \trouteHandler := NewRouteHandler(pool, []string{\"X-Backend\", \"Content-Type\"})\n36: \thealthChecker := NewHealthChecker(pool, config.HealthCheckInterval, config.HealthCheckTimeout, 3)\n37: \trateLimiter := NewRateLimiter(config.RateLimitRPS, config.RateLimitRPS*2, config.RateLimitEnabled)\n38: \tauthenticator := NewAuthenticator(config.AuthToken, config.AuthEnabled)\n39: \tlogger := NewLogger(nil)\n40: \tmetrics := NewMetrics()\n41: \n42: \tvar sessionManager *SessionManager\n43: \tvar sessionHandler *SessionHandler\n44: \tif config.SessionEnabled {\n45: \t\tsessionManager = NewSessionManager(config)\n46: \t\tsessionHandler = NewSessionHandler(sessionManager)\n47: \t}\n48: \n49: \trouter := &Router{\n50: \t\tconfig:         config,\n51: \t\tpool:           pool,\n52: \t\tproxy:          proxy,\n53: \t\trouteHandler:   routeHandler,\n54: \t\thealthChecker:  healthChecker,\n55: \t\trateLimiter:    rateLimiter,\n56: \t\tauthenticator:  authenticator,\n57: \t\tlogger:         logger,\n58: \t\tmetrics:        metrics,\n59: \t\tsessionManager: sessionManager,\n60: \t\tsessionHandler: sessionHandler,\n61: \t}\n62: \n63: \tmux := http.NewServeMux()\n64: \tmux.HandleFunc(\"/\", router.handleRequest)\n65: \n66: \tif sessionHandler != nil {\n67: \t\tmux.Handle(\"/v1/sessions\", sessionHandler)\n68: \t}\n69: \n70: \thandler := logger.Middleware(mux)\n71: \thandler = rateLimiter.Middleware(handler)\n72: \thandler = authenticator.Middleware(handler)\n73: \n74: \tif sessionManager != nil {\n75: \t\thandler = sessionManager.Middleware(handler)\n76: \t}\n77: \n78: \trouter.server = &http.Server{\n79: \t\tAddr:         config.ListenAddress,\n80: \t\tHandler:      handler,\n81: \t\tReadTimeout:  config.BackendTimeout,\n82: \t\tWriteTimeout: config.BackendTimeout,\n83: \t\tIdleTimeout:  config.IdleTimeout,\n84: \t}\n85: \n86: \treturn router\n87: }\n88: \n89: func (r *Router) Start() error {\n90: \tgo func() {\n91: \t\tfmt.Printf(\"Starting router on %s\\n\", r.config.ListenAddress)\n92: \t\tif err := r.server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n93: \t\t\tfmt.Printf(\"Server error: %v\\n\", err)\n94: \t\t}\n95: \t}()\n96: \n97: \tr.healthChecker.Start()\n98: \n99: \tif r.sessionManager != nil {\n100: \t\tr.sessionManager.StartCleanup()\n101: \t}\n102: \n103: \treturn nil\n104: }\n105: \n106: func (r *Router) Shutdown(ctx context.Context) error {\n107: \tr.healthChecker.Stop()\n108: \n109: \tif r.sessionManager != nil {\n110: \t\tr.sessionManager.StopCleanup()\n111: \t}\n112: \n113: \tfmt.Println(\"Shutting down router...\")\n114: \treturn r.server.Shutdown(ctx)\n115: }\n116: \n117: func (r *Router) handleRequest(w http.ResponseWriter, req *http.Request) {\n118: \tstart := time.Now()\n119: \n120: \tvar backend *Backend\n121: \n122: \tif r.sessionManager != nil {\n123: \t\tsessionBackendKey := req.Header.Get(\"X-Session-Backend\")\n124: \t\tif sessionBackendKey != \"\" {\n125: \t\t\tbackend = r.pool.GetBackendByPath(sessionBackendKey)\n126: \t\t}\n127: \t}\n128: \n129: \tif backend == nil {\n130: \t\tbackend = r.routeHandler.GetBackendForRequest(req)\n131: \t}\n132: \n133: \tif backend == nil {\n134: \t\tr.metrics.IncErrors(\"not_found\")\n135: \t\tw.WriteHeader(http.StatusNotFound)\n136: \t\treturn\n137: \t}\n138: \n139: \tr.proxy.ServeHTTP(w, req, backend)\n140: \n141: \tduration := time.Since(start).Seconds()\n142: \tr.metrics.RecordRequestDuration(req.Method, req.URL.Path, backend.Name, duration)\n143: \tr.metrics.IncBackendRequests(backend.Name, \"success\")\n144: }\n145: \n146: func (r *Router) GetPool() *BackendPool {\n147: \treturn r.pool\n148: }\n149: \n150: func (r *Router) GetConfig() *Config {\n151: \treturn r.config\n152: }\n153: \n154: func (r *Router) GetHealthChecker() *HealthChecker {\n155: \treturn r.healthChecker\n156: }\n157: \n158: func (r *Router) GetMetrics() *Metrics {\n159: \treturn r.metrics\n160: }\n161: \n162: func (r *Router) AddBackend(key, endpoint, pathPrefix, name string) error {\n163: \treturn r.pool.AddBackend(key, endpoint, pathPrefix, name)\n164: }\n165: \n166: func (r *Router) RemoveBackend(key string) {\n167: \tr.pool.RemoveBackend(key)\n168: }\n169: \n170: func (r *Router) SetHeaderRoute(headerName, headerValue, backendKey string) {\n171: \tr.pool.SetHeaderRoute(headerName, headerValue, backendKey)\n172: }\n173: \n174: func (r *Router) GetSessionManager() *SessionManager {\n175: \treturn r.sessionManager\n176: }\n177: \n178: func RunWithSignal(cfg *Config) error {\n179: \trouter := NewRouter(cfg)\n180: \n181: \tif err := router.Start(); err != nil {\n182: \t\treturn err\n183: \t}\n184: \n185: \tsigCh := make(chan os.Signal, 1)\n186: \tsignal.Notify(sigCh, syscall.SIGINT, syscall.SIGTERM)\n187: \n188: \t<-sigCh\n189: \tfmt.Println(\"\\nReceived shutdown signal\")\n190: \n191: \tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n192: \tdefer cancel()\n193: \n194: \treturn router.Shutdown(ctx)\n195: }\n\n(End of file - total 195 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\t\"time\"\n)\n\ntype Router struct {\n\tconfig         *Config\n\tserver         *http.Server\n\tpool           *BackendPool\n\tproxy          *Proxy\n\trouteHandler   *RouteHandler\n\thealthChecker  *HealthChecker\n\trateLimiter    *RateLimiter","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server.go","time":{"start":1775849648069,"end":1775849648082}}}}
