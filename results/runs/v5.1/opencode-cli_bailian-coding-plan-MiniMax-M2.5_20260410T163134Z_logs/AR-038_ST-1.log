\n517: \t\t\t\tImage: \"python:3.9\",\n518: \t\t\t},\n519: \t\t},\n520: \t}\n521: \n522: \t_, err := wm.CreateCodeInterpreter(ctx, \"default\", ci, metav1.CreateOptions{})\n523: \tif err != nil {\n524: \t\tt.Fatalf(\"CreateCodeInterpreter failed: %v\", err)\n525: \t}\n526: \n527: \tci.Spec.AuthMode = agentcubev1alpha1.AuthModePicod\n528: \tresult, err := wm.UpdateCodeInterpreter(ctx, \"default\", ci, metav1.UpdateOptions{})\n529: \tif err != nil {\n530: \t\tt.Errorf(\"UpdateCodeInterpreter failed: %v\", err)\n531: \t}\n532: \n533: \tif result.Spec.AuthMode != agentcubev1alpha1.AuthModePicod {\n534: \t\tt.Errorf(\"Expected AuthMode picod, got %s\", result.Spec.AuthMode)\n535: \t}\n536: }\n537: \n538: func TestWorkloadManagerDeleteCodeInterpreter(t *testing.T) {\n539: \twm := newTestWorkloadManager()\n540: \tctx := context.Background()\n541: \n542: \tci := &agentcubev1alpha1.CodeInterpreter{\n543: \t\tObjectMeta: metav1.ObjectMeta{\n544: \t\t\tName:      \"test-ci\",\n545: \t\t\tNamespace: \"default\",\n546: \t\t},\n547: \t\tSpec: agentcubev1alpha1.CodeInterpreterSpec{\n548: \t\t\tTemplate: agentcubev1alpha1.ContainerTemplateSpec{\n549: \t\t\t\tImage: \"python:3.9\",\n550: \t\t\t},\n551: \t\t},\n552: \t}\n553: \n554: \t_, err := wm.CreateCodeInterpreter(ctx, \"default\", ci, metav1.CreateOptions{})\n555: \tif err != nil {\n556: \t\tt.Fatalf(\"CreateCodeInterpreter failed: %v\", err)\n557: \t}\n558: \n559: \terr = wm.DeleteCodeInterpreter(ctx, \"default\", \"test-ci\", metav1.DeleteOptions{})\n560: \tif err != nil {\n561: \t\tt.Errorf(\"DeleteCodeInterpreter failed: %v\", err)\n562: \t}\n563: \n564: \t_, err = wm.GetCodeInterpreter(ctx, \"default\", \"test-ci\", metav1.GetOptions{})\n565: \tif err == nil {\n566: \t\tt.Error(\"Expected error after delete\")\n567: \t}\n568: }\n569: \n570: func TestWorkloadManagerGetCodeInterpreterStatus(t *testing.T) {\n571: \twm := newTestWorkloadManager()\n572: \tctx := context.Background()\n573: \n574: \tci := &agentcubev1alpha1.CodeInterpreter{\n575: \t\tObjectMeta: metav1.ObjectMeta{\n576: \t\t\tName:      \"test-ci\",\n577: \t\t\tNamespace: \"default\",\n578: \t\t},\n579: \t\tSpec: agentcubev1alpha1.CodeInterpreterSpec{\n580: \t\t\tTemplate: agentcubev1alpha1.ContainerTemplateSpec{\n581: \t\t\t\tImage: \"python:3.9\",\n582: \t\t\t},\n583: \t\t},\n584: \t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n585: \t\t\tReady:              true,\n586: \t\t\tObservedGeneration: 1,\n587: \t\t},\n588: \t}\n589: \n590: \t_, err := wm.CreateCodeInterpreter(ctx, \"default\", ci, metav1.CreateOptions{})\n591: \tif err != nil {\n592: \t\tt.Fatalf(\"CreateCodeInterpreter failed: %v\", err)\n593: \t}\n594: \n595: \tstatus, err := wm.GetCodeInterpreterStatus(ctx, \"default\", \"test-ci\", metav1.GetOptions{})\n596: \tif err != nil {\n597: \t\tt.Errorf(\"GetCodeInterpreterStatus failed: %v\", err)\n598: \t}\n599: \n600: \tif !status.Ready {\n601: \t\tt.Error(\"Expected Ready to be true\")\n602: \t}\n603: }\n604: \n605: func TestWorkloadManagerClose(t *testing.T) {\n606: \twm := newTestWorkloadManager()\n607: \terr := wm.Close()\n608: \tif err != nil {\n609: \t\tt.Errorf(\"Close failed: %v\", err)\n610: \t}\n611: }\n612: \n613: func TestWorkloadManagerGetNonexistentAgentRuntime(t *testing.T) {\n614: \twm := newTestWorkloadManager()\n615: \tctx := context.Background()\n616: \n617: \t_, err := wm.GetAgentRuntime(ctx, \"default\", \"nonexistent\", metav1.GetOptions{})\n618: \tif err == nil {\n619: \t\tt.Error(\"Expected error for nonexistent resource\")\n620: \t}\n621: }\n622: \n623: func TestWorkloadManagerGetNonexistentCodeInterpreter(t *testing.T) {\n624: \twm := newTestWorkloadManager()\n625: \tctx := context.Background()\n626: \n627: \t_, err := wm.GetCodeInterpreter(ctx, \"default\", \"nonexistent\", metav1.GetOptions{})\n628: \tif err == nil {\n629: \t\tt.Error(\"Expected error for nonexistent resource\")\n630: \t}\n631: }\n\n(End of file - total 631 lines)\n</content>","metadata":{"preview":"package workl