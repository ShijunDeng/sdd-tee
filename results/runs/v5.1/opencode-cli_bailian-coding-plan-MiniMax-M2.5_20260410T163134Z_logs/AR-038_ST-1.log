{"type":"tool_use","timestamp":1775880840244,"sessionID":"ses_285413e5cffeJ1uMHvGw8waBPV","part":{"id":"prt_d7abf181f001xAm5sdjF6NxgTR","messageID":"msg_d7abf05510017BznF3VcmTW5FK","sessionID":"ses_285413e5cffeJ1uMHvGw8waBPV","type":"tool","tool":"read","callID":"toolu_2755abbb43b34d0aacab52c4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"time\"\n5: \n6: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n7: \t\"k8s.io/klog/v2\"\n8: )\n9: \n10: const (\n11: \tDefaultTTL          = 8 * time.Hour\n12: \tDefaultIdleTimeout  = 15 * time.Minute\n13: \tDefaultMaxLifetime  = 24 * time.Hour\n14: \tStaleStateThreshold = 1 * time.Hour\n15: )\n16: \n17: var (\n18: \tDefaultTTLSeconds         int64 = int64(DefaultTTL.Seconds())\n19: \tDefaultIdleTimeoutSeconds int64 = int64(DefaultIdleTimeout.Seconds())\n20: \tDefaultMaxLifetimeSeconds int64 = int64(DefaultMaxLifetime.Seconds())\n21: )\n22: \n23: type ExpirationConfig struct {\n24: \tTTL         time.Duration\n25: \tIdleTimeout time.Duration\n26: \tMaxLifetime time.Duration\n27: }\n28: \n29: func NewExpirationConfig() *ExpirationConfig {\n30: \treturn &ExpirationConfig{\n31: \t\tTTL:         DefaultTTL,\n32: \t\tIdleTimeout: DefaultIdleTimeout,\n33: \t\tMaxLifetime: DefaultMaxLifetime,\n34: \t}\n35: }\n36: \n37: func isExpiredByTTL(sandbox *Sandbox) bool {\n38: \tif sandbox.ExpiresAt == nil {\n39: \t\treturn false\n40: \t}\n41: \texpired := time.Now().After(*sandbox.ExpiresAt)\n42: \tif expired {\n43: \t\tklog.V(4).InfoS(\"Sandbox expired by TTL\", \"sandboxId\", sandbox.SessionID, \"expiresAt\", sandbox.ExpiresAt)\n44: \t}\n45: \treturn expired\n46: }\n47: \n48: func isExpiredByIdleTimeout(sandbox *Sandbox) bool {\n49: \tif sandbox.LastActivityAt == nil {\n50: \t\tif sandbox.CreatedAt.Add(DefaultIdleTimeout).Before(time.Now()) {\n51: \t\t\tklog.V(4).InfoS(\"Sandbox expired by idle timeout (no activity)\", \"sandboxId\", sandbox.SessionID)\n52: \t\t\treturn true\n53: \t\t}\n54: \t\treturn false\n55: \t}\n56: \texpired := time.Now().After(sandbox.LastActivityAt.Add(DefaultIdleTimeout))\n57: \tif expired {\n58: \t\tklog.V(4).InfoS(\"Sandbox expired by idle timeout\", \"sandboxId\", sandbox.SessionID, \"lastActivityAt\", sandbox.LastActivityAt)\n59: \t}\n60: \treturn expired\n61: }\n62: \n63: func isExpiredByMaxLifetime(sandbox *Sandbox) bool {\n64: \texpired := time.Now().After(sandbox.CreatedAt.Add(DefaultMaxLifetime))\n65: \tif expired {\n66: \t\tklog.V(4).InfoS(\"Sandbox expired by max lifetime\", \"sandboxId\", sandbox.SessionID, \"createdAt\", sandbox.CreatedAt)\n67: \t}\n68: \treturn expired\n69: }\n70: \n71: func isExpiredByStaleState(sandbox *Sandbox) bool {\n72: \tif sandbox.State == SandboxStateUnknown || sandbox.State == SandboxStateFailed {\n73: \t\tthreshold := time.Now().Add(-StaleStateThreshold)\n74: \t\tif sandbox.CreatedAt.Before(threshold) {\n75: \t\t\tklog.V(4).InfoS(\"Sandbox marked as stale\", \"sandboxId\", sandbox.SessionID, \"state\", sandbox.State, \"createdAt\", sandbox.CreatedAt)\n76: \t\t\treturn true\n77: \t\t}\n78: \t}\n79: \treturn false\n80: }\n81: \n82: func isExpired(sandbox *Sandbox) bool {\n83: \treturn isExpiredByTTL(sandbox) || isExpiredByIdleTimeout(sandbox) || isExpiredByMaxLifetime(sandbox) || isExpiredByStaleState(sandbox)\n84: }\n85: \n86: func shouldExpireByIdlePolicy(sandbox *Sandbox, idleTimeoutEnabled bool) bool {\n87: \tif !idleTimeoutEnabled {\n88: \t\treturn false\n89: \t}\n90: \treturn isExpiredByIdleTimeout(sandbox)\n91: }\n92: \n93: type ExpirationChecker struct {\n94: \tconfig *ExpirationConfig\n95: }\n96: \n97: func NewExpirationChecker(config *ExpirationConfig) *ExpirationChecker {\n98: \tif config == nil {\n99: \t\tconfig = NewExpirationConfig()\n100: \t}\n101: \treturn &ExpirationChecker{\n102: \t\tconfig: config,\n103: \t}\n104: }\n105: \n106: func (e *ExpirationChecker) IsExpired(sandbox *Sandbox) bool {\n107: \tif sandbox.ExpiresAt != nil && time.Now().After(*sandbox.ExpiresAt) {\n108: \t\treturn true\n109: \t}\n110: \n111: \tif time.Now().After(sandbox.CreatedAt.Add(e.config.TTL)) {\n112: \t\treturn true\n113: \t}\n114: \n115: \tif sandbox.LastActivityAt != nil && time.Now().After(sandbox.LastActivityAt.Add(e.config.IdleTimeout)) {\n116: \t\treturn true\n117: \t}\n118: \n119: \tif time.Now().After(sandbox.CreatedAt.Add(e.config.MaxLifetime)) {\n120: \t\treturn true\n121: \t}\n122: \n123: \treturn false\n124: }\n125: \n126: func (e *ExpirationChecker) GetExpirationTime(sandbox *Sandbox) *metav1.Time {\n127: \tvar earliest time.Time\n128: \n129: \tttlExpiry := sandbox.CreatedAt.Add(e.config.TTL)\n130: \tidleExpiry := sandbox.CreatedAt.Add(e.config.MaxLifetime)\n131: \tmaxLifetimeExpiry := sandbox.CreatedAt.Add(e.config.MaxLifetime)\n132: \n133: \tearliest = ttlExpiry\n134: \tif idleExpiry.Before(earliest) {\n135: \t\tearliest = idleExpiry\n136: \t}\n137: \tif maxLifetimeExpiry.Before(earliest) {\n138: \t\tearliest = maxLifetimeExpiry\n139: \t}\n140: \n141: \tif sandbox.LastActivityAt != nil {\n142: \t\tidleExpiryActivity := sandbox.LastActivityAt.Add(e.config.IdleTimeout)\n143: \t\tif idleExpiryActivity.Before(earliest) {\n144: \t\t\tearliest = idleExpiryActivity\n145: \t\t}\n146: \t}\n147: \n148: \tmetav1Time := metav1.NewTime(earliest)\n149: \treturn &metav1Time\n150: }\n151: \n152: func CalculateGracePeriod(gracePeriodSeconds *int64) time.Duration {\n153: \tif gracePeriodSeconds == nil {\n154: \t\treturn 30 * time.Second\n155: \t}\n156: \treturn time.Duration(*gracePeriodSeconds) * time.Second\n157: }\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (\n\tDefaultTTL          = 8 * time.Hour\n\tDefaultIdleTimeout  = 15 * time.Minute\n\tDefaultMaxLifetime  = 24 * time.Hour\n\tStaleStateThreshold = 1 * time.Hour\n)\n\nvar (\n\tDefaultTTLSeconds         int64 = int64(DefaultTTL.Seconds())\n\tDefaultIdleTimeoutSeconds int64 = int64(DefaultIdleTimeout.Seconds())\n\tDefaultMaxLifetimeSeconds int64 = int64(DefaultMaxLifetime.Seconds())","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration.go","time":{"start":1775880840225,"end":1775880840242}}}}
{"type":"tool_use","timestamp":1775880840247,"sessionID":"ses_285413e5cffeJ1uMHvGw8waBPV","part":{"id":"prt_d7abf1d61001NqHytPxVrMxkbL","messageID":"msg_d7abf05510017BznF3VcmTW5FK","sessionID":"ses_285413e5cffeJ1uMHvGw8waBPV","type":"tool","tool":"read","callID":"toolu_5869f7d5560b4631bb256131","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/cleanup.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/cleanup.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \n7: \tcorev1 \"k8s.io/api/core/v1\"\n8: \t\"k8s.io/apimachinery/pkg/api/errors\"\n9: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n10: \t\"k8s.io/apimachinery/pkg/labels\"\n11: \t\"k8s.io/client-go/kubernetes\"\n12: \t\"k8s.io/klog/v2\"\n13: )\n14: \n15: type CleanupManager struct {\n16: \tk8sClient *kubernetes.Clientset\n17: }\n18: \n19: func NewCleanupManager(k8sClient *kubernetes.Clientset) *CleanupManager {\n20: \treturn &CleanupManager{\n21: \t\tk8sClient: k8sClient,\n22: \t}\n23: }\n24: \n25: func (cm *CleanupManager) cleanupServices(namespace string, ownerRef metav1.OwnerReference) ([]string, error) {\n26: \tcleaned := make([]string, 0)\n27: \n28: \tservices, err := cm.k8sClient.CoreV1().Services(namespace).List(context.Background(), metav1.ListOptions{})\n29: \tif err != nil {\n30: \t\treturn cleaned, fmt.Errorf(\"failed to list services: %w\", err)\n31: \t}\n32: \n33: \tfor _, svc := range services.Items {\n34: \t\tfor _, owner := range svc.OwnerReferences {\n35: \t\t\tif owner.UID == ownerRef.UID && owner.Kind == ownerRef.Kind && owner.Name == ownerRef.Name {\n36: \t\t\t\terr := cm.k8sClient.CoreV1().Services(namespace).Delete(context.Background(), svc.Name, metav1.DeleteOptions{})\n37: \t\t\t\tif err != nil {\n38: \t\t\t\t\tif !errors.IsNotFound(err) {\n39: \t\t\t\t\t\tklog.V(2).InfoS(\"Failed to delete service\", \"service\", svc.Name, \"error\", err)\n40: \t\t\t\t\t\tcontinue\n41: \t\t\t\t\t}\n42: \t\t\t\t}\n43: \t\t\t\tcleaned = append(cleaned, fmt.Sprintf(\"Service/%s\", svc.Name))\n44: \t\t\t\tklog.InfoS(\"Deleted service\", \"service\", svc.Name, \"namespace\", namespace)\n45: \t\t\t\tbreak\n46: \t\t\t}\n47: \t\t}\n48: \t}\n49: \n50: \treturn cleaned, nil\n51: }\n52: \n53: func (cm *CleanupManager) cleanupConfigMaps(namespace string, ownerRef metav1.OwnerReference) ([]string, error) {\n54: \tcleaned := make([]string, 0)\n55: \n56: \tconfigMaps, err := cm.k8sClient.CoreV1().ConfigMaps(namespace).List(context.Background(), metav1.ListOptions{})\n57: \tif err != nil {\n58: \t\treturn cleaned, fmt.Errorf(\"failed to list configmaps: %w\", err)\n59: \t}\n60: \n61: \tfor _, cfgMap := range configMaps.Items {\n62: \t\tannotations := cfgMap.GetAnnotations()\n63: \t\tif annotations == nil {\n64: \t\t\tcontinue\n65: \t\t}\n66: \n67: \t\tif annotations[\"agentcube.volcano.sh/auto-delete\"] != \"true\" {\n68: \t\t\tcontinue\n69: \t\t}\n70: \n71: \t\tfor _, owner := range cfgMap.OwnerReferences {\n72: \t\t\tif owner.UID == ownerRef.UID && owner.Kind == ownerRef.Kind && owner.Name == ownerRef.Name {\n73: \t\t\t\terr := cm.k8sClient.CoreV1().ConfigMaps(namespace).Delete(context.Background(), cfgMap.Name, metav1.DeleteOptions{})\n74: \t\t\t\tif err != nil {\n75: \t\t\t\t\tif !errors.IsNotFound(err) {\n76: \t\t\t\t\t\tklog.V(2).InfoS(\"Failed to delete configmap\", \"configmap\", cfgMap.Name, \"error\", err)\n77: \t\t\t\t\t\tcontinue\n78: \t\t\t\t\t}\n79: \t\t\t\t}\n80: \t\t\t\tcleaned = append(cleaned, fmt.Sprintf(\"ConfigMap/%s\", cfgMap.Name))\n81: \t\t\t\tklog.InfoS(\"Deleted configmap\", \"configmap\", cfgMap.Name, \"namespace\", namespace)\n82: \t\t\t\tbreak\n83: \t\t\t}\n84: \t\t}\n85: \t}\n86: \n87: \treturn cleaned, nil\n88: }\n89: \n90: func (cm *CleanupManager) cleanupPVCs(namespace string, ownerRef metav1.OwnerReference) ([]string, error) {\n91: \tcleaned := make([]string, 0)\n92: \n93: \tpvcs, err := cm.k8sClient.CoreV1().PersistentVolumeClaims(namespace).List(context.Background(), metav1.ListOptions{})\n94: \tif err != nil {\n95: \t\treturn cleaned, fmt.Errorf(\"failed to list pvcs: %w\", err)\n96: \t}\n97: \n98: \tfor _, pvc := range pvcs.Items {\n99: \t\tfor _, owner := range pvc.OwnerReferences {\n100: \t\t\tif owner.UID == ownerRef.UID && owner.Kind == ownerRef.Kind && owner.Name == ownerRef.Name {\n101: \t\t\t\tpvName := pvc.Spec.VolumeName\n102: \t\t\t\tif pvName != \"\" {\n103: \t\t\t\t\tpv, err := cm.k8sClient.CoreV1().PersistentVolumes().Get(context.Background(), pvName, metav1.GetOptions{})\n104: \t\t\t\t\tif err == nil && pv.Spec.PersistentVolumeReclaimPolicy == corev1.PersistentVolumeReclaimRetain {\n105: \t\t\t\t\t\tklog.V(4).InfoS(\"Retaining PVC due to PV ReclaimPolicy\", \"pvc\", pvc.Name, \"namespace\", namespace)\n106: \t\t\t\t\t\tcontinue\n107: \t\t\t\t\t}\n108: \t\t\t\t}\n109: \n110: \t\t\t\terr := cm.k8sClient.CoreV1().PersistentVolumeClaims(namespace).Delete(context.Background(), pvc.Name, metav1.DeleteOptions{})\n111: \t\t\t\tif err != nil {\n112: \t\t\t\t\tif !errors.IsNotFound(err) {\n113: \t\t\t\t\t\tklog.V(2).InfoS(\"Failed to delete pvc\", \"pvc\", pvc.Name, \"error\", err)\n114: \t\t\t\t\t\tcontinue\n115: \t\t\t\t\t}\n116: \t\t\t\t}\n117: \t\t\t\tcleaned = append(cleaned, fmt.Sprintf(\"PVC/%s\", pvc.Name))\n118: \t\t\t\tklog.InfoS(\"Deleted pvc\", \"pvc\", pvc.Name, \"namespace\", namespace)\n119: \t\t\t\tbreak\n120: \t\t\t}\n121: \t\t}\n122: \t}\n123: \n124: \treturn cleaned, nil\n125: }\n126: \n127: func (cm *CleanupManager) cleanupOrphanedResources(sandbox *Sandbox) ([]string, error) {\n128: \tcleaned := make([]string, 0)\n129: \townerRef := metav1.OwnerReference{\n130: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n131: \t\tKind:       \"AgentRuntime\",\n132: \t\tName:       sandbox.Name,\n133: \t\tUID:        \"\",\n134: \t}\n135: \n136: \tsvcCleaned, err := cm.cleanupServices(sandbox.Namespace, ownerRef)\n137: \tif err != nil {\n138: \t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n139: \t}\n140: \tcleaned = append(cleaned, svcCleaned...)\n141: \n142: \tcmCleaned, err := cm.cleanupConfigMaps(sandbox.Namespace, ownerRef)\n143: \tif err != nil {\n144: \t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n145: \t}\n146: \tcleaned = append(cleaned, cmCleaned...)\n147: \n148: \tpvcCleaned, err := cm.cleanupPVCs(sandbox.Namespace, ownerRef)\n149: \tif err != nil {\n150: \t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n151: \t}\n152: \tcleaned = append(cleaned, pvcCleaned...)\n153: \n154: \tklog.InfoS(\"Cleaned orphaned resources\", \"sandboxId\", sandbox.SessionID, \"count\", len(cleaned))\n155: \treturn cleaned, nil\n156: }\n157: \n158: func (cm *CleanupManager) CleanupAllResources(ctx context.Context, sandbox *Sandbox) ([]string, error) {\n159: \tallCleaned := make([]string, 0)\n160: \n161: \tsvcList, err := cm.cleanupServices(sandbox.Namespace, metav1.OwnerReference{\n162: \t\tName: sandbox.Name,\n163: \t})\n164: \tif err != nil {\n165: \t\tklog.V(2).InfoS(\"Error during service cleanup\", \"error\", err)\n166: \t}\n167: \tallCleaned = append(allCleaned, svcList...)\n168: \n169: \tcmList, err := cm.cleanupConfigMaps(sandbox.Namespace, metav1.OwnerReference{\n170: \t\tName: sandbox.Name,\n171: \t})\n172: \tif err != nil {\n173: \t\tklog.V(2).InfoS(\"Error during configmap cleanup\", \"error\", err)\n174: \t}\n175: \tallCleaned = append(allCleaned, cmList...)\n176: \n177: \tpvcList, err := cm.cleanupPVCs(sandbox.Namespace, metav1.OwnerReference{\n178: \t\tName: sandbox.Name,\n179: \t})\n180: \tif err != nil {\n181: \t\tklog.V(2).InfoS(\"Error during pvc cleanup\", \"error\", err)\n182: \t}\n183: \tallCleaned = append(allCleaned, pvcList...)\n184: \n185: \treturn allCleaned, nil\n186: }\n187: \n188: func (cm *CleanupManager) FindOrphanedServices(ctx context.Context, namespace string, sessionID string) ([]string, error) {\n189: \tselector := labels.SelectorFromSet(labels.Set{\"sessionId\": sessionID})\n190: \tservices, err := cm.k8sClient.CoreV1().Services(namespace).List(ctx, metav1.ListOptions{\n191: \t\tLabelSelector: selector.String(),\n192: \t})\n193: \tif err != nil {\n194: \t\treturn nil, err\n195: \t}\n196: \n197: \tcleanable := make([]string, 0)\n198: \tfor _, svc := range services.Items {\n199: \t\tif len(svc.OwnerReferences) == 0 {\n200: \t\t\tcleanable = append(cleanable, svc.Name)\n201: \t\t}\n202: \t}\n203: \n204: \treturn cleanable, nil\n205: }\n\n(End of file - total 205 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype CleanupManager struct {\n\tk8sClient *kubernetes.Clientset\n}\n\nfunc NewCleanupManager(k8sClient *kubernetes.Clientset) *CleanupManager {\n\treturn &CleanupManager{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/cleanup.go","time":{"start":1775880840228,"end":1775880840245}}}}
{"type":"tool_use","timestamp":1775880840250,"sessionID":"ses_285413e5cffeJ1uMHvGw8waBPV","part":{"id":"prt_d7abf2062001eMlm79CrMRfdgl","messageID":"msg_d7abf05510017BznF3VcmTW5FK","sessionID":"ses_285413e5cffeJ1uMHvGw8waBPV","type":"tool","tool":"read","callID":"toolu_29cd7d3426c94723b06c2c73","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/graceful.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/graceful.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"os/exec\"\n7: \t\"sync\"\n8: \t\"time\"\n9: \n10: \tcorev1 \"k8s.io/api/core/v1\"\n11: \t\"k8s.io/apimachinery/pkg/api/errors\"\n12: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n13: \t\"k8s.io/client-go/kubernetes\"\n14: \t\"k8s.io/klog/v2\"\n15: )\n16: \n17: type connectionState struct {\n18: \tactiveConnections int\n19: \tmu                sync.RWMutex\n20: \tdraining          bool\n21: }\n22: \n23: type GracefulManager struct {\n24: \tk8sClient   *kubernetes.Clientset\n25: \tconnections map[string]*connectionState\n26: \tmu          sync.RWMutex\n27: \tgracePeriod time.Duration\n28: }\n29: \n30: func NewGracefulManager(k8sClient *kubernetes.Clientset, gracePeriod time.Duration) *GracefulManager {\n31: \treturn &GracefulManager{\n32: \t\tk8sClient:   k8sClient,\n33: \t\tconnections: make(map[string]*connectionState),\n34: \t\tgracePeriod: gracePeriod,\n35: \t}\n36: }\n37: \n38: func (g *GracefulManager) drainConnections(sandboxID string) {\n39: \tg.mu.Lock()\n40: \tdefer g.mu.Unlock()\n41: \n42: \tstate, exists := g.connections[sandboxID]\n43: \tif !exists {\n44: \t\tstate = &connectionState{}\n45: \t\tg.connections[sandboxID] = state\n46: \t}\n47: \tstate.draining = true\n48: \tklog.InfoS(\"Started draining connections\", \"sandboxId\", sandboxID)\n49: }\n50: \n51: func (g *GracefulManager) waitForConnections(sandboxID string, timeout time.Duration) error {\n52: \tg.mu.RLock()\n53: \tstate, exists := g.connections[sandboxID]\n54: \tg.mu.RUnlock()\n55: \n56: \tif !exists || state.activeConnections == 0 {\n57: \t\tklog.V(4).InfoS(\"No active connections to wait for\", \"sandboxId\", sandboxID)\n58: \t\treturn nil\n59: \t}\n60: \n61: \tctx, cancel := context.WithTimeout(context.Background(), timeout)\n62: \tdefer cancel()\n63: \n64: \tticker := time.NewTicker(100 * time.Millisecond)\n65: \tdefer ticker.Stop()\n66: \n67: \tfor {\n68: \t\tselect {\n69: \t\tcase <-ctx.Done():\n70: \t\t\treturn fmt.Errorf(\"timeout waiting for connections to drain\")\n71: \t\tcase <-ticker.C:\n72: \t\t\tg.mu.RLock()\n73: \t\t\tcurrentState := state\n74: \t\t\tg.mu.RUnlock()\n75: \n76: \t\t\tif currentState.activeConnections == 0 {\n77: \t\t\t\treturn nil\n78: \t\t\t}\n79: \t\t}\n80: \t}\n81: }\n82: \n83: func (g *GracefulManager) executePreDeleteHook(sandbox *Sandbox, hookConfig *WebhookConfig) error {\n84: \tif hookConfig == nil || hookConfig.URL == \"\" {\n85: \t\treturn nil\n86: \t}\n87: \n88: \tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n89: \tdefer cancel()\n90: \n91: \ttimeout := time.Duration(hookConfig.Timeout) * time.Second\n92: \tif timeout == 0 {\n93: \t\ttimeout = 30 * time.Second\n94: \t}\n95: \n96: \thookCtx, hookCancel := context.WithTimeout(ctx, timeout)\n97: \tdefer hookCancel()\n98: \n99: \tklog.InfoS(\"Executing pre-delete hook\", \"sandboxId\", sandbox.SessionID, \"url\", hookConfig.URL)\n100: \n101: \tselect {\n102: \tcase <-hookCtx.Done():\n103: \t\tklog.V(2).InfoS(\"Pre-delete hook context cancelled\", \"sandboxId\", sandbox.SessionID)\n104: \t\treturn nil\n105: \tdefault:\n106: \t\treturn nil\n107: \t}\n108: }\n109: \n110: func (g *GracefulManager) sendSIGTERM(podName, namespace string) error {\n111: \tpod, err := g.k8sClient.CoreV1().Pods(namespace).Get(context.Background(), podName, metav1.GetOptions{})\n112: \tif err != nil {\n113: \t\tif errors.IsNotFound(err) {\n114: \t\t\tklog.V(4).InfoS(\"Pod not found, skipping SIGTERM\", \"pod\", podName, \"namespace\", namespace)\n115: \t\t\treturn nil\n116: \t\t}\n117: \t\treturn fmt.Errorf(\"failed to get pod: %w\", err)\n118: \t}\n119: \n120: \tif pod.Spec.TerminationGracePeriodSeconds != nil && *pod.Spec.TerminationGracePeriodSeconds == 0 {\n121: \t\tklog.V(4).InfoS(\"Pod has gracePeriodSeconds=0, skipping SIGTERM\", \"pod\", podName)\n122: \t\treturn nil\n123: \t}\n124: \n125: \tcmd := exec.Command(\"kubectl\", \"exec\", \"-n\", namespace, podName, \"--\", \"kill\", \"-TERM\", \"1\")\n126: \toutput, err := cmd.CombinedOutput()\n127: \tif err != nil {\n128: \t\tklog.V(4).InfoS(\"Failed to send SIGTERM via exec\", \"pod\", podName, \"error\", err)\n129: \t\treturn nil\n130: \t}\n131: \n132: \tklog.InfoS(\"Sent SIGTERM to pod\", \"pod\", podName, \"output\", string(output))\n133: \treturn nil\n134: }\n135: \n136: func (g *GracefulManager) executeGracefulDelete(ctx context.Context, sandbox *Sandbox, opts DeleteOptions, hookConfig *WebhookConfig) error {\n137: \tpods, err := g.k8sClient.CoreV1().Pods(sandbox.Namespace).List(ctx, metav1.ListOptions{\n138: \t\tLabelSelector: fmt.Sprintf(\"sessionId=%s\", sandbox.SessionID),\n139: \t})\n140: \tif err != nil {\n141: \t\treturn fmt.Errorf(\"failed to list pods: %w\", err)\n142: \t}\n143: \n144: \tif len(pods.Items) > 0 {\n145: \t\tg.drainConnections(sandbox.SessionID)\n146: \n147: \t\tfor _, pod := range pods.Items {\n148: \t\t\tif err := g.sendSIGTERM(pod.Name, pod.Namespace); err != nil {\n149: \t\t\t\tklog.V(4).InfoS(\"Error sending SIGTERM\", \"pod\", pod.Name, \"error\", err)\n150: \t\t\t}\n151: \t\t}\n152: \t}\n153: \n154: \tgracePeriod := g.gracePeriod\n155: \tif opts.GracePeriodSeconds != nil {\n156: \t\tgracePeriod = time.Duration(*opts.GracePeriodSeconds) * time.Second\n157: \t}\n158: \n159: \tif err := g.waitForConnections(sandbox.SessionID, gracePeriod); err != nil {\n160: \t\tklog.V(2).InfoS(\"Timeout waiting for connections to drain\", \"sandboxId\", sandbox.SessionID, \"error\", err)\n161: \t}\n162: \n163: \treturn nil\n164: }\n165: \n166: func (g *GracefulManager) StopRouting(sandboxID string) {\n167: \tg.drainConnections(sandboxID)\n168: }\n169: \n170: func (g *GracefulManager) RegisterConnection(sandboxID string) {\n171: \tg.mu.Lock()\n172: \tdefer g.mu.Unlock()\n173: \n174: \tstate, exists := g.connections[sandboxID]\n175: \tif !exists {\n176: \t\tstate = &connectionState{}\n177: \t\tg.connections[sandboxID] = state\n178: \t}\n179: \tstate.mu.Lock()\n180: \tstate.activeConnections++\n181: \tstate.mu.Unlock()\n182: }\n183: \n184: func (g *GracefulManager) UnregisterConnection(sandboxID string) {\n185: \tg.mu.Lock()\n186: \tdefer g.mu.Unlock()\n187: \n188: \tstate, exists := g.connections[sandboxID]\n189: \tif !exists {\n190: \t\treturn\n191: \t}\n192: \tstate.mu.Lock()\n193: \tstate.activeConnections--\n194: \tstate.mu.Unlock()\n195: }\n196: \n197: func (g *GracefulManager) IsDraining(sandboxID string) bool {\n198: \tg.mu.RLock()\n199: \tdefer g.mu.RUnlock()\n200: \n201: \tstate, exists := g.connections[sandboxID]\n202: \tif !exists {\n203: \t\treturn false\n204: \t}\n205: \treturn state.draining\n206: }\n207: \n208: func (g *GracefulManager) GetActiveConnections(sandboxID string) int {\n209: \tg.mu.RLock()\n210: \tdefer g.mu.RUnlock()\n211: \n212: \tstate, exists := g.connections[sandboxID]\n213: \tif !exists {\n214: \t\treturn 0\n215: \t}\n216: \tstate.mu.RLock()\n217: \tdefer state.mu.RUnlock()\n218: \treturn state.activeConnections\n219: }\n220: \n221: func (g *GracefulManager) Cleanup(sandboxID string) {\n222: \tg.mu.Lock()\n223: \tdefer g.mu.Unlock()\n224: \tdelete(g.connections, sandboxID)\n225: }\n226: \n227: func waitForPodDeletion(ctx context.Context, k8sClient *kubernetes.Clientset, podName, namespace string, timeout time.Duration) error {\n228: \tticker := time.NewTicker(500 * time.Millisecond)\n229: \tdefer ticker.Stop()\n230: \n231: \ttimeoutCh := time.After(timeout)\n232: \n233: \tfor {\n234: \t\tselect {\n235: \t\tcase <-ctx.Done():\n236: \t\t\treturn ctx.Err()\n237: \t\tcase <-timeoutCh:\n238: \t\t\treturn fmt.Errorf(\"timeout waiting for pod deletion\")\n239: \t\tcase <-ticker.C:\n240: \t\t\t_, err := k8sClient.CoreV1().Pods(namespace).Get(ctx, podName, metav1.GetOptions{})\n241: \t\t\tif errors.IsNotFound(err) {\n242: \t\t\t\treturn nil\n243: \t\t\t}\n244: \t\t\tif err != nil {\n245: \t\t\t\treturn fmt.Errorf(\"error checking pod status: %w\", err)\n246: \t\t\t}\n247: \t\t}\n248: \t}\n249: }\n250: \n251: func deletePodWithGracePeriod(ctx context.Context, k8sClient *kubernetes.Clientset, podName, namespace string, gracePeriodSeconds *int64) error {\n252: \tgracePeriod := int64(30)\n253: \tif gracePeriodSeconds != nil {\n254: \t\tgracePeriod = *gracePeriodSeconds\n255: \t}\n256: \n257: \tzeroGracePeriod := int64(0)\n258: \tif gracePeriod == 0 {\n259: \t\terr := k8sClient.CoreV1().Pods(namespace).Delete(ctx, podName, metav1.DeleteOptions{\n260: \t\t\tGracePeriodSeconds: &zeroGracePeriod,\n261: \t\t})\n262: \t\tif err != nil && !errors.IsNotFound(err) {\n263: \t\t\treturn err\n264: \t\t}\n265: \t\treturn waitForPodDeletion(ctx, k8sClient, podName, namespace, 10*time.Second)\n266: \t}\n267: \n268: \terr := k8sClient.CoreV1().Pods(namespace).Delete(ctx, podName, metav1.DeleteOptions{\n269: \t\tGracePeriodSeconds: &gracePeriod,\n270: \t})\n271: \tif err != nil && !errors.IsNotFound(err) {\n272: \t\treturn err\n273: \t}\n274: \treturn waitForPodDeletion(ctx, k8sClient, podName, namespace, time.Duration(gracePeriod+5)*time.Second)\n275: }\n276: \n277: func terminatePod(ctx context.Context, k8sClient *kubernetes.Clientset, pod corev1.Pod) error {\n278: \tif pod.Spec.TerminationGracePeriodSeconds != nil && *pod.Spec.TerminationGracePeriodSeconds == 0 {\n279: \t\treturn nil\n280: \t}\n281: \n282: \treturn deletePodWithGracePeriod(ctx, k8sClient, pod.Name, pod.Namespace, pod.Spec.TerminationGracePeriodSeconds)\n283: }\n\n(End of file - total 283 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os/exec\"\n\t\"sync\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype connectionState struct {\n\tactiveConnections int\n\tmu                sync.RWMutex\n\tdraining          bool","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/graceful.go","time":{"start":1775880840230,"end":1775880840247}}}}
