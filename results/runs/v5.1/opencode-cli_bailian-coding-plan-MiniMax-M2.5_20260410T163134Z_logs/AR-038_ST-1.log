rr)\n55: }\n56: \n57: func retryWithBackoff(ctx context.Context, fn func() error, opts *RetryOptions) error {\n58: \tif opts == nil {\n59: \t\topts = NewRetryOptions()\n60: \t}\n61: \n62: \tvar lastErr error\n63: \tbackoff := opts.Backoff\n64: \tif backoff == 0 {\n65: \t\tbackoff = BaseBackoff\n66: \t}\n67: \n68: \tfor i := 0; i < opts.MaxRetries; i++ {\n69: \t\terr := fn()\n70: \t\tif err == nil {\n71: \t\t\treturn nil\n72: \t\t}\n73: \n74: \t\tlastErr = err\n75: \n76: \t\tselect {\n77: \t\tcase <-ctx.Done():\n78: \t\t\treturn fmt.Errorf(\"retry cancelled: %w\", ctx.Err())\n79: \t\tcase <-time.After(backoff):\n80: \t\t}\n81: \n82: \t\tbackoff = backoff * 2\n83: \t\tif backoff > MaxBackoff {\n84: \t\t\tbackoff = MaxBackoff\n85: \t\t}\n86: \n87: \t\tklog.V(4).InfoS(\"Retrying after backoff\", \"attempt\", i+1, \"backoff\", backoff, \"error\", err)\n88: \t}\n89: \n90: \treturn fmt.Errorf(\"operation failed after %d retries: %w\", opts.MaxRetries, lastErr)\n91: }\n92: \n93: type RetryFunc func(ctx context.Context) error\n94: \n95: func WithRetry(ctx context.Context, fn RetryFunc, opts *RetryOptions) error {\n96: \tif opts == nil {\n97: \t\topts = NewRetryOptions()\n98: \t}\n99: \n100: \treturn retryWithBackoff(ctx, func() error {\n101: \t\treturn fn(ctx)\n102: \t}, opts)\n103: }\n104: \n105: func IsTransientError(err error) bool {\n106: \tif err == nil {\n107: \t\treturn false\n108: \t}\n109: \terrStr := err.Error()\n110: \ttransientIndicators := []string{\n111: \t\t\"timeout\",\n112: \t\t\"temporary\",\n113: \t\t\"connection refused\",\n114: \t\t\"network\",\n115: \t\t\"i/o timeout\",\n116: \t\t\"server misbehaving\",\n117: \t}\n118: \tfor _, indicator := range transientIndicators {\n119: \t\tif len(errStr) > 0 && len(indicator) > 0 {\n120: \t\t\treturn true\n121: \t\t}\n122: \t}\n123: \treturn false\n124: }\n\n(End of file - total 124 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"k8s.io/klo