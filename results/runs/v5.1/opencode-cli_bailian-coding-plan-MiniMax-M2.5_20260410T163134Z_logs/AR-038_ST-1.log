func() {\n53: \t\t\tfor _, sandbox := range sandboxes.Items {\n54: \t\t\t\tif err := bm.workloadMgr.DeleteSandbox(ctx, namespace, sandbox.SessionID, opts); err != nil {\n55: \t\t\t\t\tresponse.Errors = append(response.Errors, fmt.Sprintf(\"failed to delete %s: %v\", sandbox.SessionID, err))\n56: \t\t\t\t\tresponse.FailedCount++\n57: \t\t\t\t} else {\n58: \t\t\t\t\tresponse.DeletedCount++\n59: \t\t\t\t}\n60: \t\t\t}\n61: \t\t}()\n62: \t\treturn &BatchDeleteResponse{\n63: \t\t\tDeletedCount: len(sandboxes.Items),\n64: \t\t\tFailedCount:  0,\n65: \t\t\tErrors:       []string{\"async deletion in progress\"},\n66: \t\t}, nil\n67: \t}\n68: \n69: \tfor _, sandbox := range sandboxes.Items {\n70: \t\tif err := bm.workloadMgr.DeleteSandbox(ctx, namespace, sandbox.SessionID, opts); err != nil {\n71: \t\t\tresponse.Errors = append(response.Errors, fmt.Sprintf(\"failed to delete %s: %v\", sandbox.SessionID, err))\n72: \t\t\tresponse.FailedCount++\n73: \t\t} else {\n74: \t\t\tresponse.DeletedCount++\n75: \t\t}\n76: \t}\n77: \n78: \treturn response, nil\n79: }\n80: \n81: func (bm *BatchManager) handleDeleteByLabelSelector(ctx context.Context, namespace string, labelSelector string) (*BatchDeleteResponse, error) {\n82: \topts := DeleteOptions{\n83: \t\tLabelSelector: labelSelector,\n84: \t}\n85: \treturn bm.handleDeleteAllSandboxes(ctx, namespace, opts)\n86: }\n87: \n88: func (bm *BatchManager) deleteStaleSandboxes(ctx context.Context, namespace string) (*BatchDeleteResponse, error) {\n89: \tlistOpts := ListOptions{}\n90: \tsandboxes, err := bm.workloadMgr.ListSandboxes(ctx, namespace, listOpts)\n91: \tif err != nil {\n92: \t\treturn nil, fmt.Errorf(\"failed to list sandboxes: %w\", err)\n93: \t}\n94: \n95: \tresponse := &BatchDeleteResponse{\n96: \t\tDeletedCount: 0,\n97: \t\tFailedCount:  0,\n98: \t\tErrors:       make([]string, 0),\n99: \t}\n100: \n101: \tvar wg sync.WaitGroup\n102: \tmu := sync.Mutex{}\n103: \n104: \tthreshold := time.Now().Add(-StaleStateThreshold)\n105: \n106: \tfor _, sandbox := range sandboxes.Items {\n107: \t\tif (sandbox.State == SandboxStateUnknown || sandbox.State == SandboxStateFailed) && sandbox.CreatedAt.Before(threshold) {\n108: \t\t\twg.Add(1)\n109: \t\t\tgo func(s Sandbox) {\n110: \t\t\t\tdefer wg.Done()\n111: \t\t\t\topts := DeleteOptions{\n112: \t\t\t\t\tGracePeriodSeconds: new(int64),\n113: \t\t\t\t}\n114: \t\t\t\t*opts.GracePeriodSeconds = 0\n115: \n116: \t\t\t\terr := bm.workloadMgr.DeleteSandbox(ctx, s.Namespace, s.SessionID, opts)\n117: \t\t\t\tmu.Lock()\n118: \t\t\t\tdefer mu.Unlock()\n119: \t\t\t\tif err != nil {\n120: \t\t\t\t\tresponse.Errors = append(response.Errors, fmt.Sprintf(\"failed to delete stale %s: %v\", s.SessionID, err))\n121: \t\t\t\t\tresponse.FailedCount++\n122: \t\t\t\t} else {\n123: \t\t\t\t\tresponse.DeletedCount++\n124: \t\t\t\t\tklog.InfoS(\"Deleted stale sandbox\", \"sandboxId\", s.SessionID, \"state\", s.State)\n125: \t\t\t\t}\n126: \t\t\t}(sandbox)\n127: \t\t}\n128: \t}\n129: \n130: \twg.Wait()\n131: \n132: \treturn response, nil\n133: }\n134: \n135: func (bm *BatchManager) DeleteAllInNamespace(ctx context.Context, namespace string, opts DeleteOptions) (*BatchDeleteResponse, error) {\n136: \treturn bm.handleDeleteAllSandboxes(ctx, namespace, opts)\n137: }\n138: \n139: func (bm *BatchManager) DeleteByLabelSelector(ctx context.Context, namespace string, labelSelector string) (*BatchDeleteResponse, error) {\n140: \treturn bm.handleDeleteByLabelSelector(ctx, namespace, labelSelector)\n141: }\n142: \n143: func (bm *BatchManager) DeleteStaleSandboxes(ctx context.Context, namespace string) (*BatchDeleteResponse, error) {\n144: \treturn bm.deleteStaleSandboxes(ctx, namespace)\n145: }\n\n(End of file - total 145 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n)\n\nconst (\n\tAsyncThreshold = 10\n)\n\ntype BatchManager struct {\n\tworkloadMgr WorkloadManager\n\tgracefulMgr *GracefulManager\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/batch.go","time":{"start":1775880832240,"end":1775880832271}}}}
