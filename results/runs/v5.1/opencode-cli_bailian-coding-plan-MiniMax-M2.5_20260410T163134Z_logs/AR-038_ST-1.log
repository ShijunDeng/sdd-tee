t},\n47: \t\tReason:  reason,\n48: \t\tMessage: message,\n49: \t\tSource: corev1.EventSource{\n50: \t\t\tComponent: \"workloadmanager\",\n51: \t\t},\n52: \t\tFirstTimestamp: timestamp,\n53: \t\tLastTimestamp:  timestamp,\n54: \t\tCount:          1,\n55: \t\tType:           \"Normal\",\n56: \t}\n57: \n58: \tcreatedEvent, err := er.k8sClient.CoreV1().Events(sandbox.Namespace).Create(context.Background(), event, metav1.CreateOptions{})\n59: \tif err != nil {\n60: \t\tklog.V(2).InfoS(\"Failed to emit deletion event\", \"sandboxId\", sandbox.SessionID, \"error\", err)\n61: \t\treturn\n62: \t}\n63: \n64: \tklog.V(4).InfoS(\"Emitted deletion event\", \"event\", createdEvent.Name, \"reason\", reason)\n65: }\n66: \n67: func (er *EventRecorder) emitOrphanCleanupEvent(sandbox *Sandbox) {\n68: \ter.emitDeletionEvent(sandbox, \"OrphanedResourceCleanup\", fmt.Sprintf(\"Cleaned up orphaned resources for sandbox %s\", sandbox.SessionID))\n69: }\n70: \n71: func (er *EventRecorder) emitTTLExpirationEvent(sandbox *Sandbox) {\n72: \ter.emitDeletionEvent(sandbox, \"TTLExpired\", fmt.Sprintf(\"Sandbox %s expired due to TTL\", sandbox.SessionID))\n73: }\n74: \n75: func (er *EventRecorder) emitIdleTimeoutEvent(sandbox *Sandbox) {\n76: \ter.emitDeletionEvent(sandbox, \"IdleTimeout\", fmt.Sprintf(\"Sandbox %s expired due to idle timeout\", sandbox.SessionID))\n77: }\n78: \n79: func (er *EventRecorder) emitMaxLifetimeEvent(sandbox *Sandbox) {\n80: \ter.emitDeletionEvent(sandbox, \"MaxLifetimeExceeded\", fmt.Sprintf(\"Sandbox %s exceeded maximum lifetime\", sandbox.SessionID))\n81: }\n82: \n83: func (er *EventRecorder) emitStaleCleanupEvent(sandbox *Sandbox) {\n84: \ter.emitDeletionEvent(sandbox, \"StaleCleanup\", fmt.Sprintf(\"Cleaned up stale sandbox %s\", sandbox.SessionID))\n85: }\n86: \n87: func (er *EventRecorder) sendDeletionWebhook(sandbox *Sandbox, config *WebhookConfig) error {\n88: \tif config == nil || config.URL == \"\" {\n89: \t\treturn nil\n90: \t}\n91: \n92: \tretryCount := config.RetryCount\n93: \tif retryCount == 0 {\n94: \t\tretryCount = 3\n95: \t}\n96: \n97: \ttimeout := time.Duration(config.Timeout) * time.Second\n98: \tif timeout == 0 {\n99: \t\ttimeout = 10 * time.Second\n100: \t}\n101: \n102: \tpayload := map[string]interface{}{\n103: \t\t\"sandboxId\": sandbox.SessionID,\n104: \t\t\"name\":      sandbox.Name,\n105: \t\t\"namespace\": sandbox.Namespace,\n106: \t\t\"state\":     sandbox.State,\n107: \t\t\"action\":    \"deleted\",\n108: \t\t\"timestamp\": time.Now().Unix(),\n109: \t}\n110: \n111: \tpayloadBytes, err := json.Marshal(payload)\n112: \tif err != nil {\n113: \t\treturn fmt.Errorf(\"failed to marshal webhook payload: %w\", err)\n114: \t}\n115: \n116: \tvar lastErr error\n117: \tfor i := 0; i < retryCount; i++ {\n118: \t\tctx, cancel := context.WithTimeout(context.Background(), timeout)\n119: \t\tdefer cancel()\n120: \n121: \t\treq, err := http.NewRequestWithContext(ctx, \"POST\", config.URL, bytes.NewBuffer(payloadBytes))\n122: \t\tif err != nil {\n123: \t\t\treturn fmt.Errorf(\"failed to create webhook request: %w\", err)\n124: \t\t}\n125: \n126: \t\treq.Header.Set(\"Content-Type\", \"application/json\")\n127: \n128: \t\tclient := &http.Client{}\n129: \t\tresp, err := client.Do(req)\n130: \t\tif err != nil {\n131: \t\t\tlastErr = err\n132: \t\t\tklog.V(2).InfoS(\"Webhook request failed\", \"sandboxId\", sandbox.SessionID, \"attempt\", i+1, \"error\", err)\n133: \t\t\ttime.Sleep(time.Duration(i+1) * time.Second)\n134: \t\t\tcontinue\n135: \t\t}\n136: \t\tdefer resp.Body.Close()\n137: \n138: \t\tif resp.StatusCode >= 200 && resp.StatusCode < 300 {\n139: \t\t\tklog.InfoS(\"Webhook notification sent successfully\", \"sandboxId\", sandbox.SessionID, \"url\", config.URL)\n140: \t\t\treturn nil\n141: \t\t}\n142: \n143: \t\tlastErr = fmt.Errorf(\"webhook returned status %d\", resp.StatusCode)\n144: \t\tklog.V(2).InfoS(\"Webhook returned error status\", \"sandboxId\", sandbox.SessionID, \"status\", resp.StatusCode)\n145: \t\ttime.Sleep(time.Duration(i+1) * time.Second)\n146: \t}\n147: \n148: \tklog.V(2).InfoS(\"All webhook retries failed\", \"sandboxId\", sandbox.SessionID, \"error\", lastErr)\n149: \treturn lastErr\n150: }\n151: \n152: func (er *EventRecorder) logDeletionAudit(entry AuditLogEntry) {\n153: \tklog.InfoS(\"Deletion audit log\",\n154: \t\t\"sandboxId\", entry.SandboxID,\n155: \t\t\"namespace\", entry.Namespace,\n156: \t\t\"reason\", entry.Reason,\n157: \t\t\"initiator\", entry.Initiator,\n158: \t\t\"duration\", entry.Duration,\n159: \t\t\"resourcesCleaned\", entry.ResourcesCleaned,\n160: \t)\n161: }\n162: \n163: func (er *EventRecorder) LogDeletionComplete(sandbox *Sandbox, reason, initiator string, duration time.Duration, resources []string) {\n164: \tentry := AuditLogEntry{\n165: \t\tSandboxID:        sandbox.SessionID,\n166: \t\tNamespace:        sandbox.Namespace,\n167: \t\tReason:           reason,\n168: \t\tInitiator:        initiator,\n169: \t\tDuration:         int64(duration.Seconds()),\n170: \t\tResourcesCleaned: resources,\n171: \t\tTimestamp:        metav1.Time{Time: time.Now()},\n172: \t}\n173: \ter.logDeletionAudit(entry)\n174: }\n\n(End of file - total 174 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype EventRecorder struct {\n\tk8sClient *kubernetes.Clientset\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/events.go","time":{"start":1775880871010,"end":1775880871029}}}}
