{"type":"tool_use","timestamp":1775849587107,"sessionID":"ses_2871e069fffeDDE9bhBiHTD0uC","part":{"id":"prt_d78e23ca1001NrPG2Njs1aetc2","messageID":"msg_d78e225dc001buzyBbszvDDMDc","sessionID":"ses_2871e069fffeDDE9bhBiHTD0uC","type":"tool","tool":"read","callID":"toolu_3ff0c47958374cf3b37fc916","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/config.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/config.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"time\"\n5: )\n6: \n7: type Config struct {\n8: \tListenAddress       string        // Listen address for the HTTP server (default: \":8080\")\n9: \tBackendTimeout      time.Duration // Timeout for backend requests (default: 30s)\n10: \tIdleTimeout         time.Duration // Idle connection timeout (default: 60s)\n11: \tHealthCheckInterval time.Duration // Health check interval (default: 10s)\n12: \tHealthCheckTimeout  time.Duration // Health check request timeout (default: 5s)\n13: \tMaxConnsPerBackend  int           // Max connections per backend (default: 100)\n14: \tRateLimitEnabled    bool          // Enable rate limiting (default: false)\n15: \tRateLimitRPS        int           // Requests per second for rate limiting (default: 10)\n16: \tAuthEnabled         bool          // Enable authentication (default: false)\n17: \tAuthToken           string        // Bearer token for authentication\n18: \tWatchNamespaces     []string      // Namespaces to watch for CRs (empty = all)\n19: \n20: \t// Session management\n21: \tSessionEnabled         bool          // Enable session management (default: false)\n22: \tSessionTimeout         time.Duration // Session timeout (default: 30m)\n23: \tSessionCookieName      string        // Session cookie name (default: \"AGENTSESSIONID\")\n24: \tSessionMaxActive       int           // Max active sessions (default: 10000)\n25: \tSessionCookieSecure    bool          // Set cookie Secure flag (default: true)\n26: \tSessionCookieHTTPOnly  bool          // Set cookie HttpOnly flag (default: true)\n27: \tSessionCookieDomain    string        // Cookie domain (optional)\n28: \tSessionCleanupInterval time.Duration // Session cleanup interval (default: 5m)\n29: }\n30: \n31: func DefaultConfig() *Config {\n32: \treturn &Config{\n33: \t\tListenAddress:          \":8080\",\n34: \t\tBackendTimeout:         30 * time.Second,\n35: \t\tIdleTimeout:            60 * time.Second,\n36: \t\tHealthCheckInterval:    10 * time.Second,\n37: \t\tHealthCheckTimeout:     5 * time.Second,\n38: \t\tMaxConnsPerBackend:     100,\n39: \t\tRateLimitEnabled:       false,\n40: \t\tRateLimitRPS:           10,\n41: \t\tAuthEnabled:            false,\n42: \t\tAuthToken:              \"\",\n43: \t\tWatchNamespaces:        nil,\n44: \t\tSessionEnabled:         false,\n45: \t\tSessionTimeout:         30 * time.Minute,\n46: \t\tSessionCookieName:      \"AGENTSESSIONID\",\n47: \t\tSessionMaxActive:       10000,\n48: \t\tSessionCookieSecure:    true,\n49: \t\tSessionCookieHTTPOnly:  true,\n50: \t\tSessionCookieDomain:    \"\",\n51: \t\tSessionCleanupInterval: 5 * time.Minute,\n52: \t}\n53: }\n\n(End of file - total 53 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"time\"\n)\n\ntype Config struct {\n\tListenAddress       string        // Listen address for the HTTP server (default: \":8080\")\n\tBackendTimeout      time.Duration // Timeout for backend requests (default: 30s)\n\tIdleTimeout         time.Duration // Idle connection timeout (default: 60s)\n\tHealthCheckInterval time.Duration // Health check interval (default: 10s)\n\tHealthCheckTimeout  time.Duration // Health check request timeout (default: 5s)\n\tMaxConnsPerBackend  int           // Max connections per backend (default: 100)\n\tRateLimitEnabled    bool          // Enable rate limiting (default: false)\n\tRateLimitRPS        int           // Requests per second for rate limiting (default: 10)\n\tAuthEnabled         bool          // Enable authentication (default: false)\n\tAuthToken           string        // Bearer token for authentication\n\tWatchNamespaces     []string      // Namespaces to watch for CRs (empty = all)\n\n\t// Session management","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/config.go","time":{"start":1775849587083,"end":1775849587104}}}}
