etBackendRequests() *prometheus.CounterVec {\n\treturn backendRequests\n}\n\nfunc (m *Metrics) GetBackendHealthy() *prometheus.GaugeVec {\n\treturn backendHealthy\n}\n\nfunc (m *Metrics) GetErrors() *prometheus.CounterVec {\n\treturn errorsTotal\n}\n\nfunc (m *Metrics) SetSessionsActive(count int) {\n\tsessionsActive.Set(float64(count))\n}\n\nfunc (m *Metrics) IncSessionsCreated() {\n\tsessionsCreatedTotal.Inc()\n}\n\nfunc (m *Metrics) IncSessionsExpired() {\n\tsessionsExpiredTotal.Inc()\n}\n\nfunc (m *Metrics) RecordSessionDuration(duration float64) {\n\tsessionDuration.Observe(duration)\n}\n\nfunc (m *Metrics) GetSessionsActive() prometheus.Gauge {\n\treturn sessionsActive\n}\n","additions":20,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/metrics.go","time":{"start":1775848770730,"end":1775848770913}}}}
