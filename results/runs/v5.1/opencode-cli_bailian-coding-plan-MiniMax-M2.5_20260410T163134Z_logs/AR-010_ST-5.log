9 @@\n \n func TestConfig_SessionDefaults(t *testing.T) {\n \tconfig := DefaultConfig()\n \n-\tif !config.SessionEnabled {\n+\tif config.SessionEnabled != false {\n \t\tt.Error(\"Expected SessionEnabled to default to false\")\n \t}\n \tif config.SessionTimeout != 30*time.Minute {\n \t\tt.Errorf(\"Expected SessionTimeout to be 30m, got %v\", config.SessionTimeout)\n@@ -353,12 +353,12 @@\n \t}\n \tif config.SessionMaxActive != 10000 {\n \t\tt.Errorf(\"Expected SessionMaxActive to be 10000, got %d\", config.SessionMaxActive)\n \t}\n-\tif !config.SessionCookieSecure {\n+\tif config.SessionCookieSecure != true {\n \t\tt.Error(\"Expected SessionCookieSecure to default to true\")\n \t}\n-\tif !config.SessionCookieHTTPOnly {\n+\tif config.SessionCookieHTTPOnly != true {\n \t\tt.Error(\"Expected SessionCookieHTTPOnly to default to true\")\n \t}\n \tif config.SessionCleanupInterval != 5*time.Minute {\n \t\tt.Errorf(\"Expected SessionCleanupInterval to be 5m, got %v\", config.SessionCleanupInterval)\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/session_test.go","before":"package router\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n)\n\nfunc TestGenerateSessionID(t *testing.T) {\n\tids := make(map[string]bool)\n\tfor i := 0; i < 1000; i++ {\n\t\tid := GenerateSessionID()\n\t\tif len(id) != 36 {\n\t\t\tt.Errorf(\"Expected UUID v4 format (36 chars), got %d\", len(id))\n\t\t}\n\t\tif ids[id] {\n\t\t\tt.Errorf(\"Duplicate session ID generated: %s\", id)\n\t\t}\n\t\tids[id] = true\n\t}\n\tif len(ids) != 1000 {\n\t\tt.Errorf(\"Expected 1000 unique IDs, got %d\", len(ids))\n\t}\n}\n\nfunc TestGenerateSessionID_Format(t *testing.T) {\n\tid := GenerateSessionID()\n\tif len(id) != 36 {\n\t\tt.Errorf(\"Expected UUID v4 format (36 chars), got %d\", len(id))\n\t}\n\tif id[14] != '4' {\n\t\tt.Errorf(\"Expected version 4 UUID, got %c\", id[14])\n\t}\n}\n\nfunc TestMemorySessionStore_Create(t *testing.T) {\n\tstore := NewMemorySessionStore(10)\n\n\tsession, err := store.Create(\"backend1\", map[string]string{\"key\": \"value\"})\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got %v\", err)\n\t}\n\tif session == nil {\n\t\tt.Error(\"Expected session, got nil\")\n\t}\n\tif session.ID == \"\" {\n\t\tt.Error(\"Expected session ID to be set\")\n\t}\n\tif session.BackendKey != \"backend1\" {\n\t\tt.Errorf(\"Expected backend key 'backend1', got '%s'\", session.BackendKey)\n\t}\n\tif session.Metadata == nil || session.Metadata[\"key\"] != \"value\" {\n\t\tt.Error(\"Expected metadata to be set\")\n\t}\n}\n\nfunc TestMemorySessionStore_Get(t *testing.T) {\n\tstore := NewMemorySessionStore(10)\n\n\tsession, _ := store.Create(\"backend1\", nil)\n\tsessionID := session.ID\n\n\tretrieved := store.Get(sessionID)\n\tif retrieved == nil {\n\t\tt.Error(\"Expected to get session, got nil\")\n\t}\n\tif retrieved.ID != sessionID {\n\t\tt.Errorf(\"Expected session ID %s, got %s\", sessionID, retrieved.ID)\n\t}\n}\n\nfunc TestMemorySessionStore_Get_NotFound(t *testing.T) {\n\tstore := NewMemorySessionStore(10)\n\n\tsession := store.Get(\"nonexistent-id\")\n\tif session != nil {\n\t\tt.Error(\"Expected nil for nonexistent session\")\n\t}\n}\n\nfunc TestMemorySessionStore_Update(t *testing.T) {\n\tstore := NewMemorySessionStore(10)\n\n\tsession, _ := store.Create(\"backend1\", nil)\n\tinitialActivity := session.LastActivity\n\n\ttime.Sleep(10 * time.Millisecond)\n\n\terr := store.Update(session.ID)\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got %v\", err)\n\t}\n\n\tupdated := store.Get(session.ID)\n\tif updated.LastActivity.Before(initialActivity) {\n\t\tt.Error(\"Expected last activity to be updated\")\n\t}\n}\n\nfunc TestMemorySessionStore_Delete(t *testing.T) {\n\tstore := NewMemorySessionStore(10)\n\n\tsession, _ := store.Create(\"backend1\", nil)\n\tsessionID := session.ID\n\n\terr := store.Delete(sessionID)\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got %v\", err)\n\t}\n\n\tdeleted := store.Get(sessionID)\n\tif deleted != nil {\n\t\tt.Error(\"Expected nil after deletion\")\n\t}\n}\n\nfunc TestMemorySessionStore_List(t *testing.T) {\n\tstore := NewMemorySessionStore(10)\n\n\tstore.Create(\"backend1\", nil)\n\tstore.Create(\"backend2\", nil)\n\tstore.Create(\"backend3\", nil)\n\n\tsessions := store.List()\n\tif len(sessions) != 3 {\n\t\tt.Errorf(\"Expected 3 sessions, got %d\", len(sessions))\n\t}\n}\n\nfunc TestMemorySessionStore_MaxSessions(t *testing.T) {\n\tstore := NewMemorySessionStore(2)\n\n\t_, err := store.Create(\"backend1\", nil)\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error for first session, got %v\", err)\n\t}\n\n\t_, err = store.Create(\"backend2\", nil)\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error for second session, got %v\", err)\n\t}\n\n\t_, err = store.Create(\"backend3\", nil)\n\tif err != ErrMaxSessionsExceeded {\n\t\tt.Errorf(\"Expected ErrMaxSessionsExceeded, got %v\", err)\n\t}\n}\n\nfunc TestMemorySessionStore_Cleanup(t *testing.T) {\n\tstore := NewMemorySessionStore(10)\n\n\tsession, _ := store.Create(\"backend1\", nil)\n\tsession.ExpiresAt = time.Now().Add(-1 * time.Hour)\n\n\tcount := store.Cleanup()\n\tif count != 1 {\n\t\tt.Errorf(\"Expected 1 expired session to be cleaned, got %d\", count)\n\t}\n\n\tsessions := store.List()\n\tif len(sessions) != 0 {\n\t\tt.Errorf(\"Expected 0 sessions after cleanup, got %d\", len(sessions))\n\t}\n}\n\nfunc TestMemorySessionStore_GetActiveCount(t *testing.T) {\n\tstore := NewMemorySessionStore(10)\n\n\tstore.Create(\"backend1\", nil)\n\tstore.Create(\"backend2\", nil)\n\tsession, _ := store.Create(\"backend3\", nil)\n\tsession.ExpiresAt = time.Now().Add(-1 * time.Hour)\n\n\tcount := store.GetActiveCount()\n\tif count != 2 {\n\t\tt.Errorf(\"Expected 2 active sessions, got %d\", count)\n\t}\n}\n\nfunc TestMemorySessionStore_InvalidateBackend(t *testing.T) {\n\tstore := NewMemorySessionStore(10)\n\n\tstore.Create(\"backend1\", nil)\n\tstore.Create(\"backend1\", nil)\n\tstore.Create(\"backend2\", nil)\n\n\tcount := store.InvalidateBackend(\"backend1\")\n\tif count != 2 {\n\t\tt.Errorf(\"Expected 2 sessions invalidated, got %d\", count)\n\t}\n\n\tsessions := store.List()\n\tif len(sessions) != 1 {\n\t\tt.Errorf(\"Expected 1 session remaining, got %d\", len(sessions))\n\t}\n\tif sessions[0].BackendKey != \"backend2\" {\n\t\tt.Error(\"Expected remaining session to have backend2\")\n\t}\n}\n\nfunc TestSessionManager_Middleware_ExtractsFromCookie(t *testing.T) {\n\tconfig := DefaultConfig()\n\tconfig.SessionEnabled = true\n\n\tmanager := NewSessionManager(config)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\treq.AddCookie(&http.Cookie{\n\t\tName:  config.SessionCookieName,\n\t\tValue: \"test-session-id\",\n\t})\n\n\tw := httptest.NewRecorder()\n\n\tstore := manager.GetStore()\n\tstore.Create(\"backend1\", nil)\n\n\tnextCalled := false\n\tnext := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tnextCalled = true\n\t})\n\n\tmanager.Middleware(next).ServeHTTP(w, req)\n\n\tif !nextCalled {\n\t\tt.Error(\"Expected next handler to be called\")\n\t}\n\n\tsessionID := req.Header.Get(\"X-Session-ID\")\n\tif sessionID == \"\" {\n\t\tt.Error(\"Expected X-Session-ID header to be set\")\n\t}\n}\n\nfunc TestSessionManager_Middleware_ExtractsFromHeader(t *testing.T) {\n\tconfig := DefaultConfig()\n\tconfig.SessionEnabled = true\n\n\tmanager := NewSessionManager(config)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\treq.Header.Set(\"X-Session-ID\", \"header-session-id\")\n\n\tw := httptest.NewRecorder()\n\n\tnextCalled := false\n\tnext := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tnextCalled = true\n\t})\n\n\tmanager.Middleware(next).ServeHTTP(w, req)\n\n\tif !nextCalled {\n\t\tt.Error(\"Expected next handler to be called\")\n\t}\n\n\tsessionID := req.Header.Get(\"X-Session-ID\")\n\tif sessionID == \"\" {\n\t\tt.Error(\"Expected 