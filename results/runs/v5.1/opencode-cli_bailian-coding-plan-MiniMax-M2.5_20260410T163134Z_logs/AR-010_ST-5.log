n\t\tif session.BackendKey != \"\" {\n\t\t\tr.Header.Set(\"X-Session-Backend\", session.BackendKey)\n\t\t}\n\n\t\tnext.ServeHTTP(w, r)\n\t})\n}\n\nfunc (sm *SessionManager) extractSessionID(r *http.Request) string {\n\tcookie, err := r.Cookie(sm.config.SessionCookieName)\n\tif err == nil && cookie != nil && cookie.Value != \"\" {\n\t\treturn cookie.Value\n\t}\n\n\tsessionID := r.Header.Get(\"X-Session-ID\")\n\tif sessionID != \"\" {\n\t\treturn sessionID\n\t}\n\n\treturn \"\"\n}\n\nfunc (sm *SessionManager) setSessionCookie(w http.ResponseWriter, sessionID string) {\n\tcookie := &http.Cookie{\n\t\tName:     sm.config.SessionCookieName,\n\t\tValue:    sessionID,\n\t\tPath:     \"/\",\n\t\tHttpOnly: sm.config.SessionCookieHTTPOnly,\n\t\tSecure:   sm.config.SessionCookieSecure,\n\t\tExpires:  time.Now().Add(sm.config.SessionTimeout),\n\t\tSameSite: http.SameSiteLaxMode,\n\t}\n\n\tif sm.config.SessionCookieDomain != \"\" {\n\t\tcookie.Domain = sm.config.SessionCookieDomain\n\t}\n\n\thttp.SetCookie(w, cookie)\n}\n\nfunc (sm *SessionManager) StartCleanup() {\n\tticker := time.NewTicker(sm.config.SessionCleanupInterval)\n\tgo func() {\n\t\tfor {\n\t\t\tselect {\n\t\t\tcase <-ticker.C:\n\t\t\t\tsm.store.Cleanup()\n\t\t\tcase <-sm.cleanupCh:\n\t\t\t\tticker.Stop()\n\t\t\t\treturn\n\t\t\t}\n\t\t}\n\t}()\n}\n\nfunc (sm *SessionManager) StopCleanup() {\n\tclose(sm.cleanupCh)\n}\n\nfunc (sm *SessionManager) GetStore() SessionStore {\n\treturn sm.store\n}\n\nfunc (sm *SessionManager) GetSession(r *http.Request) *Session {\n\tsessionID := sm.extractSessionID(r)\n\tif sessionID == \"\" {\n\t\treturn nil\n\t}\n\treturn sm.store.Get(sessionID)\n}\n\nfunc (sm *SessionManager) InvalidateSession(w http.ResponseWriter, sessionID string) error {\n\terr := sm.store.Delete(sessionID)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tcookie := &http.Cookie{\n\t\tName:     sm.config.SessionCookieName,\n\t\tValue:    \"\",\n\t\tPath:     \"/\",\n\t\tHttpOnly: sm.config.SessionCookieHTTPOnly,\n\t\tS