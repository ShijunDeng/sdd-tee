ics{}\n}\n\nfunc (m *Metrics) RecordRequestDuration(method, path, backend string, duration float64) {\n\trequestDuration.WithLabelValues(method, path, backend).Observe(duration)\n}\n\nfunc (m *Metrics) IncBackendRequests(backend string, status string) {\n\tbackendRequests.WithLabelValues(backend, status).Inc()\n}\n\nfunc (m *Metrics) SetBackendHealth(backend string, healthy bool) {\n\tvalue := 0.0\n\tif healthy {\n\t\tvalue = 1.0\n\t}\n\tbackendHealthy.WithLabelValues(backend).Set(value)\n}\n\nfunc (m *Metrics) IncErrors(errType string) {\n\terrorsTotal.WithLabelValues(errType).Inc()\n}\n\nfunc (m *Metrics) GetRequestDuration() *prometheus.HistogramVec {\n\treturn requestDuration\n}\n\nfunc (m *Metrics) GetBackendRequests() *prometheus.CounterVec {\n\treturn backendRequests\n}\n\nfunc (m *Metrics) GetBackendHealthy() *prometheus.GaugeVec {\n\treturn backendHealthy\n}\n\nfunc (m *Metrics) GetErrors() *prometheus.CounterVec {\n\treturn errorsTotal\n}\n","after":"package router\n\nimport (\n\t\"github.com/prometheus/client_golang/prometheus\"\n\t\"github.com/prometheus/client_golang/prometheus/promauto\"\n\t\"sync\"\n)\n\nvar (\n\trequestDuration = promauto.NewHistogramVec(prometheus.HistogramOpts{\n\t\tName:    \"router_request_duration_seconds\",\n\t\tHelp:    \"Time spent processing requests\",\n\t\tBuckets: prometheus.DefBuckets,\n\t}, []string{\"method\", \"path\", \"backend\"})\n\n\tbackendRequests = promauto.NewCounterVec(prometheus.CounterOpts{\n\t\tName: \"router_backend_requests_total\",\n\t\tHelp: \"Total number of requests to backends\",\n\t}, []string{\"backend\", \"status\"})\n\n\tbackendHealthy = promauto.NewGaugeVec(prometheus.GaugeOpts{\n\t\tName: \"router_backend_healthy\",\n\t\tHelp: \"Backend health status (1 = healthy, 0 = unhealthy)\",\n\t}, []string{\"backend\"})\n\n\terrorsTotal = promauto.NewCounterVec(prometheus.CounterOpts{\n\t\tName: \"router_errors_total\",\n\t\tHelp: \"Total number of errors\",\n\t}, []string{\"type\"})\n\n\tsessionsActive