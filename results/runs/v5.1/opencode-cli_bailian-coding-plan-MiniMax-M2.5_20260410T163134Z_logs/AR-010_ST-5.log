: \t}\n39: \n40: \treq = httptest.NewRequest(http.MethodGet, \"/unknown/path\", nil)\n41: \tbackend = handler.GetBackendForRequest(req)\n42: \n43: \tif backend != nil {\n44: \t\tt.Error(\"Expected nil for unknown path\")\n45: \t}\n46: }\n47: \n48: func TestRouteHandler_GetBackendForRequest_HeaderRouting(t *testing.T) {\n49: \tpool := NewBackendPool()\n50: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n51: \n52: \thandler := NewRouteHandler(pool, []string{\"X-Backend\"})\n53: \n54: \treq := httptest.NewRequest(http.MethodGet, \"/any/path\", nil)\n55: \treq.Header.Set(\"X-Backend\", \"backend1\")\n56: \tbackend := handler.GetBackendForRequest(req)\n57: \n58: \tif backend == nil {\n59: \t\tt.Error(\"Expected backend for header X-Backend: backend1\")\n60: \t}\n61: }\n62: \n63: func TestRouteHandler_PathWithQueryParams(t *testing.T) {\n64: \tpool := NewBackendPool()\n65: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/api/\", \"test-backend\")\n66: \n67: \thandler := NewRouteHandler(pool, []string{})\n68: \n69: \treq := httptest.NewRequest(http.MethodGet, \"/api/data?param=value\", nil)\n70: \tbackend := handler.GetBackendForRequest(req)\n71: \n72: \tif backend == nil {\n73: \t\tt.Error(\"Expected backend for path with query params\")\n74: \t}\n75: }\n\n(End of file - total 75 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n)\n\nfunc TestRouteHandler_ServeHTTP(t *testing.T) {\n\tpool := NewBackendPool()\n\tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n\tpool.AddBackend(\"backend2\", \"http://10.0.0.2:8080\", \"/code/\", \"test-backend2\")\n\n\thandler := NewRouteHandler(pool, []string{\"X-Backend\"})\n\n\treq := httptest.NewRequest(http.MethodGet, \"/agent/session-123\", nil)\n\trec := httptest.NewRecorder()\n\n\thandler.ServeHTTP(rec, req)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.