er  *HealthChecker\n\trateLimiter    *RateLimiter\n\tauthenticator  *Authenticator\n\tlogger         *Logger\n\tmetrics        *Metrics\n\tsessionManager *SessionManager\n\tsessionHandler *SessionHandler\n}\n\nfunc NewRouter(config *Config) *Router {\n\tif config == nil {\n\t\tconfig = DefaultConfig()\n\t}\n\n\tpool := NewBackendPool()\n\tproxy := NewProxy(config.BackendTimeout, config.IdleTimeout, config.MaxConnsPerBackend)\n\trouteHandler := NewRouteHandler(pool, []string{\"X-Backend\", \"Content-Type\"})\n\thealthChecker := NewHealthChecker(pool, config.HealthCheckInterval, config.HealthCheckTimeout, 3)\n\trateLimiter := NewRateLimiter(config.RateLimitRPS, config.RateLimitRPS*2, config.RateLimitEnabled)\n\tauthenticator := NewAuthenticator(config.AuthToken, config.AuthEnabled)\n\tlogger := NewLogger(nil)\n\tmetrics := NewMetrics()\n\n\tvar sessionManager *SessionManager\n\tvar sessionHandler *SessionHandler\n\tif config.SessionEnabled {\n\t\tsessionManager = NewSessionManager(config)\n\t\tsessionHandler = NewSessionHandler(sessionManager)\n\t}\n\n\trouter := &Router{\n\t\tconfig:         config,\n\t\tpool:           pool,\n\t\tproxy:          proxy,\n\t\trouteHandler:   routeHandler,\n\t\thealthChecker:  healthChecker,\n\t\trateLimiter:    rateLimiter,\n\t\tauthenticator:  authenticator,\n\t\tlogger:         logger,\n\t\tmetrics:        metrics,\n\t\tsessionManager: sessionManager,\n\t\tsessionHandler: sessionHandler,\n\t}\n\n\tmux := http.NewServeMux()\n\tmux.HandleFunc(\"/\", router.handleRequest)\n\n\tif sessionHandler != nil {\n\t\tmux.Handle(\"/v1/sessions\", sessionHandler)\n\t}\n\n\thandler := logger.Middleware(mux)\n\thandler = rateLimiter.Middleware(handler)\n\thandler = authenticator.Middleware(handler)\n\n\tif sessionManager != nil {\n\t\thandler = sessionManager.Middleware(handler)\n\t}\n\n\trouter.server = &http.Server{\n\t\tAddr:         config.ListenAddress,\n\t\tHandler:      handler,\n\t\tReadTimeout:  config.BackendTimeout,\n\t\tWriteTimeout: config.BackendTimeout,\n\t\tIdleTimeout:  config.IdleTimeout,\n\t}\n\n\treturn router\n}\n\nfunc (r *Router) Start() error {\n\tgo func() {\n\t\tfmt.Printf(\"Starting router on %s\\n\", r.config.ListenAddress)\n\t\tif err := r.server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n\t\t\tfmt.Printf(\"Server error: %v\\n\", err)\n\t\t}\n\t}()\n\n\tr.healthChecker.Start()\n\n\tif r.sessionManager != nil {\n\t\tr.sessionManager.StartCleanup()\n\t}\n\n\treturn nil\n}\n\nfunc (r *Router) Shutdown(ctx context.Context) error {\n\tr.healthChecker.Stop()\n\n\tif r.sessionManager != nil {\n\t\tr.sessionManager.StopCleanup()\n\t}\n\n\tfmt.Println(\"Shutting down router...\")\n\treturn r.server.Shutdown(ctx)\n}\n\nfunc (r *Router) handleRequest(w http.ResponseWriter, req *http.Request) {\n\tstart := time.Now()\n\n\tvar backend *Backend\n\n\tif r.sessionManager != nil {\n\t\tsessionBackendKey := req.Header.Get(\"X-Session-Backend\")\n\t\tif sessionBackendKey != \"\" {\n\t\t\tbackend = r.pool.GetBackendByPath(sessionBackendKey)\n\t\t}\n\t}\n\n\tif backend == nil {\n\t\tbackend = r.routeHandler.GetBackendForRequest(req)\n\t}\n\n\tif backend == nil {\n\t\tr.metrics.IncErrors(\"not_found\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\treturn\n\t}\n\n\tr.proxy.ServeHTTP(w, req, backend)\n\n\tduration := time.Since(start).Seconds()\n\tr.metrics.RecordRequestDuration(req.Method, req.URL.Path, backend.Name, duration)\n\tr.metrics.IncBackendRequests(backend.Name, \"success\")\n}\n\nfunc (r *Router) GetPool() *BackendPool {\n\treturn r.pool\n}\n\nfunc (r *Router) GetConfig() *Config {\n\treturn r.config\n}\n\nfunc (r *Router) GetHealthChecker() *HealthChecker {\n\treturn r.healthChecker\n}\n\nfunc (r *Router) GetMetrics() *Metrics {\n\treturn r.metrics\n}\n\nfunc (r *Router) AddBackend(key, endpoint, pathPrefix, name string) error {\n\treturn r.pool.AddBackend(key, endpoint, pathPrefix, name)\n}\n\nfunc (r *Router) RemoveBackend(key string) {\n\tr.pool.RemoveBackend(key)\n}\n\