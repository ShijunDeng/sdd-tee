L\n            username: Username for authentication\n            password: Password for authentication\n\n        Returns:\n            Dictionary with push status (pushed_image, push_time)\n        \"\"\"\n        try:\n            client = docker.from_env()\n            target_image = image_name\n\n            if registry_url and username and password:\n                self._docker_login_sdk(registry_url, username, password)\n\n                if registry_url not in image_name:\n                    target_image = f\"{registry_url}/{image_name}\"\n                    self._tag_image_sdk(image_name, target_image)\n                    if self.verbose:\n                        self.logger.debug(f\"Retagged image to: {target_image}\")\n\n            if self.verbose:\n                self.logger.debug(f\"Pushing image: {target_image}\")\n\n            start_time = time.time()\n            client.api.push(target_image, stream=True, decode=True)\n            for line in client.api.push(target_image, stream=True, decode=True):\n                if \"status\" in line and self.verbose:\n                    self.logger.debug(line[\"status\"])\n\n            push_time = time.time() - start_time\n\n            return {\n                \"pushed_image\": target_image,\n                \"push_time\": f\"{push_time:.2f}s\",\n            }\n        except NotFound:\n            raise ValueError(f\"Image not found: {image_name}\")\n        except DockerAPIError as e:\n            raise ValueError(f\"Docker API error: {e}\")\n        except Exception as e:\n            self.logger.error(f\"Unexpected error during push: {e}\")\n            raise\n\n    def remove_image(self, image_name: str) -> bool:\n        \"\"\"\n        Remove a Docker image.\n\n        Args:\n            image_name: Name of the image to remove\n\n        Returns:\n            True if successful, False if image doesn't exist or removal fails\n        \"\"\"\n        try:\n            client = docker.from_env()\n            client.images.remove(image_name)\n            if self.verbose:\n                self.logger.debug(f\"Image removed: {image_name}\")\n            return True\n        except NotFound:\n            self.logger.warning(f\"Image not found: {image_name}\")\n            return False\n        except DockerAPIError as e:\n            self.logger.warning(f\"Failed to remove image {image_name}: {e}\")\n            return False\n        except Exception as e:\n            self.logger.warning(f\"Unexpected error removing image {image_name}: {e}\")\n            return False\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/docker_service.py","time":{"start":1775865161366,"end":1775865162016}}}}
