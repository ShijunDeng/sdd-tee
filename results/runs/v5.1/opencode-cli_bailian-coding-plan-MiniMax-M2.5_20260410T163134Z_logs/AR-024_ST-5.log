d.return_value = (mock_image, [])\n mock_docker.return_value = mock_client\n \n with tempfile.TemporaryDirectory() as tmpdir:\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_build_runtime.py","before":"\"\"\"Unit tests for BuildRuntime.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\nimport yaml\n\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestBuildRuntimeValidatePrerequisites:\n    \"\"\"Tests for _validate_build_prerequisites method.\"\"\"\n\n    def test_missing_dockerfile_raises_value_error(self):\n        \"\"\"Test missing Dockerfile raises ValueError.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            runtime = BuildRuntime()\n            with pytest.raises(ValueError, match=\"Dockerfile not found\"):\n                runtime._validate_build_prerequisites(workspace)\n\n    def test_valid_dockerfile_passes(self):\n        \"\"\"Test valid Dockerfile passes.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"Dockerfile\").write_text(\"FROM python:3.11\")\n\n            runtime = BuildRuntime()\n            with patch.object(runtime.docker_service, \"check_docker_available\", return_value=True):\n                runtime._validate_build_prerequisites(workspace)\n\n\nclass TestBuildRuntimeIncrementVersion:\n    \"\"\"Tests for _increment_version method.\"\"\"\n\n    def test_increment_version_simple(self):\n        \"\"\"Test incrementing simple version.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                version=\"1.0.0\",\n            )\n\n            runtime = BuildRuntime()\n            new_version = runtime._increment_version(workspace, metadata)\n\n            assert new_version == \"1.0.1\"\n\n    def test_increment_version_with_suffix(self):\n        \"\"\"Test incrementing version with suffix.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                version=\"1.0.0-beta\",\n            )\n\n            runtime = BuildRuntime()\n            new_version = runtime._increment_version(workspace, metadata)\n\n            assert \"1.0.0\" in new_version\n\n\nclass TestBuildRuntimeBuildLocal:\n    \"\"\"Tests for _build_local method.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_build_local_success(self, mock_docker):\n        \"\"\"Test successful local build.\"\"\"\n        mock_client = MagicMock()\n        mock_image = MagicMock()\n        mock_image.id = \"sha256:abc123\"\n        mock_client.images.build.return_value = (mock_image, [])\n        mock_docker.return_value = mock_client\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"Dockerfile\").write_text(\"FROM python:3.11\")\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n\n            runtime = BuildRuntime()\n            result = runtime._build_local(workspace, metadata, {})\n\n            assert result[\"image_name\"] == \"test-agent\"\n            assert result[\"build_mode\"] == \"local\"\n\n\nclass TestBuildRuntimeBuild:\n    \"\"\"Tests for build method.\"\"\"\n\n    def test_build_with_missing_workspace(self):\n        \"\"\"Test build with missing workspace.\"\"\"\n        runtime = BuildRuntime()\n\n        with pytest.raises(Exception):\n            runtime.build(\"/nonexistent/path\")\n\n\nclass TestBuildRuntimeRevertVersion:\n    \"\"\"Tests for _revert_version method.\"\"\"\n\n    def test_revert_version(self):\n        \"\"\"Test version revert on failure.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"Dockerfile\").write_text(\"FROM python:3.11\")\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                version=\"1.0.0\",\n            )\n\n            import yaml\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = BuildRuntime()\n            runtime._revert_version(workspace, \"0.1.0\")\n\n            loaded = yaml.safe_load(open(workspace / \"agent_metadata.yaml\"))\n            assert loaded[\"version\"] == \"0.1.0\"\n","after":"\"\"\"Unit tests for BuildRuntime.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\nimport yaml\n\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestBuildRuntimeValidatePrerequisites:\n    \"\"\"Tests for _validate_build_prerequisites method.\"\"\"\n\n    def test_missing_dockerfile_raises_value_error(self):\n        \"\"\"Test missing Dockerfile raises ValueError.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            runtime = BuildRuntime()\n            with pytest.raises(ValueError, match=\"Dockerfile not found\"):\n                runtime._validate_build_prerequisites(workspace)\n\n    def test_valid_dockerfile_passes(self):\n        \"\"\"Test valid Dockerfile passes.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"Dockerfile\").write_text(\"FROM python:3.11\")\n\n            runtime = BuildRuntime()\n            with patch.object(runtime.docker_service, \"check_docker_available\", return_value=True):\n                runtime._validate_build_prerequisites(workspace)\n\n\nclass TestBuildRuntimeIncrementVersion:\n    \"\"\"Tests for _increment_version method.\"\"\"\n\n    def test_increment_version_simple(self):\n        \"\"\"Test incrementing simple version.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                version=\"1.0.0\",\n            )\n\n            runtime = BuildRuntime()\n            new_version = runtime._increment_version(workspace, metadata)\n\n            assert new_version == \"1.0.1\"\n\n    def test_increment_version_with_suffix(self):\n        \"\"\"Test incrementing version with suffix.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                version=\"1.0.0-beta\",\n            )\n\n            runtime = BuildRuntime()\n            new_version = runtime._increment_version(workspace, metadata)\n\n            assert \"1.0.0\" in new_version\n\n\nclass TestBuildRuntimeBuildLocal:\n    \"\"\"Tests for _build_local method.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_build_local_success(self, mock_docker):\n        \"\"\"Test successful local build.\"\"\"\n        mock_client = MagicMock()\n        mock_image = MagicMock()\n        mock_image.id = \"sha256:abc123\"\n        mock_image.attrs = {\"Size\": 1024000}\n        mock_client.images.build.return_value = (mock_image, [])\n        mock_docker.return_value = mock_client\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"Dockerfile\").write_text(\"FROM python:3.11\")\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n\n            runtime = BuildRuntime()\n            result = runtime._build_local(workspace, metadata, {})\n\n            assert result[\"image_name\"] == \"test-agent\"\n            assert result[\"build_mode\"] == \"local\"\n\n\nclass TestBuildRuntimeBuild:\n    \"\"\"Tests for build method.\"\"\"\n\n    def test_build_with_missing_workspace(self):\n        \"\"\"Test build with missing workspace.\"\"\"\n        runtime = BuildRuntime()\n\n        with pytest.raises(Exception):\n            runtime.build(\"/nonexistent/path\")\n\n\nclass TestBuildRuntimeRevertVersion:\n    \"\"\"Tests for _revert_version method.\"\"\"\n\n    def test_revert_version(self):\n        \"\"\"Test version revert on failure.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"Dockerfile\").write_text(\"FROM python:3.11\")\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                version=\"1.0.0\",\n            )\n\n            import yaml\n\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata.model_dump(), f)\n\n            runtime = BuildRuntime()\n            runtime._revert_version(workspace, \"0.1.0\")\n\n            loaded = yaml.safe_load(open(workspace / \"agent_metadata.yaml\"))\n            assert loaded[\"version\"] == \"0.1.0\"\n","additions":1,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_build_runtime.py","time":{"start":1775865449580,"end":1775865450208}}}}
