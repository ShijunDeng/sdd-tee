:"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pack_runtime.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pack_runtime.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pack_runtime.py\n@@ -2,9 +2,9 @@\n \n import os\n import tempfile\n from pathlib import Path\n-from unittest.mock import patch\n+from unittest.mock import MagicMock, patch\n \n import pytest\n import yaml\n \n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_pack_runtime.py","before":"\"\"\"Unit tests for PackRuntime.\"\"\"\n\nimport os\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import patch\n\nimport pytest\nimport yaml\n\nfrom agentcube.models.pack_models import MetadataOptions\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestValidateWorkspaceStructure:\n    \"\"\"Tests for _validate_workspace_structure method.\"\"\"\n\n    def test_missing_directory_raises_value_error(self):\n        \"\"\"T080: Missing directory raises ValueError.\"\"\"\n        runtime = PackRuntime()\n        with pytest.raises(ValueError, match=\"does not exist\"):\n            runtime._validate_workspace_structure(Path(\"/nonexistent/path\"))\n\n    def test_valid_python_workspace_passes(self):\n        \"\"\"T081: Valid Python workspace passes.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").touch()\n\n            runtime = PackRuntime()\n            runtime._validate_workspace_structure(workspace)\n\n    def test_valid_java_workspace_passes(self):\n        \"\"\"T082: Valid Java workspace passes.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"pom.xml\").touch()\n\n            runtime = PackRuntime()\n            runtime._validate_workspace_structure(workspace)\n\n\nclass TestValidatePythonCompatibility:\n    \"\"\"Tests for _validate_python_compatibility method.\"\"\"\n\n    def test_no_python_files_raises_value_error(self):\n        \"\"\"T083: No Python files raises ValueError.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            runtime = PackRuntime()\n            with pytest.raises(ValueError, match=\"No Python files found\"):\n                runtime._validate_python_compatibility(workspace)\n\n\nclass TestValidateJavaCompatibility:\n    \"\"\"Tests for _validate_java_compatibility method.\"\"\"\n\n    def test_no_pom_xml_raises_value_error(self):\n        \"\"\"T084: No pom.xml raises ValueError.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            runtime = PackRuntime()\n            with pytest.raises(ValueError, match=\"No pom.xml found\"):\n                runtime._validate_java_compatibility(workspace)\n\n\nclass TestLoadOrCreateMetadata:\n    \"\"\"Tests for _load_or_create_metadata method.\"\"\"\n\n    def test_loads_existing_metadata_file(self):\n        \"\"\"T085: Loads existing metadata file.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            metadata_data = {\n                \"agent_name\": \"test-agent\",\n                \"language\": \"python\",\n                \"entrypoint\": \"python main.py\",\n                \"port\": 8080,\n                \"build_mode\": \"local\",\n            }\n            with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n                yaml.safe_dump(metadata_data, f)\n\n            runtime = PackRuntime()\n            metadata = runtime._load_or_create_metadata(workspace, MetadataOptions())\n\n            assert metadata.agent_name == \"test-agent\"\n            assert metadata.language == \"python\"\n            assert metadata.port == 8080\n\n    def test_creates_defaults_when_no_file(self):\n        \"\"\"T086: Creates defaults when no metadata file.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").touch()\n\n            runtime = PackRuntime()\n            metadata = runtime._load_or_create_metadata(workspace, MetadataOptions())\n\n            assert metadata.language == \"python\"\n            assert metadata.port == 8080\n            assert metadata.build_mode == \"local\"\n            assert metadata.requirements_file == \"requirements.txt\"\n\n\nclass TestApplyOptionOverrides:\n    \"\"\"Tests for _apply_option_overrides method.\"\"\"\n\n    def test_cli_options_override_metadata(self):\n        \"\"\"T087: CLI options override metadata.\"\"\"\n        runtime = PackRuntime()\n        metadata = AgentMetadata(\n            agent_name=\"original\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=8080,\n            build_mode=\"local\",\n        )\n\n        options = MetadataOptions(\n            agent_name=\"override\",\n            port=9000,\n            description=\"New description\",\n        )\n\n        result = runtime._apply_option_overrides(metadata, options)\n\n        assert result.agent_name == \"override\"\n        assert result.port == 9000\n        assert result.description == \"New description\"\n        assert result.language == \"python\"\n\n\nclass TestAgentMetadataValidators:\n    \"\"\"Tests for AgentMetadata validators.\"\"\"\n\n    def test_invalid_language_raises_validation_error(self):\n        \"\"\"T088: Invalid language raises ValidationError.\"\"\"\n        with pytest.raises(ValueError, match=\"Language must be 'python' or 'java'\"):\n            AgentMetadata(\n                agent_name=\"test\",\n                language=\"invalid\",\n                entrypoint=\"python main.py\",\n            )\n\n    def test_invalid_port_raises_validation_error(self):\n        \"\"\"T089: Invalid port raises ValidationError.\"\"\"\n        with pytest.raises(ValueError, match=\"Port must be between 1 and 65535\"):\n            AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=70000,\n            )\n\n    def test_invalid_build_mode_raises_validation_error(self):\n        \"\"\"Test invalid build_mode raises ValidationError.\"\"\"\n        with pytest.raises(ValueError, match=\"Build mode must be 'local' or 'cloud'\"):\n            AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                build_mode=\"invalid\",\n            )\n\n\nclass TestInferEntrypoint:\n    \"\"\"Tests for _infer_entrypoint method.\"\"\"\n\n    def test_finds_main_py_for_python(self):\n        \"\"\"T090: Finds main.py for Python.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").touch()\n\n            runtime = PackRuntime()\n            entrypoint = runtime._infer_entrypoint(workspace, \"python\")\n\n            assert entrypoint == \"python main.py\"\n\n    def test_no_entrypoint_for_missing_main_py(self):\n        \"\"\"Test returns None for missing main.py.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            runtime = PackRuntime()\n            entrypoint = runtime._infer_entrypoint(workspace, \"python\")\n\n            assert entrypoint is None\n\n\nclass TestGenerateDockerfile:\n    \"\"\"Tests for _generate_dockerfile method.\"\"\"\n\n    def test_skips_when_dockerfile_exists(self):\n        \"\"\"T091: Skips when Dockerfile exists.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"Dockerfile\").write_text(\"FROM python:3.11\")\n\n            runtime = PackRuntime()\n            metadata = AgentMetadata(\n                agent_name=\"test\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n\n            result = runtime._generate_dockerfile(workspace, metadata)\n\n            assert result is None\n\n\nclass TestPackEndToEnd:\n    \"\"\"Tests for pack method end-to-end.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_pack_valid_python_workspace(self, mock_from_env):\n        \"\"\"T092: Pack end-to-end with valid workspace.\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        mock_from_env.return_value = mock_client\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n\n            runtime = PackRuntime()\n            result = runtime.pack(\n                workspace_path=str(workspace),\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n                build_mode=\"local\",\n            )\n\n            assert result[\"agent_name\"] == \"test-agent\"\n            assert result[\"dockerfile_generated\"] is True\n\n            metadata_file = workspace / \"agent_metadata.yaml\"\n            assert metadata_file.exists()\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_pack_java_workspace(self, mock_from_env):\n        \"\"\"Test pack Java workspace end-to-end.\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        mock_from_env.return_value = mock_client\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"pom.xml\").write_text(\"<project></project>\")\n\n            runtime = PackRuntime()\n            result = runtime.pack(\n                workspace_path=str(workspace),\n                agent_name=\"java-agent\",\n                language=\"java\",\n                entrypoint=\"java -jar target/app.jar\",\n                port=8080,\n                build_mode=\"local\",\n            )\n\n            assert result[\"agent_name\"] == \"java-agent\"\n            assert result[\"dockerfile_generated\"] is True\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_pack_with_existing_dockerfile(self, mock_from_env):\n        \"\"\"Test pack with existing Dockerfile skips generation.\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        mock_from_env.return_value = mock_client\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n            (workspace / \"Dockerfile\").write_text(\"FROM python:3.11-slim\")\n\n            runtime = PackRuntime()\n            result = runtime.pack(\n                workspace_path=str(workspace),\n                agent_name=\"test-agent\",\n            )\n\n            assert result[\"dockerfile_generated\"] is False\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_pack_with_custom_output(self, mock_from_env):\n        \"\"\"Test pack with custom output path.\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        mock_from_env.return_value = mock_client\n\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").writ