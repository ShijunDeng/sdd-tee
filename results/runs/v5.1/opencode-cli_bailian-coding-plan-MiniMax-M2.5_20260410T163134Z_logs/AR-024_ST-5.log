ents.\"\"\"\n36:         metadata = AgentMetadata(\n37:             agent_name=\"test-agent\",\n38:             language=\"python\",\n39:             entrypoint=\"python main.py\",\n40:             port=8080,\n41:             requirements_file=None,\n42:         )\n43: \n44:         dockerfile = DockerService.generate_python_dockerfile(metadata)\n45: \n46:         assert \"FROM python:3.11-slim\" in dockerfile\n47:         assert \"requirements.txt\" not in dockerfile\n48:         assert \"pip install\" not in dockerfile\n49: \n50: \n51: class TestDockerServiceJava:\n52:     \"\"\"Tests for DockerService.generate_java_dockerfile method.\"\"\"\n53: \n54:     def test_generates_java_dockerfile(self):\n55:         \"\"\"Test generating Java Dockerfile.\"\"\"\n56:         metadata = AgentMetadata(\n57:             agent_name=\"java-agent\",\n58:             language=\"java\",\n59:             entrypoint=\"java -jar target/app.jar\",\n60:             port=8080,\n61:         )\n62: \n63:         dockerfile = DockerService.generate_java_dockerfile(metadata)\n64: \n65:         assert \"FROM maven:3.9-eclipse-temurin-17\" in dockerfile\n66:         assert \"FROM eclipse-temurin:17-jre\" in dockerfile\n67:         assert \"COPY pom.xml\" in dockerfile\n68:         assert \"mvn package\" in dockerfile\n69:         assert \"EXPOSE 8080\" in dockerfile\n70:         assert \"java -jar target/app.jar\" in dockerfile\n71: \n72: \n73: class TestDockerServiceWrite:\n74:     \"\"\"Tests for DockerService.write_dockerfile method.\"\"\"\n75: \n76:     def test_writes_dockerfile(self):\n77:         \"\"\"Test writing Dockerfile to workspace.\"\"\"\n78:         with tempfile.TemporaryDirectory() as tmpdir:\n79:             workspace = Path(tmpdir)\n80:             content = 'FROM python:3.11-slim\\nCMD [\"python\", \"main.py\"]'\n81: \n82:             result = DockerService.write_dockerfile(workspace, content)\n83: \n84:             assert result == workspace / \"Dockerfile\"\n85:        