        with tempfile.TemporaryDirectory() as tmpdir:\n37:             workspace = Path(tmpdir)\n38:             (workspace / \"pom.xml\").touch()\n39: \n40:             runtime = PackRuntime()\n41:             runtime._validate_workspace_structure(workspace)\n42: \n43: \n44: class TestValidatePythonCompatibility:\n45:     \"\"\"Tests for _validate_python_compatibility method.\"\"\"\n46: \n47:     def test_no_python_files_raises_value_error(self):\n48:         \"\"\"T083: No Python files raises ValueError.\"\"\"\n49:         with tempfile.TemporaryDirectory() as tmpdir:\n50:             workspace = Path(tmpdir)\n51: \n52:             runtime = PackRuntime()\n53:             with pytest.raises(ValueError, match=\"No Python files found\"):\n54:                 runtime._validate_python_compatibility(workspace)\n55: \n56: \n57: class TestValidateJavaCompatibility:\n58:     \"\"\"Tests for _validate_java_compatibility method.\"\"\"\n59: \n60:     def test_no_pom_xml_raises_value_error(self):\n61:         \"\"\"T084: No pom.xml raises ValueError.\"\"\"\n62:         with tempfile.TemporaryDirectory() as tmpdir:\n63:             workspace = Path(tmpdir)\n64: \n65:             runtime = PackRuntime()\n66:             with pytest.raises(ValueError, match=\"No pom.xml found\"):\n67:                 runtime._validate_java_compatibility(workspace)\n68: \n69: \n70: class TestLoadOrCreateMetadata:\n71:     \"\"\"Tests for _load_or_create_metadata method.\"\"\"\n72: \n73:     def test_loads_existing_metadata_file(self):\n74:         \"\"\"T085: Loads existing metadata file.\"\"\"\n75:         with tempfile.TemporaryDirectory() as tmpdir:\n76:             workspace = Path(tmpdir)\n77:             metadata_data = {\n78:                 \"agent_name\": \"test-agent\",\n79:                 \"language\": \"python\",\n80:                 \"entrypoint\": \"python main.py\",\n81:                 \"port\": 8080,\n82:                 \"build_mode\": \"local\",\n83:             }\n84:        