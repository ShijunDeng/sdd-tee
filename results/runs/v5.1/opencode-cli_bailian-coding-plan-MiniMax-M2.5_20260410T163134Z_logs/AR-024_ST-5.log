rvice\",\n    \"priority\": \"high\",\n    \"status\": \"in_progress\"\n  }\n]","metadata":{"todos":[{"content":"Add helper methods to DockerService (_format_size, _get_image_info, _docker_login_sdk, _tag_image_sdk)","priority":"high","status":"completed"},{"content":"Update return values for build_image, get_image_info, push_image","priority":"high","status":"completed"},{"content":"Add Docker availability check to PackRuntime for local build mode","priority":"high","status":"completed"},{"content":"Add DockerService to PublishRuntime with _prepare_local_image","priority":"high","status":"completed"},{"content":"Add generic Exception catch and handle remove_image for non-existent","priority":"high","status":"completed"},{"content":"Write comprehensive unit tests for DockerService","priority":"high","status":"in_progress"}],"truncated":false},"title":"1 todos","time":{"start":1775865237472,"end":1775865237477}}}}
