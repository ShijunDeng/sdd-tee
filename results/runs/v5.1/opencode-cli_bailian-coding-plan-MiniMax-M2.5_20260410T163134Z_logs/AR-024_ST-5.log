lass TestDockerServiceGetImageInfo:\n    \"\"\"Tests for DockerService.get_image_info method.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_get_image_info_existing(self, mock_from_env):\n        \"\"\"Test getting image info for existing image (AR-024-003-A).\"\"\"\n        mock_image = MagicMock()\n        mock_image.id = \"sha256:abc123\"\n        mock_image.tags = [\"myagent:latest\", \"myagent:v1.0.0\"]\n        mock_image.attrs = {\"Size\": 1024000, \"Created\": \"2024-01-01T00:00:00Z\"}\n\n        mock_client = MagicMock()\n        mock_client.images.get.return_value = mock_image\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=False)\n        result = service.get_image_info(\"myagent:latest\")\n\n        assert \"id\" in result\n        assert \"tags\" in result\n        assert \"size\" in result\n        assert \"created\" in result\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_get_image_info_not_found(self, mock_from_env):\n        \"\"\"Test getting image info for non-existent image (AR-024-003-B).\"\"\"\n        from docker.errors import NotFound\n\n        mock_client = MagicMock()\n        mock_client.images.get.side_effect = NotFound(\"Image not found\")\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=False)\n\n        with pytest.raises(ValueError, match=\"Image not found\"):\n            service.get_image_info(\"nonexistent:latest\")\n\n\nclass TestDockerServicePushImage:\n    \"\"\"Tests for DockerService.push_image method.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_push_image_without_auth(self, mock_from_env):\n        \"\"\"Test pushing image without authentication (AR-024-004-A).\"\"\"\n        mock_image = MagicMock()\n        mock_client = MagicMock()\n        mock_client.images.get.return_value = mock_image\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=False)\n        result = service.push_image(\"myagent:latest\", registry_url=\"registry.example.com\")\n\n        assert \"pushed_image\" in result\n        assert \"push_time\" in result\n\n    @patch(\"agentcube.services.docker_service.DockerService._docker_login_sdk\")\n    @patch(\"agentcube.services.docker_service.DockerService._tag_image_sdk\")\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_push_image_with_auth(self, mock_from_env, mock_tag, mock_login):\n        \"\"\"Test pushing image with authentication (AR-024-004-B).\"\"\"\n        mock_image = MagicMock()\n        mock_client = MagicMock()\n        mock_client.images.get.return_value = mock_image\n        mock_client.api.push.return_value = iter([])\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=False)\n        result = service.push_image(\n            \"myagent:latest\",\n            registry_url=\"registry.example.com\",\n            username=\"user\",\n            password=\"pass\",\n        )\n\n        mock_login.assert_called_once_with(\"registry.example.com\", \"user\", \"pass\")\n        mock_tag.assert_called_once()\n        assert \"pushed_image\" in result\n        assert \"push_time\" in result\n\n\nclass TestDockerServiceRemoveImage:\n    \"\"\"Tests for DockerService.remove_image method.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_remove_existing_image(self, mock_from_env):\n        \"\"\"Test removing existing image (AR-024-005-A).\"\"\"\n        mock_client = MagicMock()\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=False)\n        result = service.remove_image(\"myagent:latest\")\n\n        assert result is True\n        mock_client.images.remove.assert_called_once_with(\"myagent:latest\")\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_remove_non_existent_image(self, mock_from_env):\n        \"\"\"Test removing non-existent image (AR-024-005-B).\"\"\"\n        from docker.errors import NotFound\n\n        mock_client = MagicMock()\n        mock_client.images.remove.side_effect = NotFound(\"Image not found\")\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=False)\n        result = service.remove_image(\"nonexistent:latest\")\n\n        assert result is False\n\n\nclass TestDockerServiceVerboseLogging:\n    \"\"\"Tests for DockerService verbose logging support.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_verbose_mode_enables_debug_logging(self, mock_from_env):\n        \"\"\"Test verbose mode enables debug logging (AR-024-009-A).\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=True)\n        assert service.verbose is True\n        assert service.logger.level == logging.DEBUG\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_non_verbose_mode_enables_info_logging(self, mock_from_env):\n        \"\"\"Test non-verbose mode uses info logging.\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=False)\n        assert service.verbose is False\n        assert service.logger.level == logging.INFO\n\n\nclass TestDockerServiceErrorHandling:\n    \"\"\"Tests for DockerService error handling.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_handle_generic_docker_exception(self, mock_from_env):\n        \"\"\"Test handling generic Docker exception (AR-024-011-A).\"\"\"\n        mock_from_env.side_effect = Exception(\"Unexpected error\")\n\n        service = DockerService(verbose=False)\n\n        with pytest.raises(Exception):\n            service.check_docker_available()\n","after":"\"\"\"Unit tests for DockerService.\"\"\"\n\nimport logging\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestDockerServicePython:\n    \"\"\"Tests for DockerService.generate_python_dockerfile method.\"\"\"\n\n    def test_generates_python_dockerfile(self):\n        \"\"\"Test generating Python Dockerfile.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=8080,\n            requirements_file=\"requirements.txt\",\n        )\n\n        dockerfile = DockerService.generate_python_dockerfile(metadata)\n\n        assert \"FROM python:3.11-slim\" in dockerfile\n        assert \"WORKDIR /app\" in dockerfile\n        assert \"COPY requirements.txt .\" in dockerfile\n        assert \"RUN pip install\" in dockerfile\n        assert \"EXPOSE 8080\" in dockerfile\n        assert \"python main.py\" in dockerfile\n\n    def test_generates_python_dockerfile_without_requirements(self):\n        \"\"\"Test generating Python Dockerfile without requirements.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=8080,\n            requirements_file=None,\n        )\n\n        dockerfile = DockerService.generate_python_dockerfile(metadata)\n\n        assert \"FROM python:3.11-slim\" in dockerfile\n        assert \"requirements.txt\" not in dockerfile\n        assert \"pip install\" not in dockerfile\n\n\nclass TestDockerServiceJava:\n    \"\"\"Tests for DockerService.generate_java_dockerfile method.\"\"\"\n\n    def test_generates_java_dockerfile(self):\n        \"\"\"Test generating Java Dockerfile.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"java-agent\",\n            language=\"java\",\n            entrypoint=\"java -jar target/app.jar\",\n            port=8080,\n        )\n\n        dockerfile = DockerService.generate_java_dockerfile(metadata)\n\n        assert \"FROM maven:3.9-eclipse-temurin-17\" in dockerfile\n        assert \"FROM eclipse-temurin:17-jre\" in dockerfile\n        assert \"COPY pom.xml\" in dockerfile\n        assert \"mvn package\" in dockerfile\n        assert \"EXPOSE 8080\" in dockerfile\n        assert \"java -jar target/app.jar\" in dockerfile\n\n\nclass TestDockerServiceWrite:\n    \"\"\"Tests for DockerService.write_dockerfile method.\"\"\"\n\n    def test_writes_dockerfile(self):\n        \"\"\"Test writing Dockerfile to workspace.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            content = 'FROM python:3.11-slim\\nCMD [\"python\", \"main.py\"]'\n\n            result = DockerService.write_dockerfile(workspace, content)\n\n            assert result == workspace / \"Dockerfile\"\n            assert result.exists()\n            assert result.read_text() == content\n\n\nclass TestDockerServiceFormatSize:\n    \"\"\"Tests for DockerService._format_size method.\"\"\"\n\n    def test_format_bytes_to_kb(self):\n        \"\"\"Test formatting bytes to KB (AR-024-006-A).\"\"\"\n        result = DockerService._format_size(1024)\n        assert result == \"1.00 KB\"\n\n    def test_format_bytes_to_mb(self):\n        \"\"\"Test formatting bytes to MB (AR-024-006-B).\"\"\"\n        result = DockerService._format_size(10485760)\n        assert result == \"10.00 MB\"\n\n    def test_format_bytes_to_gb(self):\n        \"\"\"Test formatting bytes to GB (AR-024-006-C).\"\"\"\n        result = DockerService._format_size(1073741824)\n        assert result == \"1.00 GB\"\n\n    def test_format_bytes_to_b(self):\n        \"\"\"Test formatting bytes less than 1KB.\"\"\"\n        result = DockerService._format_size(512)\n        assert result == \"512 B\"\n\n\nclass TestDockerServiceCheckDockerAvailable:\n    \"\"\"Tests for DockerService.check_docker_available method.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_docker_running_returns_true(self, mock_from_env):\n        \"\"\"Test Docker running returns true (AR-024-001-A).\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=False)\n        result = service.check_docker_available()\n\n        assert result is True\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_docker_not_running_returns_false(self, mock_from_env):\n        \"\"\"Test Docker not running returns false (AR-024-001-B).\"\"\"\n        from docker.errors import DockerException\n\n        mock_client = MagicMock()\n        mock_client.ping.side_effect = DockerException(\"Docker not running\")\n        mock_from_env.return_value = mock_client\n\n        service = DockerService(verbose=False)\n        result = service.check_docker_available()\n\n        assert result is False\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_docker_not_installed_returns_false(self, mock_from_env):\n        \"\"\"Test Docker not installed returns false (AR-024-001-C).\"\"\"\n        mock_from_env.side_effect = FileNotFoundError(\"Docker socket not found\")\n\n        service = DockerService(verbose=False)\n        result = service.check_docker_available()\n\n        assert result is False\n\n\nclass TestDockerServiceDockerLogin:\n    \"\"\"Tests for DockerService._docker_login_sdk method.\"\"\"\n\n    @patch(\"agentcube.services.docker_service.docker.from_env\")\n    def test_login_to_registry(self, mock_from_env):\n        \"\"\"Test login to regis