{"type":"tool_use","timestamp":1775843627361,"sessionID":"ses_2877918f6ffezvgoFvhl65AcnO","part":{"id":"prt_d78874de4001nO81KufgTwpj8U","messageID":"msg_d78873078001TMJoBx32jtKnn5","sessionID":"ses_2877918f6ffezvgoFvhl65AcnO","type":"tool","tool":"read","callID":"toolu_01e8f27197c84545989c0109","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/server.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"fmt\"\n7: \t\"net\"\n8: \t\"net/http\"\n9: \t\"os\"\n10: \t\"os/signal\"\n11: \t\"sync\"\n12: \t\"time\"\n13: \n14: \t\"github.com/gin-gonic/gin\"\n15: \tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n16: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n17: \t\"k8s.io/apimachinery/pkg/types\"\n18: \t\"k8s.io/klog/v2\"\n19: \n20: \tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n21: )\n22: \n23: const (\n24: \tDefaultPort = 8080\n25: )\n26: \n27: type Config struct {\n28: \tPort            int\n29: \tKubeconfig      string\n30: \tShutdownTimeout time.Duration\n31: \tEnableMetrics   bool\n32: \tEnableLogging   bool\n33: }\n34: \n35: type Server struct {\n36: \tconfig      *Config\n37: \thttpServer  *http.Server\n38: \tworkloadMgr WorkloadManager\n39: \tready       bool\n40: \tmu          sync.RWMutex\n41: \tstopCh      chan struct{}\n42: }\n43: \n44: func NewServer(cfg *Config, workloadMgr WorkloadManager) *Server {\n45: \tif cfg.Port == 0 {\n46: \t\tcfg.Port = DefaultPort\n47: \t}\n48: \tif cfg.ShutdownTimeout == 0 {\n49: \t\tcfg.ShutdownTimeout = 30 * time.Second\n50: \t}\n51: \n52: \tgin.SetMode(gin.ReleaseMode)\n53: \trouter := gin.New()\n54: \n55: \tserver := &Server{\n56: \t\tconfig:      cfg,\n57: \t\tworkloadMgr: workloadMgr,\n58: \t\tstopCh:      make(chan struct{}),\n59: \t}\n60: \n61: \trouter.Use(gin.Recovery())\n62: \trouter.Use(server.loggingMiddleware())\n63: \trouter.Use(server.corsMiddleware())\n64: \n65: \trouter.GET(\"/healthz\", server.handleHealthz)\n66: \trouter.GET(\"/readyz\", server.handleReadyz)\n67: \n68: \tapi := router.Group(\"/api/v1\")\n69: \t{\n70: \t\tapi.GET(\"/namespaces/:namespace/agentruntimes\", server.handleListAgentRuntimes)\n71: \t\tapi.POST(\"/namespaces/:namespace/agentruntimes\", server.handleCreateAgentRuntime)\n72: \t\tapi.GET(\"/namespaces/:namespace/agentruntimes/:name\", server.handleGetAgentRuntime)\n73: \t\tapi.PUT(\"/namespaces/:namespace/agentruntimes/:name\", server.handleUpdateAgentRuntime)\n74: \t\tapi.DELETE(\"/namespaces/:namespace/agentruntimes/:name\", server.handleDeleteAgentRuntime)\n75: \t\tapi.GET(\"/namespaces/:namespace/agentruntimes/:name/status\", server.handleGetAgentRuntimeStatus)\n76: \t\tapi.PATCH(\"/namespaces/:namespace/agentruntimes/:name/status\", server.handlePatchAgentRuntimeStatus)\n77: \n78: \t\tapi.GET(\"/namespaces/:namespace/codeinterpreters\", server.handleListCodeInterpreters)\n79: \t\tapi.POST(\"/namespaces/:namespace/codeinterpreters\", server.handleCreateCodeInterpreter)\n80: \t\tapi.GET(\"/namespaces/:namespace/codeinterpreters/:name\", server.handleGetCodeInterpreter)\n81: \t\tapi.PUT(\"/namespaces/:namespace/codeinterpreters/:name\", server.handleUpdateCodeInterpreter)\n82: \t\tapi.DELETE(\"/namespaces/:namespace/codeinterpreters/:name\", server.handleDeleteCodeInterpreter)\n83: \t\tapi.GET(\"/namespaces/:namespace/codeinterpreters/:name/status\", server.handleGetCodeInterpreterStatus)\n84: \t\tapi.PATCH(\"/namespaces/:namespace/codeinterpreters/:name/status\", server.handlePatchCodeInterpreterStatus)\n85: \t}\n86: \n87: \tserver.httpServer = &http.Server{\n88: \t\tAddr:    fmt.Sprintf(\":%d\", cfg.Port),\n89: \t\tHandler: router,\n90: \t}\n91: \n92: \treturn server\n93: }\n94: \n95: func (s *Server) Start() error {\n96: \tklog.InfoS(\"Starting HTTP server\", \"port\", s.config.Port)\n97: \n98: \tln, err := net.Listen(\"tcp\", fmt.Sprintf(\":%d\", s.config.Port))\n99: \tif err != nil {\n100: \t\treturn fmt.Errorf(\"failed to listen on port %d: %w\", s.config.Port, err)\n101: \t}\n102: \n103: \tgo func() {\n104: \t\tif err := s.httpServer.Serve(ln); err != nil && err != http.ErrServerClosed {\n105: \t\t\tklog.ErrorS(err, \"HTTP server error\")\n106: \t\t}\n107: \t}()\n108: \n109: \ts.SetReady(true)\n110: \tklog.InfoS(\"HTTP server started\", \"port\", s.config.Port)\n111: \treturn nil\n112: }\n113: \n114: func (s *Server) Stop() error {\n115: \tklog.Info(\"Shutting down HTTP server...\")\n116: \ts.SetReady(false)\n117: \n118: \tctx, cancel := context.WithTimeout(context.Background(), s.config.ShutdownTimeout)\n119: \tdefer cancel()\n120: \n121: \tif err := s.httpServer.Shutdown(ctx); err != nil {\n122: \t\treturn fmt.Errorf(\"failed to shutdown HTTP server: %w\", err)\n123: \t}\n124: \n125: \tif s.workloadMgr != nil {\n126: \t\ts.workloadMgr.Close()\n127: \t}\n128: \n129: \tklog.Info(\"HTTP server stopped\")\n130: \treturn nil\n131: }\n132: \n133: func (s *Server) Run() error {\n134: \tif err := s.Start(); err != nil {\n135: \t\treturn err\n136: \t}\n137: \n138: \tsigCh := make(chan os.Signal, 1)\n139: \tsignal.Notify(sigCh, os.Interrupt, os.Kill)\n140: \n141: \t<-sigCh\n142: \tklog.Info(\"Received shutdown signal\")\n143: \n144: \treturn s.Stop()\n145: }\n146: \n147: func (s *Server) SetReady(ready bool) {\n148: \ts.mu.Lock()\n149: \tdefer s.mu.Unlock()\n150: \ts.ready = ready\n151: }\n152: \n153: func (s *Server) IsReady() bool {\n154: \ts.mu.RLock()\n155: \tdefer s.mu.RUnlock()\n156: \treturn s.ready\n157: }\n158: \n159: func (s *Server) loggingMiddleware() gin.HandlerFunc {\n160: \treturn func(c *gin.Context) {\n161: \t\tstart := time.Now()\n162: \t\tpath := c.Request.URL.Path\n163: \t\tmethod := c.Request.Method\n164: \n165: \t\tc.Next()\n166: \n167: \t\tlatency := time.Since(start)\n168: \t\tstatus := c.Writer.Status()\n169: \n170: \t\tif status >= 500 {\n171: \t\t\tklog.ErrorS(nil, \"Request completed with error\",\n172: \t\t\t\t\"method\", method,\n173: \t\t\t\t\"path\", path,\n174: \t\t\t\t\"status\", status,\n175: \t\t\t\t\"latency\", latency)\n176: \t\t} else {\n177: \t\t\tklog.V(4).InfoS(\"Request completed\",\n178: \t\t\t\t\"method\", method,\n179: \t\t\t\t\"path\", path,\n180: \t\t\t\t\"status\", status,\n181: \t\t\t\t\"latency\", latency)\n182: \t\t}\n183: \t}\n184: }\n185: \n186: func (s *Server) corsMiddleware() gin.HandlerFunc {\n187: \treturn func(c *gin.Context) {\n188: \t\tc.Header(\"Access-Control-Allow-Origin\", \"*\")\n189: \t\tc.Header(\"Access-Control-Allow-Methods\", \"GET, POST, PUT, DELETE, PATCH, OPTIONS\")\n190: \t\tc.Header(\"Access-Control-Allow-Headers\", \"Content-Type, Authorization\")\n191: \n192: \t\tif c.Request.Method == \"OPTIONS\" {\n193: \t\t\tc.AbortWithStatus(http.StatusNoContent)\n194: \t\t\treturn\n195: \t\t}\n196: \n197: \t\tc.Next()\n198: \t}\n199: }\n200: \n201: func (s *Server) handleHealthz(c *gin.Context) {\n202: \tc.String(http.StatusOK, \"ok\")\n203: }\n204: \n205: func (s *Server) handleReadyz(c *gin.Context) {\n206: \tif s.IsReady() {\n207: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n208: \t} else {\n209: \t\tc.JSON(http.StatusServiceUnavailable, gin.H{\"status\": \"not ready\"})\n210: \t}\n211: }\n212: \n213: func (s *Server) handleListAgentRuntimes(c *gin.Context) {\n214: \tnamespace := c.Param(\"namespace\")\n215: \n216: \topts := metav1.ListOptions{}\n217: \tif err := c.ShouldBindQuery(&opts); err != nil {\n218: \t\tc.JSON(http.StatusBadRequest, NewAPIError(err.Error(), \"BadRequest\", http.StatusBadRequest))\n219: \t\treturn\n220: \t}\n221: \n222: \tlist, err := s.workloadMgr.ListAgentRuntimes(c.Request.Context(), namespace, opts)\n223: \tif err != nil {\n224: \t\ts.handleError(c, err)\n225: \t\treturn\n226: \t}\n227: \n228: \titems := make([]AgentRuntimeItem, len(list.Items))\n229: \tfor i := range list.Items {\n230: \t\titems[i] = AgentRuntimeItem{\n231: \t\t\tTypeMeta:   list.Items[i].TypeMeta,\n232: \t\t\tObjectMeta: list.Items[i].ObjectMeta,\n233: \t\t\tSpec:       list.Items[i].Spec,\n234: \t\t\tStatus:     list.Items[i].Status,\n235: \t\t}\n236: \t}\n237: \n238: \tlistMeta := &ListMeta{\n239: \t\tContinue:           list.ListMeta.Continue,\n240: \t\tRemainingItemCount: list.ListMeta.RemainingItemCount,\n241: \t\tResourceVersion:    list.ListMeta.ResourceVersion,\n242: \t}\n243: \n244: \tc.JSON(http.StatusOK, AgentRuntimeListResponse{\n245: \t\tKind:       \"AgentRuntimeList\",\n246: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n247: \t\tItems:      items,\n248: \t\tListMeta:   listMeta,\n249: \t})\n250: }\n251: \n252: func (s *Server) handleCreateAgentRuntime(c *gin.Context) {\n253: \tnamespace := c.Param(\"namespace\")\n254: \n255: \tvar req CreateAgentRuntimeRequest\n256: \tif err := c.ShouldBindJSON(&req); err != nil {\n257: \t\tc.JSON(http.StatusBadRequest, NewAPIError(err.Error(), \"BadRequest\", http.StatusBadRequest))\n258: \t\treturn\n259: \t}\n260: \n261: \tagentRuntime := &agentcubev1alpha1.AgentRuntime{\n262: \t\tTypeMeta:   req.TypeMeta,\n263: \t\tObjectMeta: req.ObjectMeta,\n264: \t}\n265: \tif req.Spec != nil {\n266: \t\tspecMap, ok := req.Spec.(map[string]interface{})\n267: \t\tif ok {\n268: \t\t\tspecBytes, _ := json.Marshal(specMap)\n269: \t\t\tjson.Unmarshal(specBytes, &agentRuntime.Spec)\n270: \t\t}\n271: \t}\n272: \n273: \topts := metav1.CreateOptions{}\n274: \tif err := c.ShouldBindQuery(&opts); err != nil {\n275: \t\tc.JSON(http.StatusBadRequest, NewAPIError(err.Error(), \"BadRequest\", http.StatusBadRequest))\n276: \t\treturn\n277: \t}\n278: \n279: \tresult, err := s.workloadMgr.CreateAgentRuntime(c.Request.Context(), namespace, agentRuntime, opts)\n280: \tif err != nil {\n281: \t\ts.handleError(c, err)\n282: \t\treturn\n283: \t}\