 {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tcopied.Name = \"modified\"\n\tif original.Name == copied.Name {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Name\")\n\t}\n\n\tcopied.Spec.MaxSessionDuration = \"4h\"\n\tif original.Spec.MaxSessionDuration == copied.Spec.MaxSessionDuration {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Spec\")\n\t}\n\n\tif copied.Status.Conditions[0].Type != original.Status.Conditions[0].Type {\n\t\tt.Errorf(\"DeepCopy did not copy Status correctly\")\n\t}\n}\n\nfunc TestAgentRuntimeListDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntimeList\",\n\t\t},\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"123\",\n\t\t},\n\t\tItems: []AgentRuntime{\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"runtime-1\"}},\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"runtime-2\"}},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif len(copied.Items) != len(original.Items) {\n\t\tt.Errorf(\"DeepCopyList did not copy all items\")\n\t}\n\n\tcopied.Items[0].Name = \"modified\"\n\tif original.Items[0].Name == copied.Items[0].Name {\n\t\tt.Errorf(\"DeepCopyList did not create independent copy of items\")\n\t}\n}\n\nfunc TestCodeInterpreterDeepCopy(t *testing.T) {\n\truntimeClassName := \"test-class\"\n\toriginal := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-ci\",\n\t\t\tNamespace: \"default\",\n\t\t},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tAuthMode:           AuthModePicod,\n\t\t\tMaxSessionDuration: \"8h\",\n\t\t\tSessionTimeout:     \"15m\",\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{Port: 9000, Protocol: \"HTTP\"},\n\t\t\t},\n\t\t\tTemplate: ContainerTemplateSpec{\n\t\t\t\tImage:            \"python:3.9\",\n\t\t\t\tCommand:          []string{\"python\"},\n\t\t\t\tArgs:             []string{\"-m\", \"http.server\"},\n\t\t\t\tRuntimeClassName: &runtimeClassName,\n\t\t\t},\n\t\t\tWarmPoolSize: 2,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tReady: true,\n\t\t\tConditions: []metav1.Condition{\n\t\t\t\t{Type: \"Ready\", Status: metav1.ConditionTrue},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.Spec.AuthMode != AuthModePicod {\n\t\tt.Errorf(\"AuthMode not copied correctly\")\n\t}\n\n\tif *copied.Spec.Template.RuntimeClassName != *original.Spec.Template.RuntimeClassName {\n\t\tt.Errorf(\"RuntimeClassName not copied correctly\")\n\t}\n}\n\nfunc TestCodeInterpreterListDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreterList\",\n\t\t},\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"456\",\n\t\t},\n\t\tItems: []CodeInterpreter{\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci-1\"}},\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci-2\"}},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif len(copied.Items) != len(original.Items) {\n\t\tt.Errorf(\"DeepCopyList did not copy all items\")\n\t}\n}\n\nfunc TestTargetPortDeepCopy(t *testing.T) {\n\toriginal := &TargetPort{\n\t\tPort:       8080,\n\t\tProtocol:   \"HTTP\",\n\t\tName:       \"http-port\",\n\t\tPathPrefix: \"/api\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tcopied.Port = 9000\n\tif original.Port == copied.Port {\n\t\tt.Errorf(\"DeepCopy did not create independent copy\")\n\t}\n}\n\nfunc TestPodTemplateSpecDeepCopy(t *testing.T) {\n\toriginal := &PodTemplateSpec{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-pod\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels:    map[string]string{\"app\": \"test\"},\n\t\t},\n\t\tSpec: &PodSpec{\n\t\t\tContainers: []ContainerSpec{\n\t\t\t\t{\n\t\t\t\t\tName:  \"main\",\n\t\t\t\t\tImage: \"nginx:latest\",\n\t\t\t\t\tEnv: []corev1.EnvVar{\n\t\t\t\t\t\t{Name: \"ENV\", Value: \"test\"},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\tNodeSelector: map[string]string{\"zone\": \"us-east\"},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tcopied.Spec.NodeSelector[\"zone\"] = \"us-west\"\n\tif original.Spec.NodeSelector[\"zone\"] == \"us-west\" {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of NodeSelector\")\n\t}\n\n\tcopied.Spec.Containers[0].Image = \"alpine\"\n\tif original.Spec.Containers[0].Image == \"alpine\" {\n\t\tt.Errorf(\"DeepCopy did not create independent copy of Containers\")\n\t}\n}\n\nfunc TestContainerTemplateSpecDeepCopy(t *testing.T) {\n\truntimeClassName := \"test-class\"\n\tmemLimit := kresource.NewQuantity(1024, \"Mi\")\n\toriginal := &ContainerTemplateSpec{\n\t\tImage:   \"python:3.9\",\n\t\tCommand: []string{\"python\"},\n\t\tArgs:    []string{\"-m\", \"http.server\"},\n\t\tEnv: []corev1.EnvVar{\n\t\t\t{Name: \"PYTHON_ENV\", Value: \"production\"},\n\t\t},\n\t\tResources: corev1.ResourceRequirements{\n\t\t\tLimits: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceMemory: *memLimit,\n\t\t\t},\n\t\t},\n\t\tRuntimeClassName: &runtimeClassName,\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif *copied.RuntimeClassName != *original.RuntimeClassName {\n\t\tt.Errorf(\"RuntimeClassName not copied correctly\")\n\t}\n}\n\nfunc TestPodSpecDeepCopy(t *testing.T) {\n\tpriority := int32(100)\n\toriginal := &PodSpec{\n\t\tContainers: []ContainerSpec{\n\t\t\t{Name: \"main\", Image: \"nginx:latest\"},\n\t\t},\n\t\tVolumes: []corev1.Volume{\n\t\t\t{Name: \"config\"},\n\t\t},\n\t\tRestartPolicy: corev1.RestartPolicyAlways,\n\t\tNodeSelector: map[string]