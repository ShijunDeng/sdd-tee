ntimeClassName != *original.RuntimeClassName {\n\t\tt.Errorf(\"RuntimeClassName not copied correctly\")\n\t}\n}\n\nfunc TestPodSpecDeepCopy(t *testing.T) {\n\tpriority := int32(100)\n\toriginal := &PodSpec{\n\t\tContainers: []ContainerSpec{\n\t\t\t{Name: \"main\", Image: \"nginx:latest\"},\n\t\t},\n\t\tVolumes: []corev1.Volume{\n\t\t\t{Name: \"config\"},\n\t\t},\n\t\tRestartPolicy: corev1.RestartPolicyAlways,\n\t\tNodeSelector: map[string]string{\n\t\t\t\"zone\": \"us-east\",\n\t\t},\n\t\tPriority: &priority,\n\t\tTolerations: []corev1.Toleration{\n\t\t\t{Key: \"key\", Operator: \"Equal\", Value: \"value\"},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif *copied.Priority != *original.Priority {\n\t\tt.Errorf(\"Priority not copied correctly\")\n\t}\n\n\tcopied.NodeSelector[\"zone\"] = \"us-west\"\n\tif original.NodeSelector[\"zone\"] == \"us-west\" {\n\t\tt.Errorf(\"DeepCopy did not create independent copy\")\n\t}\n}\n\nfunc TestContainerSpecDeepCopy(t *testing.T) {\n\toriginal := &ContainerSpec{\n\t\tName:    \"main\",\n\t\tImage:   \"nginx:latest\",\n\t\tCommand: []string{\"/bin/sh\"},\n\t\tArgs:    []string{\"-c\", \"echo hello\"},\n\t\tEnv: []corev1.EnvVar{\n\t\t\t{Name: \"FOO\", Value: \"bar\"},\n\t\t},\n\t\tResources: corev1.ResourceRequirements{\n\t\t\tLimits: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceCPU: *original.NewQuantity(1000, \"m\"),\n\t\t\t},\n\t\t},\n\t\tLivenessProbe: &corev1.Probe{\n\t\t\tInitialDelaySeconds: 10,\n\t\t},\n\t\tSecurityContext: &corev1.SecurityContext{\n\t\t\tRunAsNonRoot: newBool(false),\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.LivenessProbe.InitialDelaySeconds != original.LivenessProbe.InitialDelaySeconds {\n\t\tt.Errorf(\"LivenessProbe not copied correctly\")\n\t}\n\n\tcopied.Env[0].Value 