inal, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.Ready != true {\n\t\tt.Errorf(\"Ready not copied correctly\")\n\t}\n\n\tcopied.Ready = false\n\tif original.Ready == false {\n\t\tt.Errorf(\"DeepCopy did not create independent copy\")\n\t}\n}\n\nfunc TestSchemeGroupVersion(t *testing.T) {\n\tif SchemeGroupVersion.Group != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"SchemeGroupVersion has wrong group: %s\", SchemeGroupVersion.Group)\n\t}\n\tif SchemeGroupVersion.Version != \"v1alpha1\" {\n\t\tt.Errorf(\"SchemeGroupVersion has wrong version: %s\", SchemeGroupVersion.Version)\n\t}\n}\n\nfunc TestResource(t *testing.T) {\n\tresource := Resource(\"agentruntimes\")\n\tif resource.Group != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"Resource has wrong group\")\n\t}\n\tif resource.Resource != \"agentruntimes\" {\n\t\tt.Errorf(\"Resource has wrong resource name\")\n\t}\n}\n\nfunc TestAuthMode(t *testing.T) {\n\tif AuthModePicod != \"picod\" {\n\t\tt.Errorf(\"AuthModePicod has wrong value\")\n\t}\n\tif AuthModeNone != \"none\" {\n\t\tt.Errorf(\"AuthModeNone has wrong value\")\n\t}\n}\n\nfunc (r *ResourceRequirements) NewQuantity(value int64, suffix string) *resourceInfo {\n\tpanic(\"unimplemented\")\n}\n\ntype resourceInfo struct{}\n\nfunc TestContainerSpecNewQuantity(t *testing.T) {\n\tspec := &ContainerSpec{}\n\tq := spec.NewQuantity(1024, \"Mi\")\n\tif q == nil {\n\t\tt.Error(\"NewQuantity should not return nil\")\n\t}\n}\n","additions":2,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/types_test.go","time":{"start":1775840455472,"end":1775840455653}}}}
