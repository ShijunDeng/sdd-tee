de:           AuthModePicod,\n\t\t\tMaxSessionDuration: \"8h\",\n\t\t\tSessionTimeout:     \"15m\",\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{Port: 9000, Protocol: \"HTTP\"},\n\t\t\t},\n\t\t\tTemplate: ContainerTemplateSpec{\n\t\t\t\tImage:            \"python:3.9\",\n\t\t\t\tCommand:          []string{\"python\"},\n\t\t\t\tArgs:             []string{\"-m\", \"http.server\"},\n\t\t\t\tRuntimeClassName: &runtimeClassName,\n\t\t\t},\n\t\t\tWarmPoolSize: 2,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tReady: true,\n\t\t\tConditions: []metav1.Condition{\n\t\t\t\t{Type: \"Ready\", Status: metav1.ConditionTrue},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tif copied.Spec.AuthMode != AuthModePicod {\n\t\tt.Errorf(\"AuthMode not copied correctly\")\n\t}\n\n\tif *copied.Spec.Template.RuntimeClassName != *original.Spec.Template.RuntimeClassName {\n\t\tt.Errorf(\"RuntimeClassName not copied correctly\")\n\t}\n}\n\nfunc TestCodeInterpreterListDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreterList\",\n\t\t},\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"456\",\n\t\t},\n\t\tItems: []CodeInterpreter{\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci-1\"}},\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci-2\"}},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif len(copied.Items) != len(original.Items) {\n\t\tt.Errorf(\"DeepCopyList did not copy all items\")\n\t}\n}\n\nfunc TestTargetPortDeepCopy(t *testing.T) {\n\toriginal := &TargetPort{\n\t\tPort:       8080,\n\t\tProtocol:   \"HTTP\",\n\t\tName:       \"http-port\",\n\t\tPathPrefix: \"/api\",\n\t}\n\n\tcopied := original.DeepCopy()\n\n\tif !reflect.DeepEqual(original, copied) {\n\t\tt.Errorf(\"DeepCopy returned different object\")\n\t}\n\n\tcopied.P