pied.PodTemplate.Name = \"modified\"\n351: \tif original.PodTemplate.Name == \"modified\" {\n352: \t\tt.Errorf(\"DeepCopy did not create independent copy of PodTemplate\")\n353: \t}\n354: }\n355: \n356: func TestAgentRuntimeStatusDeepCopy(t *testing.T) {\n357: \toriginal := &AgentRuntimeStatus{\n358: \t\tConditions: []metav1.Condition{\n359: \t\t\t{\n360: \t\t\t\tType:               \"Ready\",\n361: \t\t\t\tStatus:             metav1.ConditionTrue,\n362: \t\t\t\tLastTransitionTime: metav1.Now(),\n363: \t\t\t\tReason:             \"Ready\",\n364: \t\t\t\tMessage:            \"Runtime is ready\",\n365: \t\t\t},\n366: \t\t},\n367: \t\tObservedGeneration: 1,\n368: \t}\n369: \n370: \tcopied := original.DeepCopy()\n371: \n372: \tif !reflect.DeepEqual(original, copied) {\n373: \t\tt.Errorf(\"DeepCopy returned different object\")\n374: \t}\n375: \n376: \tcopied.Conditions[0].Status = metav1.ConditionFalse\n377: \tif original.Conditions[0].Status == metav1.ConditionFalse {\n378: \t\tt.Errorf(\"DeepCopy did not create independent copy of Conditions\")\n379: \t}\n380: }\n381: \n382: func TestCodeInterpreterSpecDeepCopy(t *testing.T) {\n383: \toriginal := &CodeInterpreterSpec{\n384: \t\tAuthMode:           AuthModePicod,\n385: \t\tMaxSessionDuration: \"8h\",\n386: \t\tSessionTimeout:     \"15m\",\n387: \t\tPorts:              []TargetPort{{Port: 9000, Protocol: \"HTTP\"}},\n388: \t\tTemplate:           ContainerTemplateSpec{Image: \"python:3.9\"},\n389: \t\tWarmPoolSize:       2,\n390: \t}\n391: \n392: \tcopied := original.DeepCopy()\n393: \n394: \tif !reflect.DeepEqual(original, copied) {\n395: \t\tt.Errorf(\"DeepCopy returned different object\")\n396: \t}\n397: \n398: \tif copied.AuthMode != AuthModePicod {\n399: \t\tt.Errorf(\"AuthMode not copied correctly\")\n400: \t}\n401: \n402: \tif copied.WarmPoolSize != 2 {\n403: \t\tt.Errorf(\"WarmPoolSize not copied correctly\")\n404: \t}\n405: \n406: \tcopied.Ports[0].Port = 8080\n407: \tif original.Ports[0].Port == 8080 {\n408: \t\tt.Errorf(\"DeepCopy did not create independent copy of Ports\")\n409: \t}\n410: }\n411: \n412: func TestCodeInterpreterStatusDeepCopy(t *testing.T) {\n413: \toriginal := &CodeInterpreterStatus{\n414: \t\tReady: true,\n415: \t\tConditions: []metav1.Condition{\n416: \t\t\t{Type: \"Ready\", Status: metav1.ConditionTrue},\n417: \t\t},\n418: \t\tObservedGeneration: 1,\n419: \t}\n420: \n421: \tcopied := original.DeepCopy()\n422: \n423: \tif !reflect.DeepEqual(original, copied) {\n424: \t\tt.Errorf(\"DeepCopy returned different object\")\n425: \t}\n426: \n427: \tif copied.Ready != true {\n428: \t\tt.Errorf(\"Ready not copied correctly\")\n429: \t}\n430: \n431: \tcopied.Ready = false\n432: \tif original.Ready == false {\n433: \t\tt.Errorf(\"DeepCopy did not create independent copy\")\n434: \t}\n435: }\n436: \n437: func TestSchemeGroupVersion(t *testing.T) {\n438: \tif SchemeGroupVersion.Group != \"runtime.agentcube.volcano.sh\" {\n439: \t\tt.Errorf(\"SchemeGroupVersion has wrong group: %s\", SchemeGroupVersion.Group)\n440: \t}\n441: \tif SchemeGroupVersion.Version != \"v1alpha1\" {\n442: \t\tt.Errorf(\"SchemeGroupVersion has wrong version: %s\", SchemeGroupVersion.Version)\n443: \t}\n444: }\n445: \n446: func TestResource(t *testing.T) {\n447: \tresource := Resource(\"agentruntimes\")\n448: \tif resource.Group != \"runtime.agentcube.volcano.sh\" {\n449: \t\tt.Errorf(\"Resource has wrong group\")\n450: \t}\n451: \tif resource.Resource != \"agentruntimes\" {\n452: \t\tt.Errorf(\"Resource has wrong resource name\")\n453: \t}\n454: }\n455: \n456: func TestAuthMode(t *testing.T) {\n457: \tif AuthModePicod != \"picod\" {\n458: \t\tt.Errorf(\"AuthModePicod has wrong value\")\n459: \t}\n460: \tif AuthModeNone != \"none\" {\n461: \t\tt.Errorf(\"AuthModeNone has wrong value\")\n462: \t}\n463: }\n464: \n465: func (r *ResourceRequirements) NewQuantity(value int64, suffix string) *resourceInfo {\n466: \tpanic(\"unimplemented\")\n467: }\n468: \n469: type resourceInfo struct{}\n470: \n471