h Complete\",\n382:                 style=\"green\",\n383:             )\n384:         )\n385: \n386:     except Exception as e:\n387:         _handle_error(e, \"publish\", verbose)\n388:         raise typer.Exit(code=1)\n389: \n390: \n391: @app.command()\n392: def invoke(\n393:     workspace: str = typer.Option(\n394:         \".\",\n395:         \"-f\",\n396:         \"--workspace\",\n397:         help=\"Path to the agent workspace directory\",\n398:     ),\n399:     payload: str = typer.Option(\n400:         \"{}\",\n401:         \"--payload\",\n402:         help=\"JSON-formatted input passed to the agent\",\n403:     ),\n404:     header_list: Optional[list[str]] = typer.Option(\n405:         None,\n406:         \"--header\",\n407:         help=\"Custom HTTP headers (key:value format)\",\n408:     ),\n409:     provider: str = typer.Option(\n410:         \"agentcube\",\n411:         \"--provider\",\n412:         help=\"Target provider: 'agentcube' or 'k8s'\",\n413:     ),\n414:     verbose: bool = typer.Option(\n415:         False,\n416:         \"--verbose\",\n417:         help=\"Enable detailed logging\",\n418:     ),\n419: ) -> None:\n420:     \"\"\"\n421:     Invoke a published agent.\n422: \n423:     Posts JSON to the published agent endpoint and returns the response.\n424:     \"\"\"\n425:     try:\n426:         if verbose:\n427:             logging.basicConfig(level=logging.DEBUG)\n428: \n429:         with Progress(\n430:             SpinnerColumn(),\n431:             TextColumn(\"[progress.description]{task.description}\"),\n432:             console=console,\n433:         ) as progress:\n434:             task = progress.add_task(\"Invoking agent...\", total=None)\n435: \n436:             runtime = InvokeRuntime(verbose=verbose, provider=provider)\n437: \n438:             result = runtime.invoke(\n439:                 workspace_path=workspace,\n440:                 payload=payload,\n441:                 header_list=header_list,\n442:                 provider=provider,\n443:                 verbose=verbose,\n444:             )\n445: \n446:             progress.update(task, completed=True)\n447: \n448:         console.print(\n449:             Panel(\n450:                 f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n451:                 f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n452:                 f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n453:                 f\"[bold]Response:[/bold]\",\n454:                 title=\"Invoke Complete\",\n455:                 style=\"green\",\n456:             )\n457:         )\n458: \n459:         import json\n460: \n461:         console.print_json(json.dumps(result[\"response\"], indent=2))\n462: \n463:     except Exception as e:\n464:         _handle_error(e, \"invoke\", verbose)\n465:         raise typer.Exit(code=1)\n466: \n467: \n468: @app.command()\n469: def status(\n470:     workspace: str = typer.Option(\n471:         \".\",\n472:         \"-f\",\n473:         \"--workspace\",\n474:         help=\"Path to the agent workspace directory\",\n475:     ),\n476:     provider: str = typer.Option(\n477:         \"agentcube\",\n478:         \"--provider\",\n479:         help=\"Target provider: 'agentcube' or 'k8s'\",\n480:     ),\n481:     verbose: bool = typer.Option(\n482:         False,\n483:         \"--verbose\",\n484:         help=\"Enable detailed logging\",\n485:     ),\n486: ) -> None:\n487:     \"\"\"\n488:     Check the status of a published agent.\n489: \n490:     Loads workspace metadata and displays agent status in a table.\n491:     \"\"\"\n492:     try:\n493:         if verbose:\n494:             logging.basicConfig(level=logging.DEBUG)\n495: \n496:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n497: \n498:         result = runtime.get_status(\n499:             workspace_path=workspace,\n500:             provider=provider,\n501:         )\n502: \n503:         table = Table(title=f\"Agent Status: {result.get('a