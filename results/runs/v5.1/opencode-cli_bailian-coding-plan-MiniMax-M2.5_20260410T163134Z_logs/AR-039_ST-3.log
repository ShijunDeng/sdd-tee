{"type":"tool_use","timestamp":1775882708612,"sessionID":"ses_28524d66cffePG3Ba89bHGEPE1","part":{"id":"prt_d7adb9eb3001K1prL4ysrGEVmi","messageID":"msg_d7adb862f0011oXRBu7pyA6AMn","sessionID":"ses_28524d66cffePG3Ba89bHGEPE1","type":"tool","tool":"read","callID":"toolu_e160bf5c827742778a0d0bb5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"net/http\"\n6: \t\"net/http/httptest\"\n7: \t\"testing\"\n8: \t\"time\"\n9: )\n10: \n11: func TestNewRouter(t *testing.T) {\n12: \trouter := NewRouter(nil)\n13: \n14: \tif router == nil {\n15: \t\tt.Error(\"Expected router to be created\")\n16: \t}\n17: \n18: \tif router.config == nil {\n19: \t\tt.Error(\"Expected config to be set\")\n20: \t}\n21: \n22: \tif router.pool == nil {\n23: \t\tt.Error(\"Expected pool to be created\")\n24: \t}\n25: \n26: \tif router.proxy == nil {\n27: \t\tt.Error(\"Expected proxy to be created\")\n28: \t}\n29: }\n30: \n31: func TestNewRouter_CustomConfig(t *testing.T) {\n32: \tconfig := &Config{\n33: \t\tListenAddress:    \":9090\",\n34: \t\tBackendTimeout:   60 * time.Second,\n35: \t\tIdleTimeout:      120 * time.Second,\n36: \t\tRateLimitEnabled: true,\n37: \t\tRateLimitRPS:     50,\n38: \t\tAuthEnabled:      true,\n39: \t\tAuthToken:        \"test-token\",\n40: \t}\n41: \n42: \trouter := NewRouter(config)\n43: \n44: \tif router.config.ListenAddress != \":9090\" {\n45: \t\tt.Errorf(\"Expected :9090, got %s\", router.config.ListenAddress)\n46: \t}\n47: \n48: \tif router.config.RateLimitRPS != 50 {\n49: \t\tt.Errorf(\"Expected 50, got %d\", router.config.RateLimitRPS)\n50: \t}\n51: }\n52: \n53: func TestRouter_AddBackend(t *testing.T) {\n54: \trouter := NewRouter(nil)\n55: \n56: \terr := router.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test\")\n57: \tif err != nil {\n58: \t\tt.Errorf(\"Expected no error, got %v\", err)\n59: \t}\n60: \n61: \tbackend := router.pool.GetAllBackends()[\"backend1\"]\n62: \tif backend == nil {\n63: \t\tt.Error(\"Expected backend to be added\")\n64: \t}\n65: }\n66: \n67: func TestRouter_RemoveBackend(t *testing.T) {\n68: \trouter := NewRouter(nil)\n69: \n70: \trouter.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test\")\n71: \trouter.RemoveBackend(\"backend1\")\n72: \n73: \tbackend := router.pool.GetAllBackends()[\"backend1\"]\n74: \tif backend != nil {\n75: \t\tt.Error(\"Expected backend to be removed\")\n76: \t}\n77: }\n78: \n79: func TestRouter_SetHeaderRoute(t *testing.T) {\n80: \trouter := NewRouter(nil)\n81: \n82: \trouter.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test\")\n83: \trouter.SetHeaderRoute(\"X-Backend\", \"backend1\", \"backend1\")\n84: \n85: \tbackend := router.pool.GetBackendByHeader(\"X-Backend\", \"backend1\")\n86: \tif backend == nil {\n87: \t\tt.Error(\"Expected backend for header route\")\n88: \t}\n89: }\n90: \n91: func TestRouter_GetConfig(t *testing.T) {\n92: \tconfig := DefaultConfig()\n93: \trouter := NewRouter(config)\n94: \n95: \tcfg := router.GetConfig()\n96: \tif cfg != config {\n97: \t\tt.Error(\"Expected config to be the same\")\n98: \t}\n99: \n100: \tif cfg.ListenAddress != \":8080\" {\n101: \t\tt.Errorf(\"Expected :8080, got %s\", cfg.ListenAddress)\n102: \t}\n103: }\n104: \n105: func TestRouter_GetPool(t *testing.T) {\n106: \trouter := NewRouter(nil)\n107: \n108: \tpool := router.GetPool()\n109: \tif pool == nil {\n110: \t\tt.Error(\"Expected pool to be returned\")\n111: \t}\n112: }\n113: \n114: func TestRouter_GetHealthChecker(t *testing.T) {\n115: \trouter := NewRouter(nil)\n116: \n117: \thc := router.GetHealthChecker()\n118: \tif hc == nil {\n119: \t\tt.Error(\"Expected health checker to be returned\")\n120: \t}\n121: }\n122: \n123: func TestRouter_GetMetrics(t *testing.T) {\n124: \trouter := NewRouter(nil)\n125: \n126: \tmetrics := router.GetMetrics()\n127: \tif metrics == nil {\n128: \t\tt.Error(\"Expected metrics to be returned\")\n129: \t}\n130: }\n131: \n132: func TestRouter_Start_Shutdown(t *testing.T) {\n133: \tconfig := &Config{\n134: \t\tListenAddress: \":18080\",\n135: \t}\n136: \trouter := NewRouter(config)\n137: \n138: \terr := router.Start()\n139: \tif err != nil {\n140: \t\tt.Errorf(\"Expected no error, got %v\", err)\n141: \t}\n142: \n143: \ttime.Sleep(100 * time.Millisecond)\n144: \n145: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n146: \tdefer cancel()\n147: \n148: \terr = router.Shutdown(ctx)\n149: \tif err != nil {\n150: \t\tt.Errorf(\"Expected no error on shutdown, got %v\", err)\n151: \t}\n152: }\n153: \n154: func TestRouter_HandleRequest_NoBackend(t *testing.T) {\n155: \trouter := NewRouter(&Config{\n156: \t\tListenAddress: \":18081\",\n157: \t})\n158: \n159: \treq := httptest.NewRequest(http.MethodGet, \"/unknown\", nil)\n160: \trec := httptest.NewRecorder()\n161: \n162: \trouter.handleRequest(rec, req)\n163: \n164: \tif rec.Code != http.StatusNotFound {\n165: \t\tt.Errorf(\"Expected 404, got %d\", rec.Code)\n166: \t}\n167: }\n\n(End of file - total 167 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n)\n\nfunc TestNewRouter(t *testing.T) {\n\trouter := NewRouter(nil)\n\n\tif router == nil {\n\t\tt.Error(\"Expected router to be created\")\n\t}\n\n\tif router.config == nil {\n\t\tt.Error(\"Expected config to be set\")\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server_test.go","time":{"start":1775882708598,"end":1775882708611}}}}
