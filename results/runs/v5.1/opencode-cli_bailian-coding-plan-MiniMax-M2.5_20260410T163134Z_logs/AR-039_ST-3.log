Expected 1 backend after removal, got %d\", len(backends))\n45: \t}\n46: \n47: \tif _, exists := backends[\"backend1\"]; exists {\n48: \t\tt.Error(\"Expected backend1 to be removed\")\n49: \t}\n50: }\n51: \n52: func TestBackendPool_UpdateBackend(t *testing.T) {\n53: \tpool := NewBackendPool()\n54: \n55: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n56: \n57: \terr := pool.UpdateBackend(\"backend1\", \"http://10.0.0.2:9090\", \"/api/\")\n58: \tif err != nil {\n59: \t\tt.Errorf(\"Expected no error, got %v\", err)\n60: \t}\n61: \n62: \tbackends := pool.GetAllBackends()\n63: \tif backends[\"backend1\"].URL.Host != \"10.0.0.2:9090\" {\n64: \t\tt.Errorf(\"Expected host 10.0.0.2:9090, got %s\", backends[\"backend1\"].URL.Host)\n65: \t}\n66: }\n67: \n68: func TestBackendPool_GetBackendByPath(t *testing.T) {\n69: \tpool := NewBackendPool()\n70: \n71: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n72: \tpool.AddBackend(\"backend2\", \"http://10.0.0.2:8080\", \"/code/\", \"test-backend2\")\n73: \n74: \tbackend := pool.GetBackendByPath(\"/agent/session-123\")\n75: \tif backend == nil {\n76: \t\tt.Error(\"Expected backend for /agent/ path\")\n77: \t}\n78: \n79: \t// Without a default backend set, unknown paths should return nil\n80: \tbackend = pool.GetBackendByPath(\"/unknown\")\n81: \tif backend == nil {\n82: \t\tt.Error(\"Expected default backend for unknown path\")\n83: \t}\n84: }\n85: \n86: func TestBackendPool_GetBackendByPath_PrefixMatching(t *testing.T) {\n87: \tpool := NewBackendPool()\n88: \n89: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n90: \n91: \tbackend := pool.GetBackendByPath(\"/agent/test\")\n92: \tif backend == nil {\n93: \t\tt.Error(\"Expected backend for /agent/test path\")\n94: \t}\n95: \n96: \tbackend = pool.GetBackendByPath(\"/agent\")\n97: \tif backend == nil {\n98: \t\tt.Error(\"Expected backend for /agent path\")\n99: \t}\n100: }\n101: \n102: func TestBackendPool_SetHeaderRoute(t *testing.T) {\n103: \tpool := NewBackendPool()\n104: \n105: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n106: \n107: \tpool.SetHeaderRoute(\"X-Backend\", \"backend1\", \"backend1\")\n108: \n109: \tbackend := pool.GetBackendByHeader(\"X-Backend\", \"backend1\")\n110: \tif backend == nil {\n111: \t\tt.Error(\"Expected backend for header route\")\n112: \t}\n113: \n114: \tbackend = pool.GetBackendByHeader(\"X-Backend\", \"nonexistent\")\n115: \tif backend != nil {\n116: \t\tt.Error(\"Expected nil for non-existent header route\")\n117: \t}\n118: }\n119: \n120: func TestBackendPool_SetDefaultBackend(t *testing.T) {\n121: \tpool := NewBackendPool()\n122: \n123: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n124: \tpool.AddBackend(\"backend2\", \"http://10.0.0.2:8080\", \"/code/\", \"test-backend2\")\n125: \n126: \tpool.SetDefaultBackend(\"backend2\")\n127: \n128: \tbackend := pool.GetBackendByPath(\"/unknown\")\n129: \tif backend == nil {\n130: \t\tt.Error(\"Expected default backend for unknown path\")\n131: \t}\n132: }\n133: \n134: func TestBackend_SetHealthy(t *testing.T) {\n135: \tpool := NewBackendPool()\n136: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n137: \n138: \tbackend := pool.backends[\"backend1\"]\n139: \n140: \tbackend.SetHealthy(false)\n141: \tif backend.IsHealthy() {\n142: \t\tt.Error(\"Expected backend to be unhealthy\")\n143: \t}\n144: \n145: \tbackend.SetHealthy(true)\n146: \tif !backend.IsHealthy() {\n147: \t\tt.Error(\"Expected backend to be healthy\")\n148: \t}\n149: }\n150: \n151: func TestBackend_RecordFailure(t *testing.T) {\n152: \tpool := NewBackendPool()\n153: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n154: \n155: \tbackend := pool.backends[\"backend1\"]\n156: \n157: \tbackend.RecordFailure()\n158: \tif backend.GetConsecutiveFailures() != 1 {\n159: \t\tt.Errorf(\"Expected 1 failure, got %d\", backend.GetConsecutiveFailures())\n160: \t}\n161: \n162: \tbackend.RecordFailure()\n163: \tbackend.RecordFailure()\n164: \tbackend.RecordFailure()\n165: \n166: \tif backend.IsHealthy() {\n167: \t\tt.Error(\"Expected backend to be unhealthy after 3 failures\")\n168: \t}\n169: }\n170: \n171: func TestBackend_RecordSuccess(t *testing.T) {\n172: \tpool := NewBackendPool()\n173: \tpool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n174: \n175: \tbackend := pool.backends[\"backend1\"]\n176: \n177: \tbackend.RecordFailure()\n178: \tbackend.RecordFailure()\n179: \n180: \tbackend.RecordSuccess()\n181: \n182: \tif backend.GetConsecutiveFailures() != 0 {\n183: \t\tt.Errorf(\"Expected 0 failures after success, got %d\", backend.GetConsecutiveFailures())\n184: \t}\n185: \n186: \tif !backend.IsHealthy() {\n187: \t\tt.Error(\"Expected backend to be healthy after success\")\n188: \t}\n189: }\n\n(End of file - total 189 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"testing\"\n)\n\nfunc TestBackendPool_AddBackend(t *testing.T) {\n\tpool := NewBackendPool()\n\n\terr := pool.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test-backend\")\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got %v\", err)\n\t}\n\n\tbackends := pool.GetAllBackends()\n\tif len(backends) != 1 {\n\t\tt.Errorf(\"Expected 1 backend, got %d\", len(backends))\n\t}\n\n\tif !backends[\"backend1\"].Healthy {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/backend_test.go","time":{"start":1775882708602,"end":1775882708613}}}}
