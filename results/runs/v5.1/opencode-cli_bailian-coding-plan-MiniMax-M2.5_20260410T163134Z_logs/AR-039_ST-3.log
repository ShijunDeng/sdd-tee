{"type":"tool_use","timestamp":1775882700281,"sessionID":"ses_28524d66cffePG3Ba89bHGEPE1","part":{"id":"prt_d7adb7851001hrozcFnSkF6MyK","messageID":"msg_d7adb6886001tZUU30nhnic8Z4","sessionID":"ses_28524d66cffePG3Ba89bHGEPE1","type":"tool","tool":"read","callID":"toolu_a2eca76f847b4b17a50f85e7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/backend.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/backend.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"net/url\"\n5: \t\"sync\"\n6: \t\"time\"\n7: )\n8: \n9: type Backend struct {\n10: \tURL                 *url.URL\n11: \tPathPrefix          string\n12: \tName                string\n13: \tHealthy             bool\n14: \tConsecutiveFailures int\n15: \tLastHealthyCheck    time.Time\n16: \tmu                  sync.RWMutex\n17: }\n18: \n19: type BackendPool struct {\n20: \tbackends       map[string]*Backend\n21: \theaderRoutes   map[string]map[string]string // header name -> header value -> backend key\n22: \tdefaultBackend string\n23: \tmu             sync.RWMutex\n24: }\n25: \n26: func NewBackendPool() *BackendPool {\n27: \treturn &BackendPool{\n28: \t\tbackends:       make(map[string]*Backend),\n29: \t\theaderRoutes:   make(map[string]map[string]string),\n30: \t\tdefaultBackend: \"\",\n31: \t}\n32: }\n33: \n34: func (bp *BackendPool) AddBackend(key, endpoint, pathPrefix, name string) error {\n35: \tbp.mu.Lock()\n36: \tdefer bp.mu.Unlock()\n37: \n38: \tparsedURL, err := url.Parse(endpoint)\n39: \tif err != nil {\n40: \t\treturn err\n41: \t}\n42: \n43: \tbp.backends[key] = &Backend{\n44: \t\tURL:              parsedURL,\n45: \t\tPathPrefix:       pathPrefix,\n46: \t\tName:             name,\n47: \t\tHealthy:          true,\n48: \t\tLastHealthyCheck: time.Now(),\n49: \t}\n50: \n51: \tif bp.defaultBackend == \"\" {\n52: \t\tbp.defaultBackend = key\n53: \t}\n54: \n55: \treturn nil\n56: }\n57: \n58: func (bp *BackendPool) RemoveBackend(key string) {\n59: \tbp.mu.Lock()\n60: \tdefer bp.mu.Unlock()\n61: \n62: \tdelete(bp.backends, key)\n63: \n64: \tif bp.defaultBackend == key {\n65: \t\tbp.defaultBackend = \"\"\n66: \t\tfor k := range bp.backends {\n67: \t\t\tbp.defaultBackend = k\n68: \t\t\tbreak\n69: \t\t}\n70: \t}\n71: \n72: \tfor _, routeMap := range bp.headerRoutes {\n73: \t\tdelete(routeMap, key)\n74: \t}\n75: }\n76: \n77: func (bp *BackendPool) UpdateBackend(key, endpoint, pathPrefix string) error {\n78: \tbp.mu.Lock()\n79: \tdefer bp.mu.Unlock()\n80: \n81: \tbackend, exists := bp.backends[key]\n82: \tif !exists {\n83: \t\treturn nil\n84: \t}\n85: \n86: \tparsedURL, err := url.Parse(endpoint)\n87: \tif err != nil {\n88: \t\treturn err\n89: \t}\n90: \n91: \tbackend.URL = parsedURL\n92: \tbackend.PathPrefix = pathPrefix\n93: \n94: \treturn nil\n95: }\n96: \n97: func (bp *BackendPool) GetBackendByPath(path string) *Backend {\n98: \tbp.mu.RLock()\n99: \tdefer bp.mu.RUnlock()\n100: \n101: \tfor _, backend := range bp.backends {\n102: \t\tif backend.Healthy && len(backend.PathPrefix) > 0 &&\n103: \t\t\t(path == backend.PathPrefix ||\n104: \t\t\t\t(len(path) > len(backend.PathPrefix) && path[:len(backend.PathPrefix)] == backend.PathPrefix)) {\n105: \t\t\treturn backend\n106: \t\t}\n107: \t}\n108: \n109: \tif bp.defaultBackend != \"\" {\n110: \t\treturn bp.backends[bp.defaultBackend]\n111: \t}\n112: \n113: \treturn nil\n114: }\n115: \n116: func (bp *BackendPool) GetBackendByHeader(headerName, headerValue string) *Backend {\n117: \tbp.mu.RLock()\n118: \tdefer bp.mu.RUnlock()\n119: \n120: \trouteMap, exists := bp.headerRoutes[headerName]\n121: \tif !exists {\n122: \t\treturn nil\n123: \t}\n124: \n125: \tbackendKey, exists := routeMap[headerValue]\n126: \tif !exists {\n127: \t\treturn nil\n128: \t}\n129: \n130: \tbackend, exists := bp.backends[backendKey]\n131: \tif exists && backend.Healthy {\n132: \t\treturn backend\n133: \t}\n134: \n135: \treturn nil\n136: }\n137: \n138: func (bp *BackendPool) SetHeaderRoute(headerName, headerValue, backendKey string) {\n139: \tbp.mu.Lock()\n140: \tdefer bp.mu.Unlock()\n141: \n142: \tif _, exists := bp.backends[backendKey]; !exists {\n143: \t\treturn\n144: \t}\n145: \n146: \tif _, exists := bp.headerRoutes[headerName]; !exists {\n147: \t\tbp.headerRoutes[headerName] = make(map[string]string)\n148: \t}\n149: \n150: \tbp.headerRoutes[headerName][headerValue] = backendKey\n151: }\n152: \n153: func (bp *BackendPool) SetDefaultBackend(key string) {\n154: \tbp.mu.Lock()\n155: \tdefer bp.mu.Unlock()\n156: \n157: \tif _, exists := bp.backends[key]; exists {\n158: \t\tbp.defaultBackend = key\n159: \t}\n160: }\n161: \n162: func (bp *BackendPool) GetAllBackends() map[string]*Backend {\n163: \tbp.mu.RLock()\n164: \tdefer bp.mu.RUnlock()\n165: \n166: \tresult := make(map[string]*Backend)\n167: \tfor k, v := range bp.backends {\n168: \t\tresult[k] = v\n169: \t}\n170: \n171: \treturn result\n172: }\n173: \n174: func (b *Backend) SetHealthy(healthy bool) {\n175: \tb.mu.Lock()\n176: \tdefer b.mu.Unlock()\n177: \n178: \tb.Healthy = healthy\n179: \tif healthy {\n180: \t\tb.ConsecutiveFailures = 0\n181: \t} else {\n182: \t\tb.ConsecutiveFailures++\n183: \t}\n184: \tb.LastHealthyCheck = time.Now()\n185: }\n186: \n187: func (b *Backend) IsHealthy() bool {\n188: \tb.mu.RLock()\n189: \tdefer b.mu.RUnlock()\n190: \n191: \treturn b.Healthy\n192: }\n193: \n194: func (b *Backend) GetConsecutiveFailures() int {\n195: \tb.mu.RLock()\n196: \tdefer b.mu.RUnlock()\n197: \n198: \treturn b.ConsecutiveFailures\n199: }\n200: \n201: func (b *Backend) RecordFailure() {\n202: \tb.mu.Lock()\n203: \tdefer b.mu.Unlock()\n204: \n205: \tb.ConsecutiveFailures++\n206: \tb.Healthy = b.ConsecutiveFailures < 3\n207: }\n208: \n209: func (b *Backend) RecordSuccess() {\n210: \tb.mu.Lock()\n211: \tdefer b.mu.Unlock()\n212: \n213: \tb.ConsecutiveFailures = 0\n214: \tb.Healthy = true\n215: \tb.LastHealthyCheck = time.Now()\n216: }\n\n(End of file - total 216 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/url\"\n\t\"sync\"\n\t\"time\"\n)\n\ntype Backend struct {\n\tURL                 *url.URL\n\tPathPrefix          string\n\tName                string\n\tHealthy             bool\n\tConsecutiveFailures int\n\tLastHealthyCheck    time.Time\n\tmu                  sync.RWMutex\n}\n\ntype BackendPool struct {\n\tbackends       map[string]*Backend","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/backend.go","time":{"start":1775882700267,"end":1775882700280}}}}
{"type":"tool_use","timestamp":1775882700283,"sessionID":"ses_28524d66cffePG3Ba89bHGEPE1","part":{"id":"prt_d7adb7ce9001IneV9oYZXmF3fK","messageID":"msg_d7adb6886001tZUU30nhnic8Z4","sessionID":"ses_28524d66cffePG3Ba89bHGEPE1","type":"tool","tool":"read","callID":"toolu_32a0fe81149f40d6ae0a7107","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/session.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/session.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"errors\"\n5: \t\"sync\"\n6: \t\"time\"\n7: \n8: \t\"github.com/google/uuid\"\n9: )\n10: \n11: var (\n12: \tErrMaxSessionsExceeded = errors.New(\"maximum number of sessions exceeded\")\n13: \tErrSessionNotFound     = errors.New(\"session not found\")\n14: )\n15: \n16: type Session struct {\n17: \tID           string            // Unique session identifier\n18: \tBackendKey   string            // Associated backend key for sticky sessions\n19: \tCreatedAt    time.Time         // Session creation time\n20: \tLastActivity time.Time         // Last activity timestamp\n21: \tExpiresAt    time.Time         // Session expiration time\n22: \tMetadata     map[string]string // Additional session metadata\n23: }\n24: \n25: type SessionStore interface {\n26: \tCreate(backendKey string, metadata map[string]string) (*Session, error)\n27: \tGet(sessionID string) *Session\n28: \tUpdate(sessionID string) error\n29: \tDelete(sessionID string) error\n30: \tList() []*Session\n31: \tCleanup() int\n32: \tGetActiveCount() int\n33: \tSetMaxSessions(max int)\n34: }\n35: \n36: type MemorySessionStore struct {\n37: \tsessions       map[string]*Session\n38: \tmaxSessions    int\n39: \tsessionTimeout time.Duration\n40: \tmu             sync.RWMutex\n41: }\n42: \n43: func NewMemorySessionStore(maxSessions int) *MemorySessionStore {\n44: \tif maxSessions <= 0 {\n45: \t\tmaxSessions = 10000\n46: \t}\n47: \treturn &MemorySessionStore{\n48: \t\tsessions:       make(map[string]*Session),\n49: \t\tmaxSessions:    maxSessions,\n50: \t\tsessionTimeout: 30 * time.Minute,\n51: \t}\n52: }\n53: \n54: func NewMemorySessionStoreWithTimeout(maxSessions int, timeout time.Duration) *MemorySessionStore {\n55: \tif maxSessions <= 0 {\n56: \t\tmaxSessions = 10000\n57: \t}\n58: \tif timeout <= 0 {\n59: \t\ttimeout = 30 * time.Minute\n60: \t}\n61: \treturn &MemorySessionStore{\n62: \t\tsessions:       make(map[string]*Session),\n63: \t\tmaxSessions:    maxSessions,\n64: \t\tsessionTimeout: timeout,\n65: \t}\n66: }\n67: \n68: func GenerateSessionID() string {\n69: \treturn uuid.New().String()\n70: }\n71: \n72: func (ms *MemorySessionStore) Create(backendKey string, metadata map[string]string) (*Session, error) {\n73: \tms.mu.Lock()\n74: \tdefer ms.mu.Unlock()\n75: \n76: \tif len(ms.sessions) >= ms.maxSessions {\n77: \t\treturn nil, ErrMaxSessionsExceeded\n78: \t}\n79: \n80: \tnow := time.Now()\n81: \tsession := &Session{\n82: \t\tID:           GenerateSessionID(),\n83: \t\tBackendKey:   backendKey,\n84: \t\tCreatedAt:    now,\n85: \t\tLastActivity: now,\n86: \t\tExpiresAt:    now.Add(ms.sessionTimeout),\n87: \t\tMetadata:     metadata,\n88: \t}\n89: \n90: \tms.sessions[session.ID] = session\n91: \treturn session, nil\n92: }\n93: \n94: func (ms *MemorySessionStore) Get(sessionID string) *Session {\n95: \tms.mu.RLock()\n96: \tdefer ms.mu.RUnlock()\n97: \n98: \tsession, exists := ms.sessions[sessionID]\n99: \tif !exists {\n100: \t\treturn nil\n101: \t}\n102: \n103: \tif time.Now().After(session.ExpiresAt) {\n104: \t\treturn nil\n105: \t}\n106: \n107: \treturn session\n108: }\n109: \n110: func (ms *MemorySessionStore) Update(sessionID string) error {\n111: \tms.mu.Lock()\n112: \tdefer ms.mu.Unlock()\n113: \n114: \tsession, exists := ms.sessions[sessionID]\n115: \tif !exists {\n116: \t\treturn ErrSessionNotFound\n117: \t}\n118: \n119: \tsession.LastActivity = time.Now()\n120: \tsession.ExpiresAt = time.Now().Add(ms.sessionTimeout)\n121: \treturn nil\n122: }\n123: \n124: func (ms *MemorySessionStore) Delete(sessionID string) error {\n125: \tms.mu.Lock()\n126: \tdefer ms.mu.Unlock()\n127: \n128: \tif _, exists := ms.sessions[sessionID]; !exists {\n129: \t\treturn ErrSessionNotFound\n130: \t}\n131: \n132: \tdelete(ms.sessions, sessionID)\n133: \treturn nil\n134: }\n135: \n136: func (ms *MemorySessionStore) List() []*Session {\n137: \tms.mu.RLock()\n138: \tdefer ms.mu.RUnlock()\n139: \n140: \tsessions := make([]*Session, 0, len(ms.sessions))\n141: \tfor _, session := range ms.sessions {\n142: \t\tif time.Now().Before(session.ExpiresAt) {\n143: \t\t\tsessions = append(sessions, session)\n144: \t\t}\n145: \t}\n146: \n147: \treturn sessions\n148: }\n149: \n150: func (ms *MemorySessionStore) Cleanup() int {\n151: \tms.mu.Lock()\n152: \tdefer ms.mu.Unlock()\n153: \n154: \tnow := time.Now()\n155: \tcleaned := 0\n156: \n157: \tfor id, session := range ms.sessions {\n158: \t\tif now.After(session.ExpiresAt) {\n159: \t\t\tdelete(ms.sessions, id)\n160: \t\t\tcleaned++\n161: \t\t}\n162: \t}\n163: \n164: \treturn cleaned\n165: }\n166: \n167: func (ms *MemorySessionStore) GetActiveCount() int {\n168: \tms.mu.RLock()\n169: \tdefer ms.mu.RUnlock()\n170: \n171: \tcount := 0\n172: \tnow := time.Now()\n173: \tfor _, session := range ms.sessions {\n174: \t\tif now.Before(session.ExpiresAt) {\n175: \t\t\tcount++\n176: \t\t}\n177: \t}\n178: \n179: \treturn count\n180: }\n181: \n182: func (ms *MemorySessionStore) SetMaxSessions(max int) {\n183: \tms.mu.Lock()\n184: \tdefer ms.mu.Unlock()\n185: \n186: \tms.maxSessions = max\n187: }\n188: \n189: func (ms *MemorySessionStore) InvalidateBackend(backendKey string) int {\n190: \tms.mu.Lock()\n191: \tdefer ms.mu.Unlock()\n192: \n193: \tcleaned := 0\n194: \tfor id, session := range ms.sessions {\n195: \t\tif session.BackendKey == backendKey {\n196: \t\t\tdelete(ms.sessions, id)\n197: \t\t\tcleaned++\n198: \t\t}\n199: \t}\n200: \n201: \treturn cleaned\n202: }\n\n(End of file - total 202 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"errors\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n)\n\nvar (\n\tErrMaxSessionsExceeded = errors.New(\"maximum number of sessions exceeded\")\n\tErrSessionNotFound     = errors.New(\"session not found\")\n)\n\ntype Session struct {\n\tID           string            // Unique session identifier\n\tBackendKey   string            // Associated backend key for sticky sessions\n\tCreatedAt    time.Time         // Session creation time\n\tLastActivity time.Time         // Last activity timestamp","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/session.go","time":{"start":1775882700270,"end":1775882700282}}}}
