stActivityStr)\n42: \t\tif err != nil {\n43: \t\t\tklog.ErrorS(err, \"Failed to parse last-activity-time annotation\", \"sandbox\", klog.KObj(sandbox))\n44: \t\t\treturn reconcile.Result{RequeueAfter: 30 * time.Second}, err\n45: \t\t}\n46: \n47: \t\texpirationTime := lastActivity.Add(SessionExpirationTimeout)\n48: \t\tif time.Now().After(expirationTime) {\n49: \t\t\tklog.InfoS(\"Deleting expired sandbox\", \"sandbox\", klog.KObj(sandbox), \"lastActivity\", lastActivity, \"expirationTime\", expirationTime)\n50: \t\t\tdeleteErr := r.Delete(ctx, sandbox)\n51: \t\t\tif deleteErr != nil && !apierrors.IsNotFound(deleteErr) {\n52: \t\t\t\treturn reconcile.Result{}, deleteErr\n53: \t\t\t}\n54: \t\t} else {\n55: \t\t\treturn reconcile.Result{RequeueAfter: time.Until(expirationTime)}, nil\n56: \t\t}\n57: \t}\n58: \n59: \treturn reconcile.Result{}, nil\n60: }\n61: \n62: func (r *Reconciler) SetupWithManager(mgr manager.Manager) error {\n63: \treturn builder.ControllerManagedBy(mgr).\n64: \t\tFor(&v1alpha1.Sandbox{}).\n65: \t\tComplete(r)\n66: }\n\n(End of file - total 66 lines)\n</content>","metadata":{"preview":"package agentd\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/klog/v2\"\n\t\"sigs.k8s.io/agent-sandbox/api/v1alpha1\"\n\t\"sigs.k8s.io/controller-runtime/pkg/builder\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/manager\"\n\t\"sigs.k8s.io/controller-runtime/pkg/reconcile\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\nconst (\n\tSessionExpirationTimeout  = 15 * time.Minute","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/agentd/reconciler.go","time":{"start":1775858663973,"end":1775858663980}}}}
