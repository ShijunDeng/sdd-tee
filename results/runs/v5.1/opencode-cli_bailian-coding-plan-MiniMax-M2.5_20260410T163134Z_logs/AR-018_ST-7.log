ockClient{\n38: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n39: \t\t\t\treturn apierrors.NewNotFound(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, key.Name)\n40: \t\t\t},\n41: \t\t},\n42: \t\tScheme: &runtime.Scheme{},\n43: \t}\n44: \n45: \treq := reconcile.Request{\n46: \t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n47: \t}\n48: \n49: \tresult, err := reconciler.Reconcile(context.Background(), req)\n50: \tif err != nil {\n51: \t\tt.Errorf(\"Expected no error, got %v\", err)\n52: \t}\n53: \tif result != (reconcile.Result{}) {\n54: \t\tt.Errorf(\"Expected empty result, got %v\", result)\n55: \t}\n56: }\n57: \n58: func TestReconcile_GetError(t *testing.T) {\n59: \treconciler := &Reconciler{\n60: \t\tClient: &mockClient{\n61: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n62: \t\t\t\treturn errors.New(\"some get error\")\n63: \t\t\t},\n64: \t\t},\n65: \t\tScheme: &runtime.Scheme{},\n66: \t}\n67: \n68: \treq := reconcile.Request{\n69: \t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n70: \t}\n71: \n72: \t_, err := reconciler.Reconcile(context.Background(), req)\n73: \tif err == nil {\n74: \t\tt.Error(\"Expected error, got nil\")\n75: \t}\n76: }\n77: \n78: func TestReconcile_NoAnnotation(t *testing.T) {\n79: \treconciler := &Reconciler{\n80: \t\tClient: &mockClient{\n81: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n82: \t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n83: \t\t\t\tsandbox.Name = key.Name\n84: \t\t\t\tsandbox.Namespace = key.Namespace\n85: \t\t\t\tsandbox.Annotations = nil\n86: \t\t\t\treturn nil\n87: \t\t\t},\n88: \t\t},\n89: \t\tScheme: &runtime.Scheme{},\n90: \t}\n91: \n92: \treq := reconcile.Request{\n93: \t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n94: \t}\n95: \n96: \tresult, err := reconciler.Reconcile(context.Background(), req)\n97: \tif err != nil {\n98: \t\tt.Errorf(\"Expected no error, got %v\", err)\n99: \t}\n100: \tif result != (reconcile.Result{}) {\n101: \t\tt.Errorf(\"Expected empty result, got %v\", result)\n102: \t}\n103: }\n104: \n105: func TestReconcile_Expired(t *testing.T) {\n106: \tdeleteCalled := false\n107: \treconciler := &Reconciler{\n108: \t\tClient: &mockClient{\n109: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n110: \t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n111: \t\t\t\tsandbox.Name = key.Name\n112: \t\t\t\tsandbox.Namespace = key.Namespace\n113: \t\t\t\tsandbox.Annotations = map[string]string{\n114: \t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: time.Now().Add(-30 * time.Minute).Format(time.RFC3339),\n115: \t\t\t\t}\n116: \t\t\t\treturn nil\n117: \t\t\t},\n118: \t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n119: \t\t\t\tdeleteCalled = true\n120: \t\t\t\treturn nil\n121: \t\t\t},\n122: \t\t},\n123: \t\tScheme: &runtime.Scheme{},\n124: \t}\n125: \n126: \treq := reconcile.Request{\n127: \t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n128: \t}\n129: \n130: \tresult, err := reconciler.Reconcile(context.Background(), req)\n131: \tif err != nil {\n132: \t\tt.Errorf(\"Expected no error, got %v\", err)\n133: \t}\n134: \tif !deleteCalled {\n135: \t\tt.Error(\"Expected delete to be called\")\n136: \t}\n137: \tif result != (reconcile.Result{}) {\n138: \t\tt.Errorf(\"Expected empty result after deletion, got %v\", result)\n139: \t}\n140: }\n141: \n142: func TestReconcile_NotExpired(t *testing.T) {\n143: \treconciler := &Reconciler{\n144: \t\tClient: &mockClient{\n145: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n146: \t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n147: \t\t\t\tsandbox.Name = key.Name\n148: \t\t\t\tsandbox.Namespace = key.Namespace\n149: \t\t\t\tsandbox.Annotations = map[string]string{\n150: \t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: time.Now().Add(-5 * time.Minute).Format(time.RFC3339),\n151: \t\t\t\t}\n152: \t\t\t\treturn nil\n153: \t\t\t},\n154: \t\t},\n155: \t\tScheme: &runtime.Scheme{},\n156: \t}\n157: \n158: \treq := reconcile.Request{\n159: \t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n160: \t}\n161: \n162: \tresult, err := reconciler.Reconcile(context.Background(), req)\n163: \tif err != nil {\n164: \t\tt.Errorf(\"Expected no error, got %v\", err)\n165: \t}\n166: \tif result.RequeueAfter == 0 {\n167: \t\tt.Error(\"Expected RequeueAfter to be set\")\n168: \t}\n169: \texpectedRequeueAfter := 10 * time.Minute\n170: \tif result.RequeueAfter < expectedRequeueAfter-time.Second || result.RequeueAfter > expectedRequeueAfter+time.Second {\n171: \t\tt.Errorf(\"Expected RequeueAfter around %v, got %v\", expectedRequeueAfter, result.RequeueAfter)\n172: \t}\n173: }\n174: \n175: func TestReconcile_InvalidTimestamp(t *testing.T) {\n176: \treconciler := &Reconciler{\n177: \t\tClient: &mockClient{\n178: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n179: \t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n180: \t\t\t\tsandbox.Name = key.Name\n181: \t\t\t\tsandbox.Namespace = key.Namespace\n182: \t\t\t\tsandbox.Annotations = map[string]string{\n183: \t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: \"invalid-timestamp\",\n184: \t\t\t\t}\n185: \t\t\t\treturn nil\n186: \t\t\t},\n187: \t\t},\n188: \t\tScheme: &runtime.Scheme{},\n189: \t}\n190: \n191: \treq := reconcile.Request{\n192: \t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n193: \t}\n194: \n195: \tresult, err := reconciler.Reconcile(context.Background(), req)\n196: \tif err == nil {\n197: \t\tt.Error(\"Expected error, got nil\")\n198: \t}\n199: \tif result.RequeueAfter != 30*time.Second {\n200: \t\tt.Errorf(\"Expected RequeueAfter to be 30s, got %v\", result.RequeueAfter)\n201: \t}\n202: }\n203: \n204: func TestReconcile_DeleteNotFound(t *testing.T) {\n205: \treconciler := &Reconciler{\n206: \t\tClient: &mockClient{\n207: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n208: \t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n209: \t\t\t\tsandbox.Name = key.Name\n210: \t\t\t\tsandbox.Namespace = key.Namespace\n211: \t\t\t\tsandbox.Annotations = map[string]string{\n212: \t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: time.Now().Add(-30 * time.Minute).Format(time.RFC3339),\n213: \t\t\t\t}\n214: \t\t\t\treturn nil\n215: \t\t\t},\n216: \t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n217: \t\t\t\treturn apierrors.NewNotFound(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, obj.GetName())\n218: \t\t\t},\n219: \t\t},\n220: \t\tScheme: &runtime.Scheme{},\n221: \t}\n222: \n223: \treq := reconcile.Request{\n224: \t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n225: \t}\n226: \n227: \tresult, err := reconciler.Reconcile(context.Background(), req)\n228: \tif err != nil {\n229: \t\tt.Errorf(\"Expected no error, got %v\", err)\n230: \t}\n231: \tif result != (reconcile.Result{}) {\n232: \t\tt.Errorf(\"Expected empty result, got %v\", result)\n233: \t}\n234: }\n235: \n236: func TestReconcile_DeleteError(t *testing.T) {\n237: \treconciler := &Reconciler{\n238: \t\tClient: &mockClient{\n239: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n240: \t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n241: \t\t\t\tsandbox.Name = key.Name\n242: \t\t\t\tsandbox.Namespace = key.Namespace\n243: \t\t\t\tsandbox.Annotations = map[string]string{\n244: \t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: time.Now().Add(-30 * time.Minute).Format(time.RFC3339),\n245: \t\t\t\t}\n246: \t\t\t\treturn nil\n247: \t\t\t},\n248: \t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n249: \t\t\t\treturn errors.New(\"delete failed\")\n250: \t\t\t},\n251: \t\t},\n252: \t\tScheme: &runtime.Scheme{},\n253: \t}\n254: \n255: \treq := reconcile.Request{\n256: \t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n257: \t}\n258: \n259: \t_, err := reconciler.Reconcile(context.Background(), req)\n260: \tif err == nil {\n261: \t\tt.Error(\"Expected error, got nil\")\n262: \t}\n263: }\n264: \n265: func TestReconcile_EmptyAnnotationValue(t *testing.T) {\n266: \treconciler := &Reconciler{\n267: \t\tClient: &mockClient{\n268: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n269: \t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n270: \t\t\t\tsandbox.Name = key.Name\n271: \t\t\t\tsandbox.Namespace = key.Namespace\n272: \t\t\t\tsandbox.Annotations = map[string]string{\n273: \t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: \"\",\n274: \t\t\t\t}\n275: \t\t\t\treturn nil\n276: \t\t\t},\n277: \t\t},\n278: \t\tScheme: &runtime.Scheme{},\n279: \t}\n280: \n281: \treq := reconcile.Request{\n282: \t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n283: \t}\n284: \n285: \tresult, err := reconciler.Reconcile(context.Background(), req)\n286: \tif err != nil {\n287: \t\tt.Errorf(\"Expected no error, got %v\", err)\n288: \t}\n289: \tif result != (reconcile.Result{}) {\n290: \t\tt.Errorf(\"Expected empty result, got %v\", result)\n291: \t}\n292: }\n293: \n294: func TestTimeParsingEdgeCases(t *testing.T) {\n295: \ttests := []struct {\n296: \t\tname        string\n297: \t\ttimestamp   string\n298: \t\texpectError bool\n299: \t}{\n300: \t\t{\n301: \t\t\tname:        \"RFC3339 format\",\n302: \t\t\ttimestamp:   \"2024-01-15T10:30:00Z\",\n303: \t\t\texpectError: false,\n304: \t\t},\n305: \t\t{\n306: \t\t\tname:        \"RFC3339 with timezone\",\n307: \t\t\ttimestamp:   \"2024-01-15T10:30:00+05:30\",\n308: \t\t\texpectError: false,\n309: \t\t},\n310: \t\t{\n311: \t\t\tname:        \"invalid timestamp\",\n312: \t\t\ttimestamp:   \"not-a-timestamp\",\n313: \t\t\texpectError: true,\n314: \t\t},\n315: \t\t{\n316: \t\t\tname:        \"empty string\",\n317: \t\t\ttimestamp:   \"\",\n318: \t\t\texpectError: true,\n319: \t\t},\n320: \t\t{\n321: \t\t\tname:        \"Unix timestamp\",\n322: \t\t\ttimestamp:   \"1705315800\",\n323: \t\t\texpectError: true,\n324: \t\t},\n325: \t}\n326: \n327: \tfor _, tt := range tests {\n328: \t\tt.Run(tt.name, func(t *testing.T) {\n329: \t\t\t_, err := time.Parse(time.RFC3339, tt.timestamp)\n330: \t\t\tif tt.expectError && err == nil {\n331: \t\t\t\tt.Errorf(\"Expected error for timestamp %q\", tt.timestamp)\n332: \t\t\t}\n333: \t\t\tif !tt.expectError && err != nil {\n334: \t\t\t\tt.Errorf(\"Expected no error for timestamp %q, got %v\", tt.timestamp, err)\n335: \t\t\t}\n336: \t\t})\n337: \t}\n338: }\n339: \n340: func TestReconcile_SandboxObjectMeta(t *testing.T) {\n341: \treconciler := &Reconciler{\n342: \t\tClient: &mockClient{\n343: \t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n344: \t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n345: \t\t\t\tsandbox.ObjectMeta = metav1.ObjectMeta{\n346: \t\t\t\t\tName:      key.Name,\n347: \t\t\t\t\tNamespace: key.Namespace,\n348: \t\t\t\t\tAnnotations: map[string]string{\n349: \t\t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: time.Now().Add(-5 * time.Minute).Format(time.RFC3339),\n350: \t\t\t\t\t},\n351: \t\t\t\t}\n352: \t\t\t\treturn nil\n353: \t\t\t},\n354: \t\t},\n355: \t\tScheme: &runtime.Scheme{},\n356: \t}\n357: \n358: \treq := reconcile.Request{\n359: \t\tNamespacedName: types.NamespacedName{Namespace: \"test-ns\", Name: \"test-sandbox\"},\n360: \t}\n361: \n362: \tresult, err := reconciler.Reconcile(context.Background(), req)\n363: \tif err != nil {\n364: \t\tt.Errorf(\"Expected no error, got %v\", err)\n365: \t}\n366: \tif result.RequeueAfter == 0 {\n367: \t\tt.Error(\"Expected RequeueAfter to be set when not expired\")\n368: \t}\n369: }\n\n(End of file - total 369 lines)\n</content>","metadata":{"preview":"package agentd\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"sigs.k8s.io/agent-sandbox/api/v1alpha1\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/reconcile\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/agentd/reconciler_test.go","time":{"start":1775858673193,"end":1775858673200}}}}
