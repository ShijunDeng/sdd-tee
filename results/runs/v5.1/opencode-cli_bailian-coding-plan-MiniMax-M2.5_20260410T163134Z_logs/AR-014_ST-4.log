1: \t\texpiryIndexKey:       sessionExpiryIndexKey,\n52: \t\tlastActivityIndexKey: sessionLastActivityKey,\n53: \t}, nil\n54: }\n55: \n56: func makeValkeyOptions() (*valkey.ClientOption, error) {\n57: \tvalkeyAddr := os.Getenv(\"VALKEY_ADDR\")\n58: \tif valkeyAddr == \"\" {\n59: \t\treturn nil, errors.New(\"VALKEY_ADDR is required\")\n60: \t}\n61: \n62: \tvalkeyPasswordRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n63: \tvalkeyPassword := os.Getenv(\"VALKEY_PASSWORD\")\n64: \n65: \tpasswordRequired := true\n66: \tif strings.EqualFold(valkeyPasswordRequired, \"false\") {\n67: \t\tpasswordRequired = false\n68: \t}\n69: \n70: \tif passwordRequired && valkeyPassword == \"\" {\n71: \t\treturn nil, errors.New(\"VALKEY_PASSWORD is required\")\n72: \t}\n73: \n74: \topts := valkey.ClientOption{\n75: \t\tInitAddress: strings.Split(valkeyAddr, \",\"),\n76: \t\tPassword:    valkeyPassword,\n77: \t}\n78: \n79: \tif disableCache, _ := os.LookupEnv(\"VALKEY_DISABLE_CACHE\"); strings.EqualFold(disableCache, \"true\") {\n80: \t\topts.DisableCache = true\n81: \t\tklog.Info(\"Valkey DisableCache is enabled\")\n82: \t}\n83: \n84: \tif forceSingle, _ := os.LookupEnv(\"VALKEY_FORCE_SINGLE\"); strings.EqualFold(forceSingle, \"true\") {\n85: \t\topts.ForceSingleClient = true\n86: \t\tklog.Info(\"Valkey ForceSingleClient is enabled\")\n87: \t}\n88: \n89: \treturn &opts, nil\n90: }\n91: \n92: func (vs *valkeyStore) Ping(ctx context.Context) error {\n93: \tresult := vs.cli.B().Ping().Build()\n94: \tresp := vs.cli.Do(ctx, result)\n95: \tpong, err := resp.ToString()\n96: \tif err != nil {\n97: \t\treturn err\n98: \t}\n99: \tif pong != \"PONG\" {\n100: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n101: \t}\n102: \treturn nil\n103: }\n104: \n105: func (vs *valkeyStore) sessionKey(sessionID string) string {\n106: \treturn vs.sessionPrefix + sessionID\n107: }\n108: \n109: func (vs *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n110: \tkey := vs.sessionKey(sessionID)\n111: \tresult := vs.cli.B().Get().Key(key).Build()\n112: \tresp := vs.cli.Do(ctx, result)\n113: \n114: \tif valkey.IsValkeyNil(resp.Error()) {\n115: \t\treturn nil, ErrNotFound\n116: \t}\n117: \tif resp.Error() != nil {\n118: \t\treturn nil, resp.Error()\n119: \t}\n120: \n121: \tdata, err := resp.ToString()\n122: \tif err != nil {\n123: \t\treturn nil, err\n124: \t}\n125: \n126: \tvar sandbox types.SandboxInfo\n127: \tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n128: \t\treturn nil, err\n129: \t}\n130: \n131: \treturn &sandbox, nil\n132: }\n133: \n134: func (vs *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n135: \tif sandboxStore == nil {\n136: \t\treturn errors.New(\"sandbox is nil\")\n137: \t}\n138: \tif sandboxStore.ExpiresAt.IsZero() {\n139: \t\treturn errors.New(\"invalid expiry: ExpiresAt is zero\")\n140: \t}\n141: \tif sandboxStore.SessionID == \"\" {\n142: \t\treturn errors.New(\"session ID is required\")\n143: \t}\n144: \n145: \tkey := vs.sessionKey(sandboxStore.SessionID)\n146: \tdata, err := json.Marshal(sandboxStore)\n147: \tif err != nil {\n148: \t\treturn err\n149: \t}\n150: \n151: \tnow := time.Now().Unix()\n152: \texpiryScore := float64(sandboxStore.ExpiresAt.Unix())\n153: \tlastActivityScore := float64(now)\n154: \n155: \tcmds := []valkey.Completed{\n156: \t\tvs.cli.B().Setnx().Key(key).Value(string(data)).Build(),\n157: \t\tvs.cli.B().Zadd().Key(vs.expiryIndexKey).ScoreMember(expiryScore, sandboxStore.SessionID).Build(),\n158: \t\tvs.cli.B().Zadd().Key(vs.lastActivityIndexKey).ScoreMember(lastActivityScore, sandboxStore.SessionID).Build(),\n159: \t}\n160: \tresults := vs.cli.DoMulti(ctx, cmds...)\n161: \tfor _, r := range results {\n162: \t\tif err := r.Error(); err != nil {\n163: \t\t\treturn err\n164: \t\t}\n165: \t}\n166: \n167: \treturn nil\n168: }\n169: \n170: func (vs *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n171: \tif sandboxStore == nil {\n172: \t\treturn errors.New(\"sandbox is nil\")\n173: \t}\n174: \tif sandboxStore.SessionID == \"\" {\n175: \t\treturn errors.New(\"session ID is required\")\n176: \t}\n177: \n178: \tkey := vs.sessionKey(sandboxStore.SessionID)\n179: \tdata, err := json.Marshal(sandboxStore)\n180: \tif err != nil {\n181: \t\treturn err\n182: \t}\n183: \n184: \tresult := vs.cli.B().Set().Key(key).Value(string(data)).Xx().Build()\n185: \tresp := vs.cli.Do(ctx, result)\n186: \n187: \tif valkey.IsValkeyNil(resp.Error()) {\n188: \t\treturn errors.New(\"key not exists\")\n189: \t}\n190: \tif resp.Error() != nil {\n191: \t\treturn resp.Error()\n192: \t}\n193: \n194: \tok, err := resp.ToString()\n195: \tif err != nil {\n196: \t\treturn err\n197: \t}\n198: \tif ok != \"OK\" {\n199: \t\treturn errors.New(\"key not exists\")\n200: \t}\n201: \n202: \treturn nil\n203: }\n204: \n205: func (vs *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n206: \tkey := vs.sessionKey(sessionID)\n207: \n208: \tcmds := []valkey.Completed{\n209: \t\tvs.cli.B().Del().Key(key).Build(),\n210: \t\tvs.cli.B().Zrem().Key(vs.expiryIndexKey).Member(sessionID).Build(),\n211: \t\tvs.cli.B().Zrem().Key(vs.lastActivityIndexKey).Member(sessionID).Build(),\n212: \t}\n213: \tresults := vs.cli.DoMulti(ctx, cmds...)\n214: \tfor _, r := range results {\n215: \t\tif err := r.Error(); err != nil {\n216: \t\t\treturn err\n217: \t\t}\n218: \t}\n219: \n220: \treturn nil\n221: }\n222: \n223: func (vs *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n224: \tif limit <= 0 {\n225: \t\treturn nil, nil\n226: \t}\n227: \n228: \tresult := vs.cli.B().\n229: \t\tZrangebyscore().\n230: \t\tKey(vs.expiryIndexKey).\n231: \t\tMin(\"-inf\").\n232: \t\tMax(fmt.Sprintf(\"%d\", before.Unix())).\n233: \t\tLimit(0, limit).\n234: \t\tBuild()\n235: \tresp := vs.cli.Do(ctx, result)\n236: \tif resp.Error() != nil {\n237: \t\treturn nil, resp.Error()\n238: \t}\n239: \n240: \tsessionIDs, err := resp.AsStrSlice()\n241: \tif err != nil {\n242: \t\treturn nil, err\n243: \t}\n244: \n245: \treturn vs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n246: }\n247: \n248: func (vs *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n249: \tif limit <= 0 {\n250: \t\treturn nil, nil\n251: \t}\n252: \n253: \tresult := vs.cli.B().\n254: \t\tZrangebyscore().\n255: \t\tKey(vs.lastActivityIndexKey).\n256: \t\tMin(\"-inf\").\n257: \t\tMax(fmt.Sprintf(\"%d\", before.Unix())).\n258: \t\tLimit(0, limit).\n259: \t\tBuild()\n260: \tresp := vs.cli.Do(ctx, result)\n261: \tif resp.Error() != nil {\n262: \t\treturn nil, resp.Error()\n263: \t}\n264: \n265: \tsessionIDs, err := resp.AsStrSlice()\n266: \tif err != nil {\n267: \t\treturn nil, err\n268: \t}\n269: \n270: \treturn vs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n271: }\n272: \n273: func (vs *valkeyStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n274: \tif len(sessionIDs) == 0 {\n275: \t\treturn nil, nil\n276: \t}\n277: \n278: \tkeys := make([]string, len(sessionIDs))\n279: \tfor i, sid := range sessionIDs {\n280: \t\tkeys[i] = vs.sessionKey(sid)\n281: \t}\n282: \n283: \tresult := vs.cli.B().Mget().Key(keys...).Build()\n284: \tresp := vs.cli.Do(ctx, result)\n285: \tif resp.Error() != nil {\n286: \t\treturn nil, resp.Error()\n287: \t}\n288: \n289: \tsliceResp, err := resp.ToArray()\n290: \tif err != nil {\n291: \t\treturn nil, err\n292: \t}\n293: \n294: \tvar sandboxes []*types.SandboxInfo\n295: \tfor i, item := range sliceResp {\n296: \t\tif item.IsNil() {\n297: \t\t\tcontinue\n298: \t\t}\n299: \n300: \t\tstr, err := item.ToString()\n301: \t\tif err != nil || str == \"\" {\n302: \t\t\tcontinue\n303: \t\t}\n304: \n305: \t\tvar sandbox types.SandboxInfo\n306: \t\tif err := json.Unmarshal([]byte(str), &sandbox); err != nil {\n307: \t\t\tklog.V(4).Infof(\"failed to unmarshal sandbox %s: %v\", sessionIDs[i], err)\n308: \t\t\tcontinue\n309: \t\t}\n310: \t\tsandboxes = append(sandboxes, &sandbox)\n311: \t}\n312: \n313: \treturn sandboxes, nil\n314: }\n315: \n316: func (vs *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n317: \tif sessionID == \"\" {\n318: \t\treturn errors.New(\"session ID is required\")\n319: \t}\n320: \n321: \tkey := vs.sessionKey(sessionID)\n322: \texistsResult := vs.cli.B().Exists().Key(key).Build()\n323: \texistsResp := vs.cli.Do(ctx, existsResult)\n324: \tif existsResp.Error() != nil {\n325: \t\treturn existsResp.Error()\n326: \t}\n327: \texists, _ := existsResp.AsInt64()\n328: \tif exists != 1 {\n329: \t\treturn ErrNotFound\n330: \t}\n331: \n332: \ttimestamp := at\n333: \tif timestamp.IsZero() {\n334: \t\ttimestamp = time.Now()\n335: \t}\n336: \n337: \tscore := float64(timestamp.Unix())\n338: \tupdateResult := vs.cli.B().Zadd().Key(vs.lastActivityIndexKey).Score(score).Member(sessionID).Build()\n339: \tupdateResp := vs.cli.Do(ctx, updateResult)\n340: \tif updateResp.Error() != nil {\n341: \t\treturn updateResp.Error()\n342: \t}\n343: \n344: \treturn nil\n345: }\n346: \n347: func (vs *valkeyStore) Close() error {\n348: \treturn vs.cli.Close()\n349: }\n\n(End of file - total 349 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_valkey.go","time":{"start":1775852198096,"end":1775852198126}}}}
{"type":"tool_use","timestamp":1775852198129,"sessionID":"ses_286f62cb7ffeV3l1pQN8gI1KEf","part":{"id":"prt_d790a10e9001yb75RsDmsTtnuW","messageID":"msg_d7909fe62001gFGxCfz8XpbowW","sessionID":"ses_286f62cb7ffeV3l1pQN8gI1KEf","type":"tool","tool":"read","callID":"toolu_1d2c53e8779147c79b0f3015","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_redis.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_redis.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"errors\"\n7: \t\"fmt\"\n8: \t\"os\"\n9: \t\"strings\"\n10: \t\"time\"\n11: \n12: \t\"github.com/redis/go-redis/v9\"\n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: \t\"k8s.io/klog/v2\"\n15: )\n16: \n17: type redisStore struct {\n18: \tcli                  *redis.Client\n19: \tsessionPrefix        string\n20: \texpiryIndexKey       string\n21: \tlastActivityIndexKey string\n22: }\n23: \n24: const (\n25: \tsessionKeyPrefix       = \"session:\"\n26: \tsessionExpiryIndexKey  = \"session:expiry\"\n27: \tsessionLastActivityKey = \"session:last_activity\"\n28: )\n29: \n30: func newRedisStore() (Store, error) {\n31: \topts, err := makeRedisOptions()\n32: \tif err != nil {\n33: \t\treturn nil, err\n34: \t}\n35: \n36: \tcli := redis.NewClient(opts)\n37: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n38: \tdefer cancel()\n39: \n40: \tif err := cli.Ping(ctx).Err(); err != nil {\n41: \t\treturn nil, fmt.Errorf(\"failed to connect to redis: %w\", err)\n42: \t}\n43: \n44: \treturn &redisStore{\n45: \t\tcli:                  cli,\n46: \t\tsessionPrefix:        sessionKeyPrefix,\n47: \t\texpiryIndexKey:       sessionExpiryIndexKey,\n48: \t\tlastActivityIndexKey: sessionLastActivityKey,\n49: \t}, nil\n50: }\n51: \n52: func makeRedisOptions() (*redis.Options, error) {\n53: \tredisAddr := os.Getenv(\"REDIS_ADDR\")\n54: \tif redisAddr == \"\" {\n55: \t\treturn nil, errors.New(\"REDIS_ADDR is required\")\n56: \t}\n57: \n58: \tredisPasswordRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n59: \tredisPassword := os.Getenv(\"REDIS_PASSWORD\")\n60: \n61: \tpasswordRequired := true\n62: \tif strings.EqualFold(redisPasswordRequired, \"false\") {\n63: \t\tpasswordRequired = false\n64: \t}\n65: \n66: \tif passwordRequired && redisPassword == \"\" {\n67: \t\treturn nil, errors.New(\"REDIS_PASSWORD is required\")\n68: \t}\n69: \n70: \treturn &redis.Options{\n71: \t\tAddr:     redisAddr,\n72: \t\tPassword: redisPassword,\n73: \t}, nil\n74: }\n75: \n76: func (rs *redisStore) Ping(ctx context.Context) error {\n77: \tresult, err := rs.cli.Ping(ctx).Result()\n78: \tif err != nil {\n79: \t\treturn err\n80: \t}\n81: \tif result != \"PONG\" {\n82: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n83: \t}\n84: \treturn nil\n85: }\n86: \n87: func (rs *redisStore) sessionKey(sessionID string) string {\n88: \treturn rs.sessionPrefix + sessionID\n89: }\n90: \n91: func (rs *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n92: \tkey := rs.sessionKey(sessionID)\n93: \tdata, err := rs.cli.Get(ctx, key).Bytes()\n94: \tif err != nil {\n95: \t\tif errors.Is(err, redis.Nil) {\n96: \t\t\treturn nil, ErrNotFound\n97: \t\t}\n98: \t\treturn nil, err\n99: \t}\n100: \n101: \tvar sandbox types.SandboxInfo\n102: \tif err := json.Unmarshal(data, &sandbox); err != nil {\n103: \t\treturn nil, err\n104: \t}\n105: \n106: \treturn &sandbox, nil\n107: }\n108: \n109: func (rs *redisStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n110: \tif sandboxStore == nil {\n111: \t\treturn errors.New(\"sandbox is nil\")\n112: \t}\n113: \tif sandboxStore.ExpiresAt.IsZero() {\n114: \t\treturn errors.New(\"invalid expiry: ExpiresAt is zero\")\n115: \t}\n116: \n117: \tif sandboxStore.SessionID == \"\" {\n118: \t\treturn errors.New(\"session ID is required\")\n119: \t}\n120: \n121: \tkey := rs.sessionKey(sandboxStore.SessionID)\n122: \tdata, err := json.Marshal(sandboxStore)\n123: \tif err != nil {\n124: \t\treturn err\n125: \t}\n126: \n127: \tnow := time.Now().Unix()\n128: \texpiryScore := float64(sandboxStore.ExpiresAt.Unix())\n129: \tlastActivityScore := float64(now)\n130: \n131: \tpipe := rs.cli.Pipeline()\n132: \tpipe.SetNX(ctx, key, data, 0)\n133: \tpipe.ZAdd(ctx, rs.expiryIndexKey, redis.Z{Score: expiryScore, Member: sandboxStore.SessionID})\n134: \tpipe.ZAdd(ctx, rs.lastActivityIndexKey, redis.Z{Score: lastActivityScore, Member: sandboxStore.SessionID})\n135: \n136: \t_, err = pipe.Exec(ctx)\n137: \tif err != nil {\n138: \t\treturn err\n139: \t}\n140: \n141: \treturn nil\n142: }\n143: \n144: func (rs *redisStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n145: \tif sandboxStore == nil {\n146: \t\treturn errors.New(\"sandbox is nil\")\n147: \t}\n148: \tif sandboxStore.SessionID == \"\" {\n149: \t\treturn errors.New(\"session ID is required\")\n150: \t}\n151: \n152: \tkey := rs.sessionKey(sandboxStore.SessionID)\n153: \tdata, err := json.Marshal(sandboxStore)\n154: \tif err != nil {\n155: \t\treturn err\n156: \t}\n157: \n158: \tsuccess, err := rs.cli.SetXX(ctx, key, data, 0).Result()\n159: \tif err != nil {\n160: \t\treturn err\n161: \t}\n162: \tif !success {\n163: \t\treturn errors.New(\"key not exists\")\n164: \t}\n165: \n166: \treturn nil\n167: }\n168: \n169: func (rs *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n170: \tkey := rs.sessionKey(sessionID)\n171: \n172: \tpipe := rs.cli.Pipeline()\n173: \tpipe.Del(ctx, key)\n174: \tpipe.ZRem(ctx, rs.expiryIndexKey, sessionID)\n175: \tpipe.ZRem(ctx, rs.lastActivityIndexKey, sessionID)\n176: \n177: \t_, err := pipe.Exec(ctx)\n178: \tif err != nil {\n179: \t\treturn err\n180: \t}\n181: \n182: \treturn nil\n183: }\n184: \n185: func (rs *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n186: \tif limit <= 0 {\n187: \t\treturn nil, nil\n188: \t}\n189: \n190: \tsessionIDs, err := rs.cli.ZRangeByScore(ctx, rs.expiryIndexKey, &redis.ZRangeBy{\n191: \t\tMin:    \"-inf\",\n192: \t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n193: \t\tOffset: 0,\n194: \t\tCount:  limit,\n195: \t}).Result()\n196: \tif err != nil {\n197: \t\treturn nil, err\n198: \t}\n199: \n200: \treturn rs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n201: }\n202: \n203: func (rs *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n204: \tif limit <= 0 {\n205: \t\treturn nil, nil\n206: \t}\n207: \n208: \tsessionIDs, err := rs.cli.ZRangeByScore(ctx, rs.lastActivityIndexKey, &redis.ZRangeBy{\n209: \t\tMin:    \"-inf\",\n210: \t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n211: \t\tOffset: 0,\n212: \t\tCount:  limit,\n213: \t}).Result()\n214: \tif err != nil {\n215: \t\treturn nil, err\n216: \t}\n217: \n218: \treturn rs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n219: }\n220: \n221: func (rs *redisStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n222: \tif len(sessionIDs) == 0 {\n223: \t\treturn nil, nil\n224: \t}\n225: \n226: \tkeys := make([]string, len(sessionIDs))\n227: \tfor i, sid := range sessionIDs {\n228: \t\tkeys[i] = rs.sessionKey(sid)\n229: \t}\n230: \n231: \tresults, err := rs.cli.MGet(ctx, keys...).Result()\n232: \tif err != nil {\n233: \t\treturn nil, err\n234: \t}\n235: \n236: \tvar sandboxes []*types.SandboxInfo\n237: \tfor i, data := range results {\n238: \t\tif data == nil {\n239: \t\t\tcontinue\n240: \t\t}\n241: \t\tstr, ok := data.(string)\n242: \t\tif !ok || str == \"\" {\n243: \t\t\tcontinue\n244: \t\t}\n245: \t\tvar sandbox types.SandboxInfo\n246: \t\tif err := json.Unmarshal([]byte(str), &sandbox); err != nil {\n247: \t\t\tklog.V(4).Infof(\"failed to unmarshal sandbox %s: %v\", sessionIDs[i], err)\n248: \t\t\tcontinue\n249: \t\t}\n250: \t\tsandboxes = append(sandboxes, &sandbox)\n251: \t}\n252: \n253: \treturn sandboxes, nil\n254: }\n255: \n256: func (rs *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n257: \tif sessionID == \"\" {\n258: \t\treturn errors.New(\"session ID is required\")\n259: \t}\n260: \n261: \tkey := rs.sessionKey(sessionID)\n262: \texists, err := rs.cli.Exists(ctx, key).Result()\n263: \tif err != nil {\n264: \t\treturn err\n265: \t}\n266: \tif exists != 1 {\n267: \t\treturn ErrNotFound\n268: \t}\n269: \n270: \ttimestamp := at\n271: \tif timestamp.IsZero() {\n272: \t\ttimestamp = time.Now()\n273: \t}\n274: \n275: \tscore := float64(timestamp.Unix())\n276: \t_, err = rs.cli.ZAdd(ctx, rs.lastActivityIndexKey, redis.Z{Score: score, Member: sessionID}).Result()\n277: \tif err != nil {\n278: \t\treturn err\n279: \t}\n280: \n281: \treturn nil\n282: }\n283: \n284: func (rs *redisStore) Close() error {\n285: \treturn rs.cli.Close()\n286: }\n\n(End of file - total 286 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  *redis.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_redis.go","time":{"start":1775852198098,"end":1775852198128}}}}
