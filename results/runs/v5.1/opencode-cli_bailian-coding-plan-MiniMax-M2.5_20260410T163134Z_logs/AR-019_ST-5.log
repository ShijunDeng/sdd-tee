134Z/pkg/picod/config_test.go","range":{"start":{"line":91,"character":5},"end":{"line":91,"character":22}}},"message":"other declaration of TestDefaultConfig"}]}]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go\n@@ -692,8 +692,12 @@\n \t}{\n \t\t{Config{Port: 8080}, false},\n \t\t{Config{Port: 0}, true},\n \t\t{Config{Port: 70000}, true},\n+\t\t{Config{Port: 8080, AuthMode: \"picod\", SessionTimeout: 15 * time.Minute, MaxSessionDuration: 8 * time.Hour}, false},\n+\t\t{Config{Port: 8080, AuthMode: \"\", SessionTimeout: 0, MaxSessionDuration: 0}, false},\n+\t\t{Config{Port: 1}, false},\n+\t\t{Config{Port: 65535}, false},\n \t}\n \n \tfor _, tt := range tests {\n \t\terr := tt.config.Validate()\n@@ -702,8 +706,52 @@\n \t\t}\n \t}\n }\n \n+func TestConfig_ValidateSetsDefaults(t *testing.T) {\n+\tcfg := &Config{\n+\t\tPort: 9000,\n+\t}\n+\n+\terr := cfg.Validate()\n+\tif err != nil {\n+\t\tt.Fatalf(\"Unexpected error: %v\", err)\n+\t}\n+\n+\tif cfg.Port != 9000 {\n+\t\tt.Errorf(\"Port should remain 9000, got %d\", cfg.Port)\n+\t}\n+\tif cfg.AuthMode != \"picod\" {\n+\t\tt.Errorf(\"AuthMode should default to 'picod', got %s\", cfg.AuthMode)\n+\t}\n+\tif cfg.SessionTimeout != 15*time.Minute {\n+\t\tt.Errorf(\"SessionTimeout should default to 15m, got %v\", cfg.SessionTimeout)\n+\t}\n+\tif cfg.MaxSessionDuration != 8*time.Hour {\n+\t\tt.Errorf(\"MaxSessionDuration should default to 8h, got %v\", cfg.MaxSessionDuration)\n+\t}\n+}\n+\n+func TestDefaultConfig(t *testing.T) {\n+\tcfg := DefaultConfig()\n+\n+\tif cfg.Port != 8080 {\n+\t\tt.Errorf(\"Expected port 8080, got %d\", cfg.Port)\n+\t}\n+\tif cfg.Workspace != \"\" {\n+\t\tt.Errorf(\"Expected empty workspace, got %s\", cfg.Workspace)\n+\t}\n+\tif cfg.AuthMode != \"picod\" {\n+\t\tt.Errorf(\"Expected auth mode 'picod', got %s\", cfg.AuthMode)\n+\t}\n+\tif cfg.SessionTimeout != 15*time.Minute {\n+\t\tt.Errorf(\"Expected session timeout 15m, got %v\", cfg.SessionTimeout)\n+\t}\n+\tif cfg.MaxSessionDuration != 8*time.Hour {\n+\t\tt.Errorf(\"Expected max session duration 8h, got %v\", cfg.MaxSessionDuration)\n+\t}\n+}\n+\n func TestNewAuthManager_LoadPublicKeyFromEnv(t *testing.T) {\n \tpubKey := &testRSAKey.PublicKey\n \n \tderBytes, _ := x509.MarshalPKIXPublicKey(pubKey)\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go","before":"package picod\n\nimport (\n\t\"bytes\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nfunc init() {\n\tgin.SetMode(gin.TestMode)\n}\n\nvar testRSAKey *rsa.PrivateKey\n\nfunc init() {\n\tvar err error\n\ttestRSAKey, err = rsa.GenerateKey(rand.Reader, 2048)\n\tif err != nil {\n\t\tpanic(\"failed to generate test RSA key: \" + err.Error())\n\t}\n}\n\nfunc generateTestJWT(t *testing.T, expiry time.Time) string {\n\tclaims := jwt.MapClaims{\n\t\t\"exp\": expiry.Unix(),\n\t\t\"iat\": time.Now().Unix(),\n\t}\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, err := token.SignedString(testRSAKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to sign token: %v\", err)\n\t}\n\treturn tokenString\n}\n\nfunc setupTestServer(t *testing.T, workspace string) *Server {\n\tpubKey := &testRSAKey.PublicKey\n\n\tpemData := base64.StdEncoding.EncodeToString(pubKeyToBytes(t, pubKey))\n\tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n\tfor i := 0; i < len(pemData); i += 64 {\n\t\tend := i + 64\n\t\tif end > len(pemData) {\n\t\t\tend = len(pemData)\n\t\t}\n\t\tpemBlock += pemData[i:end] + \"\\n\"\n\t}\n\tpemBlock += \"-----END PUBLIC KEY-----\"\n\n\tos.Setenv(PublicKeyEnvVar, pemBlock)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\ttmpDir := t.TempDir()\n\tif workspace != \"\" {\n\t\ttmpDir = workspace\n\t\tos.MkdirAll(tmpDir, 0755)\n\t}\n\n\tconfig := &Config{\n\t\tPort:      8080,\n\t\tWorkspace: tmpDir,\n\t}\n\n\tauthConfig := &AuthConfig{\n\t\tPublicPaths: []string{\"/health\"},\n\t}\n\n\tserver, err := NewServer(config, authConfig)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to create server: %v\", err)\n\t}\n\n\treturn server\n}\n\nfunc pubKeyToBytes(t *testing.T, pubKey *rsa.PublicKey) []byte {\n\tderBytes, err := x509.MarshalPKIXPublicKey(pubKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to marshal public key: %v\", err)\n\t}\n\treturn derBytes\n}\n\nfunc createTestRequest(t *testing.T, method, path, token string, body interface{}) *http.Request {\n\tvar bodyReader io.Reader\n\tif body != nil {\n\t\tjsonBody, err := json.Marshal(body)\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"failed to marshal body: %v\", err)\n\t\t}\n\t\tbodyReader = bytes.NewBuffer(jsonBody)\n\t}\n\n\treq := httptest.NewRequest(method, path, bodyReader)\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tif token != \"\" {\n\t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\t}\n\treturn req\n}\n\nfunc TestExecuteHandler_Success(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp ExecuteResponse\n\tif err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {\n\t\tt.Fatalf(\"failed to unmarshal response: %v\", err)\n\t}\n\n\tif resp.Stdout == \"\" {\n\t\tt.Error(\"expected stdout to contain 'hello', got empty\")\n\t}\n}\n\nfunc TestExecuteHandler_EmptyCommand(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n\n\tvar resp map[string]interface{}\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\tif resp[\"error\"] != \"command cannot be empty\" {\n\t\tt.Errorf(\"expected error 'command cannot be empty', got %v\", resp[\"error\"])\n\t}\n}\n\nfunc TestExecuteHandler_InvalidTimeout(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t\tTimeout: \"invalid\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestExecuteHandler_TimeoutExceeded(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"sleep\", \"5\"},\n\t\tTimeout: \"100ms\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n\n\tvar resp ExecuteResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif resp.ExitCode != TimeoutExitCode {\n\t\tt.Errorf(\"expected exit code %d, got %d\", TimeoutExitCode, resp.ExitCode)\n\t}\n}\n\nfunc TestExecuteHandler_CustomTimeout(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t\tTimeout: \"5s\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n\n\tvar resp ExecuteResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif resp.ExitCode != 0 {\n\t\tt.Errorf(\"expected exit code 0, got %d\", resp.ExitCode)\n\t}\n}\n\nfunc TestExecuteHandler_WorkingDir(t *testing.T) {\n\ttmpDir := t.TempDir()\n\ttestDir := filepath.Join(tmpDir, \"testdir\")\n\tos.MkdirAll(testDir, 0755)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand:    []string{\"pwd\"},\n\t\tWorkingDir: \"testdir\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp ExecuteResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif !strings.Contains(resp.Stdout, \"testdir\") {\n\t\tt.Errorf(\"expected working dir in stdout, got: %s\", resp.Stdout)\n\t}\n}\n\nfunc TestExecuteHandler_InvalidWorkingDir(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand:    []string{\"pwd\"},\n\t\tWorkingDir: \"../etc\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestExecuteHandler_MalformedJSON(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"POST\", \"/api/execute\", strings.NewReader(\"{invalid json\"))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestExecuteHandler_Env(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"sh\", \"-c\", \"echo $TEST_VAR\"},\n\t\tEnv:     map[string]string{\"TEST_VAR\": \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp ExecuteResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif !strings.Contains(resp.Stdout, \"hello\") {\n\t\tt.Errorf(\"expected 'hello' in stdout, got: %s\", resp.Stdout)\n\t}\n}\n\nfunc TestHealthCheckHandler(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n\n\tvar resp map[string]interface{}\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif resp[\"status\"] != \"ok\" {\n\t\tt.Errorf(\"expected status 'ok', got %v\", resp[\"status\"])\n\t}\n\tif resp[\"service\"] != \"PicoD\" {\n\t\tt.Errorf(\"expected service 'PicoD', got %v\", resp[\"service\"])\n\t}\n\tif resp[\"version\"] != \"0.0.1\" {\n\t\tt.Errorf(\"expected version '0.0.1', got %v\", resp[\"version\"])\n\t}\n}\n\nfunc TestAuthMiddleware_MissingHeader(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", \"\", reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n\t}\n}\n\nfunc TestAuthMiddleware_InvalidFormat(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", \"InvalidFormat\", reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n\t}\n}\n\nfunc TestAuthMiddleware_InvalidToken(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", \"Bearer invalidtoken\", reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n\t}\n}\n\nfunc TestListFilesHandler_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tos.MkdirAll(filepath.Join(tmpDir, \"subdir\"), 0755)\n\tos.WriteFile(filepath.Join(tmpDir, \"test.txt\"), []byte(\"hello\"), 0644)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files?path=.\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp ListFilesResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif len(resp.Files) == 0 {\n\t\tt.Error(\"expected files in response, got empty\")\n\t}\n}\n\nfunc TestListFilesHandler_MissingPath(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestListFilesHandler_NotFound(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files?path=nonexistent\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusNotFound {\n\t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n\t}\n}\n\nfunc TestUploadFileHandler_JSON_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"hello world\"))\n\treqBody := UploadFileRequest{\n\t\tPath:    \"test.txt\",\n\t\tContent: content,\n\t}\n\n\tjsonBody, _ := json.Marshal(reqBody)\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp FileInfo\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif resp.Path != \"test.txt\" {\n\t\tt.Errorf(\"expected path 'test.txt', got %s\", resp.Path)\n\t}\n}\n\nfunc TestUploadFileHandler_JSON_InvalidBase64(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := UploadFileRequest{\n\t\tPath:    \"test.txt\",\n\t\tContent: \"not-valid-base64!!!\",\n\t}\n\n\tjsonBody, _ := json.Marshal(reqBody)\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestUploadFileHandler_Multipart_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\tvar b bytes.Buffer\n\twr := multipart.NewWriter(&b)\n\twr.WriteField(\"path\", \"test.txt\")\n\tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n\tfw.Write([]byte(\"hello world\"))\n\twr.Close()\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n\treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n}\n\nfunc TestUploadFileHandler_Multipart_MissingPath(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\tvar b bytes.Buffer\n\twr := multipart.NewWriter(&b)\n\tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n\tfw.Write([]byte(\"hello world\"))\n\twr.Close()\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n\treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestDownloadFileHandler_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tos.WriteFile(filepath.Join(tmpDir, \"test.txt\"), []byte(\"hello world\"), 0644)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files/test.txt\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n\n\tif w.Body.String() != \"hello world\" {\n\t\tt.Errorf(\"expected 'hello world', got %s\", w.Body.String())\n\t}\n}\n\nfunc TestDownloadFileHandler_NotFound(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files/nonexistent.txt\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusNotFound {\n\t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n\t}\n}\n\nfunc TestDownloadFileHandler_Directory(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tos.MkdirAll(filepath.Join(tmpDir, \"mydir\"), 0755)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files/mydir\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestDownloadFileHandler_EscapeWorkspace(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files/../../../etc/passwd\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestSanitizePath(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tos.MkdirAll(filepath.Join(tmpDir, \"subdir\"), 0755)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttests := []struct {\n\t\tname    string\n\t\tinput   string\n\t\twantErr bool\n\t}{\n\t\t{\"valid relative\", \"subdir\", false},\n\t\t{\"valid nested\", \"subdir/nested\", false},\n\t\t{\"escape attempt\", \"../etc\", true},\n\t\t{\"absolute path\", \"/etc/passwd\", false},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\t_, err := server.sanitizePath(tt.input)\n\t\t\tif (err != nil) != tt.wantErr {\n\t\t\t\tt.Errorf(\"sanitizePath() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestParseFileMode(t *testing.T) {\n\ttests := []struct {\n\t\tinput    string\n\t\texpected os.FileMode\n\t}{\n\t\t{\"\", 0644},\n\t\t{\"0777\", 0777},\n\t\t{\"0644\", 0644},\n\t\t{\"invalid\", 0644},\n\t\t{\"09999\", 0644},\n\t}\n\n\tfor _, tt := range tests {\n\t\tresult := parseFileMode(tt.input)\n\t\tif result != tt.expected {\n\t\t\tt.Errorf(\"parseFileMode(%q) = %o, expected %o\", tt.input, result, tt.expected)\n\t\t}\n\t}\n}\n\nfunc TestConfig_Validate(t *testing.T) {\n\ttests := []struct {\n\t\tconfig  Config\n\t\twantErr bool\n\t}{\n\t\t{Config{Port: 8080}, false},\n\t\t{Config{Port: 0}, true},\n\t\t{Config{Port: 70000}, true},\n\t}\n\n\tfor _, tt := range tests {\n\t\terr := tt.config.Validate()\n\t\tif (err != nil) != tt.wantErr {\n\t\t\tt.Errorf(\"Config.Validate() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t}\n\t}\n}\n\nfunc TestNewAuthManager_LoadPublicKeyFromEnv(t *testing.T) {\n\tpubKey := &testRSAKey.PublicKey\n\n\tderBytes, _ := x509.MarshalPKIXPublicKey(pubKey)\n\tpemData := base64.StdEncoding.EncodeToString(derBytes)\n\tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n\tfor i := 0; i < len(pemData); i += 64 {\n\t\tend := i + 64\n\t\tif end > len(pemData) {\n\t\t\tend = len(pemData)\n\t\t}\n\t\tpemBlock += pemData[i:end] + \"\\n\"\n\t}\n\tpemBlock += \"-----END PUBLIC KEY-----\"\n\n\tos.Setenv(PublicKeyEnvVar, pemBlock)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tam := NewAuthManager()\n\terr := am.LoadPublicKeyFromEnv()\n\tif err != nil {\n\t\tt.Errorf(\"LoadPublicKeyFromEnv() error = %v\", err)\n\t}\n\n\tif am.GetPublicKey() == nil {\n\t\tt.Error(\"expected public key to be loaded\")\n\t}\n}\n\nfunc TestNewAuthManager_LoadPublicKeyFromEnv_Empty(t *testing.T) {\n\tos.Unsetenv(PublicKeyEnvVar)\n\n\tam := NewAuthManager()\n\terr := am.LoadPublicKeyFromEnv()\n\n\tif err == nil {\n\t\tt.Error(\"expected error for empty env var\")\n\t}\n}\n\nfunc TestExecuteContext_TimeoutExitCode(t *testing.T) {\n\tif TimeoutExitCode != 124 {\n\t\tt.Errorf(\"expected TimeoutExitCode to be 124, got %d\", TimeoutExitCode)\n\t}\n}\n\nfunc TestDefaultTimeout(t *testing.T) {\n\texpected := 60 * time.Second\n\tif DefaultTimeout != expected {\n\t\tt.Errorf(\"expected DefaultTimeout to be %v, got %v\", expected, DefaultTimeout)\n\t}\n}\n\nfunc TestAuthManager_InvalidPublicKey(t *testing.T) {\n\tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tam := NewAuthManager()\n\terr := am.LoadPublicKeyFromEnv()\n\n\tif err == nil {\n\t\tt.Error(\"expected error for invalid PEM data\")\n\t}\n}\n\nfunc TestServer_Run_GracefulShutdown(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tserver := setupTestServer(t, tmpDir)\n\n\tserver.config.Port = 18080\n\n\treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"bytes\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nfunc init() {\n\tgin.SetMode(gin.TestMode)\n}\n\nvar testRSAKey *rsa.PrivateKey\n\nfunc init() {\n\tvar err error\n\ttestRSAKey, err = rsa.GenerateKey(rand.Reader, 2048)\n\tif err != nil {\n\t\tpanic(\"failed to generate test RSA key: \" + err.Error())\n\t}\n}\n\nfunc generateTestJWT(t *testing.T, expiry time.Time) string {\n\tclaims := jwt.MapClaims{\n\t\t\"exp\": expiry.Unix(),\n\t\t\"iat\": time.Now().Unix(),\n\t}\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, err := token.SignedString(testRSAKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to sign token: %v\", err)\n\t}\n\treturn tokenString\n}\n\nfunc setupTestServer(t *testing.T, workspace string) *Server {\n\tpubKey := &testRSAKey.PublicKey\n\n\tpemData := base64.StdEncoding.EncodeToString(pubKeyToBytes(t, pubKey))\n\tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n\tfor i := 0; i < len(pemData); i += 64 {\n\t\tend := i + 64\n\t\tif end > len(pemData) {\n\t\t\tend = len(pemData)\n\t\t}\n\t\tpemBlock += pemData[i:end] + \"\\n\"\n\t}\n\tpemBlock += \"-----END PUBLIC KEY-----\"\n\n\tos.Setenv(PublicKeyEnvVar, pemBlock)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\ttmpDir := t.TempDir()\n\tif workspace != \"\" {\n\t\ttmpDir = workspace\n\t\tos.MkdirAll(tmpDir, 0755)\n\t}\n\n\tconfig := &Config{\n\t\tPort:      8080,\n\t\tWorkspace: tmpDir,\n\t}\n\n\tauthConfig := &AuthConfig{\n\t\tPublicPaths: []string{\"/health\"},\n\t}\n\n\tserver, err := NewServer(config, authConfig)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to create server: %v\", err)\n\t}\n\n\treturn server\n}\n\nfunc pubKeyToBytes(t *testing.T, pubKey *rsa.PublicKey) []byte {\n\tderBytes, err := x509.MarshalPKIXPublicKey(pubKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to marshal public key: %v\", err)\n\t}\n\treturn derBytes\n}\n\nfunc createTestRequest(t *testing.T, method, path, token string, body interface{}) *http.Request {\n\tvar bodyReader io.Reader\n\tif body != nil {\n\t\tjsonBody, err := json.Marshal(body)\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"failed to marshal body: %v\", err)\n\t\t}\n\t\tbodyReader = bytes.NewBuffer(jsonBody)\n\t}\n\n\treq := httptest.NewRequest(method, path, bodyReader)\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tif token != \"\" {\n\t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\t}\n\treturn req\n}\n\nfunc TestExecuteHandler_Success(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp ExecuteResponse\n\tif err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {\n\t\tt.Fatalf(\"failed to unmarshal response: %v\", err)\n\t}\n\n\tif resp.Stdout == \"\" {\n\t\tt.Error(\"expected stdout to contain 'hello', got empty\")\n\t}\n}\n\nfunc TestExecuteHandler_EmptyCommand(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n\n\tvar resp map[string]interface{}\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\tif resp[\"error\"] != \"command cannot be empty\" {\n\t\tt.Errorf(\"expected error 'command cannot be empty', got %v\", resp[\"error\"])\n\t}\n}\n\nfunc TestExecuteHandler_InvalidTimeout(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t\tTimeout: \"invalid\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestExecuteHandler_TimeoutExceeded(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"sleep\", \"5\"},\n\t\tTimeout: \"100ms\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n\n\tvar resp ExecuteResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif resp.ExitCode != TimeoutExitCode {\n\t\tt.Errorf(\"expected exit code %d, got %d\", TimeoutExitCode, resp.ExitCode)\n\t}\n}\n\nfunc TestExecuteHandler_CustomTimeout(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t\tTimeout: \"5s\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n\n\tvar resp ExecuteResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif resp.ExitCode != 0 {\n\t\tt.Errorf(\"expected exit code 0, got %d\", resp.ExitCode)\n\t}\n}\n\nfunc TestExecuteHandler_WorkingDir(t *testing.T) {\n\ttmpDir := t.TempDir()\n\ttestDir := filepath.Join(tmpDir, \"testdir\")\n\tos.MkdirAll(testDir, 0755)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand:    []string{\"pwd\"},\n\t\tWorkingDir: \"testdir\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp ExecuteResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif !strings.Contains(resp.Stdout, \"testdir\") {\n\t\tt.Errorf(\"expected working dir in stdout, got: %s\", resp.Stdout)\n\t}\n}\n\nfunc TestExecuteHandler_InvalidWorkingDir(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand:    []string{\"pwd\"},\n\t\tWorkingDir: \"../etc\",\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestExecuteHandler_MalformedJSON(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"POST\", \"/api/execute\", strings.NewReader(\"{invalid json\"))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestExecuteHandler_Env(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"sh\", \"-c\", \"echo $TEST_VAR\"},\n\t\tEnv:     map[string]string{\"TEST_VAR\": \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp ExecuteResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif !strings.Contains(resp.Stdout, \"hello\") {\n\t\tt.Errorf(\"expected 'hello' in stdout, got: %s\", resp.Stdout)\n\t}\n}\n\nfunc TestHealthCheckHandler(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n\n\tvar resp map[string]interface{}\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif resp[\"status\"] != \"ok\" {\n\t\tt.Errorf(\"expected status 'ok', got %v\", resp[\"status\"])\n\t}\n\tif resp[\"service\"] != \"PicoD\" {\n\t\tt.Errorf(\"expected service 'PicoD', got %v\", resp[\"service\"])\n\t}\n\tif resp[\"version\"] != \"0.0.1\" {\n\t\tt.Errorf(\"expected version '0.0.1', got %v\", resp[\"version\"])\n\t}\n}\n\nfunc TestAuthMiddleware_MissingHeader(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", \"\", reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n\t}\n}\n\nfunc TestAuthMiddleware_InvalidFormat(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", \"InvalidFormat\", reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n\t}\n}\n\nfunc TestAuthMiddleware_InvalidToken(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\treqBody := ExecuteRequest{\n\t\tCommand: []string{\"echo\", \"hello\"},\n\t}\n\treq := createTestRequest(t, \"POST\", \"/api/execute\", \"Bearer invalidtoken\", reqBody)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusUnauthorized {\n\t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n\t}\n}\n\nfunc TestListFilesHandler_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tos.MkdirAll(filepath.Join(tmpDir, \"subdir\"), 0755)\n\tos.WriteFile(filepath.Join(tmpDir, \"test.txt\"), []byte(\"hello\"), 0644)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files?path=.\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp ListFilesResponse\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif len(resp.Files) == 0 {\n\t\tt.Error(\"expected files in response, got empty\")\n\t}\n}\n\nfunc TestListFilesHandler_MissingPath(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestListFilesHandler_NotFound(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files?path=nonexistent\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusNotFound {\n\t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n\t}\n}\n\nfunc TestUploadFileHandler_JSON_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"hello world\"))\n\treqBody := UploadFileRequest{\n\t\tPath:    \"test.txt\",\n\t\tContent: content,\n\t}\n\n\tjsonBody, _ := json.Marshal(reqBody)\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n\n\tvar resp FileInfo\n\tjson.Unmarshal(w.Body.Bytes(), &resp)\n\n\tif resp.Path != \"test.txt\" {\n\t\tt.Errorf(\"expected path 'test.txt', got %s\", resp.Path)\n\t}\n}\n\nfunc TestUploadFileHandler_JSON_InvalidBase64(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treqBody := UploadFileRequest{\n\t\tPath:    \"test.txt\",\n\t\tContent: \"not-valid-base64!!!\",\n\t}\n\n\tjsonBody, _ := json.Marshal(reqBody)\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestUploadFileHandler_Multipart_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\tvar b bytes.Buffer\n\twr := multipart.NewWriter(&b)\n\twr.WriteField(\"path\", \"test.txt\")\n\tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n\tfw.Write([]byte(\"hello world\"))\n\twr.Close()\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n\treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n\t}\n}\n\nfunc TestUploadFileHandler_Multipart_MissingPath(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\tvar b bytes.Buffer\n\twr := multipart.NewWriter(&b)\n\tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n\tfw.Write([]byte(\"hello world\"))\n\twr.Close()\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n\treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestDownloadFileHandler_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tos.WriteFile(filepath.Join(tmpDir, \"test.txt\"), []byte(\"hello world\"), 0644)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files/test.txt\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n\n\tif w.Body.String() != \"hello world\" {\n\t\tt.Errorf(\"expected 'hello world', got %s\", w.Body.String())\n\t}\n}\n\nfunc TestDownloadFileHandler_NotFound(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files/nonexistent.txt\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusNotFound {\n\t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n\t}\n}\n\nfunc TestDownloadFileHandler_Directory(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tos.MkdirAll(filepath.Join(tmpDir, \"mydir\"), 0755)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files/mydir\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestDownloadFileHandler_EscapeWorkspace(t *testing.T) {\n\tserver := setupTestServer(t, \"\")\n\n\ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/files/../../../etc/passwd\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n\t}\n}\n\nfunc TestSanitizePath(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tos.MkdirAll(filepath.Join(tmpDir, \"subdir\"), 0755)\n\n\tserver := setupTestServer(t, tmpDir)\n\n\ttests := []struct {\n\t\tname    string\n\t\tinput   string\n\t\twantErr bool\n\t}{\n\t\t{\"valid relative\", \"subdir\", false},\n\t\t{\"valid nested\", \"subdir/nested\", false},\n\t\t{\"escape attempt\", \"../etc\", true},\n\t\t{\"absolute path\", \"/etc/passwd\", false},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\t_, err := server.sanitizePath(tt.input)\n\t\t\tif (err != nil) != tt.wantErr {\n\t\t\t\tt.Errorf(\"sanitizePath() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestParseFileMode(t *testing.T) {\n\ttests := []struct {\n\t\tinput    string\n\t\texpected os.FileMode\n\t}{\n\t\t{\"\", 0644},\n\t\t{\"0777\", 0777},\n\t\t{\"0644\", 0644},\n\t\t{\"invalid\", 0644},\n\t\t{\"09999\", 0644},\n\t}\n\n\tfor _, tt := range tests {\n\t\tresult := parseFileMode(tt.input)\n\t\tif result != tt.expected {\n\t\t\tt.Errorf(\"parseFileMode(%q) = %o, expected %o\", tt.input, result, tt.expected)\n\t\t}\n\t}\n}\n\nfunc TestConfig_Validate(t *testing.T) {\n\ttests := []struct {\n\t\tconfig  Config\n\t\twantErr bool\n\t}{\n\t\t{Config{Port: 8080}, false},\n\t\t{Config{Port: 0}, true},\n\t\t{Config{Port: 70000}, true},\n\t\t{Config{Port: 8080, AuthMode: \"picod\", SessionTimeout: 15 * time.Minute, MaxSessionDuration: 8 * time.Hour}, false},\n\t\t{Config{Port: 8080, AuthMode: \"\", SessionTimeout: 0, MaxSessionDuration: 0}, false},\n\t\t{Config{Port: 1}, false},\n\t\t{Config{Port: 65535}, false},\n\t}\n\n\tfor _, tt := range tests {\n\t\terr := tt.config.Validate()\n\t\tif (err != nil) != tt.wantErr {\n\t\t\tt.Errorf(\"Config.Validate() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t}\n\t}\n}\n\nfunc TestConfig_ValidateSetsDefaults(t *testing.T) {\n\tcfg := &Config{\n\t\tPort: 9000,\n\t}\n\n\terr := cfg.Validate()\n\tif err != nil {\n\t\tt.Fatalf(\"Unexpected error: %v\", err)\n\t}\n\n\tif cfg.Port != 9000 {\n\t\tt.Errorf(\"Port should remain 9000, got %d\", cfg.Port)\n\t}\n\tif cfg.AuthMode != \"picod\" {\n\t\tt.Errorf(\"AuthMode should default to 'picod', got %s\", cfg.AuthMode)\n\t}\n\tif cfg.SessionTimeout != 15*time.Minute {\n\t\tt.Errorf(\"SessionTimeout should default to 15m, got %v\", cfg.SessionTimeout)\n\t}\n\tif cfg.MaxSessionDuration != 8*time.Hour {\n\t\tt.Errorf(\"MaxSessionDuration should default to 8h, got %v\", cfg.MaxSessionDuration)\n\t}\n}\n\nfunc TestDefaultConfig(t *testing.T) {\n\tcfg := DefaultConfig()\n\n\tif cfg.Port != 8080 {\n\t\tt.Errorf(\"Expected port 8080, got %d\", cfg.Port)\n\t}\n\tif cfg.Workspace != \"\" {\n\t\tt.Errorf(\"Expected empty workspace, got %s\", cfg.Workspace)\n\t}\n\tif cfg.AuthMode != \"picod\" {\n\t\tt.Errorf(\"Expected auth mode 'picod', got %s\", cfg.AuthMode)\n\t}\n\tif cfg.SessionTimeout != 15*time.Minute {\n\t\tt.Errorf(\"Expected session timeout 15m, got %v\", cfg.SessionTimeout)\n\t}\n\tif cfg.MaxSessionDuration != 8*time.Hour {\n\t\tt.Errorf(\"Expected max session duration 8h, got %v\", cfg.MaxSessionDuration)\n\t}\n}\n\nfunc TestNewAuthManager_LoadPublicKeyFromEnv(t *testing.T) {\n\tpubKey := &testRSAKey.PublicKey\n\n\tderBytes, _ := x509.MarshalPKIXPublicKey(pubKey)\n\tpemData := base64.StdEncoding.EncodeToString(derBytes)\n\tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n\tfor i := 0; i < len(pemData); i += 64 {\n\t\tend := i + 64\n\t\tif end > len(pemData) {\n\t\t\tend = len(pemData)\n\t\t}\n\t\tpemBlock += pemData[i:end] + \"\\n\"\n\t}\n\tpemBlock += \"-----END PUBLIC KEY-----\"\n\n\tos.Setenv(PublicKeyEnvVar, pemBlock)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tam := NewAuthManager()\n\terr := am.LoadPublicKeyFromEnv()\n\tif err != nil {\n\t\tt.Errorf(\"LoadPublicKeyFromEnv() error = %v\", err)\n\t}\n\n\tif am.GetPublicKey() == nil {\n\t\tt.Error(\"expected public key to be loaded\")\n\t}\n}\n\nfunc TestNewAuthManager_LoadPublicKeyFromEnv_Empty(t *testing.T) {\n\tos.Unsetenv(PublicKeyEnvVar)\n\n\tam := NewAuthManager()\n\terr := am.LoadPublicKeyFromEnv()\n\n\tif err == nil {\n\t\tt.Error(\"expected error for empty env var\")\n\t}\n}\n\nfunc TestExecuteContext_TimeoutExitCode(t *testing.T) {\n\tif TimeoutExitCode != 124 {\n\t\tt.Errorf(\"expected TimeoutExitCode to be 124, got %d\", TimeoutExitCode)\n\t}\n}\n\nfunc TestDefaultTimeout(t *testing.T) {\n\texpected := 60 * time.Second\n\tif DefaultTimeout != expected {\n\t\tt.Errorf(\"expected DefaultTimeout to be %v, got %v\", expected, DefaultTimeout)\n\t}\n}\n\nfunc TestAuthManager_InvalidPublicKey(t *testing.T) {\n\tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tam := NewAuthManager()\n\terr := am.LoadPublicKeyFromEnv()\n\n\tif err == nil {\n\t\tt.Error(\"expected error for invalid PEM data\")\n\t}\n}\n\nfunc TestServer_Run_GracefulShutdown(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tserver := setupTestServer(t, tmpDir)\n\n\tserver.config.Port = 18080\n\n\treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n\tw := httptest.NewRecorder()\n\n\tserver.GetEngine().ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n\t}\n}\n","additions":48,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go","time":{"start":1775859678855,"end":1775859679061}}}}
