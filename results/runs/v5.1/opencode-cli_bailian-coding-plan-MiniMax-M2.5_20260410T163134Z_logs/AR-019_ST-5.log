{"type":"tool_use","timestamp":1775859654467,"sessionID":"ses_28689bf22ffeC98snfSVZcdBAN","part":{"id":"prt_d797bdabc001GXpxBIORY0mKOJ","messageID":"msg_d797bcdfa0019F0c1IYo3QmJ69","sessionID":"ses_28689bf22ffeC98snfSVZcdBAN","type":"tool","tool":"read","callID":"toolu_e225b1ceafbb4a119cb43371","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/base64\"\n9: \t\"encoding/json\"\n10: \t\"io\"\n11: \t\"mime/multipart\"\n12: \t\"net/http\"\n13: \t\"net/http/httptest\"\n14: \t\"os\"\n15: \t\"path/filepath\"\n16: \t\"strings\"\n17: \t\"testing\"\n18: \t\"time\"\n19: \n20: \t\"github.com/gin-gonic/gin\"\n21: \t\"github.com/golang-jwt/jwt/v5\"\n22: )\n23: \n24: func init() {\n25: \tgin.SetMode(gin.TestMode)\n26: }\n27: \n28: var testRSAKey *rsa.PrivateKey\n29: \n30: func init() {\n31: \tvar err error\n32: \ttestRSAKey, err = rsa.GenerateKey(rand.Reader, 2048)\n33: \tif err != nil {\n34: \t\tpanic(\"failed to generate test RSA key: \" + err.Error())\n35: \t}\n36: }\n37: \n38: func generateTestJWT(t *testing.T, expiry time.Time) string {\n39: \tclaims := jwt.MapClaims{\n40: \t\t\"exp\": expiry.Unix(),\n41: \t\t\"iat\": time.Now().Unix(),\n42: \t}\n43: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n44: \ttokenString, err := token.SignedString(testRSAKey)\n45: \tif err != nil {\n46: \t\tt.Fatalf(\"failed to sign token: %v\", err)\n47: \t}\n48: \treturn tokenString\n49: }\n50: \n51: func setupTestServer(t *testing.T, workspace string) *Server {\n52: \tpubKey := &testRSAKey.PublicKey\n53: \n54: \tpemData := base64.StdEncoding.EncodeToString(pubKeyToBytes(t, pubKey))\n55: \tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n56: \tfor i := 0; i < len(pemData); i += 64 {\n57: \t\tend := i + 64\n58: \t\tif end > len(pemData) {\n59: \t\t\tend = len(pemData)\n60: \t\t}\n61: \t\tpemBlock += pemData[i:end] + \"\\n\"\n62: \t}\n63: \tpemBlock += \"-----END PUBLIC KEY-----\"\n64: \n65: \tos.Setenv(PublicKeyEnvVar, pemBlock)\n66: \tdefer os.Unsetenv(PublicKeyEnvVar)\n67: \n68: \ttmpDir := t.TempDir()\n69: \tif workspace != \"\" {\n70: \t\ttmpDir = workspace\n71: \t\tos.MkdirAll(tmpDir, 0755)\n72: \t}\n73: \n74: \tconfig := &Config{\n75: \t\tPort:      8080,\n76: \t\tWorkspace: tmpDir,\n77: \t}\n78: \n79: \tauthConfig := &AuthConfig{\n80: \t\tPublicPaths: []string{\"/health\"},\n81: \t}\n82: \n83: \tserver, err := NewServer(config, authConfig)\n84: \tif err != nil {\n85: \t\tt.Fatalf(\"failed to create server: %v\", err)\n86: \t}\n87: \n88: \treturn server\n89: }\n90: \n91: func pubKeyToBytes(t *testing.T, pubKey *rsa.PublicKey) []byte {\n92: \tderBytes, err := x509.MarshalPKIXPublicKey(pubKey)\n93: \tif err != nil {\n94: \t\tt.Fatalf(\"failed to marshal public key: %v\", err)\n95: \t}\n96: \treturn derBytes\n97: }\n98: \n99: func createTestRequest(t *testing.T, method, path, token string, body interface{}) *http.Request {\n100: \tvar bodyReader io.Reader\n101: \tif body != nil {\n102: \t\tjsonBody, err := json.Marshal(body)\n103: \t\tif err != nil {\n104: \t\t\tt.Fatalf(\"failed to marshal body: %v\", err)\n105: \t\t}\n106: \t\tbodyReader = bytes.NewBuffer(jsonBody)\n107: \t}\n108: \n109: \treq := httptest.NewRequest(method, path, bodyReader)\n110: \treq.Header.Set(\"Content-Type\", \"application/json\")\n111: \tif token != \"\" {\n112: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n113: \t}\n114: \treturn req\n115: }\n116: \n117: func TestExecuteHandler_Success(t *testing.T) {\n118: \tserver := setupTestServer(t, \"\")\n119: \n120: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n121: \n122: \treqBody := ExecuteRequest{\n123: \t\tCommand: []string{\"echo\", \"hello\"},\n124: \t}\n125: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n126: \tw := httptest.NewRecorder()\n127: \n128: \tserver.GetEngine().ServeHTTP(w, req)\n129: \n130: \tif w.Code != http.StatusOK {\n131: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n132: \t}\n133: \n134: \tvar resp ExecuteResponse\n135: \tif err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {\n136: \t\tt.Fatalf(\"failed to unmarshal response: %v\", err)\n137: \t}\n138: \n139: \tif resp.Stdout == \"\" {\n140: \t\tt.Error(\"expected stdout to contain 'hello', got empty\")\n141: \t}\n142: }\n143: \n144: func TestExecuteHandler_EmptyCommand(t *testing.T) {\n145: \tserver := setupTestServer(t, \"\")\n146: \n147: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n148: \n149: \treqBody := ExecuteRequest{\n150: \t\tCommand: []string{},\n151: \t}\n152: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n153: \tw := httptest.NewRecorder()\n154: \n155: \tserver.GetEngine().ServeHTTP(w, req)\n156: \n157: \tif w.Code != http.StatusBadRequest {\n158: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n159: \t}\n160: \n161: \tvar resp map[string]interface{}\n162: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n163: \tif resp[\"error\"] != \"command cannot be empty\" {\n164: \t\tt.Errorf(\"expected error 'command cannot be empty', got %v\", resp[\"error\"])\n165: \t}\n166: }\n167: \n168: func TestExecuteHandler_InvalidTimeout(t *testing.T) {\n169: \tserver := setupTestServer(t, \"\")\n170: \n171: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n172: \n173: \treqBody := ExecuteRequest{\n174: \t\tCommand: []string{\"echo\", \"hello\"},\n175: \t\tTimeout: \"invalid\",\n176: \t}\n177: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n178: \tw := httptest.NewRecorder()\n179: \n180: \tserver.GetEngine().ServeHTTP(w, req)\n181: \n182: \tif w.Code != http.StatusBadRequest {\n183: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n184: \t}\n185: }\n186: \n187: func TestExecuteHandler_TimeoutExceeded(t *testing.T) {\n188: \tserver := setupTestServer(t, \"\")\n189: \n190: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n191: \n192: \treqBody := ExecuteRequest{\n193: \t\tCommand: []string{\"sleep\", \"5\"},\n194: \t\tTimeout: \"100ms\",\n195: \t}\n196: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n197: \tw := httptest.NewRecorder()\n198: \n199: \tserver.GetEngine().ServeHTTP(w, req)\n200: \n201: \tif w.Code != http.StatusOK {\n202: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n203: \t}\n204: \n205: \tvar resp ExecuteResponse\n206: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n207: \n208: \tif resp.ExitCode != TimeoutExitCode {\n209: \t\tt.Errorf(\"expected exit code %d, got %d\", TimeoutExitCode, resp.ExitCode)\n210: \t}\n211: }\n212: \n213: func TestExecuteHandler_CustomTimeout(t *testing.T) {\n214: \tserver := setupTestServer(t, \"\")\n215: \n216: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n217: \n218: \treqBody := ExecuteRequest{\n219: \t\tCommand: []string{\"echo\", \"hello\"},\n220: \t\tTimeout: \"5s\",\n221: \t}\n222: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n223: \tw := httptest.NewRecorder()\n224: \n225: \tserver.GetEngine().ServeHTTP(w, req)\n226: \n227: \tif w.Code != http.StatusOK {\n228: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n229: \t}\n230: \n231: \tvar resp ExecuteResponse\n232: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n233: \n234: \tif resp.ExitCode != 0 {\n235: \t\tt.Errorf(\"expected exit code 0, got %d\", resp.ExitCode)\n236: \t}\n237: }\n238: \n239: func TestExecuteHandler_WorkingDir(t *testing.T) {\n240: \ttmpDir := t.TempDir()\n241: \ttestDir := filepath.Join(tmpDir, \"testdir\")\n242: \tos.MkdirAll(testDir, 0755)\n243: \n244: \tserver := setupTestServer(t, tmpDir)\n245: \n246: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n247: \n248: \treqBody := ExecuteRequest{\n249: \t\tCommand:    []string{\"pwd\"},\n250: \t\tWorkingDir: \"testdir\",\n251: \t}\n252: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n253: \tw := httptest.NewRecorder()\n254: \n255: \tserver.GetEngine().ServeHTTP(w, req)\n256: \n257: \tif w.Code != http.StatusOK {\n258: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n259: \t}\n260: \n261: \tvar resp ExecuteResponse\n262: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n263: \n264: \tif !strings.Contains(resp.Stdout, \"testdir\") {\n265: \t\tt.Errorf(\"expected working dir in stdout, got: %s\", resp.Stdout)\n266: \t}\n267: }\n268: \n269: func TestExecuteHandler_InvalidWorkingDir(t *testing.T) {\n270: \tserver := setupTestServer(t, \"\")\n271: \n272: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n273: \n274: \treqBody := ExecuteRequest{\n275: \t\tCommand:    []string{\"pwd\"},\n276: \t\tWorkingDir: \"../etc\",\n277: \t}\n278: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n279: \tw := httptest.NewRecorder()\n280: \n281: \tserver.GetEngine().ServeHTTP(w, req)\n282: \n283: \tif w.Code != http.StatusBadRequest {\n284: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n285: \t}\n286: }\n287: \n288: func TestExecuteHandler_MalformedJSON(t *testing.T) {\n289: \tserver := setupTestServer(t, \"\")\n290: \n291: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n292: \n293: \treq := httptest.NewRequest(\"POST\", \"/api/execute\", strings.NewReader(\"{invalid json\"))\n294: \treq.Header.Set(\"Content-Type\", \"application/json\")\n295: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n296: \tw := httptest.NewRecorder()\n297: \n298: \tserver.GetEngine().ServeHTTP(w, req)\n299: \n300: \tif w.Code != http.StatusBadRequest {\n301: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n302: \t}\n303: }\n304: \n305: func TestExecuteHandler_Env(t *testing.T) {\n306: \tserver := setupTestServer(t, \"\")\n307: \n308: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n309: \n310: \treqBody := ExecuteRequest{\n311: \t\tCommand: []string{\"sh\", \"-c\", \"echo $TEST_VAR\"},\n312: \t\tEnv:     map[string]string{\"TEST_VAR\": \"hello\"},\n313: \t}\n314: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n315: \tw := httptest.NewRecorder()\n316: \n317: \tserver.GetEngine().ServeHTTP(w, req)\n318: \n319: \tif w.Code != http.StatusOK {\n320: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n321: \t}\n322: \n323: \tvar resp ExecuteResponse\n324: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n325: \n326: \tif !strings.Contains(resp.Stdout, \"hello\") {\n327: \t\tt.Errorf(\"expected 'hello' in stdout, got: %s\", resp.Stdout)\n328: \t}\n329: }\n330: \n331: func TestHealthCheckHandler(t *testing.T) {\n332: \tserver := setupTestServer(t, \"\")\n333: \n334: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n335: \tw := httptest.NewRecorder()\n336: \n337: \tserver.GetEngine().ServeHTTP(w, req)\n338: \n339: \tif w.Code != http.StatusOK {\n340: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n341: \t}\n342: \n343: \tvar resp map[string]interface{}\n344: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n345: \n346: \tif resp[\"status\"] != \"ok\" {\n347: \t\tt.Errorf(\"expected status 'ok', got %v\", resp[\"status\"])\n348: \t}\n349: \tif resp[\"service\"] != \"PicoD\" {\n350: \t\tt.Errorf(\"expected service 'PicoD', got %v\", resp[\"service\"])\n351: \t}\n352: \tif resp[\"version\"] != \"0.0.1\" {\n353: \t\tt.Errorf(\"expected version '0.0.1', got %v\", resp[\"version\"])\n354: \t}\n355: }\n356: \n357: func TestAuthMiddleware_MissingHeader(t *testing.T) {\n358: \tserver := setupTestServer(t, \"\")\n359: \n360: \treqBody := ExecuteRequest{\n361: \t\tCommand: []string{\"echo\", \"hello\"},\n362: \t}\n363: \treq := createTestRequest(t, \"POST\", \"/api/execute\", \"\", reqBody)\n364: \tw := httptest.NewRecorder()\n365: \n366: \tserver.GetEngine().ServeHTTP(w, req)\n367: \n368: \tif w.Code != http.StatusUnauthorized {\n369: \t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n370: \t}\n371: }\n372: \n373: func TestAuthMiddleware_InvalidFormat(t *testing.T) {\n374: \tserver := setupTestServer(t, \"\")\n375: \n376: \treqBody := ExecuteRequest{\n377: \t\tCommand: []string{\"echo\", \"hello\"},\n378: \t}\n379: \treq := createTestRequest(t, \"POST\", \"/api/execute\", \"InvalidFormat\", reqBody)\n380: \tw := httptest.NewRecorder()\n381: \n382: \tserver.GetEngine().ServeHTTP(w, req)\n383: \n384: \tif w.Code != http.StatusUnauthorized {\n385: \t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n386: \t}\n387: }\n388: \n389: func TestAuthMiddleware_InvalidToken(t *testing.T) {\n390: \tserver := setupTestServer(t, \"\")\n391: \n392: \treqBody := ExecuteRequest{\n393: \t\tCommand: []string{\"echo\", \"hello\"},\n394: \t}\n395: \treq := createTestRequest(t, \"POST\", \"/api/execute\", \"Bearer invalidtoken\", reqBody)\n396: \tw := httptest.NewRecorder()\n397: \n398: \tserver.GetEngine().ServeHTTP(w, req)\n399: \n400: \tif w.Code != http.StatusUnauthorized {\n401: \t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n402: \t}\n403: }\n404: \n405: func TestListFilesHandler_Success(t *testing.T) {\n406: \ttmpDir := t.TempDir()\n407: \tos.MkdirAll(filepath.Join(tmpDir, \"subdir\"), 0755)\n408: \tos.WriteFile(filepath.Join(tmpDir, \"test.txt\"), []byte(\"hello\"), 0644)\n409: \n410: \tserver := setupTestServer(t, tmpDir)\n411: \n412: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n413: \n414: \treq := httptest.NewRequest(\"GET\", \"/api/files?path=.\", nil)\n415: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n416: \tw := httptest.NewRecorder()\n417: \n418: \tserver.GetEngine().ServeHTTP(w, req)\n419: \n420: \tif w.Code != http.StatusOK {\n421: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n422: \t}\n423: \n424: \tvar resp ListFilesResponse\n425: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n426: \n427: \tif len(resp.Files) == 0 {\n428: \t\tt.Error(\"expected files in response, got empty\")\n429: \t}\n430: }\n431: \n432: func TestListFilesHandler_MissingPath(t *testing.T) {\n433: \tserver := setupTestServer(t, \"\")\n434: \n435: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n436: \n437: \treq := httptest.NewRequest(\"GET\", \"/api/files\", nil)\n438: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n439: \tw := httptest.NewRecorder()\n440: \n441: \tserver.GetEngine().ServeHTTP(w, req)\n442: \n443: \tif w.Code != http.StatusBadRequest {\n444: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n445: \t}\n446: }\n447: \n448: func TestListFilesHandler_NotFound(t *testing.T) {\n449: \tserver := setupTestServer(t, \"\")\n450: \n451: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n452: \n453: \treq := httptest.NewRequest(\"GET\", \"/api/files?path=nonexistent\", nil)\n454: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n455: \tw := httptest.NewRecorder()\n456: \n457: \tserver.GetEngine().ServeHTTP(w, req)\n458: \n459: \tif w.Code != http.StatusNotFound {\n460: \t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n461: \t}\n462: }\n463: \n464: func TestUploadFileHandler_JSON_Success(t *testing.T) {\n465: \ttmpDir := t.TempDir()\n466: \tserver := setupTestServer(t, tmpDir)\n467: \n468: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n469: \n470: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"hello world\"))\n471: \treqBody := UploadFileRequest{\n472: \t\tPath:    \"test.txt\",\n473: \t\tContent: content,\n474: \t}\n475: \n476: \tjsonBody, _ := json.Marshal(reqBody)\n477: \treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n478: \treq.Header.Set(\"Content-Type\", \"application/json\")\n479: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n480: \tw := httptest.NewRecorder()\n481: \n482: \tserver.GetEngine().ServeHTTP(w, req)\n483: \n484: \tif w.Code != http.StatusOK {\n485: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n486: \t}\n487: \n488: \tvar resp FileInfo\n489: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n490: \n491: \tif resp.Path != \"test.txt\" {\n492: \t\tt.Errorf(\"expected path 'test.txt', got %s\", resp.Path)\n493: \t}\n494: }\n495: \n496: func TestUploadFileHandler_JSON_InvalidBase64(t *testing.T) {\n497: \tserver := setupTestServer(t, \"\")\n498: \n499: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n500: \n501: \treqBody := UploadFileRequest{\n502: \t\tPath:    \"test.txt\",\n503: \t\tContent: \"not-valid-base64!!!\",\n504: \t}\n505: \n506: \tjsonBody, _ := json.Marshal(reqBody)\n507: \treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n508: \treq.Header.Set(\"Content-Type\", \"application/json\")\n509: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n510: \tw := httptest.NewRecorder()\n511: \n512: \tserver.GetEngine().ServeHTTP(w, req)\n513: \n514: \tif w.Code != http.StatusBadRequest {\n515: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n516: \t}\n517: }\n518: \n519: func TestUploadFileHandler_Multipart_Success(t *testing.T) {\n520: \ttmpDir := t.TempDir()\n521: \tserver := setupTestServer(t, tmpDir)\n522: \n523: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n524: \n525: \tvar b bytes.Buffer\n526: \twr := multipart.NewWriter(&b)\n527: \twr.WriteField(\"path\", \"test.txt\")\n528: \tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n529: \tfw.Write([]byte(\"hello world\"))\n530: \twr.Close()\n531: \n532: \treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n533: \treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n534: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n535: \tw := httptest.NewRecorder()\n536: \n537: \tserver.GetEngine().ServeHTTP(w, req)\n538: \n539: \tif w.Code != http.StatusOK {\n540: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n541: \t}\n542: }\n543: \n544: func TestUploadFileHandler_Multipart_MissingPath(t *testing.T) {\n545: \tserver := setupTestServer(t, \"\")\n546: \n547: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n548: \n549: \tvar b bytes.Buffer\n550: \twr := multipart.NewWriter(&b)\n551: \tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n552: \tfw.Write([]byte(\"hello world\"))\n553: \twr.Close()\n554: \n555: \treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n556: \treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n557: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n558: \tw := httptest.NewRecorder()\n559: \n560: \tserver.GetEngine().ServeHTTP(w, req)\n561: \n562: \tif w.Code != http.StatusBadRequest {\n563: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n564: \t}\n565: }\n566: \n567: func TestDownloadFileHandler_Success(t *testing.T) {\n568: \ttmpDir := t.TempDir()\n569: \tos.WriteFile(filepath.Join(tmpDir, \"test.txt\"), []byte(\"hello world\"), 0644)\n570: \n571: \tserver := setupTestServer(t, tmpDir)\n572: \n573: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n574: \n575: \treq := httptest.NewRequest(\"GET\", \"/api/files/test.txt\", nil)\n576: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n577: \tw := httptest.NewRecorder()\n578: \n579: \tserver.GetEngine().ServeHTTP(w, req)\n580: \n581: \tif w.Code != http.StatusOK {\n582: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n583: \t}\n584: \n585: \tif w.Body.String() != \"hello world\" {\n586: \t\tt.Errorf(\"expected 'hello world', got %s\", w.Body.String())\n587: \t}\n588: }\n589: \n590: func TestDownloadFileHandler_NotFound(t *testing.T) {\n591: \tserver := setupTestServer(t, \"\")\n592: \n593: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n594: \n595: \treq := httptest.NewRequest(\"GET\", \"/api/files/nonexistent.txt\", nil)\n596: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n597: \tw := httptest.NewRecorder()\n598: \n599: \tserver.GetEngine().ServeHTTP(w, req)\n600: \n601: \tif w.Code != http.StatusNotFound {\n602: \t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n603: \t}\n604: }\n605: \n606: func TestDownloadFileHandler_Directory(t *testing.T) {\n607: \ttmpDir := t.TempDir()\n608: \tos.MkdirAll(filepath.Join(tmpDir, \"mydir\"), 0755)\n609: \n610: \tserver := setupTestServer(t, tmpDir)\n611: \n612: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n613: \n614: \treq := httptest.NewRequest(\"GET\", \"/api/files/mydir\", nil)\n615: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n616: \tw := httptest.NewRecorder()\n617: \n618: \tserver.GetEngine().ServeHTTP(w, req)\n619: \n620: \tif w.Code != http.StatusBadRequest {\n621: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n622: \t}\n623: }\n624: \n625: func TestDownloadFileHandler_EscapeWorkspace(t *testing.T) {\n626: \tserver := setupTestServer(t, \"\")\n627: \n628: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n629: \n630: \treq := httptest.NewRequest(\"GET\", \"/api/files/../../../etc/passwd\", nil)\n631: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n632: \tw := httptest.NewRecorder()\n633: \n634: \tserver.GetEngine().ServeHTTP(w, req)\n635: \n636: \tif w.Code != http.StatusBadRequest {\n637: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n638: \t}\n639: }\n640: \n641: func TestSanitizePath(t *testing.T) {\n642: \ttmpDir := t.TempDir()\n643: \tos.MkdirAll(filepath.Join(tmpDir, \"subdir\"), 0755)\n644: \n645: \tserver := setupTestServer(t, tmpDir)\n646: \n647: \ttests := []struct {\n648: \t\tname    string\n649: \t\tinput   string\n650: \t\twantErr bool\n651: \t}{\n652: \t\t{\"valid relative\", \"subdir\", false},\n653: \t\t{\"valid nested\", \"subdir/nested\", false},\n654: \t\t{\"escape attempt\", \"../etc\", true},\n655: \t\t{\"absolute path\", \"/etc/passwd\", false},\n656: \t}\n657: \n658: \tfor _, tt := range tests {\n659: \t\tt.Run(tt.name, func(t *testing.T) {\n660: \t\t\t_, err := server.sanitizePath(tt.input)\n661: \t\t\tif (err != nil) != tt.wantErr {\n662: \t\t\t\tt.Errorf(\"sanitizePath() error = %v, wantErr %v\", err, tt.wantErr)\n663: \t\t\t}\n664: \t\t})\n665: \t}\n666: }\n667: \n668: func TestParseFileMode(t *testing.T) {\n669: \ttests := []struct {\n670: \t\tinput    string\n671: \t\texpected os.FileMode\n672: \t}{\n673: \t\t{\"\", 0644},\n674: \t\t{\"0777\", 0777},\n675: \t\t{\"0644\", 0644},\n676: \t\t{\"invalid\", 0644},\n677: \t\t{\"09999\", 0644},\n678: \t}\n679: \n680: \tfor _, tt := range tests {\n681: \t\tresult := parseFileMode(tt.input)\n682: \t\tif result != tt.expected {\n683: \t\t\tt.Errorf(\"parseFileMode(%q) = %o, expected %o\", tt.input, result, tt.expected)\n684: \t\t}\n685: \t}\n686: }\n687: \n688: func TestConfig_Validate(t *testing.T) {\n689: \ttests := []struct {\n690: \t\tconfig  Config\n691: \t\twantErr bool\n692: \t}{\n693: \t\t{Config{Port: 8080}, false},\n694: \t\t{Config{Port: 0}, true},\n695: \t\t{Config{Port: 70000}, true},\n696: \t}\n697: \n698: \tfor _, tt := range tests {\n699: \t\terr := tt.config.Validate()\n700: \t\tif (err != nil) != tt.wantErr {\n701: \t\t\tt.Errorf(\"Config.Validate() error = %v, wantErr %v\", err, tt.wantErr)\n702: \t\t}\n703: \t}\n704: }\n705: \n706: func TestNewAuthManager_LoadPublicKeyFromEnv(t *testing.T) {\n707: \tpubKey := &testRSAKey.PublicKey\n708: \n709: \tderBytes, _ := x509.MarshalPKIXPublicKey(pubKey)\n710: \tpemData := base64.StdEncoding.EncodeToString(derBytes)\n711: \tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n712: \tfor i := 0; i < len(pemData); i += 64 {\n713: \t\tend := i + 64\n714: \t\tif end > len(pemData) {\n715: \t\t\tend = len(pemData)\n716: \t\t}\n717: \t\tpemBlock += pemData[i:end] + \"\\n\"\n718: \t}\n719: \tpemBlock += \"-----END PUBLIC KEY-----\"\n720: \n721: \tos.Setenv(PublicKeyEnvVar, pemBlock)\n722: \tdefer os.Unsetenv(PublicKeyEnvVar)\n723: \n724: \tam := NewAuthManager()\n725: \terr := am.LoadPublicKeyFromEnv()\n726: \tif err != nil {\n727: \t\tt.Errorf(\"LoadPublicKeyFromEnv() error = %v\", err)\n728: \t}\n729: \n730: \tif am.GetPublicKey() == nil {\n731: \t\tt.Error(\"expected public key to be loaded\")\n732: \t}\n733: }\n734: \n735: func TestNewAuthManager_LoadPublicKeyFromEnv_Empty(t *testing.T) {\n736: \tos.Unsetenv(PublicKeyEnvVar)\n737: \n738: \tam := NewAuthManager()\n739: \terr := am.LoadPublicKeyFromEnv()\n740: \n741: \tif err == nil {\n742: \t\tt.Error(\"expected error for empty env var\")\n743: \t}\n744: }\n745: \n746: func TestExecuteContext_TimeoutExitCode(t *testing.T) {\n747: \tif TimeoutExitCode != 124 {\n748: \t\tt.Errorf(\"expected TimeoutExitCode to be 124, got %d\", TimeoutExitCode)\n749: \t}\n750: }\n751: \n752: func TestDefaultTimeout(t *testing.T) {\n753: \texpected := 60 * time.Second\n754: \tif DefaultTimeout != expected {\n755: \t\tt.Errorf(\"expected DefaultTimeout to be %v, got %v\", expected, DefaultTimeout)\n756: \t}\n757: }\n758: \n759: func TestAuthManager_InvalidPublicKey(t *testing.T) {\n760: \tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n761: \tdefer os.Unsetenv(PublicKeyEnvVar)\n762: \n763: \tam := NewAuthManager()\n764: \terr := am.LoadPublicKeyFromEnv()\n765: \n766: \tif err == nil {\n767: \t\tt.Error(\"expected error for invalid PEM data\")\n768: \t}\n769: }\n770: \n771: func TestServer_Run_GracefulShutdown(t *testing.T) {\n772: \ttmpDir := t.TempDir()\n773: \tserver := setupTestServer(t, tmpDir)\n774: \n775: \tserver.config.Port = 18080\n776: \n777: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n778: \tw := httptest.NewRecorder()\n779: \n780: \tserver.GetEngine().ServeHTTP(w, req)\n781: \n782: \tif w.Code != http.StatusOK {\n783: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n784: \t}\n785: }\n\n(End of file - total 785 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"bytes\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\