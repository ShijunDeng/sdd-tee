f !publicKeyPathSet && !publicPathsSet {\n47: \t\treturn nil, fmt.Errorf(\"either %s must be set or %s must be configured\", EnvPublicKeyPath, EnvPublicPaths)\n48: \t}\n49: \n50: \treturn config, nil\n51: }\n52: \n53: func GetPublicPathsFromEnv() []string {\n54: \tenvValue := os.Getenv(EnvPublicPaths)\n55: \tif envValue == \"\" {\n56: \t\treturn []string{DefaultPublicPath}\n57: \t}\n58: \n59: \tpaths := strings.Split(envValue, \",\")\n60: \tvar result []string\n61: \tfor _, p := range paths {\n62: \t\tp = strings.TrimSpace(p)\n63: \t\tif p != \"\" {\n64: \t\t\tresult = append(result, p)\n65: \t\t}\n66: \t}\n67: \n68: \tif len(result) == 0 {\n69: \t\treturn []string{DefaultPublicPath}\n70: \t}\n71: \n72: \treturn result\n73: }\n74: \n75: func GetBoolEnv(key string, defaultValue bool) bool {\n76: \tval := os.Getenv(key)\n77: \tif val == \"\" {\n78: \t\treturn defaultValue\n79: \t}\n80: \treturn strings.ToLower(val) == \"true\" || val == \"1\"\n81: }\n82: \n83: func (c *AuthConfig) Validate() error {\n84: \tif c.PublicKeyPath == \"\" && len(c.PublicPaths) == 0 {\n85: \t\treturn fmt.Errorf(\"either %s must be set or public paths must be configured\", EnvPublicKeyPath)\n86: \t}\n87: \treturn nil\n88: }\n\n(End of file - total 88 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n)\n\nconst (\n\tEnvPublicKeyPath   = \"PICOD_AUTH_PUBLIC_KEY\"\n\tEnvPublicPaths     = \"PICOD_AUTH_PUBLIC_PATHS\"\n\tEnvAllowQueryParam = \"PICOD_AUTH_ALLOW_QUERY_PARAM\"\n\tEnvJWTIssuer       = \"PICOD_JWT_ISSUER\"\n\tEnvJWTAudience     = \"PICOD_JWT_AUDIENCE\"\n\tDefaultPublicPath  = \"/health\"\n)\n\ntype AuthConfig struct {\n\tPublicKeyPath   string\n\tPublicPaths     []string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_config.go","time":{"start":1775859374292,"end":1775859374299}}}}
