rt)\n\t}\n\tif cfg.Workspace != \"\" {\n\t\tt.Errorf(\"Expected empty workspace, got %s\", cfg.Workspace)\n\t}\n\tif cfg.AuthMode != \"picod\" {\n\t\tt.Errorf(\"Expected auth mode 'picod', got %s\", cfg.AuthMode)\n\t}\n\tif cfg.SessionTimeout != 15*time.Minute {\n\t\tt.Errorf(\"Expected session timeout 15m, got %v\", cfg.SessionTimeout)\n\t}\n\tif cfg.MaxSessionDuration != 8*time.Hour {\n\t\tt.Errorf(\"Expected max session duration 8h, got %v\", cfg.MaxSessionDuration)\n\t}\n}","oldString":"func TestConfig_Validate(t *testing.T) {\n\ttests := []struct {\n\t\tconfig  Config\n\t\twantErr bool\n\t}{\n\t\t{Config{Port: 8080}, false},\n\t\t{Config{Port: 0}, true},\n\t\t{Config{Port: 70000}, true},\n\t}\n\n\tfor _, tt := range tests {\n\t\terr := tt.config.Validate()\n\t\tif (err != nil) != tt.wantErr {\n\t\t\tt.Errorf(\"Config.Validate() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t}\n\t}\n}"},"output":"Edit applied successfully.\n\nLSP errors detected in this file, please fix:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go\">\nERROR [688:6] TestConfig_Validate redeclared in this block\nERROR [710:6] TestConfig_ValidateSetsDefaults redeclared in this block\nERROR [734:6] TestDefaultConfig redeclared in this block\n</diagnostics>","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/cmd/picod/main.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration_test.go":[{"range":{"start":{"line":93,"character":15},"end":{"line":93,"character":21}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: metav1"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T