\"`\n44: \tDeletedCount     int           `json:\"deletedCount\"`\n45: \tFailedCount      int           `json:\"failedCount\"`\n46: \tDuration         time.Duration `json:\"duration\"`\n47: \tErrors           []string      `json:\"errors,omitempty\"`\n48: \tCleanedResources []string      `json:\"cleanedResources,omitempty\"`\n49: }\n50: \n51: type GCStats struct {\n52: \tTotalCycles  int64     `json:\"totalCycles\"`\n53: \tTotalDeleted int64     `json:\"totalDeleted\"`\n54: \tTotalFailed  int64     `json:\"totalFailed\"`\n55: \tLastRunTime  time.Time `json:\"lastRunTime\"`\n56: \tLastResult   *GCResult `json:\"lastResult,omitempty\"`\n57: }\n58: \n59: type GCWorker struct {\n60: \tclient            versioned.Interface\n61: \tk8sClient         *kubernetes.Clientset\n62: \tconfig            *GCConfig\n63: \tstopCh            chan struct{}\n64: \tcleanupMgr        *CleanupManager\n65: \texpirationChecker *ExpirationChecker\n66: \tstats             GCStats\n67: \tstatsMu           sync.RWMutex\n68: \tisRunning         bool\n69: \trunningMu         sync.RWMutex\n70: }\n71: \n72: func NewGCWorker(client versioned.Interface, k8sClient *kubernetes.Clientset, config *GCConfig) *GCWorker {\n73: \tif config == nil {\n74: \t\tconfig = DefaultGCConfig()\n75: \t}\n76: \n77: \treturn &GCWorker{\n78: \t\tclient:            client,\n79: \t\tk8sClient:         k8sClient,\n80: \t\tconfig:            config,\n81: \t\tstopCh:            make(chan struct{}),\n82: \t\tcleanupMgr:        NewCleanupManager(k8sClient),\n83: \t\texpirationChecker: NewExpirationChecker(nil),\n84: \t}\n85: }\n86: \n87: func (g *GCWorker) Start(ctx context.Context) {\n88: \tif !g.config.GCEnabled {\n89: \t\tklog.InfoS(\"GC worker is disabled by configuration\")\n90: \t\treturn\n91: \t}\n92: \n93: \tg.setRunning(true)\n94: \tklog.InfoS(\"Starting GC worker\", \"interval\", g.config.GCInterval)\n95: \n96: \tticker := time.NewTicker(g.config.GCInterval)\n97: \tdefer ticker.Stop()\n98: \n99: \tfor {\n100: \t\tselect {\n101: \t\tcase <-ctx.Done():\n102: \t\t\tklog.InfoS(\"GC worker stopping due to context cancellation\")\n103: \t\t\tg.setRunning(false)\n104: \t\t\treturn\n105: \t\tcase <-g.stopCh:\n106: \t\t\tklog.InfoS(\"GC worker stopping\")\n107: \t\t\tg.setRunning(false)\n108: \t\t\treturn\n109: \t\tcase <-ticker.C:\n110: \t\t\tg.runGCCycle(ctx)\n111: \t\t}\n112: \t}\n113: }\n114: \n115: func (g *GCWorker) Stop() {\n116: \tclose(g.stopCh)\n117: \tg.setRunning(false)\n118: }\n119: \n120: func (g *GCWorker) IsRunning() bool {\n121: \tg.runningMu.RLock()\n122: \tdefer g.runningMu.RUnlock()\n123: \treturn g.isRunning\n124: }\n125: \n126: func (g *GCWorker) setRunning(running bool) {\n127: \tg.runningMu.Lock()\n128: \tdefer g.runningMu.Unlock()\n129: \tg.isRunning = running\n130: }\n131: \n132: func (g *GCWorker) GetConfig() *GCConfig {\n133: \treturn g.config\n134: }\n135: \n136: func (g *GCWorker) GetStats() GCStats {\n137: \tg.statsMu.RLock()\n138: \tdefer g.statsMu.RUnlock()\n139: \treturn g.stats\n140: }\n141: \n142: func (g *GCWorker) runGCCycle(ctx context.Context) {\n143: \tstartTime := time.Now()\n144: \tresult := &GCResult{}\n145: \n146: \tklog.V(4).InfoS(\"Starting GC cycle\")\n147: \n148: \tnamespaces, err := g.getNamespaces(ctx)\n149: \tif err != nil {\n150: \t\tklog.ErrorS(err, \"Failed to get namespaces\")\n151: \t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"failed to get namespaces: %v\", err))\n152: \t\tg.recordGCResult(result, startTime)\n153: \t\treturn\n154: \t}\n155: \n156: \tresult.ScannedCount = len(namespaces)\n157: \n158: \tfor _, ns := range namespaces {\n159: \t\tselect {\n160: \t\tcase <-ctx.Done():\n161: \t\t\tklog.InfoS(\"GC cycle cancelled\")\n162: \t\t\tbreak\n163: \t\tcase <-g.stopCh:\n164: \t\t\tklog.InfoS(\"GC cycle stopped\")\n165: \t\t\tbreak\n166: \t\tdefault:\n167: \t\t}\n168: \n169: \t\tif err := g.processNamespace(ctx, ns, result); err != nil {\n170: \t\t\tklog.ErrorS(err, \"Failed to process namespace\", \"namespace\", ns)\n171: \t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"%s: %v\", ns, err))\n172: \t\t}\n173: \n174: \t\tif result.ScannedCount >= g.config.GCBatchSize {\n175: \t\t\tklog.V(4).InfoS(\"Batch size reached\", \"scanned\", result.ScannedCount)\n176: \t\t\tbreak\n177: \t\t}\n178: \t}\n179: \n180: \tresult.Duration = time.Since(startTime)\n181: \tg.recordGCResult(result, startTime)\n182: \n183: \tklog.InfoS(\"GC cycle completed\",\n184: \t\t\"scanned\", result.ScannedCount,\n185: \t\t\"expired\", result.ExpiredCount,\n186: \t\t\"deleted\", result.DeletedCount,\n187: \t\t\"failed\", result.FailedCount,\n188: \t\t\"duration\", result.Duration)\n189: }\n190: \n191: func (g *GCWorker) getNamespaces(ctx context.Context) ([]string, error) {\n192: \tnsList, err := g.k8sClient.CoreV1().Namespaces().List(ctx, metav1.ListOptions{})\n193: \tif err != nil {\n194: \t\treturn nil, fmt.Errorf(\"failed to list namespaces: %w\", err)\n195: \t}\n196: \n197: \tnamespaces := make([]string, 0, len(nsList.Items))\n198: \tfor _, ns := range nsList.Items {\n199: \t\tnamespaces = append(namespaces, ns.Name)\n200: \t}\n201: \n202: \treturn namespaces, nil\n203: }\n204: \n205: func (g *GCWorker) processNamespace(ctx context.Context, namespace string, result *GCResult) error {\n206: \tarList, err := g.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{})\n207: \tif err != nil {\n208: \t\treturn fmt.Errorf(\"failed to list agentruntimes: %w\", err)\n209: \t}\n210: \n211: \tciList, err := g.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{})\n212: \tif err != nil {\n213: \t\treturn fmt.Errorf(\"failed to list codeinterpreters: %w\", err)\n214: \t}\n215: \n216: \tfor i := range arList.Items {\n217: \t\tar := &arList.Items[i]\n218: \t\tresult.ScannedCount++\n219: \n220: \t\tif g.isAgentRuntimeExpired(ar) {\n221: \t\t\tresult.ExpiredCount++\n222: \t\t\tcleaned, err := g.deleteAgentRuntime(ctx, namespace, ar.Name, ar)\n223: \t\t\tresult.CleanedResources = append(result.CleanedResources, cleaned...)\n224: \t\t\tif err != nil {\n225: \t\t\t\tresult.FailedCount++\n226: \t\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"agentruntime/%s: %v\", ar.Name, err))\n227: \t\t\t\tklog.ErrorS(err, \"Failed to delete expired agentruntime\", \"name\", ar.Name)\n228: \t\t\t} else {\n229: \t\t\t\tresult.DeletedCount++\n230: \t\t\t}\n231: \t\t}\n232: \n233: \t\tif result.ScannedCount >= g.config.GCBatchSize {\n234: \t\t\tbreak\n235: \t\t}\n236: \t}\n237: \n238: \tfor i := range ciList.Items {\n239: \t\tci := &ciList.Items[i]\n240: \t\tresult.ScannedCount++\n241: \n242: \t\tif g.isCodeInterpreterExpired(ci) {\n243: \t\t\tresult.ExpiredCount++\n244: \t\t\tcleaned, err := g.deleteCodeInterpreter(ctx, namespace, ci.Name, ci)\n245: \t\t\tresult.CleanedResources = append(result.CleanedResources, cleaned...)\n246: \t\t\tif err != nil {\n247: \t\t\t\tresult.FailedCount++\n248: \t\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"codeinterpreter/%s: %v\", ci.Name, err))\n249: \t\t\t\tklog.ErrorS(err, \"Failed to delete expired codeinterpreter\", \"name\", ci.Name)\n250: \t\t\t} else {\n251: \t\t\t\tresult.DeletedCount++\n252: \t\t\t}\n253: \t\t}\n254: \n255: \t\tif result.ScannedCount >= g.config.GCBatchSize {\n256: \t\t\tbreak\n257: \t\t}\n258: \t}\n259: \n260: \treturn nil\n261: }\n262: \n263: func (g *GCWorker) isAgentRuntimeExpired(ar *agentcubev1alpha1.AgentRuntime) bool {\n264: \tif ar.DeletionTimestamp != nil {\n265: \t\treturn true\n266: \t}\n267: \n268: \tsandbox := &Sandbox{\n269: \t\tName:           ar.Name,\n270: \t\tNamespace:      ar.Namespace,\n271: \t\tSessionID:      ar.Labels[\"sessionId\"],\n272: \t\tState:          g.getAgentRuntimeState(ar),\n273: \t\tCreatedAt:      ar.CreationTimestamp.Time,\n274: \t\tLastActivityAt: g.getLastActivityTime(ar),\n275: \t\tLabels:         ar.Labels,\n276: \t\tAnnotations:    ar.Annotations,\n277: \t}\n278: \n279: \treturn isExpired(sandbox)\n280: }\n281: \n282: func (g *GCWorker) isCodeInterpreterExpired(ci *agentcubev1alpha1.CodeInterpreter) bool {\n283: \tif ci.DeletionTimestamp != nil {\n284: \t\treturn true\n285: \t}\n286: \n287: \tsandbox := &Sandbox{\n288: \t\tName:           ci.Name,\n289: \t\tNamespace:      ci.Namespace,\n290: \t\tSessionID:      ci.Labels[\"sessionId\"],\n291: \t\tState:          g.getCodeInterpreterState(ci),\n292: \t\tCreatedAt:      ci.CreationTimestamp.Time,\n293: \t\tLastActivityAt: g.getLastActivityTime(ci),\n294: \t\tLabels:         ci.Labels,\n295: \t\tAnnotations:    ci.Annotations,\n296: \t}\n297: \n298: \treturn isExpired(sandbox)\n299: }\n300: \n301: func (g *GCWorker) getAgentRuntimeState(ar *agentcubev1alpha1.AgentRuntime) SandboxState {\n302: \tstate := SandboxStateUnknown\n303: \tif len(ar.Status.Conditions) > 0 {\n304: \t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n305: \t\tif lastCondition.Status == \"True\" {\n306: \t\t\tif lastCondition.Reason == \"Running\" {\n307: \t\t\t\tstate = SandboxStateRunning\n308: \t\t\t} else if lastCondition.Reason == \"Failed\" {\n309: \t\t\t\tstate = SandboxStateFailed\n310: \t\t\t}\n311: \t\t}\n312: \t}\n313: \tif ar.DeletionTimestamp != nil {\n314: \t\tstate = SandboxStateDeleting\n315: \t}\n316: \treturn state\n317: }\n318: \n319: func (g *GCWorker) getCodeInterpreterState(ci *agentcubev1alpha1.CodeInterpreter) SandboxState {\n320: \tstate := SandboxStateUnknown\n321: \tif ci.Status.Ready {\n322: \t\tstate = SandboxStateRunning\n323: \t}\n324: \tif len(ci.Status.Conditions) > 0 {\n325: \t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n326: \t\tif lastCondition.Status == \"True\" {\n327: \t\t\tif lastCondition.Reason == \"Failed\" {\n328: \t\t\t\tstate = SandboxStateFailed\n329: \t\t\t}\n330: \t\t}\n331: \t}\n332: \tif ci.DeletionTimestamp != nil {\n333: \t\tstate = SandboxStateDeleting\n334: \t}\n335: \treturn state\n336: }\n337: \n338: func (g *GCWorker) getLastActivityTime(obj metav1.Object) *time.Time {\n339: \tannotations := obj.GetAnnotations()\n340: \tif annotations == nil {\n341: \t\treturn nil\n342: \t}\n343: \n344: \tlastActivityStr := annotations[\"last-activity-time\"]\n345: \tif lastActivityStr == \"\" {\n346: \t\treturn nil\n347: \t}\n348: \n349: \tt, err := time.Parse(time.RFC3339, lastActivityStr)\n350: \tif err != nil {\n351: \t\treturn nil\n352: \t}\n353: \n354: \treturn &t\n355: }\n356: \n357: func (g *GCWorker) deleteAgentRuntime(ctx context.Context, namespace, name string, ar *agentcubev1alpha1.AgentRuntime) ([]string, error) {\n358: \tcleaned := make([]string, 0)\n359: \n360: \townerRef := metav1.OwnerReference{\n361: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n362: \t\tKind:       \"AgentRuntime\",\n363: \t\tName:       ar.Name,\n364: \t\tUID:        ar.UID,\n365: \t}\n366: \n367: \tsvcCleaned, err := g.cleanupMgr.cleanupServices(namespace, ownerRef)\n368: \tif err != nil {\n369: \t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n370: \t}\n371: \tcleaned = append(cleaned, svcCleaned...)\n372: \n373: \tcmCleaned, err := g.cleanupMgr.cleanupConfigMaps(namespace, ownerRef)\n374: \tif err != nil {\n375: \t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n376: \t}\n377: \tcleaned = append(cleaned, cmCleaned...)\n378: \n379: \tpvcCleaned, err := g.cleanupMgr.cleanupPVCs(namespace, ownerRef)\n380: \tif err != nil {\n381: \t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n382: \t}\n383: \tcleaned = append(cleaned, pvcCleaned...)\n384: \n385: \tdeleteOpts := metav1.DeleteOptions{}\n386: \tstate := g.getAgentRuntimeState(ar)\n387: \tif state == SandboxStateUnknown || state == SandboxStateFailed {\n388: \t\tgracePeriodSeconds := int64(StaleGracePeriod.Seconds())\n389: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n390: \t\tklog.InfoS(\"Force deleting stale sandbox\", \"name\", name, \"namespace\", namespace)\n391: \t} else {\n392: \t\tgracePeriodSeconds := int64(DefaultGracePeriod.Seconds())\n393: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n394: \t}\n395: \n396: \terr = g.client.RuntimeV1alpha1().AgentRuntimes(namespace).Delete(ctx, name, deleteOpts)\n397: \tif err != nil {\n398: \t\tif apierrors.IsNotFound(err) {\n399: \t\t\tklog.V(4).InfoS(\"AgentRuntime already deleted\", \"name\", name, \"namespace\", namespace)\n400: \t\t\treturn cleaned, nil\n401: \t\t}\n402: \t\treturn cleaned, fmt.Errorf(\"failed to delete agentruntime: %w\", err)\n403: \t}\n404: \n405: \tklog.InfoS(\"Deleted expired agentruntime\", \"name\", name, \"namespace\", namespace,\n406: \t\t\"cleanedResources\", len(cleaned))\n407: \n408: \treturn cleaned, nil\n409: }\n410: \n411: func (g *GCWorker) deleteCodeInterpreter(ctx context.Context, namespace, name string, ci *agentcubev1alpha1.CodeInterpreter) ([]string, error) {\n412: \tcleaned := make([]string, 0)\n413: \n414: \townerRef := metav1.OwnerReference{\n415: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n416: \t\tKind:       \"CodeInterpreter\",\n417: \t\tName:       ci.Name,\n418: \t\tUID:        ci.UID,\n419: \t}\n420: \n421: \tsvcCleaned, err := g.cleanupMgr.cleanupServices(namespace, ownerRef)\n422: \tif err != nil {\n423: \t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n424: \t}\n425: \tcleaned = append(cleaned, svcCleaned...)\n426: \n427: \tcmCleaned, err := g.cleanupMgr.cleanupConfigMaps(namespace, ownerRef)\n428: \tif err != nil {\n429: \t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n430: \t}\n431: \tcleaned = append(cleaned, cmCleaned...)\n432: \n433: \tpvcCleaned, err := g.cleanupMgr.cleanupPVCs(namespace, ownerRef)\n434: \tif err != nil {\n435: \t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n436: \t}\n437: \tcleaned = append(cleaned, pvcCleaned...)\n438: \n439: \tdeleteOpts := metav1.DeleteOptions{}\n440: \tstate := g.getCodeInterpreterState(ci)\n441: \tif state == SandboxStateUnknown || state == SandboxStateFailed {\n442: \t\tgracePeriodSeconds := int64(StaleGracePeriod.Seconds())\n443: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n444: \t\tklog.InfoS(\"Force deleting stale sandbox\", \"name\", name, \"namespace\", namespace)\n445: \t} else {\n446: \t\tgracePeriodSeconds := int64(DefaultGracePeriod.Seconds())\n447: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n448: \t}\n449: \n450: \terr = g.client.RuntimeV1alpha1().CodeInterpreters(namespace).Delete(ctx, name, deleteOpts)\n451: \tif err != nil {\n452: \t\tif apierrors.IsNotFound(err) {\n453: \t\t\tklog.V(4).InfoS(\"CodeInterpreter already deleted\", \"name\", name, \"namespace\", namespace)\n454: \t\t\treturn cleaned, nil\n455: \t\t}\n456: \t\treturn cleaned, fmt.Errorf(\"failed to delete codeinterpreter: %w\", err)\n457: \t}\n458: \n459: \tklog.InfoS(\"Deleted expired codeinterpreter\", \"name\", name, \"namespace\", namespace,\n460: \t\t\"cleanedResources\", len(cleaned))\n461: \n462: \treturn cleaned, nil\n463: }\n464: \n465: func (g *GCWorker) recordGCResult(result *GCResult, startTime time.Time) {\n466: \tg.statsMu.Lock()\n467: \tdefer g.statsMu.Unlock()\n468: \n469: \tg.stats.TotalCycles++\n470: \tg.stats.TotalDeleted += int64(result.DeletedCount)\n471: \tg.stats.TotalFailed += int64(result.FailedCount)\n472: \tg.stats.LastRunTime = startTime\n473: \tg.stats.LastResult = result\n474: }\n475: \n476: func (g *GCWorker) TriggerGCCycle(ctx context.Context) *GCResult {\n477: \tresult := &GCResult{}\n478: \n479: \tklog.InfoS(\"Manually triggering GC cycle\")\n480: \n481: \tnamespaces, err := g.getNamespaces(ctx)\n482: \tif err != nil {\n483: \t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"failed to get namespaces: %v\", err))\n484: \t\treturn result\n485: \t}\n486: \n487: \tresult.ScannedCount = len(namespaces)\n488: \tstartTime := time.Now()\n489: \n490: \tfor _, ns := range namespaces {\n491: \t\tif err := g.processNamespace(ctx, ns, result); err != nil {\n492: \t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"%s: %v\", ns, err))\n493: \t\t}\n494: \t}\n495: \n496: \tresult.Duration = time.Since(startTime)\n497: \tg.recordGCResult(result, startTime)\n498: \n499: \tklog.InfoS(\"Manual GC cycle completed\",\n500: \t\t\"scanned\", result.ScannedCount,\n501: \t\t\"expired\", result.ExpiredCount,\n502: \t\t\"deleted\", result.DeletedCount,\n503: \t\t\"failed\", result.FailedCount)\n504: \n505: \treturn result\n506: }\n507: \n508: func (g *GCWorker) UpdateConfig(config *GCConfig) {\n509: \tif config == nil {\n510: \t\treturn\n511: \t}\n512: \n513: \tg.config.GCEnabled = config.GCEnabled\n514: \tif config.GCInterval > 0 {\n515: \t\tg.config.GCInterval = config.GCInterval\n516: \t}\n517: \tif config.GCBatchSize > 0 {\n518: \t\tg.config.GCBatchSize = config.GCBatchSize\n519: \t}\n520: \n521: \tklog.InfoS(\"GC config updated\", \"gcEnabled\", g.config.GCEnabled,\n522: \t\t\"gcInterval\", g.config.GCInterval, \"gcBatchSize\", g.config.GCBatchSize)\n523: }\n524: \n525: type GCHandler struct {\n526: \tworker *GCWorker\n527: }\n528: \n529: func NewGCHandler(worker *GCWorker) *GCHandler {\n530: \treturn &GCHandler{\n531: \t\tworker: worker,\n532: \t}\n533: }\n534: \n535: func (h *GCHandler) TriggerGC() map[string]interface{} {\n536: \tresult := h.worker.TriggerGCCycle(context.Background())\n537: \treturn map[string]interface{}{\n538: \t\t\"started\":      true,\n539: \t\t\"scannedCount\": result.ScannedCount,\n540: \t\t\"expiredCount\": result.ExpiredCount,\n541: \t\t\"deletedCount\": result.DeletedCount,\n542: \t\t\"failedCount\":  result.FailedCount,\n543: \t\t\"duration\":     result.Duration.String(),\n544: \t\t\"message\":      \"GC cycle triggered\",\n545: \t}\n546: }\n547: \n548: func (h *GCHandler) GetStatus() map[string]interface{} {\n549: \tstats := h.worker.GetStats()\n550: \tconfig := h.worker.GetConfig()\n551: \n552: \treturn map[string]interface{}{\n553: \t\t\"running\":      h.worker.IsRunning(),\n554: \t\t\"gcEnabled\":    config.GCEnabled,\n555: \t\t\"gcInterval\":   config.GCInterval.String(),\n556: \t\t\"gcBatchSize\":  config.GCBatchSize,\n557: \t\t\"totalCycles\":  stats.TotalCycles,\n558: \t\t\"totalDeleted\": stats.TotalDeleted,\n559: \t\t\"totalFailed\":  stats.TotalFailed,\n560: \t\t\"lastRunTime\":  stats.LastRunTime.Format(time.RFC3339),\n561: \t}\n562: }\n563: \n564: func (h *GCHandler) UpdateConfig(config *GCConfig) map[string]interface{} {\n565: \th.worker.UpdateConfig(config)\n566: \treturn map[string]interface{}{\n567: \t\t\"message\": \"GC configuration updated\",\n568: \t}\n569: }\n570: \n571: func ListExpiredSandboxes(ctx context.Context, client versioned.Interface, namespace string) ([]*Sandbox, error) {\n572: \texpired := make([]*Sandbox, 0)\n573: \n574: \tarList, err := client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{\n575: \t\tLabelSelector: labels.Everything().String(),\n576: \t})\n577: \tif err != nil {\n578: \t\treturn nil, fmt.Errorf(\"failed to list agentruntimes: %w\", err)\n579: \t}\n580: \n581: \tfor i := range arList.Items {\n582: \t\tar := &arList.Items[i]\n583: \t\tsandbox := &Sandbox{\n584: \t\t\tName:           ar.Name,\n585: \t\t\tNamespace:      ar.Namespace,\n586: \t\t\tSessionID:      ar.Labels[\"sessionId\"],\n587: \t\t\tState:          getAgentRuntimeState(ar),\n588: \t\t\tCreatedAt:      ar.CreationTimestamp.Time,\n589: \t\t\tLastActivityAt: getLastActivityTimeFromAnnotations(ar.Annotations),\n590: \t\t\tLabels:         ar.Labels,\n591: \t\t\tAnnotations:    ar.Annotations,\n592: \t\t}\n593: \t\tif isExpired(sandbox) {\n594: \t\t\texpired = append(expired, sandbox)\n595: \t\t}\n596: \t}\n597: \n598: \tciList, err := client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{\n599: \t\tLabelSelector: labels.Everything().String(),\n600: \t})\n601: \tif err != nil {\n602: \t\treturn nil, fmt.Errorf(\"failed to list codeinterpreters: %w\", err)\n603: \t}\n604: \n605: \tfor i := range ciList.Items {\n606: \t\tci := &ciList.Items[i]\n607: \t\tsandbox := &Sandbox{\n608: \t\t\tName:           ci.Name,\n609: \t\t\tNamespace:      ci.Namespace,\n610: \t\t\tSessionID:      ci.Labels[\"sessionId\"],\n611: \t\t\tState:          getCodeInterpreterState(ci),\n612: \t\t\tCreatedAt:      ci.CreationTimestamp.Time,\n613: \t\t\tLastActivityAt: getLastActivityTimeFromAnnotations(ci.Annotations),\n614: \t\t\tLabels:         ci.Labels,\n615: \t\t\tAnnotations:    ci.Annotations,\n616: \t\t}\n617: \t\tif isExpired(sandbox) {\n618: \t\t\texpired = append(expired, sandbox)\n619: \t\t}\n620: \t}\n621: \n622: \treturn expired, nil\n623: }\n624: \n625: func getAgentRuntimeState(ar *agentcubev1alpha1.AgentRuntime) SandboxState {\n626: \tstate := SandboxStateUnknown\n627: \tif len(ar.Status.Conditions) > 0 {\n628: \t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n629: \t\tif lastCondition.Status == \"True\" {\n630: \t\t\tif lastCondition.Reason == \"Running\" {\n631: \t\t\t\tstate = SandboxStateRunning\n632: \t\t\t} else if lastCondition.Reason == \"Failed\" {\n633: \t\t\t\tstate = SandboxStateFailed\n634: \t\t\t}\n635: \t\t}\n636: \t}\n637: \tif ar.DeletionTimestamp != nil {\n638: \t\tstate = SandboxStateDeleting\n639: \t}\n640: \treturn state\n641: }\n642: \n643: func getCodeInterpreterState(ci *agentcubev1alpha1.CodeInterpreter) SandboxState {\n644: \tstate := SandboxStateUnknown\n645: \tif ci.Status.Ready {\n646: \t\tstate = SandboxStateRunning\n647: \t}\n648: \tif len(ci.Status.Conditions) > 0 {\n649: \t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n650: \t\tif lastCondition.Status == \"True\" {\n651: \t\t\tif lastCondition.Reason == \"Failed\" {\n652: \t\t\t\tstate = SandboxStateFailed\n653: \t\t\t}\n654: \t\t}\n655: \t}\n656: \tif ci.DeletionTimestamp != nil {\n657: \t\tstate = SandboxStateDeleting\n658: \t}\n659: \treturn state\n660: }\n661: \n662: func getLastActivityTimeFromAnnotations(annotations map[string]string) *time.Time {\n663: \tif annotations == nil {\n664: \t\treturn nil\n665: \t}\n666: \n667: \tlastActivityStr := annotations[\"last-activity-time\"]\n668: \tif lastActivityStr == \"\" {\n669: \t\treturn nil\n670: \t}\n671: \n672: \tt, err := time.Parse(time.RFC3339, lastActivityStr)\n673: \tif err != nil {\n674: \t\treturn nil\n675: \t}\n676: \n677: \treturn &t\n678: }\n\n(End of file - total 678 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n)\n\nconst (\n\tDefaultGCInterval         = 5 * time.Minute","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc.go","time":{"start":1775880999914,"end":1775880999929}}}}
{"type":"tool_use","timestamp":1775880999933,"sessionID":"ses_2853ed3b7ffekZ0flphk6ou8DL","part":{"id":"prt_d7ac18b3c001C27bfwEktF7G6q","messageID":"msg_d7ac1739b0010U6fuX8CnrBt7Q","sessionID":"ses_2853ed3b7ffekZ0flphk6ou8DL","type":"tool","tool":"read","callID":"toolu_e17b9052ad294e68b5969395","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"time\"\n5: \n6: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n7: \t\"k8s.io/klog/v2\"\n8: )\n9: \n10: const (\n11: \tDefaultTTL          = 8 * time.Hour\n12: \tDefaultIdleTimeout  = 15 * time.Minute\n13: \tDefaultMaxLifetime  = 24 * time.Hour\n14: \tStaleStateThreshold = 1 * time.Hour\n15: )\n16: \n17: var (\n18: \tDefaultTTLSeconds         int64 = int64(DefaultTTL.Seconds())\n19: \tDefaultIdleTimeoutSeconds int64 = int64(DefaultIdleTimeout.Seconds())\n20: \tDefaultMaxLifetimeSeconds int64 = int64(DefaultMaxLifetime.Seconds())\n21: )\n22: \n23: type ExpirationConfig struct {\n24: \tTTL         time.Duration\n25: \tIdleTimeout time.Duration\n26: \tMaxLifetime time.Duration\n27: }\n28: \n29: func NewExpirationConfig() *ExpirationConfig {\n30: \treturn &ExpirationConfig{\n31: \t\tTTL:         DefaultTTL,\n32: \t\tIdleTimeout: DefaultIdleTimeout,\n33: \t\tMaxLifetime: DefaultMaxLifetime,\n34: \t}\n35: }\n36: \n37: func isExpiredByTTL(sandbox *Sandbox) bool {\n38: \tif sandbox.ExpiresAt == nil {\n39: \t\treturn false\n40: \t}\n41: \texpired := time.Now().After(*sandbox.ExpiresAt)\n42: \tif expired {\n43: \t\tklog.V(4).InfoS(\"Sandbox expired by TTL\", \"sandboxId\", sandbox.SessionID, \"expiresAt\", sandbox.ExpiresAt)\n44: \t}\n45: \treturn expired\n46: }\n47: \n48: func isExpiredByIdleTimeout(sandbox *Sandbox) bool {\n49: \tif sandbox.LastActivityAt == nil {\n50: \t\tif sandbox.CreatedAt.Add(DefaultIdleTimeout).Before(time.Now()) {\n51: \t\t\tklog.V(4).InfoS(\"Sandbox expired by idle timeout (no activity)\", \"sandboxId\", sandbox.SessionID)\n52: \t\t\treturn true\n53: \t\t}\n54: \t\treturn false\n55: \t}\n56: \texpired := time.Now().After(sandbox.LastActivityAt.Add(DefaultIdleTimeout))\n57: \tif expired {\n58: \t\tklog.V(4).InfoS(\"Sandbox expired by idle timeout\", \"sandboxId\", sandbox.SessionID, \"lastActivityAt\", sandbox.LastActivityAt)\n59: \t}\n60: \treturn expired\n61: }\n62: \n63: func isExpiredByMaxLifetime(sandbox *Sandbox) bool {\n64: \texpired := time.Now().After(sandbox.CreatedAt.Add(DefaultMaxLifetime))\n65: \tif expired {\n66: \t\tklog.V(4).InfoS(\"Sandbox expired by max lifetime\", \"sandboxId\", sandbox.SessionID, \"createdAt\", sandbox.CreatedAt)\n67: \t}\n68: \treturn expired\n69: }\n70: \n71: func isExpiredByStaleState(sandbox *Sandbox) bool {\n72: \tif sandbox.State == SandboxStateUnknown || sandbox.State == SandboxStateFailed {\n73: \t\tthreshold := time.Now().Add(-StaleStateThreshold)\n74: \t\tif sandbox.CreatedAt.Before(threshold) {\n75: \t\t\tklog.V(4).InfoS(\"Sandbox marked as stale\", \"sandboxId\", sandbox.SessionID, \"state\", sandbox.State, \"createdAt\", sandbox.CreatedAt)\n76: \t\t\treturn true\n77: \t\t}\n78: \t}\n79: \treturn false\n80: }\n81: \n82: func isExpired(sandbox *Sandbox) bool {\n83: \treturn isExpiredByTTL(sandbox) || isExpiredByIdleTimeout(sandbox) || isExpiredByMaxLifetime(sandbox) || isExpiredByStaleState(sandbox)\n84: }\n85: \n86: func shouldExpireByIdlePolicy(sandbox *Sandbox, idleTimeoutEnabled bool) bool {\n87: \tif !idleTimeoutEnabled {\n88: \t\treturn false\n89: \t}\n90: \treturn isExpiredByIdleTimeout(sandbox)\n91: }\n92: \n93: type ExpirationChecker struct {\n94: \tconfig *ExpirationConfig\n95: }\n96: \n97: func NewExpirationChecker(config *ExpirationConfig) *ExpirationChecker {\n98: \tif config == nil {\n99: \t\tconfig = NewExpirationConfig()\n100: \t}\n101: \treturn &ExpirationChecker{\n102: \t\tconfig: config,\n103: \t}\n104: }\n105: \n106: func (e *ExpirationChecker) IsExpired(sandbox *Sandbox) bool {\n107: \tif sandbox.ExpiresAt != nil && time.Now().After(*sandbox.ExpiresAt) {\n108: \t\treturn true\n109: \t}\n110: \n111: \tif time.Now().After(sandbox.CreatedAt.Add(e.config.TTL)) {\n112: \t\treturn true\n113: \t}\n114: \n115: \tif sandbox.LastActivityAt != nil && time.Now().After(sandbox.LastActivityAt.Add(e.config.IdleTimeout)) {\n116: \t\treturn true\n117: \t}\n118: \n119: \tif time.Now().After(sandbox.CreatedAt.Add(e.config.MaxLifetime)) {\n120: \t\treturn true\n121: \t}\n122: \n123: \treturn false\n124: }\n125: \n126: func (e *ExpirationChecker) GetExpirationTime(sandbox *Sandbox) *metav1.Time {\n127: \tvar earliest time.Time\n128: \n129: \tttlExpiry := sandbox.CreatedAt.Add(e.config.TTL)\n130: \tidleExpiry := sandbox.CreatedAt.Add(e.config.MaxLifetime)\n131: \tmaxLifetimeExpiry := sandbox.CreatedAt.Add(e.config.MaxLifetime)\n132: \n133: \tearliest = ttlExpiry\n134: \tif idleExpiry.Before(earliest) {\n135: \t\tearliest = idleExpiry\n136: \t}\n137: \tif maxLifetimeExpiry.Before(earliest) {\n138: \t\tearliest = maxLifetimeExpiry\n139: \t}\n140: \n141: \tif sandbox.LastActivityAt != nil {\n142: \t\tidleExpiryActivity := sandbox.LastActivityAt.Add(e.config.IdleTimeout)\n143: \t\tif idleExpiryActivity.Before(earliest) {\n144: \t\t\tearliest = idleExpiryActivity\n145: \t\t}\n146: \t}\n147: \n148: \tmetav1Time := metav1.NewTime(earliest)\n149: \treturn &metav1Time\n150: }\n151: \n152: func CalculateGracePeriod(gracePeriodSeconds *int64) time.Duration {\n153: \tif gracePeriodSeconds == nil {\n154: \t\treturn 30 * time.Second\n155: \t}\n156: \treturn time.Duration(*gracePeriodSeconds) * time.Second\n157: }\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (\n\tDefaultTTL          = 8 * time.Hour\n\tDefaultIdleTimeout  = 15 * time.Minute\n\tDefaultMaxLifetime  = 24 * time.Hour\n\tStaleStateThreshold = 1 * time.Hour\n)\n\nvar (\n\tDefaultTTLSeconds         int64 = int64(DefaultTTL.Seconds())\n\tDefaultIdleTimeoutSeconds int64 = int64(DefaultIdleTimeout.Seconds())\n\tDefaultMaxLifetimeSeconds int64 = int64(DefaultMaxLifetime.Seconds())","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration.go","time":{"start":1775880999918,"end":1775880999932}}}}
{"type":"tool_use","timestamp":1775880999936,"sessionID":"ses_2853ed3b7ffekZ0flphk6ou8DL","part":{"id":"prt_d7ac18fc8001zpVGVnehXJzh3t","messageID":"msg_d7ac1739b0010U6fuX8CnrBt7Q","sessionID":"ses_2853ed3b7ffekZ0flphk6ou8DL","type":"tool","tool":"read","callID":"toolu_b3ff9bd7e4054ba4ac43de55","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/graceful.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/graceful.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"os/exec\"\n7: \t\"sync\"\n8: \t\"time\"\n9: \n10: \tcorev1 \"k8s.io/api/core/v1\"\n11: \t\"k8s.io/apimachinery/pkg/api/errors\"\n12: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n13: \t\"k8s.io/client-go/kubernetes\"\n14: \t\"k8s.io/klog/v2\"\n15: )\n16: \n17: type connectionState struct {\n18: \tactiveConnections int\n19: \tmu                sync.RWMutex\n20: \tdraining          bool\n21: }\n22: \n23: type GracefulManager struct {\n24: \tk8sClient   *kubernetes.Clientset\n25: \tconnections map[string]*connectionState\n26: \tmu          sync.RWMutex\n27: \tgracePeriod time.Duration\n28: }\n29: \n30: func NewGracefulManager(k8sClient *kubernetes.Clientset, gracePeriod time.Duration) *GracefulManager {\n31: \treturn &GracefulManager{\n32: \t\tk8sClient:   k8sClient,\n33: \t\tconnections: make(map[string]*connectionState),\n34: \t\tgracePeriod: gracePeriod,\n35: \t}\n36: }\n37: \n38: func (g *GracefulManager) drainConnections(sandboxID string) {\n39: \tg.mu.Lock()\n40: \tdefer g.mu.Unlock()\n41: \n42: \tstate, exists := g.connections[sandboxID]\n43: \tif !exists {\n44: \t\tstate = &connectionState{}\n45: \t\tg.connections[sandboxID] = state\n46: \t}\n47: \tstate.draining = true\n48: \tklog.InfoS(\"Started draining connections\", \"sandboxId\", sandboxID)\n49: }\n50: \n51: func (g *GracefulManager) waitForConnections(sandboxID string, timeout time.Duration) error {\n52: \tg.mu.RLock()\n53: \tstate, exists := g.connections[sandboxID]\n54: \tg.mu.RUnlock()\n55: \n56: \tif !exists || state.activeConnections == 0 {\n57: \t\tklog.V(4).InfoS(\"No active connections to wait for\", \"sandboxId\", sandboxID)\n58: \t\treturn nil\n59: \t}\n60: \n61: \tctx, cancel := context.WithTimeout(context.Background(), timeout)\n62: \tdefer cancel()\n63: \n64: \tticker := time.NewTicker(100 * time.Millisecond)\n65: \tdefer ticker.Stop()\n66: \n67: \tfor {\n68: \t\tselect {\n69: \t\tcase <-ctx.Done():\n70: \t\t\treturn fmt.Errorf(\"timeout waiting for connections to drain\")\n71: \t\tcase <-ticker.C:\n72: \t\t\tg.mu.RLock()\n73: \t\t\tcurrentState := state\n74: \t\t\tg.mu.RUnlock()\n75: \n76: \t\t\tif currentState.activeConnections == 0 {\n77: \t\t\t\treturn nil\n78: \t\t\t}\n79: \t\t}\n80: \t}\n81: }\n82: \n83: func (g *GracefulManager) executePreDeleteHook(sandbox *Sandbox, hookConfig *WebhookConfig) error {\n84: \tif hookConfig == nil || hookConfig.URL == \"\" {\n85: \t\treturn nil\n86: \t}\n87: \n88: \tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n89: \tdefer cancel()\n90: \n91: \ttimeout := time.Duration(hookConfig.Timeout) * time.Second\n92: \tif timeout == 0 {\n93: \t\ttimeout = 30 * time.Second\n94: \t}\n95: \n96: \thookCtx, hookCancel := context.WithTimeout(ctx, timeout)\n97: \tdefer hookCancel()\n98: \n99: \tklog.InfoS(\"Executing pre-delete hook\", \"sandboxId\", sandbox.SessionID, \"url\", hookConfig.URL)\n100: \n101: \tselect {\n102: \tcase <-hookCtx.Done():\n103: \t\tklog.V(2).InfoS(\"Pre-delete hook context cancelled\", \"sandboxId\", sandbox.SessionID)\n104: \t\treturn nil\n105: \tdefault:\n106: \t\treturn nil\n107: \t}\n108: }\n109: \n110: func (g *GracefulManager) sendSIGTERM(podName, namespace string) error {\n111: \tpod, err := g.k8sClient.CoreV1().Pods(namespace).Get(context.Background(), podName, metav1.GetOptions{})\n112: \tif err != nil {\n113: \t\tif errors.IsNotFound(err) {\n114: \t\t\tklog.V(4).InfoS(\"Pod not found, skipping SIGTERM\", \"pod\", podName, \"namespace\", namespace)\n115: \t\t\treturn nil\n116: \t\t}\n117: \t\treturn fmt.Errorf(\"failed to get pod: %w\", err)\n118: \t}\n119: \n120: \tif pod.Spec.TerminationGracePeriodSeconds != nil && *pod.Spec.TerminationGracePeriodSeconds == 0 {\n121: \t\tklog.V(4).InfoS(\"Pod has gracePeriodSeconds=0, skipping SIGTERM\", \"pod\", podName)\n122: \t\treturn nil\n123: \t}\n124: \n125: \tcmd := exec.Command(\"kubectl\", \"exec\", \"-n\", namespace, podName, \"--\", \"kill\", \"-TERM\", \"1\")\n126: \toutput, err := cmd.CombinedOutput()\n127: \tif err != nil {\n128: \t\tklog.V(4).InfoS(\"Failed to send SIGTERM via exec\", \"pod\", podName, \"error\", err)\n129: \t\treturn nil\n130: \t}\n131: \n132: \tklog.InfoS(\"Sent SIGTERM to pod\", \"pod\", podName, \"output\", string(output))\n133: \treturn nil\n134: }\n135: \n136: func (g *GracefulManager) executeGracefulDelete(ctx context.Context, sandbox *Sandbox, opts DeleteOptions, hookConfig *WebhookConfig) error {\n137: \tpods, err := g.k8sClient.CoreV1().Pods(sandbox.Namespace).List(ctx, metav1.ListOptions{\n138: \t\tLabelSelector: fmt.Sprintf(\"sessionId=%s\", sandbox.SessionID),\n139: \t})\n140: \tif err != nil {\n141: \t\treturn fmt.Errorf(\"failed to list pods: %w\", err)\n142: \t}\n143: \n144: \tif len(pods.Items) > 0 {\n145: \t\tg.drainConnections(sandbox.SessionID)\n146: \n147: \t\tfor _, pod := range pods.Items {\n148: \t\t\tif err := g.sendSIGTERM(pod.Name, pod.Namespace); err != nil {\n149: \t\t\t\tklog.V(4).InfoS(\"Error sending SIGTERM\", \"pod\", pod.Name, \"error\", err)\n150: \t\t\t}\n151: \t\t}\n152: \t}\n153: \n154: \tgracePeriod := g.gracePeriod\n155: \tif opts.GracePeriodSeconds != nil {\n156: \t\tgracePeriod = time.Duration(*opts.GracePeriodSeconds) * time.Second\n157: \t}\n158: \n159: \tif err := g.waitForConnections(sandbox.SessionID, gracePeriod); err != nil {\n160: \t\tklog.V(2).InfoS(\"Timeout waiting for connections to drain\", \"sandboxId\", sandbox.SessionID, \"error\", err)\n161: \t}\n162: \n163: \treturn nil\n164: }\n165: \n166: func (g *GracefulManager) StopRouting(sandboxID string) {\n167: \tg.drainConnections(sandboxID)\n168: }\n169: \n170: func (g *GracefulManager) RegisterConnection(sandboxID string) {\n171: \tg.mu.Lock()\n172: \tdefer g.mu.Unlock()\n173: \n174: \tstate, exists := g.connections[sandboxID]\n175: \tif !exists {\n176: \t\tstate = &connectionState{}\n177: \t\tg.connections[sandboxID] = state\n178: \t}\n179: \tstate.mu.Lock()\n180: \tstate.activeConnections++\n181: \tstate.mu.Unlock()\n182: }\n183: \n184: func (g *GracefulManager) UnregisterConnection(sandboxID string) {\n185: \tg.mu.Lock()\n186: \tdefer g.mu.Unlock()\n187: \n188: \tstate, exists := g.connections[sandboxID]\n189: \tif !exists {\n190: \t\treturn\n191: \t}\n192: \tstate.mu.Lock()\n193: \tstate.activeConnections--\n194: \tstate.mu.Unlock()\n195: }\n196: \n197: func (g *GracefulManager) IsDraining(sandboxID string) bool {\n198: \tg.mu.RLock()\n199: \tdefer g.mu.RUnlock()\n200: \n201: \tstate, exists := g.connections[sandboxID]\n202: \tif !exists {\n203: \t\treturn false\n204: \t}\n205: \treturn state.draining\n206: }\n207: \n208: func (g *GracefulManager) GetActiveConnections(sandboxID string) int {\n209: \tg.mu.RLock()\n210: \tdefer g.mu.RUnlock()\n211: \n212: \tstate, exists := g.connections[sandboxID]\n213: \tif !exists {\n214: \t\treturn 0\n215: \t}\n216: \tstate.mu.RLock()\n217: \tdefer state.mu.RUnlock()\n218: \treturn state.activeConnections\n219: }\n220: \n221: func (g *GracefulManager) Cleanup(sandboxID string) {\n222: \tg.mu.Lock()\n223: \tdefer g.mu.Unlock()\n224: \tdelete(g.connections, sandboxID)\n225: }\n226: \n227: func waitForPodDeletion(ctx context.Context, k8sClient *kubernetes.Clientset, podName, namespace string, timeout time.Duration) error {\n228: \tticker := time.NewTicker(500 * time.Millisecond)\n229: \tdefer ticker.Stop()\n230: \n231: \ttimeoutCh := time.After(timeout)\n232: \n233: \tfor {\n234: \t\tselect {\n235: \t\tcase <-ctx.Done():\n236: \t\t\treturn ctx.Err()\n237: \t\tcase <-timeoutCh:\n238: \t\t\treturn fmt.Errorf(\"timeout waiting for pod deletion\")\n239: \t\tcase <-ticker.C:\n240: \t\t\t_, err := k8sClient.CoreV1().Pods(namespace).Get(ctx, podName, metav1.GetOptions{})\n241: \t\t\tif errors.IsNotFound(err) {\n242: \t\t\t\treturn nil\n243: \t\t\t}\n244: \t\t\tif err != nil {\n245: \t\t\t\treturn fmt.Errorf(\"error checking pod status: %w\", err)\n246: \t\t\t}\n247: \t\t}\n248: \t}\n249: }\n250: \n251: func deletePodWithGracePeriod(ctx context.Context, k8sClient *kubernetes.Clientset, podName, namespace string, gracePeriodSeconds *int64) error {\n252: \tgracePeriod := int64(30)\n253: \tif gracePeriodSeconds != nil {\n254: \t\tgracePeriod = *gracePeriodSeconds\n255: \t}\n256: \n257: \tzeroGracePeriod := int64(0)\n258: \tif gracePeriod == 0 {\n259: \t\terr := k8sClient.CoreV1().Pods(namespace).Delete(ctx, podName, metav1.DeleteOptions{\n260: \t\t\tGracePeriodSeconds: &zeroGracePeriod,\n261: \t\t})\n262: \t\tif err != nil && !errors.IsNotFound(err) {\n263: \t\t\treturn err\n264: \t\t}\n265: \t\treturn waitForPodDeletion(ctx, k8sClient, podName, namespace, 10*time.Second)\n266: \t}\n267: \n268: \terr := k8sClient.CoreV1().Pods(namespace).Delete(ctx, podName, metav1.DeleteOptions{\n269: \t\tGracePeriodSeconds: &gracePeriod,\n270: \t})\n271: \tif err != nil && !errors.IsNotFound(err) {\n272: \t\treturn err\n273: \t}\n274: \treturn waitForPodDeletion(ctx, k8sClient, podName, namespace, time.Duration(gracePeriod+5)*time.Second)\n275: }\n276: \n277: func terminatePod(ctx context.Context, k8sClient *kubernetes.Clientset, pod corev1.Pod) error {\n278: \tif pod.Spec.TerminationGracePeriodSeconds != nil && *pod.Spec.TerminationGracePeriodSeconds == 0 {\n279: \t\treturn nil\n280: \t}\n281: \n282: \treturn deletePodWithGracePeriod(ctx, k8sClient, pod.Name, pod.Namespace, pod.Spec.TerminationGracePeriodSeconds)\n283: }\n\n(End of file - total 283 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os/exec\"\n\t\"sync\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype connectionState struct {\n\tactiveConnections int\n\tmu                sync.RWMutex\n\tdraining          bool","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/graceful.go","time":{"start":1775880999920,"end":1775880999934}}}}
