 \"disabled GC\",\n50: \t\t\tgcEnabled:   false,\n51: \t\t\tgcInterval:  5 * time.Minute,\n52: \t\t\tgcBatchSize: 50,\n53: \t\t\texpectedErr: false,\n54: \t\t},\n55: \t\t{\n56: \t\t\tname:        \"custom interval\",\n57: \t\t\tgcEnabled:   true,\n58: \t\t\tgcInterval:  10 * time.Minute,\n59: \t\t\tgcBatchSize: 100,\n60: \t\t\texpectedErr: false,\n61: \t\t},\n62: \t\t{\n63: \t\t\tname:        \"custom batch size\",\n64: \t\t\tgcEnabled:   true,\n65: \t\t\tgcInterval:  5 * time.Minute,\n66: \t\t\tgcBatchSize: 200,\n67: \t\t\texpectedErr: false,\n68: \t\t},\n69: \t}\n70: \n71: \tfor _, tt := range tests {\n72: \t\tt.Run(tt.name, func(t *testing.T) {\n73: \t\t\tconfig := &GCConfig{\n74: \t\t\t\tGCEnabled:   tt.gcEnabled,\n75: \t\t\t\tGCInterval:  tt.gcInterval,\n76: \t\t\t\tGCBatchSize: tt.gcBatchSize,\n77: \t\t\t}\n78: \n79: \t\t\tif config.GCEnabled != tt.gcEnabled {\n80: \t\t\t\tt.Errorf(\"Expected GCEnabled to be %v, got %v\", tt.gcEnabled, config.GCEnabled)\n81: \t\t\t}\n82: \n83: \t\t\tif config.GCInterval != tt.gcInterval {\n84: \t\t\t\tt.Errorf(\"Expected GCInterval to be %v, got %v\", tt.gcInterval, config.GCInterval)\n85: \t\t\t}\n86: \n87: \t\t\tif config.GCBatchSize != tt.gcBatchSize {\n88: \t\t\t\tt.Errorf(\"Expected GCBatchSize to be %d, got %d\", tt.gcBatchSize, config.GCBatchSize)\n89: \t\t\t}\n90: \t\t})\n91: \t}\n92: }\n93: \n94: func TestGCWorkerNewGCWorker(t *testing.T) {\n95: \tworker := NewGCWorker(nil, nil, nil)\n96: \n97: \tif worker == nil {\n98: \t\tt.Error(\"Expected non-nil GCWorker\")\n99: \t}\n100: \n101: \tif worker.config == nil {\n102: \t\tt.Error(\"Expected non-nil config\")\n103: \t}\n104: \n105: \tif worker.cleanupMgr == nil {\n106: \t\tt.Error(\"Expected non-nil cleanupMgr\")\n107: \t}\n108: \n109: \tif worker.expirationChecker == nil {\n110: \t\tt.Error(\"Expected non-nil expirationChecker\")\n111: \t}\n112: \n113: \tif worker.stopCh == nil {\n114: \t\tt.Error(\"Expected non-nil stopCh\")\n115: \t}\n116: }\n117: \n118: func TestGCWorkerWithCustomConfig(t *testing.T) {\n119: \tconfig := &GCConfig{\n120: \t\tGCEnabled:   false,\n121: \t\tGCInterval:  10 * time.Minute,\n122: \t\tGCBatchSize: 100,\n123: \t}\n124: \n125: \tworker := NewGCWorker(nil, nil, config)\n126: \n127: \tif worker.config.GCEnabled != false {\n128: \t\tt.Error(\"Expected GCEnabled to be false\")\n129: \t}\n130: \n131: \tif worker.config.GCInterval != 10*time.Minute {\n132: \t\tt.Errorf(\"Expected GCInterval to be 10m, got %v\", worker.config.GCInterval)\n133: \t}\n134: \n135: \tif worker.config.GCBatchSize != 100 {\n136: \t\tt.Errorf(\"Expected GCBatchSize to be 100, got %d\", worker.config.GCBatchSize)\n137: \t}\n138: }\n139: \n140: func TestGCWorkerIsRunning(t *testing.T) {\n141: \tworker := NewGCWorker(nil, nil, nil)\n142: \n143: \tif worker.IsRunning() {\n144: \t\tt.Error(\"Expected GCWorker to not be running initially\")\n145: \t}\n146: \n147: \tworker.setRunning(true)\n148: \n149: \tif !worker.IsRunning() {\n150: \t\tt.Error(\"Expected GCWorker to be running after setRunning(true)\")\n151: \t}\n152: \n153: \tworker.setRunning(false)\n154: \n155: \tif worker.IsRunning() {\n156: \t\tt.Error(\"Expected GCWorker to not be running after setRunning(false)\")\n157: \t}\n158: }\n159: \n160: func TestGCWorkerGetConfig(t *testing.T) {\n161: \tconfig := &GCConfig{\n162: \t\tGCEnabled:   true,\n163: \t\tGCInterval:  15 * time.Minute,\n164: \t\tGCBatchSize: 75,\n165: \t}\n166: \n167: \tworker := NewGCWorker(nil, nil, config)\n168: \n169: \treturnedConfig := worker.GetConfig()\n170: \n171: \tif returnedConfig.GCEnabled != config.GCEnabled {\n172: \t\tt.Errorf(\"Expected GCEnabled to be %v, got %v\", config.GCEnabled, returnedConfig.GCEnabled)\n173: \t}\n174: \n175: \tif returnedConfig.GCInterval != config.GCInterval {\n176: \t\tt.Errorf(\"Expected GCInterval to be %v, got %v\", config.GCInterval, returnedConfig.GCInterval)\n177: \t}\n178: \n179: \tif returnedConfig.GCBatchSize != config.GCBatchSize {\n180: \t\tt.Errorf(\"Expected GCBatchSize to be %d, got %d\", config.GCBatchSize, returnedConfig.GCBatchSize)\n181: \t}\n182: }\n183: \n184: func TestGCWorkerGetStats(t *testing.T) {\n185: \tworker := NewGCWorker(nil, nil, nil)\n186: \n187: \tstats := worker.GetStats()\n188: \n189: \tif stats.TotalCycles != 0 {\n190: \t\tt.Errorf(\"Expected TotalCycles to be 0, got %d\", stats.TotalCycles)\n191: \t}\n192: \n193: \tif stats.TotalDeleted != 0 {\n194: \t\tt.Errorf(\"Expected TotalDeleted to be 0, got %d\", stats.TotalDeleted)\n195: \t}\n196: \n197: \tif stats.TotalFailed != 0 {\n198: \t\tt.Errorf(\"Expected TotalFailed to be 0, got %d\", stats.TotalFailed)\n199: \t}\n200: }\n201: \n202: func TestGCWorkerRecordGCResult(t *testing.T) {\n203: \tworker := NewGCWorker(nil, nil, nil)\n204: \n205: \tresult := &GCResult{\n206: \t\tScannedCount: 10,\n207: \t\tExpiredCount: 5,\n208: \t\tDeletedCount: 4,\n209: \t\tFailedCount:  1,\n210: \t\tDuration:     100 * time.Millisecond,\n211: \t}\n212: \n213: \tstartTime := time.Now()\n214: \tworker.recordGCResult(result, startTime)\n215: \n216: \tstats := worker.GetStats()\n217: \n218: \tif stats.TotalCycles != 1 {\n219: \t\tt.Errorf(\"Expected TotalCycles to be 1, got %d\", stats.TotalCycles)\n220: \t}\n221: \n222: \tif stats.TotalDeleted != 4 {\n223: \t\tt.Errorf(\"Expected TotalDeleted to be 4, got %d\", stats.TotalDeleted)\n224: \t}\n225: \n226: \tif stats.TotalFailed != 1 {\n227: \t\tt.Errorf(\"Expected TotalFailed to be 1, got %d\", stats.TotalFailed)\n228: \t}\n229: \n230: \tif stats.LastRunTime.IsZero() {\n231: \t\tt.Error(\"Expected LastRunTime to be set\")\n232: \t}\n233: \n234: \tif stats.LastResult == nil {\n235: \t\tt.Error(\"Expected LastResult to be set\")\n236: \t}\n237: \n238: \tif stats.LastResult.DeletedCount != 4 {\n239: \t\tt.Errorf(\"Expected LastResult.DeletedCount to be 4, got %d\", stats.LastResult.DeletedCount)\n240: \t}\n241: }\n242: \n243: func TestGCWorkerUpdateConfig(t *testing.T) {\n244: \tworker := NewGCWorker(nil, nil, nil)\n245: \n246: \tnewConfig := &GCConfig{\n247: \t\tGCEnabled:   false,\n248: \t\tGCInterval:  20 * time.Minute,\n249: \t\tGCBatchSize: 150,\n250: \t}\n251: \n252: \tworker.UpdateConfig(newConfig)\n253: \n254: \tif worker.config.GCEnabled != false {\n255: \t\tt.Error(\"Expected GCEnabled to be false after update\")\n256: \t}\n257: \n258: \tif worker.config.GCInterval != 20*time.Minute {\n259: \t\tt.Errorf(\"Expected GCInterval to be 20m, got %v\", worker.config.GCInterval)\n260: \t}\n261: \n262: \tworker.UpdateConfig(&GCConfig{\n263: \t\tGCEnabled:   false,\n264: \t\tGCInterval:  20 * time.Minute,\n265: \t\tGCBatchSize: 150,\n266: \t})\n267: \n268: \tif worker.config.GCEnabled != false {\n269: \t\tt.Error(\"Expected GCEnabled to be false after update\")\n270: \t}\n271: \n272: \tworker.UpdateConfig(nil)\n273: \n274: \tif worker.config.GCInterval != 20*time.Minute {\n275: \t\tt.Errorf(\"Expected GCInterval to remain 20m after nil update, got %v\", worker.config.GCInterval)\n276: \t}\n277: }\n278: \n279: func TestGCWorkerTriggerGCCycle(t *testing.T) {\n280: \tt.Skip(\"Skipping test - requires mock clients\")\n281: }\n282: \n283: func TestIsAgentRuntimeExpired(t *testing.T) {\n284: \tworker := NewGCWorker(nil, nil, nil)\n285: \n286: \ttests := []struct {\n287: \t\tname        string\n288: \t\tar          *agentcubev1alpha1.AgentRuntime\n289: \t\texpectedExp bool\n290: \t}{\n291: \t\t{\n292: \t\t\tname: \"not expired - recently created\",\n293: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n294: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n295: \t\t\t\t\tName:              \"test-ar\",\n296: \t\t\t\t\tNamespace:         \"default\",\n297: \t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n298: \t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n299: \t\t\t\t},\n300: \t\t\t},\n301: \t\t\texpectedExp: false,\n302: \t\t},\n303: \t\t{\n304: \t\t\tname: \"expired by TTL\",\n305: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n306: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n307: \t\t\t\t\tName:              \"test-ar\",\n308: \t\t\t\t\tNamespace:         \"default\",\n309: \t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-10 * time.Hour)},\n310: \t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n311: \t\t\t\t\tAnnotations:       map[string]string{\"expires-at\": time.Now().Add(-1 * time.Hour).Format(time.RFC3339)},\n312: \t\t\t\t},\n313: \t\t\t},\n314: \t\t\texpectedExp: true,\n315: \t\t},\n316: \t\t{\n317: \t\t\tname: \"marked for deletion\",\n318: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n319: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n320: \t\t\t\t\tName:              \"test-ar\",\n321: \t\t\t\t\tNamespace:         \"default\",\n322: \t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n323: \t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n324: \t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n325: \t\t\t\t},\n326: \t\t\t},\n327: \t\t\texpectedExp: true,\n328: \t\t},\n329: \t\t{\n330: \t\t\tname: \"stale state - Unknown with old creation\",\n331: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n332: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n333: \t\t\t\t\tName:              \"test-ar\",\n334: \t\t\t\t\tNamespace:         \"default\",\n335: \t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-2 * time.Hour)},\n336: \t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n337: \t\t\t\t},\n338: \t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n339: \t\t\t\t\tConditions: []metav1.Condition{\n340: \t\t\t\t\t\t{\n341: \t\t\t\t\t\t\tType:   \"Ready\",\n342: \t\t\t\t\t\t\tStatus: \"False\",\n343: \t\t\t\t\t\t\tReason: \"Unknown\",\n344: \t\t\t\t\t\t},\n345: \t\t\t\t\t},\n346: \t\t\t\t},\n347: \t\t\t},\n348: \t\t\texpectedExp: true,\n349: \t\t},\n350: \t\t{\n351: \t\t\tname: \"stale state - Failed with old creation\",\n352: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n353: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n354: \t\t\t\t\tName:              \"test-ar\",\n355: \t\t\t\t\tNamespace:         \"default\",\n356: \t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-2 * time.Hour)},\n357: \t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n358: \t\t\t\t},\n359: \t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n360: \t\t\t\t\tConditions: []metav1.Condition{\n361: \t\t\t\t\t\t{\n362: \t\t\t\t\t\t\tType:   \"Ready\",\n363: \t\t\t\t\t\t\tStatus: \"False\",\n364: \t\t\t\t\t\t\tReason: \"Failed\",\n365: \t\t\t\t\t\t},\n366: \t\t\t\t\t},\n367: \t\t\t\t},\n368: \t\t\t},\n369: \t\t\texpectedExp: true,\n370: \t\t},\n371: \t}\n372: \n373: \tfor _, tt := range tests {\n374: \t\tt.Run(tt.name, func(t *testing.T) {\n375: \t\t\texpired := worker.isAgentRuntimeExpired(tt.ar)\n376: \t\t\tif expired != tt.expectedExp {\n377: \t\t\t\tt.Errorf(\"Expected expired=%v, got %v\", tt.expectedExp, expired)\n378: \t\t\t}\n379: \t\t})\n380: \t}\n381: }\n382: \n383: func TestIsCodeInterpreterExpired(t *testing.T) {\n384: \tworker := NewGCWorker(nil, nil, nil)\n385: \n386: \ttests := []struct {\n387: \t\tname        string\n388: \t\tci          *agentcubev1alpha1.CodeInterpreter\n389: \t\texpectedExp bool\n390: \t}{\n391: \t\t{\n392: \t\t\tname: \"not expired - recently created\",\n393: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n394: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n395: \t\t\t\t\tName:              \"test-ci\",\n396: \t\t\t\t\tNamespace:         \"default\",\n397: \t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n398: \t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n399: \t\t\t\t},\n400: \t\t\t},\n401: \t\t\texpectedExp: false,\n402: \t\t},\n403: \t\t{\n404: \t\t\tname: \"expired by TTL\",\n405: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n406: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n407: \t\t\t\t\tName:              \"test-ci\",\n408: \t\t\t\t\tNamespace:         \"default\",\n409: \t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-10 * time.Hour)},\n410: \t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n411: \t\t\t\t\tAnnotations:       map[string]string{\"expires-at\": time.Now().Add(-1 * time.Hour).Format(time.RFC3339)},\n412: \t\t\t\t},\n413: \t\t\t},\n414: \t\t\texpectedExp: true,\n415: \t\t},\n416: \t\t{\n417: \t\t\tname: \"marked for deletion\",\n418: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n419: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n420: \t\t\t\t\tName:              \"test-ci\",\n421: \t\t\t\t\tNamespace:         \"default\",\n422: \t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now()},\n423: \t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n424: \t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n425: \t\t\t\t},\n426: \t\t\t},\n427: \t\t\texpectedExp: true,\n428: \t\t},\n429: \t\t{\n430: \t\t\tname: \"stale state - Failed with old creation\",\n431: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n432: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n433: \t\t\t\t\tName:              \"test-ci\",\n434: \t\t\t\t\tNamespace:         \"default\",\n435: \t\t\t\t\tCreationTimestamp: metav1.Time{Time: time.Now().Add(-2 * time.Hour)},\n436: \t\t\t\t\tLabels:            map[string]string{\"sessionId\": \"test-session\"},\n437: \t\t\t\t},\n438: \t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n439: \t\t\t\t\tReady: false,\n440: \t\t\t\t\tConditions: []metav1.Condition{\n441: \t\t\t\t\t\t{\n442: \t\t\t\t\t\t\tType:   \"Ready\",\n443: \t\t\t\t\t\t\tStatus: \"False\",\n444: \t\t\t\t\t\t\tReason: \"Failed\",\n445: \t\t\t\t\t\t},\n446: \t\t\t\t\t},\n447: \t\t\t\t},\n448: \t\t\t},\n449: \t\t\texpectedExp: true,\n450: \t\t},\n451: \t}\n452: \n453: \tfor _, tt := range tests {\n454: \t\tt.Run(tt.name, func(t *testing.T) {\n455: \t\t\texpired := worker.isCodeInterpreterExpired(tt.ci)\n456: \t\t\tif expired != tt.expectedExp {\n457: \t\t\t\tt.Errorf(\"Expected expired=%v, got %v\", tt.expectedExp, expired)\n458: \t\t\t}\n459: \t\t})\n460: \t}\n461: }\n462: \n463: func TestGetAgentRuntimeState(t *testing.T) {\n464: \tworker := NewGCWorker(nil, nil, nil)\n465: \n466: \ttests := []struct {\n467: \t\tname          string\n468: \t\tar            *agentcubev1alpha1.AgentRuntime\n469: \t\texpectedState SandboxState\n470: \t}{\n471: \t\t{\n472: \t\t\tname: \"Unknown state - no conditions\",\n473: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n474: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n475: \t\t\t\t\tName: \"test-ar\",\n476: \t\t\t\t},\n477: \t\t\t},\n478: \t\t\texpectedState: SandboxStateUnknown,\n479: \t\t},\n480: \t\t{\n481: \t\t\tname: \"Running state\",\n482: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n483: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n484: \t\t\t\t\tName: \"test-ar\",\n485: \t\t\t\t},\n486: \t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n487: \t\t\t\t\tConditions: []metav1.Condition{\n488: \t\t\t\t\t\t{\n489: \t\t\t\t\t\t\tType:   \"Ready\",\n490: \t\t\t\t\t\t\tStatus: \"True\",\n491: \t\t\t\t\t\t\tReason: \"Running\",\n492: \t\t\t\t\t\t},\n493: \t\t\t\t\t},\n494: \t\t\t\t},\n495: \t\t\t},\n496: \t\t\texpectedState: SandboxStateRunning,\n497: \t\t},\n498: \t\t{\n499: \t\t\tname: \"Failed state\",\n500: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n501: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n502: \t\t\t\t\tName: \"test-ar\",\n503: \t\t\t\t},\n504: \t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n505: \t\t\t\t\tConditions: []metav1.Condition{\n506: \t\t\t\t\t\t{\n507: \t\t\t\t\t\t\tType:   \"Ready\",\n508: \t\t\t\t\t\t\tStatus: \"True\",\n509: \t\t\t\t\t\t\tReason: \"Failed\",\n510: \t\t\t\t\t\t},\n511: \t\t\t\t\t},\n512: \t\t\t\t},\n513: \t\t\t},\n514: \t\t\texpectedState: SandboxStateFailed,\n515: \t\t},\n516: \t\t{\n517: \t\t\tname: \"Deleting state\",\n518: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n519: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n520: \t\t\t\t\tName:              \"test-ar\",\n521: \t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n522: \t\t\t\t},\n523: \t\t\t},\n524: \t\t\texpectedState: SandboxStateDeleting,\n525: \t\t},\n526: \t}\n527: \n528: \tfor _, tt := range tests {\n529: \t\tt.Run(tt.name, func(t *testing.T) {\n530: \t\t\tstate := worker.getAgentRuntimeState(tt.ar)\n531: \t\t\tif state != tt.expectedState {\n532: \t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n533: \t\t\t}\n534: \t\t})\n535: \t}\n536: }\n537: \n538: func TestGetCodeInterpreterState(t *testing.T) {\n539: \tworker := NewGCWorker(nil, nil, nil)\n540: \n541: \ttests := []struct {\n542: \t\tname          string\n543: \t\tci            *agentcubev1alpha1.CodeInterpreter\n544: \t\texpectedState SandboxState\n545: \t}{\n546: \t\t{\n547: \t\t\tname: \"Unknown state - not ready\",\n548: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n549: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n550: \t\t\t\t\tName: \"test-ci\",\n551: \t\t\t\t},\n552: \t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n553: \t\t\t\t\tReady: false,\n554: \t\t\t\t},\n555: \t\t\t},\n556: \t\t\texpectedState: SandboxStateUnknown,\n557: \t\t},\n558: \t\t{\n559: \t\t\tname: \"Running state - ready\",\n560: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n561: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n562: \t\t\t\t\tName: \"test-ci\",\n563: \t\t\t\t},\n564: \t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n565: \t\t\t\t\tReady: true,\n566: \t\t\t\t},\n567: \t\t\t},\n568: \t\t\texpectedState: SandboxStateRunning,\n569: \t\t},\n570: \t\t{\n571: \t\t\tname: \"Failed state\",\n572: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n573: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n574: \t\t\t\t\tName: \"test-ci\",\n575: \t\t\t\t},\n576: \t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n577: \t\t\t\t\tReady: false,\n578: \t\t\t\t\tConditions: []metav1.Condition{\n579: \t\t\t\t\t\t{\n580: \t\t\t\t\t\t\tType:   \"Ready\",\n581: \t\t\t\t\t\t\tStatus: \"True\",\n582: \t\t\t\t\t\t\tReason: \"Failed\",\n583: \t\t\t\t\t\t},\n584: \t\t\t\t\t},\n585: \t\t\t\t},\n586: \t\t\t},\n587: \t\t\texpectedState: SandboxStateFailed,\n588: \t\t},\n589: \t\t{\n590: \t\t\tname: \"Deleting state\",\n591: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n592: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n593: \t\t\t\t\tName:              \"test-ci\",\n594: \t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n595: \t\t\t\t},\n596: \t\t\t},\n597: \t\t\texpectedState: SandboxStateDeleting,\n598: \t\t},\n599: \t}\n600: \n601: \tfor _, tt := range tests {\n602: \t\tt.Run(tt.name, func(t *testing.T) {\n603: \t\t\tstate := worker.getCodeInterpreterState(tt.ci)\n604: \t\t\tif state != tt.expectedState {\n605: \t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n606: \t\t\t}\n607: \t\t})\n608: \t}\n609: }\n610: \n611: func TestGetLastActivityTime(t *testing.T) {\n612: \tworker := NewGCWorker(nil, nil, nil)\n613: \n614: \ttests := []struct {\n615: \t\tname         string\n616: \t\tannotations  map[string]string\n617: \t\texpectedTime *time.Time\n618: \t}{\n619: \t\t{\n620: \t\t\tname:         \"nil annotations\",\n621: \t\t\tannotations:  nil,\n622: \t\t\texpectedTime: nil,\n623: \t\t},\n624: \t\t{\n625: \t\t\tname:         \"empty annotations\",\n626: \t\t\tannotations:  map[string]string{},\n627: \t\t\texpectedTime: nil,\n628: \t\t},\n629: \t\t{\n630: \t\t\tname:         \"no last-activity-time\",\n631: \t\t\tannotations:  map[string]string{\"other\": \"value\"},\n632: \t\t\texpectedTime: nil,\n633: \t\t},\n634: \t\t{\n635: \t\t\tname:         \"valid last-activity-time\",\n636: \t\t\tannotations:  map[string]string{\"last-activity-time\": \"2024-01-15T10:30:00Z\"},\n637: \t\t\texpectedTime: func() *time.Time { t, _ := time.Parse(time.RFC3339, \"2024-01-15T10:30:00Z\"); return &t }(),\n638: \t\t},\n639: \t\t{\n640: \t\t\tname:         \"invalid last-activity-time\",\n641: \t\t\tannotations:  map[string]string{\"last-activity-time\": \"invalid\"},\n642: \t\t\texpectedTime: nil,\n643: \t\t},\n644: \t}\n645: \n646: \tfor _, tt := range tests {\n647: \t\tt.Run(tt.name, func(t *testing.T) {\n648: \t\t\tobj := &metav1.ObjectMeta{\n649: \t\t\t\tAnnotations: tt.annotations,\n650: \t\t\t}\n651: \t\t\tresult := worker.getLastActivityTime(obj)\n652: \n653: \t\t\tif tt.expectedTime == nil && result != nil {\n654: \t\t\t\tt.Error(\"Expected nil result, got non-nil\")\n655: \t\t\t}\n656: \n657: \t\t\tif tt.expectedTime != nil && result == nil {\n658: \t\t\t\tt.Error(\"Expected non-nil result, got nil\")\n659: \t\t\t}\n660: \t\t})\n661: \t}\n662: }\n663: \n664: func TestGCHandler(t *testing.T) {\n665: \tworker := NewGCWorker(nil, nil, nil)\n666: \thandler := NewGCHandler(worker)\n667: \n668: \tif handler == nil {\n669: \t\tt.Error(\"Expected non-nil GCHandler\")\n670: \t}\n671: \n672: \tif handler.worker == nil {\n673: \t\tt.Error(\"Expected non-nil worker in handler\")\n674: \t}\n675: }\n676: \n677: func TestGCHandlerTriggerGC(t *testing.T) {\n678: \tt.Skip(\"Skipping test - requires mock clients\")\n679: }\n680: \n681: func TestGCHandlerGetStatus(t *testing.T) {\n682: \tworker := NewGCWorker(nil, nil, nil)\n683: \thandler := NewGCHandler(worker)\n684: \n685: \tstatus := handler.GetStatus()\n686: \n687: \tif status == nil {\n688: \t\tt.Error(\"Expected non-nil status\")\n689: \t}\n690: \n691: \tif status[\"running\"] != false {\n692: \t\tt.Error(\"Expected running to be false\")\n693: \t}\n694: \n695: \tif status[\"gcEnabled\"] != true {\n696: \t\tt.Error(\"Expected gcEnabled to be true\")\n697: \t}\n698: \n699: \tif status[\"gcBatchSize\"] != DefaultGCBatchSize {\n700: \t\tt.Errorf(\"Expected gcBatchSize to be %d, got %v\", DefaultGCBatchSize, status[\"gcBatchSize\"])\n701: \t}\n702: }\n703: \n704: func TestGCHandlerUpdateConfig(t *testing.T) {\n705: \tworker := NewGCWorker(nil, nil, nil)\n706: \thandler := NewGCHandler(worker)\n707: \n708: \tnewConfig := &GCConfig{\n709: \t\tGCEnabled:  false,\n710: \t\tGCInterval: 30 * time.Minute,\n711: \t}\n712: \n713: \tresult := handler.UpdateConfig(newConfig)\n714: \n715: \tif result == nil {\n716: \t\tt.Error(\"Expected non-nil result\")\n717: \t}\n718: \n719: \tif result[\"message\"] != \"GC configuration updated\" {\n720: \t\tt.Errorf(\"Expected message 'GC configuration updated', got %v\", result[\"message\"])\n721: \t}\n722: \n723: \tif worker.config.GCEnabled != false {\n724: \t\tt.Error(\"Expected GCEnabled to be false after update\")\n725: \t}\n726: }\n727: \n728: func TestGCResult(t *testing.T) {\n729: \tresult := &GCResult{\n730: \t\tScannedCount:     100,\n731: \t\tExpiredCount:     50,\n732: \t\tDeletedCount:     45,\n733: \t\tFailedCount:      5,\n734: \t\tDuration:         5 * time.Second,\n735: \t\tErrors:           []string{\"error1\", \"error2\"},\n736: \t\tCleanedResources: []string{\"Service/svc1\", \"ConfigMap/cm1\"},\n737: \t}\n738: \n739: \tif result.ScannedCount != 100 {\n740: \t\tt.Errorf(\"Expected ScannedCount=100, got %d\", result.ScannedCount)\n741: \t}\n742: \n743: \tif result.ExpiredCount != 50 {\n744: \t\tt.Errorf(\"Expected ExpiredCount=50, got %d\", result.ExpiredCount)\n745: \t}\n746: \n747: \tif result.DeletedCount != 45 {\n748: \t\tt.Errorf(\"Expected DeletedCount=45, got %d\", result.DeletedCount)\n749: \t}\n750: \n751: \tif result.FailedCount != 5 {\n752: \t\tt.Errorf(\"Expected FailedCount=5, got %d\", result.FailedCount)\n753: \t}\n754: \n755: \tif len(result.Errors) != 2 {\n756: \t\tt.Errorf(\"Expected 2 errors, got %d\", len(result.Errors))\n757: \t}\n758: \n759: \tif len(result.CleanedResources) != 2 {\n760: \t\tt.Errorf(\"Expected 2 cleaned resources, got %d\", len(result.CleanedResources))\n761: \t}\n762: }\n763: \n764: func TestGCStats(t *testing.T) {\n765: \tstats := GCStats{\n766: \t\tTotalCycles:  10,\n767: \t\tTotalDeleted: 100,\n768: \t\tTotalFailed:  5,\n769: \t\tLastRunTime:  time.Now(),\n770: \t\tLastResult: &GCResult{\n771: \t\t\tDeletedCount: 10,\n772: \t\t},\n773: \t}\n774: \n775: \tif stats.TotalCycles != 10 {\n776: \t\tt.Errorf(\"Expected TotalCycles=10, got %d\", stats.TotalCycles)\n777: \t}\n778: \n779: \tif stats.TotalDeleted != 100 {\n780: \t\tt.Errorf(\"Expected TotalDeleted=100, got %d\", stats.TotalDeleted)\n781: \t}\n782: \n783: \tif stats.TotalFailed != 5 {\n784: \t\tt.Errorf(\"Expected TotalFailed=5, got %d\", stats.TotalFailed)\n785: \t}\n786: \n787: \tif stats.LastResult == nil {\n788: \t\tt.Error(\"Expected non-nil LastResult\")\n789: \t}\n790: \n791: \tif stats.LastResult.DeletedCount != 10 {\n792: \t\tt.Errorf(\"Expected LastResult.DeletedCount=10, got %d\", stats.LastResult.DeletedCount)\n793: \t}\n794: }\n795: \n796: func TestGetAgentRuntimeStateStandalone(t *testing.T) {\n797: \ttests := []struct {\n798: \t\tname          string\n799: \t\tar            *agentcubev1alpha1.AgentRuntime\n800: \t\texpectedState SandboxState\n801: \t}{\n802: \t\t{\n803: \t\t\tname: \"Unknown with DeletionTimestamp\",\n804: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n805: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n806: \t\t\t\t\tName:              \"test\",\n807: \t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n808: \t\t\t\t},\n809: \t\t\t},\n810: \t\t\texpectedState: SandboxStateDeleting,\n811: \t\t},\n812: \t\t{\n813: \t\t\tname: \"Running\",\n814: \t\t\tar: &agentcubev1alpha1.AgentRuntime{\n815: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n816: \t\t\t\t\tName: \"test\",\n817: \t\t\t\t},\n818: \t\t\t\tStatus: agentcubev1alpha1.AgentRuntimeStatus{\n819: \t\t\t\t\tConditions: []metav1.Condition{\n820: \t\t\t\t\t\t{Type: \"Ready\", Status: \"True\", Reason: \"Running\"},\n821: \t\t\t\t\t},\n822: \t\t\t\t},\n823: \t\t\t},\n824: \t\t\texpectedState: SandboxStateRunning,\n825: \t\t},\n826: \t}\n827: \n828: \tfor _, tt := range tests {\n829: \t\tt.Run(tt.name, func(t *testing.T) {\n830: \t\t\tstate := getAgentRuntimeState(tt.ar)\n831: \t\t\tif state != tt.expectedState {\n832: \t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n833: \t\t\t}\n834: \t\t})\n835: \t}\n836: }\n837: \n838: func TestGetCodeInterpreterStateStandalone(t *testing.T) {\n839: \ttests := []struct {\n840: \t\tname          string\n841: \t\tci            *agentcubev1alpha1.CodeInterpreter\n842: \t\texpectedState SandboxState\n843: \t}{\n844: \t\t{\n845: \t\t\tname: \"Unknown\",\n846: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n847: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n848: \t\t\t\t\tName: \"test\",\n849: \t\t\t\t},\n850: \t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n851: \t\t\t\t\tReady: false,\n852: \t\t\t\t},\n853: \t\t\t},\n854: \t\t\texpectedState: SandboxStateUnknown,\n855: \t\t},\n856: \t\t{\n857: \t\t\tname: \"Running\",\n858: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n859: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n860: \t\t\t\t\tName: \"test\",\n861: \t\t\t\t},\n862: \t\t\t\tStatus: agentcubev1alpha1.CodeInterpreterStatus{\n863: \t\t\t\t\tReady: true,\n864: \t\t\t\t},\n865: \t\t\t},\n866: \t\t\texpectedState: SandboxStateRunning,\n867: \t\t},\n868: \t\t{\n869: \t\t\tname: \"Deleting\",\n870: \t\t\tci: &agentcubev1alpha1.CodeInterpreter{\n871: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n872: \t\t\t\t\tName:              \"test\",\n873: \t\t\t\t\tDeletionTimestamp: &metav1.Time{Time: time.Now()},\n874: \t\t\t\t},\n875: \t\t\t},\n876: \t\t\texpectedState: SandboxStateDeleting,\n877: \t\t},\n878: \t}\n879: \n880: \tfor _, tt := range tests {\n881: \t\tt.Run(tt.name, func(t *testing.T) {\n882: \t\t\tstate := getCodeInterpreterState(tt.ci)\n883: \t\t\tif state != tt.expectedState {\n884: \t\t\t\tt.Errorf(\"Expected state=%v, got %v\", tt.expectedState, state)\n885: \t\t\t}\n886: \t\t})\n887: \t}\n888: }\n889: \n890: func TestGetLastActivityTimeFromAnnotations(t *testing.T) {\n891: \ttests := []struct {\n892: \t\tname        string\n893: \t\tannotations map[string]string\n894: \t\texpectNil   bool\n895: \t}{\n896: \t\t{\n897: \t\t\tname:        \"nil annotations\",\n898: \t\t\tannotations: nil,\n899: \t\t\texpectNil:   true,\n900: \t\t},\n901: \t\t{\n902: \t\t\tname:        \"empty annotations\",\n903: \t\t\tannotations: map[string]string{},\n904: \t\t\texpectNil:   true,\n905: \t\t},\n906: \t\t{\n907: \t\t\tname:        \"valid time\",\n908: \t\t\tannotations: map[string]string{\"last-activity-time\": \"2024-01-15T10:30:00Z\"},\n909: \t\t\texpectNil:   false,\n910: \t\t},\n911: \t\t{\n912: \t\t\tname:        \"invalid time\",\n913: \t\t\tannotations: map[string]string{\"last-activity-time\": \"invalid\"},\n914: \t\t\texpectNil:   true,\n915: \t\t},\n916: \t\t{\n917: \t\t\tname:        \"no key\",\n918: \t\t\tannotations: map[string]string{\"other\": \"value\"},\n919: \t\t\texpectNil:   true,\n920: \t\t},\n921: \t}\n922: \n923: \tfor _, tt := range tests {\n924: \t\tt.Run(tt.name, func(t *testing.T) {\n925: \t\t\tresult := getLastActivityTimeFromAnnotations(tt.annotations)\n926: \t\t\tif tt.expectNil && result != nil {\n927: \t\t\t\tt.Error(\"Expected nil result\")\n928: \t\t\t}\n929: \t\t\tif !tt.expectNil && result == nil {\n930: \t\t\t\tt.Error(\"Expected non-nil result\")\n931: \t\t\t}\n932: \t\t})\n933: \t}\n934: }\n935: \n936: func TestGCWorkerStartDisabled(t *testing.T) {\n937: \tconfig := &GCConfig{\n938: \t\tGCEnabled:  false,\n939: \t\tGCInterval: 5 * time.Minute,\n940: \t}\n941: \n942: \tworker := NewGCWorker(nil, nil, config)\n943: \n944: \tctx, cancel := context.WithCancel(context.Background())\n945: \tcancel()\n946: \n947: \tworker.Start(ctx)\n948: \n949: \tif worker.IsRunning() {\n950: \t\tt.Error(\"Expected GC worker to not be running when disabled\")\n951: \t}\n952: }\n953: \n954: func TestGCWorkerStop(t *testing.T) {\n955: \tconfig := &GCConfig{\n956: \t\tGCEnabled:  true,\n957: \t\tGCInterval: 1 * time.Second,\n958: \t}\n959: \n960: \tworker := NewGCWorker(nil, nil, config)\n961: \n962: \tworker.Stop()\n963: \n964: \tif worker.IsRunning() {\n965: \t\tt.Error(\"Expected GC worker to not be running after Stop\")\n966: \t}\n967: }\n\n(End of file - total 967 lines)\n</content