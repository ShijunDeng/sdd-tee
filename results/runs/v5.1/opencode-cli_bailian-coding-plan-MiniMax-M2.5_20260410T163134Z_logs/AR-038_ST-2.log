\n41: \t\t\t}\n42: \t\t}\n43: \t} else {\n44: \t\tconfig, err = clientcmd.BuildConfigFromFlags(\"\", expandKubeconfigPath(kubeconfig))\n45: \t\tif err != nil {\n46: \t\t\treturn nil, fmt.Errorf(\"failed to load kubeconfig from %s: %w\", kubeconfig, err)\n47: \t\t}\n48: \t}\n49: \n50: \tclientset, err := versioned.NewForConfig(config)\n51: \tif err != nil {\n52: \t\treturn nil, fmt.Errorf(\"failed to create agentcube clientset: %w\", err)\n53: \t}\n54: \n55: \tk8sClient, err := kubernetes.NewForConfig(config)\n56: \tif err != nil {\n57: \t\treturn nil, fmt.Errorf(\"failed to create kubernetes clientset: %w\", err)\n58: \t}\n59: \n60: \tdynamicClient, err := dynamic.NewForConfig(config)\n61: \tif err != nil {\n62: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n63: \t}\n64: \n65: \treturn &K8sClient{\n66: \t\tClientset:        clientset,\n67: \t\tKubernetesClient: k8sClient,\n68: \t\tDynamicClient:    dynamicClient,\n69: \t}, nil\n70: }\n71: \n72: func NewInClusterClient() (*K8sClient, error) {\n73: \tconfig, err := rest.InClusterConfig()\n74: \tif err != nil {\n75: \t\treturn nil, fmt.Errorf(\"failed to get in-cluster config: %w\", err)\n76: \t}\n77: \n78: \tclientset, err := versioned.NewForConfig(config)\n79: \tif err != nil {\n80: \t\treturn nil, fmt.Errorf(\"failed to create agentcube clientset: %w\", err)\n81: \t}\n82: \n83: \tk8sClient, err := kubernetes.NewForConfig(config)\n84: \tif err != nil {\n85: \t\treturn nil, fmt.Errorf(\"failed to create kubernetes clientset: %w\", err)\n86: \t}\n87: \n88: \tdynamicClient, err := dynamic.NewForConfig(config)\n89: \tif err != nil {\n90: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n91: \t}\n92: \n93: \treturn &K8sClient{\n94: \t\tClientset:        clientset,\n95: \t\tKubernetesClient: k8sClient,\n96: \t\tDynamicClient:    dynamicClient,\n97: \t}, nil\n98: }\n99: \n100: func expandKubeconfigPath(path string) string {\n101: \tif path == \"\" {\n102: \t\treturn path\n103: \t}\n104: \tif path[0] == '~' {\n105: \t\thomeDir, err := os.UserHomeDir()\n106: \t\tif err != nil {\n107: \t\t\treturn path\n108: \t\t}\n109: \t\treturn homeDir + path[1:]\n110: \t}\n111: \treturn path\n112: }\n113: \n114: func (c *K8sClient) Close() error {\n115: \treturn nil\n116: }\n\n(End of file - total 116 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/client-go/tools/clientcmd\"\n\t\"k8s.io/klog/v2\"\n\n\tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n)\n\nconst (\n\tDefaultKubeconfig = \"~/.kube/config\"\n\tInClusterMode     = \"in-cluster\"\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/client.go","time":{"start":1775880991554,"end":1775880991574}}}}
