 className=\"admonition-content\">{children}</div>\n47:     </div>\n48:   );\n49: }\n\n(End of file - total 49 lines)\n</content>","metadata":{"preview":"import React, {type ReactNode} from 'react';\nimport clsx from 'clsx';\nimport {useColorMode} from '@docusaurus/theme-common';\n\ntype AlertType = 'note' | 'info' | 'tip' | 'warning' | 'danger' | 'success';\n\ninterface AlertProps {\n  type?: AlertType;\n  title?: string;\n  children: ReactNode;\n}\n\nconst iconMap: Record<AlertType, string> = {\n  note: '📘',\n  info: 'ℹ️',\n  tip: '💡',\n  warning: '⚠️',\n  danger: '⛔',\n  success: '✅',\n};","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/docs/src/components/Alert.tsx","time":{"start":1775886721634,"end":1775886721645}}}}
