{"type":"tool_use","timestamp":1775882827565,"sessionID":"ses_28522f548ffewS6xzFM6NJ4fZi","part":{"id":"prt_d7add7428001mSc47r4BpyNTTG","messageID":"msg_d7add5fd50015CxS9zGJ2356AA","sessionID":"ses_28522f548ffewS6xzFM6NJ4fZi","type":"tool","tool":"read","callID":"toolu_b9b2507b4e3a4d5c88f6ef78","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"encoding/pem\"\n6: \t\"errors\"\n7: \t\"fmt\"\n8: \t\"io\"\n9: \t\"net/http\"\n10: \t\"os\"\n11: \t\"strings\"\n12: \t\"time\"\n13: \n14: \t\"github.com/golang-jwt/jwt/v5\"\n15: )\n16: \n17: var (\n18: \tErrMalformedToken      = errors.New(\"malformed token\")\n19: \tErrInvalidSignature    = errors.New(\"invalid signature\")\n20: \tErrTokenExpired        = errors.New(\"token has expired\")\n21: \tErrInvalidAudience     = errors.New(\"invalid audience\")\n22: \tErrInvalidIssuer       = errors.New(\"invalid issuer\")\n23: \tErrUnauthorized        = errors.New(\"unauthorized\")\n24: \tErrInvalidCredentials  = errors.New(\"invalid credentials\")\n25: \tErrInvalidRefreshToken = errors.New(\"invalid or expired refresh token\")\n26: \tErrInvalidTokenType    = errors.New(\"invalid token type\")\n27: \tErrMissingKey          = errors.New(\"missing key configuration\")\n28: )\n29: \n30: const (\n31: \tErrCodeMalformedToken      = \"MALFORMED_TOKEN\"\n32: \tErrCodeInvalidSignature    = \"INVALID_SIGNATURE\"\n33: \tErrCodeTokenExpired        = \"TOKEN_EXPIRED\"\n34: \tErrCodeInvalidAudience     = \"INVALID_AUDIENCE\"\n35: \tErrCodeInvalidIssuer       = \"INVALID_ISSUER\"\n36: \tErrCodeUnauthorized        = \"UNAUTHORIZED\"\n37: \tErrCodeInvalidCredentials  = \"INVALID_CREDENTIALS\"\n38: \tErrCodeInvalidRefreshToken = \"INVALID_REFRESH_TOKEN\"\n39: \tErrCodeInvalidTokenType    = \"INVALID_TOKEN_TYPE\"\n40: )\n41: \n42: type JWTConfig struct {\n43: \tAlgorithm         string\n44: \tSecret            string\n45: \tPrivateKeyPath    string\n46: \tPublicKeyPath     string\n47: \tIssuer            string\n48: \tAudience          []string\n49: \tExpiration        time.Duration\n50: \tRefreshExpiration time.Duration\n51: \tClockSkew         time.Duration\n52: \tAllowQueryParam   bool\n53: }\n54: \n55: type Claims struct {\n56: \tjwt.RegisteredClaims\n57: \tRoles     []string `json:\"roles,omitempty\"`\n58: \tTenantID  string   `json:\"tenant_id,omitempty\"`\n59: \tNamespace string   `json:\"namespace,omitempty\"`\n60: }\n61: \n62: type UserCredentials struct {\n63: \tUsername string `json:\"username\" binding:\"required\"`\n64: \tPassword string `json:\"password\" binding:\"required\"`\n65: }\n66: \n67: type LoginResponse struct {\n68: \tAccessToken  string `json:\"access_token\"`\n69: \tRefreshToken string `json:\"refresh_token,omitempty\"`\n70: \tTokenType    string `json:\"token_type\"`\n71: \tExpiresIn    int    `json:\"expires_in\"`\n72: }\n73: \n74: type TokenRefreshRequest struct {\n75: \tRefreshToken string `json:\"refresh_token\" binding:\"required\"`\n76: }\n77: \n78: type UserValidator interface {\n79: \tValidate(username, password string) (*UserClaims, error)\n80: }\n81: \n82: type UserClaims struct {\n83: \tUsername  string\n84: \tRoles     []string\n85: \tTenantID  string\n86: \tNamespace string\n87: }\n88: \n89: type JWTManager struct {\n90: \tconfig        *JWTConfig\n91: \tsecret        []byte\n92: \tprivateKey    interface{}\n93: \tpublicKey     interface{}\n94: \tmetrics       *JWTMetrics\n95: \tuserValidator UserValidator\n96: }\n97: \n98: func NewJWTManager(config *JWTConfig, validator UserValidator) (*JWTManager, error) {\n99: \tif config == nil {\n100: \t\tconfig = &JWTConfig{\n101: \t\t\tAlgorithm:         \"HS256\",\n102: \t\t\tIssuer:            \"agentcube\",\n103: \t\t\tExpiration:        1 * time.Hour,\n104: \t\t\tRefreshExpiration: 24 * time.Hour,\n105: \t\t\tClockSkew:         30 * time.Second,\n106: \t\t}\n107: \t}\n108: \n109: \tmanager := &JWTManager{\n110: \t\tconfig:        config,\n111: \t\tmetrics:       NewJWTMetrics(),\n112: \t\tuserValidator: validator,\n113: \t}\n114: \n115: \tif err := manager.loadKeys(); err != nil {\n116: \t\treturn nil, err\n117: \t}\n118: \n119: \treturn manager, nil\n120: }\n121: \n122: func (j *JWTManager) loadKeys() error {\n123: \talgorithm := strings.ToUpper(j.config.Algorithm)\n124: \n125: \tswitch algorithm {\n126: \tcase \"HS256\", \"HS384\", \"HS512\":\n127: \t\tif j.config.Secret == \"\" {\n128: \t\t\treturn ErrMissingKey\n129: \t\t}\n130: \t\tj.secret = []byte(j.config.Secret)\n131: \n132: \tcase \"RS256\", \"RS384\", \"RS512\":\n133: \t\tif j.config.PrivateKeyPath != \"\" {\n134: \t\t\tprivateKey, err := loadPrivateKey(j.config.PrivateKeyPath)\n135: \t\t\tif err != nil {\n136: \t\t\t\treturn fmt.Errorf(\"failed to load private key: %w\", err)\n137: \t\t\t}\n138: \t\t\tj.privateKey = privateKey\n139: \t\t}\n140: \n141: \t\tif j.config.PublicKeyPath != \"\" {\n142: \t\t\tpublicKey, err := loadPublicKey(j.config.PublicKeyPath)\n143: \t\t\tif err != nil {\n144: \t\t\t\treturn fmt.Errorf(\"failed to load public key: %w\", err)\n145: \t\t\t}\n146: \t\t\tj.publicKey = publicKey\n147: \t\t}\n148: \n149: \t\tif j.privateKey == nil && j.publicKey == nil {\n150: \t\t\treturn ErrMissingKey\n151: \t\t}\n152: \n153: \tdefault:\n154: \t\treturn fmt.Errorf(\"unsupported algorithm: %s\", algorithm)\n155: \t}\n156: \n157: \treturn nil\n158: }\n159: \n160: func loadPrivateKey(path string) (interface{}, error) {\n161: \tdata, err := os.ReadFile(path)\n162: \tif err != nil {\n163: \t\treturn nil, err\n164: \t}\n165: \n166: \tblock, _ := pem.Decode(data)\n167: \tif block == nil {\n168: \t\treturn nil, errors.New(\"failed to parse PEM block\")\n169: \t}\n170: \n171: \tif block.Type == \"RSA PRIVATE KEY\" {\n172: \t\treturn jwt.ParseRSAPrivateKeyFromPEM(data)\n173: \t}\n174: \tif block.Type == \"EC PRIVATE KEY\" {\n175: \t\treturn jwt.ParseECPrivateKeyFromPEM(data)\n176: \t}\n177: \n178: \treturn nil, fmt.Errorf(\"unsupported private key type: %s\", block.Type)\n179: }\n180: \n181: func loadPublicKey(path string) (interface{}, error) {\n182: \tdata, err := os.ReadFile(path)\n183: \tif err != nil {\n184: \t\treturn nil, err\n185: \t}\n186: \n187: \tblock, _ := pem.Decode(data)\n188: \tif block == nil {\n189: \t\treturn nil, errors.New(\"failed to parse PEM block\")\n190: \t}\n191: \n192: \tif block.Type == \"RSA PUBLIC KEY\" || block.Type == \"PUBLIC KEY\" {\n193: \t\treturn jwt.ParseRSAPublicKeyFromPEM(data)\n194: \t}\n195: \tif block.Type == \"EC PUBLIC KEY\" {\n196: \t\treturn jwt.ParseECPublicKeyFromPEM(data)\n197: \t}\n198: \n199: \treturn nil, fmt.Errorf(\"unsupported public key type: %s\", block.Type)\n200: }\n201: \n202: func (j *JWTManager) ValidateToken(tokenString string) (*Claims, error) {\n203: \tkeyFunc := func(token *jwt.Token) (interface{}, error) {\n204: \t\treturn j.getSigningKey(token)\n205: \t}\n206: \n207: \tvar opts []jwt.ParserOption\n208: \topts = append(opts, jwt.WithIssuer(j.config.Issuer))\n209: \tif len(j.config.Audience) > 0 {\n210: \t\topts = append(opts, jwt.WithAudience(j.config.Audience[0]))\n211: \t}\n212: \n213: \ttoken, err := jwt.ParseWithClaims(tokenString, &Claims{}, keyFunc, opts...)\n214: \n215: \tif err != nil {\n216: \t\treturn j.handleValidationError(err)\n217: \t}\n218: \n219: \tif !token.Valid {\n220: \t\tj.metrics.IncValidationError(ErrCodeMalformedToken)\n221: \t\treturn nil, ErrMalformedToken\n222: \t}\n223: \n224: \tclaims, ok := token.Claims.(*Claims)\n225: \tif !ok {\n226: \t\tj.metrics.IncValidationError(ErrCodeMalformedToken)\n227: \t\treturn nil, ErrMalformedToken\n228: \t}\n229: \n230: \tj.metrics.IncValidated(\"success\")\n231: \treturn claims, nil\n232: }\n233: \n234: func (j *JWTManager) getSigningKey(token *jwt.Token) (interface{}, error) {\n235: \talg := token.Method.Alg()\n236: \n237: \tswitch strings.ToUpper(alg) {\n238: \tcase \"HS256\", \"HS384\", \"HS512\":\n239: \t\treturn j.secret, nil\n240: \tcase \"RS256\", \"RS384\", \"RS512\":\n241: \t\tif j.publicKey != nil {\n242: \t\t\treturn j.publicKey, nil\n243: \t\t}\n244: \t\treturn nil, ErrMissingKey\n245: \tcase \"ES256\", \"ES384\":\n246: \t\tif j.publicKey != nil {\n247: \t\t\treturn j.publicKey, nil\n248: \t\t}\n249: \t\treturn nil, ErrMissingKey\n250: \t}\n251: \n252: \treturn nil, fmt.Errorf(\"unsupported algorithm: %s\", alg)\n253: }\n254: \n255: func (j *JWTManager) getSigningKeyForIssuance() (interface{}, error) {\n256: \talg := strings.ToUpper(j.config.Algorithm)\n257: \n258: \tswitch alg {\n259: \tcase \"HS256\", \"HS384\", \"HS512\":\n260: \t\treturn j.secret, nil\n261: \tcase \"RS256\", \"RS384\", \"RS512\":\n262: \t\tif j.privateKey != nil {\n263: \t\t\treturn j.privateKey, nil\n264: \t\t}\n265: \t\treturn nil, ErrMissingKey\n266: \tcase \"ES256\", \"ES384\":\n267: \t\tif j.privateKey != nil {\n268: \t\t\treturn j.privateKey, nil\n269: \t\t}\n270: \t\treturn nil, ErrMissingKey\n271: \t}\n272: \n273: \treturn nil, fmt.Errorf(\"unsupported algorithm: %s\", alg)\n274: }\n275: \n276: func (j *JWTManager) handleValidationError(err error) (*Claims, error) {\n277: \terrStr := err.Error()\n278: \n279: \tif strings.Contains(errStr, \"malformed\") || strings.Contains(errStr, \"token contains an invalid number of segments\") {\n280: \t\tj.metrics.IncValidationError(ErrCodeMalformedToken)\n281: \t\treturn nil, ErrMalformedToken\n282: \t}\n283: \tif strings.Contains(errStr, \"expired\") || strings.Contains(errStr, \"token is expired\") {\n284: \t\tj.metrics.IncValidationError(ErrCodeTokenExpired)\n285: \t\treturn nil, ErrTokenExpired\n286: \t}\n287: \tif strings.Contains(errStr, \"signature\") || strings.Contains(errStr, \"invalid signature\") {\n288: \t\tj.metrics.IncValidationError(ErrCodeInvalidSignature)\n289: \t\treturn nil, ErrInvalidSignature\n290: \t}\n291: \tif strings.Contains(errStr, \"audience\") || strings.Contains(errStr, \"invalid audience\") {\n292: \t\tj.metrics.IncValidationError(ErrCodeInvalidAudience)\n293: \t\treturn nil, ErrInvalidAudience\n294: \t}\n295: \tif strings.Contains(errStr, \"issuer\") || strings.Contains(errStr, \"invalid issuer\") {\n296: \t\tj.metrics.IncValidationError(ErrCodeInvalidIssuer)\n297: \t\treturn nil, ErrInvalidIssuer\n298: \t}\n299: \n300: \tj.metrics.IncValidationError(ErrCodeUnauthorized)\n301: \treturn nil, ErrUnauthorized\n302: }\n303: \n304: func (j *JWTManager) IssueToken(user *UserClaims) (string, error) {\n305: \tnow := time.Now()\n306: \n307: \tclaims := &Claims{\n308: \t\tRegisteredClaims: jwt.RegisteredClaims{\n309: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(j.config.Expiration)),\n310: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n311: \t\t\tNotBefore: jwt.NewNumericDate(now),\n312: \t\t\tIssuer:    j.config.Issuer,\n313: \t\t\tSubject:   user.Username,\n314: \t\t\tAudience:  jwt.ClaimStrings(j.config.Audience),\n315: \t\t},\n316: \t\tRoles:     user.Roles,\n317: \t\tTenantID:  user.TenantID,\n318: \t\tNamespace: user.Namespace,\n319: \t}\n320: \n321: \tkey, err := j.getSigningKeyForIssuance()\n322: \tif err != nil {\n323: \t\treturn \"\", err\n324: \t}\n325: \n326: \ttoken := jwt.NewWithClaims(jwt.GetSigningMethod(j.config.Algorithm), claims)\n327: \tsignedToken, err := token.SignedString(key)\n328: \tif err != nil {\n329: \t\treturn \"\", fmt.Errorf(\"failed to sign token: %w\", err)\n330: \t}\n331: \n332: \tj.metrics.IncIssued()\n333: \treturn signedToken, nil\n334: }\n335: \n336: func (j *JWTManager) IssueRefreshToken(user *UserClaims) (string, error) {\n337: \tnow := time.Now()\n338: \n339: \tclaims := &Claims{\n340: \t\tRegisteredClaims: jwt.RegisteredClaims{\n341: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(j.config.RefreshExpiration)),\n342: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n343: \t\t\tNotBefore: jwt.NewNumericDate(now),\n344: \t\t\tIssuer:    j.config.Issuer,\n345: \t\t\tSubject:   user.Username,\n346: \t\t\tID:        \"refresh\",\n347: \t\t\tAudience:  jwt.ClaimStrings(j.config.Audience),\n348: \t\t},\n349: \t\tRoles:     user.Roles,\n350: \t\tTenantID:  user.TenantID,\n351: \t\tNamespace: user.Namespace,\n352: \t}\n353: \n354: \tkey, err := j.getSigningKeyForIssuance()\n355: \tif err != nil {\n356: \t\treturn \"\", err\n357: \t}\n358: \n359: \ttoken := jwt.NewWithClaims(jwt.GetSigningMethod(j.config.Algorithm), claims)\n360: \tsignedToken, err := token.SignedString(key)\n361: \tif err != nil {\n362: \t\treturn \"\", fmt.Errorf(\"failed to sign refresh token: %w\", err)\n363: \t}\n364: \n365: \treturn signedToken, nil\n366: }\n367: \n368: func (j *JWTManager) ValidateRefreshToken(tokenString string) (*Claims, error) {\n369: \tclaims, err := j.ValidateToken(tokenString)\n370: \tif err != nil {\n371: \t\treturn nil, err\n372: \t}\n373: \n374: \tif claims.ID != \"refresh\" {\n375: \t\treturn nil, ErrInvalidTokenType\n376: \t}\n377: \n378: \treturn claims, nil\n379: }\n380: \n381: func (j *JWTManager) GetMetrics() *JWTMetrics {\n382: \treturn j.metrics\n383: }\n384: \n385: func (j *JWTManager) IsRefreshToken(tokenString string) bool {\n386: \tclaims, err := j.ValidateToken(tokenString)\n387: \tif err != nil {\n388: \t\treturn false\n389: \t}\n390: \treturn claims.ID == \"refresh\"\n391: }\n392: \n393: func ParseJWTFromBody(body io.Reader) (*Claims, error) {\n394: \tvar claims Claims\n395: \tif err := json.NewDecoder(body).Decode(&claims); err != nil {\n396: \t\treturn nil, err\n397: \t}\n398: \treturn &claims, nil\n399: }\n400: \n401: func GetClaimsFromContext(req *http.Request) *Claims {\n402: \tval := req.Context().Value(ContextKeyClaims)\n403: \tif claims, ok := val.(*Claims); ok {\n404: \t\treturn claims\n405: \t}\n406: \treturn nil\n407: }\n408: \n409: func GetUsernameFromContext(req *http.Request) string {\n410: \tval := req.Context().Value(ContextKeyUsername)\n411: \tif username, ok := val.(string); ok {\n412: \t\treturn username\n413: \t}\n414: \treturn \"\"\n415: }\n416: \n417: const (\n418: \tContextKeyClaims   = \"jwt_claims\"\n419: \tContextKeyUsername = \"jwt_username\"\n420: )\n\n(End of file - total 420 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nvar (\n\tErrMalformedToken      = errors.New(\"malformed token\")\n\tErrInvalidSignature    = errors.New(\"invalid signature\")\n\tErrTokenExpired        = errors.New(\"token has expired\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/jwt.go","time":{"start":1775882827554,"end":1775882827562}}}}
