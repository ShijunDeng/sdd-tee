ode = 1\n120: \t\t\tif stderr != \"\" {\n121: \t\t\t\tstderr += \"\\n\"\n122: \t\t\t}\n123: \t\t\tstderr += err.Error()\n124: \t\t}\n125: \t}\n126: \n127: \tc.JSON(200, ExecuteResponse{\n128: \t\tStdout:    stdoutBuf.String(),\n129: \t\tStderr:    stderr,\n130: \t\tExitCode:  exitCode,\n131: \t\tDuration:  duration,\n132: \t\tStartTime: startTime,\n133: \t\tEndTime:   endTime,\n134: \t})\n135: }\n\n(End of file - total 135 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nconst (\n\tTimeoutExitCode = 124\n\tDefaultTimeout  = 60 * time.Second\n)\n\ntype ExecuteRequest struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/execute.go","time":{"start":1775882821497,"end":1775882821519}}}}
