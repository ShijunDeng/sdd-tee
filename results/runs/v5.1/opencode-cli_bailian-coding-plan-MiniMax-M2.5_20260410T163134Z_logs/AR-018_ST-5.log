/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc_test.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/agentd/reconciler_test.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/agentd/reconciler_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/agentd/reconciler_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/agentd/reconciler_test.go\n@@ -213,9 +213,9 @@\n \t\t\t}\n \t\t\treturn nil\n \t\t},\n \t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n-\t\t\treturn apierrors.NewNotFound(v1alpha1.Resource(\"sandbox\"), obj.GetName())\n+\t\t\treturn apierrors.NewNotFound(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, obj.GetName())\n \t\t},\n \t},\n \tScheme: &runtime.Scheme{},\n }\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/agentd/reconciler_test.go","before":"package agentd\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"sigs.k8s.io/agent-sandbox/api/v1alpha1\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/reconcile\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\ntype mockClient struct {\n\tclient.Client\n\tgetFunc    func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error\n\tdeleteFunc func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error\n}\n\nfunc (m *mockClient) Get(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n\treturn m.getFunc(ctx, key, obj, opts...)\n}\n\nfunc (m *mockClient) Delete(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\treturn m.deleteFunc(ctx, obj, opts...)\n}\n\nfunc TestReconcile_NotFound(t *testing.T) {\n\treconciler := &Reconciler{\n\t\tClient: &mockClient{\n\t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\treturn apierrors.NewNotFound(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, key.Name)\n\t\t\t},\n\t\t},\n\t\tScheme: &runtime.Scheme{},\n\t}\n\n\treq := reconcile.Request{\n\t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n\t}\n\n\tresult, err := reconciler.Reconcile(context.Background(), req)\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got %v\", err)\n\t}\n\tif result != (reconcile.Result{}) {\n\t\tt.Errorf(\"Expected empty result, got %v\", result)\n\t}\n}\n\nfunc TestReconcile_GetError(t *testing.T) {\n\treconciler := &Reconciler{\n\t\tClient: &mockClient{\n\t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\treturn errors.New(\"some get error\")\n\t\t\t},\n\t\t},\n\t\tScheme: &runtime.Scheme{},\n\t}\n\n\treq := reconcile.Request{\n\t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n\t}\n\n\t_, err := reconciler.Reconcile(context.Background(), req)\n\tif err == nil {\n\t\tt.Error(\"Expected error, got nil\")\n\t}\n}\n\nfunc TestReconcile_NoAnnotation(t *testing.T) {\n\treconciler := &Reconciler{\n\t\tClient: &mockClient{\n\t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n\t\t\t\tsandbox.Name = key.Name\n\t\t\t\tsandbox.Namespace = key.Namespace\n\t\t\t\tsandbox.Annotations = nil\n\t\t\t\treturn nil\n\t\t\t},\n\t\t},\n\t\tScheme: &runtime.Scheme{},\n\t}\n\n\treq := reconcile.Request{\n\t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n\t}\n\n\tresult, err := reconciler.Reconcile(context.Background(), req)\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got %v\", err)\n\t}\n\tif result != (reconcile.Result{}) {\n\t\tt.Errorf(\"Expected empty result, got %v\", result)\n\t}\n}\n\nfunc TestReconcile_Expired(t *testing.T) {\n\tdeleteCalled := false\n\treconciler := &Reconciler{\n\t\tClient: &mockClient{\n\t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n\t\t\t\tsandbox.Name = key.Name\n\t\t\t\tsandbox.Namespace = key.Namespace\n\t\t\t\tsandbox.Annotations = map[string]string{\n\t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: time.Now().Add(-30 * time.Minute).Format(time.RFC3339),\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t},\n\t\t\tdeleteFunc: func(ctx context.Context, obj client.Object, opts ...client.DeleteOption) error {\n\t\t\t\tdeleteCalled = true\n\t\t\t\treturn nil\n\t\t\t},\n\t\t},\n\t\tScheme: &runtime.Scheme{},\n\t}\n\n\treq := reconcile.Request{\n\t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n\t}\n\n\tresult, err := reconciler.Reconcile(context.Background(), req)\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got %v\", err)\n\t}\n\tif !deleteCalled {\n\t\tt.Error(\"Expected delete to be called\")\n\t}\n\tif result != (reconcile.Result{}) {\n\t\tt.Errorf(\"Expected empty result after deletion, got %v\", result)\n\t}\n}\n\nfunc TestReconcile_NotExpired(t *testing.T) {\n\treconciler := &Reconciler{\n\t\tClient: &mockClient{\n\t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n\t\t\t\tsandbox.Name = key.Name\n\t\t\t\tsandbox.Namespace = key.Namespace\n\t\t\t\tsandbox.Annotations = map[string]string{\n\t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: time.Now().Add(-5 * time.Minute).Format(time.RFC3339),\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t},\n\t\t},\n\t\tScheme: &runtime.Scheme{},\n\t}\n\n\treq := reconcile.Request{\n\t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n\t}\n\n\tresult, err := reconciler.Reconcile(context.Background(), req)\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got %v\", err)\n\t}\n\tif result.RequeueAfter == 0 {\n\t\tt.Error(\"Expected RequeueAfter to be set\")\n\t}\n\texpectedRequeueAfter := 10 * time.Minute\n\tif result.RequeueAfter < expectedRequeueAfter || result.RequeueAfter > expectedRequeueAfter+time.Second {\n\t\tt.Errorf(\"Expected RequeueAfter around %v, got %v\", expectedRequeueAfter, result.RequeueAfter)\n\t}\n}\n\nfunc TestReconcile_InvalidTimestamp(t *testing.T) {\n\treconciler := &Reconciler{\n\t\tClient: &mockClient{\n\t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n\t\t\t\tsandbox.Name = key.Name\n\t\t\t\tsandbox.Namespace = key.Namespace\n\t\t\t\tsandbox.Annotations = map[string]string{\n\t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: \"invalid-timestamp\",\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t},\n\t\t},\n\t\tScheme: &runtime.Scheme{},\n\t}\n\n\treq := reconcile.Request{\n\t\tNamespacedName: types.NamespacedName{Namespace: \"default\", Name: \"test-sandbox\"},\n\t}\n\n\tresult, err := reconciler.Reconcile(context.Background(), req)\n\tif err == nil {\n\t\tt.Error(\"Expected error, got nil\")\n\t}\n\tif result.RequeueAfter != 30*time.Second {\n\t\tt.Errorf(\"Expected RequeueAfter to be 30s, got %v\", result.RequeueAfter