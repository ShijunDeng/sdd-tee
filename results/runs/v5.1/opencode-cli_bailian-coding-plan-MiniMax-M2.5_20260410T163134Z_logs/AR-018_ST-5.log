ontroller-runtime/pkg/client\"\n-\"sigs.k8s.io/controller-runtime/pkg/controller/controllerutil\"\n \"sigs.k8s.io/controller-runtime/pkg/manager\"\n \"sigs.k8s.io/controller-runtime/pkg/reconcile\"\n \n \"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/agentd/reconciler.go","before":"package agentd\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/klog/v2\"\n\t\"sigs.k8s.io/agent-sandbox/api/v1alpha1\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/controller/controllerutil\"\n\t\"sigs.k8s.io/controller-runtime/pkg/manager\"\n\t\"sigs.k8s.io/controller-runtime/pkg/reconcile\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\nconst (\n\tSessionExpirationTimeout  = 15 * time.Minute\n\tlastActivityAnnotationKey = workloadmanager.LastActivityAnnotationKey\n)\n\ntype Reconciler struct {\n\tclient.Client\n\tScheme *runtime.Scheme\n}\n\nfunc (r *Reconciler) Reconcile(ctx context.Context, req reconcile.Request) (reconcile.Result, error) {\n\tsandbox := &v1alpha1.Sandbox{}\n\terr := r.Get(ctx, req.NamespacedName, sandbox)\n\tif err != nil {\n\t\tif apierrors.IsNotFound(err) {\n\t\t\treturn reconcile.Result{}, nil\n\t\t}\n\t\treturn reconcile.Result{}, err\n\t}\n\n\tlastActivityStr, exists := sandbox.Annotations[lastActivityAnnotationKey]\n\tif exists && lastActivityStr != \"\" {\n\t\tlastActivity, err := time.Parse(time.RFC3339, lastActivityStr)\n\t\tif err != nil {\n\t\t\tklog.ErrorS(err, \"Failed to parse last-activity-time annotation\", \"sandbox\", klog.KObj(sandbox))\n\t\t\treturn reconcile.Result{RequeueAfter: 30 * time.Second}, err\n\t\t}\n\n\t\texpirationTime := lastActivity.Add(SessionExpirationTimeout)\n\t\tif time.Now().After(expirationTime) {\n\t\t\tklog.InfoS(\"Deleting expired sandbox\", \"sandbox\", klog.KObj(sandbox), \"lastActivity\", lastActivity, \"expirationTime\", expirationTime)\n\t\t\tdeleteErr := r.Delete(ctx, sandbox)\n\t\t\tif deleteErr != nil && !apierrors.IsNotFound(deleteErr) {\n\t\t\t\treturn reconcile.Result{}, deleteErr\n\t\t\t}\n\t\t} else {\n\t\t\treturn reconcile.Result{RequeueAfter: time.Until(expirationTime)}, nil\n\t\t}\n\t}\n\n\treturn reconcile.Result{}, nil\n}\n\nfunc (r *Reconciler) SetupWithManager(mgr manager.Manager) error {\n\treturn controllerutil.NewControllerManagedBy(mgr).\n\t\tFor(&v1alpha1.Sandbox{}).\n\t\tComplete(r)\n}\n","after":"package agentd\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/klog/v2\"\n\t\"sigs.k8s.io/agent-sandbox/api/v1alpha1\"\n\t\"sigs.k8s.io/controller-runtime/pkg/builder\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/manager\"\n\t\"sigs.k8s.io/controller-runtime/pkg/reconcile\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\nconst (\n\tSessionExpirationTimeout  = 15 * time.Minute\n\tlastActivityAnnotationKey = workloadmanager.LastActivityAnnotationKey\n)\n\ntype Reconciler struct {\n\tclient.Client\n\tScheme *runtime.Scheme\n}\n\nfunc (r *Reconciler) Reconcile(ctx context.Context, req reconcile.Request) (reconcile.Result, error) {\n\tsandbox := &v1alpha1.Sandbox{}\n\terr := r.Get(ctx, req.NamespacedName, sandbox)\n\tif err != nil {\n\t\tif apierrors.IsNotFound(err) {\n\t\t\treturn reconcile.Result{}, nil\n\t\t}\n\t\treturn reconcile.Result{}, err\n\t}\n\n\tlastActivityStr, exists := sandbox.Annotations[lastActivityAnnotationKey]\n\tif exists && lastActivityStr != \"\" {\n\t\tlastActivity, err := time.Parse(time.RFC3339, lastActivityStr)\n\t\tif err != nil {\n\t\t\tklog.ErrorS(err, \"Failed to parse last-activity-time annotation\", \"sandbox\", klog.KObj(sandbox))\n\t\t\treturn reconcile.Result{RequeueAfter: 30 * time.Second