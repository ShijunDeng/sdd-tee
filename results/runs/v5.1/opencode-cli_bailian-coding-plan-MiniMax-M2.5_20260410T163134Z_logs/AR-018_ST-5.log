ol\n\t}{\n\t\t{\n\t\t\tname:        \"RFC3339 format\",\n\t\t\ttimestamp:   \"2024-01-15T10:30:00Z\",\n\t\t\texpectError: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"RFC3339 with timezone\",\n\t\t\ttimestamp:   \"2024-01-15T10:30:00+05:30\",\n\t\t\texpectError: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"invalid timestamp\",\n\t\t\ttimestamp:   \"not-a-timestamp\",\n\t\t\texpectError: true,\n\t\t},\n\t\t{\n\t\t\tname:        \"empty string\",\n\t\t\ttimestamp:   \"\",\n\t\t\texpectError: true,\n\t\t},\n\t\t{\n\t\t\tname:        \"Unix timestamp\",\n\t\t\ttimestamp:   \"1705315800\",\n\t\t\texpectError: true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\t_, err := time.Parse(time.RFC3339, tt.timestamp)\n\t\t\tif tt.expectError && err == nil {\n\t\t\t\tt.Errorf(\"Expected error for timestamp %q\", tt.timestamp)\n\t\t\t}\n\t\t\tif !tt.expectError && err != nil {\n\t\t\t\tt.Errorf(\"Expected no error for timestamp %q, got %v\", tt.timestamp, err)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestReconcile_SandboxObjectMeta(t *testing.T) {\n\treconciler := &Reconciler{\n\t\tClient: &mockClient{\n\t\t\tgetFunc: func(ctx context.Context, key types.NamespacedName, obj client.Object, opts ...client.GetOption) error {\n\t\t\t\tsandbox := obj.(*v1alpha1.Sandbox)\n\t\t\t\tsandbox.ObjectMeta = metav1.ObjectMeta{\n\t\t\t\t\tName:      key.Name,\n\t\t\t\t\tNamespace: key.Namespace,\n\t\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\tworkloadmanager.LastActivityAnnotationKey: time.Now().Add(-5 * time.Minute).Format(time.RFC3339),\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t},\n\t\t},\n\t\tScheme: &runtime.Scheme{},\n\t}\n\n\treq := reconcile.Request{\n\t\tNamespacedName: types.NamespacedName{Namespace: \"test-ns\", Name: \"test-sandbox\"},\n\t}\n\n\tresult, err := reconciler.Reconcile(context.Background(), req)\n\tif err != nil {\n\t\tt.Errorf(\"Expected no error, got %v\", err)\n\t}\n\tif result.RequeueAfter == 0 {\n\t\tt.Error(\"Expec