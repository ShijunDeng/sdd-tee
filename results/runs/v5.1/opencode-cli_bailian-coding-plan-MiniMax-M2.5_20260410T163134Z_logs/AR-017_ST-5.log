)\n\t}\n\n\tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n\t}\n\n\trsaPubKey, ok := pubKey.(*rsa.PublicKey)\n\tif !ok {\n\t\treturn errors.New(\"public key is not an RSA key\")\n\t}\n\n\tam.mutex.Lock()\n\tam.publicKey = rsaPubKey\n\tam.mutex.Unlock()\n\n\treturn nil\n}\n\nfunc (am *AuthManager) GetPublicKey() *rsa.PublicKey {\n\tam.mutex.RLock()\n\tdefer am.mutex.RUnlock()\n\treturn am.publicKey\n}\n\nfunc (am *AuthManager) AuthMiddleware() gin.HandlerFunc {\n\treturn func(c *gin.Context) {\n\t\tauthHeader := c.GetHeader(\"Authorization\")\n\t\tif authHeader == \"\" {\n\t\t\tc.AbortWithStatusJSON(401, gin.H{\n\t\t\t\t\"error\":  \"Missing authorization header\",\n\t\t\t\t\"code\":   401,\n\t\t\t\t\"detail\": \"JWT required: Use Bearer <token>\",\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\tparts := strings.Split(authHeader, \" \")\n\t\tif len(parts) != 2 || parts[0] != \"Bearer\" {\n\t\t\tc.AbortWithStatusJSON(401, gin.H{\n\t\t\t\t\"error\":  \"Invalid authorization header format\",\n\t\t\t\t\"code\":   401,\n\t\t\t\t\"detail\": \"Use Bearer <token>\",\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\ttokenString := parts[1]\n\n\t\tam.mutex.RLock()\n\t\tpubKey := am.publicKey\n\t\tam.mutex.RUnlock()\n\n\t\tif pubKey == nil {\n\t\t\tc.AbortWithStatusJSON(401, gin.H{\n\t\t\t\t\"error\":  \"Invalid token\",\n\t\t\t\t\"code\":   401,\n\t\t\t\t\"detail\": \"Public key not configured\",\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n\t\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n\t\t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n\t\t\t}\n\t\t\treturn pubKey, nil\n\t\t}, jwt.WithExpirationRequired(), jwt.WithIssuedAt(), jwt.WithLeeway(time.Minute))\n\n\t\tif err != nil || !token.Valid {\n\t\t\tdetail := \"verification failed\"\n\t\t\tif err != nil {\n\t\t\t\tdetail = err.Error()\n\t\t\t}\n\t\t\tc.AbortWithStatusJSON(401, gin.H{\n\t\t\t\t\"error\":  \"Invalid token\",\n\t\t\t\t\"code\":   401,\n\t\t\t\t\"detail\": detail,\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\tc.Request.Body = http.MaxBytesReader(c.Writer, c.Request.Body, MaxBodySize)\n\t\tc.Next()\n\t}\n}\n\nfunc (am *AuthManager) RequireAuth() gin.HandlerFunc {\n\treturn func(c *gin.Context) {\n\t\tif err := am.LoadPublicKeyFromEnv(); err != nil {\n\t\t\tklog.Fatalf(\"Failed to load public key: %v\", err)\n\t\t}\n\t\tam.AuthMiddleware()(c)\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"strings\"\n\t\"sync\"\n\t\"syscall\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (\n\tPublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"\n\tMaxBodySize     = 32 << 20\n\tminute          = time.Minute\n)\n\nvar (\n\tErrCodeMissingHeader    = \"AUTH_MISSING_HEADER\"\n\tErrCodeInvalidFormat    = \"AUTH_INVALID_FORMAT\"\n\tErrCodeInvalidToken     = \"AUTH_INVALID_TOKEN\"\n\tErrCodeTokenExpired     = \"AUTH_TOKEN_EXPIRED\"\n\tErrCodeKeyNotConfigured = \"AUTH_KEY_NOT_CONFIGURED\"\n\tErrInvalidSigningMethod = errors.New(\"invalid signing method\")\n)\n\ntype AuthManager struct {\n\tpublicKey *rsa.PublicKey\n\tmutex     sync.RWMutex\n}\n\nfunc NewAuthManager() *AuthManager {\n\treturn &AuthManager{}\n}\n\nfunc (am *AuthManager) LoadPublicKeyFromEnv() error {\n\tkeyData := os.Getenv(PublicKeyEnvVar)\n\tif keyData == \"\" {\n\t\treturn fmt.Errorf(\"environment variable %s is not set\", PublicKeyEnvVar)\n\t}\n\n\tblock, _ := pem.Decode([]byte(keyData))\n\tif block == nil {\n\t\treturn errors.New(\"failed to decode PEM block\")\n\t}\n\n\tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n\t}\n\n\trsaPubKey, ok := pubKey.(*rsa.PublicKey)\n\tif !ok {\n\t\treturn errors.New(\"public key is not an RSA key\")\n\t}\n\n\tam.mutex.Lock()\n\tam.publicKey = rsaPubKey\n\tam.mutex.Unlock()\n\n\treturn nil\n}\n\nfunc (am *AuthManager) GetPublicKey() *rsa.PublicKey {\n\tam.mutex.RLock()\n\tdefer am.mutex.RUnlock()\n\treturn am.publicKey\n}\n\nfunc (am *AuthManager) AuthMiddleware() gin.HandlerFunc {\n\treturn func(c *gin.Context) {\n\t\tauthHeader := c.GetHeader(\"Authorization\")\n\t\tif authHeader == \"\" {\n\t\t\tc.AbortWithStatusJSON(401, gin.H{\n\t\t\t\t\"error\":  \"Missing authorization header\",\n\t\t\t\t\"code\":   401,\n\t\t\t\t\"detail\": \"JWT required: Use Bearer <token>\",\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\tparts := strings.Split(authHeader, \" \")\n\t\tif len(parts) != 2 || parts[0] != \"Bearer\" {\n\t\t\tc.AbortWithStatusJSON(401, gin.H{\n\t\t\t\t\"error\":  \"Invalid authorization header format\",\n\t\t\t\t\"code\":   401,\n\t\t\t\t\"detail\": \"Use Bearer <token>\",\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\ttokenString := parts[1]\n\n\t\tam.mutex.RLock()\n\t\tpubKey := am.publicKey\n\t\tam.mutex.RUnlock()\n\n\t\tif pubKey == nil {\n\t\t\tc.AbortWithStatusJSON(401, gin.H{\n\t\t\t\t\"error\":  \"Invalid token\",\n\t\t\t\t\"code\":   401,\n\t\t\t\t\"detail\": \"Public key not configured\",\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n\t\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n\t\t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n\t\t\t}\n\t\t\treturn pubKey, nil\n\t\t}, jwt.WithExpirationRequired(), jwt.WithIssuedAt(), jwt.WithLeeway(time.Minute))\n\n\t\tif err != nil || !token.Valid {\n\t\t\tdetail := \"verification failed\"\n\t\t\tif err != nil {\n\t\t\t\tdetail = err.Error()\n\t\t\t}\n\t\t\tc.AbortWithStatusJSON(401, gin.H{\n\t\t\t\t\"error\":  \"Invalid token\",\n\t\t\t\t\"code\":   401,\n\t\t\t\t\"detail\": detail,\n\t\t\t})\n\t\t\treturn\n\t\t}\n\n\t\tc.Request.Body = http.MaxBytesReader(c.Writer, c.Request.Body, MaxBodySize)\n\t\tc.Next()\n\t}\n}\n\nfunc (am *AuthManager) RequireAuth() gin.HandlerFunc {\n\treturn func(c *gin.Context) {\n\t\tif err := am.LoadPublicKeyFromEnv(); err != nil {\n\t\t\tklog.Fatalf(\"Failed to load public key: %v\", err)\n\t\t}\n\t\tam.AuthMiddleware()(c)\n\t}\n}\n","additions":12,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth.go","time":{"start":1775857152975,"end":1775857153348}}}}
