{"type":"tool_use","timestamp":1775857173047,"sessionID":"ses_286ab945dffeHMyQulcQOnOwt7","part":{"id":"prt_d7955fe6f0018Lqxvtn94Nd2K9","messageID":"msg_d7955f230001yIS0fyhjiJwEgD","sessionID":"ses_286ab945dffeHMyQulcQOnOwt7","type":"tool","tool":"read","callID":"toolu_05e78cdeee3b4efba53a16cf","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"crypto/rsa\"\n5: \t\"crypto/x509\"\n6: \t\"encoding/pem\"\n7: \t\"errors\"\n8: \t\"fmt\"\n9: \t\"net/http\"\n10: \t\"os\"\n11: \t\"os/signal\"\n12: \t\"strings\"\n13: \t\"sync\"\n14: \t\"syscall\"\n15: \t\"time\"\n16: \n17: \t\"github.com/gin-gonic/gin\"\n18: \t\"github.com/golang-jwt/jwt/v5\"\n19: \t\"k8s.io/klog/v2\"\n20: )\n21: \n22: const (\n23: \tPublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"\n24: \tMaxBodySize     = 32 << 20\n25: \tminute          = time.Minute\n26: )\n27: \n28: var (\n29: \tErrCodeMissingHeader    = \"AUTH_MISSING_HEADER\"\n30: \tErrCodeInvalidFormat    = \"AUTH_INVALID_FORMAT\"\n31: \tErrCodeInvalidToken     = \"AUTH_INVALID_TOKEN\"\n32: \tErrCodeTokenExpired     = \"AUTH_TOKEN_EXPIRED\"\n33: \tErrCodeKeyNotConfigured = \"AUTH_KEY_NOT_CONFIGURED\"\n34: \tErrInvalidSigningMethod = errors.New(\"invalid signing method\")\n35: )\n36: \n37: type AuthManager struct {\n38: \tpublicKey *rsa.PublicKey\n39: \tmutex     sync.RWMutex\n40: }\n41: \n42: func NewAuthManager() *AuthManager {\n43: \treturn &AuthManager{}\n44: }\n45: \n46: func (am *AuthManager) LoadPublicKeyFromEnv() error {\n47: \tkeyData := os.Getenv(PublicKeyEnvVar)\n48: \tif keyData == \"\" {\n49: \t\treturn fmt.Errorf(\"environment variable %s is not set\", PublicKeyEnvVar)\n50: \t}\n51: \n52: \tblock, _ := pem.Decode([]byte(keyData))\n53: \tif block == nil {\n54: \t\treturn errors.New(\"failed to decode PEM block\")\n55: \t}\n56: \n57: \tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n58: \tif err != nil {\n59: \t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n60: \t}\n61: \n62: \trsaPubKey, ok := pubKey.(*rsa.PublicKey)\n63: \tif !ok {\n64: \t\treturn errors.New(\"public key is not an RSA key\")\n65: \t}\n66: \n67: \tam.mutex.Lock()\n68: \tam.publicKey = rsaPubKey\n69: \tam.mutex.Unlock()\n70: \n71: \treturn nil\n72: }\n73: \n74: func (am *AuthManager) GetPublicKey() *rsa.PublicKey {\n75: \tam.mutex.RLock()\n76: \tdefer am.mutex.RUnlock()\n77: \treturn am.publicKey\n78: }\n79: \n80: func (am *AuthManager) ReloadPublicKey() error {\n81: \tkeyData := os.Getenv(PublicKeyEnvVar)\n82: \tif keyData == \"\" {\n83: \t\treturn fmt.Errorf(\"environment variable %s is not set\", PublicKeyEnvVar)\n84: \t}\n85: \n86: \tblock, _ := pem.Decode([]byte(keyData))\n87: \tif block == nil {\n88: \t\treturn errors.New(\"failed to decode PEM block\")\n89: \t}\n90: \n91: \tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n92: \tif err != nil {\n93: \t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n94: \t}\n95: \n96: \trsaPubKey, ok := pubKey.(*rsa.PublicKey)\n97: \tif !ok {\n98: \t\treturn errors.New(\"public key is not an RSA key\")\n99: \t}\n100: \n101: \tam.mutex.Lock()\n102: \tam.publicKey = rsaPubKey\n103: \tam.mutex.Unlock()\n104: \n105: \tklog.Info(\"Public key reloaded successfully\")\n106: \treturn nil\n107: }\n108: \n109: func (am *AuthManager) StartKeyRotationWatcher() {\n110: \tsigChan := make(chan os.Signal, 1)\n111: \tsignal.Notify(sigChan, syscall.SIGHUP)\n112: \n113: \tgo func() {\n114: \t\tfor {\n115: \t\t\tsig := <-sigChan\n116: \t\t\tklog.Infof(\"Received signal: %v\", sig)\n117: \t\t\tif err := am.ReloadPublicKey(); err != nil {\n118: \t\t\t\tklog.Errorf(\"Failed to reload public key on SIGHUP: %v\", err)\n119: \t\t\t}\n120: \t\t}\n121: \t}()\n122: }\n123: \n124: func (am *AuthManager) AuthMiddleware() gin.HandlerFunc {\n125: \treturn func(c *gin.Context) {\n126: \t\tauthHeader := c.GetHeader(\"Authorization\")\n127: \t\tif authHeader == \"\" {\n128: \t\t\tc.AbortWithStatusJSON(401, gin.H{\n129: \t\t\t\t\"error\":  \"Missing authorization header\",\n130: \t\t\t\t\"code\":   401,\n131: \t\t\t\t\"detail\": \"JWT required: Use Bearer <token>\",\n132: \t\t\t})\n133: \t\t\treturn\n134: \t\t}\n135: \n136: \t\tparts := strings.Split(authHeader, \" \")\n137: \t\tif len(parts) != 2 || parts[0] != \"Bearer\" {\n138: \t\t\tc.AbortWithStatusJSON(401, gin.H{\n139: \t\t\t\t\"error\":  \"Invalid authorization header format\",\n140: \t\t\t\t\"code\":   401,\n141: \t\t\t\t\"detail\": \"Use Bearer <token>\",\n142: \t\t\t})\n143: \t\t\treturn\n144: \t\t}\n145: \n146: \t\ttokenString := parts[1]\n147: \n148: \t\tam.mutex.RLock()\n149: \t\tpubKey := am.publicKey\n150: \t\tam.mutex.RUnlock()\n151: \n152: \t\tif pubKey == nil {\n153: \t\t\tc.AbortWithStatusJSON(401, gin.H{\n154: \t\t\t\t\"error\":  \"Invalid token\",\n155: \t\t\t\t\"code\":   401,\n156: \t\t\t\t\"detail\": \"Public key not configured\",\n157: \t\t\t})\n158: \t\t\treturn\n159: \t\t}\n160: \n161: \t\ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n162: \t\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n163: \t\t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n164: \t\t\t}\n165: \t\t\treturn pubKey, nil\n166: \t\t}, jwt.WithExpirationRequired(), jwt.WithIssuedAt(), jwt.WithLeeway(time.Minute))\n167: \n168: \t\tif err != nil || !token.Valid {\n169: \t\t\tdetail := \"verification failed\"\n170: \t\t\tif err != nil {\n171: \t\t\t\tdetail = err.Error()\n172: \t\t\t}\n173: \t\t\tc.AbortWithStatusJSON(401, gin.H{\n174: \t\t\t\t\"error\":  \"Invalid token\",\n175: \t\t\t\t\"code\":   401,\n176: \t\t\t\t\"detail\": detail,\n177: \t\t\t})\n178: \t\t\treturn\n179: \t\t}\n180: \n181: \t\tc.Request.Body = http.MaxBytesReader(c.Writer, c.Request.Body, MaxBodySize)\n182: \t\tc.Next()\n183: \t}\n184: }\n185: \n186: func (am *AuthManager) RequireAuth() gin.HandlerFunc {\n187: \treturn func(c *gin.Context) {\n188: \t\tif err := am.LoadPublicKeyFromEnv(); err != nil {\n189: \t\t\tklog.Fatalf(\"Failed to load public key: %v\", err)\n190: \t\t}\n191: \t\tam.AuthMiddleware()(c)\n192: \t}\n193: }\n\n(End of file - total 193 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"strings\"\n\t\"sync\"\n\t\"syscall\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"k8s.io/klog/v2\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth.go","time":{"start":1775857173031,"end":1775857173045}}}}
