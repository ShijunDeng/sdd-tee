{"type":"tool_use","timestamp":1775857091187,"sessionID":"ses_286ab945dffeHMyQulcQOnOwt7","part":{"id":"prt_d7954bdce001NDjGs0iO0vBkYR","messageID":"msg_d7954a9cb001GzCCNtkMsty0us","sessionID":"ses_286ab945dffeHMyQulcQOnOwt7","type":"tool","tool":"read","callID":"toolu_e54c6cbe54fa4784863e7120","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/base64\"\n9: \t\"encoding/json\"\n10: \t\"io\"\n11: \t\"mime/multipart\"\n12: \t\"net/http\"\n13: \t\"net/http/httptest\"\n14: \t\"os\"\n15: \t\"path/filepath\"\n16: \t\"strings\"\n17: \t\"testing\"\n18: \t\"time\"\n19: \n20: \t\"github.com/gin-gonic/gin\"\n21: \t\"github.com/golang-jwt/jwt/v5\"\n22: )\n23: \n24: func init() {\n25: \tgin.SetMode(gin.TestMode)\n26: }\n27: \n28: var testRSAKey *rsa.PrivateKey\n29: \n30: func init() {\n31: \tvar err error\n32: \ttestRSAKey, err = rsa.GenerateKey(rand.Reader, 2048)\n33: \tif err != nil {\n34: \t\tpanic(\"failed to generate test RSA key: \" + err.Error())\n35: \t}\n36: }\n37: \n38: func generateTestJWT(t *testing.T, expiry time.Time) string {\n39: \tclaims := jwt.MapClaims{\n40: \t\t\"exp\": expiry.Unix(),\n41: \t\t\"iat\": time.Now().Unix(),\n42: \t}\n43: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n44: \ttokenString, err := token.SignedString(testRSAKey)\n45: \tif err != nil {\n46: \t\tt.Fatalf(\"failed to sign token: %v\", err)\n47: \t}\n48: \treturn tokenString\n49: }\n50: \n51: func setupTestServer(t *testing.T, workspace string) *Server {\n52: \tpubKey := &testRSAKey.PublicKey\n53: \n54: \tpemData := base64.StdEncoding.EncodeToString(pubKeyToBytes(t, pubKey))\n55: \tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n56: \tfor i := 0; i < len(pemData); i += 64 {\n57: \t\tend := i + 64\n58: \t\tif end > len(pemData) {\n59: \t\t\tend = len(pemData)\n60: \t\t}\n61: \t\tpemBlock += pemData[i:end] + \"\\n\"\n62: \t}\n63: \tpemBlock += \"-----END PUBLIC KEY-----\"\n64: \n65: \tos.Setenv(PublicKeyEnvVar, pemBlock)\n66: \tdefer os.Unsetenv(PublicKeyEnvVar)\n67: \n68: \ttmpDir := t.TempDir()\n69: \tif workspace != \"\" {\n70: \t\ttmpDir = workspace\n71: \t\tos.MkdirAll(tmpDir, 0755)\n72: \t}\n73: \n74: \tconfig := &Config{\n75: \t\tPort:      8080,\n76: \t\tWorkspace: tmpDir,\n77: \t}\n78: \n79: \tserver, err := NewServer(config)\n80: \tif err != nil {\n81: \t\tt.Fatalf(\"failed to create server: %v\", err)\n82: \t}\n83: \n84: \treturn server\n85: }\n86: \n87: func pubKeyToBytes(t *testing.T, pubKey *rsa.PublicKey) []byte {\n88: \tderBytes, err := x509.MarshalPKIXPublicKey(pubKey)\n89: \tif err != nil {\n90: \t\tt.Fatalf(\"failed to marshal public key: %v\", err)\n91: \t}\n92: \treturn derBytes\n93: }\n94: \n95: func createTestRequest(t *testing.T, method, path, token string, body interface{}) *http.Request {\n96: \tvar bodyReader io.Reader\n97: \tif body != nil {\n98: \t\tjsonBody, err := json.Marshal(body)\n99: \t\tif err != nil {\n100: \t\t\tt.Fatalf(\"failed to marshal body: %v\", err)\n101: \t\t}\n102: \t\tbodyReader = bytes.NewBuffer(jsonBody)\n103: \t}\n104: \n105: \treq := httptest.NewRequest(method, path, bodyReader)\n106: \treq.Header.Set(\"Content-Type\", \"application/json\")\n107: \tif token != \"\" {\n108: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n109: \t}\n110: \treturn req\n111: }\n112: \n113: func TestExecuteHandler_Success(t *testing.T) {\n114: \tserver := setupTestServer(t, \"\")\n115: \n116: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n117: \n118: \treqBody := ExecuteRequest{\n119: \t\tCommand: []string{\"echo\", \"hello\"},\n120: \t}\n121: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n122: \tw := httptest.NewRecorder()\n123: \n124: \tserver.GetEngine().ServeHTTP(w, req)\n125: \n126: \tif w.Code != http.StatusOK {\n127: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n128: \t}\n129: \n130: \tvar resp ExecuteResponse\n131: \tif err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {\n132: \t\tt.Fatalf(\"failed to unmarshal response: %v\", err)\n133: \t}\n134: \n135: \tif resp.Stdout == \"\" {\n136: \t\tt.Error(\"expected stdout to contain 'hello', got empty\")\n137: \t}\n138: }\n139: \n140: func TestExecuteHandler_EmptyCommand(t *testing.T) {\n141: \tserver := setupTestServer(t, \"\")\n142: \n143: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n144: \n145: \treqBody := ExecuteRequest{\n146: \t\tCommand: []string{},\n147: \t}\n148: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n149: \tw := httptest.NewRecorder()\n150: \n151: \tserver.GetEngine().ServeHTTP(w, req)\n152: \n153: \tif w.Code != http.StatusBadRequest {\n154: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n155: \t}\n156: \n157: \tvar resp map[string]interface{}\n158: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n159: \tif resp[\"error\"] != \"command cannot be empty\" {\n160: \t\tt.Errorf(\"expected error 'command cannot be empty', got %v\", resp[\"error\"])\n161: \t}\n162: }\n163: \n164: func TestExecuteHandler_InvalidTimeout(t *testing.T) {\n165: \tserver := setupTestServer(t, \"\")\n166: \n167: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n168: \n169: \treqBody := ExecuteRequest{\n170: \t\tCommand: []string{\"echo\", \"hello\"},\n171: \t\tTimeout: \"invalid\",\n172: \t}\n173: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n174: \tw := httptest.NewRecorder()\n175: \n176: \tserver.GetEngine().ServeHTTP(w, req)\n177: \n178: \tif w.Code != http.StatusBadRequest {\n179: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n180: \t}\n181: }\n182: \n183: func TestExecuteHandler_TimeoutExceeded(t *testing.T) {\n184: \tserver := setupTestServer(t, \"\")\n185: \n186: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n187: \n188: \treqBody := ExecuteRequest{\n189: \t\tCommand: []string{\"sleep\", \"5\"},\n190: \t\tTimeout: \"100ms\",\n191: \t}\n192: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n193: \tw := httptest.NewRecorder()\n194: \n195: \tserver.GetEngine().ServeHTTP(w, req)\n196: \n197: \tif w.Code != http.StatusOK {\n198: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n199: \t}\n200: \n201: \tvar resp ExecuteResponse\n202: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n203: \n204: \tif resp.ExitCode != TimeoutExitCode {\n205: \t\tt.Errorf(\"expected exit code %d, got %d\", TimeoutExitCode, resp.ExitCode)\n206: \t}\n207: }\n208: \n209: func TestExecuteHandler_CustomTimeout(t *testing.T) {\n210: \tserver := setupTestServer(t, \"\")\n211: \n212: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n213: \n214: \treqBody := ExecuteRequest{\n215: \t\tCommand: []string{\"echo\", \"hello\"},\n216: \t\tTimeout: \"5s\",\n217: \t}\n218: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n219: \tw := httptest.NewRecorder()\n220: \n221: \tserver.GetEngine().ServeHTTP(w, req)\n222: \n223: \tif w.Code != http.StatusOK {\n224: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n225: \t}\n226: \n227: \tvar resp ExecuteResponse\n228: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n229: \n230: \tif resp.ExitCode != 0 {\n231: \t\tt.Errorf(\"expected exit code 0, got %d\", resp.ExitCode)\n232: \t}\n233: }\n234: \n235: func TestExecuteHandler_WorkingDir(t *testing.T) {\n236: \ttmpDir := t.TempDir()\n237: \ttestDir := filepath.Join(tmpDir, \"testdir\")\n238: \tos.MkdirAll(testDir, 0755)\n239: \n240: \tserver := setupTestServer(t, tmpDir)\n241: \n242: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n243: \n244: \treqBody := ExecuteRequest{\n245: \t\tCommand:    []string{\"pwd\"},\n246: \t\tWorkingDir: \"testdir\",\n247: \t}\n248: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n249: \tw := httptest.NewRecorder()\n250: \n251: \tserver.GetEngine().ServeHTTP(w, req)\n252: \n253: \tif w.Code != http.StatusOK {\n254: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n255: \t}\n256: \n257: \tvar resp ExecuteResponse\n258: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n259: \n260: \tif !strings.Contains(resp.Stdout, \"testdir\") {\n261: \t\tt.Errorf(\"expected working dir in stdout, got: %s\", resp.Stdout)\n262: \t}\n263: }\n264: \n265: func TestExecuteHandler_InvalidWorkingDir(t *testing.T) {\n266: \tserver := setupTestServer(t, \"\")\n267: \n268: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n269: \n270: \treqBody := ExecuteRequest{\n271: \t\tCommand:    []string{\"pwd\"},\n272: \t\tWorkingDir: \"../etc\",\n273: \t}\n274: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n275: \tw := httptest.NewRecorder()\n276: \n277: \tserver.GetEngine().ServeHTTP(w, req)\n278: \n279: \tif w.Code != http.StatusBadRequest {\n280: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n281: \t}\n282: }\n283: \n284: func TestExecuteHandler_MalformedJSON(t *testing.T) {\n285: \tserver := setupTestServer(t, \"\")\n286: \n287: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n288: \n289: \treq := httptest.NewRequest(\"POST\", \"/api/execute\", strings.NewReader(\"{invalid json\"))\n290: \treq.Header.Set(\"Content-Type\", \"application/json\")\n291: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n292: \tw := httptest.NewRecorder()\n293: \n294: \tserver.GetEngine().ServeHTTP(w, req)\n295: \n296: \tif w.Code != http.StatusBadRequest {\n297: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n298: \t}\n299: }\n300: \n301: func TestExecuteHandler_Env(t *testing.T) {\n302: \tserver := setupTestServer(t, \"\")\n303: \n304: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n305: \n306: \treqBody := ExecuteRequest{\n307: \t\tCommand: []string{\"sh\", \"-c\", \"echo $TEST_VAR\"},\n308: \t\tEnv:     map[string]string{\"TEST_VAR\": \"hello\"},\n309: \t}\n310: \treq := createTestRequest(t, \"POST\", \"/api/execute\", token, reqBody)\n311: \tw := httptest.NewRecorder()\n312: \n313: \tserver.GetEngine().ServeHTTP(w, req)\n314: \n315: \tif w.Code != http.StatusOK {\n316: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n317: \t}\n318: \n319: \tvar resp ExecuteResponse\n320: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n321: \n322: \tif !strings.Contains(resp.Stdout, \"hello\") {\n323: \t\tt.Errorf(\"expected 'hello' in stdout, got: %s\", resp.Stdout)\n324: \t}\n325: }\n326: \n327: func TestHealthCheckHandler(t *testing.T) {\n328: \tserver := setupTestServer(t, \"\")\n329: \n330: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n331: \tw := httptest.NewRecorder()\n332: \n333: \tserver.GetEngine().ServeHTTP(w, req)\n334: \n335: \tif w.Code != http.StatusOK {\n336: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n337: \t}\n338: \n339: \tvar resp map[string]interface{}\n340: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n341: \n342: \tif resp[\"status\"] != \"ok\" {\n343: \t\tt.Errorf(\"expected status 'ok', got %v\", resp[\"status\"])\n344: \t}\n345: \tif resp[\"service\"] != \"PicoD\" {\n346: \t\tt.Errorf(\"expected service 'PicoD', got %v\", resp[\"service\"])\n347: \t}\n348: \tif resp[\"version\"] != \"0.0.1\" {\n349: \t\tt.Errorf(\"expected version '0.0.1', got %v\", resp[\"version\"])\n350: \t}\n351: }\n352: \n353: func TestAuthMiddleware_MissingHeader(t *testing.T) {\n354: \tserver := setupTestServer(t, \"\")\n355: \n356: \treqBody := ExecuteRequest{\n357: \t\tCommand: []string{\"echo\", \"hello\"},\n358: \t}\n359: \treq := createTestRequest(t, \"POST\", \"/api/execute\", \"\", reqBody)\n360: \tw := httptest.NewRecorder()\n361: \n362: \tserver.GetEngine().ServeHTTP(w, req)\n363: \n364: \tif w.Code != http.StatusUnauthorized {\n365: \t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n366: \t}\n367: }\n368: \n369: func TestAuthMiddleware_InvalidFormat(t *testing.T) {\n370: \tserver := setupTestServer(t, \"\")\n371: \n372: \treqBody := ExecuteRequest{\n373: \t\tCommand: []string{\"echo\", \"hello\"},\n374: \t}\n375: \treq := createTestRequest(t, \"POST\", \"/api/execute\", \"InvalidFormat\", reqBody)\n376: \tw := httptest.NewRecorder()\n377: \n378: \tserver.GetEngine().ServeHTTP(w, req)\n379: \n380: \tif w.Code != http.StatusUnauthorized {\n381: \t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n382: \t}\n383: }\n384: \n385: func TestAuthMiddleware_InvalidToken(t *testing.T) {\n386: \tserver := setupTestServer(t, \"\")\n387: \n388: \treqBody := ExecuteRequest{\n389: \t\tCommand: []string{\"echo\", \"hello\"},\n390: \t}\n391: \treq := createTestRequest(t, \"POST\", \"/api/execute\", \"Bearer invalidtoken\", reqBody)\n392: \tw := httptest.NewRecorder()\n393: \n394: \tserver.GetEngine().ServeHTTP(w, req)\n395: \n396: \tif w.Code != http.StatusUnauthorized {\n397: \t\tt.Errorf(\"expected status 401, got %d\", w.Code)\n398: \t}\n399: }\n400: \n401: func TestListFilesHandler_Success(t *testing.T) {\n402: \ttmpDir := t.TempDir()\n403: \tos.MkdirAll(filepath.Join(tmpDir, \"subdir\"), 0755)\n404: \tos.WriteFile(filepath.Join(tmpDir, \"test.txt\"), []byte(\"hello\"), 0644)\n405: \n406: \tserver := setupTestServer(t, tmpDir)\n407: \n408: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n409: \n410: \treq := httptest.NewRequest(\"GET\", \"/api/files?path=.\", nil)\n411: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n412: \tw := httptest.NewRecorder()\n413: \n414: \tserver.GetEngine().ServeHTTP(w, req)\n415: \n416: \tif w.Code != http.StatusOK {\n417: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n418: \t}\n419: \n420: \tvar resp ListFilesResponse\n421: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n422: \n423: \tif len(resp.Files) == 0 {\n424: \t\tt.Error(\"expected files in response, got empty\")\n425: \t}\n426: }\n427: \n428: func TestListFilesHandler_MissingPath(t *testing.T) {\n429: \tserver := setupTestServer(t, \"\")\n430: \n431: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n432: \n433: \treq := httptest.NewRequest(\"GET\", \"/api/files\", nil)\n434: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n435: \tw := httptest.NewRecorder()\n436: \n437: \tserver.GetEngine().ServeHTTP(w, req)\n438: \n439: \tif w.Code != http.StatusBadRequest {\n440: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n441: \t}\n442: }\n443: \n444: func TestListFilesHandler_NotFound(t *testing.T) {\n445: \tserver := setupTestServer(t, \"\")\n446: \n447: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n448: \n449: \treq := httptest.NewRequest(\"GET\", \"/api/files?path=nonexistent\", nil)\n450: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n451: \tw := httptest.NewRecorder()\n452: \n453: \tserver.GetEngine().ServeHTTP(w, req)\n454: \n455: \tif w.Code != http.StatusNotFound {\n456: \t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n457: \t}\n458: }\n459: \n460: func TestUploadFileHandler_JSON_Success(t *testing.T) {\n461: \ttmpDir := t.TempDir()\n462: \tserver := setupTestServer(t, tmpDir)\n463: \n464: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n465: \n466: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"hello world\"))\n467: \treqBody := UploadFileRequest{\n468: \t\tPath:    \"test.txt\",\n469: \t\tContent: content,\n470: \t}\n471: \n472: \tjsonBody, _ := json.Marshal(reqBody)\n473: \treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n474: \treq.Header.Set(\"Content-Type\", \"application/json\")\n475: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n476: \tw := httptest.NewRecorder()\n477: \n478: \tserver.GetEngine().ServeHTTP(w, req)\n479: \n480: \tif w.Code != http.StatusOK {\n481: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n482: \t}\n483: \n484: \tvar resp FileInfo\n485: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n486: \n487: \tif resp.Path != \"test.txt\" {\n488: \t\tt.Errorf(\"expected path 'test.txt', got %s\", resp.Path)\n489: \t}\n490: }\n491: \n492: func TestUploadFileHandler_JSON_InvalidBase64(t *testing.T) {\n493: \tserver := setupTestServer(t, \"\")\n494: \n495: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n496: \n497: \treqBody := UploadFileRequest{\n498: \t\tPath:    \"test.txt\",\n499: \t\tContent: \"not-valid-base64!!!\",\n500: \t}\n501: \n502: \tjsonBody, _ := json.Marshal(reqBody)\n503: \treq := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(jsonBody))\n504: \treq.Header.Set(\"Content-Type\", \"application/json\")\n505: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n506: \tw := httptest.NewRecorder()\n507: \n508: \tserver.GetEngine().ServeHTTP(w, req)\n509: \n510: \tif w.Code != http.StatusBadRequest {\n511: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n512: \t}\n513: }\n514: \n515: func TestUploadFileHandler_Multipart_Success(t *testing.T) {\n516: \ttmpDir := t.TempDir()\n517: \tserver := setupTestServer(t, tmpDir)\n518: \n519: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n520: \n521: \tvar b bytes.Buffer\n522: \twr := multipart.NewWriter(&b)\n523: \twr.WriteField(\"path\", \"test.txt\")\n524: \tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n525: \tfw.Write([]byte(\"hello world\"))\n526: \twr.Close()\n527: \n528: \treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n529: \treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n530: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n531: \tw := httptest.NewRecorder()\n532: \n533: \tserver.GetEngine().ServeHTTP(w, req)\n534: \n535: \tif w.Code != http.StatusOK {\n536: \t\tt.Errorf(\"expected status 200, got %d: %s\", w.Code, w.Body.String())\n537: \t}\n538: }\n539: \n540: func TestUploadFileHandler_Multipart_MissingPath(t *testing.T) {\n541: \tserver := setupTestServer(t, \"\")\n542: \n543: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n544: \n545: \tvar b bytes.Buffer\n546: \twr := multipart.NewWriter(&b)\n547: \tfw, _ := wr.CreateFormFile(\"file\", \"test.txt\")\n548: \tfw.Write([]byte(\"hello world\"))\n549: \twr.Close()\n550: \n551: \treq := httptest.NewRequest(\"POST\", \"/api/files\", &b)\n552: \treq.Header.Set(\"Content-Type\", wr.FormDataContentType())\n553: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n554: \tw := httptest.NewRecorder()\n555: \n556: \tserver.GetEngine().ServeHTTP(w, req)\n557: \n558: \tif w.Code != http.StatusBadRequest {\n559: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n560: \t}\n561: }\n562: \n563: func TestDownloadFileHandler_Success(t *testing.T) {\n564: \ttmpDir := t.TempDir()\n565: \tos.WriteFile(filepath.Join(tmpDir, \"test.txt\"), []byte(\"hello world\"), 0644)\n566: \n567: \tserver := setupTestServer(t, tmpDir)\n568: \n569: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n570: \n571: \treq := httptest.NewRequest(\"GET\", \"/api/files/test.txt\", nil)\n572: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n573: \tw := httptest.NewRecorder()\n574: \n575: \tserver.GetEngine().ServeHTTP(w, req)\n576: \n577: \tif w.Code != http.StatusOK {\n578: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n579: \t}\n580: \n581: \tif w.Body.String() != \"hello world\" {\n582: \t\tt.Errorf(\"expected 'hello world', got %s\", w.Body.String())\n583: \t}\n584: }\n585: \n586: func TestDownloadFileHandler_NotFound(t *testing.T) {\n587: \tserver := setupTestServer(t, \"\")\n588: \n589: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n590: \n591: \treq := httptest.NewRequest(\"GET\", \"/api/files/nonexistent.txt\", nil)\n592: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n593: \tw := httptest.NewRecorder()\n594: \n595: \tserver.GetEngine().ServeHTTP(w, req)\n596: \n597: \tif w.Code != http.StatusNotFound {\n598: \t\tt.Errorf(\"expected status 404, got %d\", w.Code)\n599: \t}\n600: }\n601: \n602: func TestDownloadFileHandler_Directory(t *testing.T) {\n603: \ttmpDir := t.TempDir()\n604: \tos.MkdirAll(filepath.Join(tmpDir, \"mydir\"), 0755)\n605: \n606: \tserver := setupTestServer(t, tmpDir)\n607: \n608: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n609: \n610: \treq := httptest.NewRequest(\"GET\", \"/api/files/mydir\", nil)\n611: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n612: \tw := httptest.NewRecorder()\n613: \n614: \tserver.GetEngine().ServeHTTP(w, req)\n615: \n616: \tif w.Code != http.StatusBadRequest {\n617: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n618: \t}\n619: }\n620: \n621: func TestDownloadFileHandler_EscapeWorkspace(t *testing.T) {\n622: \tserver := setupTestServer(t, \"\")\n623: \n624: \ttoken := generateTestJWT(t, time.Now().Add(time.Hour))\n625: \n626: \treq := httptest.NewRequest(\"GET\", \"/api/files/../../../etc/passwd\", nil)\n627: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n628: \tw := httptest.NewRecorder()\n629: \n630: \tserver.GetEngine().ServeHTTP(w, req)\n631: \n632: \tif w.Code != http.StatusBadRequest {\n633: \t\tt.Errorf(\"expected status 400, got %d\", w.Code)\n634: \t}\n635: }\n636: \n637: func TestSanitizePath(t *testing.T) {\n638: \ttmpDir := t.TempDir()\n639: \tos.MkdirAll(filepath.Join(tmpDir, \"subdir\"), 0755)\n640: \n641: \tserver := setupTestServer(t, tmpDir)\n642: \n643: \ttests := []struct {\n644: \t\tname    string\n645: \t\tinput   string\n646: \t\twantErr bool\n647: \t}{\n648: \t\t{\"valid relative\", \"subdir\", false},\n649: \t\t{\"valid nested\", \"subdir/nested\", false},\n650: \t\t{\"escape attempt\", \"../etc\", true},\n651: \t\t{\"absolute path\", \"/etc/passwd\", false},\n652: \t}\n653: \n654: \tfor _, tt := range tests {\n655: \t\tt.Run(tt.name, func(t *testing.T) {\n656: \t\t\t_, err := server.sanitizePath(tt.input)\n657: \t\t\tif (err != nil) != tt.wantErr {\n658: \t\t\t\tt.Errorf(\"sanitizePath() error = %v, wantErr %v\", err, tt.wantErr)\n659: \t\t\t}\n660: \t\t})\n661: \t}\n662: }\n663: \n664: func TestParseFileMode(t *testing.T) {\n665: \ttests := []struct {\n666: \t\tinput    string\n667: \t\texpected os.FileMode\n668: \t}{\n669: \t\t{\"\", 0644},\n670: \t\t{\"0777\", 0777},\n671: \t\t{\"0644\", 0644},\n672: \t\t{\"invalid\", 0644},\n673: \t\t{\"09999\", 0644},\n674: \t}\n675: \n676: \tfor _, tt := range tests {\n677: \t\tresult := parseFileMode(tt.input)\n678: \t\tif result != tt.expected {\n679: \t\t\tt.Errorf(\"parseFileMode(%q) = %o, expected %o\", tt.input, result, tt.expected)\n680: \t\t}\n681: \t}\n682: }\n683: \n684: func TestConfig_Validate(t *testing.T) {\n685: \ttests := []struct {\n686: \t\tconfig  Config\n687: \t\twantErr bool\n688: \t}{\n689: \t\t{Config{Port: 8080}, false},\n690: \t\t{Config{Port: 0}, true},\n691: \t\t{Config{Port: 70000}, true},\n692: \t}\n693: \n694: \tfor _, tt := range tests {\n695: \t\terr := tt.config.Validate()\n696: \t\tif (err != nil) != tt.wantErr {\n697: \t\t\tt.Errorf(\"Config.Validate() error = %v, wantErr %v\", err, tt.wantErr)\n698: \t\t}\n699: \t}\n700: }\n701: \n702: func TestNewAuthManager_LoadPublicKeyFromEnv(t *testing.T) {\n703: \tpubKey := &testRSAKey.PublicKey\n704: \n705: \tderBytes, _ := x509.MarshalPKIXPublicKey(pubKey)\n706: \tpemData := base64.StdEncoding.EncodeToString(derBytes)\n707: \tpemBlock := \"-----BEGIN PUBLIC KEY-----\\n\"\n708: \tfor i := 0; i < len(pemData); i += 64 {\n709: \t\tend := i + 64\n710: \t\tif end > len(pemData) {\n711: \t\t\tend = len(pemData)\n712: \t\t}\n713: \t\tpemBlock += pemData[i:end] + \"\\n\"\n714: \t}\n715: \tpemBlock += \"-----END PUBLIC KEY-----\"\n716: \n717: \tos.Setenv(PublicKeyEnvVar, pemBlock)\n718: \tdefer os.Unsetenv(PublicKeyEnvVar)\n719: \n720: \tam := NewAuthManager()\n721: \terr := am.LoadPublicKeyFromEnv()\n722: \tif err != nil {\n723: \t\tt.Errorf(\"LoadPublicKeyFromEnv() error = %v\", err)\n724: \t}\n725: \n726: \tif am.GetPublicKey() == nil {\n727: \t\tt.Error(\"expected public key to be loaded\")\n728: \t}\n729: }\n730: \n731: func TestNewAuthManager_LoadPublicKeyFromEnv_Empty(t *testing.T) {\n732: \tos.Unsetenv(PublicKeyEnvVar)\n733: \n734: \tam := NewAuthManager()\n735: \terr := am.LoadPublicKeyFromEnv()\n736: \n737: \tif err == nil {\n738: \t\tt.Error(\"expected error for empty env var\")\n739: \t}\n740: }\n741: \n742: func TestExecuteContext_TimeoutExitCode(t *testing.T) {\n743: \tif TimeoutExitCode != 124 {\n744: \t\tt.Errorf(\"expected TimeoutExitCode to be 124, got %d\", TimeoutExitCode)\n745: \t}\n746: }\n747: \n748: func TestDefaultTimeout(t *testing.T) {\n749: \texpected := 60 * time.Second\n750: \tif DefaultTimeout != expected {\n751: \t\tt.Errorf(\"expected DefaultTimeout to be %v, got %v\", expected, DefaultTimeout)\n752: \t}\n753: }\n754: \n755: func TestAuthManager_InvalidPublicKey(t *testing.T) {\n756: \tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n757: \tdefer os.Unsetenv(PublicKeyEnvVar)\n758: \n759: \tam := NewAuthManager()\n760: \terr := am.LoadPublicKeyFromEnv()\n761: \n762: \tif err == nil {\n763: \t\tt.Error(\"expected error for invalid PEM data\")\n764: \t}\n765: }\n766: \n767: func TestServer_Run_GracefulShutdown(t *testing.T) {\n768: \ttmpDir := t.TempDir()\n769: \tserver := setupTestServer(t, tmpDir)\n770: \n771: \tserver.config.Port = 18080\n772: \n773: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n774: \tw := httptest.NewRecorder()\n775: \n776: \tserver.GetEngine().ServeHTTP(w, req)\n777: \n778: \tif w.Code != http.StatusOK {\n779: \t\tt.Errorf(\"expected status 200, got %d\", w.Code)\n780: \t}\n781: }\n\n(End of file - total 781 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"bytes\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/picod_test.go","time":{"start":1775857091160,"end":1775857091184}}}}
