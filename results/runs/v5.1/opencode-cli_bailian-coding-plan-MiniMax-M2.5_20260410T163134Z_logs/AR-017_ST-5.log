 \t}\n \n-\ts.registerRoutes()\n+\ts.registerRoutes(publicPaths)\n \n \treturn s, nil\n }\n \n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/server.go","before":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tengine       *gin.Engine\n\tconfig       Config\n\tauthManager  *AuthManager\n\tstartTime    time.Time\n\tworkspaceDir string\n}\n\nfunc NewServer(config *Config) (*Server, error) {\n\tif err := config.Validate(); err != nil {\n\t\treturn nil, fmt.Errorf(\"invalid config: %w\", err)\n\t}\n\n\tgin.SetMode(gin.ReleaseMode)\n\tengine := gin.New()\n\tengine.Use(gin.Logger(), gin.Recovery())\n\n\ts := &Server{\n\t\tengine:    engine,\n\t\tconfig:    *config,\n\t\tstartTime: time.Now(),\n\t}\n\n\ts.authManager = NewAuthManager()\n\tif err := s.authManager.LoadPublicKeyFromEnv(); err != nil {\n\t\tklog.Fatalf(\"Failed to load public key: %v\", err)\n\t}\n\n\tif err := s.setWorkspace(config.Workspace); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to set workspace: %w\", err)\n\t}\n\n\ts.registerRoutes()\n\n\treturn s, nil\n}\n\nfunc (s *Server) setWorkspace(workspace string) error {\n\tvar err error\n\tvar absWorkspace string\n\n\tif workspace != \"\" {\n\t\tabsWorkspace, err = filepath.Abs(workspace)\n\t\tif err != nil {\n\t\t\tabsWorkspace = workspace\n\t\t}\n\t} else {\n\t\tabsWorkspace, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"failed to get current working directory: %w\", err)\n\t\t}\n\t}\n\n\tresolved, err := filepath.EvalSymlinks(absWorkspace)\n\tif err != nil {\n\t\tresolved, _ = filepath.Abs(absWorkspace)\n\t\tif resolved == \"\" {\n\t\t\tresolved = filepath.Clean(absWorkspace)\n\t\t}\n\t}\n\n\ts.workspaceDir = filepath.Clean(resolved)\n\n\tif err := os.MkdirAll(s.workspaceDir, 0755); err != nil {\n\t\treturn fmt.Errorf(\"failed to create workspace directory: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *Server) sanitizePath(p string) (string, error) {\n\tif s.workspaceDir == \"\" {\n\t\treturn \"\", errors.New(\"workspace directory not initialized\")\n\t}\n\n\tresolvedWorkspace := s.workspaceDir\n\tif evalSym, err := filepath.EvalSymlinks(s.workspaceDir); err == nil {\n\t\tresolvedWorkspace = evalSym\n\t}\n\tresolvedWorkspace = filepath.Clean(resolvedWorkspace)\n\n\tcleanPath := filepath.Clean(p)\n\tif filepath.IsAbs(cleanPath) {\n\t\tcleanPath = strings.TrimPrefix(cleanPath, string(os.PathSeparator))\n\t}\n\n\tfullPathCandidate := filepath.Clean(filepath.Join(resolvedWorkspace, cleanPath))\n\n\trelPath, relErr := filepath.Rel(resolvedWorkspace, fullPathCandidate)\n\tif relErr != nil {\n\t\treturn \"\", errors.New(\"access denied: path resolution failed\")\n\t}\n\n\tsep := string(os.PathSeparator)\n\tif strings.HasPrefix(relPath, \"..\"+sep) || relPath == \"..\" {\n\t\treturn \"\", errors.New(\"access denied: path escapes workspace\")\n\t}\n\n\tresolvedFinalPath, err := filepath.EvalSymlinks(fullPathCandidate)\n\tif err != nil {\n\t\treturn fullPathCandidate, nil\n\t}\n\n\tcheckRel, checkErr := filepath.Rel(resolvedWorkspace, resolvedFinalPath)\n\tif checkErr != nil {\n\t\treturn \"\", errors.New(\"access denied: path escape detected\")\n\t}\n\n\tif strings.HasPrefix(checkRel, \"..\"+sep) || checkRel == \"..\" {\n\t\treturn \"\", errors.New(\"access denied: path escapes workspace\")\n\t}\n\n\treturn resolvedFinalPath, nil\n}\n\nfunc (s *Server) registerRoutes() {\n\tapi := s.engine.Group(\"/api\")\n\tapi.Use(s.authManager.AuthMiddleware())\n\t{\n\t\tapi.POST(\"/execute\", s.ExecuteHandler)\n\t\tapi.POST(\"/files\", s.UploadFileHandler)\n\t\tapi.GET(\"/files\", s.ListFilesHandler)\n\t\tapi.GET(\"/files/*path\", s.DownloadFileHandler)\n\t}\n\n\ts.engine.GET(\"/health\", s.HealthCheckHandler)\n}\n\nfunc (s *Server) Run() error {\n\tserver := &http.Server{\n\t\tAddr:              fmt.Sprintf(\":%d\", s.config.Port),\n\t\tHandler:           s.engine,\n\t\tReadHeaderTimeout: 10 * time.Second,\n\t}\n\n\tklog.Infof(\"Starting PicoD server on port %d\", s.config.Port)\n\treturn server.ListenAndServe()\n}\n\nfunc (s *Server) GetEngine() *gin.Engine {\n\treturn s.engine\n}\n\nfunc (s *Server) GetWorkspaceDir() string {\n\treturn s.workspaceDir\n}\n\nfunc (s *Server) GetConfig() Config {\n\treturn s.config\n}\n\nfunc LoadRSAPublicKey(pemData string) (*rsa.PublicKey, error) {\n\tblock, _ := pem.Decode([]byte(pemData))\n\tif block == nil {\n\t\treturn nil, errors.New(\"failed to decode PEM block\")\n\t}\n\n\tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n\t}\n\n\trsaPubKey, ok := pubKey.(*rsa.PublicKey)\n\tif !ok {\n\t\treturn nil, errors.New(\"public key is not an RSA key\")\n\t}\n\n\treturn rsaPubKey, nil\n}\n","after":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tengine       *gin.Engine\n\tconfig       Config\n\tauthConfig   *AuthConfig\n\tauthManager  *AuthManager\n\tstartTime    time.Time\n\tworkspaceDir string\n}\n\nfunc NewServer(config *Config, authConfig *AuthConfig) (*Server, error) {\n\tif err := config.Validate(); err != nil {\n\t\treturn nil, fmt.Errorf(\"invalid config: %w\", err)\n\t}\n\n\tgin.SetMode(gin.ReleaseMode)\n\tengine := gin.New()\n\tengine.Use(gin.Logger(), gin.Recovery())\n\n\ts := &Server{\n\t\tengine:     engine,\n\t\tconfig:     *config,\n\t\tauthConfig: authConfig,\n\t\tstartTime:  time.Now(),\n\t}\n\n\ts.authManager = NewAuthManager()\n\tif err := s.authManager.LoadPublicKeyFromEnv(); err != nil {\n\t\tklog.Fatalf(\"Failed to load public key: %v\", err)\n\t}\n\n\tpublicPaths := []string{DefaultPublicPath}\n\tif authConfig != nil {\n\t\tpublicPaths = authConfig.PublicPaths\n\t\ts.authManager.StartKeyRotationWatcher()\n\t}\n\n\tif err := s.setWorkspace(config.Workspace); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to set workspace: %w\", err)\n\t}\n\n\ts.registerRoutes(publicPaths)\n\n\treturn s, nil\n}\n\nfunc (s *Server) setWorkspace(workspace string) error {\n\tvar err error\n\tvar absWorkspace string\n\n\tif workspace != \"\" {\n\t\tabsWorkspace, err = filepath.Abs(workspace)\n\t\tif err != nil {\n\t\t\tabsWorkspace = workspace\n\t\t}\n\t} else {\n\t\tabsWorkspace, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"failed to get current working directory: %w\", err)\n\t\t}\n\t}\n\n\tresolved, err := filepath.EvalSymlinks(absWorkspace)\n\tif err != nil {\n\t\tresolved, _ = filepath.Abs(absWorkspace)\n\t\tif resolved == \"\" {\n\t\t\tresolved = filepath.Clean(absWorkspace)\n\t\t}\n\t}\n\n\ts.workspaceDir = filepath.Clean(resolved)\n\n\tif err := os.MkdirAll(s.workspaceDir, 0755); err != nil {\n\t\treturn fmt.Errorf(\"failed to create workspace directory: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *Server) sanitizePath(p string) (string, error) {\n\tif s.workspaceDir == \"\" {\n\t\treturn \"\", errors.New(\"workspace directory not initialized\")\n\t}\n\n\tresolvedWorkspace := s.workspaceDir\n\tif evalSym, err := filepath.EvalSymlinks(s.workspaceDir); err == nil {\n\t\tresolvedWorkspace = evalSym\n\t}\n\tresolvedWorkspace = filepath.Clean(resolvedWorkspace)\n\n\tcleanPath := filepath.Clean(p)\n\tif filepath.IsAbs(cleanPath) {\n\t\tcleanPath = strings.TrimPrefix(cleanPath, string(os.PathSeparator))\n\t}\n\n\tfullPathCandidate := filepath.Clean(filepath.Join(resolvedWorkspace, cleanPath))\n\n\trelPath, relErr := filepath.Rel(resolvedWorkspace, fullPathCandidate)\n\tif relErr != nil {\n\t\treturn \"\", errors.New(\"access denied: path resolution failed\")\n\t}\n\n\tsep := string(os.PathSeparator)\n\tif strings.HasPrefix(relPath, \"..\"+sep) || relPath == \"..\" {\n\t\treturn \"\", errors.New(\"access denied: path escapes workspace\")\n\t}\n\n\tresolvedFinalPath, err := filepath.EvalSymlinks(fullPathCandidate)\n\tif err != nil {\n\t\treturn fullPathCandidate, nil\n\t}\n\n\tcheckRel, checkErr := filepath.Rel(resolvedWorkspace, resolvedFinalPath)\n\tif checkErr != nil {\n\t\treturn \"\", errors.New(\"access denied: path escape detected\")\n\t}\n\n\tif strings.HasPrefix(checkRel, \"..\"+sep) || checkRel == \"..\" {\n\t\treturn \"\", errors.New(\"access denied: path escapes workspace\")\n\t}\n\n\treturn resolvedFinalPath, nil\n}\n\nfunc (s *Server) registerRoutes() {\n\tapi := s.engine.Group(\"/api\")\n\tapi.Use(s.authManager.AuthMiddleware())\n\t{\n\t\tapi.POST(\"/execute\", s.ExecuteHandler)\n\t\tapi.POST(\"/files\", s.UploadFileHandler)\n\t\tapi.GET(\"/files\", s.ListFilesHandler)\n\t\tapi.GET(\"/files/*path\", s.DownloadFileHandler)\n\t}\n\n\ts.engine.GET(\"/health\", s.HealthCheckHandler)\n}\n\nfunc (s *Server) Run() error {\n\tserver := &http.Server{\n\t\tAddr:              fmt.Sprintf(\":%d\", s.config.Port),\n\t\tHandler:           s.engine,\n\t\tReadHeaderTimeout: 10 * time.Second,\n\t}\n\n\tklog.Infof(\"Starting PicoD server on port %d\", s.config.Port)\n\treturn server.ListenAndServe()\n}\n\nfunc (s *Server) GetEngine() *gin.Engine {\n\treturn s.engine\n}\n\nfunc (s *Server) GetWorkspaceDir() string {\n\treturn s.workspaceDir\n}\n\nfunc (s *Server) GetConfig() Config {\n\treturn s.config\n}\n\nfunc LoadRSAPublicKey(pemData string) (*rsa.PublicKey, error) {\n\tblock, _ := pem.Decode([]byte(pemData))\n\tif block == nil {\n\t\treturn nil, errors.New(\"failed to decode PEM block\")\n\t}\n\n\tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n\t}\n\n\trsaPubKey, ok := pubKey.(*rsa.PublicKey)\n\tif !ok {\n\t\treturn nil, errors.New(\"publ