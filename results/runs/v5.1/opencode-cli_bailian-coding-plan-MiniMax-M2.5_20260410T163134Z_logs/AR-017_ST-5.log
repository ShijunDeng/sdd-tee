licKeyPath   string\n\tPublicPaths     []string\n\tAllowQueryParam bool\n\tJWTIssuer       string\n\tJWTAudience     string\n}\n\nfunc LoadAuthConfigFromEnv() (*AuthConfig, error) {\n\tconfig := &AuthConfig{\n\t\tPublicKeyPath:   os.Getenv(EnvPublicKeyPath),\n\t\tPublicPaths:     GetPublicPathsFromEnv(),\n\t\tAllowQueryParam: GetBoolEnv(EnvAllowQueryParam, false),\n\t\tJWTIssuer:       os.Getenv(EnvJWTIssuer),\n\t\tJWTAudience:     os.Getenv(EnvJWTAudience),\n\t}\n\n\tif err := config.Validate(); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn config, nil\n}\n\nfunc GetPublicPathsFromEnv() []string {\n\tenvValue := os.Getenv(EnvPublicPaths)\n\tif envValue == \"\" {\n\t\treturn []string{DefaultPublicPath}\n\t}\n\n\tpaths := strings.Split(envValue, \",\")\n\tvar result []string\n\tfor _, p := range paths {\n\t\tp = strings.TrimSpace(p)\n\t\tif p != \"\" {\n\t\t\tresult = append(result, p)\n\t\t}\n\t}\n\n\tif len(result) == 0 {\n\t\treturn []string{DefaultPublicPath}\n\t}\n\n\treturn result\n}\n\nfunc GetBoolEnv(key string, defaultValue bool) bool {\n\tval := os.Getenv(key)\n\tif val == \"\" {\n\t\treturn defaultValue\n\t}\n\treturn strings.ToLower(val) == \"true\" || val == \"1\"\n}\n\nfunc (c *AuthConfig) Validate() error {\n\tif c.PublicKeyPath == \"\" && len(c.PublicPaths) == 0 {\n\t\treturn fmt.Errorf(\"either %s must be set or public paths must be configured\", EnvPublicKeyPath)\n\t}\n\treturn nil\n}\n","after":"package picod\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n)\n\nconst (\n\tEnvPublicKeyPath   = \"PICOD_AUTH_PUBLIC_KEY\"\n\tEnvPublicPaths     = \"PICOD_AUTH_PUBLIC_PATHS\"\n\tEnvAllowQueryParam = \"PICOD_AUTH_ALLOW_QUERY_PARAM\"\n\tEnvJWTIssuer       = \"PICOD_JWT_ISSUER\"\n\tEnvJWTAudience     = \"PICOD_JWT_AUDIENCE\"\n\tDefaultPublicPath  = \"/health\"\n)\n\ntype AuthConfig struct {\n\tPublicKeyPath   string\n\tPublicPaths     []string\n\tAllowQueryParam bool\n\tJWTIssuer       string\n\tJWTAudience     string\n}\n\nfunc LoadAuthConfigFromEnv() (*AuthConfig, error) {\n\tpublicKeyPath := os.Getenv(EnvPublicKeyPath)\n\tpublicPathsEnv := os.Getenv(EnvPublicPaths)\n\tallowQueryParam := GetBoolEnv(EnvAllowQueryParam, false)\n\tjwtIssuer := os.Getenv(EnvJWTIssuer)\n\tjwtAudience := os.Getenv(EnvJWTAudience)\n\n\tpublicPaths := GetPublicPathsFromEnv()\n\n\tconfig := &AuthConfig{\n\t\tPublicKeyPath:   publicKeyPath,\n\t\tPublicPaths:     publicPaths,\n\t\tAllowQueryParam: allowQueryParam,\n\t\tJWTIssuer:       jwtIssuer,\n\t\tJWTAudience:     jwtAudience,\n\t}\n\n\tpublicKeyPathSet := publicKeyPath != \"\"\n\tpublicPathsSet := publicPathsEnv != \"\"\n\n\tif !publicKeyPathSet && !publicPathsSet {\n\t\treturn nil, fmt.Errorf(\"either %s must be set or %s must be configured\", EnvPublicKeyPath, EnvPublicPaths)\n\t}\n\n\treturn config, nil\n}\n\nfunc GetPublicPathsFromEnv() []string {\n\tenvValue := os.Getenv(EnvPublicPaths)\n\tif envValue == \"\" {\n\t\treturn []string{DefaultPublicPath}\n\t}\n\n\tpaths := strings.Split(envValue, \",\")\n\tvar result []string\n\tfor _, p := range paths {\n\t\tp = strings.TrimSpace(p)\n\t\tif p != \"\" {\n\t\t\tresult = append(result, p)\n\t\t}\n\t}\n\n\tif len(result) == 0 {\n\t\treturn []string{DefaultPublicPath}\n\t}\n\n\treturn result\n}\n\nfunc GetBoolEnv(key string, defaultValue bool) bool {\n\tval := os.Getenv(key)\n\tif val == \"\" {\n\t\treturn defaultValue\n\t}\n\treturn strings.ToLower(val) == \"true\" || val == \"1\"\n}\n\nfunc (c *AuthConfig) Validate() error {\n\tif c.PublicKeyPath == \"\" && len(c.PublicPaths) == 0 {\n\t\treturn fmt.Errorf(\"either %s must be set or public paths must be configured\", EnvPublicKeyPath)\n\t}\n\treturn nil\n}\n","additions":18,"deletions":7},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/picod/auth_config.go","time":{"start":1775857350962,"end":1775857351147}}}}
