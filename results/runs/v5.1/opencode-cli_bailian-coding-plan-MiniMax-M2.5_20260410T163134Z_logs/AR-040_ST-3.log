nes)\n</content>","metadata":{"preview":"\"\"\"Tests for agentcube HTTP utilities.\"\"\"\n\nimport pytest\n\nfrom agentcube.utils.http import (\n    DEFAULT_CONNECT_TIMEOUT,\n    DEFAULT_POOL_CONNECTIONS,\n    DEFAULT_POOL_MAXSIZE,\n    DEFAULT_TIMEOUT,\n    create_session,\n)\n\n\nclass TestHttpUtils:\n    \"\"\"Test cases for HTTP utilities.\"\"\"\n\n    def test_create_session_returns_session(self):\n        \"\"\"Test create_session returns a requests.Session.\"\"\"\n        session = create_session()\n        assert session is not None","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_http.py","time":{"start":1775883756991,"end":1775883756997}}}}
