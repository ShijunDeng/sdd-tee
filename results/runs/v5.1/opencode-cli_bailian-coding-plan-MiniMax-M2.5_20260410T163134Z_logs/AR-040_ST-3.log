t call_kwargs[\"timeout\"] == (5.0, 60)\n235:             client.close()\n236: \n237:     @patch(\"agentcube.agent_runtime.create_session\")\n238:     def test_close(self, mock_create_session):\n239:         \"\"\"Test close releases resources.\"\"\"\n240:         mock_session = Mock()\n241:         mock_response = Mock()\n242:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n243:         mock_response.raise_for_status = Mock()\n244:         mock_session.get.return_value = mock_response\n245:         mock_create_session.return_value = mock_session\n246: \n247:         client = AgentRuntimeClient(router_url=\"http://router:8080\")\n248: \n249:         with patch.object(client.dp_client, \"close\") as mock_dp_close:\n250:             client.close()\n251:             mock_dp_close.assert_called_once()\n252: \n253:         mock_session.close.assert_called_once()\n254: \n255:     @patch(\"agentcube.agent_runtime.create_session\")\n256:     def test_session_id_property(self, mock_create_session):\n257:         \"\"\"Test session_id property returns correct value.\"\"\"\n258:         mock_session = Mock()\n259:         mock_response = Mock()\n260:         mock_response.headers = {\"x-agentcube-session-id\": \"session-123\"}\n261:         mock_response.raise_for_status = Mock()\n262:         mock_session.get.return_value = mock_response\n263:         mock_create_session.return_value = mock_session\n264: \n265:         client = AgentRuntimeClient(\n266:             router_url=\"http://router:8080\",\n267:             session_id=\"custom-session\",\n268:         )\n269: \n270:         assert client.session_id == \"custom-session\"\n271:         client.close()\n272: \n273:     @patch(\"agentcube.agent_runtime.create_session\")\n274:     def test_bootstrap_session_network_error(self, mock_create_session):\n275:         \"\"\"Test SessionError is raised on network failure during bootstrap.\"\"\"\n276:         mock_session = Mock()\n277:         mock_session.get.side_effect = requests.RequestException(\"Connection failed\")\n278:         mock_create_session.return_value = mock_session\n279: \n280:         with pytest.raises(SessionError) as exc_info:\n281:             AgentRuntimeClient(router_url=\"http://router:8080\")\n282:         assert \"Session bootstrap failed\" in str(exc_info.value)\n\n(End of file - total 282 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentRuntimeClient.\"\"\"\n\nfrom unittest.mock import Mock, patch\n\nimport pytest\nimport requests\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom agentcube.exceptions import SessionError\n\n\nclass TestAgentRuntimeClient:\n    \"\"\"Test cases for AgentRuntimeClient.\"\"\"\n\n    def test_constructor_requires_router_url(self):\n        \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n        with pytest.raises(ValueError) as exc_info:\n            AgentRuntimeClient()\n        assert \"router_url\" in str(exc_info.value).lower()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_agent_runtime_client.py","time":{"start":1775883746452,"end":1775883746458}}}}
