{"type":"tool_use","timestamp":1775883727564,"sessionID":"ses_2851506ccffefkIVb2j6EWAN4H","part":{"id":"prt_d7aeb2f7d001cWoZCS012ub8E2","messageID":"msg_d7aeb1d360017z8x6diwJ4LSX1","sessionID":"ses_2851506ccffefkIVb2j6EWAN4H","type":"tool","tool":"read","callID":"toolu_7af818b310914dd0a020d596","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterClient.\"\"\"\n2: \n3: import pytest\n4: from unittest.mock import Mock, patch\n5: \n6: from agentcube.agent_runtime import AgentRuntimeClient\n7: from agentcube.code_interpreter import CodeInterpreterClient\n8: from agentcube.exceptions import (\n9:     CommandExecutionError,\n10:     DataPlaneError,\n11: )\n12: \n13: \n14: class TestCodeInterpreterClient:\n15:     \"\"\"Test cases for CodeInterpreterClient.\"\"\"\n16: \n17:     def test_constructor_requires_router_url(self):\n18:         \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n19:         with pytest.raises(ValueError) as exc_info:\n20:             CodeInterpreterClient()\n21:         assert \"router_url\" in str(exc_info.value).lower()\n22: \n23:     def test_constructor_with_env_var(self):\n24:         \"\"\"Test Router URL can be set via environment variable.\"\"\"\n25:         with patch.dict(\"os.environ\", {\"ROUTER_URL\": \"http://router:8080\"}):\n26:             with pytest.raises(Exception):\n27:                 CodeInterpreterClient()\n28: \n29:     def test_constructor_with_explicit_url(self):\n30:         \"\"\"Test Router URL can be set explicitly.\"\"\"\n31:         with patch(\"agentcube.code_interpreter.CodeInterpreterClient._create_session\"):\n32:             client = CodeInterpreterClient(\n33:                 router_url=\"http://router:8080\",\n34:                 workload_manager_url=\"http://wm:8080\",\n35:             )\n36:             assert client.router_url == \"http://router:8080\"\n37:             client.stop()\n38: \n39:     def test_constructor_default_values(self):\n40:         \"\"\"Test constructor sets default values.\"\"\"\n41:         with patch(\"agentcube.code_interpreter.CodeInterpreterClient._create_session\"):\n42:             client = CodeInterpreterClient(\n43:                 router_url=\"http://router:8080\",\n44:                 workload_manager_url=\"http://wm:8080\",\n45:             )\n46:             assert client.name == \"my-interpreter\"\n47:             assert client.namespace == \"default\"\n48:             assert client.ttl == 3600\n49:             assert client.verbose is False\n50:             client.stop()\n51: \n52:     def test_constructor_with_session_id(self):\n53:         \"\"\"Test constructor reuses existing session_id.\"\"\"\n54:         with patch(\n55:             \"agentcube.code_interpreter.CodeInterpreterClient._init_data_plane\"\n56:         ) as mock_init:\n57:             client = CodeInterpreterClient(\n58:                 router_url=\"http://router:8080\",\n59:                 workload_manager_url=\"http://wm:8080\",\n60:                 session_id=\"existing-session-123\",\n61:             )\n62:             assert client._session_id == \"existing-session-123\"\n63:             assert client._session_id_provided is True\n64:             mock_init.assert_called_once()\n65: \n66:     def test_context_manager(self):\n67:         \"\"\"Test context manager protocol.\"\"\"\n68:         with patch(\n69:             \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n70:         ) as mock_create_session:\n71:             mock_cp_client = Mock()\n72:             mock_create_session.return_value = mock_cp_client\n73: \n74:             client = CodeInterpreterClient(\n75:                 router_url=\"http://router:8080\",\n76:                 workload_manager_url=\"http://wm:8080\",\n77:             )\n78:             mock_dp_client = Mock()\n79:             client._data_plane_client = mock_dp_client\n80: \n81:             with client:\n82:                 assert client.session_id == mock_cp_client\n83:                 mock_dp_client.close.assert_not_called()\n84: \n85:             mock_dp_client.close.assert_called_once()\n86: \n87:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n88:     @patch.object(CodeInterpreterClient, \"_create_session\")\n89:     def test_data_plane_init_failure_cleanup(self, mock_create_session, mock_dp_class):\n90:         \"\"\"Test data plane init failure triggers session cleanup.\"\"\"\n91:         mock_cp_client = Mock()\n92:         mock_cp_client.delete_session.return_value = True\n93:         mock_create_session.return_value = \"session-123\"\n94: \n95:         mock_dp_class.side_effect = DataPlaneError(\"Init failed\")\n96: \n97:         client = CodeInterpreterClient(\n98:             router_url=\"http://router:8080\",\n99:             workload_manager_url=\"http://wm:8080\",\n100:         )\n101:         client._control_plane_client = mock_cp_client\n102: \n103:         with pytest.raises(DataPlaneError):\n104:             client._init_data_plane()\n105: \n106:         mock_cp_client.delete_session.assert_called_once_with(\"session-123\")\n107: \n108:     def test_execute_command_raises_on_non_zero_exit(self):\n109:         \"\"\"Test execute_command raises CommandExecutionError on non-zero exit.\"\"\"\n110:         with patch(\n111:             \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n112:         ) as mock_create_session:\n113:             mock_dp_client = Mock()\n114:             mock_dp_client.execute_command.return_value = {\n115:                 \"exit_code\": 1,\n116:                 \"stderr\": \"Command not found\",\n117:                 \"command\": \"ls /nonexistent\",\n118:             }\n119:             mock_create_session.return_value = Mock()\n120: \n121:             client = CodeInterpreterClient(\n122:                 router_url=\"http://router:8080\",\n123:                 workload_manager_url=\"http://wm:8080\",\n124:             )\n125:             client._data_plane_client = mock_dp_client\n126: \n127:             with pytest.raises(CommandExecutionError) as exc_info:\n128:                 client.execute_command(\"ls /nonexistent\")\n129: \n130:             assert exc_info.value.exit_code == 1\n131:             assert exc_info.value.stderr == \"Command not found\"\n132:             client.stop()\n133: \n134:     def test_run_code_python(self):\n135:         \"\"\"Test run_code with Python language.\"\"\"\n136:         with patch(\n137:             \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n138:         ) as mock_create_session:\n139:             mock_dp_client = Mock()\n140:             mock_dp_client.execute_command.return_value = {\n141:                 \"exit_code\": 0,\n142:                 \"stdout\": \"hello\",\n143:             }\n144:             mock_dp_client.write_file.return_value = {\"success\": True}\n145:             mock_create_session.return_value = Mock()\n146: \n147:             client = CodeInterpreterClient(\n148:                 router_url=\"http://router:8080\",\n149:                 workload_manager_url=\"http://wm:8080\",\n150:             )\n151:             client._data_plane_client = mock_dp_client\n152: \n153:             result = client.run_code(\"print('hello')\", language=\"python\")\n154: \n155:             assert result[\"exit_code\"] == 0\n156:             mock_dp_client.write_file.assert_called_once()\n157:             mock_dp_client.execute_command.assert_called_once()\n158:             client.stop()\n159: \n160:     def test_run_code_unsupported_language(self):\n161:         \"\"\"Test run_code raises ValueError for unsupported language.\"\"\"\n162:         with patch(\n163:             \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n164:         ) as mock_create_session:\n165:             mock_dp_client = Mock()\n166:             mock_create_session.return_value = Mock()\n167: \n168:             client = CodeInterpreterClient(\n169:                 router_url=\"http://router:8080\",\n170:                 workload_manager_url=\"http://wm:8080\",\n171:             )\n172:             client._data_plane_client = mock_dp_client\n173: \n174:             with pytest.raises(ValueError) as exc_info:\n175:                 client.run_code(\"code\", language=\"unsupported\")\n176: \n177:             assert \"Unsupported language\" in str(exc_info.value)\n178:             client.stop()\n179: \n180:     def test_stop_closes_clients(self):\n181:         \"\"\"Test stop closes both data plane and control plane.\"\"\"\n182:         mock_dp_client = Mock()\n183:         mock_cp_client = Mock()\n184: \n185:         client = CodeInterpreterClient(\n186:             router_url=\"http://router:8080\",\n187:             workload_manager_url=\"http://wm:8080\",\n188:             session_id=\"test-session\",\n189:         )\n190:         client._data_plane_client = mock_dp_client\n191:         client._control_plane_client = mock_cp_client\n192:         client._session_id_provided = False\n193: \n194:         client.stop()\n195: \n196:         mock_dp_client.close.assert_called_once()\n197:         mock_cp_client.delete_session.assert_called_once_with(\"test-session\")\n198:         mock_cp_client.close.assert_called_once()\n199:         assert client._data_plane_client is None\n200: \n201:     def test_session_id_property(self):\n202:         \"\"\"Test session_id property returns the session ID.\"\"\"\n203:         with patch(\n204:             \"agentcube.code_interpreter.CodeInterpreterClient._create_session\"\n205:         ) as mock_create_session:\n206:             mock_create_session.return_value = \"test-id\"\n207: \n208:             client = CodeInterpreterClient(\n209:                 router_url=\"http://router:8080\",\n210:                 workload_manager_url=\"http://wm:8080\",\n211:             )\n212:             assert client.session_id == \"test-id\"\n213:             client.stop()\n214: \n215: \n216: class TestAgentRuntimeClient:\n217:     \"\"\"Test cases for AgentRuntimeClient.\"\"\"\n218: \n219:     def test_requires_router_url(self):\n220:         \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n221:         with pytest.raises(ValueError) as exc_info:\n222:             AgentRuntimeClient()\n223:         assert \"router_url\" in str(exc_info.value).lower()\n\n(End of file - total 223 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterClient.\"\"\"\n\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.exceptions import (\n    CommandExecutionError,\n    DataPlaneError,\n)\n\n\nclass TestCodeInterpreterClient:\n    \"\"\"Test cases for CodeInterpreterClient.\"\"\"\n\n    def test_constructor_requires_router_url(self):\n        \"\"\"Test ValueError is raised when router_url is not provided.\"\"\"\n        with pytest.raises(ValueError) as exc_info:\n            CodeInterpreterClient()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter.py","time":{"start":1775883727546,"end":1775883727562}}}}
