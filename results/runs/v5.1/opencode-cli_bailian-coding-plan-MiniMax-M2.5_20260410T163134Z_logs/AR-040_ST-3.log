efault\",\n34:             agent_name=\"my-agent\",\n35:             session_id=\"test-session-123\",\n36:         )\n37:         assert client._headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n38:         client.close()\n39: \n40:     def test_base_url_construction(self):\n41:         \"\"\"Test base URL is constructed from router components.\"\"\"\n42:         client = AgentRuntimeDataPlaneClient(\n43:             router_url=\"https://router.example.com\",\n44:             namespace=\"prod\",\n45:             agent_name=\"my-agent\",\n46:         )\n47:         assert (\n48:             client.base_url\n49:             == \"https://router.example.com/v1/namespaces/prod/agent-runtimes/my-agent/invocations/\"\n50:         )\n51:         client.close()\n52: \n53:     def test_base_url_explicit(self):\n54:         \"\"\"Test explicit base_url is used when provided.\"\"\"\n55:         client = AgentRuntimeDataPlaneClient(\n56:             router_url=\"http://router:8080\",\n57:             namespace=\"default\",\n58:             agent_name=\"my-agent\",\n59:             base_url=\"http://custom.example.com/api\",\n60:         )\n61:         assert client.base_url == \"http://custom.example.com/api\"\n62:         client.close()\n63: \n64:     @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n65:     def test_invoke_success(self, mock_create_session):\n66:         \"\"\"Test invoke makes correct POST request with JSON payload.\"\"\"\n67:         mock_session = Mock()\n68:         mock_response = Mock()\n69:         mock_response.json.return_value = {\"result\": \"success\"}\n70:         mock_response.raise_for_status = Mock()\n71:         mock_session.request.return_value = mock_response\n72:         mock_create_session.return_value = mock_session\n73: \n74:         client = AgentRuntimeDataPlaneClient(\n75:             router_url=\"http://router:8080\",\n76:             namespace=\"default\",\n77:             agent_name=\"my-agent\",\n78:             session_id=\"test-session-123\",\n79:         )\n80:         client._session = mock_session\n81: \n82:         result = client.invoke(\n83:             \"session-456\", {\"tool\": \"calculator\", \"input\": {\"expression\": \"2+2\"}}\n84:         )\n85: \n86:         mock_session.request.assert_called_once()\n87:         call_args = mock_session.request.call_args\n88:         assert call_args[0][0] == \"POST\"\n89:         assert call_args[1][\"json\"] == {\"tool\": \"calculator\", \"input\": {\"expression\": \"2+2\"}}\n90:         assert call_args[1][\"headers\"][\"x-agentcube-session-id\"] == \"session-456\"\n91:         assert result == mock_response\n92:         client.close()\n93: \n94:     @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n95:     def test_invoke_with_timeout(self, mock_create_session):\n96:         \"\"\"Test invoke uses custom timeout when provided.\"\"\"\n97:         mock_session = Mock()\n98:         mock_response = Mock()\n99:         mock_response.json.return_value = {\"result\": \"success\"}\n100:         mock_response.raise_for_status = Mock()\n101:         mock_session.request.return_value = mock_response\n102:         mock_create_session.return_value = mock_session\n103: \n104:         client = AgentRuntimeDataPlaneClient(\n105:             router_url=\"http://router:8080\",\n106:             namespace=\"default\",\n107:             agent_name=\"my-agent\",\n108:             session_id=\"test-session-123\",\n109:         )\n110:         client._session = mock_session\n111: \n112:         client.invoke(\"session-456\", {\"tool\": \"test\"}, timeout=60)\n113: \n114:         call_args = mock_session.request.call_args\n115:         assert call_args[1][\"timeout\"] == (5.0, 60)\n116:         client.close()\n117: \n118:     @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n119:     def test_invoke_default_timeout(self, mock_create_session):\n120:         \"\"\"Test invoke uses default timeout tuple when timeout=None.\"\"\"\n121:         mock_session = Mock()\n122:         mock_response = Mock()\n123:         mock_response.json.return_value = {\"result\": \"success\"}\n124:         mock_response.raise_for_status = Mock()\n125:         mock_session.request.return_value = mock_response\n126:         mock_create_session.return_value = mock_session\n127: \n128:         client = AgentRuntimeDataPlaneClient(\n129:             router_url=\"http://router:8080\",\n130:             namespace=\"default\",\n131:             agent_name=\"my-agent\",\n132:             session_id=\"test-session-123\",\n133:             timeout=120,\n134:             connect_timeout=5.0,\n135:         )\n136:         client._session = mock_session\n137: \n138:         client.invoke(\"session-456\", {\"tool\": \"test\"}, timeout=None)\n139: \n140:         call_args = mock_session.request.call_args\n141:         assert call_args[1][\"timeout\"] == (5.0, 120)\n142:         client.close()\n143: \n144:     @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n145:     def test_bootstrap_session_id(self, mock_create_session):\n146:         \"\"\"Test bootstrap_session_id makes GET request and extracts session ID.\"\"\"\n147:         mock_session = Mock()\n148:         mock_response = Mock()\n149:         mock_response.headers = {\"x-agentcube-session-id\": \"bootstrapped-session-123\"}\n150:         mock_response.raise_for_status = Mock()\n151:         mock_session.request.return_value = mock_response\n152:         mock_create_session.return_value = mock_session\n153: \n154:         client = AgentRuntimeDataPlaneClient(\n155:             router_url=\"http://router:8080\",\n156:             namespace=\"default\",\n157:             agent_name=\"my-agent\",\n158:         )\n159:         client._session = mock_session\n160: \n161:         session_id = client.bootstrap_session_id()\n162: \n163:         assert session_id == \"bootstrapped-session-123\"\n164:         assert client._session_id == \"bootstrapped-session-123\"\n165:         mock_session.request.assert_called_once()\n166:         call_args = mock_session.request.call_args\n167:         assert call_args[0][0] == \"GET\"\n168:         client.close()\n169: \n170:     @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n171:     def test_bootstrap_session_id_missing_header(self, mock_create_session):\n172:         \"\"\"Test bootstrap_session_id raises error when header is missing.\"\"\"\n173:         mock_session = Mock()\n174:         mock_response = Mock()\n175:         mock_response.headers = {}\n176:         mock_response.raise_for_status = Mock()\n177:         mock_session.request.return_value = mock_response\n178:         mock_create_session.return_value = mock_session\n179: \n180:         client = AgentRuntimeDataPlaneClient(\n181:             router_url=\"http://router:8080\",\n182:             namespace=\"default\",\n183:             agent_name=\"my-agent\",\n184:         )\n185:         client._session = mock_session\n186: \n187:         with pytest.raises(DataPlaneError) as exc_info:\n188:             client.bootstrap_session_id()\n189:         assert \"x-agentcube-session-id\" in str(exc_info.value)\n190:         client.close()\n191: \n192:     @patch(\"agentcube.clients.agent_runtime_data_plane.create_session\")\n193:     def test_invoke_raises_data_plane_error(self, mock_create_session):\n194:         \"\"\"Test invoke raises DataPlaneError on request failure.\"\"\"\n195:         import requests\n196: \n197:         mock_session = Mock()\n198:         mock_session.request.side_effect = requests.RequestException(\"Connection failed\")\n199:         mock_create_session.return_value = mock_session\n200: \n201:         client = AgentRuntimeDataPlaneClient(\n202:             router_url=\"http://router:8080\",\n203:             namespace=\"default\",\n204:             agent_name=\"my-agent\",\n205:             session_id=\"test-session-123\",\n206:         )\n207:         client._session = mock_session\n208: \n209:         with pytest.raises(DataPlaneError):\n210:             client.invoke(\"session-456\", {\"tool\": \"test\"})\n211:         client.close()\n212: \n213:     def test_close(self):\n214:         \"\"\"Test close method closes the session.\"\"\"\n215:         client = AgentRuntimeDataPlaneClient(\n216:             router_url=\"http://router:8080\",\n217:             namespace=\"default\",\n218:             agent_name=\"my-agent\",\n219:         )\n220:         client._session.close = Mock()\n221:         client.close()\n222:         client._session.close.assert_called_once()\n\n(End of file - total 222 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentRuntimeDataPlaneClient.\"\"\"\n\nfrom unittest.mock import Mock, patch\n\nimport pytest\n\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom agentcube.exceptions import DataPlaneError\n\n\nclass TestAgentRuntimeDataPlaneClient:\n    \"\"\"Test cases for AgentRuntimeDataPlaneClient.\"\"\"\n\n    def test_session_header_constant(self):\n        \"\"\"Test SESSION_HEADER class constant.\"\"\"\n        assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n\n    def test_constructor_default_values(self):\n        \"\"\"Test constructor sets default values correctly.\"\"\"\n        client = AgentRuntimeDataPlaneClient(","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_agent_runtime_data_plane.py","time":{"start":1775883750486,"end":1775883750494}}}}
