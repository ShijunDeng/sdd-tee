{"type":"tool_use","timestamp":1775883741484,"sessionID":"ses_2851506ccffefkIVb2j6EWAN4H","part":{"id":"prt_d7aeb65d9001lq4V15FJc3j0b2","messageID":"msg_d7aeb5167001hHfAq3k7eEFJL9","sessionID":"ses_2851506ccffefkIVb2j6EWAN4H","type":"tool","tool":"read","callID":"toolu_183817508d1b49aa812d43d3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter_data_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter_data_plane.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n2: \n3: import pytest\n4: from unittest.mock import Mock, patch, MagicMock\n5: from pathlib import Path\n6: \n7: from agentcube.clients.code_interpreter_data_plane import (\n8:     CodeInterpreterDataPlaneClient,\n9: )\n10: from agentcube.exceptions import DataPlaneError\n11: \n12: \n13: class TestCodeInterpreterDataPlaneClient:\n14:     \"\"\"Test cases for CodeInterpreterDataPlaneClient.\"\"\"\n15: \n16:     def test_constructor_with_base_url(self):\n17:         \"\"\"Test constructor with explicit base_url.\"\"\"\n18:         client = CodeInterpreterDataPlaneClient(\n19:             router_url=\"http://router:8080\",\n20:             namespace=\"default\",\n21:             cr_name=\"my-interpreter\",\n22:             session_id=\"test-session\",\n23:             base_url=\"http://router:8080/api\",\n24:         )\n25:         assert client.base_url == \"http://router:8080/api\"\n26:         client.close()\n27: \n28:     def test_constructor_without_base_url(self):\n29:         \"\"\"Test constructor builds base_url from components.\"\"\"\n30:         client = CodeInterpreterDataPlaneClient(\n31:             router_url=\"http://router:8080\",\n32:             namespace=\"test-ns\",\n33:             cr_name=\"my-agent\",\n34:             session_id=\"test-session\",\n35:         )\n36:         assert \"test-ns\" in client.base_url\n37:         assert \"my-agent\" in client.base_url\n38:         assert \"invocations\" in client.base_url\n39:         client.close()\n40: \n41:     def test_constructor_session_header(self):\n42:         \"\"\"Test constructor sets x-agentcube-session-id header.\"\"\"\n43:         client = CodeInterpreterDataPlaneClient(\n44:             router_url=\"http://router:8080\",\n45:             namespace=\"default\",\n46:             cr_name=\"my-interpreter\",\n47:             session_id=\"test-session-123\",\n48:         )\n49:         assert client._headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n50:         client.close()\n51: \n52:     def test_constructor_default_values(self):\n53:         \"\"\"Test constructor sets default values.\"\"\"\n54:         client = CodeInterpreterDataPlaneClient(\n55:             router_url=\"http://router:8080\",\n56:             namespace=\"default\",\n57:             cr_name=\"my-interpreter\",\n58:             session_id=\"test-session\",\n59:         )\n60:         assert client.timeout == 120\n61:         assert client.connect_timeout == 5.0\n62:         client.close()\n63: \n64:     def test_execute_command(self):\n65:         \"\"\"Test execute_command makes POST request.\"\"\"\n66:         client = CodeInterpreterDataPlaneClient(\n67:             router_url=\"http://router:8080\",\n68:             namespace=\"default\",\n69:             cr_name=\"my-interpreter\",\n70:             session_id=\"test-session\",\n71:         )\n72: \n73:         mock_response = Mock()\n74:         mock_response.json.return_value = {\n75:             \"exit_code\": 0,\n76:             \"stdout\": \"hello\",\n77:             \"stderr\": \"\",\n78:         }\n79: \n80:         with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n81:             result = client.execute_command(\"ls -la\")\n82: \n83:             assert result == \"hello\"\n84:             mock_request.assert_called_once()\n85:         client.close()\n86: \n87:     def test_execute_command_with_list(self):\n88:         \"\"\"Test execute_command works with list of arguments.\"\"\"\n89:         client = CodeInterpreterDataPlaneClient(\n90:             router_url=\"http://router:8080\",\n91:             namespace=\"default\",\n92:             cr_name=\"my-interpreter\",\n93:             session_id=\"test-session\",\n94:         )\n95: \n96:         mock_response = Mock()\n97:         mock_response.json.return_value = {\n98:             \"exit_code\": 0,\n99:             \"stdout\": \"test output\",\n100:             \"stderr\": \"\",\n101:         }\n102: \n103:         with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n104:             result = client.execute_command([\"ls\", \"-la\", \"/tmp\"])\n105: \n106:             assert result == \"test output\"\n107:             call_kwargs = mock_request.call_args.kwargs\n108:             assert call_kwargs[\"json\"][\"command\"] == [\"ls\", \"-la\", \"/tmp\"]\n109:         client.close()\n110: \n111:     def test_execute_command_with_timeout(self):\n112:         \"\"\"Test execute_command uses custom timeout.\"\"\"\n113:         client = CodeInterpreterDataPlaneClient(\n114:             router_url=\"http://router:8080\",\n115:             namespace=\"default\",\n116:             cr_name=\"my-interpreter\",\n117:             session_id=\"test-session\",\n118:             timeout=60,\n119:         )\n120: \n121:         mock_response = Mock()\n122:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n123: \n124:         with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n125:             client.execute_command(\"ls\", timeout=30)\n126: \n127:             call_kwargs = mock_request.call_args.kwargs\n128:             assert call_kwargs[\"timeout\"] == (5.0, 32.0)  # 30 + 2\n129:         client.close()\n130: \n131:     def test_run_code(self):\n132:         \"\"\"Test run_code makes POST request with language and code.\"\"\"\n133:         client = CodeInterpreterDataPlaneClient(\n134:             router_url=\"http://router:8080\",\n135:             namespace=\"default\",\n136:             cr_name=\"my-interpreter\",\n137:             session_id=\"test-session\",\n138:         )\n139: \n140:         mock_response = Mock()\n141:         mock_response.json.return_value = {\n142:             \"exit_code\": 0,\n143:             \"stdout\": \"Hello World\",\n144:             \"stderr\": \"\",\n145:         }\n146: \n147:         with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n148:             result = client.run_code(\"python\", \"print('Hello World')\")\n149: \n150:             assert result == \"Hello World\"\n151:             call_kwargs = mock_request.call_args.kwargs\n152:             assert call_kwargs[\"json\"][\"command\"] == [\"python\", \"-c\", \"print('Hello World')\"]\n153:         client.close()\n154: \n155:     def test_run_code_with_timeout(self):\n156:         \"\"\"Test run_code uses custom timeout.\"\"\"\n157:         client = CodeInterpreterDataPlaneClient(\n158:             router_url=\"http://router:8080\",\n159:             namespace=\"default\",\n160:             cr_name=\"my-interpreter\",\n161:             session_id=\"test-session\",\n162:             timeout=60,\n163:         )\n164: \n165:         mock_response = Mock()\n166:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n167: \n168:         with patch.object(client, \"_request\", return_value=mock_response) as mock_request:\n169:             client.run_code(\"python\", \"print('test')\", timeout=30)\n170: \n171:             call_kwargs = mock_request.call_args.kwargs\n172:             assert call_kwargs[\"timeout\"] == (5.0, 32.0)  # 30 + 2\n173:         client.close()\n174: \n175:     @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n176:     def test_write_file(self, mock_session_class):\n177:         \"\"\"Test write_file makes POST request with base64 content.\"\"\"\n178:         mock_response = Mock()\n179:         mock_response.json.return_value = {\"success\": True}\n180: \n181:         mock_session = Mock()\n182:         mock_session.request.return_value = mock_response\n183:         mock_session_class.return_value = mock_session\n184: \n185:         client = CodeInterpreterDataPlaneClient(\n186:             router_url=\"http://router:8080\",\n187:             namespace=\"default\",\n188:             cr_name=\"my-interpreter\",\n189:             session_id=\"test-session\",\n190:         )\n191:         client._session = mock_session\n192: \n193:         import base64\n194: \n195:         result = client.write_file(\"Hello World\", \"/tmp/test.txt\")\n196: \n197:         assert result[\"success\"] is True\n198:         call_kwargs = mock_session.request.call_args.kwargs\n199:         body = call_kwargs[\"json\"]\n200:         assert \"content\" in body\n201:         assert base64.b64decode(body[\"content\"]).decode() == \"Hello World\"\n202:         assert body[\"path\"] == \"/tmp/test.txt\"\n203:         client.close()\n204: \n205:     @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n206:     def test_list_files(self, mock_session_class):\n207:         \"\"\"Test list_files makes GET request with path param.\"\"\"\n208:         mock_response = Mock()\n209:         mock_response.json.return_value = {\"files\": [\"a.txt\", \"b.txt\"]}\n210: \n211:         mock_session = Mock()\n212:         mock_session.request.return_value = mock_response\n213:         mock_session_class.return_value = mock_session\n214: \n215:         client = CodeInterpreterDataPlaneClient(\n216:             router_url=\"http://router:8080\",\n217:             namespace=\"default\",\n218:             cr_name=\"my-interpreter\",\n219:             session_id=\"test-session\",\n220:         )\n221:         client._session = mock_session\n222: \n223:         result = client.list_files(\"/tmp\")\n224: \n225:         assert \"files\" in result\n226:         call_kwargs = mock_session.request.call_args.kwargs\n227:         assert call_kwargs[\"params\"][\"path\"] == \"/tmp\"\n228:         client.close()\n229: \n230:     @patch(\"agentcube.clients.code_interpreter_data_plane.requests.Session\")\n231:     def test_download_file(self, mock_session_class):\n232:         \"\"\"Test download_file streams to local file.\"\"\"\n233:         mock_response = Mock()\n234:         mock_response.iter_content = lambda chunk_size: [b\"test content\"]\n235: \n236:         mock_session = Mock()\n237:         mock_session.request.return_value = mock_response\n238:         mock_session_class.return_value = mock_session\n239: \n240:         client = CodeInterpreterDataPlaneClient(\n241:             router_url=\"http://router:8080\",\n242:             namespace=\"default\",\n243:             cr_name=\"my-interpreter\",\n244:             session_id=\"test-session\",\n245:         )\n246:         client._session = mock_session\n247: \n248:         with patch(\"pathlib.Path.open\", create=True) as mock_open:\n249:             mock_file = Mock()\n250:             mock_open.return_value.__enter__ = Mock(return_value=mock_file)\n251:             mock_open.return_value.__exit__ = Mock(return_value=False)\n252: \n253:             client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n254: \n255:         client.close()\n256: \n257:     def test_close(self):\n258:         \"\"\"Test close method closes the session.\"\"\"\n259:         client = CodeInterpreterDataPlaneClient(\n260:             router_url=\"http://router:8080\",\n261:             namespace=\"default\",\n262:             cr_name=\"my-interpreter\",\n263:             session_id=\"test-session\",\n264:         )\n265:         client._session.close = Mock()\n266:         client.close()\n267:         client._session.close.assert_called_once()\n\n(End of file - total 267 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nimport pytest\nfrom unittest.mock import Mock, patch, MagicMock\nfrom pathlib import Path\n\nfrom agentcube.clients.code_interpreter_data_plane import (\n    CodeInterpreterDataPlaneClient,\n)\nfrom agentcube.exceptions import DataPlaneError\n\n\nclass TestCodeInterpreterDataPlaneClient:\n    \"\"\"Test cases for CodeInterpreterDataPlaneClient.\"\"\"\n\n    def test_constructor_with_base_url(self):\n        \"\"\"Test constructor with explicit base_url.\"\"\"\n        client = CodeInterpreterDataPlaneClient(\n            router_url=\"http://router:8080\",\n            namespace=\"default\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_code_interpreter_data_plane.py","time":{"start":1775883741474,"end":1775883741481}}}}
