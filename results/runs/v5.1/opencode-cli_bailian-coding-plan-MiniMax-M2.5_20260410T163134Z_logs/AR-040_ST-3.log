39:     def test_read_token_from_file_success(self):\n40:         \"\"\"Test read_token_from_file reads token from file.\"\"\"\n41:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False) as f:\n42:             f.write(\"test-token-123\")\n43:             temp_path = f.name\n44: \n45:         try:\n46:             result = read_token_from_file(temp_path)\n47:             assert result == \"test-token-123\"\n48:         finally:\n49:             os.unlink(temp_path)\n50: \n51:     def test_read_token_from_file_default_path(self):\n52:         \"\"\"Test read_token_from_file uses default path when None.\"\"\"\n53:         result = read_token_from_file(None)\n54:         # This will be None unless running in a K8s pod\n55:         assert result is None or isinstance(result, str)\n\n(End of file - total 55 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for agentcube utils.\"\"\"\n\nimport os\nimport tempfile\n\nimport pytest\n\nfrom agentcube.utils.log import get_logger\nfrom agentcube.utils.utils import read_token_from_file\n\n\nclass TestLogUtils:\n    \"\"\"Test cases for logging utilities.\"\"\"\n\n    def test_get_logger_returns_logger(self):\n        \"\"\"Test get_logger returns a logger instance.\"\"\"\n        logger = get_logger(\"test\")\n        assert logger.name == \"test\"\n\n    def test_get_logger_verbose(self):","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/tests/test_utils.py","time":{"start":1775883753764,"end":1775883753772}}}}
