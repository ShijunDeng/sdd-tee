ver.handleDeleteAllSandboxes)\n88: \t\tapi.DELETE(\"/namespaces/:namespace/sandboxes/:sessionId\", server.handleDeleteSandbox)\n89: \t}\n90: \n91: \tserver.httpServer = &http.Server{\n92: \t\tAddr:    fmt.Sprintf(\":%d\", cfg.Port),\n93: \t\tHandler: router,\n94: \t}\n95: \n96: \treturn server\n97: }\n98: \n99: func (s *Server) Start() error {\n100: \tklog.InfoS(\"Starting HTTP server\", \"port\", s.config.Port)\n\n(Showing lines 1-100 of 776. Use offset=101 to continue.)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/server.go","time":{"start":1775859210589,"end":1775859210598}}}}
