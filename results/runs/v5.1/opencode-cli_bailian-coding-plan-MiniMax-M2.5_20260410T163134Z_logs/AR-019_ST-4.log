ics := NewMetrics()\n43: \n44: \tvar sessionManager *SessionManager\n45: \tvar sessionHandler *SessionHandler\n46: \tif config.SessionEnabled {\n47: \t\tsessionManager = NewSessionManager(config)\n48: \t\tsessionHandler = NewSessionHandler(sessionManager)\n49: \t}\n50: \n51: \tvar jwtManager *JWTManager\n52: \tvar jwtMiddleware *JWTMiddleware\n53: \tif config.JWTEnabled {\n54: \t\tjwtConfig := &JWTConfig{\n55: \t\t\tAlgorithm:         config.JWTAlgorithm,\n56: \t\t\tSecret:            config.JWTSecret,\n57: \t\t\tPrivateKeyPath:    config.JWTPrivateKeyPath,\n58: \t\t\tPublicKeyPath:     config.JWTPublicKeyPath,\n59: \t\t\tIssuer:            config.JWTIssuer,\n60: \t\t\tAudience:          config.JWTAudience,\n61: \t\t\tExpiration:        config.JWTExpiration,\n62: \t\t\tRefreshExpiration: config.JWTRefreshExpiration,\n63: \t\t\tClockSkew:         config.JWTClockSkew,\n64: \t\t\tAllowQueryParam:   config.JWTAllowQueryParam,\n65: \t\t}\n66: \t\tjwtManager, _ = NewJWTManager(jwtConfig, nil)\n67: \t\tjwtMiddleware = NewJWTMiddleware(jwtManager, nil, config.JWTAllowQueryParam)\n68: \t}\n69: \n70: \trouter := &Router{\n71: \t\tconfig:         config,\n72: \t\tpool:           pool,\n73: \t\tproxy:          proxy,\n74: \t\trouteHandler:   routeHandler,\n75: \t\thealthChecker:  healthChecker,\n76: \t\trateLimiter:    rateLimiter,\n77: \t\tauthenticator:  authenticator,\n78: \t\tlogger:         logger,\n79: \t\tmetrics:        metrics,\n80: \t\tsessionManager: sessionManager,\n81: \t\tsessionHandler: sessionHandler,\n82: \t\tjwtManager:     jwtManager,\n83: \t\tjwtMiddleware:  jwtMiddleware,\n84: \t}\n85: \n86: \tmux := http.NewServeMux()\n87: \tmux.HandleFunc(\"/\", router.handleRequest)\n88: \n89: \tif sessionHandler != nil {\n90: \t\tmux.Handle(\"/v1/sessions\", sessionHandler)\n91: \t}\n92: \n93: \tif jwtManager != nil {\n94: \t\tmux.HandleFunc(\"/login\", HandleLogin(jwtManager))\n95: \t\tmux.HandleFunc(\"/refresh\", HandleRefresh(jwtManager))\n96: \t}\n97: \n98: \thandler := logger.Middleware(mux)\n99: \thandler = rateLimiter.Middleware(handler)\n100: \thandler = authenticator.Middleware(handler)\n101: \n102: \tif sessionManager != nil {\n103: \t\thandler = sessionManager.Middleware(handler)\n104: \t}\n105: \n106: \tif jwtMiddleware != nil {\n107: \t\thandler = jwtMiddleware.Middleware(handler)\n108: \t}\n109: \n110: \trouter.server = &http.Server{\n111: \t\tAddr:         config.ListenAddress,\n112: \t\tHandler:      handler,\n113: \t\tReadTimeout:  config.BackendTimeout,\n114: \t\tWriteTimeout: config.BackendTimeout,\n115: \t\tIdleTimeout:  config.IdleTimeout,\n116: \t}\n117: \n118: \treturn router\n119: }\n120: \n121: func (r *Router) Start() error {\n122: \tgo func() {\n123: \t\tfmt.Printf(\"Starting router on %s\\n\", r.config.ListenAddress)\n124: \t\tif err := r.server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n125: \t\t\tfmt.Printf(\"Server error: %v\\n\", err)\n126: \t\t}\n127: \t}()\n128: \n129: \tr.healthChecker.Start()\n130: \n131: \tif r.sessionManager != nil {\n132: \t\tr.sessionManager.StartCleanup()\n133: \t}\n134: \n135: \treturn nil\n136: }\n137: \n138: func (r *Router) Shutdown(ctx context.Context) error {\n139: \tr.healthChecker.Stop()\n140: \n141: \tif r.sessionManager != nil {\n142: \t\tr.sessionManager.StopCleanup()\n143: \t}\n144: \n145: \tfmt.Println(\"Shutting down router...\")\n146: \treturn r.server.Shutdown(ctx)\n147: }\n148: \n149: func (r *Router) handleRequest(w http.ResponseWriter, req *http.Request) {\n150: \tstart := time.Now()\n151: \n152: \tvar backend *Backend\n153: \n154: \tif r.sessionManager != nil {\n155: \t\tsessionBackendKey := req.Header.Get(\"X-Session-Backend\")\n156: \t\tif sessionBackendKey != \"\" {\n157: \t\t\tbackend = r.pool.GetBackendByPath(sessionBackendKey)\n158: \t\t}\n159: \t}\n160: \n161: \tif backend == nil {\n162: \t\tbackend = r.routeHandler.GetBackendForRequest(req)\n163: \t}\n164: \n165: \tif backend == nil {\n166: \t\tr.metrics.IncErrors(\"not_found\")\n167: \t\tw.WriteHeader(http.StatusNotFound)\n168: \t\treturn\n169: \t}\n170: \n171: \tr.proxy.ServeHTTP(w, req, backend)\n172: \n173: \tduration := time.Since(start).Seconds()\n174: \tr.metrics.RecordRequestDuration(req.Method, req.URL.Path, backend.Name, duration)\n175: \tr.metrics.IncBackendRequests(backend.Name, \"success\")\n176: }\n177: \n178: func (r *Router) GetPool() *BackendPool {\n179: \treturn r.pool\n180: }\n181: \n182: func (r *Router) GetConfig() *Config {\n183: \treturn r.config\n184: }\n185: \n186: func (r *Router) GetHealthChecker() *HealthChecker {\n187: \treturn r.healthChecker\n188: }\n189: \n190: func (r *Router) GetMetrics() *Metrics {\n191: \treturn r.metrics\n192: }\n193: \n194: func (r *Router) AddBackend(key, endpoint, pathPrefix, name string) error {\n195: \treturn r.pool.AddBackend(key, endpoint, pathPrefix, name)\n196: }\n197: \n198: func (r *Router) RemoveBackend(key string) {\n199: \tr.pool.RemoveBackend(key)\n200: }\n201: \n202: func (r *Router) SetHeaderRoute(headerName, headerValue, backendKey string) {\n203: \tr.pool.SetHeaderRoute(headerName, headerValue, backendKey)\n204: }\n205: \n206: func (r *Router) GetSessionManager() *SessionManager {\n207: \treturn r.sessionManager\n208: }\n209: \n210: func (r *Router) GetJWTManager() *JWTManager {\n211: \treturn r.jwtManager\n212: }\n213: \n214: func RunWithSignal(cfg *Config) error {\n215: \trouter := NewRouter(cfg)\n216: \n217: \tif err := router.Start(); err != nil {\n218: \t\treturn err\n219: \t}\n220: \n221: \tsigCh := make(chan os.Signal, 1)\n222: \tsignal.Notify(sigCh, syscall.SIGINT, syscall.SIGTERM)\n223: \n224: \t<-sigCh\n225: \tfmt.Println(\"\\nReceived shutdown signal\")\n226: \n227: \tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n228: \tdefer cancel()\n229: \n230: \treturn router.Shutdown(ctx)\n231: }\n\n(End of file - total 231 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\t\"time\"\n)\n\ntype Router struct {\n\tconfig         *Config\n\tserver         *http.Server\n\tpool           *BackendPool\n\tproxy          *Proxy\n\trouteHandler   *RouteHandler\n\thealthChecker  *HealthChecker\n\trateLimiter    *RateLimiter","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server.go","time":{"start":1775859210587,"end":1775859210596}}}}
