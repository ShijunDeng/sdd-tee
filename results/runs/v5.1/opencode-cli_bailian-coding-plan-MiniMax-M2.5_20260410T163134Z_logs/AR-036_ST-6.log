   form: true\n35:     label:\n36:       en_US: Workload Manager URL\n37:       ja_JP: Workload Manager URL\n38:       zh_Hans: Workload Manager URL\n39:       pt_BR: Workload Manager URL\n40:     description:\n41:       en_US: The URL of the AgentCube Workload Manager service\n42:       ja_JP: AgentCube Workload ManagerサービスのURL\n43:       zh_Hans: AgentCube Workload Manager 服务的 URL\n44:       pt_BR: A URL do serviço Workload Manager do AgentCube\n45: \n46:   - name: language\n47:     type: select\n48:     required: false\n49:     form: llm\n50:     options:\n51:       - python\n52:       - javascript\n53:       - typescript\n54:     default: python\n55:     label:\n56:       en_US: Language\n57:       ja_JP: 言語\n58:       zh_Hans: 语言\n59:       pt_BR: Linguagem\n60:     description:\n61:       en_US: Programming language to use for code execution\n62:       ja_JP: コード実行に使用するプログラミング言語\n63:       zh_Hans: 用于代码执行的编程语言\n64:       pt_BR: Linguagem de programação para execução de código\n65: \n66:   - name: code\n67:     type: string\n68:     required: false\n69:     form: llm\n70:     label:\n71:       en_US: Code\n72:       ja_JP: コード\n73:       zh_Hans: 代码\n74:       pt_BR: Código\n75:     description:\n76:       en_US: Python code to execute in the sandbox\n77:       ja_JP: サンドボックスで実行するPythonコード\n78:       zh_Hans: 要在沙箱中执行的 Python 代码\n79:       pt_BR: Código Python para executar no sandbox\n80: \n81:   - name: command\n82:     type: string\n83:     required: false\n84:     form: llm\n85:     label:\n86:       en_US: Command\n87:       ja_JP: コマンド\n88:       zh_Hans: 命令\n89:       pt_BR: Comando\n90:     description:\n91:       en_US: Shell command to execute (alternative to code)\n92:       ja_JP: 実行するシェルコマンド（codeの代替）\n93:       zh_Hans: 要执行的 shell 命令（code 的替代）\n94:       pt_BR: Comando shell para executar (alternativo ao código)\n95: \n96:   - name: session_id\n97:     type: string\n98:     required: false\n99:     form: llm\n100:     label:\n101:       en_US: Sessi