ory() as tmpdir:\n38:             workspace = Path(tmpdir)\n39: \n40:             metadata = AgentMetadata(\n41:                 agent_name=\"test\",\n42:                 language=\"python\",\n43:                 entrypoint=\"python main.py\",\n44:             )\n45: \n46:             runtime = PublishRuntime()\n47:             image_url = runtime._prepare_image_for_publishing(workspace, metadata, {})\n48: \n49:             assert \"test:\" in image_url\n50: \n51: \n52: class TestPublishRuntimeK8s:\n53:     \"\"\"Tests for _publish_k8s method.\"\"\"\n54: \n55:     @patch(\"agentcube.services.k8s_provider.KubernetesProvider\")\n56:     def test_publish_k8s_success(self, mock_provider):\n57:         \"\"\"Test successful K8s publish.\"\"\"\n58:         mock_instance = MagicMock()\n59:         mock_instance.deploy_agent.return_value = {\n60:             \"name\": \"test-agent\",\n61:             \"service\": \"test-agent-service\",\n62:             \"endpoint\": \"http://test-agent:8080\",\n63:         }\n64:         mock_provider.return_value = mock_instance\n65: \n66:         with tempfile.TemporaryDirectory() as tmpdir:\n67:             workspace = Path(tmpdir)\n68:             metadata = AgentMetadata(\n69:                 agent_name=\"test-agent\",\n70:                 language=\"python\",\n71:                 entrypoint=\"python main.py\",\n72:                 port=8080,\n73:             )\n74:             with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n75:                 yaml.safe_dump(metadata.model_dump(), f)\n76: \n77:             runtime = PublishRuntime()\n78:             result = runtime._publish_k8s(workspace, metadata, {})\n79: \n80:             assert result[\"status\"] == \"deployed\"\n81:             assert result[\"provider\"] == \"k8s\"\n82: \n83: \n84: class TestPublishRuntimeAgentCube:\n85:     \"\"\"Tests for _publish_cr_to_k8s method.\"\"\"\n86: \n87:     @patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\")\n88:     def test_publish_agentcube_success(self, mock_provider):\n89:         \"\"\"Test successful AgentCube publish.\"\"\"\n90:         mock_instance = MagicMock()\n91:         mock_instance.deploy_agent_runtime.return_value = {\n92:             \"name\": \"test-agent\",\n93:             \"endpoint\": \"http://test-agent:8080\",\n94:         }\n95:         mock_provider.return_value = mock_instance\n96: \n97:         with tempfile.TemporaryDirectory() as tmpdir:\n98:             workspace = Path(tmpdir)\n99:             metadata = AgentMetadata(\n100:                 agent_name=\"test-agent\",\n101:                 language=\"python\",\n102:                 entrypoint=\"python main.py\",\n103:                 port=8080,\n104:             )\n105:             with open(workspace / \"agent_metadata.yaml\", \"w\") as f:\n106:                 yaml.safe_dump(metadata.model_dump(), f)\n107: \n108:             runtime = PublishRuntime(provider=\"agentcube\")\n109:             result = runtime._publish_cr_to_k8s(workspace, metadata, {})\n110: \n111:             assert result[\"status\"] == \"deployed\"\n112:             assert result[\"provider\"] == \"agentcube\"\n113: \n114: \n115: class TestPublishRuntimePublish:\n116:     \"\"\"Tests for publish method.\"\"\"\n117: \n118:     def test_publish_with_missing_workspace(self):\n119:         \"\"\"Test publish with missing workspace.\"\"\"\n120:         runtime = PublishRuntime()\n121: \n122:         with pytest.raises(Exception):\n123:             runtime.publish(\"/nonexistent/path\")\n\n(End of file - total 123 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for PublishRuntime.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\nimport yaml\n\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestPublishRuntimePrepareImage:\n    \"\"\"Tests for _prepare_image_for_publishing 