{"type":"tool_use","timestamp":1775862201859,"sessionID":"ses_2865de249ffe6HkFMq7rwvY7jn","part":{"id":"prt_d79a2ba0c001KwjcARC0XCCijk","messageID":"msg_d79a2b151001LT40c8xnJ5r5Cc","sessionID":"ses_2865de249ffe6HkFMq7rwvY7jn","type":"tool","tool":"read","callID":"toolu_569eef75371e4d8d9194493f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/k8s_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/k8s_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Kubernetes provider for AgentCube - handles K8s deployments.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: from typing import Any, Dict, Optional\n7: \n8: \n9: class KubernetesProvider:\n10:     \"\"\"Provider for Kubernetes deployments using native resources.\"\"\"\n11: \n12:     def __init__(\n13:         self,\n14:         namespace: str = \"default\",\n15:         verbose: bool = False,\n16:         kubeconfig: Optional[str] = None,\n17:     ):\n18:         \"\"\"\n19:         Initialize the KubernetesProvider.\n20: \n21:         Args:\n22:             namespace: Kubernetes namespace\n23:             verbose: Enable verbose logging\n24:             kubeconfig: Path to kubeconfig file\n25:         \"\"\"\n26:         self.namespace = namespace\n27:         self.verbose = verbose\n28:         self.kubeconfig = kubeconfig\n29:         self.logger = logging.getLogger(__name__)\n30: \n31:         if verbose:\n32:             logging.basicConfig(level=logging.DEBUG)\n33:         else:\n34:             logging.basicConfig(level=logging.INFO)\n35: \n36:         self._client = None\n37: \n38:     def _get_client(self) -> Any:\n39:         \"\"\"Get Kubernetes client (lazy initialization).\"\"\"\n40:         if self._client is not None:\n41:             return self._client\n42: \n43:         try:\n44:             from kubernetes import client, config\n45: \n46:             if self.kubeconfig:\n47:                 config.load_kube_config(config_file=self.kubeconfig)\n48:             else:\n49:                 try:\n50:                     config.load_kube_config()\n51:                 except Exception:\n52:                     config.load_incluster_config()\n53: \n54:             self._client = client\n55:             return self._client\n56:         except ImportError:\n57:             self.logger.warning(\"kubernetes library not available, using mock mode\")\n58:             return None\n59: \n60:     def deploy_agent(\n61:         self,\n62:         agent_name: str,\n63:         image_url: str,\n64:         port: int,\n65:         entrypoint: Optional[str] = None,\n66:         replicas: int = 1,\n67:         node_port: Optional[int] = None,\n68:         env_vars: Optional[Dict[str, str]] = None,\n69:     ) -> Dict[str, Any]:\n70:         \"\"\"\n71:         Deploy an agent to Kubernetes.\n72: \n73:         Args:\n74:             agent_name: Name of the agent\n75:             image_url: Container image URL\n76:             port: Port to expose\n77:             entrypoint: Entrypoint command\n78:             replicas: Number of replicas\n79:             node_port: NodePort for service (30000-32767)\n80:             env_vars: Environment variables\n81: \n82:         Returns:\n83:             Dictionary with deployment info\n84:         \"\"\"\n85:         client = self._get_client()\n86: \n87:         if client is None:\n88:             self.logger.warning(\"Using mock Kubernetes deployment\")\n89:             return {\n90:                 \"name\": agent_name,\n91:                 \"namespace\": self.namespace,\n92:                 \"service\": f\"{agent_name}-service\",\n93:                 \"endpoint\": f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\",\n94:             }\n95: \n96:         try:\n97:             k8s = client\n98:             apps_v1 = k8s.AppsV1Api()\n99:             core_v1 = k8s.CoreV1Api()\n100: \n101:             deployment = k8s.V1Deployment(\n102:                 metadata=k8s.V1ObjectMeta(\n103:                     name=agent_name,\n104:                     namespace=self.namespace,\n105:                     labels={\"app\": agent_name, \"agentcube agent\": \"true\"},\n106:                 ),\n107:                 spec=k8s.V1DeploymentSpec(\n108:                     replicas=replicas,\n109:                     selector=k8s.V1LabelSelector(match_labels={\"app\": agent_name}),\n110:                     template=k8s.V1PodTemplateSpec(\n111:                         metadata=k8s.V1ObjectMeta(labels={\"app\": agent_name}),\n112:                         spec=k8s.V1PodSpec(\n113:                             containers=[\n114:                                 k8s.V1Container(\n115:                                     name=\"agent\",\n116:                                     image=image_url,\n117:                                     ports=[k8s.V1ContainerPort(container_port=port, name=\"http\")],\n118:                                     env=[\n119:                                         k8s.V1EnvVar(name=k, value=v)\n120:                                         for k, v in (env_vars or {}).items()\n121:                                     ]\n122:                                     if env_vars\n123:                                     else [],\n124:                                     image_pull_policy=\"IfNotPresent\",\n125:                                 )\n126:                             ]\n127:                         ),\n128:                     ),\n129:                 ),\n130:             )\n131: \n132:             apps_v1.create_namespaced_deployment(namespace=self.namespace, body=deployment)\n133: \n134:             service_type = \"NodePort\" if node_port else \"ClusterIP\"\n135:             service = k8s.V1Service(\n136:                 metadata=k8s.V1ObjectMeta(\n137:                     name=f\"{agent_name}-service\",\n138:                     namespace=self.namespace,\n139:                 ),\n140:                 spec=k8s.V1ServiceSpec(\n141:                     type=service_type,\n142:                     selector={\"app\": agent_name},\n143:                     ports=[\n144:                         k8s.V1ServicePort(\n145:                             port=port,\n146:                             target_port=port,\n147:                             name=\"http\",\n148:                             node_port=node_port,\n149:                         )\n150:                     ],\n151:                 ),\n152:             )\n153: \n154:             core_v1.create_namespaced_service(namespace=self.namespace, body=service)\n155: \n156:             return {\n157:                 \"name\": agent_name,\n158:                 \"namespace\": self.namespace,\n159:                 \"service\": f\"{agent_name}-service\",\n160:                 \"endpoint\": f\"http://{agent_name}.{self.namespace}.svc.cluster.local:{port}\",\n161:             }\n162: \n163:         except Exception as e:\n164:             self.logger.error(f\"Failed to deploy to Kubernetes: {e}\")\n165:             raise ValueError(f\"Kubernetes deployment failed: {e}\")\n166: \n167:     def wait_for_deployment_ready(self, name: str, timeout: int = 120) -> None:\n168:         \"\"\"\n169:         Wait for deployment to be ready.\n170: \n171:         Args:\n172:             name: Deployment name\n173:             timeout: Timeout in seconds\n174: \n175:         Raises:\n176:             ValueError: If timeout\n177:         \"\"\"\n178:         client = self._get_client()\n179: \n180:         if client is None:\n181:             self.logger.debug(\"Mock: deployment ready\")\n182:             return\n183: \n184:         import time\n185: \n186:         k8s = client.AppsV1Api()\n187:         start_time = time.time()\n188: \n189:         while time.time() - start_time < timeout:\n190:             try:\n191:                 deployment = k8s.read_namespaced_deployment(name=name, namespace=self.namespace)\n192: \n193:                 if deployment.status.ready_replicas == deployment.spec.replicas:\n194:                     self.logger.debug(f\"Deployment {name} is ready\")\n195:                     return\n196: \n197:             except Exception:\n198:                 pass\n199: \n200:             time.sleep(2)\n201: \n202:         raise ValueError(f\"Deployment {name} not ready within {timeout}s\")\n203: \n204:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n205:         \"\"\"\n206:         Get agent status from Kubernetes.\n207: \n208:         Args:\n209:             agent_name: Name of the agent\n210: \n211:         Returns:\n212:             Dictionary with status info\n213:         \"\"\"\n214:         client = self._get_client()\n215: \n216:         if client is None:\n217:             return {\n218:                 \"name\": agent_name,\n219:                 \"namespace\": self.namespace,\n220:                 \"status\": \"running\",\n221:                 \"ready_replicas\": 1,\n222:             }\n223: \n224:         try:\n225:             k8s = client.AppsV1Api()\n226:             deployment = k8s.read_namespaced_deployment(name=agent_name, namespace=self.namespace)\n227: \n228:             return {\n229:                 \"name\": agent_name,\n230:                 \"namespace\": self.namespace,\n231:                 \"status\": \"running\" if deployment.status.ready_replicas else \"pending\",\n232:                 \"ready_replicas\": deployment.status.ready_replicas or 0,\n233:                 \"replicas\": deployment.spec.replicas,\n234:             }\n235: \n236:         except Exception as e:\n237:             return {\n238:                 \"name\": agent_name,\n239:                 \"namespace\": self.namespace,\n240:                 \"status\": \"not_found\",\n241:                 \"error\": str(e),\n242:             }\n243: \n244:     def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n245:         \"\"\"\n246:         Delete an agent from Kubernetes.\n247: \n248:         Args:\n249:             agent_name: Name of the agent\n250: \n251:         Returns:\n252:             Dictionary with deletion result\n253:         \"\"\"\n254:         client = self._get_client()\n255: \n256:         if client is None:\n257:             return {\n258:                 \"name\": agent_name,\n259:                 \"status\": \"deleted\",\n260:             }\n261: \n262:         try:\n263:             k8s = client\n264:             apps_v1 = k8s.AppsV1Api()\n265:             core_v1 = k8s.CoreV1Api()\n266: \n267:             try:\n268:                 apps_v1.delete_namespaced_deployment(\n269:                     name=agent_name, namespace=self.namespace, body=k8s.V1DeleteOptions()\n270:                 )\n271:             except Exception:\n272:                 pass\n273: \n274:             try:\n275:                 core_v1.delete_namespaced_service(\n276:                     name=f\"{agent_name}-service\",\n277:                     namespace=self.namespace,\n278:                     body=k8s.V1DeleteOptions(),\n279:                 )\n280:             except Exception:\n281:                 pass\n282: \n283:             return {\n284:                 \"name\": agent_name,\n285:                 \"status\": \"deleted\",\n286:             }\n287: \n288:         except Exception as e:\n289:             raise ValueError(f\"Failed to delete agent: {e}\")\n\n(End of file - total 289 lines)\n</content>","metadata":{"preview":"\"\"\"Kubernetes provider for AgentCube - handles K8s deployments.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom typing import Any, Dict, Optional\n\n\nclass KubernetesProvider:\n    \"\"\"Provider for Kubernetes deployments using native resources.\"\"\"\n\n    def __init__(\n        self,\n        namespace: str = \"default\",\n        verbose: bool = False,\n        kubeconfig: Optional[str] = None,\n    ):\n        \"\"\"\n        Initialize the KubernetesProvider.\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/agentcube/services/k8s_provider.py","time":{"start":1775862201843,"end":1775862201856}}}}
