ientset kubernetes.Interface, router *Router, namespaces []string) *Informer {\n39: \treturn &Informer{\n40: \t\tclientset:       clientset,\n41: \t\trouter:          router,\n42: \t\twatchNamespaces: namespaces,\n43: \t\tstopCh:          make(chan struct{}),\n44: \t}\n45: }\n46: \n47: func (i *Informer) Start() error {\n48: \treturn nil\n49: }\n50: \n51: func (i *Informer) Stop() {\n52: \tclose(i.stopCh)\n53: }\n54: \n55: func (i *Informer) AddAgentRuntime(ar *agentcubev1alpha1.AgentRuntime) {\n56: \tif ar.Status.Phase != agentcubev1alpha1.PhaseRunning {\n57: \t\treturn\n58: \t}\n59: \n60: \tif ar.Status.Endpoint == \"\" {\n61: \t\treturn\n62: \t}\n63: \n64: \tkey := fmt.Sprintf(\"agentruntime/%s/%s\", ar.Namespace, ar.Name)\n65: \tpathPrefix := \"/agent/\"\n66: \n67: \tfor _, port := range ar.Spec.TargetPorts {\n68: \t\tif port.PathPrefix != \"\" {\n69: \t\t\tpathPrefix = port.PathPrefix\n70: \t\t\tbreak\n71: \t\t}\n72: \t}\n73: \n74: \terr := i.router.AddBackend(key, ar.Status.Endpoint, pathPrefix, ar.Name)\n75: \tif err != nil {\n76: \t\tfmt.Printf(\"Failed to add AgentRuntime backend: %v\\n\", err)\n77: \t\treturn\n78: \t}\n79: \n80: \tfmt.Printf(\"Added AgentRuntime backend: %s -> %s\\n\", key, ar.Status.Endpoint)\n81: }\n82: \n83: func (i *Informer) UpdateAgentRuntime(ar *agentcubev1alpha1.AgentRuntime) {\n84: \tkey := fmt.Sprintf(\"agentruntime/%s/%s\", ar.Namespace, ar.Name)\n85: \n86: \tif ar.Status.Phase != agentcubev1alpha1.PhaseRunning || ar.Status.Endpoint == \"\" {\n87: \t\ti.router.RemoveBackend(key)\n88: \t\tfmt.Printf(\"Removed AgentRuntime backend (not running): %s\\n\", key)\n89: \t\treturn\n90: \t}\n91: \n92: \tpathPrefix := \"/agent/\"\n93: \tfor _, port := range ar.Spec.TargetPorts {\n94: \t\tif port.PathPrefix != \"\" {\n95: \t\t\tpathPrefix = port.PathPrefix\n96: \t\t\tbreak\n97: \t\t}\n98: \t}\n99: \n100: \terr := i.router.pool.UpdateBackend(key, ar.Status.Endpoint, pathPrefix)\n101: \tif err != nil {\n102: \t\tfmt.Printf(\"Failed to update AgentRuntime backend: %v\\n\", err)\n103: \t}\n104: }\n105: \n106: func (i *Informer) DeleteAgentRuntime(ar *agentcubev1alpha1.AgentRuntime) {\n107: \tkey := fmt.Sprintf(\"agentruntime/%s/%s\", ar.Namespace, ar.Name)\n108: \ti.router.RemoveBackend(key)\n109: \tfmt.Printf(\"Removed AgentRuntime backend: %s\\n\", key)\n110: }\n111: \n112: func (i *Informer) AddCodeInterpreter(ci *agentcubev1alpha1.CodeInterpreter) {\n113: \tif ci.Status.Phase != agentcubev1alpha1.PhaseRunning {\n114: \t\treturn\n115: \t}\n116: \n117: \tif ci.Status.Endpoint == \"\" {\n118: \t\treturn\n119: \t}\n120: \n121: \tkey := fmt.Sprintf(\"codeinterpreter/%s/%s\", ci.Namespace, ci.Name)\n122: \tpathPrefix := \"/code/\"\n123: \n124: \terr := i.router.AddBackend(key, ci.Status.Endpoint, pathPrefix, ci.Name)\n125: \tif err != nil {\n126: \t\tfmt.Printf(\"Failed to add CodeInterpreter backend: %v\\n\", err)\n127: \t\treturn\n128: \t}\n129: \n130: \tfmt.Printf(\"Added CodeInterpreter backend: %s -> %s\\n\", key, ci.Status.Endpoint)\n131: }\n132: \n133: func (i *Informer) UpdateCodeInterpreter(ci *agentcubev1alpha1.CodeInterpreter) {\n134: \tkey := fmt.Sprintf(\"codeinterpreter/%s/%s\", ci.Namespace, ci.Name)\n135: \n136: \tif ci.Status.Phase != agentcubev1alpha1.PhaseRunning || ci.Status.Endpoint == \"\" {\n137: \t\ti.router.RemoveBackend(key)\n138: \t\tfmt.Printf(\"Removed CodeInterpreter backend (not running): %s\\n\", key)\n139: \t\treturn\n140: \t}\n141: \n142: \tpathPrefix := \"/code/\"\n143: \terr := i.router.pool.UpdateBackend(key, ci.Status.Endpoint, pathPrefix)\n144: \tif err != nil {\n145: \t\tfmt.Printf(\"Failed to update CodeInterpreter backend: %v\\n\", err)\n146: \t}\n147: }\n148: \n149: func (i *Informer) DeleteCodeInterpreter(ci *agentcubev1alpha1.CodeInterpreter) {\n150: \tkey := fmt.Sprintf(\"codeinterpreter/%s/%s\", ci.Namespace, ci.Name)\n151: \ti.router.RemoveBackend(key)\n152: \tfmt.Printf(\"Removed CodeInterpreter backend: %s\\n\", key)\n153: }\n154: \n155: func NewListWatch(clientset kubernetes.Interface, namespace string, resourceType string) *cache.ListWatch {\n156: \treturn &cache.ListWatch{\n157: \t\tListFunc: func(options metav1.ListOptions) (runtime.Object, error) {\n158: \t\t\treturn nil, nil\n159: \t\t},\n160: \t\tWatchFunc: func(options metav1.ListOptions) (watch.Interface, error) {\n161: \t\t\treturn nil, nil\n162: \t\t},\n163: \t}\n164: }\n165: \n166: func RunInformerExample() {\n167: \trouter := NewRouter(nil)\n168: \t_ = router\n169: }\n170: \n171: var _ cache.ListerWatcher = &cache.ListWatch{}\n\n(End of file - total 171 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/watch\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/tools/cache\"\n)\n\ntype Informer struct {\n\tclientset       kubernetes.Interface\n\trouter          *Router\n\twatchNamespaces []string\n\tstopCh          chan struct{}\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/informer.go","time":{"start":1775848437658,"end":1775848437673}}}}
