t}\n47: \n48: \treturn proxy\n49: }\n50: \n51: func (p *Proxy) ServeHTTP(w http.ResponseWriter, r *http.Request, backend *Backend) {\n52: \tif backend == nil {\n53: \t\thttp.NotFound(w, r)\n54: \t\treturn\n55: \t}\n56: \n57: \tp.mu.Lock()\n58: \tp.connPool[backend.URL.Host]++\n59: \tif p.connPool[backend.URL.Host] > p.maxConns {\n60: \t\tp.mu.Unlock()\n61: \t\thttp.Error(w, \"Backend overloaded\", http.StatusServiceUnavailable)\n62: \t\treturn\n63: \t}\n64: \tp.mu.Unlock()\n65: \n66: \tdefer func() {\n67: \t\tp.mu.Lock()\n68: \t\tp.connPool[backend.URL.Host]--\n69: \t\tp.mu.Unlock()\n70: \t}()\n71: \n72: \toriginalURL := r.URL\n73: \tr.URL.Scheme = backend.URL.Scheme\n74: \tr.URL.Host = backend.URL.Host\n75: \n76: \tif backend.PathPrefix != \"\" && len(originalURL.Path) > len(backend.PathPrefix) {\n77: \t\tr.URL.Path = originalURL.Path[len(backend.PathPrefix):]\n78: \t} else if backend.PathPrefix != \"\" && originalURL.Path == backend.PathPrefix {\n79: \t\tr.URL.Path = \"/\"\n80: \t}\n81: \n82: \tr.URL.RawQuery = originalURL.RawQuery\n83: \n84: \tr.Header.Set(\"X-Forwarded-Host\", r.Host)\n85: \tr.Header.Set(\"X-Forwarded-For\", r.RemoteAddr)\n86: \n87: \tp.reverseProxy.ServeHTTP(w, r)\n88: }\n89: \n90: func (p *Proxy) GetTransport() *http.Transport {\n91: \treturn p.transport\n92: }\n\n(End of file - total 92 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"sync\"\n\t\"time\"\n)\n\ntype Proxy struct {\n\treverseProxy *httputil.ReverseProxy\n\ttransport    *http.Transport\n\tmaxConns     int\n\tconnPool     map[string]int\n\tmu           sync.RWMutex\n}\n\nfunc NewProxy(backendTimeout, idleTimeout time.Duration, maxConnsPerBackend int) *Proxy {\n\ttransport := &http.Transport{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/proxy.go","time":{"start":1775848432994,"end":1775848433005}}}}
