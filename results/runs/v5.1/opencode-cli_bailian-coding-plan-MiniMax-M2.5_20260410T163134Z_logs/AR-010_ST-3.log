\n41: \trequestDuration.WithLabelValues(method, path, backend).Observe(duration)\n42: }\n43: \n44: func (m *Metrics) IncBackendRequests(backend string, status string) {\n45: \tbackendRequests.WithLabelValues(backend, status).Inc()\n46: }\n47: \n48: func (m *Metrics) SetBackendHealth(backend string, healthy bool) {\n49: \tvalue := 0.0\n50: \tif healthy {\n51: \t\tvalue = 1.0\n52: \t}\n53: \tbackendHealthy.WithLabelValues(backend).Set(value)\n54: }\n55: \n56: func (m *Metrics) IncErrors(errType string) {\n57: \terrorsTotal.WithLabelValues(errType).Inc()\n58: }\n59: \n60: func (m *Metrics) GetRequestDuration() *prometheus.HistogramVec {\n61: \treturn requestDuration\n62: }\n63: \n64: func (m *Metrics) GetBackendRequests() *prometheus.CounterVec {\n65: \treturn backendRequests\n66: }\n67: \n68: func (m *Metrics) GetBackendHealthy() *prometheus.GaugeVec {\n69: \treturn backendHealthy\n70: }\n71: \n72: func (m *Metrics) GetErrors() *prometheus.CounterVec {\n73: \treturn errorsTotal\n74: }\n\n(End of file - total 74 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"github.com/prometheus/client_golang/prometheus\"\n\t\"github.com/prometheus/client_golang/prometheus/promauto\"\n\t\"sync\"\n)\n\nvar (\n\trequestDuration = promauto.NewHistogramVec(prometheus.HistogramOpts{\n\t\tName:    \"router_request_duration_seconds\",\n\t\tHelp:    \"Time spent processing requests\",\n\t\tBuckets: prometheus.DefBuckets,\n\t}, []string{\"method\", \"path\", \"backend\"})\n\n\tbackendRequests = promauto.NewCounterVec(prometheus.CounterOpts{\n\t\tName: \"router_backend_requests_total\",\n\t\tHelp: \"Total number of requests to backends\",\n\t}, []string{\"backend\", \"status\"})\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/metrics.go","time":{"start":1775848437661,"end":1775848437675}}}}
