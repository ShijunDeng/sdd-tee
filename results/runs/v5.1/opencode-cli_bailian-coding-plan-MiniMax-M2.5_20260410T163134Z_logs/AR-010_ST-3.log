{"type":"tool_use","timestamp":1775848433004,"sessionID":"ses_2872fe219ffe8JUj26k1EB2YSq","part":{"id":"prt_d78d09d830018tGRfz7RCro3Lq","messageID":"msg_d78d093120017WVELKXWoI9xa3","sessionID":"ses_2872fe219ffe8JUj26k1EB2YSq","type":"tool","tool":"read","callID":"toolu_7e55cbb201b3423aa331712a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/health.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/health.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"time\"\n8: )\n9: \n10: type HealthChecker struct {\n11: \tpool        *BackendPool\n12: \tinterval    time.Duration\n13: \ttimeout     time.Duration\n14: \tstopCh      chan struct{}\n15: \tmaxFailures int\n16: }\n17: \n18: func NewHealthChecker(pool *BackendPool, interval, timeout time.Duration, maxFailures int) *HealthChecker {\n19: \treturn &HealthChecker{\n20: \t\tpool:        pool,\n21: \t\tinterval:    interval,\n22: \t\ttimeout:     timeout,\n23: \t\tstopCh:      make(chan struct{}),\n24: \t\tmaxFailures: maxFailures,\n25: \t}\n26: }\n27: \n28: func (hc *HealthChecker) Start() {\n29: \tgo func() {\n30: \t\tticker := time.NewTicker(hc.interval)\n31: \t\tdefer ticker.Stop()\n32: \n33: \t\tfor {\n34: \t\t\tselect {\n35: \t\t\tcase <-ticker.C:\n36: \t\t\t\thc.checkAllBackends()\n37: \t\t\tcase <-hc.stopCh:\n38: \t\t\t\treturn\n39: \t\t\t}\n40: \t\t}\n41: \t}()\n42: }\n43: \n44: func (hc *HealthChecker) Stop() {\n45: \tclose(hc.stopCh)\n46: }\n47: \n48: func (hc *HealthChecker) checkAllBackends() {\n49: \tbackends := hc.pool.GetAllBackends()\n50: \n51: \tfor key, backend := range backends {\n52: \t\thc.checkBackend(key, backend)\n53: \t}\n54: }\n55: \n56: func (hc *HealthChecker) checkBackend(key string, backend *Backend) {\n57: \tctx, cancel := context.WithTimeout(context.Background(), hc.timeout)\n58: \tdefer cancel()\n59: \n60: \turl := *backend.URL\n61: \turl.Path = \"/health\"\n62: \tif url.Path == \"\" {\n63: \t\turl.Path = \"/\"\n64: \t}\n65: \n66: \treq, err := http.NewRequestWithContext(ctx, http.MethodGet, url.String(), nil)\n67: \tif err != nil {\n68: \t\tbackend.RecordFailure()\n69: \t\tif backend.GetConsecutiveFailures() >= hc.maxFailures {\n70: \t\t\tbackend.SetHealthy(false)\n71: \t\t}\n72: \t\treturn\n73: \t}\n74: \n75: \tclient := &http.Client{Timeout: hc.timeout}\n76: \tresp, err := client.Do(req)\n77: \tif err != nil {\n78: \t\tbackend.RecordFailure()\n79: \t\tif backend.GetConsecutiveFailures() >= hc.maxFailures {\n80: \t\t\tbackend.SetHealthy(false)\n81: \t\t}\n82: \t\treturn\n83: \t}\n84: \tdefer resp.Body.Close()\n85: \n86: \tif resp.StatusCode >= 200 && resp.StatusCode < 400 {\n87: \t\tbackend.RecordSuccess()\n88: \t\tfmt.Printf(\"Backend %s is healthy\\n\", key)\n89: \t} else {\n90: \t\tbackend.RecordFailure()\n91: \t\tif backend.GetConsecutiveFailures() >= hc.maxFailures {\n92: \t\t\tbackend.SetHealthy(false)\n93: \t\t\tfmt.Printf(\"Backend %s is unhealthy (status: %d)\\n\", key, resp.StatusCode)\n94: \t\t}\n95: \t}\n96: }\n97: \n98: func (hc *HealthChecker) CheckBackend(backend *Backend) bool {\n99: \tif backend == nil {\n100: \t\treturn false\n101: \t}\n102: \n103: \tctx, cancel := context.WithTimeout(context.Background(), hc.timeout)\n104: \tdefer cancel()\n105: \n106: \turl := *backend.URL\n107: \tif url.Path == \"\" {\n108: \t\turl.Path = \"/\"\n109: \t}\n110: \n111: \treq, err := http.NewRequestWithContext(ctx, http.MethodGet, url.String(), nil)\n112: \tif err != nil {\n113: \t\treturn false\n114: \t}\n115: \n116: \tclient := &http.Client{Timeout: hc.timeout}\n117: \tresp, err := client.Do(req)\n118: \tif err != nil {\n119: \t\treturn false\n120: \t}\n121: \tdefer resp.Body.Close()\n122: \n123: \treturn resp.StatusCode >= 200 && resp.StatusCode < 400\n124: }\n\n(End of f