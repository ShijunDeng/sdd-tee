ientIP = forwarded\n55: \t\t}\n56: \n57: \t\tif !rl.Allow(clientIP) {\n58: \t\t\thttp.Error(w, \"Too Many Requests\", http.StatusTooManyRequests)\n59: \t\t\treturn\n60: \t\t}\n61: \n62: \t\tnext.ServeHTTP(w, r)\n63: \t})\n64: }\n65: \n66: func (rl *RateLimiter) SetRate(rps int) {\n67: \trl.mu.Lock()\n68: \tdefer rl.mu.Unlock()\n69: \trl.rate = rate.Limit(rps)\n70: }\n71: \n72: func (rl *RateLimiter) SetBurst(burst int) {\n73: \trl.mu.Lock()\n74: \tdefer rl.mu.Unlock()\n75: \trl.burst = burst\n76: }\n77: \n78: func (rl *RateLimiter) IsEnabled() bool {\n79: \treturn rl.enabled\n80: }\n81: \n82: func (rl *RateLimiter) Enable() {\n83: \trl.mu.Lock()\n84: \tdefer rl.mu.Unlock()\n85: \trl.enabled = true\n86: }\n87: \n88: func (rl *RateLimiter) Disable() {\n89: \trl.mu.Lock()\n90: \tdefer rl.mu.Unlock()\n91: \trl.enabled = false\n92: }\n\n(End of file - total 92 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"golang.org/x/time/rate\"\n\t\"net/http\"\n\t\"sync\"\n)\n\ntype RateLimiter struct {\n\tlimiters map[string]*rate.Limiter\n\trate     rate.Limit\n\tburst    int\n\tmu       sync.RWMutex\n\tenabled  bool\n}\n\nfunc NewRateLimiter(rps int, burst int, enabled bool) *RateLimiter {\n\treturn &RateLimiter{\n\t\tlimiters: make(map[string]*rate.Limiter),\n\t\trate:     rate.Limit(rps),","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/ratelimit.go","time":{"start":1775848446033,"end":1775848446052}}}}
