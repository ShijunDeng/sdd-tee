r=provider,\n443:                 verbose=verbose,\n444:             )\n445: \n446:             progress.update(task, completed=True)\n447: \n448:         console.print(\n449:             Panel(\n450:                 f\"[bold green]Agent invoked successfully![/bold green]\\n\\n\"\n451:                 f\"[bold]Agent:[/bold] {result['agent_name']}\\n\"\n452:                 f\"[bold]Payload:[/bold] {result['payload']}\\n\\n\"\n453:                 f\"[bold]Response:[/bold]\",\n454:                 title=\"Invoke Complete\",\n455:                 style=\"green\",\n456:             )\n457:         )\n458: \n459:         import json\n460: \n461:         console.print_json(json.dumps(result[\"response\"], indent=2))\n462: \n463:     except Exception as e:\n464:         _handle_error(e, \"invoke\", verbose)\n465:         raise typer.Exit(code=1)\n466: \n467: \n468: @app.command()\n469: def status(\n470:     workspace: str = typer.Option(\n471:         \".\",\n472:         \"-f\",\n473:         \"--workspace\",\n474:         help=\"Path to the agent workspace directory\",\n475:     ),\n476:     provider: str = typer.Option(\n477:         \"agentcube\",\n478:         \"--provider\",\n479:         help=\"Target provider: 'agentcube' or 'k8s'\",\n480:     ),\n481:     verbose: bool = typer.Option(\n482:         False,\n483:         \"--verbose\",\n484:         help=\"Enable detailed logging\",\n485:     ),\n486: ) -> None:\n487:     \"\"\"\n488:     Check the status of a published agent.\n489: \n490:     Loads workspace metadata and displays agent status in a table.\n491:     \"\"\"\n492:     try:\n493:         if verbose:\n494:             logging.basicConfig(level=logging.DEBUG)\n495: \n496:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n497: \n498:         result = runtime.get_status(\n499:             workspace_path=workspace,\n500:             provider=provider,\n501:         )\n502: \n503:         table = Table(title=f\"Agent Status: {result.get('a