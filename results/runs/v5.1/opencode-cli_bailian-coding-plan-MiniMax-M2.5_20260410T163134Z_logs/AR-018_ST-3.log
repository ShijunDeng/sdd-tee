\"`\n152: \n153: \t// +optional\n154: \tPathPrefix string `json:\"pathPrefix,omitempty\"`\n155: }\n156: \n157: // PodTemplateSpec defines a custom pod template for the runtime.\n158: type PodTemplateSpec struct {\n159: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n160: \tSpec              *PodSpec `json:\"spec,omitempty\"`\n161: }\n162: \n163: // PodSpec is a selective subset of corev1.PodSpec.\n164: type PodSpec struct {\n165: \t// +optional\n166: \tContainers []ContainerSpec `json:\"containers,omitempty\"`\n167: \n168: \t// +optional\n169: \tVolumes []corev1.Volume `json:\" volumes,omitempty\"`\n170: \n171: \t// +optional\n172: \tRestartPolicy corev1.RestartPolicy `json:\"restartPolicy,omitempty\"`\n173: \n174: \t// +optional\n175: \tServiceAccountName string `json:\"serviceAccountName,omitempty\"`\n176: \n177: \t// +optional\n178: \tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n179: \n180: \t// +optional\n181: \tAffinity *corev1.Affinity `json:\"affinity,omitempty\"`\n182: \n183: \t// +optional\n184: \tTolerations []corev1.Toleration `json:\"tolerations,omitempty\"`\n185: \n186: \t// +optional\n187: \tPriorityClassName string `json:\"priorityClassName,omitempty\"`\n188: \n189: \t// +optional\n190: \tPriority *int32 `json:\"priority,omitempty\"`\n191: \n192: \t// +optional\n193: \tDNSPolicy corev1.DNSPolicy `json:\"dnsPolicy,omitempty\"`\n194: \n195: \t// +optional\n196: \tHostNetwork bool `json:\"hostNetwork,omitempty\"`\n197: \n198: \t// +optional\n199: \tHostPID bool `json:\"hostPID,omitempty\"`\n200: \n201: \t// +optional\n202: \tHostIPC bool `json:\"hostIPC,omitempty\"`\n203: \n204: \t// +optional\n205: \tSecurityContext *corev1.PodSecurityContext `json:\"securityContext,omitempty\"`\n206: \n207: \t// +optional\n208: \tImagePullSecrets []corev1.LocalObjectReference `json:\"imagePullSecrets,omitempty\"`\n209: \n210: \t// +optional\n211: \tInitContainers []ContainerSpec `json:\"initContainers,omitempty\"`\n212: }\n213: \n214: // Contain