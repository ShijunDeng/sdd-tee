ation\"`\n38: \n39: \t// +kubebuilder:validation:Required\n40: \t// +kubebuilder:validation:Pattern:=`^(\\d+m)|(\\d+h)(\\d+m)?$`\n41: \t// +kubebuilder:default:=\"15m\"\n42: \tSessionTimeout string `json:\"sessionTimeout\"`\n43: \n44: \t// +kubebuilder:validation:Required\n45: \t// +kubebuilder:validation:MinItems:=1\n46: \tTargetPorts []TargetPort `json:\"targetPorts\"`\n47: \n48: \t// +optional\n49: \tPodTemplate *PodTemplateSpec `json:\"podTemplate,omitempty\"`\n50: }\n51: \n52: // AgentRuntimeStatus defines the observed state of AgentRuntime.\n53: type AgentRuntimeStatus struct {\n54: \t// +optional\n55: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n56: \n57: \t// +optional\n58: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n59: \n60: \t// +optional\n61: \t// +kubebuilder:validation:Enum=Pending;Running;Failed;Succeeded\n62: \tPhase string `json:\"phase,omitempty\"`\n63: \n64: \t// +optional\n65: \tEndpoint string `json:\"endpoint,omitempty\"`\n66: }\n67: \n68: // +genclient\n69: // +kubebuilder:object:root=true\n70: // +kubebuilder:subresource:status\n71: // +kubebuilder:resource:shortName=ci\n72: \n73: // CodeInterpreter defines code execution environment specifications.\n74: type CodeInterpreter struct {\n75: \tmetav1.TypeMeta   `json:\",inline\"`\n76: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n77: \n78: \tSpec   CodeInterpreterSpec   `json:\"spec,omitempty\"`\n79: \tStatus CodeInterpreterStatus `json:\"status,omitempty\"`\n80: }\n81: \n82: // +kubebuilder:object:root=true\n83: \n84: // CodeInterpreterList contains a list of CodeInterpreter.\n85: type CodeInterpreterList struct {\n86: \tmetav1.TypeMeta `json:\",inline\"`\n87: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n88: \tItems           []CodeInterpreter `json:\"items\"`\n89: }\n90: \n91: // CodeInterpreterSpec defines the desired state of CodeInterpreter.\n92: type CodeInterpreterSpec struct {\n93: \t// +optional\n94: \t// +kubebuilder:validation:Enum=