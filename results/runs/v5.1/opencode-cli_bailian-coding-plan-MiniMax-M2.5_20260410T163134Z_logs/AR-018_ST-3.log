rrorIssuer"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/cmd/picod/main.go":[{"range":{"start":{"line":23,"character":38},"end":{"line":23,"character":38}},"severity":1,"code":"WrongArgCount","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#WrongArgCount"},"source":"compiler","message":"not enough arguments in call to picod.NewServer\n\thave (*picod.Config)\n\twant (*picod.Config, *picod.AuthConfig)"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/reconciler/reconciler_test.go":[{"range":{"start":{"line":145,"character":5},"end":{"line":145,"character":5}},"severity":1,"source":"syntax","message":"expected '(', found TestGetObservedGenerationCodeInterpreter"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/apis/runtime/v1alpha1/types_test.go":[{"range":{"start":{"line":664,"character":27},"end":{"line":664,"character":27}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field TargetPorts"},{"range":{"start":{"line":680,"character":20},"end":{"line":680,"character":20}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field MaxSessionDuration"},{"range":{"start":{"line":681,"character":16},"end":{"line":681,"character":16}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field SessionTimeout"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_valkey.go":[{"range":{"start":{"line":156,"character":43},"end":{"line":156,"character":58}},"severity":1,"code":"MissingFieldOrMethod","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#MissingFieldOrMethod"},"source":"compiler","message":"vs.cli.B().Zadd().Key(vs.expiryIndexKey).ZaddScoreMember undefined (type cmds.ZaddKey has no field or method ZaddScoreMember)"},{"range":{"start":{"line":156,"character":66},"end":{"line":156,"character":81}},"severity":1,"code":"UndeclaredImportedName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredImportedName"},"source":"compiler","message":"undefined: valkey.ZaddScoreMember"},{"range":{"start":{"line":157,"character":49},"end":{"line":157,"character":64}},"severity":1,"code":"MissingFieldOrMethod","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#MissingFieldOrMethod"},"source":"compiler","message":"vs.cli.B().Zadd().Key(vs.lastActivityIndexKey).ZaddScoreMember undefined (type cmds.ZaddKey has no field or method ZaddScoreMember)"},{"range":{"start":{"line":157,"character":72},"end":{"line":157,"character":87}},"severity":1,"code":"UndeclaredImportedName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredImportedName"},"source":"compiler","message":"undefined: valkey.ZaddScoreMember"},{"range":{"start":{"line":337,"character":64},"end":{"line":337,"character":69}},"severity":1,"code":"MissingFieldOrMethod","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#MissingFieldOrMethod"},"source":"compiler","message":"vs.cli.B().Zadd().Key(vs.lastActivityIndexKey).Score undefined (type cmds.ZaddKey has no field or method Score)"},{"range":{"start":{"line":347,"character":8},"end":{"line":347,"character":22}},"severity":1,"code":"TooManyValues","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#TooManyValues"},"source":"compiler","message":"vs.cli.Close() (no value) used as value"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/expiration_test.go":[{"range":{"start":{"line":93,"character":15},"end":{"line":93,"character":21}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: metav1"}]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/design.md\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/design.md\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/design.md\n@@ -1687,5 +1687,316 @@\n 3. Set `VALKEY_PASSWORD`\n 4. Optionally set `VALKEY_DISABLE_CACHE=true`\n 5. Ensure cluster mode if using multiple Valkey nodes\n \n-Key compatibility is maintained across both backends (same key schema, same ZSET semantics).\n\\ No newline at end of file\n+Key compatibility is maintained across both backends (same key schema, same ZSET semantics).\n+\n+---\n+\n+# AR-018 — Agentd 空闲清理控制器\n+\n+- **AR ID**: AR-018\n+- **Module**: `pkg/agentd`\n+- **Language**: Go\n+- **Size**: S\n+- **Status**: Draft\n+\n+## 1. 概述\n+\n+Agentd Idle Cleanup Controller 监控 `runtime.agentcube.volcano.sh/v1alpha1` API 组的 `AgentRuntime` 和 `CodeInterpreter` 资源。当资源因长时间无活动而空闲时，控制器自动删除这些资源以释放集群资源。\n+\n+### 1.1 目标\n+\n+- 自动清理空闲过期的 AgentRuntime 资源\n+- 自动清理空闲过期的 CodeInterpreter 资源\n+- 通过 annotation (`agentcube.io/last-activity-time`) 跟踪最后活动时间\n+- 支持可配置的空闲超时阈值\n+\n+### 1.2 依赖\n+\n+- `github.com/volcano/sh/agentcube/client-go` — Kubernetes typed client\n+- `k8s.io/apimachinery` — API 类型定义\n+- `sigs.k8s.io/controller-runtime` — Controller 框架\n+\n+---\n+\n+## 2. 架构设计\n+\n+### 2.1 组件结构\n+\n+```\n+┌─────────────────────────────────────────────────────────────┐\n+│                      agentd binary                          │\n+│  ┌────────────────────────────────────────────────────────┐ │\n+│  │               controller-runtime Manager               │ │\n+│  │  ┌────────────────────────────────────────────────────┐│ │\n+│  │  │         IdleCleanupReconciler                      ││ │\n+│  │  │  ┌──────────────────┐  ┌────────────────────┐     ││ │\n+│  │  │  │ AgentRuntime     │  │ CodeInterpreter    │     ││ │\n+│  │  │  │ Controller       │  │ Controller         │     ││ │\n+│  │  │  └──────────────────┘  └────────────────────┘     ││ │\n+│  │  └────────────────────────────────────────────────────┘│ │\n+│  └────────────────────────────────────────────────────────┘ │\n+└─────────────────────────────────────────────────────────────┘\n+```\n+\n+### 2.2 包结构\n+\n+```\n+cmd/agentd/main.go              # Binary entry point\n+pkg/agentd/\n+├── reconciler.go               # Reconciler 实现\n+├── options.go                  # Controller 配置选项\n+├── controller.go               # Controller 注册\n+└── suite_test.go               # 测试套件\n+```\n+\n+### 2.3 监听资源\n+\n+| API Group | Version | Kind | Trigger |\n+|-----------|---------|------|---------|\n+| `runtime.agentcube.volcano.sh` | `v1alpha1` | `AgentRuntime` | Create/Update/Delete 事件 |\n+| `runtime.agentcube.volcano.sh` | `v1alpha1` | `CodeInterpreter` | Create/Update/Delete 事件 |\n+\n+---\n+\n+## 3. 数据结构\n+\n+### 3.1 配置常量\n+\n+```go\n+package agentd\n+\n+const (\n+    DefaultSessionExpirationTimeout = 15 * time.Minute\n+    DefaultRequeueDelayOnError      = 30 * time.Second\n+    LastActivityAnnotationKey       = \"agentcube.io/last-activity-time\"\n+)\n+```\n+\n+### 3.2 Controller 选项\n+\n+```go\n+type ControllerOptions struct {\n+    SessionExpirationTimeout time.Duration\n+    MaxConcurrentReconciles  int\n+}\n+```\n+\n+默认值：\n+- `SessionExpirationTimeout`: 15 分钟\n+- `MaxConcurrentReconciles`: 1\n+\n+### 3.3 Reconciler\n+\n+```go\n+type Reconciler struct {\n+    client.Client\n+    Scheme *runtime.Scheme\n+    \n+    expirationTimeout time.Duration\n+}\n+\n+func NewReconciler(c client.Client, s *runtime.Scheme, timeout time.Duration) *Reconciler\n+func (r *Reconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error)\n+func (r *Reconciler) SetupWithManager(mgr ctrl.Manager) error\n+```\n+\n+---\n+\n+## 4. API 合约\n+\n+### 4.1 AgentRuntime\n+\n+```go\n+// AgentRuntimeSpec 包含会话时间配置\n+type AgentRuntimeSpec struct {\n+    MaxSessionDuration string `json:\"maxSessionDuration\"` // 例如: \"8h\"\n+    SessionTimeout     string `json:\"sessionTimeout\"`     // 例如: \"15m\"\n+    TargetPorts        []TargetPort `json:\"targetPorts\"`\n+    PodTemplate        *PodTemplateSpec `json:\"podTemplate,omitempty\"`\n+}\n+```\n+\n+**空闲检测**：控制器读取 `agentcube.io/last-activity-time` annotation。如果存在且超过 `SessionExpirationTimeout`，则删除资源。\n+\n+### 4.2 CodeInterpreter\n+\n+```go\n+// CodeInterpreterSpec 包含会话时间配置\n+type CodeInterpreterSpec struct {\n+    AuthMode             AuthMode `json:\"authMode,omitempty\"`\n+    MaxSessionDuration   string   `json:\"maxSessionDuration,omitempty\"`\n+    SessionTimeout       string   `json:\"sessionTimeout,omitempty\"`\n+    Ports                []TargetPort `json:\"ports,omitempty\"`\n+    Template             ContainerTemplateSpec `json:\"template\"`\n+    WarmPoolSize         int32    `json:\"warmPoolSize,omitempty\"`\n+}\n+```\n+\n+**空闲检测**：与 AgentRuntime 相同 — 读取 `agentcube.io/last-activity-time` annotation。\n+\n+---\n+\n+## 5. 调和逻辑\n+\n+### 5.1 算法\n+\n+```\n+1. 按 namespace/name 获取资源 (AgentRuntime 或 CodeInterpreter)\n+2. 如果 NotFound → 返回 nil error, 不重队列\n+3. 如果其他获取错误 → 返回错误, 不重队列\n+4. 读取 \"agentcube.io/last-activity-time\" annotation\n+5. 如果 annotation 不存在或为空 → 返回 nil, 不重队列\n+6. 将 annotation 值解析为 time.RFC3339\n+   - 如果解析错误 → 30 秒后重队列并返回错误\n+7. 计算 expirationTime = lastActivityTime + SessionExpirationTimeout\n+8. 如果 time.Now().After(expirationTime):\n+   a. 删除资源\n+   b. 如果 NotFound → 返回 nil, 不重队列\n+   c. 如果其他删除错误 → 返回错误, 不重队列\n+9. 否则 (未过期):\n+   a. 计算 requeueAfter = time.Until(expirationTime)\n+   b. 返回 RequeueAfter, 无错误\n+10. 返回 nil, 不重队列\n+```\n+\n+### 5.2 重队列行为\n+\n+| 条件 | RequeueAfter | 原因 |\n+|------|--------------|------|\n+| 解析错误 | 30s | 固定延迟后重试 |\n+| 未过期 | `time.Until(expirationTime)` | 等待过期 |\n+| 已删除/未找到/无 annotation | 0 | 不重队列 |\n+\n+---\n+\n+## 6. 错误处理\n+\n+### 6.1 删除幂等性\n+\n+- **删除时 NotFound**: 视为成功，返回 `(ctrl.Result{}, nil)`\n+- **其他删除错误**: 返回错误以触发重试\n+\n+### 6.2 获取 NotFound\n+\n+- **获取时 NotFound**: 返回 `(ctrl.Result{}, nil)` — 资源已被移除\n+\n+### 6.3 解析错误\n+\n+- 无效时间戳格式 → 返回 `RequeueAfter: 30s` 和错误\n+\n+---\n+\n+## 7. 测试策略\n+\n+### 7.1 单元测试\n+\n+1. **ReconcileAgentRuntime**\n+   - 测试过期时成功删除\n+   - 测试无 annotation 时不删除\n+   - 测试未过期时不删除 (验证重队列)\n+   - 测试解析错误处理\n+   - 测试 Get NotFound 返回 nil\n+   - 测试 Delete NotFound 返回 nil\n+\n+2. **ReconcileCodeInterpreter**\n+   - 与 AgentRuntime 相同的测试用例\n+\n+### 7.2 测试夹具\n+\n+```go\n+func TestReconciler_Reconcile(t *testing.T) {\n+    tests := []struct {\n+        name           string\n+        annotation     string\n+        expires        bool\n+        expectedResult ctrl.Result\n+        expectDelete   bool\n+        expectError    bool\n+    }{\n+        {\n+            name:           \"expired - should delete\",\n+            annotation:     \"2024-01-01T00:00:00Z\",\n+            expires:        true,\n+            expectedResult: ctrl.Result{},\n+            expectDelete:   true,\n+            expectError:    false,\n+        },\n+        {\n+            name:           \"not expired - should requeue\",\n+            annotation:     time.Now().Add(-5 * time.Minute).Format(time.RFC3339),\n+            expires:        false,\n+            expectedResult: ctrl.Result{RequeueAfter: 10 * time.Minute},\n+            expectDelete:   false,\n+            expectError:    false,\n+        },\n+    }\n+}\n+```\n+\n+### 7.3 集成测试\n+\n+1. **完整调和循环** — 使用 fake client\n+2. **Manager 集成** — 两个 controller 都已注册\n+3. **信号处理** — 验证优雅关闭\n+\n+---\n+\n+## 8. Manager 配置\n+\n+```go\n+mgr, err := ctrl.NewManager(ctrl.GetConfigOrDie(), ctrl.Options{\n+    Scheme:                 schemeBuilder,\n+    Metrics:                metricsserver.Options{BindAddress: \"0\"},\n+    HealthProbeBindAddress: \"0\",\n+})\n+```\n+\n+### 8.1 注册 Controller\n+\n+```go\n+// AgentRuntime controller\n+err = ctrl.NewControllerManagedBy(mgr).\n+    For(&runtimev1alpha1.AgentRuntime{}).\n+    Complete(agentd.NewReconciler(mgr.GetClient(), mgr.GetScheme(), 15*time.Minute))\n+\n+// CodeInterpreter controller\n+err = ctrl.NewControllerManagedBy(mgr).\n+    For(&runtimev1alpha1.CodeInterpreter{}).\n+    Complete(agentd.NewReconciler(mgr.GetClient(), mgr.GetScheme(), 15*time.Minute))\n+```\n+\n+---\n+\n+## 9. 生命周期\n+\n+### 9.1 启动\n+\n+1. 解析 flags / 环境变量获取配置\n+2. 使用 scheme 构建 controller-runtime manager\n+3. 注册两个 controller\n+4. 使用 signal handler 启动 manager\n+\n+### 9.2 关闭\n+\n+- SIGTERM / SIGINT 触发优雅关闭\n+- Manager 停止所有 controller\n+- Cache 停止\n+- Process 以 exit code 0 退出\n+\n+---\n+\n+## 10. 依赖\n+\n+### 10.1 直接导入\n+\n+- `k8s.io/apimachinery/pkg/api/errors`\n+- `k8s.io/apimachinery/pkg/runtime`\n+- `k8s.io/apimachinery/pkg/runtime/schema`\n+- `k8s.io/client-go/tools/cache`\n+- `sigs.k8s.io/controller-runtime`\n+- `sigs.k8s.io/controller-runtime/pkg/client`\n+- `sigs.k8s.io/controller-runtime/pkg/controller`\n+- `sigs.k8s.io/controller-runtime/pkg/manager`\n+- `github.com/volcano.sh/agentcube/pkg/apis/runtime/v1alpha1`\n+- `github.com/volcano.sh/agentcube/client-go` (client-go 库)\n\\ No newline at end of file\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/design.md","before":"# AR-007 — K8s Reconciler Controller\n\n- **AR ID**: AR-007\n- **Module**: pkg/workloadmanager\n- **Language**: Go\n- **Size**: L\n- **Status**: ST-1 Completed (design.md)\n\n## 1. Architecture\n\n### 1.1 Overview\n\nThe K8s Reconciler Controller is a Kubernetes controller that watches `AgentRuntime` and `CodeInterpreter` custom resources and ensures the desired runtime state matches the actual cluster state. It provides declarative management of sandbox runtimes through the Kubernetes API server, enabling native Kubernetes patterns for resource lifecycle management.\n\n### 1.2 Component Structure\n\n```\npkg/workloadmanager/\n├── controller/\n│   ├── controller.go           # Controller framework & reconciliation loop\n│   ├── reconciler.go           # Reconciler implementation\n│   ├── agentruntime_reconciler.go    # AgentRuntime-specific reconciliation\n│   ├── codeinterpreter_reconciler.go # CodeInterpreter-specific reconciliation\n│   └── controller_test.go      # Controller tests\n├── informer/\n│   ├── factory.go              # Shared informer factory setup\n│   └── handlers.go             # Custom event handlers\n├── reconciler/\n│   ├── types.go                # Reconciler data structures\n│   ├── status.go               # Status update utilities\n│   ├── conditions.go           # Condition helpers\n│   └── finalizer.go            # Finalizer management\n├── client.go                   # Kubernetes client initialization (existing)\n├── service.go                  # WorkloadManager interface (existing)\n├── server.go                   # HTTP server (existing)\n└── types.go                    # Request/Response types (existing)\n```\n\n### 1.3 Architecture Diagram\n\n```\n┌─────────────────────────────────────────────────────────────────────────┐\n│                         Kubernetes API Server                           │\n│  ┌─────────────────┐  ┌─────────────────┐  ┌────────────────────────┐ │\n│  │ AgentRuntime    │  │ CodeInterpreter │  │ Pods/Service/ConfigMap  │ │\n│  │ (CRD)           │  │ (CRD)           │  │ (Managed Resources)     │ │\n│  └────────┬────────┘  └────────┬────────┘  └───────────┬────────────┘ │\n│           │                     │                        │              │\n└───────────┼─────────────────────┼────────────────────────┼──────────────┘\n            │                     │                        │\n            ▼                     ▼                        ▼\n┌─────────────────────────────────────────────────────────────────────────┐\n│                    K8s Reconciler Controller                            │\n│  ┌─────────────────────────────────────────────────────────────────────┐ │\n│  │                    SharedInformerFactory                           │ │\n│  │  ┌──────────────────────┐    ┌──────────────────────────────────┐ │ │\n│  │  │ AgentRuntime Informer│    │ CodeInterpreter Informer        │ │ │\n│  │  └──────────┬───────────┘    └───────────────┬──────────────────┘ │ │\n│  │             │                                  │                    │ │\n│  │             ▼                                  ▼                    │ │\n│  │  ┌──────────────────────┐    ┌──────────────────────────────────┐ │ │\n│  │  │ AgentRuntime Lister  │    │ CodeInterpreter Lister           │ │ │\n│  │  └──────────────────────┘    └──────────────────────────────────┘ │ │\n│  └─────────────────────────────────────────────────────────────────────┘ │\n│                                    │                                      │\n│                                    ▼                                      │\n│  ┌─────────────────────────────────────────────────────────────────────┐ │\n│  │              Reconciliation Loop (WorkQueue)                       │ │\n│  │  ┌─────────────┐  ┌─────────────┐  ┌─────────────┐  ┌──────────┐ │ │\n│  │  │  Enqueue    │→ │   Reconcile  │→ │   Update    │→ │  Update  │ │ │\n│  │  │  (trigger)  │  │   (compare)  │  │   (diff)    │  │  Status  │ │ │\n│  │  └─────────────┘  └─────────────┘  └─────────────┘  └──────────┘ │ │\n│  └─────────────────────────────────────────────────────────────────────┘ │\n└─────────────────────────────────────────────────────────────────────────┘\n                                    │\n                                    ▼\n┌─────────────────────────────────────────────────────────────────────────┐\n│                     WorkloadManager Service                             │\n│  ┌─────────────────────────────────────────────────────────────────────┐ │\n│  │  HTTP API Layer (server.go)                                        │ │\n│  │  - CRUD operations for AgentRuntime/CodeInterpreter                │ │\n│  │  - Sandbox lifecycle management                                    │ │\n│  └─────────────────────────────────────────────────────────────────────┘ │\n└─────────────────────────────────────────────────────────────────────────┘\n```\n\n### 1.4 Reconciliation Flow\n\n```\n                    ┌─────────────────────┐\n                    │  Object Created/    │\n                    │  Updated/Deleted    │\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Informer Event     │\n                    │  (Add/Update/Delete)│\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Enqueue with Key   │\n                    │  (namespace/name)   │\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Get from Lister   │\n                    │  (cached object)    │\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Reconcile Object   │\n                    │                     │\n                    │  1. Fetch latest    │\n                    │  2. Check deletion  │\n                    │  3. Ensure finalizer│\n                    │  4. Reconcile spec  │\n                    │  5. Update status   │\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Update Status     │\n                    │  (conditions, gen)  │\n                    └─────────────────────┘\n```\n\n## 2. Data Structures\n\n### 2.1 Controller Types\n\n```go\n// ControllerConfig holds controller configuration\ntype ControllerConfig struct {\n    // Namespace to watch. Empty means all namespaces.\n    Namespace string\n    \n    // ResyncPeriod is the period to force a full sync\n    ResyncPeriod time.Duration\n    \n    // MaxConcurrentReconciles is the max concurrent reconciliation threads\n    MaxConcurrentReconciles int\n    \n    // Reconciler is the actual reconcile logic implementation\n    Reconciler Reconciler\n    \n    // Client is the Kubernetes clientset\n    Client kubernetes.Interface\n    \n    // Scheme is the API scheme\n    Scheme *runtime.Scheme\n}\n\n// Controller manages the reconciliation loop\ntype Controller interface {\n    // Run starts the controller\n    Run(ctx context.Context, workers int) error\n    \n    // WaitForCacheSync waits for informers to sync\n    WaitForCacheSync(ctx context.Context) bool\n    \n    // GetHandler returns the event handler\n    GetHandler() cache.HandlerFuncs\n}\n```\n\n### 2.2 Reconciler Interface\n\n```go\n// Reconciler reconciles AgentRuntime and CodeInterpreter resources\ntype Reconciler interface {\n    // ReconcileAgentRuntime reconciles an AgentRuntime resource\n    ReconcileAgentRuntime(ctx context.Context, req reconcile.Request) (reconcile.Result, error)\n    \n    // ReconcileCodeInterpreter reconciles a CodeInterpreter resource  \n    ReconcileCodeInterpreter(ctx context.Context, req reconcile.Request) (reconcile.Result, error)\n    \n    // SetupWithManager sets up the controller with a manager\n    SetupWithManager(mgr ctrl.Manager, options ControllerOptions) error\n}\n\n// AgentRuntimeReconciler reconciles AgentRuntime resources\ntype AgentRuntimeReconciler struct {\n    client     client.Client\n    scheme     *runtime.Scheme\n    log        logr.Logger\n    recorder   record.EventRecorder\n}\n\n// CodeInterpreterReconciler reconciles CodeInterpreter resources\ntype CodeInterpreterReconciler struct {\n    client     client.Client\n    scheme     *runtime.Scheme\n    log        logr.Logger\n    recorder   record.EventRecorder\n}\n```\n\n### 2.3 Reconciliation Request\n\n```go\n// Request contains the information required to reconcile a resource\ntype Request struct {\n    // Namespace is the namespace of the resource\n    Namespace string\n    \n    // Name is the name of the resource\n    Name string\n}\n```\n\n### 2.4 Reconciliation Result\n\n```go\n// Result contains the result of a reconciliation\ntype Result struct {\n    // Requeue requests immediate requeue\n    Requeue bool\n    \n    // RequeueAfter requests requeue after the specified duration\n    RequeueAfter time.Duration\n    \n    // Error is the reconciliation error\n    Error error\n}\n\n// RequeueOnError returns a Result that requeues on error\nfunc RequeueOnError(err error) Result {\n    return Result{Requeue: true, Error: err}\n}\n\n// NoRequeue returns a Result that does not requeue\nfunc NoRequeue() Result {\n    return Result{Requeue: false}\n}\n\n// RequeueAfter returns a Result that requeues after the specified duration\nfunc RequeueAfter(after time.Duration) Result {\n    return Result{Requeue: true, RequeueAfter: after}\n}\n```\n\n### 2.5 Status Types\n\n```go\n// ReconcileStatus contains the reconciliation status information\ntype ReconcileStatus struct {\n    // ObservedGeneration is the generation observed\n    ObservedGeneration int64\n    \n    // Conditions is the list of conditions\n    Conditions []metav1.Condition\n    \n    // Phase is the current phase\n    Phase ReconcilePhase\n    \n    // Message is the status message\n    Message string\n}\n\ntype ReconcilePhase string\n\nconst (\n    ReconcilePhasePending   ReconcilePhase = \"Pending\"\n    ReconcilePhaseRunning   ReconcilePhase = \"Running\"\n    ReconcilePhaseSucceeded ReconcilePhase = \"Succeeded\"\n    ReconcilePhaseFailed    ReconcilePhase = \"Failed\"\n)\n\n// Condition types for AgentRuntime\nconst (\n    AgentRuntimeConditionReady     = \"Ready\"\n    AgentRuntimeConditionReconciled = \"Reconciled\"\n    AgentRuntimeConditionInitialized = \"Initialized\"\n)\n\n// Condition types for CodeInterpreter\nconst (\n    CodeInterpreterConditionReady     = \"Ready\"\n    CodeInterpreterConditionReconciled = \"Reconciled\"\n    CodeInterpreterConditionPodReady   = \"PodReady\"\n    CodeInterpreterConditionWarmPoolReady = \"WarmPoolReady\"\n)\n```\n\n### 2.6 Finalizer Types\n\n```go\nconst (\n    // FinalizerAgentRuntime is the standard finalizer for AgentRuntime\n    FinalizerAgentRuntime = \"agentruntime.agentcube.volcano.sh/deletion-protection\"\n    \n    // FinalizerCodeInterpreter is the standard finalizer for CodeInterpreter\n    FinalizerCodeInterpreter = \"codeinterpreter.agentcube.volcano.sh/deletion-protection\"\n)\n\n// FinalizerManager handles finalizer operations\ntype FinalizerManager interface {\n    // AddFinalizer adds a finalizer to the resource\n    AddFinalizer(ctx context.Context, obj client.Object) error\n    \n    // RemoveFinalizer removes a finalizer from the resource\n    RemoveFinalizer(ctx context.Context, obj client.Object) error\n    \n    // HasFinalizer checks if the resource has a specific finalizer\n    HasFinalizer(obj client.Object, finalizer string) bool\n    \n    // EnsureFinalizer ensures the finalizer is present\n    EnsureFinalizer(ctx context.Context, obj client.Object, finalizer string) error\n}\n```\n\n### 2.7 Reconcile Options\n\n```go\n// ReconcileOptions contains options for reconciliation\ntype ReconcileOptions struct {\n    // SkipStatusUpdate skips updating the status\n    SkipStatusUpdate bool\n    \n    // SkipFinalizerCheck skips checking finalizers\n    SkipFinalizerCheck bool\n    \n    // ForceReconcile forces reconciliation even if up-to-date\n    ForceReconcile bool\n}\n\n// ReconcileOptionsFunc modifies ReconcileOptions\ntype ReconcileOptionsFunc func(*ReconcileOptions)\n\n// WithSkipStatusUpdate sets the skip status update option\nfunc WithSkipStatusUpdate(skip bool) ReconcileOptionsFunc {\n    return func(o *ReconcileOptions) {\n        o.SkipStatusUpdate = skip\n    }\n}\n```\n\n## 3. API Contracts\n\n### 3.1 Controller Setup\n\nThe controller uses the controller-runtime framework for integration with Kubernetes:\n\n```go\n// NewAgentRuntimeReconciler creates a new AgentRuntimeReconciler\nfunc NewAgentRuntimeReconciler(\n    client client.Client,\n    log logr.Logger,\n    recorder record.EventRecorder,\n) *AgentRuntimeReconciler\n\n// NewCodeInterpreterReconciler creates a new CodeInterpreterReconciler\nfunc NewCodeInterpreterReconciler(\n    client client.Client,\n    log logr.Logger,\n    recorder record.EventRecorder,\n) *CodeInterpreterReconciler\n\n// SetupWithManager sets up the reconciler with the manager\nfunc (r *AgentRuntimeReconciler) SetupWithManager(mgr ctrl.Manager, opts controller.Options) error {\n    return ctrl.NewControllerManagedBy(mgr).\n        For(&agentcubev1alpha1.AgentRuntime{}).\n        Owns(&corev1.Pod{}).\n        WithOptions(opts).\n        Complete(r)\n}\n```\n\n### 3.2 Reconciliation Triggers\n\n| Trigger | Source | Action |\n|---------|--------|--------|\n| Object Created | Informer (Add) | Enqueue Request |\n| Object Updated | Informer (Update) | Enqueue Request if spec/status changed |\n| Object Deleted | Informer (Delete) | Enqueue Request (cleanup) |\n| Owner Deleted | Owner's Informer | Enqueue dependent (cleanup) |\n| Periodic Sync | Controller (Resync) | Enqueue all objects |\n| Manual Retry | External | Enqueue specific Request |\n\n### 3.3 Status Update Contracts\n\n```go\n// UpdateStatus updates the resource status with reconciliation results\nfunc (r *AgentRuntimeReconciler) UpdateStatus(\n    ctx context.Context,\n    obj *agentcubev1alpha1.AgentRuntime,\n    conditions []metav1.Condition,\n    phase ReconcilePhase,\n) error {\n    obj.Status.ObservedGeneration = obj.Generation\n    obj.Status.Conditions = conditions\n    \n    // Set phase condition\n    metav1.SetStatusCondition(&obj.Status.Conditions, metav1.Condition{\n        Type:               string(phase),\n        Status:             metav1.ConditionTrue,\n        ObservedGeneration: obj.Generation,\n        LastTransitionTime: metav1.Now(),\n    })\n    \n    return r.client.Status().Update(ctx, obj)\n}\n\n// PatchStatus patches the resource status using strategic merge\nfunc (r *AgentRuntimeReconciler) PatchStatus(\n    ctx context.Context,\n    obj *agentcubev1alpha1.AgentRuntime,\n    patch *agentcubev1alpha1.AgentRuntime,\n) error {\n    return r.client.Status().Patch(ctx, patch, client.MergeFrom(obj))\n}\n```\n\n### 3.4 Event Recording\n\n```go\n// Events recorded during reconciliation\nconst (\n    // AgentRuntime Events\n    EventReconciling    = \"Reconciling\"\n    EventReconcileSucceeded = \"ReconcileSucceeded\"\n    EventReconcileFailed = \"ReconcileFailed\"\n    EventFinalizerAdded = \"FinalizerAdded\"\n    EventFinalizerRemoved = \"FinalizerRemoved\"\n    EventPodCreated = \"PodCreated\"\n    EventPodDeleted = \"PodDeleted\"\n    \n    // CodeInterpreter Events\n    EventWarmPoolCreating = \"WarmPoolCreating\"\n    EventWarmPoolReady = \"WarmPoolReady\"\n    EventPodReady = \"PodReady\"\n)\n\n// Example event recording\nr.recorder.Eventf(ar, corev1.EventTypeNormal, EventReconciling, \n    \"Reconciling AgentRuntime %s/%s\", ar.Namespace, ar.Name)\n```\n\n### 3.5 Owner Reference\n\nResources are owned by the CR and get garbage collected when CR is deleted:\n\n```go\n// OwnerReference creates an owner reference for the resource\nfunc OwnerReference(owner client.Object) []metav1.OwnerReference {\n    return []metav1.OwnerReference{\n        *metav1.NewControllerRef(owner, owner.GetObjectKind().GroupVersionKind()),\n    }\n}\n\n// IsOwnedBy checks if the object is owned by the given owner\nfunc IsOwnedBy(obj metav1.Object, owner metav1.OwnerReference) bool {\n    return obj.GetController() != nil && \n           *obj.GetController().UID == owner.UID\n}\n```\n\n## 4. Error Handling\n\n### 4.1 Error Types\n\n```go\nvar (\n    // ErrNotFound is returned when the resource is not found\n    ErrNotFound = errors.New(\"resource not found\")\n    \n    // ErrNotReady is returned when the resource is not ready\n    ErrNotReady = errors.New(\"resource not ready\")\n    \n    // ErrStaleGeneration is returned when the generation has changed\n    ErrStaleGeneration = errors.New(\"stale generation\")\n    \n    // ErrReconcileFailed is returned when reconciliation fails\n    ErrReconcileFailed = errors.New(\"reconciliation failed\")\n    \n    // ErrFinalizerFailed is returned when a finalizer operation fails\n    ErrFinalizerFailed = errors.New(\"finalizer operation failed\")\n    \n    // ErrDependencyNotReady is returned when a dependency is not ready\n    ErrDependencyNotReady = errors.New(\"dependency not ready\")\n    \n    // ErrMaxRetriesExceeded is returned when max retries are exceeded\n    ErrMaxRetriesExceeded = errors.New(\"max retries exceeded\")\n)\n```\n\n### 4.2 Error Handling Strategies\n\n```go\n// HandleError handles reconciliation errors with logging and status update\nfunc (r *AgentRuntimeReconciler) HandleError(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime, err error) (reconcile.Result, error) {\n    // Log the error\n    r.log.Error(err, \"Reconciliation failed\", \"namespace\", ar.Namespace, \"name\", ar.Name)\n    \n    // Record failure event\n    r.recorder.Eventf(ar, corev1.EventTypeWarning, EventReconcileFailed, \n        \"Reconciliation failed: %v\", err)\n    \n    // Update status with error condition\n    metav1.SetStatusCondition(&ar.Status.Conditions, metav1.Condition{\n        Type:    AgentRuntimeConditionReconciled,\n        Status:  metav1.ConditionFalse,\n        Reason:  \"ReconciliationFailed\",\n        Message: err.Error(),\n    })\n    \n    // Update status\n    if updateErr := r.client.Status().Update(ctx, ar); updateErr != nil {\n        r.log.Error(updateErr, \"Failed to update status\")\n    }\n    \n    // Determine requeue behavior\n    if errors.Is(err, ErrMaxRetriesExceeded) {\n        return reconcile.Result{}, nil // Don't requeue\n    }\n    \n    // Requeue after error with exponential backoff\n    return reconcile.Result{RequeueAfter: time.Minute}, nil\n}\n\n// IsRetryable checks if an error is retryable\nfunc IsRetryable(err error) bool {\n    if errors.Is(err, context.DeadlineExceeded) {\n        return true\n    }\n    if errors.Is(err, ErrDependencyNotReady) {\n        return true\n    }\n    return false\n}\n```\n\n### 4.3 Error Response Mapping\n\n| Error Type | HTTP Status | K8s Reason | Action |\n|------------|-------------|------------|--------|\n| NotFound | 404 | NotFound | Stop reconciliation |\n| NotReady | Unprocessable | NotReady | Requeue |\n| StaleGeneration | Conflict | Conflict | Requeue with latest |\n| ReconcileFailed | 500 | InternalError | Requeue with backoff |\n| FinalizerFailed | 500 | InternalError | Requeue |\n| DependencyNotReady | Unprocessable | ErrDepNotReady | Requeue |\n| MaxRetriesExceeded | 500 | InternalError | Stop, alert |\n\n### 4.4 Condition Error Helpers\n\n```go\n// SetErrorCondition sets an error condition on the resource\nfunc SetErrorCondition(conditions *[]metav1.Condition, conditionType string, err error) {\n    metav1.SetStatusCondition(conditions, metav1.Condition{\n        Type:    conditionType,\n        Status:  metav1.ConditionFalse,\n        Reason:  \"Error\",\n        Message: err.Error(),\n    })\n}\n\n// SetSuccessCondition sets a success condition on the resource\nfunc SetSuccessCondition(conditions *[]metav1.Condition, conditionType string, message string) {\n    metav1.SetStatusCondition(conditions, metav1.Condition{\n        Type:               conditionType,\n        Status:             metav1.ConditionTrue,\n        Reason:             \"Success\",\n        Message:            message,\n        LastTransitionTime: metav1.Now(),\n    })\n}\n\n// SetPendingCondition sets a pending condition on the resource\nfunc SetPendingCondition(conditions *[]metav1.Condition, conditionType string, message string) {\n    metav1.SetStatusCondition(conditions, metav1.Condition{\n        Type:    conditionType,\n        Status:  metav1.ConditionUnknown,\n        Reason:  \"Pending\",\n        Message: message,\n    })\n}\n```\n\n## 5. Testing Strategy\n\n### 5.1 Unit Tests\n\n#### Reconciler Tests\n\n```go\nfunc TestAgentRuntimeReconciler_Reconcile(t *testing.T) {\n    // Setup fake client\n    fakeClient := fake.NewClientBuilder().\n        WithScheme(scheme).\n        WithObjects(agentRuntime).\n        Build()\n    \n    // Create reconciler\n    r := &AgentRuntimeReconciler{\n        client:   fakeClient,\n        log:      ctrl.Log.WithName(\"test\"),\n        recorder: record.NewFakeRecorder(10),\n    }\n    \n    // Test reconciliation\n    result, err := r.ReconcileAgentRuntime(ctx, reconcile.Request{\n        NamespacedName: types.NamespacedName{\n            Namespace: \"default\",\n            Name:      \"test-runtime\",\n        },\n    })\n    \n    // Assertions\n    require.NoError(t, err)\n    assert.False(t, result.Requeue)\n    \n    // Verify finalizer was added\n    updatedAR := &agentcubev1alpha1.AgentRuntime{}\n    err = fakeClient.Get(ctx, key, updatedAR)\n    require.NoError(t, err)\n    assert.Contains(t, updatedAR.Finalizers, FinalizerAgentRuntime)\n}\n```\n\n#### Finalizer Tests\n\n```go\nfunc TestFinalizerManager(t *testing.T) {\n    tests := []struct {\n        name       string\n        obj        client.Object\n        finalizer  string\n        wantHas    bool\n        wantUpdate bool\n    }{\n        {\n            name:       \"add finalizer to object without finalizer\",\n            obj:        &agentcubev1alpha1.AgentRuntime{},\n            finalizer:  FinalizerAgentRuntime,\n            wantHas:    true,\n            wantUpdate: true,\n        },\n        {\n            name: \"object already has finalizer\",\n            obj: &agentcubev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Finalizers: []string{FinalizerAgentRuntime},\n                },\n            },\n            finalizer:  FinalizerAgentRuntime,\n            wantHas:    true,\n            wantUpdate: false,\n        },\n    }\n    \n    for _, tt := range tests {\n        t.Run(tt.name, func(t *testing.T) {\n            fm := NewFinalizerManager(fakeClient)\n            \n            has := fm.HasFinalizer(tt.obj, tt.finalizer)\n            assert.Equal(t, tt.wantHas, has)\n        })\n    }\n}\n```\n\n### 5.2 Integration Tests\n\n```go\nfunc TestAgentRuntimeReconciler_Integration(t *testing.T) {\n    // Skip if not in integration test mode\n    if testing.Short() {\n        t.Skip(\"Skipping integration tests\")\n    }\n    \n    // Use envtest (kubebuilder)\n    env, err := envtest.Environment()\n    require.NoError(t, err)\n    \n    // Start test environment\n    cfg, err := env.Start()\n    require.NoError(t, err)\n    defer env.Stop()\n    \n    // Create manager\n    mgr, err := ctrl.NewManager(cfg, ctrl.Options{})\n    require.NoError(t, err)\n    \n    // Register reconciler\n    err = (&AgentRuntimeReconciler{\n        Client:   mgr.GetClient(),\n        Log:      mgr.GetLogger(),\n        Recorder: mgr.GetEventRecorderFor(\"agentruntime-controller\"),\n    }).SetupWithManager(mgr, controller.Options{})\n    require.NoError(t, err)\n    \n    // Start manager in goroutine\n    go func() {\n        err := mgr.Start(ctx)\n        require.NoError(t, err)\n    }()\n    \n    // Wait for cache sync\n    require.True(t, mgr.GetCache().WaitForCacheSync(ctx))\n    \n    // Create test resource\n    ar := &agentcubev1alpha1.AgentRuntime{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"test-runtime\",\n            Namespace: \"default\",\n        },\n        Spec: agentcubev1alpha1.AgentRuntimeSpec{\n            MaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n            SessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n            Ports:              []agentcubev1alpha1.TargetPort{{Port: 8080}},\n        },\n    }\n    \n    err = mgr.GetClient().Create(ctx, ar)\n    require.NoError(t, err)\n    \n    // Wait for reconciliation\n    time.Sleep(2 * time.Second)\n    \n    // Verify status was updated\n    updatedAR := &agentcubev1alpha1.AgentRuntime{}\n    err = mgr.GetClient().Get(ctx, key, updatedAR)\n    require.NoError(t, err)\n    \n    // Verify conditions\n    assert.Equal(t, 1, len(updatedAR.Status.Conditions))\n}\n```\n\n### 5.3 Controller Behavior Tests\n\n| Test Case | Input | Expected Output |\n|-----------|-------|-----------------|\n| Create Object | New AgentRuntime | Finalizer added, Status.Initialized = True |\n| Update Spec | Changed MaxSessionDuration | Status.Reconciled updated |\n| Update Status | Changed conditions | No requeue |\n| Delete with Finalizer | DeletionTimestamp set | Finalizer removed, then deleted |\n| Delete without Finalizer | DeletionTimestamp set | Directly deleted |\n| Dep Not Ready | Pod not created | Requeue |\n| Error During Reconcile | Reconciliation fails | Condition set to False, event recorded |\n\n### 5.4 Test Coverage Targets\n\n| Component | Target Coverage |\n|-----------|-----------------|\n| controller.go | 80% |\n| reconciler.go | 85% |\n| agentruntime_reconciler.go | 85% |\n| codeinterpreter_reconciler.go | 85% |\n| status.go | 90% |\n| finalizer.go | 90% |\n| conditions.go | 90% |\n\n### 5.5 Fake Clients Usage\n\n```go\nimport (\n    \"sigs.k8s.io/controller-runtime/pkg/client/fake\"\n    \"k8s.io/client-go/kubernetes/fake\"\n    agentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nfunc TestWithFakeClient(t *testing.T) {\n    // Initialize scheme with all types\n    scheme := runtime.NewScheme()\n    agentcubev1alpha1.AddToScheme(scheme)\n    corev1.AddToScheme(scheme)\n    \n    // Build fake client with initial objects\n    fakeClient := fake.NewClientBuilder().\n        WithScheme(scheme).\n        WithObjects(\n            &agentcubev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"test-runtime\",\n                    Namespace: \"default\",\n                },\n            },\n        ).\n        WithStatusSubresource(\n            &agentcubev1alpha1.AgentRuntime{},\n        ).\n        Build()\n    \n    // Use in reconciler\n    r := &AgentRuntimeReconciler{\n        client: fakeClient,\n    }\n    \n    // Test reconciliation\n    result, err := r.Reconcile(ctx, req)\n    assert.NoError(t, err)\n}\n```\n\n## 6. Dependencies\n\n### 6.1 Required Dependencies\n\n| Package | Version | Purpose |\n|---------|---------|---------|\n| sigs.k8s.io/controller-runtime | ^0.20.0 | Controller framework |\n| k8s.io/client-go | ^0.34.0 | Kubernetes client |\n| k8s.io/apimachinery | ^0.34.0 | API types |\n| k8s.io/klog/v2 | ^2.0 | Logging |\n| github.com/go-logr/logr | ^1.0 | Structured logging |\n| github.com/onsi/ginkgo | ^2.0 | Testing framework |\n| github.com/onsi/gomega | ^1.27 | Testing matchers |\n\n### 6.2 Internal Dependencies\n\n| Module | Purpose |\n|--------|---------|\n| github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1 | CRD types |\n| github.com/volcano-sh/agentcube/pkg/client/listers | Listers for caching |\n| github.com/volcano-sh/agentcube/pkg/client/informers | Informers for watching |\n\n## 7. Configuration\n\n### 7.1 Controller Configuration\n\n```go\n// ControllerOptions contains options for the controller\ntype ControllerOptions struct {\n    // MaxConcurrentReconciles is the number of concurrent reconciliation workers\n    MaxConcurrentReconciles int\n    \n    // ReconcilePeriod is the period between full reconciles\n    ReconcilePeriod time.Duration\n    \n    // FailureThreshold is the number of failures before stopping reconciliation\n    FailureThreshold int\n    \n    // ResourceNotFoundCacheDuration is the cache duration for not found errors\n    ResourceNotFoundCacheDuration time.Duration\n}\n\n// DefaultControllerOptions returns default options\nfunc DefaultControllerOptions() ControllerOptions {\n    return ControllerOptions{\n        MaxConcurrentReconciles:        10,\n        ReconcilePeriod:                time.Hour,\n        FailureThreshold:               3,\n        ResourceNotFoundCacheDuration: 1 * time.Minute,\n    }\n}\n```\n\n### 7.2 Environment Variables\n\n| Variable | Default | Description |\n|----------|---------|-------------|\n| WORKLOAD_CONTROLLER_NAME | agentcube-workload-controller | Controller name for identity |\n| WORKLOAD_CONTROLLER_NAMESPACE | agentcube-system | Namespace to watch |\n| MAX_CONCURRENT_RECONCILES | 10 | Concurrent workers |\n| RECONCILE_PERIOD | 1h | Full sync period |\n| LOG_LEVEL | info | Logging level |\n\n### 7.3 Leader Election\n\nThe controller supports leader election for high availability:\n\n```go\n// LeaderElectionConfig for controller manager\nLeaderElection:           true,\nLeaderElectionID:         \"agentcube-workload-controller-lock\",\nLeaderElectionNamespace:  \"agentcube-system\",  // or operator namespace\n```\n\n## 8. Monitoring\n\n### 8.1 Metrics\n\n| Metric | Type | Description |\n|--------|------|-------------|\n| reconcile_total | Counter | Total reconciliation attempts |\n| reconcile_duration_seconds | Histogram | Reconciliation duration |\n| reconcile_errors_total | Counter | Reconciliation errors |\n| reconcile_retries_total | Counter | Retry count |\n| controller_queue_depth | Gauge | Work queue depth |\n| controller_worker_count | Gauge | Active worker count |\n\n### 8.2 Health Checks\n\n```go\n// Healthz endpoint returns controller health\nr.GET(\"/healthz\", func(c *gin.Context) {\n    // Check if informers are synced\n    if !controller.WaitForCacheSync(ctx) {\n        c.JSON(http.StatusServiceUnavailable, gin.H{\"status\": \"not ready\"})\n        return\n    }\n    c.JSON(http.StatusOK, gin.H{\"status\": \"ready\"})\n})\n```\n\n## 9. Security\n\n### 9.1 RBAC Requirements\n\n```yaml\nrules:\n# AgentRuntime and CodeInterpreter CRUD\n- apiGroups: [\"runtime.agentcube.volcano.sh\"]\n  resources: [\"agentruntimes\", \"codeinterpreters\"]\n  verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"]\n\n# Status subresource\n- apiGroups: [\"runtime.agentcube.volcano.sh\"]\n  resources: [\"agentruntimes/status\", \"codeinterpreters/status\"]\n  verbs: [\"get\", \"update\", \"patch\"]\n\n# Managed resources (Pods, Services, ConfigMaps)\n- apiGroups: [\"\"]\n  resources: [\"pods\", \"services\", \"configmaps\", \"secrets\"]\n  verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"]\n\n# Events\n- apiGroups: [\"events.k8s.io\"]\n  resources: [\"events\"]\n  verbs: [\"create\", \"patch\"]\n```\n\n### 9.2 Security Considerations\n\n- Controller runs with minimal required RBAC permissions\n- Finalizers prevent garbage collection of resources with active dependents\n- Status updates use optimistic concurrency to prevent race conditions\n- All client operations include context with timeout\n\n# AR-009: Router HTTP 反向代理核心\n\n**AR Number:** AR-009  \n**Module:** `pkg/router`  \n**Language:** Go  \n**Size:** M  \n**Status:** Draft\n\n## 1. 概述\n\n`pkg/router` 是 agentcube 的 HTTP 反向代理核心模块，负责将外部 HTTP 请求路由到后端的 AgentRuntime 和 CodeInterpreter 实例。该模块基于 client-go 库与 Kubernetes API 交互，获取目标服务信息并执行代理转发。\n\n### 1.1 目标\n\n- 提供高性能 HTTP 反向代理能力\n- 支持动态服务发现（通过 Kubernetes API）\n- 支持 WebSocket 长连接\n- 实现流量控制和熔断机制\n- 提供可观测性（指标、日志、追踪）\n\n### 1.2 依赖\n\n- `github.com/volcano-sh/agentcube/client-go` — Kubernetes typed client\n- `k8s.io/client-go/rest` — REST 客户端\n- `k8s.io/apimachinery` — API 类型定义\n\n---\n\n## 2. 架构设计\n\n### 2.1 整体架构\n\n```\n                    ┌─────────────────┐\n                    │   Ingress       │\n                    │   (External)    │\n                    └────────┬────────┘\n                             │\n                    ┌────────▼────────┐\n                    │   Router        │\n                    │   Server        │\n                    │   (pkg/router)  │\n                    └────────┬────────┘\n                             │\n            ┌────────────────┼────────────────┐\n            │                │                │\n   ┌────────▼────────┐ ┌────▼────┐ ┌────────▼────────┐\n   │ AgentRuntime    │ │ Agent   │ │ CodeInterpreter │\n   │ Instance 1      │ │ Runtime │ │ Instance N      │\n   │                 │ │ Instance│ │                 │\n   └─────────────────┘ │ 2      │ └─────────────────┘\n                       └────────┘\n```\n\n### 2.2 核心组件\n\n| 组件 | 职责 |\n|------|------|\n| `ProxyServer` | HTTP/HTTPS 服务器生命周期管理 |\n| `RequestRouter` | 请求路径解析与目标选择 |\n| `ServiceDiscovery` | 通过 client-go 动态发现后端服务 |\n| `ProxyHandler` | 请求转发与响应回传 |\n| `ConnectionPool` | HTTP 连接池管理 |\n| `CircuitBreaker` | 熔断器实现 |\n| `MetricsCollector` | 指标采集 |\n\n### 2.3 数据流\n\n1. 客户端请求进入 `ProxyServer`\n2. `RequestRouter` 解析请求路径，提取 `namespace` 和 `resource`\n3. `ServiceDiscovery` 通过 client-go 查询对应的 `AgentRuntime` 或 `CodeInterpreter` 端点\n4. `CircuitBreaker` 检查目标实例健康状态\n5. `ProxyHandler` 建立到后端的连接并转发请求\n6. 响应回传后记录指标并返回客户端\n\n---\n\n## 3. 数据结构\n\n### 3.1 核心配置\n\n```go\n// Config holds router configuration\ntype Config struct {\n    // Server addresses\n    BindAddress string\n    Port        int\n    TLSConfig   *TLSConfig\n\n    // Client-go configuration\n    KubeConfigPath string\n    QPS           float32\n    Burst         int\n\n    // Proxy settings\n    MaxConnections     int\n    RequestTimeout     time.Duration\n    IdleTimeout        time.Duration\n    WebSocketEnabled   bool\n\n    // Circuit breaker\n    CircuitBreakerConfig CircuitBreakerConfig\n\n    // Metrics\n    MetricsEnabled bool\n    MetricsPort    int\n}\n\n// TLSConfig holds TLS settings\ntype TLSConfig struct {\n    CertFile string\n    KeyFile  string\n    CAFile   string\n}\n\n// CircuitBreakerConfig holds circuit breaker settings\ntype CircuitBreakerConfig struct {\n    FailureThreshold  int\n    SuccessThreshold  int\n    Timeout           time.Duration\n    HalfOpenMaxCalls  int\n}\n```\n\n### 3.2 服务发现\n\n```go\n// ServiceEndpoint represents a discovered backend service\ntype ServiceEndpoint struct {\n    Name      string\n    Namespace string\n    URL       string\n    Labels    map[string]string\n    Healthy   bool\n}\n\n// ServiceRegistry caches discovered service endpoints\ntype ServiceRegistry struct {\n    mu sync.RWMutex\n    // key: namespace/resource name\n    endpoints map[string][]ServiceEndpoint\n}\n```\n\n### 3.3 代理上下文\n\n```go\n// ProxyContext holds request context for proxying\ntype ProxyContext struct {\n    Context     context.Context\n    Request     *http.Request\n    Response    http.ResponseWriter\n    Target      *ServiceEndpoint\n    StartTime   time.Time\n    RequestID   string\n}\n```\n\n### 3.4 客户端接口\n\n使用 `github.com/volcano-sh/agentcube/client-go` 进行 Kubernetes API 交互：\n\n```go\n// RuntimeClient wraps client-go typed client\ntype RuntimeClient interface {\n    // AgentRuntime operations\n    GetAgentRuntime(ctx context.Context, namespace, name string) (*runtimev1alpha1.AgentRuntime, error)\n    ListAgentRuntimes(ctx context.Context, namespace string, opts metav1.ListOptions) (*runtimev1alpha1.AgentRuntimeList, error)\n    WatchAgentRuntimes(ctx context.Context, namespace string, opts metav1.ListOptions) (watch.Interface, error)\n\n    // CodeInterpreter operations\n    GetCodeInterpreter(ctx context.Context, namespace, name string) (*runtimev1alpha1.CodeInterpreter, error)\n    ListCodeInterpreters(ctx context.Context, namespace string, opts metav1.ListOptions) (*runtimev1alpha1.CodeInterpreterList, error)\n    WatchCodeInterpreters(ctx context.Context, namespace string, opts metav1.ListOptions) (watch.Interface, error)\n}\n```\n\n---\n\n## 4. API 合约\n\n### 4.1 路由规则\n\n| 路径模式 | 描述 |\n|----------|------|\n| `GET /api/v1/namespaces/{namespace}/agentruntimes/{name}` | 获取 AgentRuntime 详情 |\n| `GET /api/v1/namespaces/{namespace}/agentruntimes/{name}/proxy` | 代理到 AgentRuntime 端点 |\n| `GET /api/v1/namespaces/{namespace}/codeinterpreters/{name}` | 获取 CodeInterpreter 详情 |\n| `GET /api/v1/namespaces/{namespace}/codeinterpreters/{name}/proxy` | 代理到 CodeInterpreter 端点 |\n| `WS /api/v1/namespaces/{namespace}/agentruntimes/{name}/ws` | WebSocket 代理 |\n| `WS /api/v1/namespaces/{namespace}/codeinterpreters/{name}/ws` | WebSocket 代理 |\n| `GET /health` | 健康检查 |\n| `GET /metrics` | Prometheus 指标 |\n\n### 4.2 代理请求头\n\n| Header | 描述 |\n|--------|------|\n| `X-Request-ID` | 请求唯一标识 |\n| `X-Forwarded-For` | 原始客户端 IP |\n| `X-Forwarded-Proto` | 原始协议 |\n| `X-Real-IP` | 真实客户端 IP |\n| `X-Target-Namespace` | 目标命名空间 |\n| `X-Target-Name` | 目标资源名称 |\n\n### 4.3 响应格式\n\n成功响应：\n```json\n{\n  \"status\": \"success\",\n  \"data\": { ... }\n}\n```\n\n错误响应：\n```json\n{\n  \"status\": \"error\",\n  \"code\": \"ERR_CODE\",\n  \"message\": \"human readable message\",\n  \"requestId\": \"req-xxx\"\n}\n```\n\n### 4.4 状态码\n\n| 状态码 | 含义 |\n|--------|------|\n| 200 | 成功 |\n| 400 | 请求参数错误 |\n| 404 | 资源不存在 |\n| 502 | 后端服务不可用 |\n| 503 | 服务熔断中 |\n| 504 | 请求超时 |\n\n---\n\n## 5. 错误处理\n\n### 5.1 错误类型\n\n```go\n// Error codes\nconst (\n    ErrCodeBadRequest       = \"ERR_BAD_REQUEST\"\n    ErrCodeNotFound         = \"ERR_NOT_FOUND\"\n    ErrCodeTargetNotReady   = \"ERR_TARGET_NOT_READY\"\n    ErrCodeProxyFailed      = \"ERR_PROXY_FAILED\"\n    ErrCodeTimeout          = \"ERR_TIMEOUT\"\n    ErrCodeCircuitOpen      = \"ERR_CIRCUIT_OPEN\"\n    ErrCodeInternalError    = \"ERR_INTERNAL\"\n)\n\n// RouterError represents a router-specific error\ntype RouterError struct {\n    Code      string\n    Message   string\n    StatusCode int\n    Err       error\n}\n```\n\n### 5.2 处理策略\n\n| 错误类型 | 处理方式 |\n|----------|----------|\n| 客户端错误 (4xx) | 直接返回错误响应 |\n| 后端超时 | 熔断计数 + 返回 504 |\n| 后端连接失败 | 重试一次，失败则熔断 |\n| 资源不存在 | 返回 404 |\n| 熔断器开启 | 返回 503 |\n\n### 5.3 日志规范\n\n```go\n// 日志字段\nlog := zaplog.With(\n    \"requestId\", requestID,\n    \"method\", method,\n    \"path\", path,\n    \"namespace\", namespace,\n    \"target\", targetName,\n    \"latency\", latency,\n    \"statusCode\", statusCode,\n)\n```\n\n---\n\n## 6. 测试策略\n\n### 6.1 单元测试\n\n| 模块 | 测试重点 |\n|------|----------|\n| `RequestRouter` | 路径解析、目标选择逻辑 |\n| `ServiceDiscovery` | 缓存更新、并发安全 |\n| `ProxyHandler` | 请求转发、响应处理 |\n| `CircuitBreaker` | 状态转换、计数逻辑 |\n\n### 6.2 集成测试\n\n```go\n// 使用 fake client-go 进行集成测试\nimport (\n    \"k8s.io/client-go/kubernetes/fake\"\n    \"github.com/volcano-sh/agentcube/client-go/clientset/versioned/fake\"\n)\n\n// TestProxyFlow tests full proxy flow with fake clients\nfunc TestProxyFlow(t *testing.T) {\n    // Setup fake clients\n    kubeClient := fake.NewSimpleClientset()\n    runtimeClient := clientsetfake.NewSimpleClientset()\n    \n    // Create router with fake clients\n    router := NewRouter(Config{\n        RuntimeClient: runtimeClient,\n    })\n    \n    // Test proxy request\n    // ...\n}\n```\n\n### 6.3 测试场景\n\n1. **正常代理流程** — 端到端请求转发\n2. **服务发现更新** — 动态更新后端列表\n3. **熔断触发** — 失败次数达到阈值后熔断\n4. **熔断恢复** — 超时后尝试恢复\n5. **WebSocket 连接** — 长连接代理\n6. **并发安全** — 多请求同时处理\n\n### 6.4 Benchmark\n\n```go\n// BenchmarkRequestRouting benchmarks path parsing\nfunc BenchmarkRequestRouting(b *testing.B) {\n    // Setup\n    router := NewRouter(Config{})\n    \n    // Benchmark\n    b.ResetTimer()\n    for i := 0; i < b.N; i++ {\n        router.routeRequest(request)\n    }\n}\n```\n\n---\n\n## 7. 关键接口定义\n\n### 7.1 Router 接口\n\n```go\n// Router defines the interface for HTTP reverse proxy\ntype Router interface {\n    // Start begins serving HTTP requests\n    Start(ctx context.Context) error\n    \n    // Stop gracefully shuts down the router\n    Stop(ctx context.Context) error\n    \n    // RegisterRoute adds a custom route handler\n    RegisterRoute(pattern string, handler http.Handler)\n    \n    // Metrics returns current router metrics\n    Metrics() *Metrics\n}\n```\n\n### 7.2 ServiceDiscoverer 接口\n\n```go\n// ServiceDiscoverer defines interface for service discovery\ntype ServiceDiscoverer interface {\n    // GetEndpoint returns endpoint for given namespace and name\n    GetEndpoint(ctx context.Context, namespace, name, resourceType string) (*ServiceEndpoint, error)\n    \n    // WatchEndpoints starts watching for endpoint changes\n    WatchEndpoints(ctx context.Context, namespace string, resourceType string) (<-chan []ServiceEndpoint, error)\n    \n    // Refresh forces a cache refresh\n    Refresh(ctx context.Context) error\n}\n```\n\n### 7.3 ProxyHandler 接口\n\n```go\n// ProxyHandler handles request proxying\ntype ProxyHandler interface {\n    // Handle proxies the request to target\n    Handle(ctx context.Context, proxyCtx *ProxyContext) error\n    \n    // HandleWebSocket proxies WebSocket connection\n    HandleWebSocket(ctx context.Context, proxyCtx *ProxyContext) error\n}\n```\n\n---\n\n## 8. 实施计划\n\n### Phase 1: 核心功能\n- [ ] ProxyServer 基础实现\n- [ ] RequestRouter 路径解析\n- [ ] 基础 client-go 集成\n\n### Phase 2: 服务发现\n- [ ] ServiceDiscovery 实现\n- [ ] 缓存机制\n- [ ] Watch 集成\n\n### Phase 3: 可靠性\n- [ ] 连接池实现\n- [ ] 熔断器\n- [ ] 超时控制\n\n### Phase 4: 可观测性\n- [ ] 日志集成\n- [ ] Prometheus 指标\n- [ ] 健康检查端点\n\n### Phase 5: 高级特性\n- [ ] WebSocket 支持\n- [ ] TLS 支持\n- [ ] 性能优化\n\n---\n\n## 9. 参考资料\n\n- [client-go 文档](deployment/client-go.md)\n- [Go HTTP reverse proxy](https://pkg.go.dev/net/http/httputil#ReverseProxy)\n\n---\n\n## 10. References\n\n- [client-go library](deployment/client-go.md)\n- [AR-001: CRD AgentRuntime Type Definition](design.md)\n- [AR-003: Shared Types and Constants](design.md)\n- [AR-006: Sandbox Deletion and Lifecycle Management](pkg/workloadmanager/design.md)\n- [controller-runtime documentation](https://pkg.go.dev/sigs.k8s.io/controller-runtime)\n- [Kubernetes Controller Pattern](https://kubernetes.io/docs/concepts/extend-kubernetes/api-extension/custom-resources/)\n- [kubebuilder](https://book.kubebuilder.io/)\n\n---\n\n# AR-013 — Redis 存储实现\n\n- **AR ID**: AR-013\n- **Module**: `pkg/store`\n- **Language**: Go\n- **Size**: M\n- **Status**: Design\n\n## 1. Overview\n\nThe Session Store module (`pkg/store`) provides a storage abstraction layer for persisting sandbox metadata in the agentcube system. It supports both Redis and Valkey backends, selected at initialization via configuration.\n\n### Goals\n\n- Persist sandbox metadata keyed by session ID\n- Index sessions by expiry and last activity for garbage collection\n- Provide unified Store interface with Redis and Valkey implementations\n\n### Scope\n\n| Item | Description |\n|------|-------------|\n| Module | `github.com/volcano-sh/agentcube/pkg/store` |\n| Language | Go |\n| Requirement Reference | AR-013 |\n| Dependencies | Redis go-redis/v9, Valkey valkey-go |\n\n---\n\n## 2. Architecture\n\n### 2.1 Component Overview\n\n```\n┌─────────────────┐     ┌──────────────────┐     ┌─────────────────┐\n│   Application   │────▶│   Store iface    │────▶│ Redis Store     │\n│   Layer         │     │   (interface)    │     │ (implementation)│\n└─────────────────┘     └──────────────────┘     └─────────────────┘\n                                │\n                                │ (via STORE_TYPE)\n                                ▼\n                        ┌──────────────────┐\n                        │ Valkey Store     │\n                        │ (implementation) │\n                        └──────────────────┘\n```\n\n### 2.2 Package Structure\n\n| File | Responsibility |\n|------|----------------|\n| `store.go` | Store interface definition, error types |\n| `singleton.go` | Singleton provider initialization |\n| `store_redis.go` | Redis implementation |\n| `store_valkey.go` | Valkey implementation |\n\n---\n\n## 3. API Contracts\n\n### 3.1 Store Interface\n\n```go\ntype Store interface {\n    Ping(ctx context.Context) error\n    GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n    StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\n    UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\n    DeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n    ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n    ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n    UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n    Close() error\n}\n```\n\n### 3.2 Errors\n\n```go\nvar ErrNotFound = errors.New(\"store: not found\")\n```\n\n### 3.3 Singleton Access\n\n```go\nfunc Storage() Store\nfunc initStore() error\n```\n\n- `Storage()` uses `sync.Once` for thread-safe initialization\n- On initialization failure, logs fatal via klog\n\n---\n\n## 4. Data Structures\n\n### 4.1 SandboxInfo\n\n```go\ntype SandboxInfo struct {\n    Kind             string              `json:\"kind\"`\n    SandboxID        string              `json:\"sandboxId\"`\n    SandboxNamespace string              `json:\"sandboxNamespace\"`\n    Name             string              `json:\"name\"`\n    EntryPoints      []SandboxEntryPoint `json:\"entryPoints\"`\n    SessionID        string              `json:\"sessionId\"`\n    CreatedAt        time.Time           `json:\"createdAt\"`\n    ExpiresAt        time.Time           `json:\"expiresAt\"`\n    Status           string              `json:\"status\"`\n}\n\ntype SandboxEntryPoint struct {\n    Path     string `json:\"path\"`\n    Protocol string `json:\"protocol\"`\n    Endpoint string `json:\"endpoint\"`\n}\n```\n\n### 4.2 Key Schema\n\n| Key Pattern | Type | Description |\n|-------------|------|-------------|\n| `session:{sessionID}` | String (JSON) | Primary sandbox document |\n| `session:expiry` | ZSET | Members: sessionID, Score: ExpiresAt Unix |\n| `session:last_activity` | ZSET | Members: sessionID, Score: last activity Unix |\n\n---\n\n## 5. Implementation Details\n\n### 5.1 Redis Implementation\n\n**Struct:**\n\n```go\ntype redisStore struct {\n    cli                  *redisv9.Client\n    sessionPrefix        string  // \"session:\"\n    expiryIndexKey       string  // \"session:expiry\"\n    lastActivityIndexKey string  // \"session:last_activity\"\n}\n```\n\n**Connection Configuration:**\n\n| Env Variable | Required | Description |\n|--------------|----------|-------------|\n| `REDIS_ADDR` | Yes | Server address |\n| `REDIS_PASSWORD` | Yes* | Password (*unless REDIS_PASSWORD_REQUIRED=false) |\n| `STORE_TYPE` | No | Default: \"redis\" |\n\n**Operation Mappings:**\n\n| Method | Redis Commands |\n|--------|----------------|\n| `Ping` | PING → expect \"PONG\" |\n| `GetSandboxBySessionID` | GET session:{id} |\n| `StoreSandbox` | Pipeline: SETNX, ZADD expiry, ZADD last_activity |\n| `UpdateSandbox` | SET key value XX |\n| `DeleteSandboxBySessionID` | Pipeline: DEL, ZREM expiry, ZREM last_activity |\n| `ListExpiredSandboxes` | ZRANGEBYSCORE with LIMIT, then GET pipeline |\n| `ListInactiveSandboxes` | ZRANGEBYSCORE on last_activity, then GET pipeline |\n| `UpdateSessionLastActivity` | GET (verify exists), then ZADD |\n\n### 5.2 Valkey Implementation\n\n**Struct:**\n\n```go\ntype valkeyStore struct {\n    cli                  valkey.Client\n    sessionPrefix        string  // \"session:\"\n    expiryIndexKey       string  // \"session:expiry\"\n    lastActivityIndexKey string  // \"session:last_activity\"\n}\n```\n\n**Connection Configuration:**\n\n| Env Variable | Required | Description |\n|--------------|----------|-------------|\n| `VALKEY_ADDR` | Yes | Comma-separated addresses |\n| `VALKEY_PASSWORD` | Yes* | Password (*unless VALKEY_PASSWORD_REQUIRED=false) |\n| `VALKEY_DISABLE_CACHE` | No | \"true\" enables DisableCache |\n| `VALKEY_FORCE_SINGLE` | No | \"true\" enables ForceSingleClient |\n| `STORE_TYPE` | Must be \"valkey\" | Case-insensitive |\n\n**Operation Mappings:**\n\n| Method | Valkey API |\n|--------|------------|\n| `Ping` | B().Ping() → \"PONG\" |\n| `GetSandboxBySessionID` | B().Get().Key(key), IsValkeyNil → ErrNotFound |\n| `StoreSandbox` | DoMulti: SETNX, ZADD expiry, ZADD last_activity |\n| `UpdateSandbox` | SET ... XX, verify response == \"OK\" |\n| `DeleteSandboxBySessionID` | DoMulti: DEL, ZREM expiry, ZREM last_activity |\n| `ListInactiveSandboxes` | Same pattern on last_activity key |\n\n### 5.3 ZSET Score Semantics\n\n- **Expiry index:** Score = `float64(sandboxInfo.ExpiresAt.Unix())`\n- **Last activity:**\n  - On store: `float64(time.Now().Unix())`\n  - On update: `float64(at.Unix())` or `time.Now()` if `at` is zero\n\n---\n\n## 6. Error Handling\n\n### 6.1 Error Types\n\n| Error | Condition |\n|-------|-----------|\n| `ErrNotFound` | Session key does not exist; ZSET member missing |\n| \"sandbox is nil\" | StoreSandbox called with nil |\n| \"key not exists\" | UpdateSandbox on non-existent key |\n| \"password required\" | Missing password without _REQUIRED=false |\n\n### 6.2 Precondition Validation\n\n| Operation | Validation |\n|-----------|------------|\n| `StoreSandbox` | Reject nil sandbox, reject zero ExpiresAt |\n| `UpdateSandbox` | Use SET with XX flag (key must exist) |\n| `UpdateSessionLastActivity` | Verify session key exists before ZADD |\n| `ListExpired/Inactive` | If limit <= 0, return nil, nil |\n\n---\n\n## 7. Testing Strategy\n\n### 7.1 Unit Tests\n\n| Component | Test Coverage |\n|-----------|---------------|\n| Store Interface | Mock implementation verification |\n| Redis Store | All CRUD operations |\n| Valkey Store | All CRUD operations |\n| Key Construction | sessionKey(), prefix constants |\n| Error Conditions | ErrNotFound paths |\n\n### 7.2 Integration Tests\n\n| Scenario | Approach |\n|----------|----------|\n| Real Redis | Docker container, test suite |\n| Real Valkey | Docker container, test suite |\n| Key Schema | Verify actual keys in Redis/Valkey |\n\n### 7.3 Edge Cases\n\n- Empty session ID on UpdateSessionLastActivity → error\n- Zero time on UpdateSessionLastActivity → use time.Now()\n- Orphan ZSET member (no document) → skip without error\n- Concurrent Storage() calls → only one initialization\n\n---\n\n## 8. Dependencies\n\n```go\nimport (\n    \"github.com/redis/go-redis/v9\"\n    \"github.com/valkey-io/valkey-go\"\n    \"k8s.io/klog/v2\"\n    \"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n```\n\n---\n\n## 9. Configuration Flow\n\n```\nStorage() \n    → initStoreOnce.Do(initStore)\n        → Read STORE_TYPE (default: \"redis\")\n        → Validate required env vars\n        → Create provider (Redis or Valkey)\n        → Return provider singleton\n```\n\n### Provider Selection\n\n| STORE_TYPE | Implementation |\n|------------|----------------|\n| \"redis\" (default) | redisStore |\n| \"valkey\" | valkeyStore |\n| other | fail initialization |\n\n---\n\n## 10. Migration Path\n\nIf migrating from Redis to Valkey:\n\n1. Set `STORE_TYPE=valkey`\n2. Set `VALKEY_ADDR` (cluster addresses)\n3. Set `VALKEY_PASSWORD`\n4. Optionally set `VALKEY_DISABLE_CACHE=true`\n5. Ensure cluster mode if using multiple Valkey nodes\n\nKey compatibility is maintained across both backends (same key schema, same ZSET semantics).","after":"# AR-007 — K8s Reconciler Controller\n\n- **AR ID**: AR-007\n- **Module**: pkg/workloadmanager\n- **Language**: Go\n- **Size**: L\n- **Status**: ST-1 Completed (design.md)\n\n## 1. Architecture\n\n### 1.1 Overview\n\nThe K8s Reconciler Controller is a Kubernetes controller that watches `AgentRuntime` and `CodeInterpreter` custom resources and ensures the desired runtime state matches the actual cluster state. It provides declarative management of sandbox runtimes through the Kubernetes API server, enabling native Kubernetes patterns for resource lifecycle management.\n\n### 1.2 Component Structure\n\n```\npkg/workloadmanager/\n├── controller/\n│   ├── controller.go           # Controller framework & reconciliation loop\n│   ├── reconciler.go           # Reconciler implementation\n│   ├── agentruntime_reconciler.go    # AgentRuntime-specific reconciliation\n│   ├── codeinterpreter_reconciler.go # CodeInterpreter-specific reconciliation\n│   └── controller_test.go      # Controller tests\n├── informer/\n│   ├── factory.go              # Shared informer factory setup\n│   └── handlers.go             # Custom event handlers\n├── reconciler/\n│   ├── types.go                # Reconciler data structures\n│   ├── status.go               # Status update utilities\n│   ├── conditions.go           # Condition helpers\n│   └── finalizer.go            # Finalizer management\n├── client.go                   # Kubernetes client initialization (existing)\n├── service.go                  # WorkloadManager interface (existing)\n├── server.go                   # HTTP server (existing)\n└── types.go                    # Request/Response types (existing)\n```\n\n### 1.3 Architecture Diagram\n\n```\n┌─────────────────────────────────────────────────────────────────────────┐\n│                         Kubernetes API Server                           │\n│  ┌─────────────────┐  ┌─────────────────┐  ┌────────────────────────┐ │\n│  │ AgentRuntime    │  │ CodeInterpreter │  │ Pods/Service/ConfigMap  │ │\n│  │ (CRD)           │  │ (CRD)           │  │ (Managed Resources)     │ │\n│  └────────┬────────┘  └────────┬────────┘  └───────────┬────────────┘ │\n│           │                     │                        │              │\n└───────────┼─────────────────────┼────────────────────────┼──────────────┘\n            │                     │                        │\n            ▼                     ▼                        ▼\n┌─────────────────────────────────────────────────────────────────────────┐\n│                    K8s Reconciler Controller                            │\n│  ┌─────────────────────────────────────────────────────────────────────┐ │\n│  │                    SharedInformerFactory                           │ │\n│  │  ┌──────────────────────┐    ┌──────────────────────────────────┐ │ │\n│  │  │ AgentRuntime Informer│    │ CodeInterpreter Informer        │ │ │\n│  │  └──────────┬───────────┘    └───────────────┬──────────────────┘ │ │\n│  │             │                                  │                    │ │\n│  │             ▼                                  ▼                    │ │\n│  │  ┌──────────────────────┐    ┌──────────────────────────────────┐ │ │\n│  │  │ AgentRuntime Lister  │    │ CodeInterpreter Lister           │ │ │\n│  │  └──────────────────────┘    └──────────────────────────────────┘ │ │\n│  └─────────────────────────────────────────────────────────────────────┘ │\n│                                    │                                      │\n│                                    ▼                                      │\n│  ┌─────────────────────────────────────────────────────────────────────┐ │\n│  │              Reconciliation Loop (WorkQueue)                       │ │\n│  │  ┌─────────────┐  ┌─────────────┐  ┌─────────────┐  ┌──────────┐ │ │\n│  │  │  Enqueue    │→ │   Reconcile  │→ │   Update    │→ │  Update  │ │ │\n│  │  │  (trigger)  │  │   (compare)  │  │   (diff)    │  │  Status  │ │ │\n│  │  └─────────────┘  └─────────────┘  └─────────────┘  └──────────┘ │ │\n│  └─────────────────────────────────────────────────────────────────────┘ │\n└─────────────────────────────────────────────────────────────────────────┘\n                                    │\n                                    ▼\n┌─────────────────────────────────────────────────────────────────────────┐\n│                     WorkloadManager Service                             │\n│  ┌─────────────────────────────────────────────────────────────────────┐ │\n│  │  HTTP API Layer (server.go)                                        │ │\n│  │  - CRUD operations for AgentRuntime/CodeInterpreter                │ │\n│  │  - Sandbox lifecycle management                                    │ │\n│  └─────────────────────────────────────────────────────────────────────┘ │\n└─────────────────────────────────────────────────────────────────────────┘\n```\n\n### 1.4 Reconciliation Flow\n\n```\n                    ┌─────────────────────┐\n                    │  Object Created/    │\n                    │  Updated/Deleted    │\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Informer Event     │\n                    │  (Add/Update/Delete)│\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Enqueue with Key   │\n                    │  (namespace/name)   │\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Get from Lister   │\n                    │  (cached object)    │\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Reconcile Object   │\n                    │                     │\n                    │  1. Fetch latest    │\n                    │  2. Check deletion  │\n                    │  3. Ensure finalizer│\n                    │  4. Reconcile spec  │\n                    │  5. Update status   │\n                    └──────────┬──────────┘\n                               │\n                               ▼\n                    ┌─────────────────────┐\n                    │  Update Status     │\n                    │  (conditions, gen)  │\n                    └─────────────────────┘\n```\n\n## 2. Data Structures\n\n### 2.1 Controller Types\n\n```go\n// ControllerConfig holds controller configuration\ntype ControllerConfig struct {\n    // Namespace to watch. Empty means all namespaces.\n    Namespace string\n    \n    // ResyncPeriod is the period to force a full sync\n    ResyncPeriod time.Duration\n    \n    // MaxConcurrentReconciles is the max concurrent reconciliation threads\n    MaxConcurrentReconciles int\n    \n    // Reconciler is the actual reconcile logic implementation\n    Reconciler Reconciler\n    \n    // Client is the Kubernetes clientset\n    Client kubernetes.Interface\n    \n    // Scheme is the API scheme\n    Scheme *runtime.Scheme\n}\n\n// Controller manages the reconciliation loop\ntype Controller interface {\n    // Run starts the controller\n    Run(ctx context.Context, workers int) error\n    \n    // WaitForCacheSync waits for informers to sync\n    WaitForCacheSync(ctx context.Context) bool\n    \n    // GetHandler returns the event handler\n    GetHandler() cache.HandlerFuncs\n}\n```\n\n### 2.2 Reconciler Interface\n\n```go\n// Reconciler reconciles AgentRuntime and CodeInterpreter resources\ntype Reconciler interface {\n    // ReconcileAgentRuntime reconciles an AgentRuntime resource\n    ReconcileAgentRuntime(ctx context.Context, req reconcile.Request) (reconcile.Result, error)\n    \n    // ReconcileCodeInterpreter reconciles a CodeInterpreter resource  \n    ReconcileCodeInterpreter(ctx context.Context, req reconcile.Request) (reconcile.Result, error)\n    \n    // SetupWithManager sets up the controller with a manager\n    SetupWithManager(mgr ctrl.Manager, options ControllerOptions) error\n}\n\n// AgentRuntimeReconciler reconciles AgentRuntime resources\ntype AgentRuntimeReconciler struct {\n    client     client.Client\n    scheme     *runtime.Scheme\n    log        logr.Logger\n    recorder   record.EventRecorder\n}\n\n// CodeInterpreterReconciler reconciles CodeInterpreter resources\ntype CodeInterpreterReconciler struct {\n    client     client.Client\n    scheme     *runtime.Scheme\n    log        logr.Logger\n    recorder   record.EventRecorder\n}\n```\n\n### 2.3 Reconciliation Request\n\n```go\n// Request contains the information required to reconcile a resource\ntype Request struct {\n    // Namespace is the namespace of the resource\n    Namespace string\n    \n    // Name is the name of the resource\n    Name string\n}\n```\n\n### 2.4 Reconciliation Result\n\n```go\n// Result contains the result of a reconciliation\ntype Result struct {\n    // Requeue requests immediate requeue\n    Requeue bool\n    \n    // RequeueAfter requests requeue after the specified duration\n    RequeueAfter time.Duration\n    \n    // Error is the reconciliation error\n    Error error\n}\n\n// RequeueOnError returns a Result that requeues on error\nfunc RequeueOnError(err error) Result {\n    return Result{Requeue: true, Error: err}\n}\n\n// NoRequeue returns a Result that does not requeue\nfunc NoRequeue() Result {\n    return Result{Requeue: false}\n}\n\n// RequeueAfter returns a Result that requeues after the specified duration\nfunc RequeueAfter(after time.Duration) Result {\n    return Result{Requeue: true, RequeueAfter: after}\n}\n```\n\n### 2.5 Status Types\n\n```go\n// ReconcileStatus contains the reconciliation status information\ntype ReconcileStatus struct {\n    // ObservedGeneration is the generation observed\n    ObservedGeneration int64\n    \n    // Conditions is the list of conditions\n    Conditions []metav1.Condition\n    \n    // Phase is the current phase\n    Phase ReconcilePhase\n    \n    // Message is the status message\n    Message string\n}\n\ntype ReconcilePhase string\n\nconst (\n    ReconcilePhasePending   ReconcilePhase = \"Pending\"\n    ReconcilePhaseRunning   ReconcilePhase = \"Running\"\n    ReconcilePhaseSucceeded ReconcilePhase = \"Succeeded\"\n    ReconcilePhaseFailed    ReconcilePhase = \"Failed\"\n)\n\n// Condition types for AgentRuntime\nconst (\n    AgentRuntimeConditionReady     = \"Ready\"\n    AgentRuntimeConditionReconciled = \"Reconciled\"\n    AgentRuntimeConditionInitialized = \"Initialized\"\n)\n\n// Condition types for CodeInterpreter\nconst (\n    CodeInterpreterConditionReady     = \"Ready\"\n    CodeInterpreterConditionReconciled = \"Reconciled\"\n    CodeInterpreterConditionPodReady   = \"PodReady\"\n    CodeInterpreterConditionWarmPoolReady = \"WarmPoolReady\"\n)\n```\n\n### 2.6 Finalizer Types\n\n```go\nconst (\n    // FinalizerAgentRuntime is the standard finalizer for AgentRuntime\n    FinalizerAgentRuntime = \"agentruntime.agentcube.volcano.sh/deletion-protection\"\n    \n    // FinalizerCodeInterpreter is the standard finalizer for CodeInterpreter\n    FinalizerCodeInterpreter = \"codeinterpreter.agentcube.volcano.sh/deletion-protection\"\n)\n\n// FinalizerManager handles finalizer operations\ntype FinalizerManager interface {\n    // AddFinalizer adds a finalizer to the resource\n    AddFinalizer(ctx context.Context, obj client.Object) error\n    \n    // RemoveFinalizer removes a finalizer from the resource\n    RemoveFinalizer(ctx context.Context, obj client.Object) error\n    \n    // HasFinalizer checks if the resource has a specific finalizer\n    HasFinalizer(obj client.Object, finalizer string) bool\n    \n    // EnsureFinalizer ensures the finalizer is present\n    EnsureFinalizer(ctx context.Context, obj client.Object, finalizer string) error\n}\n```\n\n### 2.7 Reconcile Options\n\n```go\n// ReconcileOptions contains options for reconciliation\ntype ReconcileOptions struct {\n    // SkipStatusUpdate skips updating the status\n    SkipStatusUpdate bool\n    \n    // SkipFinalizerCheck skips checking finalizers\n    SkipFinalizerCheck bool\n    \n    // ForceReconcile forces reconciliation even if up-to-date\n    ForceReconcile bool\n}\n\n// ReconcileOptionsFunc modifies ReconcileOptions\ntype ReconcileOptionsFunc func(*ReconcileOptions)\n\n// WithSkipStatusUpdate sets the skip status update option\nfunc WithSkipStatusUpdate(skip bool) ReconcileOptionsFunc {\n    return func(o *ReconcileOptions) {\n        o.SkipStatusUpdate = skip\n    }\n}\n```\n\n## 3. API Contracts\n\n### 3.1 Controller Setup\n\nThe controller uses the controller-runtime framework for integration with Kubernetes:\n\n```go\n// NewAgentRuntimeReconciler creates a new AgentRuntimeReconciler\nfunc NewAgentRuntimeReconciler(\n    client client.Client,\n    log logr.Logger,\n    recorder record.EventRecorder,\n) *AgentRuntimeReconciler\n\n// NewCodeInterpreterReconciler creates a new CodeInterpreterReconciler\nfunc NewCodeInterpreterReconciler(\n    client client.Client,\n    log logr.Logger,\n    recorder record.EventRecorder,\n) *CodeInterpreterReconciler\n\n// SetupWithManager sets up the reconciler with the manager\nfunc (r *AgentRuntimeReconciler) SetupWithManager(mgr ctrl.Manager, opts controller.Options) error {\n    return ctrl.NewControllerManagedBy(mgr).\n        For(&agentcubev1alpha1.AgentRuntime{}).\n        Owns(&corev1.Pod{}).\n        WithOptions(opts).\n        Complete(r)\n}\n```\n\n### 3.2 Reconciliation Triggers\n\n| Trigger | Source | Action |\n|---------|--------|--------|\n| Object Created | Informer (Add) | Enqueue Request |\n| Object Updated | Informer (Update) | Enqueue Request if spec/status changed |\n| Object Deleted | Informer (Delete) | Enqueue Request (cleanup) |\n| Owner Deleted | Owner's Informer | Enqueue dependent (cleanup) |\n| Periodic Sync | Controller (Resync) | Enqueue all objects |\n| Manual Retry | External | Enqueue specific Request |\n\n### 3.3 Status Update Contracts\n\n```go\n// UpdateStatus updates the resource status with reconciliation results\nfunc (r *AgentRuntimeReconciler) UpdateStatus(\n    ctx context.Context,\n    obj *agentcubev1alpha1.AgentRuntime,\n    conditions []metav1.Condition,\n    phase ReconcilePhase,\n) error {\n    obj.Status.ObservedGeneration = obj.Generation\n    obj.Status.Conditions = conditions\n    \n    // Set phase condition\n    metav1.SetStatusCondition(&obj.Status.Conditions, metav1.Condition{\n        Type:               string(phase),\n        Status:             metav1.ConditionTrue,\n        ObservedGeneration: obj.Generation,\n        LastTransitionTime: metav1.Now(),\n    })\n    \n    return r.client.Status().Update(ctx, obj)\n}\n\n// PatchStatus patches the resource status using strategic merge\nfunc (r *AgentRuntimeReconciler) PatchStatus(\n    ctx context.Context,\n    obj *agentcubev1alpha1.AgentRuntime,\n    patch *agentcubev1alpha1.AgentRuntime,\n) error {\n    return r.client.Status().Patch(ctx, patch, client.MergeFrom(obj))\n}\n```\n\n### 3.4 Event Recording\n\n```go\n// Events recorded during reconciliation\nconst (\n    // AgentRuntime Events\n    EventReconciling    = \"Reconciling\"\n    EventReconcileSucceeded = \"ReconcileSucceeded\"\n    EventReconcileFailed = \"ReconcileFailed\"\n    EventFinalizerAdded = \"FinalizerAdded\"\n    EventFinalizerRemoved = \"FinalizerRemoved\"\n    EventPodCreated = \"PodCreated\"\n    EventPodDeleted = \"PodDeleted\"\n    \n    // CodeInterpreter Events\n    EventWarmPoolCreating = \"WarmPoolCreating\"\n    EventWarmPoolReady = \"WarmPoolReady\"\n    EventPodReady = \"PodReady\"\n)\n\n// Example event recording\nr.recorder.Eventf(ar, corev1.EventTypeNormal, EventReconciling, \n    \"Reconciling AgentRuntime %s/%s\", ar.Namespace, ar.Name)\n```\n\n### 3.5 Owner Reference\n\nResources are owned by the CR and get garbage collected when CR is deleted:\n\n```go\n// OwnerReference creates an owner reference for the resource\nfunc OwnerReference(owner client.Object) []metav1.OwnerReference {\n    return []metav1.OwnerReference{\n        *metav1.NewControllerRef(owner, owner.GetObjectKind().GroupVersionKind()),\n    }\n}\n\n// IsOwnedBy checks if the object is owned by the given owner\nfunc IsOwnedBy(obj metav1.Object, owner metav1.OwnerReference) bool {\n    return obj.GetController() != nil && \n           *obj.GetController().UID == owner.UID\n}\n```\n\n## 4. Error Handling\n\n### 4.1 Error Types\n\n```go\nvar (\n    // ErrNotFound is returned when the resource is not found\n    ErrNotFound = errors.New(\"resource not found\")\n    \n    // ErrNotReady is returned when the resource is not ready\n    ErrNotReady = errors.New(\"resource not ready\")\n    \n    // ErrStaleGeneration is returned when the generation has changed\n    ErrStaleGeneration = errors.New(\"stale generation\")\n    \n    // ErrReconcileFailed is returned when reconciliation fails\n    ErrReconcileFailed = errors.New(\"reconciliation failed\")\n    \n    // ErrFinalizerFailed is returned when a finalizer operation fails\n    ErrFinalizerFailed = errors.New(\"finalizer operation failed\")\n    \n    // ErrDependencyNotReady is returned when a dependency is not ready\n    ErrDependencyNotReady = errors.New(\"dependency not ready\")\n    \n    // ErrMaxRetriesExceeded is returned when max retries are exceeded\n    ErrMaxRetriesExceeded = errors.New(\"max retries exceeded\")\n)\n```\n\n### 4.2 Error Handling Strategies\n\n```go\n// HandleError handles reconciliation errors with logging and status update\nfunc (r *AgentRuntimeReconciler) HandleError(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime, err error) (reconcile.Result, error) {\n    // Log the error\n    r.log.Error(err, \"Reconciliation failed\", \"namespace\", ar.Namespace, \"name\", ar.Name)\n    \n    // Record failure event\n    r.recorder.Eventf(ar, corev1.EventTypeWarning, EventReconcileFailed, \n        \"Reconciliation failed: %v\", err)\n    \n    // Update status with error condition\n    metav1.SetStatusCondition(&ar.Status.Conditions, metav1.Condition{\n        Type:    AgentRuntimeConditionReconciled,\n        Status:  metav1.ConditionFalse,\n        Reason:  \"ReconciliationFailed\",\n        Message: err.Error(),\n    })\n    \n    // Update status\n    if updateErr := r.client.Status().Update(ctx, ar); updateErr != nil {\n        r.log.Error(updateErr, \"Failed to update status\")\n    }\n    \n    // Determine requeue behavior\n    if errors.Is(err, ErrMaxRetriesExceeded) {\n        return reconcile.Result{}, nil // Don't requeue\n    }\n    \n    // Requeue after error with exponential backoff\n    return reconcile.Result{RequeueAfter: time.Minute}, nil\n}\n\n// IsRetryable checks if an error is retryable\nfunc IsRetryable(err error) bool {\n    if errors.Is(err, context.DeadlineExceeded) {\n        return true\n    }\n    if errors.Is(err, ErrDependencyNotReady) {\n        return true\n    }\n    return false\n}\n```\n\n### 4.3 Error Response Mapping\n\n| Error Type | HTTP Status | K8s Reason | Action |\n|------------|-------------|------------|--------|\n| NotFound | 404 | NotFound | Stop reconciliation |\n| NotReady | Unprocessable | NotReady | Requeue |\n| StaleGeneration | Conflict | Conflict | Requeue with latest |\n| ReconcileFailed | 500 | InternalError | Requeue with backoff |\n| FinalizerFailed | 500 | InternalError | Requeue |\n| DependencyNotReady | Unprocessable | ErrDepNotReady | Requeue |\n| MaxRetriesExceeded | 500 | InternalError | Stop, alert |\n\n### 4.4 Condition Error Helpers\n\n```go\n// SetErrorCondition sets an error condition on the resource\nfunc SetErrorCondition(conditions *[]metav1.Condition, conditionType string, err error) {\n    metav1.SetStatusCondition(conditions, metav1.Condition{\n        Type:    conditionType,\n        Status:  metav1.ConditionFalse,\n        Reason:  \"Error\",\n        Message: err.Error(),\n    })\n}\n\n// SetSuccessCondition sets a success condition on the resource\nfunc SetSuccessCondition(conditions *[]metav1.Condition, conditionType string, message string) {\n    metav1.SetStatusCondition(conditions, metav1.Condition{\n        Type:               conditionType,\n        Status:             metav1.ConditionTrue,\n        Reason:             \"Success\",\n        Message:            message,\n        LastTransitionTime: metav1.Now(),\n    })\n}\n\n// SetPendingCondition sets a pending condition on the resource\nfunc SetPendingCondition(conditions *[]metav1.Condition, conditionType string, message string) {\n    metav1.SetStatusCondition(conditions, metav1.Condition{\n        Type:    conditionType,\n        Status:  metav1.ConditionUnknown,\n        Reason:  \"Pending\",\n        Message: message,\n    })\n}\n```\n\n## 5. Testing Strategy\n\n### 5.1 Unit Tests\n\n#### Reconciler Tests\n\n```go\nfunc TestAgentRuntimeReconciler_Reconcile(t *testing.T) {\n    // Setup fake client\n    fakeClient := fake.NewClientBuilder().\n        WithScheme(scheme).\n        WithObjects(agentRuntime).\n        Build()\n    \n    // Create reconciler\n    r := &AgentRuntimeReconciler{\n        client:   fakeClient,\n        log:      ctrl.Log.WithName(\"test\"),\n        recorder: record.NewFakeRecorder(10),\n    }\n    \n    // Test reconciliation\n    result, err := r.ReconcileAgentRuntime(ctx, reconcile.Request{\n        NamespacedName: types.NamespacedName{\n            Namespace: \"default\",\n            Name:      \"test-runtime\",\n        },\n    })\n    \n    // Assertions\n    require.NoError(t, err)\n    assert.False(t, result.Requeue)\n    \n    // Verify finalizer was added\n    updatedAR := &agentcubev1alpha1.AgentRuntime{}\n    err = fakeClient.Get(ctx, key, updatedAR)\n    require.NoError(t, err)\n    assert.Contains(t, updatedAR.Finalizers, FinalizerAgentRuntime)\n}\n```\n\n#### Finalizer Tests\n\n```go\nfunc TestFinalizerManager(t *testing.T) {\n    tests := []struct {\n        name       string\n        obj        client.Object\n        finalizer  string\n        wantHas    bool\n        wantUpdate bool\n    }{\n        {\n            name:       \"add finalizer to object without finalizer\",\n            obj:        &agentcubev1alpha1.AgentRuntime{},\n            finalizer:  FinalizerAgentRuntime,\n            wantHas:    true,\n            wantUpdate: true,\n        },\n        {\n            name: \"object already has finalizer\",\n            obj: &agentcubev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Finalizers: []string{FinalizerAgentRuntime},\n                },\n            },\n            finalizer:  FinalizerAgentRuntime,\n            wantHas:    true,\n            wantUpdate: false,\n        },\n    }\n    \n    for _, tt := range tests {\n        t.Run(tt.name, func(t *testing.T) {\n            fm := NewFinalizerManager(fakeClient)\n            \n            has := fm.HasFinalizer(tt.obj, tt.finalizer)\n            assert.Equal(t, tt.wantHas, has)\n        })\n    }\n}\n```\n\n### 5.2 Integration Tests\n\n```go\nfunc TestAgentRuntimeReconciler_Integration(t *testing.T) {\n    // Skip if not in integration test mode\n    if testing.Short() {\n        t.Skip(\"Skipping integration tests\")\n    }\n    \n    // Use envtest (kubebuilder)\n    env, err := envtest.Environment()\n    require.NoError(t, err)\n    \n    // Start test environment\n    cfg, err := env.Start()\n    require.NoError(t, err)\n    defer env.Stop()\n    \n    // Create manager\n    mgr, err := ctrl.NewManager(cfg, ctrl.Options{})\n    require.NoError(t, err)\n    \n    // Register reconciler\n    err = (&AgentRuntimeReconciler{\n        Client:   mgr.GetClient(),\n        Log:      mgr.GetLogger(),\n        Recorder: mgr.GetEventRecorderFor(\"agentruntime-controller\"),\n    }).SetupWithManager(mgr, controller.Options{})\n    require.NoError(t, err)\n    \n    // Start manager in goroutine\n    go func() {\n        err := mgr.Start(ctx)\n        require.NoError(t, err)\n    }()\n    \n    // Wait for cache sync\n    require.True(t, mgr.GetCache().WaitForCacheSync(ctx))\n    \n    // Create test resource\n    ar := &agentcubev1alpha1.AgentRuntime{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"test-runtime\",\n            Namespace: \"default\",\n        },\n        Spec: agentcubev1alpha1.AgentRuntimeSpec{\n            MaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n            SessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n            Ports:              []agentcubev1alpha1.TargetPort{{Port: 8080}},\n        },\n    }\n    \n    err = mgr.GetClient().Create(ctx, ar)\n    require.NoError(t, err)\n    \n    // Wait for reconciliation\n    time.Sleep(2 * time.Second)\n    \n    // Verify status was updated\n    updatedAR := &agentcubev1alpha1.AgentRuntime{}\n    err = mgr.GetClient().Get(ctx, key, updatedAR)\n    require.NoError(t, err)\n    \n    // Verify conditions\n    assert.Equal(t, 1, len(updatedAR.Status.Conditions))\n}\n```\n\n### 5.3 Controller Behavior Tests\n\n| Test Case | Input | Expected Output |\n|-----------|-------|-----------------|\n| Create Object | New AgentRuntime | Finalizer added, Status.Initialized = True |\n| Update Spec | Changed MaxSessionDuration | Status.Reconciled updated |\n| Update Status | Changed conditions | No requeue |\n| Delete with Finalizer | DeletionTimestamp set | Finalizer removed, then deleted |\n| Delete without Finalizer | DeletionTimestamp set | Directly deleted |\n| Dep Not Ready | Pod not created | Requeue |\n| Error During Reconcile | Reconciliation fails | Condition set to False, event recorded |\n\n### 5.4 Test Coverage Targets\n\n| Component | Target Coverage |\n|-----------|-----------------|\n| controller.go | 80% |\n| reconciler.go | 85% |\n| agentruntime_reconciler.go | 85% |\n| codeinterpreter_reconciler.go | 85% |\n| status.go | 90% |\n| finalizer.go | 90% |\n| conditions.go | 90% |\n\n### 5.5 Fake Clients Usage\n\n```go\nimport (\n    \"sigs.k8s.io/controller-runtime/pkg/client/fake\"\n    \"k8s.io/client-go/kubernetes/fake\"\n    agentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nfunc TestWithFakeClient(t *testing.T) {\n    // Initialize scheme with all types\n    scheme := runtime.NewScheme()\n    agentcubev1alpha1.AddToScheme(scheme)\n    corev1.AddToScheme(scheme)\n    \n    // Build fake client with initial objects\n    fakeClient := fake.NewClientBuilder().\n        WithScheme(scheme).\n        WithObjects(\n            &agentcubev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"test-runtime\",\n                    Namespace: \"default\",\n                },\n            },\n        ).\n        WithStatusSubresource(\n            &agentcubev1alpha1.AgentRuntime{},\n        ).\n        Build()\n    \n    // Use in reconciler\n    r := &AgentRuntimeReconciler{\n        client: fakeClient,\n    }\n    \n    // Test reconciliation\n    result, err := r.Reconcile(ctx, req)\n    assert.NoError(t, err)\n}\n```\n\n## 6. Dependencies\n\n### 6.1 Required Dependencies\n\n| Package | Version | Purpose |\n|---------|---------|---------|\n| sigs.k8s.io/controller-runtime | ^0.20.0 | Controller framework |\n| k8s.io/client-go | ^0.34.0 | Kubernetes client |\n| k8s.io/apimachinery | ^0.34.0 | API types |\n| k8s.io/klog/v2 | ^2.0 | Logging |\n| github.com/go-logr/logr | ^1.0 | Structured logging |\n| github.com/onsi/ginkgo | ^2.0 | Testing framework |\n| github.com/onsi/gomega | ^1.27 | Testing matchers |\n\n### 6.2 Internal Dependencies\n\n| Module | Purpose |\n|--------|---------|\n| github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1 | CRD types |\n| github.com/volcano-sh/agentcube/pkg/client/listers | Listers for caching |\n| github.com/volcano-sh/agentcube/pkg/client/informers | Informers for watching |\n\n## 7. Configuration\n\n### 7.1 Controller Configuration\n\n```go\n// ControllerOptions contains options for the controller\ntype ControllerOptions struct {\n    // MaxConcurrentReconciles is the number of concurrent reconciliation workers\n    MaxConcurrentReconciles int\n    \n    // ReconcilePeriod is the period between full reconciles\n    ReconcilePeriod time.Duration\n    \n    // FailureThreshold is the number of failures before stopping reconciliation\n    FailureThreshold int\n    \n    // ResourceNotFoundCacheDuration is the cache duration for not found errors\n    ResourceNotFoundCacheDuration time.Duration\n}\n\n// DefaultControllerOptions returns default options\nfunc DefaultControllerOptions() ControllerOptions {\n    return ControllerOptions{\n        MaxConcurrentReconciles:        10,\n        ReconcilePeriod:                time.Hour,\n        FailureThreshold:               3,\n        ResourceNotFoundCacheDuration: 1 * time.Minute,\n    }\n}\n```\n\n### 7.2 Environment Variables\n\n| Variable | Default | Description |\n|----------|---------|-------------|\n| WORKLOAD_CONTROLLER_NAME | agentcube-workload-controller | Controller name for identity |\n| WORKLOAD_CONTROLLER_NAMESPACE | agentcube-system | Namespace to watch |\n| MAX_CONCURRENT_RECONCILES | 10 | Concurrent workers |\n| RECONCILE_PERIOD | 1h | Full sync period |\n| LOG_LEVEL | info | Logging level |\n\n### 7.3 Leader Election\n\nThe controller supports leader election for high availability:\n\n```go\n// LeaderElectionConfig for controller manager\nLeaderElection:           true,\nLeaderElectionID:         \"agentcube-workload-controller-lock\",\nLeaderElectionNamespace:  \"agentcube-system\",  // or operator namespace\n```\n\n## 8. Monitoring\n\n### 8.1 Metrics\n\n| Metric | Type | Description |\n|--------|------|-------------|\n| reconcile_total | Counter | Total reconciliation attempts |\n| reconcile_duration_seconds | Histogram | Reconciliation duration |\n| reconcile_errors_total | Counter | Reconciliation errors |\n| reconcile_retries_total | Counter | Retry count |\n| controller_queue_depth | Gauge | Work queue depth |\n| controller_worker_count | Gauge | Active worker count |\n\n### 8.2 Health Checks\n\n```go\n// Healthz endpoint returns controller health\nr.GET(\"/healthz\", func(c *gin.Context) {\n    // Check if informers are synced\n    if !controller.WaitForCacheSync(ctx) {\n        c.JSON(http.StatusServiceUnavailable, gin.H{\"status\": \"not ready\"})\n        return\n    }\n    c.JSON(http.StatusOK, gin.H{\"status\": \"ready\"})\n})\n```\n\n## 9. Security\n\n### 9.1 RBAC Requirements\n\n```yaml\nrules:\n# AgentRuntime and CodeInterpreter CRUD\n- apiGroups: [\"runtime.agentcube.volcano.sh\"]\n  resources: [\"agentruntimes\", \"codeinterpreters\"]\n  verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"]\n\n# Status subresource\n- apiGroups: [\"runtime.agentcube.volcano.sh\"]\n  resources: [\"agentruntimes/status\", \"codeinterpreters/status\"]\n  verbs: [\"get\", \"update\", \"patch\"]\n\n# Managed resources (Pods, Services, ConfigMaps)\n- apiGroups: [\"\"]\n  resources: [\"pods\", \"services\", \"configmaps\", \"secrets\"]\n  verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"]\n\n# Events\n- apiGroups: [\"events.k8s.io\"]\n  resources: [\"events\"]\n  verbs: [\"create\", \"patch\"]\n```\n\n### 9.2 Security Considerations\n\n- Controller runs with minimal required RBAC permissions\n- Finalizers prevent garbage collection of resources with active dependents\n- Status updates use optimistic concurrency to prevent race conditions\n- All client operations include context with timeout\n\n# AR-009: Router HTTP 反向代理核心\n\n**AR Number:** AR-009  \n**Module:** `pkg/router`  \n**Language:** Go  \n**Size:** M  \n**Status:** Draft\n\n## 1. 概述\n\n`pkg/router` 是 agentcube 的 HTTP 反向代理核心模块，负责将外部 HTTP 请求路由到后端的 AgentRuntime 和 CodeInterpreter 实例。该模块基于 client-go 库与 Kubernetes API 交互，获取目标服务信息并执行代理转发。\n\n### 1.1 目标\n\n- 提供高性能 HTTP 反向代理能力\n- 支持动态服务发现（通过 Kubernetes API）\n- 支持 WebSocket 长连接\n- 实现流量控制和熔断机制\n- 提供可观测性（指标、日志、追踪）\n\n### 1.2 依赖\n\n- `github.com/volcano-sh/agentcube/client-go` — Kubernetes typed client\n- `k8s.io/client-go/rest` — REST 客户端\n- `k8s.io/apimachinery` — API 类型定义\n\n---\n\n## 2. 架构设计\n\n### 2.1 整体架构\n\n```\n                    ┌─────────────────┐\n                    │   Ingress       │\n                    │   (External)    │\n                    └────────┬────────┘\n                             │\n                    ┌────────▼────────┐\n                    │   Router        │\n                    │   Server        │\n                    │   (pkg/router)  │\n                    └────────┬────────┘\n                             │\n            ┌────────────────┼────────────────┐\n            │                │                │\n   ┌────────▼────────┐ ┌────▼────┐ ┌────────▼────────┐\n   │ AgentRuntime    │ │ Agent   │ │ CodeInterpreter │\n   │ Instance 1      │ │ Runtime │ │ Instance N      │\n   │                 │ │ Instance│ │                 │\n   └─────────────────┘ │ 2      │ └─────────────────┘\n                       └────────┘\n```\n\n### 2.2 核心组件\n\n| 组件 | 职责 |\n|------|------|\n| `ProxyServer` | HTTP/HTTPS 服务器生命周期管理 |\n| `RequestRouter` | 请求路径解析与目标选择 |\n| `ServiceDiscovery` | 通过 client-go 动态发现后端服务 |\n| `ProxyHandler` | 请求转发与响应回传 |\n| `ConnectionPool` | HTTP 连接池管理 |\n| `CircuitBreaker` | 熔断器实现 |\n| `MetricsCollector` | 指标采集 |\n\n### 2.3 数据流\n\n1. 客户端请求进入 `ProxyServer`\n2. `RequestRouter` 解析请求路径，提取 `namespace` 和 `resource`\n3. `ServiceDiscovery` 通过 client-go 查询对应的 `AgentRuntime` 或 `CodeInterpreter` 端点\n4. `CircuitBreaker` 检查目标实例健康状态\n5. `ProxyHandler` 建立到后端的连接并转发请求\n6. 响应回传后记录指标并返回客户端\n\n---\n\n## 3. 数据结构\n\n### 3.1 核心配置\n\n```go\n// Config holds router configuration\ntype Config struct {\n    // Server addresses\n    BindAddress string\n    Port        int\n    TLSConfig   *TLSConfig\n\n    // Client-go configuration\n    KubeConfigPath string\n    QPS           float32\n    Burst         int\n\n    // Proxy settings\n    MaxConnections     int\n    RequestTimeout     time.Duration\n    IdleTimeout        time.Duration\n    WebSocketEnabled   bool\n\n    // Circuit breaker\n    CircuitBreakerConfig CircuitBreakerConfig\n\n    // Metrics\n    MetricsEnabled bool\n    MetricsPort    int\n}\n\n// TLSConfig holds TLS settings\ntype TLSConfig struct {\n    CertFile string\n    KeyFile  string\n    CAFile   string\n}\n\n// CircuitBreakerConfig holds circuit breaker settings\ntype CircuitBreakerConfig struct {\n    FailureThreshold  int\n    SuccessThreshold  int\n    Timeout           time.Duration\n    HalfOpenMaxCalls  int\n}\n```\n\n### 3.2 服务发现\n\n```go\n// ServiceEndpoint represents a discovered backend service\ntype ServiceEndpoint struct {\n    Name      string\n    Namespace string\n    URL       string\n    Labels    map[string]string\n    Healthy   bool\n}\n\n// ServiceRegistry caches discovered service endpoints\ntype ServiceRegistry struct {\n    mu sync.RWMutex\n    // key: namespace/resource name\n    endpoints map[string][]ServiceEndpoint\n}\n```\n\n### 3.3 代理上下文\n\n```go\n// ProxyContext holds request context for proxying\ntype ProxyContext struct {\n    Context     context.Context\n    Request     *http.Request\n    Response    http.ResponseWriter\n    Target      *ServiceEndpoint\n    StartTime   time.Time\n    RequestID   string\n}\n```\n\n### 3.4 客户端接口\n\n使用 `github.com/volcano-sh/agentcube/client-go` 进行 Kubernetes API 交互：\n\n```go\n// RuntimeClient wraps client-go typed client\ntype RuntimeClient interface {\n    // AgentRuntime operations\n    GetAgentRuntime(ctx context.Context, namespace, name string) (*runtimev1alpha1.AgentRuntime, error)\n    ListAgentRuntimes(ctx context.Context, namespace string, opts metav1.ListOptions) (*runtimev1alpha1.AgentRuntimeList, error)\n    WatchAgentRuntimes(ctx context.Context, namespace string, opts metav1.ListOptions) (watch.Interface, error)\n\n    // CodeInterpreter operations\n    GetCodeInterpreter(ctx context.Context, namespace, name string) (*runtimev1alpha1.CodeInterpreter, error)\n    ListCodeInterpreters(ctx context.Context, namespace string, opts metav1.ListOptions) (*runtimev1alpha1.CodeInterpreterList, error)\n    WatchCodeInterpreters(ctx context.Context, namespace string, opts metav1.ListOptions) (watch.Interface, error)\n}\n```\n\n---\n\n## 4. API 合约\n\n### 4.1 路由规则\n\n| 路径模式 | 描述 |\n|----------|------|\n| `GET /api/v1/namespaces/{namespace}/agentruntimes/{name}` | 获取 AgentRuntime 详情 |\n| `GET /api/v1/namespaces/{namespace}/agentruntimes/{name}/proxy` | 代理到 AgentRuntime 端点 |\n| `GET /api/v1/namespaces/{namespace}/codeinterpreters/{name}` | 获取 CodeInterpreter 详情 |\n| `GET /api/v1/namespaces/{namespace}/codeinterpreters/{name}/proxy` | 代理到 CodeInterpreter 端点 |\n| `WS /api/v1/namespaces/{namespace}/agentruntimes/{name}/ws` | WebSocket 代理 |\n| `WS /api/v1/namespaces/{namespace}/codeinterpreters/{name}/ws` | WebSocket 代理 |\n| `GET /health` | 健康检查 |\n| `GET /metrics` | Prometheus 指标 |\n\n### 4.2 代理请求头\n\n| Header | 描述 |\n|--------|------|\n| `X-Request-ID` | 请求唯一标识 |\n| `X-Forwarded-For` | 原始客户端 IP |\n| `X-Forwarded-Proto` | 原始协议 |\n| `X-Real-IP` | 真实客户端 IP |\n| `X-Target-Namespace` | 目标命名空间 |\n| `X-Target-Name` | 目标资源名称 |\n\n### 4.3 响应格式\n\n成功响应：\n```json\n{\n  \"status\": \"success\",\n  \"data\": { ... }\n}\n```\n\n错误响应：\n```json\n{\n  \"status\": \"error\",\n  \"code\": \"ERR_CODE\",\n  \"message\": \"human readable message\",\n  \"requestId\": \"req-xxx\"\n}\n```\n\n### 4.4 状态码\n\n| 状态码 | 含义 |\n|--------|------|\n| 200 | 成功 |\n| 400 | 请求参数错误 |\n| 404 | 资源不存在 |\n| 502 | 后端服务不可用 |\n| 503 | 服务熔断中 |\n| 504 | 请求超时 |\n\n---\n\n## 5. 错误处理\n\n### 5.1 错误类型\n\n```go\n// Error codes\nconst (\n    ErrCodeBadRequest       = \"ERR_BAD_REQUEST\"\n    ErrCodeNotFound         = \"ERR_NOT_FOUND\"\n    ErrCodeTargetNotReady   = \"ERR_TARGET_NOT_READY\"\n    ErrCodeProxyFailed      = \"ERR_PROXY_FAILED\"\n    ErrCodeTimeout          = \"ERR_TIMEOUT\"\n    ErrCodeCircuitOpen      = \"ERR_CIRCUIT_OPEN\"\n    ErrCodeInternalError    = \"ERR_INTERNAL\"\n)\n\n// RouterError represents a router-specific error\ntype RouterError struct {\n    Code      string\n    Message   string\n    StatusCode int\n    Err       error\n}\n```\n\n### 5.2 处理策略\n\n| 错误类型 | 处理方式 |\n|----------|----------|\n| 客户端错误 (4xx) | 直接返回错误响应 |\n| 后端超时 | 熔断计数 + 返回 504 |\n| 后端连接失败 | 重试一次，失败则熔断 |\n| 资源不存在 | 返回 404 |\n| 熔断器开启 | 返回 503 |\n\n### 5.3 日志规范\n\n```go\n// 日志字段\nlog := zaplog.With(\n    \"requestId\", requestID,\n    \"method\", method,\n    \"path\", path,\n    \"namespace\", namespace,\n    \"target\", targetName,\n    \"latency\", latency,\n    \"statusCode\", statusCode,\n)\n```\n\n---\n\n## 6. 测试策略\n\n### 6.1 单元测试\n\n| 模块 | 测试重点 |\n|------|----------|\n| `RequestRouter` | 路径解析、目标选择逻辑 |\n| `ServiceDiscovery` | 缓存更新、并发安全 |\n| `ProxyHandler` | 请求转发、响应处理 |\n| `CircuitBreaker` | 状态转换、计数逻辑 |\n\n### 6.2 集成测试\n\n```go\n// 使用 fake client-go 进行集成测试\nimport (\n    \"k8s.io/client-go/kubernetes/fake\"\n    \"github.com/volcano-sh/agentcube/client-go/clientset/versioned/fake\"\n)\n\n// TestProxyFlow tests full proxy flow with fake clients\nfunc TestProxyFlow(t *testing.T) {\n    // Setup fake clients\n    kubeClient := fake.NewSimpleClientset()\n    runtimeClient := clientsetfake.NewSimpleClientset()\n    \n    // Create router with fake clients\n    router := NewRouter(Config{\n        RuntimeClient: runtimeClient,\n    })\n    \n    // Test proxy request\n    // ...\n}\n```\n\n### 6.3 测试场景\n\n1. **正常代理流程** — 端到端请求转发\n2. **服务发现更新** — 动态更新后端列表\n3. **熔断触发** — 失败次数达到阈值后熔断\n4. **熔断恢复** — 超时后尝试恢复\n5. **WebSocket 连接** — 长连接代理\n6. **并发安全** — 多请求同时处理\n\n### 6.4 Benchmark\n\n```go\n// BenchmarkRequestRouting benchmarks path parsing\nfunc BenchmarkRequestRouting(b *testing.B) {\n    // Setup\n    router := NewRouter(Config{})\n    \n    // Benchmark\n    b.ResetTimer()\n    for i := 0; i < b.N; i++ {\n        router.routeRequest(request)\n    }\n}\n```\n\n---\n\n## 7. 关键接口定义\n\n### 7.1 Router 接口\n\n```go\n// Router defines the interface for HTTP reverse proxy\ntype Router interface {\n    // Start begins serving HTTP requests\n    Start(ctx context.Context) error\n    \n    // Stop gracefully shuts down the router\n    Stop(ctx context.Context) error\n    \n    // RegisterRoute adds a custom route handler\n    RegisterRoute(pattern string, handler http.Handler)\n    \n    // Metrics returns current router metrics\n    Metrics() *Metrics\n}\n```\n\n### 7.2 ServiceDiscoverer 接口\n\n```go\n// ServiceDiscoverer defines interface for service discovery\ntype ServiceDiscoverer interface {\n    // GetEndpoint returns endpoint for given namespace and name\n    GetEndpoint(ctx context.Context, namespace, name, resourceType string) (*ServiceEndpoint, error)\n    \n    // WatchEndpoints starts watching for endpoint changes\n    WatchEndpoints(ctx context.Context, namespace string, resourceType string) (<-chan []ServiceEndpoint, error)\n    \n    // Refresh forces a cache refresh\n    Refresh(ctx context.Context) error\n}\n```\n\n### 7.3 ProxyHandler 接口\n\n```go\n// ProxyHandler handles request proxying\ntype ProxyHandler interface {\n    // Handle proxies the request to target\n    Handle(ctx context.Context, proxyCtx *ProxyContext) error\n    \n    // HandleWebSocket proxies WebSocket connection\n    HandleWebSocket(ctx context.Context, proxyCtx *ProxyContext) error\n}\n```\n\n---\n\n## 8. 实施计划\n\n### Phase 1: 核心功能\n- [ ] ProxyServer 基础实现\n- [ ] RequestRouter 路径解析\n- [ ] 基础 client-go 集成\n\n### Phase 2: 服务发现\n- [ ] ServiceDiscovery 实现\n- [ ] 缓存机制\n- [ ] Watch 集成\n\n### Phase 3: 可靠性\n- [ ] 连接池实现\n- [ ] 熔断器\n- [ ] 超时控制\n\n### Phase 4: 可观测性\n- [ ] 日志集成\n- [ ] Prometheus 指标\n- [ ] 健康检查端点\n\n### Phase 5: 高级特性\n- [ ] WebSocket 支持\n- [ ] TLS 支持\n- [ ] 性能优化\n\n---\n\n## 9. 参考资料\n\n- [client-go 文档](deployment/client-go.md)\n- [Go HTTP reverse proxy](https://pkg.go.dev/net/http/httputil#ReverseProxy)\n\n---\n\n## 10. References\n\n- [client-go library](deployment/client-go.md)\n- [AR-001: CRD AgentRuntime Type Definition](design.md)\n- [AR-003: Shared Types and Constants](design.md)\n- [AR-006: Sandbox Deletion and Lifecycle Management](pkg/workloadmanager/design.md)\n- [controller-runtime documentation](https://pkg.go.dev/sigs.k8s.io/controller-runtime)\n- [Kubernetes Controller Pattern](https://kubernetes.io/docs/concepts/extend-kubernetes/api-extension/custom-resources/)\n- [kubebuilder](https://book.kubebuilder.io/)\n\n---\n\n# AR-013 — Redis 存储实现\n\n- **AR ID**: AR-013\n- **Module**: `pkg/store`\n- **Language**: Go\n- **Size**: M\n- **Status**: Design\n\n## 1. Overview\n\nThe Session Store module (`pkg/store`) provides a storage abstraction layer for persisting sandbox metadata in the agentcube system. It supports both Redis and Valkey backends, selected at initialization via configuration.\n\n### Goals\n\n- Persist sandbox metadata keyed by session ID\n- Index sessions by expiry and last activity for garbage collection\n- Provide unified Store interface with Redis and Valkey implementations\n\n### Scope\n\n| Item | Description |\n|------|-------------|\n| Module | `github.com/volcano-sh/agentcube/pkg/store` |\n| Language | Go |\n| Requirement Reference | AR-013 |\n| Dependencies | Redis go-redis/v9, Valkey valkey-go |\n\n---\n\n## 2. Architecture\n\n### 2.1 Component Overview\n\n```\n┌─────────────────┐     ┌──────────────────┐     ┌─────────────────┐\n│   Application   │────▶│   Store iface    │────▶│ Redis Store     │\n│   Layer         │     │   (interface)    │     │ (implementation)│\n└─────────────────┘     └──────────────────┘     └─────────────────┘\n                                │\n                                │ (via STORE_TYPE)\n                                ▼\n                        ┌──────────────────┐\n                        │ Valkey Store     │\n                        │ (implementation) │\n                        └──────────────────┘\n```\n\n### 2.2 Package Structure\n\n| File | Responsibility |\n|------|----------------|\n| `store.go` | Store interface definition, error types |\n| `singleton.go` | Singleton provider initialization |\n| `store_redis.go` | Redis implementation |\n| `store_valkey.go` | Valkey implementation |\n\n---\n\n## 3. API Contracts\n\n### 3.1 Store Interface\n\n```go\ntype Store interface {\n    Ping(ctx context.Context) error\n    GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n    StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\n    UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\n    DeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n    ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n    ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n    UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n    Close() error\n}\n```\n\n### 3.2 Errors\n\n```go\nvar ErrNotFound = errors.New(\"store: not found\")\n```\n\n### 3.3 Singleton Access\n\n```go\nfunc Storage() Store\nfunc initStore() error\n```\n\n- `Storage()` uses `sync.Once` for thread-safe initialization\n- On initialization failure, logs fatal via klog\n\n---\n\n## 4. Data Structures\n\n### 4.1 SandboxInfo\n\n```go\ntype SandboxInfo struct {\n    Kind             string              `json:\"kind\"`\n    SandboxID        string              `json:\"sandboxId\"`\n    SandboxNamespace string              `json:\"sandboxNamespace\"`\n    Name             string              `json:\"name\"`\n    EntryPoints      []SandboxEntryPoint `json:\"entryPoints\"`\n    SessionID        string              `json:\"sessionId\"`\n    CreatedAt        time.Time           `json:\"createdAt\"`\n    ExpiresAt        time.Time           `json:\"expiresAt\"`\n    Status           string              `json:\"status\"`\n}\n\ntype SandboxEntryPoint struct {\n    Path     string `json:\"path\"`\n    Protocol string `json:\"protocol\"`\n    Endpoint string `json:\"endpoint\"`\n}\n```\n\n### 4.2 Key Schema\n\n| Key Pattern | Type | Description |\n|-------------|------|-------------|\n| `session:{sessionID}` | String (JSON) | Primary sandbox document |\n| `session:expiry` | ZSET | Members: sessionID, Score: ExpiresAt Unix |\n| `session:last_activity` | ZSET | Members: sessionID, Score: last activity Unix |\n\n---\n\n## 5. Implementation Details\n\n### 5.1 Redis Implementation\n\n**Struct:**\n\n```go\ntype redisStore struct {\n    cli                  *redisv9.Client\n    sessionPrefix        string  // \"session:\"\n    expiryIndexKey       string  // \"session:expiry\"\n    lastActivityIndexKey string  // \"session:last_activity\"\n}\n```\n\n**Connection Configuration:**\n\n| Env Variable | Required | Description |\n|--------------|----------|-------------|\n| `REDIS_ADDR` | Yes | Server address |\n| `REDIS_PASSWORD` | Yes* | Password (*unless REDIS_PASSWORD_REQUIRED=false) |\n| `STORE_TYPE` | No | Default: \"redis\" |\n\n**Operation Mappings:**\n\n| Method | Redis Commands |\n|--------|----------------|\n| `Ping` | PING → expect \"PONG\" |\n| `GetSandboxBySessionID` | GET session:{id} |\n| `StoreSandbox` | Pipeline: SETNX, ZADD expiry, ZADD last_activity |\n| `UpdateSandbox` | SET key value XX |\n| `DeleteSandboxBySessionID` | Pipeline: DEL, ZREM expiry, ZREM last_activity |\n| `ListExpiredSandboxes` | ZRANGEBYSCORE with LIMIT, then GET pipeline |\n| `ListInactiveSandboxes` | ZRANGEBYSCORE on last_activity, then GET pipeline |\n| `UpdateSessionLastActivity` | GET (verify exists), then ZADD |\n\n### 5.2 Valkey Implementation\n\n**Struct:**\n\n```go\ntype valkeyStore struct {\n    cli                  valkey.Client\n    sessionPrefix        string  // \"session:\"\n    expiryIndexKey       string  // \"session:expiry\"\n    lastActivityIndexKey string  // \"session:last_activity\"\n}\n```\n\n**Connection Configuration:**\n\n| Env Variable | Required | Description |\n|--------------|----------|-------------|\n| `VALKEY_ADDR` | Yes | Comma-separated addresses |\n| `VALKEY_PASSWORD` | Yes* | Password (*unless VALKEY_PASSWORD_REQUIRED=false) |\n| `VALKEY_DISABLE_CACHE` | No | \"true\" enables DisableCache |\n| `VALKEY_FORCE_SINGLE` | No | \"true\" enables ForceSingleClient |\n| `STORE_TYPE` | Must be \"valkey\" | Case-insensitive |\n\n**Operation Mappings:**\n\n| Method | Valkey API |\n|--------|------------|\n| `Ping` | B().Ping() → \"PONG\" |\n| `GetSandboxBySessionID` | B().Get().Key(key), IsValkeyNil → ErrNotFound |\n| `StoreSandbox` | DoMulti: SETNX, ZADD expiry, ZADD last_activity |\n| `UpdateSandbox` | SET ... XX, verify response == \"OK\" |\n| `DeleteSandboxBySessionID` | DoMulti: DEL, ZREM expiry, ZREM last_activity |\n| `ListInactiveSandboxes` | Same pattern on last_activity key |\n\n### 5.3 ZSET Score Semantics\n\n- **Expiry index:** Score = `float64(sandboxInfo.ExpiresAt.Unix())`\n- **Last activity:**\n  - On store: `float64(time.Now().Unix())`\n  - On update: `float64(at.Unix())` or `time.Now()` if `at` is zero\n\n---\n\n## 6. Error Handling\n\n### 6.1 Error Types\n\n| Error | Condition |\n|-------|-----------|\n| `ErrNotFound` | Session key does not exist; ZSET member missing |\n| \"sandbox is nil\" | StoreSandbox called with nil |\n| \"key not exists\" | UpdateSandbox on non-existent key |\n| \"password required\" | Missing password without _REQUIRED=false |\n\n### 6.2 Precondition Validation\n\n| Operation | Validation |\n|-----------|------------|\n| `StoreSandbox` | Reject nil sandbox, reject zero ExpiresAt |\n| `UpdateSandbox` | Use SET with XX flag (key must exist) |\n| `UpdateSessionLastActivity` | Verify session key exists before ZADD |\n| `ListExpired/Inactive` | If limit <= 0, return nil, nil |\n\n---\n\n## 7. Testing Strategy\n\n### 7.1 Unit Tests\n\n| Component | Test Coverage |\n|-----------|---------------|\n| Store Interface | Mock implementation verification |\n| Redis Store | All CRUD operations |\n| Valkey Store | All CRUD operations |\n| Key Construction | sessionKey(), prefix constants |\n| Error Conditions | ErrNotFound paths |\n\n### 7.2 Integration Tests\n\n| Scenario | Approach |\n|----------|----------|\n| Real Redis | Docker container, test suite |\n| Real Valkey | Docker container, test suite |\n| Key Schema | Verify actual keys in Redis/Valkey |\n\n### 7.3 Edge Cases\n\n- Empty session ID on UpdateSessionLastActivity → error\n- Zero time on UpdateSessionLastActivity → use time.Now()\n- Orphan ZSET member (no document) → skip without error\n- Concurrent Storage() calls → only one initialization\n\n---\n\n## 8. Dependencies\n\n```go\nimport (\n    \"github.com/redis/go-redis/v9\"\n    \"github.com/valkey-io/valkey-go\"\n    \"k8s.io/klog/v2\"\n    \"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n```\n\n---\n\n## 9. Configuration Flow\n\n```\nStorage() \n    → initStoreOnce.Do(initStore)\n        → Read STORE_TYPE (default: \"redis\")\n        → Validate required env vars\n        → Create provider (Redis or Valkey)\n        → Return provider singleton\n```\n\n### Provider Selection\n\n| STORE_TYPE | Implementation |\n|------------|----------------|\n| \"redis\" (default) | redisStore |\n| \"valkey\" | valkeyStore |\n| other | fail initialization |\n\n---\n\n## 10. Migration Path\n\nIf migrating from Redis to Valkey:\n\n1. Set `STORE_TYPE=valkey`\n2. Set `VALKEY_ADDR` (cluster addresses)\n3. Set `VALKEY_PASSWORD`\n4. Optionally set `VALKEY_DISABLE_CACHE=true`\n5. Ensure cluster mode if using multiple Valkey nodes\n\nKey compatibility is maintained across both backends (same key schema, same ZSET semantics).\n\n---\n\n# AR-018 — Agentd 空闲清理控制器\n\n- **AR ID**: AR-018\n- **Module**: `pkg/agentd`\n- **Language**: Go\n- **Size**: S\n- **Status**: Draft\n\n## 1. 概述\n\nAgentd Idle Cleanup Controller 监控 `runtime.agentcube.volcano.sh/v1alpha1` API 组的 `AgentRuntime` 和 `CodeInterpreter` 资源。当资源因长时间无活动而空闲时，控制器自动删除这些资源以释放集群资源。\n\n### 1.1 目标\n\n- 自动清理空闲过期的 AgentRuntime 资源\n- 自动清理空闲过期的 CodeInterpreter 资源\n- 通过 annotation (`agentcube.io/last-activity-time`) 跟踪最后活动时间\n- 支持可配置的空闲超时阈值\n\n### 1.2 依赖\n\n- `github.com/volcano/sh/agentcube/client-go` — Kubernetes typed client\n- `k8s.io/apimachinery` — API 类型定义\n- `sigs.k8s.io/controller-runtime` — Controller 框架\n\n---\n\n## 2. 架构设计\n\n### 2.1 组件结构\n\n```\n┌─────────────────────────────────────────────────────────────┐\n│                      agentd binary                          │\n│  ┌────────────────────────────────────────────────────────┐ │\n│  │               controller-runtime Manager               │ │\n│  │  ┌────────────────────────────────────────────────────┐│ │\n│  │  │         IdleCleanupReconciler                      ││ │\n│  │  │  ┌──────────────────┐  ┌────────────────────┐     ││ │\n│  │  │  │ AgentRuntime     │  │ CodeInterpreter    │     ││ │\n│  │  │  │ Controller       │  │ Controller         │     ││ │\n│  │  │  └──────────────────┘  └────────────────────┘     ││ │\n│  │  └────────────────────────────────────────────────────┘│ │\n│  └────────────────────────────────────────────────────────┘ │\n└─────────────────────────────────────────────────────────────┘\n```\n\n### 2.2 包结构\n\n```\ncmd/agentd/main.go              # Binary entry point\npkg/agentd/\n├── reconciler.go               # Reconciler 实现\n├── options.go                  # Controller 配置选项\n├── controller.go               # Controller 注册\n└── suite_test.go               # 测试套件\n```\n\n### 2.3 监听资源\n\n| API Group | Version | Kind | Trigger |\n|-----------|---------|------|---------|\n| `runtime.agentcube.volcano.sh` | `v1alpha1` | `AgentRuntime` | Create/Update/Delete 事件 |\n| `runtime.agentcube.volcano.sh` | `v1alpha1` | `CodeInterpreter` | Create/Update/Delete 事件 |\n\n---\n\n## 3. 数据结构\n\n### 3.1 配置常量\n\n```go\npackage agentd\n\nconst (\n    DefaultSessionExpirationTimeout = 15 * time.Minute\n    DefaultRequeueDelayOnError      = 30 * time.Second\n    LastActivityAnnotationKey       = \"agentcube.io/last-activity-time\"\n)\n```\n\n### 3.2 Controller 选项\n\n```go\ntype ControllerOptions struct {\n    SessionExpirationTimeout time.Duration\n    MaxConcurrentReconciles  int\n}\n```\n\n默认值：\n- `SessionExpirationTimeout`: 15 分钟\n- `MaxConcurrentReconciles`: 1\n\n### 3.3 Reconciler\n\n```go\ntype Reconciler struct {\n    client.Client\n    Scheme *runtime.Scheme\n    \n    expirationTimeout time.Duration\n}\n\nfunc NewReconciler(c client.Client, s *runtime.Scheme, timeout time.Duration) *Reconciler\nfunc (r *Reconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error)\nfunc (r *Reconciler) SetupWithManager(mgr ctrl.Manager) error\n```\n\n---\n\n## 4. API 合约\n\n### 4.1 AgentRuntime\n\n```go\n// AgentRuntimeSpec 包含会话时间配置\ntype AgentRuntimeSpec struct {\n    MaxSessionDuration string `json:\"maxSessionDuration\"` // 例如: \"8h\"\n    SessionTimeout     string `json:\"sessionTimeout\"`     // 例如: \"15m\"\n    TargetPorts        []TargetPort `json:\"targetPorts\"`\n    PodTemplate        *PodTemplateSpec `json:\"podTemplate,omitempty\"`\n}\n```\n\n**空闲检测**：控制器读取 `agentcube.io/last-activity-time` annotation。如果存在且超过 `SessionExpirationTimeout`，则删除资源。\n\n### 4.2 CodeInterpreter\n\n```go\n// CodeInterpreterSpec 包含会话时间配置\ntype CodeInterpreterSpec struct {\n    AuthMode             AuthMode `json:\"authMode,omitempty\"`\n    MaxSessionDuration   string   `json:\"maxSessionDuration,omitempty\"`\n    SessionTimeout       string   `json:\"sessionTimeout,omitempty\"`\n    Ports                []TargetPort `json:\"ports,omitempty\"`\n    Template             ContainerTemplateSpec `json:\"template\"`\n    WarmPoolSize         int32    `json:\"warmPoolSize,omitempty\"`\n}\n```\n\n**空闲检测**：与 AgentRuntime 相同 — 读取 `agentcube.io/last-activity-time` annotation。\n\n---\n\n## 5. 调和逻辑\n\n### 5.1 算法\n\n```\n1. 按 namespace/name 获取资源 (AgentRuntime 或 CodeInterpreter)\n2. 如果 NotFound → 返回 nil error, 不重队列\n3. 如果其他获取错误 → 返回错误, 不重队列\n4. 读取 \"agentcube.io/last-activity-time\" annotation\n5. 如果 annotation 不存在或为空 → 返回 nil, 不重队列\n6. 将 annotation 值解析为 time.RFC3339\n   - 如果解析错误 → 30 秒后重队列并返回错误\n7. 计算 expirationTime = lastActivityTime + SessionExpirationTimeout\n8. 如果 time.Now().After(expirationTime):\n   a. 删除资源\n   b. 如果 NotFound → 返回 nil, 不重队列\n   c. 如果其他删除错误 → 返回错误, 不重队列\n9. 否则 (未过期):\n   a. 计算 requeueAfter = time.Until(expirationTime)\n   b. 返回 RequeueAfter, 无错误\n10. 返回 nil, 不重队列\n```\n\n### 5.2 重队列行为\n\n| 条件 | RequeueAfter | 原因 |\n|------|--------------|------|\n| 解析错误 | 30s | 固定延迟后重试 |\n| 未过期 | `time.Until(expirationTime)` | 等待过期 |\n| 已删除/未找到/无 annotation | 0 | 不重队列 |\n\n---\n\n## 6. 错误处理\n\n### 6.1 删除幂等性\n\n- **删除时 NotFound**: 视为成功，返回 `(ctrl.Result{}, nil)`\n- **其他删除错误**: 返回错误以触发重试\n\n### 6.2 获取 NotFound\n\n- **获取时 NotFound**: 返回 `(ctrl.Result{}, nil)` — 资源已被移除\n\n### 6.3 解析错误\n\n- 无效时间戳格式 → 返回 `RequeueAfter: 30s` 和错误\n\n---\n\n## 7. 测试策略\n\n### 7.1 单元测试\n\n1. **ReconcileAgentRuntime**\n   - 测试过期时成功删除\n   - 测试无 annotation 时不删除\n   - 测试未过期时不删除 (验证重队列)\n   - 测试解析错误处理\n   - 测试 Get NotFound 返回 nil\n   - 测试 Delete NotFound 返回 nil\n\n2. **ReconcileCodeInterpreter**\n   - 与 AgentRuntime 相同的测试用例\n\n### 7.2 测试夹具\n\n```go\nfunc TestReconciler_Reconcile(t *testing.T) {\n    tests := []struct {\n        name           string\n        annotation     string\n        expires        bool\n        expectedResult ctrl.Result\n        expectDelete   bool\n        expectError    bool\n    }{\n        {\n            name:           \"expired - should delete\",\n            annotation:     \"2024-01-01T00:00:00Z\",\n            expires:        true,\n            expectedResult: ctrl.Result{},\n            expectDelete:   true,\n            expectError:    false,\n        },\n        {\n            name:           \"not expired - should requeue\",\n            annotation:     time.Now().Add(-5 * time.Minute).Format(time.RFC3339),\n            expires:        false,\n            expectedResult: ctrl.Result{RequeueAfter: 10 * time.Minute},\n            expectDelete:   false,\n            expectError:    false,\n        },\n    }\n}\n```\n\n### 7.3 集成测试\n\n1. **完整调和循环** — 使用 fake client\n2. **Manager 集成** — 两个 controller 都已注册\n3. **信号处理** — 验证优雅关闭\n\n---\n\n## 8. Manager 配置\n\n```go\nmgr, err := ctrl.NewManager(ctrl.GetConfigOrDie(), ctrl.Options{\n    Scheme:                 schemeBuilder,\n    Metrics:                metricsserver.Options{BindAddress: \"0\"},\n    HealthProbeBindAddress: \"0\",\n})\n```\n\n### 8.1 注册 Controller\n\n```go\n// AgentRuntime controller\nerr = ctrl.NewControllerManagedBy(mgr).\n    For(&runtimev1alpha1.AgentRuntime{}).\n    Complete(agentd.NewReconciler(mgr.GetClient(), mgr.GetScheme(), 15*time.Minute))\n\n// CodeInterpreter controller\nerr = ctrl.NewControllerManagedBy(mgr).\n    For(&runtimev1alpha1.CodeInterpreter{}).\n    Complete(agentd.NewReconciler(mgr.GetClient(), mgr.GetScheme(), 15*time.Minute))\n```\n\n---\n\n## 9. 生命周期\n\n### 9.1 启动\n\n1. 解析 flags / 环境变量获取配置\n2. 使用 scheme 构建 controller-runtime manager\n3. 注册两个 controller\n4. 使用 signal handler 启动 manager\n\n### 9.2 关闭\n\n- SIGTERM / SIGINT 触发优雅关闭\n- Manager 停止所有 controller\n- Cache 停止\n- Process 以 exit code 0 退出\n\n---\n\n## 10. 依赖\n\n### 10.1 直接导入\n\n- `k8s.io/apimachinery/pkg/api/errors`\n- `k8s.io/apimachinery/pkg/runtime`\n- `k8s.io/apimachinery/pkg/runtime/schema`\n- `k8s.io/client-go/tools/cache`\n- `sigs.k8s.io/controller-runtime`\n- `sigs.k8s.io/controller-runtime/pkg/client`\n- `sigs.k8s.io/controller-runtime/pkg/controller`\n- `sigs.k8s.io/controller-runtime/pkg/manager`\n- `github.com/volcano.sh/agentcube/pkg/apis/runtime/v1alpha1`\n- `github.com/volcano.sh/agentcube/client-go` (client-go 库)","additions":312,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/design.md","time":{"start":1775857924976,"end":1775857925010}}}}
