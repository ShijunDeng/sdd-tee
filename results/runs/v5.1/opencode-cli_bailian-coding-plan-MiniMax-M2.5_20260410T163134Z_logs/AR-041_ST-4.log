esting.T) {\n54: \trouter := NewRouter(nil)\n55: \n56: \terr := router.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test\")\n57: \tif err != nil {\n58: \t\tt.Errorf(\"Expected no error, got %v\", err)\n59: \t}\n60: \n61: \tbackend := router.pool.GetAllBackends()[\"backend1\"]\n62: \tif backend == nil {\n63: \t\tt.Error(\"Expected backend to be added\")\n64: \t}\n65: }\n66: \n67: func TestRouter_RemoveBackend(t *testing.T) {\n68: \trouter := NewRouter(nil)\n69: \n70: \trouter.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test\")\n71: \trouter.RemoveBackend(\"backend1\")\n72: \n73: \tbackend := router.pool.GetAllBackends()[\"backend1\"]\n74: \tif backend != nil {\n75: \t\tt.Error(\"Expected backend to be removed\")\n76: \t}\n77: }\n78: \n79: func TestRouter_SetHeaderRoute(t *testing.T) {\n80: \trouter := NewRouter(nil)\n81: \n82: \trouter.AddBackend(\"backend1\", \"http://10.0.0.1:8080\", \"/agent/\", \"test\")\n83: \trouter.SetHeaderRoute(\"X-Backend\", \"backend1\", \"backend1\")\n84: \n85: \tbackend := router.pool.GetBackendByHeader(\"X-Backend\", \"backend1\")\n86: \tif backend == nil {\n87: \t\tt.Error(\"Expected backend for header route\")\n88: \t}\n89: }\n90: \n91: func TestRouter_GetConfig(t *testing.T) {\n92: \tconfig := DefaultConfig()\n93: \trouter := NewRouter(config)\n94: \n95: \tcfg := router.GetConfig()\n96: \tif cfg != config {\n97: \t\tt.Error(\"Expected config to be the same\")\n98: \t}\n99: \n100: \tif cfg.ListenAddress != \":8080\" {\n\n(Showing lines 1-100 of 167. Use offset=101 to continue.)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n)\n\nfunc TestNewRouter(t *testing.T) {\n\trouter := NewRouter(nil)\n\n\tif router == nil {\n\t\tt.Error(\"Expected router to be created\")\n\t}\n\n\tif router.config == nil {\n\t\tt.Error(\"Expected config to be set\")\n\t}","truncated":true,"loaded":[]},"title":"workspaces