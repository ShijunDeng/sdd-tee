base_url = workload_manager_url or os.getenv(\"WORKLOAD_MANAGER_URL\")\n41:         if not self.base_url:\n42:             raise ValueError(\n43:                 \"Workload Manager URL must be provided via argument or WORKLOAD_MANAGER_URL environment variable\"\n44:             )\n45: \n46:         self.session = create_session(\n47:             pool_connections=pool_connections,\n48:             pool_maxsize=pool_maxsize,\n49:         )\n50:         self.session.headers[\"Content-Type\"] = \"application/json\"\n51: \n52:         token = auth_token or read_token_from_file(\n53:             \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n54:         )\n55:         if token:\n56:             self.session.headers[\"Authorization\"] = f\"Bearer {token}\"\n57: \n58:     def create_session(\n59:         self,\n60:         name: str = \"my-interpreter\",\n61:         namespace: str = \"default\",\n62:         metadata: Optional[Dict[str, Any]] = None,\n63:         ttl: int = 3600,\n64:     ) -> str:\n65:         \"\"\"Create a new Code Interpreter session.\n66: \n67:         Args:\n68:             name: Name for the session.\n69:             namespace: Kubernetes namespace.\n70:             metadata: Optional metadata dictionary.\n71:             ttl: Time-to-live in seconds.\n72: \n73:         Returns:\n74:             The session ID from the response.\n75: \n76:         Raises:\n77:             ValueError: If the response does not contain a sessionId.\n78:         \"\"\"\n79:         url = f\"{self.base_url}/v1/code-interpreter\"\n80:         payload = {\n81:             \"name\": name,\n82:             \"namespace\": namespace,\n83:             \"ttl\": ttl,\n84:             \"metadata\": metadata or {},\n85:         }\n86: \n87:         response = self.session.post(\n88:             url,\n89:             json=payload,\n90:             timeout=(self.connect_timeout, self.timeout),\n91:         )\n92:         response.raise_for_status()\n93: \n94:         data = response.json()\n95:         session_id = data.get(\"data\", {}).get(\"sessionId\")\n96:         if not session_id:\n97:             raise ValueError(\"Response does not contain sessionId\")\n98: \n99:         return session_id\n100: \n101:     def delete_session(self, session_id: str) -> bool:\n102:         \"\"\"Delete a Code Interpreter session.\n103: \n104:         Args:\n105:             session_id: The session ID to delete.\n106: \n107:         Returns:\n108:             True if deletion succeeded or session was not found (404), False otherwise.\n109:         \"\"\"\n110:         url = f\"{self.base_url}/v1/code-interpreter/sessions/{session_id}\"\n111: \n112:         try:\n113:             response = self.session.delete(\n114:                 url,\n115:                 timeout=(self.connect_timeout, self.timeout),\n116:             )\n117:             if response.status_code == 404:\n118:                 return True\n119:             response.raise_for_status()\n120:             return True\n121:         except requests.exceptions.RequestException as e:\n122:             self.logger.warning(f\"Failed to delete session {session_id}: {e}\")\n123:             return False\n124: \n125:     def close(self) -> None:\n126:         \"\"\"Close the underlying HTTP session.\"\"\"\n127:         self.session.close()\n\n(End of file - total 127 lines)\n</content>","metadata":{"preview":"\"\"\"Control Plane client for AgentCube SDK.\"\"\"\n\nimport logging\nimport os\nfrom typing import Any, Dict, Optional\n\nimport requests\n\nfrom ..utils.http import create_session\nfrom ..utils.utils import read_token_from_file\nfrom ..utils.log import get_logger\n\n\nclass ControlPlaneClient:\n    \"\"\"Client for interacting with the Workload Manager (control plane).\"\"\"\n\n    def __init__(\n        self,\n        workload_manager_url: Optional[str] = None,\n        auth_token: Optional[str] = None,","truncated":false,"loaded":[]},"title":"sdk-python/agentcube/clients/control_plan