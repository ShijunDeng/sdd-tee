.\n40:             session_id: Existing session ID to reuse.\n41: \n42:         Raises:\n43:             ValueError: If router_url is not provided via argument or ROUTER_URL env var.\n44:         \"\"\"\n45:         self.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n46:         self.name = name\n47:         self.namespace = namespace\n48:         self.ttl = ttl\n49:         self.verbose = verbose\n50:         self.session_id = session_id\n51: \n52:         self.router_url = router_url or os.getenv(\"ROUTER_URL\")\n53:         if not self.router_url:\n54:             raise ValueError(\n55:                 \"Router URL must be provided via argument or ROUTER_URL environment variable\"\n56:             )\n57: \n58:         self.cp_client = ControlPlaneClient(\n59:             workload_manager_url=workload_manager_url,\n60:             auth_token=auth_token,\n61:         )\n62: \n63:         if self.session_id:\n64:             self._init_data_plane()\n65:         else:\n66:             self._init_data_plane()\n67: \n68:     def _init_data_plane(self) -> None:\n69:         \"\"\"Initialize the data plane client.\n70: \n71:         Creates a new session if session_id was not provided.\n72:         \"\"\"\n73:         if not self.session_id:\n74:             self.session_id = self.cp_client.create_session(\n75:                 name=self.name,\n76:                 namespace=self.namespace,\n77:                 ttl=self.ttl,\n78:             )\n79:             self.logger.info(f\"Created new session: {self.session_id}\")\n80: \n81:         self.dp_client = CodeInterpreterDataPlaneClient(\n82:             session_id=self.session_id,\n83:             router_url=self.router_url,\n84:             namespace=self.namespace,\n85:             cr_name=self.name,\n86:         )\n87: \n88:     def __enter__(self):\n89:         \"\"\"Context manager entry.\"\"\"\n90:         return self\n91: \n92:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n93:         \"\"\"Context manager exit - cleanup resources.\"\"\"\n94:         self.stop()\n95: \n96:     def stop(self) -> None:\n97:         \"\"\"Stop the session and cleanup resources.\n98: \n99:         Closes the data plane session, deletes the control plane session\n100:         if session_id was set, and closes the control plane HTTP session.\n101:         \"\"\"\n102:         if self.dp_client:\n103:             self.dp_client.close()\n104: \n105:         if self.session_id and self.cp_client:\n106:             self.cp_client.delete_session(self.session_id)\n107:             self.logger.info(f\"Deleted session: {self.session_id}\")\n108:             self.session_id = None\n109: \n110:         if self.cp_client:\n111:             self.cp_client.close()\n112: \n113:     def execute_command(\n114:         self,\n115:         command: str,\n116:         timeout: Optional[float] = None,\n117:     ) -> str:\n118:         \"\"\"Execute a command in the code interpreter.\n119: \n120:         Args:\n121:             command: Command to execute.\n122:             timeout: Timeout in seconds.\n123: \n124:         Returns:\n125:             The command output.\n126:         \"\"\"\n127:         return self.dp_client.execute_command(command, timeout)\n128: \n129:     def run_code(\n130:         self,\n131:         language: str,\n132:         code: str,\n133:         timeout: Optional[float] = None,\n134:     ) -> str:\n135:         \"\"\"Run code in the specified language.\n136: \n137:         Args:\n138:             language: Programming language.\n139:             code: Code to execute.\n140:             timeout: Timeout in seconds.\n141: \n142:         Returns:\n143:             The code output.\n144:         \"\"\"\n145:         return self.dp_client.run_code(language, code, timeout)\n146: \n147:     def write_file(self, content: str, remote_path: str) -> None:\n148:         \"\"\"Write content to a remote file.\n149: \n150:         Args:\n151:             content: File content.\n152:             remote_path: Remote file path.\n153:         \"\"\"\n154:         self.dp_client.write_file(content, remote_path)\n155: \n156:     def upload_file(self, local_path: str, remote_path: str) -> None:\n157:         \"\"\"Upload a local file to the remote environment.\n158: \n159:         Args:\n160:             local_path: Local file path.\n161:             remote_path: Remote file path.\n162:         \"\"\"\n163:         self.dp_client.upload_file(local_path, remote_path)\n164: \n165:     def download_file(self, remote_path: str, local_path: str) -> None:\n166:         \"\"\"Download a file from the remote environment.\n167: \n168:         Args:\n169:             remote_path: Remote file path.\n170:             local_path: Local file path to save to.\n171:         \"\"\"\n172:         self.dp_client.download_file(remote_path, local_path)\n173: \n174:     def list_files(self, path: str = \".\") -> Any:\n175:         \"\"\"List files in the remote environment.\n176: \n177:         Args:\n178:             path: Path to list.\n179: \n180:         Returns:\n181:             The file listing.\n182:         \"\"\"\n183:         return self.dp_client.list_files(path)\n\n(End of file - total 183 lines)\n</content>","metadata":{"preview":"\"\"\"Code Interpreter Client for AgentCube SDK.\"\"\"\n\nimport logging\nimport os\nfrom typing import Any, Dict, List, Optional\n\nfrom .clients.control_plane import ControlPlaneClient\nfrom .clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom .utils.log import get_logger\n\n\nclass CodeInterpreterClient:\n    \"\"\"High-level client for Code Interpreter operations.\n\n    This client manages session lifecycle and provides a convenient interface\n    for executing commands, running code, and managing files.\n    \"\"\"\n\n    def __init__(\n        self,","truncated":false,"loaded":[]},"title":"sdk-python/agentcube/code_interpreter.py","time":{"start":1775884350058,"end":17758843500