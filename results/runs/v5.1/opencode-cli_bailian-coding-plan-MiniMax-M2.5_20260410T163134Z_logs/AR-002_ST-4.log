ation\"`\n38: \n39: \t// +kubebuilder:validation:Required\n40: \t// +kubebuilder:validation:Pattern:=`^(\\d+m)|(\\d+h)(\\d+m)?$`\n41: \t// +kubebuilder:default:=\"15m\"\n42: \tSessionTimeout string `json:\"sessionTimeout\"`\n43: \n44: \t// +kubebuilder:validation:Required\n45: \t// +kubebuilder:validation:MinItems:=1\n46: \tTargetPorts []TargetPort `json:\"targetPorts\"`\n47: \n48: \t// +optional\n49: \tPodTemplate *PodTemplateSpec `json:\"podTemplate,omitempty\"`\n50: }\n51: \n52: // AgentRuntimeStatus defines the observed state of AgentRuntime.\n53: type AgentRuntimeStatus struct {\n54: \t// +optional\n55: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n56: \n57: \t// +optional\n58: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n59: }\n60: \n61: // +genclient\n62: // +kubebuilder:object:root=true\n63: // +kubebuilder:subresource:status\n64: // +kubebuilder:resource:shortName=ci\n65: \n66: // CodeInterpreter defines code execution environment specifications.\n67: type CodeInterpreter struct {\n68: \tmetav1.TypeMeta   `json:\",inline\"`\n69: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n70: \n71: \tSpec   CodeInterpreterSpec   `json:\"spec,omitempty\"`\n72: \tStatus CodeInterpreterStatus `json:\"status,omitempty\"`\n73: }\n74: \n75: // +kubebuilder:object:root=true\n76: \n77: // CodeInterpreterList contains a list of CodeInterpreter.\n78: type CodeInterpreterList struct {\n79: \tmetav1.TypeMeta `json:\",inline\"`\n80: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n81: \tItems           []CodeInterpreter `json:\"items\"`\n82: }\n83: \n84: // CodeInterpreterSpec defines the desired state of CodeInterpreter.\n85: type CodeInterpreterSpec struct {\n86: \t// +optional\n87: \t// +kubebuilder:validation:Enum=picod;none\n88: \t// +kubebuilder:default:=picod\n89: \tAuthMode AuthMode `json:\"authMode,omitempty\"`\n90: \n91: \t// +optional\n92: \t// +kubebuilder:validation:Pattern:=`^(\\d+h)(\\d+m)?$`\n93: \t// +kubebuilder:default: