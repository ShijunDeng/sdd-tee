ntainers []ContainerSpec `json:\"containers,omitempty\"`\n153: \n154: \t// +optional\n155: \tVolumes []corev1.Volume `json:\" volumes,omitempty\"`\n156: \n157: \t// +optional\n158: \tRestartPolicy corev1.RestartPolicy `json:\"restartPolicy,omitempty\"`\n159: \n160: \t// +optional\n161: \tServiceAccountName string `json:\"serviceAccountName,omitempty\"`\n162: \n163: \t// +optional\n164: \tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n165: \n166: \t// +optional\n167: \tAffinity *corev1.Affinity `json:\"affinity,omitempty\"`\n168: \n169: \t// +optional\n170: \tTolerations []corev1.Toleration `json:\"tolerations,omitempty\"`\n171: \n172: \t// +optional\n173: \tPriorityClassName string `json:\"priorityClassName,omitempty\"`\n174: \n175: \t// +optional\n176: \tPriority *int32 `json:\"priority,omitempty\"`\n177: \n178: \t// +optional\n179: \tDNSPolicy corev1.DNSPolicy `json:\"dnsPolicy,omitempty\"`\n180: \n181: \t// +optional\n182: \tHostNetwork bool `json:\"hostNetwork,omitempty\"`\n183: \n184: \t// +optional\n185: \tHostPID bool `json:\"hostPID,omitempty\"`\n186: \n187: \t// +optional\n188: \tHostIPC bool `json:\"hostIPC,omitempty\"`\n189: \n190: \t// +optional\n191: \tSecurityContext *corev1.PodSecurityContext `json:\"securityContext,omitempty\"`\n192: \n193: \t// +optional\n194: \tImagePullSecrets []corev1.LocalObjectReference `json:\"imagePullSecrets,omitempty\"`\n195: \n196: \t// +optional\n197: \tInitContainers []ContainerSpec `json:\"initContainers,omitempty\"`\n198: }\n199: \n200: // ContainerSpec is a selective subset of corev1.Container.\n201: type ContainerSpec struct {\n202: \t// +kubebuilder:validation:Required\n203: \tName string `json:\"name\"`\n204: \n205: \t// +kubebuilder:validation:Required\n206: \tImage string `json:\"image\"`\n207: \n208: \t// +optional\n209: \tCommand []string `json:\"command,omitempty\"`\n210: \n211: \t// +optional\n212: \tArgs []string `json:\"args,omitempty\"`\n213: \n214: \t// +optional\n215: \tEnv []corev1.EnvVar `json:\"env,omitempty\"`\n216: \n217: \t// +optional\n218: \tResources corev1.ResourceRequirements `json:\"resources,omitempty\"`\n219: \n220: \t// +optional\n221: \tImagePullPolicy corev1.PullPolicy `json:\"imagePullPolicy,omitempty\"`\n222: \n223: \t// +optional\n224: \tPorts []corev1.ContainerPort `json:\"ports,omitempty\"`\n225: \n226: \t// +optional\n227: \tLivenessProbe *corev1.Probe `json:\"livenessProbe,omitempty\"`\n228: \n229: \t// +optional\n230: \tReadinessProbe *corev1.Probe `json:\"readinessProbe,omitempty\"`\n231: \n232: \t// +optional\n233: \tStartupProbe *corev1.Probe `json:\"startupProbe,omitempty\"`\n234: \n235: \t// +optional\n236: \tVolumeMounts []corev1.VolumeMount `json:\"volumeMounts,omitempty\"`\n237: \n238: \t// +optional\n239: \tSecurityContext *corev1.SecurityContext `json:\"securityContext,omitempty\"`\n240: }\n241: \n242: // ContainerTemplateSpec defines container specification for CodeInterpreter.\n243: type ContainerTemplateSpec struct {\n244: \t// +kubebuilder:validation:Required\n245: \tImage string `json:\"image\"`\n246: \n247: \t// +optional\n248: \tCommand []string `json:\"command,omitempty\"`\n249: \n250: \t// +optional\n251: \tArgs []string `json:\"args,omitempty\"`\n252: \n253: \t// +optional\n254: \tEnv []corev1.EnvVar `json:\"env,omitempty\"`\n255: \n256: \t// +optional\n257: \tResources corev1.ResourceRequirements `json:\"resources,omitempty\"`\n258: \n259: \t// +optional\n260: \tRuntimeClassName *string `json:\"runtimeClassName,omitempty\"`\n261: }\n262: \n263: // AuthMode defines the authentication mode for CodeInterpreter.\n264: type AuthMode string\n265: \n266: const (\n267: \t// AuthModePicod uses picod authentication.\n268: \tAuthModePicod AuthMode = \"picod\"\n269: \n270: \t// AuthModeNone means no authentication.\n271: \tAuthModeNone AuthMode = \"none\"\n272: )\n\n(End of file - total 272 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/