{"type":"tool_use","timestamp":1775881233618,"sessionID":"ses_2853b86e2ffeKKyacV6BUsnhng","part":{"id":"prt_d7ac520f3001gIiQSh3sA03ShE","messageID":"msg_d7ac514a3001ktLorHEi2K18Vd","sessionID":"ses_2853b86e2ffeKKyacV6BUsnhng","type":"tool","tool":"read","callID":"toolu_6bfdb9db5e394cd09d72753b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/reconciler/errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/reconciler/errors.go</path>\n<type>file</type>\n<content>\n1: package reconciler\n2: \n3: import (\n4: \t\"errors\"\n5: \t\"fmt\"\n6: \n7: \tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n8: )\n9: \n10: type ErrorType string\n11: \n12: const (\n13: \tErrorTypeTransient  ErrorType = \"Transient\"\n14: \tErrorTypePermanent  ErrorType = \"Permanent\"\n15: \tErrorTypeConflict   ErrorType = \"Conflict\"\n16: \tErrorTypeNotFound   ErrorType = \"NotFound\"\n17: \tErrorTypeValidation ErrorType = \"Validation\"\n18: )\n19: \n20: type ReconcilerError struct {\n21: \tErrorType  ErrorType\n22: \tMessage    string\n23: \tResource   string\n24: \tCause      error\n25: \tRetryCount int\n26: \tMaxRetries int\n27: }\n28: \n29: func (e *ReconcilerError) Error() string {\n30: \tif e.Cause != nil {\n31: \t\treturn fmt.Sprintf(\"%s: %s (resource: %s, cause: %v)\", e.ErrorType, e.Message, e.Resource, e.Cause)\n32: \t}\n33: \treturn fmt.Sprintf(\"%s: %s (resource: %s)\", e.ErrorType, e.Message, e.Resource)\n34: }\n35: \n36: func (e *ReconcilerError) Unwrap() error {\n37: \treturn e.Cause\n38: }\n39: \n40: func (e *ReconcilerError) IsTransient() bool {\n41: \treturn e.ErrorType == ErrorTypeTransient\n42: }\n43: \n44: func (e *ReconcilerError) IsPermanent() bool {\n45: \treturn e.ErrorType == ErrorTypePermanent\n46: }\n47: \n48: func (e *ReconcilerError) IsConflict() bool {\n49: \treturn e.ErrorType == ErrorTypeConflict\n50: }\n51: \n52: func NewTransientError(message, resource string, cause error) *ReconcilerError {\n53: \treturn &ReconcilerError{\n54: \t\tErrorType: ErrorTypeTransient,\n55: \t\tMessage:   message,\n56: \t\tResource:  resource,\n57: \t\tCause:     cause,\n58: \t}\n59: }\n60: \n61: func NewPermanentError(message, resource string, cause error) *ReconcilerError {\n62: \treturn &ReconcilerError{\n63: \t\tErrorType: ErrorTypePermanent,\n64: \t\tMessage:   message,\n65: \t\tResource:  resource,\n66: \t\tCause:     cause,\n67: \t}\n68: }\n69: \n70: func NewConflictError(message, resource string, cause error) *ReconcilerError {\n71: \treturn &ReconcilerError{\n72: \t\tErrorType: ErrorTypeConflict,\n73: \t\tMessage:   message,\n74: \t\tResource:  resource,\n75: \t\tCause:     cause,\n76: \t}\n77: }\n78: \n79: func NewNotFoundError(message, resource string) *ReconcilerError {\n80: \treturn &ReconcilerError{\n81: \t\tErrorType: ErrorTypeNotFound,\n82: \t\tMessage:   message,\n83: \t\tResource:  resource,\n84: \t}\n85: }\n86: \n87: func NewValidationError(message, resource string, cause error) *ReconcilerError {\n88: \treturn &ReconcilerError{\n89: \t\tErrorType: ErrorTypeValidation,\n90: \t\tMessage:   message,\n91: \t\tResource:  resource,\n92: \t\tCause:     cause,\n93: \t}\n94: }\n95: \n96: func GetErrorType(err error) ErrorType {\n97: \tif err == nil {\n98: \t\treturn \"\"\n99: \t}\n100: \tvar reconcilerErr *ReconcilerError\n101: \tif errors.As(err, &reconcilerErr) {\n102: \t\treturn reconcilerErr.ErrorType\n103: \t}\n104: \tif k8serrors.IsNotFound(err) {\n105: \t\treturn ErrorTypeNotFound\n106: \t}\n107: \tif k8serrors.IsConflict(err) {\n108: \t\treturn ErrorTypeConflict\n109: \t}\n110: \tif k8serrors.IsInvalid(err) {\n111: \t\treturn ErrorTypeValidation\n112: \t}\n113: \treturn ErrorTypeTransient\n114: }\n115: \n116: func IsRetryable(err error) bool {\n117: \terrType := GetErrorType(err)\n118: \treturn errType == ErrorTypeTransient || errType == ErrorTypeConflict\n119: }\n120: \n121: func IsTerminal(err error) bool {\n122: \terrType := GetErrorType(err)\n123: \treturn errType == ErrorTypePermanent || errType == ErrorTypeNotFound || errType == ErrorTypeValidation\n124: }\n125: \n126: type ErrorRegistry struct {\n127: \terrors map[string]error\n128: }\n129: \n130: func NewErrorRegistry() *ErrorRegistry {\n131: \treturn &ErrorRegistry{\n132: \t\terrors: make(map[string]error),\n133: \t}\n134: }\n135: \n136: func (r *ErrorRegistry) Register(code string, err error) {\n137: \tr.errors[code] = err\n138: }\n139: \n140: func (r *ErrorRegistry) Get(code string) error {\n141: \treturn r.errors[code]\n142: }\n143: \n144: var (\n145: \tErrSandboxNotFound         = NewNotFoundError(\"sandbox not found\", \"Sandbox\")\n146: \tErrPodCreationFailed       = NewPermanentError(\"failed to create pod\", \"Pod\", nil)\n147: \tErrServiceCreationFailed   = NewPermanentError(\"failed to create service\", \"Service\", nil)\n148: \tErrConfigMapCreationFailed = NewPermanentError(\"failed to create configmap\", \"ConfigMap\", nil)\n149: \tErrPodUpdateFailed         = NewPermanentError(\"failed to update pod\", \"Pod\", nil)\n150: \tErrServiceUpdateFailed     = NewPermanentError(\"failed to update service\", \"Service\", nil)\n151: \tErrConfigMapUpdateFailed   = NewPermanentError(\"failed to update configmap\", \"ConfigMap\", nil)\n152: \tErrPodDeleteFailed         = NewTransientError(\"failed to delete pod\", \"Pod\", nil)\n153: \tErrServiceDeleteFailed     = NewTransientError(\"failed to delete service\", \"Service\", nil)\n154: \tErrStatusUpdateFailed      = NewTransientError(\"failed to update status\", \"Sandbox\", nil)\n155: \tErrInvalidSpec             = NewValidationError(\"invalid sandbox spec\", \"Sandbox\", nil)\n156: \tErrResourceQuotaExceeded   = NewPermanentError(\"resource quota exceeded\", \"ResourceQuota\", nil)\n157: )\n158: \n159: func NewReconcilerErrorFromK8s(err error, resource string) *ReconcilerError {\n160: \tif err == nil {\n161: \t\treturn nil\n162: \t}\n163: \tif k8serrors.IsNotFound(err) {\n164: \t\treturn NewNotFoundError(err.Error(), resource)\n165: \t}\n166: \tif k8serrors.IsConflict(err) {\n167: \t\treturn NewConflictError(err.Error(), resource, err)\n168: \t}\n169: \tif k8serrors.IsInvalid(err) {\n170: \t\treturn NewValidationError(err.Error(), resource, err)\n171: \t}\n172: \tif k8serrors.IsServerTimeout(err) {\n173: \t\treturn NewTransientError(err.Error(), resource, err)\n174: \t}\n175: \tif k8serrors.IsServiceUnavailable(err) {\n176: \t\treturn NewTransientError(err.Error(), resource, err)\n177: \t}\n178: \tif k8serrors.IsBadRequest(err) {\n179: \t\treturn NewValidationError(err.Error(), resource, err)\n180: \t}\n181: \treturn NewTransientError(err.Error(), resource, err)\n182: }\n183: \n184: func IsAlreadyExists(err error) bool {\n185: \treturn k8serrors.IsAlreadyExists(err)\n186: }\n187: \n188: func IsNotFound(err error) bool {\n189: \treturn k8serrors.IsNotFound(err)\n190: }\n191: \n192: func IsConflict(err error) bool {\n193: \treturn k8serrors.IsConflict(err)\n194: }\n195: \n196: func IsInvalid(err error) bool {\n197: \treturn k8serrors.IsInvalid(err)\n198: }\n199: \n200: var _ error = (*ReconcilerError)(nil)\n\n(End of file - total 200 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\n\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n)\n\ntype ErrorType string\n\nconst (\n\tErrorTypeTransient  ErrorType = \"Transient\"\n\tErrorTypePermanent  ErrorType = \"Permanent\"\n\tErrorTypeConflict   ErrorType = \"Conflict\"\n\tErrorTypeNotFound   ErrorType = \"NotFound\"\n\tErrorTypeValidation ErrorType = \"Validation\"\n)\n\ntype ReconcilerError struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/reconciler/errors.go","time":{"start":1775881233606,"end":1775881233615}}}}
