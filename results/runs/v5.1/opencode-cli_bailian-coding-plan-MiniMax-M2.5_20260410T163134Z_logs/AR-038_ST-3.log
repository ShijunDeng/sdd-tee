e, name string, opts metav1.GetOptions) (*agentcubev1alpha1.CodeInterpreterStatus, error) {\n109: \tci, err := m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Get(ctx, name, opts)\n110: \tif err != nil {\n111: \t\treturn nil, err\n112: \t}\n113: \treturn &ci.Status, nil\n114: }\n115: \n116: func (m *workloadManagerImpl) PatchCodeInterpreterStatus(ctx context.Context, namespace, name string, pt types.PatchType, data []byte, opts metav1.PatchOptions) (*agentcubev1alpha1.CodeInterpreter, error) {\n117: \treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Patch(ctx, name, pt, data, opts, \"status\")\n118: }\n119: \n120: func (m *workloadManagerImpl) WatchCodeInterpreters(ctx context.Context, namespace string, opts metav1.ListOptions) (watch.Interface, error) {\n121: \topts.Watch = true\n122: \treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Watch(ctx, opts)\n123: }\n124: \n125: func (m *workloadManagerImpl) Close() error {\n126: \tklog.Info(\"WorkloadManager closed\")\n127: \treturn nil\n128: }\n129: \n130: func (m *workloadManagerImpl) DeleteSandbox(ctx context.Context, namespace, sessionID string, opts DeleteOptions) error {\n131: \tdeleteOpts := metav1.DeleteOptions{}\n132: \tif opts.GracePeriodSeconds != nil {\n133: \t\tgracePeriodSeconds := *opts.GracePeriodSeconds\n134: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n135: \t}\n136: \tif opts.Force {\n137: \t\tdeleteOpts.GracePeriodSeconds = new(int64)\n138: \t\t*deleteOpts.GracePeriodSeconds = 0\n139: \t}\n140: \n141: \tlabelSelector := \"\"\n142: \tif opts.LabelSelector != \"\" {\n143: \t\tlabelSelector = opts.LabelSelector\n144: \t}\n145: \n146: \tars, err := m.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{\n147: \t\tLabelSelector: labelSelector,\n148: \t\tFieldSelector: \"\",\n149: \t})\n150: \tif err != nil {\n151: \t\treturn err\n152: \t}\n153: \n154: \tfor i := range ars.Items {\n155: \t\tar := &ars.Items[i]\n156: \t\tif ar.Labels != nil && ar.Labels[\"sessionId\"] == sessionID {\n157: \t\t\treturn m.client.RuntimeV1alpha1().AgentRuntimes(namespace).Delete(ctx, ar.Name, deleteOpts)\n158: \t\t}\n159: \t}\n160: \n161: \tcis, err := m.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{\n162: \t\tLabelSelector: labelSelector,\n163: \t\tFieldSelector: \"\",\n164: \t})\n165: \tif err != nil {\n166: \t\treturn err\n167: \t}\n168: \n169: \tfor i := range cis.Items {\n170: \t\tci := &cis.Items[i]\n171: \t\tif ci.Labels != nil && ci.Labels[\"sessionId\"] == sessionID {\n172: \t\t\treturn m.client.RuntimeV1alpha1().CodeInterpreters(namespace).Delete(ctx, ci.Name, deleteOpts)\n173: \t\t}\n174: \t}\n175: \n176: \treturn ErrSandboxNotFound\n177: }\n178: \n179: func (m *workloadManagerImpl) GetSandboxBySessionID(ctx context.Context, namespace, sessionID string) (*Sandbox, error) {\n180: \tars, err := m.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{})\n181: \tif err != nil {\n182: \t\treturn nil, err\n183: \t}\n184: \n185: \tfor i := range ars.Items {\n186: \t\tar := &ars.Items[i]\n187: \t\tif ar.Labels != nil && ar.Labels[\"sessionId\"] == sessionID {\n188: \t\t\treturn sandboxFromAgentRuntime(ar), nil\n189: \t\t}\n190: \t}\n191: \n192: \tcis, err := m.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{})\n193: \tif err != nil {\n194: \t\treturn nil, err\n195: \t}\n196: \n197: \tfor i := range cis.Items {\n198: \t\tci := &cis.Items[i]\n199: \t\tif ci.Labels != nil && ci.Labels[\"sessionId\"] == sessionID {\n200: \t\t\treturn sandboxFromCodeInterpreter(ci), nil\n201: \t\t}\n202: \t}\n203: \n204: \treturn nil, ErrSandboxNotFound\n205: }\n206: \n207: func (m *workloadManagerImpl) ListSandboxes(ctx context.Context, namespace string, opts ListOptions) (*SandboxList, error) {\n208: \tlist := &SandboxList{\n209: \t\tItems: make([]Sandbox, 0),\n210: \t}\n211: \n212: \tlabelSelector := \"\"\n213: \tif opts.LabelSelector != \"\" {\n214: \t\tlabelSelector = opts.LabelSelector\n215: \t}\n216: \n217: \tars, err := m.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{\n218: \t\tLabelSelector: labelSelector,\n219: \t\tFieldSelector: opts.FieldSelector,\n220: \t\tLimit:         opts.Limit,\n221: \t\tContinue:      opts.Continue,\n222: \t})\n223: \tif err != nil {\n224: \t\treturn nil, err\n225: \t}\n226: \n227: \tfor i := range ars.Items {\n228: \t\tlist.Items = append(list.Items, *sandboxFromAgentRuntime(&ars.Items[i]))\n229: \t}\n230: \n231: \tcis, err := m.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{\n232: \t\tLabelSelector: labelSelector,\n233: \t\tFieldSelector: opts.FieldSelector,\n234: \t\tLimit:         opts.Limit,\n235: \t\tContinue:      opts.Continue,\n236: \t})\n237: \tif err != nil {\n238: \t\treturn nil, err\n239: \t}\n240: \n241: \tfor i := range cis.Items {\n242: \t\tlist.Items = append(list.Items, *sandboxFromCodeInterpreter(&cis.Items[i]))\n243: \t}\n244: \n245: \treturn list, nil\n246: }\n247: \n248: func sandboxFromAgentRuntime(ar *agentcubev1alpha1.AgentRuntime) *Sandbox {\n249: \tstate := SandboxStateUnknown\n250: \tif len(ar.Status.Conditions) > 0 {\n251: \t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n252: \t\tif lastCondition.Status == \"True\" {\n253: \t\t\tif lastCondition.Reason == \"Running\" {\n254: \t\t\t\tstate = SandboxStateRunning\n255: \t\t\t} else if lastCondition.Reason == \"Failed\" {\n256: \t\t\t\tstate = SandboxStateFailed\n257: \t\t\t}\n258: \t\t}\n259: \t}\n260: \tif ar.DeletionTimestamp != nil {\n261: \t\tstate = SandboxStateDeleting\n262: \t}\n263: \n264: \treturn &Sandbox{\n265: \t\tName:        ar.Name,\n266: \t\tNamespace:   ar.Namespace,\n267: \t\tSessionID:   ar.Labels[\"sessionId\"],\n268: \t\tState:       state,\n269: \t\tCreatedAt:   ar.CreationTimestamp.Time,\n270: \t\tLabels:      ar.Labels,\n271: \t\tAnnotations: ar.Annotations,\n272: \t}\n273: }\n274: \n275: func sandboxFromCodeInterpreter(ci *agentcubev1alpha1.CodeInterpreter) *Sandbox {\n276: \tstate := SandboxStateUnknown\n277: \tif ci.Status.Ready {\n278: \t\tstate = SandboxStateRunning\n279: \t}\n280: \tif len(ci.Status.Conditions) > 0 {\n281: \t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n282: \t\tif lastCondition.Status == \"True\" {\n283: \t\t\tif lastCondition.Reason == \"Failed\" {\n284: \t\t\t\tstate = SandboxStateFailed\n285: \t\t\t}\n286: \t\t}\n287: \t}\n288: \tif ci.DeletionTimestamp != nil {\n289: \t\tstate = SandboxStateDeleting\n290: \t}\n291: \n292: \treturn &Sandbox{\n293: \t\tName:        ci.Name,\n294: \t\tNamespace:   ci.Namespace,\n295: \t\tSessionID:   ci.Labels[\"sessionId\"],\n296: \t\tState:       state,\n297: \t\tCreatedAt:   ci.CreationTimestamp.Time,\n298: \t\tLabels:      ci.Labels,\n299: \t\tAnnotations: ci.Annotations,\n300: \t}\n301: }\n\n(End of file - total 301 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"k8s.io/apimachinery/pkg/watch\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n)\n\ntype WorkloadManager interface {\n\tCreateAgentRuntime(ctx context.Context, namespace string, agentRuntime *agentcubev1alpha1.AgentRuntime, opts metav1.CreateOptions) (*agentcubev1alpha1.AgentRuntime, error)\n\tGetAgentRuntime(ctx context.Context, namespace, name string, opts metav1.GetOptions) (*agentcubev1alpha1.AgentRuntime, error)\n\tListAgentRuntimes(ctx context.Context, namespace string, opts metav1.ListOptions) (*agentcubev1alpha1.AgentRuntimeList, error)\n\tUpdateAgentRuntime(ctx context.Context, namespace string, agentRuntime *agentcubev1alpha1.AgentRuntime, opts metav1.UpdateOptions) (*agentcubev1alpha1.AgentRuntime, error)\n\tDeleteAgentRuntime(ctx context.Context, namespace, name string, opts metav1.DeleteOptions) error","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/service.go","time":{"start":1775881209147,"end":1775881209165}}}}
{"type":"tool_use","timestamp":1775881209187,"sessionID":"ses_2853b86e2ffeKKyacV6BUsnhng","part":{"id":"prt_d7ac4c0900015XZQj5Hvl6IWbo","messageID":"msg_d7ac4a0fc001ft7e6JOyLqKtOy","sessionID":"ses_2853b86e2ffeKKyacV6BUsnhng","type":"tool","tool":"read","callID":"toolu_27840d669cd34c90a791f197","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/reconciler/reconciler.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/reconciler/reconciler.go</path>\n<type>file</type>\n<content>\n1: package reconciler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"sync\"\n7: \t\"time\"\n8: \n9: \tcorev1 \"k8s.io/api/core/v1\"\n10: \t\"k8s.io/apimachinery/pkg/api/errors\"\n11: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n12: \t\"k8s.io/apimachinery/pkg/runtime\"\n13: \t\"k8s.io/client-go/tools/record\"\n14: \t\"k8s.io/klog/v2\"\n15: \n16: \tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n17: \tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n18: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n19: )\n20: \n21: const (\n22: \tAgentRuntimeControllerName    = \"agentruntime-controller\"\n23: \tCodeInterpreterControllerName = \"codeinterpreter-controller\"\n24: \n25: \tFinalizerAgentRuntime    = \"agentruntime.agentcube.volcano.sh/deletion-protection\"\n26: \tFinalizerCodeInterpreter = \"codeinterpreter.agentcube.volcano.sh/deletion-protection\"\n27: \n28: \tMaxRetries   = 5\n29: \tSyncInterval = 30 * time.Second\n30: \tMaxBatchSize = 10\n31: )\n32: \n33: type Phase string\n34: \n35: const (\n36: \tPhasePending   Phase = \"Pending\"\n37: \tPhaseRunning   Phase = \"Running\"\n38: \tPhaseSucceeded Phase = \"Succeeded\"\n39: \tPhaseFailed    Phase = \"Failed\"\n40: \tPhaseUnknown   Phase = \"Unknown\"\n41: \tPhaseDeleting  Phase = \"Deleting\"\n42: )\n43: \n44: type ConditionType string\n45: \n46: const (\n47: \tConditionPodScheduled    ConditionType = \"PodScheduled\"\n48: \tConditionContainersReady ConditionType = \"ContainersReady\"\n49: \tConditionInitialized     ConditionType = \"Initialized\"\n50: \tConditionReconciled      ConditionType = \"Reconciled\"\n51: \tConditionFailed          ConditionType = \"Failed\"\n52: )\n53: \n54: type ReconcilerConfig struct {\n55: \tSyncInterval   time.Duration\n56: \tMaxRetries     int\n57: \tRetryDelays    time.Duration\n58: \tNamespace      string\n59: \tEnableMetrics  bool\n60: \tWorkers        int\n61: \tRateLimitBurst int\n62: \tRateLimitQPS   float64\n63: }\n64: \n65: type ReconcilerMetrics struct {\n66: \tmu                sync.RWMutex\n67: \treconcileTotal    map[string]int64\n68: \treconcileErrors   map[string]int64\n69: \treconcileDuration []float64\n70: \tretryCount        int64\n71: \tlastReconcileTime time.Time\n72: }\n73: \n74: func NewReconcilerMetrics() *ReconcilerMetrics {\n75: \treturn &ReconcilerMetrics{\n76: \t\treconcileTotal:    make(map[string]int64),\n77: \t\treconcileErrors:   make(map[string]int64),\n78: \t\treconcileDuration: make([]float64, 0),\n79: \t}\n80: }\n81: \n82: func (m *ReconcilerMetrics) incrementReconcileTotal(action string) {\n83: \tm.mu.Lock()\n84: \tdefer m.mu.Unlock()\n85: \tm.reconcileTotal[action]++\n86: \tm.lastReconcileTime = time.Now()\n87: }\n88: \n89: func (m *ReconcilerMetrics) incrementReconcileErrors(action string) {\n90: \tm.mu.Lock()\n91: \tdefer m.mu.Unlock()\n92: \tm.reconcileErrors[action]++\n93: }\n94: \n95: func (m *ReconcilerMetrics) incrementRetries() {\n96: \tm.mu.Lock()\n97: \tdefer m.mu.Unlock()\n98: \tm.retryCount++\n99: }\n100: \n101: func (m *ReconcilerMetrics) observeReconcileDuration(d time.Duration) {\n102: \tm.mu.Lock()\n103: \tdefer m.mu.Unlock()\n104: \tm.reconcileDuration = append(m.reconcileDuration, d.Seconds())\n105: \tif len(m.reconcileDuration) > 1000 {\n106: \t\tm.reconcileDuration = m.reconcileDuration[1:]\n107: \t}\n108: }\n109: \n110: func (m *ReconcilerMetrics) GetReconcileTotal(action string) int64 {\n111: \tm.mu.RLock()\n112: \tdefer m.mu.RUnlock()\n113: \treturn m.reconcileTotal[action]\n114: }\n115: \n116: func (m *ReconcilerMetrics) GetReconcileErrors(action string) int64 {\n117: \tm.mu.RLock()\n118: \tdefer m.mu.RUnlock()\n119: \treturn m.reconcileErrors[action]\n120: }\n121: \n122: func (m *ReconcilerMetrics) GetRetryCount() int64 {\n123: \tm.mu.RLock()\n124: \tdefer m.mu.RUnlock()\n125: \treturn m.retryCount\n126: }\n127: \n128: type AgentRuntimeReconciler struct {\n129: \tclient         versioned.Interface\n130: \tk8sClient      *workloadmanager.K8sClient\n131: \tscheme         *runtime.Scheme\n132: \trecorder       record.EventRecorder\n133: \tconfig         *ReconcilerConfig\n134: \tlastSyncTime   time.Time\n135: \tsyncErrors     int\n136: \tmetrics        *ReconcilerMetrics\n137: \tworkqueueDepth int\n138: \tmu             sync.RWMutex\n139: }\n140: \n141: func NewAgentRuntimeReconciler(\n142: \tclient versioned.Interface,\n143: \tk8sClient *workloadmanager.K8sClient,\n144: \tscheme *runtime.Scheme,\n145: \trecorder record.EventRecorder,\n146: \tconfig *ReconcilerConfig,\n147: ) *AgentRuntimeReconciler {\n148: \tif config == nil {\n149: \t\tconfig = &ReconcilerConfig{\n150: \t\t\tSyncInterval:   SyncInterval,\n151: \t\t\tMaxRetries:     MaxRetries,\n152: \t\t\tRetryDelays:    5 * time.Second,\n153: \t\t\tWorkers:        1,\n154: \t\t\tEnableMetrics:  true,\n155: \t\t\tRateLimitBurst: 10,\n156: \t\t\tRateLimitQPS:   10,\n157: \t\t}\n158: \t}\n159: \n160: \treturn &AgentRuntimeReconciler{\n161: \t\tclient:       client,\n162: \t\tk8sClient:    k8sClient,\n163: \t\tscheme:       scheme,\n164: \t\trecorder:     recorder,\n165: \t\tconfig:       config,\n166: \t\tmetrics:      NewReconcilerMetrics(),\n167: \t\tlastSyncTime: time.Now(),\n168: \t}\n169: }\n170: \n171: type ReconcileRequest struct {\n172: \tNamespace string\n173: \tName      string\n174: }\n175: \n176: type ReconcileResult struct {\n177: \tRequeue      bool\n178: \tRequeueAfter time.Duration\n179: }\n180: \n181: func (r *AgentRuntimeReconciler) Reconcile(ctx context.Context, req ReconcileRequest) (ReconcileResult, error) {\n182: \tstartTime := time.Now()\n183: \tdefer func() {\n184: \t\tduration := time.Since(startTime)\n185: \t\tr.metrics.observeReconcileDuration(duration)\n186: \t\tklog.V(4).InfoS(\"Reconcile completed\", \"duration\", duration)\n187: \t}()\n188: \n189: \tnamespace := req.Namespace\n190: \tname := req.Name\n191: \n192: \tklog.V(4).InfoS(\"Starting reconciliation\", \"namespace\", namespace, \"name\", name)\n193: \n194: \tagentRuntime, err := r.client.RuntimeV1alpha1().AgentRuntimes(namespace).Get(ctx, name, metav1.GetOptions{})\n195: \tif err != nil {\n196: \t\tif errors.IsNotFound(err) {\n197: \t\t\tklog.V(4).InfoS(\"AgentRuntime not found, skipping reconciliation\", \"namespace\", namespace, \"name\", name)\n198: \t\t\treturn ReconcileResult{}, nil\n199: \t\t}\n200: \t\tr.metrics.incrementReconcileErrors(\"fetch_error\")\n201: \t\treturn r.handleError(err, \"failed to fetch agentruntime\")\n202: \t}\n203: \n204: \tvar reconcileErr error\n205: \tvar action string\n206: \n207: \tif agentRuntime.GetDeletionTimestamp() != nil {\n208: \t\taction = \"delete\"\n209: \t\treconcileErr = r.reconcileDelete(ctx, agentRuntime)\n210: \t} else {\n211: \t\toldSpec := agentRuntime.Status.ObservedGeneration\n212: \t\tnewSpec := agentRuntime.GetGeneration()\n213: \n214: \t\tif oldSpec != newSpec {\n215: \t\t\taction = \"update\"\n216: \t\t\treconcileErr = r.reconcileUpdate(ctx, agentRuntime)\n217: \t\t} else {\n218: \t\t\taction = \"create\"\n219: \t\t\treconcileErr = r.reconcileCreate(ctx, agentRuntime)\n220: \t\t}\n221: \t}\n222: \n223: \tr.metrics.incrementReconcileTotal(action)\n224: \n225: \tif reconcileErr != nil {\n226: \t\tr.metrics.incrementReconcileErrors(action)\n227: \t\treturn r.handleError(reconcileErr, fmt.Sprintf(\"reconciliation %s failed\", action))\n228: \t}\n229: \n230: \tr.setLastSyncTime(time.Now())\n231: \tklog.V(4).InfoS(\"Reconciliation completed successfully\", \"namespace\", namespace, \"name\", name, \"action\", action)\n232: \n233: \treturn ReconcileResult{}, nil\n234: }\n235: \n236: func (r *AgentRuntimeReconciler) handleError(err error, msg string) (ReconcileResult, error) {\n237: \tif IsRetryable(err) && r.shouldRetry() {\n238: \t\tr.metrics.incrementRetries()\n239: \t\tdelay := r.config.RetryDelays\n240: \t\tklog.V(2).InfoS(msg, \"error\", err, \"retryable\", true, \"delay\", delay)\n241: \t\treturn ReconcileResult{Requeue: true, RequeueAfter: delay}, nil\n242: \t}\n243: \n244: \tklog.V(2).InfoS(msg, \"error\", err, \"retryable\", false)\n245: \treturn ReconcileResult{}, err\n246: }\n247: \n248: func (r *AgentRuntimeReconciler) shouldRetry() bool {\n249: \treturn r.syncErrors < r.config.MaxRetries\n250: }\n251: \n252: func (r *AgentRuntimeReconciler) reconcileCreate(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n253: \tklog.V(4).InfoS(\"Reconciling create\", \"name\", ar.Name, \"namespace\", ar.Namespace)\n254: \n255: \tif err := r.ensureFinalizer(ctx, ar); err != nil {\n256: \t\treturn err\n257: \t}\n258: \n259: \tif err := r.createPod(ctx, ar); err != nil {\n260: \t\tr.emitEvent(ar, corev1.EventTypeWarning, \"PodCreationFailed\", err.Error())\n261: \t\treturn err\n262: \t}\n263: \n264: \tif err := r.createServices(ctx, ar); err != nil {\n265: \t\tr.emitEvent(ar, corev1.EventTypeWarning, \"ServiceCreationFailed\", err.Error())\n266: \t\treturn err\n267: \t}\n268: \n269: \tif err := r.createConfigMaps(ctx, ar); err != nil {\n270: \t\tr.emitEvent(ar, corev1.EventTypeWarning, \"ConfigMapCreationFailed\", err.Error())\n271: \t\treturn err\n272: \t}\n273: \n274: \tif err := r.updateStatusPhase(ctx, ar, PhaseRunning); err != nil {\n275: \t\treturn err\n276: \t}\n277: \n278: \tr.emitEvent(ar, corev1.EventTypeNormal, \"Reconciled\", \"AgentRuntime reconciled successfully\")\n279: \treturn nil\n280: }\n281: \n282: func (r *AgentRuntimeReconciler) reconcileUpdate(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n283: \tklog.V(4).InfoS(\"Reconciling update\", \"name\", ar.Name, \"namespace\", ar.Namespace)\n284: \n285: \thasChanges, err := r.detectChanges(ctx, ar)\n286: \tif err != nil {\n287: \t\treturn err\n288: \t}\n289: \n290: \tif !hasChanges {\n291: \t\tklog.V(4).InfoS(\"No changes detected, skipping update\", \"name\", ar.Name)\n292: \t\treturn r.syncStatusFromPod(ctx, ar)\n293: \t}\n294: \n295: \tif err := r.updatePod(ctx, ar); err != nil {\n296: \t\tr.emitEvent(ar, corev1.EventTypeWarning, \"PodUpdateFailed\", err.Error())\n297: \t\treturn err\n298: \t}\n299: \n300: \tif err := r.updateServices(ctx, ar); err != nil {\n301: \t\tr.emitEvent(ar, corev1.EventTypeWarning, \"ServiceUpdateFailed\", err.Error())\n302: \t\treturn err\n303: \t}\n304: \n305: \tif err := r.updateConfigMaps(ctx, ar); err != nil {\n306: \t\tr.emitEvent(ar, corev1.EventTypeWarning, \"ConfigMapUpdateFailed\", err.Error())\n307: \t\treturn err\n308: \t}\n309: \n310: \tif err := r.syncStatusFromPod(ctx, ar); err != nil {\n311: \t\treturn err\n312: \t}\n313: \n314: \tr.emitEvent(ar, corev1.EventTypeNormal, \"Updated\", \"AgentRuntime updated successfully\")\n315: \treturn nil\n316: }\n317: \n318: func (r *AgentRuntimeReconciler) reconcileDelete(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n319: \tklog.V(4).InfoS(\"Reconciling delete\", \"name\", ar.Name, \"namespace\", ar.Namespace)\n320: \n321: \tif err := r.cleanupOwnedResources(ctx, ar); err != nil {\n322: \t\tr.emitEvent(ar, corev1.EventTypeWarning, \"CleanupFailed\", err.Error())\n323: \t\treturn err\n324: \t}\n325: \n326: \tif err := r.removeFinalizer(ctx, ar); err != nil {\n327: \t\treturn err\n328: \t}\n329: \n330: \tr.emitEvent(ar, corev1.EventTypeNormal, \"Deleted\", \"AgentRuntime and owned resources deleted\")\n331: \treturn nil\n332: }\n333: \n334: func (r *AgentRuntimeReconciler) ensureFinalizer(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n335: \tfor _, f := range ar.Finalizers {\n336: \t\tif f == FinalizerAgentRuntime {\n337: \t\t\treturn nil\n338: \t\t}\n339: \t}\n340: \n341: \tar.Finalizers = append(ar.Finalizers, FinalizerAgentRuntime)\n342: \t_, err := r.client.RuntimeV1alpha1().AgentRuntimes(ar.Namespace).Update(ctx, ar, metav1.UpdateOptions{})\n343: \treturn err\n344: }\n345: \n346: func (r *AgentRuntimeReconciler) removeFinalizer(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n347: \tvar newFinalizers []string\n348: \tfor _, f := range ar.Finalizers {\n349: \t\tif f != FinalizerAgentRuntime {\n350: \t\t\tnewFinalizers = append(newFinalizers, f)\n351: \t\t}\n352: \t}\n353: \n354: \tar.Finalizers = newFinalizers\n355: \t_, err := r.client.RuntimeV1alpha1().AgentRuntimes(ar.Namespace).Update(ctx, ar, metav1.UpdateOptions{})\n356: \treturn err\n357: }\n358: \n359: func (r *AgentRuntimeReconciler) emitEvent(ar *agentcubev1alpha1.AgentRuntime, eventType, reason, message string) {\n360: \tif r.recorder != nil {\n361: \t\tr.recorder.Event(ar, eventType, reason, message)\n362: \t}\n363: }\n364: \n365: func (r *AgentRuntimeReconciler) updateStatusPhase(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime, phase Phase) error {\n366: \tupdated := false\n367: \tfor i := range ar.Status.Conditions {\n368: \t\tif ar.Status.Conditions[i].Type == string(ConditionReconciled) {\n369: \t\t\tar.Status.Conditions[i].Status = metav1.ConditionTrue\n370: \t\t\tar.Status.Conditions[i].Reason = string(phase)\n371: \t\t\tar.Status.Conditions[i].Message = fmt.Sprintf(\"AgentRuntime is %s\", phase)\n372: \t\t\tar.Status.Conditions[i].LastTransitionTime = metav1.Now()\n373: \t\t\tupdated = true\n374: \t\t\tbreak\n375: \t\t}\n376: \t}\n377: \n378: \tif !updated {\n379: \t\tar.Status.Conditions = append(ar.Status.Conditions, metav1.Condition{\n380: \t\t\tType:               string(ConditionReconciled),\n381: \t\t\tStatus:             metav1.ConditionTrue,\n382: \t\t\tLastTransitionTime: metav1.Now(),\n383: \t\t\tReason:             string(phase),\n384: \t\t\tMessage:            fmt.Sprintf(\"AgentRuntime is %s\", phase),\n385: \t\t})\n386: \t}\n387: \n388: \tar.Status.ObservedGeneration = ar.GetGeneration()\n389: \t_, err := r.client.RuntimeV1alpha1().AgentRuntimes(ar.Namespace).UpdateStatus(ctx, ar, metav1.UpdateOptions{})\n390: \treturn err\n391: }\n392: \n393: func (r *AgentRuntimeReconciler) createPod(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n394: \tnamespace := ar.Namespace\n395: \tname := ar.Name\n396: \tuid := ar.UID\n397: \n398: \tpod := &corev1.Pod{\n399: \t\tObjectMeta: metav1.ObjectMeta{\n400: \t\t\tName:      fmt.Sprintf(\"%s-pod\", name),\n401: \t\t\tNamespace: namespace,\n402: \t\t\tLabels: map[string]string{\n403: \t\t\t\t\"app.kubernetes.io/name\":       name,\n404: \t\t\t\t\"app.kubernetes.io/managed-by\": \"agentcube\",\n405: \t\t\t\t\"agentruntime-uid\":             string(uid),\n406: \t\t\t},\n407: \t\t\tOwnerReferences: []metav1.OwnerReference{\n408: \t\t\t\t{\n409: \t\t\t\t\tAPIVersion:         \"runtime.agentcube.volcano.sh/v1alpha1\",\n410: \t\t\t\t\tKind:               \"AgentRuntime\",\n411: \t\t\t\t\tName:               name,\n412: \t\t\t\t\tUID:                uid,\n413: \t\t\t\t\tController:         boolPtr(true),\n414: \t\t\t\t\tBlockOwnerDeletion: boolPtr(true),\n415: \t\t\t\t},\n416: \t\t\t},\n417: \t\t},\n418: \t\tSpec: corev1.PodSpec{\n419: \t\t\tContainers: []corev1.Container{\n420: \t\t\t\t{\n421: \t\t\t\t\tName:  \"agent\",\n422: \t\t\t\t\tImage: \"agentcube/agent:latest\",\n423: \t\t\t\t},\n424: \t\t\t},\n425: \t\t},\n426: \t}\n427: \n428: \tif ar.Spec.PodTemplate != nil && ar.Spec.PodTemplate.Spec != nil {\n429: \t\tfor _, container := range ar.Spec.PodTemplate.Spec.Containers {\n430: \t\t\tpod.Spec.Containers = append(pod.Spec.Containers, corev1.Container{\n431: \t\t\t\tName:  container.Name,\n432: \t\t\t\tImage: container.Image,\n433: \t\t\t\tEnv:   container.Env,\n434: \t\t\t})\n435: \t\t}\n436: \t}\n437: \n438: \t_, err := r.k8sClient.KubernetesClient.CoreV1().Pods(namespace).Create(ctx, pod, metav1.CreateOptions{})\n439: \tif err != nil && !errors.IsAlreadyExists(err) {\n440: \t\treturn fmt.Errorf(\"failed to create pod: %w\", err)\n441: \t}\n442: \n443: \tklog.V(4).InfoS(\"Pod created\", \"pod\", pod.Name, \"namespace\", namespace)\n444: \treturn nil\n445: }\n446: \n447: func (r *AgentRuntimeReconciler) createServices(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n448: \treturn nil\n449: }\n450: \n451: func (r *AgentRuntimeReconciler) createConfigMaps(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n452: \treturn nil\n453: }\n454: \n455: func (r *AgentRuntimeReconciler) updatePod(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n456: \treturn nil\n457: }\n458: \n459: func (r *AgentRuntimeReconciler) updateServices(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n460: \treturn nil\n461: }\n462: \n463: func (r *AgentRuntimeReconciler) updateConfigMaps(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n464: \treturn nil\n465: }\n466: \n467: func (r *AgentRuntimeReconciler) detectChanges(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) (bool, error) {\n468: \treturn true, nil\n469: }\n470: \n471: func (r *AgentRuntimeReconciler) syncStatusFromPod(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n472: \tpods, err := r.k8sClient.KubernetesClient.CoreV1().Pods(ar.Namespace).List(ctx, metav1.ListOptions{\n473: \t\tLabelSelector: fmt.Sprintf(\"agentruntime-uid=%s\", ar.UID),\n474: \t})\n475: \tif err != nil {\n476: \t\treturn err\n477: \t}\n478: \n479: \tif len(pods.Items) > 0 {\n480: \t\tpod := pods.Items[0]\n481: \t\tr.updateStatusFromPod(ar, &pod)\n482: \t}\n483: \n484: \t_, err = r.client.RuntimeV1alpha1().AgentRuntimes(ar.Namespace).UpdateStatus(ctx, ar, metav1.UpdateOptions{})\n485: \treturn err\n486: }\n487: \n488: func (r *AgentRuntimeReconciler) updateStatusFromPod(ar *agentcubev1alpha1.AgentRuntime, pod *corev1.Pod) {\n489: \tfor i := range pod.Status.Conditions {\n490: \t\tcondition := pod.Status.Conditions[i]\n491: \t\tif condition.Type == corev1.PodReady {\n492: \t\t\tfound := false\n493: \t\t\tfor j := range ar.Status.Conditions {\n494: \t\t\t\tif ar.Status.Conditions[j].Type == string(ConditionContainersReady) {\n495: \t\t\t\t\tar.Status.Conditions[j].Status = metav1.ConditionStatus(condition.Status)\n496: \t\t\t\t\tfound = true\n497: \t\t\t\t\tbreak\n498: \t\t\t\t}\n499: \t\t\t}\n500: \t\t\tif !found {\n501: \t\t\t\tar.Status.Conditions = append(ar.Status.Conditions, metav1.Condition{\n502: \t\t\t\t\tType:               string(ConditionContainersReady),\n503: \t\t\t\t\tStatus:             metav1.ConditionStatus(condition.Status),\n504: \t\t\t\t\tLastTransitionTime: metav1.Now(),\n505: \t\t\t\t\tReason:             condition.Reason,\n506: \t\t\t\t\tMessage:            condition.Message,\n507: \t\t\t\t})\n508: \t\t\t}\n509: \t\t}\n510: \t\tif condition.Type == corev1.PodScheduled {\n511: \t\t\tfound := false\n512: \t\t\tfor j := range ar.Status.Conditions {\n513: \t\t\t\tif ar.Status.Conditions[j].Type == string(ConditionPodScheduled) {\n514: \t\t\t\t\tar.Status.Conditions[j].Status = metav1.ConditionStatus(condition.Status)\n515: \t\t\t\t\tfound = true\n516: \t\t\t\t\tbreak\n517: \t\t\t\t}\n518: \t\t\t}\n519: \t\t\tif !found {\n520: \t\t\t\tar.Status.Conditions = append(ar.Status.Conditions, metav1.Condition{\n521: \t\t\t\t\tType:               string(ConditionPodScheduled),\n522: \t\t\t\t\tStatus:             metav1.ConditionStatus(condition.Status),\n523: \t\t\t\t\tLastTransitionTime: metav1.Now(),\n524: \t\t\t\t\tReason:             condition.Reason,\n525: \t\t\t\t\tMessage:            condition.Message,\n526: \t\t\t\t})\n527: \t\t\t}\n528: \t\t}\n529: \t}\n530: }\n531: \n532: func (r *AgentRuntimeReconciler) cleanupOwnedResources(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n533: \tnamespace := ar.Namespace\n534: \tuid := ar.UID\n535: \n536: \tpods, err := r.k8sClient.KubernetesClient.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n537: \t\tLabelSelector: fmt.Sprintf(\"agentruntime-uid=%s\", uid),\n538: \t})\n539: \tif err != nil {\n540: \t\treturn err\n541: \t}\n542: \n543: \tfor _, pod := range pods.Items {\n544: \t\terr := r.k8sClient.KubernetesClient.CoreV1().Pods(namespace).Delete(ctx, pod.Name, metav1.DeleteOptions{})\n545: \t\tif err != nil && !errors.IsNotFound(err) {\n546: \t\t\tklog.V(2).InfoS(\"Failed to delete pod\", \"pod\", pod.Name, \"error\", err)\n547: \t\t}\n548: \t}\n549: \n550: \tservices, err := r.k8sClient.KubernetesClient.CoreV1().Services(namespace).List(ctx, metav1.ListOptions{\n551: \t\tLabelSelector: fmt.Sprintf(\"agentruntime-uid=%s\", uid),\n552: \t})\n553: \tif err != nil {\n554: \t\treturn err\n555: \t}\n556: \n557: \tfor _, svc := range services.Items {\n558: \t\terr := r.k8sClient.KubernetesClient.CoreV1().Services(namespace).Delete(ctx, svc.Name, metav1.DeleteOptions{})\n559: \t\tif err != nil && !errors.IsNotFound(err) {\n560: \t\t\tklog.V(2).InfoS(\"Failed to delete service\", \"service\", svc.Name, \"error\", err)\n561: \t\t}\n562: \t}\n563: \n564: \tconfigMaps, err := r.k8sClient.KubernetesClient.CoreV1().ConfigMaps(namespace).List(ctx, metav1.ListOptions{\n565: \t\tLabelSelector: fmt.Sprintf(\"agentruntime-uid=%s\", uid),\n566: \t})\n567: \tif err != nil {\n568: \t\treturn err\n569: \t}\n570: \n571: \tfor _, cm := range configMaps.Items {\n572: \t\terr := r.k8sClient.KubernetesClient.CoreV1().ConfigMaps(namespace).Delete(ctx, cm.Name, metav1.DeleteOptions{})\n573: \t\tif err != nil && !errors.IsNotFound(err) {\n574: \t\t\tklog.V(2).InfoS(\"Failed to delete configmap\", \"configmap\", cm.Name, \"error\", err)\n575: \t\t}\n576: \t}\n577: \n578: \treturn nil\n579: }\n580: \n581: func (r *AgentRuntimeReconciler) StartPeriodicSync(ctx context.Context, stopCh <-chan struct{}) {\n582: \tticker := time.NewTicker(r.config.SyncInterval)\n583: \tdefer ticker.Stop()\n584: \n585: \tfor {\n586: \t\tselect {\n587: \t\tcase <-ctx.Done():\n588: \t\t\treturn\n589: \t\tcase <-stopCh:\n590: \t\t\treturn\n591: \t\tcase <-ticker.C:\n592: \t\t\tif err := r.syncAllAgentRuntimes(ctx); err != nil {\n593: \t\t\t\tklog.V(2).InfoS(\"Periodic sync failed\", \"error\", err)\n594: \t\t\t}\n595: \t\t}\n596: \t}\n597: }\n598: \n599: func (r *AgentRuntimeReconciler) syncAllAgentRuntimes(ctx context.Context) error {\n600: \tklog.V(4).InfoS(\"Starting periodic sync\")\n601: \n602: \tnamespaces := []string{metav1.NamespaceAll}\n603: \n604: \tfor _, ns := range namespaces {\n605: \t\tagentRuntimes, err := r.client.RuntimeV1alpha1().AgentRuntimes(ns).List(ctx, metav1.ListOptions{})\n606: \t\tif err != nil {\n607: \t\t\tklog.V(2).InfoS(\"Failed to list agentruntimes\", \"namespace\", ns, \"error\", err)\n608: \t\t\tcontinue\n609: \t\t}\n610: \n611: \t\tfor i := range agentRuntimes.Items {\n612: \t\t\tar := &agentRuntimes.Items[i]\n613: \t\t\tif err := r.repairDrift(ctx, ar); err != nil {\n614: \t\t\t\tklog.V(2).InfoS(\"Failed to repair drift\", \"name\", ar.Name, \"error\", err)\n615: \t\t\t}\n616: \t\t}\n617: \t}\n618: \n619: \treturn nil\n620: }\n621: \n622: func (r *AgentRuntimeReconciler) repairDrift(ctx context.Context, ar *agentcubev1alpha1.AgentRuntime) error {\n623: \tnamespace := ar.Namespace\n624: \tuid := ar.UID\n625: \n626: \tpods, err := r.k8sClient.KubernetesClient.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n627: \t\tLabelSelector: fmt.Sprintf(\"agentruntime-uid=%s\", uid),\n628: \t})\n629: \tif err != nil {\n630: \t\treturn err\n631: \t}\n632: \n633: \tif len(pods.Items) == 0 {\n634: \t\tif ar.DeletionTimestamp == nil {\n635: \t\t\tklog.V(4).InfoS(\"Pod not found but agentruntime exists, creating\", \"name\", ar.Name)\n636: \t\t\treturn r.createPod(ctx, ar)\n637: \t\t}\n638: \t}\n639: \n640: \treturn nil\n641: }\n642: \n643: func boolPtr(b bool) *bool {\n644: \treturn &b\n645: }\n646: \n647: func (r *AgentRuntimeReconciler) GetLastSyncTime() time.Time {\n648: \tr.mu.RLock()\n649: \tdefer r.mu.RUnlock()\n650: \treturn r.lastSyncTime\n651: }\n652: \n653: func (r *AgentRuntimeReconciler) setLastSyncTime(t time.Time) {\n654: \tr.mu.Lock()\n655: \tdefer r.mu.Unlock()\n656: \tr.lastSyncTime = t\n657: }\n658: \n659: func (r *AgentRuntimeReconciler) GetWorkqueueDepth() int {\n660: \treturn r.workqueueDepth\n661: }\n662: \n663: func (r *AgentRuntimeReconciler) SetWorkqueueDepth(depth int) {\n664: \tr.workqueueDepth = depth\n665: }\n666: \n667: func (r *AgentRuntimeReconciler) GetMetrics() *ReconcilerMetrics {\n668: \treturn r.metrics\n669: }\n\n(End of file - total 669 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/tools/record\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/reconciler/reconciler.go","time":{"start":1775881209149,"end":1775881209184}}}}
