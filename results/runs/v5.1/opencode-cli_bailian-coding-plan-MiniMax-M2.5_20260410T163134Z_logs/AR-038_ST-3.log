{"type":"tool_use","timestamp":1775881216899,"sessionID":"ses_2853b86e2ffeKKyacV6BUsnhng","part":{"id":"prt_d7ac4d88c001X8LUtagTz1ORLK","messageID":"msg_d7ac4c599001Foh3n2RXZCaZmw","sessionID":"ses_2853b86e2ffeKKyacV6BUsnhng","type":"tool","tool":"read","callID":"toolu_bf87084c70e2405080785eeb","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"sync\"\n7: \t\"time\"\n8: \n9: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: \t\"k8s.io/apimachinery/pkg/labels\"\n12: \t\"k8s.io/client-go/kubernetes\"\n13: \t\"k8s.io/klog/v2\"\n14: \n15: \tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n16: \tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n17: )\n18: \n19: const (\n20: \tDefaultGCInterval         = 5 * time.Minute\n21: \tDefaultGCBatchSize        = 50\n22: \tDefaultGracePeriod        = 30 * time.Second\n23: \tStaleGracePeriod          = 0 * time.Second\n24: \tLastActivityAnnotationKey = \"last-activity-time\"\n25: )\n26: \n27: type GCConfig struct {\n28: \tGCEnabled   bool          `json:\"gcEnabled\"`\n29: \tGCInterval  time.Duration `json:\"gcInterval\"`\n30: \tGCBatchSize int           `json:\"gcBatchSize\"`\n31: }\n32: \n33: func DefaultGCConfig() *GCConfig {\n34: \treturn &GCConfig{\n35: \t\tGCEnabled:   true,\n36: \t\tGCInterval:  DefaultGCInterval,\n37: \t\tGCBatchSize: DefaultGCBatchSize,\n38: \t}\n39: }\n40: \n41: type GCResult struct {\n42: \tScannedCount     int           `json:\"scannedCount\"`\n43: \tExpiredCount     int           `json:\"expiredCount\"`\n44: \tDeletedCount     int           `json:\"deletedCount\"`\n45: \tFailedCount      int           `json:\"failedCount\"`\n46: \tDuration         time.Duration `json:\"duration\"`\n47: \tErrors           []string      `json:\"errors,omitempty\"`\n48: \tCleanedResources []string      `json:\"cleanedResources,omitempty\"`\n49: }\n50: \n51: type GCStats struct {\n52: \tTotalCycles  int64     `json:\"totalCycles\"`\n53: \tTotalDeleted int64     `json:\"totalDeleted\"`\n54: \tTotalFailed  int64     `json:\"totalFailed\"`\n55: \tLastRunTime  time.Time `json:\"lastRunTime\"`\n56: \tLastResult   *GCResult `json:\"lastResult,omitempty\"`\n57: }\n58: \n59: type GCWorker struct {\n60: \tclient            versioned.Interface\n61: \tk8sClient         *kubernetes.Clientset\n62: \tconfig            *GCConfig\n63: \tstopCh            chan struct{}\n64: \tcleanupMgr        *CleanupManager\n65: \texpirationChecker *ExpirationChecker\n66: \tstats             GCStats\n67: \tstatsMu           sync.RWMutex\n68: \tisRunning         bool\n69: \trunningMu         sync.RWMutex\n70: }\n71: \n72: func NewGCWorker(client versioned.Interface, k8sClient *kubernetes.Clientset, config *GCConfig) *GCWorker {\n73: \tif config == nil {\n74: \t\tconfig = DefaultGCConfig()\n75: \t}\n76: \n77: \treturn &GCWorker{\n78: \t\tclient:            client,\n79: \t\tk8sClient:         k8sClient,\n80: \t\tconfig:            config,\n81: \t\tstopCh:            make(chan struct{}),\n82: \t\tcleanupMgr:        NewCleanupManager(k8sClient),\n83: \t\texpirationChecker: NewExpirationChecker(nil),\n84: \t}\n85: }\n86: \n87: func (g *GCWorker) Start(ctx context.Context) {\n88: \tif !g.config.GCEnabled {\n89: \t\tklog.InfoS(\"GC worker is disabled by configuration\")\n90: \t\treturn\n91: \t}\n92: \n93: \tg.setRunning(true)\n94: \tklog.InfoS(\"Starting GC worker\", \"interval\", g.config.GCInterval)\n95: \n96: \tticker := time.NewTicker(g.config.GCInterval)\n97: \tdefer ticker.Stop()\n98: \n99: \tfor {\n100: \t\tselect {\n101: \t\tcase <-ctx.Done():\n102: \t\t\tklog.InfoS(\"GC worker stopping due to context cancellation\")\n103: \t\t\tg.setRunning(false)\n104: \t\t\treturn\n105: \t\tcase <-g.stopCh:\n106: \t\t\tklog.InfoS(\"GC worker stopping\")\n107: \t\t\tg.setRunning(false)\n108: \t\t\treturn\n109: \t\tcase <-ticker.C:\n110: \t\t\tg.runGCCycle(ctx)\n111: \t\t}\n112: \t}\n113: }\n114: \n115: func (g *GCWorker) Stop() {\n116: \tclose(g.stopCh)\n117: \tg.setRunning(false)\n118: }\n119: \n120: func (g *GCWorker) IsRunning() bool {\n121: \tg.runningMu.RLock()\n122: \tdefer g.runningMu.RUnlock()\n123: \treturn g.isRunning\n124: }\n125: \n126: func (g *GCWorker) setRunning(running bool) {\n127: \tg.runningMu.Lock()\n128: \tdefer g.runningMu.Unlock()\n129: \tg.isRunning = running\n130: }\n131: \n132: func (g *GCWorker) GetConfig() *GCConfig {\n133: \treturn g.config\n134: }\n135: \n136: func (g *GCWorker) GetStats() GCStats {\n137: \tg.statsMu.RLock()\n138: \tdefer g.statsMu.RUnlock()\n139: \treturn g.stats\n140: }\n141: \n142: func (g *GCWorker) runGCCycle(ctx context.Context) {\n143: \tstartTime := time.Now()\n144: \tresult := &GCResult{}\n145: \n146: \tklog.V(4).InfoS(\"Starting GC cycle\")\n147: \n148: \tnamespaces, err := g.getNamespaces(ctx)\n149: \tif err != nil {\n150: \t\tklog.ErrorS(err, \"Failed to get namespaces\")\n151: \t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"failed to get namespaces: %v\", err))\n152: \t\tg.recordGCResult(result, startTime)\n153: \t\treturn\n154: \t}\n155: \n156: \tresult.ScannedCount = len(namespaces)\n157: \n158: \tfor _, ns := range namespaces {\n159: \t\tselect {\n160: \t\tcase <-ctx.Done():\n161: \t\t\tklog.InfoS(\"GC cycle cancelled\")\n162: \t\t\tbreak\n163: \t\tcase <-g.stopCh:\n164: \t\t\tklog.InfoS(\"GC cycle stopped\")\n165: \t\t\tbreak\n166: \t\tdefault:\n167: \t\t}\n168: \n169: \t\tif err := g.processNamespace(ctx, ns, result); err != nil {\n170: \t\t\tklog.ErrorS(err, \"Failed to process namespace\", \"namespace\", ns)\n171: \t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"%s: %v\", ns, err))\n172: \t\t}\n173: \n174: \t\tif result.ScannedCount >= g.config.GCBatchSize {\n175: \t\t\tklog.V(4).InfoS(\"Batch size reached\", \"scanned\", result.ScannedCount)\n176: \t\t\tbreak\n177: \t\t}\n178: \t}\n179: \n180: \tresult.Duration = time.Since(startTime)\n181: \tg.recordGCResult(result, startTime)\n182: \n183: \tklog.InfoS(\"GC cycle completed\",\n184: \t\t\"scanned\", result.ScannedCount,\n185: \t\t\"expired\", result.ExpiredCount,\n186: \t\t\"deleted\", result.DeletedCount,\n187: \t\t\"failed\", result.FailedCount,\n188: \t\t\"duration\", result.Duration)\n189: }\n190: \n191: func (g *GCWorker) getNamespaces(ctx context.Context) ([]string, error) {\n192: \tnsList, err := g.k8sClient.CoreV1().Namespaces().List(ctx, metav1.ListOptions{})\n193: \tif err != nil {\n194: \t\treturn nil, fmt.Errorf(\"failed to list namespaces: %w\", err)\n195: \t}\n196: \n197: \tnamespaces := make([]string, 0, len(nsList.Items))\n198: \tfor _, ns := range nsList.Items {\n199: \t\tnamespaces = append(namespaces, ns.Name)\n200: \t}\n201: \n202: \treturn namespaces, nil\n203: }\n204: \n205: func (g *GCWorker) processNamespace(ctx context.Context, namespace string, result *GCResult) error {\n206: \tarList, err := g.client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{})\n207: \tif err != nil {\n208: \t\treturn fmt.Errorf(\"failed to list agentruntimes: %w\", err)\n209: \t}\n210: \n211: \tciList, err := g.client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{})\n212: \tif err != nil {\n213: \t\treturn fmt.Errorf(\"failed to list codeinterpreters: %w\", err)\n214: \t}\n215: \n216: \tfor i := range arList.Items {\n217: \t\tar := &arList.Items[i]\n218: \t\tresult.ScannedCount++\n219: \n220: \t\tif g.isAgentRuntimeExpired(ar) {\n221: \t\t\tresult.ExpiredCount++\n222: \t\t\tcleaned, err := g.deleteAgentRuntime(ctx, namespace, ar.Name, ar)\n223: \t\t\tresult.CleanedResources = append(result.CleanedResources, cleaned...)\n224: \t\t\tif err != nil {\n225: \t\t\t\tresult.FailedCount++\n226: \t\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"agentruntime/%s: %v\", ar.Name, err))\n227: \t\t\t\tklog.ErrorS(err, \"Failed to delete expired agentruntime\", \"name\", ar.Name)\n228: \t\t\t} else {\n229: \t\t\t\tresult.DeletedCount++\n230: \t\t\t}\n231: \t\t}\n232: \n233: \t\tif result.ScannedCount >= g.config.GCBatchSize {\n234: \t\t\tbreak\n235: \t\t}\n236: \t}\n237: \n238: \tfor i := range ciList.Items {\n239: \t\tci := &ciList.Items[i]\n240: \t\tresult.ScannedCount++\n241: \n242: \t\tif g.isCodeInterpreterExpired(ci) {\n243: \t\t\tresult.ExpiredCount++\n244: \t\t\tcleaned, err := g.deleteCodeInterpreter(ctx, namespace, ci.Name, ci)\n245: \t\t\tresult.CleanedResources = append(result.CleanedResources, cleaned...)\n246: \t\t\tif err != nil {\n247: \t\t\t\tresult.FailedCount++\n248: \t\t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"codeinterpreter/%s: %v\", ci.Name, err))\n249: \t\t\t\tklog.ErrorS(err, \"Failed to delete expired codeinterpreter\", \"name\", ci.Name)\n250: \t\t\t} else {\n251: \t\t\t\tresult.DeletedCount++\n252: \t\t\t}\n253: \t\t}\n254: \n255: \t\tif result.ScannedCount >= g.config.GCBatchSize {\n256: \t\t\tbreak\n257: \t\t}\n258: \t}\n259: \n260: \treturn nil\n261: }\n262: \n263: func (g *GCWorker) isAgentRuntimeExpired(ar *agentcubev1alpha1.AgentRuntime) bool {\n264: \tif ar.DeletionTimestamp != nil {\n265: \t\treturn true\n266: \t}\n267: \n268: \tsandbox := &Sandbox{\n269: \t\tName:           ar.Name,\n270: \t\tNamespace:      ar.Namespace,\n271: \t\tSessionID:      ar.Labels[\"sessionId\"],\n272: \t\tState:          g.getAgentRuntimeState(ar),\n273: \t\tCreatedAt:      ar.CreationTimestamp.Time,\n274: \t\tLastActivityAt: g.getLastActivityTime(ar),\n275: \t\tLabels:         ar.Labels,\n276: \t\tAnnotations:    ar.Annotations,\n277: \t}\n278: \n279: \treturn isExpired(sandbox)\n280: }\n281: \n282: func (g *GCWorker) isCodeInterpreterExpired(ci *agentcubev1alpha1.CodeInterpreter) bool {\n283: \tif ci.DeletionTimestamp != nil {\n284: \t\treturn true\n285: \t}\n286: \n287: \tsandbox := &Sandbox{\n288: \t\tName:           ci.Name,\n289: \t\tNamespace:      ci.Namespace,\n290: \t\tSessionID:      ci.Labels[\"sessionId\"],\n291: \t\tState:          g.getCodeInterpreterState(ci),\n292: \t\tCreatedAt:      ci.CreationTimestamp.Time,\n293: \t\tLastActivityAt: g.getLastActivityTime(ci),\n294: \t\tLabels:         ci.Labels,\n295: \t\tAnnotations:    ci.Annotations,\n296: \t}\n297: \n298: \treturn isExpired(sandbox)\n299: }\n300: \n301: func (g *GCWorker) getAgentRuntimeState(ar *agentcubev1alpha1.AgentRuntime) SandboxState {\n302: \tstate := SandboxStateUnknown\n303: \tif len(ar.Status.Conditions) > 0 {\n304: \t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n305: \t\tif lastCondition.Status == \"True\" {\n306: \t\t\tif lastCondition.Reason == \"Running\" {\n307: \t\t\t\tstate = SandboxStateRunning\n308: \t\t\t} else if lastCondition.Reason == \"Failed\" {\n309: \t\t\t\tstate = SandboxStateFailed\n310: \t\t\t}\n311: \t\t}\n312: \t}\n313: \tif ar.DeletionTimestamp != nil {\n314: \t\tstate = SandboxStateDeleting\n315: \t}\n316: \treturn state\n317: }\n318: \n319: func (g *GCWorker) getCodeInterpreterState(ci *agentcubev1alpha1.CodeInterpreter) SandboxState {\n320: \tstate := SandboxStateUnknown\n321: \tif ci.Status.Ready {\n322: \t\tstate = SandboxStateRunning\n323: \t}\n324: \tif len(ci.Status.Conditions) > 0 {\n325: \t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n326: \t\tif lastCondition.Status == \"True\" {\n327: \t\t\tif lastCondition.Reason == \"Failed\" {\n328: \t\t\t\tstate = SandboxStateFailed\n329: \t\t\t}\n330: \t\t}\n331: \t}\n332: \tif ci.DeletionTimestamp != nil {\n333: \t\tstate = SandboxStateDeleting\n334: \t}\n335: \treturn state\n336: }\n337: \n338: func (g *GCWorker) getLastActivityTime(obj metav1.Object) *time.Time {\n339: \tannotations := obj.GetAnnotations()\n340: \tif annotations == nil {\n341: \t\treturn nil\n342: \t}\n343: \n344: \tlastActivityStr := annotations[\"last-activity-time\"]\n345: \tif lastActivityStr == \"\" {\n346: \t\treturn nil\n347: \t}\n348: \n349: \tt, err := time.Parse(time.RFC3339, lastActivityStr)\n350: \tif err != nil {\n351: \t\treturn nil\n352: \t}\n353: \n354: \treturn &t\n355: }\n356: \n357: func (g *GCWorker) deleteAgentRuntime(ctx context.Context, namespace, name string, ar *agentcubev1alpha1.AgentRuntime) ([]string, error) {\n358: \tcleaned := make([]string, 0)\n359: \n360: \townerRef := metav1.OwnerReference{\n361: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n362: \t\tKind:       \"AgentRuntime\",\n363: \t\tName:       ar.Name,\n364: \t\tUID:        ar.UID,\n365: \t}\n366: \n367: \tsvcCleaned, err := g.cleanupMgr.cleanupServices(namespace, ownerRef)\n368: \tif err != nil {\n369: \t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n370: \t}\n371: \tcleaned = append(cleaned, svcCleaned...)\n372: \n373: \tcmCleaned, err := g.cleanupMgr.cleanupConfigMaps(namespace, ownerRef)\n374: \tif err != nil {\n375: \t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n376: \t}\n377: \tcleaned = append(cleaned, cmCleaned...)\n378: \n379: \tpvcCleaned, err := g.cleanupMgr.cleanupPVCs(namespace, ownerRef)\n380: \tif err != nil {\n381: \t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n382: \t}\n383: \tcleaned = append(cleaned, pvcCleaned...)\n384: \n385: \tdeleteOpts := metav1.DeleteOptions{}\n386: \tstate := g.getAgentRuntimeState(ar)\n387: \tif state == SandboxStateUnknown || state == SandboxStateFailed {\n388: \t\tgracePeriodSeconds := int64(StaleGracePeriod.Seconds())\n389: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n390: \t\tklog.InfoS(\"Force deleting stale sandbox\", \"name\", name, \"namespace\", namespace)\n391: \t} else {\n392: \t\tgracePeriodSeconds := int64(DefaultGracePeriod.Seconds())\n393: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n394: \t}\n395: \n396: \terr = g.client.RuntimeV1alpha1().AgentRuntimes(namespace).Delete(ctx, name, deleteOpts)\n397: \tif err != nil {\n398: \t\tif apierrors.IsNotFound(err) {\n399: \t\t\tklog.V(4).InfoS(\"AgentRuntime already deleted\", \"name\", name, \"namespace\", namespace)\n400: \t\t\treturn cleaned, nil\n401: \t\t}\n402: \t\treturn cleaned, fmt.Errorf(\"failed to delete agentruntime: %w\", err)\n403: \t}\n404: \n405: \tklog.InfoS(\"Deleted expired agentruntime\", \"name\", name, \"namespace\", namespace,\n406: \t\t\"cleanedResources\", len(cleaned))\n407: \n408: \treturn cleaned, nil\n409: }\n410: \n411: func (g *GCWorker) deleteCodeInterpreter(ctx context.Context, namespace, name string, ci *agentcubev1alpha1.CodeInterpreter) ([]string, error) {\n412: \tcleaned := make([]string, 0)\n413: \n414: \townerRef := metav1.OwnerReference{\n415: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n416: \t\tKind:       \"CodeInterpreter\",\n417: \t\tName:       ci.Name,\n418: \t\tUID:        ci.UID,\n419: \t}\n420: \n421: \tsvcCleaned, err := g.cleanupMgr.cleanupServices(namespace, ownerRef)\n422: \tif err != nil {\n423: \t\tklog.V(2).InfoS(\"Error cleaning services\", \"error\", err)\n424: \t}\n425: \tcleaned = append(cleaned, svcCleaned...)\n426: \n427: \tcmCleaned, err := g.cleanupMgr.cleanupConfigMaps(namespace, ownerRef)\n428: \tif err != nil {\n429: \t\tklog.V(2).InfoS(\"Error cleaning configmaps\", \"error\", err)\n430: \t}\n431: \tcleaned = append(cleaned, cmCleaned...)\n432: \n433: \tpvcCleaned, err := g.cleanupMgr.cleanupPVCs(namespace, ownerRef)\n434: \tif err != nil {\n435: \t\tklog.V(2).InfoS(\"Error cleaning pvcs\", \"error\", err)\n436: \t}\n437: \tcleaned = append(cleaned, pvcCleaned...)\n438: \n439: \tdeleteOpts := metav1.DeleteOptions{}\n440: \tstate := g.getCodeInterpreterState(ci)\n441: \tif state == SandboxStateUnknown || state == SandboxStateFailed {\n442: \t\tgracePeriodSeconds := int64(StaleGracePeriod.Seconds())\n443: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n444: \t\tklog.InfoS(\"Force deleting stale sandbox\", \"name\", name, \"namespace\", namespace)\n445: \t} else {\n446: \t\tgracePeriodSeconds := int64(DefaultGracePeriod.Seconds())\n447: \t\tdeleteOpts.GracePeriodSeconds = &gracePeriodSeconds\n448: \t}\n449: \n450: \terr = g.client.RuntimeV1alpha1().CodeInterpreters(namespace).Delete(ctx, name, deleteOpts)\n451: \tif err != nil {\n452: \t\tif apierrors.IsNotFound(err) {\n453: \t\t\tklog.V(4).InfoS(\"CodeInterpreter already deleted\", \"name\", name, \"namespace\", namespace)\n454: \t\t\treturn cleaned, nil\n455: \t\t}\n456: \t\treturn cleaned, fmt.Errorf(\"failed to delete codeinterpreter: %w\", err)\n457: \t}\n458: \n459: \tklog.InfoS(\"Deleted expired codeinterpreter\", \"name\", name, \"namespace\", namespace,\n460: \t\t\"cleanedResources\", len(cleaned))\n461: \n462: \treturn cleaned, nil\n463: }\n464: \n465: func (g *GCWorker) recordGCResult(result *GCResult, startTime time.Time) {\n466: \tg.statsMu.Lock()\n467: \tdefer g.statsMu.Unlock()\n468: \n469: \tg.stats.TotalCycles++\n470: \tg.stats.TotalDeleted += int64(result.DeletedCount)\n471: \tg.stats.TotalFailed += int64(result.FailedCount)\n472: \tg.stats.LastRunTime = startTime\n473: \tg.stats.LastResult = result\n474: }\n475: \n476: func (g *GCWorker) TriggerGCCycle(ctx context.Context) *GCResult {\n477: \tresult := &GCResult{}\n478: \n479: \tklog.InfoS(\"Manually triggering GC cycle\")\n480: \n481: \tnamespaces, err := g.getNamespaces(ctx)\n482: \tif err != nil {\n483: \t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"failed to get namespaces: %v\", err))\n484: \t\treturn result\n485: \t}\n486: \n487: \tresult.ScannedCount = len(namespaces)\n488: \tstartTime := time.Now()\n489: \n490: \tfor _, ns := range namespaces {\n491: \t\tif err := g.processNamespace(ctx, ns, result); err != nil {\n492: \t\t\tresult.Errors = append(result.Errors, fmt.Sprintf(\"%s: %v\", ns, err))\n493: \t\t}\n494: \t}\n495: \n496: \tresult.Duration = time.Since(startTime)\n497: \tg.recordGCResult(result, startTime)\n498: \n499: \tklog.InfoS(\"Manual GC cycle completed\",\n500: \t\t\"scanned\", result.ScannedCount,\n501: \t\t\"expired\", result.ExpiredCount,\n502: \t\t\"deleted\", result.DeletedCount,\n503: \t\t\"failed\", result.FailedCount)\n504: \n505: \treturn result\n506: }\n507: \n508: func (g *GCWorker) UpdateConfig(config *GCConfig) {\n509: \tif config == nil {\n510: \t\treturn\n511: \t}\n512: \n513: \tg.config.GCEnabled = config.GCEnabled\n514: \tif config.GCInterval > 0 {\n515: \t\tg.config.GCInterval = config.GCInterval\n516: \t}\n517: \tif config.GCBatchSize > 0 {\n518: \t\tg.config.GCBatchSize = config.GCBatchSize\n519: \t}\n520: \n521: \tklog.InfoS(\"GC config updated\", \"gcEnabled\", g.config.GCEnabled,\n522: \t\t\"gcInterval\", g.config.GCInterval, \"gcBatchSize\", g.config.GCBatchSize)\n523: }\n524: \n525: type GCHandler struct {\n526: \tworker *GCWorker\n527: }\n528: \n529: func NewGCHandler(worker *GCWorker) *GCHandler {\n530: \treturn &GCHandler{\n531: \t\tworker: worker,\n532: \t}\n533: }\n534: \n535: func (h *GCHandler) TriggerGC() map[string]interface{} {\n536: \tresult := h.worker.TriggerGCCycle(context.Background())\n537: \treturn map[string]interface{}{\n538: \t\t\"started\":      true,\n539: \t\t\"scannedCount\": result.ScannedCount,\n540: \t\t\"expiredCount\": result.ExpiredCount,\n541: \t\t\"deletedCount\": result.DeletedCount,\n542: \t\t\"failedCount\":  result.FailedCount,\n543: \t\t\"duration\":     result.Duration.String(),\n544: \t\t\"message\":      \"GC cycle triggered\",\n545: \t}\n546: }\n547: \n548: func (h *GCHandler) GetStatus() map[string]interface{} {\n549: \tstats := h.worker.GetStats()\n550: \tconfig := h.worker.GetConfig()\n551: \n552: \treturn map[string]interface{}{\n553: \t\t\"running\":      h.worker.IsRunning(),\n554: \t\t\"gcEnabled\":    config.GCEnabled,\n555: \t\t\"gcInterval\":   config.GCInterval.String(),\n556: \t\t\"gcBatchSize\":  config.GCBatchSize,\n557: \t\t\"totalCycles\":  stats.TotalCycles,\n558: \t\t\"totalDeleted\": stats.TotalDeleted,\n559: \t\t\"totalFailed\":  stats.TotalFailed,\n560: \t\t\"lastRunTime\":  stats.LastRunTime.Format(time.RFC3339),\n561: \t}\n562: }\n563: \n564: func (h *GCHandler) UpdateConfig(config *GCConfig) map[string]interface{} {\n565: \th.worker.UpdateConfig(config)\n566: \treturn map[string]interface{}{\n567: \t\t\"message\": \"GC configuration updated\",\n568: \t}\n569: }\n570: \n571: func ListExpiredSandboxes(ctx context.Context, client versioned.Interface, namespace string) ([]*Sandbox, error) {\n572: \texpired := make([]*Sandbox, 0)\n573: \n574: \tarList, err := client.RuntimeV1alpha1().AgentRuntimes(namespace).List(ctx, metav1.ListOptions{\n575: \t\tLabelSelector: labels.Everything().String(),\n576: \t})\n577: \tif err != nil {\n578: \t\treturn nil, fmt.Errorf(\"failed to list agentruntimes: %w\", err)\n579: \t}\n580: \n581: \tfor i := range arList.Items {\n582: \t\tar := &arList.Items[i]\n583: \t\tsandbox := &Sandbox{\n584: \t\t\tName:           ar.Name,\n585: \t\t\tNamespace:      ar.Namespace,\n586: \t\t\tSessionID:      ar.Labels[\"sessionId\"],\n587: \t\t\tState:          getAgentRuntimeState(ar),\n588: \t\t\tCreatedAt:      ar.CreationTimestamp.Time,\n589: \t\t\tLastActivityAt: getLastActivityTimeFromAnnotations(ar.Annotations),\n590: \t\t\tLabels:         ar.Labels,\n591: \t\t\tAnnotations:    ar.Annotations,\n592: \t\t}\n593: \t\tif isExpired(sandbox) {\n594: \t\t\texpired = append(expired, sandbox)\n595: \t\t}\n596: \t}\n597: \n598: \tciList, err := client.RuntimeV1alpha1().CodeInterpreters(namespace).List(ctx, metav1.ListOptions{\n599: \t\tLabelSelector: labels.Everything().String(),\n600: \t})\n601: \tif err != nil {\n602: \t\treturn nil, fmt.Errorf(\"failed to list codeinterpreters: %w\", err)\n603: \t}\n604: \n605: \tfor i := range ciList.Items {\n606: \t\tci := &ciList.Items[i]\n607: \t\tsandbox := &Sandbox{\n608: \t\t\tName:           ci.Name,\n609: \t\t\tNamespace:      ci.Namespace,\n610: \t\t\tSessionID:      ci.Labels[\"sessionId\"],\n611: \t\t\tState:          getCodeInterpreterState(ci),\n612: \t\t\tCreatedAt:      ci.CreationTimestamp.Time,\n613: \t\t\tLastActivityAt: getLastActivityTimeFromAnnotations(ci.Annotations),\n614: \t\t\tLabels:         ci.Labels,\n615: \t\t\tAnnotations:    ci.Annotations,\n616: \t\t}\n617: \t\tif isExpired(sandbox) {\n618: \t\t\texpired = append(expired, sandbox)\n619: \t\t}\n620: \t}\n621: \n622: \treturn expired, nil\n623: }\n624: \n625: func getAgentRuntimeState(ar *agentcubev1alpha1.AgentRuntime) SandboxState {\n626: \tstate := SandboxStateUnknown\n627: \tif len(ar.Status.Conditions) > 0 {\n628: \t\tlastCondition := ar.Status.Conditions[len(ar.Status.Conditions)-1]\n629: \t\tif lastCondition.Status == \"True\" {\n630: \t\t\tif lastCondition.Reason == \"Running\" {\n631: \t\t\t\tstate = SandboxStateRunning\n632: \t\t\t} else if lastCondition.Reason == \"Failed\" {\n633: \t\t\t\tstate = SandboxStateFailed\n634: \t\t\t}\n635: \t\t}\n636: \t}\n637: \tif ar.DeletionTimestamp != nil {\n638: \t\tstate = SandboxStateDeleting\n639: \t}\n640: \treturn state\n641: }\n642: \n643: func getCodeInterpreterState(ci *agentcubev1alpha1.CodeInterpreter) SandboxState {\n644: \tstate := SandboxStateUnknown\n645: \tif ci.Status.Ready {\n646: \t\tstate = SandboxStateRunning\n647: \t}\n648: \tif len(ci.Status.Conditions) > 0 {\n649: \t\tlastCondition := ci.Status.Conditions[len(ci.Status.Conditions)-1]\n650: \t\tif lastCondition.Status == \"True\" {\n651: \t\t\tif lastCondition.Reason == \"Failed\" {\n652: \t\t\t\tstate = SandboxStateFailed\n653: \t\t\t}\n654: \t\t}\n655: \t}\n656: \tif ci.DeletionTimestamp != nil {\n657: \t\tstate = SandboxStateDeleting\n658: \t}\n659: \treturn state\n660: }\n661: \n662: func getLastActivityTimeFromAnnotations(annotations map[string]string) *time.Time {\n663: \tif annotations == nil {\n664: \t\treturn nil\n665: \t}\n666: \n667: \tlastActivityStr := annotations[\"last-activity-time\"]\n668: \tif lastActivityStr == \"\" {\n669: \t\treturn nil\n670: \t}\n671: \n672: \tt, err := time.Parse(time.RFC3339, lastActivityStr)\n673: \tif err != nil {\n674: \t\treturn nil\n675: \t}\n676: \n677: \treturn &t\n678: }\n\n(End of file - total 678 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\tversioned \"github.com/volcano-sh/agentcube/pkg/client/clientset/versioned\"\n)\n\nconst (\n\tDefaultGCInterval         = 5 * time.Minute","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/workloadmanager/gc.go","time":{"start":1775881216883,"end":1775881216897}}}}
