ics := NewMetrics()\n43: \n44: \tvar sessionManager *SessionManager\n45: \tvar sessionHandler *SessionHandler\n46: \tif config.SessionEnabled {\n47: \t\tsessionManager = NewSessionManager(config)\n48: \t\tsessionHandler = NewSessionHandler(sessionManager)\n49: \t}\n50: \n51: \tvar jwtManager *JWTManager\n52: \tvar jwtMiddleware *JWTMiddleware\n53: \tif config.JWTEnabled {\n54: \t\tjwtConfig := &JWTConfig{\n55: \t\t\tAlgorithm:         config.JWTAlgorithm,\n56: \t\t\tSecret:            config.JWTSecret,\n57: \t\t\tPrivateKeyPath:    config.JWTPrivateKeyPath,\n58: \t\t\tPublicKeyPath:     config.JWTPublicKeyPath,\n59: \t\t\tIssuer:            config.JWTIssuer,\n60: \t\t\tAudience:          config.JWTAudience,\n61: \t\t\tExpiration:        config.JWTExpiration,\n62: \t\t\tRefreshExpiration: config.JWTRefreshExpiration,\n63: \t\t\tClockSkew:         config.JWTClockSkew,\n64: \t\t\tAllowQueryParam:   config.JWTAllowQueryParam,\n65: \t\t}\n66: \t\tjwtManager, _ = NewJWTManager(jwtConfig, nil)\n67: \t\tjwtMiddleware = NewJWTMiddleware(jwtManager, nil, config.JWTAllowQueryParam)\n68: \t}\n69: \n70: \trouter := &Router{\n71: \t\tconfig:         config,\n72: \t\tpool:           pool,\n73: \t\tproxy:          proxy,\n74: \t\trouteHandler:   routeHandler,\n75: \t\thealthChecker:  healthChecker,\n76: \t\trateLimiter:    rateLimiter,\n77: \t\tauthenticator:  authenticator,\n78: \t\tlogger:         logger,\n79: \t\tmetrics:        metrics,\n80: \t\tsessionManager: sessionManager,\n81: \t\tsessionHandler: sessionHandler,\n82: \t\tjwtManager:     jwtManager,\n83: \t\tjwtMiddleware:  jwtMiddleware,\n84: \t}\n85: \n86: \tmux := http.NewServeMux()\n87: \tmux.HandleFunc(\"/\", router.handleRequest)\n88: \n89: \tif sessionHandler != nil {\n90: \t\tmux.Handle(\"/v1/sessions\", sessionHandler)\n91: \t}\n92: \n93: \tif jwtManager != nil {\n94: \t\tmux.HandleFunc(\"/login\", HandleLogin(jwtManager))\n95: \t\tmux.HandleFunc(\"/refresh\", HandleRefresh(jwtManager))\n96: \t}\n97: \n98: \thandler := logger.Middleware(mux)\n99: \thandler = rateLimiter.Middleware(handler)\n100: \thandler = authenticator.Middleware(handler)\n101: \n102: \tif sessionManager != nil {\n103: \t\thandler = sessionManager.Middleware(handler)\n104: \t}\n105: \n106: \tif jwtMiddleware != nil {\n107: \t\thandler = jwtMiddleware.Middleware(handler)\n108: \t}\n109: \n110: \trouter.server = &http.Server{\n111: \t\tAddr:         config.ListenAddress,\n112: \t\tHandler:      handler,\n113: \t\tReadTimeout:  config.BackendTimeout,\n114: \t\tWriteTimeout: config.BackendTimeout,\n115: \t\tIdleTimeout:  config.IdleTimeout,\n116: \t}\n117: \n118: \treturn router\n119: }\n120: \n121: func (r *Router) Start() error {\n122: \tgo func() {\n123: \t\tfmt.Printf(\"Starting router on %s\\n\", r.config.ListenAddress)\n124: \t\tif err := r.server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n125: \t\t\tfmt.Printf(\"Server error: %v\\n\", err)\n126: \t\t}\n127: \t}()\n128: \n129: \tr.healthChecker.Start()\n130: \n131: \tif r.sessionManager != nil {\n132: \t\tr.sessionManager.StartCleanup()\n133: \t}\n134: \n135: \treturn nil\n136: }\n137: \n138: func (r *Router) Shutdown(ctx context.Context) error {\n139: \tr.healthChecker.Stop()\n140: \n141: \tif r.sessionManager != nil {\n142: \t\tr.sessionManager.StopCleanup()\n143: \t}\n144: \n145: \tfmt.Println(\"Shutting down router...\")\n146: \treturn r.server.Shutdown(ctx)\n147: }\n148: \n149: func (r *Router) handleRequest(w http.ResponseWriter, req *http.Request) {\n150: \tstart := time.Now()\n151: \n152: \tvar backend *Backend\n153: \n154: \tif r.sessionManager != nil {\n155: \t\tsessionBackendKey := req.Header.Get(\"X-Session-Backend\")\n156: \t\tif sessionBackendKey != \"\" {\n157: \t\t\tbackend = r.pool.GetBackendByPath(sessionBackendKey)\n158: \t\t}\n159: \t}\n160: \n161: \tif backend == nil {\n162: \t\tbackend = r.routeHandler.GetBackendForRequest(req)\n163: \t}\n164: \n165: \tif backend == nil {\n166: \t\tr.metrics.IncErrors(\"not_found\")\n167: \t\tw.WriteHeader(http.StatusNotFound)\n168: \t\treturn\n169: \t}\n170: \n171: \tr.proxy.ServeHTTP(w, req, backend)\n172: \n173: \tduration := time.Since(start).Seconds()\n174: \tr.metrics.RecordRequestDuration(req.Method, req.URL.Path, backend.Name, duration)\n175: \tr.metrics.IncBackendRequests(backend.Name, \"success\")\n176: }\n177: \n178: func (r *Router) GetPool() *BackendPool {\n179: \treturn r.pool\n180: }\n181: \n182: func (r *Router) GetConfig() *Config {\n183: \treturn r.config\n184: }\n185: \n186: func (r *Router) GetHealthChecker() *HealthChecker {\n187: \treturn r.healthChecker\n188: }\n189: \n190: func (r *Router) GetMetrics() *Metrics {\n191: \treturn r.metrics\n192: }\n193: \n194: func (r *Router) AddBackend(key, endpoint, pathPrefix, name string) error {\n195: \treturn r.pool.AddBackend(key, endpoint, pathPrefix, name)\n196: }\n197: \n198: func (r *Router) RemoveBackend(key string) {\n199: \tr.pool.RemoveBackend(key)\n200: }\n201: \n202: func (r *Router) SetHeaderRoute(headerName, headerValue, backendKey string) {\n203: \tr.pool.SetHeaderRoute(headerName, headerValue, backendKey)\n204: }\n205: \n206: func (r *Router) GetSessionManager() *SessionManager {\n207: \treturn r.sessionManager\n208: }\n209: \n210: func (r *Router) GetJWTManager() *JWTManager {\n211: \treturn r.jwtManager\n212: }\n213: \n214: func RunWithSignal(cfg *Config) error {\n215: \trouter := NewRouter(cfg)\n216: \n217: \tif err := router.Start(); err != nil {\n218: \t\treturn err\n219: \t}\n220: \n221: \tsigCh := make(chan os.Signal, 1)\n222: \tsignal.Notify(sigCh, syscall.SIGINT, syscall.SIGTERM)\n223: \n224: \t<-sigCh\n225: \tfmt.Println(\"\\nReceived shutdown signal\")\n226: \n227: \tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n228: \tdefer cancel()\n229: \n230: \treturn router.Shutdown(ctx)\n231: }\n\n(End of file - total 231 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\t\"time\"\n)\n\ntype Router struct {\n\tconfig         *Config\n\tserver         *http.Server\n\tpool           *BackendPool\n\tproxy          *Proxy\n\trouteHandler   *RouteHandler\n\thealthChecker  *HealthChecker\n\trateLimiter    *RateLimiter","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/router/server.go","time":{"start":1775882438988,"end":1775882439012}}}}
{"type":"tool_use","timestamp":1775882439016,"sessionID":"ses_28528da7fffeeEo22z8KG7QLjm","part":{"id":"prt_d7ad78067001tRwYvD5tSHoTBB","messageID":"msg_d7ad76a53001CRrUmsbVtSd5aF","sessionID":"ses_28528da7fffeeEo22z8KG7QLjm","type":"tool","tool":"read","callID":"toolu_0fb47228a1c64bfdbfeda0cb","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_valkey.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_valkey.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"errors\"\n7: \t\"fmt\"\n8: \t\"os\"\n9: \t\"strings\"\n10: \t\"time\"\n11: \n12: \t\"github.com/valkey-io/valkey-go\"\n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: \t\"k8s.io/klog/v2\"\n15: )\n16: \n17: type valkeyStore struct {\n18: \tcli                  valkey.Client\n19: \tsessionPrefix        string\n20: \texpiryIndexKey       string\n21: \tlastActivityIndexKey string\n22: }\n23: \n24: func newValkeyStore() (Store, error) {\n25: \topts, err := makeValkeyOptions()\n26: \tif err != nil {\n27: \t\treturn nil, err\n28: \t}\n29: \n30: \tcli, err := valkey.NewClient(*opts)\n31: \tif err != nil {\n32: \t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n33: \t}\n34: \n35: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n36: \tdefer cancel()\n37: \n38: \tresult := cli.B().Ping().Build()\n39: \tresp := cli.Do(ctx, result)\n40: \tpong, err := resp.ToString()\n41: \tif err != nil {\n42: \t\treturn nil, fmt.Errorf(\"failed to ping valkey: %w\", err)\n43: \t}\n44: \tif pong != \"PONG\" {\n45: \t\treturn nil, fmt.Errorf(\"unexpected ping response: %s\", pong)\n46: \t}\n47: \n48: \treturn &valkeyStore{\n49: \t\tcli:                  cli,\n50: \t\tsessionPrefix:        sessionKeyPrefix,\n51: \t\texpiryIndexKey:       sessionExpiryIndexKey,\n52: \t\tlastActivityIndexKey: sessionLastActivityKey,\n53: \t}, nil\n54: }\n55: \n56: func makeValkeyOptions() (*valkey.ClientOption, error) {\n57: \tvalkeyAddr := os.Getenv(\"VALKEY_ADDR\")\n58: \tif valkeyAddr == \"\" {\n59: \t\treturn nil, errors.New(\"VALKEY_ADDR is required\")\n60: \t}\n61: \n62: \tvalkeyPasswordRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n63: \tvalkeyPassword := os.Getenv(\"VALKEY_PASSWORD\")\n64: \n65: \tpasswordRequired := true\n66: \tif strings.EqualFold(valkeyPasswordRequired, \"false\") {\n67: \t\tpasswordRequired = false\n68: \t}\n69: \n70: \tif passwordRequired && valkeyPassword == \"\" {\n71: \t\treturn nil, errors.New(\"VALKEY_PASSWORD is required\")\n72: \t}\n73: \n74: \topts := valkey.ClientOption{\n75: \t\tInitAddress: strings.Split(valkeyAddr, \",\"),\n76: \t\tPassword:    valkeyPassword,\n77: \t}\n78: \n79: \tif disableCache, _ := os.LookupEnv(\"VALKEY_DISABLE_CACHE\"); strings.EqualFold(disableCache, \"true\") {\n80: \t\topts.DisableCache = true\n81: \t\tklog.Info(\"Valkey DisableCache is enabled\")\n82: \t}\n83: \n84: \tif forceSingle, _ := os.LookupEnv(\"VALKEY_FORCE_SINGLE\"); strings.EqualFold(forceSingle, \"true\") {\n85: \t\topts.ForceSingleClient = true\n86: \t\tklog.Info(\"Valkey ForceSingleClient is enabled\")\n87: \t}\n88: \n89: \treturn &opts, nil\n90: }\n91: \n92: func (vs *valkeyStore) Ping(ctx context.Context) error {\n93: \tresult := vs.cli.B().Ping().Build()\n94: \tresp := vs.cli.Do(ctx, result)\n95: \tpong, err := resp.ToString()\n96: \tif err != nil {\n97: \t\treturn err\n98: \t}\n99: \tif pong != \"PONG\" {\n100: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n101: \t}\n102: \treturn nil\n103: }\n104: \n105: func (vs *valkeyStore) sessionKey(sessionID string) string {\n106: \treturn vs.sessionPrefix + sessionID\n107: }\n108: \n109: func (vs *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n110: \tkey := vs.sessionKey(sessionID)\n111: \tresult := vs.cli.B().Get().Key(key).Build()\n112: \tresp := vs.cli.Do(ctx, result)\n113: \n114: \tif valkey.IsValkeyNil(resp.Error()) {\n115: \t\treturn nil, ErrNotFound\n116: \t}\n117: \tif resp.Error() != nil {\n118: \t\treturn nil, resp.Error()\n119: \t}\n120: \n121: \tdata, err := resp.ToString()\n122: \tif err != nil {\n123: \t\treturn nil, err\n124: \t}\n125: \n126: \tvar sandbox types.SandboxInfo\n127: \tif err := json.Unmarshal([]byte(data), &sandbox); err != nil {\n128: \t\treturn nil, err\n129: \t}\n130: \n131: \treturn &sandbox, nil\n132: }\n133: \n134: func (vs *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n135: \tif sandboxStore == nil {\n136: \t\treturn errors.New(\"sandbox is nil\")\n137: \t}\n138: \tif sandboxStore.ExpiresAt.IsZero() {\n139: \t\treturn errors.New(\"invalid expiry: ExpiresAt is zero\")\n140: \t}\n141: \tif sandboxStore.SessionID == \"\" {\n142: \t\treturn errors.New(\"session ID is required\")\n143: \t}\n144: \n145: \tkey := vs.sessionKey(sandboxStore.SessionID)\n146: \tdata, err := json.Marshal(sandboxStore)\n147: \tif err != nil {\n148: \t\treturn err\n149: \t}\n150: \n151: \tnow := time.Now().Unix()\n152: \texpiryScore := float64(sandboxStore.ExpiresAt.Unix())\n153: \tlastActivityScore := float64(now)\n154: \n155: \tcmds := []valkey.Completed{\n156: \t\tvs.cli.B().Setnx().Key(key).Value(string(data)).Build(),\n157: \t\tvs.cli.B().Zadd().Key(vs.expiryIndexKey).ZaddScoreMember(valkey.ZaddScoreMember{Score: expiryScore, Member: sandboxStore.SessionID}).Build(),\n158: \t\tvs.cli.B().Zadd().Key(vs.lastActivityIndexKey).ZaddScoreMember(valkey.ZaddScoreMember{Score: lastActivityScore, Member: sandboxStore.SessionID}).Build(),\n159: \t}\n160: \tresults := vs.cli.DoMulti(ctx, cmds...)\n161: \tfor _, r := range results {\n162: \t\tif err := r.Error(); err != nil {\n163: \t\t\treturn err\n164: \t\t}\n165: \t}\n166: \n167: \treturn nil\n168: }\n169: \n170: func (vs *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n171: \tif sandboxStore == nil {\n172: \t\treturn errors.New(\"sandbox is nil\")\n173: \t}\n174: \tif sandboxStore.SessionID == \"\" {\n175: \t\treturn errors.New(\"session ID is required\")\n176: \t}\n177: \n178: \tkey := vs.sessionKey(sandboxStore.SessionID)\n179: \tdata, err := json.Marshal(sandboxStore)\n180: \tif err != nil {\n181: \t\treturn err\n182: \t}\n183: \n184: \tresult := vs.cli.B().Set().Key(key).Value(string(data)).Xx().Build()\n185: \tresp := vs.cli.Do(ctx, result)\n186: \n187: \tif valkey.IsValkeyNil(resp.Error()) {\n188: \t\treturn errors.New(\"key not exists\")\n189: \t}\n190: \tif resp.Error() != nil {\n191: \t\treturn resp.Error()\n192: \t}\n193: \n194: \tok, err := resp.ToString()\n195: \tif err != nil {\n196: \t\treturn err\n197: \t}\n198: \tif ok != \"OK\" {\n199: \t\treturn errors.New(\"key not exists\")\n200: \t}\n201: \n202: \treturn nil\n203: }\n204: \n205: func (vs *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n206: \tkey := vs.sessionKey(sessionID)\n207: \n208: \tcmds := []valkey.Completed{\n209: \t\tvs.cli.B().Del().Key(key).Build(),\n210: \t\tvs.cli.B().Zrem().Key(vs.expiryIndexKey).Member(sessionID).Build(),\n211: \t\tvs.cli.B().Zrem().Key(vs.lastActivityIndexKey).Member(sessionID).Build(),\n212: \t}\n213: \tresults := vs.cli.DoMulti(ctx, cmds...)\n214: \tfor _, r := range results {\n215: \t\tif err := r.Error(); err != nil {\n216: \t\t\treturn err\n217: \t\t}\n218: \t}\n219: \n220: \treturn nil\n221: }\n222: \n223: func (vs *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n224: \tif limit <= 0 {\n225: \t\treturn nil, nil\n226: \t}\n227: \n228: \tresult := vs.cli.B().\n229: \t\tZrangebyscore().\n230: \t\tKey(vs.expiryIndexKey).\n231: \t\tMin(\"-inf\").\n232: \t\tMax(fmt.Sprintf(\"%d\", before.Unix())).\n233: \t\tLimit(0, limit).\n234: \t\tBuild()\n235: \tresp := vs.cli.Do(ctx, result)\n236: \tif resp.Error() != nil {\n237: \t\treturn nil, resp.Error()\n238: \t}\n239: \n240: \tsessionIDs, err := resp.AsStrSlice()\n241: \tif err != nil {\n242: \t\treturn nil, err\n243: \t}\n244: \n245: \treturn vs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n246: }\n247: \n248: func (vs *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n249: \tif limit <= 0 {\n250: \t\treturn nil, nil\n251: \t}\n252: \n253: \tresult := vs.cli.B().\n254: \t\tZrangebyscore().\n255: \t\tKey(vs.lastActivityIndexKey).\n256: \t\tMin(\"-inf\").\n257: \t\tMax(fmt.Sprintf(\"%d\", before.Unix())).\n258: \t\tLimit(0, limit).\n259: \t\tBuild()\n260: \tresp := vs.cli.Do(ctx, result)\n261: \tif resp.Error() != nil {\n262: \t\treturn nil, resp.Error()\n263: \t}\n264: \n265: \tsessionIDs, err := resp.AsStrSlice()\n266: \tif err != nil {\n267: \t\treturn nil, err\n268: \t}\n269: \n270: \treturn vs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n271: }\n272: \n273: func (vs *valkeyStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n274: \tif len(sessionIDs) == 0 {\n275: \t\treturn nil, nil\n276: \t}\n277: \n278: \tkeys := make([]string, len(sessionIDs))\n279: \tfor i, sid := range sessionIDs {\n280: \t\tkeys[i] = vs.sessionKey(sid)\n281: \t}\n282: \n283: \tresult := vs.cli.B().Mget().Key(keys...).Build()\n284: \tresp := vs.cli.Do(ctx, result)\n285: \tif resp.Error() != nil {\n286: \t\treturn nil, resp.Error()\n287: \t}\n288: \n289: \tsliceResp, err := resp.ToArray()\n290: \tif err != nil {\n291: \t\treturn nil, err\n292: \t}\n293: \n294: \tvar sandboxes []*types.SandboxInfo\n295: \tfor i, item := range sliceResp {\n296: \t\tif item.IsNil() {\n297: \t\t\tcontinue\n298: \t\t}\n299: \n300: \t\tstr, err := item.ToString()\n301: \t\tif err != nil || str == \"\" {\n302: \t\t\tcontinue\n303: \t\t}\n304: \n305: \t\tvar sandbox types.SandboxInfo\n306: \t\tif err := json.Unmarshal([]byte(str), &sandbox); err != nil {\n307: \t\t\tklog.V(4).Infof(\"failed to unmarshal sandbox %s: %v\", sessionIDs[i], err)\n308: \t\t\tcontinue\n309: \t\t}\n310: \t\tsandboxes = append(sandboxes, &sandbox)\n311: \t}\n312: \n313: \treturn sandboxes, nil\n314: }\n315: \n316: func (vs *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n317: \tif sessionID == \"\" {\n318: \t\treturn errors.New(\"session ID is required\")\n319: \t}\n320: \n321: \tkey := vs.sessionKey(sessionID)\n322: \texistsResult := vs.cli.B().Exists().Key(key).Build()\n323: \texistsResp := vs.cli.Do(ctx, existsResult)\n324: \tif existsResp.Error() != nil {\n325: \t\treturn existsResp.Error()\n326: \t}\n327: \texists, _ := existsResp.AsInt64()\n328: \tif exists != 1 {\n329: \t\treturn ErrNotFound\n330: \t}\n331: \n332: \ttimestamp := at\n333: \tif timestamp.IsZero() {\n334: \t\ttimestamp = time.Now()\n335: \t}\n336: \n337: \tscore := float64(timestamp.Unix())\n338: \tupdateResult := vs.cli.B().Zadd().Key(vs.lastActivityIndexKey).Score(score).Member(sessionID).Build()\n339: \tupdateResp := vs.cli.Do(ctx, updateResult)\n340: \tif updateResp.Error() != nil {\n341: \t\treturn updateResp.Error()\n342: \t}\n343: \n344: \treturn nil\n345: }\n346: \n347: func (vs *valkeyStore) Close() error {\n348: \treturn vs.cli.Close()\n349: }\n\n(End of file - total 349 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-MiniMax-M2.5_20260410T163134Z/pkg/store/store_valkey.go","time":{"start":1775882438993,"end":1775882439014}}}}
