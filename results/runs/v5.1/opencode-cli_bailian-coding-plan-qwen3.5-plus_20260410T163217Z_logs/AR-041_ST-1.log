{"type":"tool_use","timestamp":1775891157188,"sessionID":"ses_284a3f4d3ffe8bFOTfB7U7JhyS","part":{"id":"prt_d7b5c7f7f001kMmhROtCTrxNr8","messageID":"msg_d7b5c75a2001cHObiCS8CLfYnm","sessionID":"ses_284a3f4d3ffe8bFOTfB7U7JhyS","type":"tool","tool":"read","callID":"toolu_62b735ae51464f0eaaa7119b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go</path>\n<type>file</type>\n<content>\n1: // Copyright 2026 AgentCube Authors\n2: // E2E tests for AgentCube\n3: \n4: package e2e\n5: \n6: import (\n7: \t\"bytes\"\n8: \t\"encoding/json\"\n9: \t\"fmt\"\n10: \t\"io\"\n11: \t\"net/http\"\n12: \t\"os\"\n13: \t\"testing\"\n14: \t\"time\"\n15: )\n16: \n17: var (\n18: \tworkloadManagerURL string\n19: \trouterURL          string\n20: \tapiToken           string\n21: \tclient             *http.Client\n22: )\n23: \n24: func TestMain(m *testing.M) {\n25: \tworkloadManagerURL = os.Getenv(\"WORKLOAD_MANAGER_URL\")\n26: \trouterURL = os.Getenv(\"ROUTER_URL\")\n27: \tapiToken = os.Getenv(\"API_TOKEN\")\n28: \n29: \tif workloadManagerURL == \"\" {\n30: \t\tworkloadManagerURL = \"http://localhost:8080\"\n31: \t}\n32: \tif routerURL == \"\" {\n33: \t\trouterURL = \"http://localhost:8081\"\n34: \t}\n35: \tif apiToken == \"\" {\n36: \t\tfmt.Println(\"Warning: API_TOKEN not set\")\n37: \t}\n38: \n39: \tclient = &http.Client{\n40: \t\tTimeout: 30 * time.Second,\n41: \t}\n42: \n43: \tos.Exit(m.Run())\n44: }\n45: \n46: func TestHealthCheck(t *testing.T) {\n47: \tresp, err := client.Get(workloadManagerURL + \"/health\")\n48: \tif err != nil {\n49: \t\tt.Fatalf(\"Health check failed: %v\", err)\n50: \t}\n51: \tdefer resp.Body.Close()\n52: \n53: \tif resp.StatusCode != http.StatusOK {\n54: \t\tt.Fatalf(\"Health check returned status: %d\", resp.StatusCode)\n55: \t}\n56: \n57: \tbody, err := io.ReadAll(resp.Body)\n58: \tif err != nil {\n59: \t\tt.Fatalf(\"Failed to read response body: %v\", err)\n60: \t}\n61: \n62: \tvar health struct {\n63: \t\tStatus string `json:\"status\"`\n64: \t}\n65: \tif err := json.Unmarshal(body, &health); err != nil {\n66: \t\tt.Fatalf(\"Failed to parse health response: %v\", err)\n67: \t}\n68: \n69: \tif health.Status != \"ok\" && health.Status != \"healthy\" {\n70: \t\tt.Logf(\"Health status: %s\", health.Status)\n71: \t}\n72: }\n73: \n74: func TestRouterHealth(t *testing.T) {\n75: \tresp, err := client.Get(routerURL + \"/health/live\")\n76: \tif err != nil {\n77: \t\tt.Fatalf(\"Router health check failed: %v\", err)\n78: \t}\n79: \tdefer resp.Body.Close()\n80: \n81: \tif resp.StatusCode != http.StatusOK {\n82: \t\tt.Fatalf(\"Router health check returned status: %d\", resp.StatusCode)\n83: \t}\n84: }\n85: \n86: func TestInvokeEchoAgent(t *testing.T) {\n87: \tmessage := map[string]string{\n88: \t\t\"message\": \"Hello, echo agent!\",\n89: \t}\n90: \tbody, _ := json.Marshal(message)\n91: \n92: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/echo-agent\", bytes.NewReader(body))\n93: \tif err != nil {\n94: \t\tt.Fatalf(\"Failed to create request: %v\", err)\n95: \t}\n96: \n97: \treq.Header.Set(\"Content-Type\", \"application/json\")\n98: \treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n99: \n100: \tresp, err := client.Do(req)\n101: \tif err != nil {\n102: \t\tt.Fatalf(\"Invoke request failed: %v\", err)\n103: \t}\n104: \tdefer resp.Body.Close()\n105: \n106: \tif resp.StatusCode != http.StatusOK {\n107: \t\tbody, _ := io.ReadAll(resp.Body)\n108: \t\tt.Fatalf(\"Invoke returned status: %d, body: %s\", resp.StatusCode, string(body))\n109: \t}\n110: \n111: \tvar result map[string]interface{}\n112: \tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n113: \t\tt.Fatalf(\"Failed to decode response: %v\", err)\n114: \t}\n115: \n116: \tt.Logf(\"Echo agent response: %+v\", result)\n117: }\n118: \n119: func TestCodeInterpreter(t *testing.T) {\n120: \tcode := map[string]string{\n121: \t\t\"code\": \"print('Hello from code interpreter')\",\n122: \t}\n123: \tbody, _ := json.Marshal(code)\n124: \n125: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/e2e-code-interpreter\", bytes.NewReader(body))\n126: \tif err != nil {\n127: \t\tt.Fatalf(\"Failed to create request: %v\", err)\n128: \t}\n129: \n130: \treq.Header.Set(\"Content-Type\", \"application/json\")\n131: \treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n132: \n133: \tresp, err := client.Do(req)\n134: \tif err != nil {\n135: \t\tt.Fatalf(\"Code interpreter request failed: %v\", err)\n136: \t}\n137: \tdefer resp.Body.Close()\n138: \n139: \tif resp.StatusCode != http.StatusOK {\n140: \t\tbody, _ := io.ReadAll(resp.Body)\n141: \t\tt.Fatalf(\"Code interpreter returned status: %d, body: %s\", resp.StatusCode, string(body))\n142: \t}\n143: \n144: \tvar result map[string]interface{}\n145: \tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n146: \t\tt.Fatalf(\"Failed to decode response: %v\", err)\n147: \t}\n148: \n149: \tt.Logf(\"Code interpreter response: %+v\", result)\n150: }\n\n(End of file - total 150 lines)\n</content>","metadata":{"preview":"// Copyright 2026 AgentCube Authors\n// E2E tests for AgentCube\n\npackage e2e\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n)\n\nvar (\n\tworkloadManagerURL string\n\trouterURL          string\n\tapiToken           string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go","time":{"start":1775891157170,"end":1775891157187}}}}
{"type":"tool_use","timestamp":1775891157189,"sessionID":"ses_284a3f4d3ffe8bFOTfB7U7JhyS","part":{"id":"prt_d7b5c88de001Rp9SfnEyTdOgmL","messageID":"msg_d7b5c75a2001cHObiCS8CLfYnm","sessionID":"ses_284a3f4d3ffe8bFOTfB7U7JhyS","type":"tool","tool":"read","callID":"toolu_826e6e0503144f298a2f0ef9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/README.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/README.md</path>\n<type>file</type>\n<content>\n1: # AgentCube E2E Tests\n2: \n3: This directory contains end-to-end tests for the AgentCube platform.\n4: \n5: ## Requirements\n6: \n7: - Go 1.23+\n8: - Python 3.10+\n9: - Kind v0.30.0+\n10: - Helm 3.x\n11: - Docker\n12: \n13: ## Running E2E Tests\n14: \n15: ### Full E2E Test Suite\n16: \n17: ```bash\n18: make e2e\n19: ```\n20: \n21: This will:\n22: 1. Create a Kind cluster named `agentcube-e2e`\n23: 2. Install agent-sandbox CRDs and controllers\n24: 3. Build and load local Docker images\n25: 4. Install AgentCube via Helm\n26: 5. Apply E2E fixtures (echo agent, code interpreter)\n27: 6. Run Go and Python E2E tests\n28: 7. Clean up the cluster\n29: \n30: ### Manual Test Execution\n31: \n32: ```bash\n33: # Set up environment\n34: export WORKLOAD_MANAGER_URL=http://localhost:8080\n35: export ROUTER_URL=http://localhost:8081\n36: export API_TOKEN=$(kubectl -n agentcube create token e2e-test --duration=24h)\n37: \n38: # Run Go tests\n39: go test -v ./test/e2e/...\n40: \n41: # Run Python tests\n42: python test/e2e/test_codeinterpreter.py\n43: ```\n44: \n45: ## Configuration\n46: \n47: Environment variables:\n48: - `E2E_CLUSTER_NAME`: Kind cluster name (default: `agentcube-e2e`)\n49: - `E2E_CLEAN_CLUSTER`: Delete existing cluster before tests (default: `true`)\n50: - `E2E_SKIP_SETUP`: Skip cluster setup (default: `false`)\n51: - `AGENTCUBE_NAMESPACE`: Kubernetes namespace (default: `agentcube`)\n52: - `AGENT_SANDBOX_VERSION`: Agent sandbox version (default: `v0.1.1`)\n53: - `ARTIFACTS_PATH`: Path for log artifacts on failure\n54: \n55: ## Fixtures\n56: \n57: - `echo_agent.yaml`: Simple echo agent for testing router invocation\n58: - `e2e_code_interpreter.yaml`: CodeInterpreter resource for testing\n59: - `e2e_code_interpreter_warmpool.yaml`: CodeInterpreter with warm pool enabled\n60: \n61: ## Troubleshooting\n62: \n63: ### Collect Logs Manually\n64: \n65: ```bash\n66: ./test/e2e/run_e2e.sh 2>&1 | tee e2e.log\n67: ```\n68: \n69: ### Clean Up\n70: \n71: ```bash\n72: make e2e-clean\n73: ```\n\n(End of file - total 73 lines)\n</content>","metadata":{"preview":"# AgentCube E2E Tests\n\nThis directory contains end-to-end tests for the AgentCube platform.\n\n## Requirements\n\n- Go 1.23+\n- Python 3.10+\n- Kind v0.30.0+\n- Helm 3.x\n- Docker\n\n## Running E2E Tests\n\n### Full E2E Test Suite\n\n```bash\nmake e2e\n```\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/README.md","time":{"start":1775891157174,"end":1775891157188}}}}
{"type":"tool_use","timestamp":1775891157192,"sessionID":"ses_284a3f4d3ffe8bFOTfB7U7JhyS","part":{"id":"prt_d7b5c8ecd001P48CiCqAjRIz4D","messageID":"msg_d7b5c75a2001cHObiCS8CLfYnm","sessionID":"ses_284a3f4d3ffe8bFOTfB7U7JhyS","type":"tool","tool":"read","callID":"toolu_af099e7f34f54a96a90db88f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/run_e2e.sh"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/run_e2e.sh</path>\n<type>file</type>\n<content>\n1: #!/bin/bash\n2: # E2E test runner for AgentCube\n3: # This script sets up a Kind cluster, installs dependencies, and runs E2E tests\n4: \n5: set -e\n6: \n7: # Configuration\n8: export E2E_CLUSTER_NAME=${E2E_CLUSTER_NAME:-agentcube-e2e}\n9: export E2E_CLEAN_CLUSTER=${E2E_CLEAN_CLUSTER:-true}\n10: export E2E_SKIP_SETUP=${E2E_SKIP_SETUP:-false}\n11: export AGENTCUBE_NAMESPACE=${AGENTCUBE_NAMESPACE:-agentcube}\n12: export AGENT_SANDBOX_VERSION=${AGENT_SANDBOX_VERSION:-v0.1.1}\n13: export WORKLOAD_MANAGER_LOCAL_PORT=${WORKLOAD_MANAGER_LOCAL_PORT:-8080}\n14: export ROUTER_LOCAL_PORT=${ROUTER_LOCAL_PORT:-8081}\n15: export REDIS_IMAGE=${REDIS_IMAGE:-redis:7-alpine}\n16: export E2E_VENV_DIR=${E2E_VENV_DIR:-/tmp/agentcube-e2e-venv}\n17: export ARTIFACTS_PATH=${ARTIFACTS_PATH:-${PWD}/e2e-logs}\n18: \n19: # Colors for output\n20: RED='\\033[0;31m'\n21: GREEN='\\033[0;32m'\n22: YELLOW='\\033[1;33m'\n23: NC='\\033[0m' # No Color\n24: \n25: log_info() {\n26:     echo -e \"${GREEN}[INFO]${NC} $1\"\n27: }\n28: \n29: log_warn() {\n30:     echo -e \"${YELLOW}[WARN]${NC} $1\"\n31: }\n32: \n33: log_error() {\n34:     echo -e \"${RED}[ERROR]${NC} $1\"\n35: }\n36: \n37: # Collect component logs on failure\n38: collect_component_logs() {\n39:     log_info \"Collecting component logs...\"\n40:     mkdir -p \"$ARTIFACTS_PATH\"\n41:     \n42:     # Collect workload manager logs\n43:     kubectl -n \"$AGENTCUBE_NAMESPACE\" logs -l app=workloadmanager > \"$ARTIFACTS_PATH/workloadmanager.log\" 2>/dev/null || true\n44:     kubectl -n \"$AGENTCUBE_NAMESPACE\" describe pod -l app=workloadmanager > \"$ARTIFACTS_PATH/workloadmanager-describe.txt\" 2>/dev/null || true\n45:     \n46:     # Collect router logs\n47:     kubectl -n \"$AGENTCUBE_NAMESPACE\" logs -l app=agentcube-router > \"$ARTIFACTS_PATH/router.log\" 2>/dev/null || true\n48:     kubectl -n \"$AGENTCUBE_NAMESPACE\" describe pod -l app=agentcube-router > \"$ARTIFACTS_PATH/router-describe.txt\" 2>/dev/null || true\n49:     \n50:     # Collect sandbox pod logs\n51:     kubectl -n \"$AGENTCUBE_NAMESPACE\" logs -l app=agent-sandbox-controller > \"$ARTIFACTS_PATH/sandbox.log\" 2>/dev/null || true\n52:     kubectl -n \"$AGENTCUBE_NAMESPACE\" describe pod -l app=agent-sandbox-controller > \"$ARTIFACTS_PATH/sandbox-describe.txt\" 2>/dev/null || true\n53:     \n54:     log_info \"Logs collected in $ARTIFACTS_PATH\"\n55: }\n56: \n57: # Run setup\n58: run_setup() {\n59:     log_info \"Setting up E2E environment...\"\n60:     \n61:     # Check if cluster exists\n62:     if kind get clusters 2>/dev/null | grep -q \"^${E2E_CLUSTER_NAME}$\"; then\n63:         if [ \"$E2E_CLEAN_CLUSTER\" = \"true\" ]; then\n64:             log_info \"Deleting existing cluster...\"\n65:             kind delete cluster --name \"$E2E_CLUSTER_NAME\"\n66:         fi\n67:     fi\n68:     \n69:     # Create Kind cluster\n70:     log_info \"Creating Kind cluster...\"\n71:     kind create cluster --name \"$E2E_CLUSTER_NAME\"\n72:     \n73:     # Download and apply agent-sandbox manifests\n74:     log_info \"Installing agent-sandbox ${AGENT_SANDBOX_VERSION}...\"\n75:     wget -q \"https://github.com/kubernetes-sigs/agent-sandbox/releases/download/${AGENT_SANDBOX_VERSION}/manifest.yaml\" -O /tmp/manifest.yaml\n76:     wget -q \"https://github.com/kubernetes-sigs/agent-sandbox/releases/download/${AGENT_SANDBOX_VERSION}/extensions.yaml\" -O /tmp/extensions.yaml\n77:     kubectl apply --validate=false -f /tmp/manifest.yaml\n78:     kubectl apply --validate=false -f /tmp/extensions.yaml\n79:     \n80:     # Pull required images\n81:     log_info \"Pulling required images...\"\n82:     docker pull \"registry.k8s.io/agent-sandbox/agent-sandbox-controller:${AGENT_SANDBOX_VERSION}\"\n83:     docker pull python:3.9-slim\n84:     docker pull \"$REDIS_IMAGE\"\n85:     \n86:     # Build local images\n87:     log_info \"Building local images...\"\n88:     make docker-build\n89:     make docker-build-router\n90:     make docker-build-picod\n91:     \n92:     # Load images to Kind\n93:     log_info \"Loading images to Kind cluster...\"\n94:     kind load docker-image \"workloadmanager:latest\" --name \"$E2E_CLUSTER_NAME\"\n95:     kind load docker-image \"agentcube-router:latest\" --name \"$E2E_CLUSTER_NAME\"\n96:     kind load docker-image \"picod:latest\" --name \"$E2E_CLUSTER_NAME\"\n97:     kind load docker-image \"$REDIS_IMAGE\" --name \"$E2E_CLUSTER_NAME\"\n98:     kind load docker-image \"registry.k8s.io/agent-sandbox/agent-sandbox-controller:${AGENT_SANDBOX_VERSION}\" --name \"$E2E_CLUSTER_NAME\"\n99:     \n100:     # Create namespace\n101:     kubectl create namespace \"$AGENTCUBE_NAMESPACE\" --dry-run=client -o yaml | kubectl apply -f -\n102:     \n103:     # Install Redis\n104:     log_info \"Installing Redis...\"\n105:     kubectl -n \"$AGENTCUBE_NAMESPACE\" run redis --image=\"$REDIS_IMAGE\" --port=6379 --dry-run=client -o yaml | kubectl apply -f -\n106:     kubectl -n \"$AGENTCUBE_NAMESPACE\" expose pod redis --port=6379 --target-port=6379 --dry-run=client -o yaml | kubectl apply -f -\n107:     \n108:     # Install AgentCube via Helm\n109:     log_info \"Installing AgentCube chart...\"\n110:     helm upgrade --install agentcube manifests/charts/base \\\n111:         --namespace \"$AGENTCUBE_NAMESPACE\" \\\n112:         --create-namespace \\\n113:         --set redis.host=\"redis.${AGENTCUBE_NAMESPACE}.svc.cluster.local\" \\\n114:         --set redis.port=6379 \\\n115:         --set redis.password=\"\" \\\n116:         --set workloadmanager.image.repository=workloadmanager \\\n117:         --set workloadmanager.image.tag=latest \\\n118:         --set router.image.repository=agentcube-router \\\n119:         --set router.image.tag=latest \\\n120:         --set router.rbac.create=true \\\n121:         --set router.serviceAccountName=agentcube-router \\\n122:         --set-json='workloadmanager.extraEnv=[{\"name\":\"REDIS_PASSWORD_REQUIRED\",\"value\":\"false\"},{\"name\":\"JWT_KEY_SECRET_NAMESPACE\",\"value\":\"agentcube\"}]' \\\n123:         --set-json='router.extraEnv=[{\"name\":\"REDIS_PASSWORD_REQUIRED\",\"value\":\"false\"}]' \\\n124:         --wait\n125:     \n126:     # Apply fixtures\n127:     log_info \"Applying E2E fixtures...\"\n128:     kubectl apply -f test/e2e/echo_agent.yaml\n129:     kubectl apply -f test/e2e/e2e_code_interpreter.yaml\n130:     \n131:     # Generate short TTL agent\n132:     sed 's/sessionTimeout: \"5m\"/sessionTimeout: \"30s\"/' test/e2e/echo_agent.yaml | \\\n133:         sed 's/name: echo-agent/name: echo-agent-short-ttl/' | \\\n134:         kubectl apply -f -\n135:     \n136:     # Wait for deployments\n137:     log_info \"Waiting for deployments to be ready...\"\n138:     kubectl -n \"$AGENTCUBE_NAMESPACE\" rollout status deployment/workloadmanager --timeout=120s\n139:     kubectl -n \"$AGENTCUBE_NAMESPACE\" rollout status deployment/agentcube-router --timeout=120s\n140:     \n141:     # Set up port forwarding\n142:     log_info \"Setting up port forwarding...\"\n143:     kubectl -n \"$AGENTCUBE_NAMESPACE\" port-forward svc/workloadmanager ${WORKLOAD_MANAGER_LOCAL_PORT}:8080 &\n144:     kubectl -n \"$AGENTCUBE_NAMESPACE\" port-forward svc/agentcube-router ${ROUTER_LOCAL_PORT}:8080 &\n145:     sleep 3\n146:     \n147:     # Health checks\n148:     log_info \"Running health checks...\"\n149:     curl -s \"http://localhost:${WORKLOAD_MANAGER_LOCAL_PORT}/health\" || exit 1\n150:     curl -s \"http://localhost:${ROUTER_LOCAL_PORT}/health/live\" || exit 1\n151:     \n152:     # Create service account and token for tests\n153:     log_info \"Creating test service account...\"\n154:     kubectl -n \"$AGENTCUBE_NAMESPACE\" create sa e2e-test --dry-run=client -o yaml | kubectl apply -f -\n155:     kubectl -n \"$AGENTCUBE_NAMESPACE\" create clusterrolebinding e2e-test-binding \\\n156:         --clusterrole=workloadmanager \\\n157:         --serviceaccount=\"$AGENTCUBE_NAMESPACE\":e2e-test \\\n158:         --dry-run=client -o yaml | kubectl apply -f -\n159:     export API_TOKEN=$(kubectl -n \"$AGENTCUBE_NAMESPACE\" create token e2e-test --duration=24h)\n160:     \n161:     # Set up Python virtual environment\n162:     log_info \"Setting up Python virtual environment...\"\n163:     if [ ! -d \"$E2E_VENV_DIR\" ]; then\n164:         python3 -m venv \"$E2E_VENV_DIR\"\n165:         \"$E2E_VENV_DIR/bin/pip\" install --upgrade pip\n166:         \"$E2E_VENV_DIR/bin/pip\" install -e ./sdk-python\n167:     fi\n168:     \n169:     # Verify agentcube import\n170:     \"$E2E_VENV_DIR/bin/python\" -c \"import agentcube\" || exit 1\n171:     \n172:     log_info \"E2E environment setup complete!\"\n173: }\n174: \n175: # Run E2E tests\n176: run_tests() {\n177:     log_info \"Running E2E tests...\"\n178:     \n179:     # Run Go tests\n180:     log_info \"Running Go E2E tests...\"\n181:     WORKLOAD_MANAGER_URL=\"http://localhost:${WORKLOAD_MANAGER_LOCAL_PORT}\" \\\n182:     ROUTER_URL=\"http://localhost:${ROUTER_LOCAL_PORT}\" \\\n183:     API_TOKEN=\"$API_TOKEN\" \\\n184:     go test -v ./test/e2e/...\n185:     \n186:     # Run Python tests\n187:     log_info \"Running Python E2E tests...\"\n188:     cd test/e2e\n189:     WORKLOAD_MANAGER_URL=\"http://localhost:${WORKLOAD_MANAGER_LOCAL_PORT}\" \\\n190:     ROUTER_URL=\"http://localhost:${ROUTER_LOCAL_PORT}\" \\\n191:     API_TOKEN=\"$API_TOKEN\" \\\n192:     AGENTCUBE_NAMESPACE=\"$AGENTCUBE_NAMESPACE\" \\\n193:     \"$E2E_VENV_DIR/bin/python\" test_codeinterpreter.py --verbose\n194:     cd ..\n195:     \n196:     log_info \"All E2E tests passed!\"\n197: }\n198: \n199: # Main\n200: main() {\n201:     trap 'collect_component_logs; exit 1' ERR\n202:     \n203:     if [ \"$E2E_SKIP_SETUP\" != \"true\" ]; then\n204:         run_setup\n205:     fi\n206:     \n207:     run_tests\n208:     \n209:     log_info \"E2E tests completed successfully!\"\n210: }\n211: \n212: main \"$@\"\n\n(End of file - total 212 lines)\n</content>","metadata":{"preview":"#!/bin/bash\n# E2E test runner for AgentCube\n# This script sets up a Kind cluster, installs dependencies, and runs E2E tests\n\nset -e\n\n# Configuration\nexport E2E_CLUSTER_NAME=${E2E_CLUSTER_NAME:-agentcube-e2e}\nexport E2E_CLEAN_CLUSTER=${E2E_CLEAN_CLUSTER:-true}\nexport E2E_SKIP_SETUP=${E2E_SKIP_SETUP:-false}\nexport AGENTCUBE_NAMESPACE=${AGENTCUBE_NAMESPACE:-agentcube}\nexport AGENT_SANDBOX_VERSION=${AGENT_SANDBOX_VERSION:-v0.1.1}\nexport WORKLOAD_MANAGER_LOCAL_PORT=${WORKLOAD_MANAGER_LOCAL_PORT:-8080}\nexport ROUTER_LOCAL_PORT=${ROUTER_LOCAL_PORT:-8081}\nexport REDIS_IMAGE=${REDIS_IMAGE:-redis:7-alpine}\nexport E2E_VENV_DIR=${E2E_VENV_DIR:-/tmp/agentcube-e2e-venv}\nexport ARTIFACTS_PATH=${ARTIFACTS_PATH:-${PWD}/e2e-logs}\n\n# Colors for output\nRED='\\033[0;31m'","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/run_e2e.sh","time":{"start":1775891157176,"end":1775891157190}}}}
