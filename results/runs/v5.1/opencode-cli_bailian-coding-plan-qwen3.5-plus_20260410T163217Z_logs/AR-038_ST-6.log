se CRDs and should not be assumed reusable:\n30: //   - AgentRuntime, AgentRuntimeSpec, AgentRuntimeStatus, AgentRuntimeList\n31: //   - AgentRuntimePhase, AgentRuntimeConditionType\n32: //   - CodeInterpreterSpec\n33: //\n34: // Validation:\n35: // Shared validation functions are provided for reusable types:\n36: //   - ValidateResourceQuota: Validates resource quota fields\n37: //   - ValidateNetworkPolicy: Validates network policy configuration\n38: //   - ValidateContainerSpec: Validates container specification\n39: //   - ValidateLifecycleHook: Validates lifecycle hook URLs\n40: //\n41: // Example usage for new CRDs:\n42: //\n43: //\ttype MyCRDSpec struct {\n44: //\t    Resources *ResourceQuota      `json:\"resources,omitempty\"`\n45: //\t    Network   *NetworkPolicy      `json:\"network,omitempty\"`\n46: //\t    Container ContainerSpec       `json:\"container,omitempty\"`\n47: //\t}\n48: //\n49: //\tfunc ValidateMyCRD(spec *MyCRDSpec) field.ErrorList {\n50: //\t    allErrs := field.ErrorList{}\n51: //\t    allErrs = append(allErrs, ValidateResourceQuota(spec.Resources, field.NewPath(\"resources\"))...)\n52: //\t    allErrs = append(allErrs, ValidateNetworkPolicy(spec.Network, field.NewPath(\"network\"))...)\n53: //\t    allErrs = append(allErrs, ValidateContainerSpec(&spec.Container, field.NewPath(\"container\"))...)\n54: //\t    return allErrs\n55: //\t}\n56: //\n57: // +k8s:openapi-gen=true\n58: // +k8s:deepcopy-gen=package\n59: // +groupName=runtime.agentcube.volcano.sh\n60: // +versionName=v1alpha1\n61: package v1alpha1\n\n(End of file - total 61 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is d