e.UsedBytes)\n\t}\n\tif usage.FileCount != 2 {\n\t\tt.Errorf(\"expected FileCount 2, got %d\", usage.FileCount)\n\t}\n}\n\nfunc TestCalculateQuotaUsage_Empty(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tusage, err := calculateQuotaUsage(tmpDir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\tif usage.UsedBytes != 0 {\n\t\tt.Errorf(\"expected UsedBytes 0, got %d\", usage.UsedBytes)\n\t}\n\tif usage.FileCount != 0 {\n\t\tt.Errorf(\"expected FileCount 0, got %d\", usage.FileCount)\n\t}\n}\n\nfunc TestCheckWriteQuota(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tquota := &FileQuota{\n\t\tMaxFileSize:       100,\n\t\tMaxTotalSize:      1000,\n\t\tMaxFiles:          10,\n\t\tMaxDirectoryDepth: 5,\n\t}\n\n\tt.Run(\"within quota\", func(t *testing.T) {\n\t\tif err := checkWriteQuota(tmpDir, quota, 50); err != nil {\n\t\t\tt.Errorf(\"expected no error, got %v\", err)\n\t\t}\n\t})\n\n\tt.Run(\"exceeds MaxFileSize\", func(t *testing.T) {\n\t\tif err := checkWriteQuota(tmpDir, quota, 101); err == nil {\n\t\t\tt.Error(\"expected error for exceeding MaxFileSize\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorQuotaExceeded {\n\t\t\t\tt.Error(\"expected FileErrorQuotaExceeded\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"exceeds MaxFiles\", func(t *testing.T) {\n\t\tfor i := 0; i < 9; i++ {\n\t\t\tos.WriteFile(filepath.Join(tmpDir, \"file\"+string(rune(i))+\".txt\"), []byte(\"test\"), 0644)\n\t\t}\n\n\t\tif err := checkWriteQuota(tmpDir, quota, 10); err == nil {\n\t\t\tt.Error(\"expected error for exceeding MaxFiles\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorQuotaExceeded {\n\t\t\t\tt.Error(\"expected FileErrorQuotaExceeded\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"exceeds MaxTotalSize\", func(t *testing.T) {\n\t\ttmpDir2 := t.TempDir()\n\t\tos.WriteFile(filepath.Join(tmpDir2, \"large.txt\"), make([]byte, 950), 0644)\n\n\t\tif err := checkWriteQuota(tmpDir2, quota, 100); err == nil {\n\t\t\