if err := ValidateCommand(cmd, e.securityOpts); err != nil {\n\t\treturn nil, err\n\t}\n\n\tcmdPath, err := findCommand(cmd.Path)\n\tif err != nil {\n\t\treturn nil, &ExecutionError{\n\t\t\tType:       ExecutionErrorExec,\n\t\t\tMessage:    \"command not found\",\n\t\t\tUnderlying: err,\n\t\t}\n\t}\n\n\texecCmd := exec.CommandContext(ctx, cmdPath, cmd.Args...)\n\texecCmd.Env = cmd.Env\n\texecCmd.Dir = cmd.Dir\n\n\tif err := e.limits.Apply(execCmd); err != nil {\n\t\treturn nil, &ExecutionError{\n\t\t\tType:       ExecutionErrorResource,\n\t\t\tMessage:    \"failed to apply resource limits\",\n\t\t\tUnderlying: err,\n\t\t}\n\t}\n\n\tvar stdoutBuf, stderrBuf limitedBuffer\n\tif e.limits.MaxOutputSize > 0 {\n\t\tstdoutBuf.limit = e.limits.MaxOutputSize\n\t\tstderrBuf.limit = e.limits.MaxOutputSize\n\t}\n\tif cmd.Stdout == nil {\n\t\texecCmd.Stdout = &stdoutBuf\n\t} else {\n\t\texecCmd.Stdout = cmd.Stdout\n\t}\n\tif cmd.Stderr == nil {\n\t\texecCmd.Stderr = &stderrBuf\n\t} else {\n\t\texecCmd.Stderr = cmd.Stderr\n\t}\n\n\tstartTime := time.Now()\n\tif err := execCmd.Start(); err != nil {\n\t\treturn nil, &ExecutionError{\n\t\t\tType:       ExecutionErrorExec,\n\t\t\tMessage:    \"failed to start command\",\n\t\t\tUnderlying: err,\n\t\t}\n\t}\n\n\terr = execCmd.Wait()\n\tduration := time.Since(startTime)\n\n\tresult := &CommandResult{\n\t\tDuration: duration,\n\t}\n\n\tif cmd.Stdout == nil {\n\t\tresult.Stdout = stdoutBuf.Bytes()\n\t}\n\tif cmd.Stderr == nil {\n\t\tresult.Stderr = stderrBuf.Bytes()\n\t}\n\n\tif ctx.Err() == context.DeadlineExceeded {\n\t\tresult.Timeout = true\n\t\terr = &ExecutionError{\n\t\t\tType:    ExecutionErrorTimeout,\n\t\t\tMessage: \"command timed out\",\n\t\t}\n\t}\n\n\tif exitErr, ok := err.(*exec.ExitError); ok {\n\t\tresult.ExitCode = exitErr.ExitCode()\n\t\tif status, ok := exitErr.Sys().(syscall.WaitStatus); ok {\n\t\t\tif status.Signal() == syscall.SIGKILL || status.Signal() == syscall.SIGSEGV {\n\t\t\t\tresult.OOMKilled = true\n\t\t\t\t