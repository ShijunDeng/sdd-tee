,\n57: \t\t}\n58: \t}\n59: \n60: \texecCmd := exec.CommandContext(ctx, cmdPath, cmd.Args...)\n61: \texecCmd.Env = cmd.Env\n62: \texecCmd.Dir = cmd.Dir\n63: \n64: \tif err := e.limits.Apply(execCmd); err != nil {\n65: \t\treturn nil, &ExecutionError{\n66: \t\t\tType:       ExecutionErrorResource,\n67: \t\t\tMessage:    \"failed to apply resource limits\",\n68: \t\t\tUnderlying: err,\n69: \t\t}\n70: \t}\n71: \n72: \tvar stdoutBuf, stderrBuf limitedBuffer\n73: \tif cmd.Stdout == nil {\n74: \t\texecCmd.Stdout = &stdoutBuf\n75: \t} else {\n76: \t\texecCmd.Stdout = cmd.Stdout\n77: \t}\n78: \tif cmd.Stderr == nil {\n79: \t\texecCmd.Stderr = &stderrBuf\n80: \t} else {\n81: \t\texecCmd.Stderr = cmd.Stderr\n82: \t}\n83: \n84: \tstartTime := time.Now()\n85: \tif err := execCmd.Start(); err != nil {\n86: \t\treturn nil, &ExecutionError{\n87: \t\t\tType:       ExecutionErrorExec,\n88: \t\t\tMessage:    \"failed to start command\",\n89: \t\t\tUnderlying: err,\n90: \t\t}\n91: \t}\n92: \n93: \terr = execCmd.Wait()\n94: \tduration := time.Since(startTime)\n95: \n96: \tresult := &CommandResult{\n97: \t\tDuration: duration,\n98: \t}\n99: \n100: \tif cmd.Stdout == nil {\n101: \t\tresult.Stdout = stdoutBuf.Bytes()\n102: \t}\n103: \tif cmd.Stderr == nil {\n104: \t\tresult.Stderr = stderrBuf.Bytes()\n105: \t}\n106: \n107: \tif ctx.Err() == context.DeadlineExceeded {\n108: \t\tresult.Timeout = true\n109: \t\terr = &ExecutionError{\n110: \t\t\tType:    ExecutionErrorTimeout,\n111: \t\t\tMessage: \"command timed out\",\n112: \t\t}\n113: \t}\n114: \n115: \tif exitErr, ok := err.(*exec.ExitError); ok {\n116: \t\tresult.ExitCode = exitErr.ExitCode()\n117: \t\tif status, ok := exitErr.Sys().(syscall.WaitStatus); ok {\n118: \t\t\tif status.Signal() == syscall.SIGKILL || status.Signal() == syscall.SIGSEGV {\n119: \t\t\t\tresult.OOMKilled = true\n120: \t\t\t\terr = &ExecutionError{\n121: \t\t\t\t\tType:    ExecutionErrorOOM,\n122: \t\t\t\t\tMessage: \"process killed due to OOM\",\n123: \t\t\t\t}\n124: \t\t\t}\n125: \t\t}\n126: \t} else if err == nil {\n127: \t\tresult.ExitCode = 0\n128: \t} else if ctx.Err() == context.Canceled {\n129: \t\terr = &ExecutionError{\n130: \t\t\tType:    ExecutionErrorCancelled,\n131: \t\t\tMessage: \"command was cancelled\",\n132: \t\t}\n133: \t}\n134: \n135: \treturn result, err\n136: }\n137: \n138: func (e *Executor) Start(ctx context.Context, cmd *Command) (*Process, error) {\n139: \tif err := ValidateCommand(cmd, e.securityOpts); err != nil {\n140: \t\treturn nil, err\n141: \t}\n142: \n143: \tcmdPath, err := findCommand(cmd.Path)\n144: \tif err != nil {\n145: \t\treturn nil, &ExecutionError{\n146: \t\t\tType:       ExecutionErrorExec,\n147: \t\t\tMessage:    \"command not found\",\n148: \t\t\tUnderlying: err,\n149: \t\t}\n150: \t}\n151: \n152: \texecCmd := exec.CommandContext(ctx, cmdPath, cmd.Args...)\n153: \texecCmd.Env = cmd.Env\n154: \texecCmd.Dir = cmd.Dir\n155: \n156: \tif err := e.limits.Apply(execCmd); err != nil {\n157: \t\treturn nil, &ExecutionError{\n158: \t\t\tType:       ExecutionErrorResource,\n159: \t\t\tMessage:    \"failed to apply resource limits\",\n160: \t\t\tUnderlying: err,\n161: \t\t}\n162: \t}\n163: \n164: \tif err := execCmd.Start(); err != nil {\n165: \t\treturn nil, &ExecutionError{\n166: \t\t\tType:       ExecutionErrorExec,\n167: \t\t\tMessage:    \"failed to start command\",\n168: \t\t\tUnderlying: err,\n169: \t\t}\n170: \t}\n171: \n172: \treturn &Process{\n173: \t\tPID:       execCmd.Process.Pid,\n174: \t\tcmd:       execCmd,\n175: \t\tstartTime: time.Now(),\n176: \t\tlimits:    e.limits,\n177: \t}, nil\n178: }\n179: \n180: type limitedBuffer struct {\n181: \tdata  []byte\n182: \tlimit int64\n183: }\n184: \n185: func (b *limitedBuffer) Write(p []byte) (n int, err error) {\n186: \tremaining := int64(b.limit) - int64(len(b.data))\n187: \tif remaining <= 0 {\n188: \t\treturn len(p), nil\n189: \t}\n190: \tif int64(len(p)) > remaining {\n191: \t\tp = p[:remaining]\n192: \t}\n193: \tb.data = append(b.data, p...)\n194: \treturn len(p), nil\n195: }\n196: \n197: func (b *limitedBuffer) Bytes() []byte {\n198: \treturn b.data\n199: }\n\n(End of file - total 199 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"io\"\n\t\"os/exec\"\n\t\"syscall\"\n\t\"time\"\n)\n\nfunc findCommand(path string) (string, error) {\n\treturn exec.LookPath(path)\n}\n\ntype Command struct {\n\tPath   string\n\tArgs   []string\n\tEnv    []string\n\tDir    string\n\tStdin  io.Reader","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/executor.go","time":{"start":1775860958704,"end":1775860958713}}}}
