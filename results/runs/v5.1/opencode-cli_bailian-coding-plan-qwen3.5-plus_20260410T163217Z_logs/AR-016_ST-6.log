alSymlinks(absPath)\n50: \tif err != nil {\n51: \t\tif os.IsNotExist(err) {\n52: \t\t\treturn absPath, nil\n53: \t\t}\n54: \t\treturn \"\", &FileError{\n55: \t\t\tType:       FileErrorPathTraversal,\n56: \t\t\tMessage:    \"failed to evaluate symlinks\",\n57: \t\t\tUnderlying: err,\n58: \t\t}\n59: \t}\n60: \n61: \tabsWorkDir, err := filepath.Abs(workDir)\n62: \tif err != nil {\n63: \t\treturn \"\", &FileError{\n64: \t\t\tType:       FileErrorPathTraversal,\n65: \t\t\tMessage:    \"failed to resolve workspace absolute path\",\n66: \t\t\tUnderlying: err,\n67: \t\t}\n68: \t}\n69: \n70: \tif !strings.HasPrefix(evaluatedPath, absWorkDir) {\n71: \t\treturn \"\", &FileError{\n72: \t\t\tType:    FileErrorPathTraversal,\n73: \t\t\tMessage: fmt.Sprintf(\"symlink target %q is outside workspace %q\", evaluatedPath, absWorkDir),\n74: \t\t}\n75: \t}\n76: \n77: \treturn evaluatedPath, nil\n78: }\n79: \n80: func GetDepth(path string) int {\n81: \tcleanPath := filepath.Clean(path)\n82: \tif cleanPath == \".\" || cleanPath == \"/\" {\n83: \t\treturn 0\n84: \t}\n85: \treturn strings.Count(cleanPath, string(filepath.Separator))\n86: }\n87: \n88: func IsWithinWorkspace(path, workDir string) bool {\n89: \tabsPath, err := filepath.Abs(path)\n90: \tif err != nil {\n91: \t\treturn false\n92: \t}\n93: \n94: \tabsWorkDir, err := filepath.Abs(workDir)\n95: \tif err != nil {\n96: \t\treturn false\n97: \t}\n98: \n99: \treturn strings.HasPrefix(absPath, absWorkDir)\n100: }\n101: \n102: func ValidateDepth(path, workDir string, maxDepth int) error {\n103: \trelPath, err := filepath.Rel(workDir, path)\n104: \tif err != nil {\n105: \t\treturn &FileError{\n106: \t\t\tType:       FileErrorDepth,\n107: \t\t\tMessage:    \"failed to calculate relative path\",\n108: \t\t\tUnderlying: err,\n109: \t\t}\n110: \t}\n111: \n112: \tdepth := GetDepth(relPath)\n113: \tif depth > maxDepth {\n114: \t\treturn &FileError{\n115: \t\t\tType:    FileErrorDepth,\n116: \t\t\tMessage: fmt.Sprintf(\"path depth %d exceeds maximum depth %d\", depth, maxDepth),\n117: \t\t}\n118: \t}\n119: \n120: \treturn nil\n121: }\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n)\n\nfunc ValidatePath(path, workDir string) (string, error) {\n\tabsPath, err := filepath.Abs(path)\n\tif err != nil {\n\t\treturn \"\", &FileError{\n\t\t\tType:       FileErrorPathTraversal,\n\t\t\tMessage:    \"failed to resolve absolute path\",\n\t\t\tUnderlying: err,\n\t\t}\n\t}\n\n\tabsWorkDir, err := filepath.Abs(workDir)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/path.go","time":{"start":1775860848713,"end":1775860848721}}}}
