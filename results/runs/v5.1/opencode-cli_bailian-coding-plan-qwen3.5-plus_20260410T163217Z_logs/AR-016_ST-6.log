\n\ttmpDir := t.TempDir()\n\n\tt.Run(\"valid relative path\", func(t *testing.T) {\n\t\tresult, err := ValidatePath(\"test.txt\", tmpDir)\n\t\tif err != nil {\n\t\t\tt.Fatal(err)\n\t\t}\n\n\t\texpected := filepath.Join(tmpDir, \"test.txt\")\n\t\tif result != expected {\n\t\t\tt.Errorf(\"expected %s, got %s\", expected, result)\n\t\t}\n\t})\n\n\tt.Run(\"valid absolute path within workspace\", func(t *testing.T) {\n\t\ttestFile := filepath.Join(tmpDir, \"test.txt\")\n\t\tif err := os.WriteFile(testFile, []byte(\"test\"), 0644); err != nil {\n\t\t\tt.Fatal(err)\n\t\t}\n\n\t\tresult, err := ValidatePath(testFile, tmpDir)\n\t\tif err != nil {\n\t\t\tt.Fatal(err)\n\t\t}\n\n\t\tif result != testFile {\n\t\t\tt.Errorf(\"expected %s, got %s\", testFile, result)\n\t\t}\n\t})\n\n\tt.Run(\"normalized path\", func(t *testing.T) {\n\t\tsubDir := filepath.Join(tmpDir, \"subdir\")\n\t\tif err := os.Mkdir(subDir, 0755); err != nil {\n\t\t\tt.Fatal(err)\n\t\t}\n\n\t\tresult, err := ValidatePath(filepath.Join(\"subdir\", \"..\", \"test.txt\"), tmpDir)\n\t\tif err != nil {\n\t\t\tt.Fatal(err)\n\t\t}\n\n\t\texpected := filepath.Join(tmpDir, \"test.txt\")\n\t\tif result != expected {\n\t\t\tt.Errorf(\"expected %s, got %s\", expected, result)\n\t\t}\n\t})\n}\n\nfunc TestValidatePath_PathTraversal(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tt.Run(\"path with ../ escaping workspace\", func(t *testing.T) {\n\t\t_, err := ValidatePath(\"../test.txt\", tmpDir)\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for path traversal\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorPathTraversal {\n\t\t\t\tt.Error(\"expected FileErrorPathTraversal\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"absolute path outside workspace\", func(t *testing.T) {\n\t\t_, err := ValidatePath(\"/etc/passwd\", tmpDir)\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for absolute path outside workspace\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorPathTraversal {\n\t\t\t\tt.Error(\"expected FileErrorPathTraversal\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"symlink to outside workspace\", func(t *testing.T) {\n\t\tlinkPath := filepath.Join(tmpDir, \"link\")\n\t\tif err := os.Symlink(\"/etc/passwd\", linkPath); err != nil {\n\t\t\tt.Fatal(err)\n\t\t}\n\n\t\t_, err := ValidatePath(linkPath, tmpDir)\n\t\tif err == nil {\n\t\t\tt.Error(\"expected error for symlink to outside workspace\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorPathTraversal {\n\t\t\t\tt.Error(\"expected FileErrorPathTraversal\")\n\t\t\t}\n\t\t}\n\t})\n}\n\nfunc TestGetDepth(t *testing.T) {\n\ttests := []struct {\n\t\tpath     string\n\t\texpected int\n\t}{\n\t\t{\".\", 0},\n\t\t{\"/\", 0},\n\t\t{\"file.txt\", 0},\n\t\t{\"dir/file.txt\", 1},\n\t\t{\"dir/subdir/file.txt\", 2},\n\t\t{\"/abs/dir/file.txt\", 3},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.path, func(t *testing.T) {\n\t\t\tdepth := GetDepth(tt.path)\n\t\t\tif depth != tt.expected {\n\t\t\t\tt.Errorf(\"expected depth %d, got %d\", tt.expected, depth)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestIsWithinWorkspace(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tt.Run(\"path within workspace\", func(t *testing.T) {\n\t\tif !IsWithinWorkspace(filepath.Join(tmpDir, \"test.txt\"), tmpDir) {\n\t\t\tt.Error(\"expected true for path within workspace\")\n\t\t}\n\t})\n\n\tt.Run(\"path outside workspace\", func(t *testing.T) {\n\t\tif IsWithinWorkspace(\"/etc/passwd\", tmpDir) {\n\t\t\tt.Error(\"expected false for path outside workspace\")\n\t\t}\n\t})\n\n\tt.Run(\"invalid path\", func(t *testing.T) {\n\t\tif IsWithinWorkspace(\"\", tmpDir) {\n\t\t\tt.Error(\"expected false for empty path\")\n\t\t}\n\t})\n}\n\nfunc TestValidateDepth(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tt.Run(\"within depth limit\", func(t *testing.T) {\n\t\tpath := filepath.Join(tmpDir, \"a\", \"b\")\n\t\tif err := os.MkdirAll(path, 0755); err != ni