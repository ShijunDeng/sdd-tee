est.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/quota_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/quota_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/quota_test.go\n@@ -173,9 +173,9 @@\n \t}\n })\n \n t.Run(\"exceeds MaxFiles\", func(t *testing.T) {\n-\tfor i := 0; i < 10; i++ {\n+\tfor i := 0; i < 9; i++ {\n \t\tos.WriteFile(filepath.Join(tmpDir, \"file\"+string(rune(i))+\".txt\"), []byte(\"test\"), 0644)\n \t}\n \n \tif err := checkWriteQuota(tmpDir, quota, 10); err == nil {\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/quota_test.go","before":"package picod\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n)\n\nfunc TestFileQuota_Validate(t *testing.T) {\n\tt.Run(\"valid quota\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       1024,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err != nil {\n\t\t\tt.Errorf(\"expected no error, got %v\", err)\n\t\t}\n\t})\n\n\tt.Run(\"MaxFileSize zero\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       0,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for zero MaxFileSize\")\n\t\t}\n\t})\n\n\tt.Run(\"MaxFileSize negative\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       -1,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for negative MaxFileSize\")\n\t\t}\n\t})\n\n\tt.Run(\"MaxTotalSize zero\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       1024,\n\t\t\tMaxTotalSize:      0,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for zero MaxTotalSize\")\n\t\t}\n\t})\n\n\tt.Run(\"MaxFiles zero\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       1024,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          0,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for zero MaxFiles\")\n\t\t}\n\t})\n\n\tt.Run(\"MaxDirectoryDepth zero\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       1024,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 0,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for zero MaxDirectoryDepth\")\n\t\t}\n\t})\n}\n\nfunc TestDefaultFileQuota(t *testing.T) {\n\tquota := DefaultFileQuota()\n\n\tif quota.MaxFileSize != 10*1024*1024 {\n\t\tt.Errorf(\"expected MaxFileSize 10MB, got %d\", quota.MaxFileSize)\n\t}\n\tif quota.MaxTotalSize != 100*1024*1024 {\n\t\tt.Errorf(\"expected MaxTotalSize 100MB, got %d\", quota.MaxTotalSize)\n\t}\n\tif quota.MaxFiles != 1000 {\n\t\tt.Errorf(\"expected MaxFiles 1000, got %d\", quota.MaxFiles)\n\t}\n\tif quota.MaxDirectoryDepth != 10 {\n\t\tt.Errorf(\"expected MaxDirectoryDepth 10, got %d\", quota.MaxDirectoryDepth)\n\t}\n\n\tif err := quota.Validate(); err != nil {\n\t\tt.Errorf(\"default quota should be valid, got %v\", err)\n\t}\n}\n\nfunc TestCalculateQuotaUsage(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tif err := os.WriteFile(filepath.Join(tmpDir, \"file1.txt\"), []byte(\"hello\"), 0644); err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif err := os.WriteFile(filepath.Join(tmpDir, \"file2.txt\"), []byte(\"world!\"), 0644); err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\tusage, err := calculateQuotaUsage(tmpDir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\tif usage.UsedBytes != 11 {\n\t\tt.Errorf(\"expected UsedBytes 11, got %d\", usage.UsedBytes)\n\t}\n\tif usage.FileCount != 2 {\n\t\tt.Errorf(\"expected FileCount 2, got %d\", usage.FileCount)\n\t}\n}\n\nfunc TestCalculateQuotaUsage_Empty(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tusage, err := calculateQuotaUsage(tmpDir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\tif usage.UsedBytes != 0 {\n\t\tt.Errorf(\"expected UsedBytes 0, got %d\", usage.UsedBytes)\n\t}\n\tif usage.FileCount != 0 {\n\t\tt.Errorf(\"expected FileCount 0, got %d\", usage.FileCount)\n\t}\n}\n\nfunc TestCheckWriteQuota(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tquota := &FileQuota{\n\t\tMaxFileSize:       100,\n\t\tMaxTotalSize:      1000,\n\t\tMaxFiles:          10,\n\t\tMaxDirectoryDepth: 5,\n\t}\n\n\tt.Run(\"within quota\", func(t *testing.T) {\n\t\tif err := checkWriteQuota(tmpDir, quota, 50); err != nil {\n\t\t\tt.Errorf(\"expected no error, got %v\", err)\n\t\t}\n\t})\n\n\tt.Run(\"exceeds MaxFileSize\", func(t *testing.T) {\n\t\tif err := checkWriteQuota(tmpDir, quota, 101); err == nil {\n\t\t\tt.Error(\"expected error for exceeding MaxFileSize\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorQuotaExceeded {\n\t\t\t\tt.Error(\"expected FileErrorQuotaExceeded\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"exceeds MaxFiles\", func(t *testing.T) {\n\t\tfor i := 0; i < 10; i++ {\n\t\t\tos.WriteFile(filepath.Join(tmpDir, \"file\"+string(rune(i))+\".txt\"), []byte(\"test\"), 0644)\n\t\t}\n\n\t\tif err := checkWriteQuota(tmpDir, quota, 10); err == nil {\n\t\t\tt.Error(\"expected error for exceeding MaxFiles\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorQuotaExceeded {\n\t\t\t\tt.Error(\"expected FileErrorQuotaExceeded\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"exceeds MaxTotalSize\", func(t *testing.T) {\n\t\ttmpDir2 := t.TempDir()\n\t\tos.WriteFile(filepath.Join(tmpDir2, \"large.txt\"), make([]byte, 950), 0644)\n\n\t\tif err := checkWriteQuota(tmpDir2, quota, 100); err == nil {\n\t\t\tt.Error(\"expected error for exceeding MaxTotalSize\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorQuotaExceeded {\n\t\t\t\tt.Error(\"expected FileErrorQuotaExceeded\")\n\t\t\t}\n\t\t}\n\t})\n}\n","after":"package picod\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n)\n\nfunc TestFileQuota_Validate(t *testing.T) {\n\tt.Run(\"valid quota\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       1024,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err != nil {\n\t\t\tt.Errorf(\"expected no error, got %v\", err)\n\t\t}\n\t})\n\n\tt.Run(\"MaxFileSize zero\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       0,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for zero MaxFileSize\")\n\t\t}\n\t})\n\n\tt.Run(\"MaxFileSize negative\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       -1,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for negative MaxFileSize\")\n\t\t}\n\t})\n\n\tt.Run(\"MaxTotalSize zero\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       1024,\n\t\t\tMaxTotalSize:      0,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for zero MaxTotalSize\")\n\t\t}\n\t})\n\n\tt.Run(\"MaxFiles zero\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       1024,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          0,\n\t\t\tMaxDirectoryDepth: 5,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for zero MaxFiles\")\n\t\t}\n\t})\n\n\tt.Run(\"MaxDirectoryDepth zero\", func(t *testing.T) {\n\t\tquota := &FileQuota{\n\t\t\tMaxFileSize:       1024,\n\t\t\tMaxTotalSize:      10240,\n\t\t\tMaxFiles:          100,\n\t\t\tMaxDirectoryDepth: 0,\n\t\t}\n\n\t\tif err := quota.Validate(); err == nil {\n\t\t\tt.Error(\"expected error for zero MaxDirectoryDepth\")\n\t\t}\n\t})\n}\n\nfunc TestDefaultFileQuota(t *testing.T) {\n\tquota := DefaultFileQuota()\n\n\tif quota.MaxFileSize != 10*1024*1024 {\n\t\tt.Errorf(\"expected MaxFileSize 10MB, got %d\", quota.MaxFileSize)\n\t}\n\tif quota.MaxTotalSize != 100*1024*1024 {\n\t\tt.Errorf(\"expected MaxTotalSize 100MB, got %d\", quota.MaxTotalSize)\n\t}\n\tif quota.MaxFiles != 1000 {\n\t\tt.Errorf(\"expected MaxFiles 1000, got %d\", quota.MaxFiles)\n\t}\n\tif quota.MaxDirectoryDepth != 10 {\n\t\tt.Errorf(\"expected MaxDirectoryDepth 10, got %d\", quota.MaxDirectoryDepth)\n\t}\n\n\tif err := quota.Validate(); err != nil {\n\t\tt.Errorf(\"default quota should be valid, got %v\", err)\n\t}\n}\n\nfunc TestCalculateQuotaUsage(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tif err := os.WriteFile(filepath.Join(tmpDir, \"file1.txt\"), []byte(\"hello\"), 0644); err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif err := os.WriteFile(filepath.Join(tmpDir, \"file2.txt\"), []byte(\"world!\"), 0644); err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\tusage, err := calculateQuotaUsage(tmpDir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\tif usage.UsedBytes != 11 {\n\t\tt.Errorf(\"expected UsedBytes 11, got %d\", usage.UsedBytes)\n\t}\n\tif usage.FileCount != 2 {\n\t\tt.Errorf(\"expected FileCount 2, got %d\", usage.FileCount)\n\t}\n}\n\nfunc TestCalculateQuotaUsage_Empty(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tusage, err := calculateQuotaUsage(tmpDir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\tif usage.UsedBytes != 0 {\n\t\tt.Errorf(\"expected UsedBytes 0, got %d\", usage.UsedBytes)\n\t}\n\tif usage.FileCount != 0 {\n\t\tt.Errorf(\"expected FileCount 0, got %d\", usage.FileCount)\n\t}\n}\n\nfunc TestCheckWriteQuota(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tquota := &FileQuota{\n\t\tMaxFileSize:       100,\n\t\tMaxTotalSize:      1000,\n\t\tMaxFiles:          10,\n\t\tMaxDirectoryDepth: 5,\n\t}\n\n\tt.Run(\"within quota\", func(t *testing.T) {\n\t\tif err := checkWriteQuota(tmpDir, quota, 50); err != nil {\n\t\t\tt.Errorf(\"expected no error, got %v\", err)\n\t\t}\n\t})\n\n\tt.Run(\"exceeds MaxFileSize\", func(t *testing.T) {\n\t\tif err := checkWriteQuota(tmpDir, quota, 101); err == nil {\n\t\t\tt.Error(\"expected error for exceeding MaxFileSize\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorQuotaExceeded {\n\t\t\t\tt.Error(\"expected FileErrorQuotaExceeded\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"exceeds MaxFiles\", func(t *testing.T) {\n\t\tfor i := 0; i < 9; i++ {\n\t\t\tos.WriteFile(filepath.Join(tmpDir, \"file\"+string(rune(i))+\".txt\"), []byte(\"test\"), 0644)\n\t\t}\n\n\t\tif err := checkWriteQuota(tmpDir, quota, 10); err == nil {\n\t\t\tt.Error(\"expected error for exceeding MaxFiles\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorQuotaExceeded {\n\t\t\t\tt.Error(\"expected FileErrorQuotaExceeded\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"exceeds MaxTotalSize\", func(t *testing.T) {\n\t\ttmpDir2 := t.TempDir()\n\t\tos.WriteFile(filepath.Join(tmpDir2, \"large.txt\"), make([]byte, 950), 0644)\n\n\t\tif err := checkWriteQuota(tmpDir2, quota, 100); err == nil {\n\t\t\tt.Error(\"expected error for exceeding MaxTotalSize\")\n\t\t} else {\n\t\t\tfileErr, ok := err.(*FileError)\n\t\t\tif !ok || fileErr.Type != FileErrorQuotaExceeded {\n\t\t\t\tt.Error(\"expected FileErrorQuotaExceeded\")\n\t\t\t}\n\t\t}\n\t})\n}\n","additions":1,"deletions