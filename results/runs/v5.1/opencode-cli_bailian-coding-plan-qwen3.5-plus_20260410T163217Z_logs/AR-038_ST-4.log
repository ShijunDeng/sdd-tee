Collector{\n47: \t\tdynamicClient: dynamicClient,\n48: \t\tstoreClient:   storeClient,\n49: \t\tinterval:      interval,\n50: \t\tctx:           ctx,\n51: \t\tcancel:        cancel,\n52: \t}\n53: }\n54: \n55: func (gc *GarbageCollector) Start() {\n56: \tgo gc.gcLoop()\n57: }\n58: \n59: func (gc *GarbageCollector) Stop() {\n60: \tgc.cancel()\n61: }\n62: \n63: func (gc *GarbageCollector) gcLoop() {\n64: \tticker := time.NewTicker(gc.interval)\n65: \tdefer ticker.Stop()\n66: \n67: \tklog.Info(\"GarbageCollector started\")\n68: \n69: \tfor {\n70: \t\tselect {\n71: \t\tcase <-gc.ctx.Done():\n72: \t\t\tklog.Info(\"GarbageCollector stopped\")\n73: \t\t\treturn\n74: \t\tcase <-ticker.C:\n75: \t\t\tgc.tick()\n76: \t\t}\n77: \t}\n78: }\n79: \n80: func (gc *GarbageCollector) tick() {\n81: \ttickCtx, cancel := context.WithTimeout(gc.ctx, GCSingleTickTimeout)\n82: \tdefer cancel()\n83: \n84: \tnow := time.Now()\n85: \tidleThreshold := now.Add(-DefaultSandboxIdleTimeout)\n86: \texpiredThreshold := now\n87: \n88: \tidleSandboxes, err := gc.storeClient.ListInactiveSandboxes(tickCtx, idleThreshold, 16)\n89: \tif err != nil {\n90: \t\tklog.Errorf(\"Failed to list inactive sandboxes: %v\", err)\n91: \t} else {\n92: \t\tfor _, sandbox := range idleSandboxes {\n93: \t\t\tgc.deleteSandbox(tickCtx, sandbox, wmTypes.CleanupReasonIdleTimeout)\n94: \t\t}\n95: \t}\n96: \n97: \texpiredSandboxes, err := gc.storeClient.ListExpiredSandboxes(tickCtx, expiredThreshold, 16)\n98: \tif err != nil {\n99: \t\tklog.Errorf(\"Failed to list expired sandboxes: %v\", err)\n100: \t} else {\n101: \t\tfor _, sandbox := range expiredSandboxes {\n102: \t\t\tgc.deleteSandbox(tickCtx, sandbox, wmTypes.CleanupReasonExpired)\n103: \t\t}\n104: \t}\n105: }\n106: \n107: func (gc *GarbageCollector) deleteSandbox(\n108: \tctx context.Context,\n109: \tsandbox *wmTypes.SandboxInfo,\n110: \treason wmTypes.SandboxCleanupReason,\n111: ) {\n112: \tauditEntry := &wmTypes.CleanupAuditEntry{\n113: \t\tSessionID: sandbox.SessionID,\n114: \t\tSandboxID: sandbox.SandboxID,\n115: \t\tNamespace: sandbox.SandboxNamespace,\n116: \t\tReason:    reason,\n117: \t\tDeletedAt: time.Now(),\n118: \t}\n119: \n120: \tgvr := SandboxGVR\n121: \tif sandbox.Kind == wmTypes.SandboxClaimKind {\n122: \t\tgvr = SandboxClaimGVR\n123: \t}\n124: \n125: \tdeleteCtx, cancel := context.WithTimeout(ctx, DeleteTimeout)\n126: \tdefer cancel()\n127: \n128: \terr := gc.dynamicClient.Resource(gvr).\n129: \t\tNamespace(sandbox.SandboxNamespace).\n130: \t\tDelete(deleteCtx, sandbox.SandboxID, metav1.DeleteOptions{})\n131: \n132: \tif err != nil && !apierrors.IsNotFound(err) {\n133: \t\tauditEntry.ErrorMessage = err.Error()\n134: \t\tauditEntry.Success = false\n135: \t\tklog.Errorf(\"Failed to delete sandbox %s/%s: %v\", sandbox.SandboxNamespace, sandbox.SandboxID, err)\n136: \t} else {\n137: \t\tif err := gc.storeClient.DeleteSandboxBySessionID(ctx, sandbox.SessionID); err != nil {\n138: \t\t\tklog.Warningf(\"Failed to delete sandbox %s from store: %v\", sandbox.SessionID, err)\n139: \t\t}\n140: \t\tauditEntry.Success = true\n141: \t\tklog.Infof(\"Deleted sandbox %s/%s (reason: %s)\", sandbox.SandboxNamespace, sandbox.SandboxID, reason)\n142: \t}\n143: \n144: \tgc.recordAudit(auditEntry)\n145: }\n146: \n147: func (gc *GarbageCollector) recordAudit(entry *wmTypes.CleanupAuditEntry) {\n148: \tklog.Infof(\"Cleanup audit: sessionId=%s sandboxId=%s namespace=%s reason=%s success=%v deletedAt=%s\",\n149: \t\tentry.SessionID, entry.SandboxID, entry.Namespace, entry.Reason, entry.Success, entry.DeletedAt.Format(time.RFC3339))\n150: \tif entry.ErrorMessage != \"\" {\n151: \t\tklog.Infof(\"Cleanup audit error: %s\", entry.ErrorMessage)\n152: \t}\n153: }\n\n(End of file - total 153 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"