 kubernetes.Interface,\n40: \tpodLister corev1lister.PodLister,\n41: \tpodIndexer cache.Indexer,\n42: \trecorder record.EventRecorder,\n43: \tmetrics *ReconcilerMetrics,\n44: \tconfig *ReconcilerConfig,\n45: ) *AgentRuntimeReconciler {\n46: \tworkqueue := workqueue.NewNamedRateLimitingQueue(\n47: \t\tworkqueue.DefaultControllerRateLimiter(),\n48: \t\t\"agentruntimes\",\n49: \t)\n50: \n51: \tarResource := dynamicClient.Resource(\n52: \t\truntimev1alpha1.SchemeGroupVersion.WithResource(\"agentruntimes\"),\n53: \t)\n54: \n55: \treconciler := &AgentRuntimeReconciler{\n56: \t\tdynamicClient: dynamicClient,\n57: \t\tk8sClient:     k8sClient,\n58: \t\tarLister:      arResource,\n59: \t\tpodLister:     podLister,\n60: \t\tpodIndexer:    podIndexer,\n61: \t\trecorder:      recorder,\n62: \t\tworkqueue:     workqueue,\n63: \t\tmetrics:       metrics,\n64: \t\tconfig:        config,\n65: \t\tprocessor:     NewSandboxProcessor(k8sClient),\n66: \t\tstatusUpdater: NewStatusUpdater(dynamicClient),\n67: \t}\n68: \n69: \treturn reconciler\n70: }\n71: \n72: func (r *AgentRuntimeReconciler) Run(ctx context.Context) {\n73: \tdefer r.workqueue.ShutDown()\n74: \n75: \tfor r.processNextWorkItem(ctx) {\n76: \t}\n77: }\n78: \n79: func (r *AgentRuntimeReconciler) processNextWorkItem(ctx context.Context) bool {\n80: \tobj, shutdown := r.workqueue.Get()\n81: \tif shutdown {\n82: \t\treturn false\n83: \t}\n84: \n85: \tdefer r.workqueue.Done(obj)\n86: \n87: \treq, ok := obj.(Request)\n88: \tif !ok {\n89: \t\tr.workqueue.Forget(obj)\n90: \t\treturn true\n91: \t}\n92: \n93: \tif result, err := r.Reconcile(ctx, req); err != nil {\n94: \t\tr.metrics.RecordError()\n95: \t\tr.workqueue.AddRateLimited(obj)\n96: \t} else if result.Requeue {\n97: \t\tif result.RequeueAfter > 0 {\n98: \t\t\tr.workqueue.Forget(obj)\n99: \t\t\tr.workqueue.AddAfter(obj, result.RequeueAfter)\n100: \t\t} else {\n101: \t\t\tr.workqueue.AddRateLimited(obj)\n102: \t\t}\n103: \t} else {\n104: \t\tr.workqueue.Forget(obj)\n105: \t}\n106: \n107: \treturn true\n108: }\n109: \n110: func (r *AgentRuntimeReconciler) Reconcile(ctx context.Context, req Request) (Result, error) {\n111: \tstartTime := time.Now()\n112: \tdefer func() {\n113: \t\tr.metrics.ObserveReconcileDuration(time.Since(startTime))\n114: \t\tr.metrics.RecordReconcile()\n115: \t}()\n116: \n117: \tar, err := r.getAgentRuntime(req.Namespace, req.Name)\n118: \tif err != nil {\n119: \t\tif k8s_errors.IsNotFound(err) {\n120: \t\t\treturn Result{}, nil\n121: \t\t}\n122: \t\treturn Result{}, fmt.Errorf(\"failed to get AgentRuntime: %w\", err)\n123: \t}\n124: \n125: \tif !ar.DeletionTimestamp.IsZero() {\n126: \t\treturn r.reconcileDeletion(ctx, ar)\n127: \t}\n128: \n129: \tpod, err := r.reconcileSandboxPod(ctx, ar)\n130: \tif err != nil {\n131: \t\tr.recorder.Eventf(ar, corev1.EventTypeWarning, ErrPodCreationFailed, \"Failed to create sandbox pod: %v\", err)\n132: \n133: \t\tif IsRetryableError(err) {\n134: \t\t\treturn Result{RequeueAfter: CalculateBackoff(1)}, nil\n135: \t\t}\n136: \t\treturn Result{}, err\n137: \t}\n138: \n139: \tif err := r.statusUpdater.UpdateAgentRuntimeStatus(ctx, ar, pod); err != nil {\n140: \t\tr.recorder.Eventf(ar, corev1.EventTypeWarning, ErrStatusUpdateFailed, \"Failed to update status: %v\", err)\n141: \n142: \t\tif IsRetryableError(err) {\n143: \t\t\treturn Result{RequeueAfter: CalculateBackoff(2)}, nil\n144: \t\t}\n145: \t\treturn Result{}, err\n146: \t}\n147: \n148: \tr.recorder.Eventf(ar, corev1.EventTypeNormal, \"Reconciled\", \"Successfully reconciled AgentRuntime\")\n149: \n150: \treturn Result{}, nil\n151: }\n152: \n153: func (r *AgentRuntimeReconciler) getAgentRuntime(namespace, name string) (*runtimev1alpha1.AgentRuntime, error) {\n154: \tarMap, err := r.arLister.Namespace(namespace).Get(context.Background(), name, metav1.GetOptions{})\n155: \tif err != nil {\n156: \t\treturn nil, err\n157: \t}\n158: \n159: \tar := &runtimev1alpha1.AgentRuntime{}\n160: \tar.Name = arMap.GetName()\n161: \tar.Namespace =