r,\n40: \t\tnamespace:     namespace,\n41: \t}\n42: }\n43: \n44: func (h *SandboxHandler) HandleAgentRuntimeCreate(c *gin.Context) {\n45: \tvar req types.CreateSandboxRequest\n46: \tif err := c.ShouldBindJSON(&req); err != nil {\n47: \t\tresponse.Error(c, http.StatusBadRequest, 40002, \"Invalid request body\")\n48: \t\treturn\n49: \t}\n50: \n51: \tif err := req.Validate(); err != nil {\n52: \t\tresponse.Error(c, http.StatusBadRequest, 40003, err.Error())\n53: \t\treturn\n54: \t}\n55: \n56: \treq.Kind = \"AgentRuntime\"\n57: \n58: \truntime, err := processor.GetAgentRuntime(h.arLister, req.Namespace, req.Name)\n59: \tif err != nil {\n60: \t\tif err == processor.ErrAgentRuntimeNotFound {\n61: \t\t\tresponse.Error(c, http.StatusNotFound, 40401, \"agent runtime not found\")\n62: \t\t\treturn\n63: \t\t}\n64: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n65: \t\treturn\n66: \t}\n67: \n68: \tproc := processor.NewSandboxProcessor(h.dynamicClient, h.k8sClient, h.podLister, h.arLister, h.ciLister, h.namespace)\n69: \n70: \tsessionID, err := proc.GenerateSessionID()\n71: \tif err != nil {\n72: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n73: \t\treturn\n74: \t}\n75: \n76: \tsandbox, err := proc.BuildSandboxObject(runtime, sessionID)\n77: \tif err != nil {\n78: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n79: \t\treturn\n80: \t}\n81: \n82: \tuserClient := h.dynamicClient.Resource(processor.SandboxGVR).Namespace(runtime.Namespace)\n83: \n84: \tinfo, err := proc.CreateSandbox(c.Request.Context(), sandbox, false, userClient, sessionID)\n85: \tif err != nil {\n86: \t\tif err == processor.ErrSandboxCreationTimeout {\n87: \t\t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n88: \t\t\treturn\n89: \t\t}\n90: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n91: \t\treturn\n92: \t}\