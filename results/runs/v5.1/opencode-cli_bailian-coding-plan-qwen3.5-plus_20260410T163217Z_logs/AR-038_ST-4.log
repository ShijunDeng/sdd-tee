.Request.Context(), sandbox, isWarmPool, userClient, sessionID)\n148: \tif err != nil {\n149: \t\tif err == processor.ErrSandboxCreationTimeout {\n150: \t\t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n151: \t\t\treturn\n152: \t\t}\n153: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n154: \t\treturn\n155: \t}\n156: \n157: \tresp := types.CreateSandboxResponse{\n158: \t\tSessionID:   info.SessionID,\n159: \t\tSandboxID:   info.SandboxID,\n160: \t\tSandboxName: info.SandboxName,\n161: \t\tEntryPoints: info.EntryPoints,\n162: \t}\n163: \n164: \tresponse.JSON(c, http.StatusOK, resp)\n165: }\n\n(End of file - total 165 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/processor\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\ntype SandboxHandler struct {\n\tdynamicClient dynamic.Interface\n\tk8sClient     kubernetes.Interface\n\tpodLister     corev1lister.PodLister","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/handler/sandbox.go","time":{"start":1775888229848,"end":1775888229877}}}}
