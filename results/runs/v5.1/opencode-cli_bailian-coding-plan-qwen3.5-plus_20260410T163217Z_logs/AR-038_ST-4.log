{\n212: \t\t\treturn nil, fmt.Errorf(\"failed to update pod: %w\", err)\n213: \t\t}\n214: \t\treturn updatedPod, nil\n215: \t}\n216: \n217: \treturn pod, nil\n218: }\n219: \n220: func (r *AgentRuntimeReconciler) getSandboxPod(namespace, arName string) (*corev1.Pod, error) {\n221: \tpodName := fmt.Sprintf(\"sandbox-%s\", arName)\n222: \n223: \tpod, err := r.podLister.Pods(namespace).Get(podName)\n224: \tif err == nil {\n225: \t\treturn pod, nil\n226: \t}\n227: \n228: \tif !k8s_errors.IsNotFound(err) {\n229: \t\treturn nil, err\n230: \t}\n231: \n232: \tselector := labels.SelectorFromSet(labels.Set{\n233: \t\t\"agentcube.volcano.sh/runtime\": arName,\n234: \t})\n235: \n236: \tpodList, err := r.podLister.Pods(namespace).List(selector)\n237: \tif err != nil {\n238: \t\treturn nil, err\n239: \t}\n240: \n241: \tif len(podList) > 0 {\n242: \t\treturn podList[0], nil\n243: \t}\n244: \n245: \treturn nil, k8s_errors.NewNotFound(corev1.Resource(\"pods\"), podName)\n246: }\n247: \n248: func (r *AgentRuntimeReconciler) EnqueueAgentRuntime(obj interface{}) {\n249: \tenqueueObject(r.workqueue, obj)\n250: }\n251: \n252: func (r *AgentRuntimeReconciler) EnqueueUpdate(oldObj, newObj interface{}) {\n253: \tenqueueUpdate(r.workqueue, oldObj, newObj)\n254: }\n255: \n256: func (r *AgentRuntimeReconciler) EnqueueDelete(obj interface{}) {\n257: \tenqueueDelete(r.workqueue, obj)\n258: }\n259: \n260: func (r *AgentRuntimeReconciler) EnqueueOwnedPod(obj interface{}) {\n261: \tpod, ok := obj.(*corev1.Pod)\n262: \tif !ok {\n263: \t\treturn\n264: \t}\n265: \n266: \townerRef := metav1.GetControllerOf(pod)\n267: \tif ownerRef == nil || ownerRef.Kind != \"AgentRuntime\" {\n268: \t\treturn\n269: \t}\n270: \n271: \tr.workqueue.Add(Request{\n272: \t\tNamespace: pod.Namespace,\n273: \t\tName:      ownerRef.Name,\n274: \t})\n275: }\n276: \n277: func (r *AgentRuntimeReconciler) EnqueueOwnedPodUpdate(oldObj, newObj interface{}) {\n278: \tnewPod, ok := newObj.(*corev1.Pod)\n279: \tif !ok {\n280: \t\treturn\