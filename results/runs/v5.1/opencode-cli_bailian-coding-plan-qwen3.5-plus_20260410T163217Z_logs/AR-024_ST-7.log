{"type":"tool_use","timestamp":1775871233431,"sessionID":"ses_285d39fe0ffe8cyNpk4kUoVqPn","part":{"id":"prt_d7a2c81aa001hXWcBCFu6cH5ng","messageID":"msg_d7a2c7821001JRwUsad3jYerb7","sessionID":"ses_285d39fe0ffe8cyNpk4kUoVqPn","type":"tool","tool":"read","callID":"toolu_0ca2306f3bfb4091a224b721","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Service for Docker operations.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: import time\n7: from pathlib import Path\n8: from typing import Any, Dict, Optional\n9: \n10: import docker\n11: from docker.errors import APIError, DockerException\n12: \n13: logger = logging.getLogger(__name__)\n14: \n15: \n16: class DockerService:\n17:     \"\"\"Service for Docker operations including build, push, and image management.\n18:     \n19:     This class provides a unified interface for Docker operations:\n20:     - Building images from Dockerfiles\n21:     - Pushing images to registries with authentication\n22:     - Getting image information and metadata\n23:     - Tagging and removing images\n24:     - Checking Docker daemon availability\n25:     \n26:     Attributes:\n27:         verbose: Enable verbose logging if True\n28:         \n29:     Example:\n30:         >>> from agentcube.services.docker_service import DockerService\n31:         >>> docker = DockerService(verbose=True)\n32:         >>> if docker.check_docker_available():\n33:         ...     result = docker.build_image(\n34:         ...         dockerfile_path=Path(\"Dockerfile\"),\n35:         ...         context_path=Path(\".\"),\n36:         ...         image_name=\"my-agent\",\n37:         ...         tag=\"v1.0.0\"\n38:         ...     )\n39:         >>> print(result[\"image_id\"])\n40:     \"\"\"\n41: \n42:     def __init__(self, verbose: bool = False) -> None:\n43:         \"\"\"Initialize the Docker service.\n44:         \n45:         Args:\n46:             verbose: Enable verbose logging if True. When enabled, detailed\n47:                 operation logs are written to stderr for debugging purposes.\n48:                 \n49:         Raises:\n50:             ImportError: If docker package is not installed\n51:             \n52:         Example:\n53:             >>> # Basic initialization\n54:             >>> docker = DockerService()\n55:             >>> \n56:             >>> # Verbose mode for debugging\n57:             >>> docker_verbose = DockerService(verbose=True)\n58:         \"\"\"\n59:         self.verbose = verbose\n60:         self._client: Optional[docker.DockerClient] = None\n61:         \n62:         if verbose:\n63:             logging.basicConfig(level=logging.DEBUG)\n64:         \n65:         try:\n66:             self._client = docker.from_env()\n67:             logger.debug(\"Docker client initialized successfully\")\n68:         except DockerException as e:\n69:             logger.warning(f\"Docker daemon not available: {e}\")\n70:             self._client = None\n71: \n72:     @property\n73:     def client(self) -> docker.DockerClient:\n74:         \"\"\"Get or create Docker client.\n75:         \n76:         Returns:\n77:             Docker client instance for interacting with Docker daemon\n78:             \n79:         Raises:\n80:             RuntimeError: If Docker is not available (daemon not running,\n81:                 Docker not installed, or connection refused)\n82:                 \n83:         Example:\n84:             >>> docker = DockerService()\n85:             >>> client = docker.client  # Creates client if not exists\n86:             >>> version = client.version()\n87:         \"\"\"\n88:         if self._client is None:\n89:             try:\n90:                 self._client = docker.from_env()\n91:             except DockerException as e:\n92:                 raise RuntimeError(f\"Docker is not available: {e}\") from e\n93:         return self._client\n94: \n95:     def check_docker_available(self) -> bool:\n96:         \"\"\"Check if Docker daemon is available and running.\n97:         \n98:         This method performs a non-intrusive ping test to verify that the\n99:         Docker daemon is accessible. It returns False gracefully if Docker\n100:         is not installed, not running, or not accessible due to permissions.\n101:         \n102:         Returns:\n103:             True if Docker daemon is available and responding, False otherwise.\n104:             False indicates that Docker operations will fail.\n105:             \n106:         Example:\n107:             >>> docker = DockerService()\n108:             >>> if docker.check_docker_available():\n109:             ...     print(\"Docker is ready\")\n110:             ... else:\n111:             ...     print(\"Please start Docker daemon\")\n112:         \"\"\"\n113:         if self._client is None:\n114:             logger.debug(\"Docker client not initialized\")\n115:             return False\n116:         \n117:         try:\n118:             self._client.ping()\n119:             logger.debug(\"Docker daemon is available\")\n120:             return True\n121:         except (DockerException, APIError) as e:\n122:             logger.debug(f\"Docker daemon not available: {e}\")\n123:             return False\n124: \n125:     def build_image(\n126:         self,\n127:         dockerfile_path: Path,\n128:         context_path: Path,\n129:         image_name: str,\n130:         tag: str = \"latest\",\n131:         build_args: Optional[Dict[str, str]] = None,\n132:     ) -> Dict[str, str]:\n133:         \"\"\"Build a Docker image from a Dockerfile.\n134:         \n135:         This method builds a Docker image using the specified Dockerfile and\n136:         build context. It supports custom build arguments and tracks build\n137:         time for performance monitoring. The built image can be used locally\n138:         or pushed to a registry.\n139:         \n140:         Args:\n141:             dockerfile_path: Path to the Dockerfile. Must be a valid file\n142:                 that exists and contains valid Dockerfile syntax.\n143:             context_path: Path to the build context directory. All files\n144:                 referenced in the Dockerfile (COPY, ADD) must be under this\n145:                 directory.\n146:             image_name: Name for the built image (e.g., \"my-agent\",\n147:                 \"registry.example.com/my-agent\").\n148:             tag: Image tag (default: \"latest\"). Common tags include version\n149:                 numbers (\"v1.0.0\"), environment names (\"dev\", \"prod\"), or\n150:                 git commits (\"abc123\").\n151:             build_args: Optional dictionary of build arguments to pass to\n152:                 the Docker build process. Keys and values must be strings.\n153:                 Example: {\"VERSION\": \"1.0.0\", \"ENV\": \"production\"}\n154:                 \n155:         Returns:\n156:             Dictionary containing:\n157:                 - image_name: Full image name with tag (e.g., \"my-agent:v1.0.0\")\n158:                 - image_id: Short image ID (12 hexadecimal characters)\n159:                 - image_size: Human-readable size (e.g., \"125.50 MB\")\n160:                 - build_time: Build duration in seconds (e.g., \"15.23s\")\n161:                 \n162:         Raises:\n163:             RuntimeError: If Docker is not available, Dockerfile doesn't exist,\n164:                 or build fails. The exception message includes details about\n165:                 the failure cause.\n166:                 \n167:         Example:\n168:             >>> from pathlib import Path\n169:             >>> docker = DockerService()\n170:             >>> result = docker.build_image(\n171:             ...     dockerfile_path=Path(\"Dockerfile\"),\n172:             ...     context_path=Path(\".\"),\n173:             ...     image_name=\"my-agent\",\n174:             ...     tag=\"v1.0.0\",\n175:             ...     build_args={\"VERSION\": \"1.0.0\"}\n176:             ... )\n177:             >>> print(f\"Built {result['image_name']} ({result['image_size']})\")\n178:         \"\"\"\n179:         if not self.check_docker_available():\n180:             raise RuntimeError(\"Docker is not available or not running. \"\n181:                              \"Please ensure Docker daemon is running: sudo systemctl start docker\")\n182: \n183:         logger.info(f\"Building image {image_name}:{tag} from {dockerfile_path}\")\n184:         full_image_name = f\"{image_name}:{tag}\"\n185:         start_time = time.time()\n186: \n187:         try:\n188:             image, build_logs = self.client.images.build(\n189:                 path=str(context_path),\n190:                 dockerfile=str(dockerfile_path),\n191:                 tag=full_image_name,\n192:                 buildargs=build_args or {},\n193:                 rm=True,\n194:                 forcerm=True,\n195:             )\n196: \n197:             build_time = time.time() - start_time\n198:             logger.info(f\"Image built successfully in {build_time:.2f}s\")\n199: \n200:             image_info = self._get_image_info(full_image_name)\n201:             image_info[\"build_time\"] = f\"{build_time:.2f}s\"\n202: \n203:             if self.verbose and build_logs:\n204:                 for log in build_logs:\n205:                     if isinstance(log, dict) and \"stream\" in log:\n206:                         stream_value = log.get(\"stream\")\n207:                         if isinstance(stream_value, str):\n208:                             logger.debug(f\"Build log: {stream_value.strip()}\")\n209: \n210:             return image_info\n211: \n212:         except APIError as e:\n213:             logger.error(f\"Docker build API error: {e}\")\n214:             raise RuntimeError(f\"Failed to build Docker image: API error - {e}\") from e\n215:         except DockerException as e:\n216:             logger.error(f\"Docker build failed: {e}\")\n217:             raise RuntimeError(f\"Failed to build Docker image: {e}\") from e\n218:         except Exception as e:\n219:             logger.error(f\"Unexpected error during build: {e}\")\n220:             raise RuntimeError(f\"Failed to build Docker image: {e}\") from e\n221: \n222:     def get_image_info(self, image_name: str) -> Dict[str, str]:\n223:         \"\"\"Get information about a Docker image.\n224:         \n225:         This method retrieves metadata about a Docker image including its ID,\n226:         size, and other attributes. It's useful for verifying builds, checking\n227:         image sizes, or getting the image ID for tagging/pushing operations.\n228:         \n229:         Args:\n230:             image_name: Name of the Docker image (e.g., \"my-agent:latest\" or\n231:                 \"registry.example.com/my-agent:v1.0.0\"). The image must exist\n232:                 locally.\n233:                 \n234:         Returns:\n235:             Dictionary containing:\n236:                 - image_name: Image name as provided\n237:                 - image_id: Short image ID (12 hexadecimal characters)\n238:                 - image_size: Human-readable size (e.g., \"125.50 MB\")\n239:                 - size_bytes: Size in bytes as string (e.g., \"131072000\")\n240:             Returns empty dict if image is not found or an error occurs.\n241:             \n242:         Example:\n243:             >>> docker = DockerService()\n244:             >>> info = docker.get_image_info(\"my-agent:v1.0.0\")\n245:             >>> if info:\n246:             ...     print(f\"Image {info['image_id']} is {info['image_size']}\")\n247:             ... else:\n248:             ...     print(\"Image not found\")\n249:         \"\"\"\n250:         return self._get_image_info(image_name)\n251: \n252:     def _get_image_info(self, image_name: str) -> Dict[str, str]:\n253:         \"\"\"Internal method to get image details.\n254:         \n255:         This is the internal implementation for retrieving image metadata.\n256:         It handles all error cases gracefully and returns an empty dict\n257:         when the image cannot be found or inspected.\n258:         \n259:         Args:\n260:             image_name: Name of the Docker image to inspect\n261:             \n262:         Returns:\n263:             Dictionary with image details (see get_image_info) or empty dict\n264:             if image not found or an error occurs.\n265:             \n266:         Note:\n267:             This method is internal and may change without notice. Use\n268:             get_image_info() for external access.\n269:         \"\"\"\n270:         try:\n271:             image = self.client.images.get(image_name)\n272:             attrs = image.attrs\n273: \n274:             image_id = attrs[\"Id\"].split(\":\")[-1][:12]\n275:             size_bytes = attrs.get(\"Size\", 0)\n276: \n277:             return {\n278:                 \"image_name\": image_name,\n279:                 \"image_id\": image_id,\n280:                 \"image_size\": self._format_size(size_bytes),\n281:                 \"size_bytes\": str(size_bytes),\n282:             }\n283: \n284:         except (DockerException, APIError) as e:\n285:             logger.warning(f\"Failed to get image info for {image_name}: {e}\")\n286:             return {}\n287:         except KeyError as e:\n288:             logger.warning(f\"Unexpected image attributes structure: {e}\")\n289:             return {}\n290: \n291:     def _format_size(self, size_bytes: int) -> str:\n292:         \"\"\"Format size in human-readable format.\n293:         \n294:         Converts a size in bytes to a human-readable string with appropriate\n295:         units (B, KB, MB, GB, or TB). The result is formatted to 2 decimal\n296:         places for consistency.\n297:         \n298:         Args:\n299:             size_bytes: Size in bytes. Must be non-negative. Large values\n300:                 (over 1TB) are supported but rare for Docker images.\n301:                 \n302:         Returns:\n303:             Human-readable size string with unit. Examples:\n304:                 - 500 -> \"500.00 B\"\n305:                 - 1024 -> \"1.00 KB\"\n306:                 - 1048576 -> \"1.00 MB\"\n307:                 - 1073741824 -> \"1.00 GB\"\n308:                 \n309:         Example:\n310:             >>> docker = DockerService()\n311:             >>> docker._format_size(125000000)\n312:             '119.21 MB'\n313:         \"\"\"\n314:         size_float: float = float(size_bytes)\n315:         for unit in [\"B\", \"KB\", \"MB\", \"GB\"]:\n316:             if size_float < 1024:\n317:                 return f\"{size_float:.2f} {unit}\"\n318:             size_float /= 1024\n319:         return f\"{size_float:.2f} TB\"\n320: \n321:     def push_image(\n322:         self,\n323:         image_name: str,\n324:         registry_url: Optional[str] = None,\n325:         username: Optional[str] = None,\n326:         password: Optional[str] = None,\n327:     ) -> Dict[str, str]:\n328:         \"\"\"Push a Docker image to a registry.\n329:         \n330:         This method pushes a locally-built Docker image to a container registry.\n331:         It supports both public registries (Docker Hub) and private registries\n332:         with authentication. If a registry URL is provided, the image is\n333:         automatically tagged before pushing.\n334:         \n335:         Args:\n336:             image_name: Local image name (e.g., \"my-agent:latest\"). The image\n337:                 must exist locally before pushing.\n338:             registry_url: Registry URL (e.g., \"registry.example.com\" or\n339:                 \"gcr.io/my-project\"). If None, pushes to Docker Hub. The URL\n340:                 should not include the protocol (https://).\n341:             username: Registry username for authentication. Required for\n342:                 private registries. Optional for Docker Hub public repos.\n343:             password: Registry password for authentication. Should be provided\n344:                 via environment variable or secret management in production.\n345:                 \n346:         Returns:\n347:             Dictionary containing:\n348:                 - pushed_image: Full pushed image name including registry\n349:                     (e.g., \"registry.example.com/my-agent:v1.0.0\")\n350:                 - push_time: Push duration in seconds (e.g., \"45.67s\")\n351:                 \n352:         Raises:\n353:             RuntimeError: If Docker is not available, image doesn't exist,\n354:                 authentication fails, or push fails. The exception message\n355:                 includes specific error details from Docker.\n356:                 \n357:         Example:\n358:             >>> import os\n359:             >>> docker = DockerService()\n360:             >>> result = docker.push_image(\n361:             ...     image_name=\"my-agent:v1.0.0\",\n362:             ...     registry_url=\"registry.example.com\",\n363:             ...     username=os.getenv(\"REGISTRY_USER\"),\n364:             ...     password=os.getenv(\"REGISTRY_PASS\")\n365:             ... )\n366:             >>> print(f\"Pushed {result['pushed_image']} in {result['push_time']}\")\n367:             \n368:         Note:\n369:             - For Docker Hub, use username \"docker login\" credentials\n370:             - For private registries, ensure CA certificates are installed\n371:             - Large images may take several minutes to push\n372:             - Network interruptions will cause the push to fail\n373:         \"\"\"\n374:         if not self.check_docker_available():\n375:             raise RuntimeError(\"Docker is not available or not running\")\n376: \n377:         start_time = time.time()\n378: \n379:         target_image = image_name\n380:         if registry_url:\n381:             target_image = f\"{registry_url}/{image_name}\"\n382:             logger.info(f\"Tagging image for registry: {target_image}\")\n383:             self._tag_image_sdk(image_name, target_image)\n384: \n385:         if username and password:\n386:             logger.info(f\"Authenticating with registry: {registry_url or 'default'}\")\n387:             self._docker_login_sdk(registry_url, username, password)\n388:         elif registry_url and not username:\n389:             logger.warning(\"Registry URL provided but no credentials. \"\n390:                          \"Push may fail for private registries.\")\n391: \n392:         logger.info(f\"Pushing image {target_image}\")\n393: \n394:         try:\n395:             push_logs = self.client.images.push(target_image, stream=True, decode=True)\n396: \n397:             for line in push_logs:\n398:                 if \"error\" in line:\n399:                     error_msg = line.get(\"error\", \"Unknown error\")\n400:                     logger.error(f\"Push error: {error_msg}\")\n401:                     raise RuntimeError(f\"Failed to push image: {error_msg}\")\n402:                 if \"status\" in line:\n403:                     status = line[\"status\"]\n404:                     if self.verbose:\n405:                         progress = line.get(\"progress\", \"\")\n406:                         logger.debug(f\"Push status: {status} {progress}\")\n407:                     elif status == \"Pushed\":\n408:                         logger.info(f\"Layer pushed: {line.get('id', 'unknown')}\")\n409: \n410:             push_time = time.time() - start_time\n411:             logger.info(f\"Image pushed successfully in {push_time:.2f}s\")\n412: \n413:             return {\n414:                 \"pushed_image\": target_image,\n415:                 \"push_time\": f\"{push_time:.2f}s\",\n416:             }\n417: \n418:         except APIError as e:\n419:             logger.error(f\"Docker push API error: {e}\")\n420:             raise RuntimeError(f\"Failed to push Docker image: API error - {e}\") from e\n421:         except DockerException as e:\n422:             logger.error(f\"Docker push failed: {e}\")\n423:             raise RuntimeError(f\"Failed to push Docker image: {e}\") from e\n424: \n425:     def _docker_login_sdk(self, registry: Optional[str], username: str, password: str) -> None:\n426:         \"\"\"Log in to Docker registry.\n427:         \n428:         This method authenticates with a Docker registry using the provided\n429:         credentials. The login session is stored in Docker's configuration\n430:         and persists for subsequent operations.\n431:         \n432:         Args:\n433:             registry: Registry URL (e.g., \"registry.example.com\"). Use None\n434:                 or omit for Docker Hub (https://index.docker.io/v1/).\n435:             username: Registry username. Must be a valid account with push\n436:                 permissions for the target repository.\n437:             password: Registry password or access token. For security, use\n438:                 access tokens instead of account passwords when available.\n439:                 \n440:         Raises:\n441:             RuntimeError: If authentication fails due to invalid credentials,\n442:                 network issues, or registry unavailability. The exception\n443:                 message includes the specific error from Docker.\n444:                 \n445:         Example:\n446:             >>> docker = DockerService()\n447:             >>> docker._docker_login_sdk(\n448:             ...     registry=\"registry.example.com\",\n449:             ...     username=\"myuser\",\n450:             ...     password=\"mytoken\"\n451:             ... )\n452:             \n453:         Note:\n454:             - Credentials are stored in ~/.docker/config.json\n455:             - Use access tokens instead of passwords when possible\n456:             - Logout with `docker logout` when done\n457:         \"\"\"\n458:         try:\n459:             registry_url = registry or \"https://index.docker.io/v1/\"\n460:             self.client.login(\n461:                 username=username,\n462:                 password=password,\n463:                 registry=registry_url,\n464:             )\n465:             logger.info(f\"Successfully logged in to registry: {registry or 'Docker Hub'}\")\n466:         except APIError as e:\n467:             logger.error(f\"Docker login failed: {e}\")\n468:             raise RuntimeError(f\"Failed to log in to Docker registry: {e}\") from e\n469:         except DockerException as e:\n470:             logger.error(f\"Docker login failed: {e}\")\n471:             raise RuntimeError(f\"Failed to log in to Docker registry: {e}\") from e\n472: \n473:     def _tag_image_sdk(self, source_image: str, target_image: str) -> None:\n474:         \"\"\"Tag a Docker image.\n475:         \n476:         This method creates a new tag for an existing Docker image. Tagging\n477:         is commonly used to rename images for registry pushes or to create\n478:         multiple tags for the same image (e.g., \"v1.0.0\" and \"latest\").\n479:         \n480:         Args:\n481:             source_image: Source image name (e.g., \"my-agent:latest\"). The\n482:                 image must exist locally.\n483:             target_image: Target image name (e.g., \"registry.example.com/my-agent:v1.0.0\").\n484:                 This is the new tag that will be created.\n485:                 \n486:         Raises:\n487:             RuntimeError: If the source image doesn't exist or tagging fails.\n488:                 The exception message includes details about the failure.\n489:                 \n490:         Example:\n491:             >>> docker = DockerService()\n492:             >>> docker._tag_image_sdk(\n493:             ...     source_image=\"my-agent:latest\",\n494:             ...     target_image=\"registry.example.com/my-agent:v1.0.0\"\n495:             ... )\n496:         \"\"\"\n497:         try:\n498:             image = self.client.images.get(source_image)\n499:             image.tag(target_image, force=True)\n500:             logger.info(f\"Tagged {source_image} as {target_image}\")\n501:         except APIError as e:\n502:             logger.error(f\"Docker tag failed: {e}\")\n503:             raise RuntimeError(f\"Failed to tag Docker image: {e}\") from e\n504:         except DockerException as e:\n505:             logger.error(f\"Docker tag failed: {e}\")\n506:             raise RuntimeError(f\"Failed to tag Docker image: {e}\") from e\n507: \n508:     def remove_image(self, image_name: str) -> bool:\n509:         \"\"\"Remove a Docker image.\n510:         \n511:         This method deletes a Docker image from the local system. It uses\n512:         force mode to remove the image even if it's referenced by stopped\n513:         containers. Use with caution as this operation is irreversible.\n514:         \n515:         Args:\n516:             image_name: Name of the image to remove (e.g., \"my-agent:latest\").\n517:                 The image must exist locally.\n518:                 \n519:         Returns:\n520:             True if the image was successfully removed, False if the image\n521:             doesn't exist or removal fails. False is returned gracefully\n522:             instead of raising an exception to simplify cleanup operations.\n523:             \n524:         Example:\n525:             >>> docker = DockerService()\n526:             >>> if docker.remove_image(\"my-agent:old\"):\n527:             ...     print(\"Cleanup successful\")\n528:             ... else:\n529:             ...     print(\"Image not found or removal failed\")\n530:         \"\"\"\n531:         try:\n532:             self.client.images.remove(image_name, force=True)\n533:             logger.info(f\"Removed image {image_name}\")\n534:             return True\n535:         except APIError as e:\n536:             logger.warning(f\"Failed to remove image {image_name}: {e}\")\n537:             return False\n538:         except DockerException as e:\n539:             logger.warning(f\"Failed to remove image {image_name}: {e}\")\n540:             return False\n\n(End of file - total 540 lines)\n</content>","metadata":{"preview":"\"\"\"Service for Docker operations.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport docker\nfrom docker.errors import APIError, DockerException\n\nlogger = logging.getLogger(__name__)\n\n\nclass DockerService:\n    \"\"\"Service for Docker operations including build, push, and image management.\n    \n    This class provides a unified interface for Docker operations:\n    - Building images from Dockerfiles","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/docker_service.py","time":{"start":1775871233388,"end":1775871233428}}}}
