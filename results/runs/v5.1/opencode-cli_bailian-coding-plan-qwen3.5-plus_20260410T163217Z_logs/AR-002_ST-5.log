ftware\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"k8s.io/apimachinery/pkg/util/validation/field\"\n)\n\nfunc TestValidateAgentRuntime_Valid(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tContainer: ContainerSpec{\n\t\t\t\tImage: \"nginx:latest\",\n\t\t\t},\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tCPU:    \"1\",\n\t\t\t\tMemory: \"1Gi\",\n\t\t\t},\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t\tImage:   \"volcanosh/picod:latest\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs, \"Expected no errors for valid AgentRuntime\")\n}\n\nfunc TestValidateAgentRuntime_InvalidImage(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tContainer: ContainerSpec{\n\t\t\t\tImage: \"invalid image!@#\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"image\")\n}\n\nfunc TestValidateAgentRuntime_InvalidCPU(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tCPU: \"invalid-cpu\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tfieldErr := errs[0]\n\tassert.Equal(t, field.ErrorTypeInvalid, fieldErr.Type)\n\tassert.Contains(t, fieldErr.Field, \"cpu\")\n}\n\nfunc TestValidateAgentRuntime_InvalidMemory(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tMemory: \"invalid-memory\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tfieldErr := errs[0]\n\tassert.Equal(t, field.ErrorTypeInvalid, fieldErr.Type)\n\tassert.Contains(t, fieldErr.Field, \"memory\")\n}\n\nfunc TestValidateAgentRuntime_InvalidCIDR(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tNetwork: &NetworkPolicy{\n\t\t\t\tEgressRules: []NetworkRule{\n\t\t\t\t\t{CIDR: \"invalid-cidr\"},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"cidr\")\n}\n\nfunc TestValidateAgentRuntime_InvalidURL(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tLifecycle: &LifecycleHook{\n\t\t\t\tPreStart: \"not-a-url\",\n\t\t\t\tPostStop: \"also-not-url\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"preStart\")\n\tassert.Contains(t, errs.ToAggregate().Error(), \"postStop\")\n}\n\nfunc TestValidateAgentRuntime_ValidCIDR(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tNetwork: &NetworkPolicy{\n\t\t\t\tEgressRules: []NetworkRule{\n\t\t\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{80, 443}},\n\t\t\t\t},\n\t\t\t\tIngressRules: []NetworkRule{\n\t\t\t\t\t{CIDR: \"192.168.0.0/16\"},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs)\n}\n\nfunc TestValidateAgentRuntime_ValidLifecycleHooks(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tLifecycle: &LifecycleHook{\n\t\t\t\tPreStart: \"https://example.com/prestart\",\n\t\t\t\tPostStop: \"http://example.com/poststop\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs)\n}\n\nfunc TestValidateAgentRuntime_NilFields(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources:       nil,\n\t\t\tNetwork:         nil,\n\t\t\tLifecycle:       nil,\n\t\t\tCodeInterpreter: nil,\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs, \"Nil fields should not cause errors\")\n}\n\nfunc TestValidateAgentRuntimeStatusUpdate_ValidTransitions(t *testing.T) {\n\ttestCases := []struct {\n\t\toldPhase AgentRuntimePhase\n\t\tnewPhase AgentRuntimePhase\n\t\tvalid    bool\n\t}{\n\t\t{\"\", AgentRuntimePhasePending, true},\n\t\t{AgentRuntimePhasePending, AgentRuntimePhaseRunning, true},\n\t\t{AgentRuntimePhasePending, AgentRuntimePhaseFailed, true},\n\t\t{AgentRuntimePhasePending, AgentRuntimePhaseTerminating, true},\n\t\t{AgentRuntimePhaseRunning, AgentRuntimePhaseFailed, true},\n\t\t{AgentRuntimePhaseRunning, AgentRuntimePhaseTerminating, true},\n\t\t{AgentRuntimePhaseTerminating, AgentRuntimePhaseTerminating, true},\n\t\t{AgentRuntimePhaseRunning, AgentRuntimePhasePending, false},\n\t\t{AgentRuntimePhaseFailed, AgentRuntimePhaseRunning, false},\n\t}\n\n\tfor _, tc := range testCases {\n\t\toldObj := &AgentRuntime{Status: AgentRuntimeStatus{Phase: tc.oldPhase}}\n\t\tnewObj := &AgentRuntime{Status: AgentRuntimeStatus{Phase: tc.newPhase}}\n\n\t\terrs := ValidateAgentRuntimeStatusUpdate(oldObj, newObj)\n\n\t\tif tc.valid {\n\t\t\tassert.Empty(t, errs, \"Expected valid transition from %s to %s\", tc.oldPhase, tc.newPhase)\n\t\t} else {\n\t\t\tassert.NotEmpty(t, errs, \"Expected invalid transition from %s to %s\", tc.oldPhase, tc.newPhase)\n\t\t}\n\t}\n}\n\nfunc TestValidateAgentRuntimePhase(t *testing.T) {\n\tvalidPhases := []AgentRuntimePhase{\n\t\t\"\",\n\t\tAgentRuntimePhasePending,\n\t\tAgentRuntimePhaseRunning,\n\t\tAgentRuntimePhaseFailed,\n\t\tAgentRuntimePhaseTerminating,\n\t}\n\n\tfor _, phase := range validPhases {\n\t\terr := ValidateAgentRuntimePhase(phase)\n\t\tassert.NoError(t, err, \"Phase %q should be valid\", phase)\n\t}\n\n\tinvalidPhase := AgentRuntimePhase(\"Invalid\")\n\terr := ValidateAgentRuntimePhase(invalidPhase)\n\tassert.Error(t, err, \"Invalid phase should return error\")\n}\n","after":"/*\nCopyright 2026 The AgentCube Aut