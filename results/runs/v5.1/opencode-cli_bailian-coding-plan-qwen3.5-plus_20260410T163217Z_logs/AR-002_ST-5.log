qual(t, \"\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_CodeInterpreter_Resources(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled:   true,\n\t\t\t\tResources: nil,\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.NotNil(t, obj.Spec.CodeInterpreter)\n}","oldString":"func TestSetDefaults_AgentRuntime_ExistingPhase(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tPhase: AgentRuntimePhaseRunning,\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, AgentRuntimePhaseRunning, obj.Status.Phase)\n}"},"output":"Edit applied successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/register.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/register.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/defaults.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/defaults_test.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types_test.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation_test.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/