rpreterEnabled(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"volcanosh/picod:latest\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_AgentRuntime_CodeInterpreterDisabled(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: false,\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_AgentRuntime_CodeInterpreterCustomImage(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t\tImage:   \"custom/picod:v1.0\",\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"custom/picod:v1.0\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_AgentRuntime_ExistingPhase(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tPhase: AgentRuntimePhaseRunning,\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, AgentRuntimePhaseRunning, obj.Status.Phase)\n}\n","after":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestSetDefaults_AgentRuntime_EmptyResources(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.NotNil(t, obj.Spec.Resources)\n\tassert.NotNil(t, obj.Spec.CodeInterpreter)\n\tassert.Equal(t, AgentRuntimePhasePending, obj.Status.Phase)\n}\n\nfunc TestSetDefaults_AgentRuntime_PreservesExistingResources(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tCPU: \"1\",\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"1\", obj.Spec.Resources.CPU)\n}\n\nfunc TestSetDefaults_AgentRuntime_CodeInterpreterEnabled(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"volcanosh/picod:latest\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_AgentRuntime_CodeInterpreterDisabled(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: false,\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_AgentRuntime_CodeInterpreterCustomImage(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t\tImage:   \"custom/picod:v1.0\",\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"custom/picod:v1.0\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_AgentRuntime_ExistingPhase(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tPhase: AgentRuntimePhaseRunning,\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, AgentRuntimePhaseRunning, obj.Status.Phase)\n}\n\nfunc TestSetDefaults_CodeInterpreter_NilSpec(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: nil,\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.NotNil(t, obj.Spec.CodeInterpreter)\n}\n\nfunc TestSetDefaults_CodeInterpreter_EnabledNoImage(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"volcanosh/picod:latest\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_CodeInterpreter_EnabledWithImage(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t\tImage:   \"custom/picod:v2.0\",\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"custom/picod:v2.0\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_CodeInterpreter_Disabled(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: false,\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.Equal(t, \"\", obj.Spec.CodeInterpreter.Image)\n}\n\nfunc TestSetDefaults_CodeInterpreter_Resources(t *testing.T) {\n\tobj := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled:   true,\n\t\t\t\tResources: nil,\n\t\t\t},\n\t\t},\n\t}\n\n\tSetDefaults_AgentRuntime(obj)\n\n\tassert.NotNil(t, obj.Spec.CodeInterpreter)\n}\n","additions":70,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/defaults_test.go","time":{"start":1775840081636,"end":1775840081821}}}}
