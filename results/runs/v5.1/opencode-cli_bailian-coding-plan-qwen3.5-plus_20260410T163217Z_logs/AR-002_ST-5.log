ied := original.DeepCopy()\n+\tassert.Equal(t, original.Enabled, copied.Enabled)\n+\tassert.Equal(t, original.Image, copied.Image)\n+\tassert.Equal(t, original.Resources.CPU, copied.Resources.CPU)\n+\n+\tcopied.Enabled = false\n+\tassert.NotEqual(t, original.Enabled, copied.Enabled)\n+}\n+\n+func TestCodeInterpreterSpecNilResources(t *testing.T) {\n+\toriginal := &CodeInterpreterSpec{\n+\t\tEnabled:   true,\n+\t\tImage:     \"volcanosh/picod:latest\",\n+\t\tResources: nil,\n+\t}\n+\n+\tcopied := original.DeepCopy()\n+\tassert.Equal(t, original.Enabled, copied.Enabled)\n+\tassert.Equal(t, original.Image, copied.Image)\n+\tassert.Nil(t, copied.Resources)\n+}\n+\n+func TestCodeInterpreterSpecSerialization(t *testing.T) {\n+\tci := &CodeInterpreterSpec{\n+\t\tEnabled: true,\n+\t\tImage:   \"volcanosh/picod:v1.0\",\n+\t\tResources: &ResourceQuota{\n+\t\t\tCPU:     \"1\",\n+\t\t\tMemory:  \"1Gi\",\n+\t\t\tStorage: \"5Gi\",\n+\t\t},\n+\t}\n+\n+\tdata, err := json.Marshal(ci)\n+\trequire.NoError(t, err)\n+\n+\tvar deserialized CodeInterpreterSpec\n+\terr = json.Unmarshal(data, &deserialized)\n+\trequire.NoError(t, err)\n+\n+\tassert.Equal(t, ci.Enabled, deserialized.Enabled)\n+\tassert.Equal(t, ci.Image, deserialized.Image)\n+\tassert.Equal(t, ci.Resources.CPU, deserialized.Resources.CPU)\n+}\n+\n+func TestCodeInterpreterSpecDefaultValues(t *testing.T) {\n+\tci := &CodeInterpreterSpec{\n+\t\tEnabled:   false,\n+\t\tImage:     \"\",\n+\t\tResources: nil,\n+\t}\n+\n+\tdata, err := json.Marshal(ci)\n+\trequire.NoError(t, err)\n+\n+\tvar deserialized CodeInterpreterSpec\n+\terr = json.Unmarshal(data, &deserialized)\n+\trequire.NoError(t, err)\n+\n+\tassert.False(t, deserialized.Enabled)\n+\tassert.Empty(t, deserialized.Image)\n+\tassert.Nil(t, deserialized.Resources)\n+}\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types_test.go","before":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"encoding/json\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n)\n\nfunc TestAgentRuntimeDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tContainer: ContainerSpec{\n\t\t\t\tImage: \"nginx:latest\",\n\t\t\t},\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tCPU:    \"1\",\n\t\t\t\tMemory: \"1Gi\",\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\tassert.Equal(t, original.Name, copied.Name)\n\tassert.Equal(t, original.Spec.Container.Image, copied.Spec.Container.Image)\n\n\tcopied.Name = \"modified\"\n\tassert.NotEqual(t, original.Name, copied.Name)\n}\n\nfunc TestAgentRuntimeListDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntimeList\",\n\t\t},\n\t\tItems: []AgentRuntime{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"runtime-1\",\n\t\t\t\t},\n\t\t\t},\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"runtime-2\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\tassert.Len(t, copied.Items, 2)\n\tassert.Equal(t, original.Items[0].Name, copied.Items[0].Name)\n\n\tcopied.Items[0].Name = \"modified\"\n\tassert.NotEqual(t, original.Items[0].Name, copied.Items[0].Name)\n}\n\nfunc TestAgentRuntimeSerialization(t *testing.T) {\n\truntime := &AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"agent\",\n\t\t\t},\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tContainer: ContainerSpec{\n\t\t\t\tImage:   \"nginx:latest\",\n\t\t\t\tCommand: []string{\"/bin/sh\"},\n\t\t\t\tArgs:    []string{\"-c\", \"echo hello\"},\n\t\t\t},\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tCPU:     \"500m\",\n\t\t\t\tMemory:  \"512Mi\",\n\t\t\t\tStorage: \"1Gi\",\n\t\t\t},\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t\tImage:   \"volcanosh/picod:latest\",\n\t\t\t},\n\t\t},\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tPhase: AgentRuntimePhaseRunning,\n\t\t},\n\t}\n\n\tdata, err := json.Marshal(runtime)\n\trequire.NoError(t, err)\n\n\tvar deserialized AgentRuntime\n\terr = json.Unmarshal(data, &deserialized)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, runtime.Name, deserialized.Name)\n\tassert.Equal(t, runtime.Spec.Container.Image, deserialized.Spec.Container.Image)\n\tassert.Equal(t, runtime.Spec.Resources.CPU, deserialized.Spec.Resources.CPU)\n}\n\nfunc TestAgentRuntimeImplementsRuntimeObject(t *testing.T) {\n\tobj := &AgentRuntime{}\n\t_, ok := interface{}(obj).(runtime.Object)\n\tassert.True(t, ok, \"AgentRuntime should implement runtime.Object\")\n\n\tlist := &AgentRuntimeList{}\n\t_, ok = interface{}(list).(runtime.Object)\n\tassert.True(t, ok, \"AgentRuntimeList should implement runtime.Object\")\n}\n\nfunc TestAgentRuntimeConditionDeepCopy(t *testing.T) {\n\toriginal := AgentRuntimeCondition{\n\t\tType:   AgentRuntimeConditionReady,\n\t\tStatus: \"True\",\n\t}\n\n\tcopied := original.DeepCopy()\n\tassert.Equal(t, original.Type, copied.Type)\n\tassert.Equal(t, original.Status, copied.Status)\n}\n\nfunc TestResourceQuotaDeepCopy(t *testing.T) {\n\toriginal := &ResourceQuota{\n\t\tCPU:     \"1\",\n\t\tMemory:  \"2Gi\",\n\t\tStorage: \"10Gi\",\n\t}\n\n\tcopied := original.DeepCopy()\n\tassert.Equal(t, original.CPU, copied.CPU)\n\tassert.Equal(t, original.Memory, copied.Memory)\n\n\tcopied.CPU = \"2\"\n\tassert.NotEqual(t, original.CPU, copied.CPU)\n}\n\nfunc TestNetworkPolicyDeepCopy(t *testing.T) {\n\toriginal := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{80, 443}},\n\t\t},\n\t\tIngressRules: []NetworkRule{\n\t\t\t{CIDR: \"192.168.0.0/16\"},\n\t\t},\n\t}\n\n\tcopied := original.DeepCopy()\n\tassert.Len(t, copied.EgressRules, 1)\n\tassert.Len(t, copied.IngressRules, 1)\n\n\tcopied.EgressRules[0].CIDR = \"modified\"\n\tassert.NotEqual(t, original.EgressRules[0].CIDR, copied.EgressRules[0].CIDR)\n}\n","after":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"encoding/json\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t