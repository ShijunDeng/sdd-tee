ota{\n41: \t\t\t\tCPU: \"1\",\n42: \t\t\t},\n43: \t\t},\n44: \t}\n45: \n46: \tSetDefaults_AgentRuntime(obj)\n47: \n48: \tassert.Equal(t, \"1\", obj.Spec.Resources.CPU)\n49: }\n50: \n51: func TestSetDefaults_AgentRuntime_CodeInterpreterEnabled(t *testing.T) {\n52: \tobj := &AgentRuntime{\n53: \t\tSpec: AgentRuntimeSpec{\n54: \t\t\tCodeInterpreter: &CodeInterpreterSpec{\n55: \t\t\t\tEnabled: true,\n56: \t\t\t},\n57: \t\t},\n58: \t}\n59: \n60: \tSetDefaults_AgentRuntime(obj)\n61: \n62: \tassert.Equal(t, \"volcanosh/picod:latest\", obj.Spec.CodeInterpreter.Image)\n63: }\n64: \n65: func TestSetDefaults_AgentRuntime_CodeInterpreterDisabled(t *testing.T) {\n66: \tobj := &AgentRuntime{\n67: \t\tSpec: AgentRuntimeSpec{\n68: \t\t\tCodeInterpreter: &CodeInterpreterSpec{\n69: \t\t\t\tEnabled: false,\n70: \t\t\t},\n71: \t\t},\n72: \t}\n73: \n74: \tSetDefaults_AgentRuntime(obj)\n75: \n76: \tassert.Equal(t, \"\", obj.Spec.CodeInterpreter.Image)\n77: }\n78: \n79: func TestSetDefaults_AgentRuntime_CodeInterpreterCustomImage(t *testing.T) {\n80: \tobj := &AgentRuntime{\n81: \t\tSpec: AgentRuntimeSpec{\n82: \t\t\tCodeInterpreter: &CodeInterpreterSpec{\n83: \t\t\t\tEnabled: true,\n84: \t\t\t\tImage:   \"custom/picod:v1.0\",\n85: \t\t\t},\n86: \t\t},\n87: \t}\n88: \n89: \tSetDefaults_AgentRuntime(obj)\n90: \n91: \tassert.Equal(t, \"custom/picod:v1.0\", obj.Spec.CodeInterpreter.Image)\n92: }\n93: \n94: func TestSetDefaults_AgentRuntime_ExistingPhase(t *testing.T) {\n95: \tobj := &AgentRuntime{\n96: \t\tStatus: AgentRuntimeStatus{\n97: \t\t\tPhase: AgentRuntimePhaseRunning,\n98: \t\t},\n99: \t}\n100: \n101: \tSetDefaults_AgentRuntime(obj)\n102: \n103: \tassert.Equal(t, AgentRuntimePhaseRunning, obj.Status.Phase)\n104: }\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of