NotFound(t *testing.T) {\n48: \tmr, store := setupValkeyTest(t)\n49: \tdefer mr.Close()\n50: \tdefer store.Close()\n51: \n52: \t_, err := store.GetSandboxBySessionID(context.Background(), \"nonexistent\")\n53: \tif err != ErrNotFound {\n54: \t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n55: \t}\n56: }\n57: \n58: // TestValkeyStoreStoreSandboxNil tests storing a nil sandbox\n59: func TestValkeyStoreStoreSandboxNil(t *testing.T) {\n60: \tmr, store := setupValkeyTest(t)\n61: \tdefer mr.Close()\n62: \tdefer store.Close()\n63: \n64: \terr := store.StoreSandbox(context.Background(), nil)\n65: \tif err == nil {\n66: \t\tt.Fatal(\"expected error for nil sandbox, got nil\")\n67: \t}\n68: }\n69: \n70: // TestValkeyStoreStoreSandboxZeroExpiresAt tests storing a sandbox with zero ExpiresAt\n71: func TestValkeyStoreStoreSandboxZeroExpiresAt(t *testing.T) {\n72: \tmr, store := setupValkeyTest(t)\n73: \tdefer mr.Close()\n74: \tdefer store.Close()\n75: \n76: \tinfo := &wmTypes.SandboxInfo{\n77: \t\tSessionID: \"session-1\",\n78: \t\tExpiresAt: time.Time{},\n79: \t}\n80: \n81: \terr := store.StoreSandbox(context.Background(), info)\n82: \tif err == nil {\n83: \t\tt.Fatal(\"expected error for zero ExpiresAt, got nil\")\n84: \t}\n85: }\n86: \n87: // TestValkeyStoreStoreSandbox tests storing and retrieving a sandbox\n88: func TestValkeyStoreStoreSandbox(t *testing.T) {\n89: \tmr, store := setupValkeyTest(t)\n90: \tdefer mr.Close()\n91: \tdefer store.Close()\n92: \n93: \tinfo := &wmTypes.SandboxInfo{\n94: \t\tSessionID:        \"session-1\",\n95: \t\tSandboxID:        \"sandbox-1\",\n96: \t\tSandboxName:      \"test-sandbox\",\n97: \t\tSandboxNamespace: \"default\",\n98: \t\tKind:             wmTypes.AgentRuntimeKind,\n99: \t\tNamespace:        \"default\",\n100: \t\tWorkloadName:     \"test-workload\",\n101: \t\tStatus:           \"Running\",\n102: \t\tCreatedAt:        time.Now(),\n103: \t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n104: \t\tLastActivityAt:   time.Now(),\n105: \t}\n106: \n107: \terr := store.StoreSandbox(context.Background(), info)\n108: \tif err != nil {\n109: \t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n110: \t}\n111: \n112: \tretrieved, err := store.GetSandboxBySessionID(context.Background(), \"session-1\")\n113: \tif err != nil {\n114: \t\tt.Fatalf(\"GetSandboxBySessionID failed: %v\", err)\n115: \t}\n116: \n117: \tif retrieved.SessionID != info.SessionID {\n118: \t\tt.Errorf(\"expected SessionID %q, got %q\", info.SessionID, retrieved.SessionID)\n119: \t}\n120: }\n121: \n122: // TestValkeyStoreStoreSandboxDuplicate tests storing a duplicate session\n123: func TestValkeyStoreStoreSandboxDuplicate(t *testing.T) {\n124: \tmr, store := setupValkeyTest(t)\n125: \tdefer mr.Close()\n126: \tdefer store.Close()\n127: \n128: \tinfo := &wmTypes.SandboxInfo{\n129: \t\tSessionID:        \"session-1\",\n130: \t\tSandboxID:        \"sandbox-1\",\n131: \t\tSandboxName:      \"test-sandbox\",\n132: \t\tSandboxNamespace: \"default\",\n133: \t\tKind:             wmTypes.AgentRuntimeKind,\n134: \t\tNamespace:        \"default\",\n135: \t\tWorkloadName:     \"test-workload\",\n136: \t\tStatus:           \"Running\",\n137: \t\tCreatedAt:        time.Now(),\n138: \t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n139: \t\tLastActivityAt:   time.Now(),\n140: \t}\n141: \n142: \terr := store.StoreSandbox(context.Background(), info)\n143: \tif err != nil {\n144: \t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n145: \t}\n146: \n147: \terr = store.StoreSandbox(context.Background(), info)\n148: \tif err == nil {\n149: \t\tt.Fatal(\"expected error for duplicate session, got nil\")\n150: \t}\n151: }\n152: \n153: // TestValkeyStoreUpdateSandboxNotFound tests updating a non-existent session\n154: func TestValkeyStoreUpdateSandboxNotFound(t *testing.T) {\n155: \tmr, store := setupValkeyTest(t)\n156: \tdefer mr.Close()\n157: \tdefer store.Close()\n158: \n159: \tinfo := &wmTypes.SandboxInfo{\n160: \t\tSessionID: \"session-1\",\n161: \t\tExpiresAt: time.Now().Add(8 * time.Hour),\n162: \t}\n163: \n164: \terr := store.UpdateSandbox(context.Background(), info)\n165: \tif err == nil {\n166: \t\tt.Fatal(\"expected error for non-existent session, got nil\")\n167: \t}\n168: }\n169: \n170: // TestValkeyStoreUpdateSandbox tests updating an existing session\n171: func TestValkeyStoreUpdateSandbox(t *testing.T) {\n172: \tmr, store := setupValkeyTest(t)\n173: \tdefer mr.Close()\n174: \tdefer store.Close()\n175: \n176: \tinfo := &wmTypes.SandboxInfo{\n177: \t\tSessionID:        \"session-1\",\n178: \t\tSandboxID:        \"sandbox-1\",\n179: \t\tSandboxName:      \"test-sandbox\",\n180: \t\tSandboxNamespace: \"default\",\n181: \t\tKind:             wmTypes.AgentRuntimeKind,\n182: \t\tNamespace:        \"default\",\n183: \t\tWorkloadName:     \"test-workload\",\n184: \t\tStatus:           \"Running\",\n185: \t\tCreatedAt:        time.Now(),\n186: \t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n187: \t\tLastActivityAt:   time.Now(),\n188: \t}\n189: \n190: \terr := store.StoreSandbox(context.Background(), info)\n191: \tif err != nil {\n192: \t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n193: \t}\n194: \n195: \tinfo.Status = \"Updated\"\n196: \terr = store.UpdateSandbox(context.Background(), info)\n197: \tif err != nil {\n198: \t\tt.Fatalf(\"UpdateSandbox failed: %v\", err)\n199: \t}\n200: \n201: \tretrieved, err := store.GetSandboxBySessionID(context.Background(), \"session-1\")\n202: \tif err != nil {\n203: \t\tt.Fatalf(\"GetSandboxBySessionID failed: %v\", err)\n204: \t}\n205: \n206: \tif retrieved.Status != \"Updated\" {\n207: \t\tt.Errorf(\"expected Status 'Updated', got %q\", retrieved.Status)\n208: \t}\n209: }\n210: \n211: // TestValkeyStoreDeleteSandboxBySessionID tests deleting a session\n212: func TestValkeyStoreDeleteSandboxBySessionID(t *testing.T) {\n213: \tmr, store := setupValkeyTest(t)\n214: \tdefer mr.Close()\n215: \tdefer store.Close()\n216: \n217: \tctx := context.Background()\n218: \tinfo := &wmTypes.SandboxInfo{\n219: \t\tSessionID:        \"session-1\",\n220: \t\tSandboxID:        \"sandbox-1\",\n221: \t\tSandboxName:      \"test-sandbox\",\n222: \t\tSandboxNamespace: \"default\",\n223: \t\tKind:             wmTypes.AgentRuntimeKind,\n224: \t\tNamespace:        \"default\",\n225: \t\tWorkloadName:     \"test-workload\",\n226: \t\tStatus:           \"Running\",\n227: \t\tCreatedAt:        time.Now(),\n228: \t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n229: \t\tLastActivityAt:   time.Now(),\n230: \t}\n231: \n232: \terr := store.StoreSandbox(ctx, info)\n233: \tif err != nil {\n234: \t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n235: \t}\n236: \n237: \terr = store.DeleteSandboxBySessionID(ctx, \"session-1\")\n238: \tif err != nil {\n239: \t\tt.Fatalf(\"DeleteSandboxBySessionID failed: %v\", err)\n240: \t}\n241: \n242: \t_, err = store.GetSandboxBySessionID(ctx, \"session-1\")\n243: \tif err != ErrNotFound {\n244: \t\tt.Errorf(\"expected ErrNotFound after delete, got %v\", err)\n245: \t}\n246: }\n247: \n248: // TestValkeyStoreDeleteSandboxBySessionIDNonExistent tests deleting a non-existent session\n249: func TestValkeyStoreDeleteSandboxBySessionIDNonExistent(t *testing.T) {\n250: \tmr, store := setupValkeyTest(t)\n251: \tdefer mr.Close()\n252: \tdefer store.Close()\n253: \n254: \terr := store.DeleteSandboxBySessionID(context.Background(), \"nonexistent\")\n255: \tif err != nil {\n256: \t\tt.Errorf(\"DeleteSandboxBySessionID should be idempotent, got error: %v\", err)\n257: \t}\n258: }\n259: \n260: // TestValkeyStoreListExpiredSandboxesZeroLimit tests listing with zero limit\n261: func TestValkeyStoreListExpiredSandboxesZeroLimit(t *testing.T) {\n262: \tmr, store := setupValkeyTest(t)\n263: \tdefer mr.Close()\n264: \tdefer store.Close()\n265: \n266: \tresult, err := store.ListExpiredSandboxes(context.Background(), time.Now(), 0)\n267: \tif err != nil {\n268: \t\tt.Fatalf(\"ListExpiredSandboxes failed: %v\", err)\n269: \t}\n270: \tif result != nil {\n271: \t\tt.Errorf(\"expected nil result for limit 0, got %v\", result)\n272: \t}\n273: }\n274: \n275: // TestValkeyStoreListExpiredSandboxes tests listing expired sandboxes\n276: func TestValkeyStoreListExpiredSandboxes(t *testing.T) {\n277: \tmr, store := setupValkeyTest(t)\n278: \tdefer mr.Close()\n279: \tdefer store.Close()\n280: \n281: \tctx := context.Background()\n282: \tnow := time.Now()\n283: \n284: \texpiredInfo := &wmTypes.SandboxInfo{\n285: \t\tSessionID:        \"expired-session\",\n286: \t\tSandboxID:        \"sandbox-1\",\n287: \t\tSandboxName:      \"expired-sandbox\",\n288: \t\tSandboxNamespace: \"default\",\n289: \t\tKind:             wmTypes.AgentRuntimeKind,\n290: \t\tNamespace:        \"default\",\n291: \t\tWorkloadName:     \"test-workload\",\n292: \t\tStatus:           \"Running\",\n293: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n294: \t\tExpiresAt:        now.Add(-2 * time.Hour),\n295: \t\tLastActivityAt:   now.Add(-9 * time.Hour),\n296: \t}\n297: \n298: \tactiveInfo := &wmTypes.SandboxInfo{\n299: \t\tSessionID:        \"active-session\",\n300: \t\tSandboxID:        \"sandbox-2\",\n301: \t\tSandboxName:      \"active-sandbox\",\n302: \t\tSandboxNamespace: \"default\",\n303: \t\tKind:             wmTypes.AgentRuntimeKind,\n304: \t\tNamespace:        \"default\",\n305: \t\tWorkloadName:     \"test-workload-2\",\n306: \t\tStatus:           \"Running\",\n307: \t\tCreatedAt:        now.Add(-1 * time.Hour),\n308: \t\tExpiresAt:        now.Add(7 * time.Hour),\n309: \t\tLastActivityAt:   now.Add(-30 * time.Minute),\n310: \t}\n311: \n312: \terr := store.StoreSandbox(ctx, expiredInfo)\n313: \tif err != nil {\n314: \t\tt.Fatalf(\"StoreSandbox failed for expired: %v\", err)\n315: \t}\n316: \n317: \terr = store.StoreSandbox(ctx, activeInfo)\n318: \tif err != nil {\n319: \t\tt.Fatalf(\"StoreSandbox failed for active: %v\", err)\n320: \t}\n321: \n322: \tresult, err := store.ListExpiredSandboxes(ctx, now, 10)\n323: \tif err != nil {\n324: \t\tt.Fatalf(\"ListExpiredSandboxes failed: %v\", err)\n325: \t}\n326: \n327: \tif len(result) != 1 {\n328: \t\tt.Errorf(\"expected 1 expired sandbox, got %d\", len(result))\n329: \t} else if result[0].SessionID != \"expired-session\" {\n330: \t\tt.Errorf(\"expected expired-session, got %s\", result[0].SessionID)\n331: \t}\n332: }\n333: \n334: // TestValkeyStoreListInactiveSandboxesZeroLimit tests listing inactive with zero limit\n335: func TestValkeyStoreListInactiveSandboxesZeroLimit(t *testing.T) {\n336: \tmr, store := setupValkeyTest(t)\n337: \tdefer mr.Close()\n338: \tdefer store.Close()\n339: \n340: \tresult, err := store.ListInactiveSandboxes(context.Background(), time.Now(), 0)\n341: \tif err != nil {\n342: \t\tt.Fatalf(\"ListInactiveSandboxes failed: %v\", err)\n343: \t}\n344: \tif result != nil {\n345: \t\tt.Errorf(\"expected nil result for limit 0, got %v\", result)\n346: \t}\n347: }\n348: \n349: // TestValkeyStoreListInactiveSandboxes tests listing inactive sandboxes\n350: func TestValkeyStoreListInactiveSandboxes(t *testing.T) {\n351: \tmr, store := setupValkeyTest(t)\n352: \tdefer mr.Close()\n353: \tdefer store.Close()\n354: \n355: \tctx := context.Background()\n356: \tnow := time.Now()\n357: \n358: \tactiveInfo := &wmTypes.SandboxInfo{\n359: \t\tSessionID:        \"active-session\",\n360: \t\tSandboxID:        \"sandbox-1\",\n361: \t\tSandboxName:      \"active-sandbox\",\n362: \t\tSandboxNamespace: \"default\",\n363: \t\tKind:             wmTypes.AgentRuntimeKind,\n364: \t\tNamespace:        \"default\",\n365: \t\tWorkloadName:     \"test-workload\",\n366: \t\tStatus:           \"Running\",\n367: \t\tCreatedAt:        now.Add(-1 * time.Hour),\n368: \t\tExpiresAt:        now.Add(7 * time.Hour),\n369: \t\tLastActivityAt:   now.Add(-30 * time.Minute),\n370: \t}\n371: \n372: \tinactiveInfo := &wmTypes.SandboxInfo{\n373: \t\tSessionID:        \"inactive-session\",\n374: \t\tSandboxID:        \"sandbox-2\",\n375: \t\tSandboxName:      \"inactive-sandbox\",\n376: \t\tSandboxNamespace: \"default\",\n377: \t\tKind:             wmTypes.AgentRuntimeKind,\n378: \t\tNamespace:        \"default\",\n379: \t\tWorkloadName:     \"test-workload-2\",\n380: \t\tStatus:           \"Running\",\n381: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n382: \t\tExpiresAt:        now.Add(6 * time.Hour),\n383: \t\tLastActivityAt:   now.Add(-5 * time.Hour),\n384: \t}\n385: \n386: \terr := store.StoreSandbox(ctx, activeInfo)\n387: \tif err != nil {\n388: \t\tt.Fatalf(\"StoreSandbox failed for active: %v\", err)\n389: \t}\n390: \n391: \terr = store.StoreSandbox(ctx, inactiveInfo)\n392: \tif err != nil {\n393: \t\tt.Fatalf(\"StoreSandbox failed for inactive: %v\", err)\n394: \t}\n395: \n396: \tresult, err := store.ListInactiveSandboxes(ctx, now.Add(-1*time.Hour), 10)\n397: \tif err != nil {\n398: \t\tt.Fatalf(\"ListInactiveSandboxes failed: %v\", err)\n399: \t}\n400: \n401: \tif len(result) != 1 {\n402: \t\tt.Errorf(\"expected 1 inactive sandbox, got %d\", len(result))\n403: \t} else if result[0].SessionID != \"inactive-session\" {\n404: \t\tt.Errorf(\"expected inactive-session, got %s\", result[0].SessionID)\n405: \t}\n406: }\n407: \n408: // TestValkeyStoreUpdateSessionLastActivityEmptySessionID tests updating with empty session ID\n409: func TestValkeyStoreUpdateSessionLastActivityEmptySessionID(t *testing.T) {\n410: \tmr, store := setupValkeyTest(t)\n411: \tdefer mr.Close()\n412: \tdefer store.Close()\n413: \n414: \terr := store.UpdateSessionLastActivity(context.Background(), \"\", time.Now())\n415: \tif err == nil {\n416: \t\tt.Fatal(\"expected error for empty sessionID, got nil\")\n417: \t}\n418: }\n419: \n420: // TestValkeyStoreUpdateSessionLastActivityNotFound tests updating last activity for non-existent session\n421: func TestValkeyStoreUpdateSessionLastActivityNotFound(t *testing.T) {\n422: \tmr, store := setupValkeyTest(t)\n423: \tdefer mr.Close()\n424: \tdefer store.Close()\n425: \n426: \terr := store.UpdateSessionLastActivity(context.Background(), \"nonexistent\", time.Now())\n427: \tif err != ErrNotFound {\n428: \t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n429: \t}\n430: }\n431: \n432: // TestValkeyStoreUpdateSessionLastActivity tests updating last activity\n433: func TestValkeyStoreUpdateSessionLastActivity(t *testing.T) {\n434: \tmr, store := setupValkeyTest(t)\n435: \tdefer mr.Close()\n436: \tdefer store.Close()\n437: \n438: \tctx := context.Background()\n439: \tinfo := &wmTypes.SandboxInfo{\n440: \t\tSessionID:        \"session-1\",\n441: \t\tSandboxID:        \"sandbox-1\",\n442: \t\tSandboxName:      \"test-sandbox\",\n443: \t\tSandboxNamespace: \"default\",\n444: \t\tKind:             wmTypes.AgentRuntimeKind,\n445: \t\tNamespace:        \"default\",\n446: \t\tWorkloadName:     \"test-workload\",\n447: \t\tStatus:           \"Running\",\n448: \t\tCreatedAt:        time.Now(),\n449: \t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n450: \t\tLastActivityAt:   time.Now().Add(-1 * time.Hour),\n451: \t}\n452: \n453: \terr := store.StoreSandbox(ctx, info)\n454: \tif err != nil {\n455: \t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n456: \t}\n457: \n458: \tnewActivity := time.Now().Add(1 * time.Hour)\n459: \terr = store.UpdateSessionLastActivity(ctx, \"session-1\", newActivity)\n460: \tif err != nil {\n461: \t\tt.Fatalf(\"UpdateSessionLastActivity failed: %v\", err)\n462: \t}\n463: \n464: \tretrieved, err := store.GetSandboxBySessionID(ctx, \"session-1\")\n465: \tif err != nil {\n466: \t\tt.Fatalf(\"GetSandboxBySessionID failed: %v\", err)\n467: \t}\n468: \n469: \tif retrieved.SessionID != \"session-1\" {\n470: \t\tt.Errorf(\"expected session-1, got %s\", retrieved.SessionID)\n471: \t}\n472: }\n473: \n474: // TestValkeyStoreUpdateSessionLastActivityZeroTime tests updating with zero time\n475: func TestValkeyStoreUpdateSessionLastActivityZeroTime(t *testing.T) {\n476: \tmr, store := setupValkeyTest(t)\n477: \tdefer mr.Close()\n478: \tdefer store.Close()\n479: \n480: \tctx := context.Background()\n481: \tinfo := &wmTypes.SandboxInfo{\n482: \t\tSessionID:        \"session-1\",\n483: \t\tSandboxID:        \"sandbox-1\",\n484: \t\tSandboxName:      \"test-sandbox\",\n485: \t\tSandboxNamespace: \"default\",\n486: \t\tKind:             wmTypes.AgentRuntimeKind,\n487: \t\tNamespace:        \"default\",\n488: \t\tWorkloadName:     \"test-workload\",\n489: \t\tStatus:           \"Running\",\n490: \t\tCreatedAt:        time.Now(),\n491: \t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n492: \t\tLastActivityAt:   time.Now(),\n493: \t}\n494: \n495: \terr := store.StoreSandbox(ctx, info)\n496: \tif err != nil {\n497: \t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n498: \t}\n499: \n500: \terr = store.UpdateSessionLastActivity(ctx, \"session-1\", time.Time{})\n501: \tif err != nil {\n502: \t\tt.Fatalf(\"UpdateSessionLastActivity with zero time failed: %v\", err)\n503: \t}\n504: }\n505: \n506: // TestValkeyStoreClose tests closing the store\n507: func TestValkeyStoreClose(t *testing.T) {\n508: \tmr, err := miniredis.Run()\n509: \tif err != nil {\n510: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n511: \t}\n512: \tdefer mr.Close()\n513: \n514: \tos.Setenv(\"VALKEY_ADDR\", mr.Addr())\n515: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n516: \tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n517: \tdefer os.Unsetenv(\"VALKEY_ADDR\")\n518: \tdefer os.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n519: \tdefer os.Unsetenv(\"VALKEY_DISABLE_CACHE\")\n520: \n521: \topts, _ := makeValkeyOptions()\n522: \tstore, err := NewValkeyStore(opts)\n523: \tif err != nil {\n524: \t\tt.Fatalf(\"NewValkeyStore failed: %v\", err)\n525: \t}\n526: \n527: \terr = store.Close()\n528: \tif err != nil {\n529: \t\tt.Errorf(\"Close failed: %v\", err)\n530: \t}\n531: }\n532: \n533: // TestValkeyStoreListExpiredWithNegativeLimit tests listing expired with negative limit\n534: func TestValkeyStoreListExpiredWithNegativeLimit(t *testing.T) {\n535: \tmr, store := setupValkeyTest(t)\n536: \tdefer mr.Close