","before":"package router\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestResolver_NewResolver(t *testing.T) {\n\troutes := &sync.Map{}\n\tresolver := NewResolver(routes)\n\tassert.NotNil(t, resolver)\n}\n\nfunc TestResolver_ParsePath_Success(t *testing.T) {\n\tresolver := NewResolver(&sync.Map{})\n\n\tnamespace, resourceType, name, err := resolver.ParsePath(\"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/agentruntimes/test-runtime\")\n\tassert.NoError(t, err)\n\tassert.Equal(t, \"default\", namespace)\n\tassert.Equal(t, \"agentruntimes\", resourceType)\n\tassert.Equal(t, \"test-runtime\", name)\n}\n\nfunc TestResolver_ParsePath_CodeInterpreter(t *testing.T) {\n\tresolver := NewResolver(&sync.Map{})\n\n\tnamespace, resourceType, name, err := resolver.ParsePath(\"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/kube-system/codeinterpreters/ci-123\")\n\tassert.NoError(t, err)\n\tassert.Equal(t, \"kube-system\", namespace)\n\tassert.Equal(t, \"codeinterpreters\", resourceType)\n\tassert.Equal(t, \"ci-123\", name)\n}\n\nfunc TestResolver_ParsePath_WithSubpath(t *testing.T) {\n\tresolver := NewResolver(&sync.Map{})\n\n\tnamespace, resourceType, name, err := resolver.ParsePath(\"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/agentruntimes/test-runtime/api/v1/health\")\n\tassert.NoError(t, err)\n\tassert.Equal(t, \"default\", namespace)\n\tassert.Equal(t, \"agentruntimes\", resourceType)\n\tassert.Equal(t, \"test-runtime\", name)\n}\n\nfunc TestResolver_ParsePath_TooShort(t *testing.T) {\n\tresolver := NewResolver(&sync.Map{})\n\n\t_, _, _, err := resolver.ParsePath(\"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces\")\n\tassert.Error(t, err)\n\tassert.Equal(t, ErrMalformedPath, err)\n}\n\nfunc TestResolver_ParsePath_InvalidAPIGroup(t *testing.T) {\n\tresolver := NewResolver(&sync.Map{})\n\n\t_, _, _, err := resolver.ParsePath(\"/apis/other.group/v1/namespaces/default/agentruntimes/test\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"invalid API group\")\n}\n\nfunc TestResolver_ParsePath_MissingNamespaces(t *testing.T) {\n\tresolver := NewResolver(&sync.Map{})\n\n\t_, _, _, err := resolver.ParsePath(\"/apis/runtime.agentcube.volcano.sh/v1alpha1/default/agentruntimes/test\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"must include /namespaces\")\n}\n\nfunc TestResolver_ResourceTypeToKind_AgentRuntime(t *testing.T) {\n\tresolver := NewResolver(&sync.Map{})\n\n\tkind := resolver.resourceTypeToKind(\"agentruntimes\")\n\tassert.Equal(t, \"AgentRuntime\", kind)\n\n\tkind = resolver.resourceTypeToKind(\"AgentRuntimes\")\n\tassert.Equal(t, \"AgentRuntime\", kind)\n\n\tkind = resolver.resourceTypeToKind(\"AGENTRUNTIMES\")\n\tassert.Equal(t, \"AgentRuntime\", kind)\n}\n\nfunc TestResolver_ResourceTypeToKind_CodeInterpreter(t *testing.T) {\n\tresolver := NewResolver(&sync.Map{})\n\n\tkind := resolver.resourceTypeToKind(\"codeinterpreters\")\n\tassert.Equal(t, \"CodeInterpreter\", kind)\n\n\tkind = resolver.resourceTypeToKind(\"CodeInterpreters\")\n\tassert.Equal(t, \"CodeInterpreter\", kind)\n}\n\nfunc TestResolver_ResourceTypeToKind_Invalid(t *testing.T) {\n\tresolver := NewResolver(&sync.Map{})\n\n\tkind := resolver.resourceTypeToKind(\"invalid\")\n\tassert.Equal(t, \"\", kind)\n}\n\nfunc TestResolver_Resolve_Success(t *testing.T) {\n\troutes := &sync.Map{}\n\tresolver := NewResolver(routes)\n\n\tentry := &RouteEntry{\n\t\tName:       \"test\",\n\t\tNamespace:  \"default\",\n\t\tKind:       \"AgentRuntime\",\n\t\tBackendURL: \"http://localhost:8080\",\n\t\tHealth:     HealthStatus{Healthy: true},\n\t}\n\n\tkey := routeKey(\"default\", \"AgentRuntime\", \"test\")\n\troutes.Store(key, entry)\n\n\treq := httptest.NewRequest(http.MethodGet, \"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/agentruntimes/test\", nil)\n\tresolved, err := resolver.Resolve(req)\n\n\tassert.NoError(t, err)\n\tassert.Equal(t, \"test\", resolved.Name)\n\tassert.Equal(t, \"default\", resolved.Namespace)\n\tassert.Equal(t, \"AgentRuntime\", resolved.Kind)\n}\n\nfunc TestResolver_Resolve_NotFound(t *testing.T) {\n\troutes := &sync.Map{}\n\tresolver := NewResolver(routes)\n\n\treq := httptest.NewRequest(http.MethodGet, \"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/agentruntimes/nonexistent\", nil)\n\t_, err := resolver.Resolve(req)\n\n\tassert.Error(t, err)\n\tassert.Equal(t, ErrRouteNotFound, err)\n}\n\nfunc TestResolver_Resolve_Unhealthy(t *testing.T) {\n\troutes := &sync.Map{}\n\tresolver := NewResolver(routes)\n\n\tentry := &RouteEntry{\n\t\tName:       \"test\",\n\t\tNamespace:  \"default\",\n\t\tKind:       \"AgentRuntime\",\n\t\tBackendURL: \"http://localhost:8080\",\n\t\tHealth:     HealthStatus{Healthy: false, ConsecutiveFailures: 3},\n\t}\n\n\tkey := routeKey(\"default\", \"AgentRuntime\", \"test\")\n\troutes.Store(key, entry)\n\n\treq := httptest.NewRequest(http.MethodGet, \"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/agentruntimes/test\", nil)\n\t_, err := resolver.Resolve(req)\n\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"no healthy backends\")\n}\n\nfunc TestResolver_Resolve_InvalidResourceType(t *testing.T) {\n\troutes := &sync.Map{}\n\tresolver := NewResolver(routes)\n\n\treq := httptest.NewRequest(http.MethodGet, \"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/invalid/test\", nil)\n\t_, err := resolver.Resolve(req)\n\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"invalid resource type\")\n}\n","after":"package router\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"sync\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestResolver_NewResolver(t *testing.T) {\n\troutes := &sync.Map{}\n\tresolver := NewResolver(routes)\n\tassert.NotNil(t, resolver)\n}\n\nfunc TestResolver_ParsePath_Success(t *testing.T) {\n\tresolver := NewResolver(&s