ngleHostReverseProxy(backendURL)\n53: \tproxy.ErrorHandler = func(w http.ResponseWriter, r *http.Request, err error) {\n54: \t\tklog.Errorf(\"Proxy error: %v\", err)\n55: \t}\n56: \n57: \tproxy.ModifyResponse = func(resp *http.Response) error {\n58: \t\tfor k, vv := range resp.Header {\n59: \t\t\tfor _, v := range vv {\n60: \t\t\t\tw.Header().Add(k, v)\n61: \t\t\t}\n62: \t\t}\n63: \t\treturn nil\n64: \t}\n65: \n66: \tr = h.AddForwardingHeaders(r)\n67: \tctx := r.Context()\n68: \tctx = context.WithValue(ctx, \"route\", route)\n69: \tr = r.WithContext(ctx)\n70: \n71: \tproxy.ServeHTTP(w, r)\n72: \treturn nil\n73: }\n74: \n75: func (h *Handler) AddForwardingHeaders(r *http.Request) *http.Request {\n76: \tclientIP, _, err := net.SplitHostPort(r.RemoteAddr)\n77: \tif err != nil {\n78: \t\tclientIP = r.RemoteAddr\n79: \t}\n80: \n81: \tr.Header.Set(\"X-Forwarded-For\", clientIP)\n82: \tr.Header.Set(\"X-Real-IP\", clientIP)\n83: \tr.Header.Set(\"X-Forwarded-Host\", r.Host)\n84: \tr.Header.Set(\"X-Forwarded-Proto\", r.URL.Scheme)\n85: \n86: \tif r.TLS != nil {\n87: \t\tr.Header.Set(\"X-Forwarded-Proto\", \"https\")\n88: \t} else {\n89: \t\tr.Header.Set(\"X-Forwarded-Proto\", \"http\")\n90: \t}\n91: \n92: \treturn r\n93: }\n94: \n95: func (h *Handler) writeError(w http.ResponseWriter, err error, statusCode int) {\n96: \tw.Header().Set(\"Content-Type\", \"application/json\")\n97: \tw.WriteHeader(statusCode)\n98: \n99: \tresp := ErrorResponse{\n100: \t\tError:     err.Error(),\n101: \t\tCode:      http.StatusText(statusCode),\n102: \t\tTimestamp: time.Now().Format(time.RFC3339),\n103: \t}\n104: \n105: \tif strings.Contains(err.Error(), \"route not found\") {\n106: \t\tresp.Code = \"RouteNotFound\"\n107: \t} else if strings.Contains(err.Error(), \"invalid resource type\") {\n108: \t\tresp.Code = \"InvalidResourceType\"\n109: \t\tw.WriteHeader(http.StatusBadRequest)\n110: \t} else if strings.Contains(err.Error(), \"malformed\") {\n111: \t\tresp.Code = \"MalformedPath\"\n112: \t\tw.WriteHeader(http.StatusBadRequest)\n113: \t} else if strings.Contains(err.Error(), \"no healthy backends\") {\n114: \t\tresp.Code = \"NoHealthyBackends\"\n115: \t\tw.WriteHeader(http.StatusServiceUnavailable)\n116: \t} else if strings.Contains(err.Error(), \"backend\") {\n117: \t\tresp.Code = \"BackendError\"\n118: \t\tw.WriteHeader(http.StatusBadGateway)\n119: \t}\n120: \n121: \tjson.NewEncoder(w).Encode(resp)\n122: }\n123: \n124: var (\n125: \tErrBackendConnection  = errors.New(\"failed to connect to backend\")\n126: \tErrBackendTimeout     = errors.New(\"backend timeout\")\n127: \tErrBackendUnavailable = errors.New(\"backend unavailable\")\n128: )\n\n(End of file - total 128 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n)\n\ntype ErrorResponse struct {\n\tError     string `json:\"error\"`\n\tCode      string `json:\"code\"`\n\tRouteName string `json:\"routeName,omitempty\"`\n\tTimestamp string `json:\"timestamp\"`\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler.go","time":{"start":1775848618535,"end":1775848618549}}}}
