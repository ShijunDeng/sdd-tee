ttps\")\n\t} else {\n\t\tr.Header.Set(\"X-Forwarded-Proto\", \"http\")\n\t}\n\n\treturn r\n}\n\nfunc (h *Handler) writeError(w http.ResponseWriter, err error, statusCode int) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(statusCode)\n\n\tresp := ErrorResponse{\n\t\tError:     err.Error(),\n\t\tCode:      http.StatusText(statusCode),\n\t\tTimestamp: time.Now().Format(time.RFC3339),\n\t}\n\n\tif strings.Contains(err.Error(), \"route not found\") {\n\t\tresp.Code = \"RouteNotFound\"\n\t} else if strings.Contains(err.Error(), \"invalid resource type\") {\n\t\tresp.Code = \"InvalidResourceType\"\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t} else if strings.Contains(err.Error(), \"malformed\") {\n\t\tresp.Code = \"MalformedPath\"\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t} else if strings.Contains(err.Error(), \"no healthy backends\") {\n\t\tresp.Code = \"NoHealthyBackends\"\n\t\tw.WriteHeader(http.StatusServiceUnavailable)\n\t} else if strings.Contains(err.Error(), \"backend\") {\n\t\tresp.Code = \"BackendError\"\n\t\tw.WriteHeader(http.StatusBadGateway)\n\t}\n\n\tjson.NewEncoder(w).Encode(resp)\n}\n\nvar (\n\tErrBackendConnection  = errors.New(\"failed to connect to backend\")\n\tErrBackendTimeout     = errors.New(\"backend timeout\")\n\tErrBackendUnavailable = errors.New(\"backend unavailable\")\n)\n","after":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n)\n\ntype ErrorResponse struct {\n\tError     string `json:\"error\"`\n\tCode      string `json:\"code\"`\n\tRouteName string `json:\"routeName,omitempty\"`\n\tTimestamp string `json:\"timestamp\"`\n}\n\ntype Handler struct {\n\trouter   *Router\n\tresolver *Resolver\n}\n\nfunc NewHandler(router *Router, resolver *Resolver) *Handler {\n\treturn &Handler{\n\t\trouter:   router,\n\t\tresolver: resolver,\n\t}\n}\n\nfunc (h *Hand