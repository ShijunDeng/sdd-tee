try)\n59: \t\treturn true\n60: \t})\n61: }\n62: \n63: func (hc *HealthChecker) checkRoute(entry *RouteEntry) {\n64: \tctx, cancel := context.WithTimeout(context.Background(), hc.config.HealthCheckTimeout)\n65: \tdefer cancel()\n66: \n67: \treq, err := http.NewRequestWithContext(ctx, http.MethodGet, entry.BackendURL, nil)\n68: \tif err != nil {\n69: \t\tentry.Health.MarkFailure(err)\n70: \t\tklog.V(4).Infof(\"Health check failed for %s/%s/%s: %v\", entry.Namespace, entry.Kind, entry.Name, err)\n71: \t\treturn\n72: \t}\n73: \n74: \tresp, err := hc.httpClient.Do(req)\n75: \tif err != nil {\n76: \t\tentry.Health.MarkFailure(err)\n77: \t\tklog.V(4).Infof(\"Health check failed for %s/%s/%s: %v\", entry.Namespace, entry.Kind, entry.Name, err)\n78: \t\treturn\n79: \t}\n80: \tdefer resp.Body.Close()\n81: \n82: \tif resp.StatusCode >= 200 && resp.StatusCode < 400 {\n83: \t\tentry.Health.MarkHealthy()\n84: \t\tklog.V(4).Infof(\"Health check passed for %s/%s/%s\", entry.Namespace, entry.Kind, entry.Name)\n85: \t} else {\n86: \t\tentry.Health.MarkFailure(fmt.Errorf(\"unhealthy status code: %d\", resp.StatusCode))\n87: \t\tklog.V(4).Infof(\"Health check failed for %s/%s/%s: status code %d\", entry.Namespace, entry.Kind, entry.Name, resp.StatusCode)\n88: \t}\n89: }\n90: \n91: func (hc *HealthChecker) MarkUnhealthy(entry *RouteEntry) {\n92: \tentry.Health.MarkFailure(errors.New(\"manually marked unhealthy\"))\n93: }\n94: \n95: func (hc *HealthChecker) MarkHealthy(entry *RouteEntry) {\n96: \tentry.Health.MarkHealthy()\n97: }\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n)\n\ntype HealthChecker struct {\n\tconfig     *RouterConfig\n\troutes     *sync.Map\n\thttpClient *http.Client\n\tstopCh     chan struct{}\n\twg         sync.WaitGroup\n}\n\nfunc NewHealthChecker(config *RouterConfig, routes *sync.Map, httpClient *http.Client) *HealthChecker {","truncate