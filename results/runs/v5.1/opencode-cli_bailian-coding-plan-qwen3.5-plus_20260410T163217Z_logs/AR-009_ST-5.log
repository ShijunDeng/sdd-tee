_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router.go\n@@ -3,16 +3,14 @@\n import (\n \t\"context\"\n \t\"fmt\"\n \t\"net/http\"\n-\t\"strings\"\n \t\"sync\"\n \t\"time\"\n \n \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n \twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n-\t\"k8s.io/apimachinery/pkg/api/errors\"\n-\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n+\tcorev1 \"k8s.io/api/core/v1\"\n \t\"k8s.io/client-go/kubernetes/scheme\"\n \t\"k8s.io/client-go/tools/cache\"\n \t\"k8s.io/klog/v2\"\n )\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router.go","before":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes/scheme\"\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype RouterInterface interface {\n\tStart(ctx context.Context) error\n\tShutdown(ctx context.Context) error\n\tServeHTTP(w http.ResponseWriter, r *http.Request)\n}\n\ntype Router struct {\n\tconfig              *RouterConfig\n\troutes              sync.Map\n\thttpClient          *http.Client\n\truntimeInformer     cache.SharedIndexInformer\n\tinterpreterInformer cache.SharedIndexInformer\n\tstopCh              chan struct{}\n\twg                  sync.WaitGroup\n\tmu                  sync.RWMutex\n\thandler             *Handler\n\tresolver            *Resolver\n\thealthChecker       *HealthChecker\n}\n\nfunc NewRouter(config *RouterConfig) (*Router, error) {\n\tif config.KubeConfig == nil {\n\t\treturn nil, fmt.Errorf(\"kubeconfig is required\")\n\t}\n\n\tif err := runtimev1alpha1.AddToScheme(scheme.Scheme); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to add runtime scheme: %w\", err)\n\t}\n\n\ttransport := &http.Transport{\n\t\tMaxConnsPerHost:     config.MaxConnsPerHost,\n\t\tMaxIdleConns:        100,\n\t\tMaxIdleConnsPerHost: 10,\n\t\tIdleConnTimeout:     90 * time.Second,\n\t}\n\n\thttpClient := &http.Client{\n\t\tTransport: transport,\n\t\tTimeout:   config.WriteTimeout,\n\t}\n\n\trouter := &Router{\n\t\tconfig:     config,\n\t\thttpClient: httpClient,\n\t\tstopCh:     make(chan struct{}),\n\t\troutes:     sync.Map{},\n\t}\n\n\trouter.resolver = NewResolver(&router.routes)\n\trouter.handler = NewHandler(router, router.resolver)\n\trouter.healthChecker = NewHealthChecker(config, &router.routes, httpClient)\n\n\treturn router, nil\n}\n\nfunc (r *Router) SetInformers(runtimeInformer, interpreterInformer cache.SharedIndexInformer) {\n\tr.runtimeInformer = runtimeInformer\n\tr.interpreterInformer = interpreterInformer\n\n\tif r.runtimeInformer != nil {\n\t\tr.runtimeInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n\t\t\tAddFunc:    r.onAgentRuntimeAdd,\n\t\t\tUpdateFunc: r.onAgentRuntimeUpdate,\n\t\t\tDeleteFunc: r.onAgentRuntimeDelete,\n\t\t})\n\t}\n\n\tif r.interpreterInformer != nil {\n\t\tr.interpreterInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n\t\t\tAddFunc:    r.onCodeInterpreterAdd,\n\t\t\tUpdateFunc: r.onCodeInterpreterUpdate,\n\t\t\tDeleteFunc: r.onCodeInterpreterDelete,\n\t\t})\n\t}\n}\n\nfunc (r *Router) onAgentRuntimeAdd(obj interface{}) {\n\trt, ok := obj.(*runtimev1alpha1.AgentRuntime)\n\tif !ok {\n\t\tklog.Errorf(\"Failed to convert object to AgentRuntime\")\n\t\treturn\n\t}\n\n\tif !r.shouldExpose(rt.Labels) {\n\t\tklog.V(4).Infof(\"AgentRuntime %s/%s is not exposed, skipping\", rt.Namespace, rt.Name)\n\t\treturn\n\t}\n\n\tbackendURL := r.extractBackendURLFromStatus(rt.Status.SandboxRef)\n\tif backendURL == \"\" {\n\t\tklog.V(4).Infof(\"AgentRuntime %s/%s has no backend URL, skipping\", rt.Namespace, rt.Name)\n\t\treturn\n\t}\n\n\tentry := &RouteEntry{\n\t\tName:       rt.Name,\n\t\tNamespace:  rt.Namespace,\n\t\tKind:       wmTypes.AgentRuntimeKind,\n\t\tBackendURL: backendURL,\n\t\tHealth:     HealthStatus{Healthy: true, LastCheck: time.Now()},\n\t\tUpdatedAt:  time.Now(),\n\t}\n\n\tkey := routeKey(rt.Namespace, rt.Kind, rt.Name)\n\tr.routes.Store(key, entry)\n\tklog.V(4).Infof(\"Added route for AgentRuntime %s/%s -> %s\", rt.Namespace, rt.Name, backendURL)\n}\n\nfunc (r *Router) onAgentRuntimeUpdate(oldObj, newObj interface{}) {\n\tr.onAgentRuntimeAdd(newObj)\n}\n\nfunc (r *Router) onAgentRuntimeDelete(obj interface{}) {\n\trt, ok := obj.(*runtimev1alpha1.AgentRuntime)\n\tif !ok {\n\t\ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n\t\tif !ok {\n\t\t\tklog.Errorf(\"Failed to convert object to AgentRuntime\")\n\t\t\treturn\n\t\t}\n\t\trt, ok = tombstone.Obj.(*runtimev1alpha1.AgentRuntime)\n\t\tif !ok {\n\t\t\tklog.Errorf(\"Failed to convert tombstone to AgentRuntime\")\n\t\t\treturn\n\t\t}\n\t}\n\n\tkey := routeKey(rt.Namespace, rt.Kind, rt.Name)\n\tr.routes.Delete(key)\n\tklog.V(4).Infof(\"Removed route for AgentRuntime %s/%s\", rt.Namespace, rt.Name)\n}\n\nfunc (r *Router) onCodeInterpreterAdd(obj interface{}) {\n\tci, ok := obj.(*runtimev1alpha1.CodeInterpreter)\n\tif !ok {\n\t\tklog.Errorf(\"Failed to convert object to CodeInterpreter\")\n\t\treturn\n\t}\n\n\tif !r.shouldExpose(ci.Labels) {\n\t\tklog.V(4).Infof(\"CodeInterpreter %s/%s is not exposed, skipping\", ci.Namespace, ci.Name)\n\t\treturn\n\t}\n\n\tbackendURL := r.extractBackendURLFromStatus(ci.Status.SandboxRef)\n\tif backendURL == \"\" {\n\t\tklog.V(4).Infof(\"CodeInterpreter %s/%s has no backend URL, skipping\", ci.Namespace, ci.Name)\n\t\treturn\n\t}\n\n\tentry := &RouteEntry{\n\t\tName:       ci.Name,\n\t\tNamespace:  ci.Namespace,\n\t\tKind:       wmTypes.CodeInterpreterKind,\n\t\tBackendURL: backendURL,\n\t\tHealth:     HealthStatus{Healthy: true, LastCheck: time.Now()},\n\t\tUpdatedAt:  time.Now(),\n\t}\n\n\tkey := routeKey(ci.Namespace, ci.Kind, ci.Name)\n\tr.routes.Store(key, entry)\n\tklog.V(4).Infof(\"Added route for CodeInterpreter %s/%s -> %s\", ci.Namespace, ci.Name, backendURL)\n}\n\nfunc (r *Router) onCodeInterpreterUpdate(oldObj, newObj interface{}) {\n\tr.onCodeInterpreterAdd(newObj)\n}\n\nfunc (r *Router) onCodeInterpreterDelete(obj interface{}) {\n\tci, ok := obj.(*runtimev1alpha1.CodeInterpreter)\n\tif !ok {\n\t\ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n\t\tif !ok {\n\t\t\tklog.Errorf(\"Failed to convert object to CodeInterpreter\")\n\t\t\treturn\n\t\t}\n\t\tci, ok = tombstone.Obj.(*runtimev1alpha1.CodeInterpreter)\n\t\tif !ok {\n\t\t\tklog.Errorf(\"Failed to convert tombstone to CodeInterpreter\")\n\t\t\treturn\n\t\t}\n\t}\n\n\tkey := routeKey(ci.Namespace, ci.Kind, ci.Name)\n\tr.routes.Delete(key)\n\tklog.V(4).Infof(\"Removed route for CodeInterpreter %s/%s\", ci.Namespace, ci.Name)\n}\n\nfunc (r *Router) shouldExpose(labels map[string]string) bool {\n\treturn labels[\"agentcube.volcano.sh/expose\"] == \"true\"\n}\n\nfunc (r *Router) extractBackendURLFromStatus(sandboxRef *corev1.ObjectReference) string {\n\tif sandboxRef == nil {\n\t\treturn \"\"\n\t}\n\n\tif sandboxRef.Name == \"\" {\n\t\treturn \"\"\n\t}\n\n\treturn fmt.Sprintf(\"http://%s.%s.svc.cluster.local:8080\", sandboxRef.Name, sandboxRef.Namespace)\n}\n\nfunc (r *Router) Start(ctx context.Context) error {\n\tr.healthChecker.Start()\n\n\tserver := &http.Server{\n\t\tAddr:         r.config.ListenAddr,\n\t\tHandler:      r.handler,\n\t\tReadTimeout:  r.config.ReadTimeout,\n\t\tWriteTimeout: r.config.WriteTimeout,\n\t\tIdleTimeout:  r.config.IdleTimeout,\n\t}\n\n\tr.wg.Add(1)\n\tgo func() {\n\t\tdefer r.wg.Done()\n\t\tklog.Infof(\"Router listening on %s\", r.config.ListenAddr)\n\t\tif err := server.ListenAndServe(); err != nil && err !=