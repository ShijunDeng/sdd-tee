o-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nvar (\n\tErrRouteNotFound       = errors.New(\"route not found\")\n\tErrNoHealthyBackends   = errors.New(\"no healthy backends available\")\n\tErrInvalidResourceType = errors.New(\"invalid resource type\")\n\tErrMalformedPath       = errors.New(\"malformed request path\")\n)\n\ntype Resolver struct {\n\troutes *sync.Map\n}\n\nfunc NewResolver(routes *sync.Map) *Resolver {\n\treturn &Resolver{\n\t\troutes: routes,\n\t}\n}\n\nfunc (r *Resolver) Resolve(req *http.Request) (*RouteEntry, error) {\n\tnamespace, resourceType, name, err := r.ParsePath(req.URL.Path)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tkind := r.resourceTypeToKind(resourceType)\n\tif kind == \"\" {\n\t\treturn nil, fmt.Errorf(\"%w: %s\", ErrInvalidResourceType, resourceType)\n\t}\n\n\tkey := routeKey(namespace, kind, name)\n\tentry, ok := r.routes.Load(key)\n\tif !ok {\n\t\treturn nil, ErrRouteNotFound\n\t}\n\n\trouteEntry := entry.(*RouteEntry)\n\n\tif !routeEntry.Health.IsHealthy() {\n\t\treturn nil, fmt.Errorf(\"%w: backend %s/%s is unhealthy\", ErrNoHealthyBackends, namespace, name)\n\t}\n\n\treturn routeEntry, nil\n}\n\nfunc (r *Resolver) ParsePath(path string) (namespace, resourceType, name string, err error) {\n\tparts := strings.Split(strings.Trim(path, \"/\"), \"/\")\n\n\tif len(parts) < 5 {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: path must have at least 5 segments\", ErrMalformedPath)\n\t}\n\n\tif parts[0] != \"apis\" {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: path must start with /apis\", ErrMalformedPath)\n\t}\n\n\tif parts[1] != \"runtime.agentcube.volcano.sh\" || parts[2] != \"v1alpha1\" {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: invalid API group or version\", ErrMalformedPath)\n\t}\n\n\tif parts[3] != \"namespaces\" {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: path must include /namespaces\", ErrMalformedPath)\n\t}\n\n\tnamespace = parts[4]\n\n\tif len(parts) < 6 {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%