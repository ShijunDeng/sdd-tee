h string) (namespace, resourceType, name string, err error) {\n\tparts := strings.Split(strings.Trim(path, \"/\"), \"/\")\n\n\tif len(parts) < 5 {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: path must have at least 5 segments\", ErrMalformedPath)\n\t}\n\n\tif parts[0] != \"apis\" {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: path must start with /apis\", ErrMalformedPath)\n\t}\n\n\tif parts[1] != \"runtime.agentcube.volcano.sh\" || parts[2] != \"v1alpha1\" {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: invalid API group or version\", ErrMalformedPath)\n\t}\n\n\tif parts[3] != \"namespaces\" {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: path must include /namespaces\", ErrMalformedPath)\n\t}\n\n\tnamespace = parts[4]\n\n\tif len(parts) < 6 {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: missing resource type\", ErrMalformedPath)\n\t}\n\n\tresourceType = parts[5]\n\n\tif len(parts) < 7 {\n\t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: missing resource name\", ErrMalformedPath)\n\t}\n\n\tname = parts[6]\n\n\treturn namespace, resourceType, name, nil\n}\n\nfunc (r *Resolver) resourceTypeToKind(resourceType string) string {\n\tswitch strings.ToLower(resourceType) {\n\tcase \"agentruntimes\":\n\t\treturn wmTypes.AgentRuntimeKind\n\tcase \"codeinterpreters\":\n\t\treturn wmTypes.CodeInterpreterKind\n\tdefault:\n\t\treturn \"\"\n\t}\n}\n","after":"package router\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"strings\"\n\t\"sync\"\n\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\nvar (\n\tErrRouteNotFound       = errors.New(\"route not found\")\n\tErrNoHealthyBackends   = errors.New(\"no healthy backends available\")\n\tErrInvalidResourceType = errors.New(\"invalid resource type\")\n\tErrMalformedPath       = errors.New(\"malformed request path\")\n)\n\ntype Resolver struct {\n\troutes *sync.Map\n}\n\nfunc NewResolver(routes *sync.Map) *Resolver {\n\treturn &Resolver{\n\t\troutes: routes,\n\t}\n}\n\nfunc (r *Resolver) Reso