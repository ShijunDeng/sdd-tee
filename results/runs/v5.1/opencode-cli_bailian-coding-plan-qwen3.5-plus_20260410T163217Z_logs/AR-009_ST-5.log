rorf(\"%w: backend %s/%s is unhealthy\", ErrNoHealthyBackends, namespace, name)\n50: \t}\n51: \n52: \treturn routeEntry, nil\n53: }\n54: \n55: func (r *Resolver) ParsePath(path string) (namespace, resourceType, name string, err error) {\n56: \tparts := strings.Split(strings.Trim(path, \"/\"), \"/\")\n57: \n58: \tif len(parts) < 5 {\n59: \t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: path must have at least 5 segments\", ErrMalformedPath)\n60: \t}\n61: \n62: \tif parts[0] != \"apis\" {\n63: \t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: path must start with /apis\", ErrMalformedPath)\n64: \t}\n65: \n66: \tif parts[1] != \"runtime.agentcube.volcano.sh\" || parts[2] != \"v1alpha1\" {\n67: \t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: invalid API group or version\", ErrMalformedPath)\n68: \t}\n69: \n70: \tif parts[3] != \"namespaces\" {\n71: \t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: path must include /namespaces\", ErrMalformedPath)\n72: \t}\n73: \n74: \tnamespace = parts[4]\n75: \n76: \tif len(parts) < 6 {\n77: \t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: missing resource type\", ErrMalformedPath)\n78: \t}\n79: \n80: \tresourceType = parts[5]\n81: \n82: \tif len(parts) < 7 {\n83: \t\treturn \"\", \"\", \"\", fmt.Errorf(\"%w: missing resource name\", ErrMalformedPath)\n84: \t}\n85: \n86: \tname = parts[6]\n87: \n88: \treturn namespace, resourceType, name, nil\n89: }\n90: \n91: func (r *Resolver) resourceTypeToKind(resourceType string) string {\n92: \tswitch strings.ToLower(resourceType) {\n93: \tcase \"agentruntimes\":\n94: \t\treturn runtimev1alpha1.AgentRuntimeKind\n95: \tcase \"codeinterpreters\":\n96: \t\treturn runtimev1alpha1.CodeInterpreterKind\n97: \tdefault:\n98: \t\treturn \"\"\n99: \t}\n100: }\n\n(End of file - total 100 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"strings\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nvar (\n\tErrRouteNotFound       = errors.New(\"route not found\")\n\tErrNoHealthyBackends   = errors.New(\"no healthy backends available\")\n\tErrInvalidResourceType = errors.New(\"invalid resource type\")\n\tErrMalformedPath       = errors.New(\"malformed request path\")\n)\n\ntype Resolver struct {\n\troutes *sync.Map","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/resolver.go","time":{"start":1775848618531,"end":1775848618545}}}}
