efault\",\n\t\tKind:       \"AgentRuntime\",\n\t\tBackendURL: \"http://localhost:1\",\n\t\tHealth:     HealthStatus{Healthy: true},\n\t}\n\n\tkey := routeKey(\"default\", \"AgentRuntime\", \"test\")\n\troutes.Store(key, entry)\n\n\thttpClient := &http.Client{}\n\tchecker := NewHealthChecker(config, routes, httpClient)\n\n\tchecker.checkRoute(entry)\n\n\tassert.False(t, entry.Health.IsHealthy())\n\tassert.Greater(t, entry.Health.GetConsecutiveFailures(), 0)\n}\n\nfunc TestHealthChecker_MarkUnhealthy(t *testing.T) {\n\troutes := &sync.Map{}\n\thttpClient := &http.Client{}\n\tconfig := DefaultRouterConfig()\n\n\tchecker := NewHealthChecker(config, routes, httpClient)\n\n\tentry := &RouteEntry{\n\t\tName:       \"test\",\n\t\tNamespace:  \"default\",\n\t\tKind:       \"AgentRuntime\",\n\t\tBackendURL: \"http://localhost:8080\",\n\t\tHealth:     HealthStatus{Healthy: true},\n\t}\n\n\tchecker.MarkUnhealthy(entry)\n\n\tassert.False(t, entry.Health.IsHealthy())\n\tassert.Greater(t, entry.Health.GetConsecutiveFailures(), 0)\n}\n\nfunc TestHealthChecker_MarkHealthy(t *testing.T) {\n\troutes := &sync.Map{}\n\thttpClient := &http.Client{}\n\tconfig := DefaultRouterConfig()\n\n\tchecker := NewHealthChecker(config, routes, httpClient)\n\n\tentry := &RouteEntry{\n\t\tName:       \"test\",\n\t\tNamespace:  \"default\",\n\t\tKind:       \"AgentRuntime\",\n\t\tBackendURL: \"http://localhost:8080\",\n\t\tHealth:     HealthStatus{Healthy: false, ConsecutiveFailures: 5, Error: assert.AnError},\n\t}\n\n\tchecker.MarkHealthy(entry)\n\n\tassert.True(t, entry.Health.IsHealthy())\n\tassert.Equal(t, 0, entry.Health.GetConsecutiveFailures())\n\tassert.Nil(t, entry.Health.Error)\n}\n\nfunc TestHealthChecker_CheckAllRoutes(t *testing.T) {\n\tbackend1 := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t}))\n\tdefer backend1.Close()\n\n\tbackend2 := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t}))\n\tdefer backend2.Close()\n\n\tconfig := DefaultRouterConfig()\n\tconfig.HealthCheckTimeout = 5 * time.Second\n\troutes := &sync.Map{}\n\n\tentry1 := &RouteEntry{\n\t\tName:       \"test1\",\n\t\tNamespace:  \"default\",\n\t\tKind:       \"AgentRuntime\",\n\t\tBackendURL: backend1.URL,\n\t\tHealth:     HealthStatus{Healthy: false},\n\t}\n\n\tentry2 := &RouteEntry{\n\t\tName:       \"test2\",\n\t\tNamespace:  \"default\",\n\t\tKind:       \"CodeInterpreter\",\n\t\tBackendURL: backend2.URL,\n\t\tHealth:     HealthStatus{Healthy: false},\n\t}\n\n\troutes.Store(routeKey(\"default\", \"AgentRuntime\", \"test1\"), entry1)\n\troutes.Store(routeKey(\"default\", \"CodeInterpreter\", \"test2\"), entry2)\n\n\thttpClient := &http.Client{}\n\tchecker := NewHealthChecker(config, routes, httpClient)\n\n\tchecker.checkAllRoutes()\n\n\tassert.True(t, entry1.Health.IsHealthy())\n\tassert.True(t, entry2.Health.IsHealthy())\n}\n\nfunc TestHealthChecker_ConcurrentHealthChecks(t *testing.T) {\n\tbackend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\ttime.Sleep(10 * time.Millisecond)\n\t\tw.WriteHeader(http.StatusOK)\n\t}))\n\tdefer backend.Close()\n\n\tconfig := DefaultRouterConfig()\n\tconfig.HealthCheckInterval = 50 * time.Millisecond\n\tconfig.HealthCheckTimeout = 5 * time.Second\n\troutes := &sync.Map{}\n\n\tfor i := 0; i < 10; i++ {\n\t\tentry := &RouteEntry{\n\t\t\tName:       \"test\",\n\t\t\tNamespace:  \"default\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t\tBackendURL: backend.URL,\n\t\t\tHealth:     HealthStatus{Healthy: true},\n\t\t}\n\t\troutes.Store(routeKey(\"default\", \"AgentRuntime\", \"test\"), entry)\n\t}\n\n\thttpClient := &http.Client{}\n\tchecker := NewHealthChecker(config, routes, httpClient)\n\n\tchecker.Start()\n\ttime.Sleep(200 * time.Millisecond)\n\tchecker.Stop()\n}\n","additions":0,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-pla