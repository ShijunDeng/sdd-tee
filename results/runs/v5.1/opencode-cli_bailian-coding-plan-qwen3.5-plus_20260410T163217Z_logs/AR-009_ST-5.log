n\tr.Header.Set(\"X-Forwarded-Host\", r.Host)\n\tr.Header.Set(\"X-Forwarded-Proto\", r.URL.Scheme)\n\n\tif r.TLS != nil {\n\t\tr.Header.Set(\"X-Forwarded-Proto\", \"https\")\n\t} else {\n\t\tr.Header.Set(\"X-Forwarded-Proto\", \"http\")\n\t}\n\n\treturn r\n}\n\nfunc (h *Handler) writeError(w http.ResponseWriter, err error, statusCode int) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(statusCode)\n\n\tresp := ErrorResponse{\n\t\tError:     err.Error(),\n\t\tCode:      http.StatusText(statusCode),\n\t\tTimestamp: time.Now().Format(time.RFC3339),\n\t}\n\n\tif strings.Contains(err.Error(), \"route not found\") {\n\t\tresp.Code = \"RouteNotFound\"\n\t} else if strings.Contains(err.Error(), \"invalid resource type\") {\n\t\tresp.Code = \"InvalidResourceType\"\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t} else if strings.Contains(err.Error(), \"malformed\") {\n\t\tresp.Code = \"MalformedPath\"\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t} else if strings.Contains(err.Error(), \"no healthy backends\") {\n\t\tresp.Code = \"NoHealthyBackends\"\n\t\tw.WriteHeader(http.StatusServiceUnavailable)\n\t} else if strings.Contains(err.Error(), \"backend\") {\n\t\tresp.Code = \"BackendError\"\n\t\tw.WriteHeader(http.StatusBadGateway)\n\t}\n\n\tjson.NewEncoder(w).Encode(resp)\n}\n\nvar (\n\tErrBackendConnection  = errors.New(\"failed to connect to backend\")\n\tErrBackendTimeout     = errors.New(\"backend timeout\")\n\tErrBackendUnavailable = errors.New(\"backend unavailable\")\n)\n","after":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n)\n\ntype ErrorResponse struct {\n\tError     string `json:\"error\"`\n\tCode      string `json:\"code\"`\n\tRouteName string `json:\"routeName,omitempty\"`\n\tTimestamp string `json:\"timestamp\"`\n}\n\ntype Handler struct {\n\trouter   *Router\n\tresolver *Resolver\n}\n\nfunc NewHandler(router *Router, resolver *Resolver) *Handler {\n\treturn &Handler{\n\t\trouter:   router,\n\t\tresolver: resolver,\n\t}\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\troute, err := h.resolver.Resolve(r)\n\tif err != nil {\n\t\th.writeError(w, err, http.StatusNotFound)\n\t\treturn\n\t}\n\n\tif err := h.ProxyRequest(w, r, route); err != nil {\n\t\th.writeError(w, err, http.StatusBadGateway)\n\t}\n}\n\nfunc (h *Handler) ProxyRequest(w http.ResponseWriter, r *http.Request, route *RouteEntry) error {\n\tbackendURL, err := url.Parse(route.BackendURL)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"%w: %v\", ErrBackendConnection, err)\n\t}\n\n\tproxy := httputil.NewSingleHostReverseProxy(backendURL)\n\tproxy.ErrorHandler = func(w http.ResponseWriter, r *http.Request, err error) {\n\t\tklog.Errorf(\"Proxy error: %v\", err)\n\t\tw.WriteHeader(http.StatusBadGateway)\n\t}\n\n\tproxy.ModifyResponse = func(resp *http.Response) error {\n\t\tfor k, vv := range resp.Header {\n\t\t\tfor _, v := range vv {\n\t\t\t\tw.Header().Add(k, v)\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\tr = h.AddForwardingHeaders(r)\n\tctx := r.Context()\n\tctx = context.WithValue(ctx, \"route\", route)\n\tr = r.WithContext(ctx)\n\n\tproxy.ServeHTTP(w, r)\n\treturn nil\n}\n\nfunc (h *Handler) AddForwardingHeaders(r *http.Request) *http.Request {\n\tclientIP, _, err := net.SplitHostPort(r.RemoteAddr)\n\tif err != nil {\n\t\tclientIP = r.RemoteAddr\n\t}\n\n\tr.Header.Set(\"X-Forwarded-For\", clientIP)\n\tr.Header.Set(\"X-Real-IP\", clientIP)\n\tr.Header.Set(\"X-Forwarded-Host\", r.Host)\n\tr.Header.Set(\"X-Forwarded-Proto\", r.URL.Scheme)\n\n\tif r.TLS != nil {\n\t\tr.Header.Set(\"X-Forwarded-Proto\", \"https\")\n\t} else {\n\t\tr.Header.Set(\"X-Forwarded-Proto\", \"http\")\n\t}\n\n\treturn r\n}\n\nfunc (h *Handler) writeError(w http.ResponseWriter, err error, statusCode int) {\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(statusCode)\n\n\tresp := ErrorResponse{\n\t\tError:     err.Error(),\n\t\tCode:      http.StatusText(statusCode),\n\t\tTimestamp: time.Now().Format(time.RFC3339),\n\t}\n\n\tif strings.Contains(err.Error(), \"route not found\") {\n\t\tresp.Code = \"RouteNotFound\"\n\t} else if strings.Contains(err.Error(), \"invalid resource type\") {\n\t\tresp.Code = \"InvalidResourceType\"\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t} else if strings.Contains(err.Error(), \"malformed\") {\n\t\tresp.Code = \"MalformedPath\"\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t} else if strings.Contains(err.Error(), \"no healthy backends\") {\n\t\tresp.Code = \"NoHealthyBackends\"\n\t\tw.WriteHeader(http.StatusServiceUnavailable)\n\t} else if strings.Contains(err.Error(), \"backend\") {\n\t\tresp.Code = \"BackendError\"\n\t\tw.WriteHeader(http.StatusBadGateway)\n\t}\n\n\tjson.NewEncoder(w).Encode(resp)\n}\n\nvar (\n\tErrBackendConnection  = errors.New(\"failed to connect to backend\")\n\tErrBackendTimeout     = errors.New(\"backend timeout\")\n\tErrBackendUnavailable = errors.New(\"backend unavailable\")\n)\n","additions":1,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler.go","time":{"start":1775849036075,"end":1775849036268}}}}
