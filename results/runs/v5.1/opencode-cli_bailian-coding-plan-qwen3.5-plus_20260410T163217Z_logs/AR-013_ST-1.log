eport.md\n","metadata":{"output":"total 184\ndrwxr-xr-x 17 root root  4096 Apr 11 02:58 .\ndrwxr-xr-x 14 root root  4096 Apr 11 03:52 ..\ndrwxr-xr-x 15 root root  4096 Apr 11 04:41 changes\ndrwxr-xr-x  2 root root  4096 Mar 21 15:58 ci-cd\ndrwxr-xr-x  2 root root  4096 Mar 21 15:55 cli-toolkit\ndrwxr-xr-x  2 root root  4096 Mar 21 15:55 code-execution\n-rw-r--r--  1 root root  9881 Apr 11 03:24 coverage.out\n-rw-r--r--  1 root root 14973 Apr 11 04:27 delta-spec.md\ndrwxr-xr-x  2 root root  4096 Apr 11 00:35 deployment\n-rw-r--r--  1 root root  6141 Apr 11 01:42 design.md\ndrwxr-xr-x  2 root root  4096 Apr 11 00:46 examples\n-rw-r--r--  1 root root  3830 Apr 11 04:39 go.mod\n-rw-r--r--  1 root root 19257 Apr 11 04:39 go.sum\ndrwxr-xr-x  2 root root  4096 Mar 21 15:56 idle-cleanup\ndrwxr-xr-x  2 root root  4096 Mar 21 15:58 integrations\ndrwxr-xr-x  3 root root  4096 Apr 11 00:37 manifests\ndrwxr-xr-x  7 root root  4096 Apr 11 03:13 pkg\n-rw-r--r--  1 root root  1674 Mar 21 15:53 project.md\n-rw-r--r--  1 root root 11553 Apr 11 03:57 proposal.md\ndrwxr-xr-x  2 root root  4096 Mar 21 15:56 python-sdk\ndrwxr-xr-x  4 root root  4096 Apr 11 02:04 sandbox-orchestration\n-rw-r--r--  1 root root 22974 Apr 11 04:41 .sdd_prompt.md\ndrwxr-xr-x  2 root root  4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root  4096 Mar 21 15:56 session-store\ndrwxr-xr-x  2 root root  4096 Mar 25 09:51 testing\n-rw-r--r--  1 root root  1983 Mar 25 09:36 test_spec.md\n-rw-r--r--  1 root root  8552 Apr 11 01:56 verification-report.md\n","exit":0,"description":"List files in workspace root","truncated":false},"title":"List files in workspace root","time":{"start":1775853716075,"end":1775853716177}}}}
