{"type":"tool_use","timestamp":1775866224431,"sessionID":"ses_28620d44cffeKB7Ks6lA61lHBF","part":{"id":"prt_d79e0135f0015fPrZCDVMVv9H8","messageID":"msg_d79dffbf80016ewdIRJmlhit5n","sessionID":"ses_28620d44cffeKB7Ks6lA61lHBF","type":"tool","tool":"read","callID":"toolu_2cc76dbc4acd4dc0b2090565","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Agent metadata service and models.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from pathlib import Path\n6: from typing import Any, Dict, Optional\n7: \n8: import yaml\n9: from pydantic import BaseModel, Field, field_validator\n10: \n11: \n12: class AgentMetadata(BaseModel):\n13:     \"\"\"Agent metadata model for agent_metadata.yaml.\"\"\"\n14: \n15:     agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n16:     description: Optional[str] = Field(None, description=\"Human-readable summary\")\n17:     language: str = Field(\"python\", description=\"Programming language used\")\n18:     entrypoint: str = Field(..., description=\"Command to launch the agent\")\n19:     port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n20:     build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n21:     region: Optional[str] = Field(None, description=\"Deployment region\")\n22:     version: Optional[str] = Field(None, description=\"Semantic version string for publishing\")\n23:     image: Optional[Dict[str, Any]] = Field(None, description=\"Container image information\")\n24:     auth: Optional[Dict[str, Any]] = Field(None, description=\"Authentication configuration\")\n25:     requirements_file: Optional[str] = Field(\"requirements.txt\", description=\"Python dependency file\")\n26:     registry_url: Optional[str] = Field(\"\", description=\"Registry URL for image publishing\")\n27:     registry_username: Optional[str] = Field(\"\", description=\"Registry username\")\n28:     registry_password: Optional[str] = Field(\"\", description=\"Registry password\")\n29:     agent_endpoint: Optional[str] = Field(None, description=\"Agent endpoint URL\")\n30:     workload_manager_url: Optional[str] = Field(None, description=\"URL for the Workload Manager\")\n31:     router_url: Optional[str] = Field(None, description=\"URL for the Router\")\n32:     readiness_probe_path: Optional[str] = Field(None, description=\"Path for the readiness probe\")\n33:     readiness_probe_port: Optional[int] = Field(None, description=\"Port for the readiness probe\")\n34:     agent_id: Optional[str] = Field(None, description=\"Agent ID assigned by AgentCube\")\n35:     session_id: Optional[str] = Field(None, description=\"The session ID for the agent\")\n36:     k8s_deployment: Optional[Dict[str, Any]] = Field(None, description=\"Kubernetes deployment information\")\n37: \n38:     @field_validator(\"language\")\n39:     @classmethod\n40:     def validate_language(cls, v: str) -> str:\n41:         if v.lower() not in [\"python\", \"java\"]:\n42:             raise ValueError(f\"Unsupported language: {v}. Must be 'python' or 'java'\")\n43:         return v.lower()\n44: \n45:     @field_validator(\"build_mode\")\n46:     @classmethod\n47:     def validate_build_mode(cls, v: str) -> str:\n48:         if v.lower() not in [\"local\", \"cloud\"]:\n49:             raise ValueError(f\"Unsupported build mode: {v}. Must be 'local' or 'cloud'\")\n50:         return v.lower()\n51: \n52:     @field_validator(\"port\")\n53:     @classmethod\n54:     def validate_port(cls, v: int) -> int:\n55:         if not 1 <= v <= 65535:\n56:             raise ValueError(f\"Port must be between 1 and 65535, got {v}\")\n57:         return v\n58: \n59: \n60: class MetadataService:\n61:     \"\"\"Service for loading and saving agent metadata.\"\"\"\n62: \n63:     METADATA_FILES = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n64: \n65:     def __init__(self, verbose: bool = False) -> None:\n66:         self.verbose = verbose\n67: \n68:     def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n69:         \"\"\"Load metadata from workspace directory.\"\"\"\n70:         for filename in self.METADATA_FILES:\n71:             metadata_file = workspace_path / filename\n72:             if metadata_file.exists():\n73:                 with open(metadata_file, \"r\") as f:\n74:                     data = yaml.safe_load(f)\n75:                 return AgentMetadata(**data)\n76: \n77:         raise FileNotFoundError(\n78:             f\"No metadata file found. Expected one of: {', '.join(self.METADATA_FILES)}\"\n79:         )\n80: \n81:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n82:         \"\"\"Save metadata to workspace directory.\"\"\"\n83:         metadata_file = workspace_path / \"agent_metadata.yaml\"\n84:         with open(metadata_file, \"w\") as f:\n85:             yaml.dump(\n86:                 metadata.model_dump(exclude_none=True),\n87:                 f,\n88:                 default_flow_style=False,\n89:                 indent=2,\n90:                 sort_keys=False,\n91:             )\n92: \n93:     def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n94:         \"\"\"Update metadata with provided fields.\"\"\"\n95:         metadata = self.load_metadata(workspace_path)\n96:         updated_data = metadata.model_dump()\n97:         updated_data.update(updates)\n98:         updated_metadata = AgentMetadata(**updated_data)\n99:         self.save_metadata(workspace_path, updated_metadata)\n100:         return updated_metadata\n101: \n102:     def validate_workspace(self, workspace_path: Path) -> bool:\n103:         \"\"\"Validate workspace structure.\"\"\"\n104:         metadata = self.load_metadata(workspace_path)\n105: \n106:         if metadata.language == \"python\":\n107:             self._validate_python_workspace(workspace_path, metadata)\n108:         elif metadata.language == \"java\":\n109:             self._validate_java_workspace(workspace_path, metadata)\n110: \n111:         return True\n112: \n113:     def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n114:         \"\"\"Validate Python workspace.\"\"\"\n115:         py_files = list(workspace_path.glob(\"*.py\"))\n116:         if not py_files:\n117:             raise ValueError(\"No Python files found in workspace\")\n118: \n119:     def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n120:         \"\"\"Validate Java workspace.\"\"\"\n121:         pom_xml = workspace_path / \"pom.xml\"\n122:         if not pom_xml.exists():\n123:             raise ValueError(\"pom.xml not found in workspace\")\n\n(End of file - total 123 lines)\n</content>","metadata":{"preview":"\"\"\"Agent metadata service and models.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Agent metadata model for agent_metadata.yaml.\"\"\"\n\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: Optional[str] = Field(None, description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775866224407,"end":1775866224429}}}}
