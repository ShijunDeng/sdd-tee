{"type":"tool_use","timestamp":1775857443081,"sessionID":"ses_286a69499ffe42thtO1Jz8aHeX","part":{"id":"prt_d795a1bf7001Cdge4HQgT1viQm","messageID":"msg_d795a08de001tcLKlS9Pu4wKeM","sessionID":"ses_286a69499ffe42thtO1Jz8aHeX","type":"tool","tool":"read","callID":"toolu_0f67ae5e4cbc4bbdae71c551","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_valkey.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_valkey.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"fmt\"\n7: \t\"os\"\n8: \t\"strconv\"\n9: \t\"strings\"\n10: \t\"time\"\n11: \n12: \tvalkey \"github.com/valkey-io/valkey-go\"\n13: \twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n14: \t\"k8s.io/klog/v2\"\n15: )\n16: \n17: type valkeyStore struct {\n18: \tcli                  valkey.Client\n19: \tsessionPrefix        string\n20: \texpiryIndexKey       string\n21: \tlastActivityIndexKey string\n22: }\n23: \n24: func makeValkeyOptions() (*valkey.ClientOption, error) {\n25: \taddr := os.Getenv(\"VALKEY_ADDR\")\n26: \tif addr == \"\" {\n27: \t\treturn nil, fmt.Errorf(\"VALKEY_ADDR is required\")\n28: \t}\n29: \n30: \taddresses := strings.Split(addr, \",\")\n31: \n32: \tpassword := os.Getenv(\"VALKEY_PASSWORD\")\n33: \tpasswordRequired := true\n34: \tif val := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\"); val != \"\" {\n35: \t\tpasswordRequired = strings.ToLower(val) != \"false\"\n36: \t}\n37: \n38: \tif passwordRequired && password == \"\" {\n39: \t\treturn nil, fmt.Errorf(\"VALKEY_PASSWORD is required (set VALKEY_PASSWORD_REQUIRED=false to disable)\")\n40: \t}\n41: \n42: \tdisableCache := false\n43: \tif val := os.Getenv(\"VALKEY_DISABLE_CACHE\"); val != \"\" {\n44: \t\tdisableCache, _ = strconv.ParseBool(val)\n45: \t}\n46: \n47: \tforceSingle := false\n48: \tif val := os.Getenv(\"VALKEY_FORCE_SINGLE\"); val != \"\" {\n49: \t\tforceSingle, _ = strconv.ParseBool(val)\n50: \t}\n51: \n52: \topt := valkey.ClientOption{\n53: \t\tInitAddress:  addresses,\n54: \t\tPassword:     password,\n55: \t\tDisableCache: disableCache,\n56: \t}\n57: \n58: \tif forceSingle {\n59: \t\topt.ForceSingleClient = true\n60: \t}\n61: \n62: \treturn &opt, nil\n63: }\n64: \n65: func NewValkeyStore(opts *valkey.ClientOption) (*valkeyStore, error) {\n66: \tclient, err := valkey.NewClient(*opts)\n67: \tif err != nil {\n68: \t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n69: \t}\n70: \n71: \treturn &valkeyStore{\n72: \t\tcli:                  client,\n73: \t\tsessionPrefix:        sessionPrefix,\n74: \t\texpiryIndexKey:       expiryIndexKey,\n75: \t\tlastActivityIndexKey: lastActivityIndexKey,\n76: \t}, nil\n77: }\n78: \n79: func (vs *valkeyStore) Ping(ctx context.Context) error {\n80: \tresp := vs.cli.B().Ping().Build()\n81: \tresult, err := vs.cli.Do(ctx, resp).ToString()\n82: \tif err != nil {\n83: \t\treturn err\n84: \t}\n85: \tif result != \"PONG\" {\n86: \t\treturn fmt.Errorf(\"unexpected ping response: %q\", result)\n87: \t}\n88: \treturn nil\n89: }\n90: \n91: func (vs *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*wmTypes.SandboxInfo, error) {\n92: \tkey := vs.sessionPrefix + sessionID\n93: \tcmd := vs.cli.B().Get().Key(key).Build()\n94: \tresult, err := vs.cli.Do(ctx, cmd).ToString()\n95: \tif err != nil {\n96: \t\tif valkey.IsValkeyNil(err) {\n97: \t\t\treturn nil, ErrNotFound\n98: \t\t}\n99: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n100: \t}\n101: \n102: \tvar info wmTypes.SandboxInfo\n103: \tif err := json.Unmarshal([]byte(result), &info); err != nil {\n104: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox: %w\", err)\n105: \t}\n106: \treturn &info, nil\n107: }\n108: \n109: func (vs *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *wmTypes.SandboxInfo) error {\n110: \tif sandboxStore == nil {\n111: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n112: \t}\n113: \tif sandboxStore.ExpiresAt.IsZero() {\n114: \t\treturn fmt.Errorf(\"sandbox ExpiresAt cannot be zero\")\n115: \t}\n116: \n117: \tkey := vs.sessionPrefix + sandboxStore.SessionID\n118: \tdata, err := json.Marshal(sandboxStore)\n119: \tif err != nil {\n120: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n121: \t}\n122: \n123: \tnow := time.Now().Unix()\n124: \texpiresAt := sandboxStore.ExpiresAt.Unix()\n125: \tlastActivity := sandboxStore.LastActivityAt.Unix()\n126: \tif lastActivity == 0 {\n127: \t\tlastActivity = now\n128: \t}\n129: \n130: \tsetCmd := vs.cli.B().Setnx().Key(key).Value(string(data)).Build()\n131: \texpiryCmd := vs.cli.B().Zadd().Key(vs.expiryIndexKey).ScoreMember().ScoreMember(float64(expiresAt), sandboxStore.SessionID).Build()\n132: \tlastActivityCmd := vs.cli.B().Zadd().Key(vs.lastActivityIndexKey).ScoreMember().ScoreMember(float64(lastActivity), sandboxStore.SessionID).Build()\n133: \n134: \tresponses := vs.cli.DoMulti(ctx, setCmd, expiryCmd, lastActivityCmd)\n135: \n136: \tsetResult, err := responses[0].AsBool()\n137: \tif err != nil {\n138: \t\treturn fmt.Errorf(\"SETNX failed: %w\", err)\n139: \t}\n140: \tif !setResult {\n141: \t\treturn fmt.Errorf(\"session %s already exists\", sandboxStore.SessionID)\n142: \t}\n143: \n144: \tif err := responses[1].Error(); err != nil {\n145: \t\treturn fmt.Errorf(\"ZADD expiry failed: %w\", err)\n146: \t}\n147: \tif err := responses[2].Error(); err != nil {\n148: \t\treturn fmt.Errorf(\"ZADD last_activity failed: %w\", err)\n149: \t}\n150: \n151: \treturn nil\n152: }\n153: \n154: func (vs *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *wmTypes.SandboxInfo) error {\n155: \tif sandboxStore == nil {\n156: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n157: \t}\n158: \n159: \tkey := vs.sessionPrefix + sandboxStore.SessionID\n160: \tdata, err := json.Marshal(sandboxStore)\n161: \tif err != nil {\n162: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n163: \t}\n164: \n165: \tcmd := vs.cli.B().Set().Key(key).Value(string(data)).Xx().Build()\n166: \tresult, err := vs.cli.Do(ctx, cmd).ToString()\n167: \tif err != nil {\n168: \t\treturn fmt.Errorf(\"SET XX failed: %w\", err)\n169: \t}\n170: \tif result != \"OK\" {\n171: \t\treturn ErrNotFound\n172: \t}\n173: \n174: \treturn nil\n175: }\n176: \n177: func (vs *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n178: \tkey := vs.sessionPrefix + sessionID\n179: \n180: \tdelCmd := vs.cli.B().Del().Key(key).Build()\n181: \texpiryCmd := vs.cli.B().Zrem().Key(vs.expiryIndexKey).Member(sessionID).Build()\n182: \tlastActivityCmd := vs.cli.B().Zrem().Key(vs.lastActivityIndexKey).Member(sessionID).Build()\n183: \n184: \tresponses := vs.cli.DoMulti(ctx, delCmd, expiryCmd, lastActivityCmd)\n185: \n186: \tfor i, resp := range responses {\n187: \t\tif err := resp.Error(); err != nil {\n188: \t\t\treturn fmt.Errorf(\"command %d failed: %w\", i, err)\n189: \t\t}\n190: \t}\n191: \n192: \treturn nil\n193: }\n194: \n195: func (vs *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*wmTypes.SandboxInfo, error) {\n196: \tif limit <= 0 {\n197: \t\treturn nil, nil\n198: \t}\n199: \n200: \tcmd := vs.cli.B().Zrangebyscore().Key(vs.expiryIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()\n201: \tsessionIDs, err := vs.cli.Do(ctx, cmd).AsStrSlice()\n202: \tif err != nil {\n203: \t\treturn nil, fmt.Errorf(\"failed to query expired sessions: %w\", err)\n204: \t}\n205: \n206: \treturn vs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n207: }\n208: \n209: func (vs *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*wmTypes.SandboxInfo, error) {\n210: \tif limit <= 0 {\n211: \t\treturn nil, nil\n212: \t}\n213: \n214: \tcmd := vs.cli.B().Zrangebyscore().Key(vs.lastActivityIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()\n215: \tsessionIDs, err := vs.cli.Do(ctx, cmd).AsStrSlice()\n216: \tif err != nil {\n217: \t\treturn nil, fmt.Errorf(\"failed to query inactive sessions: %w\", err)\n218: \t}\n219: \n220: \treturn vs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n221: }\n222: \n223: func (vs *valkeyStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*wmTypes.SandboxInfo, error) {\n224: \tif len(sessionIDs) == 0 {\n225: \t\treturn nil, nil\n226: \t}\n227: \n228: \tkeys := make([]string, len(sessionIDs))\n229: \tfor i, sid := range sessionIDs {\n230: \t\tkeys[i] = vs.sessionPrefix + sid\n231: \t}\n232: \n233: \tmgetCmd := vs.cli.B().Mget().Key(keys...).Build()\n234: \tresults, err := vs.cli.Do(ctx, mgetCmd).AsStrSlice()\n235: \tif err != nil {\n236: \t\treturn nil, fmt.Errorf(\"MGET failed: %w\", err)\n237: \t}\n238: \n239: \tvar result []*wmTypes.SandboxInfo\n240: \tfor i, data := range results {\n241: \t\tif data == \"\" {\n242: \t\t\tklog.Warningf(\"orphaned ZSET member: session %s not found\", sessionIDs[i])\n243: \t\t\tcontinue\n244: \t\t}\n245: \n246: \t\tvar info wmTypes.SandboxInfo\n247: \t\tif err := json.Unmarshal([]byte(data), &info); err != nil {\n248: \t\t\tklog.Warningf(\"failed to unmarshal session %s: %v\", sessionIDs[i], err)\n249: \t\t\tcontinue\n250: \t\t}\n251: \t\tresult = append(result, &info)\n252: \t}\n253: \n254: \treturn result, nil\n255: }\n256: \n257: func (vs *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n258: \tif sessionID == \"\" {\n259: \t\treturn fmt.Errorf(\"sessionID cannot be empty\")\n260: \t}\n261: \n262: \tkey := vs.sessionPrefix + sessionID\n263: \n264: \texistsCmd := vs.cli.B().Exists().Key(key).Build()\n265: \tcount, err := vs.cli.Do(ctx, existsCmd).AsInt64()\n266: \tif err != nil {\n267: \t\treturn fmt.Errorf(\"EXISTS failed: %w\", err)\n268: \t}\n269: \tif count == 0 {\n270: \t\treturn ErrNotFound\n271: \t}\n272: \n273: \tif at.IsZero() {\n274: \t\tat = time.Now()\n275: \t}\n276: \n277: \tzaddCmd := vs.cli.B().Zadd().Key(vs.lastActivityIndexKey).ScoreMember().ScoreMember(float64(at.Unix()), sessionID).Build()\n278: \treturn vs.cli.Do(ctx, zaddCmd).Error()\n279: }\n280: \n281: func (vs *valkeyStore) Close() error {\n282: \tvs.cli.Close()\n283: \treturn nil\n284: }\n\n(End of file - total 284 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tvalkey \"github.com/valkey-io/valkey-go\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_valkey.go","time":{"start":1775857443059,"end":1775857443078}}}}
