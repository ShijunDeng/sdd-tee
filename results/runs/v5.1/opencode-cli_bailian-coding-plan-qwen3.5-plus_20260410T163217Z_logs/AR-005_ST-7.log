ntryPoint `json:\"entryPoints\"`\n39: }\n40: \n41: // SandboxEntryPoint represents an entry point for accessing the sandbox.\n42: type SandboxEntryPoint struct {\n43: \tPath     string `json:\"path\"`\n44: \tProtocol string `json:\"protocol\"`\n45: \tEndpoint string `json:\"endpoint\"`\n46: }\n47: \n48: // SandboxInfo contains information about a sandbox session.\n49: type SandboxInfo struct {\n50: \tSessionID          string              `json:\"sessionId\"`\n51: \tSandboxID          string              `json:\"sandboxId\"`\n52: \tSandboxName        string              `json:\"sandboxName\"`\n53: \tKind               string              `json:\"kind\"`\n54: \tNamespace          string              `json:\"namespace\"`\n55: \tWorkloadName       string              `json:\"workloadName\"`\n56: \tStatus             string              `json:\"status\"`\n57: \tPodIP              string              `json:\"podIP,omitempty\"`\n58: \tEntryPoints        []SandboxEntryPoint `json:\"entryPoints,omitempty\"`\n59: \tCreatedAt          time.Time           `json:\"createdAt\"`\n60: \tUpdatedAt          time.Time           `json:\"updatedAt\"`\n61: \tIdleTimeout        string              `json:\"idleTimeout,omitempty\"`\n62: \tMaxSessionDuration string              `json:\"maxSessionDuration,omitempty\"`\n63: }\n64: \n65: // TargetPort represents a target port configuration.\n66: type TargetPort struct {\n67: \tPort       int32  `json:\"port\"`\n68: \tProtocol   string `json:\"protocol\"`\n69: \tPathPrefix string `json:\"pathPrefix\"`\n70: }\n\n(End of file - total 70 lines)\n</content>","metadata":{"preview":"package types\n\nimport (\n\t\"fmt\"\n\t\"time\"\n)\n\n// CreateSandboxRequest represents a request to create a sandbox.\ntype CreateSandboxRequest struct {\n\tKind      string            `json:\"kind\"`\n\tName      string            `json:\"name\"`\n\tNamespace string            `json:\"namespace\"`\n\tLabels    map[string]string `json:\"labels,omitempty\"`\n}\n\n// Val