result\n\t\t}(i)\n\t}\n\n\twg.Wait()\n\tclose(results)\n\tclose(errors)\n\n\tif len(errors) > 0 {\n\t\tfor err := range errors {\n\t\t\tt.Errorf(\"concurrent execution error: %v\", err)\n\t\t}\n\t}\n\n\tsuccessCount := 0\n\tfor result := range results {\n\t\tif result.ExitCode == 0 {\n\t\t\tsuccessCount++\n\t\t}\n\t}\n\n\tif successCount != numCommands {\n\t\tt.Errorf(\"expected %d successful commands, got %d\", numCommands, successCount)\n\t}\n}\n\nfunc TestPicoD_Integration_ResourceLimits(t *testing.T) {\n\tif testing.Short() {\n\t\tt.Skip(\"skipping integration test in short mode\")\n\t}\n\n\tlimits := &ResourceLimits{\n\t\tTimeout:       5 * time.Second,\n\t\tMaxCPU:        1.0,\n\t\tMaxMemory:     10 * 1024 * 1024,\n\t\tMaxOutputSize: 10 * 1024 * 1024,\n\t\tMaxProcesses:  10,\n\t}\n\n\tp := New(\"test-limits\", WithLimits(limits))\n\tdefer os.RemoveAll(p.GetWorkDir())\n\n\tcmd := &Command{\n\t\tPath: \"echo\",\n\t\tArgs: []string{\"test\"},\n\t}\n\n\tresult, err := p.Run(context.Background(), cmd)\n\tif err != nil {\n\t\tt.Fatalf(\"Run() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n}\n\nfunc TestPicoD_Integration_Streaming(t *testing.T) {\n\tif testing.Short() {\n\t\tt.Skip(\"skipping integration test in short mode\")\n\t}\n\n\tp := New(\"test-streaming\")\n\tdefer os.RemoveAll(p.GetWorkDir())\n\n\tcmd := &Command{\n\t\tPath: \"sh\",\n\t\tArgs: []string{\"-c\", \"echo line1; sleep 0.1; echo line2\"},\n\t}\n\n\thandler := &mockOutputHandler{\n\t\tstdoutCalls: make([][]byte, 0),\n\t}\n\n\tresult, err := p.RunWithStreaming(context.Background(), cmd, handler)\n\tif err != nil {\n\t\tt.Fatalf(\"RunWithStreaming() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n\n\tif len(handler.stdoutCalls) == 0 {\n\t\tt.Error(\"expected stdout output from streaming\")\n\t}\n}\n\nfunc TestPicoD_Integration_SignalHandling(t *testing.T) {\n\tif testing.Short() {\n\t\tt.Skip(\"skipping integration test in short mode\")\n\t}\n\n\tp := New(\"test-signals\")\n\tdefer os.RemoveAll(p.GetWorkDir())\n\n\tcmd := &Command{\n\t\tPath: \"sleep\",\n\t\tArgs: []string{\"sleep\", \"10\"},\n\t}\n\n\tprocess, err := p.Start(context.Background(), cmd)\n\tif err != nil {\n\t\tt.Fatalf(\"Start() unexpected error: %v\", err)\n\t}\n\n\ttime.Sleep(100 * time.Millisecond)\n\n\terr = process.Signal(syscall.SIGTERM)\n\tif err != nil {\n\t\tt.Errorf(\"Signal() unexpected error: %v\", err)\n\t}\n\n\t_, err = process.Wait()\n\tif err == nil {\n\t\tt.Error(\"Wait() expected error after signal\")\n\t}\n}\n\nfunc TestPicoD_Integration_Timeout(t *testing.T) {\n\tif testing.Short() {\n\t\tt.Skip(\"skipping integration test in short mode\")\n\t}\n\n\tlimits := &ResourceLimits{\n\t\tTimeout:       500 * time.Millisecond,\n\t\tMaxCPU:        1.0,\n\t\tMaxMemory:     128 * 1024 * 1024,\n\t\tMaxOutputSize: 10 * 1024 * 1024,\n\t\tMaxProcesses:  10,\n\t}\n\n\tp := New(\"test-timeout\", WithLimits(limits))\n\tdefer os.RemoveAll(p.GetWorkDir())\n\n\tcmd := &Command{\n\t\tPath: \"sleep\",\n\t\tArgs: []string{\"2\"},\n\t}\n\n\tresult, err := p.Run(context.Background(), cmd)\n\tif err == nil {\n\t\tt.Fatal(\"Run() expected timeout error\")\n\t}\n\n\tif !result.Timeout {\n\t\tt.Error(\"expected Timeout=true\")\n\t}\n\n\texecErr, ok := err.(*ExecutionError)\n\tif !ok {\n\t\tt.Fatalf(\"expected ExecutionError, got %T\", err)\n\t}\n\tif execErr.Type != ExecutionErrorTimeout {\n\t\tt.Errorf(\"expected ExecutionErrorTimeout, got %v\", execErr.Type)\n\t}\n}\n\nfunc TestPicoD_Integration_ContextCancellation(t *testing.T) {\n\tif testing.Short() {\n\t\tt.Skip(\"skipping integration test in short mode\")\n\t}\n\n\tp := New(\"test-cancel\")\n\tdefer os.RemoveAll(p.GetWorkDir())\n\n\tcmd := &Command{\n\t\tPath: \"sleep\",\n\t\tArgs: []string{\"10\"},\n\t}\n\n\tctx, cancel := context.WithCancel(context.Background())\n\n\tgo func() {\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\tcancel()\n\t}()\n\n\t_, err := p.Run(ctx, cmd)\n\tif err == nil {\n\t\tt.Fatal(\"Run() expected cancellation error\")\n\t}\n}\n\nfunc TestPicoD_Integration_WorkDir(t *testing.T) {\n\tif testing.Short() {\n\t\tt.Skip(\"skipping integration test in short mode\")\n\t}\n\n\ttmpDir, err := os.MkdirTemp(\"\", \"picod-test-*\")\n\tif err != nil {\n\t\tt.Fatalf(\"failed to create temp dir: %v\", err)\n\t}\n\tdefer os.RemoveAll(tmpDir)\n\n\tp := New(\"test-workdir\", WithWorkDir(tmpDir))\n\n\tif p.GetWorkDir() != tmpDir {\n\t\tt.Errorf(\"expected WorkDir=%s, got %s\", tmpDir, p.GetWorkDir())\n\t}\n\n\tcmd := &Command{\n\t\tPath: \"pwd\",\n\t\tArgs: []string{\"pwd\"},\n\t\tDir:  tmpDir,\n\t}\n\n\tresult, err := p.Run(context.Background(), cmd)\n\tif err != nil {\n\t\tt.Fatalf(\"Run() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n}\n\nfunc TestPicoD_Integration_EnvironmentVariables(t *testing.T) {\n\tif testing.Short() {\n\t\tt.Skip(\"skipping integration test in short mode\")\n\t}\n\n\tp := New(\"test-env\")\n\tdefer os.RemoveAll(p.GetWorkDir())\n\n\tcmd := &Command{\n\t\tPath: \"sh\",\n\t\tArgs: []string{\"sh\", \"-c\", \"echo $TEST_VAR\"},\n\t\tEnv:  []string{\"TEST_VAR=hello\"},\n\t}\n\n\tresult, err := p.Run(context.Background(), cmd)\n\tif err != nil {\n\t\tt.Fatalf(\"Run() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n\n\tif !bytes.Contains(result.Stdout, []byte(\"hello\")) {\n\t\tt.Errorf(\"expected Stdout to contain 'hello', got %q\", result.Stdout)\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"os\"\n\t\"sync\"\n\t\"syscall\"\n\t\"testing\"\n\t\"time\"\n)\n\nfunc TestPicoD_Integration_FullLifecycle(t *testing.T) {\n\tif testing.Short() {\n\t\tt.Skip(\"skipping integration test in short mode\")\n\t}\n\n\tp := New