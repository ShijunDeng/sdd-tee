rkspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/output_test.go\n@@ -42,9 +42,9 @@\n executor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n \n cmd := &Command{\n \tPath: \"echo\",\n-\tArgs: []string{\"echo\", \"hello\"},\n+\tArgs: []string{\"hello\"},\n }\n \n handler := &mockOutputHandler{}\n \n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/output_test.go","before":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"sync\"\n\t\"testing\"\n)\n\ntype mockOutputHandler struct {\n\tmu             sync.Mutex\n\tstdoutCalls    [][]byte\n\tstderrCalls    [][]byte\n\tcompleteCalled bool\n\tlastResult     *CommandResult\n}\n\nfunc (m *mockOutputHandler) OnStdout(data []byte) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tdataCopy := make([]byte, len(data))\n\tcopy(dataCopy, data)\n\tm.stdoutCalls = append(m.stdoutCalls, dataCopy)\n}\n\nfunc (m *mockOutputHandler) OnStderr(data []byte) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tdataCopy := make([]byte, len(data))\n\tcopy(dataCopy, data)\n\tm.stderrCalls = append(m.stderrCalls, dataCopy)\n}\n\nfunc (m *mockOutputHandler) OnComplete(result *CommandResult) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.completeCalled = true\n\tm.lastResult = result\n}\n\nfunc TestRunWithStreaming(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"echo\",\n\t\tArgs: []string{\"echo\", \"hello\"},\n\t}\n\n\thandler := &mockOutputHandler{}\n\n\tresult, err := executor.RunWithStreaming(context.Background(), cmd, handler)\n\tif err != nil {\n\t\tt.Fatalf(\"RunWithStreaming() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n\n\tif !handler.completeCalled {\n\t\tt.Error(\"expected OnComplete to be called\")\n\t}\n\n\tif handler.lastResult == nil {\n\t\tt.Fatal(\"expected lastResult to be set\")\n\t}\n\n\tif handler.lastResult.ExitCode != 0 {\n\t\tt.Errorf(\"expected lastResult.ExitCode=0, got %d\", handler.lastResult.ExitCode)\n\t}\n}\n\nfunc TestRunWithStreaming_StdoutStderr(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"sh\",\n\t\tArgs: []string{\"sh\", \"-c\", \"echo stdout; echo stderr >&2\"},\n\t}\n\n\thandler := &mockOutputHandler{}\n\n\tresult, err := executor.RunWithStreaming(context.Background(), cmd, handler)\n\tif err != nil {\n\t\tt.Fatalf(\"RunWithStreaming() unexpected error: %v\", err)\n\t}\n\n\thandler.mu.Lock()\n\tstdoutCalls := len(handler.stdoutCalls)\n\tstderrCalls := len(handler.stderrCalls)\n\thandler.mu.Unlock()\n\n\tif stdoutCalls == 0 {\n\t\tt.Error(\"expected OnStdout to be called\")\n\t}\n\n\tif stderrCalls == 0 {\n\t\tt.Error(\"expected OnStderr to be called\")\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n}\n\nfunc TestRunWithStreaming_EmptyOutput(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"true\",\n\t\tArgs: []string{\"true\"},\n\t}\n\n\thandler := &mockOutputHandler{}\n\n\tresult, err := executor.RunWithStreaming(context.Background(), cmd, handler)\n\tif err != nil {\n\t\tt.Fatalf(\"RunWithStreaming() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n\n\tif !handler.completeCalled {\n\t\tt.Error(\"expected OnComplete to be called\")\n\t}\n}\n\nfunc TestOutputHandler_Interface(t *testing.T) {\n\thandler := &mockOutputHandler{}\n\n\thandler.OnStdout([]byte(\"test\"))\n\thandler.OnStderr([]byte(\"error\"))\n\thandler.OnComplete(&CommandResult{ExitCode: 0})\n\n\thandler.mu.Lock()\n\tdefer handler.mu.Unlock()\n\n\tif len(handler.stdoutCalls) != 1 {\n\t\tt.Errorf(\"expected 1 stdout call, got %d\", len(handler.stdoutCalls))\n\t}\n\n\tif len(handler.stderrCalls) != 1 {\n\t\tt.Errorf(\"expected 1 stderr call, got %d\", len(handler.stderrCalls))\n\t}\n\n\tif !handler.completeCalled {\n\t\tt.Error(\"expected OnComplete to be called\")\n\t}\n\n\tif handler.lastResult == nil {\n\t\tt.Error(\"expected lastResult to be set\")\n\t}\n}\n\nfunc TestTeeWriter(t *testing.T) {\n\tvar buf bytes.Buffer\n\tvar called bool\n\n\ttee := &teeWriter{\n\t\twriter: &buf,\n\t\thandler: func(data []byte) {\n\t\t\tcalled = true\n\t\t},\n\t}\n\n\tn, err := tee.Write([]byte(\"hello\"))\n\tif err != nil {\n\t\tt.Fatalf(\"Write() unexpected error: %v\", err)\n\t}\n\n\tif n != 5 {\n\t\tt.Errorf(\"expected n=5, got %d\", n)\n\t}\n\n\tif !called {\n\t\tt.Error(\"expected handler to be called\")\n\t}\n\n\tif buf.String() != \"hello\" {\n\t\tt.Errorf(\"expected buffer to be %q, got %q\", \"hello\", buf.String())\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"sync\"\n\t\"testing\"\n)\n\ntype mockOutputHandler struct {\n\tmu             sync.Mutex\n\tstdoutCalls    [][]byte\n\tstderrCalls    [][]byte\n\tcompleteCalled bool\n\tlastResult     *CommandResult\n}\n\nfunc (m *mockOutputHandler) OnStdout(data []byte) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tdataCopy := make([]byte, len(data))\n\tcopy(dataCopy, data)\n\tm.stdoutCalls = append(m.stdoutCalls, dataCopy)\n}\n\nfunc (m *mockOutputHandler) OnStderr(data []byte) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tdataCopy := make([]byte, len(data))\n\tcopy(dataCopy, data)\n\tm.stderrCalls = append(m.stderrCalls, dataCopy)\n}\n\nfunc (m *mockOutputHandler) OnComplete(result *CommandResult) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\tm.completeCalled = true\n\tm.lastResult = result\n}\n\nfunc TestRunWithStreaming(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"echo\",\n\t\tArgs: []string{\"hello\"},\n\t}\n\n\thandler := &mockOutputHandle