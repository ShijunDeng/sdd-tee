next.ServeHTTP(w, r)\n54: \t})\n55: }\n56: \n57: func (m *JWTMiddleware) extractToken(r *http.Request) (string, error) {\n58: \tauthHeader := r.Header.Get(\"Authorization\")\n59: \tif authHeader == \"\" {\n60: \t\treturn \"\", &AuthError{\n61: \t\t\tType:    AuthErrorMissingToken,\n62: \t\t\tMessage: \"missing authorization header\",\n63: \t\t}\n64: \t}\n65: \n66: \tconst bearerPrefix = \"Bearer \"\n67: \tif len(authHeader) < len(bearerPrefix) || !strings.HasPrefix(authHeader, bearerPrefix) {\n68: \t\treturn \"\", &AuthError{\n69: \t\t\tType:    AuthErrorInvalidToken,\n70: \t\t\tMessage: \"invalid authorization format\",\n71: \t\t}\n72: \t}\n73: \n74: \ttoken := strings.TrimPrefix(authHeader, bearerPrefix)\n75: \tif token == \"\" {\n76: \t\treturn \"\", &AuthError{\n77: \t\t\tType:    AuthErrorMissingToken,\n78: \t\t\tMessage: \"empty token\",\n79: \t\t}\n80: \t}\n81: \n82: \treturn token, nil\n83: }\n84: \n85: func (m *JWTMiddleware) shouldSkip(path string) bool {\n86: \treturn m.skipPaths[path]\n87: }\n88: \n89: type HealthResponse struct {\n90: \tStatus    string    `json:\"status\"`\n91: \tTimestamp time.Time `json:\"timestamp\"`\n92: \tSandboxID string    `json:\"sandbox_id,omitempty\"`\n93: }\n94: \n95: func WriteJSON(w http.ResponseWriter, status int, data interface{}) {\n96: \tw.Header().Set(\"Content-Type\", \"application/json\")\n97: \tw.WriteHeader(status)\n98: \tif err := json.NewEncoder(w).Encode(data); err != nil {\n99: \t\tklog.ErrorS(err, \"failed to write JSON response\")\n100: \t}\n101: }\n102: \n103: func WriteError(w http.ResponseWriter, err error) {\n104: \tvar authErr *AuthError\n105: \tif errors.As(err, &authErr) {\n106: \t\tresponse := map[string]string{\n107: \t\t\t\"error\": string(authErr.Type),\n108: \t\t}\n109: \t\tif authErr.Message != \"\" {\n110: \t\t\tresponse[\"message\"] = authErr.Message\n111: \t\t}\n112: \t\tWriteJSON(w, authErr.HTTPStatus(), response)\n113: \t\treturn\n114: \t}\n115: \n116: \tWriteJSON(w, http.StatusInternalServerError, map[string]string{\n117: \t\t\"error\": \"internal_error\",\n118: \t})\n119: }\n\n(End of file - total 119 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"net/http\"\n\t\"strings\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n)\n\ntype JWTMiddleware struct {\n\tpublicKey *rsa.PublicKey\n\tskipPaths map[string]bool\n\tlogger    klog.Logger\n}\n\nfunc NewJWTMiddleware(publicKey *rsa.PublicKey, skipPaths ...string) *JWTMiddleware {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/middleware.go","time":{"start":1775889690415,"end":1775889690436}}}}
