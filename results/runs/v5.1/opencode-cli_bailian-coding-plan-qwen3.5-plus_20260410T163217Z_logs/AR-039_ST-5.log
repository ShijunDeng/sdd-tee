t64\n52: \n53: \terr := filepath.Walk(workDir, func(path string, info os.FileInfo, err error) error {\n54: \t\tif err != nil {\n55: \t\t\treturn err\n56: \t\t}\n57: \t\tif !info.IsDir() {\n58: \t\t\ttotalSize += info.Size()\n59: \t\t\tfileCount++\n60: \t\t}\n61: \t\treturn nil\n62: \t})\n63: \n64: \tif err != nil {\n65: \t\treturn nil, err\n66: \t}\n67: \n68: \treturn &QuotaUsage{\n69: \t\tUsedBytes:   totalSize,\n70: \t\tFileCount:   fileCount,\n71: \t\tMaxBytes:    DefaultFileQuota().MaxTotalSize,\n72: \t\tMaxFiles:    DefaultFileQuota().MaxFiles,\n73: \t\tPercentUsed: float64(totalSize) / float64(DefaultFileQuota().MaxTotalSize) * 100,\n74: \t}, nil\n75: }\n76: \n77: func checkWriteQuota(workDir string, quota *FileQuota, fileSize int64) error {\n78: \tusage, err := calculateQuotaUsage(workDir)\n79: \tif err != nil {\n80: \t\treturn err\n81: \t}\n82: \n83: \tif fileSize > quota.MaxFileSize {\n84: \t\treturn &FileError{\n85: \t\t\tType:    FileErrorQuotaExceeded,\n86: \t\t\tMessage: fmt.Sprintf(\"file size %d exceeds max file size %d\", fileSize, quota.MaxFileSize),\n87: \t\t}\n88: \t}\n89: \n90: \tif usage.FileCount+1 > quota.MaxFiles {\n91: \t\treturn &FileError{\n92: \t\t\tType:    FileErrorQuotaExceeded,\n93: \t\t\tMessage: fmt.Sprintf(\"file count %d would exceed max files %d\", usage.FileCount+1, quota.MaxFiles),\n94: \t\t}\n95: \t}\n96: \n97: \tif usage.UsedBytes+fileSize > quota.MaxTotalSize {\n98: \t\treturn &FileError{\n99: \t\t\tType:    FileErrorQuotaExceeded,\n100: \t\t\tMessage: fmt.Sprintf(\"total size %d would exceed max total size %d\", usage.UsedBytes+fileSize, quota.MaxTotalSize),\n101: \t\t}\n102: \t}\n103: \n104: \treturn nil\n105: }\n\n(End of file - total 105 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n)\n\ntype FileQuota struct {\n\tMaxFileSize       int64\n\tMaxTotalSize      int64\n\tMaxFiles          int64\n\tMaxDirectoryDepth int\n}\n\nfunc (q *FileQuota) Validate() error {\n\tif q.MaxFileSize <= 0 {\n\t\treturn fmt.Errorf(\"MaxFileSize must be > 0, got %d\", q.MaxFileSize)\n\t}\n\tif q.MaxTotalSize <= 0 {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/quota.go","time":{"start":1775889673348,"end":1775889673376}}}}
