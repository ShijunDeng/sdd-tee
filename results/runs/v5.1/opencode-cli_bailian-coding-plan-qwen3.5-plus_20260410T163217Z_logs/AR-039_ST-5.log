, cmd, handler)\n52: \tif err != nil {\n53: \t\tt.Fatalf(\"RunWithStreaming() unexpected error: %v\", err)\n54: \t}\n55: \n56: \tif result.ExitCode != 0 {\n57: \t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n58: \t}\n59: \n60: \tif !handler.completeCalled {\n61: \t\tt.Error(\"expected OnComplete to be called\")\n62: \t}\n63: \n64: \tif handler.lastResult == nil {\n65: \t\tt.Fatal(\"expected lastResult to be set\")\n66: \t}\n67: \n68: \tif handler.lastResult.ExitCode != 0 {\n69: \t\tt.Errorf(\"expected lastResult.ExitCode=0, got %d\", handler.lastResult.ExitCode)\n70: \t}\n71: }\n72: \n73: func TestRunWithStreaming_StdoutStderr(t *testing.T) {\n74: \texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n75: \n76: \tcmd := &Command{\n77: \t\tPath: \"sh\",\n78: \t\tArgs: []string{\"sh\", \"-c\", \"echo stdout; echo stderr >&2\"},\n79: \t}\n80: \n81: \thandler := &mockOutputHandler{}\n82: \n83: \tresult, err := executor.RunWithStreaming(context.Background(), cmd, handler)\n84: \tif err != nil {\n85: \t\tt.Fatalf(\"RunWithStreaming() unexpected error: %v\", err)\n86: \t}\n87: \n88: \thandler.mu.Lock()\n89: \tstdoutCalls := len(handler.stdoutCalls)\n90: \tstderrCalls := len(handler.stderrCalls)\n91: \thandler.mu.Unlock()\n92: \n93: \tif stdoutCalls == 0 {\n94: \t\tt.Error(\"expected OnStdout to be called\")\n95: \t}\n96: \n97: \tif stderrCalls == 0 {\n98: \t\tt.Error(\"expected OnStderr to be called\")\n99: \t}\n100: \n101: \tif result.ExitCode != 0 {\n102: \t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n103: \t}\n104: }\n105: \n106: func TestRunWithStreaming_EmptyOutput(t *testing.T) {\n107: \texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n108: \n109: \tcmd := &Command{\n110: \t\tPath: \"true\",\n111: \t\tArgs: []string{\"true\"},\n112: \t}\n113: \n114: \thandler := &mockOutputHandler{}\n115: \n116: \tresult, err := executor.RunWithStreaming(context.Background(), cmd, handler)\n117: \tif err != nil {\n118: \t\tt.Fatalf(\"RunWithStreaming() unexpected error: %v\", err)\n119: \t}\n120: \n121: \tif result.ExitCode != 0 {\n122: \t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n123: \t}\n124: \n125: \tif !handler.completeCalled {\n126: \t\tt.Error(\"expected OnComplete to be called\")\n127: \t}\n128: }\n129: \n130: func TestOutputHandler_Interface(t *testing.T) {\n131: \thandler := &mockOutputHandler{}\n132: \n133: \thandler.OnStdout([]byte(\"test\"))\n134: \thandler.OnStderr([]byte(\"error\"))\n135: \thandler.OnComplete(&CommandResult{ExitCode: 0})\n136: \n137: \thandler.mu.Lock()\n138: \tdefer handler.mu.Unlock()\n139: \n140: \tif len(handler.stdoutCalls) != 1 {\n141: \t\tt.Errorf(\"expected 1 stdout call, got %d\", len(handler.stdoutCalls))\n142: \t}\n143: \n144: \tif len(handler.stderrCalls) != 1 {\n145: \t\tt.Errorf(\"expected 1 stderr call, got %d\", len(handler.stderrCalls))\n146: \t}\n147: \n148: \tif !handler.completeCalled {\n149: \t\tt.Error(\"expected OnComplete to be called\")\n150: \t}\n151: \n152: \tif handler.lastResult == nil {\n153: \t\tt.Error(\"expected lastResult to be set\")\n154: \t}\n155: }\n156: \n157: func TestTeeWriter(t *testing.T) {\n158: \tvar buf bytes.Buffer\n159: \tvar called bool\n160: \n161: \ttee := &teeWriter{\n162: \t\twriter: &buf,\n163: \t\thandler: func(data []byte) {\n164: \t\t\tcalled = true\n165: \t\t},\n166: \t}\n167: \n168: \tn, err := tee.Write([]byte(\"hello\"))\n169: \tif err != nil {\n170: \t\tt.Fatalf(\"Write() unexpected error: %v\", err)\n171: \t}\n172: \n173: \tif n != 5 {\n174: \t\tt.Errorf(\"expected n=5, got %d\", n)\n175: \t}\n176: \n177: \tif !called {\n178: \t\tt.Error(\"expected handler to be called\")\n179: \t}\n180: \n181: \tif buf.String() != \"hello\" {\n182: \t\tt.Errorf(\"expected buffer to be %q, got %q\", \"hello\", buf.String())\n183: \t}\n184: }\n\n(End of file - total 184 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"sync