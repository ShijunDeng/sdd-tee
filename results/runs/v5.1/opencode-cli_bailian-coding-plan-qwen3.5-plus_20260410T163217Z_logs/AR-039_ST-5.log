curity,\n54: \t\t\t\tMessage: fmt.Sprintf(\"command %q not in allowlist\", cmd.Path),\n55: \t\t\t}\n56: \t\t}\n57: \t}\n58: \n59: \tif cmd.Dir != \"\" && opts.WorkDir != \"\" {\n60: \t\tif !IsPathSafe(cmd.Dir, opts.WorkDir) {\n61: \t\t\treturn &ExecutionError{\n62: \t\t\t\tType:    ExecutionErrorSecurity,\n63: \t\t\t\tMessage: fmt.Sprintf(\"working directory %q is outside workspace\", cmd.Dir),\n64: \t\t\t}\n65: \t\t}\n66: \t}\n67: \n68: \tfor _, arg := range cmd.Args {\n69: \t\tif strings.Contains(arg, \"..\") {\n70: \t\t\treturn &ExecutionError{\n71: \t\t\t\tType:    ExecutionErrorSecurity,\n72: \t\t\t\tMessage: fmt.Sprintf(\"argument %q contains path traversal\", arg),\n73: \t\t\t}\n74: \t\t}\n75: \t}\n76: \n77: \tfor _, env := range cmd.Env {\n78: \t\tif strings.HasPrefix(env, \"LD_PRELOAD=\") || strings.HasPrefix(env, \"LD_LIBRARY_PATH=\") {\n79: \t\t\treturn &ExecutionError{\n80: \t\t\t\tType:    ExecutionErrorSecurity,\n81: \t\t\t\tMessage: fmt.Sprintf(\"dangerous environment variable: %s\", env),\n82: \t\t\t}\n83: \t\t}\n84: \t}\n85: \n86: \treturn nil\n87: }\n88: \n89: func IsPathSafe(path, workDir string) bool {\n90: \tabsPath, err := filepath.Abs(path)\n91: \tif err != nil {\n92: \t\treturn false\n93: \t}\n94: \n95: \tabsWorkDir, err := filepath.Abs(workDir)\n96: \tif err != nil {\n97: \t\treturn false\n98: \t}\n99: \n100: \treturn strings.HasPrefix(absPath, absWorkDir+string(filepath.Separator)) || absPath == absWorkDir\n101: }\n102: \n103: func DropPrivileges(uid, gid int) error {\n104: \tif uid >= 0 {\n105: \t\tif err := syscall.Setuid(uid); err != nil {\n106: \t\t\treturn fmt.Errorf(\"failed to set UID: %w\", err)\n107: \t\t}\n108: \t}\n109: \n110: \tif gid >= 0 {\n111: \t\tif err := syscall.Setgid(gid); err != nil {\n112: \t\t\treturn fmt.Errorf(\"failed to set GID: %w\", err)\n113: \t\t}\n114: \t}\n115: \n116: \treturn nil\n117: }\n\n(End of file - total 117 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"path/fi