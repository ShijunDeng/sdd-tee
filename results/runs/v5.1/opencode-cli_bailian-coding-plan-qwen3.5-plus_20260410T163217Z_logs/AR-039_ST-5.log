\t\"testing\"\n\t\"time\"\n)\n\nfunc TestExecutor_Run_Success(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"echo\",\n\t\tArgs: []string{\"echo\", \"hello\"},\n\t}\n\n\tresult, err := executor.Run(context.Background(), cmd)\n\tif err != nil {\n\t\tt.Fatalf(\"Run() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n\n\texpectedOutput := []byte(\"hello\\n\")\n\tif !bytes.Contains(result.Stdout, expectedOutput) {\n\t\tt.Errorf(\"expected Stdout to contain %q, got %q\", expectedOutput, result.Stdout)\n\t}\n\n\tif result.Duration <= 0 {\n\t\tt.Error(\"expected positive Duration\")\n\t}\n}\n\nfunc TestExecutor_Run_WithStdout(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tvar stdoutBuf bytes.Buffer\n\tcmd := &Command{\n\t\tPath:   \"echo\",\n\t\tArgs:   []string{\"echo\", \"hello\"},\n\t\tStdout: &stdoutBuf,\n\t}\n\n\tresult, err := executor.Run(context.Background(), cmd)\n\tif err != nil {\n\t\tt.Fatalf(\"Run() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n\n\tif len(result.Stdout) != 0 {\n\t\tt.Error(\"expected empty Stdout in result when custom stdout provided\")\n\t}\n\n\tif stdoutBuf.String() != \"echo hello\\n\" {\n\t\tt.Errorf(\"expected stdout buffer to be %q, got %q\", \"echo hello\\n\", stdoutBuf.String())\n\t}\n}\n\nfunc TestExecutor_Run_NonZeroExit(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"false\",\n\t\tArgs: []string{\"false\"},\n\t}\n\n\tresult, err := executor.Run(context.Background(), cmd)\n\tif err == nil {\n\t\tt.Fatal(\"Run() expected error for non-zero exit\")\n\t}\n\n\tif result.ExitCode != 1 {\n\t\tt.Errorf(\"expected ExitCode=1, got %d\", result.ExitCode)\n\t}\n}\n\nfunc TestExecutor_Run_InvalidCommand(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"/nonexistent/command\",\n\t\tArgs: []string{\"nonexistent\"},\n\t}\n\n\t_, err := executor.Run(context.Background(), cmd)\n\tif err == nil {\n\t\tt.Fatal(\"Run() expected error for nonexistent command\")\n\t}\n}\n\nfunc TestExecutor_Start_Wait(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"echo\",\n\t\tArgs: []string{\"echo\", \"hello\"},\n\t}\n\n\tprocess, err := executor.Start(context.Background(), cmd)\n\tif err != nil {\n\t\tt.Fatalf(\"Start() unexpected error: %v\", err)\n\t}\n\n\tif process.PID <= 0 {\n\t\tt.Errorf(\"expected positive PID, got %d\", process.PID)\n\t}\n\n\tresult, err := process.Wait()\n\tif err != nil {\n\t\tt.Fatalf(\"Wait() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n}\n\nfunc TestLimitedBuffer(t *testing.T) {\n\tbuf := &limitedBuffer{\n\t\tlimit: 100,\n\t}\n\n\tn, err := buf.Write([]byte(\"hello\"))\n\tif err != nil {\n\t\tt.Fatalf(\"Write() unexpected error: %v\", err)\n\t}\n\tif n != 5 {\n\t\tt.Errorf(\"expected n=5, got %d\", n)\n\t}\n\n\tdata := buf.Bytes()\n\tif string(data) != \"hello\" {\n\t\tt.Errorf(\"expected %q, got %q\", \"hello\", data)\n\t}\n}\n\nfunc TestLimitedBuffer_ExceedsLimit(t *testing.T) {\n\tbuf := &limitedBuffer{\n\t\tlimit: 5,\n\t}\n\n\tn, err := buf.Write([]byte(\"hello world\"))\n\tif err != nil {\n\t\tt.Fatalf(\"Write() unexpected error: %v\", err)\n\t}\n\tif n != 5 {\n\t\tt.Errorf(\"expected n=5, got %d\", n)\n\t}\n\n\tdata := buf.Bytes()\n\tif len(data) != 5 {\n\t\tt.Errorf(\"expected length 5, got %d\", len(data))\n\t}\n}\n\nfunc TestExecutor_WithAllowlist(t *testing.T) {\n\topts := &SecurityOptions{\n\t\tAllowedCommands: []string{\"/bin/echo\"},\n\t\tWorkDir:         \"/tmp\",\n\t}\n\texecutor := NewExecutor(DefaultResourceLimits(), opts)\n\n\tcmd := &Command{\n\t\tPath: \"/bin/bash\",\n\t\tArgs: []string{\"bash\"},\n\t}\n\n\t_, err := executor.Run(context.Background(), cmd)\n\tif err == nil {\n\t\tt.Fatal(\"Run() expected error for command not in allowlist\")\n\t}\n\n\texecErr, ok := err.(*ExecutionError)\n\tif !ok {\n\t\tt.Fatalf(\"expected ExecutionError, got %T\", err)\n\t}\n\tif execErr.Type != ExecutionErrorSecurity {\n\t\tt.Errorf(\"expected ExecutionErrorSecurity, got %v\", execErr.Type)\n\t}\n}\n\nfunc TestExecutor_WithContextCancellation(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"sleep\",\n\t\tArgs: []string{\"sleep\", \"10\"},\n\t}\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tcancel()\n\n\t_, err := executor.Run(ctx, cmd)\n\tif err == nil {\n\t\tt.Fatal(\"Run() expected error for cancelled context\")\n\t}\n}\n\nfunc TestExecutor_WithTimeout(t *testing.T) {\n\tlimits := &ResourceLimits{\n\t\tTimeout:       100 * time.Millisecond,\n\t\tMaxCPU:        1.0,\n\t\tMaxMemory:     128 * 1024 * 1024,\n\t\tMaxOutputSize: 10 * 1024 * 1024,\n\t\tMaxProcesses:  10,\n\t}\n\texecutor := NewExecutor(limits, DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"sleep\",\n\t\tArgs: []string{\"sleep\", \"1\"},\n\t}\n\n\tctx := context.Background()\n\tresult, err := executor.Run(ctx, cmd)\n\tif err == nil {\n\t\tt.Fatal(\"Run() expected error for timeout\")\n\t}\n\n\tif !result.Timeout {\n\t\tt.Error(\"expected Timeout=true\")\n\t}\n\n\texecErr, ok := err.(*ExecutionError)\n\tif !ok {\n\t\tt.Fatalf(\"expected ExecutionError, got %T\", err)\n\t}\n\tif execErr.Type != ExecutionErrorTimeout {\n\t\tt.Errorf(\"expected ExecutionErrorTimeout, got %v\", execErr.Type)\n\t}\n}\n\nfunc TestCommandResult_Fields(t *testing.T) {\n\tresult := &CommandResult{\n\t\tExitCode:  0,\n\t\tStdout:    []byte(\"output\"),\n\t\tStderr:    []byte(\"error\"),\n\t\tDuration:  time.Second,\n\t\tOOMKilled: false,\n\t\tTimeout:   false,\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n\tif string(result.Stdout) != \"output\" {\n\t\tt.Errorf(\"expected Stdout=output, got %s\", result.Stdout)\n\t}\n\tif string(result.Stderr) != \"error\" {\n\t\tt.Errorf(\"expected Stderr=error, got %s\", result.Stderr)\n\t}\n\tif result.Duration != time.Second {\n\t\tt.Errorf(\"expected Duration=1s, got %v\", result.Duration)\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n)\n\nfunc TestExecutor_Run_Success(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tcmd := &Command{\n\t\tPath: \"echo\",\n\t\tArgs: []string{\"echo\", \"hello\"},\n\t}\n\n\tresult, err := executor.Run(context.Background(), cmd)\n\tif err != nil {\n\t\tt.Fatalf(\"Run() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n\n\texpectedOutput := []byte(\"hello\\n\")\n\tif !bytes.Contains(result.Stdout, expectedOutput) {\n\t\tt.Errorf(\"expected Stdout to contain %q, got %q\", expectedOutput, result.Stdout)\n\t}\n\n\tif result.Duration <= 0 {\n\t\tt.Error(\"expected positive Duration\")\n\t}\n}\n\nfunc TestExecutor_Run_WithStdout(t *testing.T) {\n\texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n\n\tvar stdoutBuf bytes.Buffer\n\tcmd := &Command{\n\t\tPath:   \"echo\",\n\t\tArgs:   []string{\"echo\", \"hello\"},\n\t\tStdout: &stdoutBuf,\n\t}\n\n\tresult, err := executor.Run(context.Background(), cmd)\n\tif err != nil {\n\t\tt.Fatalf(\"Run() unexpected error: %v\", err)\n\t}\n\n\tif result.ExitCode != 0 {\n\t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n\t}\n\n\tif len(result.Stdout) != 0 {\n\t\tt.Error(\"expected empty Stdout in result when custom stdout provided\")\n\t}\n\n\tif stdoutBuf.String() != \"echo hello\\n\" {\n\t\