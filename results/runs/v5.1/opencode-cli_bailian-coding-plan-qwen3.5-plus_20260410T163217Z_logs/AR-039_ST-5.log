ontent>","metadata":{"preview":"package picod\n\nimport (\n\t\"net/http\"\n)\n\ntype AuthErrorType string\n\nconst (\n\tAuthErrorMissingToken  AuthErrorType = \"missing_token\"\n\tAuthErrorInvalidToken  AuthErrorType = \"invalid_token\"\n\tAuthErrorExpiredToken  AuthErrorType = \"expired_token\"\n\tAuthErrorInvalidSig    AuthErrorType = \"invalid_signature\"\n\tAuthErrorInvalidClaims AuthErrorType = \"invalid_claims\"\n\tAuthErrorInternal      AuthErrorType = \"internal_error\"\n)\n\ntype AuthError struct {\n\tType       AuthErrorType\n\tMessage    string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/auth_errors.go","time":{"start":1775889698714,"end":1775889698729}}}}
{"type":"tool_use","timestamp":1775889698742,"sessionID":"ses_284baea35ffekdXTMbxb7bi5On","part":{"id":"prt_d7b463edc001ThtgOavDvZRz16","messageID":"msg_d7b462f88001KFNtwgaShr5Mx2","sessionID":"ses_284baea35ffekdXTMbxb7bi5On","type":"tool","tool":"read","callID":"toolu_103e523a90b942e5957fea51","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/middleware/auth.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/middleware/auth.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"context\"\n5: \t\"net/http\"\n6: \t\"strings\"\n7: \n8: \t\"github.com/volcano-sh/agentcube/pkg/router/auth\"\n9: \t\"k8s.io/klog/v2\"\n10: )\n11: \n12: type contextKeyType string\n13: \n14: const (\n15: \tTokenClaimsContextKey contextKeyType = \"jwt_claims\"\n16: )\n17: \n18: type JWTAuthMiddleware struct {\n19: \tauthenticator auth.JWTAuthenticator\n20: \tskipPaths     map[string]bool\n21: }\n22: \n23: func NewJWTAuthMiddleware(authenticator auth.JWTAuthenticator, skipPaths ...string) *JWTAuthMiddleware {\n24: \tskipMap := make(map[string]bool)\n25: \tfor _, path := range skipPaths {\n26: \t\tskipMap[path] = true\n27: \t}\n28: \n29: \treturn &JWTAuthMiddleware{\n30: \t\tauthenticator: authenticator,\n31: \t\tskipPaths:     skipMap,\n32: \t}\n33: }\n34: \n35: func (m *JWTAuthMiddleware) Middleware(next http.Handler) http.Handler {\n36: \treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n37: \t\tif m.shouldSkip(r.URL.Path) {\n38: \t\t\tnext.ServeHTTP(w, r)\n39: \t\t\treturn\n40: \t\t}\n41: \n42: \t\tauthHeader := r.Header.Get(\"Authorization\")\n43: \t\ttoken, err := auth.ExtractTokenFromHeader(authHeader)\n44: \t\tif err != nil {\n45: \t\t\tklog.Warningf(\"JWT auth failed: %v\", err)\n46: \t\t\tm.writeError(w, http.StatusUnauthorized, \"missing authorization header\")\n47: \t\t\treturn\n48: \t\t}\n49: \n50: \t\tclaims, err := m.authenticator.Validate(token)\n51: \t\tif err != nil {\n52: \t\t\tklog.Warningf(\"JWT validation failed: %v\", err)\n53: \t\t\tm.writeAuthError(w, err)\n54: \t\t\treturn\n55: \t\t}\n56: \n57: \t\tctx := context.WithValue(r.Context(), TokenClaimsContextKey, claims)\n58: \t\tr = r.WithContext(ctx)\n59: \n60: \t\tklog.V(4).Infof(\"JWT authenticated user: %s, role: %s\", claims.UserID, claims.Role)\n61: \t\tnext.ServeHTTP(w, r)\n62: \t})\n63: }\n64: \n65: func (m *JWTAuthMiddleware) shouldSkip(path string) bool {\n66: \tif m.skipPaths[path] {\n67: \t\treturn true\n68: \t}\n69: \n70: \tfor skipPath := range m.skipPaths {\n71: \t\tif strings.HasSuffix(skipPath, \"*\") {\n72: \t\t\tprefix := strings.TrimSuffix(skipPath, \"*\")\n73: \t\t\tif strings.HasPrefix(path, prefix) {\n74: \t\t\t\treturn true\n75: \t\t\t}\n76: \t\t}\n77: \t}\n78: \n79: \treturn false\n80: }\n81: \n82: func (m *JWTAuthMiddleware) writeError(w http.ResponseWriter, statusCode int, message string) {\n83: \tw.Header().Set(\"Content-Type\", \"application/json\")\n84: \tw.WriteHeader(statusCode)\n85: \tw.Write([]byte(`{\"error\": \"` + message + `\", \"code\": \"AUTH_ERROR\"}`))\n86: }\n87: \n88: func (m *JWTAuthMiddleware) writeAuthError(w http.ResponseWriter, err error) {\n89: \tstatusCode := http.StatusUnauthorized\n90: \tmessage := err.Error()\n91: \n92: \tswitch err {\n93: \tcase auth.ErrInvalidTokenSignature:\n94: \t\tmessage = \"invalid token signature\"\n95: \tcase auth.ErrTokenExpired:\n96: \t\tmessage = \"token expired\"\n97: \tcase auth.ErrInvalidIssuer:\n98: \t\tmessage = \"invalid issuer\"\n99: \tcase auth.ErrInvalidAudience:\n100: \t\tmessage = \"invalid audience\"\n101: \tcase auth.ErrMissingClaims:\n102: \t\tmessage = \"missing required claims\"\n103: \tcase auth.ErrTokenRevoked:\n104: \t\tmessage = \"token revoked\"\n105: \t}\n106: \n107: \tm.writeError(w, statusCode, message)\n108: }\n109: \n110: func GetClaimsFromContext(ctx context.Context) (*auth.TokenClaims, bool) {\n111: \tclaims, ok := ctx.Value(TokenClaimsContextKey).(*auth.TokenClaims)\n112: \treturn claims, ok\n113: }\n114: \n115: func RequireRole(allowedRoles ...string) func(http.Handler) http.Handler {\n116: \treturn func(next http.Handler) http.Handler {\n117: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n118: \t\t\tclaims, ok := GetClaimsFromContext(r.Context())\n119: \t\t\tif !ok || claims == nil {\n120: \t\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n121: \t\t\t\tw.WriteHeader(http.StatusUnauthorized)\n122: \t\t\t\tw.Write([]byte(`{\"error\": \"authentication required\", \"code\": \"AUTH_REQUIRED\"}`))\n123: \t\t\t\treturn\n124: \t\t\t}\n125: \n126: \t\t\tfor _, role := range allowedRoles {\n127: \t\t\t\tif claims.Role == role {\n128: \t\t\t\t\tnext.ServeHTTP(w, r)\n129: \t\t\t\t\treturn\n130: \t\t\t\t}\n131: \t\t\t}\n132: \n133: \t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n134: \t\t\tw.WriteHeader(http.StatusForbidden)\n135: \t\t\tw.Write([]byte(`{\"error\": \"insufficient permissions\", \"code\": \"FORBIDDEN\"}`))\n136: \t\t})\n137: \t}\n138: }\n\n(End of file - total 138 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"strings\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/router/auth\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype contextKeyType string\n\nconst (\n\tTokenClaimsContextKey contextKeyType = \"jwt_claims\"\n)\n\ntype JWTAuthMiddleware struct {\n\tauthenticator auth.JWTAuthenticator\n\tskipPaths     map[string]bool","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/middleware/auth.go","time":{"start":1775889698717,"end":1775889698740}}}}
