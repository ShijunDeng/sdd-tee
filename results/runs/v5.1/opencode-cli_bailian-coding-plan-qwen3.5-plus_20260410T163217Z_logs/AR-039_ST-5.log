l, fmt.Errorf(\"invalid PICOD_QUOTA_MAX_FILES: %w\", err)\n107: \t\t}\n108: \t\tconfig.QuotaMaxFiles = count\n109: \t}\n110: \n111: \tif env := os.Getenv(\"PICOD_QUOTA_MAX_DEPTH\"); env != \"\" {\n112: \t\tdepth, err := strconv.Atoi(env)\n113: \t\tif err != nil {\n114: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_QUOTA_MAX_DEPTH: %w\", err)\n115: \t\t}\n116: \t\tconfig.QuotaMaxDepth = depth\n117: \t}\n118: \n119: \tif env := os.Getenv(\"PICOD_AUTH_MODE\"); env != \"\" {\n120: \t\tconfig.AuthMode = env\n121: \t}\n122: \n123: \tif env := os.Getenv(\"PICOD_AUTH_PUBLIC_KEY\"); env != \"\" {\n124: \t\tconfig.PublicKeyPEM = env\n125: \t}\n126: \n127: \tif env := os.Getenv(\"PICOD_AUTH_SKIP_PATHS\"); env != \"\" {\n128: \t\tpaths := strings.Split(env, \",\")\n129: \t\tconfig.SkipPaths = make([]string, 0, len(paths))\n130: \t\tfor _, path := range paths {\n131: \t\t\tif trimmed := strings.TrimSpace(path); trimmed != \"\" {\n132: \t\t\t\tconfig.SkipPaths = append(config.SkipPaths, trimmed)\n133: \t\t\t}\n134: \t\t}\n135: \t}\n136: \n137: \treturn config, nil\n138: }\n139: \n140: func parseSize(s string) (int64, error) {\n141: \ts = strings.TrimSpace(s)\n142: \tif len(s) == 0 {\n143: \t\treturn 0, fmt.Errorf(\"empty size string\")\n144: \t}\n145: \n146: \tmultipliers := map[string]int64{\n147: \t\t\"K\":  1024,\n148: \t\t\"KB\": 1024,\n149: \t\t\"M\":  1024 * 1024,\n150: \t\t\"MB\": 1024 * 1024,\n151: \t\t\"G\":  1024 * 1024 * 1024,\n152: \t\t\"GB\": 1024 * 1024 * 1024,\n153: \t}\n154: \n155: \tfor suffix, mult := range multipliers {\n156: \t\tif strings.HasSuffix(s, suffix) {\n157: \t\t\tnumStr := strings.TrimSuffix(s, suffix)\n158: \t\t\tnum, err := strconv.ParseInt(numStr, 10, 64)\n159: \t\t\tif err != nil {\n160: \t\t\t\treturn 0, err\n161: \t\t\t}\n162: \t\t\treturn num * mult, nil\n163: \t\t}\n164: \t}\n165: \n166: \tnum, err := strconv.ParseInt(s, 10, 64)\n167: \tif err != nil {\n168: \t\treturn 0, err\n169: \t}\n170: \treturn num, nil\n171: }\n\n(End of file - total 1