plit(tokenString, \".\")\n50: \tif len(parts) != 3 {\n51: \t\treturn nil, &AuthError{\n52: \t\t\tType:    AuthErrorInvalidToken,\n53: \t\t\tMessage: \"invalid token format\",\n54: \t\t}\n55: \t}\n56: \n57: \tpayloadJSON, err := base64URLDecode(parts[1])\n58: \tif err != nil {\n59: \t\treturn nil, &AuthError{\n60: \t\t\tType:    AuthErrorInvalidToken,\n61: \t\t\tMessage: \"failed to decode payload\",\n62: \t\t}\n63: \t}\n64: \n65: \tvar claims Claims\n66: \tif err := json.Unmarshal(payloadJSON, &claims); err != nil {\n67: \t\treturn nil, &AuthError{\n68: \t\t\tType:    AuthErrorInvalidClaims,\n69: \t\t\tMessage: \"failed to parse claims\",\n70: \t\t}\n71: \t}\n72: \n73: \tif err := claims.Validate(time.Now()); err != nil {\n74: \t\treturn nil, err\n75: \t}\n76: \n77: \treturn &claims, nil\n78: }\n79: \n80: func VerifySignature(tokenString string, publicKey *rsa.PublicKey) error {\n81: \tparts := strings.Split(tokenString, \".\")\n82: \tif len(parts) != 3 {\n83: \t\treturn &AuthError{\n84: \t\t\tType:    AuthErrorInvalidToken,\n85: \t\t\tMessage: \"invalid token format\",\n86: \t\t}\n87: \t}\n88: \n89: \theaderJSON, err := base64URLDecode(parts[0])\n90: \tif err != nil {\n91: \t\treturn &AuthError{\n92: \t\t\tType:    AuthErrorInvalidToken,\n93: \t\t\tMessage: \"failed to decode header\",\n94: \t\t}\n95: \t}\n96: \n97: \tvar header struct {\n98: \t\tAlg string `json:\"alg\"`\n99: \t\tTyp string `json:\"typ\"`\n100: \t}\n101: \tif err := json.Unmarshal(headerJSON, &header); err != nil {\n102: \t\treturn &AuthError{\n103: \t\t\tType:    AuthErrorInvalidToken,\n104: \t\t\tMessage: \"failed to parse header\",\n105: \t\t}\n106: \t}\n107: \n108: \tif header.Alg != \"RS256\" {\n109: \t\treturn &AuthError{\n110: \t\t\tType:    AuthErrorInvalidToken,\n111: \t\t\tMessage: fmt.Sprintf(\"unsupported algorithm: %s\", header.Alg),\n112: \t\t}\n113: \t}\n114: \n115: \tsignature, err := base64URLDecode(parts[2])\n116: \tif err != nil {\n117: \t\treturn &AuthError{\n118: \t\t\tType:    AuthErrorInvalidToken,\n119: \t\t\tMessage: \"failed to decode signature\",\n120: \t\t}\n121: \t}\n122: \n123: \tsigningInput := parts[0] + \".\" + parts[1]\n124: \thash := sha256.Sum256([]byte(signingInput))\n125: \n126: \tif err := rsa.VerifyPKCS1v15(publicKey, crypto.SHA256, hash[:], signature); err != nil {\n127: \t\treturn &AuthError{\n128: \t\t\tType:    AuthErrorInvalidSig,\n129: \t\t\tMessage: \"invalid signature\",\n130: \t\t}\n131: \t}\n132: \n133: \treturn nil\n134: }\n135: \n136: func base64URLDecode(s string) ([]byte, error) {\n137: \ts = strings.TrimRight(s, \"=\")\n138: \treturn base64.RawURLEncoding.DecodeString(s)\n139: }\n\n(End of file - total 139 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto\"\n\t\"crypto/rsa\"\n\t\"crypto/sha256\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strings\"\n\t\"time\"\n)\n\nconst defaultClockSkew = 30 * time.Second\n\ntype Claims struct {\n\tSub       string `json:\"sub\"`\n\tIss       string `json:\"iss\"`\n\tAud       string `json:\"aud\"`\n\tExp       int64  `json:\"exp\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/jwt.go","time":{"start":1775862263668,"end":1775862263701}}}}
