.5-plus_20260410T163217Z/pkg/picod/crypto_test.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/crypto_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/crypto_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/crypto_test.go\n@@ -199,9 +199,9 @@\n if block == nil {\n \tt.Fatal(\"failed to decode PEM\")\n }\n \n-if block.Type != \"-----BEGIN PUBLIC KEY-----\" {\n+if block.Type != \"PUBLIC KEY\" {\n \tt.Fatalf(\"unexpected PEM block type: %s\", block.Type)\n }\n \n loadedKey, err := ParsePEM(block)\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/crypto_test.go","before":"package picod\n\nimport (\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/pem\"\n\t\"testing\"\n)\n\nfunc TestGenerateKeyPair(t *testing.T) {\n\tprivateKey, publicKey, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tif privateKey == nil {\n\t\tt.Fatal(\"private key is nil\")\n\t}\n\n\tif publicKey == nil {\n\t\tt.Fatal(\"public key is nil\")\n\t}\n\n\tif privateKey.N.Cmp(publicKey.N) != 0 {\n\t\tt.Fatal(\"public key does not match private key's public key\")\n\t}\n\n\tif privateKey.N.Cmp(publicKey.N) != 0 {\n\t\tt.Fatal(\"key modulus mismatch\")\n\t}\n}\n\nfunc TestLoadPublicKeyFromBase64(t *testing.T) {\n\t_, publicKey, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tpemBytes, err := EncodePublicKeyToPEM(publicKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to encode public key: %v\", err)\n\t}\n\n\tbase64PEM := base64.StdEncoding.EncodeToString(pemBytes)\n\n\tloadedKey, err := LoadPublicKeyFromBase64(base64PEM)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to load public key from base64: %v\", err)\n\t}\n\n\tif loadedKey.N.Cmp(publicKey.N) != 0 {\n\t\tt.Fatal(\"loaded key does not match original key\")\n\t}\n\n\tif loadedKey.E != publicKey.E {\n\t\tt.Fatal(\"loaded key exponent does not match\")\n\t}\n}\n\nfunc TestLoadPublicKeyFromBase64_InvalidBase64(t *testing.T) {\n\t_, err := LoadPublicKeyFromBase64(\"invalid-base64!!!\")\n\tif err == nil {\n\t\tt.Fatal(\"expected error for invalid base64\")\n\t}\n}\n\nfunc TestLoadPublicKey(t *testing.T) {\n\t_, publicKey, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tpemBytes, err := EncodePublicKeyToPEM(publicKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to encode public key: %v\", err)\n\t}\n\n\tloadedKey, err := LoadPublicKey(pemBytes)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to load public key: %v\", err)\n\t}\n\n\tif loadedKey.N.Cmp(publicKey.N) != 0 {\n\t\tt.Fatal(\"loaded key does not match original key\")\n\t}\n}\n\nfunc TestLoadPublicKey_InvalidPEM(t *testing.T) {\n\t_, err := LoadPublicKey([]byte(\"not a valid PEM\"))\n\tif err == nil {\n\t\tt.Fatal(\"expected error for invalid PEM\")\n\t}\n}\n\nfunc TestParsePEM_RSAPublicKey(t *testing.T) {\n\t_, publicKey, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tpubDER := x509.MarshalPKCS1PublicKey(publicKey)\n\n\tpemBlock := &pem.Block{\n\t\tType:  \"RSA PUBLIC KEY\",\n\t\tBytes: pubDER,\n\t}\n\n\tloadedKey, err := ParsePEM(pemBlock)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to parse RSA public key: %v\", err)\n\t}\n\n\tif loadedKey.N.Cmp(publicKey.N) != 0 {\n\t\tt.Fatal(\"parsed key does not match original key\")\n\t}\n}\n\nfunc TestParsePEM_PKIXPublicKey(t *testing.T) {\n\t_, publicKey, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tpubDER, err := x509.MarshalPKIXPublicKey(publicKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to marshal key: %v\", err)\n\t}\n\n\tpemBlock := &pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: pubDER,\n\t}\n\n\tloadedKey, err := ParsePEM(pemBlock)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to parse PKIX public key: %v\", err)\n\t}\n\n\tif loadedKey.N.Cmp(publicKey.N) != 0 {\n\t\tt.Fatal(\"parsed key does not match original key\")\n\t}\n}\n\nfunc TestParsePEM_UnsupportedType(t *testing.T) {\n\tpemBlock := &pem.Block{\n\t\tType:  \"CERTIFICATE\",\n\t\tBytes: []byte{1, 2, 3},\n\t}\n\n\t_, err := ParsePEM(pemBlock)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for unsupported PEM type\")\n\t}\n}\n\nfunc TestParsePEM_InvalidPKIX(t *testing.T) {\n\tpemBlock := &pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: []byte{1, 2, 3},\n\t}\n\n\t_, err := ParsePEM(pemBlock)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for invalid PKIX data\")\n\t}\n}\n\nfunc TestParsePEM_NotRSA(t *testing.T) {\n\tprivateKey, _, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tprivDER := x509.MarshalPKCS1PrivateKey(privateKey)\n\n\tpemBlock := &pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: privDER,\n\t}\n\n\t_, err = ParsePEM(pemBlock)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for non-RSA key\")\n\t}\n}\n\nfunc TestEncodePublicKeyToPEM(t *testing.T) {\n\t_, publicKey, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tpemBytes, err := EncodePublicKeyToPEM(publicKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to encode public key: %v\", err)\n\t}\n\n\tblock, _ := pem.Decode(pemBytes)\n\tif block == nil {\n\t\tt.Fatal(\"failed to decode PEM\")\n\t}\n\n\tif block.Type != \"-----BEGIN PUBLIC KEY-----\" {\n\t\tt.Fatalf(\"unexpected PEM block type: %s\", block.Type)\n\t}\n\n\tloadedKey, err := ParsePEM(block)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to parse encoded key: %v\", err)\n\t}\n\n\tif loadedKey.N.Cmp(publicKey.N) != 0 {\n\t\tt.Fatal(\"encoded/decoded key does not match original\")\n\t}\n}\n\nfunc TestLoadPublicKeyFromBase64_RoundTrip(t *testing.T) {\n\t_, originalKey, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tpemBytes, err := EncodePublicKeyToPEM(originalKey)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to encode public key: %v\", err)\n\t}\n\n\tbase64PEM := base64.StdEncoding.EncodeToString(pemBytes)\n\n\tloadedKey, err := LoadPublicKeyFromBase64(base64PEM)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to load public key: %v\", err)\n\t}\n\n\tif loadedKey.N.Cmp(originalKey.N) != 0 {\n\t\tt.Fatal(\"round-trip key does not match original\")\n\t}\n\n\tif loadedKey.E != originalKey.E {\n\t\tt.Fatal(\"round-trip key exponent does not match\")\n\t}\n}\n\nfunc TestGenerateKeyPair_DifferentSizes(t *testing.T) {\n\tsizes := []int{1024, 2048, 4096}\n\n\tfor _, size := range sizes {\n\t\tt.Run(string(rune(size)), func(t *testing.T) {\n\t\t\tprivateKey, publicKey, err := GenerateKeyPair(size)\n\t\t\tif err != nil {\n\t\t\t\tt.Fatalf(\"failed to generate %d-bit key pair: %v\", size, err)\n\t\t\t}\n\n\t\t\tif privateKey.N.BitLen() != size {\n\t\t\t\tt.Errorf(\"expected %d-bit key, got %d-bit\", size, privateKey.N.BitLen())\n\t\t\t}\n\n\t\t\tif publicKey.N.BitLen() != size {\n\t\t\t\tt.Errorf(\"expected %d-bit public key, got %d-bit\", size, publicKey.N.BitLen())\n\t\t\t}\n\t\t})\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/pem\"\n\t\"testing\"\n)\n\nfunc TestGenerateKeyPair(t *testing.T) {\n\tprivateKey, publicKey, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tif privateKey == nil {\n\t\tt.Fatal(\"private key is nil\")\n\t}\n\n\tif publicKey == nil {\n\t\tt.Fatal(\"public key is nil\")\n\t}\n\n\tif privateKey.N.Cmp(publicKey.N) != 0 {\n\t\tt.Fatal(\"public key d