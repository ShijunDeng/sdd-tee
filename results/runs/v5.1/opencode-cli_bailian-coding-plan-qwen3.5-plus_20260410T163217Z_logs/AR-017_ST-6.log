next.ServeHTTP(w, r)\n54: \t})\n55: }\n56: \n57: func (m *JWTMiddleware) extractToken(r *http.Request) (string, error) {\n58: \tauthHeader := r.Header.Get(\"Authorization\")\n59: \tif authHeader == \"\" {\n60: \t\treturn \"\", &AuthError{\n61: \t\t\tType:    AuthErrorMissingToken,\n62: \t\t\tMessage: \"missing authorization header\",\n63: \t\t}\n64: \t}\n65: \n66: \tconst bearerPrefix = \"Bearer \"\n67: \tif len(authHeader) < len(bearerPrefix) || !strings.HasPrefix(authHeader, bearerPrefix) {\n68: \t\treturn \"\", &AuthError{\n69: \t\t\tType:    AuthErrorInvalidToken,\n70: \t\t\tMessage: \"invalid authorization format\",\n71: \t\t}\n72: \t}\n73: \n74: \ttoken := strings.TrimPrefix(authHeader, bearerPrefix)\n75: \tif token == \"\" {\n76: \t\treturn \"\", &AuthError{\n77: \t\t\tType:    AuthErrorMissingToken,\n78: \t\t\tMessage: \"empty token\",\n79: \t\t}\n80: \t}\n81: \n82: \treturn token, nil\n83: }\n84: \n85: func (m *JWTMiddleware) shouldSkip(path string) bool {\n86: \treturn m.skipPaths[path]\n87: }\n88: \n89: type HealthResponse struct {\n90: \tStatus    string    `json:\"status\"`\n91: \tTimestamp time.Time `json:\"timestamp\"`\n92: \tSandboxID string    `json:\"sandbox_id,omitempty\"`\n93: }\n94: \n95: func WriteJSON(w http.ResponseWriter, status int, data interface{}) {\n96: \tw.Header().Set(\"Content-Type\", \"application/json\")\n97: \tw.WriteHeader(status)\n98: \tif err := json.NewEncoder(w).Encode(data); err != nil {\n99: \t\tklog.ErrorS(err, \"failed to write JSON response\")\n100: \t}\n101: }\n102: \n103: func WriteError(w http.ResponseWriter, err error) {\n104: \tvar authErr *AuthError\n105: \tif errors.As(err, &authErr) {\n106: \t\tresponse := map[string]string{\n107: \t\t\t\"error\": string(authErr.Type),\n108: \t\t}\n109: \t\tif authErr.Message != \"\" {\n110: \t\t\tresponse[\"message\"] = authErr.Message\n111: \t\t}\n112: \t\tWriteJSON(w, authErr.HTTPStatus(), response)\n113: \t\treturn\n114: \t}\n115: \n116: \tWriteJSON(w, http.StatusInternalServerError, map[string]string{\n117: \t\t\"error\": \"internal_error\",\n118: \t})\n119: }\n\n(End of file - total 119 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"net/http\"\n\t\"strings\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n)\n\ntype JWTMiddleware struct {\n\tpublicKey *rsa.PublicKey\n\tskipPaths map[string]bool\n\tlogger    klog.Logger\n}\n\nfunc NewJWTMiddleware(publicKey *rsa.PublicKey, skipPaths ...string) *JWTMiddleware {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/middleware.go","time":{"start":1775862263671,"end":1775862263703}}}}
{"type":"tool_use","timestamp":1775862263706,"sessionID":"ses_2865caaa7ffej00mi7tnqMEY5Y","part":{"id":"prt_d79a3a27e001S3ZwbcINWE9XJ0","messageID":"msg_d79a37d2e0013pBB27LHdzh8ej","sessionID":"ses_2865caaa7ffej00mi7tnqMEY5Y","type":"tool","tool":"read","callID":"toolu_815de30212f3442889286210","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/jwt_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/jwt_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"crypto\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/sha256\"\n8: \t\"encoding/base64\"\n9: \t\"encoding/json\"\n10: \t\"strings\"\n11: \t\"testing\"\n12: \t\"time\"\n13: )\n14: \n15: func generateTestToken(privateKey *rsa.PrivateKey, claims *Claims) (string, error) {\n16: \theader := map[string]string{\n17: \t\t\"alg\": \"RS256\",\n18: \t\t\"typ\": \"JWT\",\n19: \t}\n20: \n21: \theaderJSON, err := json.Marshal(header)\n22: \tif err != nil {\n23: \t\treturn \"\", err\n24: \t}\n25: \n26: \tclaimsJSON, err := json.Marshal(claims)\n27: \tif err != nil {\n28: \t\treturn \"\", err\n29: \t}\n30: \n31: \theaderEncoded := strings.TrimRight(base64.URLEncoding.EncodeToString(headerJSON), \"=\")\n32: \tclaimsEncoded := strings.TrimRight(base64.URLEncoding.EncodeToString(claimsJSON), \"=\")\n33: \n34: \tsigningInput := headerEncoded + \".\" + claimsEncoded\n35: \thash := sha256.Sum256([]byte(signingInput))\n36: \n37: \tsignature, err := rsa.SignPKCS1v15(rand.Reader, privateKey, crypto.SHA256, hash[:])\n38: \tif err != nil {\n39: \t\treturn \"\", err\n40: \t}\n41: \n42: \tsignatureEncoded := strings.TrimRight(base64.URLEncoding.EncodeToString(signature), \"=\")\n43: \n44: \treturn signingInput + \".\" + signatureEncoded, nil\n45: }\n46: \n47: func testClaims() *Claims {\n48: \treturn &Claims{\n49: \t\tSub:       \"test-user\",\n50: \t\tIss:       \"test-issuer\",\n51: \t\tAud:       \"picod\",\n52: \t\tExp:       time.Now().Add(1 * time.Hour).Unix(),\n53: \t\tIat:       time.Now().Unix(),\n54: \t\tSandboxID: \"test-sandbox\",\n55: \t\tNamespace: \"default\",\n56: \t}\n57: }\n58: \n59: func testExpiredClaims() *Claims {\n60: \treturn &Claims{\n61: \t\tSub:       \"test-user\",\n62: \t\tIss:       \"test-issuer\",\n63: \t\tAud:       \"picod\",\n64: \t\tExp:       time.Now().Add(-1 * time.Hour).Unix(),\n65: \t\tIat:       time.Now().Add(-2 * time.Hour).Unix(),\n66: \t\tSandboxID: \"test-sandbox\",\n67: \t\tNamespace: \"default\",\n68: \t}\n69: }\n70: \n71: func TestClaims_Validate_Success(t *testing.T) {\n72: \tclaims := testClaims()\n73: \terr := claims.Validate(time.Now())\n74: \tif err != nil {\n75: \t\tt.Fatalf(\"expected valid claims to pass validation: %v\", err)\n76: \t}\n77: }\n78: \n79: func TestClaims_Validate_Expired(t *testing.T) {\n80: \tclaims := testExpiredClaims()\n81: \terr := claims.Validate(time.Now())\n82: \tif err == nil {\n83: \t\tt.Fatal(\"expected error for expired claims\")\n84: \t}\n85: \n86: \tauthErr, ok := err.(*AuthError)\n87: \tif !ok {\n88: \t\tt.Fatalf(\"expected AuthError, got %T\", err)\n89: \t}\n90: \n91: \tif authErr.Type != AuthErrorExpiredToken {\n92: \t\tt.Errorf(\"expected AuthErrorExpiredToken, got %s\", authErr.Type)\n93: \t}\n94: }\n95: \n96: func TestClaims_Validate_Future(t *testing.T) {\n97: \tclaims := &Claims{\n98: \t\tSub: \"test-user\",\n99: \t\tIss: \"test-issuer\",\n100: \t\tAud: \"picod\",\n101: \t\tExp: time.Now().Add(1 * time.Hour).Unix(),\n102: \t\tIat: time.Now().Add(1 * time.Hour).Unix(),\n103: \t}\n104: \n105: \terr := claims.Validate(time.Now())\n106: \tif err == nil {\n107: \t\tt.Fatal(\"expected error for future claims\")\n108: \t}\n109: \n110: \tauthErr, ok := err.(*AuthError)\n111: \tif !ok {\n112: \t\tt.Fatalf(\"expected AuthError, got %T\", err)\n113: \t}\n114: \n115: \tif authErr.Type != AuthErrorInvalidToken {\n116: \t\tt.Errorf(\"expected AuthErrorInvalidToken, got %s\", authErr.Type)\n117: \t}\n118: }\n119: \n120: func TestClaims_Validate_NoExpiration(t *testing.T) {\n121: \tclaims := &Claims{\n122: \t\tSub: \"test-user\",\n123: \t\tIss: \"test-issuer\",\n124: \t\tAud: \"picod\",\n125: \t\tIat: time.Now().Unix(),\n126: \t}\n127: \n128: \terr := claims.Validate(time.Now())\n129: \tif err != nil {\n130: \t\tt.Fatalf(\"claims without expiration should be valid: %v\", err)\n131: \t}\n132: }\n133: \n134: func TestParseAndValidate_Success(t *testing.T) {\n135: \tprivateKey, publicKey, err := GenerateKeyPair(2048)\n136: \tif err != nil {\n137: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n138: \t}\n139: \n140: \tclaims := testClaims()\n141: \ttoken, err := generateTestToken(privateKey, claims)\n142: \tif err != nil {\n143: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n144: \t}\n145: \n146: \tvalidatedClaims, err := ParseAndValidate(token, publicKey)\n147: \tif err != nil {\n148: \t\tt.Fatalf(\"failed to validate token: %v\", err)\n149: \t}\n150: \n151: \tif validatedClaims.Sub != claims.Sub {\n152: \t\tt.Errorf(\"subject mismatch: expected %s, got %s\", claims.Sub, validatedClaims.Sub)\n153: \t}\n154: \n155: \tif validatedClaims.SandboxID != claims.SandboxID {\n156: \t\tt.Errorf(\"sandbox_id mismatch: expected %s, got %s\", claims.SandboxID, validatedClaims.SandboxID)\n157: \t}\n158: }\n159: \n160: func TestParseAndValidate_InvalidSignature(t *testing.T) {\n161: \tprivateKey, _, err := GenerateKeyPair(2048)\n162: \tif err != nil {\n163: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n164: \t}\n165: \n166: \tclaims := testClaims()\n167: \ttoken, err := generateTestToken(privateKey, claims)\n168: \tif err != nil {\n169: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n170: \t}\n171: \n172: \t_, otherKey, _ := GenerateKeyPair(2048)\n173: \ttamperedToken := token[:len(token)-10] + \"tampered\"\n174: \n175: \t_, err = ParseAndValidate(tamperedToken, otherKey)\n176: \tif err == nil {\n177: \t\tt.Fatal(\"expected error for tampered token\")\n178: \t}\n179: \n180: \tauthErr, ok := err.(*AuthError)\n181: \tif !ok {\n182: \t\tt.Fatalf(\"expected AuthError, got %T\", err)\n183: \t}\n184: \n185: \tif authErr.Type != AuthErrorInvalidSig {\n186: \t\tt.Errorf(\"expected AuthErrorInvalidSig, got %s\", authErr.Type)\n187: \t}\n188: }\n189: \n190: func TestParseAndValidate_ExpiredToken(t *testing.T) {\n191: \tprivateKey, publicKey, err := GenerateKeyPair(2048)\n192: \tif err != nil {\n193: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n194: \t}\n195: \n196: \tclaims := testExpiredClaims()\n197: \ttoken, err := generateTestToken(privateKey, claims)\n198: \tif err != nil {\n199: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n200: \t}\n201: \n202: \t_, err = ParseAndValidate(token, publicKey)\n203: \tif err == nil {\n204: \t\tt.Fatal(\"expected error for expired token\")\n205: \t}\n206: \n207: \tauthErr, ok := err.(*AuthError)\n208: \tif !ok {\n209: \t\tt.Fatalf(\"expected AuthError, got %T\", err)\n210: \t}\n211: \n212: \tif authErr.Type != AuthErrorExpiredToken {\n213: \t\tt.Errorf(\"expected AuthErrorExpiredToken, got %s\", authErr.Type)\n214: \t}\n215: }\n216: \n217: func TestParseAndValidate_InvalidFormat(t *testing.T) {\n218: \t_, publicKey, err := GenerateKeyPair(2048)\n219: \tif err != nil {\n220: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n221: \t}\n222: \n223: \t_, err = ParseAndValidate(\"invalid.token\", publicKey)\n224: \tif err == nil {\n225: \t\tt.Fatal(\"expected error for invalid token format\")\n226: \t}\n227: \n228: \tauthErr, ok := err.(*AuthError)\n229: \tif !ok {\n230: \t\tt.Fatalf(\"expected AuthError, got %T\", err)\n231: \t}\n232: \n233: \tif authErr.Type != AuthErrorInvalidToken {\n234: \t\tt.Errorf(\"expected AuthErrorInvalidToken, got %s\", authErr.Type)\n235: \t}\n236: }\n237: \n238: func TestParseAndValidate_InvalidAlgorithm(t *testing.T) {\n239: \t_, publicKey, err := GenerateKeyPair(2048)\n240: \tif err != nil {\n241: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n242: \t}\n243: \n244: \theader := map[string]string{\n245: \t\t\"alg\": \"HS256\",\n246: \t\t\"typ\": \"JWT\",\n247: \t}\n248: \tclaims := testClaims()\n249: \n250: \theaderJSON, _ := json.Marshal(header)\n251: \tclaimsJSON, _ := json.Marshal(claims)\n252: \n253: \theaderEncoded := strings.TrimRight(base64.URLEncoding.EncodeToString(headerJSON), \"=\")\n254: \tclaimsEncoded := strings.TrimRight(base64.URLEncoding.EncodeToString(claimsJSON), \"=\")\n255: \n256: \ttoken := headerEncoded + \".\" + claimsEncoded + \".signature\"\n257: \n258: \t_, err = ParseAndValidate(token, publicKey)\n259: \tif err == nil {\n260: \t\tt.Fatal(\"expected error for unsupported algorithm\")\n261: \t}\n262: \n263: \tauthErr, ok := err.(*AuthError)\n264: \tif !ok {\n265: \t\tt.Fatalf(\"expected AuthError, got %T\", err)\n266: \t}\n267: \n268: \tif authErr.Type != AuthErrorInvalidToken {\n269: \t\tt.Errorf(\"expected AuthErrorInvalidToken, got %s\", authErr.Type)\n270: \t}\n271: }\n272: \n273: func TestVerifySignature_Success(t *testing.T) {\n274: \tprivateKey, publicKey, err := GenerateKeyPair(2048)\n275: \tif err != nil {\n276: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n277: \t}\n278: \n279: \tclaims := testClaims()\n280: \ttoken, err := generateTestToken(privateKey, claims)\n281: \tif err != nil {\n282: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n283: \t}\n284: \n285: \terr = VerifySignature(token, publicKey)\n286: \tif err != nil {\n287: \t\tt.Fatalf(\"signature verification failed: %v\", err)\n288: \t}\n289: }\n290: \n291: func TestVerifySignature_InvalidSignature(t *testing.T) {\n292: \tprivateKey, _, err := GenerateKeyPair(2048)\n293: \tif err != nil {\n294: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n295: \t}\n296: \n297: \tclaims := testClaims()\n298: \ttoken, err := generateTestToken(privateKey, claims)\n299: \tif err != nil {\n300: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n301: \t}\n302: \n303: \t_, otherKey, _ := GenerateKeyPair(2048)\n304: \n305: \terr = VerifySignature(token, otherKey)\n306: \tif err == nil {\n307: \t\tt.Fatal(\"expected error for invalid signature\")\n308: \t}\n309: \n310: \tauthErr, ok := err.(*AuthError)\n311: \tif !ok {\n312: \t\tt.Fatalf(\"expected AuthError, got %T\", err)\n313: \t}\n314: \n315: \tif authErr.Type != AuthErrorInvalidSig {\n316: \t\tt.Errorf(\"expected AuthErrorInvalidSig, got %s\", authErr.Type)\n317: \t}\n318: }\n319: \n320: func TestVerifySignature_InvalidFormat(t *testing.T) {\n321: \t_, publicKey, err := GenerateKeyPair(2048)\n322: \tif err != nil {\n323: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n324: \t}\n325: \n326: \terr = VerifySignature(\"invalid\", publicKey)\n327: \tif err == nil {\n328: \t\tt.Fatal(\"expected error for invalid format\")\n329: \t}\n330: }\n331: \n332: func TestVerifySignature_InvalidHeader(t *testing.T) {\n333: \t_, publicKey, err := GenerateKeyPair(2048)\n334: \tif err != nil {\n335: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n336: \t}\n337: \n338: \ttoken := \"not-base64.payload.signature\"\n339: \n340: \terr = VerifySignature(token, publicKey)\n341: \tif err == nil {\n342: \t\tt.Fatal(\"expected error for invalid header\")\n343: \t}\n344: }\n345: \n346: func TestBase64URLDecode(t *testing.T) {\n347: \ttestCases := []struct {\n348: \t\tinput  string\n349: \t\toutput string\n350: \t}{\n351: \t\t{\"eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9\", `{\"typ\":\"JWT\",\"alg\":\"HS256\"}`},\n352: \t\t{\"aGVsbG8\", \"hello\"},\n353: \t\t{\"d29ybGQ\", \"world\"},\n354: \t}\n355: \n356: \tfor _, tc := range testCases {\n357: \t\tdecoded, err := base64URLDecode(tc.input)\n358: \t\tif err != nil {\n359: \t\t\tt.Errorf(\"failed to decode %s: %v\", tc.input, err)\n360: \t\t\tcontinue\n361: \t\t}\n362: \n363: \t\tif string(decoded) != tc.output {\n364: \t\t\tt.Errorf(\"decoded mismatch for %s: expected %s, got %s\", tc.input, tc.output, string(decoded))\n365: \t\t}\n366: \t}\n367: }\n368: \n369: func TestParseAndValidate_WithCustomClaims(t *testing.T) {\n370: \tprivateKey, publicKey, err := GenerateKeyPair(2048)\n371: \tif err != nil {\n372: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n373: \t}\n374: \n375: \tclaims := &Claims{\n376: \t\tSub:       \"user-123\",\n377: \t\tIss:       \"agentcube\",\n378: \t\tAud:       \"picod\",\n379: \t\tExp:       time.Now().Add(1 * time.Hour).Unix(),\n380: \t\tIat:       time.Now().Unix(),\n381: \t\tSandboxID: \"sandbox-456\",\n382: \t\tNamespace: \"production\",\n383: \t}\n384: \n385: \ttoken, err := generateTestToken(privateKey, claims)\n386: \tif err != nil {\n387: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n388: \t}\n389: \n390: \tvalidatedClaims, err := ParseAndValidate(token, publicKey)\n391: \tif err != nil {\n392: \t\tt.Fatalf(\"failed to validate token: %v\", err)\n393: \t}\n394: \n395: \tif validatedClaims.Namespace != \"production\" {\n396: \t\tt.Errorf(\"namespace mismatch: expected production, got %s\", validatedClaims.Namespace)\n397: \t}\n398: }\n399: \n400: func TestVerifySignature_TamperedPayload(t *testing.T) {\n401: \tprivateKey, publicKey, err := GenerateKeyPair(2048)\n402: \tif err != nil {\n403: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n404: \t}\n405: \n406: \tclaims := testClaims()\n407: \ttoken, err := generateTestToken(privateKey, claims)\n408: \tif err != nil {\n409: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n410: \t}\n411: \n412: \tparts := strings.Split(token, \".\")\n413: \ttamperedClaims := &Claims{\n414: \t\tSub:       \"hacker\",\n415: \t\tIss:       \"test-issuer\",\n416: \t\tAud:       \"picod\",\n417: \t\tExp:       time.Now().Add(1 * time.Hour).Unix(),\n418: \t\tIat:       time.Now().Unix(),\n419: \t\tSandboxID: \"hacked-sandbox\",\n420: \t\tNamespace: \"default\",\n421: \t}\n422: \n423: \tclaimsJSON, _ := json.Marshal(tamperedClaims)\n424: \tclaimsEncoded := strings.TrimRight(base64.URLEncoding.EncodeToString(claimsJSON), \"=\")\n425: \ttamperedToken := parts[0] + \".\" + claimsEncoded + \".\" + parts[2]\n426: \n427: \terr = VerifySignature(tamperedToken, publicKey)\n428: \tif err == nil {\n429: \t\tt.Fatal(\"expected error for tampered payload\")\n430: \t}\n431: }\n\n(End of file - total 431 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/sha256\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n)\n\nfunc generateTestToken(privateKey *rsa.PrivateKey, claims *Claims) (string, error) {\n\theader := map[string]string{\n\t\t\"alg\": \"RS256\",\n\t\t\"typ\": \"JWT\",\n\t}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/jwt_test.go","time":{"start":1775862263673,"end":1775862263705}}}}
