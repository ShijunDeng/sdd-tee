64(base64PEM string) (*rsa.PublicKey, error) {\n\tpemData, err := base64.StdEncoding.DecodeString(base64PEM)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to decode base64: %w\", err)\n\t}\n\treturn LoadPublicKey(pemData)\n}\n\nfunc ParsePEM(pemBlock *pem.Block) (*rsa.PublicKey, error) {\n\tswitch pemBlock.Type {\n\tcase \"RSA PUBLIC KEY\":\n\t\tkey, err := x509.ParsePKCS1PublicKey(pemBlock.Bytes)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"failed to parse PKCS1 public key: %w\", err)\n\t\t}\n\t\treturn key, nil\n\tcase \"PUBLIC KEY\":\n\t\tpubKey, err := x509.ParsePKIXPublicKey(pemBlock.Bytes)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"failed to parse PKIX public key: %w\", err)\n\t\t}\n\t\trsaKey, ok := pubKey.(*rsa.PublicKey)\n\t\tif !ok {\n\t\t\treturn nil, fmt.Errorf(\"not an RSA public key\")\n\t\t}\n\t\treturn rsaKey, nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported PEM block type: %s\", pemBlock.Type)\n\t}\n}\n\nfunc GenerateKeyPair(bits int) (*rsa.PrivateKey, *rsa.PublicKey, error) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, bits)\n\tif err != nil {\n\t\treturn nil, nil, fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n\t}\n\treturn privateKey, &privateKey.PublicKey, nil\n}\n\nfunc EncodePublicKeyToPEM(publicKey *rsa.PublicKey) ([]byte, error) {\n\tpubDER, err := x509.MarshalPKIXPublicKey(publicKey)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to marshal public key: %w\", err)\n\t}\n\n\tpemBlock := &pem.Block{\n\t\tType:  publicKeyBegin,\n\t\tBytes: pubDER,\n\t}\n\n\tpemData := pem.EncodeToMemory(pemBlock)\n\treturn pemData, nil\n}\n","after":"package picod\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/pem\"\n\t\"fmt\"\n)\n\nconst (\n\trsaPublicKeyBegin = \"-----BEGIN RSA PUBLIC KEY-----\"\n\trsaPublicKeyEnd   = \"-----END RSA PUBLIC KEY-----\"\n\tpublicKeyBegin    = \"-----BEGIN PUBLIC KEY-----\"\n\tpublicKeyEnd      = \"-----END PUBLIC KEY-----\"\n)\n\nfunc LoadPublicKey(pemData []byte) (*rsa.PublicKey, error) {\n\tblock, _ := pem.Decode(pemData)\n\tif block == nil {\n\t\treturn nil, fmt.Errorf(\"failed to decode PEM data\")\n\t}\n\treturn ParsePEM(block)\n}\n\nfunc LoadPublicKeyFromBase64(base64PEM string) (*rsa.PublicKey, error) {\n\tpemData, err := base64.StdEncoding.DecodeString(base64PEM)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to decode base64: %w\", err)\n\t}\n\treturn LoadPublicKey(pemData)\n}\n\nfunc ParsePEM(pemBlock *pem.Block) (*rsa.PublicKey, error) {\n\tswitch pemBlock.Type {\n\tcase \"RSA PUBLIC KEY\":\n\t\tkey, err := x509.ParsePKCS1PublicKey(pemBlock.Bytes)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"failed to parse PKCS1 public key: %w\", err)\n\t\t}\n\t\treturn key, nil\n\tcase \"PUBLIC KEY\":\n\t\tpubKey, err := x509.ParsePKIXPublicKey(pemBlock.Bytes)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"failed to parse PKIX public key: %w\", err)\n\t\t}\n\t\trsaKey, ok := pubKey.(*rsa.PublicKey)\n\t\tif !ok {\n\t\t\treturn nil, fmt.Errorf(\"not an RSA public key\")\n\t\t}\n\t\treturn rsaKey, nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported PEM block type: %s\", pemBlock.Type)\n\t}\n}\n\nfunc GenerateKeyPair(bits int) (*rsa.PrivateKey, *rsa.PublicKey, error) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, bits)\n\tif err != nil {\n\t\treturn nil, nil, fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n\t}\n\treturn privateKey, &privateKey.PublicKey, nil\n}\n\nfunc EncodePublicKeyToPEM(publicKey *rsa.PublicKey) ([]byte, error) {\n\tpubDER, err := x509.MarshalPKIXPublicKey(publicKey)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to marshal public key: %w\", err)\n\t}\n\n\tpemBlock := &pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: pubDER,\n\t}\n\n\tpemData := pem.EncodeToMemory(pemBlock)\n\treturn pemData, nil\n}\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-p