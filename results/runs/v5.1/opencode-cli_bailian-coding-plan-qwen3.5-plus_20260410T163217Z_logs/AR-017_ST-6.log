\tmiddleware := NewJWTMiddleware(publicKey)\n49: \n50: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n51: \t\tw.WriteHeader(http.StatusOK)\n52: \t})\n53: \n54: \twrappedHandler := middleware.Middleware(handler)\n55: \n56: \treq := httptest.NewRequest(\"GET\", \"/api/test\", nil)\n57: \n58: \trr := httptest.NewRecorder()\n59: \twrappedHandler.ServeHTTP(rr, req)\n60: \n61: \tif rr.Code != http.StatusUnauthorized {\n62: \t\tt.Errorf(\"expected status 401, got %d\", rr.Code)\n63: \t}\n64: \n65: \tvar response map[string]string\n66: \tif err := json.Unmarshal(rr.Body.Bytes(), &response); err != nil {\n67: \t\tt.Fatalf(\"failed to parse response: %v\", err)\n68: \t}\n69: \n70: \tif response[\"error\"] != string(AuthErrorMissingToken) {\n71: \t\tt.Errorf(\"expected error %s, got %s\", AuthErrorMissingToken, response[\"error\"])\n72: \t}\n73: }\n74: \n75: func TestJWTMiddleware_InvalidToken(t *testing.T) {\n76: \t_, publicKey, err := GenerateKeyPair(2048)\n77: \tif err != nil {\n78: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n79: \t}\n80: \n81: \tmiddleware := NewJWTMiddleware(publicKey)\n82: \n83: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n84: \t\tw.WriteHeader(http.StatusOK)\n85: \t})\n86: \n87: \twrappedHandler := middleware.Middleware(handler)\n88: \n89: \treq := httptest.NewRequest(\"GET\", \"/api/test\", nil)\n90: \treq.Header.Set(\"Authorization\", \"Bearer invalid.token.here\")\n91: \n92: \trr := httptest.NewRecorder()\n93: \twrappedHandler.ServeHTTP(rr, req)\n94: \n95: \tif rr.Code != http.StatusUnauthorized {\n96: \t\tt.Errorf(\"expected status 401, got %d\", rr.Code)\n97: \t}\n98: }\n99: \n100: func TestJWTMiddleware_ExpiredToken(t *testing.T) {\n101: \tprivateKey, publicKey, err := GenerateKeyPair(2048)\n102: \tif err != nil {\n103: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n104: \t}\n105: \n106: \tmiddleware := NewJWTMiddleware(publicKey)\n107: \n108: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n109: \t\tw.WriteHeader(http.StatusOK)\n110: \t})\n111: \n112: \twrappedHandler := middleware.Middleware(handler)\n113: \n114: \tclaims := testExpiredClaims()\n115: \ttoken, err := generateTestToken(privateKey, claims)\n116: \tif err != nil {\n117: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n118: \t}\n119: \n120: \treq := httptest.NewRequest(\"GET\", \"/api/test\", nil)\n121: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n122: \n123: \trr := httptest.NewRecorder()\n124: \twrappedHandler.ServeHTTP(rr, req)\n125: \n126: \tif rr.Code != http.StatusUnauthorized {\n127: \t\tt.Errorf(\"expected status 401, got %d\", rr.Code)\n128: \t}\n129: }\n130: \n131: func TestJWTMiddleware_SkipPath(t *testing.T) {\n132: \t_, publicKey, err := GenerateKeyPair(2048)\n133: \tif err != nil {\n134: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n135: \t}\n136: \n137: \tmiddleware := NewJWTMiddleware(publicKey, \"/health\", \"/status\")\n138: \n139: \thandlerCalled := false\n140: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n141: \t\thandlerCalled = true\n142: \t\tw.WriteHeader(http.StatusOK)\n143: \t})\n144: \n145: \twrappedHandler := middleware.Middleware(handler)\n146: \n147: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n148: \n149: \trr := httptest.NewRecorder()\n150: \twrappedHandler.ServeHTTP(rr, req)\n151: \n152: \tif !handlerCalled {\n153: \t\tt.Fatal(\"handler should have been called for skipped path\")\n154: \t}\n155: \n156: \tif rr.Code != http.StatusOK {\n157: \t\tt.Errorf(\"expected status 200, got %d\", rr.Code)\n158: \t}\n159: }\n160: \n161: func TestJWTMiddleware_InvalidAuthFormat(t *testing.T) {\n162: \t_, publicKey, err := GenerateKeyPair(2048)\n163: \tif err != nil {\n164: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n165: \t}\n166: \n167: \tmiddleware := NewJWTMiddleware(publicKey)\n168: \n169: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n170: \t\tw.WriteHeader(http.StatusOK)\n171: \t})\n172: \n173: \twrappedHandler := middleware.Middleware(handler)\n174: \n175: \treq := httptest.NewRequest(\"GET\", \"/api/test\", nil)\n176: \treq.Header.Set(\"Authorization\", \"Basic dXNlcjpwYXNz\")\n177: \n178: \trr := httptest.NewRecorder()\n179: \twrappedHandler.ServeHTTP(rr, req)\n180: \n181: \tif rr.Code != http.StatusUnauthorized {\n182: \t\tt.Errorf(\"expected status 401, got %d\", rr.Code)\n183: \t}\n184: }\n185: \n186: func TestJWTMiddleware_EmptyToken(t *testing.T) {\n187: \t_, publicKey, err := GenerateKeyPair(2048)\n188: \tif err != nil {\n189: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n190: \t}\n191: \n192: \tmiddleware := NewJWTMiddleware(publicKey)\n193: \n194: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n195: \t\tw.WriteHeader(http.StatusOK)\n196: \t})\n197: \n198: \twrappedHandler := middleware.Middleware(handler)\n199: \n200: \treq := httptest.NewRequest(\"GET\", \"/api/test\", nil)\n201: \treq.Header.Set(\"Authorization\", \"Bearer \")\n202: \n203: \trr := httptest.NewRecorder()\n204: \twrappedHandler.ServeHTTP(rr, req)\n205: \n206: \tif rr.Code != http.StatusUnauthorized {\n207: \t\tt.Errorf(\"expected status 401, got %d\", rr.Code)\n208: \t}\n209: }\n210: \n211: func TestJWTMiddleware_MultipleSkipPaths(t *testing.T) {\n212: \t_, publicKey, err := GenerateKeyPair(2048)\n213: \tif err != nil {\n214: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n215: \t}\n216: \n217: \tmiddleware := NewJWTMiddleware(publicKey, \"/health\", \"/status\", \"/metrics\")\n218: \n219: \tskipPaths := []string{\"/health\", \"/status\", \"/metrics\"}\n220: \tnonSkipPaths := []string{\"/api/test\", \"/api/v1/execute\"}\n221: \n222: \tfor _, path := range skipPaths {\n223: \t\tt.Run(\"skip_\"+path, func(t *testing.T) {\n224: \t\t\thandlerCalled := false\n225: \t\t\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n226: \t\t\t\thandlerCalled = true\n227: \t\t\t\tw.WriteHeader(http.StatusOK)\n228: \t\t\t})\n229: \n230: \t\t\twrappedHandler := middleware.Middleware(handler)\n231: \n232: \t\t\treq := httptest.NewRequest(\"GET\", path, nil)\n233: \t\t\trr := httptest.NewRecorder()\n234: \t\t\twrappedHandler.ServeHTTP(rr, req)\n235: \n236: \t\t\tif !handlerCalled {\n237: \t\t\t\tt.Errorf(\"handler should have been called for skipped path %s\", path)\n238: \t\t\t}\n239: \t\t})\n240: \t}\n241: \n242: \tfor _, path := range nonSkipPaths {\n243: \t\tt.Run(\"require_\"+path, func(t *testing.T) {\n244: \t\t\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n245: \t\t\t\tw.WriteHeader(http.StatusOK)\n246: \t\t\t})\n247: \n248: \t\t\twrappedHandler := middleware.Middleware(handler)\n249: \n250: \t\t\treq := httptest.NewRequest(\"GET\", path, nil)\n251: \t\t\trr := httptest.NewRecorder()\n252: \t\t\twrappedHandler.ServeHTTP(rr, req)\n253: \n254: \t\t\tif rr.Code != http.StatusUnauthorized {\n255: \t\t\t\tt.Errorf(\"expected status 401 for path %s, got %d\", path, rr.Code)\n256: \t\t\t}\n257: \t\t})\n258: \t}\n259: }\n260: \n261: func TestWriteJSON(t *testing.T) {\n262: \trr := httptest.NewRecorder()\n263: \n264: \tdata := map[string]string{\n265: \t\t\"status\": \"ok\",\n266: \t\t\"id\":     \"123\",\n267: \t}\n268: \n269: \tWriteJSON(rr, http.StatusOK, data)\n270: \n271: \tif rr.Code != http.StatusOK {\n272: \t\tt.Errorf(\"expected status 200, got %d\", rr.Code)\n273: \t}\n274: \n275: \tcontentType := rr.Header().Get(\"Content-Type\")\n276: \tif contentType != \"application/json\" {\n277: \t\tt.Errorf(\"expected Content-Type application/json, got %s\", contentType)\n278: \t}\n279: \n280: \tvar response map[string]string\n281: \tif err := json.Unmarshal(rr.Body.Bytes(), &response); err != nil {\n282: \t\tt.Fatalf(\"failed to parse response: %v\", err)\n283: \t}\n284: \n285: \tif response[\"status\"] != \"ok\" {\n286: \t\tt.Errorf(\"expected status ok, got %s\", response[\"status\"])\n287: \t}\n288: }\n289: \n290: func TestWriteError_AuthError(t *testing.T) {\n291: \trr := httptest.NewRecorder()\n292: \n293: \tauthErr := &AuthError{\n294: \t\tType:    AuthErrorExpiredToken,\n295: \t\tMessage: \"token has expired\",\n296: \t}\n297: \n298: \tWriteError(rr, authErr)\n299: \n300: \tif rr.Code != http.StatusUnauthorized {\n301: \t\tt.Errorf(\"expected status 401, got %d\", rr.Code)\n302: \t}\n303: \n304: \tvar response map[string]string\n305: \tif err := json.Unmarshal(rr.Body.Bytes(), &response); err != nil {\n306: \t\tt.Fatalf(\"failed to parse response: %v\", err)\n307: \t}\n308: \n309: \tif response[\"error\"] != string(AuthErrorExpiredToken) {\n310: \t\tt.Errorf(\"expected error %s, got %s\", AuthErrorExpiredToken, response[\"error\"])\n311: \t}\n312: }\n313: \n314: func TestWriteError_GenericError(t *testing.T) {\n315: \trr := httptest.NewRecorder()\n316: \n317: \tgenericErr := &AuthError{\n318: \t\tType:    AuthErrorInternal,\n319: \t\tMessage: \"internal error\",\n320: \t}\n321: \n322: \tWriteError(rr, genericErr)\n323: \n324: \tif rr.Code != http.StatusInternalServerError {\n325: \t\tt.Errorf(\"expected status 500, got %d\", rr.Code)\n326: \t}\n327: }\n328: \n329: func TestAuthError_HTTPStatus(t *testing.T) {\n330: \ttestCases := []struct {\n331: \t\terrType  AuthErrorType\n332: \t\texpected int\n333: \t}{\n334: \t\t{AuthErrorMissingToken, http.StatusUnauthorized},\n335: \t\t{AuthErrorInvalidToken, http.StatusUnauthorized},\n336: \t\t{AuthErrorExpiredToken, http.StatusUnauthorized},\n337: \t\t{AuthErrorInvalidSig, http.StatusUnauthorized},\n338: \t\t{AuthErrorInvalidClaims, http.StatusForbidden},\n339: \t\t{AuthErrorInternal, http.StatusInternalServerError},\n340: \t}\n341: \n342: \tfor _, tc := range testCases {\n343: \t\tt.Run(string(tc.errType), func(t *testing.T) {\n344: \t\t\terr := &AuthError{\n345: \t\t\t\tType: tc.errType,\n346: \t\t\t}\n347: \n348: \t\t\tstatus := err.HTTPStatus()\n349: \t\t\tif status != tc.expected {\n350: \t\t\t\tt.Errorf(\"expected status %d for %s, got %d\", tc.expected, tc.errType, status)\n351: \t\t\t}\n352: \t\t})\n353: \t}\n354: }\n355: \n356: func TestAuthError_Error(t *testing.T) {\n357: \terr := &AuthError{\n358: \t\tType:    AuthErrorExpiredToken,\n359: \t\tMessage: \"token expired 1 hour ago\",\n360: \t}\n361: \n362: \texpected := \"expired_token: token expired 1 hour ago\"\n363: \tif err.Error() != expected {\n364: \t\tt.Errorf(\"expected error message %q, got %q\", expected, err.Error())\n365: \t}\n366: }\n367: \n368: func TestAuthError_WithUnderlying(t *testing.T) {\n369: \tunderlying := &time.ParseError{Layout: \"2006-01-02\", Value: \"invalid\", LayoutElem: \"2006\"}\n370: \terr := &AuthError{\n371: \t\tType:       AuthErrorInvalidToken,\n372: \t\tMessage:    \"failed to parse\",\n373: \t\tUnderlying: underlying,\n374: \t}\n375: \n376: \tif err.Unwrap() != underlying {\n377: \t\tt.Fatal(\"Unwrap() should return underlying error\")\n378: \t}\n379: }\n380: \n381: func TestJWTMiddleware_Integration_ValidTokenWithClaims(t *testing.T) {\n382: \tprivateKey, publicKey, err := GenerateKeyPair(2048)\n383: \tif err != nil {\n384: \t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n385: \t}\n386: \n387: \tmiddleware := NewJWTMiddleware(publicKey)\n388: \n389: \tvar capturedClaims *Claims\n390: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n391: \t\ttoken := r.Header.Get(\"Authorization\")[7:]\n392: \t\tclaims, _ := ParseAndValidate(token, publicKey)\n393: \t\tcapturedClaims = claims\n394: \t\tw.WriteHeader(http.StatusOK)\n395: \t})\n396: \n397: \twrappedHandler := middleware.Middleware(handler)\n398: \n399: \tclaims := &Claims{\n400: \t\tSub:       \"integration-user\",\n401: \t\tIss:       \"test-issuer\",\n402: \t\tAud:       \"picod\",\n403: \t\tExp:       time.Now().Add(1 * time.Hour).Unix(),\n404: \t\tIat:       time.Now().Unix(),\n405: \t\tSandboxID: \"integration-sandbox\",\n406: \t\tNamespace: \"test-ns\",\n407: \t}\n408: \n409: \ttoken, err := generateTestToken(privateKey, claims)\n410: \tif err != nil {\n411: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n412: \t}\n413: \n414: \treq := httptest.NewRequest(\"GET\", \"/api/test\", nil)\n415: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n416: \n417: \trr := httptest.NewRecorder()\n418: \twrappedHandler.ServeHTTP(rr, req)\n419: \n420: \tif rr.Code != http.StatusOK {\n421: \t\tt.Fatalf(\"expected status 200, got %d\", rr.Code)\n422: \t}\n423: \n424: \tif capturedClaims == nil {\n425: \t\tt.Fatal(\"claims should have been captured\")\n426: \t}\n427: \n428: \tif capturedClaims.Sub != \"integration-user\" {\n429: \t\tt.Errorf(\"expected sub integration-user, got %s\", capturedClaims.Sub)\n430: \t}\n431: \n432: \tif capturedClaims.SandboxID != \"integration-sandbox\" {\n433: \t\tt.Errorf(\"expected sandbox_id integration-sandbox, got %s\", capturedClaims.SandboxID)\n434: \t}\n435: }\n436: \n437: func TestHealthResponse(t *testing.T) {\n438: \tresponse := HealthResponse{\n439: \t\tStatus:    \"healthy\",\n440: \t\tTimestamp: time.Now(),\n441: \t\tSandboxID: \"test-sandbox\",\n442: \t}\n443: \n444: \tdata, err := json.Marshal(response)\n445: \tif err != nil {\n446: \t\tt.Fatalf(\"failed to marshal response: %v\", err)\n447: \t}\n448: \n449: \tvar decoded HealthResponse\n450: \tif err := json.Unmarshal(data, &decoded); err != nil {\n451: \t\tt.Fatalf(\"failed to unmarshal response: %v\", err)\n452: \t}\n453: \n454: \tif decoded.Status != response.Status {\n455: \t\tt.Errorf(\"status mismatch: expected %s, got %s\", response.Status, decoded.Status)\n456: \t}\n457: \n458: \tif decoded.SandboxID != response.SandboxID {\n459: \t\tt.Errorf(\"sandbox_id mismatch: expected %s, got %s\", response.SandboxID, decoded.SandboxID)\n460: \t}\n461: }\n\n(End of file - total 461 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n)\n\nfunc TestJWTMiddleware_ValidToken(t *testing.T) {\n\tprivateKey, publicKey, err := GenerateKeyPair(2048)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to generate key pair: %v\", err)\n\t}\n\n\tmiddleware := NewJWTMiddleware(publicKey)\n\n\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/middleware_test.go","time":{"start":1775862263676,"end":1775862263707}}}}
