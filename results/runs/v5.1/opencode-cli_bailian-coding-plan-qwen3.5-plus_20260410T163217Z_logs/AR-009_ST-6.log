eEntry)\n60: \t\thc.checkRoute(entry)\n61: \t\treturn true\n62: \t})\n63: }\n64: \n65: func (hc *HealthChecker) checkRoute(entry *RouteEntry) {\n66: \tctx, cancel := context.WithTimeout(context.Background(), hc.config.HealthCheckTimeout)\n67: \tdefer cancel()\n68: \n69: \treq, err := http.NewRequestWithContext(ctx, http.MethodGet, entry.BackendURL, nil)\n70: \tif err != nil {\n71: \t\tentry.Health.MarkFailure(err)\n72: \t\tklog.V(4).Infof(\"Health check failed for %s/%s/%s: %v\", entry.Namespace, entry.Kind, entry.Name, err)\n73: \t\treturn\n74: \t}\n75: \n76: \tresp, err := hc.httpClient.Do(req)\n77: \tif err != nil {\n78: \t\tentry.Health.MarkFailure(err)\n79: \t\tklog.V(4).Infof(\"Health check failed for %s/%s/%s: %v\", entry.Namespace, entry.Kind, entry.Name, err)\n80: \t\treturn\n81: \t}\n82: \tdefer resp.Body.Close()\n83: \n84: \tif resp.StatusCode >= 200 && resp.StatusCode < 400 {\n85: \t\tentry.Health.MarkHealthy()\n86: \t\tklog.V(4).Infof(\"Health check passed for %s/%s/%s\", entry.Namespace, entry.Kind, entry.Name)\n87: \t} else {\n88: \t\tentry.Health.MarkFailure(fmt.Errorf(\"unhealthy status code: %d\", resp.StatusCode))\n89: \t\tklog.V(4).Infof(\"Health check failed for %s/%s/%s: status code %d\", entry.Namespace, entry.Kind, entry.Name, resp.StatusCode)\n90: \t}\n91: }\n92: \n93: func (hc *HealthChecker) MarkUnhealthy(entry *RouteEntry) {\n94: \tentry.Health.MarkFailure(errors.New(\"manually marked unhealthy\"))\n95: }\n96: \n97: func (hc *HealthChecker) MarkHealthy(entry *RouteEntry) {\n98: \tentry.Health.MarkHealthy()\n99: }\n\n(End of file - total 99 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n)\n\ntype HealthChecker struct {\n\tconfig     *RouterConfig\n\troutes     *sync.Map\n\thttpClient *http.Client\n\tstopCh     chan struct{}\n\twg         sync.WaitGroup\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/op