{"type":"tool_use","timestamp":1775849101404,"sessionID":"ses_287256e9fffeSRz9kwMdlXsQmu","part":{"id":"prt_d78dac49f001ELa9Z5sKPiwjDn","messageID":"msg_d78daae2a001Rvv2zN1ZS6OKbE","sessionID":"ses_287256e9fffeSRz9kwMdlXsQmu","type":"tool","tool":"read","callID":"toolu_a79307aed3174f5dadd717fb","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"sync\"\n8: \t\"time\"\n9: \n10: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n11: \twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n12: \tcorev1 \"k8s.io/api/core/v1\"\n13: \t\"k8s.io/client-go/kubernetes/scheme\"\n14: \t\"k8s.io/client-go/tools/cache\"\n15: \t\"k8s.io/klog/v2\"\n16: )\n17: \n18: type RouterInterface interface {\n19: \tStart(ctx context.Context) error\n20: \tShutdown(ctx context.Context) error\n21: \tServeHTTP(w http.ResponseWriter, r *http.Request)\n22: }\n23: \n24: type Router struct {\n25: \tconfig              *RouterConfig\n26: \troutes              sync.Map\n27: \thttpClient          *http.Client\n28: \truntimeInformer     cache.SharedIndexInformer\n29: \tinterpreterInformer cache.SharedIndexInformer\n30: \tstopCh              chan struct{}\n31: \twg                  sync.WaitGroup\n32: \tmu                  sync.RWMutex\n33: \thandler             *Handler\n34: \tresolver            *Resolver\n35: \thealthChecker       *HealthChecker\n36: }\n37: \n38: func NewRouter(config *RouterConfig) (*Router, error) {\n39: \tif config.KubeConfig == nil {\n40: \t\treturn nil, fmt.Errorf(\"kubeconfig is required\")\n41: \t}\n42: \n43: \tif err := runtimev1alpha1.AddToScheme(scheme.Scheme); err != nil {\n44: \t\treturn nil, fmt.Errorf(\"failed to add runtime scheme: %w\", err)\n45: \t}\n46: \n47: \ttransport := &http.Transport{\n48: \t\tMaxConnsPerHost:     config.MaxConnsPerHost,\n49: \t\tMaxIdleConns:        100,\n50: \t\tMaxIdleConnsPerHost: 10,\n51: \t\tIdleConnTimeout:     90 * time.Second,\n52: \t}\n53: \n54: \thttpClient := &http.Client{\n55: \t\tTransport: transport,\n56: \t\tTimeout:   config.WriteTimeout,\n57: \t}\n58: \n59: \trouter := &Router{\n60: \t\tconfig:     config,\n61: \t\thttpClient: httpClient,\n62: \t\tstopCh:     make(chan struct{}),\n63: \t\troutes:     sync.Map{},\n64: \t}\n65: \n66: \trouter.resolver = NewResolver(&router.routes)\n67: \trouter.handler = NewHandler(router, router.resolver)\n68: \trouter.healthChecker = NewHealthChecker(config, &router.routes, httpClient)\n69: \n70: \treturn router, nil\n71: }\n72: \n73: func (r *Router) SetInformers(runtimeInformer, interpreterInformer cache.SharedIndexInformer) {\n74: \tr.runtimeInformer = runtimeInformer\n75: \tr.interpreterInformer = interpreterInformer\n76: \n77: \tif r.runtimeInformer != nil {\n78: \t\tr.runtimeInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n79: \t\t\tAddFunc:    r.onAgentRuntimeAdd,\n80: \t\t\tUpdateFunc: r.onAgentRuntimeUpdate,\n81: \t\t\tDeleteFunc: r.onAgentRuntimeDelete,\n82: \t\t})\n83: \t}\n84: \n85: \tif r.interpreterInformer != nil {\n86: \t\tr.interpreterInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n87: \t\t\tAddFunc:    r.onCodeInterpreterAdd,\n88: \t\t\tUpdateFunc: r.onCodeInterpreterUpdate,\n89: \t\t\tDeleteFunc: r.onCodeInterpreterDelete,\n90: \t\t})\n91: \t}\n92: }\n93: \n94: func (r *Router) onAgentRuntimeAdd(obj interface{}) {\n95: \trt, ok := obj.(*runtimev1alpha1.AgentRuntime)\n96: \tif !ok {\n97: \t\tklog.Errorf(\"Failed to convert object to AgentRuntime\")\n98: \t\treturn\n99: \t}\n100: \n101: \tif !r.shouldExpose(rt.Labels) {\n102: \t\tklog.V(4).Infof(\"AgentRuntime %s/%s is not exposed, skipping\", rt.Namespace, rt.Name)\n103: \t\treturn\n104: \t}\n105: \n106: \tbackendURL := r.extractBackendURLFromStatus(rt.Status.SandboxRef)\n107: \tif backendURL == \"\" {\n108: \t\tklog.V(4).Infof(\"AgentRuntime %s/%s has no backend URL, skipping\", rt.Namespace, rt.Name)\n109: \t\treturn\n110: \t}\n111: \n112: \tentry := &RouteEntry{\n113: \t\tName:       rt.Name,\n114: \t\tNamespace:  rt.Namespace,\n115: \t\tKind:       wmTypes.AgentRuntimeKind,\n116: \t\tBackendURL: backendURL,\n117: \t\tHealth:     HealthStatus{Healthy: true, LastCheck: time.Now()},\n118: \t\tUpdatedAt:  time.Now(),\n119: \t}\n120: \n121: \tkey := routeKey(rt.Namespace, rt.Kind, rt.Name)\n122: \tr.routes.Store(key, entry)\n123: \tklog.V(4).Infof(\"Added route for AgentRuntime %s/%s -> %s\", rt.Namespace, rt.Name, backendURL)\n124: }\n125: \n126: func (r *Router) onAgentRuntimeUpdate(oldObj, newObj interface{}) {\n127: \tr.onAgentRuntimeAdd(newObj)\n128: }\n129: \n130: func (r *Router) onAgentRuntimeDelete(obj interface{}) {\n131: \trt, ok := obj.(*runtimev1alpha1.AgentRuntime)\n132: \tif !ok {\n133: \t\ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n134: \t\tif !ok {\n135: \t\t\tklog.Errorf(\"Failed to convert object to AgentRuntime\")\n136: \t\t\treturn\n137: \t\t}\n138: \t\trt, ok = tombstone.Obj.(*runtimev1alpha1.AgentRuntime)\n139: \t\tif !ok {\n140: \t\t\tklog.Errorf(\"Failed to convert tombstone to AgentRuntime\")\n141: \t\t\treturn\n142: \t\t}\n143: \t}\n144: \n145: \tkey := routeKey(rt.Namespace, rt.Kind, rt.Name)\n146: \tr.routes.Delete(key)\n147: \tklog.V(4).Infof(\"Removed route for AgentRuntime %s/%s\", rt.Namespace, rt.Name)\n148: }\n149: \n150: func (r *Router) onCodeInterpreterAdd(obj interface{}) {\n151: \tci, ok := obj.(*runtimev1alpha1.CodeInterpreter)\n152: \tif !ok {\n153: \t\tklog.Errorf(\"Failed to convert object to CodeInterpreter\")\n154: \t\treturn\n155: \t}\n156: \n157: \tif !r.shouldExpose(ci.Labels) {\n158: \t\tklog.V(4).Infof(\"CodeInterpreter %s/%s is not exposed, skipping\", ci.Namespace, ci.Name)\n159: \t\treturn\n160: \t}\n161: \n162: \tbackendURL := r.extractBackendURLFromStatus(ci.Status.SandboxRef)\n163: \tif backendURL == \"\" {\n164: \t\tklog.V(4).Infof(\"CodeInterpreter %s/%s has no backend URL, skipping\", ci.Namespace, ci.Name)\n165: \t\treturn\n166: \t}\n167: \n168: \tentry := &RouteEntry{\n169: \t\tName:       ci.Name,\n170: \t\tNamespace:  ci.Namespace,\n171: \t\tKind:       wmTypes.CodeInterpreterKind,\n172: \t\tBackendURL: backendURL,\n173: \t\tHealth:     HealthStatus{Healthy: true, LastCheck: time.Now()},\n174: \t\tUpdatedAt:  time.Now(),\n175: \t}\n176: \n177: \tkey := routeKey(ci.Namespace, ci.Kind, ci.Name)\n178: \tr.routes.Store(key, entry)\n179: \tklog.V(4).Infof(\"Added route for CodeInterpreter %s/%s -> %s\", ci.Namespace, ci.Name, backendURL)\n180: }\n181: \n182: func (r *Router) onCodeInterpreterUpdate(oldObj, newObj interface{}) {\n183: \tr.onCodeInterpreterAdd(newObj)\n184: }\n185: \n186: func (r *Router) onCodeInterpreterDelete(obj interface{}) {\n187: \tci, ok := obj.(*runtimev1alpha1.CodeInterpreter)\n188: \tif !ok {\n189: \t\ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n190: \t\tif !ok {\n191: \t\t\tklog.Errorf(\"Failed to convert object to CodeInterpreter\")\n192: \t\t\treturn\n193: \t\t}\n194: \t\tci, ok = tombstone.Obj.(*runtimev1alpha1.CodeInterpreter)\n195: \t\tif !ok {\n196: \t\t\tklog.Errorf(\"Failed to convert tombstone to CodeInterpreter\")\n197: \t\t\treturn\n198: \t\t}\n199: \t}\n200: \n201: \tkey := routeKey(ci.Namespace, ci.Kind, ci.Name)\n202: \tr.routes.Delete(key)\n203: \tklog.V(4).Infof(\"Removed route for CodeInterpreter %s/%s\", ci.Namespace, ci.Name)\n204: }\n205: \n206: func (r *Router) shouldExpose(labels map[string]string) bool {\n207: \treturn labels[\"agentcube.volcano.sh/expose\"] == \"true\"\n208: }\n209: \n210: func (r *Router) extractBackendURLFromStatus(sandboxRef *corev1.ObjectReference) string {\n211: \tif sandboxRef == nil {\n212: \t\treturn \"\"\n213: \t}\n214: \n215: \tif sandboxRef.Name == \"\" {\n216: \t\treturn \"\"\n217: \t}\n218: \n219: \treturn fmt.Sprintf(\"http://%s.%s.svc.cluster.local:8080\", sandboxRef.Name, sandboxRef.Namespace)\n220: }\n221: \n222: func (r *Router) Start(ctx context.Context) error {\n223: \tr.healthChecker.Start()\n224: \n225: \tserver := &http.Server{\n226: \t\tAddr:         r.config.ListenAddr,\n227: \t\tHandler:      r.handler,\n228: \t\tReadTimeout:  r.config.ReadTimeout,\n229: \t\tWriteTimeout: r.config.WriteTimeout,\n230: \t\tIdleTimeout:  r.config.IdleTimeout,\n231: \t}\n232: \n233: \tr.wg.Add(1)\n234: \tgo func() {\n235: \t\tdefer r.wg.Done()\n236: \t\tklog.Infof(\"Router listening on %s\", r.config.ListenAddr)\n237: \t\tif err := server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n238: \t\t\tklog.Errorf(\"Router server error: %v\", err)\n239: \t\t}\n240: \t}()\n241: \n242: \treturn nil\n243: }\n244: \n245: func (r *Router) Shutdown(ctx context.Context) error {\n246: \tclose(r.stopCh)\n247: \tr.healthChecker.Stop()\n248: \n249: \tserver := &http.Server{\n250: \t\tAddr:         r.config.ListenAddr,\n251: \t\tReadTimeout:  r.config.ReadTimeout,\n252: \t\tWriteTimeout: r.config.WriteTimeout,\n253: \t\tIdleTimeout:  r.config.IdleTimeout,\n254: \t}\n255: \n256: \tif err := server.Shutdown(ctx); err != nil {\n257: \t\treturn fmt.Errorf(\"failed to shutdown server: %w\", err)\n258: \t}\n259: \n260: \tr.wg.Wait()\n261: \tklog.Info(\"Router shutdown complete\")\n262: \treturn nil\n263: }\n264: \n265: func (r *Router) ServeHTTP(w http.ResponseWriter, req *http.Request) {\n266: \tr.handler.ServeHTTP(w, req)\n267: }\n268: \n269: func (r *Router) GetRoute(namespace, kind, name string) (*RouteEntry, bool) {\n270: \tkey := routeKey(namespace, kind, name)\n271: \tentry, ok := r.routes.Load(key)\n272: \tif !ok {\n273: \t\treturn nil, false\n274: \t}\n275: \treturn entry.(*RouteEntry), true\n276: }\n277: \n278: func (r *Router) ListRoutes() []*RouteEntry {\n279: \tvar routes []*RouteEntry\n280: \tr.routes.Range(func(key, value interface{}) bool {\n281: \t\troutes = append(routes, value.(*RouteEntry))\n282: \t\treturn true\n283: \t})\n284: \treturn routes\n285: }\n286: \n287: func (r *Router) AddRoute(entry *RouteEntry) {\n288: \tkey := routeKey(entry.Namespace, entry.Kind, entry.Name)\n289: \tr.routes.Store(key, entry)\n290: \tklog.V(4).Infof(\"Manually added route for %s/%s/%s -> %s\", entry.Namespace, entry.Kind, entry.Name, entry.BackendURL)\n291: }\n292: \n293: func (r *Router) RemoveRoute(namespace, kind, name string) {\n294: \tkey := routeKey(namespace, kind, name)\n295: \tr.routes.Delete(key)\n296: \tklog.V(4).Infof(\"Manually removed route for %s/%s/%s\", namespace, kind, name)\n297: }\n\n(End of file - total 297 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/client-go/kubernetes/scheme\"\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype RouterInterface interface {\n\tStart(ctx context.Context) error\n\tShutdown(ctx context.Context) error","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router.go","time":{"start":1775849101372,"end":1775849101402}}}}
