err)\n53: \t}\n54: \n55: \tproxy := httputil.NewSingleHostReverseProxy(backendURL)\n56: \tproxy.ErrorHandler = func(w http.ResponseWriter, r *http.Request, err error) {\n57: \t\tklog.Errorf(\"Proxy error: %v\", err)\n58: \t\tw.WriteHeader(http.StatusBadGateway)\n59: \t}\n60: \n61: \tproxy.ModifyResponse = func(resp *http.Response) error {\n62: \t\tfor k, vv := range resp.Header {\n63: \t\t\tfor _, v := range vv {\n64: \t\t\t\tw.Header().Add(k, v)\n65: \t\t\t}\n66: \t\t}\n67: \t\treturn nil\n68: \t}\n69: \n70: \tr = h.AddForwardingHeaders(r)\n71: \tctx := r.Context()\n72: \tctx = context.WithValue(ctx, \"route\", route)\n73: \tr = r.WithContext(ctx)\n74: \n75: \tproxy.ServeHTTP(w, r)\n76: \treturn nil\n77: }\n78: \n79: func (h *Handler) AddForwardingHeaders(r *http.Request) *http.Request {\n80: \tclientIP, _, err := net.SplitHostPort(r.RemoteAddr)\n81: \tif err != nil {\n82: \t\tclientIP = r.RemoteAddr\n83: \t}\n84: \n85: \tr.Header.Set(\"X-Forwarded-For\", clientIP)\n86: \tr.Header.Set(\"X-Real-IP\", clientIP)\n87: \tr.Header.Set(\"X-Forwarded-Host\", r.Host)\n88: \tr.Header.Set(\"X-Forwarded-Proto\", r.URL.Scheme)\n89: \n90: \tif r.TLS != nil {\n91: \t\tr.Header.Set(\"X-Forwarded-Proto\", \"https\")\n92: \t} else {\n93: \t\tr.Header.Set(\"X-Forwarded-Proto\", \"http\")\n94: \t}\n95: \n96: \treturn r\n97: }\n98: \n99: func (h *Handler) writeError(w http.ResponseWriter, err error, statusCode int) {\n100: \tw.Header().Set(\"Content-Type\", \"application/json\")\n101: \tw.WriteHeader(statusCode)\n102: \n103: \tresp := ErrorResponse{\n104: \t\tError:     err.Error(),\n105: \t\tCode:      http.StatusText(statusCode),\n106: \t\tTimestamp: time.Now().Format(time.RFC3339),\n107: \t}\n108: \n109: \tif strings.Contains(err.Error(), \"route not found\") {\n110: \t\tresp.Code = \"RouteNotFound\"\n111: \t} else if strings.Contains(err.Error(), \"invalid resource type\") {\n112: \t\tresp.Code = \"InvalidResourceType\"\n113: \t\tw.WriteHeader(http.StatusBadRequest)\n114: \t} else if strings.Contains(err.Error(), \"malformed\") {\n115: \t\tresp.Code = \"MalformedPath\"\n116: \t\tw.WriteHeader(http.StatusBadRequest)\n117: \t} else if strings.Contains(err.Error(), \"no healthy backends\") {\n118: \t\tresp.Code = \"NoHealthyBackends\"\n119: \t\tw.WriteHeader(http.StatusServiceUnavailable)\n120: \t} else if strings.Contains(err.Error(), \"backend\") {\n121: \t\tresp.Code = \"BackendError\"\n122: \t\tw.WriteHeader(http.StatusBadGateway)\n123: \t}\n124: \n125: \tjson.NewEncoder(w).Encode(resp)\n126: }\n127: \n128: var (\n129: \tErrBackendConnection  = errors.New(\"failed to connect to backend\")\n130: \tErrBackendTimeout     = errors.New(\"backend timeout\")\n131: \tErrBackendUnavailable = errors.New(\"backend unavailable\")\n132: )\n\n(End of file - total 132 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n)\n\ntype ErrorResponse struct {\n\tError     string `json:\"error\"`\n\tCode      string `json:\"code\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler.go","time":{"start":1775849101375,"end":1775849101405}}}}
