6: \t\tarGroup.PUT(\"/:name\", arHandler.UpdateAgentRuntime)\n37: \t\tarGroup.DELETE(\"/:name\", arHandler.DeleteAgentRuntime)\n38: \t}\n39: \n40: \tciGroup := engine.Group(\"/api/v1/codeinterpreters\")\n41: \t{\n42: \t\tciHandler := handler.NewCodeInterpreterHandler(deps.Client)\n43: \t\tciGroup.POST(\"\", ciHandler.CreateCodeInterpreter)\n44: \t\tciGroup.GET(\"\", ciHandler.ListCodeInterpreters)\n45: \t\tciGroup.GET(\"/:name\", ciHandler.GetCodeInterpreter)\n46: \t\tciGroup.PUT(\"/:name\", ciHandler.UpdateCodeInterpreter)\n47: \t\tciGroup.DELETE(\"/:name\", ciHandler.DeleteCodeInterpreter)\n48: \t}\n49: \n50: \tsandboxGroup := engine.Group(\"/v1\")\n51: \t{\n52: \t\tsandboxHandler := handler.NewSandboxHandler(\n53: \t\t\tdeps.Client,\n54: \t\t\tdeps.K8sClient,\n55: \t\t\tdeps.PodLister,\n56: \t\t\tdeps.ARLister,\n57: \t\t\tdeps.CILister,\n58: \t\t\t\"default\",\n59: \t\t)\n60: \t\tsandboxGroup.POST(\"/agent-runtime\", sandboxHandler.HandleAgentRuntimeCreate)\n61: \t\tsandboxGroup.POST(\"/code-interpreter\", sandboxHandler.HandleCodeInterpreterCreate)\n62: \t}\n63: }\n\n(End of file - total 63 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/middleware\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/processor\"\n)\n\ntype Dependencies struct {\n\tClient    dynamic.Interface\n\tK8sClient kubernetes.Interface\n\tPodLister corev1lister.PodLister\n\tARLister  processor.AgentRuntimeLister\n\tCILister  processor.CodeInterpreterLister\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/routes.go","time":{"start":1775847912844,"end":1775847912866}}}}
