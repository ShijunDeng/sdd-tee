2: }\n213: \n214: func TestGarbageCollector_Tick_StoreError(t *testing.T) {\n215: \tfakeClient := newFakeDynamicClient()\n216: \tfakeStore := &fakeStore{}\n217: \n218: \tgc := NewGarbageCollector(fakeClient, fakeStore, 1*time.Hour)\n219: \n220: \tgc.tick()\n221: \n222: \tif len(fakeStore.deletedSessionIDs) != 0 {\n223: \t\tt.Errorf(\"Expected no sandboxes to be deleted, got %d\", len(fakeStore.deletedSessionIDs))\n224: \t}\n225: }\n226: \n227: func newFakeDynamicClient() *fake.FakeDynamicClient {\n228: \tscheme := runtime.NewScheme()\n229: \treturn fake.NewSimpleDynamicClient(scheme)\n230: }\n\n(End of file - total 230 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\ntype fakeStore struct {\n\tinactiveSandboxes []*wmTypes.SandboxInfo\n\texpiredSandboxes  []*wmTypes.SandboxInfo\n\tdeletedSessionIDs []string\n}\n\nfunc (f *fakeStore) Ping(ctx context.Context) error {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/garbage_collector_test.go","time":{"start":1775847744930,"end":1775847744950}}}}
