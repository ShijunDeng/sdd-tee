: --port=8080\n38:       - contains:\n39:           path: spec.template.spec.containers[0].args\n40:           content: --runtime-class-name=\n41: \n42:   - it: should render workloadmanager service with default values\n43:     asserts:\n44:       - isKind:\n45:           of: Service\n46:         documentIndex: 1\n47:       - equal:\n48:           path: metadata.name\n49:           value: workloadmanager\n50:       - equal:\n51:           path: spec.type\n52:           value: ClusterIP\n53:       - equal:\n54:           path: spec.ports[0].port\n55:           value: 8080\n56:       - equal:\n57:           path: spec.ports[0].targetPort\n58:           value: 8080\n59:       - equal:\n60:           path: spec.selector.app\n61:           value: workloadmanager\n62: \n63:   - it: should render with custom replicas and image\n64:     set:\n65:       workloadmanager:\n66:         replicas: 3\n67:         image:\n68:           repository: custom-repo/workloadmanager\n69:           tag: v1.2.3\n70:     asserts:\n71:       - isKind:\n72:           of: Deployment\n73:         documentIndex: 0\n74:       - equal:\n75:           path: spec.replicas\n76:           value: 3\n77:       - equal:\n78:           path: spec.template.spec.containers[0].image\n79:           value: custom-repo/workloadmanager:v1.2.3\n80: \n81:   - it: should render with custom resources\n82:     set:\n83:       workloadmanager:\n84:         resources:\n85:           limits:\n86:             cpu: 1000m\n87:             memory: 1Gi\n88:           requests:\n89:             cpu: 500m\n90:             memory: 256Mi\n91:     asserts:\n92:       - equal:\n93:           path: spec.template.spec.containers[0].resources.limits.cpu\n94:           value: 1000m\n95:       - equal:\n96:           path: spec.template.spec.containers[0].resources.limits.memory\n97:           value: 1Gi\n98:       - equal:\n99:           path: spec.template.spec.containers[0].resources.requests.cpu\n100:           value: 500m\n101:       - equal:\n102:           path: spec.template.spec.containers[0].resources.requests.memory\n103:           value: 256Mi\n104: \n105:   - it: should render with extraEnv\n106:     set:\n107:       workloadmanager:\n108:         extraEnv:\n109:           - name: CUSTOM_ENV\n110:             value: custom-value\n111:     asserts:\n112:       - contains:\n113:           path: spec.template.spec.containers[0].env\n114:           content:\n115:             name: CUSTOM_ENV\n116:             value: custom-value\n117: \n118:   - it: should render with imagePullSecrets\n119:     set:\n120:       imagePullSecrets:\n121:         - name: my-secret\n122:     asserts:\n123:       - contains:\n124:           path: spec.template.spec.imagePullSecrets\n125:           content:\n126:             name: my-secret\n127: \n128:   - it: should have correct health probes\n129:     asserts:\n130:       - equal:\n131:           path: spec.template.spec.containers[0].livenessProbe.httpGet.path\n132:           value: /health\n133:       - equal:\n134:           path: spec.template.spec.containers[0].livenessProbe.httpGet.port\n135:           value: 8080\n136:       - equal:\n137:           path: spec.template.spec.containers[0].livenessProbe.initialDelaySeconds\n138:           value: 10\n139:       - equal:\n140:           path: spec.template.spec.containers[0].livenessProbe.periodSeconds\n141:           value: 10\n142:       - equal:\n143:           path: spec.template.spec.containers[0].readinessProbe.httpGet.path\n144:           value: /health\n145:       - equal:\n146:           path: spec.template.spec.containers[0].readinessProbe.httpGet.port\n147:           value: 8080\n148:       - equal:\n149:           path: spec.template.spec.containers[0].readinessProbe.initialDelaySeconds\n150:           value: 5\n151:       - equal:\n152:           path: spec.template.spec.containers[0].readinessProbe.periodSeconds\n153:           value: 5\n154: \n155:   - it: should render with redis configuration\n156:     set:\n157:       redis:\n158:         addr: redis.default.svc.cluster.local:6379\n159:         password: mypassword\n160:     asserts:\n161:       - contains:\n162:           path: spec.template.spec.containers[0].env\n163:           content:\n164:             name: REDIS_ADDR\n165:             value: redis.default.svc.cluster.local:6379\n166:       - contains:\n167:           path: spec.template.spec.containers[0].env\n168:           content:\n169:             name: REDIS_PASSWORD\n170:             value: mypassword\n\n(End of file - total 170 lines)\n</content>","metadata":{"preview":"suite: Workload Manager Tests\ntemplates:\n  - workloadmanager.yaml\ntests:\n  - it: should render workloadmanager deployment with default values\n    asserts:\n      - isKind:\n          of: Deployment\n        documentIndex: 0\n      - equal:\n          path: metadata.name\n          value: workloadmanager\n      - equal:\n          path: spec.replicas\n          value: 1\n      - equal:\n          path: spec.template.spec.containers[0].name\n          value: workloadmanager\n      - equal:\n          path: spec.template.spec.containers[0].image","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/manifests/charts/base/tests/workloadmanager_test.yaml","time":{"start":1775879735127,"end":1775879735160}}}}
