{"type":"tool_use","timestamp":1775892127466,"sessionID":"ses_28494f3c6ffeBwBClNho7eOo6i","part":{"id":"prt_d7b6b5461001IyZXTxQb3vUf9D","messageID":"msg_d7b6b304c0019Hy7rvLnkmxqoq","sessionID":"ses_28494f3c6ffeBwBClNho7eOo6i","type":"tool","tool":"read","callID":"toolu_355f56e6a4c94b79807eefd5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go</path>\n<type>file</type>\n<content>\n1: // Copyright 2026 AgentCube Authors\n2: // E2E tests for AgentCube\n3: \n4: package e2e\n5: \n6: import (\n7: \t\"bytes\"\n8: \t\"context\"\n9: \t\"encoding/json\"\n10: \t\"fmt\"\n11: \t\"io\"\n12: \t\"net/http\"\n13: \t\"os\"\n14: \t\"testing\"\n15: \t\"time\"\n16: \n17: \tcorev1 \"k8s.io/api/core/v1\"\n18: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n19: \t\"k8s.io/client-go/kubernetes\"\n20: \t\"k8s.io/client-go/tools/clientcmd\"\n21: )\n22: \n23: var (\n24: \tworkloadManagerURL string\n25: \trouterURL          string\n26: \tapiToken           string\n27: \tclient             *http.Client\n28: \tk8sClient          *kubernetes.Clientset\n29: \tnamespace          string\n30: )\n31: \n32: func TestMain(m *testing.M) {\n33: \tworkloadManagerURL = os.Getenv(\"WORKLOAD_MANAGER_URL\")\n34: \trouterURL = os.Getenv(\"ROUTER_URL\")\n35: \tapiToken = os.Getenv(\"API_TOKEN\")\n36: \tnamespace = os.Getenv(\"AGENTCUBE_NAMESPACE\")\n37: \n38: \tif workloadManagerURL == \"\" {\n39: \t\tworkloadManagerURL = \"http://localhost:8080\"\n40: \t}\n41: \tif routerURL == \"\" {\n42: \t\trouterURL = \"http://localhost:8081\"\n43: \t}\n44: \tif namespace == \"\" {\n45: \t\tnamespace = \"agentcube\"\n46: \t}\n47: \tif apiToken == \"\" {\n48: \t\tfmt.Println(\"Warning: API_TOKEN not set\")\n49: \t}\n50: \n51: \tclient = &http.Client{\n52: \t\tTimeout: 30 * time.Second,\n53: \t}\n54: \n55: \tkubeconfig := os.Getenv(\"KUBECONFIG\")\n56: \tif kubeconfig == \"\" {\n57: \t\thome, _ := os.UserHomeDir()\n58: \t\tkubeconfig = fmt.Sprintf(\"%s/.kube/config\", home)\n59: \t}\n60: \n61: \tconfig, err := clientcmd.BuildConfigFromFlags(\"\", kubeconfig)\n62: \tif err == nil {\n63: \t\tk8sClient, _ = kubernetes.NewForConfig(config)\n64: \t}\n65: \n66: \tos.Exit(m.Run())\n67: }\n68: \n69: func TestHealthCheck(t *testing.T) {\n70: \tresp, err := client.Get(workloadManagerURL + \"/health\")\n71: \tif err != nil {\n72: \t\tt.Fatalf(\"Health check failed: %v\", err)\n73: \t}\n74: \tdefer resp.Body.Close()\n75: \n76: \tif resp.StatusCode != http.StatusOK {\n77: \t\tt.Fatalf(\"Health check returned status: %d\", resp.StatusCode)\n78: \t}\n79: \n80: \tbody, err := io.ReadAll(resp.Body)\n81: \tif err != nil {\n82: \t\tt.Fatalf(\"Failed to read response body: %v\", err)\n83: \t}\n84: \n85: \tvar health struct {\n86: \t\tStatus string `json:\"status\"`\n87: \t}\n88: \tif err := json.Unmarshal(body, &health); err != nil {\n89: \t\tt.Fatalf(\"Failed to parse health response: %v\", err)\n90: \t}\n91: \n92: \tif health.Status != \"ok\" && health.Status != \"healthy\" {\n93: \t\tt.Logf(\"Health status: %s\", health.Status)\n94: \t}\n95: }\n96: \n97: func TestRouterHealth(t *testing.T) {\n98: \tresp, err := client.Get(routerURL + \"/health/live\")\n99: \tif err != nil {\n100: \t\tt.Fatalf(\"Router health check failed: %v\", err)\n101: \t}\n102: \tdefer resp.Body.Close()\n103: \n104: \tif resp.StatusCode != http.StatusOK {\n105: \t\tt.Fatalf(\"Router health check returned status: %d\", resp.StatusCode)\n106: \t}\n107: }\n108: \n109: func TestRouterReady(t *testing.T) {\n110: \tresp, err := client.Get(routerURL + \"/health/ready\")\n111: \tif err != nil {\n112: \t\tt.Fatalf(\"Router ready check failed: %v\", err)\n113: \t}\n114: \tdefer resp.Body.Close()\n115: \n116: \tif resp.StatusCode != http.StatusOK {\n117: \t\tt.Fatalf(\"Router ready check returned status: %d\", resp.StatusCode)\n118: \t}\n119: \n120: \tbody, err := io.ReadAll(resp.Body)\n121: \tif err != nil {\n122: \t\tt.Fatalf(\"Failed to read response body: %v\", err)\n123: \t}\n124: \n125: \tvar ready struct {\n126: \t\tReady bool `json:\"ready\"`\n127: \t}\n128: \tif err := json.Unmarshal(body, &ready); err != nil {\n129: \t\tt.Fatalf(\"Failed to parse ready response: %v\", err)\n130: \t}\n131: \n132: \tif !ready.Ready {\n133: \t\tt.Fatal(\"Router is not ready\")\n134: \t}\n135: }\n136: \n137: func TestInvokeEchoAgent(t *testing.T) {\n138: \tmessage := map[string]string{\n139: \t\t\"message\": \"Hello, echo agent!\",\n140: \t}\n141: \tbody, _ := json.Marshal(message)\n142: \n143: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/echo-agent\", bytes.NewReader(body))\n144: \tif err != nil {\n145: \t\tt.Fatalf(\"Failed to create request: %v\", err)\n146: \t}\n147: \n148: \treq.Header.Set(\"Content-Type\", \"application/json\")\n149: \tif apiToken != \"\" {\n150: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n151: \t}\n152: \n153: \tresp, err := client.Do(req)\n154: \tif err != nil {\n155: \t\tt.Fatalf(\"Invoke request failed: %v\", err)\n156: \t}\n157: \tdefer resp.Body.Close()\n158: \n159: \tif resp.StatusCode != http.StatusOK {\n160: \t\tbody, _ := io.ReadAll(resp.Body)\n161: \t\tt.Fatalf(\"Invoke returned status: %d, body: %s\", resp.StatusCode, string(body))\n162: \t}\n163: \n164: \tvar result map[string]interface{}\n165: \tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n166: \t\tt.Fatalf(\"Failed to decode response: %v\", err)\n167: \t}\n168: \n169: \tt.Logf(\"Echo agent response: %+v\", result)\n170: \n171: \tif status, ok := result[\"status\"].(string); !ok || status != \"success\" {\n172: \t\tt.Errorf(\"Expected status 'success', got '%v'\", result[\"status\"])\n173: \t}\n174: }\n175: \n176: func TestCodeInterpreter(t *testing.T) {\n177: \tcode := map[string]string{\n178: \t\t\"code\": \"print('Hello from code interpreter')\",\n179: \t}\n180: \tbody, _ := json.Marshal(code)\n181: \n182: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/e2e-code-interpreter\", bytes.NewReader(body))\n183: \tif err != nil {\n184: \t\tt.Fatalf(\"Failed to create request: %v\", err)\n185: \t}\n186: \n187: \treq.Header.Set(\"Content-Type\", \"application/json\")\n188: \tif apiToken != \"\" {\n189: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n190: \t}\n191: \n192: \tresp, err := client.Do(req)\n193: \tif err != nil {\n194: \t\tt.Fatalf(\"Code interpreter request failed: %v\", err)\n195: \t}\n196: \tdefer resp.Body.Close()\n197: \n198: \tif resp.StatusCode != http.StatusOK {\n199: \t\tbody, _ := io.ReadAll(resp.Body)\n200: \t\tt.Fatalf(\"Code interpreter returned status: %d, body: %s\", resp.StatusCode, string(body))\n201: \t}\n202: \n203: \tvar result map[string]interface{}\n204: \tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n205: \t\tt.Fatalf(\"Failed to decode response: %v\", err)\n206: \t}\n207: \n208: \tt.Logf(\"Code interpreter response: %+v\", result)\n209: }\n210: \n211: func TestSessionLifecycle(t *testing.T) {\n212: \tif k8sClient == nil {\n213: \t\tt.Skip(\"Kubernetes client not available\")\n214: \t}\n215: \n216: \tctx := context.Background()\n217: \n218: \tpods, err := k8sClient.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n219: \t\tLabelSelector: \"app=workloadmanager\",\n220: \t})\n221: \tif err != nil {\n222: \t\tt.Fatalf(\"Failed to list pods: %v\", err)\n223: \t}\n224: \n225: \tif len(pods.Items) == 0 {\n226: \t\tt.Fatal(\"No workload manager pods found\")\n227: \t}\n228: \n229: \tfor _, pod := range pods.Items {\n230: \t\tif pod.Status.Phase == corev1.PodRunning {\n231: \t\t\tt.Logf(\"Found running workload manager pod: %s\", pod.Name)\n232: \t\t\treturn\n233: \t\t}\n234: \t}\n235: \n236: \tt.Fatal(\"No running workload manager pods found\")\n237: }\n238: \n239: func TestSessionCreationAndDeletion(t *testing.T) {\n240: \tsessionPayload := map[string]interface{}{\n241: \t\t\"interpreter\": \"e2e-code-interpreter\",\n242: \t\t\"namespace\":   namespace,\n243: \t\t\"ttl\":         \"60s\",\n244: \t}\n245: \tbody, _ := json.Marshal(sessionPayload)\n246: \n247: \treq, err := http.NewRequest(\"POST\", workloadManagerURL+\"/api/v1/sessions\", bytes.NewReader(body))\n248: \tif err != nil {\n249: \t\tt.Fatalf(\"Failed to create session request: %v\", err)\n250: \t}\n251: \n252: \treq.Header.Set(\"Content-Type\", \"application/json\")\n253: \tif apiToken != \"\" {\n254: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n255: \t}\n256: \n257: \tresp, err := client.Do(req)\n258: \tif err != nil {\n259: \t\tt.Skipf(\"Session creation not available: %v\", err)\n260: \t}\n261: \tdefer resp.Body.Close()\n262: \n263: \tif resp.StatusCode == http.StatusNotFound {\n264: \t\tt.Skip(\"Sessions API not available\")\n265: \t}\n266: \n267: \tif resp.StatusCode != http.StatusOK && resp.StatusCode != http.StatusCreated {\n268: \t\tbody, _ := io.ReadAll(resp.Body)\n269: \t\tt.Fatalf(\"Session creation returned status: %d, body: %s\", resp.StatusCode, string(body))\n270: \t}\n271: \n272: \tvar result map[string]interface{}\n273: \tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n274: \t\tt.Fatalf(\"Failed to decode session response: %v\", err)\n275: \t}\n276: \n277: \tsessionID, ok := result[\"sessionId\"].(string)\n278: \tif !ok {\n279: \t\tt.Fatal(\"Session ID not returned\")\n280: \t}\n281: \n282: \tt.Logf(\"Created session: %s\", sessionID)\n283: \n284: \tdeleteReq, err := http.NewRequest(\"DELETE\", workloadManagerURL+\"/api/v1/sessions/\"+sessionID, nil)\n285: \tif err != nil {\n286: \t\tt.Fatalf(\"Failed to create delete request: %v\", err)\n287: \t}\n288: \n289: \tif apiToken != \"\" {\n290: \t\tdeleteReq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n291: \t}\n292: \n293: \tdeleteResp, err := client.Do(deleteReq)\n294: \tif err != nil {\n295: \t\tt.Logf(\"Session deletion not available: %v\", err)\n296: \t\treturn\n297: \t}\n298: \tdefer deleteResp.Body.Close()\n299: \n300: \tt.Logf(\"Session deletion status: %d\", deleteResp.StatusCode)\n301: }\n302: \n303: func TestMetricsEndpoint(t *testing.T) {\n304: \tresp, err := client.Get(workloadManagerURL + \"/metrics\")\n305: \tif err != nil {\n306: \t\tt.Skipf(\"Metrics endpoint not available: %v\", err)\n307: \t}\n308: \tdefer resp.Body.Close()\n309: \n310: \tif resp.StatusCode != http.StatusOK {\n311: \t\tt.Skipf(\"Metrics returned status: %d\", resp.StatusCode)\n312: \t}\n313: \n314: \tbody, err := io.ReadAll(resp.Body)\n315: \tif err != nil {\n316: \t\tt.Fatalf(\"Failed to read metrics: %v\", err)\n317: \t}\n318: \n319: \tif len(body) == 0 {\n320: \t\tt.Fatal(\"Metrics body is empty\")\n321: \t}\n322: \n323: \tt.Logf(\"Metrics endpoint returned %d bytes\", len(body))\n324: }\n325: \n326: func TestRouterMetrics(t *testing.T) {\n327: \tresp, err := client.Get(routerURL + \"/metrics\")\n328: \tif err != nil {\n329: \t\tt.Skipf(\"Router metrics endpoint not available: %v\", err)\n330: \t}\n331: \tdefer resp.Body.Close()\n332: \n333: \tif resp.StatusCode != http.StatusOK {\n334: \t\tt.Skipf(\"Router metrics returned status: %d\", resp.StatusCode)\n335: \t}\n336: \n337: \tbody, err := io.ReadAll(resp.Body)\n338: \tif err != nil {\n339: \t\tt.Fatalf(\"Failed to read router metrics: %v\", err)\n340: \t}\n341: \n342: \tif len(body) == 0 {\n343: \t\tt.Fatal(\"Router metrics body is empty\")\n344: \t}\n345: \n346: \tt.Logf(\"Router metrics endpoint returned %d bytes\", len(body))\n347: }\n348: \n349: func TestConcurrentInvocations(t *testing.T) {\n350: \tconcurrency := 5\n351: \terrors := make(chan error, concurrency)\n352: \tsuccesses := make(chan bool, concurrency)\n353: \n354: \tfor i := 0; i < concurrency; i++ {\n355: \t\tgo func(id int) {\n356: \t\t\tmessage := map[string]string{\n357: \t\t\t\t\"message\": fmt.Sprintf(\"Concurrent test %d\", id),\n358: \t\t\t}\n359: \t\t\tbody, _ := json.Marshal(message)\n360: \n361: \t\t\treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/echo-agent\", bytes.NewReader(body))\n362: \t\t\tif err != nil {\n363: \t\t\t\terrors <- err\n364: \t\t\t\treturn\n365: \t\t\t}\n366: \n367: \t\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n368: \t\t\tif apiToken != \"\" {\n369: \t\t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n370: \t\t\t}\n371: \n372: \t\t\tresp, err := client.Do(req)\n373: \t\t\tif err != nil {\n374: \t\t\t\terrors <- err\n375: \t\t\t\treturn\n376: \t\t\t}\n377: \t\t\tdefer resp.Body.Close()\n378: \n379: \t\t\tif resp.StatusCode != http.StatusOK {\n380: \t\t\t\tbody, _ := io.ReadAll(resp.Body)\n381: \t\t\t\terrors <- fmt.Errorf(\"status %d: %s\", resp.StatusCode, string(body))\n382: \t\t\t\treturn\n383: \t\t\t}\n384: \n385: \t\t\tsuccesses <- true\n386: \t\t}(i)\n387: \t}\n388: \n389: \tsuccessCount := 0\n390: \terrorCount := 0\n391: \n392: \tfor i := 0; i < concurrency; i++ {\n393: \t\tselect {\n394: \t\tcase <-successes:\n395: \t\t\tsuccessCount++\n396: \t\tcase err := <-errors:\n397: \t\t\tt.Logf(\"Concurrent invocation error: %v\", err)\n398: \t\t\terrorCount++\n399: \t\tcase <-time.After(10 * time.Second):\n400: \t\t\tt.Fatal(\"Timeout waiting for concurrent invocations\")\n401: \t\t}\n402: \t}\n403: \n404: \tt.Logf(\"Concurrent test: %d successes, %d errors\", successCount, errorCount)\n405: \n406: \tif successCount < concurrency-1 {\n407: \t\tt.Errorf(\"Expected at least %d successes, got %d\", concurrency-1, successCount)\n408: \t}\n409: }\n410: \n411: func TestInvalidAgentInvocation(t *testing.T) {\n412: \tmessage := map[string]string{\n413: \t\t\"message\": \"Test invalid agent\",\n414: \t}\n415: \tbody, _ := json.Marshal(message)\n416: \n417: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/non-existent-agent\", bytes.NewReader(body))\n418: \tif err != nil {\n419: \t\tt.Fatalf(\"Failed to create request: %v\", err)\n420: \t}\n421: \n422: \treq.Header.Set(\"Content-Type\", \"application/json\")\n423: \tif apiToken != \"\" {\n424: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n425: \t}\n426: \n427: \tresp, err := client.Do(req)\n428: \tif err != nil {\n429: \t\tt.Fatalf(\"Request failed: %v\", err)\n430: \t}\n431: \tdefer resp.Body.Close()\n432: \n433: \tif resp.StatusCode != http.StatusNotFound && resp.StatusCode != http.StatusBadRequest {\n434: \t\tbody, _ := io.ReadAll(resp.Body)\n435: \t\tt.Fatalf(\"Expected 404 or 400, got status: %d, body: %s\", resp.StatusCode, string(body))\n436: \t}\n437: \n438: \tt.Logf(\"Invalid agent correctly rejected with status: %d\", resp.StatusCode)\n439: }\n440: \n441: func TestMalformedRequest(t *testing.T) {\n442: \tbody := []byte(\"invalid json\")\n443: \n444: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/echo-agent\", bytes.NewReader(body))\n445: \tif err != nil {\n446: \t\tt.Fatalf(\"Failed to create request: %v\", err)\n447: \t}\n448: \n449: \treq.Header.Set(\"Content-Type\", \"application/json\")\n450: \tif apiToken != \"\" {\n451: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n452: \t}\n453: \n454: \tresp, err := client.Do(req)\n455: \tif err != nil {\n456: \t\tt.Fatalf(\"Request failed: %v\", err)\n457: \t}\n458: \tdefer resp.Body.Close()\n459: \n460: \tif resp.StatusCode != http.StatusBadRequest {\n461: \t\tt.Logf(\"Malformed request status: %d (expected 400)\", resp.StatusCode)\n462: \t}\n463: \n464: \tt.Logf(\"Malformed request correctly rejected with status: %d\", resp.StatusCode)\n465: }\n466: \n467: func TestSessionTimeout(t *testing.T) {\n468: \tif k8sClient == nil {\n469: \t\tt.Skip(\"Kubernetes client not available\")\n470: \t}\n471: \n472: \tmessage := map[string]string{\n473: \t\t\"message\": \"Short TTL test\",\n474: \t}\n475: \tbody, _ := json.Marshal(message)\n476: \n477: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/echo-agent-short-ttl\", bytes.NewReader(body))\n478: \tif err != nil {\n479: \t\tt.Fatalf(\"Failed to create request: %v\", err)\n480: \t}\n481: \n482: \treq.Header.Set(\"Content-Type\", \"application/json\")\n483: \tif apiToken != \"\" {\n484: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n485: \t}\n486: \n487: \tresp, err := client.Do(req)\n488: \tif err != nil {\n489: \t\tt.Fatalf(\"Request failed: %v\", err)\n490: \t}\n491: \tdefer resp.Body.Close()\n492: \n493: \tif resp.StatusCode != http.StatusOK {\n494: \t\tbody, _ := io.ReadAll(resp.Body)\n495: \t\tt.Fatalf(\"Short TTL test returned status: %d, body: %s\", resp.StatusCode, string(body))\n496: \t}\n497: \n498: \tt.Log(\"Short TTL agent invoked successfully, waiting for expiration...\")\n499: \n500: \ttime.Sleep(35 * time.Second)\n501: \n502: \tctx := context.Background()\n503: \tpods, err := k8sClient.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n504: \t\tLabelSelector: \"app=echo-agent-short-ttl\",\n505: \t})\n506: \tif err != nil {\n507: \t\tt.Logf(\"Failed to list pods after TTL: %v\", err)\n508: \t\treturn\n509: \t}\n510: \n511: \tt.Logf(\"Found %d pods after TTL expiration\", len(pods.Items))\n512: }\n513: \n514: func TestWarmPoolCodeInterpreter(t *testing.T) {\n515: \tcode := map[string]string{\n516: \t\t\"code\": \"import time; start = time.time(); print(f'Warm start: {time.time() - start:.3f}s')\",\n517: \t}\n518: \tbody, _ := json.Marshal(code)\n519: \n520: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/e2e-code-interpreter-warmpool\", bytes.NewReader(body))\n521: \tif err != nil {\n522: \t\tt.Skipf(\"Warm pool interpreter not available: %v\", err)\n523: \t}\n524: \n525: \treq.Header.Set(\"Content-Type\", \"application/json\")\n526: \tif apiToken != \"\" {\n527: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n528: \t}\n529: \n530: \tstartTime := time.Now()\n531: \tresp, err := client.Do(req)\n532: \telapsed := time.Since(startTime)\n533: \n534: \tif err != nil {\n535: \t\tt.Skipf(\"Warm pool request failed: %v\", err)\n536: \t}\n537: \tdefer resp.Body.Close()\n538: \n539: \tif resp.StatusCode != http.StatusOK {\n540: \t\tbody, _ := io.ReadAll(resp.Body)\n541: \t\tt.Logf(\"Warm pool returned status: %d, body: %s\", resp.StatusCode, string(body))\n542: \t\tt.Skip(\"Warm pool interpreter not configured\")\n543: \t}\n544: \n545: \tvar result map[string]interface{}\n546: \tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n547: \t\tt.Fatalf(\"Failed to decode response: %v\", err)\n548: \t}\n549: \n550: \tt.Logf(\"Warm pool response: %+v (latency: %v)\", result, elapsed)\n551: \n552: \tif elapsed > 5*time.Second {\n553: \t\tt.Logf(\"Warning: Warm pool latency (%v) higher than expected\", elapsed)\n554: \t}\n555: }\n556: \n557: func TestNamespaceIsolation(t *testing.T) {\n558: \tif k8sClient == nil {\n559: \t\tt.Skip(\"Kubernetes client not available\")\n560: \t}\n561: \n562: \tctx := context.Background()\n563: \n564: \tnsList, err := k8sClient.CoreV1().Namespaces().List(ctx, metav1.ListOptions{})\n565: \tif err != nil {\n566: \t\tt.Fatalf(\"Failed to list namespaces: %v\", err)\n567: \t}\n568: \n569: \tfoundAgentCube := false\n570: \tfor _, ns := range nsList.Items {\n571: \t\tif ns.Name == namespace {\n572: \t\t\tfoundAgentCube = true\n573: \t\t\tt.Logf(\"Found AgentCube namespace: %s\", ns.Name)\n574: \t\t\tbreak\n575: \t\t}\n576: \t}\n577: \n578: \tif !foundAgentCube {\n579: \t\tt.Fatalf(\"AgentCube namespace %s not found\", namespace)\n580: \t}\n581: }\n582: \n583: func TestResourceQuotas(t *testing.T) {\n584: \tif k8sClient == nil {\n585: \t\tt.Skip(\"Kubernetes client not available\")\n586: \t}\n587: \n588: \tctx := context.Background()\n589: \n590: \tresourceQuotas, err := k8sClient.CoreV1().ResourceQuotas(namespace).List(ctx, metav1.ListOptions{})\n591: \tif err != nil {\n592: \t\tt.Logf(\"Failed to list resource quotas (may not be configured): %v\", err)\n593: \t\tt.Skip(\"Resource quotas not configured\")\n594: \t}\n595: \n596: \tif len(resourceQuotas.Items) > 0 {\n597: \t\tfor _, rq := range resourceQuotas.Items {\n598: \t\t\tt.Logf(\"Found resource quota: %s\", rq.Name)\n599: \t\t}\n600: \t} else {\n601: \t\tt.Skip(\"No resource quotas configured\")\n602: \t}\n603: }\n604: \n605: func TestConfigMapExists(t *testing.T) {\n606: \tif k8sClient == nil {\n607: \t\tt.Skip(\"Kubernetes client not available\")\n608: \t}\n609: \n610: \tctx := context.Background()\n611: \n612: \tconfigMaps, err := k8sClient.CoreV1().ConfigMaps(namespace).List(ctx, metav1.ListOptions{\n613: \t\tLabelSelector: \"app.kubernetes.io/name=agentcube\",\n614: \t})\n615: \tif err != nil {\n616: \t\tt.Fatalf(\"Failed to list ConfigMaps: %v\", err)\n617: \t}\n618: \n619: \tif len(configMaps.Items) == 0 {\n620: \t\tt.Skip(\"No AgentCube ConfigMaps found\")\n621: \t}\n622: \n623: \tfor _, cm := range configMaps.Items {\n624: \t\tt.Logf(\"Found ConfigMap: %s\", cm.Name)\n625: \t}\n626: }\n627: \n628: func TestServiceAccounts(t *testing.T) {\n629: \tif k8sClient == nil {\n630: \t\tt.Skip(\"Kubernetes client not available\")\n631: \t}\n632: \n633: \tctx := context.Background()\n634: \n635: \tsas, err := k8sClient.CoreV1().ServiceAccounts(namespace).List(ctx, metav1.ListOptions{})\n636: \tif err != nil {\n637: \t\tt.Fatalf(\"Failed to list ServiceAccounts: %v\", err)\n638: \t}\n639: \n640: \tfoundWorkloadManager := false\n641: \tfoundRouter := false\n642: \n643: \tfor _, sa := range sas.Items {\n644: \t\tt.Logf(\"Found ServiceAccount: %s\", sa.Name)\n645: \t\tif sa.Name == \"workloadmanager\" || sa.Name == \"agentcube-workloadmanager\" {\n646: \t\t\tfoundWorkloadManager = true\n647: \t\t}\n648: \t\tif sa.Name == \"agentcube-router\" {\n649: \t\t\tfoundRouter = true\n650: \t\t}\n651: \t}\n652: \n653: \tif !foundWorkloadManager {\n654: \t\tt.Log(\"WorkloadManager ServiceAccount not found (may use default)\")\n655: \t}\n656: \tif !foundRouter {\n657: \t\tt.Log(\"Router ServiceAccount not found (may use default)\")\n658: \t}\n659: }\n\n(End of file - total 659 lines)\n</content>","metadata":{"preview":"// Copyright 2026 AgentCube Authors\n// E2E tests for AgentCube\n\npackage e2e\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/tools/clientcmd\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go","time":{"start":1775892127434,"end":1775892127464}}}}
{"type":"tool_use","timestamp":1775892127467,"sessionID":"ses_28494f3c6ffeBwBClNho7eOo6i","part":{"id":"prt_d7b6b5a00001FP5vjnTh6b52sR","messageID":"msg_d7b6b304c0019Hy7rvLnkmxqoq","sessionID":"ses_28494f3c6ffeBwBClNho7eOo6i","type":"tool","tool":"read","callID":"toolu_2010241e3c95436c976222ca","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/helpers.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/helpers.go</path>\n<type>file</type>\n<content>\n1: // Copyright 2026 AgentCube Authors\n2: // E2E test helpers and utilities\n3: \n4: package e2e\n5: \n6: import (\n7: \t\"crypto/rand\"\n8: \t\"encoding/hex\"\n9: \t\"fmt\"\n10: \t\"io\"\n11: \t\"net/http\"\n12: \t\"time\"\n13: )\n14: \n15: // TestConfig holds E2E test configuration\n16: type TestConfig struct {\n17: \tWorkloadManagerURL string\n18: \tRouterURL          string\n19: \tAPIToken           string\n20: \tNamespace          string\n21: \tTimeout            time.Duration\n22: }\n23: \n24: // LoadTestConfig loads configuration from environment\n25: func LoadTestConfig() *TestConfig {\n26: \tconfig := &TestConfig{\n27: \t\tWorkloadManagerURL: getEnvOrDefault(\"WORKLOAD_MANAGER_URL\", \"http://localhost:8080\"),\n28: \t\tRouterURL:          getEnvOrDefault(\"ROUTER_URL\", \"http://localhost:8081\"),\n29: \t\tAPIToken:           getEnvOrDefault(\"API_TOKEN\", \"\"),\n30: \t\tNamespace:          getEnvOrDefault(\"AGENTCUBE_NAMESPACE\", \"agentcube\"),\n31: \t\tTimeout:            30 * time.Second,\n32: \t}\n33: \n34: \tif timeoutStr := getEnvOrDefault(\"E2E_TIMEOUT\", \"30s\"); timeoutStr != \"\" {\n35: \t\tif timeout, err := time.ParseDuration(timeoutStr); err == nil {\n36: \t\t\tconfig.Timeout = timeout\n37: \t\t}\n38: \t}\n39: \n40: \treturn config\n41: }\n42: \n43: func getEnvOrDefault(key, defaultValue string) string {\n44: \tif value := lookupEnv(key); value != \"\" {\n45: \t\treturn value\n46: \t}\n47: \treturn defaultValue\n48: }\n49: \n50: func lookupEnv(key string) string {\n51: \t// Simplified env lookup - in real code use os.Getenv\n52: \treturn \"\"\n53: }\n54: \n55: // NewTestClient creates a new HTTP client for E2E tests\n56: func NewTestClient(config *TestConfig) *http.Client {\n57: \treturn &http.Client{\n58: \t\tTimeout: config.Timeout,\n59: \t}\n60: }\n61: \n62: // GenerateRandomID generates a random identifier for test resources\n63: func GenerateRandomID(prefix string) string {\n64: \tbytes := make([]byte, 8)\n65: \tif _, err := rand.Read(bytes); err != nil {\n66: \t\treturn fmt.Sprintf(\"%s-%d\", prefix, time.Now().UnixNano())\n67: \t}\n68: \treturn fmt.Sprintf(\"%s-%s\", prefix, hex.EncodeToString(bytes))\n69: }\n70: \n71: // WaitForCondition waits for a condition to be true with timeout\n72: func WaitForCondition(name string, condition func() bool, timeout time.Duration, interval time.Duration) error {\n73: \tstart := time.Now()\n74: \tfor time.Since(start) < timeout {\n75: \t\tif condition() {\n76: \t\t\treturn nil\n77: \t\t}\n78: \t\ttime.Sleep(interval)\n79: \t}\n80: \treturn fmt.Errorf(\"timeout waiting for condition: %s\", name)\n81: }\n82: \n83: // RetryWithBackoff retries a function with exponential backoff\n84: func RetryWithBackoff(name string, fn func() error, maxRetries int, initialDelay time.Duration) error {\n85: \tvar lastErr error\n86: \tdelay := initialDelay\n87: \n88: \tfor i := 0; i < maxRetries; i++ {\n89: \t\tif err := fn(); err == nil {\n90: \t\t\treturn nil\n91: \t\t} else {\n92: \t\t\tlastErr = err\n93: \t\t}\n94: \t\ttime.Sleep(delay)\n95: \t\tdelay *= 2\n96: \t}\n97: \n98: \treturn fmt.Errorf(\"failed after %d retries: %w\", maxRetries, lastErr)\n99: }\n100: \n101: // CheckEndpointHealth checks if an endpoint is healthy\n102: func CheckEndpointHealth(client *http.Client, url string) error {\n103: \tresp, err := client.Get(url)\n104: \tif err != nil {\n105: \t\treturn err\n106: \t}\n107: \tdefer resp.Body.Close()\n108: \n109: \tif resp.StatusCode != http.StatusOK {\n110: \t\tbody, _ := io.ReadAll(resp.Body)\n111: \t\treturn fmt.Errorf(\"health check failed: status=%d, body=%s\", resp.StatusCode, string(body))\n112: \t}\n113: \n114: \treturn nil\n115: }\n116: \n117: // WaitForEndpoint waits for an endpoint to become available\n118: func WaitForEndpoint(client *http.Client, url string, timeout time.Duration) error {\n119: \treturn WaitForCondition(\n120: \t\tfmt.Sprintf(\"endpoint %s\", url),\n121: \t\tfunc() bool {\n122: \t\t\treturn CheckEndpointHealth(client, url) == nil\n123: \t\t},\n124: \t\ttimeout,\n125: \t\t2*time.Second,\n126: \t)\n127: }\n128: \n129: // CreateTestSession creates a test session\n130: func CreateTestSession(client *http.Client, baseURL string, interpreter string, namespace string, token string) (string, error) {\n131: \treturn \"\", nil\n132: }\n133: \n134: // DeleteTestSession deletes a test session\n135: func DeleteTestSession(client *http.Client, baseURL string, sessionID string, token string) error {\n136: \treturn nil\n137: }\n\n(End of file - total 137 lines)\n</content>","metadata":{"preview":"// Copyright 2026 AgentCube Authors\n// E2E test helpers and utilities\n\npackage e2e\n\nimport (\n\t\"crypto/rand\"\n\t\"encoding/hex\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"time\"\n)\n\n// TestConfig holds E2E test configuration\ntype TestConfig struct {\n\tWorkloadManagerURL string\n\tRouterURL          string\n\tAPIToken           string\n\tNamespace          string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/helpers.go","time":{"start":1775892127436,"end":1775892127466}}}}
