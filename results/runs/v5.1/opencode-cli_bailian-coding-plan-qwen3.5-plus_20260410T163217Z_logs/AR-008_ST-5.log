ncel := context.WithTimeout(ctx, DeleteTimeout)\n\tdefer cancel()\n\n\terr := gc.dynamicClient.Resource(gvr).\n\t\tNamespace(sandbox.SandboxNamespace).\n\t\tDelete(deleteCtx, sandbox.SandboxID, metav1.DeleteOptions{})\n\n\tif err != nil && !apierrors.IsNotFound(err) {\n\t\tauditEntry.ErrorMessage = err.Error()\n\t\tauditEntry.Success = false\n\t\tklog.Errorf(\"Failed to delete sandbox %s/%s: %v\", sandbox.SandboxNamespace, sandbox.SandboxID, err)\n\t} else {\n\t\tif err := gc.storeClient.DeleteSandboxBySessionID(ctx, sandbox.SessionID); err != nil {\n\t\t\tklog.Warningf(\"Failed to delete sandbox %s from store: %v\", sandbox.SessionID, err)\n\t\t}\n\t\tauditEntry.Success = true\n\t\tklog.Infof(\"Deleted sandbox %s/%s (reason: %s)\", sandbox.SandboxNamespace, sandbox.SandboxID, reason)\n\t}\n\n\tgc.recordAudit(auditEntry)\n}\n\nfunc (gc *GarbageCollector) recordAudit(entry *wmTypes.CleanupAuditEntry) {\n\tklog.Infof(\"Cleanup audit: sessionId=%s sandboxId=%s namespace=%s reason=%s success=%v deletedAt=%s\",\n\t\tentry.SessionID, entry.SandboxID, entry.Namespace, entry.Reason, entry.Success, entry.DeletedAt.Format(time.RFC3339))\n\tif entry.ErrorMessage != \"\" {\n\t\tklog.Infof(\"Cleanup audit error: %s\", entry.ErrorMessage)\n\t}\n}\n","additions":0,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/garbage_collector.go","time":{"start":1775847189885,"end":1775847190066}}}}
