\t\tsandboxGroup.POST(\"/agent-runtime\", sandboxHandler.HandleAgentRuntimeCreate)\n\t\tsandboxGroup.POST(\"/code-interpreter\", sandboxHandler.HandleCodeInterpreterCreate)\n\t}\n}\n","additions":0,"deletions":16},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/routes.go","time":{"start":1775847384362,"end":1775847384942}}}}
