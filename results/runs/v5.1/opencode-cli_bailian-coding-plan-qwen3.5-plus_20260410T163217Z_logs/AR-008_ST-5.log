d\"`\n\tNamespace    string              `json:\"namespace\"`\n\tName         string              `json:\"name\"`\n\tEntryPoints  []SandboxEntryPoint `json:\"entryPoints\"`\n\tLastActivity string              `json:\"lastActivity\"`\n\tCreatedAt    string              `json:\"createdAt\"`\n\tExpiresAt    string              `json:\"expiresAt\"`\n\tPodIP        string              `json:\"podIp,omitempty\"`\n}\n\ntype DeleteSessionRequest struct {\n\tSessionID string `uri:\"sessionId\" binding:\"required\"`\n}\n\ntype DeleteSessionResponse struct {\n\tSessionID string `json:\"sessionId\"`\n\tDeletedAt string `json:\"deletedAt\"`\n}\n\ntype ErrorResponse struct {\n\tError string `json:\"error\"`\n\tCode  string `json:\"code,omitempty\"`\n}\n","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/common/types/types.go"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/routes.go\">\nERROR [67:27] undefined: runtimev1alpha1.AgentRuntimeInformer\nERROR [75:27] undefined: runtimev1alpha1.CodeInterpreterInformer\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/reconciler/agentruntime_reconciler.go\">\nERROR [166:12] undefined: json\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store.go\">\nERROR [65:12] undefined: unmarshalSandboxInfo\nERROR [74:15] undefined: marshalSandboxInfo\nERROR [122:13] undefined: unmarshalSandboxInfo\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_2