are())\n\n\tengine.GET(\"/healthz\", health.HealthzHandler)\n\tengine.GET(\"/readyz\", health.ReadyzHandler)\n\n\tarGroup := engine.Group(\"/api/v1/agentruntimes\")\n\t{\n\t\tarHandler := handler.NewAgentRuntimeHandler(deps.Client)\n\t\tarGroup.POST(\"\", arHandler.CreateAgentRuntime)\n\t\tarGroup.GET(\"\", arHandler.ListAgentRuntimes)\n\t\tarGroup.GET(\"/:name\", arHandler.GetAgentRuntime)\n\t\tarGroup.PUT(\"/:name\", arHandler.UpdateAgentRuntime)\n\t\tarGroup.DELETE(\"/:name\", arHandler.DeleteAgentRuntime)\n\t}\n\n\tciGroup := engine.Group(\"/api/v1/codeinterpreters\")\n\t{\n\t\tciHandler := handler.NewCodeInterpreterHandler(deps.Client)\n\t\tciGroup.POST(\"\", ciHandler.CreateCodeInterpreter)\n\t\tciGroup.GET(\"\", ciHandler.ListCodeInterpreters)\n\t\tciGroup.GET(\"/:name\", ciHandler.GetCodeInterpreter)\n\t\tciGroup.PUT(\"/:name\", ciHandler.UpdateCodeInterpreter)\n\t\tciGroup.DELETE(\"/:name\", ciHandler.DeleteCodeInterpreter)\n\t}\n\n\tsandboxGroup := engine.Group(\"/v1\")\n\t{\n\t\tsandboxHandler := handler.NewSandboxHandler(\n\t\t\tdeps.Client,\n\t\t\tdeps.K8sClient,\n\t\t\tdeps.PodLister,\n\t\t\tdeps.ARLister,\n\t\t\tdeps.CILister,\n\t\t\t\"default\",\n\t\t)\n\t\tsandboxGroup.POST(\"/agent-runtime\", sandboxHandler.HandleAgentRuntimeCreate)\n\t\tsandboxGroup.POST(\"/code-interpreter\", sandboxHandler.HandleCodeInterpreterCreate)\n\t}\n}\n\ntype informerListerAdapter struct {\n\tinformer runtimev1alpha1.AgentRuntimeInformer\n}\n\nfunc (a *informerListerAdapter) AgentRuntimes(namespace string) processor.AgentRuntimeNamespaceLister {\n\treturn a.informer.Lister().AgentRuntimes(namespace)\n}\n\ntype codeInterpreterListerAdapter struct {\n\tinformer runtimev1alpha1.CodeInterpreterInformer\n}\n\nfunc (a *codeInterpreterListerAdapter) CodeInterpreters(namespace string) processor.CodeInterpreterNamespaceLister {\n\treturn a.informer.Lister().CodeInterpreters(namespace)\n}\n","after":"package workloadmanager\n\nimport (\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/c