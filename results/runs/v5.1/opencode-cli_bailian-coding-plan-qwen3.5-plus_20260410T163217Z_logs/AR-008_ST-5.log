.NewTicker(gc.interval)\n\tdefer ticker.Stop()\n\n\tklog.Info(\"GarbageCollector started\")\n\n\tfor {\n\t\tselect {\n\t\tcase <-gc.ctx.Done():\n\t\t\tklog.Info(\"GarbageCollector stopped\")\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tgc.tick()\n\t\t}\n\t}\n}\n\nfunc (gc *GarbageCollector) tick() {\n\ttickCtx, cancel := context.WithTimeout(gc.ctx, GCSingleTickTimeout)\n\tdefer cancel()\n\n\tnow := time.Now()\n\tidleThreshold := now.Add(-DefaultSandboxIdleTimeout)\n\texpiredThreshold := now\n\n\tidleSandboxes, err := gc.storeClient.ListInactiveSandboxes(tickCtx, idleThreshold, 16)\n\tif err != nil {\n\t\tklog.Errorf(\"Failed to list inactive sandboxes: %v\", err)\n\t} else {\n\t\tfor _, sandbox := range idleSandboxes {\n\t\t\tgc.deleteSandbox(tickCtx, sandbox, wmTypes.CleanupReasonIdleTimeout)\n\t\t}\n\t}\n\n\texpiredSandboxes, err := gc.storeClient.ListExpiredSandboxes(tickCtx, expiredThreshold, 16)\n\tif err != nil {\n\t\tklog.Errorf(\"Failed to list expired sandboxes: %v\", err)\n\t} else {\n\t\tfor _, sandbox := range expiredSandboxes {\n\t\t\tgc.deleteSandbox(tickCtx, sandbox, wmTypes.CleanupReasonExpired)\n\t\t}\n\t}\n}\n\nfunc (gc *GarbageCollector) deleteSandbox(\n\tctx context.Context,\n\tsandbox *types.SandboxInfo,\n\treason wmTypes.SandboxCleanupReason,\n) {\n\tauditEntry := &wmTypes.CleanupAuditEntry{\n\t\tSessionID: sandbox.SessionID,\n\t\tSandboxID: sandbox.SandboxID,\n\t\tNamespace: sandbox.SandboxNamespace,\n\t\tReason:    reason,\n\t\tDeletedAt: time.Now(),\n\t}\n\n\tgvr := SandboxGVR\n\tif sandbox.Kind == types.SandboxClaimKind {\n\t\tgvr = SandboxClaimGVR\n\t}\n\n\tdeleteCtx, cancel := context.WithTimeout(ctx, DeleteTimeout)\n\tdefer cancel()\n\n\terr := gc.dynamicClient.Resource(gvr).\n\t\tNamespace(sandbox.SandboxNamespace).\n\t\tDelete(deleteCtx, sandbox.SandboxID, metav1.DeleteOptions{})\n\n\tif err != nil && !apierrors.IsNotFound(err) {\n\t\tauditEntry.ErrorMessage = err.Error()\n\t\tauditEntry.Success = false\n\t\tklog.Errorf(\"Failed to delete sandbox %s/%s: %v\", sandbox.SandboxNamespace, sandbox.SandboxID, err)\n\t} else {\n\t\tif err := gc.storeClient.DeleteSandboxBySessionID(ctx, sandbox.SessionID); err != nil {\n\t\t\tklog.Warningf(\"Failed to delete sandbox %s from store: %v\", sandbox.SessionID, err)\n\t\t}\n\t\tauditEntry.Success = true\n\t\tklog.Infof(\"Deleted sandbox %s/%s (reason: %s)\", sandbox.SandboxNamespace, sandbox.SandboxID, reason)\n\t}\n\n\tgc.recordAudit(auditEntry)\n}\n\nfunc (gc *GarbageCollector) recordAudit(entry *wmTypes.CleanupAuditEntry) {\n\tklog.Infof(\"Cleanup audit: sessionId=%s sandboxId=%s namespace=%s reason=%s success=%v deletedAt=%s\",\n\t\tentry.SessionID, entry.SandboxID, entry.Namespace, entry.Reason, entry.Success, entry.DeletedAt.Format(time.RFC3339))\n\tif entry.ErrorMessage != \"\" {\n\t\tklog.Infof(\"Cleanup audit error: %s\", entry.ErrorMessage)\n\t}\n}\n","after":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/klog/v2\"\n\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\nvar (\n\tSandboxGVR = schema.GroupVersionResource{\n\t\tGroup:    \"agents.x-k8s.io\",\n\t\tVersion:  \"v1alpha1\",\n\t\tResource: \"sandboxes\",\n\t}\n\n\tSandboxClaimGVR = schema.GroupVersionResource{\n\t\tGroup:    \"extensions.agents.x-k8s.io\",\n\t\tVersion:  \"v1alpha1\",\n\t\tResource: \"sandboxclaims\",\n\t}\n)\n\ntype GarbageCollector struct {\n\tdynamicClient dynamic.Interface\n\tstoreClient   store.Store\n\tinterval      time.Duration\n\tctx           context.Context\n\tcancel        context.CancelFunc\n}\n\nfunc NewGarbageCollector(\n\tdynamicClient dynamic.Interface,\n\tstoreClient store.Store,\n\tinterval time.Duration,\n) *GarbageCollector {\n\tctx, cancel := context.WithCancel(context.Bac