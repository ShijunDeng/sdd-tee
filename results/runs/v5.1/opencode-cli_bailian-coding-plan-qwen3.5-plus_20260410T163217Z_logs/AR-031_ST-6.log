  verbs:\n114:               - get\n115:               - list\n116:               - watch\n117:         documentIndex: 1\n118:       - contains:\n119:           path: rules\n120:           content:\n121:             apiGroups:\n122:               - runtime.agentcube.volcano.sh\n123:             resources:\n124:               - agentruntimes/status\n125:             verbs:\n126:               - update\n127:               - patch\n128:         documentIndex: 1\n129: \n130:   - it: should have RBAC rules for secrets\n131:     asserts:\n132:       - contains:\n133:           path: rules\n134:           content:\n135:             apiGroups:\n136:               - \"\"\n137:             resources:\n138:               - secrets\n139:             verbs:\n140:               - get\n141:               - list\n142:               - watch\n143:               - create\n144:               - update\n145:               - patch\n146:               - delete\n147:         documentIndex: 1\n148: \n149:   - it: should have RBAC rules for tokenreviews\n150:     asserts:\n151:       - contains:\n152:           path: rules\n153:           content:\n154:             apiGroups:\n155:               - authentication.k8s.io\n156:             resources:\n157:               - tokenreviews\n158:             verbs:\n159:               - create\n160:         documentIndex: 1\n161: \n162:   - it: should bind to correct namespace\n163:     release:\n164:       namespace: custom-namespace\n165:     asserts:\n166:       - equal:\n167:           path: metadata.namespace\n168:           value: custom-namespace\n169:         documentIndex: 0\n170:       - equal:\n171:           path: subjects[0].namespace\n172:           value: custom-namespace\n173:         documentIndex: 2\n\n(End of file - total 173 lines)\n</content>","metadata":{"preview":"suite: Workload Manager RBAC Tests\ntemplates:\n  - rbac/workloadmanager.yaml\ntests:\n  - it: should render ServiceAccount\n    asserts:\n      - isKind:\n          o