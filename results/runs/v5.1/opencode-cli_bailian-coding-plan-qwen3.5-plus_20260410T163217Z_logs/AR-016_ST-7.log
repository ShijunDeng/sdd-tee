 \t\t\tMessage:    \"failed to resolve absolute path\",\n50: \t\t\tUnderlying: err,\n51: \t\t}\n52: \t}\n53: \n54: \tevaluatedPath, err := filepath.EvalSymlinks(absPath)\n55: \tif err != nil {\n56: \t\tif os.IsNotExist(err) {\n57: \t\t\treturn absPath, nil\n58: \t\t}\n59: \t\treturn \"\", &FileError{\n60: \t\t\tType:       FileErrorPathTraversal,\n61: \t\t\tMessage:    \"failed to evaluate symlinks\",\n62: \t\t\tUnderlying: err,\n63: \t\t}\n64: \t}\n65: \n66: \tabsWorkDir, err := filepath.Abs(workDir)\n67: \tif err != nil {\n68: \t\treturn \"\", &FileError{\n69: \t\t\tType:       FileErrorPathTraversal,\n70: \t\t\tMessage:    \"failed to resolve workspace absolute path\",\n71: \t\t\tUnderlying: err,\n72: \t\t}\n73: \t}\n74: \n75: \tif !strings.HasPrefix(evaluatedPath, absWorkDir) {\n76: \t\treturn \"\", &FileError{\n77: \t\t\tType:    FileErrorPathTraversal,\n78: \t\t\tMessage: fmt.Sprintf(\"symlink target %q is outside workspace %q\", evaluatedPath, absWorkDir),\n79: \t\t}\n80: \t}\n81: \n82: \treturn evaluatedPath, nil\n83: }\n84: \n85: func GetDepth(path string) int {\n86: \tcleanPath := filepath.Clean(path)\n87: \tif cleanPath == \".\" || cleanPath == \"/\" {\n88: \t\treturn 0\n89: \t}\n90: \treturn strings.Count(cleanPath, string(filepath.Separator))\n91: }\n92: \n93: func IsWithinWorkspace(path, workDir string) bool {\n94: \tabsPath, err := filepath.Abs(path)\n95: \tif err != nil {\n96: \t\treturn false\n97: \t}\n98: \n99: \tabsWorkDir, err := filepath.Abs(workDir)\n100: \tif err != nil {\n101: \t\treturn false\n102: \t}\n103: \n104: \treturn strings.HasPrefix(absPath, absWorkDir)\n105: }\n106: \n107: func ValidateDepth(path, workDir string, maxDepth int) error {\n108: \trelPath, err := filepath.Rel(workDir, path)\n109: \tif err != nil {\n110: \t\treturn &FileError{\n111: \t\t\tType:       FileErrorDepth,\n112: \t\t\tMessage:    \"failed to calculate relative path\",\n113: \t\t\tUnderlying: err,\n114: \t\t}\n115: \t}\n116: \n117: \tdepth := GetDepth(relPath)\n