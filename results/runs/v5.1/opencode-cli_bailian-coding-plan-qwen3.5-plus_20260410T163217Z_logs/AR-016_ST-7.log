}\n49: \n50: \tif env := os.Getenv(\"PICOD_MAX_MEMORY\"); env != \"\" {\n51: \t\tsize, err := parseSize(env)\n52: \t\tif err != nil {\n53: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_MAX_MEMORY: %w\", err)\n54: \t\t}\n55: \t\tconfig.MaxMemory = size\n56: \t}\n57: \n58: \tif env := os.Getenv(\"PICOD_MAX_CPU\"); env != \"\" {\n59: \t\tcpu, err := strconv.ParseFloat(env, 64)\n60: \t\tif err != nil {\n61: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_MAX_CPU: %w\", err)\n62: \t\t}\n63: \t\tconfig.MaxCPU = cpu\n64: \t}\n65: \n66: \tif env := os.Getenv(\"PICOD_MAX_OUTPUT_SIZE\"); env != \"\" {\n67: \t\tsize, err := parseSize(env)\n68: \t\tif err != nil {\n69: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_MAX_OUTPUT_SIZE: %w\", err)\n70: \t\t}\n71: \t\tconfig.MaxOutputSize = size\n72: \t}\n73: \n74: \tif env := os.Getenv(\"PICOD_MAX_PROCESSES\"); env != \"\" {\n75: \t\tcount, err := strconv.Atoi(env)\n76: \t\tif err != nil {\n77: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_MAX_PROCESSES: %w\", err)\n78: \t\t}\n79: \t\tconfig.MaxProcesses = count\n80: \t}\n81: \n82: \tif env := os.Getenv(\"PICOD_QUOTA_MAX_FILE_SIZE\"); env != \"\" {\n83: \t\tsize, err := parseSize(env)\n84: \t\tif err != nil {\n85: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_QUOTA_MAX_FILE_SIZE: %w\", err)\n86: \t\t}\n87: \t\tconfig.QuotaMaxFileSize = size\n88: \t}\n89: \n90: \tif env := os.Getenv(\"PICOD_QUOTA_MAX_TOTAL_SIZE\"); env != \"\" {\n91: \t\tsize, err := parseSize(env)\n92: \t\tif err != nil {\n93: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_QUOTA_MAX_TOTAL_SIZE: %w\", err)\n94: \t\t}\n95: \t\tconfig.QuotaMaxTotalSize = size\n96: \t}\n97: \n98: \tif env := os.Getenv(\"PICOD_QUOTA_MAX_FILES\"); env != \"\" {\n99: \t\tcount, err := strconv.ParseInt(env, 10, 64)\n100: \t\tif err != nil {\n101: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_QUOTA_MAX_FILES: %w\", err)\n102: \t\t}\n103: \t\tconfig.QuotaMaxFiles = count\n104: \t}\n105: \n106: \tif env := os.Getenv(\"PICOD_QUOTA_MAX_DEPTH\"); env != \"\" {\n107: \t\tdepth, err := strconv.Atoi(env)\n108: \t\tif err != nil {\n109: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_QUOTA_MAX_DEPTH: %w\", err)\n110: \t\t}\n111: \t\tconfig.QuotaMaxDepth = depth\n112: \t}\n113: \n114: \treturn config, nil\n115: }\n116: \n117: func parseSize(s string) (int64, error) {\n118: \ts = strings.TrimSpace(s)\n119: \tif len(s) == 0 {\n120: \t\treturn 0, fmt.Errorf(\"empty size string\")\n121: \t}\n122: \n123: \tmultipliers := map[string]int64{\n124: \t\t\"K\":  1024,\n125: \t\t\"KB\": 1024,\n126: \t\t\"M\":  1024 * 1024,\n127: \t\t\"MB\": 1024 * 1024,\n128: \t\t\"G\":  1024 * 1024 * 1024,\n129: \t\t\"GB\": 1024 * 1024 * 1024,\n130: \t}\n131: \n132: \tfor suffix, mult := range multipliers {\n133: \t\tif strings.HasSuffix(s, suffix) {\n134: \t\t\tnumStr := strings.TrimSuffix(s, suffix)\n135: \t\t\tnum, err := strconv.ParseInt(numStr, 10, 64)\n136: \t\t\tif err != nil {\n137: \t\t\t\treturn 0, err\n138: \t\t\t}\n139: \t\t\treturn num * mult, nil\n140: \t\t}\n141: \t}\n142: \n143: \tnum, err := strconv.ParseInt(s, 10, 64)\n144: \tif err != nil {\n145: \t\treturn 0, err\n146: \t}\n147: \treturn num, nil\n148: }\n\n(End of file - total 148 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n)\n\ntype Config struct {\n\tWorkDir           string\n\tDefaultTimeout    time.Duration\n\tMaxMemory         int64\n\tMaxCPU            float64\n\tMaxOutputSize     int64\n\tMaxProcesses      int\n\tQuotaMaxFileSize  int64\n\tQuotaMaxTotalSize int64\n\tQuotaMaxFiles     int64","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/config.go","time":{"start":1775861266664,"end":1775861266766}}}}
