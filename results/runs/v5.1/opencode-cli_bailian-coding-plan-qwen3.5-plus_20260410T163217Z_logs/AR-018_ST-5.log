\n39: \topts := zap.Options{\n40: \t\tDevelopment: true,\n41: \t}\n42: \topts.BindFlags(flag.CommandLine)\n43: \tflag.Parse()\n44: \n45: \tctrl.SetLogger(zap.New(zap.UseFlagOptions(&opts)))\n46: \n47: \tmgr, err := ctrl.NewManager(ctrl.GetConfigOrDie(), ctrl.Options{\n48: \t\tScheme:                 scheme,\n49: \t\tMetricsBindAddress:     metricsAddr,\n50: \t\tHealthProbeBindAddress: probeAddr,\n51: \t\tLeaderElection:         enableLeaderElection,\n52: \t\tLeaderElectionID:       \"agentd-leader\",\n53: \t})\n54: \tif err != nil {\n55: \t\tsetupLog.Error(err, \"unable to start manager\")\n56: \t\tos.Exit(1)\n57: \t}\n58: \n59: \tif err = (&agentd.Reconciler{\n60: \t\tClient: mgr.GetClient(),\n61: \t\tScheme: mgr.GetScheme(),\n62: \t}).SetupWithManager(mgr); err != nil {\n63: \t\tsetupLog.Error(err, \"unable to create controller\", \"controller\", \"Agentd\")\n64: \t\tos.Exit(1)\n65: \t}\n66: \n67: \tsetupLog.Info(\"starting manager\")\n68: \tif err := mgr.Start(signals.SetupSignalHandler()); err != nil {\n69: \t\tsetupLog.Error(err, \"problem running manager\")\n70: \t\tos.Exit(1)\n71: \t}\n72: }\n\n(End of file - total 72 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"flag\"\n\t\"os\"\n\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tutilruntime \"k8s.io/apimachinery/pkg/util/runtime\"\n\tclientgoscheme \"k8s.io/client-go/kubernetes/scheme\"\n\t_ \"k8s.io/client-go/plugin/pkg/client/auth\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/log/zap\"\n\t\"sigs.k8s.io/controller-runtime/pkg/manager/signals\"\n\n\tagentd \"github.com/volcano-sh/agentcube/pkg/agentd\"\n)\n\nvar (\n\tscheme   = runtime.NewScheme()\n\tsetupLog = ctrl.Log.WithName(\"setup\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/agentd/main.go","time":{"start":1775863258981,"end":1775863258989}}}}
