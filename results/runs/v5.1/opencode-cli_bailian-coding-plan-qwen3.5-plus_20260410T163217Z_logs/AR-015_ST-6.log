{\n49: \t\tt.Fatalf(\"Run() unexpected error: %v\", err)\n50: \t}\n51: \n52: \tif result.ExitCode != 0 {\n53: \t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n54: \t}\n55: \n56: \tif len(result.Stdout) != 0 {\n57: \t\tt.Error(\"expected empty Stdout in result when custom stdout provided\")\n58: \t}\n59: \n60: \tif stdoutBuf.String() != \"hello\\n\" {\n61: \t\tt.Errorf(\"expected stdout buffer to be %q, got %q\", \"hello\\n\", stdoutBuf.String())\n62: \t}\n63: }\n64: \n65: func TestExecutor_Run_NonZeroExit(t *testing.T) {\n66: \texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n67: \n68: \tcmd := &Command{\n69: \t\tPath: \"false\",\n70: \t\tArgs: []string{\"false\"},\n71: \t}\n72: \n73: \tresult, err := executor.Run(context.Background(), cmd)\n74: \tif err == nil {\n75: \t\tt.Fatal(\"Run() expected error for non-zero exit\")\n76: \t}\n77: \n78: \tif result.ExitCode != 1 {\n79: \t\tt.Errorf(\"expected ExitCode=1, got %d\", result.ExitCode)\n80: \t}\n81: }\n82: \n83: func TestExecutor_Run_InvalidCommand(t *testing.T) {\n84: \texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n85: \n86: \tcmd := &Command{\n87: \t\tPath: \"/nonexistent/command\",\n88: \t\tArgs: []string{\"nonexistent\"},\n89: \t}\n90: \n91: \t_, err := executor.Run(context.Background(), cmd)\n92: \tif err == nil {\n93: \t\tt.Fatal(\"Run() expected error for nonexistent command\")\n94: \t}\n95: }\n96: \n97: func TestExecutor_Start_Wait(t *testing.T) {\n98: \texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n99: \n100: \tcmd := &Command{\n101: \t\tPath: \"echo\",\n102: \t\tArgs: []string{\"echo\", \"hello\"},\n103: \t}\n104: \n105: \tprocess, err := executor.Start(context.Background(), cmd)\n106: \tif err != nil {\n107: \t\tt.Fatalf(\"Start() unexpected error: %v\", err)\n108: \t}\n109: \n110: \tif process.PID <= 0 {\n111: \t\tt.Errorf(\"expected positive PID, got %d\", process.PID)\n112: \t}\n113: \n114: \tresult, err := pr