curity, got %v\", execErr.Type)\n185: \t}\n186: }\n187: \n188: func TestExecutor_WithContextCancellation(t *testing.T) {\n189: \texecutor := NewExecutor(DefaultResourceLimits(), DefaultSecurityOpts())\n190: \n191: \tcmd := &Command{\n192: \t\tPath: \"sleep\",\n193: \t\tArgs: []string{\"sleep\", \"10\"},\n194: \t}\n195: \n196: \tctx, cancel := context.WithCancel(context.Background())\n197: \tcancel()\n198: \n199: \t_, err := executor.Run(ctx, cmd)\n200: \tif err == nil {\n201: \t\tt.Fatal(\"Run() expected error for cancelled context\")\n202: \t}\n203: }\n204: \n205: func TestExecutor_WithTimeout(t *testing.T) {\n206: \tlimits := &ResourceLimits{\n207: \t\tTimeout:       100 * time.Millisecond,\n208: \t\tMaxCPU:        1.0,\n209: \t\tMaxMemory:     128 * 1024 * 1024,\n210: \t\tMaxOutputSize: 10 * 1024 * 1024,\n211: \t\tMaxProcesses:  10,\n212: \t}\n213: \texecutor := NewExecutor(limits, DefaultSecurityOpts())\n214: \n215: \tcmd := &Command{\n216: \t\tPath: \"sleep\",\n217: \t\tArgs: []string{\"sleep\", \"1\"},\n218: \t}\n219: \n220: \tctx := context.Background()\n221: \tresult, err := executor.Run(ctx, cmd)\n222: \tif err == nil {\n223: \t\tt.Fatal(\"Run() expected error for timeout\")\n224: \t}\n225: \n226: \tif !result.Timeout {\n227: \t\tt.Error(\"expected Timeout=true\")\n228: \t}\n229: \n230: \texecErr, ok := err.(*ExecutionError)\n231: \tif !ok {\n232: \t\tt.Fatalf(\"expected ExecutionError, got %T\", err)\n233: \t}\n234: \tif execErr.Type != ExecutionErrorTimeout {\n235: \t\tt.Errorf(\"expected ExecutionErrorTimeout, got %v\", execErr.Type)\n236: \t}\n237: }\n238: \n239: func TestCommandResult_Fields(t *testing.T) {\n240: \tresult := &CommandResult{\n241: \t\tExitCode:  0,\n242: \t\tStdout:    []byte(\"output\"),\n243: \t\tStderr:    []byte(\"error\"),\n244: \t\tDuration:  time.Second,\n245: \t\tOOMKilled: false,\n246: \t\tTimeout:   false,\n247: \t}\n248: \n249: \tif result.ExitCode != 0 {\n250: \t\tt.Errorf(\"expected ExitCode=0, got %d\", result.ExitCode)\n2