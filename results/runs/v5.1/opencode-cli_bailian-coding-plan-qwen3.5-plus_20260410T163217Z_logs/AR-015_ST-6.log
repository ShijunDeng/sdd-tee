ProcAttr.Setpgid = true\n53: \n54: \tif l.MaxMemory > 0 {\n55: \t\tcmd.SysProcAttr.Credential = &syscall.Credential{}\n56: \t}\n57: \n58: \treturn nil\n59: }\n60: \n61: func (l *ResourceLimits) applyToProcess() error {\n62: \tif l.MaxMemory > 0 {\n63: \t\tif err := syscall.Setrlimit(syscall.RLIMIT_AS, &syscall.Rlimit{\n64: \t\t\tCur: uint64(l.MaxMemory),\n65: \t\t\tMax: uint64(l.MaxMemory),\n66: \t\t}); err != nil {\n67: \t\t\treturn fmt.Errorf(\"failed to set memory limit: %w\", err)\n68: \t\t}\n69: \t}\n70: \n71: \tif l.MaxProcesses > 0 {\n72: \t\tif err := syscall.Setrlimit(syscall.RLIMIT_NOFILE, &syscall.Rlimit{\n73: \t\t\tCur: uint64(l.MaxProcesses),\n74: \t\t\tMax: uint64(l.MaxProcesses),\n75: \t\t}); err != nil {\n76: \t\t\treturn fmt.Errorf(\"failed to set file descriptor limit: %w\", err)\n77: \t\t}\n78: \t}\n79: \n80: \treturn nil\n81: }\n\n(End of file - total 81 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"os/exec\"\n\t\"syscall\"\n\t\"time\"\n)\n\ntype ResourceLimits struct {\n\tTimeout       time.Duration\n\tMaxCPU        float64\n\tMaxMemory     int64\n\tMaxOutputSize int64\n\tMaxProcesses  int\n}\n\nfunc DefaultResourceLimits() *ResourceLimits {\n\treturn &ResourceLimits{\n\t\tTimeout:       30 * time.Second,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/limits.go","time":{"start":1775859750061,"end":1775859750078}}}}
