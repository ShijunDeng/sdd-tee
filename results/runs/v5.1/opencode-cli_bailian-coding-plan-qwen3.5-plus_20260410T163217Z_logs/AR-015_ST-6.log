xec,\n54: \t\t\tMessage: \"process not started\",\n55: \t\t}\n56: \t}\n57: \n58: \tif sig, ok := signal.(syscall.Signal); ok {\n59: \t\treturn p.Signal(sig)\n60: \t}\n61: \n62: \tif err := p.cmd.Process.Signal(signal); err != nil {\n63: \t\treturn err\n64: \t}\n65: \treturn nil\n66: }\n67: \n68: func (p *Process) Signal(sig syscall.Signal) error {\n69: \tif p.cmd.Process == nil {\n70: \t\treturn &ExecutionError{\n71: \t\t\tType:    ExecutionErrorExec,\n72: \t\t\tMessage: \"process not started\",\n73: \t\t}\n74: \t}\n75: \n76: \tif err := syscall.Kill(-p.cmd.Process.Pid, sig); err != nil {\n77: \t\treturn err\n78: \t}\n79: \treturn nil\n80: }\n81: \n82: func (p *Process) KillTree() error {\n83: \tif p.cmd.Process == nil {\n84: \t\treturn &ExecutionError{\n85: \t\t\tType:    ExecutionErrorExec,\n86: \t\t\tMessage: \"process not started\",\n87: \t\t}\n88: \t}\n89: \n90: \tpgid, err := syscall.Getpgid(p.cmd.Process.Pid)\n91: \tif err != nil {\n92: \t\treturn p.cmd.Process.Kill()\n93: \t}\n94: \n95: \tif err := syscall.Kill(-pgid, syscall.SIGKILL); err != nil {\n96: \t\treturn p.cmd.Process.Kill()\n97: \t}\n98: \n99: \treturn nil\n100: }\n\n(End of file - total 100 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"os\"\n\t\"os/exec\"\n\t\"syscall\"\n\t\"time\"\n)\n\ntype Process struct {\n\tPID       int\n\tcmd       *exec.Cmd\n\tstartTime time.Time\n\tlimits    *ResourceLimits\n}\n\nfunc (p *Process) Wait() (*CommandResult, error) {\n\terr := p.cmd.Wait()\n\tduration := time.Since(p.startTime)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/process.go","time":{"start":1775859750056,"end":1775859750076}}}}
