!= \"\" {\n51: \t\tcpu, err := strconv.ParseFloat(env, 64)\n52: \t\tif err != nil {\n53: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_MAX_CPU: %w\", err)\n54: \t\t}\n55: \t\tconfig.MaxCPU = cpu\n56: \t}\n57: \n58: \tif env := os.Getenv(\"PICOD_MAX_OUTPUT_SIZE\"); env != \"\" {\n59: \t\tsize, err := parseSize(env)\n60: \t\tif err != nil {\n61: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_MAX_OUTPUT_SIZE: %w\", err)\n62: \t\t}\n63: \t\tconfig.MaxOutputSize = size\n64: \t}\n65: \n66: \tif env := os.Getenv(\"PICOD_MAX_PROCESSES\"); env != \"\" {\n67: \t\tcount, err := strconv.Atoi(env)\n68: \t\tif err != nil {\n69: \t\t\treturn nil, fmt.Errorf(\"invalid PICOD_MAX_PROCESSES: %w\", err)\n70: \t\t}\n71: \t\tconfig.MaxProcesses = count\n72: \t}\n73: \n74: \treturn config, nil\n75: }\n76: \n77: func parseSize(s string) (int64, error) {\n78: \ts = strings.TrimSpace(s)\n79: \tif len(s) == 0 {\n80: \t\treturn 0, fmt.Errorf(\"empty size string\")\n81: \t}\n82: \n83: \tmultipliers := map[string]int64{\n84: \t\t\"K\":  1024,\n85: \t\t\"KB\": 1024,\n86: \t\t\"M\":  1024 * 1024,\n87: \t\t\"MB\": 1024 * 1024,\n88: \t\t\"G\":  1024 * 1024 * 1024,\n89: \t\t\"GB\": 1024 * 1024 * 1024,\n90: \t}\n91: \n92: \tfor suffix, mult := range multipliers {\n93: \t\tif strings.HasSuffix(s, suffix) {\n94: \t\t\tnumStr := strings.TrimSuffix(s, suffix)\n95: \t\t\tnum, err := strconv.ParseInt(numStr, 10, 64)\n96: \t\t\tif err != nil {\n97: \t\t\t\treturn 0, err\n98: \t\t\t}\n99: \t\t\treturn num * mult, nil\n100: \t\t}\n101: \t}\n102: \n103: \tnum, err := strconv.ParseInt(s, 10, 64)\n104: \tif err != nil {\n105: \t\treturn 0, err\n106: \t}\n107: \treturn num, nil\n108: }\n\n(End of file - total 108 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n)\n\ntype Config struct {\n\tWorkDir        string\n\tDefaultTimeout time.Duration\n\tMaxMemory      int64\n\tMaxCPU         float64\n\tMaxOutputSize  int64\n\tMaxProcesses   i