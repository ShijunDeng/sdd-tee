gger(logger)\n61: \t}\n62: }\n63: \n64: func (p *PicoD) Run(ctx context.Context, cmd *Command) (*CommandResult, error) {\n65: \tklog.V(4).InfoS(\"executing command\", \"path\", cmd.Path, \"args\", cmd.Args)\n66: \n67: \tresult, err := p.executor.Run(ctx, cmd)\n68: \n69: \tif err != nil {\n70: \t\tklog.ErrorS(err, \"command execution failed\", \"path\", cmd.Path)\n71: \t} else {\n72: \t\tklog.V(4).InfoS(\"command completed\", \"path\", cmd.Path, \"exitCode\", result.ExitCode, \"duration\", result.Duration)\n73: \t}\n74: \n75: \treturn result, err\n76: }\n77: \n78: func (p *PicoD) Start(ctx context.Context, cmd *Command) (*Process, error) {\n79: \tklog.V(4).InfoS(\"starting command\", \"path\", cmd.Path, \"args\", cmd.Args)\n80: \n81: \tprocess, err := p.executor.Start(ctx, cmd)\n82: \tif err != nil {\n83: \t\tklog.ErrorS(err, \"failed to start command\", \"path\", cmd.Path)\n84: \t}\n85: \n86: \treturn process, err\n87: }\n88: \n89: func (p *PicoD) RunWithStreaming(ctx context.Context, cmd *Command, handler OutputHandler) (*CommandResult, error) {\n90: \tklog.V(4).InfoS(\"executing command with streaming\", \"path\", cmd.Path, \"args\", cmd.Args)\n91: \n92: \tresult, err := p.executor.RunWithStreaming(ctx, cmd, handler)\n93: \n94: \tif err != nil {\n95: \t\tklog.ErrorS(err, \"streaming command execution failed\", \"path\", cmd.Path)\n96: \t}\n97: \n98: \treturn result, err\n99: }\n100: \n101: func (p *PicoD) ensureWorkDir() error {\n102: \tif _, err := os.Stat(p.workDir); os.IsNotExist(err) {\n103: \t\tif err := os.MkdirAll(p.workDir, 0755); err != nil {\n104: \t\t\treturn fmt.Errorf(\"failed to create work directory: %w\", err)\n105: \t\t}\n106: \t}\n107: \treturn nil\n108: }\n109: \n110: func (p *PicoD) GetWorkDir() string {\n111: \treturn p.workDir\n112: }\n113: \n114: func (p *PicoD) GetSandboxID() string {\n115: \treturn p.sandboxID\n116: }\n\n(End of file - total 116 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"fmt\"\