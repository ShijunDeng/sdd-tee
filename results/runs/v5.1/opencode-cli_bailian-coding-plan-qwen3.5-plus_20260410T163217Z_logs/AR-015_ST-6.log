e\",\n48: \t\t\tUnderlying: err,\n49: \t\t}\n50: \t}\n51: \n52: \tif cmd.Stdin != nil {\n53: \t\texecCmd.Stdin = cmd.Stdin\n54: \t}\n55: \n56: \tstartTime := time.Now()\n57: \tif err := execCmd.Start(); err != nil {\n58: \t\treturn nil, &ExecutionError{\n59: \t\t\tType:       ExecutionErrorExec,\n60: \t\t\tMessage:    \"failed to start command\",\n61: \t\t\tUnderlying: err,\n62: \t\t}\n63: \t}\n64: \n65: \tdone := make(chan struct{})\n66: \tvar result *CommandResult\n67: \tvar execErr error\n68: \n69: \tgo func() {\n70: \t\tdefer close(done)\n71: \n72: \t\tvar stdoutBuf, stderrBuf limitedBuffer\n73: \t\tteeStdout := &teeWriter{writer: &stdoutBuf, handler: handler.OnStdout}\n74: \t\tteeStderr := &teeWriter{writer: &stderrBuf, handler: handler.OnStderr}\n75: \n76: \t\tgo func() {\n77: \t\t\tbuf := make([]byte, 4096)\n78: \t\t\tfor {\n79: \t\t\t\tselect {\n80: \t\t\t\tcase <-ctx.Done():\n81: \t\t\t\t\treturn\n82: \t\t\t\tdefault:\n83: \t\t\t\t}\n84: \t\t\t\tn, err := stdoutPipe.Read(buf)\n85: \t\t\t\tif n > 0 {\n86: \t\t\t\t\tteeStdout.Write(buf[:n])\n87: \t\t\t\t}\n88: \t\t\t\tif err == io.EOF {\n89: \t\t\t\t\treturn\n90: \t\t\t\t}\n91: \t\t\t\tif err != nil {\n92: \t\t\t\t\treturn\n93: \t\t\t\t}\n94: \t\t\t}\n95: \t\t}()\n96: \n97: \t\tgo func() {\n98: \t\t\tbuf := make([]byte, 4096)\n99: \t\t\tfor {\n100: \t\t\t\tselect {\n101: \t\t\t\tcase <-ctx.Done():\n102: \t\t\t\t\treturn\n103: \t\t\t\tdefault:\n104: \t\t\t\t}\n105: \t\t\t\tn, err := stderrPipe.Read(buf)\n106: \t\t\t\tif n > 0 {\n107: \t\t\t\t\tteeStderr.Write(buf[:n])\n108: \t\t\t\t}\n109: \t\t\t\tif err == io.EOF {\n110: \t\t\t\t\treturn\n111: \t\t\t\t}\n112: \t\t\t\tif err != nil {\n113: \t\t\t\t\treturn\n114: \t\t\t\t}\n115: \t\t\t}\n116: \t\t}()\n117: \n118: \t\twaitErr := execCmd.Wait()\n119: \t\tduration := time.Since(startTime)\n120: \n121: \t\tresult = &CommandResult{\n122: \t\t\tDuration: duration,\n123: \t\t\tStdout:   stdoutBuf.Bytes(),\n124: \t\t\tStderr:   stderrBuf.Bytes(),\n125: \t\t}\n126: \n127: \t\tif exitErr, ok := waitErr.(*exec.ExitError); ok {\n128: \t\t\tresult.ExitCode = exitErr.ExitCode()\n129: \t\t\tif status, ok := exitErr.Sys().(syscall.WaitStatus); ok {\n130: \t\t\t\tif status.Signal() == syscall.SIGKILL || status.Signal() == syscall.SIGSEGV {\n131: \t\t\t\t\tresult.OOMKilled = true\n132: \t\t\t\t}\n133: \t\t\t}\n134: \t\t\texecErr = waitErr\n135: \t\t} else if waitErr == nil {\n136: \t\t\tresult.ExitCode = 0\n137: \t\t} else if ctx.Err() == context.DeadlineExceeded {\n138: \t\t\tresult.Timeout = true\n139: \t\t\texecErr = &ExecutionError{\n140: \t\t\t\tType:    ExecutionErrorTimeout,\n141: \t\t\t\tMessage: \"command timed out\",\n142: \t\t\t}\n143: \t\t} else if ctx.Err() == context.Canceled {\n144: \t\t\texecErr = &ExecutionError{\n145: \t\t\t\tType:    ExecutionErrorCancelled,\n146: \t\t\t\tMessage: \"command was cancelled\",\n147: \t\t\t}\n148: \t\t}\n149: \t}()\n150: \n151: \t<-done\n152: \thandler.OnComplete(result)\n153: \treturn result, execErr\n154: }\n155: \n156: type teeWriter struct {\n157: \twriter  io.Writer\n158: \thandler func([]byte)\n159: }\n160: \n161: func (t *teeWriter) Write(p []byte) (n int, err error) {\n162: \tdata := make([]byte, len(p))\n163: \tcopy(data, p)\n164: \tt.handler(data)\n165: \treturn t.writer.Write(p)\n166: }\n\n(End of file - total 166 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"io\"\n\t\"os/exec\"\n\t\"syscall\"\n\t\"time\"\n)\n\ntype OutputHandler interface {\n\tOnStdout(data []byte)\n\tOnStderr(data []byte)\n\tOnComplete(result *CommandResult)\n}\n\nfunc (e *Executor) RunWithStreaming(ctx context.Context, cmd *Command, handler OutputHandler) (*CommandResult, error) {\n\tif err := ValidateCommand(cmd, e.securityOpts); err != nil {\n\t\treturn nil, err\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/output.go","time":{"start":1775859750064,"end":1775859750080}}}}
