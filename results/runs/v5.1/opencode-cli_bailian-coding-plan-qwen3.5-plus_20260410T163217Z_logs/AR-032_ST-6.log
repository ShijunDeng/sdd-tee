ER router\n53: \n54: # Expose port\n55: EXPOSE 8080\n56: \n57: # Health check\n58: HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \\\n59:     CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1\n60: \n61: # OCI image labels\n62: LABEL org.opencontainers.image.title=\"router\"\n63: LABEL org.opencontainers.image.description=\"AgentCube Router component\"\n64: LABEL org.opencontainers.image.vendor=\"AgentCube\"\n65: LABEL org.opencontainers.image.version=\"${VERSION}\"\n66: LABEL org.opencontainers.image.revision=\"${COMMIT_SHA}\"\n67: \n68: # Entrypoint\n69: ENTRYPOINT [\"/app/router\"]\n70: CMD [\"--port=8080\", \"--debug\"]\n\n(End of file - total 70 lines)\n</content>","metadata":{"preview":"# deployment/docker/Dockerfile.router\n# Multi-stage build for Router\n\n# Build arguments for version injection\nARG GO_VERSION=1.21\nARG ALPINE_VERSION=3.19\nARG VERSION=dev\nARG COMMIT_SHA=unknown\n\n# Stage 1: Builder\nFROM golang:${GO_VERSION}-alpine AS builder\n\nWORKDIR /build\n\n# Install git for go mod\nRUN apk add --no-cache git\n\n# Cache Go modules layer\nCOPY go.mod go.sum ./\nRUN go mod download","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/deployment/docker/Dockerfile.router","time":{"start":1775882021993,"end":1775882022011}}}}
