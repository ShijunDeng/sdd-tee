n\n49:     echo -e \"${RED}✗ Image size ${size_mb}MB exceeds maximum ${MAX_SIZE_MB}MB${NC}\"\n50:     exit 1\n51: fi\n52: \n53: echo -e \"${GREEN}✓${NC} Image size is within limits (< ${MAX_SIZE_MB}MB)\"\n54: \n55: # Count layers\n56: echo \"Checking layer count...\"\n57: layer_count=$(docker history --quiet \"$IMAGE\" | wc -l)\n58: \n59: echo \"  Layer count: ${layer_count}\"\n60: \n61: if [ \"$layer_count\" -gt \"$MAX_LAYERS\" ]; then\n62:     echo -e \"${RED}✗ Layer count ${layer_count} exceeds maximum ${MAX_LAYERS}${NC}\"\n63:     exit 1\n64: fi\n65: \n66: echo -e \"${GREEN}✓${NC} Layer count is within limits (≤ ${MAX_LAYERS})\"\n67: \n68: # Check user configuration (run temporary container to check UID)\n69: echo \"Checking user configuration...\"\n70: container_name=\"validate-$(date +%s)\"\n71: \n72: docker run -d --name \"$container_name\" \"$IMAGE\" > /dev/null 2>&1 || true\n73: sleep 2\n74: \n75: user_uid=$(docker exec \"$container_name\" id -u 2>/dev/null || echo \"0\")\n76: docker stop \"$container_name\" > /dev/null 2>&1 || true\n77: docker rm \"$container_name\" > /dev/null 2>&1 || true\n78: \n79: echo \"  Runtime UID: ${user_uid}\"\n80: \n81: if [ \"$user_uid\" = \"0\" ]; then\n82:     echo -e \"${RED}✗ Container runs as root (UID 0)${NC}\"\n83:     exit 1\n84: fi\n85: \n86: if [ \"$user_uid\" != \"$EXPECTED_UID\" ]; then\n87:     echo -e \"${YELLOW}⚠ Warning: Running as UID $user_uid (expected $EXPECTED_UID)${NC}\"\n88: else\n89:     echo -e \"${GREEN}✓${NC} Running as non-root user (UID: $user_uid)\"\n90: fi\n91: \n92: # Check port exposure\n93: echo \"Checking port exposure...\"\n94: exposed_ports=$(docker inspect \"$IMAGE\" --format='{{range $p, $conf := .Config.ExposedPorts}}{{$p}} {{end}}' 2>/dev/null || echo \"\")\n95: \n96: echo \"  Exposed ports: $exposed_ports\"\n97: \n98: if ! echo \"$exposed_ports\" | grep -q \"$EXPECTED_PORT\"; then\n99:     echo -e \"${RED}✗ Port $EXPECTED_PORT is not exposed${NC}\"\n100:     exit 1\n101: fi\n102: \n103: echo -e \"${GREEN}✓${NC} Port $EXPECTED_PORT is exposed\"\n104: \n105: # Check health check configuration\n106: echo \"Checking health check configuration...\"\n107: healthcheck_test=$(docker inspect \"$IMAGE\" --format='{{if .Config.Healthcheck}}{{.Config.Healthcheck.Test}}{{else}}NONE{{end}}' 2>/dev/null || echo \"NONE\")\n108: \n109: if [ \"$healthcheck_test\" = \"NONE\" ]; then\n110:     echo -e \"${RED}✗ No health check configured${NC}\"\n111:     exit 1\n112: fi\n113: \n114: echo \"  Health check: $healthcheck_test\"\n115: echo -e \"${GREEN}✓${NC} Health check is configured\"\n116: \n117: # Check OCI labels\n118: echo \"Checking OCI image labels...\"\n119: \n120: vendor=$(docker inspect \"$IMAGE\" --format='{{index .Config.Labels \"org.opencontainers.image.vendor\"}}' 2>/dev/null || echo \"\")\n121: title=$(docker inspect \"$IMAGE\" --format='{{index .Config.Labels \"org.opencontainers.image.title\"}}' 2>/dev/null || echo \"\")\n122: description=$(docker inspect \"$IMAGE\" --format='{{index .Config.Labels \"org.opencontainers.image.description\"}}' 2>/dev/null || echo \"\")\n123: \n124: if [ -n \"$vendor\" ]; then\n125:     echo -e \"${GREEN}✓${NC} Vendor: $vendor\"\n126: else\n127:     echo -e \"${YELLOW}⚠ Warning: Missing vendor label${NC}\"\n128: fi\n129: \n130: if [ -n \"$title\" ]; then\n131:     echo -e \"${GREEN}✓${NC} Title: $title\"\n132: else\n133:     echo -e \"${YELLOW}⚠ Warning: Missing title label${NC}\"\n134: fi\n135: \n136: if [ -n \"$description\" ]; then\n137:     echo -e \"${GREEN}✓${NC} Description: $description\"\n138: else\n139:     echo -e \"${YELLOW}⚠ Warning: Missing description label${NC}\"\n140: fi\n141: \n142: # Check entrypoint\n143: echo \"Checking entrypoint...\"\n144: entrypoint=$(docker inspect \"$IMAGE\" --format='{{join .Config.Entrypoint \" \"}}' 2>/dev/null || echo \"\")\n145: \n146: if [ -n \"$entrypoint\" ]; then\n147:     echo -e \"${GREEN}✓${NC} Entrypoint: $entrypoint\"\n148: else\n149:     echo -e \"${YELLOW}⚠ Warning: No entrypoint configured${NC}\"\n150: fi\n151: \n152: echo \"\"\n153: echo \"==========================================\"\n154: echo -e \"${GREEN}Image validation passed!${NC}\"\n155: echo \"==========================================\"\n156: \n157: exit 0\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"#!/bin/bash\n# deployment/docker/test/validate.sh\n# Image validation script for AgentCube Docker images\n# Validates image size, layer count, user configuration, and security settings\n\nset -e\n\n# Colors for output\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nNC='\\033[0m' # No Color\n\n# Configuration\nMAX_SIZE_MB=50\nMAX_LAYERS=5\nEXPECTED_PORT=8080\nEXPECTED_UID=1000\n\nif [ $# -lt 1 ]; then","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/deployment/docker/test/validate.sh","time":{"start":1775882038643,"end":1775882038654}}}}
