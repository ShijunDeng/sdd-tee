piredSandboxes(t *testing.T) {\n    // Given\n    mockStore := &mockStore.Store{}\n    expiredSandboxes := []*types.SandboxInfo{\n        {\n            SessionID:    \"expired-session-1\",\n            SandboxID:    \"expired-sandbox-1\",\n            SandboxNamespace: \"default\",\n            Kind:         \"Sandbox\",\n        },\n    }\n    mockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, int64(16)).Return(expiredSandboxes, nil)\n    mockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\").Return(nil)\n\n    fakeDynamicClient := fakedynamic.NewSimpleDynamicClient(scheme)\n    sandboxObj := buildUnstructuredSandbox(\"expired-sandbox-1\", \"default\")\n    fakeDynamicClient.Resource(processor.SandboxGVR).Namespace(\"default\").Create(\n        context.Background(), sandboxObj, metav1.CreateOptions{})\n\n    gc := newGarbageCollector(&K8sClient{dynamicClient: fakeDynamicClient}, mockStore, GCInterval)\n\n    // When\n    gc.tick()\n\n    // Then\n    mockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, int64(16))\n}\n\nfunc TestGarbageCollector_Tick_KubernetesNotFound(t *testing.T) {\n    // Given: sandbox in store but not in K8s\n    mockStore := &mockStore.Store{}\n    sandboxInfo := &types.SandboxInfo{\n        SessionID:    \"missing-session\",\n        SandboxID:    \"missing-sandbox\",\n        SandboxNamespace: \"default\",\n        Kind:         \"Sandbox\",\n    }\n    mockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, int64(16)).Return([]*types.SandboxInfo{sandboxInfo}, nil)\n    mockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\").Return(nil)\n\n    fakeDynamicClient := fakedynamic.NewSimpleDynamicClient(scheme)\n    // Sandbox NOT pre-populated\n\n    gc := newGarbageCollector(&K8sClient{dynamicClient: fakeDynamicClient}, mockStore, GCInterval)\n\n    // When\n    gc.tick()\n\n    // Then: Should still delete from store (K8s NotFound is OK)\n    mockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\")\n}\n```\n\n### 测试基础设施\n\n```go\n// pkg/workloadmanager/garbage_collector_test.go\n\n// buildUnstructuredSandbox creates an unstructured Sandbox object for testing.\nfunc buildUnstructuredSandbox(name, namespace string) *unstructured.Unstructured {\n    return &unstructured.Unstructured{\n        Object: map[string]interface{}{\n            \"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n            \"kind\":       \"Sandbox\",\n            \"metadata\": map[string]interface{}{\n                \"name\":      name,\n                \"namespace\": namespace,\n                \"labels\": map[string]interface{}{\n                    SessionIDLabelKey: \"test-session\",\n                },\n            },\n        },\n    }\n}\n\n// buildUnstructuredSandboxClaim creates an unstructured SandboxClaim object for testing.\nfunc buildUnstructuredSandboxClaim(name, namespace string) *unstructured.Unstructured {\n    return &unstructured.Unstructured{\n        Object: map[string]interface{}{\n            \"apiVersion\": \"extensions.agents.x-k8s.io/v1alpha1\",\n            \"kind\":       \"SandboxClaim\",\n            \"metadata\": map[string]interface{}{\n                \"name\":      name,\n                \"namespace\": namespace,\n            },\n        },\n    }\n}\n```\n\n### 表驱动测试\n\n```go\nfunc TestDeleteSandboxRequest_Validation(t *testing.T) {\n    tests := []struct {\n        name      string\n        sessionID string\n        wantCode  int\n        wantErr   string\n    }{\n        {\"valid\", \"valid-session-id\", http.StatusOK, \"\"},\n        {\"empty\", \"\", http.StatusBadRequest, \"sessionId is required\"},\n        {\"whitespace\", \"   \", http.StatusBadRequest, \"sessionId is required\"},\n    }\n    for _, tt := range tests {\n        t.Run(tt.name, func(t *testing.T) {\n            // ... test execution\n        })\n    }\n}\n```\n\n### 集成测试\n\n```go\n// pkg/workloadmanager/integration_test.go\n\nfunc TestE2E_DeleteSandbox(t *testing.T) {\n    if testing.Short() {\n        t.Skip(\"Skipping integration test in short mode\")\n    }\n\n    // 1. Create sandbox via POST /v1/agent-runtime\n    createResp := createTestAgentRuntimeSandbox(t)\n\n    // 2. Verify sandbox accessible\n    verifySandboxAccessible(t, createResp.SessionID)\n\n    // 3. Delete sandbox via DELETE /v1/agent-runtime/sessions/:sessionId\n    deleteResp := deleteTestSandbox(t, createResp.SessionID)\n    assert.Equal(t, http.StatusOK, deleteResp.StatusCode)\n\n    // 4. Verify sandbox deleted (GET should 404)\n    _, err := getSandbox(t, createResp.SessionID)\n    assert.Error(t, err)\n}\n```\n\n### 测试覆盖率目标\n\n- 测试代码/业务代码比例 > 0.4\n- 每个源文件对应一个 `*_test.go`\n- Handler 层：成功路径、NotFound、SandboxClaim 路径\n- GarbageCollector：idle 清理、expired 清理、K8s NotFound 处理\n- 使用 `go test -race -v -coverprofile=coverage.out -coverpkg=./pkg/... ./pkg/...` 验证\n\n## 文件结构\n\n```\npkg/workloadmanager/\n  handler/\n    sandbox.go               — HandleAgentRuntimeCreate, HandleCodeInterpreterCreate, HandleDeleteSandbox\n    sandbox_test.go          — Tests for sandbox handlers\n  garbage_collector.go       — garbageCollector struct, gcLoop, tick, deleteSandbox\n  garbage_collector_test.go  — GC unit tests\n  defaults.go                — 常量：DefaultSandboxTTL, DefaultSandboxIdleTimeout, GCInterval 等\n  types/sandbox_types.go     — DeleteSandboxResponse, SandboxCleanupReason, CleanupAuditEntry\n```\n\n## 关键决策\n\n### 为什么 Store NotFound 返回 404 而非 200\n\n如果 Store 中找不到 session，说明 sandbox 可能已经被删除或从未存在过。返回 404 告知客户端资源不存在，而非掩盖事实。这与 Kubernetes API 的行为一致。\n\n### 为什么 K8s NotFound 视为成功\n\n如果 sandbox 在 Kubernetes 中已被删除（可能被 GC、手动操作或其他控制器删除），但 Store 中仍有记录，删除操作应清理 Store 记录并视为成功。这确保了最终一致性。\n\n### 为什么 GC 批次大小为 16\n\n批次大小 16 是平衡内存使用和清理速度的折中：\n- 太大会占用过多内存和 API 调用配额\n- 太小会导致多次 tick 才能清理完大量 sandbox\n- 16 是 sandbox-orchestration/design.md 中 spec 规定的值\n\n### 为什么 GC 间隔为 15 秒\n\n15 秒间隔确保：\n- 空闲 sandbox 最多 15m15s 被清理（DefaultSandboxIdleTimeout + GCInterval）\n- 过期 sandbox 最多 15s 被清理\n- 不过度频繁调用 Kubernetes API\n\n### 删除审计日志\n\n每次 GC 清理都记录 `CleanupAuditEntry`，包含：\n- SessionID, SandboxID, Namespace\n- 清理原因（manual/idle_timeout/expired）\n- 删除时间和成功/失败状态\n\n这便于后续审计和问题排查。\n\n## 配置选项\n\n### 环境变量\n\n| 变量 | 默认值 | 描述 |\n|------|--------|------|\n| `WORKLOAD_MANAGER_GC_INTERVAL` | `15s` | GarbageCollector 检查间隔 |\n| `WORKLOAD_MANAGER_SANDBOX_TTL` | `8h` | Sandbox 最大存活时间 |\n| `WORKLOAD_MANAGER_IDLE_TIMEOUT` | `15m` | Sandbox 空闲超时时间 |\n| `WORKLOAD_MANAGER_DELETE_TIMEOUT` | `30s` | 删除操作超时时间 |\n\n### 常量覆盖\n\n```go\n// 可通过编译时变量覆盖\nvar (\n    DefaultSandboxTTL = 8 * time.Hour\n    DefaultSandboxIdleTimeout = 15 * time.Minute\n    GCInterval = 15 * time.Second\n    GCSingleTickTimeout = 2 * time.Minute\n    DeleteTimeout = 30 * time.Second\n)\n```\n\n## 与 Store 的集成\n\n### Store 接口要求\n\n```go\n// pkg/store/store.go\n\ntype Store interface {\n    // ... other methods\n\n    // GetSandboxBySessionID retrieves sandbox info by session ID.\n    GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n\n    // DeleteSandboxBySessionID deletes sandbox record by session ID.\n    DeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n\n    // ListInactiveSandboxes lists sandboxes idle longer than threshold.\n    ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n\n    // ListExpiredSandboxes lists sandboxes past their expiresAt.\n    ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n}\n```\n\n### Redis 实现\n\n```go\n// pkg/store/redis.go\n\nfunc (r *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n    key := r.sessionKey(sessionID)\n    data, err := r.client.Get(ctx, key).Bytes()\n    if err == redis.Nil {\n        return nil, ErrNotFound\n    }\n    if err != nil {\n        return nil, err\n    }\n    var info types.SandboxInfo\n    if err := json.Unmarshal(data, &info); err != nil {\n        return nil, err\n    }\n    return &info, nil\n}\n\nfunc (r *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n    key := r.sessionKey(sessionID)\n    return r.client.Del(ctx, key).Err()\n}\n\nfunc (r *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n    // Scan all session keys\n    // For each, check LastActivityAnnotation < before\n    // Return up to limit entries\n}\n\nfunc (r *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n    // Scan all session keys\n    // For each, check ExpiresAt < before\n    // Return up to limit entries\n}\n```\n\n## 与 SandboxReconciler 的集成\n\n### Watcher 清理\n\n当 sandbox 被删除时，SandboxReconciler 应清理对应的 watcher channel：\n\n```go\n// pkg/controller/sandbox_reconciler.go\n\nfunc (r *SandboxReconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error) {\n    sandbox := &sandboxv1alpha1.Sandbox{}\n    err := r.Get(ctx, req.NamespacedName, sandbox)\n    if err != nil {\n        if k8s_errors.IsNotFound(err) {\n            // Sandbox deleted, cleanup watcher\n            r.cleanupWatcher(req.NamespacedName)\n            return ctrl.Result{}, nil\n        }\n        return ctrl.Result{}, err\n    }\n\n    // ... rest of reconcile\n}\n\nfunc (r *SandboxReconciler) cleanupWatcher(name types.NamespacedName) {\n    r.mu.Lock()\n    defer r.mu.Unlock()\n    if ch, ok := r.watchers[name]; ok {\n        close(ch)\n        delete(r.watchers, name)\n    }\n}\n```\n\n## 与 AR-005 的边界\n\n| 功能 | AR-005 (Sandbox 创建处理器) | AR-006 (Sandbox 删除与生命周期管理) |\n|------|--------------------------|----------------------------------|\n| Sandbox 创建 | ✅ | ❌ |\n| Sandbox 删除（手动） | ❌ | ✅ |\n| Sandbox 删除（自动 GC） | ❌ | ✅ |\n| Store 占位记录 | ✅ | ✅（清理） |\n| 等待 running | ✅ | ❌ |\n| Pod IP 解析 | ✅ | ❌ |\n| 空闲超时检测 | ❌ | ✅ |\n| 过期检测 | ❌ | ✅ |\n| 审计日志 | ❌ | ✅ |\n\nAR-005 负责 sandbox 的创建和初始化，AR-006 负责 sandbox 的删除和全生命周期管理。\n"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/routes.go\">\nERROR [67:27] undefined: runtimev1alpha1.AgentRuntimeInformer\nERROR [75:27] undefined: runtimev1alpha1.CodeInterpreterInformer\n</diagnostics>","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/server.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/routes.go":[{"range":{"start":{"line":66,"character":26},"end":{"line":66,"character":46}},"severity":1,"code":"UndeclaredImportedName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredImportedName"},"source":"compiler","message":"undefined: runtimev1alpha1.AgentRuntimeInformer"},{"range":{"start":{"line":74,"character":26},"end":{"line":74,"character":49}},"severity":1,"code":"UndeclaredImportedName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredImportedName"},"source":"compiler","message":"undefined: runtimev1alpha1.CodeInterpreterInformer"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/processor/sandbox_processor.go":[{"range":{"start":{"line":98,"character":5},"end":{"line":98,"character":23}},"severity":4,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/modernize#rangeint"},"source":"rangeint","message":"for loop can be modernized using range over int"},{"range":{"start":{"line":148,"character":2},"end":{"line":148,"character":11}},"severity":4,"code":"default","codeDesc