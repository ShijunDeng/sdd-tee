i_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/python-sdk/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/idle-cleanup/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/idle-cleanup/spec.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/python-sdk/spec.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/session-store/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/session-store/spec.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/session-routing/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/session-routing/spec.md\n\n(Results are truncated: showing first 100 results. Consider using a more specific path or pattern.)","metadata":{"count":100,"truncated":true},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z","time":{"start":1775869024253,"end":1775869024269}}}}
