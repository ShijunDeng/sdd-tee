{"type":"tool_use","timestamp":1775872286488,"sessionID":"ses_285c3b860ffeoC25s0iwFY3XI5","part":{"id":"prt_d7a3c8f000016SgSO0bL2457Z0","messageID":"msg_d7a3c831c001CQdWq6Gr7DycjX","sessionID":"ses_285c3b860ffeoC25s0iwFY3XI5","type":"tool","tool":"read","callID":"toolu_202892ac4037453cb970b4ee","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Runtime for the publish command.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: import secrets\n7: import string\n8: from pathlib import Path\n9: from typing import Any, Dict, Optional\n10: \n11: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n12: from agentcube.services.docker_service import DockerService\n13: from agentcube.services.k8s_provider import KubernetesProvider\n14: from agentcube.services.agentcube_provider import AgentCubeProvider\n15: \n16: \n17: logger = logging.getLogger(__name__)\n18: \n19: \n20: class PublishRuntime:\n21:     \"\"\"Runtime for publishing agents to Kubernetes or AgentCube.\"\"\"\n22: \n23:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n24:         \"\"\"Initialize the publish runtime.\n25:         \n26:         Args:\n27:             verbose: Enable verbose logging\n28:             provider: Target provider ('agentcube' or 'k8s')\n29:         \"\"\"\n30:         self.verbose = verbose\n31:         self.provider = provider\n32:         if verbose:\n33:             logging.basicConfig(level=logging.DEBUG)\n34:         self.metadata_service = MetadataService(verbose=verbose)\n35:         self.docker_service = DockerService(verbose=verbose)\n36: \n37:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n38:         \"\"\"Publish an agent to the specified provider.\n39:         \n40:         Args:\n41:             workspace_path: Path to the agent workspace\n42:             **options: Publish options including version, image_url, replicas, etc.\n43:             \n44:         Returns:\n45:             Dict containing deployment information\n46:             \n47:         Raises:\n48:             ValueError: If provider is unsupported or prerequisites are missing\n49:             RuntimeError: If deployment fails\n50:         \"\"\"\n51:         logger.info(f\"Publishing workspace: {workspace_path} to provider: {self.provider}\")\n52: \n53:         metadata = self.metadata_service.load_metadata(workspace_path)\n54: \n55:         self._apply_publish_options(metadata, options)\n56: \n57:         self._validate_publish_prerequisites(metadata, options)\n58: \n59:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n60: \n61:         agent_info: Dict[str, Any] = {}\n62: \n63:         if self.provider == \"agentcube\":\n64:             agent_info = self._publish_cr_to_k8s(workspace_path, metadata, image_url, options)\n65:         elif self.provider == \"k8s\":\n66:             agent_info = self._publish_k8s(workspace_path, metadata, image_url, options)\n67:         else:\n68:             raise ValueError(f\"Unsupported provider: {self.provider}\")\n69: \n70:         self._update_publish_metadata(workspace_path, agent_info)\n71:         \n72:         logger.info(f\"Successfully published agent: {metadata.agent_name}\")\n73: \n74:         return agent_info\n75: \n76:     def _apply_publish_options(self, metadata: AgentMetadata, options: Dict[str, Any]) -> None:\n77:         \"\"\"Apply CLI option overrides to metadata.\n78:         \n79:         Args:\n80:             metadata: AgentMetadata object to update\n81:             options: CLI options dict\n82:         \"\"\"\n83:         updates: Dict[str, Any] = {}\n84: \n85:         for field in [\n86:             \"version\", \"description\", \"region\", \"registry_url\",\n87:             \"registry_username\", \"registry_password\", \"agent_endpoint\",\n88:         ]:\n89:             value = options.get(field)\n90:             if value is not None and value != \"\":\n91:                 updates[field] = value\n92: \n93:         if updates:\n94:             logger.debug(f\"Applying publish overrides: {updates}\")\n95:             metadata_dict = metadata.model_dump()\n96:             metadata_dict.update(updates)\n97:             for key, value in metadata_dict.items():\n98:                 setattr(metadata, key, value)\n99: \n100:     def _validate_publish_prerequisites(self, metadata: AgentMetadata, options: Dict[str, Any]) -> None:\n101:         \"\"\"Validate prerequisites for publishing.\n102:         \n103:         Args:\n104:             metadata: AgentMetadata object\n105:             options: CLI options dict\n106:             \n107:         Raises:\n108:             RuntimeError: If Docker is required but not available\n109:             ValueError: If required parameters are missing\n110:         \"\"\"\n111:         if metadata.build_mode == \"local\":\n112:             if not self.docker_service.check_docker_available():\n113:                 raise RuntimeError(\"Docker is not available or not running\")\n114: \n115:         if self.provider == \"agentcube\":\n116:             if not metadata.workload_manager_url or not metadata.router_url:\n117:                 raise ValueError(\n118:                     \"AgentCube provider requires 'router_url' and 'workload_manager_url' \"\n119:                     \"in agent_metadata.yaml. Please run 'pack' with --router-url and \"\n120:                     \"--workload-manager-url options.\"\n121:                 )\n122: \n123:         if metadata.build_mode == \"cloud\" and not options.get(\"image_url\"):\n124:             raise ValueError(\n125:                 \"Cloud build mode requires --image-url to be specified\"\n126:             )\n127: \n128:     def _prepare_image_for_publishing(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> str:\n129:         \"\"\"Prepare the image for publishing.\n130:         \n131:         Args:\n132:             workspace_path: Path to the agent workspace\n133:             metadata: AgentMetadata object\n134:             options: CLI options dict\n135:             \n136:         Returns:\n137:             Image URL to use for deployment\n138:         \"\"\"\n139:         if options.get(\"image_url\"):\n140:             logger.info(f\"Using provided image URL: {options['image_url']}\")\n141:             return options[\"image_url\"]\n142: \n143:         if metadata.build_mode == \"local\":\n144:             return self._prepare_local_image(workspace_path, metadata, options)\n145:         elif metadata.build_mode == \"cloud\":\n146:             return self._prepare_cloud_image(workspace_path, metadata, options)\n147:         else:\n148:             raise ValueError(f\"Unsupported build mode: {metadata.build_mode}\")\n149: \n150:     def _prepare_local_image(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> str:\n151:         \"\"\"Prepare a locally built image for publishing.\n152:         \n153:         Args:\n154:             workspace_path: Path to the agent workspace\n155:             metadata: AgentMetadata object\n156:             options: CLI options dict\n157:             \n158:         Returns:\n159:             Image URL after building and optionally pushing\n160:             \n161:         Raises:\n162:             ValueError: If image_url is not provided for local mode\n163:             FileNotFoundError: If Dockerfile is missing\n164:         \"\"\"\n165:         image_url = options.get(\"image_url\")\n166:         if not image_url and metadata.image:\n167:             image_url = metadata.image.get(\"image_name\")\n168: \n169:         if not image_url:\n170:             raise ValueError(\n171:                 \"image_url is required for local build mode. \"\n172:                 \"Provide it via --image-url option or build the image first.\"\n173:             )\n174: \n175:         if metadata.image and \"image_name\" in metadata.image:\n176:             local_image = metadata.image[\"image_name\"]\n177:             registry_url = options.get(\"registry_url\") or metadata.registry_url\n178:             username = options.get(\"image_username\") or metadata.registry_username\n179:             password = options.get(\"image_password\") or metadata.registry_password\n180: \n181:             if registry_url and username and password:\n182:                 pushed_image = f\"{registry_url}/{local_image}\"\n183:                 self.docker_service.push_image(\n184:                     image_name=local_image,\n185:                     registry_url=registry_url,\n186:                     username=username,\n187:                     password=password,\n188:                 )\n189:                 logger.info(f\"Pushed image to: {pushed_image}\")\n190:                 return pushed_image\n191:             else:\n192:                 logger.warning(\"Registry credentials not provided. Image built but not pushed.\")\n193: \n194:         return image_url\n195: \n196:     def _prepare_cloud_image(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> str:\n197:         \"\"\"Prepare a cloud-built image for publishing.\n198:         \n199:         Args:\n200:             workspace_path: Path to the agent workspace\n201:             metadata: AgentMetadata object\n202:             options: CLI options dict\n203:             \n204:         Returns:\n205:             Image URL for cloud-built image\n206:             \n207:         Raises:\n208:             ValueError: If image_url is not provided for cloud mode\n209:         \"\"\"\n210:         if options.get(\"image_url\"):\n211:             return options[\"image_url\"]\n212: \n213:         if metadata.image and \"image_name\" in metadata.image:\n214:             return metadata.image[\"image_name\"]\n215: \n216:         raise ValueError(\n217:             \"Cloud build mode requires --image-url to specify the pre-built image\"\n218:         )\n219: \n220:     def _publish_cr_to_k8s(self, workspace_path: Path, metadata: AgentMetadata, image_url: str, options: Dict[str, Any]) -> Dict[str, Any]:\n221:         \"\"\"Publish using AgentCube AgentRuntime custom resource.\n222:         \n223:         Args:\n224:             workspace_path: Path to the agent workspace\n225:             metadata: AgentMetadata object\n226:             image_url: Container image URL\n227:             options: Additional publish options\n228:             \n229:         Returns:\n230:             Dict with deployment information\n231:         \"\"\"\n232:         namespace = options.get(\"namespace\") or \"default\"\n233: \n234:         logger.info(\"Deploying AgentRuntime CR to Kubernetes\")\n235: \n236:         provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n237: \n238:         readiness_probe_path = metadata.readiness_probe_path or \"/health\"\n239:         readiness_probe_port = metadata.readiness_probe_port or metadata.port\n240: \n241:         result = provider.deploy_agent_runtime(\n242:             agent_name=metadata.agent_name,\n243:             image_url=image_url,\n244:             port=metadata.port,\n245:             entrypoint=metadata.entrypoint,\n246:             env_vars=self._build_agent_env_vars(metadata),\n247:             workload_manager_url=metadata.workload_manager_url,\n248:             router_url=metadata.router_url,\n249:             readiness_probe_path=readiness_probe_path,\n250:             readiness_probe_port=readiness_probe_port,\n251:         )\n252: \n253:         provider.wait_for_deployment_ready(metadata.agent_name, namespace, timeout=120)\n254: \n255:         status = provider.get_agent_runtime_status(metadata.agent_name, namespace)\n256: \n257:         session_id = self._generate_session_id()\n258:         agent_id = result.get(\"agent_name\", metadata.agent_name)\n259: \n260:         return {\n261:             \"agent_name\": metadata.agent_name,\n262:             \"agent_id\": agent_id,\n263:             \"session_id\": session_id,\n264:             \"deployment_type\": \"AgentRuntime\",\n265:             \"namespace\": namespace,\n266:             \"image_url\": image_url,\n267:             \"status\": status.get(\"status\", \"running\"),\n268:             \"endpoint\": status.get(\"agent_endpoint\"),\n269:             \"router_url\": metadata.router_url,\n270:             \"workload_manager_url\": metadata.workload_manager_url,\n271:         }\n272: \n273:     def _publish_k8s(self, workspace_path: Path, metadata: AgentMetadata, image_url: str, options: Dict[str, Any]) -> Dict[str, Any]:\n274:         \"\"\"Publish using standard Kubernetes Deployment and Service.\n275:         \n276:         Args:\n277:             workspace_path: Path to the agent workspace\n278:             metadata: AgentMetadata object\n279:             image_url: Container image URL\n280:             options: Additional publish options\n281:             \n282:         Returns:\n283:             Dict with deployment information\n284:         \"\"\"\n285:         namespace = options.get(\"namespace\") or \"default\"\n286:         replicas = options.get(\"replicas\", 1)\n287:         node_port = options.get(\"node_port\")\n288: \n289:         if node_port and not (30000 <= node_port <= 32767):\n290:             raise ValueError(f\"NodePort must be between 30000 and 32767, got {node_port}\")\n291: \n292:         logger.info(\"Deploying standard Kubernetes Deployment and Service\")\n293: \n294:         provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n295: \n296:         env_vars = self._build_agent_env_vars(metadata)\n297: \n298:         result = provider.deploy_agent(\n299:             agent_name=metadata.agent_name,\n300:             image_url=image_url,\n301:             port=metadata.port,\n302:             entrypoint=metadata.entrypoint,\n303:             replicas=replicas,\n304:             node_port=node_port,\n305:             env_vars=env_vars,\n306:         )\n307: \n308:         provider.wait_for_deployment_ready(metadata.agent_name, timeout=120)\n309: \n310:         status = provider.get_agent_status(metadata.agent_name)\n311: \n312:         session_id = self._generate_session_id()\n313: \n314:         return {\n315:             \"agent_name\": metadata.agent_name,\n316:             \"agent_id\": result.get(\"deployment_name\", metadata.agent_name),\n317:             \"session_id\": session_id,\n318:             \"deployment_type\": \"Kubernetes\",\n319:             \"namespace\": namespace,\n320:             \"image_url\": image_url,\n321:             \"deployment_name\": result[\"deployment_name\"],\n322:             \"service_name\": result[\"service_name\"],\n323:             \"node_port\": result[\"node_port\"],\n324:             \"service_url\": result[\"service_url\"],\n325:             \"replicas\": replicas,\n326:             \"status\": status.get(\"status\", \"running\"),\n327:         }\n328: \n329:     def _build_agent_env_vars(self, metadata: AgentMetadata) -> Dict[str, str]:\n330:         \"\"\"Build environment variables for agent deployment.\n331:         \n332:         Args:\n333:             metadata: AgentMetadata object\n334:             \n335:         Returns:\n336:             Dict of environment variables\n337:         \"\"\"\n338:         env_vars: Dict[str, str] = {}\n339: \n340:         if metadata.workload_manager_url:\n341:             env_vars[\"WORKLOAD_MANAGER_URL\"] = metadata.workload_manager_url\n342:         if metadata.router_url:\n343:             env_vars[\"ROUTER_URL\"] = metadata.router_url\n344:         if metadata.agent_endpoint:\n345:             env_vars[\"AGENT_ENDPOINT\"] = metadata.agent_endpoint\n346: \n347:         return env_vars\n348: \n349:     def _update_publish_metadata(self, workspace_path: Path, agent_info: Dict[str, Any]) -> None:\n350:         \"\"\"Update metadata with publish information.\n351:         \n352:         Args:\n353:             workspace_path: Path to the agent workspace\n354:             agent_info: Deployment information dict\n355:         \"\"\"\n356:         metadata = self.metadata_service.load_metadata(workspace_path)\n357: \n358:         updates = {\n359:             \"agent_id\": agent_info.get(\"agent_id\"),\n360:             \"session_id\": agent_info.get(\"session_id\"),\n361:             \"agent_endpoint\": agent_info.get(\"endpoint\") or agent_info.get(\"service_url\"),\n362:             \"image\": {\n363:                 \"url\": agent_info.get(\"image_url\"),\n364:                 \"type\": agent_info.get(\"deployment_type\"),\n365:             },\n366:             \"k8s_deployment\": {\n367:                 \"type\": agent_info.get(\"deployment_type\"),\n368:                 \"namespace\": agent_info.get(\"namespace\"),\n369:                 \"name\": agent_info.get(\"deployment_name\") or agent_info.get(\"agent_name\"),\n370:             },\n371:         }\n372: \n373:         metadata_dict = metadata.model_dump()\n374:         for key, value in updates.items():\n375:             if value is not None:\n376:                 metadata_dict[key] = value\n377: \n378:         updated_metadata = AgentMetadata(**metadata_dict)\n379:         self.metadata_service.save_metadata(workspace_path, updated_metadata)\n380:         logger.debug(\"Updated publish metadata\")\n381: \n382:     def _generate_session_id(self) -> str:\n383:         \"\"\"Generate a unique session ID.\n384:         \n385:         Returns:\n386:             32-character alphanumeric session ID\n387:         \"\"\"\n388:         alphabet = string.ascii_letters + string.digits\n389:         return \"\".join(secrets.choice(alphabet) for _ in range(32))\n\n(End of file - total 389 lines)\n</content>","metadata":{"preview":"\"\"\"Runtime for the publish command.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport secrets\nimport string\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass PublishRuntime:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/runtime/publish_runtime.py","time":{"start":1775872286459,"end":1775872286485}}}}
