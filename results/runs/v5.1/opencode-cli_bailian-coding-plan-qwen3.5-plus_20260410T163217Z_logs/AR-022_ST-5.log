raise RuntimeError(\n                \"Kubernetes Python client is not installed. \"\n                \"Install it with: pip install kubernetes\"\n            )\n\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        self._load_config()\n        self._custom_api = CustomObjectsApi()\n\n    def _load_config(self) -> None:\n        \"\"\"Load Kubernetes configuration.\"\"\"\n        try:\n            if self.kubeconfig:\n                config.load_kube_config(config_file=self.kubeconfig)\n            else:\n                config.load_kube_config()\n        except config.ConfigException:\n            try:\n                config.load_incluster_config()\n            except config.ConfigException as e:\n                raise RuntimeError(\n                    \"Failed to load Kubernetes configuration. \"\n                    \"Please provide a kubeconfig file or run in a Kubernetes cluster.\"\n                ) from e\n\n    def _ensure_namespace(self) -> None:\n        \"\"\"Ensure the namespace exists.\"\"\"\n        try:\n            core_v1 = client.CoreV1Api()\n            core_v1.read_namespace(self.namespace)\n        except ApiException as e:\n            if e.status == 404:\n                core_v1 = client.CoreV1Api()\n                namespace = client.V1Namespace(\n                    metadata=client.V1ObjectMeta(name=self.namespace)\n                )\n                core_v1.create_namespace(namespace)\n                logger.info(f\"Created namespace: {self.namespace}\")\n            else:\n                raise\n\n    def deploy_agent_runtime(\n        self,\n        agent_name: str,\n        image_url: str,\n        port: int,\n        entrypoint: Optional[str] = None,\n        env_vars: Optional[Dict[str, str]] = None,\n        workload_manager_url: Optional[str] = None,\n        router_url: Optional[str] = None,\n        readiness_probe_path: Optional[str] = None,\n        readiness_probe_port: Optional[int] = None,\n    ) -> Dict[str, Any]:\n        \"\"\"Deploy an agent using AgentRuntime custom resource.\"\"\"\n        self._ensure_namespace()\n\n        sanitized_name = self._sanitize_name(agent_name)\n\n        workload_manager = workload_manager_url or os.getenv(\"WORKLOAD_MANAGER_URL\")\n        router = router_url or os.getenv(\"ROUTER_URL\")\n\n        if not workload_manager:\n            raise ValueError(\n                \"workload_manager_url is required. \"\n                \"Provide it as a parameter or set WORKLOAD_MANAGER_URL environment variable.\"\n            )\n\n        if not router:\n            raise ValueError(\n                \"router_url is required. \"\n                \"Provide it as a parameter or set ROUTER_URL environment variable.\"\n            )\n\n        env_list = [\n            client.V1EnvVar(name=k, value=v) for k, v in (env_vars or {}).items()\n        ]\n\n        cr = {\n            \"apiVersion\": f\"{CR_GROUP}/{CR_VERSION}\",\n            \"kind\": \"AgentRuntime\",\n            \"metadata\": {\n                \"name\": sanitized_name,\n                \"namespace\": self.namespace,\n            },\n            \"spec\": {\n                \"image\": image_url,\n                \"port\": port,\n                \"entrypoint\": entrypoint or \"\",\n                \"env\": env_list,\n                \"workloadManagerURL\": workload_manager,\n                \"routerURL\": router,\n                \"sessionTimeout\": \"15m\",\n                \"maxSessionDuration\": \"8h\",\n                \"readinessProbe\": {\n                    \"path\": readiness_probe_path or \"/health\",\n                    \"port\": readiness_probe_port or port,\n                },\n                \"imagePullSecrets\": [{\"name\": \"default-secret\"}],\n            },\n        }\n\n        try:\n            self._custom_api.create_namespaced_custom_object(\n                group=CR_GROUP,\n                version=CR_VERSION,\n                namespace=self.namespace,\n                plural=CR_PLURAL,\n                body=cr,\n            )\n            logger.info(f\"Created AgentRuntime {sanitized_name}\")\n        except ApiException as e:\n            if e.status == 409:\n                self._custom_api.replace_namespaced_custom_object(\n                    group=CR_GROUP,\n                    version=CR_VERSION,\n                    namespace=self.namespace,\n                    plural=CR_PLURAL,\n                    name=sanitized_name,\n                    body=cr,\n                )\n                logger.info(f\"Updated AgentRuntime {sanitized_name}\")\n            else:\n                raise\n\n        return {\n            \"status\": \"created\",\n            \"agent_name\": sanitized_name,\n            \"namespace\": self.namespace,\n        }\n\n    def get_agent_runtime(self, name: str, namespace: str) -> Optional[Dict[str, Any]]:\n        \"\"\"Get an AgentRuntime custom resource.\"\"\"\n        try:\n            cr = self._custom_api.get_namespaced_custom_object(\n                group=CR_GROUP,\n                version=CR_VERSION,\n                namespace=namespace,\n                plural=CR_PLURAL,\n                name=name,\n            )\n            return cr\n        except ApiException as e:\n            if e.status == 404:\n                return None\n            raise\n\n    def _sanitize_name(self, name: str) -> str:\n        \"\"\"Sanitize a name for Kubernetes.\"\"\"\n        sanitized = re.sub(r\"[^a-z0-9-]\", \"-\", name.lower())\n        sanitized = re.sub(r\"-+\", \"-\", sanitized)\n        sanitized = sanitized.strip(\"-\")\n        if len(sanitized) > 63:\n            sanitized = sanitized[:63].rstrip(\"-\")\n        return sanitized or \"agent\"","after":"\"\"\"AgentCube provider service for AgentRuntime CR.\"\"\"\n\nimport logging\nimport os\nimport re\nimport time\nfrom typing import Any, Dict, List, Optional\n\ntry:\n    from kubernetes import client, config\n    from kubernetes.client.rest import ApiException\n    from kubernetes.client import CustomObjectsApi\n    KUBERNETES_AVAILABLE = True\nexcept ImportError:\n    KUBERNETES_AVAILABLE = False\n    client = None\n    config = None\n    ApiException = Exception\n    CustomObjectsApi = None\n\n\nlogger = logging.getLogger(__name__)\n\nCR_GROUP = \"runtime.agentcube.volcano.sh\"\nCR_VERSION = \"v1alpha1\"\nCR_PLURAL = \"agentruntimes\"\n\n\nclass AgentCubeProvider:\n    \"\"\"Provider for deploying agents using AgentCube AgentRuntime CR.\"\"\"\n\n    def __init__(\n        self,\n        namespace: str = \"default\",\n        verbose: bool = False,\n        kubeconfig: Optional[str] = None,\n    ) -> None:\n        \"\"\"Initialize the AgentCube provider.\n        \n        Args:\n            namespace: Kubernetes namespace for deployment\n            verbose: Enable verbose logging\n            kubeconfig: Path to kubeconfig file (optional)\n        \"\"\"\n        self.namespace = namespace\n        self.verbose = verbose\n        self.kubeconfig = kubeconfig\n\n        if not KUBERNETES_AVAILABLE:\n            raise RuntimeError(\n                \"Kubernetes Python client is not installed. \"\n                \"Install it with: pip install kubernetes\"\n            )\n\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n        self._load_config()\n        self._custom_api = CustomObjectsApi()\n\n    def _load_config(self) -> None:\n        \"\"\"Load Kubernetes configuration.\"\"\"\n        try:\n            if self.kubeconfig:\n                config.load_kube_config(config_file=self.kubeconfig)\n            else:\n                config.load_kube_config()\n        except config.ConfigException:\n            try:\n                config.load_incluster_config()\n            except config.ConfigException as e:\n                raise RuntimeError(\n                    \"Failed to load Kubernetes configuration. \"\n                    \"Please provide a kubeconfig file or run in a Kubernetes cluster.\"\n                ) from e\n\n    def _ensure_namespace(self) -> None:\n        \"\"\"Ensure the namespace exists.\"\"\"\n        try:\n            core_v1 = client.CoreV1Api()\n            core_v1.read_namespace(self.namespace)\n        except ApiException as e:\n            if e.status == 404:\n                core_v1 = client.CoreV1Api()\n                namespace = client.V1Namespace(\n                    metadata=client.V1ObjectMeta(name=self.namespace)\n                )\n                core_v1.create_namespace(namespace)\n                logger.info(f\"Created namespace: {self.namespace}\")\n            else:\n                raise\n\n    def deploy_agent_runtime(\n        self,\n        agent_name: str,\n        image_url: str,\n        port: int,\n        entrypoint: Optional[str] = None,\n        env_vars: Optional[Dict[str, str]] = None,\n        workload_manager_url: Optional[str] = None,\n        router_url: Optional[str] = None,\n        readiness_probe_path: Optional[str] = None,\n        readiness_probe_port: Optional[int] = None,\n    ) -> Dict[str, Any]:\n        \"\"\"Deploy an agent using AgentRuntime custom resource.\n        \n        Args:\n            agent_name: Name of the agent\n            image_url: Container image URL\n            port: Container port\n            entrypoint: Entrypoint command\n            env_vars: Environment variables dict\n            workload_manager_url: Workload Manager URL\n            router_url: Router URL\n            readiness_probe_path: Health check path\n            readiness_probe_port: Health check port\n            \n        Returns:\n            Dict with deployment status\n        \"\"\"\n        self._ensure_namespace()\n\n        sanitized_name = self._sanitize_name(agent_name)\n\n        workload_manager = workload_manager_url or os.getenv(\"WORKLOAD_MANAGER_URL\")\n        router = router_url or os.getenv(\"ROUTER_URL\")\n\n        if not workload_manager:\n            raise ValueError(\n                \"workload_manager_url is required. \"\n                \"Provide it as a parameter or set WORKLOAD_MANAGER_URL environment variable.\"\n            )\n\n        if not router:\n            raise ValueError(\n                \"router_url is required. \"\n                \"Provide it as a parameter or set ROUTER_URL environment variable.\"\n            )\n\n        env_list = [\n            client.V1EnvVar(name=k, value=v) for k, v in (env_vars or {}).items()\n        ]\n\n        cr = {\n            \"apiVersion\": f\"{CR_GROUP}/{CR_VERSION}\",\n            \"kind\": \"AgentRuntime\",\n            \"metadata\": {\n                \"name\": sanitized_name,\n                \"namespace\": self.namespace,\n            },\n            \"spec\": {\n                \"image\": image_url,\n                \"port\": port,\n                \"entrypoint\": entrypoint or \"\",\n                \"env\": env_list,\n                \"workloadManagerURL\": workload_manager,\n                \"routerURL\": router,\n                \"sessionTimeout\": \"15m\",\n                \"maxSessionDuration\": \"8h\",\n                \"readinessProbe\": {\n                    \"path\": readiness_probe_path or \"/health\",\n                    \"port\": readiness_probe_port or port,\n                },\n                \"imagePullSecrets\": [{\"name\": \"default-secret\"}],\n            },\n        }\n\n        try:\n            self._custom_api.create_namespaced_custom_object(\n                group=CR_GROUP,\n                version=CR_VERSION,\n                namespace=self.namespace,\n                plural=CR_PLURAL,\n                body=cr,\n            )\n            logger.info(f\"Created AgentRuntime {sanitized_name}\")\n        except ApiException as e:\n            if e.status == 409:\n                logger.info(f\"Updating existing AgentRuntime {sanitized_name}\")\n                self._custom_api.replace_namespaced_custom_object(\n                    group=CR_GROUP,\n                    version=CR_VERSION,\n                    namespace=self.namespace,\n                    plural=CR_PLURAL,\n                    name=sanitized_name,\n                    body=cr,\n                )\n            else:\n                raise\n\n        return {\n            \"status\": \"created\",\n            \"agent_name\": sanitized_name,\n            \"namespace\": self.namespace,\n        }\n\n    def get_agent_runtime(self, name: str, namespace: Optional[str] = None) -> Optional[Dict[str, Any]]:\n        \"\"\"Get an AgentRuntime custom resource.\n        \n        Args:\n            name: AgentRuntime name\n            namespace: Kubernetes namespace (defaults to self.namespace)\n            \n        Returns:\n            AgentRuntime CR dict or None if not found\n        \"\"\"\n        ns = namespace or self.namespace\n        try:\n            cr = self._custom_api.get_namespaced_custom_object(\n                group=CR_GROUP,\n                version=CR_VERSION,\n                namespace=ns,\n                plural=CR_PLURAL,\n                name=name,\n            )\n            return cr\n        except ApiException as e:\n            if e.status == 404:\n                return None\n            raise\n\n    def wait_for_deployment_ready(self, agent_name: str, namespace: Optional[str] = None, timeout: int = 120) -> None:\n        \"\"\"Wait for AgentRuntime to be ready.\n        \n        Args:\n            agent_name: Agent name\n            namespace: Kubernetes namespace\n            timeout: Timeout in seconds (default: 120)\n            \n        Raises:\n            TimeoutError: If deployment doesn't become ready within timeout\n        \"\"\"\n        logger.info(f\"Waiting for AgentRuntime {agent_name} to be ready (timeout: {timeout}s)\")\n\n        start_time = time.time()\n        sanitized_name = self._sanitize_name(agent_name)\n        ns = namespace or self.namespace\n\n        while time.time() - start_time < timeout:\n            try:\n                cr = self.get_agent_runtime(sanitized_name, ns)\n                if cr:\n                    status = cr.get(\"status\", {})\n                    conditions = status.get(\"conditions\", [])\n\n                    for condition in conditions:\n                        if condition.get(\"type\") == \"Ready\" and condition.get(\"status\") == \"True\":\n                            logger.info(f\"AgentRuntime {agent_name} is ready\")\n                            return\n\n                    phase = status.get(\"phase\", \"unknown\")\n                    logger.debug(f\"AgentRuntime status: {phase}\")\n\n            except ApiException as e:\n                logger.warning(f\"Error checking AgentRuntime status: {e}\")\n\n            time.sleep(5)\n\n        raise TimeoutError(f\"AgentRuntime {agent_name} did not become ready within {timeout}s\")\n\n    def get_agent_runtime_status(self, agent_name: str, namespace: Optional[str] = None) -> Dict[str, Any]:\n        \"\"\"Get AgentRuntime status.\n        \n        Args:\n            agent_name: Agent name\n            namespace: Kubernetes namespace\n            \n        Returns:\n            Dict with status information\n        \"\"\"\n        ns = namespace or self.namespace\n        sanitized_name = self._sanitize_name(agent_name)\n        cr = self.get_agent_runtime(sanitized_name, ns)\n\n        if not cr:\n            return {\"status\": \"not_found\", \"agent_name\": agent_name}\n\n        status = cr.get(\"status\", {})\n        return {\n            \"status\": status.get(\"phase\", \"unknown\"),\n            \"agent_name\": agent_name,\n            \"cr_name\": sanitized_name,\n            \"namespace\": ns,\n            \"agent_endpoint\": status.get(\"agentEndpoint\"),\n            \"conditions\": status.get(\"conditions\", []),\n        }\n\n    def delete_agent_runtime(self, agent_name: str, namespace: Optional[str] = None) -> Dict[str, Any]:\n        \"\"\"Delete an AgentRuntime custom resource.\n        \n        Args:\n            agent_name: Agent name\n            namespace: Kubernetes namespace\n            \n        Returns:\n            Dict with deletion status\n        \"\"\"\n        ns = namespace or self.namespace\n        sanitized_name = self._sanitize_name(agent_name)\n        logger.info(f\"Deleting AgentRuntime: {sanitized_name}\")\n\n        try:\n            self._custom_api.delete_namespaced_custom_object(\n                group=CR_GROUP,\n                version=CR_VERSION,\n                namespace=ns,\n                plural=CR_PLURAL,\n                name=sanitized_name,\n            )\n            logger.info(f\"AgentRuntime deleted: {sanitized_name}\")\n            return {\"status\": \"deleted\", \"agent_name\": agent_name, \"namespace\": ns}\n        except ApiException as e:\n            if e.status == 404:\n                logger.warning(f\"AgentRuntime not found: {sanitized_name}\")\n                return {\"status\": \"not_found\", \"agent_name\": agent_name}\n            raise\n\n    def _sanitize_name(self, name: str) -> str:\n        \"\"\"Sanitize a name for Kubernetes.\n        \n        Args:\n            name: Name to sanitize\n            \n        Returns:\n            Sanitized name suitable for Kubernetes resources\n        \"\"\"\n        sanitized = re.sub(r\"[^a-z0-9-]\", \"-\", name.lower())\n        sanitized = re.sub(r\"-+\", \"-\", sanitized)\n        sanitized = sanitized.strip(\"-\")\n        if len(sanitized) > 63:\n            sanitized = sanitized[:63].rstrip(\"-\")\n        return sanitized or \"agent\"","additions":141,"deletions":7},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/agentcube_provider.py","time":{"start":1775868553085,"end":1775868553938}}}}
