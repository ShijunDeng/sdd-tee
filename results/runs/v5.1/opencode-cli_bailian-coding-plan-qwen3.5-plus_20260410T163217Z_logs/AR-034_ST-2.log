\ndrwxr-xr-x  2 root root     4096 Mar 21 15:58 integrations\n-rw-r--r--  1 root root     8228 Apr 11 12:30 Makefile\ndrwxr-xr-x  3 root root     4096 Apr 11 11:43 manifests\ndrwxr-xr-x 10 root root     4096 Apr 11 07:39 pkg\n-rw-r--r--  1 root root     1674 Mar 21 15:53 project.md\n-rw-r--r--  1 root root    31518 Apr 11 10:36 proposal_ar_027.md\n-rw-r--r--  1 root root    26004 Apr 11 10:55 proposal_ar_028.md\n-rw-r--r--  1 root root     4456 Apr 11 11:17 proposal_ar_029.md\n-rw-r--r--  1 root root    23214 Apr 11 09:38 proposal.md\ndrwxr-xr-x  3 root root     4096 Apr 11 08:33 .pytest_cache\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 python-sdk\ndrwxr-xr-x  5 root root     4096 Apr 11 12:05 sandbox-orchestration\n-rw-r--r--  1 root root    18689 Apr 11 11:17 .sdd_prompt.md\ndrwxr-xr-x  8 root root     4096 Apr 11 11:31 sdk-python\ndrwxr-xr-x  2 root root     4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 session-store\ndrwxr-xr-x  2 root root     4096 Mar 25 09:51 testing\n-rw-r--r--  1 root root     1983 Mar 25 09:36 test_spec.md\n-rw-r--r--  1 root root     8552 Apr 11 01:56 verification-report.md\n","exit":0,"description":"List project root directory","truncated":false},"title":"List project root directory","time":{"start":1775883085082,"end":1775883085197}}}}
