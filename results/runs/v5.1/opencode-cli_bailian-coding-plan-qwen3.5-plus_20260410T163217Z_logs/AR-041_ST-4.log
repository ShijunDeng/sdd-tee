{"type":"tool_use","timestamp":1775891409706,"sessionID":"ses_2849fd21bffeUKa4X2cYGkL1x4","part":{"id":"prt_d7b6065ed0015NxEckP86RVm8i","messageID":"msg_d7b6042d80018s1p3wegtKTo87","sessionID":"ses_2849fd21bffeUKa4X2cYGkL1x4","type":"tool","tool":"read","callID":"toolu_d7ca8aadb93a445f96522ac1","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go</path>\n<type>file</type>\n<content>\n1: // Copyright 2026 AgentCube Authors\n2: // E2E tests for AgentCube\n3: \n4: package e2e\n5: \n6: import (\n7: \t\"bytes\"\n8: \t\"encoding/json\"\n9: \t\"fmt\"\n10: \t\"io\"\n11: \t\"net/http\"\n12: \t\"os\"\n13: \t\"testing\"\n14: \t\"time\"\n15: )\n16: \n17: var (\n18: \tworkloadManagerURL string\n19: \trouterURL          string\n20: \tapiToken           string\n21: \tclient             *http.Client\n22: )\n23: \n24: func TestMain(m *testing.M) {\n25: \tworkloadManagerURL = os.Getenv(\"WORKLOAD_MANAGER_URL\")\n26: \trouterURL = os.Getenv(\"ROUTER_URL\")\n27: \tapiToken = os.Getenv(\"API_TOKEN\")\n28: \n29: \tif workloadManagerURL == \"\" {\n30: \t\tworkloadManagerURL = \"http://localhost:8080\"\n31: \t}\n32: \tif routerURL == \"\" {\n33: \t\trouterURL = \"http://localhost:8081\"\n34: \t}\n35: \tif apiToken == \"\" {\n36: \t\tfmt.Println(\"Warning: API_TOKEN not set\")\n37: \t}\n38: \n39: \tclient = &http.Client{\n40: \t\tTimeout: 30 * time.Second,\n41: \t}\n42: \n43: \tos.Exit(m.Run())\n44: }\n45: \n46: func TestHealthCheck(t *testing.T) {\n47: \tresp, err := client.Get(workloadManagerURL + \"/health\")\n48: \tif err != nil {\n49: \t\tt.Fatalf(\"Health check failed: %v\", err)\n50: \t}\n51: \tdefer resp.Body.Close()\n52: \n53: \tif resp.StatusCode != http.StatusOK {\n54: \t\tt.Fatalf(\"Health check returned status: %d\", resp.StatusCode)\n55: \t}\n56: \n57: \tbody, err := io.ReadAll(resp.Body)\n58: \tif err != nil {\n59: \t\tt.Fatalf(\"Failed to read response body: %v\", err)\n60: \t}\n61: \n62: \tvar health struct {\n63: \t\tStatus string `json:\"status\"`\n64: \t}\n65: \tif err := json.Unmarshal(body, &health); err != nil {\n66: \t\tt.Fatalf(\"Failed to parse health response: %v\", err)\n67: \t}\n68: \n69: \tif health.Status != \"ok\" && health.Status != \"healthy\" {\n70: \t\tt.Logf(\"Health status: %s\", health.Status)\n71: \t}\n72: }\n73: \n74: func TestRouterHealth(t *testing.T) {\n75: \tresp, err := client.Get(routerURL + \"/health/live\")\n76: \tif err != nil {\n77: \t\tt.Fatalf(\"Router health check failed: %v\", err)\n78: \t}\n79: \tdefer resp.Body.Close()\n80: \n81: \tif resp.StatusCode != http.StatusOK {\n82: \t\tt.Fatalf(\"Router health check returned status: %d\", resp.StatusCode)\n83: \t}\n84: }\n85: \n86: func TestInvokeEchoAgent(t *testing.T) {\n87: \tmessage := map[string]string{\n88: \t\t\"message\": \"Hello, echo agent!\",\n89: \t}\n90: \tbody, _ := json.Marshal(message)\n91: \n92: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/echo-agent\", bytes.NewReader(body))\n93: \tif err != nil {\n94: \t\tt.Fatalf(\"Failed to create request: %v\", err)\n95: \t}\n96: \n97: \treq.Header.Set(\"Content-Type\", \"application/json\")\n98: \treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n99: \n100: \tresp, err := client.Do(req)\n101: \tif err != nil {\n102: \t\tt.Fatalf(\"Invoke request failed: %v\", err)\n103: \t}\n104: \tdefer resp.Body.Close()\n105: \n106: \tif resp.StatusCode != http.StatusOK {\n107: \t\tbody, _ := io.ReadAll(resp.Body)\n108: \t\tt.Fatalf(\"Invoke returned status: %d, body: %s\", resp.StatusCode, string(body))\n109: \t}\n110: \n111: \tvar result map[string]interface{}\n112: \tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n113: \t\tt.Fatalf(\"Failed to decode response: %v\", err)\n114: \t}\n115: \n116: \tt.Logf(\"Echo agent response: %+v\", result)\n117: }\n118: \n119: func TestCodeInterpreter(t *testing.T) {\n120: \tcode := map[string]string{\n121: \t\t\"code\": \"print('Hello from code interpreter')\",\n122: \t}\n123: \tbody, _ := json.Marshal(code)\n124: \n125: \treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/e2e-code-interpreter\", bytes.NewReader(body))\n126: \tif err != nil {\n127: \t\tt.Fatalf(\"Failed to create request: %v\", err)\n128: \t}\n129: \n130: \treq.Header.Set(\"Content-Type\", \"application/json\")\n131: \treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n132: \n133: \tresp, err := client.Do(req)\n134: \tif err != nil {\n135: \t\tt.Fatalf(\"Code interpreter request failed: %v\", err)\n136: \t}\n137: \tdefer resp.Body.Close()\n138: \n139: \tif resp.StatusCode != http.StatusOK {\n140: \t\tbody, _ := io.ReadAll(resp.Body)\n141: \t\tt.Fatalf(\"Code interpreter returned status: %d, body: %s\", resp.StatusCode, string(body))\n142: \t}\n143: \n144: \tvar result map[string]interface{}\n145: \tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n146: \t\tt.Fatalf(\"Failed to decode response: %v\", err)\n147: \t}\n148: \n149: \tt.Logf(\"Code interpreter response: %+v\", result)\n150: }\n\n(End of file - total 150 lines)\n</content>","metadata":{"preview":"// Copyright 2026 AgentCube Authors\n// E2E tests for AgentCube\n\npackage e2e\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n)\n\nvar (\n\tworkloadManagerURL string\n\trouterURL          string\n\tapiToken           string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go","time":{"start":1775891409677,"end":1775891409704}}}}
{"type":"tool_use","timestamp":1775891409708,"sessionID":"ses_2849fd21bffeUKa4X2cYGkL1x4","part":{"id":"prt_d7b606084001pNJyvNyFsOKak3","messageID":"msg_d7b6042d80018s1p3wegtKTo87","sessionID":"ses_2849fd21bffeUKa4X2cYGkL1x4","type":"tool","tool":"read","callID":"toolu_350487108de34377bcd085f3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/README.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/README.md</path>\n<type>file</type>\n<content>\n1: # AgentCube E2E Tests\n2: \n3: This directory contains end-to-end tests for the AgentCube platform.\n4: \n5: ## Requirements\n6: \n7: - Go 1.23+\n8: - Python 3.10+\n9: - Kind v0.30.0+\n10: - Helm 3.x\n11: - Docker\n12: \n13: ## Running E2E Tests\n14: \n15: ### Full E2E Test Suite\n16: \n17: ```bash\n18: make e2e\n19: ```\n20: \n21: This will:\n22: 1. Create a Kind cluster named `agentcube-e2e`\n23: 2. Install agent-sandbox CRDs and controllers\n24: 3. Build and load local Docker images\n25: 4. Install AgentCube via Helm\n26: 5. Apply E2E fixtures (echo agent, code interpreter)\n27: 6. Run Go and Python E2E tests\n28: 7. Clean up the cluster\n29: \n30: ### Manual Test Execution\n31: \n32: ```bash\n33: # Set up environment\n34: export WORKLOAD_MANAGER_URL=http://localhost:8080\n35: export ROUTER_URL=http://localhost:8081\n36: export API_TOKEN=$(kubectl -n agentcube create token e2e-test --duration=24h)\n37: \n38: # Run Go tests\n39: go test -v ./test/e2e/...\n40: \n41: # Run Python tests\n42: python test/e2e/test_codeinterpreter.py\n43: ```\n44: \n45: ## Configuration\n46: \n47: Environment variables:\n48: - `E2E_CLUSTER_NAME`: Kind cluster name (default: `agentcube-e2e`)\n49: - `E2E_CLEAN_CLUSTER`: Delete existing cluster before tests (default: `true`)\n50: - `E2E_SKIP_SETUP`: Skip cluster setup (default: `false`)\n51: - `AGENTCUBE_NAMESPACE`: Kubernetes namespace (default: `agentcube`)\n52: - `AGENT_SANDBOX_VERSION`: Agent sandbox version (default: `v0.1.1`)\n53: - `ARTIFACTS_PATH`: Path for log artifacts on failure\n54: \n55: ## Fixtures\n56: \n57: - `echo_agent.yaml`: Simple echo agent for testing router invocation\n58: - `e2e_code_interpreter.yaml`: CodeInterpreter resource for testing\n59: - `e2e_code_interpreter_warmpool.yaml`: CodeInterpreter with warm pool enabled\n60: \n61: ## Troubleshooting\n62: \n63: ### Collect Logs Manually\n64: \n65: ```bash\n66: ./test/e2e/run_e2e.sh 2>&1 | tee e2e.log\n67: ```\n68: \n69: ### Clean Up\n70: \n71: ```bash\n72: make e2e-clean\n73: ```\n\n(End of file - total 73 lines)\n</content>","metadata":{"preview":"# AgentCube E2E Tests\n\nThis directory contains end-to-end tests for the AgentCube platform.\n\n## Requirements\n\n- Go 1.23+\n- Python 3.10+\n- Kind v0.30.0+\n- Helm 3.x\n- Docker\n\n## Running E2E Tests\n\n### Full E2E Test Suite\n\n```bash\nmake e2e\n```\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/README.md","time":{"start":1775891409675,"end":1775891409707}}}}
