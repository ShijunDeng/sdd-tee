{"type":"tool_use","timestamp":1775890306708,"sessionID":"ses_284b12e61ffegKYv9ZTZvGCjkO","part":{"id":"prt_d7b4f863c001tqQfCvqChvCSUR","messageID":"msg_d7b4f7bd8001NpJXcNaj0mI1Bz","sessionID":"ses_284b12e61ffegKYv9ZTZvGCjkO","type":"tool","tool":"read","callID":"toolu_81068f42c1784dc88de96987","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/code_interpreter.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/code_interpreter.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Code Interpreter Client for the agentcube SDK.\"\"\"\n2: \n3: import logging\n4: import os\n5: from typing import Any, Dict, Optional\n6: \n7: from .clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n8: from .clients.control_plane import ControlPlaneClient\n9: from .exceptions import CommandExecutionError\n10: from .utils.log import get_logger\n11: \n12: \n13: class CodeInterpreterClient:\n14:     \"\"\"High-level client for Code Interpreter operations.\n15:     \n16:     This client manages session lifecycle and provides a simplified\n17:     interface for code execution and file operations.\n18:     \n19:     Attributes:\n20:         namespace: Kubernetes namespace\n21:         router_url: Router base URL\n22:         workload_manager_url: Workload Manager base URL\n23:         verbose: Enable debug logging flag\n24:         session_id: Session identifier\n25:         timeout: Default request timeout in seconds\n26:         connect_timeout: Connection timeout in seconds\n27:         cp_client: Control plane client instance\n28:         dp_client: Data plane client instance\n29:         logger: Module logger\n30:     \n31:     Example usage:\n32:         # Context manager pattern (recommended)\n33:         with CodeInterpreterClient(\n34:             namespace=\"default\",\n35:             router_url=\"http://router:8080\",\n36:             workload_manager_url=\"http://workload-manager:8080\"\n37:         ) as client:\n38:             result = client.execute(\"print('hello')\")\n39:             print(result)\n40:             client.upload_file(\"data.txt\", b\"sample data\")\n41:             content = client.download_file(\"data.txt\")\n42:         \n43:         # Explicit session ID\n44:         client = CodeInterpreterClient(\n45:             session_id=\"pre-existing-session\",\n46:             router_url=\"http://router:8080\"\n47:         )\n48:         try:\n49:             result = client.execute(\"x = 1 + 1\")\n50:         finally:\n51:             client.close()\n52:     \"\"\"\n53:     \n54:     def __init__(\n55:         self,\n56:         namespace: str = \"default\",\n57:         router_url: Optional[str] = None,\n58:         workload_manager_url: Optional[str] = None,\n59:         verbose: bool = False,\n60:         session_id: Optional[str] = None,\n61:         timeout: float = 120.0,\n62:         connect_timeout: float = 5.0,\n63:         token_path: Optional[str] = None,\n64:     ) -> None:\n65:         \"\"\"Initialize CodeInterpreterClient.\n66:         \n67:         Args:\n68:             namespace: Kubernetes namespace (default: \"default\")\n69:             router_url: Router base URL. Resolves from arg or ROUTER_URL env var\n70:             workload_manager_url: Workload Manager URL. Resolves from arg or\n71:                                  WORKLOAD_MANAGER_URL env var\n72:             verbose: Enable debug logging (default: False)\n73:             session_id: Existing session ID. If None, creates new session\n74:             timeout: Default request timeout in seconds (default: 120)\n75:             connect_timeout: Connection timeout in seconds (default: 5.0)\n76:             token_path: Path to Kubernetes SA token file\n77:         \n78:         Raises:\n79:             ValueError: If required URLs not provided and env vars not set\n80:         \"\"\"\n81:         self.namespace = namespace\n82:         self.timeout = timeout\n83:         self.connect_timeout = connect_timeout\n84:         self.verbose = verbose\n85:         \n86:         log_level = \"DEBUG\" if verbose else \"INFO\"\n87:         self.logger = get_logger(__name__, level=log_level)\n88:         \n89:         self.router_url = router_url or os.getenv(\"ROUTER_URL\")\n90:         if not self.router_url:\n91:             raise ValueError(\n92:                 \"router_url must be provided or ROUTER_URL environment variable must be set\"\n93:             )\n94:         \n95:         self.workload_manager_url = workload_manager_url or os.getenv(\"WORKLOAD_MANAGER_URL\")\n96:         if not self.workload_manager_url:\n97:             raise ValueError(\n98:                 \"workload_manager_url must be provided or \"\n99:                 \"WORKLOAD_MANAGER_URL environment variable must be set\"\n100:             )\n101:         \n102:         self.session_id = session_id\n103:         \n104:         self.cp_client = ControlPlaneClient(\n105:             workload_manager_url=self.workload_manager_url,\n106:             namespace=self.namespace,\n107:             timeout=self.timeout,\n108:             connect_timeout=self.connect_timeout,\n109:             token_path=token_path,\n110:         )\n111:         \n112:         self.dp_client = CodeInterpreterDataPlaneClient(\n113:             router_url=self.router_url,\n114:             namespace=self.namespace,\n115:             timeout=self.timeout,\n116:             connect_timeout=self.connect_timeout,\n117:         )\n118:         \n119:         if not self.session_id:\n120:             self.session_id = self.cp_client.create_session()\n121:             self.logger.debug(f\"Created new session: {self.session_id}\")\n122:         else:\n123:             self.logger.debug(f\"Using provided session_id: {self.session_id}\")\n124:     \n125:     def __enter__(self) -> \"CodeInterpreterClient\":\n126:         \"\"\"Context manager entry.\n127:         \n128:         Returns:\n129:             self: The current CodeInterpreterClient instance\n130:         \"\"\"\n131:         return self\n132:     \n133:     def __exit__(self, exc_type: Any, exc_val: Any, exc_tb: Any) -> None:\n134:         \"\"\"Context manager exit - ensures cleanup.\n135:         \n136:         Args:\n137:             exc_type: Exception type if an exception was raised\n138:             exc_val: Exception value if an exception was raised\n139:             exc_tb: Exception traceback if an exception was raised\n140:         \"\"\"\n141:         self.close()\n142:     \n143:     def execute(\n144:         self,\n145:         code: str,\n146:         language: str = \"python\",\n147:         timeout: Optional[float] = None,\n148:     ) -> Dict[str, Any]:\n149:         \"\"\"Execute code in the code interpreter.\n150:         \n151:         Args:\n152:             code: Code to execute\n153:             language: Programming language (default: \"python\")\n154:             timeout: Optional per-call timeout override in seconds\n155:         \n156:         Returns:\n157:             Parsed JSON response from the code interpreter\n158:         \n159:         Raises:\n160:             ValueError: If session_id is not initialized\n161:             CommandExecutionError: If code execution returns non-zero exit code\n162:         \n163:         Example:\n164:             result = client.execute(\"x = 1 + 1; print(x)\")\n165:             print(result[\"output\"])\n166:         \"\"\"\n167:         if not self.session_id:\n168:             raise ValueError(\"CodeInterpreter session_id is not initialized\")\n169:         \n170:         self.logger.debug(f\"Executing code: {code[:100]}...\")\n171:         \n172:         response = self.dp_client.execute(\n173:             session_id=self.session_id,\n174:             code=code,\n175:             language=language,\n176:             timeout=timeout,\n177:         )\n178:         \n179:         result = response.json()\n180:         \n181:         if result.get(\"exit_code\", 0) != 0:\n182:             raise CommandExecutionError(\n183:                 command=code,\n184:                 exit_code=result.get(\"exit_code\", 0),\n185:                 output=result.get(\"output\", \"\"),\n186:             )\n187:         \n188:         return result\n189:     \n190:     def upload_file(\n191:         self,\n192:         file_path: str,\n193:         file_content: bytes,\n194:         timeout: Optional[float] = None,\n195:     ) -> Dict[str, Any]:\n196:         \"\"\"Upload a file to the code interpreter session.\n197:         \n198:         Args:\n199:             file_path: Path/filename for the uploaded file\n200:             file_content: File content as bytes\n201:             timeout: Optional per-call timeout override in seconds\n202:         \n203:         Returns:\n204:             Parsed JSON response from the upload operation\n205:         \n206:         Raises:\n207:             ValueError: If session_id is not initialized\n208:         \"\"\"\n209:         if not self.session_id:\n210:             raise ValueError(\"CodeInterpreter session_id is not initialized\")\n211:         \n212:         self.logger.debug(f\"Uploading file: {file_path}\")\n213:         \n214:         response = self.dp_client.upload_file(\n215:             session_id=self.session_id,\n216:             file_path=file_path,\n217:             file_content=file_content,\n218:             timeout=timeout,\n219:         )\n220:         \n221:         return response.json()\n222:     \n223:     def download_file(\n224:         self,\n225:         file_path: str,\n226:         timeout: Optional[float] = None,\n227:     ) -> bytes:\n228:         \"\"\"Download a file from the code interpreter session.\n229:         \n230:         Args:\n231:             file_path: Path/filename of the file to download\n232:             timeout: Optional per-call timeout override in seconds\n233:         \n234:         Returns:\n235:             File content as bytes\n236:         \n237:         Raises:\n238:             ValueError: If session_id is not initialized\n239:         \"\"\"\n240:         if not self.session_id:\n241:             raise ValueError(\"CodeInterpreter session_id is not initialized\")\n242:         \n243:         self.logger.debug(f\"Downloading file: {file_path}\")\n244:         \n245:         response = self.dp_client.download_file(\n246:             session_id=self.session_id,\n247:             file_path=file_path,\n248:             timeout=timeout,\n249:         )\n250:         \n251:         return response.content\n252:     \n253:     def close(self) -> None:\n254:         \"\"\"Close the client and release resources.\n255:         \n256:         This method closes both control plane and data plane HTTP sessions.\n257:         It also deletes the session if it was created by this client.\n258:         \"\"\"\n259:         self.logger.debug(\"Closing CodeInterpreterClient\")\n260:         \n261:         if self.dp_client:\n262:             self.dp_client.close()\n263:         \n264:         if self.cp_client:\n265:             if self.session_id:\n266:                 self.cp_client.delete_session(self.session_id)\n267:             self.cp_client.close()\n268:         \n269:         self.logger.debug(\"CodeInterpreterClient closed\")\n\n(End of file - total 269 lines)\n</content>","metadata":{"preview":"\"\"\"Code Interpreter Client for the agentcube SDK.\"\"\"\n\nimport logging\nimport os\nfrom typing import Any, Dict, Optional\n\nfrom .clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom .clients.control_plane import ControlPlaneClient\nfrom .exceptions import CommandExecutionError\nfrom .utils.log import get_logger\n\n\nclass CodeInterpreterClient:\n    \"\"\"High-level client for Code Interpreter operations.\n    \n    This client manages session lifecycle and provides a simplified\n    interface for code execution and file operations.\n    \n    Attributes:\n        namespace: Kubernetes namespace","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/code_interpreter.py","time":{"start":1775890306681,"end":1775890306706}}}}
