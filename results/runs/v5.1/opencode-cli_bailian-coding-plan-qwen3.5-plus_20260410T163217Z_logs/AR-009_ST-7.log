\n88: \tkind := resolver.resourceTypeToKind(\"codeinterpreters\")\n89: \tassert.Equal(t, \"CodeInterpreter\", kind)\n90: \n91: \tkind = resolver.resourceTypeToKind(\"CodeInterpreters\")\n92: \tassert.Equal(t, \"CodeInterpreter\", kind)\n93: }\n94: \n95: func TestResolver_ResourceTypeToKind_Invalid(t *testing.T) {\n96: \tresolver := NewResolver(&sync.Map{})\n97: \n98: \tkind := resolver.resourceTypeToKind(\"invalid\")\n99: \tassert.Equal(t, \"\", kind)\n100: }\n101: \n102: func TestResolver_Resolve_Success(t *testing.T) {\n103: \troutes := &sync.Map{}\n104: \tresolver := NewResolver(routes)\n105: \n106: \tentry := &RouteEntry{\n107: \t\tName:       \"test\",\n108: \t\tNamespace:  \"default\",\n109: \t\tKind:       \"AgentRuntime\",\n110: \t\tBackendURL: \"http://localhost:8080\",\n111: \t\tHealth:     HealthStatus{Healthy: true},\n112: \t}\n113: \n114: \tkey := routeKey(\"default\", \"AgentRuntime\", \"test\")\n115: \troutes.Store(key, entry)\n116: \n117: \treq := httptest.NewRequest(http.MethodGet, \"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/agentruntimes/test\", nil)\n118: \tresolved, err := resolver.Resolve(req)\n119: \n120: \tassert.NoError(t, err)\n121: \tassert.Equal(t, \"test\", resolved.Name)\n122: \tassert.Equal(t, \"default\", resolved.Namespace)\n123: \tassert.Equal(t, \"AgentRuntime\", resolved.Kind)\n124: }\n125: \n126: func TestResolver_Resolve_NotFound(t *testing.T) {\n127: \troutes := &sync.Map{}\n128: \tresolver := NewResolver(routes)\n129: \n130: \treq := httptest.NewRequest(http.MethodGet, \"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/agentruntimes/nonexistent\", nil)\n131: \t_, err := resolver.Resolve(req)\n132: \n133: \tassert.Error(t, err)\n134: \tassert.Equal(t, ErrRouteNotFound, err)\n135: }\n136: \n137: func TestResolver_Resolve_Unhealthy(t *testing.T) {\n138: \troutes := &sync.Map{}\n139: \tresolver := NewResolver(routes)\n140: \n141: \tentry := &RouteEntry{\n142: \t\tName:       \"test\",\n143: \t\tNa