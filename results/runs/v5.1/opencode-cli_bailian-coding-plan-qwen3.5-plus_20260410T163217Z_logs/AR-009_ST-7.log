ime\",\n48: \t\tBackendURL: backend.URL,\n49: \t\tHealth:     HealthStatus{Healthy: false},\n50: \t}\n51: \n52: \tkey := routeKey(\"default\", \"AgentRuntime\", \"test\")\n53: \troutes.Store(key, entry)\n54: \n55: \thttpClient := &http.Client{}\n56: \tchecker := NewHealthChecker(config, routes, httpClient)\n57: \n58: \tchecker.checkRoute(entry)\n59: \n60: \tassert.True(t, entry.Health.IsHealthy())\n61: \tassert.Equal(t, 0, entry.Health.GetConsecutiveFailures())\n62: }\n63: \n64: func TestHealthChecker_CheckHealth_Failure(t *testing.T) {\n65: \tconfig := DefaultRouterConfig()\n66: \tconfig.HealthCheckTimeout = 100 * time.Millisecond\n67: \troutes := &sync.Map{}\n68: \n69: \tentry := &RouteEntry{\n70: \t\tName:       \"test\",\n71: \t\tNamespace:  \"default\",\n72: \t\tKind:       \"AgentRuntime\",\n73: \t\tBackendURL: \"http://localhost:1\",\n74: \t\tHealth:     HealthStatus{Healthy: true},\n75: \t}\n76: \n77: \tkey := routeKey(\"default\", \"AgentRuntime\", \"test\")\n78: \troutes.Store(key, entry)\n79: \n80: \thttpClient := &http.Client{}\n81: \tchecker := NewHealthChecker(config, routes, httpClient)\n82: \n83: \tchecker.checkRoute(entry)\n84: \n85: \tassert.False(t, entry.Health.IsHealthy())\n86: \tassert.Greater(t, entry.Health.GetConsecutiveFailures(), 0)\n87: }\n88: \n89: func TestHealthChecker_MarkUnhealthy(t *testing.T) {\n90: \troutes := &sync.Map{}\n91: \thttpClient := &http.Client{}\n92: \tconfig := DefaultRouterConfig()\n93: \n94: \tchecker := NewHealthChecker(config, routes, httpClient)\n95: \n96: \tentry := &RouteEntry{\n97: \t\tName:       \"test\",\n98: \t\tNamespace:  \"default\",\n99: \t\tKind:       \"AgentRuntime\",\n100: \t\tBackendURL: \"http://localhost:8080\",\n101: \t\tHealth:     HealthStatus{Healthy: true},\n102: \t}\n103: \n104: \tchecker.MarkUnhealthy(entry)\n105: \n106: \tassert.False(t, entry.Health.IsHealthy())\n107: \tassert.Greater(t, entry.Health.GetConsecutiveFailures(), 0)\n108: }\n109: \n110: func TestHealthChecker_MarkHealthy(t *testing.T) {\n111: \troutes := &sync.Map{}\n112: \thttpClient := &http.Client{}\n113: \tconfig := DefaultRouterConfig()\n114: \n115: \tchecker := NewHealthChecker(config, routes, httpClient)\n116: \n117: \tentry := &RouteEntry{\n118: \t\tName:       \"test\",\n119: \t\tNamespace:  \"default\",\n120: \t\tKind:       \"AgentRuntime\",\n121: \t\tBackendURL: \"http://localhost:8080\",\n122: \t\tHealth:     HealthStatus{Healthy: false, ConsecutiveFailures: 5, Error: assert.AnError},\n123: \t}\n124: \n125: \tchecker.MarkHealthy(entry)\n126: \n127: \tassert.True(t, entry.Health.IsHealthy())\n128: \tassert.Equal(t, 0, entry.Health.GetConsecutiveFailures())\n129: \tassert.Nil(t, entry.Health.Error)\n130: }\n131: \n132: func TestHealthChecker_CheckAllRoutes(t *testing.T) {\n133: \tbackend1 := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n134: \t\tw.WriteHeader(http.StatusOK)\n135: \t}))\n136: \tdefer backend1.Close()\n137: \n138: \tbackend2 := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n139: \t\tw.WriteHeader(http.StatusOK)\n140: \t}))\n141: \tdefer backend2.Close()\n142: \n143: \tconfig := DefaultRouterConfig()\n144: \tconfig.HealthCheckTimeout = 5 * time.Second\n145: \troutes := &sync.Map{}\n146: \n147: \tentry1 := &RouteEntry{\n148: \t\tName:       \"test1\",\n149: \t\tNamespace:  \"default\",\n150: \t\tKind:       \"AgentRuntime\",\n151: \t\tBackendURL: backend1.URL,\n152: \t\tHealth:     HealthStatus{Healthy: false},\n153: \t}\n154: \n155: \tentry2 := &RouteEntry{\n156: \t\tName:       \"test2\",\n157: \t\tNamespace:  \"default\",\n158: \t\tKind:       \"CodeInterpreter\",\n159: \t\tBackendURL: backend2.URL,\n160: \t\tHealth:     HealthStatus{Healthy: false},\n161: \t}\n162: \n163: \troutes.Store(routeKey(\"default\", \"AgentRuntime\", \"test1\"), entry1)\n164: \troutes.Store(routeKey(\"default\", \"CodeInterpreter\", \"test2\"), entry2)\n165: \n166: \thttpClient := &http.Client{}\n167: \tchecker := NewHealthChecker(config, routes, httpClient)\n168: \n169: \tchecker.checkAllRoutes()\n170: \n171: \tassert.True(t, entry1.Health.IsHealthy())\n172: \tassert.True(t, entry2.Health.IsHealthy())\n173: }\n174: \n175: func TestHealthChecker_ConcurrentHealthChecks(t *testing.T) {\n176: \tbackend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n177: \t\ttime.Sleep(10 * time.Millisecond)\n178: \t\tw.WriteHeader(http.StatusOK)\n179: \t}))\n180: \tdefer backend.Close()\n181: \n182: \tconfig := DefaultRouterConfig()\n183: \tconfig.HealthCheckInterval = 50 * time.Millisecond\n184: \tconfig.HealthCheckTimeout = 5 * time.Second\n185: \troutes := &sync.Map{}\n186: \n187: \tfor i := 0; i < 10; i++ {\n188: \t\tentry := &RouteEntry{\n189: \t\t\tName:       \"test\",\n190: \t\t\tNamespace:  \"default\",\n191: \t\t\tKind:       \"AgentRuntime\",\n192: \t\t\tBackendURL: backend.URL,\n193: \t\t\tHealth:     HealthStatus{Healthy: true},\n194: \t\t}\n195: \t\troutes.Store(routeKey(\"default\", \"AgentRuntime\", \"test\"), entry)\n196: \t}\n197: \n198: \thttpClient := &http.Client{}\n199: \tchecker := NewHealthChecker(config, routes, httpClient)\n200: \n201: \tchecker.Start()\n202: \ttime.Sleep(200 * time.Millisecond)\n203: \tchecker.Stop()\n204: }\n\n(End of file - total 204 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestHealthChecker_New(t *testing.T) {\n\tconfig := DefaultRouterConfig()\n\troutes := &sync.Map{}\n\thttpClient := &http.Client{}\n\n\tchecker := NewHealthChecker(config, routes, httpClient)\n\tassert.NotNil(t, checker)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/health_test.go","time":{"start":1775849208122,"end":1775849208133}}}}
