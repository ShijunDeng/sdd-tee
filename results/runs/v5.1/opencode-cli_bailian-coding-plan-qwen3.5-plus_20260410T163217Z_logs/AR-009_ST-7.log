heme.Scheme); err != nil {\n44: \t\treturn nil, fmt.Errorf(\"failed to add runtime scheme: %w\", err)\n45: \t}\n46: \n47: \ttransport := &http.Transport{\n48: \t\tMaxConnsPerHost:     config.MaxConnsPerHost,\n49: \t\tMaxIdleConns:        100,\n50: \t\tMaxIdleConnsPerHost: 10,\n51: \t\tIdleConnTimeout:     90 * time.Second,\n52: \t}\n53: \n54: \thttpClient := &http.Client{\n55: \t\tTransport: transport,\n56: \t\tTimeout:   config.WriteTimeout,\n57: \t}\n58: \n59: \trouter := &Router{\n60: \t\tconfig:     config,\n61: \t\thttpClient: httpClient,\n62: \t\tstopCh:     make(chan struct{}),\n63: \t\troutes:     sync.Map{},\n64: \t}\n65: \n66: \trouter.resolver = NewResolver(&router.routes)\n67: \trouter.handler = NewHandler(router, router.resolver)\n68: \trouter.healthChecker = NewHealthChecker(config, &router.routes, httpClient)\n69: \n70: \treturn router, nil\n71: }\n72: \n73: func (r *Router) SetInformers(runtimeInformer, interpreterInformer cache.SharedIndexInformer) {\n74: \tr.runtimeInformer = runtimeInformer\n75: \tr.interpreterInformer = interpreterInformer\n76: \n77: \tif r.runtimeInformer != nil {\n78: \t\tr.runtimeInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n79: \t\t\tAddFunc:    r.onAgentRuntimeAdd,\n80: \t\t\tUpdateFunc: r.onAgentRuntimeUpdate,\n81: \t\t\tDeleteFunc: r.onAgentRuntimeDelete,\n82: \t\t})\n83: \t}\n84: \n85: \tif r.interpreterInformer != nil {\n86: \t\tr.interpreterInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n87: \t\t\tAddFunc:    r.onCodeInterpreterAdd,\n88: \t\t\tUpdateFunc: r.onCodeInterpreterUpdate,\n89: \t\t\tDeleteFunc: r.onCodeInterpreterDelete,\n90: \t\t})\n91: \t}\n92: }\n93: \n94: func (r *Router) onAgentRuntimeAdd(obj interface{}) {\n95: \trt, ok := obj.(*runtimev1alpha1.AgentRuntime)\n96: \tif !ok {\n97: \t\tklog.Errorf(\"Failed to convert object to AgentRuntime\")\n98: \t\treturn\n99: \t}\n100: \n101: \tif !r.shouldExpose(rt.Labels) {\n102: \t\tklog.V(4).Infof(\"AgentRuntime %s/%s is not exposed, skipping\", rt.Namespace, rt.Name)\n103: \t\treturn\n104: \t}\n105: \n106: \tbackendURL := r.extractBackendURLFromStatus(rt.Status.SandboxRef)\n107: \tif backendURL == \"\" {\n108: \t\tklog.V(4).Infof(\"AgentRuntime %s/%s has no backend URL, skipping\", rt.Namespace, rt.Name)\n109: \t\treturn\n110: \t}\n111: \n112: \tentry := &RouteEntry{\n113: \t\tName:       rt.Name,\n114: \t\tNamespace:  rt.Namespace,\n115: \t\tKind:       wmTypes.AgentRuntimeKind,\n116: \t\tBackendURL: backendURL,\n117: \t\tHealth:     HealthStatus{Healthy: true, LastCheck: time.Now()},\n118: \t\tUpdatedAt:  time.Now(),\n119: \t}\n120: \n121: \tkey := routeKey(rt.Namespace, rt.Kind, rt.Name)\n122: \tr.routes.Store(key, entry)\n123: \tklog.V(4).Infof(\"Added route for AgentRuntime %s/%s -> %s\", rt.Namespace, rt.Name, backendURL)\n124: }\n125: \n126: func (r *Router) onAgentRuntimeUpdate(oldObj, newObj interface{}) {\n127: \tr.onAgentRuntimeAdd(newObj)\n128: }\n129: \n130: func (r *Router) onAgentRuntimeDelete(obj interface{}) {\n131: \trt, ok := obj.(*runtimev1alpha1.AgentRuntime)\n132: \tif !ok {\n133: \t\ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n134: \t\tif !ok {\n135: \t\t\tklog.Errorf(\"Failed to convert object to AgentRuntime\")\n136: \t\t\treturn\n137: \t\t}\n138: \t\trt, ok = tombstone.Obj.(*runtimev1alpha1.AgentRuntime)\n139: \t\tif !ok {\n140: \t\t\tklog.Errorf(\"Failed to convert tombstone to AgentRuntime\")\n141: \t\t\treturn\n142: \t\t}\n143: \t}\n144: \n145: \tkey := routeKey(rt.Namespace, rt.Kind, rt.Name)\n146: \tr.routes.Delete(key)\n147: \tklog.V(4).Infof(\"Removed route for AgentRuntime %s/%s\", rt.Namespace, rt.Name)\n148: }\n149: \n150: func (r *Router) onCodeInterpreterAdd(obj interface{}) {\n151: \tci, ok := obj.(*runtimev1alpha1.CodeInterpreter)\n152: \tif !ok {\n153: \t\tklog.Errorf(\"Failed to convert object to CodeInterpreter\")\n154: \t\treturn\n155: \t}\n156: \n157: \tif !r.shouldExpose(ci.Labels) {\n158: \t\tklog.V(4).Infof(\"CodeInterpreter %s/%s is not exposed, skipping\", ci.Namespace, ci.Name)\n159: \t\treturn\n160: \t}\n161: \n162: \tbackendURL := r.extractBackendURLFromStatus(ci.Status.SandboxRef)\n163: \tif backendURL == \"\" {\n164: \t\tklog.V(4).Infof(\"CodeInterpreter %s/%s has no backend URL, skipping\", ci.Namespace, ci.Name)\n165: \t\treturn\n166: \t}\n167: \n168: \tentry := &RouteEntry{\n169: \t\tName:       ci.Name,\n170: \t\tNamespace:  ci.Namespace,\n171: \t\tKind:       wmTypes.CodeInterpreterKind,\n172: \t\tBackendURL: backendURL,\n173: \t\tHealth:     HealthStatus{Healthy: true, LastCheck: time.Now()},\n174: \t\tUpdatedAt:  time.Now(),\n175: \t}\n176: \n177: \tkey := routeKey(ci.Namespace, ci.Kind, ci.Name)\n178: \tr.routes.Store(key, entry)\n179: \tklog.V(4).Infof(\"Added route for CodeInterpreter %s/%s -> %s\", ci.Namespace, ci.Name, backendURL)\n180: }\n181: \n182: func (r *Router) onCodeInterpreterUpdate(oldObj, newObj interface{}) {\n183: \tr.onCodeInterpreterAdd(newObj)\n184: }\n185: \n186: func (r *Router) onCodeInterpreterDelete(obj interface{}) {\n187: \tci, ok := obj.(*runtimev1alpha1.CodeInterpreter)\n188: \tif !ok {\n189: \t\ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n190: \t\tif !ok {\n191: \t\t\tklog.Errorf(\"Failed to convert object to CodeInterpreter\")\n192: \t\t\treturn\n193: \t\t}\n194: \t\tci, ok = tombstone.Obj.(*runtimev1alpha1.CodeInterpreter)\n195: \t\tif !ok {\n196: \t\t\tklog.Errorf(\"Failed to convert tombstone to CodeInterpreter\")\n197: \t\t\treturn\n198: \t\t}\n199: \t}\n200: \n201: \tkey := routeKey(ci.Namespace, ci.Kind, ci.Name)\n202: \tr.routes.Delete(key)\n203: \tklog.V(4).Infof(\"Removed route for CodeInterpreter %s/%s\", ci.Namespace, ci.Name)\n204: }\n205: \n206: func (r *Router) shouldExpose(labels map[string]string) bool {\n207: \treturn labels[\"agentcube.volcano.sh/expose\"] == \"true\"\n208: }\n209: \n210: func (r *Router) extractBackendURLFromStatus(sandboxRef *corev1.ObjectReference) string {\n211: \tif sandboxRef == nil {\n212: \t\treturn \"\"\n213: \t}\n214: \n215: \tif sandboxRef.Name == \"\" {\n216: \t\treturn \"\"\n217: \t}\n218: \n219: \treturn fmt.Sprintf(\"http://%s.%s.svc.cluster.local:8080\", sandboxRef.Name, sandboxRef.Namespace)\n220: }\n221: \n222: func (r *Router) Start(ctx context.Context) error {\n223: \tr.healthChecker.Start()\n224: \n225: \tserver := &http.Server{\n226: \t\tAddr:         r.config.ListenAddr,\n227: \t\tHandler:      r.handler,\n228: \t\tReadTimeout:  r.config.ReadTimeout,\n229: \t\tWriteTimeout: r.config.WriteTimeout,\n230: \t\tIdleTimeout:  r.config.IdleTimeout,\n231: \t}\n232: \n233: \tr.wg.Add(1)\n234: \tgo func() {\n235: \t\tdefer r.wg.Done()\n236: \t\tklog.Infof(\"Router listening on %s\", r.config.ListenAddr)\n237: \t\tif err := server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n238: \t\t\tklog.Errorf(\"Router server error: %v\", err)\n239: \t\t}\n240: \t}()\n241: \n242: \treturn nil\n243: }\n244: \n245: func (r *Router) Shutdown(ctx context.Context) error {\n246: \tclose(r.stopCh)\n247: \tr.healthChecker.Stop()\n248: \n249: \tserver := &http.Server{\n250: \t\tAddr:         r.config.ListenAddr,\n251: \t\tReadTimeout:  r.config.ReadTimeout,\n252: \t\tWriteTimeout: r.config.WriteTimeout,\n253: \t\tIdleTimeout:  r.config.IdleTimeout,\n254: \t}\n255: \n256: \tif err := server.Shutdown(ctx); err != nil {\n257: \t\treturn fmt.Errorf(\"failed to shutdown server: %w\", err)\n258: \t}\n259: \n260: \tr.wg.Wait()\n261: \tklog.Info(\"Router shutdown complete\")\n262: \treturn nil\n263: }\n264: \n265: func (r *Router) ServeHTTP(w http.ResponseWriter, req *http.Request) {\n266: \tr.handler.ServeHTTP(w, req)\n267: }\n268: \n269: func (r *Router) GetRoute(namespace, kind, name string) (*RouteEntry, bool) {\n270: \tkey := routeKey(namespace, kind, name)\n271: \tentry, ok := r.routes.Load(key)\n272: \tif !ok {\n273: \t\treturn nil, false\n274: \t}\n275: \treturn entry.(*RouteEntry), true\n276: }\n277: \n278: func (r *Router) ListRoutes() []*RouteEntry {\n279: \tvar routes []*RouteEntry\n280: \tr.routes.Range(func(key, value interface{}) bool {\n281: \t\troutes = append(routes, value.(*RouteEntry))\n282: \t\treturn true\n283: \t})\n284: \treturn routes\n285: }\n286: \n287: func (r *Router) AddRoute(entry *RouteEntry) {\n288: \tkey := routeKey(entry.Namespace, entry.Kind, entry.Name)\n289: \tr.routes.Store(key, entry)\n290: \tklog.V(4).Infof(\"Manually added route for %s/%s/%s -> %s\", entry.Namespace, entry.Kind, entry.Name, entry.BackendURL)\n291: }\n292: \n293: func (r *Router) RemoveRoute(namespace, kind, name string) {\n294: \tkey := routeKey(namespace, kind, name)\n295: \tr.routes.Delete(key)\n296: \tklog.V(4).Infof(\"Manually removed route for %s/%s/%s\", namespace, kind, name)\n297: }\n\n(End of file - total 297 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/client-go/kubernetes/scheme\"\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype RouterInterface interface {\n\tStart(ctx context.Context) error\n\tShutdown(ctx context.Context) error","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router.go","time":{"start":1775849185240,"end":1775849185268}}}}
{"type":"tool_use","timestamp":1775849185272,"sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","part":{"id":"prt_d78dc115e0016NxWBZdvwBJpc6","messageID":"msg_d78dbfcf8001t2wA9uCeP7CBkO","sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","type":"tool","tool":"read","callID":"toolu_b8b5dc46263441988c4a2a07","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"errors\"\n7: \t\"fmt\"\n8: \t\"net\"\n9: \t\"net/http\"\n10: \t\"net/http/httputil\"\n11: \t\"net/url\"\n12: \t\"strings\"\n13: \t\"time\"\n14: \n15: \t\"k8s.io/klog/v2\"\n16: )\n17: \n18: type ErrorResponse struct {\n19: \tError     string `json:\"error\"`\n20: \tCode      string `json:\"code\"`\n21: \tRouteName string `json:\"routeName,omitempty\"`\n22: \tTimestamp string `json:\"timestamp\"`\n23: }\n24: \n25: type Handler struct {\n26: \trouter   *Router\n27: \tresolver *Resolver\n28: }\n29: \n30: func NewHandler(router *Router, resolver *Resolver) *Handler {\n31: \treturn &Handler{\n32: \t\trouter:   router,\n33: \t\tresolver: resolver,\n34: \t}\n35: }\n36: \n37: func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n38: \troute, err := h.resolver.Resolve(r)\n39: \tif err != nil {\n40: \t\th.writeError(w, err, http.StatusNotFound)\n41: \t\treturn\n42: \t}\n43: \n44: \tif err := h.ProxyRequest(w, r, route); err != nil {\n45: \t\th.writeError(w, err, http.StatusBadGateway)\n46: \t}\n47: }\n48: \n49: func (h *Handler) ProxyRequest(w http.ResponseWriter, r *http.Request, route *RouteEntry) error {\n50: \tbackendURL, err := url.Parse(route.BackendURL)\n51: \tif err != nil {\n52: \t\treturn fmt.Errorf(\"%w: %v\", ErrBackendConnection, err)\n53: \t}\n54: \n55: \tproxy := httputil.NewSingleHostReverseProxy(backendURL)\n56: \tproxy.ErrorHandler = func(w http.ResponseWriter, r *http.Request, err error) {\n57: \t\tklog.Errorf(\"Proxy error: %v\", err)\n58: \t\tw.WriteHeader(http.StatusBadGateway)\n59: \t}\n60: \n61: \tproxy.ModifyResponse = func(resp *http.Response) error {\n62: \t\tfor k, vv := range resp.Header {\n63: \t\t\tfor _, v := range vv {\n64: \t\t\t\tw.Header().Add(k, v)\n65: \t\t\t}\n66: \t\t}\n67: \t\treturn nil\n68: \t}\n69: \n70: \tr = h.AddForwardingHeaders(r)\n71: \tctx := r.Context()\n72: \tctx = context.WithValue(ctx, \"route\", route)\n73: \tr = r.WithContext(ctx)\n74: \n75: \tproxy.ServeHTTP(w, r)\n76: \treturn nil\n77: }\n78: \n79: func (h *Handler) AddForwardingHeaders(r *http.Request) *http.Request {\n80: \tclientIP, _, err := net.SplitHostPort(r.RemoteAddr)\n81: \tif err != nil {\n82: \t\tclientIP = r.RemoteAddr\n83: \t}\n84: \n85: \tr.Header.Set(\"X-Forwarded-For\", clientIP)\n86: \tr.Header.Set(\"X-Real-IP\", clientIP)\n87: \tr.Header.Set(\"X-Forwarded-Host\", r.Host)\n88: \tr.Header.Set(\"X-Forwarded-Proto\", r.URL.Scheme)\n89: \n90: \tif r.TLS != nil {\n91: \t\tr.Header.Set(\"X-Forwarded-Proto\", \"https\")\n92: \t} else {\n93: \t\tr.Header.Set(\"X-Forwarded-Proto\", \"http\")\n94: \t}\n95: \n96: \treturn r\n97: }\n98: \n99: func (h *Handler) writeError(w http.ResponseWriter, err error, statusCode int) {\n100: \tw.Header().Set(\"Content-Type\", \"application/json\")\n101: \tw.WriteHeader(statusCode)\n102: \n103: \tresp := ErrorResponse{\n104: \t\tError:     err.Error(),\n105: \t\tCode:      http.StatusText(statusCode),\n106: \t\tTimestamp: time.Now().Format(time.RFC3339),\n107: \t}\n108: \n109: \tif strings.Contains(err.Error(), \"route not found\") {\n110: \t\tresp.Code = \"RouteNotFound\"\n111: \t} else if strings.Contains(err.Error(), \"invalid resource type\") {\n112: \t\tresp.Code = \"InvalidResourceType\"\n113: \t\tw.WriteHeader(http.StatusBadRequest)\n114: \t} else if strings.Contains(err.Error(), \"malformed\") {\n115: \t\tresp.Code = \"MalformedPath\"\n116: \t\tw.WriteHeader(http.StatusBadRequest)\n117: \t} else if strings.Contains(err.Error(), \"no healthy backends\") {\n118: \t\tresp.Code = \"NoHealthyBackends\"\n119: \t\tw.WriteHeader(http.StatusServiceUnavailable)\n120: \t} else if strings.Contains(err.Error(), \"backend\") {\n121: \t\tresp.Code = \"BackendError\"\n122: \t\tw.WriteHeader(http.StatusBadGateway)\n123: \t}\n124: \n125: \tjson.NewEncoder(w).Encode(resp)\n126: }\n127: \n128: var (\n129: \tErrBackendConnection  = errors.New(\"failed to connect to backend\")\n130: \tErrBackendTimeout     = errors.New(\"backend timeout\")\n131: \tErrBackendUnavailable = errors.New(\"backend unavailable\")\n132: )\n\n(End of file - total 132 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n)\n\ntype ErrorResponse struct {\n\tError     string `json:\"error\"`\n\tCode      string `json:\"code\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler.go","time":{"start":1775849185242,"end":1775849185270}}}}
{"type":"tool_use","timestamp":1775849185273,"sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","part":{"id":"prt_d78dc1665001xy1rwq2X0t69rt","messageID":"msg_d78dbfcf8001t2wA9uCeP7CBkO","sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","type":"tool","tool":"read","callID":"toolu_4b71af00dae54c1199839619","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/types.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"sync\"\n5: \t\"time\"\n6: )\n7: \n8: type RouteEntry struct {\n9: \tName       string\n10: \tNamespace  string\n11: \tKind       string\n12: \tBackendURL string\n13: \tHealth     HealthStatus\n14: \tUpdatedAt  time.Time\n15: }\n16: \n17: type HealthStatus struct {\n18: \tHealthy             bool\n19: \tLastCheck           time.Time\n20: \tError               error\n21: \tConsecutiveFailures int\n22: \tmu                  sync.Mutex\n23: }\n24: \n25: func (hs *HealthStatus) MarkHealthy() {\n26: \ths.mu.Lock()\n27: \tdefer hs.mu.Unlock()\n28: \ths.Healthy = true\n29: \ths.Error = nil\n30: \ths.ConsecutiveFailures = 0\n31: \ths.LastCheck = time.Now()\n32: }\n33: \n34: func (hs *HealthStatus) MarkFailure(err error) {\n35: \ths.mu.Lock()\n36: \tdefer hs.mu.Unlock()\n37: \ths.Healthy = false\n38: \ths.Error = err\n39: \ths.ConsecutiveFailures++\n40: \ths.LastCheck = time.Now()\n41: }\n42: \n43: func (hs *HealthStatus) IsHealthy() bool {\n44: \ths.mu.Lock()\n45: \tdefer hs.mu.Unlock()\n46: \treturn hs.Healthy\n47: }\n48: \n49: func (hs *HealthStatus) GetConsecutiveFailures() int {\n50: \ths.mu.Lock()\n51: \tdefer hs.mu.Unlock()\n52: \treturn hs.ConsecutiveFailures\n53: }\n54: \n55: func routeKey(namespace, kind, name string) string {\n56: \treturn namespace + \"/\" + kind + \"/\" + name\n57: }\n\n(End of file - total 57 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"sync\"\n\t\"time\"\n)\n\ntype RouteEntry struct {\n\tName       string\n\tNamespace  string\n\tKind       string\n\tBackendURL string\n\tHealth     HealthStatus\n\tUpdatedAt  time.Time\n}\n\ntype HealthStatus struct {\n\tHealthy             bool\n\tLastCheck           time.Time\n\tError               error","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/types.go","time":{"start":1775849185245,"end":1775849185272}}}}
{"type":"tool_use","timestamp":1775849185274,"sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","part":{"id":"prt_d78dc1b4e001PAKMel5qRjT7Dv","messageID":"msg_d78dbfcf8001t2wA9uCeP7CBkO","sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","type":"tool","tool":"read","callID":"toolu_a57ded8824f7497ab5372b8b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/config.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/config.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"time\"\n5: \n6: \t\"k8s.io/client-go/rest\"\n7: )\n8: \n9: type RouterConfig struct {\n10: \tKubeConfig          *rest.Config\n11: \tListenAddr          string\n12: \tReadTimeout         time.Duration\n13: \tWriteTimeout        time.Duration\n14: \tIdleTimeout         time.Duration\n15: \tMaxConnsPerHost     int\n16: \tHealthCheckInterval time.Duration\n17: \tHealthCheckTimeout  time.Duration\n18: \tUnhealthyThreshold  int\n19: \tNamespace           string\n20: }\n21: \n22: func DefaultRouterConfig() *RouterConfig {\n23: \treturn &RouterConfig{\n24: \t\tListenAddr:          \":8080\",\n25: \t\tReadTimeout:         15 * time.Second,\n26: \t\tWriteTimeout:        30 * time.Second,\n27: \t\tIdleTimeout:         60 * time.Second,\n28: \t\tMaxConnsPerHost:     100,\n29: \t\tHealthCheckInterval: 10 * time.Second,\n30: \t\tHealthCheckTimeout:  5 * time.Second,\n31: \t\tUnhealthyThreshold:  3,\n32: \t\tNamespace:           \"\",\n33: \t}\n34: }\n\n(End of file - total 34 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"time\"\n\n\t\"k8s.io/client-go/rest\"\n)\n\ntype RouterConfig struct {\n\tKubeConfig          *rest.Config\n\tListenAddr          string\n\tReadTimeout         time.Duration\n\tWriteTimeout        time.Duration\n\tIdleTimeout         time.Duration\n\tMaxConnsPerHost     int\n\tHealthCheckInterval time.Duration\n\tHealthCheckTimeout  time.Duration\n\tUnhealthyThreshold  int\n\tNamespace           string\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/config.go","time":{"start":1775849185247,"end":1775849185273}}}}
{"type":"tool_use","timestamp":1775849185278,"sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","part":{"id":"prt_d78dc07450010rragUVcHxXuUq","messageID":"msg_d78dbfcf8001t2wA9uCeP7CBkO","sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","type":"tool","tool":"read","callID":"toolu_a11ee772cbc64854bec3b9c1","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/design.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/design.md</path>\n<type>file</type>\n<content>\n1: # Design: AR-009 Router HTTP Reverse Proxy Core\n2: \n3: ## Overview\n4: \n5: This document describes the technical implementation for the Router module (`pkg/router`) that acts as an HTTP reverse proxy, routing incoming requests to appropriate AgentRuntime or CodeInterpreter backends based on Kubernetes CRD resources.\n6: \n7: ## Architecture\n8: \n9: ### Component Structure\n10: \n11: ```\n12: pkg/router/\n13: ├── router.go                   # Main router implementation\n14: ├── router_test.go             # Unit tests\n15: ├── handler.go                 # HTTP handler for proxy requests\n16: ├── handler_test.go            # Handler tests\n17: ├── resolver.go                # Route resolution logic\n18: ├── resolver_test.go           # Resolver tests\n19: ├── health.go                  # Health check manager\n20: ├── health_test.go             # Health check tests\n21: ├── config.go                  # Configuration structures\n22: └── types.go                   # Type definitions\n23: ```\n24: \n25: ### Integration Points\n26: \n27: - **Clientset**: Uses generated `versioned.Clientset` for `runtime.agentcube.volcano.sh/v1alpha1`\n28: - **Informers**: Watches `AgentRuntime` and `CodeInterpreter` resources via `SharedInformerFactory`\n29: - **Listers**: Provides cached read access for route resolution\n30: - **HTTP Client**: Reusable connection pool for backend requests\n31: \n32: ### High-Level Flow\n33: \n34: ```\n35: ┌─────────────┐     ┌──────────────┐     ┌─────────────┐     ┌─────────────────┐\n36: │   Client    │────▶│   Handler    │────▶│  Resolver   │────▶│  RouteEntry     │\n37: │             │     │              │     │             │     │  (from routes)  │\n38: └─────────────┘     └──────────────┘     └─────────────┘     └─────────────────┘\n39:                            │                                          │\n40:                            ▼                                          ▼\n41:                     ┌──────────────┐                          ┌─────────────────┐\n42:                     │   Router     │                          │  Backend URL    │\n43:                     │  (manages    │                          │  (proxy target) │\n44:                     │   routes)    │                          │                 │\n45:                     └──────────────┘                          └─────────────────┘\n46:                            │\n47:                            ▼\n48:                     ┌──────────────┐\n49:                     │  Informers   │\n50:                     │  (watch CRs) │\n51:                     └──────────────┘\n52: ```\n53: \n54: ## Data Structures\n55: \n56: ### Router\n57: \n58: ```go\n59: type Router struct {\n60:     config          *RouterConfig\n61:     routes          sync.Map // map[string]*RouteEntry\n62:     httpClient      *http.Client\n63:     kubeClient      *versioned.Clientset\n64:     informerFactory informers.SharedInformerFactory\n65:     runtimeInformer v1alpha1.AgentRuntimeInformer\n66:     interpreterInformer v1alpha1.CodeInterpreterInformer\n67:     stopCh          chan struct{}\n68:     wg              sync.WaitGroup\n69:     mu              sync.RWMutex\n70: }\n71: ```\n72: \n73: ### RouterConfig\n74: \n75: ```go\n76: type RouterConfig struct {\n77:     KubeConfig          *rest.Config\n78:     ListenAddr          string\n79:     ReadTimeout         time.Duration\n80:     WriteTimeout        time.Duration\n81:     IdleTimeout         time.Duration\n82:     MaxConnsPerHost     int\n83:     HealthCheckInterval time.Duration\n84:     HealthCheckTimeout  time.Duration\n85:     UnhealthyThreshold  int\n86:     Namespace           string // empty means all namespaces\n87: }\n88: ```\n89: \n90: ### RouteEntry\n91: \n92: ```go\n93: type RouteEntry struct {\n94:     Name       string\n95:     Namespace  string\n96:     Kind       string // \"AgentRuntime\" or \"CodeInterpreter\"\n97:     BackendURL string\n98:     Health     HealthStatus\n99:     UpdatedAt  time.Time\n100: }\n101: ```\n102: \n103: ### HealthStatus\n104: \n105: ```go\n106: type HealthStatus struct {\n107:     Healthy             bool\n108:     LastCheck           time.Time\n109:     Error               error\n110:     ConsecutiveFailures int\n111:     mu                  sync.Mutex\n112: }\n113: ```\n114: \n115: ### RouteKey\n116: \n117: ```go\n118: // routeKey generates unique key for route storage\n119: func routeKey(namespace, kind, name string) string {\n120:     return fmt.Sprintf(\"%s/%s/%s\", namespace, kind, name)\n121: }\n122: ```\n123: \n124: ## API Contracts\n125: \n126: ### Incoming Request Format\n127: \n128: **Path Pattern:**\n129: ```\n130: /apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/{resourceType}/{name}[/{subpath}]\n131: ```\n132: \n133: **Resource Types:**\n134: - `agentruntimes` → Maps to AgentRuntime CR\n135: - `codeinterpreters` → Maps to CodeInterpreter CR\n136: \n137: **Headers (added by router):**\n138: - `X-Forwarded-For`: Client IP\n139: - `X-Real-IP`: Client IP\n140: - `X-Forwarded-Host`: Original host\n141: - `X-Forwarded-Proto`: Request scheme\n142: \n143: ### Processor Interface\n144: \n145: ```go\n146: type RouterInterface interface {\n147:     Start(ctx context.Context) error\n148:     Shutdown(ctx context.Context) error\n149:     ServeHTTP(w http.ResponseWriter, r *http.Request)\n150: }\n151: ```\n152: \n153: ### Resolve Operation\n154: \n155: **Input**: `*http.Request`\n156: \n157: **Output**: `*RouteEntry` or error\n158: \n159: **Behavior**:\n160: 1. Parse namespace, resourceType, name from path\n161: 2. Look up route from `routes` sync.Map\n162: 3. Check backend health status\n163: 4. Return RouteEntry or error\n164: \n165: ### Proxy Operation\n166: \n167: **Input**: `http.ResponseWriter`, `*http.Request`, `*RouteEntry`\n168: \n169: **Output**: error\n170: \n171: **Behavior**:\n172: 1. Build backend URL from RouteEntry.BackendURL\n173: 2. Clone request with new context\n174: 3. Add forwarding headers\n175: 4. Execute request via `httpClient.Do()`\n176: 5. Copy response headers and body\n177: 6. Handle errors appropriately\n178: \n179: ## Error Handling\n180: \n181: ### Error Types\n182: \n183: ```go\n184: var (\n185:     ErrRouteNotFound      = errors.New(\"route not found\")\n186:     ErrNoHealthyBackends  = errors.New(\"no healthy backends available\")\n187:     ErrInvalidResourceType = errors.New(\"invalid resource type\")\n188:     ErrMalformedPath      = errors.New(\"malformed request path\")\n189: )\n190: \n191: var (\n192:     ErrBackendConnection  = errors.New(\"failed to connect to backend\")\n193:     ErrBackendTimeout     = errors.New(\"backend timeout\")\n194:     ErrBackendUnavailable = errors.New(\"backend unavailable\")\n195: )\n196: ```\n197: \n198: ### Error Response Format\n199: \n200: ```go\n201: type ErrorResponse struct {\n202:     Error       string `json:\"error\"`\n203:     Code        string `json:\"code\"`\n204:     RouteName   string `json:\"routeName,omitempty\"`\n205:     Timestamp   string `json:\"timestamp\"`\n206: }\n207: ```\n208: \n209: ### HTTP Status Codes\n210: \n211: | Scenario | Status Code |\n212: |----------|-------------|\n213: | Route not found | 404 |\n214: | Invalid resource type | 400 |\n215: | Malformed path | 400 |\n216: | Backend unavailable | 502 |\n217: | No healthy backends | 503 |\n218: | Backend timeout | 504 |\n219: \n220: ### Retry Strategy\n221: \n222: - **Connection errors**: Retry with next healthy backend (max 2 retries)\n223: - **Timeout**: Mark backend unhealthy, return 504\n224: - **Permanent errors** (4xx from backend): Return immediately\n225: \n226: ### Health Check Failure Policy\n227: \n228: ```\n229: Consecutive Failures → Action\n230: 3                   → Mark unhealthy, remove from rotation\n231: 1                   → Continue serving, log warning\n232: Recovery (1 success) → Mark healthy, restore to rotation\n233: ```\n234: \n235: ## Testing Strategy\n236: \n237: ### Unit Tests\n238: \n239: **File**: `router/router_test.go`\n240: \n241: ```go\n242: // Test cases:\n243: func TestRouter_Start(t *testing.T)\n244: func TestRouter_Shutdown(t *testing.T)\n245: func TestRouter_ServeHTTP(t *testing.T)\n246: func TestRouter_routeKey(t *testing.T)\n247: ```\n248: \n249: **File**: `router/resolver_test.go`\n250: \n251: ```go\n252: // Test cases:\n253: func TestResolver_ResolveRoute_Success(t *testing.T)\n254: func TestResolver_ResolveRoute_NotFound(t *testing.T)\n255: func TestResolver_ResolveRoute_Unhealthy(t *testing.T)\n256: func TestResolver_ParsePath(t *testing.T)\n257: ```\n258: \n259: **File**: `router/health_test.go`\n260: \n261: ```go\n262: // Test cases:\n263: func TestHealthChecker_CheckHealth_Success(t *testing.T)\n264: func TestHealthChecker_CheckHealth_Failure(t *testing.T)\n265: func TestHealthChecker_MarkUnhealthy(t *testing.T)\n266: func TestHealthChecker_MarkHealthy(t *testing.T)\n267: ```\n268: \n269: **File**: `router/handler_test.go`\n270: \n271: ```go\n272: // Test cases:\n273: func TestHandler_ProxyRequest_Success(t *testing.T)\n274: func TestHandler_ProxyRequest_BackendError(t *testing.T)\n275: func TestHandler_ProxyRequest_Timeout(t *testing.T)\n276: func TestHandler_AddForwardingHeaders(t *testing.T)\n277: ```\n278: \n279: ### Test Fixtures\n280: \n281: ```go\n282: func newTestRouteEntry(name, namespace, backendURL string) *RouteEntry {\n283:     return &RouteEntry{\n284:         Name:       name,\n285:         Namespace:  namespace,\n286:         Kind:       \"AgentRuntime\",\n287:         BackendURL: backendURL,\n288:         Health:     HealthStatus{Healthy: true},\n289:         UpdatedAt:  time.Now(),\n290:     }\n291: }\n292: \n293: func newTestRouterConfig() *RouterConfig {\n294:     return &RouterConfig{\n295:         ListenAddr:          \":8080\",\n296:         ReadTimeout:         15 * time.Second,\n297:         WriteTimeout:        30 * time.Second,\n298:         IdleTimeout:         60 * time.Second,\n299:         HealthCheckInterval: 10 * time.Second,\n300:         HealthCheckTimeout:  5 * time.Second,\n301:         UnhealthyThreshold:  3,\n302:     }\n303: }\n304: ```\n305: \n306: ### Mock Setup\n307: \n308: ```go\n309: // Fake kube client for testing\n310: func newFakeKubeClient(objects ...runtime.Object) *versioned.Clientset {\n311:     return fake.NewSimpleClientset(objects...)\n312: }\n313: \n314: // Mock backend server\n315: func newMockBackend(handler http.HandlerFunc) *httptest.Server {\n316:     return httptest.NewServer(handler)\n317: }\n318: ```\n319: \n320: ### Integration Tests\n321: \n322: **File**: `router/router_integration_test.go`\n323: \n324: ```go\n325: // Test scenarios (requires kind cluster):\n326: // 1. CRD creation triggers route addition\n327: // 2. CRD deletion triggers route removal\n328: // 3. End-to-end request routing\n329: // 4. Health check removes unhealthy backend\n330: // 5. Concurrent request handling\n331: ```\n332: \n333: ### Coverage Requirements\n334: \n335: - Route resolution: 100%\n336: - Proxy handler: 100%\n337: - Health check: 100%\n338: - Error handling paths: 100%\n339: - Overall: ≥85%\n340: \n341: ## Implementation Notes\n342: \n343: ### Route Key Format\n344: \n345: Routes stored in sync.Map with key: `{namespace}/{kind}/{name}`\n346: - Kind is lowercased: `agentruntime` or `codeinterpreter`\n347: \n348: ### Labels Monitored\n349: \n350: Informer filters resources with labels:\n351: - `agentcube.volcano.sh/expose: \"true\"` (only exposed resources are routed)\n352: \n353: ### Backend URL Discovery\n354: \n355: Backend URL extracted from CR spec:\n356: - AgentRuntime: `.spec.endpoint`\n357: - CodeInterpreter: `.spec.serviceURL`\n358: \n359: ### Connection Pooling\n360: \n361: HTTP client configured with:\n362: ```go\n363: &http.Transport{\n364:     MaxConnsPerHost:     config.MaxConnsPerHost,\n365:     MaxIdleConns:        100,\n366:     MaxIdleConnsPerHost: 10,\n367:     IdleConnTimeout:     90 * time.Second,\n368: }\n369: ```\n370: \n371: ### Graceful Shutdown\n372: \n373: 1. Stop accepting new connections\n374: 2. Close idle connections\n375: 3. Wait for in-flight requests (max 30s)\n376: 4. Stop informers\n377: 5. Close Kubernetes client\n\n(End of file - total 377 lines)\n</content>","metadata":{"preview":"# Design: AR-009 Router HTTP Reverse Proxy Core\n\n## Overview\n\nThis document describes the technical implementation for the Router module (`pkg/router`) that acts as an HTTP reverse proxy, routing incoming requests to appropriate AgentRuntime or CodeInterpreter backends based on Kubernetes CRD resources.\n\n## Architecture\n\n### Component Structure\n\n```\npkg/router/\n├── router.go                   # Main router implementation\n├── router_test.go             # Unit tests\n├── handler.go                 # HTTP handler for proxy requests\n├── handler_test.go            # Handler tests\n├── resolver.go                # Route resolution logic\n├── resolver_test.go           # Resolver tests\n├── health.go                  # Health check manager\n├── health_test.go             # Health check tests","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/design.md","time":{"start":1775849185236,"end":1775849185275}}}}
