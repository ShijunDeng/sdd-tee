t.Equal(t, \":9090\", config.ListenAddr)\n41: \tassert.Equal(t, 10*time.Second, config.ReadTimeout)\n42: \tassert.Equal(t, 5, config.UnhealthyThreshold)\n43: \tassert.Equal(t, \"default\", config.Namespace)\n44: }\n45: \n46: func TestRouter_NewRouter_NilConfig(t *testing.T) {\n47: \tconfig := &RouterConfig{\n48: \t\tKubeConfig: nil,\n49: \t}\n50: \n51: \trouter, err := NewRouter(config)\n52: \tassert.Error(t, err)\n53: \tassert.Nil(t, router)\n54: \tassert.Contains(t, err.Error(), \"kubeconfig is required\")\n55: }\n56: \n57: func TestRouter_routeKey(t *testing.T) {\n58: \tkey := routeKey(\"default\", \"AgentRuntime\", \"test-runtime\")\n59: \tassert.Equal(t, \"default/AgentRuntime/test-runtime\", key)\n60: }\n61: \n62: func TestRouteEntry_HealthStatus(t *testing.T) {\n63: \tentry := &RouteEntry{\n64: \t\tName:       \"test\",\n65: \t\tNamespace:  \"default\",\n66: \t\tKind:       \"AgentRuntime\",\n67: \t\tBackendURL: \"http://localhost:8080\",\n68: \t\tHealth:     HealthStatus{Healthy: true},\n69: \t\tUpdatedAt:  time.Now(),\n70: \t}\n71: \n72: \tassert.True(t, entry.Health.IsHealthy())\n73: \tassert.Equal(t, 0, entry.Health.GetConsecutiveFailures())\n74: }\n75: \n76: func TestHealthStatus_MarkHealthy(t *testing.T) {\n77: \ths := &HealthStatus{\n78: \t\tHealthy:             false,\n79: \t\tConsecutiveFailures: 5,\n80: \t\tError:               assert.AnError,\n81: \t}\n82: \n83: \ths.MarkHealthy()\n84: \n85: \tassert.True(t, hs.Healthy)\n86: \tassert.Nil(t, hs.Error)\n87: \tassert.Equal(t, 0, hs.ConsecutiveFailures)\n88: }\n89: \n90: func TestHealthStatus_MarkFailure(t *testing.T) {\n91: \ths := &HealthStatus{\n92: \t\tHealthy:             true,\n93: \t\tConsecutiveFailures: 0,\n94: \t}\n95: \n96: \terr := assert.AnError\n97: \ths.MarkFailure(err)\n98: \n99: \tassert.False(t, hs.Healthy)\n100: \tassert.Equal(t, err, hs.Error)\n101: \tassert.Equal(t, 1, hs.ConsecutiveFailures)\n102: }\n103: \n104: func TestHealthStatus_ConcurrentAccess(t *testing.T) {\n105: \ths := &HealthStatus{Healthy: true}\n106: \n107: \tvar wg sync.WaitGroup\n108: \tfor i := 0; i < 100; i++ {\n109: \t\twg.Add(1)\n110: \t\tgo func() {\n111: \t\t\tdefer wg.Done()\n112: \t\t\ths.MarkHealthy()\n113: \t\t\ths.MarkFailure(assert.AnError)\n114: \t\t\ths.IsHealthy()\n115: \t\t\ths.GetConsecutiveFailures()\n116: \t\t}()\n117: \t}\n118: \n119: \twg.Wait()\n120: }\n121: \n122: func TestRouter_Start(t *testing.T) {\n123: \tconfig := DefaultRouterConfig()\n124: \tconfig.ListenAddr = \":0\"\n125: \tconfig.KubeConfig = &rest.Config{\n126: \t\tHost: \"http://localhost:8080\",\n127: \t}\n128: \n129: \trouter, err := NewRouter(config)\n130: \tassert.NoError(t, err)\n131: \tassert.NotNil(t, router)\n132: }\n133: \n134: func TestRouter_GetRoute(t *testing.T) {\n135: \trouter := &Router{\n136: \t\troutes: sync.Map{},\n137: \t}\n138: \n139: \tentry := &RouteEntry{\n140: \t\tName:       \"test\",\n141: \t\tNamespace:  \"default\",\n142: \t\tKind:       \"AgentRuntime\",\n143: \t\tBackendURL: \"http://localhost:8080\",\n144: \t}\n145: \n146: \tkey := routeKey(\"default\", \"AgentRuntime\", \"test\")\n147: \trouter.routes.Store(key, entry)\n148: \n149: \tfound, ok := router.GetRoute(\"default\", \"AgentRuntime\", \"test\")\n150: \tassert.True(t, ok)\n151: \tassert.Equal(t, \"test\", found.Name)\n152: \n153: \t_, ok = router.GetRoute(\"default\", \"AgentRuntime\", \"nonexistent\")\n154: \tassert.False(t, ok)\n155: }\n156: \n157: func TestRouter_ListRoutes(t *testing.T) {\n158: \trouter := &Router{\n159: \t\troutes: sync.Map{},\n160: \t}\n161: \n162: \trouter.AddRoute(&RouteEntry{\n163: \t\tName:       \"test1\",\n164: \t\tNamespace:  \"default\",\n165: \t\tKind:       \"AgentRuntime\",\n166: \t\tBackendURL: \"http://localhost:8080\",\n167: \t})\n168: \n169: \trouter.AddRoute(&RouteEntry{\n170: \t\tName:       \"test2\",\n171: \t\tNamespace:  \"default\",\n172: \t\tKind:       \"CodeInterpreter\",\n173: \t\tBackendURL: \"http://localhost:8081\",\n174: \t})\n175: \n176: \troutes := router.ListRoutes()\n177: \tassert.Len(t, routes, 2)\n178: }\n179: \n180: func TestRouter_AddRoute(t *testing.T) {\n181: \trouter := &Router{\n182: \t\troutes: sync.Map{},\n183: \t}\n184: \n185: \tentry := &RouteEntry{\n186: \t\tName:       \"test\",\n187: \t\tNamespace:  \"default\",\n188: \t\tKind:       \"AgentRuntime\",\n189: \t\tBackendURL: \"http://localhost:8080\",\n190: \t}\n191: \n192: \trouter.AddRoute(entry)\n193: \n194: \tfound, ok := router.GetRoute(\"default\", \"AgentRuntime\", \"test\")\n195: \tassert.True(t, ok)\n196: \tassert.Equal(t, \"test\", found.Name)\n197: }\n198: \n199: func TestRouter_RemoveRoute(t *testing.T) {\n200: \trouter := &Router{\n201: \t\troutes: sync.Map{},\n202: \t}\n203: \n204: \trouter.AddRoute(&RouteEntry{\n205: \t\tName:       \"test\",\n206: \t\tNamespace:  \"default\",\n207: \t\tKind:       \"AgentRuntime\",\n208: \t\tBackendURL: \"http://localhost:8080\",\n209: \t})\n210: \n211: \t_, ok := router.GetRoute(\"default\", \"AgentRuntime\", \"test\")\n212: \tassert.True(t, ok)\n213: \n214: \trouter.RemoveRoute(\"default\", \"AgentRuntime\", \"test\")\n215: \n216: \t_, ok = router.GetRoute(\"default\", \"AgentRuntime\", \"test\")\n217: \tassert.False(t, ok)\n218: }\n219: \n220: func TestRouter_Shutdown(t *testing.T) {\n221: \tconfig := DefaultRouterConfig()\n222: \tconfig.ListenAddr = \":0\"\n223: \tconfig.KubeConfig = &rest.Config{\n224: \t\tHost: \"http://localhost:8080\",\n225: \t}\n226: \n227: \trouter, err := NewRouter(config)\n228: \tassert.NoError(t, err)\n229: \tassert.NotNil(t, router)\n230: }\n\n(End of file - total 230 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"k8s.io/client-go/rest\"\n)\n\nfunc TestRouterConfig_Default(t *testing.T) {\n\tconfig := DefaultRouterConfig()\n\n\tassert.Equal(t, \":8080\", config.ListenAddr)\n\tassert.Equal(t, 15*time.Second, config.ReadTimeout)\n\tassert.Equal(t, 30*time.Second, config.WriteTimeout)\n\tassert.Equal(t, 60*time.Second, config.IdleTimeout)\n\tassert.Equal(t, 100, config.MaxConnsPerHost)\n\tassert.Equal(t, 10*time.Second, config.HealthCheckInterval)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router_test.go","time":{"start":1775849202462,"end":1775849202472}}}}
{"type":"tool_use","timestamp":1775849202476,"sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","part":{"id":"prt_d78dc5e0a001iRtOfj4SOQaiVC","messageID":"msg_d78dc4fcc001lHlVH9Wk88uTmD","sessionID":"ses_2872415a6ffelgbf4QRW7wMnzS","type":"tool","tool":"read","callID":"toolu_950e3f0ce5dd4ff9bef28e5c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"crypto/tls\"\n5: \t\"net/http\"\n6: \t\"net/http/httptest\"\n7: \t\"strings\"\n8: \t\"sync\"\n9: \t\"testing\"\n10: \n11: \t\"github.com/stretchr/testify/assert\"\n12: )\n13: \n14: func TestHandler_NewHandler(t *testing.T) {\n15: \trouter := &Router{\n16: \t\troutes: sync.Map{},\n17: \t}\n18: \tresolver := NewResolver(&router.routes)\n19: \n20: \thandler := NewHandler(router, resolver)\n21: \tassert.NotNil(t, handler)\n22: }\n23: \n24: func TestHandler_ServeHTTP_Success(t *testing.T) {\n25: \tbackend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n26: \t\tw.WriteHeader(http.StatusOK)\n27: \t\tw.Write([]byte(\"OK\"))\n28: \t}))\n29: \tdefer backend.Close()\n30: \n31: \trouter := &Router{\n32: \t\troutes: sync.Map{},\n33: \t}\n34: \n35: \tentry := &RouteEntry{\n36: \t\tName:       \"test\",\n37: \t\tNamespace:  \"default\",\n38: \t\tKind:       \"AgentRuntime\",\n39: \t\tBackendURL: backend.URL,\n40: \t\tHealth:     HealthStatus{Healthy: true},\n41: \t}\n42: \n43: \trouter.routes.Store(routeKey(\"default\", \"AgentRuntime\", \"test\"), entry)\n44: \n45: \tresolver := NewResolver(&router.routes)\n46: \thandler := NewHandler(router, resolver)\n47: \n48: \treq := httptest.NewRequest(http.MethodGet, \"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/agentruntimes/test\", nil)\n49: \tw := httptest.NewRecorder()\n50: \n51: \thandler.ServeHTTP(w, req)\n52: \n53: \tassert.Equal(t, http.StatusOK, w.Code)\n54: \tassert.Contains(t, w.Body.String(), \"OK\")\n55: }\n56: \n57: func TestHandler_ServeHTTP_RouteNotFound(t *testing.T) {\n58: \trouter := &Router{\n59: \t\troutes: sync.Map{},\n60: \t}\n61: \n62: \tresolver := NewResolver(&router.routes)\n63: \thandler := NewHandler(router, resolver)\n64: \n65: \treq := httptest.NewRequest(http.MethodGet, \"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/agentruntimes/nonexistent\", nil)\n66: \tw := httptest.NewRecorder()\n67: \n68: \thandler.ServeHTTP(w, req)\n69: \n70: \tassert.Equal(t, http.StatusNotFound, w.Code)\n71: \tassert.Contains(t, w.Body.String(), \"route not found\")\n72: }\n73: \n74: func TestHandler_ServeHTTP_InvalidResourceType(t *testing.T) {\n75: \trouter := &Router{\n76: \t\troutes: sync.Map{},\n77: \t}\n78: \n79: \tresolver := NewResolver(&router.routes)\n80: \thandler := NewHandler(router, resolver)\n81: \n82: \treq := httptest.NewRequest(http.MethodGet, \"/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/default/invalid/test\", nil)\n83: \tw := httptest.NewRecorder()\n84: \n85: \thandler.ServeHTTP(w, req)\n86: \n87: \tassert.Equal(t, http.StatusNotFound, w.Code)\n88: \tassert.Contains(t, w.Body.String(), \"invalid resource type\")\n89: }\n90: \n91: func TestHandler_ServeHTTP_MalformedPath(t *testing.T) {\n92: \trouter := &Router{\n93: \t\troutes: sync.Map{},\n94: \t}\n95: \n96: \tresolver := NewResolver(&router.routes)\n97: \thandler := NewHandler(router, resolver)\n98: \n99: \treq := httptest.NewRequest(http.MethodGet, \"/invalid/path\", nil)\n100: \tw := httptest.NewRecorder()\n101: \n102: \thandler.ServeHTTP(w, req)\n103: \n104: \tassert.Equal(t, http.StatusNotFound, w.Code)\n105: \tassert.Contains(t, w.Body.String(), \"malformed\")\n106: }\n107: \n108: func TestHandler_ProxyRequest_Success(t *testing.T) {\n109: \tbackend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n110: \t\tassert.Equal(t, \"/api/test\", r.URL.Path)\n111: \t\tw.Header().Set(\"X-Custom-Header\", \"value\")\n112: \t\tw.WriteHeader(http.StatusCreated)\n113: \t\tw.Write([]byte(\"created\"))\n114: \t}))\n115: \tdefer backend.Close()\n116: \n117: \trouter := &Router{\n118: \t\troutes: sync.Map{},\n119: \t}\n120: \tresolver := NewResolver(&router.routes)\n121: \thandler := NewHandler(router, resolver)\n122: \n123: \tentry := &RouteEntry{\n124: \t\tName:       \"test\",\n125: \t\tNamespace:  \"default\",\n126: \t\tKind:       \"AgentRuntime\",\n127: \t\tBackendURL: backend.URL,\n128: \t\tHealth:     HealthStatus{Healthy: true},\n129: \t}\n130: \n131: \treq := httptest.NewRequest(http.MethodPost, backend.URL+\"/api/test\", strings.NewReader(\"body\"))\n132: \tw := httptest.NewRecorder()\n133: \n134: \terr := handler.ProxyRequest(w, req, entry)\n135: \tassert.NoError(t, err)\n136: \tassert.Equal(t, http.StatusCreated, w.Code)\n137: \tassert.Contains(t, w.Body.String(), \"created\")\n138: \tassert.Equal(t, \"value\", w.Header().Get(\"X-Custom-Header\"))\n139: }\n140: \n141: func TestHandler_ProxyRequest_InvalidBackendURL(t *testing.T) {\n142: \trouter := &Router{\n143: \t\troutes: sync.Map{},\n144: \t}\n145: \tresolver := NewResolver(&router.routes)\n146: \thandler := NewHandler(router, resolver)\n147: \n148: \tentry := &RouteEntry{\n149: \t\tName:       \"test\",\n150: \t\tNamespace:  \"default\",\n151: \t\tKind:       \"AgentRuntime\",\n152: \t\tBackendURL: \"://invalid\",\n153: \t\tHealth:     HealthStatus{Healthy: true},\n154: \t}\n155: \n156: \treq := httptest.NewRequest(http.MethodGet, \"http://test\", nil)\n157: \tw := httptest.NewRecorder()\n158: \n159: \terr := handler.ProxyRequest(w, req, entry)\n160: \tassert.Error(t, err)\n161: \tassert.Contains(t, err.Error(), \"failed to connect to backend\")\n162: }\n163: \n164: func TestHandler_AddForwardingHeaders(t *testing.T) {\n165: \trouter := &Router{\n166: \t\troutes: sync.Map{},\n167: \t}\n168: \tresolver := NewResolver(&router.routes)\n169: \thandler := NewHandler(router, resolver)\n170: \n171: \treq := httptest.NewRequest(http.MethodGet, \"http://example.com/test\", nil)\n172: \treq.RemoteAddr = \"192.168.1.1:12345\"\n173: \treq.Host = \"example.com\"\n174: \n175: \tresult := handler.AddForwardingHeaders(req)\n176: \n177: \tassert.Equal(t, \"192.168.1.1\", result.Header.Get(\"X-Forwarded-For\"))\n178: \tassert.Equal(t, \"192.168.1.1\", result.Header.Get(\"X-Real-IP\"))\n179: \tassert.Equal(t, \"example.com\", result.Header.Get(\"X-Forwarded-Host\"))\n180: \tassert.Equal(t, \"http\", result.Header.Get(\"X-Forwarded-Proto\"))\n181: }\n182: \n183: func TestHandler_AddForwardingHeaders_HTTPS(t *testing.T) {\n184: \trouter := &Router{\n185: \t\troutes: sync.Map{},\n186: \t}\n187: \tresolver := NewResolver(&router.routes)\n188: \thandler := NewHandler(router, resolver)\n189: \n190: \treq := httptest.NewRequest(http.MethodGet, \"https://example.com/test\", nil)\n191: \treq.RemoteAddr = \"192.168.1.1:12345\"\n192: \treq.TLS = &tls.ConnectionState{}\n193: \n194: \tresult := handler.AddForwardingHeaders(req)\n195: \n196: \tassert.Equal(t, \"https\", result.Header.Get(\"X-Forwarded-Proto\"))\n197: }\n198: \n199: func TestHandler_AddForwardingHeaders_InvalidRemoteAddr(t *testing.T) {\n200: \trouter := &Router{\n201: \t\troutes: sync.Map{},\n202: \t}\n203: \tresolver := NewResolver(&router.routes)\n204: \thandler := NewHandler(router, resolver)\n205: \n206: \treq := httptest.NewRequest(http.MethodGet, \"http://example.com/test\", nil)\n207: \treq.RemoteAddr = \"invalid\"\n208: \n209: \tresult := handler.AddForwardingHeaders(req)\n210: \n211: \tassert.Equal(t, \"invalid\", result.Header.Get(\"X-Forwarded-For\"))\n212: }\n213: \n214: func TestHandler_WriteError(t *testing.T) {\n215: \trouter := &Router{\n216: \t\troutes: sync.Map{},\n217: \t}\n218: \tresolver := NewResolver(&router.routes)\n219: \thandler := NewHandler(router, resolver)\n220: \n221: \ttests := []struct {\n222: \t\tname       string\n223: \t\terr        error\n224: \t\tstatusCode int\n225: \t\tcheckBody  string\n226: \t}{\n227: \t\t{\n228: \t\t\tname:       \"route not found\",\n229: \t\t\terr:        ErrRouteNotFound,\n230: \t\t\tstatusCode: http.StatusNotFound,\n231: \t\t\tcheckBody:  \"route not found\",\n232: \t\t},\n233: \t\t{\n234: \t\t\tname:       \"invalid resource type\",\n235: \t\t\terr:        ErrInvalidResourceType,\n236: \t\t\tstatusCode: http.StatusBadRequest,\n237: \t\t\tcheckBody:  \"invalid resource type\",\n238: \t\t},\n239: \t\t{\n240: \t\t\tname:       \"malformed path\",\n241: \t\t\terr:        ErrMalformedPath,\n242: \t\t\tstatusCode: http.StatusBadRequest,\n243: \t\t\tcheckBody:  \"malformed\",\n244: \t\t},\n245: \t\t{\n246: \t\t\tname:       \"no healthy backends\",\n247: \t\t\terr:        ErrNoHealthyBackends,\n248: \t\t\tstatusCode: http.StatusServiceUnavailable,\n249: \t\t\tcheckBody:  \"no healthy backends\",\n250: \t\t},\n251: \t\t{\n252: \t\t\tname:       \"backend connection error\",\n253: \t\t\terr:        ErrBackendConnection,\n254: \t\t\tstatusCode: http.StatusBadGateway,\n255: \t\t\tcheckBody:  \"backend\",\n256: \t\t},\n257: \t}\n258: \n259: \tfor _, tt := range tests {\n260: \t\tt.Run(tt.name, func(t *testing.T) {\n261: \t\t\tw := httptest.NewRecorder()\n262: \t\t\thandler.writeError(w, tt.err, tt.statusCode)\n263: \n264: \t\t\tassert.Equal(t, \"application/json\", w.Header().Get(\"Content-Type\"))\n265: \t\t\tassert.Contains(t, w.Body.String(), tt.checkBody)\n266: \t\t\tassert.Contains(t, w.Body.String(), \"error\")\n267: \t\t\tassert.Contains(t, w.Body.String(), \"timestamp\")\n268: \t\t})\n269: \t}\n270: }\n271: \n272: func TestHandler_ProxyRequest_BackendUnavailable(t *testing.T) {\n273: \trouter := &Router{\n274: \t\troutes: sync.Map{},\n275: \t}\n276: \tresolver := NewResolver(&router.routes)\n277: \thandler := NewHandler(router, resolver)\n278: \n279: \tentry := &RouteEntry{\n280: \t\tName:       \"test\",\n281: \t\tNamespace:  \"default\",\n282: \t\tKind:       \"AgentRuntime\",\n283: \t\tBackendURL: \"http://localhost:1\",\n284: \t\tHealth:     HealthStatus{Healthy: true},\n285: \t}\n286: \n287: \treq := httptest.NewRequest(http.MethodGet, \"http://localhost:1/test\", nil)\n288: \tw := httptest.NewRecorder()\n289: \n290: \thandler.ProxyRequest(w, req, entry)\n291: \n292: \tassert.Equal(t, http.StatusBadGateway, w.Code)\n293: }\n\n(End of file - total 293 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"crypto/tls\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"strings\"\n\t\"sync\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestHandler_NewHandler(t *testing.T) {\n\trouter := &Router{\n\t\troutes: sync.Map{},\n\t}\n\tresolver := NewResolver(&router.routes)\n\n\thandler := NewHandler(router, resolver)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler_test.go","time":{"start":1775849202464,"end":1775849202474}}}}
