pec.md\n-rw-r--r--  1 root root 34947 Apr 11 01:15 design.md\n-rw-r--r--  1 root root  4012 Apr 11 02:53 garbage_collector.go\n-rw-r--r--  1 root root  6202 Apr 11 04:39 garbage_collector_test.go\ndrwxr-xr-x  2 root root  4096 Apr 11 01:47 handler\ndrwxr-xr-x  2 root root  4096 Apr 11 01:29 middleware\ndrwxr-xr-x  2 root root  4096 Apr 11 01:52 processor\n-rw-r--r--  1 root root 17940 Apr 11 02:22 proposal.md\ndrwxr-xr-x  2 root root  4096 Apr 11 14:28 reconciler\ndrwxr-xr-x  2 root root  4096 Apr 11 01:18 response\n-rw-r--r--  1 root root  1993 Apr 11 02:56 routes.go\n-rw-r--r--  1 root root  2499 Apr 11 01:29 routes_test.go\n-rw-r--r--  1 root root  2140 Apr 11 01:23 server.go\n-rw-r--r--  1 root root  1437 Apr 11 01:29 server_test.go\ndrwxr-xr-x  2 root root  4096 Apr 11 01:45 types\n","exit":0,"description":"List workloadmanager directory","truncated":false},"title":"List workloadmanager directory","time":{"start":1775894572160,"end":1775894572184}}}}
