{"type":"tool_use","timestamp":1775839616311,"sessionID":"ses_287b61ae9ffeRwGS11QpcSqa0Z","part":{"id":"prt_d784a181e001pDBy3i54lPqmnI","messageID":"msg_d7849faf9001v7nPqShxG8oHzS","sessionID":"ses_287b61ae9ffeRwGS11QpcSqa0Z","type":"tool","tool":"read","callID":"toolu_1f34f67df6ad4017a408d4e0","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types.go</path>\n<type>file</type>\n<content>\n1: /*\n2: Copyright 2026 The AgentCube Authors.\n3: \n4: Licensed under the Apache License, Version 2.0 (the \"License\");\n5: you may not use this file except in compliance with the License.\n6: You may obtain a copy of the License at\n7: \n8:     http://www.apache.org/licenses/LICENSE-2.0\n9: \n10: Unless required by applicable law or agreed to in writing, software\n11: distributed under the License is distributed on an \"AS IS\" BASIS,\n12: WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13: See the License for the specific language governing permissions and\n14: limitations under the License.\n15: */\n16: \n17: package v1alpha1\n18: \n19: import (\n20: \tcorev1 \"k8s.io/api/core/v1\"\n21: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n22: )\n23: \n24: // AgentRuntimePhase is the lifecycle phase of an AgentRuntime.\n25: type AgentRuntimePhase string\n26: \n27: const (\n28: \t// AgentRuntimePhasePending indicates the runtime is being provisioned.\n29: \tAgentRuntimePhasePending AgentRuntimePhase = \"Pending\"\n30: \t// AgentRuntimePhaseRunning indicates the runtime is running.\n31: \tAgentRuntimePhaseRunning AgentRuntimePhase = \"Running\"\n32: \t// AgentRuntimePhaseFailed indicates the runtime failed to start.\n33: \tAgentRuntimePhaseFailed AgentRuntimePhase = \"Failed\"\n34: \t// AgentRuntimePhaseTerminating indicates the runtime is being terminated.\n35: \tAgentRuntimePhaseTerminating AgentRuntimePhase = \"Terminating\"\n36: )\n37: \n38: // AgentRuntimeConditionType is the type of a runtime condition.\n39: type AgentRuntimeConditionType string\n40: \n41: const (\n42: \t// AgentRuntimeConditionReady indicates the runtime is ready to serve requests.\n43: \tAgentRuntimeConditionReady AgentRuntimeConditionType = \"Ready\"\n44: \t// AgentRuntimeConditionSandboxCreated indicates the sandbox pod has been created.\n45: \tAgentRuntimeConditionSandboxCreated AgentRuntimeConditionType = \"SandboxCreated\"\n46: \t// AgentRuntimeConditionCodeInterpreterReady indicates the code interpreter is attached and ready.\n47: \tAgentRuntimeConditionCodeInterpreterReady AgentRuntimeConditionType = \"CodeInterpreterReady\"\n48: )\n49: \n50: // AgentRuntimeCondition represents the state of a runtime condition.\n51: type AgentRuntimeCondition struct {\n52: \t// Type is the type of the condition.\n53: \tType AgentRuntimeConditionType `json:\"type\" protobuf:\"bytes,1,opt,name=type,casttype=AgentRuntimeConditionType\"`\n54: \t// Status is the status of the condition (True, False, Unknown).\n55: \tStatus corev1.ConditionStatus `json:\"status\" protobuf:\"bytes,2,opt,name=status,casttype=k8s.io/api/core/v1.ConditionStatus\"`\n56: \t// Reason is a one-word CamelCase reason for the condition's last transition.\n57: \t// +optional\n58: \tReason string `json:\"reason,omitempty\" protobuf:\"bytes,3,opt,name=reason\"`\n59: \t// Message is a human-readable message indicating details about last transition.\n60: \t// +optional\n61: \tMessage string `json:\"message,omitempty\" protobuf:\"bytes,4,opt,name=message\"`\n62: \t// LastTransitionTime is the last time the condition transitioned from one status to another.\n63: \tLastTransitionTime metav1.Time `json:\"lastTransitionTime\" protobuf:\"bytes,5,opt,name=lastTransitionTime\"`\n64: }\n65: \n66: // CodeInterpreterSpec defines the configuration for an embedded code interpreter.\n67: type CodeInterpreterSpec struct {\n68: \t// Enabled indicates whether to attach a code interpreter.\n69: \t// +optional\n70: \tEnabled bool `json:\"enabled,omitempty\" protobuf:\"varint,1,opt,name=enabled\"`\n71: \t// Image is the container image for the code interpreter.\n72: \t// +optional\n73: \tImage string `json:\"image,omitempty\" protobuf:\"bytes,2,opt,name=image\"`\n74: \t// Resources defines the resource requirements for the code interpreter.\n75: \t// +optional\n76: \tResources *ResourceQuota `json:\"resources,omitempty\" protobuf:\"bytes,3,opt,name=resources\"`\n77: }\n78: \n79: // ResourceQuota defines resource limits and requests.\n80: type ResourceQuota struct {\n81: \t// CPU is the CPU limit in cores (e.g., \"500m\" for 0.5 CPU).\n82: \t// +optional\n83: \tCPU string `json:\"cpu,omitempty\" protobuf:\"bytes,1,opt,name=cpu\"`\n84: \t// Memory is the memory limit in bytes (e.g., \"512Mi\", \"1Gi\").\n85: \t// +optional\n86: \tMemory string `json:\"memory,omitempty\" protobuf:\"bytes,2,opt,name=memory\"`\n87: \t// Storage is the storage limit in bytes (e.g., \"1Gi\", \"10Gi\").\n88: \t// +optional\n89: \tStorage string `json:\"storage,omitempty\" protobuf:\"bytes,3,opt,name=storage\"`\n90: }\n91: \n92: // NetworkPolicy defines network access rules for the runtime.\n93: type NetworkPolicy struct {\n94: \t// EgressRules defines allowed egress destinations.\n95: \t// +optional\n96: \tEgressRules []NetworkRule `json:\"egressRules,omitempty\" protobuf:\"bytes,1,rep,name=egressRules\"`\n97: \t// IngressRules defines allowed ingress sources.\n98: \t// +optional\n99: \tIngressRules []NetworkRule `json:\"ingressRules,omitempty\" protobuf:\"bytes,2,rep,name=ingressRules\"`\n100: }\n101: \n102: // NetworkRule defines a single network rule.\n103: type NetworkRule struct {\n104: \t// CIDR is the IP CIDR block (e.g., \"10.0.0.0/8\").\n105: \t// +optional\n106: \tCIDR string `json:\"cidr,omitempty\" protobuf:\"bytes,1,opt,name=cidr\"`\n107: \t// Ports is the list of allowed ports.\n108: \t// +optional\n109: \tPorts []int32 `json:\"ports,omitempty\" protobuf:\"varint,2,rep,name=ports\"`\n110: \t// Protocol is the network protocol (TCP, UDP).\n111: \t// +optional\n112: \tProtocol corev1.Protocol `json:\"protocol,omitempty\" protobuf:\"bytes,3,opt,name=protocol,casttype=k8s.io/api/core/v1.Protocol\"`\n113: }\n114: \n115: // LifecycleHook defines lifecycle callbacks for the runtime.\n116: type LifecycleHook struct {\n117: \t// PreStart is the URL to call before the runtime starts.\n118: \t// +optional\n119: \tPreStart string `json:\"preStart,omitempty\" protobuf:\"bytes,1,opt,name=preStart\"`\n120: \t// PostStop is the URL to call after the runtime stops.\n121: \t// +optional\n122: \tPostStop string `json:\"postStop,omitempty\" protobuf:\"bytes,2,opt,name=postStop\"`\n123: }\n124: \n125: // ContainerSpec defines the container configuration for the runtime.\n126: type ContainerSpec struct {\n127: \t// Image is the container image to run.\n128: \t// +optional\n129: \tImage string `json:\"image,omitempty\" protobuf:\"bytes,1,opt,name=image\"`\n130: \t// Command is the command to run in the container.\n131: \t// +optional\n132: \tCommand []string `json:\"command,omitempty\" protobuf:\"bytes,2,rep,name=command\"`\n133: \t// Args are the arguments to the command.\n134: \t// +optional\n135: \tArgs []string `json:\"args,omitempty\" protobuf:\"bytes,3,rep,name=args\"`\n136: \t// Env is the list of environment variables.\n137: \t// +optional\n138: \tEnv []corev1.EnvVar `json:\"env,omitempty\" protobuf:\"bytes,4,rep,name=env\"`\n139: \t// WorkingDir is the working directory for the container.\n140: \t// +optional\n141: \tWorkingDir string `json:\"workingDir,omitempty\" protobuf:\"bytes,5,opt,name=workingDir\"`\n142: }\n143: \n144: // AgentRuntimeSpec defines the desired state of an AgentRuntime.\n145: type AgentRuntimeSpec struct {\n146: \t// Container defines the container configuration.\n147: \t// +optional\n148: \tContainer ContainerSpec `json:\"container,omitempty\" protobuf:\"bytes,1,opt,name=container\"`\n149: \t// Resources defines the resource quotas for the runtime.\n150: \t// +optional\n151: \tResources *ResourceQuota `json:\"resources,omitempty\" protobuf:\"bytes,2,opt,name=resources\"`\n152: \t// Network defines the network policies.\n153: \t// +optional\n154: \tNetwork *NetworkPolicy `json:\"network,omitempty\" protobuf:\"bytes,3,opt,name=network\"`\n155: \t// Lifecycle defines lifecycle hooks.\n156: \t// +optional\n157: \tLifecycle *LifecycleHook `json:\"lifecycle,omitempty\" protobuf:\"bytes,4,opt,name=lifecycle\"`\n158: \t// CodeInterpreter defines the embedded code interpreter configuration.\n159: \t// +optional\n160: \tCodeInterpreter *CodeInterpreterSpec `json:\"codeInterpreter,omitempty\" protobuf:\"bytes,5,opt,name=codeInterpreter\"`\n161: }\n162: \n163: // AgentRuntimeStatus defines the observed state of an AgentRuntime.\n164: type AgentRuntimeStatus struct {\n165: \t// Phase is the current phase of the runtime.\n166: \t// +optional\n167: \tPhase AgentRuntimePhase `json:\"phase,omitempty\" protobuf:\"bytes,1,opt,name=phase,casttype=AgentRuntimePhase\"`\n168: \t// Conditions represent the latest available observations of the runtime state.\n169: \t// +optional\n170: \tConditions []AgentRuntimeCondition `json:\"conditions,omitempty\" protobuf:\"bytes,2,rep,name=conditions\"`\n171: \t// SandboxRef is the reference to the sandbox pod.\n172: \t// +optional\n173: \tSandboxRef *corev1.ObjectReference `json:\"sandboxRef,omitempty\" protobuf:\"bytes,3,opt,name=sandboxRef\"`\n174: \t// StartTime is the time when the runtime started.\n175: \t// +optional\n176: \tStartTime *metav1.Time `json:\"startTime,omitempty\" protobuf:\"bytes,4,opt,name=startTime\"`\n177: \t// LastTransitionTime is the last time the phase transitioned.\n178: \t// +optional\n179: \tLastTransitionTime *metav1.Time `json:\"lastTransitionTime,omitempty\" protobuf:\"bytes,5,opt,name=lastTransitionTime\"`\n180: }\n181: \n182: // +genclient\n183: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n184: // +kubebuilder:object:root=true\n185: // +kubebuilder:subresource:status\n186: // +kubebuilder:printcolumn:name=\"NAME\",type=\"string\",JSONPath=\".metadata.name\",description=\"Name of the runtime\"\n187: // +kubebuilder:printcolumn:name=\"PHASE\",type=\"string\",JSONPath=\".status.phase\",description=\"Current phase\"\n188: // +kubebuilder:printcolumn:name=\"SANDBOX\",type=\"string\",JSONPath=\".status.sandboxRef.name\",description=\"Sandbox pod name\"\n189: // +kubebuilder:printcolumn:name=\"AGE\",type=\"date\",JSONPath=\".metadata.creationTimestamp\",description=\"Age of the resource\"\n190: \n191: // AgentRuntime is the Schema for the agentruntimes API.\n192: type AgentRuntime struct {\n193: \tmetav1.TypeMeta   `json:\",inline\"`\n194: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n195: \n196: \tSpec   AgentRuntimeSpec   `json:\"spec,omitempty\"`\n197: \tStatus AgentRuntimeStatus `json:\"status,omitempty\"`\n198: }\n199: \n200: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n201: // +kubebuilder:object:root=true\n202: \n203: // AgentRuntimeList contains a list of AgentRuntime.\n204: type AgentRuntimeList struct {\n205: \tmetav1.TypeMeta `json:\",inline\"`\n206: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n207: \tItems           []AgentRuntime `json:\"items\"`\n208: }\n\n(End of file - total 208 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types.go","time":{"start":1775839616268,"end":1775839616309}}}}
