{"type":"tool_use","timestamp":1775843682232,"sessionID":"ses_287781959ffea28iPSNG43jv0n","part":{"id":"prt_d7888123d001Jifwg24cWC1ThV","messageID":"msg_d788805ee001ekG0TYZUSM77lb","sessionID":"ses_287781959ffea28iPSNG43jv0n","type":"tool","tool":"read","callID":"toolu_cad9aa6b07334b46b18c6657","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/processor/sandbox_processor.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/processor/sandbox_processor.go</path>\n<type>file</type>\n<content>\n1: package processor\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"fmt\"\n7: \t\"math/big\"\n8: \t\"net\"\n9: \t\"strings\"\n10: \t\"time\"\n11: \n12: \tcorev1 \"k8s.io/api/core/v1\"\n13: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n14: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n15: \t\"k8s.io/apimachinery/pkg/labels\"\n16: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n17: \t\"k8s.io/client-go/dynamic\"\n18: \t\"k8s.io/client-go/kubernetes\"\n19: \tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n20: \n21: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n22: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n23: )\n24: \n25: var (\n26: \tSandboxGVR = schema.GroupVersionResource{\n27: \t\tGroup:    \"agents.x-k8s.io\",\n28: \t\tVersion:  \"v1alpha1\",\n29: \t\tResource: \"sandboxes\",\n30: \t}\n31: \n32: \tSandboxClaimGVR = schema.GroupVersionResource{\n33: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n34: \t\tVersion:  \"v1alpha1\",\n35: \t\tResource: \"sandboxclaims\",\n36: \t}\n37: )\n38: \n39: const (\n40: \tSessionIDLabelKey        = \"runtime.agentcube.io/session-id\"\n41: \tIdleTimeoutAnnotation    = \"runtime.agentcube.io/idle-timeout\"\n42: \tSandboxNameLabelKey      = \"runtime.agentcube.io/sandbox-name\"\n43: \tSandboxPodNameAnnotation = \"agents.x-k8s.io/sandbox-pod-name\"\n44: )\n45: \n46: var (\n47: \tErrAgentRuntimeNotFound    = fmt.Errorf(\"agent runtime not found\")\n48: \tErrCodeInterpreterNotFound = fmt.Errorf(\"code interpreter not found\")\n49: \tErrTemplateMissing         = fmt.Errorf(\"template is missing\")\n50: \tErrSandboxCreationTimeout  = fmt.Errorf(\"sandbox creation timeout\")\n51: )\n52: \n53: type AgentRuntimeLister interface {\n54: \tAgentRuntimes(namespace string) AgentRuntimeNamespaceLister\n55: }\n56: \n57: type AgentRuntimeNamespaceLister interface {\n58: \tGet(name string) (*runtimev1alpha1.AgentRuntime, error)\n59: }\n60: \n61: type CodeInterpreterLister interface {\n62: \tCodeInterpreters(namespace string) CodeInterpreterNamespaceLister\n63: }\n64: \n65: type CodeInterpreterNamespaceLister interface {\n66: \tGet(name string) (*runtimev1alpha1.CodeInterpreter, error)\n67: }\n68: \n69: type SandboxProcessor struct {\n70: \tdynamicClient dynamic.Interface\n71: \tk8sClient     kubernetes.Interface\n72: \tpodLister     corev1lister.PodLister\n73: \tarLister      AgentRuntimeLister\n74: \tciLister      CodeInterpreterLister\n75: \tnamespace     string\n76: }\n77: \n78: func NewSandboxProcessor(\n79: \tdynamicClient dynamic.Interface,\n80: \tk8sClient kubernetes.Interface,\n81: \tpodLister corev1lister.PodLister,\n82: \tarLister AgentRuntimeLister,\n83: \tciLister CodeInterpreterLister,\n84: \tnamespace string,\n85: ) *SandboxProcessor {\n86: \treturn &SandboxProcessor{\n87: \t\tdynamicClient: dynamicClient,\n88: \t\tk8sClient:     k8sClient,\n89: \t\tpodLister:     podLister,\n90: \t\tarLister:      arLister,\n91: \t\tciLister:      ciLister,\n92: \t\tnamespace:     namespace,\n93: \t}\n94: }\n95: \n96: func RandString(n int) (string, error) {\n97: \tconst letters = \"abcdefghijklmnopqrstuvwxyz\"\n98: \tresult := make([]byte, n)\n99: \tfor i := 0; i < n; i++ {\n100: \t\tnum, err := rand.Int(rand.Reader, big.NewInt(int64(len(letters))))\n101: \t\tif err != nil {\n102: \t\t\treturn \"\", err\n103: \t\t}\n104: \t\tresult[i] = letters[num.Int64()]\n105: \t}\n106: \treturn string(result), nil\n107: }\n108: \n109: func (p *SandboxProcessor) GenerateSessionID() (string, error) {\n110: \tid, err := rand.Int(rand.Reader, big.NewInt(1e18))\n111: \tif err != nil {\n112: \t\treturn \"\", err\n113: \t}\n114: \treturn fmt.Sprintf(\"%018d\", id.Int64()), nil\n115: }\n116: \n117: func GetAgentRuntime(lister AgentRuntimeLister, namespace, name string) (*runtimev1alpha1.AgentRuntime, error) {\n118: \tif lister == nil {\n119: \t\treturn nil, ErrAgentRuntimeNotFound\n120: \t}\n121: \tar, err := lister.AgentRuntimes(namespace).Get(name)\n122: \tif err != nil {\n123: \t\treturn nil, ErrAgentRuntimeNotFound\n124: \t}\n125: \treturn ar, nil\n126: }\n127: \n128: func GetCodeInterpreter(lister CodeInterpreterLister, namespace, name string) (*runtimev1alpha1.CodeInterpreter, error) {\n129: \tif lister == nil {\n130: \t\treturn nil, ErrCodeInterpreterNotFound\n131: \t}\n132: \tci, err := lister.CodeInterpreters(namespace).Get(name)\n133: \tif err != nil {\n134: \t\treturn nil, ErrCodeInterpreterNotFound\n135: \t}\n136: \treturn ci, nil\n137: }\n138: \n139: func (p *SandboxProcessor) BuildSandboxObject(runtime *runtimev1alpha1.AgentRuntime, sessionID string) (*unstructured.Unstructured, error) {\n140: \tsuffix, err := RandString(8)\n141: \tif err != nil {\n142: \t\treturn nil, fmt.Errorf(\"failed to generate random suffix: %w\", err)\n143: \t}\n144: \n145: \tsandboxName := fmt.Sprintf(\"%s-%s\", runtime.Name, suffix)\n146: \n147: \tlabels := map[string]string{}\n148: \tfor k, v := range runtime.Labels {\n149: \t\tlabels[k] = v\n150: \t}\n151: \tlabels[SessionIDLabelKey] = sessionID\n152: \n153: \tannotations := map[string]string{}\n154: \tfor k, v := range runtime.Annotations {\n155: \t\tannotations[k] = v\n156: \t}\n157: \n158: \tnow := time.Now()\n159: \tshutdownTime := now.Add(8 * time.Hour)\n160: \n161: \tcontainer := map[string]interface{}{\n162: \t\t\"name\":  \"agent-runtime\",\n163: \t\t\"image\": runtime.Spec.Container.Image,\n164: \t}\n165: \n166: \tif len(runtime.Spec.Container.Command) > 0 {\n167: \t\tcontainer[\"command\"] = runtime.Spec.Container.Command\n168: \t}\n169: \n170: \tif len(runtime.Spec.Container.Args) > 0 {\n171: \t\tcontainer[\"args\"] = runtime.Spec.Container.Args\n172: \t}\n173: \n174: \tif len(runtime.Spec.Container.Env) > 0 {\n175: \t\tenvBytes := make([]interface{}, len(runtime.Spec.Container.Env))\n176: \t\tfor i, envVar := range runtime.Spec.Container.Env {\n177: \t\t\tenvMap := map[string]interface{}{\"name\": envVar.Name}\n178: \t\t\tif envVar.Value != \"\" {\n179: \t\t\t\tenvMap[\"value\"] = envVar.Value\n180: \t\t\t}\n181: \t\t\tif envVar.ValueFrom != nil {\n182: \t\t\t\tvalueFromMap := map[string]interface{}{}\n183: \t\t\t\tif envVar.ValueFrom.ConfigMapKeyRef != nil {\n184: \t\t\t\t\tvalueFromMap[\"configMapKeyRef\"] = map[string]interface{}{\n185: \t\t\t\t\t\t\"name\": envVar.ValueFrom.ConfigMapKeyRef.Name,\n186: \t\t\t\t\t\t\"key\":  envVar.ValueFrom.ConfigMapKeyRef.Key,\n187: \t\t\t\t\t}\n188: \t\t\t\t}\n189: \t\t\t\tif envVar.ValueFrom.SecretKeyRef != nil {\n190: \t\t\t\t\tvalueFromMap[\"secretKeyRef\"] = map[string]interface{}{\n191: \t\t\t\t\t\t\"name\": envVar.ValueFrom.SecretKeyRef.Name,\n192: \t\t\t\t\t\t\"key\":  envVar.ValueFrom.SecretKeyRef.Key,\n193: \t\t\t\t\t}\n194: \t\t\t\t}\n195: \t\t\t\tif envVar.ValueFrom.ResourceFieldRef != nil {\n196: \t\t\t\t\tvalueFromMap[\"resourceFieldRef\"] = map[string]interface{}{\n197: \t\t\t\t\t\t\"resource\":      envVar.ValueFrom.ResourceFieldRef.Resource,\n198: \t\t\t\t\t\t\"containerName\": envVar.ValueFrom.ResourceFieldRef.ContainerName,\n199: \t\t\t\t\t}\n200: \t\t\t\t}\n201: \t\t\t\tif envVar.ValueFrom.FieldRef != nil {\n202: \t\t\t\t\tvalueFromMap[\"fieldRef\"] = map[string]interface{}{\n203: \t\t\t\t\t\t\"fieldPath\": envVar.ValueFrom.FieldRef.FieldPath,\n204: \t\t\t\t\t}\n205: \t\t\t\t}\n206: \t\t\t\tenvMap[\"valueFrom\"] = valueFromMap\n207: \t\t\t}\n208: \t\t\tenvBytes[i] = envMap\n209: \t\t}\n210: \t\tcontainer[\"env\"] = envBytes\n211: \t}\n212: \n213: \tsandbox := &unstructured.Unstructured{\n214: \t\tObject: map[string]interface{}{\n215: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n216: \t\t\t\"kind\":       \"Sandbox\",\n217: \t\t\t\"metadata\": map[string]interface{}{\n218: \t\t\t\t\"name\":        sandboxName,\n219: \t\t\t\t\"namespace\":   runtime.Namespace,\n220: \t\t\t\t\"labels\":      labels,\n221: \t\t\t\t\"annotations\": annotations,\n222: \t\t\t},\n223: \t\t\t\"spec\": map[string]interface{}{\n224: \t\t\t\t\"podTemplate\": map[string]interface{}{\n225: \t\t\t\t\t\"spec\": map[string]interface{}{\n226: \t\t\t\t\t\t\"containers\": []interface{}{container},\n227: \t\t\t\t\t},\n228: \t\t\t\t},\n229: \t\t\t},\n230: \t\t\t\"lifecycle\": map[string]interface{}{\n231: \t\t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n232: \t\t\t},\n233: \t\t},\n234: \t}\n235: \n236: \treturn sandbox, nil\n237: }\n238: \n239: func (p *SandboxProcessor) BuildSandboxClaimObject(interpreter *runtimev1alpha1.CodeInterpreter, sessionID string) (*unstructured.Unstructured, error) {\n240: \tsuffix, err := RandString(8)\n241: \tif err != nil {\n242: \t\treturn nil, fmt.Errorf(\"failed to generate random suffix: %w\", err)\n243: \t}\n244: \n245: \tclaimName := fmt.Sprintf(\"%s-claim-%s\", interpreter.Name, suffix)\n246: \n247: \tlabels := map[string]string{}\n248: \tfor k, v := range interpreter.Labels {\n249: \t\tlabels[k] = v\n250: \t}\n251: \tlabels[SessionIDLabelKey] = sessionID\n252: \n253: \tclaim := &unstructured.Unstructured{\n254: \t\tObject: map[string]interface{}{\n255: \t\t\t\"apiVersion\": \"extensions.agents.x-k8s.io/v1alpha1\",\n256: \t\t\t\"kind\":       \"SandboxClaim\",\n257: \t\t\t\"metadata\": map[string]interface{}{\n258: \t\t\t\t\"name\":      claimName,\n259: \t\t\t\t\"namespace\": interpreter.Namespace,\n260: \t\t\t\t\"labels\":    labels,\n261: \t\t\t},\n262: \t\t\t\"spec\": map[string]interface{}{},\n263: \t\t},\n264: \t}\n265: \n266: \treturn claim, nil\n267: }\n268: \n269: func (p *SandboxProcessor) BuildCodeInterpreterSandbox(interpreter *runtimev1alpha1.CodeInterpreter, sessionID string) (*unstructured.Unstructured, error) {\n270: \tsuffix, err := RandString(8)\n271: \tif err != nil {\n272: \t\treturn nil, fmt.Errorf(\"failed to generate random suffix: %w\", err)\n273: \t}\n274: \n275: \tsandboxName := fmt.Sprintf(\"%s-%s\", interpreter.Name, suffix)\n276: \n277: \tlabels := map[string]string{}\n278: \tfor k, v := range interpreter.Labels {\n279: \t\tlabels[k] = v\n280: \t}\n281: \tlabels[SessionIDLabelKey] = sessionID\n282: \n283: \tannotations := map[string]string{}\n284: \tfor k, v := range interpreter.Annotations {\n285: \t\tannotations[k] = v\n286: \t}\n287: \n288: \tnow := time.Now()\n289: \tshutdownTime := now.Add(8 * time.Hour)\n290: \n291: \tsandbox := &unstructured.Unstructured{\n292: \t\tObject: map[string]interface{}{\n293: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n294: \t\t\t\"kind\":       \"Sandbox\",\n295: \t\t\t\"metadata\": map[string]interface{}{\n296: \t\t\t\t\"name\":        sandboxName,\n297: \t\t\t\t\"namespace\":   interpreter.Namespace,\n298: \t\t\t\t\"labels\":      labels,\n299: \t\t\t\t\"annotations\": annotations,\n300: \t\t\t},\n301: \t\t\t\"spec\": map[string]interface{}{\n302: \t\t\t\t\"podTemplate\": map[string]interface{}{\n303: \t\t\t\t\t\"spec\": map[string]interface{}{\n304: \t\t\t\t\t\t\"containers\": []interface{}{\n305: \t\t\t\t\t\t\tmap[string]interface{}{\n306: \t\t\t\t\t\t\t\t\"name\":  \"code-interpreter\",\n307: \t\t\t\t\t\t\t\t\"image\": interpreter.Spec.Image,\n308: \t\t\t\t\t\t\t},\n309: \t\t\t\t\t\t},\n310: \t\t\t\t\t},\n311: \t\t\t\t},\n312: \t\t\t},\n313: \t\t\t\"lifecycle\": map[string]interface{}{\n314: \t\t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n315: \t\t\t},\n316: \t\t},\n317: \t}\n318: \n319: \treturn sandbox, nil\n320: }\n321: \n322: func (p *SandboxProcessor) resolvePodIP(ctx context.Context, sandboxNamespace, sandboxName string) (string, error) {\n323: \tpodName := sandboxName\n324: \n325: \tpod, err := p.podLister.Pods(sandboxNamespace).Get(podName)\n326: \tif err == nil {\n327: \t\tif pod.Status.Phase != corev1.PodRunning {\n328: \t\t\treturn \"\", fmt.Errorf(\"pod %s is not running (phase: %s)\", podName, pod.Status.Phase)\n329: \t\t}\n330: \t\tif pod.Status.PodIP == \"\" {\n331: \t\t\treturn \"\", fmt.Errorf(\"pod %s has no IP assigned\", podName)\n332: \t\t}\n333: \t\treturn pod.Status.PodIP, nil\n334: \t}\n335: \n336: \tselector := labels.SelectorFromSet(labels.Set{\n337: \t\tSandboxNameLabelKey: sandboxName,\n338: \t})\n339: \n340: \tpodList, err := p.podLister.Pods(sandboxNamespace).List(selector)\n341: \tif err != nil {\n342: \t\treturn \"\", fmt.Errorf(\"failed to list pods: %w\", err)\n343: \t}\n344: \n345: \tfor _, pod := range podList {\n346: \t\tfor _, ownerRef := range pod.OwnerReferences {\n347: \t\t\tif ownerRef.Kind == \"Sandbox\" && ownerRef.Name == sandboxName {\n348: \t\t\t\tif pod.Status.Phase != corev1.PodRunning {\n349: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod %s is not running (phase: %s)\", pod.Name, pod.Status.Phase)\n350: \t\t\t\t}\n351: \t\t\t\tif pod.Status.PodIP == \"\" {\n352: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod %s has no IP assigned\", pod.Name)\n353: \t\t\t\t}\n354: \t\t\t\treturn pod.Status.PodIP, nil\n355: \t\t\t}\n356: \t\t}\n357: \t}\n358: \n359: \tfor _, pod := range podList {\n360: \t\tif pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n361: \t\t\treturn pod.Status.PodIP, nil\n362: \t\t}\n363: \t}\n364: \n365: \treturn \"\", fmt.Errorf(\"no pod found for sandbox %s\", sandboxName)\n366: }\n367: \n368: func BuildEntryPoints(podIP string, ports []types.TargetPort) []types.SandboxEntryPoint {\n369: \tvar entryPoints []types.SandboxEntryPoint\n370: \n371: \tfor _, port := range ports {\n372: \t\tentryPoint := types.SandboxEntryPoint{\n373: \t\t\tPath:     port.PathPrefix,\n374: \t\t\tProtocol: port.Protocol,\n375: \t\t\tEndpoint: net.JoinHostPort(podIP, fmt.Sprintf(\"%d\", port.Port)),\n376: \t\t}\n377: \t\tentryPoints = append(entryPoints, entryPoint)\n378: \t}\n379: \n380: \treturn entryPoints\n381: }\n382: \n383: func (p *SandboxProcessor) CreateSandbox(\n384: \tctx context.Context,\n385: \tsandbox *unstructured.Unstructured,\n386: \tisWarmPool bool,\n387: \tuserClient dynamic.ResourceInterface,\n388: \tsessionID string,\n389: ) (*types.SandboxInfo, error) {\n390: \tsandboxName := sandbox.GetName()\n391: \tsandboxNamespace := sandbox.GetNamespace()\n392: \n393: \tworkloadName := sandboxName\n394: \tif idx := strings.LastIndex(sandboxName, \"-\"); idx > 0 {\n395: \t\tworkloadName = sandboxName[:idx]\n396: \t}\n397: \n398: \tinfo := &types.SandboxInfo{\n399: \t\tSessionID:    sessionID,\n400: \t\tSandboxID:    sandboxName,\n401: \t\tSandboxName:  sandboxName,\n402: \t\tKind:         \"Sandbox\",\n403: \t\tNamespace:    sandboxNamespace,\n404: \t\tWorkloadName: workloadName,\n405: \t\tStatus:       \"pending\",\n406: \t\tCreatedAt:    time.Now(),\n407: \t\tUpdatedAt:    time.Now(),\n408: \t}\n409: \n410: \tif isWarmPool {\n411: \t\tinfo.Kind = \"SandboxClaim\"\n412: \t}\n413: \n414: \tcreateCtx, cancel := context.WithTimeout(ctx, 2*time.Minute)\n415: \tdefer cancel()\n416: \n417: \t_, err := userClient.Create(createCtx, sandbox, metav1.CreateOptions{})\n418: \tif err != nil {\n419: \t\treturn nil, fmt.Errorf(\"failed to create sandbox: %w\", err)\n420: \t}\n421: \n422: \trunningChan := make(chan struct{})\n423: \terrChan := make(chan error, 1)\n424: \n425: \tgo func() {\n426: \t\tfor {\n427: \t\t\tselect {\n428: \t\t\tcase <-createCtx.Done():\n429: \t\t\t\terrChan <- ErrSandboxCreationTimeout\n430: \t\t\t\treturn\n431: \t\t\tdefault:\n432: \t\t\t\tpod, err := p.podLister.Pods(sandboxNamespace).Get(sandboxName)\n433: \t\t\t\tif err == nil && pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n434: \t\t\t\t\tclose(runningChan)\n435: \t\t\t\t\treturn\n436: \t\t\t\t}\n437: \t\t\t\ttime.Sleep(500 * time.Millisecond)\n438: \t\t\t}\n439: \t\t}\n440: \t}()\n441: \n442: \tselect {\n443: \tcase <-runningChan:\n444: \tcase err := <-errChan:\n445: \t\tp.rollback(ctx, userClient, sandboxName)\n446: \t\treturn nil, err\n447: \tcase <-time.After(2 * time.Minute):\n448: \t\tp.rollback(ctx, userClient, sandboxName)\n449: \t\treturn nil, ErrSandboxCreationTimeout\n450: \t}\n451: \n452: \tpodIP, err := p.resolvePodIP(ctx, sandboxNamespace, sandboxName)\n453: \tif err != nil {\n454: \t\treturn nil, fmt.Errorf(\"failed to resolve pod IP: %w\", err)\n455: \t}\n456: \n457: \tinfo.PodIP = podIP\n458: \n459: \tports := []types.TargetPort{\n460: \t\t{Port: 8080, Protocol: \"HTTP\", PathPrefix: \"/\"},\n461: \t}\n462: \tinfo.EntryPoints = BuildEntryPoints(podIP, ports)\n463: \tinfo.Status = \"running\"\n464: \tinfo.UpdatedAt = time.Now()\n465: \n466: \treturn info, nil\n467: }\n468: \n469: func (p *SandboxProcessor) rollback(ctx context.Context, client dynamic.ResourceInterface, name string) {\n470: \tdeleteCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n471: \tdefer cancel()\n472: \tclient.Delete(deleteCtx, name, metav1.DeleteOptions{})\n473: }\n\n(End of file - total 473 lines)\n</content>","metadata":{"preview":"package processor\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"fmt\"\n\t\"math/big\"\n\t\"net\"\n\t\"strings\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/