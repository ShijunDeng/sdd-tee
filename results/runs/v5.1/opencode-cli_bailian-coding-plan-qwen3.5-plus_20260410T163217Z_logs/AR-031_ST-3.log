n=client -f \"$MANIFEST_DIR/roles/\"\n\necho \"Testing RoleBinding manifests...\"\nkubectl apply --dry-run=client -f \"$MANIFEST_DIR/rolebindings/\"\n\necho \"Testing combined manifest...\"\nkubectl apply --dry-run=client -f \"$MANIFEST_DIR/rbac.yaml\"\n\necho \"All dry-run tests passed\"\n```\n\n### Integration Tests\n\n**Location**: `manifests/rbac/tests/integration/`\n\n```bash\n# tests/integration/test-e2e.sh\n#!/bin/bash\n# E2E test for RBAC manifests\n\nset -e\n\nMANIFEST_DIR=\"$(dirname \"$0\")/../../..\"\nTEST_NAMESPACE=\"agentcube-rbac-test\"\n\ncleanup() {\n    echo \"Cleaning up...\"\n    kubectl delete namespace \"$TEST_NAMESPACE\" --ignore-not-found\n}\n\ntrap cleanup EXIT\n\necho \"Creating test namespace...\"\nkubectl create namespace \"$TEST_NAMESPACE\"\n\necho \"Applying RBAC manifests...\"\nkubectl apply -f \"$MANIFEST_DIR/namespace.yaml\"\nkubectl apply -f \"$MANIFEST_DIR/serviceaccounts/\" -n \"$TEST_NAMESPACE\"\nkubectl apply -f \"$MANIFEST_DIR/clusterroles/\"\nkubectl apply -f \"$MANIFEST_DIR/clusterrolebindings/\"\nkubectl apply -f \"$MANIFEST_DIR/roles/\" -n \"$TEST_NAMESPACE\"\nkubectl apply -f \"$MANIFEST_DIR/rolebindings/\" -n \"$TEST_NAMESPACE\"\n\necho \"Waiting for resources to be created...\"\nsleep 2\n\necho \"Verifying ServiceAccounts...\"\nkubectl get serviceaccount/workloadmanager -n \"$TEST_NAMESPACE\"\nkubectl get serviceaccount/agentcube-router -n \"$TEST_NAMESPACE\"\nkubectl get serviceaccount/volcano-agent-scheduler -n \"$TEST_NAMESPACE\"\n\necho \"Verifying ClusterRoles...\"\nkubectl get clusterrole/workloadmanager\nkubectl get clusterrole/volcano-agent-scheduler\n\necho \"Verifying ClusterRoleBindings...\"\nkubectl get clusterrolebinding/workloadmanager\nkubectl get clusterrolebinding/volcano-agent-scheduler-role\n\necho \"Verifying Role...\"\nkubectl get role/agentcube-router -n \"$TEST_NAMESPACE\"\n\necho \"Verifying RoleBinding...\"\nkubectl get rolebinding/agentcube-router -n \"$TEST_NAMESPACE\"\n\necho \"E2E test passed