ntryPoint `json:\"entryPoints\"`\n39: }\n40: \n41: // SandboxEntryPoint represents an entry point for accessing the sandbox.\n42: type SandboxEntryPoint struct {\n43: \tPath     string `json:\"path\"`\n44: \tProtocol string `json:\"protocol\"`\n45: \tEndpoint string `json:\"endpoint\"`\n46: }\n47: \n48: // SandboxInfo contains information about a sandbox session.\n49: type SandboxInfo struct {\n50: \tSessionID          string              `json:\"sessionId\"`\n51: \tSandboxID          string              `json:\"sandboxId\"`\n52: \tSandboxName        string              `json:\"sandboxName\"`\n53: \tKind               string              `json:\"kind\"`\n54: \tNamespace          string              `json:\"namespace\"`\n55: \tWorkloadName       string              `json:\"workloadName\"`\n56: \tStatus             string              `json:\"status\"`\n57: \tPodIP              string              `json:\"podIP,omitempty\"`\n58: \tEntryPoints        []SandboxEntryPoint `json:\"entryPoints,omitempty\"`\n59: \tCreatedAt          time.Time           `json:\"createdAt\"`\n60: \tUpdatedAt          time.Time           `json:\"updatedAt\"`\n61: \tIdleTimeout        string              `json:\"idleTimeout,omitempty\"`\n62: \tMaxSessionDuration string              `json:\"maxSessionDuration,omitempty\"`\n63: }\n64: \n65: // TargetPort represents a target port configuration.\n66: type TargetPort struct {\n67: \tPort       int32  `json:\"port\"`\n68: \tProtocol   string `json:\"protocol\"`\n69: \tPathPrefix string `json:\"pathPrefix\"`\n70: }\n\n(End of file - total 70 lines)\n</content>","metadata":{"preview":"package types\n\nimport (\n\t\"fmt\"\n\t\"time\"\n)\n\n// CreateSandboxRequest represents a request to create a sandbox.\ntype CreateSandboxRequest struct {\n\tKind      string            `json:\"kind\"`\n\tName      string            `json:\"name\"`\n\tNamespace string            `json:\"namespace\"`\n\tLabels    map[string]string `json:\"labels,omitempty\"`\n}\n\n// Validate validates the CreateSandboxRequest.\nfunc (r *CreateSandboxRequest) Validate() error {\n\tif r.Kind == \"\" {\n\t\treturn fmt.Errorf(\"kind is required\")\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/types/sandbox_types.go","time":{"start":1775843895856,"end":1775843895882}}}}
{"type":"tool_use","timestamp":1775843895886,"sessionID":"ses_2877500fbffe2ry268eDmqDR9H","part":{"id":"prt_d788b5f86001lV0MLox1Yjb9uh","messageID":"msg_d788b4e1600136JVbkefu62vOL","sessionID":"ses_2877500fbffe2ry268eDmqDR9H","type":"tool","tool":"read","callID":"toolu_8103e3b910f84b7c9d09fafa","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/processor/sandbox_processor_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/processor/sandbox_processor_test.go</path>\n<type>file</type>\n<content>\n1: package processor\n2: \n3: import (\n4: \t\"context\"\n5: \t\"testing\"\n6: \n7: \t\"github.com/stretchr/testify/assert\"\n8: \t\"github.com/stretchr/testify/require\"\n9: \tcorev1 \"k8s.io/api/core/v1\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: \t\"k8s.io/apimachinery/pkg/labels\"\n12: \t\"k8s.io/client-go/kubernetes/fake\"\n13: \tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n14: \n15: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n16: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n17: )\n18: \n19: func TestRandString(t *testing.T) {\n20: \tt.Run(\"generates correct length\", func(t *testing.T) {\n21: \t\ts, err := RandString(8)\n22: \t\trequire.NoError(t, err)\n23: \t\tassert.Len(t, s, 8)\n24: \t})\n25: \n26: \tt.Run(\"contains only lowercase letters\", func(t *testing.T) {\n27: \t\ts, err := RandString(100)\n28: \t\trequire.NoError(t, err)\n29: \t\tfor _, c := range s {\n30: \t\t\tassert.GreaterOrEqual(t, c, rune('a'))\n31: \t\t\tassert.LessOrEqual(t, c, rune('z'))\n32: \t\t}\n33: \t})\n34: \n35: \tt.Run(\"generates different strings\", func(t *testing.T) {\n36: \t\ts1, err := RandString(8)\n37: \t\trequire.NoError(t, err)\n38: \t\ts2, err := RandString(8)\n39: \t\trequire.NoError(t, err)\n40: \t\tassert.NotEqual(t, s1, s2)\n41: \t})\n42: }\n43: \n44: func TestCreateSandboxRequestValidate(t *testing.T) {\n45: \ttests := []struct {\n46: \t\tname    string\n47: \t\treq     *types.CreateSandboxRequest\n48: \t\twantErr string\n49: \t}{\n50: \t\t{\n51: \t\t\tname: \"valid AgentRuntime request\",\n52: \t\t\treq: &types.CreateSandboxRequest{\n53: \t\t\t\tKind:      \"AgentRuntime\",\n54: \t\t\t\tName:      \"my-runtime\",\n55: \t\t\t\tNamespace: \"default\",\n56: \t\t\t},\n57: \t\t\twantErr: \"\",\n58: \t\t},\n59: \t\t{\n60: \t\t\tname: \"valid CodeInterpreter request\",\n61: \t\t\treq: &types.CreateSandboxRequest{\n62: \t\t\t\tKind:      \"CodeInterpreter\",\n63: \t\t\t\tName:      \"my-interpreter\",\n64: \t\t\t\tNamespace: \"default\",\n65: \t\t\t},\n66: \t\t\twantErr: \"\",\n67: \t\t},\n68: \t\t{\n69: \t\t\tname: \"missing kind\",\n70: \t\t\treq: &types.CreateSandboxRequest{\n71: \t\t\t\tName:      \"my-runtime\",\n72: \t\t\t\tNamespace: \"default\",\n73: \t\t\t},\n74: \t\t\twantErr: \"kind is required\",\n75: \t\t},\n76: \t\t{\n77: \t\t\tname: \"invalid kind\",\n78: \t\t\treq: &types.CreateSandboxRequest{\n79: \t\t\t\tKind:      \"Unknown\",\n80: \t\t\t\tName:      \"my-runtime\",\n81: \t\t\t\tNamespace: \"default\",\n82: \t\t\t},\n83: \t\t\twantErr: \"kind must be 'AgentRuntime' or 'CodeInterpreter'\",\n84: \t\t},\n85: \t\t{\n86: \t\t\tname: \"missing name\",\n87: \t\t\treq: &types.CreateSandboxRequest{\n88: \t\t\t\tKind:      \"AgentRuntime\",\n89: \t\t\t\tNamespace: \"default\",\n90: \t\t\t},\n91: \t\t\twantErr: \"name is required\",\n92: \t\t},\n93: \t\t{\n94: \t\t\tname: \"missing namespace\",\n95: \t\t\treq: &types.CreateSandboxRequest{\n96: \t\t\t\tKind: \"AgentRuntime\",\n97: \t\t\t\tName: \"my-runtime\",\n98: \t\t\t},\n99: \t\t\twantErr: \"namespace is required\",\n100: \t\t},\n101: \t}\n102: \n103: \tfor _, tt := range tests {\n104: \t\tt.Run(tt.name, func(t *testing.T) {\n105: \t\t\terr := tt.req.Validate()\n106: \t\t\tif tt.wantErr == \"\" {\n107: \t\t\t\tassert.NoError(t, err)\n108: \t\t\t} else {\n109: \t\t\t\tassert.ErrorContains(t, err, tt.wantErr)\n110: \t\t\t}\n111: \t\t})\n112: \t}\n113: }\n114: \n115: type mockAgentRuntimeLister struct {\n116: \tar *runtimev1alpha1.AgentRuntime\n117: }\n118: \n119: func (m *mockAgentRuntimeLister) AgentRuntimes(namespace string) AgentRuntimeNamespaceLister {\n120: \treturn &mockAgentRuntimeNamespaceLister{ar: m.ar}\n121: }\n122: \n123: type mockAgentRuntimeNamespaceLister struct {\n124: \tar *runtimev1alpha1.AgentRuntime\n125: }\n126: \n127: func (m *mockAgentRuntimeNamespaceLister) Get(name string) (*runtimev1alpha1.AgentRuntime, error) {\n128: \tif m.ar == nil {\n129: \t\treturn nil, ErrAgentRuntimeNotFound\n130: \t}\n131: \treturn m.ar, nil\n132: }\n133: \n134: func TestGetAgentRuntime(t *testing.T) {\n135: \tt.Run(\"found\", func(t *testing.T) {\n136: \t\tar := &runtimev1alpha1.AgentRuntime{\n137: \t\t\tObjectMeta: metav1.ObjectMeta{\n138: \t\t\t\tName:      \"test-runtime\",\n139: \t\t\t\tNamespace: \"default\",\n140: \t\t\t},\n141: \t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n142: \t\t\t\tContainer: runtimev1alpha1.ContainerSpec{\n143: \t\t\t\t\tImage: \"python:3.11\",\n144: \t\t\t\t},\n145: \t\t\t},\n146: \t\t}\n147: \t\tlister := &mockAgentRuntimeLister{ar: ar}\n148: \t\tresult, err := GetAgentRuntime(lister, \"default\", \"test-runtime\")\n149: \t\trequire.NoError(t, err)\n150: \t\tassert.Equal(t, \"test-runtime\", result.Name)\n151: \t})\n152: \n153: \tt.Run(\"not found\", func(t *testing.T) {\n154: \t\tlister := &mockAgentRuntimeLister{ar: nil}\n155: \t\t_, err := GetAgentRuntime(lister, \"default\", \"missing\")\n156: \t\tassert.ErrorIs(t, err, ErrAgentRuntimeNotFound)\n157: \t})\n158: }\n159: \n160: type mockCodeInterpreterLister struct {\n161: \tci *runtimev1alpha1.CodeInterpreter\n162: }\n163: \n164: func (m *mockCodeInterpreterLister) CodeInterpreters(namespace string) CodeInterpreterNamespaceLister {\n165: \treturn &mockCodeInterpreterNamespaceLister{ci: m.ci}\n166: }\n167: \n168: type mockCodeInterpreterNamespaceLister struct {\n169: \tci *runtimev1alpha1.CodeInterpreter\n170: }\n171: \n172: func (m *mockCodeInterpreterNamespaceLister) Get(name string) (*runtimev1alpha1.CodeInterpreter, error) {\n173: \tif m.ci == nil {\n174: \t\treturn nil, ErrCodeInterpreterNotFound\n175: \t}\n176: \treturn m.ci, nil\n177: }\n178: \n179: func TestGetCodeInterpreter(t *testing.T) {\n180: \tt.Run(\"found\", func(t *testing.T) {\n181: \t\tci := &runtimev1alpha1.CodeInterpreter{\n182: \t\t\tObjectMeta: metav1.ObjectMeta{\n183: \t\t\t\tName:      \"test-interpreter\",\n184: \t\t\t\tNamespace: \"default\",\n185: \t\t\t},\n186: \t\t\tSpec: runtimev1alpha1.CodeInterpreterSpec{\n187: \t\t\t\tImage: \"python:3.11\",\n188: \t\t\t},\n189: \t\t}\n190: \t\tlister := &mockCodeInterpreterLister{ci: ci}\n191: \t\tresult, err := GetCodeInterpreter(lister, \"default\", \"test-interpreter\")\n192: \t\trequire.NoError(t, err)\n193: \t\tassert.Equal(t, \"test-interpreter\", result.Name)\n194: \t})\n195: \n196: \tt.Run(\"not found\", func(t *testing.T) {\n197: \t\tlister := &mockCodeInterpreterLister{ci: nil}\n198: \t\t_, err := GetCodeInterpreter(lister, \"default\", \"missing\")\n199: \t\tassert.ErrorIs(t, err, ErrCodeInterpreterNotFound)\n200: \t})\n201: }\n202: \n203: func TestBuildSandboxObject(t *testing.T) {\n204: \truntime := &runtimev1alpha1.AgentRuntime{\n205: \t\tObjectMeta: metav1.ObjectMeta{\n206: \t\t\tName:      \"my-runtime\",\n207: \t\t\tNamespace: \"default\",\n208: \t\t\tLabels: map[string]string{\n209: \t\t\t\t\"app\": \"test\",\n210: \t\t\t},\n211: \t\t\tAnnotations: map[string]string{\n212: \t\t\t\t\"description\": \"test runtime\",\n213: \t\t\t},\n214: \t\t},\n215: \t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n216: \t\t\tContainer: runtimev1alpha1.ContainerSpec{\n217: \t\t\t\tImage:   \"python:3.11\",\n218: \t\t\t\tCommand: []string{\"python\", \"main.py\"},\n219: \t\t\t\tArgs:    []string{\"--debug\"},\n220: \t\t\t\tEnv: []corev1.EnvVar{\n221: \t\t\t\t\t{Name: \"ENV_VAR\", Value: \"value\"},\n222: \t\t\t\t},\n223: \t\t\t},\n224: \t\t},\n225: \t}\n226: \n227: \tp := &SandboxProcessor{}\n228: \tsandbox, err := p.BuildSandboxObject(runtime, \"test-session-id\")\n229: \trequire.NoError(t, err)\n230: \n231: \tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", sandbox.GetAPIVersion())\n232: \tassert.Equal(t, \"Sandbox\", sandbox.GetKind())\n233: \tassert.Contains(t, sandbox.GetName(), \"my-runtime-\")\n234: \tassert.Equal(t, \"default\", sandbox.GetNamespace())\n235: \tassert.Equal(t, \"test-session-id\", sandbox.GetLabels()[SessionIDLabelKey])\n236: \tassert.Equal(t, \"test\", sandbox.GetLabels()[\"app\"])\n237: \n238: \tspec := sandbox.Object[\"spec\"].(map[string]interface{})\n239: \tpodTemplate := spec[\"podTemplate\"].(map[string]interface{})\n240: \tpodSpec := podTemplate[\"spec\"].(map[string]interface{})\n241: \tcontainers := podSpec[\"containers\"].([]interface{})\n242: \tcontainer := containers[0].(map[string]interface{})\n243: \n244: \tassert.Equal(t, \"python:3.11\", container[\"image\"])\n245: \tassert.Equal(t, []interface{}{\"python\", \"main.py\"}, container[\"command\"])\n246: \tassert.Equal(t, []interface{}{\"--debug\"}, container[\"args\"])\n247: \tassert.NotNil(t, container[\"env\"])\n248: }\n249: \n250: func TestBuildCodeInterpreterSandbox(t *testing.T) {\n251: \tinterpreter := &runtimev1alpha1.CodeInterpreter{\n252: \t\tObjectMeta: metav1.ObjectMeta{\n253: \t\t\tName:      \"my-interpreter\",\n254: \t\t\tNamespace: \"default\",\n255: \t\t\tLabels: map[string]string{\n256: \t\t\t\t\"app\": \"test\",\n257: \t\t\t},\n258: \t\t},\n259: \t\tSpec: runtimev1alpha1.CodeInterpreterSpec{\n260: \t\t\tImage: \"python:3.11\",\n261: \t\t},\n262: \t}\n263: \n264: \tp := &SandboxProcessor{}\n265: \tsandbox, err := p.BuildCodeInterpreterSandbox(interpreter, \"test-session-id\")\n266: \trequire.NoError(t, err)\n267: \n268: \tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", sandbox.GetAPIVersion())\n269: \tassert.Equal(t, \"Sandbox\", sandbox.GetKind())\n270: \tassert.Contains(t, sandbox.GetName(), \"my-interpreter-\")\n271: \tassert.Equal(t, \"default\", sandbox.GetNamespace())\n272: \tassert.Equal(t, \"test-session-id\", sandbox.GetLabels()[SessionIDLabelKey])\n273: \n274: \tspec := sandbox.Object[\"spec\"].(map[string]interface{})\n275: \tpodTemplate := spec[\"podTemplate\"].(map[string]interface{})\n276: \tpodSpec := podTemplate[\"spec\"].(map[string]interface{})\n277: \tcontainers := podSpec[\"containers\"].([]interface{})\n278: \tcontainer := containers[0].(map[string]interface{})\n279: \n280: \tassert.Equal(t, \"code-interpreter\", container[\"name\"])\n281: \tassert.Equal(t, \"python:3.11\", container[\"image\"])\n282: }\n283: \n284: func TestBuildEntryPoints(t *testing.T) {\n285: \tports := []types.TargetPort{\n286: \t\t{Port: 8080, Protocol: \"HTTP\", PathPrefix: \"/\"},\n287: \t\t{Port: 8443, Protocol: \"HTTPS\", PathPrefix: \"/api/v1\"},\n288: \t}\n289: \n290: \tentryPoints := BuildEntryPoints(\"10.244.0.5\", ports)\n291: \n292: \trequire.Len(t, entryPoints, 2)\n293: \n294: \tassert.Equal(t, \"/\", entryPoints[0].Path)\n295: \tassert.Equal(t, \"HTTP\", entryPoints[0].Protocol)\n296: \tassert.Equal(t, \"10.244.0.5:8080\", entryPoints[0].Endpoint)\n297: \n298: \tassert.Equal(t, \"/api/v1\", entryPoints[1].Path)\n299: \tassert.Equal(t, \"HTTPS\", entryPoints[1].Protocol)\n300: \tassert.Equal(t, \"10.244.0.5:8443\", entryPoints[1].Endpoint)\n301: }\n302: \n303: func TestResolvePodIP(t *testing.T) {\n304: \tpod := &corev1.Pod{\n305: \t\tObjectMeta: metav1.ObjectMeta{\n306: \t\t\tName:      \"test-sandbox\",\n307: \t\t\tNamespace: \"default\",\n308: \t\t\tLabels: map[string]string{\n309: \t\t\t\tSandboxNameLabelKey: \"test-sandbox\",\n310: \t\t\t},\n311: \t\t},\n312: \t\tStatus: corev1.PodStatus{\n313: \t\t\tPhase: corev1.PodRunning,\n314: \t\t\tPodIP: \"10.244.0.5\",\n315: \t\t},\n316: \t}\n317: \n318: \tclient := fake.NewSimpleClientset(pod)\n319: \tlister := &mockPodLister{pods: map[string]*corev1.Pod{\"default/test-sandbox\": pod}}\n320: \n321: \tp := &SandboxProcessor{\n322: \t\tk8sClient: client,\n323: \t\tpodLister: lister,\n324: \t}\n325: \n326: \tip, err := p.resolvePodIP(context.Background(), \"default\", \"test-sandbox\")\n327: \trequire.NoError(t, err)\n328: \tassert.Equal(t, \"10.244.0.5\", ip)\n329: }\n330: \n331: type mockPodLister struct {\n332: \tpods map[string]*corev1.Pod\n333: }\n334: \n335: func (m *mockPodLister) Pods(namespace string) corev1lister.PodNamespaceLister {\n336: \treturn &mockPodNamespaceLister{pods: m.pods, namespace: namespace}\n337: }\n338: \n339: func (m *mockPodLister) List(selector labels.Selector) ([]*corev1.Pod, error) {\n340: \tvar result []*corev1.Pod\n341: \tfor _, pod := range m.pods {\n342: \t\tif selector.Matches(labels.Set(pod.Labels)) {\n343: \t\t\tresult = append(result, pod)\n344: \t\t}\n345: \t}\n346: \treturn result, nil\n347: }\n348: \n349: type mockPodNamespaceLister struct {\n350: \tpods      map[string]*corev1.Pod\n351: \tnamespace string\n352: }\n353: \n354: func (m *mockPodNamespaceLister) Get(name string) (*corev1.Pod, error) {\n355: \tkey := m.namespace + \"/\" + name\n356: \tif pod, ok := m.pods[key]; ok {\n357: \t\treturn pod, nil\n358: \t}\n359: \treturn nil, ErrAgentRuntimeNotFound\n360: }\n361: \n362: func (m *mockPodNamespaceLister) List(selector labels.Selector) ([]*corev1.Pod, error) {\n363: \tvar result []*corev1.Pod\n364: \tfor _, pod := range m.pods {\n365: \t\tif selector.Matches(labels.Set(pod.Labels)) {\n366: \t\t\tresult = append(result, pod)\n367: \t\t}\n368: \t}\n369: \treturn result, nil\n370: }\n\n(End of file - total 370 lines)\n</content>","metadata":{"preview":"package processor\n\nimport (\n\t\"context\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\nfunc TestRandString(t *testing.T) {\n\tt.Run(\"generates correct length\", func(t *testing.T) {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/processor/sandbox_processor_test.go","time":{"start":1775843895860,"end":1775843895884}}}}
{"type":"tool_use","timestamp":1775843895889,"sessionID":"ses_2877500fbffe2ry268eDmqDR9H","part":{"id":"prt_d788b64fd0012V5LTV1B7ER84B","messageID":"msg_d788b4e1600136JVbkefu62vOL","sessionID":"ses_2877500fbffe2ry268eDmqDR9H","type":"tool","tool":"read","callID":"toolu_3736cc00b81d4c68a51fdcdd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/handler/agent_runtime.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/handler/agent_runtime.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"net/http\"\n6: \n7: \t\"github.com/gin-gonic/gin\"\n8: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n9: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n10: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n11: \t\"k8s.io/apimachinery/pkg/runtime\"\n12: \t\"k8s.io/client-go/dynamic\"\n13: \n14: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n15: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n16: )\n17: \n18: type AgentRuntimeHandler struct {\n19: \tclient   dynamic.Interface\n20: \tresource dynamic.NamespaceableResourceInterface\n21: }\n22: \n23: func NewAgentRuntimeHandler(client dynamic.Interface) *AgentRuntimeHandler {\n24: \tgvr := runtimev1alpha1.SchemeGroupVersion.WithResource(\"agentruntimes\")\n25: \treturn &AgentRuntimeHandler{\n26: \t\tclient:   client,\n27: \t\tresource: client.Resource(gvr),\n28: \t}\n29: }\n30: \n31: func getNamespace(c *gin.Context) (string, error) {\n32: \tns := c.Query(\"namespace\")\n33: \tif ns == \"\" {\n34: \t\treturn \"\", nil\n35: \t}\n36: \treturn ns, nil\n37: }\n38: \n39: func mapK8sError(err error) (int, int, string) {\n40: \tswitch {\n41: \tcase apierrors.IsNotFound(err):\n42: \t\treturn http.StatusNotFound, 40401, \"resource not found\"\n43: \tcase apierrors.IsAlreadyExists(err):\n44: \t\treturn http.StatusConflict, 40901, \"resource already exists\"\n45: \tcase apierrors.IsConflict(err):\n46: \t\treturn http.StatusConflict, 40902, \"resourceVersion conflict\"\n47: \tcase apierrors.IsInvalid(err):\n48: \t\treturn http.StatusBadRequest, 40003, err.Error()\n49: \tdefault:\n50: \t\treturn http.StatusInternalServerError, 50002, \"kubernetes API error\"\n51: \t}\n52: }\n53: \n54: func (h *AgentRuntimeHandler) CreateAgentRuntime(c *gin.Context) {\n55: \tvar ar runtimev1alpha1.AgentRuntime\n56: \tif err := c.ShouldBindJSON(&ar); err != nil {\n57: \t\tresponse.Error(c, http.StatusBadRequest, 40002, \"invalid JSON: \"+err.Error())\n58: \t\treturn\n59: \t}\n60: \n61: \tns, err := getNamespace(c)\n62: \tif err != nil {\n63: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n64: \t\treturn\n65: \t}\n66: \tif ns == \"\" && ar.Namespace == \"\" {\n67: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n68: \t\treturn\n69: \t}\n70: \tif ns != \"\" {\n71: \t\tar.Namespace = ns\n72: \t}\n73: \n74: \tif ar.Name == \"\" {\n75: \t\tresponse.Error(c, http.StatusBadRequest, 40003, \"metadata.name is required\")\n76: \t\treturn\n77: \t}\n78: \n79: \tif ar.Spec.Container.Image == \"\" {\n80: \t\tresponse.Error(c, http.StatusBadRequest, 40003, \"spec.container.image is required\")\n81: \t\treturn\n82: \t}\n83: \n84: \tar.TypeMeta = metav1.TypeMeta{\n85: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n86: \t\tKind:       \"AgentRuntime\",\n87: \t}\n88: \n89: \tunstructuredObj, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&ar)\n90: \tif err != nil {\n91: \t\tresponse.Error(c, http.StatusInternalServerError, 50001, \"failed to convert to unstructured: \"+err.Error())\n92: \t\treturn\n93: \t}\n94: \n95: \tcreated, err := h.resource.Namespace(ar.Namespace).Create(c.Request.Context(), &unstructured.Unstructured{Object: unstructuredObj}, metav1.CreateOptions{})\n96: \tif err != nil {\n97: \t\thttpCode, code, msg := mapK8sError(err)\n98: \t\tresponse.Error(c, httpCode, code, msg)\n99: \t\treturn\n100: \t}\n101: \n102: \tresponse.Created(c, created)\n103: }\n104: \n105: func (h *AgentRuntimeHandler) ListAgentRuntimes(c *gin.Context) {\n106: \tns, err := getNamespace(c)\n107: \tif err != nil {\n108: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n109: \t\treturn\n110: \t}\n111: \tif ns == \"\" {\n112: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n113: \t\treturn\n114: \t}\n115: \n116: \tlist, err := h.resource.Namespace(ns).List(c.Request.Context(), metav1.ListOptions{})\n117: \tif err != nil {\n118: \t\thttpCode, code, msg := mapK8sError(err)\n119: \t\tresponse.Error(c, httpCode, code, msg)\n120: \t\treturn\n121: \t}\n122: \n123: \tresponse.JSON(c, http.StatusOK, map[string]interface{}{\n124: \t\t\"items\": list.Items,\n125: \t})\n126: }\n127: \n128: func (h *AgentRuntimeHandler) GetAgentRuntime(c *gin.Context) {\n129: \tname := c.Param(\"name\")\n130: \tns, err := getNamespace(c)\n131: \tif err != nil {\n132: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n133: \t\treturn\n134: \t}\n135: \tif ns == \"\" {\n136: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n137: \t\treturn\n138: \t}\n139: \n140: \tar, err := h.resource.Namespace(ns).Get(c.Request.Context(), name, metav1.GetOptions{})\n141: \tif err != nil {\n142: \t\thttpCode, code, msg := mapK8sError(err)\n143: \t\tresponse.Error(c, httpCode, code, msg)\n144: \t\treturn\n145: \t}\n146: \n147: \tresponse.JSON(c, http.StatusOK, ar)\n148: }\n149: \n150: func (h *AgentRuntimeHandler) UpdateAgentRuntime(c *gin.Context) {\n151: \tname := c.Param(\"name\")\n152: \tns, err := getNamespace(c)\n153: \tif err != nil {\n154: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n155: \t\treturn\n156: \t}\n157: \tif ns == \"\" {\n158: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n159: \t\treturn\n160: \t}\n161: \n162: \tvar ar runtimev1alpha1.AgentRuntime\n163: \tif err := c.ShouldBindJSON(&ar); err != nil {\n164: \t\tresponse.Error(c, http.StatusBadRequest, 40002, \"invalid JSON: \"+err.Error())\n165: \t\treturn\n166: \t}\n167: \n168: \tif ar.Name != name {\n169: \t\tresponse.Error(c, http.StatusBadRequest, 40003, \"name in URL does not match name in body\")\n170: \t\treturn\n171: \t}\n172: \n173: \tar.Namespace = ns\n174: \tar.TypeMeta = metav1.TypeMeta{\n175: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n176: \t\tKind:       \"AgentRuntime\",\n177: \t}\n178: \n179: \tunstructuredObj, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&ar)\n180: \tif err != nil {\n181: \t\tresponse.Error(c, http.StatusInternalServerError, 50001, \"failed to convert to unstructured: \"+err.Error())\n182: \t\treturn\n183: \t}\n184: \n185: \tupdated, err := h.resource.Namespace(ns).Update(c.Request.Context(), &unstructured.Unstructured{Object: unstructuredObj}, metav1.UpdateOptions{})\n186: \tif err != nil {\n187: \t\thttpCode, code, msg := mapK8sError(err)\n188: \t\tresponse.Error(c, httpCode, code, msg)\n189: \t\treturn\n190: \t}\n191: \n192: \tresponse.JSON(c, http.StatusOK, updated)\n193: }\n194: \n195: func (h *AgentRuntimeHandler) DeleteAgentRuntime(c *gin.Context) {\n196: \tname := c.Param(\"name\")\n197: \tns, err := getNamespace(c)\n198: \tif err != nil {\n199: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n200: \t\treturn\n201: \t}\n202: \tif ns == \"\" {\n203: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n204: \t\treturn\n205: \t}\n206: \n207: \terr = h.resource.Namespace(ns).Delete(c.Request.Context(), name, metav1.DeleteOptions{})\n208: \tif err != nil {\n209: \t\thttpCode, code, msg := mapK8sError(err)\n210: \t\tresponse.Error(c, httpCode, code, msg)\n211: \t\treturn\n212: \t}\n213: \n214: \tresponse.JSON(c, http.StatusOK, map[string]string{\n215: \t\t\"message\": fmt.Sprintf(\"agentruntime '%s' deleted\", name),\n216: \t})\n217: }\n\n(End of file - total 217 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/dynamic\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n)\n\ntype AgentRuntimeHandler struct {\n\tclient   dynamic.Interface\n\tresource dynamic.NamespaceableResourceInterface","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/handler/agent_runtime.go","time":{"start":1775843895862,"end":1775843895887}}}}
