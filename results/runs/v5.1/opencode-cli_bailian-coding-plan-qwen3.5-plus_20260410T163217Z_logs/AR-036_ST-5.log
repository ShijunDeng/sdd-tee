{"type":"tool_use","timestamp":1775886294896,"sessionID":"ses_284f48b9fffeAzMtlRGIfh6tQM","part":{"id":"prt_d7b113ee7001twxf3Y6x7bC2Eq","messageID":"msg_d7b111d3a001M1zVbVqgnqyoyY","sessionID":"ses_284f48b9fffeAzMtlRGIfh6tQM","type":"tool","tool":"write","callID":"toolu_0918728ed8914349b6f7d85b","state":{"status":"completed","input":{"content":"\"\"\"Unit tests for AgentCube Dify Plugin.\"\"\"\n\nimport pytest\nimport yaml\nfrom pathlib import Path\n\n\nclass TestManifest:\n    \"\"\"Tests for manifest.yaml structure and content.\"\"\"\n    \n    @pytest.fixture\n    def manifest(self):\n        \"\"\"Load the manifest.yaml file.\"\"\"\n        manifest_path = Path(__file__).parent.parent / \"manifest.yaml\"\n        with open(manifest_path) as f:\n            return yaml.safe_load(f)\n    \n    def test_manifest_has_required_fields(self, manifest):\n        \"\"\"Test that manifest contains all required top-level fields.\"\"\"\n        required_fields = [\n            \"version\", \"type\", \"author\", \"name\", \"label\",\n            \"description\", \"icon\", \"icon_dark\", \"resource\",\n            \"plugins\", \"meta\"\n        ]\n        for field in required_fields:\n            assert field in manifest, f\"Missing required field: {field}\"\n    \n    def test_manifest_version(self, manifest):\n        \"\"\"Test manifest version.\"\"\"\n        assert manifest[\"version\"] == \"0.0.2\"\n    \n    def test_manifest_type(self, manifest):\n        \"\"\"Test manifest type is plugin.\"\"\"\n        assert manifest[\"type\"] == \"plugin\"\n    \n    def test_manifest_author(self, manifest):\n        \"\"\"Test manifest author.\"\"\"\n        assert manifest[\"author\"] == \"volcano-sh\"\n    \n    def test_manifest_label_locales(self, manifest):\n        \"\"\"Test manifest label has all required locales.\"\"\"\n        required_locales = [\"en_US\", \"ja_JP\", \"zh_Hans\", \"pt_BR\"]\n        for locale in required_locales:\n            assert locale in manifest[\"label\"], f\"Missing locale: {locale}\"\n            assert manifest[\"label\"][locale] == \"Agentcube\"\n    \n    def test_manifest_description_locales(self, manifest):\n        \"\"\"Test manifest description has all required locales.\"\"\"\n        required_locales = [\"en_US\", \"ja_JP\", \"zh_Hans\", \"pt_BR\"]\n        for locale in required_locales:\n            assert locale in manifest[\"description\"], f\"Missing locale: {locale}\"\n            assert len(manifest[\"description\"][locale]) > 0\n    \n    def test_manifest_resource_permissions(self, manifest):\n        \"\"\"Test manifest resource permissions.\"\"\"\n        resource = manifest[\"resource\"]\n        assert \"memory\" in resource\n        assert \"permission\" in resource\n        \n        permission = resource[\"permission\"]\n        assert permission[\"tool\"] is True\n        assert \"model\" in permission\n        assert \"endpoint\" in permission\n        assert \"app\" in permission\n        assert \"storage\" in permission\n    \n    def test_manifest_plugins_tools(self, manifest):\n        \"\"\"Test manifest plugins.tools list.\"\"\"\n        assert \"plugins\" in manifest\n        assert \"tools\" in manifest[\"plugins\"]\n        assert \"provider/agentcube.yaml\" in manifest[\"plugins\"][\"tools\"]\n    \n    def test_manifest_meta_runner(self, manifest):\n        \"\"\"Test manifest meta runner configuration.\"\"\"\n        meta = manifest[\"meta\"]\n        assert \"runner\" in meta\n        runner = meta[\"runner\"]\n        assert runner[\"language\"] == \"python\"\n        assert runner[\"version\"] == \"3.12\"\n        assert runner[\"entrypoint\"] == \"main\"\n    \n    def test_manifest_meta_arch(self, manifest):\n        \"\"\"Test manifest meta architecture support.\"\"\"\n        meta = manifest[\"meta\"]\n        assert \"arch\" in meta\n        assert \"amd64\" in meta[\"arch\"]\n        assert \"arm64\" in meta[\"arch\"]\n\n\nclass TestProviderDescriptor:\n    \"\"\"Tests for provider/agentcube.yaml structure.\"\"\"\n    \n    @pytest.fixture\n    def provider(self):\n        \"\"\"Load the provider descriptor.\"\"\"\n        provider_path = Path(__file__).parent.parent / \"provider\" / \"agentcube.yaml\"\n        with open(provider_path) as f:\n            return yaml.safe_load(f)\n    \n    def test_provider_identity(self, provider):\n        \"\"\"Test provider identity fields.\"\"\"\n        identity = provider[\"identity\"]\n        assert identity[\"author\"] == \"agentcube\"\n        assert identity[\"name\"] == \"agentcube\"\n    \n    def test_provider_identity_label(self, provider):\n        \"\"\"Test provider identity label.\"\"\"\n        label = provider[\"identity\"][\"label\"]\n        required_locales = [\"en_US\", \"ja_JP\", \"zh_Hans\", \"pt_BR\"]\n        for locale in required_locales:\n            assert locale in label\n    \n    def test_provider_tools_list(self, provider):\n        \"\"\"Test provider tools list.\"\"\"\n        assert \"tools\" in provider\n        assert \"tools/agentcube-code-interpreter.yaml\" in provider[\"tools\"]\n    \n    def test_provider_python_source(self, provider):\n        \"\"\"Test provider Python source path.\"\"\"\n        assert \"extra\" in provider\n        assert \"python\" in provider[\"extra\"]\n        assert provider[\"extra\"][\"python\"][\"source\"] == \"provider/agentcube.py\"\n\n\nclass TestToolSchema:\n    \"\"\"Tests for tools/agentcube-code-interpreter.yaml schema.\"\"\"\n    \n    @pytest.fixture\n    def tool_schema(self):\n        \"\"\"Load the tool schema.\"\"\"\n        tool_path = Path(__file__).parent.parent / \"tools\" / \"agentcube-code-interpreter.yaml\"\n        with open(tool_path) as f:\n            return yaml.safe_load(f)\n    \n    def test_tool_identity(self, tool_schema):\n        \"\"\"Test tool identity.\"\"\"\n        identity = tool_schema[\"identity\"]\n        assert identity[\"name\"] == \"agentcube-code-interpreter\"\n        assert identity[\"author\"] == \"agentcube\"\n    \n    def test_tool_required_parameters(self, tool_schema):\n        \"\"\"Test tool has required parameters.\"\"\"\n        params = {p[\"name\"]: p for p in tool_schema[\"parameters\"]}\n        \n        assert \"router_url\" in params\n        assert params[\"router_url\"][\"required\"] is True\n        assert params[\"router_url\"][\"type\"] == \"string\"\n        \n        assert \"workload_manager_url\" in params\n        assert params[\"workload_manager_url\"][\"required\"] is True\n        assert params[\"workload_manager_url\"][\"type\"] == \"string\"\n    \n    def test_tool_optional_parameters(self, tool_schema):\n        \"\"\"Test tool has optional parameters.\"\"\"\n        params = {p[\"name\"]: p for p in tool_schema[\"parameters\"]}\n        \n        assert \"language\" in params\n        assert params[\"language\"][\"required\"] is False\n        \n        assert \"code\" in params\n        assert params[\"code\"][\"required\"] is False\n        \n        assert \"command\" in params\n        assert params[\"command\"][\"required\"] is False\n        \n        assert \"session_id\" in params\n        assert params[\"session_id\"][\"required\"] is False\n        \n        assert \"session_reuse\" in params\n        assert params[\"session_reuse\"][\"required\"] is False\n        assert params[\"session_reuse\"][\"type\"] == \"boolean\"\n        \n        assert \"code_interpreter_id\" in params\n        assert params[\"code_interpreter_id\"][\"required\"] is False\n    \n    def test_tool_language_options(self, tool_schema):\n        \"\"\"Test language parameter options.\"\"\"\n        params = {p[\"name\"]: p for p in tool_schema[\"parameters\"]}\n        language_param = params[\"language\"]\n        \n        assert language_param[\"type\"] == \"select\"\n        assert \"options\" in language_param\n        options = [opt[\"value\"] for opt in language_param[\"options\"]]\n        assert \"python\" in options\n        assert \"javascript\" in options\n        assert \"typescript\" in options\n    \n    def test_tool_python_source(self, tool_schema):\n        \"\"\"Test tool Python source path.\"\"\"\n        assert \"extra\" in tool_schema\n        assert \"python\" in tool_schema[\"extra\"]\n        assert tool_schema[\"extra\"][\"python\"][\"source\"] == \"tools/agentcube-code-interpreter.py\"\n\n\nclass TestFileStructure:\n    \"\"\"Tests for plugin file structure.\"\"\"\n    \n    def test_required_files_exist(self):\n        \"\"\"Test that all required files exist.\"\"\"\n        base_path = Path(__file__).parent.parent\n        required_files = [\n            \"main.py\",\n            \"manifest.yaml\",\n            \"requirements.txt\",\n            \".difyignore\",\n            \"README.md\",\n            \"GUIDE.md\",\n            \"PRIVACY.md\",\n            \"icon.png\",\n            \"icon-dark.png\",\n            \"provider/agentcube.yaml\",\n            \"provider/agentcube.py\",\n            \"tools/agentcube-code-interpreter.yaml\",\n            \"tools/agentcube-code-interpreter.py\",\n        ]\n        \n        for file in required_files:\n            file_path = base_path / file\n            assert file_path.exists(), f\"Missing required file: {file}\"\n    \n    def test_requirements_txt(self):\n        \"\"\"Test requirements.txt content.\"\"\"\n        req_path = Path(__file__).parent.parent / \"requirements.txt\"\n        with open(req_path) as f:\n            content = f.read()\n        \n        assert \"dify-plugin>=0.4.2,<0.5.0\" in content\n        assert \"agentcube-sdk>=0.0.10\" in content\n","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/integrations/dify-plugin/tests/__init__.py"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.