ger_url: Base URL of the workload manager service\n            language: Programming language (python, javascript, typescript)\n            code_interpreter_id: Specific interpreter instance ID\n            session_id: Existing session ID to reuse\n            code: Source code to execute\n            command: Shell command to execute\n            session_reuse: Whether to reuse existing session\n            **kwargs: Additional parameters\n            \n        Returns:\n            Dictionary containing execution results\n            \n        Raises:\n            ValueError: If required URLs are not provided\n            RuntimeError: If execution fails\n        \"\"\"\n        if not router_url or not workload_manager_url:\n            raise ValueError(\"router_url and workload_manager_url are required\")\n        \n        try:\n            with CodeInterpreterClient(\n                router_url=router_url,\n                workload_manager_url=workload_manager_url,\n                session_id=session_id,\n                verbose=False,\n            ) as client:\n                if code:\n                    result = client.execute(code=code, language=language)\n                elif command:\n                    result = client.execute(code=command, language=\"bash\")\n                else:\n                    result = {\n                        \"status\": \"success\",\n                        \"output\": \"\",\n                        \"exit_code\": 0,\n                        \"message\": \"No code or command provided\",\n                    }\n                \n                return {\n                    \"success\": True,\n                    \"result\": result,\n                    \"session_id\": client.session_id,\n                }\n                \n        except Exception as e:\n            return {\n                \"success\": False,\n                \"error\": str(e),\n                \"error_type\": type(e).__name__,\n            }\n","filePa