mespace).Create(ctx, newPod, metav1.CreateOptions{})\n276: \tif err != nil {\n277: \t\treturn nil, fmt.Errorf(\"failed to create new pod: %w\", err)\n278: \t}\n279: \n280: \treturn createdPod, nil\n281: }\n282: \n283: func (p *SandboxProcessor) UpdateCodeInterpreterPod(ctx context.Context, pod *corev1.Pod, ci *runtimev1alpha1.CodeInterpreter) (*corev1.Pod, error) {\n284: \tif err := p.k8sClient.CoreV1().Pods(pod.Namespace).Delete(ctx, pod.Name, metav1.DeleteOptions{}); err != nil {\n285: \t\treturn nil, fmt.Errorf(\"failed to delete pod: %w\", err)\n286: \t}\n287: \n288: \tnewPod, err := p.BuildCodeInterpreterPod(ci)\n289: \tif err != nil {\n290: \t\treturn nil, fmt.Errorf(\"failed to build new pod: %w\", err)\n291: \t}\n292: \n293: \tcreatedPod, err := p.k8sClient.CoreV1().Pods(ci.Namespace).Create(ctx, newPod, metav1.CreateOptions{})\n294: \tif err != nil {\n295: \t\treturn nil, fmt.Errorf(\"failed to create new pod: %w\", err)\n296: \t}\n297: \n298: \treturn createdPod, nil\n299: }\n\n(End of file - total 299 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/kubernetes\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nvar (\n\tAgentRuntimeGVK = schema.GroupVersionKind{\n\t\tGroup:   \"runtime.agentcube.volcano.sh\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/reconciler/sandbox_processor.go","time":{"start":1775887837876,"end":1775887837896}}}}
