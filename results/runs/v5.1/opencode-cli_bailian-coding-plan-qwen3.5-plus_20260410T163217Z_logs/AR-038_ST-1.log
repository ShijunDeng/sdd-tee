 kubernetes.Interface,\n40: \tpodLister corev1lister.PodLister,\n41: \tpodIndexer cache.Indexer,\n42: \trecorder record.EventRecorder,\n43: \tmetrics *ReconcilerMetrics,\n44: \tconfig *ReconcilerConfig,\n45: ) *AgentRuntimeReconciler {\n46: \tworkqueue := workqueue.NewNamedRateLimitingQueue(\n47: \t\tworkqueue.DefaultControllerRateLimiter(),\n48: \t\t\"agentruntimes\",\n49: \t)\n50: \n51: \tarResource := dynamicClient.Resource(\n52: \t\truntimev1alpha1.SchemeGroupVersion.WithResource(\"agentruntimes\"),\n53: \t)\n54: \n55: \treconciler := &AgentRuntimeReconciler{\n56: \t\tdynamicClient: dynamicClient,\n57: \t\tk8sClient:     k8sClient,\n58: \t\tarLister:      arResource,\n59: \t\tpodLister:     podLister,\n60: \t\tpodIndexer:    podIndexer,\n61: \t\trecorder:      recorder,\n62: \t\tworkqueue:     workqueue,\n63: \t\tmetrics:       metrics,\n64: \t\tconfig:        config,\n65: \t\tprocessor:     NewSandboxProcessor(k8sClient),\n66: \t\tstatusUpdater: NewStatusUpdater(dynamicClient),\n67: \t}\n68: \n69: \treturn reconciler\n70: }\n71: \n72: func (r *AgentRuntimeReconciler) Run(ctx context.Context) {\n73: \tdefer r.workqueue.ShutDown()\n74: \n75: \tfor r.processNextWorkItem(ctx) {\n76: \t}\n77: }\n78: \n79: func (r *AgentRuntimeReconciler) processNextWorkItem(ctx context.Context) bool {\n80: \tobj, shutdown := r.workqueue.Get()\n81: \tif shutdown {\n82: \t\treturn false\n83: \t}\n84: \n85: \tdefer r.workqueue.Done(obj)\n86: \n87: \treq, ok := obj.(Request)\n88: \tif !ok {\n89: \t\tr.workqueue.Forget(obj)\n90: \t\treturn true\n91: \t}\n92: \n93: \tif result, err := r.Reconcile(ctx, req); err != nil {\n94: \t\tr.metrics.RecordError()\n95: \t\tr.workqueue.AddRateLimited(obj)\n96: \t} else if result.Requeue {\n97: \t\tif result.RequeueAfter > 0 {\n98: \t\t\tr.workqueue.Forget(obj)\n99: \t\t\tr.workqueue.AddAfter(obj, result.RequeueAfter)\n100: \t\t} else {\n101: \t\t\tr.workqueue.AddRateLimited(obj)\n102: \t\t}\n103: \t} else {\n104: \t\tr.workqueue.Forget(obj)\n105: \t}\n106: \n107: \treturn true\n108: }\n109: \n110: func (r *AgentRuntimeReconciler) Reconcile(ctx context.Context, req Request) (Result, error) {\n111: \tstartTime := time.Now()\n112: \tdefer func() {\n113: \t\tr.metrics.ObserveReconcileDuration(time.Since(startTime))\n114: \t\tr.metrics.RecordReconcile()\n115: \t}()\n116: \n117: \tar, err := r.getAgentRuntime(req.Namespace, req.Name)\n118: \tif err != nil {\n119: \t\tif k8s_errors.IsNotFound(err) {\n120: \t\t\treturn Result{}, nil\n121: \t\t}\n122: \t\treturn Result{}, fmt.Errorf(\"failed to get AgentRuntime: %w\", err)\n123: \t}\n124: \n125: \tif !ar.DeletionTimestamp.IsZero() {\n126: \t\treturn r.reconcileDeletion(ctx, ar)\n127: \t}\n128: \n129: \tpod, err := r.reconcileSandboxPod(ctx, ar)\n130: \tif err != nil {\n131: \t\tr.recorder.Eventf(ar, corev1.EventTypeWarning, ErrPodCreationFailed, \"Failed to create sandbox pod: %v\", err)\n132: \n133: \t\tif IsRetryableError(err) {\n134: \t\t\treturn Result{RequeueAfter: CalculateBackoff(1)}, nil\n135: \t\t}\n136: \t\treturn Result{}, err\n137: \t}\n138: \n139: \tif err := r.statusUpdater.UpdateAgentRuntimeStatus(ctx, ar, pod); err != nil {\n140: \t\tr.recorder.Eventf(ar, corev1.EventTypeWarning, ErrStatusUpdateFailed, \"Failed to update status: %v\", err)\n141: \n142: \t\tif IsRetryableError(err) {\n143: \t\t\treturn Result{RequeueAfter: CalculateBackoff(2)}, nil\n144: \t\t}\n145: \t\treturn Result{}, err\n146: \t}\n147: \n148: \tr.recorder.Eventf(ar, corev1.EventTypeNormal, \"Reconciled\", \"Successfully reconciled AgentRuntime\")\n149: \n150: \treturn Result{}, nil\n151: }\n152: \n153: func (r *AgentRuntimeReconciler) getAgentRuntime(namespace, name string) (*runtimev1alpha1.AgentRuntime, error) {\n154: \tarMap, err := r.arLister.Namespace(namespace).Get(context.Background(), name, metav1.GetOptions{})\n155: \tif err != nil {\n156: \t\treturn nil, err\n157: \t}\n158: \n159: \tar := &runtimev1alpha1.AgentRuntime{}\n160: \tar.Name = arMap.GetName()\n161: \tar.Namespace = arMap.GetNamespace()\n162: \tar.Labels = arMap.GetLabels()\n163: \tar.Annotations = arMap.GetAnnotations()\n164: \tar.Finalizers = arMap.GetFinalizers()\n165: \n166: \tspecRaw, _ := arMap.MarshalJSON()\n167: \tif err := json.Unmarshal(specRaw, ar); err != nil {\n168: \t\treturn nil, fmt.Errorf(\"failed to unmarshal AgentRuntime: %w\", err)\n169: \t}\n170: \n171: \treturn ar, nil\n172: }\n173: \n174: func (r *AgentRuntimeReconciler) reconcileDeletion(ctx context.Context, ar *runtimev1alpha1.AgentRuntime) (Result, error) {\n175: \tpod, err := r.getSandboxPod(ar.Namespace, ar.Name)\n176: \tif err != nil && !k8s_errors.IsNotFound(err) {\n177: \t\treturn Result{}, fmt.Errorf(\"failed to get pod: %w\", err)\n178: \t}\n179: \n180: \tif pod != nil {\n181: \t\tif err := r.k8sClient.CoreV1().Pods(ar.Namespace).Delete(ctx, pod.Name, metav1.DeleteOptions{}); err != nil && !k8s_errors.IsNotFound(err) {\n182: \t\t\treturn Result{}, fmt.Errorf(\"failed to delete pod: %w\", err)\n183: \t\t}\n184: \t}\n185: \n186: \treturn Result{}, nil\n187: }\n188: \n189: func (r *AgentRuntimeReconciler) reconcileSandboxPod(ctx context.Context, ar *runtimev1alpha1.AgentRuntime) (*corev1.Pod, error) {\n190: \tpod, err := r.getSandboxPod(ar.Namespace, ar.Name)\n191: \tif err != nil && !k8s_errors.IsNotFound(err) {\n192: \t\treturn nil, fmt.Errorf(\"failed to get pod: %w\", err)\n193: \t}\n194: \n195: \tif pod == nil {\n196: \t\tnewPod, err := r.processor.BuildSandboxPod(ar)\n197: \t\tif err != nil {\n198: \t\t\treturn nil, fmt.Errorf(\"failed to build pod: %w\", err)\n199: \t\t}\n200: \n201: \t\tcreatedPod, err := r.k8sClient.CoreV1().Pods(ar.Namespace).Create(ctx, newPod, metav1.CreateOptions{})\n202: \t\tif err != nil {\n203: \t\t\treturn nil, fmt.Errorf(\"failed to create pod: %w\", err)\n204: \t\t}\n205: \n206: \t\treturn createdPod, nil\n207: \t}\n208: \n209: \tif r.processor.NeedsUpdate(pod, ar) {\n210: \t\tupdatedPod, err := r.processor.UpdateSandboxPod(ctx, pod, ar)\n211: \t\tif err != nil {\n212: \t\t\treturn nil, fmt.Errorf(\"failed to update pod: %w\", err)\n213: \t\t}\n214: \t\treturn updatedPod, nil\n215: \t}\n216: \n217: \treturn pod, nil\n218: }\n219: \n220: func (r *AgentRuntimeReconciler) getSandboxPod(namespace, arName string) (*corev1.Pod, error) {\n221: \tpodName := fmt.Sprintf(\"sandbox-%s\", arName)\n222: \n223: \tpod, err := r.podLister.Pods(namespace).Get(podName)\n224: \tif err == nil {\n225: \t\treturn pod, nil\n226: \t}\n227: \n228: \tif !k8s_errors.IsNotFound(err) {\n229: \t\treturn nil, err\n230: \t}\n231: \n232: \tselector := labels.SelectorFromSet(labels.Set{\n233: \t\t\"agentcube.volcano.sh/runtime\": arName,\n234: \t})\n235: \n236: \tpodList, err := r.podLister.Pods(namespace).List(selector)\n237: \tif err != nil {\n238: \t\treturn nil, err\n239: \t}\n240: \n241: \tif len(podList) > 0 {\n242: \t\treturn podList[0], nil\n243: \t}\n244: \n245: \treturn nil, k8s_errors.NewNotFound(corev1.Resource(\"pods\"), podName)\n246: }\n247: \n248: func (r *AgentRuntimeReconciler) EnqueueAgentRuntime(obj interface{}) {\n249: \tenqueueObject(r.workqueue, obj)\n250: }\n251: \n252: func (r *AgentRuntimeReconciler) EnqueueUpdate(oldObj, newObj interface{}) {\n253: \tenqueueUpdate(r.workqueue, oldObj, newObj)\n254: }\n255: \n256: func (r *AgentRuntimeReconciler) EnqueueDelete(obj interface{}) {\n257: \tenqueueDelete(r.workqueue, obj)\n258: }\n259: \n260: func (r *AgentRuntimeReconciler) EnqueueOwnedPod(obj interface{}) {\n261: \tpod, ok := obj.(*corev1.Pod)\n262: \tif !ok {\n263: \t\treturn\n264: \t}\n265: \n266: \townerRef := metav1.GetControllerOf(pod)\n267: \tif ownerRef == nil || ownerRef.Kind != \"AgentRuntime\" {\n268: \t\treturn\n269: \t}\n270: \n271: \tr.workqueue.Add(Request{\n272: \t\tNamespace: pod.Namespace,\n273: \t\tName:      ownerRef.Name,\n274: \t})\n275: }\n276: \n277: func (r *AgentRuntimeReconciler) EnqueueOwnedPodUpdate(oldObj, newObj interface{}) {\n278: \tnewPod, ok := newObj.(*corev1.Pod)\n279: \tif !ok {\n280: \t\treturn\n281: \t}\n282: \n283: \townerRef := metav1.GetControllerOf(newPod)\n284: \tif ownerRef == nil || ownerRef.Kind != \"AgentRuntime\" {\n285: \t\treturn\n286: \t}\n287: \n288: \tr.workqueue.Add(Request{\n289: \t\tNamespace: newPod.Namespace,\n290: \t\tName:      ownerRef.Name,\n291: \t})\n292: }\n293: \n294: func (r *AgentRuntimeReconciler) EnqueueOwnedPodDelete(obj interface{}) {\n295: \tvar pod *corev1.Pod\n296: \n297: \ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n298: \tif ok {\n299: \t\tpod, ok = tombstone.Obj.(*corev1.Pod)\n300: \t\tif !ok {\n301: \t\t\treturn\n302: \t\t}\n303: \t} else {\n304: \t\tpod, ok = obj.(*corev1.Pod)\n305: \t\tif !ok {\n306: \t\t\treturn\n307: \t\t}\n308: \t}\n309: \n310: \townerRef := metav1.GetControllerOf(pod)\n311: \tif ownerRef == nil || ownerRef.Kind != \"AgentRuntime\" {\n312: \t\treturn\n313: \t}\n314: \n315: \tr.workqueue.Add(Request{\n316: \t\tNamespace: pod.Namespace,\n317: \t\tName:      ownerRef.Name,\n318: \t})\n319: }\n\n(End of file - total 319 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tk8s_errors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/client-go/tools/record\"\n\t\"k8s.io/client-go/util/workqueue\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/reconciler/agentruntime_reconciler.go","time":{"start":1775887828546,"end":1775887828563}}}}
