t\tUID:       pod.UID,\n93: \t\t}\n94: \t\tciCopy.Status.Conditions = u.buildConditionsFromPod(pod)\n95: \n96: \t\tif pod.Status.Phase == corev1.PodRunning && pod.Status.StartTime != nil {\n97: \t\t\tciCopy.Status.StartTime = pod.Status.StartTime\n98: \t\t}\n99: \t}\n100: \n101: \tif reflect.DeepEqual(ci.Status, ciCopy.Status) {\n102: \t\treturn nil\n103: \t}\n104: \n105: \tnow := metav1.Now()\n106: \tciCopy.Status.LastTransitionTime = &now\n107: \n108: \treturn u.updateCodeInterpreterStatusSubresource(ctx, ciCopy)\n109: }\n110: \n111: func (u *StatusUpdater) updateAgentRuntimeStatusSubresource(ctx context.Context, ar *runtimev1alpha1.AgentRuntime) error {\n112: \tarUnstructured, err := u.runtimeToUnstructured(ar)\n113: \tif err != nil {\n114: \t\treturn fmt.Errorf(\"failed to convert AgentRuntime to unstructured: %w\", err)\n115: \t}\n116: \n117: \tstatusMap := make(map[string]interface{})\n118: \tstatusBytes, _ := json.Marshal(ar.Status)\n119: \tjson.Unmarshal(statusBytes, &statusMap)\n120: \n121: \tarUnstructured.Object[\"status\"] = statusMap\n122: \n123: \tgvr := schema.GroupVersionResource{\n124: \t\tGroup:    \"runtime.agentcube.volcano.sh\",\n125: \t\tVersion:  \"v1alpha1\",\n126: \t\tResource: \"agentruntimes\",\n127: \t}\n128: \n129: \t_, err = u.dynamicClient.Resource(gvr).Namespace(ar.Namespace).UpdateStatus(ctx, arUnstructured, metav1.UpdateOptions{})\n130: \treturn err\n131: }\n132: \n133: func (u *StatusUpdater) updateCodeInterpreterStatusSubresource(ctx context.Context, ci *runtimev1alpha1.CodeInterpreter) error {\n134: \tciUnstructured, err := u.runtimeToUnstructured(ci)\n135: \tif err != nil {\n136: \t\treturn fmt.Errorf(\"failed to convert CodeInterpreter to unstructured: %w\", err)\n137: \t}\n138: \n139: \tstatusMap := make(map[string]interface{})\n140: \tstatusBytes, _ := json.Marshal(ci.Status)\n141: \tjson.Unmarshal(statusBytes, &statusMap)\n142: \n143: \tciUnstructured.Object[\"status\"] = statusMap\n144: \n145: \tgvr := schema.GroupVersionRe