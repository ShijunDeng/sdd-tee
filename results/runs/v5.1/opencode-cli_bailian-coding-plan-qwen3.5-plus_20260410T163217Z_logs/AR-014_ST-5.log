*testing.T) {\n41: \t\tos.Setenv(\"VALKEY_ADDR\", \"addr1,addr2,addr3\")\n42: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n43: \t\tdefer os.Unsetenv(\"VALKEY_ADDR\")\n44: \t\tdefer os.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n45: \n46: \t\topts, err := makeValkeyOptions()\n47: \t\tif err != nil {\n48: \t\t\tt.Fatalf(\"makeValkeyOptions failed: %v\", err)\n49: \t\t}\n50: \t\tif len(opts.InitAddress) != 3 {\n51: \t\t\tt.Errorf(\"expected 3 addresses, got %d\", len(opts.InitAddress))\n52: \t\t}\n53: \t\tif opts.InitAddress[0] != \"addr1\" {\n54: \t\t\tt.Errorf(\"expected first address 'addr1', got %q\", opts.InitAddress[0])\n55: \t\t}\n56: \t\tif opts.InitAddress[1] != \"addr2\" {\n57: \t\t\tt.Errorf(\"expected second address 'addr2', got %q\", opts.InitAddress[1])\n58: \t\t}\n59: \t\tif opts.InitAddress[2] != \"addr3\" {\n60: \t\t\tt.Errorf(\"expected third address 'addr3', got %q\", opts.InitAddress[2])\n61: \t\t}\n62: \t})\n63: \n64: \tt.Run(\"VALKEY_DISABLE_CACHE=true\", func(t *testing.T) {\n65: \t\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n66: \t\tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n67: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n68: \t\tdefer os.Unsetenv(\"VALKEY_ADDR\")\n69: \t\tdefer os.Unsetenv(\"VALKEY_DISABLE_CACHE\")\n70: \t\tdefer os.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n71: \n72: \t\topts, err := makeValkeyOptions()\n73: \t\tif err != nil {\n74: \t\t\tt.Fatalf(\"makeValkeyOptions failed: %v\", err)\n75: \t\t}\n76: \t\tif !opts.DisableCache {\n77: \t\t\tt.Error(\"expected DisableCache=true, got false\")\n78: \t\t}\n79: \t})\n80: \n81: \tt.Run(\"VALKEY_FORCE_SINGLE=true\", func(t *testing.T) {\n82: \t\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n83: \t\tos.Setenv(\"VALKEY_FORCE_SINGLE\", \"true\")\n84: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n85: \t\tdefer os.Unsetenv(\"VALKEY_ADDR\")\n86: \t\tdefer os.Unsetenv(\"VALKEY_FORCE_SINGLE\")\n87: \t\tdefer os.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n88: \n89: \t\topts, err := makeValkeyOptions()\n90: \t\tif err != nil {\n91: \t\t\tt.Fatalf(\"makeValkeyOptions failed: %v\", err)\n92: \t\t}\n93: \t\tif !opts.ForceSingleClient {\n94: \t\t\tt.Error(\"expected ForceSingleClient=true, got false\")\n95: \t\t}\n96: \t})\n97: \n98: \tt.Run(\"password required but empty\", func(t *testing.T) {\n99: \t\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n100: \t\tos.Unsetenv(\"VALKEY_PASSWORD\")\n101: \t\tos.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n102: \t\tdefer os.Unsetenv(\"VALKEY_ADDR\")\n103: \n104: \t\t_, err := makeValkeyOptions()\n105: \t\tif err == nil {\n106: \t\t\tt.Fatal(\"expected error for missing password, got nil\")\n107: \t\t}\n108: \t})\n109: \n110: \tt.Run(\"VALKEY_PASSWORD_REQUIRED=false\", func(t *testing.T) {\n111: \t\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n112: \t\tos.Unsetenv(\"VALKEY_PASSWORD\")\n113: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n114: \t\tdefer os.Unsetenv(\"VALKEY_ADDR\")\n115: \t\tdefer os.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n116: \n117: \t\topts, err := makeValkeyOptions()\n118: \t\tif err != nil {\n119: \t\t\tt.Fatalf(\"makeValkeyOptions failed: %v\", err)\n120: \t\t}\n121: \t\tif opts.Password != \"\" {\n122: \t\t\tt.Errorf(\"expected empty Password, got %q\", opts.Password)\n123: \t\t}\n124: \t})\n125: }\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"os\"\n\t\"testing\"\n)\n\nfunc TestMakeValkeyOptions(t *testing.T) {\n\tt.Run(\"with all env vars set\", func(t *testing.T) {\n\t\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\t\tos.Setenv(\"VALKEY_PASSWORD\", \"secret\")\n\t\tdefer os.Unsetenv(\"VALKEY_ADDR\")\n\t\tdefer os.Unsetenv(\"VALKEY_PASSWORD\")\n\n\t\topts, err := makeValkeyOptions()\n\t\tif err != nil {\n\t\t\tt.Fatalf(\"makeValkeyOptions failed: %v\", err)\n\t\t}\n\t\tif len(opts.InitAddress) != 1 || opts.InitAddress[0] != \"localhost:6379\" {\n\t\t\tt.Errorf(\"expected InitAddress ['localhost:637