\n188: \t\t\treturn fmt.Errorf(\"command %d failed: %w\", i, err)\n189: \t\t}\n190: \t}\n191: \n192: \treturn nil\n193: }\n\n(Showing lines 154-193 of 284. Use offset=194 to continue.)\n</content>","metadata":{"preview":"func (vs *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *wmTypes.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n\t}\n\n\tkey := vs.sessionPrefix + sandboxStore.SessionID\n\tdata, err := json.Marshal(sandboxStore)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n\t}\n\n\tcmd := vs.cli.B().Set().Key(key).Value(string(data)).Xx().Build()\n\tresult, err := vs.cli.Do(ctx, cmd).ToString()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"SET XX failed: %w\", err)\n\t}\n\tif result != \"OK\" {\n\t\treturn ErrNotFound\n\t}\n","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_valkey.go","time":{"start":1775857859190,"end":1775857859198}}}}
