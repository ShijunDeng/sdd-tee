"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_valkey_integration_test.go","before":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\nfunc setupValkeyTest(t *testing.T) (*miniredis.Miniredis, *valkeyStore) {\n\tt.Helper()\n\tmr, err := miniredis.Run()\n\tif err != nil {\n\t\tt.Fatalf(\"miniredis failed: %v\", err)\n\t}\n\n\tos.Setenv(\"VALKEY_ADDR\", mr.Addr())\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n\n\topts, _ := makeValkeyOptions()\n\tstore, err := NewValkeyStore(opts)\n\tif err != nil {\n\t\tmr.Close()\n\t\tt.Fatalf(\"NewValkeyStore failed: %v\", err)\n\t}\n\n\treturn mr, store\n}\n\n// TestValkeyStorePing tests the Ping operation\nfunc TestValkeyStorePing(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\terr := store.Ping(context.Background())\n\tif err != nil {\n\t\tt.Errorf(\"Ping failed: %v\", err)\n\t}\n}\n\n// TestValkeyStoreGetSandboxBySessionIDNotFound tests getting a non-existent session\nfunc TestValkeyStoreGetSandboxBySessionIDNotFound(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\t_, err := store.GetSandboxBySessionID(context.Background(), \"nonexistent\")\n\tif err != ErrNotFound {\n\t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n\t}\n}\n\n// TestValkeyStoreStoreSandboxNil tests storing a nil sandbox\nfunc TestValkeyStoreStoreSandboxNil(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\terr := store.StoreSandbox(context.Background(), nil)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for nil sandbox, got nil\")\n\t}\n}\n\n// TestValkeyStoreStoreSandboxZeroExpiresAt tests storing a sandbox with zero ExpiresAt\nfunc TestValkeyStoreStoreSandboxZeroExpiresAt(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tinfo := &wmTypes.SandboxInfo{\n\t\tSessionID: \"session-1\",\n\t\tExpiresAt: time.Time{},\n\t}\n\n\terr := store.StoreSandbox(context.Background(), info)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for zero ExpiresAt, got nil\")\n\t}\n}\n\n// TestValkeyStoreStoreSandbox tests storing and retrieving a sandbox\nfunc TestValkeyStoreStoreSandbox(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tinfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"session-1\",\n\t\tSandboxID:        \"sandbox-1\",\n\t\tSandboxName:      \"test-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        time.Now(),\n\t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n\t\tLastActivityAt:   time.Now(),\n\t}\n\n\terr := store.StoreSandbox(context.Background(), info)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n\t}\n\n\tretrieved, err := store.GetSandboxBySessionID(context.Background(), \"session-1\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID failed: %v\", err)\n\t}\n\n\tif retrieved.SessionID != info.SessionID {\n\t\tt.Errorf(\"expected SessionID %q, got %q\", info.SessionID, retrieved.SessionID)\n\t}\n}\n\n// TestValkeyStoreStoreSandboxDuplicate tests storing a duplicate session\nfunc TestValkeyStoreStoreSandboxDuplicate(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tinfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"session-1\",\n\t\tSandboxID:        \"sandbox-1\",\n\t\tSandboxName:      \"test-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        time.Now(),\n\t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n\t\tLastActivityAt:   time.Now(),\n\t}\n\n\terr := store.StoreSandbox(context.Background(), info)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n\t}\n\n\terr = store.StoreSandbox(context.Background(), info)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for duplicate session, got nil\")\n\t}\n}\n\n// TestValkeyStoreUpdateSandboxNotFound tests updating a non-existent session\nfunc TestValkeyStoreUpdateSandboxNotFound(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tinfo := &wmTypes.SandboxInfo{\n\t\tSessionID: \"session-1\",\n\t\tExpiresAt: time.Now().Add(8 * time.Hour),\n\t}\n\n\terr := store.UpdateSandbox(context.Background(), info)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for non-existent session, got nil\")\n\t}\n}\n\n// TestValkeyStoreUpdateSandbox tests updating an existing session\nfunc TestValkeyStoreUpdateSandbox(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tinfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"session-1\",\n\t\tSandboxID:        \"sandbox-1\",\n\t\tSandboxName:      \"test-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        time.Now(),\n\t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n\t\tLastActivityAt:   time.Now(),\n\t}\n\n\terr := store.StoreSandbox(context.Background(), info)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n\t}\n\n\tinfo.Status = \"Updated\"\n\terr = store.UpdateSandbox(context.Background(), info)\n\tif err != nil {\n\t\tt.Fatalf(\"UpdateSandbox failed: %v\", err)\n\t}\n\n\tretrieved, err := store.GetSandboxBySessionID(context.Background(), \"session-1\")\n\tif err != nil {\n\t\tt.Fatalf(\"GetSandboxBySessionID failed: %v\", err)\n\t}\n\n\tif retrieved.Status != \"Updated\" {\n\t\tt.Errorf(\"expected Status 'Updated', got %q\", retrieved.Status)\n\t}\n}\n\n// TestValkeyStoreDeleteSandboxBySessionID tests deleting a session\nfunc TestValkeyStoreDeleteSandboxBySessionID(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tinfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"session-1\",\n\t\tSandboxID:        \"sandbox-1\",\n\t\tSandboxName:      \"test-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        time.Now(),\n\t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n\t\tLastActivityAt:   time.Now(),\n\t}\n\n\terr := store.StoreSandbox(ctx, info)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n\t}\n\n\terr = store.DeleteSandboxBySessionID(ctx, \"session-1\")\n\tif err != nil {\n\t\tt.Fatalf(\"DeleteSandboxBySessionID failed: %v\", err)\n\t}\n\n\t_, err = store.GetSandboxBySessionID(ctx, \"session-1\")\n\tif err != ErrNotFound {\n\t\tt.Errorf(\"expected ErrNotFound after delete, got %v\", err)\n\t}\n}\n\n// TestValkeyStoreDeleteSandboxBySessionIDNonExistent tests deleting a non-existent session\nfunc TestValkeyStoreDeleteSandboxBySessionIDNonExistent(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\terr := store.DeleteSandboxBySessionID(context.Background(), \"nonexistent\")\n\tif err != nil {\n\t\tt.Errorf(\"DeleteSandboxBySessionID should be idempotent, got error: %v\", err)\n\t}\n}\n\n// TestValkeyStoreListExpiredSandboxesZeroLimit tests listing with zero limit\nfunc TestValkeyStoreListExpiredSandboxesZeroLimit(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tresult, err := store.ListExpiredSandboxes(context.Background(), time.Now(), 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes failed: %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Errorf(\"expected nil result for limit 0, got %v\", result)\n\t}\n}\n\n// TestValkeyStoreListExpiredSandboxes tests listing expired sandboxes\nfunc TestValkeyStoreListExpiredSandboxes(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\texpiredInfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"expired-session\",\n\t\tSandboxID:        \"sandbox-1\",\n\t\tSandboxName:      \"expired-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        now.Add(-10 * time.Hour),\n\t\tExpiresAt:        now.Add(-2 * time.Hour),\n\t\tLastActivityAt:   now.Add(-9 * time.Hour),\n\t}\n\n\tactiveInfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"active-session\",\n\t\tSandboxID:        \"sandbox-2\",\n\t\tSandboxName:      \"active-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload-2\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        now.Add(-1 * time.Hour),\n\t\tExpiresAt:        now.Add(7 * time.Hour),\n\t\tLastActivityAt:   now.Add(-30 * time.Minute),\n\t}\n\n\terr := store.StoreSandbox(ctx, expiredInfo)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed for expired: %v\", err)\n\t}\n\n\terr = store.StoreSandbox(ctx, activeInfo)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed for active: %v\", err)\n\t}\n\n\tresult, err := store.ListExpiredSandboxes(ctx, now, 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListExpiredSandboxes failed: %v\", err)\n\t}\n\n\tif len(result) != 1 {\n\t\tt.Errorf(\"expected 1 expired sandbox, got %d\", len(result))\n\t} else if result[0].SessionID != \"expired-session\" {\n\t\tt.Errorf(\"expected expired-session, got %s\", result[0].SessionID)\n\t}\n}\n\n// TestValkeyStoreListInactiveSandboxesZeroLimit tests listing inactive with zero limit\nfunc TestValkeyStoreListInactiveSandboxesZeroLimit(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tresult, err := store.ListInactiveSandboxes(context.Background(), time.Now(), 0)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes failed: %v\", err)\n\t}\n\tif result != nil {\n\t\tt.Errorf(\"expected nil result for limit 0, got %v\", result)\n\t}\n}\n\n// TestValkeyStoreListInactiveSandboxes tests listing inactive sandboxes\nfunc TestValkeyStoreListInactiveSandboxes(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tnow := time.Now()\n\n\tactiveInfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"active-session\",\n\t\tSandboxID:        \"sandbox-1\",\n\t\tSandboxName:      \"active-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        now.Add(-1 * time.Hour),\n\t\tExpiresAt:        now.Add(7 * time.Hour),\n\t\tLastActivityAt:   now.Add(-30 * time.Minute),\n\t}\n\n\tinactiveInfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"inactive-session\",\n\t\tSandboxID:        \"sandbox-2\",\n\t\tSandboxName:      \"inactive-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload-2\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        now.Add(-10 * time.Hour),\n\t\tExpiresAt:        now.Add(6 * time.Hour),\n\t\tLastActivityAt:   now.Add(-5 * time.Hour),\n\t}\n\n\terr := store.StoreSandbox(ctx, activeInfo)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed for active: %v\", err)\n\t}\n\n\terr = store.StoreSandbox(ctx, inactiveInfo)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed for inactive: %v\", err)\n\t}\n\n\tresult, err := store.ListInactiveSandboxes(ctx, now.Add(-1*time.Hour), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes failed: %v\", err)\n\t}\n\n\tif len(result) != 1 {\n\t\tt.Errorf(\"expected 1 inactive sandbox, got %d\", len(result))\n\t} else if result[0].SessionID != \"inactive-session\" {\n\t\tt.Errorf(\"expected inactive-session, got %s\", result[0].SessionID)\n\t}\n}\n\n// TestValkeyStoreUpdateSessionLastActivityEmptySessionID tests updating with empty session ID\nfunc TestValkeyStoreUpdateSessionLastActivityEmptySessionID(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\terr := store.UpdateSessionLastActivity(context.Background(), \"\", time.Now())\n\tif err == nil {\n\t\tt.Fatal(\"expected error for empty sessionID, got nil\")\n\t}\n}\n\n// TestValkeyStoreUpdateSessionLastActivityNotFound tests updating last activity for non-existent session\nfunc TestValkeyStoreUpdateSessionLastActivityNotFound(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\terr := store.UpdateSessionLastActivity(context.Background(), \"nonexistent\", time.Now())\n\tif err != ErrNotFound {\n\t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n\t}\n}\n\n// TestValkeyStoreUpdateSessionLastActivity tests updating last activity\nfunc TestValkeyStoreUpdateSessionLastActivity(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tinfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"session-1\",\n\t\tSandboxID:        \"sandbox-1\",\n\t\tSandboxName:      \"test-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        time.Now(),\n\t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n\t\tLastActivityAt:   time.Now().Add(-1 * time.Hour),\n\t}\n\n\terr := store.StoreSandbox(ctx, info)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n\t}\n\n\tnewActivity := time.Now().Add(1 * time.Hour)\n\terr = store.UpdateSessionLastActivity(ctx, \"session-1\", newActivity)\n\tif err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity failed: %v\", err)\n\t}\n\n\tinactiveList, err := store.ListInactiveSandboxes(ctx, newActivity.Add(-30*time.Minute), 10)\n\tif err != nil {\n\t\tt.Fatalf(\"ListInactiveSandboxes failed: %v\", err)\n\t}\n\n\tif len(inactiveList) != 1 {\n\t\tt.Errorf(\"expected 1 inactive sandbox, got %d\", len(inactiveList))\n\t}\n}\n\n// TestValkeyStoreUpdateSessionLastActivityZeroTime tests updating with zero time\nfunc TestValkeyStoreUpdateSessionLastActivityZeroTime(t *testing.T) {\n\tmr, store := setupValkeyTest(t)\n\tdefer mr.Close()\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tinfo := &wmTypes.SandboxInfo{\n\t\tSessionID:        \"session-1\",\n\t\tSandboxID:        \"sandbox-1\",\n\t\tSandboxName:      \"test-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             wmTypes.AgentRuntimeKind,\n\t\tNamespace:        \"default\",\n\t\tWorkloadName:     \"test-workload\",\n\t\tStatus:           \"Running\",\n\t\tCreatedAt:        time.Now(),\n\t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n\t\tLastActivityAt:   time.Now(),\n\t}\n\n\terr := store.StoreSandbox(ctx, info)\n\tif err != nil {\n\t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n\t}\n\n\terr = store.UpdateSessionLastActivity(ctx, \"session-1\", time.Time{})\n\tif err != nil {\n\t\tt.Fatalf(\"UpdateSessionLastActivity with zero time failed: %v\", err)\n\t}\n}\n\n// TestValkeyStoreClose tests