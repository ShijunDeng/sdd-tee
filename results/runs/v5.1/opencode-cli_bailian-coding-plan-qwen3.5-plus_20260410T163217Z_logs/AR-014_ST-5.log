ind:             types.AgentRuntimeKind,\n45: \t\tNamespace:        \"default\",\n46: \t\tWorkloadName:     \"test-workload\",\n47: \t\tStatus:           \"Running\",\n48: \t\tPodIP:            \"10.0.0.1\",\n49: \t\tCreatedAt:        time.Date(2024, 1, 1, 0, 0, 0, 0, time.UTC),\n50: \t\tUpdatedAt:        time.Date(2024, 1, 1, 0, 0, 0, 0, time.UTC),\n51: \t\tExpiresAt:        time.Date(2024, 1, 1, 8, 0, 0, 0, time.UTC),\n52: \t\tLastActivityAt:   time.Date(2024, 1, 1, 0, 30, 0, 0, time.UTC),\n53: \t\tEntryPoints: []types.SandboxEntryPoint{\n54: \t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"10.0.0.1:8080\"},\n55: \t\t},\n56: \t}\n57: \n58: \tdata, err := marshalSandboxInfo(info)\n59: \tif err != nil {\n60: \t\tt.Fatalf(\"marshalSandboxInfo failed: %v\", err)\n61: \t}\n62: \n63: \tif data == \"\" {\n64: \t\tt.Fatal(\"marshalSandboxInfo returned empty string\")\n65: \t}\n66: }\n67: \n68: func TestUnmarshalSandboxInfo(t *testing.T) {\n69: \tdata := `{\"sessionId\":\"session-1\",\"sandboxId\":\"sandbox-1\",\"sandboxName\":\"test\",\"sandboxNamespace\":\"default\",\"kind\":\"AgentRuntime\",\"namespace\":\"default\",\"workloadName\":\"test\",\"status\":\"Running\",\"createdAt\":\"2024-01-01T00:00:00Z\",\"updatedAt\":\"2024-01-01T00:00:00Z\",\"expiresAt\":\"2024-01-01T08:00:00Z\",\"lastActivityAt\":\"2024-01-01T00:30:00Z\"}`\n70: \n71: \tinfo := &types.SandboxInfo{}\n72: \terr := unmarshalSandboxInfo(data, info)\n73: \tif err != nil {\n74: \t\tt.Fatalf(\"unmarshalSandboxInfo failed: %v\", err)\n75: \t}\n76: \n77: \tif info.SessionID != \"session-1\" {\n78: \t\tt.Errorf(\"expected SessionID 'session-1', got %q\", info.SessionID)\n79: \t}\n80: \tif info.SandboxID != \"sandbox-1\" {\n81: \t\tt.Errorf(\"expected SandboxID 'sandbox-1', got %q\", info.SandboxID)\n82: \t}\n83: \tif info.Kind != types.AgentRuntimeKind {\n84: \t\tt.Errorf(\"expected Kind 'AgentRuntime', got %q\", info.Kind)\n85: \t}\n86: }\n87: \n88: func TestUnmarshalSandboxInfoInvalidJSON(t *testing.T) {\n89: \tdata := `{\"invalid json}`\n90: \n91: \tinfo := &types.SandboxInfo{}\n92: \terr := unmarshalSandboxInfo(data, info)\n93: \tif err == nil {\n94: \t\tt.Fatal(\"expected error for invalid JSON, got nil\")\n95: \t}\n96: }\n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestErrNotFound(t *testing.T) {\n\tif ErrNotFound.Error() != \"store: not found\" {\n\t\tt.Errorf(\"expected ErrNotFound to be 'store: not found', got %q\", ErrNotFound.Error())\n\t}\n}\n\nfunc TestSessionKey(t *testing.T) {\n\ttests := []struct {\n\t\tname      string\n\t\tsessionID string\n\t\twant      string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_test.go","time":{"start":1775857598341,"end":1775857598356}}}}
