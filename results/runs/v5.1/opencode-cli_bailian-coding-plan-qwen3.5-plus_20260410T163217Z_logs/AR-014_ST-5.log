{"type":"tool_use","timestamp":1775857598356,"sessionID":"ses_286a45edbffeb2i4Bne1Azi1xR","part":{"id":"prt_d795c694e001wtzbrth6EqI6TK","messageID":"msg_d795c5e5c001msfU7VBAPRYOzd","sessionID":"ses_286a45edbffeb2i4Bne1Azi1xR","type":"tool","tool":"read","callID":"toolu_8c171108189247faa4843c1f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_redis_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_redis_test.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"os\"\n6: \t\"testing\"\n7: \t\"time\"\n8: \n9: \t\"github.com/alicebob/miniredis/v2\"\n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: func TestMakeRedisOptions(t *testing.T) {\n14: \tt.Run(\"with all env vars set\", func(t *testing.T) {\n15: \t\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n16: \t\tos.Setenv(\"REDIS_PASSWORD\", \"secret\")\n17: \t\tdefer os.Unsetenv(\"REDIS_ADDR\")\n18: \t\tdefer os.Unsetenv(\"REDIS_PASSWORD\")\n19: \n20: \t\topts, err := makeRedisOptions()\n21: \t\tif err != nil {\n22: \t\t\tt.Fatalf(\"makeRedisOptions failed: %v\", err)\n23: \t\t}\n24: \t\tif opts.Addr != \"localhost:6379\" {\n25: \t\t\tt.Errorf(\"expected Addr 'localhost:6379', got %q\", opts.Addr)\n26: \t\t}\n27: \t\tif opts.Password != \"secret\" {\n28: \t\t\tt.Errorf(\"expected Password 'secret', got %q\", opts.Password)\n29: \t\t}\n30: \t})\n31: \n32: \tt.Run(\"missing REDIS_ADDR\", func(t *testing.T) {\n33: \t\tos.Unsetenv(\"REDIS_ADDR\")\n34: \t\tos.Unsetenv(\"REDIS_PASSWORD\")\n35: \n36: \t\t_, err := makeRedisOptions()\n37: \t\tif err == nil {\n38: \t\t\tt.Fatal(\"expected error for missing REDIS_ADDR, got nil\")\n39: \t\t}\n40: \t\tif err.Error() != \"REDIS_ADDR is required\" {\n41: \t\t\tt.Errorf(\"unexpected error: %v\", err)\n42: \t\t}\n43: \t})\n44: \n45: \tt.Run(\"password required but empty\", func(t *testing.T) {\n46: \t\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n47: \t\tos.Unsetenv(\"REDIS_PASSWORD\")\n48: \t\tos.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n49: \t\tdefer os.Unsetenv(\"REDIS_ADDR\")\n50: \n51: \t\t_, err := makeRedisOptions()\n52: \t\tif err == nil {\n53: \t\t\tt.Fatal(\"expected error for missing password, got nil\")\n54: \t\t}\n55: \t})\n56: \n57: \tt.Run(\"REDIS_PASSWORD_REQUIRED=false\", func(t *testing.T) {\n58: \t\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n59: \t\tos.Unsetenv(\"REDIS_PASSWORD\")\n60: \t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n61: \t\tdefer os.Unsetenv(\"REDIS_ADDR\")\n62: \t\tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n63: \n64: \t\topts, err := makeRedisOptions()\n65: \t\tif err != nil {\n66: \t\t\tt.Fatalf(\"makeRedisOptions failed: %v\", err)\n67: \t\t}\n68: \t\tif opts.Password != \"\" {\n69: \t\t\tt.Errorf(\"expected empty Password, got %q\", opts.Password)\n70: \t\t}\n71: \t})\n72: }\n73: \n74: func TestRedisStorePing(t *testing.T) {\n75: \tmr, err := miniredis.Run()\n76: \tif err != nil {\n77: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n78: \t}\n79: \tdefer mr.Close()\n80: \n81: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n82: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n83: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n84: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n85: \n86: \topts, _ := makeRedisOptions()\n87: \tstore := NewRedisStore(opts)\n88: \tdefer store.Close()\n89: \n90: \terr = store.Ping(context.Background())\n91: \tif err != nil {\n92: \t\tt.Errorf(\"Ping failed: %v\", err)\n93: \t}\n94: }\n95: \n96: func TestRedisStoreGetSandboxBySessionIDNotFound(t *testing.T) {\n97: \tmr, err := miniredis.Run()\n98: \tif err != nil {\n99: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n100: \t}\n101: \tdefer mr.Close()\n102: \n103: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n104: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n105: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n106: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n107: \n108: \topts, _ := makeRedisOptions()\n109: \tstore := NewRedisStore(opts)\n110: \tdefer store.Close()\n111: \n112: \t_, err = store.GetSandboxBySessionID(context.Background(), \"nonexistent\")\n113: \tif err != ErrNotFound {\n114: \t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n115: \t}\n116: }\n117: \n118: func TestRedisStoreStoreSandboxNil(t *testing.T) {\n119: \tmr, err := miniredis.Run()\n120: \tif err != nil {\n121: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n122: \t}\n123: \tdefer mr.Close()\n124: \n125: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n126: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n127: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n128: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n129: \n130: \topts, _ := makeRedisOptions()\n131: \tstore := NewRedisStore(opts)\n132: \tdefer store.Close()\n133: \n134: \terr = store.StoreSandbox(context.Background(), nil)\n135: \tif err == nil {\n136: \t\tt.Fatal(\"expected error for nil sandbox, got nil\")\n137: \t}\n138: }\n139: \n140: func TestRedisStoreStoreSandbox(t *testing.T) {\n141: \tmr, err := miniredis.Run()\n142: \tif err != nil {\n143: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n144: \t}\n145: \tdefer mr.Close()\n146: \n147: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n148: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n149: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n150: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n151: \n152: \topts, _ := makeRedisOptions()\n153: \tstore := NewRedisStore(opts)\n154: \tdefer store.Close()\n155: \n156: \tinfo := &types.SandboxInfo{\n157: \t\tSessionID:        \"session-1\",\n158: \t\tSandboxID:        \"sandbox-1\",\n159: \t\tSandboxName:      \"test-sandbox\",\n160: \t\tSandboxNamespace: \"default\",\n161: \t\tKind:             types.AgentRuntimeKind,\n162: \t\tNamespace:        \"default\",\n163: \t\tWorkloadName:     \"test-workload\",\n164: \t\tStatus:           \"Running\",\n165: \t\tCreatedAt:        time.Now(),\n166: \t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n167: \t\tLastActivityAt:   time.Now(),\n168: \t}\n169: \n170: \terr = store.StoreSandbox(context.Background(), info)\n171: \tif err != nil {\n172: \t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n173: \t}\n174: \n175: \tretrieved, err := store.GetSandboxBySessionID(context.Background(), \"session-1\")\n176: \tif err != nil {\n177: \t\tt.Fatalf(\"GetSandboxBySessionID failed: %v\", err)\n178: \t}\n179: \n180: \tif retrieved.SessionID != info.SessionID {\n181: \t\tt.Errorf(\"expected SessionID %q, got %q\", info.SessionID, retrieved.SessionID)\n182: \t}\n183: }\n184: \n185: func TestRedisStoreUpdateSandboxNotFound(t *testing.T) {\n186: \tmr, err := miniredis.Run()\n187: \tif err != nil {\n188: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n189: \t}\n190: \tdefer mr.Close()\n191: \n192: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n193: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n194: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n195: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n196: \n197: \topts, _ := makeRedisOptions()\n198: \tstore := NewRedisStore(opts)\n199: \tdefer store.Close()\n200: \n201: \tinfo := &types.SandboxInfo{\n202: \t\tSessionID: \"session-1\",\n203: \t\tExpiresAt: time.Now().Add(8 * time.Hour),\n204: \t}\n205: \n206: \terr = store.UpdateSandbox(context.Background(), info)\n207: \tif err != ErrNotFound {\n208: \t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n209: \t}\n210: }\n211: \n212: func TestRedisStoreDeleteSandboxBySessionID(t *testing.T) {\n213: \tmr, err := miniredis.Run()\n214: \tif err != nil {\n215: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n216: \t}\n217: \tdefer mr.Close()\n218: \n219: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n220: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n221: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n222: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n223: \n224: \topts, _ := makeRedisOptions()\n225: \tstore := NewRedisStore(opts)\n226: \tdefer store.Close()\n227: \n228: \tctx := context.Background()\n229: \tinfo := &types.SandboxInfo{\n230: \t\tSessionID:        \"session-1\",\n231: \t\tSandboxID:        \"sandbox-1\",\n232: \t\tSandboxName:      \"test-sandbox\",\n233: \t\tSandboxNamespace: \"default\",\n234: \t\tKind:             types.AgentRuntimeKind,\n235: \t\tNamespace:        \"default\",\n236: \t\tWorkloadName:     \"test-workload\",\n237: \t\tStatus:           \"Running\",\n238: \t\tCreatedAt:        time.Now(),\n239: \t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n240: \t\tLastActivityAt:   time.Now(),\n241: \t}\n242: \n243: \terr = store.StoreSandbox(ctx, info)\n244: \tif err != nil {\n245: \t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n246: \t}\n247: \n248: \terr = store.DeleteSandboxBySessionID(ctx, \"session-1\")\n249: \tif err != nil {\n250: \t\tt.Fatalf(\"DeleteSandboxBySessionID failed: %v\", err)\n251: \t}\n252: \n253: \t_, err = store.GetSandboxBySessionID(ctx, \"session-1\")\n254: \tif err != ErrNotFound {\n255: \t\tt.Errorf(\"expected ErrNotFound after delete, got %v\", err)\n256: \t}\n257: }\n258: \n259: func TestRedisStoreListExpiredSandboxesZeroLimit(t *testing.T) {\n260: \tmr, err := miniredis.Run()\n261: \tif err != nil {\n262: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n263: \t}\n264: \tdefer mr.Close()\n265: \n266: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n267: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n268: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n269: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n270: \n271: \topts, _ := makeRedisOptions()\n272: \tstore := NewRedisStore(opts)\n273: \tdefer store.Close()\n274: \n275: \tresult, err := store.ListExpiredSandboxes(context.Background(), time.Now(), 0)\n276: \tif err != nil {\n277: \t\tt.Fatalf(\"ListExpiredSandboxes failed: %v\", err)\n278: \t}\n279: \tif result != nil {\n280: \t\tt.Errorf(\"expected nil result for limit 0, got %v\", result)\n281: \t}\n282: }\n283: \n284: func TestRedisStoreUpdateSessionLastActivityNotFound(t *testing.T) {\n285: \tmr, err := miniredis.Run()\n286: \tif err != nil {\n287: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n288: \t}\n289: \tdefer mr.Close()\n290: \n291: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n292: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n293: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n294: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n295: \n296: \topts, _ := makeRedisOptions()\n297: \tstore := NewRedisStore(opts)\n298: \tdefer store.Close()\n299: \n300: \terr = store.UpdateSessionLastActivity(context.Background(), \"nonexistent\", time.Now())\n301: \tif err != ErrNotFound {\n302: \t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n303: \t}\n304: }\n\n(End of file - total 304 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestMakeRedisOptions(t *testing.T) {\n\tt.Run(\"with all env vars set\", func(t *testing.T) {\n\t\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n\t\tos.Setenv(\"REDIS_PASSWORD\", \"secret\")\n\t\tdefer os.Unsetenv(\"REDIS_ADDR\")\n\t\tdefer os.Unsetenv(\"REDIS_PASSWORD\")\n\n\t\topts, err := makeRedisOptions()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_redis_test.go","time":{"start":1775857598337,"end":1775857598354}}}}
