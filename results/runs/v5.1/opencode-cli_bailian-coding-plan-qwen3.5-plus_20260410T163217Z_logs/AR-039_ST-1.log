{"type":"tool_use","timestamp":1775889124455,"sessionID":"ses_284c31948ffekOEfBV0dHuQsUy","part":{"id":"prt_d7b3d832e0011OKpfyYd049M0w","messageID":"msg_d7b3d7324001f2PdsVrBAR8KZK","sessionID":"ses_284c31948ffekOEfBV0dHuQsUy","type":"tool","tool":"read","callID":"toolu_de49f0197f1d4e4cbea924ba","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/router.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"sync\"\n8: \t\"time\"\n9: \n10: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n11: \t\"github.com/volcano-sh/agentcube/pkg/router/auth\"\n12: \t\"github.com/volcano-sh/agentcube/pkg/router/blacklist\"\n13: \t\"github.com/volcano-sh/agentcube/pkg/router/middleware\"\n14: \twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n15: \tcorev1 \"k8s.io/api/core/v1\"\n16: \t\"k8s.io/client-go/kubernetes\"\n17: \t\"k8s.io/client-go/kubernetes/scheme\"\n18: \t\"k8s.io/client-go/tools/cache\"\n19: \t\"k8s.io/klog/v2\"\n20: )\n21: \n22: type RouterInterface interface {\n23: \tStart(ctx context.Context) error\n24: \tShutdown(ctx context.Context) error\n25: \tServeHTTP(w http.ResponseWriter, r *http.Request)\n26: }\n27: \n28: type Router struct {\n29: \tconfig              *RouterConfig\n30: \troutes              sync.Map\n31: \thttpClient          *http.Client\n32: \truntimeInformer     cache.SharedIndexInformer\n33: \tinterpreterInformer cache.SharedIndexInformer\n34: \tstopCh              chan struct{}\n35: \twg                  sync.WaitGroup\n36: \tmu                  sync.RWMutex\n37: \thandler             *Handler\n38: \tresolver            *Resolver\n39: \thealthChecker       *HealthChecker\n40: \tauthenticator       auth.JWTAuthenticator\n41: \tauthMiddleware      *middleware.JWTAuthMiddleware\n42: \ttokenBlacklist      *blacklist.TokenBlacklist\n43: \tkubeClient          kubernetes.Interface\n44: }\n45: \n46: func NewRouter(config *RouterConfig) (*Router, error) {\n47: \tif config.KubeConfig == nil {\n48: \t\treturn nil, fmt.Errorf(\"kubeconfig is required\")\n49: \t}\n50: \n51: \tif err := runtimev1alpha1.AddToScheme(scheme.Scheme); err != nil {\n52: \t\treturn nil, fmt.Errorf(\"failed to add runtime scheme: %w\", err)\n53: \t}\n54: \n55: \ttransport := &http.Transport{\n56: \t\tMaxConnsPerHost:     config.MaxConnsPerHost,\n57: \t\tMaxIdleConns:        100,\n58: \t\tMaxIdleConnsPerHost: 10,\n59: \t\tIdleConnTimeout:     90 * time.Second,\n60: \t}\n61: \n62: \thttpClient := &http.Client{\n63: \t\tTransport: transport,\n64: \t\tTimeout:   config.WriteTimeout,\n65: \t}\n66: \n67: \trouter := &Router{\n68: \t\tconfig:     config,\n69: \t\thttpClient: httpClient,\n70: \t\tstopCh:     make(chan struct{}),\n71: \t\troutes:     sync.Map{},\n72: \t}\n73: \n74: \tkubeClient, err := kubernetes.NewForConfig(config.KubeConfig)\n75: \tif err != nil {\n76: \t\treturn nil, fmt.Errorf(\"failed to create kubernetes client: %w\", err)\n77: \t}\n78: \trouter.kubeClient = kubeClient\n79: \n80: \tif config.JWTConfig == nil {\n81: \t\tif config.JWTConfigFile != \"\" {\n82: \t\t\tconfig.JWTConfig, err = auth.LoadJWTConfigFromFile(config.JWTConfigFile)\n83: \t\t\tif err != nil {\n84: \t\t\t\tklog.Warningf(\"Failed to load JWT config from file, trying environment: %v\", err)\n85: \t\t\t\tconfig.JWTConfig, _ = auth.LoadJWTConfigFromEnv()\n86: \t\t\t}\n87: \t\t} else {\n88: \t\t\tconfig.JWTConfig, _ = auth.LoadJWTConfigFromEnv()\n89: \t\t}\n90: \t}\n91: \n92: \trouter.tokenBlacklist = blacklist.NewTokenBlacklist(1 * time.Hour)\n93: \n94: \tif config.JWTConfig != nil && config.JWTConfig.SecretKey != \"\" {\n95: \t\tauthenticator, err := auth.NewJWTAuthenticator(config.JWTConfig, kubeClient, router.tokenBlacklist)\n96: \t\tif err != nil {\n97: \t\t\tklog.Warningf(\"Failed to initialize JWT authenticator: %v\", err)\n98: \t\t} else {\n99: \t\t\trouter.authenticator = authenticator\n100: \t\t\trouter.authMiddleware = middleware.NewJWTAuthMiddleware(\n101: \t\t\t\tauthenticator,\n102: \t\t\t\t\"/healthz\",\n103: \t\t\t\t\"/readyz\",\n104: \t\t\t\t\"/api/v1/auth/token\",\n105: \t\t\t\t\"/api/v1/auth/refresh\",\n106: \t\t\t\t\"/api/v1/auth/revoke\",\n107: \t\t\t)\n108: \t\t\tklog.Info(\"JWT authentication enabled\")\n109: \t\t}\n110: \t}\n111: \n112: \trouter.resolver = NewResolver(&router.routes)\n113: \trouter.handler = NewHandler(router, router.resolver)\n114: \trouter.healthChecker = NewHealthChecker(config, &router.routes, httpClient)\n115: \n116: \treturn router, nil\n117: }\n118: \n119: func (r *Router) SetInformers(runtimeInformer, interpreterInformer cache.SharedIndexInformer) {\n120: \tr.runtimeInformer = runtimeInformer\n121: \tr.interpreterInformer = interpreterInformer\n122: \n123: \tif r.runtimeInformer != nil {\n124: \t\tr.runtimeInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n125: \t\t\tAddFunc:    r.onAgentRuntimeAdd,\n126: \t\t\tUpdateFunc: r.onAgentRuntimeUpdate,\n127: \t\t\tDeleteFunc: r.onAgentRuntimeDelete,\n128: \t\t})\n129: \t}\n130: \n131: \tif r.interpreterInformer != nil {\n132: \t\tr.interpreterInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n133: \t\t\tAddFunc:    r.onCodeInterpreterAdd,\n134: \t\t\tUpdateFunc: r.onCodeInterpreterUpdate,\n135: \t\t\tDeleteFunc: r.onCodeInterpreterDelete,\n136: \t\t})\n137: \t}\n138: }\n139: \n140: func (r *Router) onAgentRuntimeAdd(obj interface{}) {\n141: \trt, ok := obj.(*runtimev1alpha1.AgentRuntime)\n142: \tif !ok {\n143: \t\tklog.Errorf(\"Failed to convert object to AgentRuntime\")\n144: \t\treturn\n145: \t}\n146: \n147: \tif !r.shouldExpose(rt.Labels) {\n148: \t\tklog.V(4).Infof(\"AgentRuntime %s/%s is not exposed, skipping\", rt.Namespace, rt.Name)\n149: \t\treturn\n150: \t}\n151: \n152: \tbackendURL := r.extractBackendURLFromStatus(rt.Status.SandboxRef)\n153: \tif backendURL == \"\" {\n154: \t\tklog.V(4).Infof(\"AgentRuntime %s/%s has no backend URL, skipping\", rt.Namespace, rt.Name)\n155: \t\treturn\n156: \t}\n157: \n158: \tentry := &RouteEntry{\n159: \t\tName:       rt.Name,\n160: \t\tNamespace:  rt.Namespace,\n161: \t\tKind:       wmTypes.AgentRuntimeKind,\n162: \t\tBackendURL: backendURL,\n163: \t\tHealth:     HealthStatus{Healthy: true, LastCheck: time.Now()},\n164: \t\tUpdatedAt:  time.Now(),\n165: \t}\n166: \n167: \tkey := routeKey(rt.Namespace, rt.Kind, rt.Name)\n168: \tr.routes.Store(key, entry)\n169: \tklog.V(4).Infof(\"Added route for AgentRuntime %s/%s -> %s\", rt.Namespace, rt.Name, backendURL)\n170: }\n171: \n172: func (r *Router) onAgentRuntimeUpdate(oldObj, newObj interface{}) {\n173: \tr.onAgentRuntimeAdd(newObj)\n174: }\n175: \n176: func (r *Router) onAgentRuntimeDelete(obj interface{}) {\n177: \trt, ok := obj.(*runtimev1alpha1.AgentRuntime)\n178: \tif !ok {\n179: \t\ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n180: \t\tif !ok {\n181: \t\t\tklog.Errorf(\"Failed to convert object to AgentRuntime\")\n182: \t\t\treturn\n183: \t\t}\n184: \t\trt, ok = tombstone.Obj.(*runtimev1alpha1.AgentRuntime)\n185: \t\tif !ok {\n186: \t\t\tklog.Errorf(\"Failed to convert tombstone to AgentRuntime\")\n187: \t\t\treturn\n188: \t\t}\n189: \t}\n190: \n191: \tkey := routeKey(rt.Namespace, rt.Kind, rt.Name)\n192: \tr.routes.Delete(key)\n193: \tklog.V(4).Infof(\"Removed route for AgentRuntime %s/%s\", rt.Namespace, rt.Name)\n194: }\n195: \n196: func (r *Router) onCodeInterpreterAdd(obj interface{}) {\n197: \tci, ok := obj.(*runtimev1alpha1.CodeInterpreter)\n198: \tif !ok {\n199: \t\tklog.Errorf(\"Failed to convert object to CodeInterpreter\")\n200: \t\treturn\n201: \t}\n202: \n203: \tif !r.shouldExpose(ci.Labels) {\n204: \t\tklog.V(4).Infof(\"CodeInterpreter %s/%s is not exposed, skipping\", ci.Namespace, ci.Name)\n205: \t\treturn\n206: \t}\n207: \n208: \tbackendURL := r.extractBackendURLFromStatus(ci.Status.SandboxRef)\n209: \tif backendURL == \"\" {\n210: \t\tklog.V(4).Infof(\"CodeInterpreter %s/%s has no backend URL, skipping\", ci.Namespace, ci.Name)\n211: \t\treturn\n212: \t}\n213: \n214: \tentry := &RouteEntry{\n215: \t\tName:       ci.Name,\n216: \t\tNamespace:  ci.Namespace,\n217: \t\tKind:       wmTypes.CodeInterpreterKind,\n218: \t\tBackendURL: backendURL,\n219: \t\tHealth:     HealthStatus{Healthy: true, LastCheck: time.Now()},\n220: \t\tUpdatedAt:  time.Now(),\n221: \t}\n222: \n223: \tkey := routeKey(ci.Namespace, ci.Kind, ci.Name)\n224: \tr.routes.Store(key, entry)\n225: \tklog.V(4).Infof(\"Added route for CodeInterpreter %s/%s -> %s\", ci.Namespace, ci.Name, backendURL)\n226: }\n227: \n228: func (r *Router) onCodeInterpreterUpdate(oldObj, newObj interface{}) {\n229: \tr.onCodeInterpreterAdd(newObj)\n230: }\n231: \n232: func (r *Router) onCodeInterpreterDelete(obj interface{}) {\n233: \tci, ok := obj.(*runtimev1alpha1.CodeInterpreter)\n234: \tif !ok {\n235: \t\ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n236: \t\tif !ok {\n237: \t\t\tklog.Errorf(\"Failed to convert object to CodeInterpreter\")\n238: \t\t\treturn\n239: \t\t}\n240: \t\tci, ok = tombstone.Obj.(*runtimev1alpha1.CodeInterpreter)\n241: \t\tif !ok {\n242: \t\t\tklog.Errorf(\"Failed to convert tombstone to CodeInterpreter\")\n243: \t\t\treturn\n244: \t\t}\n245: \t}\n246: \n247: \tkey := routeKey(ci.Namespace, ci.Kind, ci.Name)\n248: \tr.routes.Delete(key)\n249: \tklog.V(4).Infof(\"Removed route for CodeInterpreter %s/%s\", ci.Namespace, ci.Name)\n250: }\n251: \n252: func (r *Router) shouldExpose(labels map[string]string) bool {\n253: \treturn labels[\"agentcube.volcano.sh/expose\"] == \"true\"\n254: }\n255: \n256: func (r *Router) extractBackendURLFromStatus(sandboxRef *corev1.ObjectReference) string {\n257: \tif sandboxRef == nil {\n258: \t\treturn \"\"\n259: \t}\n260: \n261: \tif sandboxRef.Name == \"\" {\n262: \t\treturn \"\"\n263: \t}\n264: \n265: \treturn fmt.Sprintf(\"http://%s.%s.svc.cluster.local:8080\", sandboxRef.Name, sandboxRef.Namespace)\n266: }\n267: \n268: func (r *Router) Start(ctx context.Context) error {\n269: \tr.healthChecker.Start()\n270: \n271: \tserver := &http.Server{\n272: \t\tAddr:         r.config.ListenAddr,\n273: \t\tHandler:      r.handler,\n274: \t\tReadTimeout:  r.config.ReadTimeout,\n275: \t\tWriteTimeout: r.config.WriteTimeout,\n276: \t\tIdleTimeout:  r.config.IdleTimeout,\n277: \t}\n278: \n279: \tr.wg.Add(1)\n280: \tgo func() {\n281: \t\tdefer r.wg.Done()\n282: \t\tklog.Infof(\"Router listening on %s\", r.config.ListenAddr)\n283: \t\tif err := server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n284: \t\t\tklog.Errorf(\"Router server error: %v\", err)\n285: \t\t}\n286: \t}()\n287: \n288: \treturn nil\n289: }\n290: \n291: func (r *Router) Shutdown(ctx context.Context) error {\n292: \tclose(r.stopCh)\n293: \tr.healthChecker.Stop()\n294: \n295: \tif r.tokenBlacklist != nil {\n296: \t\tr.tokenBlacklist.Stop()\n297: \t}\n298: \n299: \tserver := &http.Server{\n300: \t\tAddr:         r.config.ListenAddr,\n301: \t\tReadTimeout:  r.config.ReadTimeout,\n302: \t\tWriteTimeout: r.config.WriteTimeout,\n303: \t\tIdleTimeout:  r.config.IdleTimeout,\n304: \t}\n305: \n306: \tif err := server.Shutdown(ctx); err != nil {\n307: \t\treturn fmt.Errorf(\"failed to shutdown server: %w\", err)\n308: \t}\n309: \n310: \tr.wg.Wait()\n311: \tklog.Info(\"Router shutdown complete\")\n312: \treturn nil\n313: }\n314: \n315: func (r *Router) ServeHTTP(w http.ResponseWriter, req *http.Request) {\n316: \tr.handler.ServeHTTP(w, req)\n317: }\n318: \n319: func (r *Router) GetRoute(namespace, kind, name string) (*RouteEntry, bool) {\n320: \tkey := routeKey(namespace, kind, name)\n321: \tentry, ok := r.routes.Load(key)\n322: \tif !ok {\n323: \t\treturn nil, false\n324: \t}\n325: \treturn entry.(*RouteEntry), true\n326: }\n327: \n328: func (r *R