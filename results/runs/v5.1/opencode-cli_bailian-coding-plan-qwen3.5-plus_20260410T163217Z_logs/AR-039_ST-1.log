treturn handler\n47: }\n48: \n49: func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n50: \tif h.router.authMiddleware != nil {\n51: \t\tif r.URL.Path == \"/api/v1/auth/token\" {\n52: \t\t\tif h.tokenHandler != nil {\n53: \t\t\t\th.tokenHandler.ServeHTTP(w, r)\n54: \t\t\t\treturn\n55: \t\t\t}\n56: \t\t} else if r.URL.Path == \"/api/v1/auth/refresh\" {\n57: \t\t\tif h.refreshHandler != nil {\n58: \t\t\t\th.refreshHandler.ServeHTTP(w, r)\n59: \t\t\t\treturn\n60: \t\t\t}\n61: \t\t} else if r.URL.Path == \"/api/v1/auth/revoke\" {\n62: \t\t\tif h.revokeHandler != nil {\n63: \t\t\t\th.revokeHandler.ServeHTTP(w, r)\n64: \t\t\t\treturn\n65: \t\t\t}\n66: \t\t}\n67: \t}\n68: \n69: \troute, err := h.resolver.Resolve(r)\n70: \tif err != nil {\n71: \t\th.writeError(w, err, http.StatusNotFound)\n72: \t\treturn\n73: \t}\n74: \n75: \tif err := h.ProxyRequest(w, r, route); err != nil {\n76: \t\th.writeError(w, err, http.StatusBadGateway)\n77: \t}\n78: }\n79: \n80: func (h *Handler) ProxyRequest(w http.ResponseWriter, r *http.Request, route *RouteEntry) error {\n81: \tbackendURL, err := url.Parse(route.BackendURL)\n82: \tif err != nil {\n83: \t\treturn fmt.Errorf(\"%w: %v\", ErrBackendConnection, err)\n84: \t}\n85: \n86: \tproxy := httputil.NewSingleHostReverseProxy(backendURL)\n87: \tproxy.ErrorHandler = func(w http.ResponseWriter, r *http.Request, err error) {\n88: \t\tklog.Errorf(\"Proxy error: %v\", err)\n89: \t\tw.WriteHeader(http.StatusBadGateway)\n90: \t}\n91: \n92: \tproxy.ModifyResponse = func(resp *http.Response) error {\n93: \t\tfor k, vv := range resp.Header {\n94: \t\t\tfor _, v := range vv {\n95: \t\t\t\tw.Header().Add(k, v)\n96: \t\t\t}\n97: \t\t}\n98: \t\treturn nil\n99: \t}\n100: \n101: \tr = h.AddForwardingHeaders(r)\n102: \tctx := r.Context()\n103: \tctx = context.WithValue(ctx, \"route\", route)\n104: \tr = r.WithContext(ctx)\n105: \n106: \tproxy.ServeHTTP(w, r)\n107: \treturn nil\n108: }\n109: \n110: func (h *Handler) AddForwardingHeaders(r *http.Request) *http.Request {\n111: \tclientIP, _, err := net.SplitHostPort(r.RemoteAddr)\n112: \tif err != nil {\n113: \t\tclientIP = r.RemoteAddr\n114: \t}\n115: \n116: \tr.Header.Set(\"X-Forwarded-For\", clientIP)\n117: \tr.Header.Set(\"X-Real-IP\", clientIP)\n118: \tr.Header.Set(\"X-Forwarded-Host\", r.Host)\n119: \tr.Header.Set(\"X-Forwarded-Proto\", r.URL.Scheme)\n120: \n121: \tif r.TLS != nil {\n122: \t\tr.Header.Set(\"X-Forwarded-Proto\", \"https\")\n123: \t} else {\n124: \t\tr.Header.Set(\"X-Forwarded-Proto\", \"http\")\n125: \t}\n126: \n127: \treturn r\n128: }\n129: \n130: func (h *Handler) writeError(w http.ResponseWriter, err error, statusCode int) {\n131: \tw.Header().Set(\"Content-Type\", \"application/json\")\n132: \tw.WriteHeader(statusCode)\n133: \n134: \tresp := ErrorResponse{\n135: \t\tError:     err.Error(),\n136: \t\tCode:      http.StatusText(statusCode),\n137: \t\tTimestamp: time.Now().Format(time.RFC3339),\n138: \t}\n139: \n140: \tif strings.Contains(err.Error(), \"route not found\") {\n141: \t\tresp.Code = \"RouteNotFound\"\n142: \t} else if strings.Contains(err.Error(), \"invalid resource type\") {\n143: \t\tresp.Code = \"InvalidResourceType\"\n144: \t\tw.WriteHeader(http.StatusBadRequest)\n145: \t} else if strings.Contains(err.Error(), \"malformed\") {\n146: \t\tresp.Code = \"MalformedPath\"\n147: \t\tw.WriteHeader(http.StatusBadRequest)\n148: \t} else if strings.Contains(err.Error(), \"no healthy backends\") {\n149: \t\tresp.Code = \"NoHealthyBackends\"\n150: \t\tw.WriteHeader(http.StatusServiceUnavailable)\n151: \t} else if strings.Contains(err.Error(), \"backend\") {\n152: \t\tresp.Code = \"BackendError\"\n153: \t\tw.WriteHeader(http.StatusBadGateway)\n154: \t}\n155: \n156: \tjson.NewEncoder(w).Encode(resp)\n157: }\n158: \n159: var (\n160: \tErrBackendConnection  = errors.New(\"failed to connect to backend\")\n161: \tErrBackendTimeout     = errors.New(\"backend timeout\")\n162: \tErrBackendUnavailable = errors.New(\"backend unavailable\")\n163: )\n\n(End of file - total 163 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/router/handlers\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype ErrorResponse struct {\n\tError     string `json:\"error\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/handler.go","time":{"start":1775889131243,"end":1775889131257}}}}
{"type":"tool_use","timestamp":1775889131260,"sessionID":"ses_284c31948ffekOEfBV0dHuQsUy","part":{"id":"prt_d7b3d9cd7001611KDxtMhkOLwG","messageID":"msg_d7b3d8ca2001xwuG181PnqmSVw","sessionID":"ses_284c31948ffekOEfBV0dHuQsUy","type":"tool","tool":"read","callID":"toolu_7926b57e35284fa0ba89ac4e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_redis.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_redis.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"fmt\"\n7: \t\"os\"\n8: \t\"strings\"\n9: \t\"time\"\n10: \n11: \t\"github.com/redis/go-redis/v9\"\n12: \twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n13: \t\"k8s.io/klog/v2\"\n14: )\n15: \n16: type redisStore struct {\n17: \tcli                  *redis.Client\n18: \tsessionPrefix        string\n19: \texpiryIndexKey       string\n20: \tlastActivityIndexKey string\n21: }\n22: \n23: func makeRedisOptions() (*redis.Options, error) {\n24: \taddr := os.Getenv(\"REDIS_ADDR\")\n25: \tif addr == \"\" {\n26: \t\treturn nil, fmt.Errorf(\"REDIS_ADDR is required\")\n27: \t}\n28: \n29: \tpassword := os.Getenv(\"REDIS_PASSWORD\")\n30: \tpasswordRequired := true\n31: \tif val := os.Getenv(\"REDIS_PASSWORD_REQUIRED\"); val != \"\" {\n32: \t\tpasswordRequired = strings.ToLower(val) != \"false\"\n33: \t}\n34: \n35: \tif passwordRequired && password == \"\" {\n36: \t\treturn nil, fmt.Errorf(\"REDIS_PASSWORD is required (set REDIS_PASSWORD_REQUIRED=false to disable)\")\n37: \t}\n38: \n39: \treturn &redis.Options{\n40: \t\tAddr:     addr,\n41: \t\tPassword: password,\n42: \t}, nil\n43: }\n44: \n45: func NewRedisStore(opts *redis.Options) *redisStore {\n46: \tclient := redis.NewClient(opts)\n47: \treturn &redisStore{\n48: \t\tcli:                  client,\n49: \t\tsessionPrefix:        sessionPrefix,\n50: \t\texpiryIndexKey:       expiryIndexKey,\n51: \t\tlastActivityIndexKey: lastActivityIndexKey,\n52: \t}\n53: }\n54: \n55: func (rs *redisStore) Ping(ctx context.Context) error {\n56: \tresp, err := rs.cli.Ping(ctx).Result()\n57: \tif err != nil {\n58: \t\treturn err\n59: \t}\n60: \tif resp != \"PONG\" {\n61: \t\treturn fmt.Errorf(\"unexpected ping response: %q\", resp)\n62: \t}\n63: \treturn nil\n64: }\n65: \n66: func (rs *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*wmTypes.SandboxInfo, error) {\n67: \tkey := rs.sessionPrefix + sessionID\n68: \tdata, err := rs.cli.Get(ctx, key).Result()\n69: \tif err != nil {\n70: \t\tif err == redis.Nil {\n71: \t\t\treturn nil, ErrNotFound\n72: \t\t}\n73: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n74: \t}\n75: \n76: \tvar info wmTypes.SandboxInfo\n77: \tif err := json.Unmarshal([]byte(data), &info); err != nil {\n78: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox: %w\", err)\n79: \t}\n80: \treturn &info, nil\n81: }\n82: \n83: func (rs *redisStore) StoreSandbox(ctx context.Context, sandboxStore *wmTypes.SandboxInfo) error {\n84: \tif sandboxStore == nil {\n85: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n86: \t}\n87: \tif sandboxStore.ExpiresAt.IsZero() {\n88: \t\treturn fmt.Errorf(\"sandbox ExpiresAt cannot be zero\")\n89: \t}\n90: \n91: \tkey := rs.sessionPrefix + sandboxStore.SessionID\n92: \tdata, err := json.Marshal(sandboxStore)\n93: \tif err != nil {\n94: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n95: \t}\n96: \n97: \tnow := time.Now().Unix()\n98: \texpiresAt := sandboxStore.ExpiresAt.Unix()\n99: \tlastActivity := sandboxStore.LastActivityAt.Unix()\n100: \tif lastActivity == 0 {\n101: \t\tlastActivity = now\n102: \t}\n103: \n104: \tpipe := rs.cli.Pipeline()\n105: \n106: \tsetCmd := pipe.SetNX(ctx, key, data, 0)\n107: \n108: \texpiryCmd := pipe.ZAdd(ctx, rs.expiryIndexKey, redis.Z{\n109: \t\tScore:  float64(expiresAt),\n110: \t\tMember: sandboxStore.SessionID,\n111: \t})\n112: \n113: \tlastActivityCmd := pipe.ZAdd(ctx, rs.lastActivityIndexKey, redis.Z{\n114: \t\tScore:  float64(lastActivity),\n115: \t\tMember: sandboxStore.SessionID,\n116: \t})\n117: \n118: \t_, err = pipe.Exec(ctx)\n119: \tif err != nil {\n120: \t\treturn fmt.Errorf(\"pipeline failed: %w\", err)\n121: \t}\n122: \n123: \tif !setCmd.Val() {\n124: \t\treturn fmt.Errorf(\"session %s already exists\", sandboxStore.SessionID)\n125: \t}\n126: \n127: \tif err := setCmd.Err(); err != nil {\n128: \t\treturn err\n129: \t}\n130: \tif err := expiryCmd.Err(); err != nil {\n131: \t\treturn err\n132: \t}\n133: \tif err := lastActivityCmd.Err(); err != nil {\n134: \t\treturn err\n135: \t}\n136: \n137: \treturn nil\n138: }\n139: \n140: func (rs *redisStore) UpdateSandbox(ctx context.Context, sandboxStore *wmTypes.SandboxInfo) error {\n141: \tif sandboxStore == nil {\n142: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n143: \t}\n144: \n145: \tkey := rs.sessionPrefix + sandboxStore.SessionID\n146: \n147: \texistsCmd := rs.cli.Exists(ctx, key)\n148: \tcount, err := existsCmd.Result()\n149: \tif err != nil {\n150: \t\treturn fmt.Errorf(\"failed to check existence: %w\", err)\n151: \t}\n152: \tif count == 0 {\n153: \t\treturn ErrNotFound\n154: \t}\n155: \n156: \tdata, err := json.Marshal(sandboxStore)\n157: \tif err != nil {\n158: \t\treturn fmt.Errorf(\"failed to marshal sandbox: %w\", err)\n159: \t}\n160: \n161: \tsetCmd := rs.cli.Set(ctx, key, data, redis.KeepTTL)\n162: \tif setCmd.Err() != nil {\n163: \t\treturn fmt.Errorf(\"failed to update sandbox: %w\", setCmd.Err())\n164: \t}\n165: \n166: \treturn nil\n167: }\n168: \n169: func (rs *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n170: \tkey := rs.sessionPrefix + sessionID\n171: \n172: \tpipe := rs.cli.Pipeline()\n173: \tpipe.Del(ctx, key)\n174: \tpipe.ZRem(ctx, rs.expiryIndexKey, sessionID)\n175: \tpipe.ZRem(ctx, rs.lastActivityIndexKey, sessionID)\n176: \n177: \t_, err := pipe.Exec(ctx)\n178: \treturn err\n179: }\n180: \n181: func (rs *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*wmTypes.SandboxInfo, error) {\n182: \tif limit <= 0 {\n183: \t\treturn nil, nil\n184: \t}\n185: \n186: \tzCmd := rs.cli.ZRangeByScore(ctx, rs.expiryIndexKey, &redis.ZRangeBy{\n187: \t\tMin:    \"-inf\",\n188: \t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n189: \t\tOffset: 0,\n190: \t\tCount:  limit,\n191: \t})\n192: \n193: \tsessionIDs, err := zCmd.Result()\n194: \tif err != nil {\n195: \t\treturn nil, fmt.Errorf(\"failed to query expired sessions: %w\", err)\n196: \t}\n197: \n198: \treturn rs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n199: }\n200: \n201: func (rs *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*wmTypes.SandboxInfo, error) {\n202: \tif limit <= 0 {\n203: \t\treturn nil, nil\n204: \t}\n205: \n206: \tzCmd := rs.cli.ZRangeByScore(ctx, rs.lastActivityIndexKey, &redis.ZRangeBy{\n207: \t\tMin:    \"-inf\",\n208: \t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n209: \t\tOffset: 0,\n210: \t\tCount:  limit,\n211: \t})\n212: \n213: \tsessionIDs, err := zCmd.Result()\n214: \tif err != nil {\n215: \t\treturn nil, fmt.Errorf(\"failed to query inactive sessions: %w\", err)\n216: \t}\n217: \n218: \treturn rs.loadSandboxesBySessionIDs(ctx, sessionIDs)\n219: }\n220: \n221: func (rs *redisStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*wmTypes.SandboxInfo, error) {\n222: \tif len(sessionIDs) == 0 {\n223: \t\treturn nil, nil\n224: \t}\n225: \n226: \tpipe := rs.cli.Pipeline()\n227: \tkeys := make([]string, len(sessionIDs))\n228: \tfor i, sid := range sessionIDs {\n229: \t\tkeys[i] = rs.sessionPrefix + sid\n230: \t\tpipe.Get(ctx, keys[i])\n231: \t}\n232: \n233: \tcmds, err := pipe.Exec(ctx)\n234: \tif err != nil && err != redis.Nil {\n235: \t\treturn nil, fmt.Errorf(\"pipeline failed: %w\", err)\n236: \t}\n237: \n238: \tvar result []*wmTypes.SandboxInfo\n239: \tfor i, cmd := range cmds {\n240: \t\tdata, err := cmd.(*redis.StringCmd).Result()\n241: \t\tif err == redis.Nil {\n242: \t\t\tklog.Warningf(\"orphaned ZSET member: session %s not found\", sessionIDs[i])\n243: \t\t\tcontinue\n244: \t\t}\n245: \t\tif err != nil {\n246: \t\t\tklog.Warningf(\"failed to get session %s: %v\", sessionIDs[i], err)\n247: \t\t\tcontinue\n248: \t\t}\n249: \n250: \t\tvar info wmTypes.SandboxInfo\n251: \t\tif err := json.Unmarshal([]byte(data), &info); err != nil {\n252: \t\t\tklog.Warningf(\"failed to unmarshal session %s: %v\", sessionIDs[i], err)\n253: \t\t\tcontinue\n254: \t\t}\n255: \t\tresult = append(result, &info)\n256: \t}\n257: \n258: \treturn result, nil\n259: }\n260: \n261: func (rs *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n262: \tif sessionID == \"\" {\n263: \t\treturn fmt.Errorf(\"sessionID cannot be empty\")\n264: \t}\n265: \n266: \tkey := rs.sessionPrefix + sessionID\n267: \n268: \tgetCmd := rs.cli.Get(ctx, key)\n269: \tif getCmd.Err() == redis.Nil {\n270: \t\treturn ErrNotFound\n271: \t}\n272: \tif getCmd.Err() != nil {\n273: \t\treturn fmt.Errorf(\"failed to check session: %w\", getCmd.Err())\n274: \t}\n275: \n276: \tif at.IsZero() {\n277: \t\tat = time.Now()\n278: \t}\n279: \n280: \tzCmd := rs.cli.ZAdd(ctx, rs.lastActivityIndexKey, redis.Z{\n281: \t\tScore:  float64(at.Unix()),\n282: \t\tMember: sessionID,\n283: \t})\n284: \n285: \treturn zCmd.Err()\n286: }\n287: \n288: func (rs *redisStore) Close() error {\n289: \treturn rs.cli.Close()\n290: }\n\n(End of file - total 290 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  *redis.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_redis.go","time":{"start":1775889131246,"end":1775889131259}}}}
{"type":"tool_use","timestamp":1775889131263,"sessionID":"ses_284c31948ffekOEfBV0dHuQsUy","part":{"id":"prt_d7b3da2510015LgMhiyePeQ810","messageID":"msg_d7b3d8ca2001xwuG181PnqmSVw","sessionID":"ses_284c31948ffekOEfBV0dHuQsUy","type":"tool","tool":"read","callID":"toolu_97c223511d7e4a1e9cd29f10","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/executor.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/executor.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"context\"\n5: \t\"io\"\n6: \t\"os/exec\"\n7: \t\"syscall\"\n8: \t\"time\"\n9: )\n10: \n11: func findCommand(path string) (string, error) {\n12: \treturn exec.LookPath(path)\n13: }\n14: \n15: type Command struct {\n16: \tPath   string\n17: \tArgs   []string\n18: \tEnv    []string\n19: \tDir    string\n20: \tStdin  io.Reader\n21: \tStdout io.Writer\n22: \tStderr io.Writer\n23: }\n24: \n25: type CommandResult struct {\n26: \tExitCode  int\n27: \tStdout    []byte\n28: \tStderr    []byte\n29: \tDuration  time.Duration\n30: \tOOMKilled bool\n31: \tTimeout   bool\n32: }\n33: \n34: type Executor struct {\n35: \tlimits       *ResourceLimits\n36: \tsecurityOpts *SecurityOptions\n37: }\n38: \n39: func NewExecutor(limits *ResourceLimits, securityOpts *SecurityOptions) *Executor {\n40: \treturn &Executor{\n41: \t\tlimits:       limits,\n42: \t\tsecurityOpts: securityOpts,\n43: \t}\n44: }\n45: \n46: func (e *Executor) Run(ctx context.Context, cmd *Command) (*CommandResult, error) {\n47: \tif err := ValidateCommand(cmd, e.securityOpts); err != nil {\n48: \t\treturn nil, err\n49: \t}\n50: \n51: \tcmdPath, err := findCommand(cmd.Path)\n52: \tif err != nil {\n53: \t\treturn nil, &ExecutionError{\n54: \t\t\tType:       ExecutionErrorExec,\n55: \t\t\tMessage:    \"command not found\",\n56: \t\t\tUnderlying: err,\n57: \t\t}\n58: \t}\n59: \n60: \t// Apply timeout from limits to context\n61: \tif e.limits.Timeout > 0 {\n62: \t\tvar cancel context.CancelFunc\n63: \t\tctx, cancel = context.WithTimeout(ctx, e.limits.Timeout)\n64: \t\tdefer cancel()\n65: \t}\n66: \n67: \texecCmd := exec.CommandContext(ctx, cmdPath, cmd.Args...)\n68: \texecCmd.Env = cmd.Env\n69: \texecCmd.Dir = cmd.Dir\n70: \n71: \tif err := e.limits.Apply(execCmd); err != nil {\n72: \t\treturn nil, &ExecutionError{\n73: \t\t\tType:       ExecutionErrorResource,\n74: \t\t\tMessage:    \"failed to apply resource limits\",\n75: \t\t\tUnderlying: err,\n76: \t\t}\n77: \t}\n78: \n79: \tvar stdoutBuf, stderrBuf limitedBuffer\n80: \tif e.limits.MaxOutputSize > 0 {\n81: \t\tstdoutBuf.limit = e.limits.MaxOutputSize\n82: \t\tstderrBuf.limit = e.limits.MaxOutputSize\n83: \t}\n84: \tif cmd.Stdout == nil {\n85: \t\texecCmd.Stdout = &stdoutBuf\n86: \t} else {\n87: \t\texecCmd.Stdout = cmd.Stdout\n88: \t}\n89: \tif cmd.Stderr == nil {\n90: \t\texecCmd.Stderr = &stderrBuf\n91: \t} else {\n92: \t\texecCmd.Stderr = cmd.Stderr\n93: \t}\n94: \n95: \tstartTime := time.Now()\n96: \tif err := execCmd.Start(); err != nil {\n97: \t\treturn nil, &ExecutionError{\n98: \t\t\tType:       ExecutionErrorExec,\n99: \t\t\tMessage:    \"failed to start command\",\n100: \t\t\tUnderlying: err,\n101: \t\t}\n102: \t}\n103: \n104: \terr = execCmd.Wait()\n105: \tduration := time.Since(startTime)\n106: \n107: \tresult := &CommandResult{\n108: \t\tDuration: duration,\n109: \t}\n110: \n111: \tif cmd.Stdout == nil {\n112: \t\tresult.Stdout = stdoutBuf.Bytes()\n113: \t}\n114: \tif cmd.Stderr == nil {\n115: \t\tresult.Stderr = stderrBuf.Bytes()\n116: \t}\n117: \n118: \t// Check for context errors first\n119: \tif ctx.Err() == context.DeadlineExceeded {\n120: \t\tresult.Timeout = true\n121: \t\terr = &ExecutionError{\n122: \t\t\tType:    ExecutionErrorTimeout,\n123: \t\t\tMessage: \"command timed out\",\n124: \t\t}\n125: \t} else if ctx.Err() == context.Canceled {\n126: \t\terr = &ExecutionError{\n127: \t\t\tType:    ExecutionErrorCancelled,\n128: \t\t\tMessage: \"command was cancelled\",\n129: \t\t}\n130: \t} else if exitErr, ok := err.(*exec.ExitError); ok {\n131: \t\tresult.ExitCode = exitErr.ExitCode()\n132: \t\tif status, ok := exitErr.Sys().(syscall.WaitStatus); ok {\n133: \t\t\tif status.Signal() == syscall.SIGKILL || status.Signal() == syscall.SIGSEGV {\n134: \t\t\t\tresult.OOMKilled = true\n135: \t\t\t\terr = &ExecutionError{\n136: \t\t\t\t\tType:    ExecutionErrorOOM,\n137: \t\t\t\t\tMessage: \"process killed due to OOM\",\n138: \t\t\t\t}\n139: \t\t\t}\n140: \t\t}\n141: \t} else if err == nil {\n142: \t\tresult.ExitCode = 0\n143: \t}\n144: \n145: \treturn result, err\n146: }\n147: \n148: func (e *Executor) Start(ctx context.Context, cmd *Command) (*Process, error) {\n149: \tif err := ValidateCommand(cmd, e.securityOpts); err != nil {\n150: \t\treturn nil, err\n151: \t}\n152: \n153: \tcmdPath, err := findCommand(cmd.Path)\n154: \tif err != nil {\n155: \t\treturn nil, &ExecutionError{\n156: \t\t\tType:       ExecutionErrorExec,\n157: \t\t\tMessage:    \"command not found\",\n158: \t\t\tUnderlying: err,\n159: \t\t}\n160: \t}\n161: \n162: \texecCmd := exec.CommandContext(ctx, cmdPath, cmd.Args...)\n163: \texecCmd.Env = cmd.Env\n164: \texecCmd.Dir = cmd.Dir\n165: \n166: \tif err := e.limits.Apply(execCmd); err != nil {\n167: \t\treturn nil, &ExecutionError{\n168: \t\t\tType:       ExecutionErrorResource,\n169: \t\t\tMessage:    \"failed to apply resource limits\",\n170: \t\t\tUnderlying: err,\n171: \t\t}\n172: \t}\n173: \n174: \tif err := execCmd.Start(); err != nil {\n175: \t\treturn nil, &ExecutionError{\n176: \t\t\tType:       ExecutionErrorExec,\n177: \t\t\tMessage:    \"failed to start command\",\n178: \t\t\tUnderlying: err,\n179: \t\t}\n180: \t}\n181: \n182: \treturn &Process{\n183: \t\tPID:       execCmd.Process.Pid,\n184: \t\tcmd:       execCmd,\n185: \t\tstartTime: time.Now(),\n186: \t\tlimits:    e.limits,\n187: \t}, nil\n188: }\n189: \n190: type limitedBuffer struct {\n191: \tdata  []byte\n192: \tlimit int64\n193: }\n194: \n195: func (b *limitedBuffer) Write(p []byte) (n int, err error) {\n196: \t// If limit is 0 or negative, accept all data\n197: \tif b.limit <= 0 {\n198: \t\tb.data = append(b.data, p...)\n199: \t\treturn len(p), nil\n200: \t}\n201: \n202: \tremaining := b.limit - int64(len(b.data))\n203: \tif remaining <= 0 {\n204: \t\t// Return input length to indicate all data was 'consumed' but discard excess\n205: \t\treturn len(p), nil\n206: \t}\n207: \tif int64(len(p)) > remaining {\n208: \t\tp = p[:remaining]\n209: \t}\n210: \tb.data = append(b.data, p...)\n211: \treturn len(p), nil\n212: }\n213: \n214: func (b *limitedBuffer) Bytes() []byte {\n215: \treturn b.data\n216: }\n\n(End of file - total 216 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"io\"\n\t\"os/exec\"\n\t\"syscall\"\n\t\"time\"\n)\n\nfunc findCommand(path string) (string, error) {\n\treturn exec.LookPath(path)\n}\n\ntype Command struct {\n\tPath   string\n\tArgs   []string\n\tEnv    []string\n\tDir    string\n\tStdin  io.Reader","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/executor.go","time":{"start":1775889131248,"end":1775889131261}}}}
