specPath.Child(\"container\"))...)\n39: \tallErrs = append(allErrs, ValidateResourceQuota(obj.Spec.Resources, specPath.Child(\"resources\"))...)\n40: \tallErrs = append(allErrs, ValidateNetworkPolicy(obj.Spec.Network, specPath.Child(\"network\"))...)\n41: \tallErrs = append(allErrs, ValidateLifecycleHook(obj.Spec.Lifecycle, specPath.Child(\"lifecycle\"))...)\n42: \tallErrs = append(allErrs, validateCodeInterpreter(obj.Spec.CodeInterpreter, specPath.Child(\"codeInterpreter\"))...)\n43: \n44: \treturn allErrs\n45: }\n46: \n47: func validateContainerSpec(spec *ContainerSpec, fldPath *field.Path) field.ErrorList {\n48: \tallErrs := field.ErrorList{}\n49: \n50: \tif spec == nil {\n51: \t\treturn allErrs\n52: \t}\n53: \n54: \tif spec.Image != \"\" && !imageRegex.MatchString(spec.Image) {\n55: \t\tallErrs = append(allErrs, field.Invalid(\n56: \t\t\tfldPath.Child(\"image\"),\n57: \t\t\tspec.Image,\n58: \t\t\t\"must be a valid container image name\",\n59: \t\t))\n60: \t}\n61: \n62: \treturn allErrs\n63: }\n64: \n65: // ValidateContainerSpec validates container specification.\n66: // This is a SHARED validation function intended for reuse across multiple CRDs.\n67: func ValidateContainerSpec(spec *ContainerSpec, fldPath *field.Path) field.ErrorList {\n68: \tallErrs := field.ErrorList{}\n69: \n70: \tif spec == nil {\n71: \t\treturn allErrs\n72: \t}\n73: \n74: \tif spec.Image != \"\" && !imageRegex.MatchString(spec.Image) {\n75: \t\tallErrs = append(allErrs, field.Invalid(\n76: \t\t\tfldPath.Child(\"image\"),\n77: \t\t\tspec.Image,\n78: \t\t\t\"must be a valid container image name\",\n79: \t\t))\n80: \t}\n81: \n82: \treturn allErrs\n83: }\n84: \n85: func validateResourceQuota(quota *ResourceQuota, fldPath *field.Path) field.ErrorList {\n86: \tallErrs := field.ErrorList{}\n87: \n88: \tif quota == nil {\n89: \t\treturn allErrs\n90: \t}\n91: \n92: \tif quota.CPU != \"\" {\n93: \t\tif _, err := resource.ParseQuantity(quota.CPU); err != nil {\n94: \t\t\tallErrs = append(allErrs, field.Invalid(\n95: \t\t\t\tfldPath.Child(\"cpu\"),\n96: \t\t\t\tquota.CPU,\n97: \t\t\t\t\"must be a valid resource quantity\",\n98: \t\t\t))\n99: \t\t}\n100: \t}\n101: \n102: \tif quota.Memory != \"\" {\n103: \t\tif _, err := resource.ParseQuantity(quota.Memory); err != nil {\n104: \t\t\tallErrs = append(allErrs, field.Invalid(\n105: \t\t\t\tfldPath.Child(\"memory\"),\n106: \t\t\t\tquota.Memory,\n107: \t\t\t\t\"must be a valid resource quantity\",\n108: \t\t\t))\n109: \t\t}\n110: \t}\n111: \n112: \tif quota.Storage != \"\" {\n113: \t\tif _, err := resource.ParseQuantity(quota.Storage); err != nil {\n114: \t\t\tallErrs = append(allErrs, field.Invalid(\n115: \t\t\t\tfldPath.Child(\"storage\"),\n116: \t\t\t\tquota.Storage,\n117: \t\t\t\t\"must be a valid resource quantity\",\n118: \t\t\t))\n119: \t\t}\n120: \t}\n121: \n122: \treturn allErrs\n123: }\n124: \n125: // ValidateResourceQuota validates resource quota fields.\n126: // This is a SHARED validation function intended for reuse across multiple CRDs.\n127: func ValidateResourceQuota(quota *ResourceQuota, fldPath *field.Path) field.ErrorList {\n128: \tallErrs := field.ErrorList{}\n129: \n130: \tif quota == nil {\n131: \t\treturn allErrs\n132: \t}\n133: \n134: \tif quota.CPU != \"\" {\n135: \t\tif _, err := resource.ParseQuantity(quota.CPU); err != nil {\n136: \t\t\tallErrs = append(allErrs, field.Invalid(\n137: \t\t\t\tfldPath.Child(\"cpu\"),\n138: \t\t\t\tquota.CPU,\n139: \t\t\t\t\"must be a valid resource quantity\",\n140: \t\t\t))\n141: \t\t}\n142: \t}\n143: \n144: \tif quota.Memory != \"\" {\n145: \t\tif _, err := resource.ParseQuantity(quota.Memory); err != nil {\n146: \t\t\tallErrs = append(allErrs, field.Invalid(\n147: \t\t\t\tfldPath.Child(\"memory\"),\n148: \t\t\t\tquota.Memory,\n149: \t\t\t\t\"must be a valid resource quantity\",\n150: \t\t\t))\n151: \t\t}\n152: \t}\n153: \n154: \tif quota.Storage != \"\" {\n155: \t\tif _, err := resource.ParseQuantity(quota.Storage); err != nil {\n156: \t\t\tallErrs = append(allErrs, field.Invalid(\n157: \t\t\t\tfldPath.Child(\"storage\"),\n158: \t\t\t\tquota.Storage,\n159: \t\t\t\t\"must be a valid resource quantity\",\n160: \t\t\t))\n161: \t\t}\n162: \t}\n163: \n164: \treturn allErrs\n165: }\n166: \n167: func validateNetworkPolicy(policy *NetworkPolicy, fldPath *field.Path) field.ErrorList {\n168: \tallErrs := field.ErrorList{}\n169: \n170: \tif policy == nil {\n171: \t\treturn allErrs\n172: \t}\n173: \n174: \tfor i, rule := range policy.EgressRules {\n175: \t\tif rule.CIDR != \"\" && !cidrRegex.MatchString(rule.CIDR) {\n176: \t\t\tallErrs = append(allErrs, field.Invalid(\n177: \t\t\t\tfldPath.Child(\"egressRules\").Index(i).Child(\"cidr\"),\n178: \t\t\t\trule.CIDR,\n179: \t\t\t\t\"must be a valid CIDR block\",\n180: \t\t\t))\n181: \t\t}\n182: \n183: \t\tfor _, port := range rule.Ports {\n184: \t\t\tif port < 1 || port > 65535 {\n185: \t\t\t\tallErrs = append(allErrs, field.Invalid(\n186: \t\t\t\t\tfldPath.Child(\"egressRules\").Index(i).Child(\"ports\").Index(0),\n187: \t\t\t\t\tport,\n188: \t\t\t\t\t\"must be between 1 and 65535\",\n189: \t\t\t\t))\n190: \t\t\t}\n191: \t\t}\n192: \t}\n193: \n194: \tfor i, rule := range policy.IngressRules {\n195: \t\tif rule.CIDR != \"\" && !cidrRegex.MatchString(rule.CIDR) {\n196: \t\t\tallErrs = append(allErrs, field.Invalid(\n197: \t\t\t\tfldPath.Child(\"ingressRules\").Index(i).Child(\"cidr\"),\n198: \t\t\t\trule.CIDR,\n199: \t\t\t\t\"must be a valid CIDR block\",\n200: \t\t\t))\n201: \t\t}\n202: \t}\n203: \n204: \treturn allErrs\n205: }\n206: \n207: // ValidateNetworkPolicy validates network policy configuration.\n208: // This is a SHARED validation function intended for reuse across multiple CRDs.\n209: func ValidateNetworkPolicy(policy *NetworkPolicy, fldPath *field.Path) field.ErrorList {\n210: \tallErrs := field.ErrorList{}\n211: \n212: \tif policy == nil {\n213: \t\treturn allErrs\n214: \t}\n215: \n216: \tfor i, rule := range policy.EgressRules {\n217: \t\tif rule.CIDR != \"\" && !cidrRegex.MatchString(rule.CIDR) {\n218: \t\t\tallErrs = append(allErrs, field.Invalid(\n219: \t\t\t\tfldPath.Child(\"egressRules\").Index(i).Child(\"cidr\"),\n220: \t\t\t\trule.CIDR,\n221: \t\t\t\t\"must be a valid CIDR block\",\n222: \t\t\t))\n223: \t\t}\n224: \n225: \t\tfor j, port := range rule.Ports {\n226: \t\t\tif port < 1 || port > 65535 {\n227: \t\t\t\tallErrs = append(allErrs, field.Invalid(\n228: \t\t\t\t\tfldPath.Child(\"egressRules\").Index(i).Child(\"ports\").Index(j),\n229: \t\t\t\t\tport,\n230: \t\t\t\t\t\"must be between 1 and 65535\",\n231: \t\t\t\t))\n232: \t\t\t}\n233: \t\t}\n234: \t}\n235: \n236: \tfor i, rule := range policy.IngressRules {\n237: \t\tif rule.CIDR != \"\" && !cidrRegex.MatchString(rule.CIDR) {\n238: \t\t\tallErrs = append(allErrs, field.Invalid(\n239: \t\t\t\tfldPath.Child(\"ingressRules\").Index(i).Child(\"cidr\"),\n240: \t\t\t\trule.CIDR,\n241: \t\t\t\t\"must be a valid CIDR block\",\n242: \t\t\t))\n243: \t\t}\n244: \t}\n245: \n246: \treturn allErrs\n247: }\n248: \n249: func validateLifecycleHook(hook *LifecycleHook, fldPath *field.Path) field.ErrorList {\n250: \tallErrs := field.ErrorList{}\n251: \n252: \tif hook == nil {\n253: \t\treturn allErrs\n254: \t}\n255: \n256: \tif hook.PreStart != \"\" && !isValidURL(hook.PreStart) {\n257: \t\tallErrs = append(allErrs, field.Invalid(\n258: \t\t\tfldPath.Child(\"preStart\"),\n259: \t\t\thook.PreStart,\n260: \t\t\t\"must be a valid URL\",\n261: \t\t))\n262: \t}\n263: \n264: \tif hook.PostStop != \"\" && !isValidURL(hook.PostStop) {\n265: \t\tallErrs = append(allErrs, field.Invalid(\n266: \t\t\tfldPath.Child(\"postStop\"),\n267: \t\t\thook.PostStop,\n268: \t\t\t\"must be a valid URL\",\n269: \t\t))\n270: \t}\n271: \n272: \treturn allErrs\n273: }\n274: \n275: // ValidateLifecycleHook validates lifecycle hook URLs.\n276: // This is a SHARED validation function intended for reuse across multiple CRDs.\n277: func ValidateLifecycleHook(hook *LifecycleHook, fldPath *field.Path) field.ErrorList {\n278: \tallErrs := field.ErrorList{}\n279: \n280: \tif hook == nil {\n281: \t\treturn allErrs\n282: \t}\n283: \n284: \tif hook.PreStart != \"\" && !isValidURL(hook.PreStart) {\n285: \t\tallErrs = append(allErrs, field.Invalid(\n286: \t\t\tfldPath.Child(\"preStart\"),\n287: \t\t\thook.PreStart,\n288: \t\t\t\"must be a valid URL\",\n289: \t\t))\n290: \t}\n291: \n292: \tif hook.PostStop != \"\" && !isValidURL(hook.PostStop) {\n293: \t\tallErrs = append(allErrs, field.Invalid(\n294: \t\t\tfldPath.Child(\"postStop\"),\n295: \t\t\thook.PostStop,\n296: \t\t\t\"must be a valid URL\",\n297: \t\t))\n298: \t}\n299: \n300: \treturn allErrs\n301: }\n302: \n303: func validateCodeInterpreter(ci *CodeInterpreterSpec, fldPath *field.Path) field.ErrorList {\n304: \tallErrs := field.ErrorList{}\n305: \n306: \tif ci == nil {\n307: \t\treturn allErrs\n308: \t}\n309: \n310: \tif ci.Enabled && ci.Image != \"\" && !imageRegex.MatchString(ci.Image) {\n311: \t\tallErrs = append(allErrs, field.Invalid(\n312: \t\t\tfldPath.Child(\"image\"),\n313: \t\t\tci.Image,\n314: \t\t\t\"must be a valid container image name\",\n315: \t\t))\n316: \t}\n317: \n318: \tallErrs = append(allErrs, validateResourceQuota(ci.Resources, fldPath.Child(\"resources\"))...)\n319: \n320: \treturn allErrs\n321: }\n322: \n323: func isValidURL(url string) bool {\n324: \treturn strings.HasPrefix(url, \"http://\") || strings.HasPrefix(url, \"https://\")\n325: }\n326: \n327: func ValidateAgentRuntimeStatusUpdate(oldObj, newObj *AgentRuntime) field.ErrorList {\n328: \tallErrs := field.ErrorList{}\n329: \tstatusPath := field.NewPath(\"status\")\n330: \n331: \tvalidTransitions := map[AgentRuntimePhase][]AgentRuntimePhase{\n332: \t\t\"\":                           {AgentRuntimePhasePending},\n333: \t\tAgentRuntimePhasePending:     {AgentRuntimePhaseRunning, AgentRuntimePhaseFailed, AgentRuntimePhaseTerminating},\n334: \t\tAgentRuntimePhaseRunning:     {AgentRuntimePhaseFailed, AgentRuntimePhaseTerminating},\n335: \t\tAgentRuntimePhaseFailed:      {},\n336: \t\tAgentRuntimePhaseTerminating: {AgentRuntimePhaseTerminating},\n337: \t}\n338: \n339: \toldPhase := oldObj.Status.Phase\n340: \tnewPhase := newObj.Status.Phase\n341: \n342: \tif allowed, ok := validTransitions[oldPhase]; ok {\n343: \t\tvalid := false\n344: \t\tfor _, p := range allowed {\n345: \t\t\tif p == newPhase {\n346: \t\t\t\tvalid = true\n347: \t\t\t\tbreak\n348: \t\t\t}\n349: \t\t}\n350: \t\tif !valid && oldPhase != newPhase {\n351: \t\t\tallErrs = append(allErrs, field.Forbidden(\n352: \t\t\t\tstatusPath.Child(\"phase\"),\n353: \t\t\t\tfmt.Sprintf(\"invalid phase transition from %s to %s\", oldPhase, newPhase),\n354: \t\t\t))\n355: \t\t}\n356: \t}\n357: \n358: \treturn allErrs\n359: }\n360: \n361: func ValidateAgentRuntimePhase(phase AgentRuntimePhase) error {\n362: \tswitch phase {\n363: \tcase \"\", AgentRuntimePhasePending, AgentRuntimePhaseRunning, AgentRuntimePhaseFailed, AgentRuntimePhaseTerminating:\n364: \t\treturn nil\n365: \tdefault:\n366: \t\treturn errors.New(\"invalid phase\")\n367: \t}\n368: }\n\n(End of file - total 368 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"errors\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation.go","time":{"start":1775841120365,"end":1775841120379}}}}
