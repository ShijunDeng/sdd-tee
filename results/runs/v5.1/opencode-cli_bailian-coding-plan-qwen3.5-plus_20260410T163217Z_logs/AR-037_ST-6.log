"\n41: \n42: [tool.setuptools.packages.find]\n43: where = [\".\"]\n44: include = [\"agentcube*\"]\n45: \n46: [tool.pytest.ini_options]\n47: testpaths = [\"tests\"]\n48: python_files = [\"test_*.py\"]\n49: python_classes = [\"Test*\"]\n50: python_functions = [\"test_*\"]\n51: addopts = \"-v --tb=short\"\n52: markers = [\n53:     \"integration: marks tests as integration tests (deselect with '-m \\\"not integration\\\"')\",\n54: ]\n55: \n56: [tool.mypy]\n57: python_version = \"3.10\"\n58: warn_return_any = true\n59: warn_unused_configs = true\n60: disallow_untyped_defs = false\n61: check_untyped_defs = true\n62: \n63: [tool.ruff]\n64: line-length = 100\n65: target-version = \"py39\"\n66: select = [\n67:     \"E\",  # pycodestyle errors\n68:     \"W\",  # pycodestyle warnings\n69:     \"F\",  # pyflakes\n70:     \"I\",  # isort\n71:     \"B\",  # flake8-bugbear\n72:     \"C4\", # flake8-comprehensions\n73: ]\n74: ignore = [\n75:     \"E501\",  # line too long (handled by ruff formatter)\n76: ]\n77: \n78: [tool.coverage.run]\n79: source = [\"agentcube\"]\n80: branch = true\n81: \n82: [tool.coverage.report]\n83: exclude_lines = [\n84:     \"pragma: no cover\",\n85:     \"def __repr__\",\n86:     \"raise AssertionError\",\n87:     \"raise NotImplementedError\",\n88:     \"if __name__ == .__main__.:\",\n89:     \"if TYPE_CHECKING:\",\n90: ]\n\n(End of file - total 90 lines)\n</content>","metadata":{"preview":"[build-system]\nrequires = [\"setuptools>=61.0\", \"wheel\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"agentcube\"\nversion = \"0.1.0\"\ndescription = \"AgentCube Python SDK for invoking Agent Runtime workloads\"\nreadme = \"README.md\"\nlicense = {text = \"Apache-2.0\"}\nrequires-python = \">=3.9\"\nauthors = [\n    {name = \"AgentCube Team\", email = \"agentcube@volcano.sh\"}\n]\nclassifiers = [\n    \"Development Status :: 3 - Alpha\",\n    \"Intended Audience :: Developers\",\n    \"License :: OSI Approved :: Apache Software License\",\n   