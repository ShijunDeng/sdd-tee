{"type":"tool_use","timestamp":1775884018342,"sessionID":"ses_28516c8a4ffeyklEf33zHwrJZe","part":{"id":"prt_d7aef4f9e001yzT8lE3JxdarVk","messageID":"msg_d7aef44e1001FDtC2lk1O2QmAd","sessionID":"ses_28516c8a4ffeyklEf33zHwrJZe","type":"tool","tool":"write","callID":"toolu_6e49ba85bd5d4fc7807a3398","state":{"status":"completed","input":{"content":"// Copyright 2026 AgentCube Authors\n// E2E tests for AgentCube\n\npackage e2e\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n)\n\nvar (\n\tworkloadManagerURL string\n\trouterURL          string\n\tapiToken           string\n\tclient             *http.Client\n)\n\nfunc TestMain(m *testing.M) {\n\tworkloadManagerURL = os.Getenv(\"WORKLOAD_MANAGER_URL\")\n\trouterURL = os.Getenv(\"ROUTER_URL\")\n\tapiToken = os.Getenv(\"API_TOKEN\")\n\n\tif workloadManagerURL == \"\" {\n\t\tworkloadManagerURL = \"http://localhost:8080\"\n\t}\n\tif routerURL == \"\" {\n\t\trouterURL = \"http://localhost:8081\"\n\t}\n\tif apiToken == \"\" {\n\t\tfmt.Println(\"Warning: API_TOKEN not set\")\n\t}\n\n\tclient = &http.Client{\n\t\tTimeout: 30 * time.Second,\n\t}\n\n\tos.Exit(m.Run())\n}\n\nfunc TestHealthCheck(t *testing.T) {\n\tresp, err := client.Get(workloadManagerURL + \"/health\")\n\tif err != nil {\n\t\tt.Fatalf(\"Health check failed: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tt.Fatalf(\"Health check returned status: %d\", resp.StatusCode)\n\t}\n\n\tbody, err := io.ReadAll(resp.Body)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to read response body: %v\", err)\n\t}\n\n\tvar health struct {\n\t\tStatus string `json:\"status\"`\n\t}\n\tif err := json.Unmarshal(body, &health); err != nil {\n\t\tt.Fatalf(\"Failed to parse health response: %v\", err)\n\t}\n\n\tif health.Status != \"ok\" && health.Status != \"healthy\" {\n\t\tt.Logf(\"Health status: %s\", health.Status)\n\t}\n}\n\nfunc TestRouterHealth(t *testing.T) {\n\tresp, err := client.Get(routerURL + \"/health/live\")\n\tif err != nil {\n\t\tt.Fatalf(\"Router health check failed: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tt.Fatalf(\"Router health check returned status: %d\", resp.StatusCode)\n\t}\n}\n\nfunc TestInvokeEchoAgent(t *testing.T) {\n\tmessage := map[string]string{\n\t\t\"message\": \"Hello, echo agent!\",\n\t}\n\tbody, _ := json.Marshal(message)\n\n\treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/echo-agent\", bytes.NewReader(body))\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create request: %v\", err)\n\t}\n\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n\n\tresp, err := client.Do(req)\n\tif err != nil {\n\t\tt.Fatalf(\"Invoke request failed: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tt.Fatalf(\"Invoke returned status: %d, body: %s\", resp.StatusCode, string(body))\n\t}\n\n\tvar result map[string]interface{}\n\tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n\t\tt.Fatalf(\"Failed to decode response: %v\", err)\n\t}\n\n\tt.Logf(\"Echo agent response: %+v\", result)\n}\n\nfunc TestCodeInterpreter(t *testing.T) {\n\tcode := map[string]string{\n\t\t\"code\": \"print('Hello from code interpreter')\",\n\t}\n\tbody, _ := json.Marshal(code)\n\n\treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/e2e-code-interpreter\", bytes.NewReader(body))\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create request: %v\", err)\n\t}\n\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n\n\tresp, err := client.Do(req)\n\tif err != nil {\n\t\tt.Fatalf(\"Code interpreter request failed: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tt.Fatalf(\"Code interpreter returned status: %d, body: %s\", resp.StatusCode, string(body))\n\t}\n\n\tvar result map[string]interface{}\n\tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n\t\tt.Fatalf(\"Failed to decode response: %v\", err)\n\t}\n\n\tt.Logf(\"Code interpreter response: %+v\", result)\n}\n","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/main.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/e2e.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/lint.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/python-sdk-tests.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/python-lint.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/test-coverage.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/codegen-check.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/copyright-check.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/codespell.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/build-push-release.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/dify-plugin-publish.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.github/workflows/workflows-approve.yml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/echo_agent.yaml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_code_interpreter.yaml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_code_interpreter_warmpool.yaml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/run_e2e.sh":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go":[]},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go","exists":false,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go","time":{"start":1775884017423,"end":1775884018338}}}}
