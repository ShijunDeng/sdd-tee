o \"dev\")\nCOMMIT_SHA ?= $(shell git rev-parse --short HEAD 2>/dev/null || echo \"unknown\")\n\n# Image names\nWORKLOADMANAGER_IMAGE := $(DOCKER_REGISTRY)/workloadmanager\nROUTER_IMAGE := $(DOCKER_REGISTRY)/router\nPICOD_IMAGE := $(DOCKER_REGISTRY)/picod\n\n# CI/CD configuration\nIMAGE_REGISTRY ?= ghcr.io\nE2E_CLUSTER_NAME ?= agentcube-e2e\nE2E_CLEAN_CLUSTER ?= true\n\n# Build all images\n.PHONY: docker-build-all\ndocker-build-all: docker-build-workloadmanager docker-build-router docker-build-picod\n\t@echo \"✓ All images built successfully\"\n\n# Build Workload Manager image\n.PHONY: docker-build-workloadmanager\ndocker-build-workloadmanager:\n\t@echo \"Building Workload Manager image...\"\n\tdocker build \\\n\t\t-f deployment/docker/Dockerfile \\\n\t\t--build-arg VERSION=$(VERSION) \\\n\t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n\t\t-t $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG) \\\n\t\t-t $(WORKLOADMANAGER_IMAGE):$(COMMIT_SHA) \\\n\t\t-t $(WORKLOADMANAGER_IMAGE):$(VERSION) \\\n\t\t.\n\t@echo \"✓ Workload Manager image built: $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG)\"\n\n# Build Router image\n.PHONY: docker-build-router\ndocker-build-router:\n\t@echo \"Building Router image...\"\n\tdocker build \\\n\t\t-f deployment/docker/Dockerfile.router \\\n\t\t--build-arg VERSION=$(VERSION) \\\n\t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n\t\t-t $(ROUTER_IMAGE):$(DOCKER_TAG) \\\n\t\t-t $(ROUTER_IMAGE):$(COMMIT_SHA) \\\n\t\t-t $(ROUTER_IMAGE):$(VERSION) \\\n\t\t.\n\t@echo \"✓ Router image built: $(ROUTER_IMAGE):$(DOCKER_TAG)\"\n\n# Build Picod image\n.PHONY: docker-build-picod\ndocker-build-picod:\n\t@echo \"Building Picod image...\"\n\tdocker build \\\n\t\t-f deployment/docker/Dockerfile.picod \\\n\t\t--build-arg VERSION=$(VERSION) \\\n\t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n\t\t-t $(PICOD_IMAGE):$(DOCKER_TAG) \\\n\t\t-t $(PICOD_IMAGE):$(COMMIT_SHA) \\\n\t\t-t $(PICOD_IMAGE):$(VERSION) \\\n\t\t.\n\t@echo \"✓ Picod image built: $(PICOD_IMAGE):$(DOCKER_TAG)\"\n\n# Push all images\n.PHONY: docker-push-all\ndocker-push-all: docker-push-workloadmanager docker-push-router docker-push-picod\n\t@echo \"✓ All images pushed successfully\"\n\n# Push Workload Manager image\n.PHONY: docker-push-workloadmanager\ndocker-push-workloadmanager:\n\t@echo \"Pushing Workload Manager image to $(DOCKER_REGISTRY)...\"\n\tdocker push $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG)\n\tdocker push $(WORKLOADMANAGER_IMAGE):$(COMMIT_SHA)\n\tdocker push $(WORKLOADMANAGER_IMAGE):$(VERSION)\n\n# Push Router image\n.PHONY: docker-push-router\ndocker-push-router:\n\t@echo \"Pushing Router image to $(DOCKER_REGISTRY)...\"\n\tdocker push $(ROUTER_IMAGE):$(DOCKER_TAG)\n\tdocker push $(ROUTER_IMAGE):$(COMMIT_SHA)\n\tdocker push $(ROUTER_IMAGE):$(VERSION)\n\n# Push Picod image\n.PHONY: docker-push-picod\ndocker-push-picod:\n\t@echo \"Pushing Picod image to $(DOCKER_REGISTRY)...\"\n\tdocker push $(PICOD_IMAGE):$(DOCKER_TAG)\n\tdocker push $(PICOD_IMAGE):$(COMMIT_SHA)\n\tdocker push $(PICOD_IMAGE):$(VERSION)\n\n# Load images to Kind cluster\n.PHONY: kind-load-all\nkind-load-all: kind-load-workloadmanager kind-load-router kind-load-picod\n\t@echo \"✓ All images loaded to Kind cluster\"\n\n.PHONY: kind-load-workloadmanager\nkind-load-workloadmanager:\n\tkind load docker-image $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG)\n\n.PHONY: kind-load-router\nkind-load-router:\n\tkind load docker-image $(ROUTER_IMAGE):$(DOCKER_TAG)\n\n.PHONY: kind-load-picod\nkind-load-picod:\n\tkind load docker-image $(PICOD_IMAGE):$(DOCKER_TAG)\n\n# Multi-architecture build (requires Docker Buildx)\n.PHONY: docker-buildx-all\ndocker-buildx-all: docker-buildx-workloadmanager docker-buildx-router docker-buildx-picod\n\t@echo \"✓ All multi-arch images built successfully\"\n\n.PHONY: docker-buildx-workloadmanager\ndocker-buildx-workloadmanager:\n\t@echo \"Building multi-arch Workload Manager image...\"\n\tdocker buildx build \\\n\t\t--platform linux/amd64,linux/arm64 \\\n\t\t-f deployment/docker/Dockerfile \\\n\t\t--build-arg VERSION=$(VERSION) \\\n\t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n\t\t-t $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG) \\\n\t\t--push \\\n\t\t.\n\n.PHONY: docker-buildx-router\ndocker-buildx-router:\n\t@echo \"Building multi-arch Router image...\"\n\tdocker buildx build \\\n\t\t--platform linux/amd64,linux/arm64 \\\n\t\t-f deployment/docker/Dockerfile.router \\\n\t\t--build-arg VERSION=$(VERSION) \\\n\t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n\t\t-t $(ROUTER_IMAGE):$(DOCKER_TAG) \\\n\t\t--push \\\n\t\t.\n\n.PHONY: docker-buildx-picod\ndocker-buildx-picod:\n\t@echo \"Building multi-arch Picod image...\"\n\tdocker buildx build \\\n\t\t--platform linux/amd64,linux/arm64 \\\n\t\t-f deployment/docker/Dockerfile.picod \\\n\t\t--build-arg VERSION=$(VERSION) \\\n\t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n\t\t-t $(PICOD_IMAGE):$(DOCKER_TAG) \\\n\t\t--push \\\n\t\t.\n\n# Clean up local images\n.PHONY: docker-clean\ndocker-clean:\n\t@echo \"Cleaning up local Docker images...\"\n\t-docker rmi $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG) 2>/dev/null || true\n\t-docker rmi $(WORKLOADMANAGER_IMAGE):$(COMMIT_SHA) 2>/dev/null || true\n\t-docker rmi $(WORKLOADMANAGER_IMAGE):$(VERSION) 2>/dev/null || true\n\t-docker rmi $(ROUTER_IMAGE):$(DOCKER_TAG) 2>/dev/null || true\n\t-docker rmi $(ROUTER_IMAGE):$(COMMIT_SHA) 2>/dev/null || true\n\t-docker rmi $(ROUTER_IMAGE):$(VERSION) 2>/dev/null || true\n\t-docker rmi $(PICOD_IMAGE):$(DOCKER_TAG) 2>/dev/null || true\n\t-docker rmi $(PICOD_IMAGE):$(COMMIT_SHA) 2>/dev/null || true\n\t-docker rmi $(PICOD_IMAGE):$(VERSION) 2>/dev/null || true\n\t@echo \"✓ Cleanup complete\"\n\n# Validate images (size, security, configuration)\n.PHONY: docker-validate\ndocker-validate: docker-validate-workloadmanager docker-validate-router docker-validate-picod\n\t@echo \"✓ All images validated successfully\"\n\n.PHONY: docker-validate-workloadmanager\ndocker-validate-workloadmanager:\n\t@echo \"Validating Workload Manager image...\"\n\t@./deployment/docker/test/validate.sh $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG)\n\n.PHONY: docker-validate-router\ndocker-validate-router:\n\t@echo \"Validating Router image...\"\n\t@./deployment/docker/test/validate.sh $(ROUTER_IMAGE):$(DOCKER_TAG)\n\n.PHONY: docker-validate-picod\ndocker-validate-picod:\n\t@echo \"Validating Picod image...\"\n\t@./deployment/docker/test/validate.sh $(PICOD_IMAGE):$(DOCKER_TAG)\n\n# Run all tests\n.PHONY: docker-test\ndocker-test: docker-test-build docker-test-runtime\n\t@echo \"✓ All Docker tests passed\"\n\n.PHONY: docker-test-build\ndocker-test-build:\n\t@echo \"Running build tests...\"\n\t@./deployment/docker/test/build_test.sh\n\n.PHONY: docker-test-runtime\ndocker-test-runtime:\n\t@echo \"Running runtime tests...\"\n\t@./deployment/docker/test/runtime_test.sh\n\n# Help target\n.PHONY: help\nhelp:\n\t@echo \"AgentCube Docker Makefile\"\n\t@echo \"\"\n\t@echo \"Build targets:\"\n\t@echo \"  docker-build-all              - Build all three images\"\n\t@echo \"  docker-build-workloadmanager  - Build Workload Manager image\"\n\t@echo \"  docker-build-router           - Build Router image\"\n\t@echo \"  docker-build-picod            - Build Picod image\"\n\t@echo \"\"\n\t@echo \"Push targets:\"\n\t@echo \"  docker-push-all               - Push all images to registry\"\n\t@echo \"  docker-push-workloadmanager   - Push Workload Manager image\"\n\t@echo \"  docker-push-router            - Push Router image\"\n\t@echo \"  docker-push-picod             - Push Picod image\"\n\t@echo \"\"\n\t@echo \"Kind targets:\"\n\t@echo \"  kind-load-all                 - Load all images to Kind cluster\"\n\t@echo \"  kind-load-workloadmanager     - Load Workload Manager image\"\n\t@echo \"  kind-load-router              - Load Router image\"\n\t@echo \"  kind-load-picod               - Load Picod image\"\n\t@echo \"\"\n\t@echo \"Multi-arch targets:\"\n\t@echo \"  docker-buildx-all             - Build multi-arch images (amd64, arm64)\"\n\t@echo \"  docker-buildx-workloadmanager - Build multi-arch Workload Manager\"\n\t@echo \"  docker-buildx-router          - Build multi-arch Router\"\n\t@echo \"  docker-buildx-picod           - Build multi-arch Picod\"\n\t@echo \"\"\n\t@echo \"Test & validate targets:\"\n\t@echo \"  docker-test                   - Run all Docker tests\"\n\t@echo \"  docker-validate               - Validate all images\"\n\t@echo \"  docker-clean                  - Clean up local images\"\n\t@echo \"\"\n\t@echo \"Variables:\"\n\t@echo \"  DOCKER_REGISTRY=$(DOCKER_REGISTRY)\"\n\t@echo \"  DOCKER_TAG=$(DOCKER_TAG)\"\n\t@echo \"  VERSION=$(VERSION)\"\n\t@echo \"  COMMIT_SHA=$(COMMIT_SHA)\"\n","after":"# Makefile for AgentCube Docker builds\n# Provides targets for building, pushing, and managing container images\n\n# Docker configuration\nDOCKER_REGISTRY ?= ghcr.io/volcano-sh\nDOCKER_TAG ?= latest\nVERSION ?= $(shell git describe --tags --always --dirty 2>/dev/null || echo \"dev\")\nCOMMIT_SHA ?= $(shell git rev-parse --short HEAD 2>/dev/null || echo \"unknown\")\n\n# Image names\nWORKLOADMANAGER_IMAGE := $(DOCKER_REGISTRY)/workloadmanager\nROUTER_IMAGE := $(DOCKER_REGISTRY)/router\nPICOD_IMAGE := $(DOCKER_REGISTRY)/picod\n\n# CI/CD configuration\nIMAGE_REGISTRY ?= ghcr.io\nE2E_CLUSTER_NAME ?= agentcube-e2e\nE2E_CLEAN_CLUSTER ?= true\n\n# Build all images\n.PHONY: docker-build-all\ndocker-build-all: docker-build-workloadmanager docker-build-router docker-build-picod\n\t@echo \"✓ All images built successfully\"\n\n# Alias for CI workflow\n.PHONY: docker-build\ndocker-build: docker-build-workloadmanager\n\n# Build Workload Manager image\n.PHONY: docker-build-workloadmanager\ndocker-build-workloadmanager:\n\t@echo \"Building Workload Manager image...\"\n\tdocker build \\\n\t\t-f deployment/docker/Dockerfile \\\n\t\t--build-arg VERSION=$(VERSION) \\\n\t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n\t\t-t $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG) \\\n\t\t-t $(WORKLOADMANAGER_IMAGE):$(COMMIT_SHA) \\\n\t\t-t $(WORKLOADMANAGER_IMAGE):$(VERSION) \\\n