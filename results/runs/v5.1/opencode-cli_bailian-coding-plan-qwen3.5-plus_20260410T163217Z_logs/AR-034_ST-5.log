outer image\n35: .PHONY: docker-build-router\n36: docker-build-router:\n37: \t@echo \"Building Router image...\"\n38: \tdocker build \\\n39: \t\t-f deployment/docker/Dockerfile.router \\\n40: \t\t--build-arg VERSION=$(VERSION) \\\n41: \t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n42: \t\t-t $(ROUTER_IMAGE):$(DOCKER_TAG) \\\n43: \t\t-t $(ROUTER_IMAGE):$(COMMIT_SHA) \\\n44: \t\t-t $(ROUTER_IMAGE):$(VERSION) \\\n45: \t\t.\n46: \t@echo \"✓ Router image built: $(ROUTER_IMAGE):$(DOCKER_TAG)\"\n47: \n48: # Build Picod image\n49: .PHONY: docker-build-picod\n50: docker-build-picod:\n51: \t@echo \"Building Picod image...\"\n52: \tdocker build \\\n53: \t\t-f deployment/docker/Dockerfile.picod \\\n54: \t\t--build-arg VERSION=$(VERSION) \\\n55: \t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n56: \t\t-t $(PICOD_IMAGE):$(DOCKER_TAG) \\\n57: \t\t-t $(PICOD_IMAGE):$(COMMIT_SHA) \\\n58: \t\t-t $(PICOD_IMAGE):$(VERSION) \\\n59: \t\t.\n60: \t@echo \"✓ Picod image built: $(PICOD_IMAGE):$(DOCKER_TAG)\"\n61: \n62: # Push all images\n63: .PHONY: docker-push-all\n64: docker-push-all: docker-push-workloadmanager docker-push-router docker-push-picod\n65: \t@echo \"✓ All images pushed successfully\"\n66: \n67: # Push Workload Manager image\n68: .PHONY: docker-push-workloadmanager\n69: docker-push-workloadmanager:\n70: \t@echo \"Pushing Workload Manager image to $(DOCKER_REGISTRY)...\"\n71: \tdocker push $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG)\n72: \tdocker push $(WORKLOADMANAGER_IMAGE):$(COMMIT_SHA)\n73: \tdocker push $(WORKLOADMANAGER_IMAGE):$(VERSION)\n74: \n75: # Push Router image\n76: .PHONY: docker-push-router\n77: docker-push-router:\n78: \t@echo \"Pushing Router image to $(DOCKER_REGISTRY)...\"\n79: \tdocker push $(ROUTER_IMAGE):$(DOCKER_TAG)\n80: \tdocker push $(ROUTER_IMAGE):$(COMMIT_SHA)\n81: \tdocker push $(ROUTER_IMAGE):$(VERSION)\n82: \n83: # Push Picod image\n84: .PHONY: docker-push-picod\n85: docker-push-picod:\n86: \t@echo \"Pushing Picod image to $(DOCKER_REGISTRY)...\"\n87: \tdocker push $(PICOD_IMAGE):$(DOCKER_TAG)\n88: \tdocker push $(PICOD_IMAGE):$(COMMIT_SHA)\n89: \tdocker push $(PICOD_IMAGE):$(VERSION)\n90: \n91: # Load images to Kind cluster\n92: .PHONY: kind-load-all\n93: kind-load-all: kind-load-workloadmanager kind-load-router kind-load-picod\n94: \t@echo \"✓ All images loaded to Kind cluster\"\n95: \n96: .PHONY: kind-load-workloadmanager\n97: kind-load-workloadmanager:\n98: \tkind load docker-image $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG)\n99: \n100: .PHONY: kind-load-router\n101: kind-load-router:\n102: \tkind load docker-image $(ROUTER_IMAGE):$(DOCKER_TAG)\n103: \n104: .PHONY: kind-load-picod\n105: kind-load-picod:\n106: \tkind load docker-image $(PICOD_IMAGE):$(DOCKER_TAG)\n107: \n108: # Multi-architecture build (requires Docker Buildx)\n109: .PHONY: docker-buildx-all\n110: docker-buildx-all: docker-buildx-workloadmanager docker-buildx-router docker-buildx-picod\n111: \t@echo \"✓ All multi-arch images built successfully\"\n112: \n113: .PHONY: docker-buildx-workloadmanager\n114: docker-buildx-workloadmanager:\n115: \t@echo \"Building multi-arch Workload Manager image...\"\n116: \tdocker buildx build \\\n117: \t\t--platform linux/amd64,linux/arm64 \\\n118: \t\t-f deployment/docker/Dockerfile \\\n119: \t\t--build-arg VERSION=$(VERSION) \\\n120: \t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n121: \t\t-t $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG) \\\n122: \t\t--push \\\n123: \t\t.\n124: \n125: .PHONY: docker-buildx-router\n126: docker-buildx-router:\n127: \t@echo \"Building multi-arch Router image...\"\n128: \tdocker buildx build \\\n129: \t\t--platform linux/amd64,linux/arm64 \\\n130: \t\t-f deployment/docker/Dockerfile.router \\\n131: \t\t--build-arg VERSION=$(VERSION) \\\n132: \t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n133: \t\t-t $(ROUTER_IMAGE):$(DOCKER_TAG) \\\n134: \t\t--push \\\n135: \t\t.\n136: \n137: .PHONY: docker-buildx-picod\n138: docker-buildx-picod:\n139: \t@echo \"Building multi-arch Picod image...\"\n140: \tdocker buildx build \\\n141: \t\t--platform linux/amd64,linux/arm64 \\\n142: \t\t-f deployment/docker/Dockerfile.picod \\\n143: \t\t--build-arg VERSION=$(VERSION) \\\n144: \t\t--build-arg COMMIT_SHA=$(COMMIT_SHA) \\\n145: \t\t-t $(PICOD_IMAGE):$(DOCKER_TAG) \\\n146: \t\t--push \\\n147: \t\t.\n148: \n149: # Clean up local images\n150: .PHONY: docker-clean\n151: docker-clean:\n152: \t@echo \"Cleaning up local Docker images...\"\n153: \t-docker rmi $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG) 2>/dev/null || true\n154: \t-docker rmi $(WORKLOADMANAGER_IMAGE):$(COMMIT_SHA) 2>/dev/null || true\n155: \t-docker rmi $(WORKLOADMANAGER_IMAGE):$(VERSION) 2>/dev/null || true\n156: \t-docker rmi $(ROUTER_IMAGE):$(DOCKER_TAG) 2>/dev/null || true\n157: \t-docker rmi $(ROUTER_IMAGE):$(COMMIT_SHA) 2>/dev/null || true\n158: \t-docker rmi $(ROUTER_IMAGE):$(VERSION) 2>/dev/null || true\n159: \t-docker rmi $(PICOD_IMAGE):$(DOCKER_TAG) 2>/dev/null || true\n160: \t-docker rmi $(PICOD_IMAGE):$(COMMIT_SHA) 2>/dev/null || true\n161: \t-docker rmi $(PICOD_IMAGE):$(VERSION) 2>/dev/null || true\n162: \t@echo \"✓ Cleanup complete\"\n163: \n164: # Validate images (size, security, configuration)\n165: .PHONY: docker-validate\n166: docker-validate: docker-validate-workloadmanager docker-validate-router docker-validate-picod\n167: \t@echo \"✓ All images validated successfully\"\n168: \n169: .PHONY: docker-validate-workloadmanager\n170: docker-validate-workloadmanager:\n171: \t@echo \"Validating Workload Manager image...\"\n172: \t@./deployment/docker/test/validate.sh $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG)\n173: \n174: .PHONY: docker-validate-router\n175: docker-validate-router:\n176: \t@echo \"Validating Router image...\"\n177: \t@./deployment/docker/test/validate.sh $(ROUTER_IMAGE):$(DOCKER_TAG)\n178: \n179: .PHONY: docker-validate-picod\n180: docker-validate-picod:\n181: \t@echo \"Validating Picod image...\"\n182: \t@./deployment/docker/test/validate.sh $(PICOD_IMAGE):$(DOCKER_TAG)\n183: \n184: # Run all tests\n185: .PH