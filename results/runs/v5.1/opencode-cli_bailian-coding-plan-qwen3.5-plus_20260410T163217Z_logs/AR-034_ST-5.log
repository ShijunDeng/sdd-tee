er rmi $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG) 2>/dev/null || true\n\t-docker rmi $(WORKLOADMANAGER_IMAGE):$(COMMIT_SHA) 2>/dev/null || true\n\t-docker rmi $(WORKLOADMANAGER_IMAGE):$(VERSION) 2>/dev/null || true\n\t-docker rmi $(ROUTER_IMAGE):$(DOCKER_TAG) 2>/dev/null || true\n\t-docker rmi $(ROUTER_IMAGE):$(COMMIT_SHA) 2>/dev/null || true\n\t-docker rmi $(ROUTER_IMAGE):$(VERSION) 2>/dev/null || true\n\t-docker rmi $(PICOD_IMAGE):$(DOCKER_TAG) 2>/dev/null || true\n\t-docker rmi $(PICOD_IMAGE):$(COMMIT_SHA) 2>/dev/null || true\n\t-docker rmi $(PICOD_IMAGE):$(VERSION) 2>/dev/null || true\n\t@echo \"✓ Cleanup complete\"\n\n# Validate images (size, security, configuration)\n.PHONY: docker-validate\ndocker-validate: docker-validate-workloadmanager docker-validate-router docker-validate-picod\n\t@echo \"✓ All images validated successfully\"\n\n.PHONY: docker-validate-workloadmanager\ndocker-validate-workloadmanager:\n\t@echo \"Validating Workload Manager image...\"\n\t@./deployment/docker/test/validate.sh $(WORKLOADMANAGER_IMAGE):$(DOCKER_TAG)\n\n.PHONY: docker-validate-router\ndocker-validate-router:\n\t@echo \"Validating Router image...\"\n\t@./deployment/docker/test/validate.sh $(ROUTER_IMAGE):$(DOCKER_TAG)\n\n.PHONY: docker-validate-picod\ndocker-validate-picod:\n\t@echo \"Validating Picod image...\"\n\t@./deployment/docker/test/validate.sh $(PICOD_IMAGE):$(DOCKER_TAG)\n\n# Run all tests\n.PHONY: docker-test\ndocker-test: docker-test-build docker-test-runtime\n\t@echo \"✓ All Docker tests passed\"\n\n.PHONY: docker-test-build\ndocker-test-build:\n\t@echo \"Running build tests...\"\n\t@./deployment/docker/test/build_test.sh\n\n.PHONY: docker-test-runtime\ndocker-test-runtime:\n\t@echo \"Running runtime tests...\"\n\t@./deployment/docker/test/runtime_test.sh\n\n# Help target\n.PHONY: help\nhelp:\n\t@echo \"AgentCube Docker Makefile\"\n\t@echo \"\"\n\t@echo \"Build targets:\"\n\t@echo \"  docker-build-all              - Build all three images\"\n\t@echo \"  docker-build-w