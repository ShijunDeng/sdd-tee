required\")\n45: \tErrNamespaceRequired = fmt.Errorf(\"namespace is required\")\n46: )\n47: \n48: type SandboxCleanupReason string\n49: \n50: const (\n51: \tCleanupReasonManual      SandboxCleanupReason = \"manual\"\n52: \tCleanupReasonIdleTimeout SandboxCleanupReason = \"idle_timeout\"\n53: \tCleanupReasonExpired     SandboxCleanupReason = \"expired\"\n54: )\n55: \n56: type CleanupAuditEntry struct {\n57: \tSessionID    string               `json:\"sessionId\"`\n58: \tSandboxID    string               `json:\"sandboxId\"`\n59: \tNamespace    string               `json:\"namespace\"`\n60: \tReason       SandboxCleanupReason `json:\"reason\"`\n61: \tDeletedAt    time.Time            `json:\"deletedAt\"`\n62: \tSuccess      bool                 `json:\"success\"`\n63: \tErrorMessage string               `json:\"errorMessage,omitempty\"`\n64: }\n65: \n66: type TargetPort struct {\n67: \tPort       int32  `json:\"port\"`\n68: \tProtocol   string `json:\"protocol\"`\n69: \tPathPrefix string `json:\"pathPrefix\"`\n70: }\n71: \n72: type SandboxEntryPoint struct {\n73: \tPath     string `json:\"path\"`\n74: \tProtocol string `json:\"protocol\"`\n75: \tEndpoint string `json:\"endpoint\"`\n76: }\n77: \n78: type SandboxInfo struct {\n79: \tSessionID          string              `json:\"sessionId\"`\n80: \tSandboxID          string              `json:\"sandboxId\"`\n81: \tSandboxName        string              `json:\"sandboxName\"`\n82: \tSandboxNamespace   string              `json:\"sandboxNamespace\"`\n83: \tKind               string              `json:\"kind\"`\n84: \tNamespace          string              `json:\"namespace\"`\n85: \tWorkloadName       string              `json:\"workloadName\"`\n86: \tStatus             string              `json:\"status\"`\n87: \tPodIP              string              `json:\"podIP,omitempty\"`\n88: \tEntryPoints        []SandboxEntryPoint `json:\"entryPoints,omitempty\"`\n89: \tCreatedAt          time.Time           `json:\"createdAt\"`\n90: \tUpdatedAt          time.Time           `json:\"updatedAt\"`\n91: \tIdleTimeout        string              `json:\"idleTimeout,omitempty\"`\n92: \tMaxSessionDuration string              `json:\"maxSessionDuration,omitempty\"`\n93: \tLastActivityAt     time.Time           `json:\"lastActivityAt,omitempty\"`\n94: \tExpiresAt          time.Time           `json:\"expiresAt,omitempty\"`\n95: }\n96: \n97: const (\n98: \tAgentRuntimeKind    = \"AgentRuntime\"\n99: \tCodeInterpreterKind = \"CodeInterpreter\"\n100: \tSandboxClaimKind    = \"SandboxClaim\"\n101: )\n\n(End of file - total 101 lines)\n</content>","metadata":{"preview":"package types\n\nimport (\n\t\"fmt\"\n\t\"time\"\n)\n\ntype DeleteSandboxResponse struct {\n\tMessage string `json:\"message\"`\n}\n\ntype CreateSandboxRequest struct {\n\tKind      string            `json:\"kind\"`\n\tName      string            `json:\"name\"`\n\tNamespace string            `json:\"namespace\"`\n\tLabels    map[string]string `json:\"labels,omitempty\"`\n}\n\ntype CreateSandboxResponse struct {\n\tSessionID   string              `json:\"sessionId\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/types/sandbox_types.go","time":{"start":1775847449431,"end":1775847449454}}}}
