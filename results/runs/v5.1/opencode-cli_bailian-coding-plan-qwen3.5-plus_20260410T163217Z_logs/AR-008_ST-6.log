t\t\tSessionID:        \"session-1\",\n107: \t\t\t\tSandboxID:        \"sandbox-1\",\n108: \t\t\t\tSandboxNamespace: \"default\",\n109: \t\t\t\tKind:             wmTypes.AgentRuntimeKind,\n110: \t\t\t\tLastActivityAt:   time.Now().Add(-20 * time.Minute),\n111: \t\t\t},\n112: \t\t},\n113: \t}\n114: \n115: \tgc := NewGarbageCollector(fakeClient, fakeStore, 1*time.Hour)\n116: \tgc.tick()\n117: \n118: \tif len(fakeStore.deletedSessionIDs) != 1 {\n119: \t\tt.Errorf(\"Expected 1 sandbox to be deleted, got %d\", len(fakeStore.deletedSessionIDs))\n120: \t}\n121: \tif fakeStore.deletedSessionIDs[0] != \"session-1\" {\n122: \t\tt.Errorf(\"Expected session-1 to be deleted, got %s\", fakeStore.deletedSessionIDs[0])\n123: \t}\n124: }\n125: \n126: func TestGarbageCollector_Tick_ExpiredCleanup(t *testing.T) {\n127: \tfakeClient := newFakeDynamicClient()\n128: \tfakeStore := &fakeStore{\n129: \t\texpiredSandboxes: []*wmTypes.SandboxInfo{\n130: \t\t\t{\n131: \t\t\t\tSessionID:        \"session-2\",\n132: \t\t\t\tSandboxID:        \"sandbox-2\",\n133: \t\t\t\tSandboxNamespace: \"default\",\n134: \t\t\t\tKind:             wmTypes.AgentRuntimeKind,\n135: \t\t\t\tExpiresAt:        time.Now().Add(-1 * time.Hour),\n136: \t\t\t\tLastActivityAt:   time.Now(),\n137: \t\t\t},\n138: \t\t},\n139: \t}\n140: \n141: \tgc := NewGarbageCollector(fakeClient, fakeStore, 1*time.Hour)\n142: \tgc.tick()\n143: \n144: \tif len(fakeStore.deletedSessionIDs) != 1 {\n145: \t\tt.Errorf(\"Expected 1 sandbox to be deleted, got %d\", len(fakeStore.deletedSessionIDs))\n146: \t}\n147: \tif fakeStore.deletedSessionIDs[0] != \"session-2\" {\n148: \t\tt.Errorf(\"Expected session-2 to be deleted, got %s\", fakeStore.deletedSessionIDs[0])\n149: \t}\n150: }\n151: \n152: func TestGarbageCollector_DeleteSandbox_NotFound(t *testing.T) {\n153: \tfakeClient := newFakeDynamicClient()\n154: \tfakeStore := &fakeStore{}\n155: \n156: \tgc := NewGarbageCollector(fakeClient, fakeStore, 1*time.Hour)\n157: \n158: \tsandbox := &wmTypes.SandboxInfo{\n159: \t\tSessionID:        \"session-3\",\n160: \t\tSandboxID:        \"sandbox-3\",\n161: \t\tSandboxNamespace: \"default\",\n162: \t\tKind:             wmTypes.AgentRuntimeKind,\n163: \t}\n164: \n165: \tgc.deleteSandbox(context.Background(), sandbox, wmTypes.CleanupReasonIdleTimeout)\n166: \n167: \tif len(fakeStore.deletedSessionIDs) != 1 {\n168: \t\tt.Errorf(\"Expected 1 sandbox to be deleted from store, got %d\", len(fakeStore.deletedSessionIDs))\n169: \t}\n170: }\n171: \n172: func TestGarbageCollector_DeleteSandbox_StoreError(t *testing.T) {\n173: \tfakeClient := newFakeDynamicClient()\n174: \tfakeStore := &fakeStore{}\n175: \n176: \tgc := NewGarbageCollector(fakeClient, fakeStore, 1*time.Hour)\n177: \n178: \tsandbox := &wmTypes.SandboxInfo{\n179: \t\tSessionID:        \"session-4\",\n180: \t\tSandboxID:        \"sandbox-4\",\n181: \t\tSandboxNamespace: \"default\",\n182: \t\tKind:             wmTypes.AgentRuntimeKind,\n183: \t}\n184: \n185: \tgc.deleteSandbox(context.Background(), sandbox, wmTypes.CleanupReasonIdleTimeout)\n186: \n187: \tif len(fakeStore.deletedSessionIDs) != 1 {\n188: \t\tt.Errorf(\"Expected 1 sandbox to be deleted from store, got %d\", len(fakeStore.deletedSessionIDs))\n189: \t}\n190: }\n191: \n192: func TestGarbageCollector_Tick_ContextTimeout(t *testing.T) {\n193: \tfakeClient := newFakeDynamicClient()\n194: \tfakeStore := &fakeStore{\n195: \t\tinactiveSandboxes: []*wmTypes.SandboxInfo{\n196: \t\t\t{\n197: \t\t\t\tSessionID:        \"session-5\",\n198: \t\t\t\tSandboxID:        \"sandbox-5\",\n199: \t\t\t\tSandboxNamespace: \"default\",\n200: \t\t\t\tKind:             wmTypes.AgentRuntimeKind,\n201: \t\t\t\tLastActivityAt:   time.Now().Add(-20 * time.Minute),\n202: \t\t\t},\n203: \t\t},\n204: \t}\n205: \n206: \tgc := NewGarbageCollector(fakeClient, fakeStore, 1*time.Hour)\n207: \tgc.tick()\n208: \n209: \tif len(fakeStore.deletedSessionIDs) == 0 {\n210: \t\tt.Error(\"Expected at least one sandbox to be deleted\")\n211: \t}\n212: }\n213: \n214: func TestGarbageCollector_Tick_StoreError(t *testing.T) {\n215: \tfakeClient := newFakeDynamicClient()\n216: \tfakeStore := &fakeStore{}\n217: \n218: \tgc := NewGarbageCollector(fakeClient, fakeStore, 1*time.Hour)\n219: \n220: \tgc.tick()\n221: \n222: \tif len(fakeStore.deletedSessionIDs) != 0 {\n223: \t\tt.Errorf(\"Expected no sandboxes to be deleted, got %d\", len(fakeStore.deletedSessionIDs))\n224: \t}\n225: }\n226: \n227: func newFakeDynamicClient() *fake.FakeDynamicClient {\n228: \tscheme := runtime.NewScheme()\n229: \treturn fake.NewSimpleDynamicClient(scheme)\n230: }\n\n(End of file - total 230 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\ntype fakeStore struct {\n\tinactiveSandboxes []*wmTypes.SandboxInfo\n\texpiredSandboxes  []*wmTypes.SandboxInfo\n\tdeletedSessionIDs []string\n}\n\nfunc (f *fakeStore) Ping(ctx context.Context) error {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/garbage_collector_test.go","time":{"start":1775847440755,"end":1775847440793}}}}
