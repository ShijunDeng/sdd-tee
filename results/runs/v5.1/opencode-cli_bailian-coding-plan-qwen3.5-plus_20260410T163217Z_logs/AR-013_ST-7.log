ptions()\n225: \tstore := NewRedisStore(opts)\n226: \tdefer store.Close()\n227: \n228: \tctx := context.Background()\n229: \tinfo := &types.SandboxInfo{\n230: \t\tSessionID:        \"session-1\",\n231: \t\tSandboxID:        \"sandbox-1\",\n232: \t\tSandboxName:      \"test-sandbox\",\n233: \t\tSandboxNamespace: \"default\",\n234: \t\tKind:             types.AgentRuntimeKind,\n235: \t\tNamespace:        \"default\",\n236: \t\tWorkloadName:     \"test-workload\",\n237: \t\tStatus:           \"Running\",\n238: \t\tCreatedAt:        time.Now(),\n239: \t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n240: \t\tLastActivityAt:   time.Now(),\n241: \t}\n242: \n243: \terr = store.StoreSandbox(ctx, info)\n244: \tif err != nil {\n245: \t\tt.Fatalf(\"StoreSandbox failed: %v\", err)\n246: \t}\n247: \n248: \terr = store.DeleteSandboxBySessionID(ctx, \"session-1\")\n249: \tif err != nil {\n250: \t\tt.Fatalf(\"DeleteSandboxBySessionID failed: %v\", err)\n251: \t}\n252: \n253: \t_, err = store.GetSandboxBySessionID(ctx, \"session-1\")\n254: \tif err != ErrNotFound {\n255: \t\tt.Errorf(\"expected ErrNotFound after delete, got %v\", err)\n256: \t}\n257: }\n258: \n259: func TestRedisStoreListExpiredSandboxesZeroLimit(t *testing.T) {\n260: \tmr, err := miniredis.Run()\n261: \tif err != nil {\n262: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n263: \t}\n264: \tdefer mr.Close()\n265: \n266: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n267: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n268: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n269: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n270: \n271: \topts, _ := makeRedisOptions()\n272: \tstore := NewRedisStore(opts)\n273: \tdefer store.Close()\n274: \n275: \tresult, err := store.ListExpiredSandboxes(context.Background(), time.Now(), 0)\n276: \tif err != nil {\n277: \t\tt.Fatalf(\"ListExpiredSandboxes failed: %v\", err)\n278: \t}\n279: \tif result != nil {\n280: \t\tt.Errorf(\"expected nil result for limit 0, got %v\", result)\n281: \t}\n282: }\n283: \n284: func TestRedisStoreUpdateSessionLastActivityNotFound(t *testing.T) {\n285: \tmr, err := miniredis.Run()\n286: \tif err != nil {\n287: \t\tt.Fatalf(\"miniredis failed: %v\", err)\n288: \t}\n289: \tdefer mr.Close()\n290: \n291: \tos.Setenv(\"REDIS_ADDR\", mr.Addr())\n292: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n293: \tdefer os.Unsetenv(\"REDIS_ADDR\")\n294: \tdefer os.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n295: \n296: \topts, _ := makeRedisOptions()\n297: \tstore := NewRedisStore(opts)\n298: \tdefer store.Close()\n299: \n300: \terr = store.UpdateSessionLastActivity(context.Background(), \"nonexistent\", time.Now())\n301: \tif err != ErrNotFound {\n302: \t\tt.Errorf(\"expected ErrNotFound, got %v\", err)\n303: \t}\n304: }\n\n(End of file - total 304 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestMakeRedisOptions(t *testing.T) {\n\tt.Run(\"with all env vars set\", func(t *testing.T) {\n\t\tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n\t\tos.Setenv(\"REDIS_PASSWORD\", \"secret\")\n\t\tdefer os.Unsetenv(\"REDIS_ADDR\")\n\t\tdefer os.Unsetenv(\"REDIS_PASSWORD\")\n\n\t\topts, err := makeRedisOptions()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store_redis_test.go","time":{"start":1775856891221,"end":1775856891233}}}}
