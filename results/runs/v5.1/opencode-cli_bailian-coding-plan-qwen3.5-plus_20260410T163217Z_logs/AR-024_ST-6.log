CubeProvider` |\n25: | `agentcube/operations/__init__.py` | Placeholder module docstring (no symbols) |\n26: | `examples/hello-agent/main.py` | Example agent |\n27: | `examples/math-agent/main.py` | Example agent |\n28: \n29: **Setuptools packages** (from `pyproject.toml` `[tool.setuptools]`):  \n30: `agentcube`, `agentcube.cli`, `agentcube.runtime`, `agentcube.operations`, `agentcube.services`  \n31: *(Note: `agentcube.models` is not listed in `[tool.setuptools] packages` but is imported; packaging may rely on setuptools discovery for subpackages — reconstruct imports from source as above.)*\n32: \n33: ## Console script entry point\n34: \n35: ```toml\n36: [project.scripts]\n37: kubectl-agentcube = \"agentcube.cli.main:app\"\n38: ```\n39: \n40: Typer app object: `app = typer.Typer(name=\"agentcube\", help=\"...\", no_args_is_help=True, rich_markup_mode=\"rich\", add_completion=False)`.\n41: \n42: ## Typer — root callback\n43: \n44: ```python\n45: def main(\n46:     version: Optional[bool] = typer.Option(\n47:         None, \"--version\", help=\"Show version and exit\",\n48:         callback=version_callback, is_eager=True,\n49:     ),\n50:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Enable verbose output\"),\n51: ) -> None:\n52:     \"\"\"AgentCube CLI - A developer tool for AI agent lifecycle management.\"\"\"\n53: ```\n54: \n55: ## Typer — `pack`\n56: \n57: ```python\n58: def pack(\n59:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n60:     agent_name: Optional[str] = typer.Option(None, \"--agent-name\", help=\"Override the agent name\"),\n61:     language: Optional[str] = typer.Option(None, \"--language\", help=\"Programming language (python, java)\"),\n62:     entrypoint: Optional[str] = typer.Option(None, \"--entrypoint\", help=\"Override the entrypoint command\"),\n63:     port: Optional[int] = typer.Option(None, \"--port\", help=\"Port to expose in the Dockerfile\"),\n64:     build_mode: Optional[str] = typer.Option(None, \"--build-mode\", help=\"Build strategy: local or cloud\"),\n65:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description\"),\n66:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for packaged workspace\"),\n67:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n68: ) -> None:\n69: ```\n70: \n71: ## Typer — `build`\n72: \n73: ```python\n74: def build(\n75:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n76:     proxy: Optional[str] = typer.Option(None, \"-p\", \"--proxy\", help=\"Custom proxy URL for dependency resolution\"),\n77:     cloud_provider: Optional[str] = typer.Option(None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei)\"),\n78:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for build artifacts\"),\n79:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n80: ) -> None:\n81: ```\n82: \n83: ## Typer — `publish`\n84: \n85: ```python\n86: def publish(\n87:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n88:     version: Optional[str] = typer.Option(None, \"--version\", help=\"Semantic version string (e.g., v1.0.0)\"),\n89:     image_url: Optional[str] = typer.Option(None, \"--image-url\", help=\"Image repository URL (required in local build mode)\"),\n90:     image_username: Optional[str] = typer.Option(None, \"--image-username\", help=\"Username for image repository\"),\n91:     image_password: Optional[str] = typer.Option(None, \"--image-password\", help=\"Password for image repository\"),\n92:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description\"),\n93:     region: Optional[str] = typer.Option(None, \"--region\", help=\"Deployment region\"),\n94:     cloud_provider: Optional[str] = typer.Option(None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei)\"),\n95:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\"),\n96:     node_port: Optional[int] = typer.Option(None, \"--node-port\", help=\"Specific NodePort to use (30000-32767) for K8s deployment\"),\n97:     replicas: Optional[int] = typer.Option(None, \"--replicas\", help=\"Number of replicas for K8s deployment (default: 1)\"),\n98:     namespace: Optional[str] = typer.Option(None, \"--namespace\", help=\"The namespace for the deployment\"),\n99:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n100: ) -> None:\n101: ```\n102: \n103: ## Typer — `invoke`\n104: \n105: ```python\n106: def invoke(\n107:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n108:     payload: str = typer.Option(\"{}\", \"--payload\", help=\"JSON-formatted input passed to the agent\"),\n109:     header_list: Optional[List[str]] = typer.Option(None, \"--header\", help=\"Custom HTTP headers (e.g., 'Authorization: Bearer token'). Can be specified multiple times.\"),\n110:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\"),\n111:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n112: ) -> None:\n113: ```\n114: \n115: ## Typer — `status`\n116: \n117: ```python\n118: def status(\n119:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n120:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\"),\n121:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n122: ) -> None:\n123: ```\n124: \n125: ## Helper functions (`agentcube/cli/main.py`)\n126: \n127: ```python\n128: def version_callback(value: bool) -> None: ...\n129: def _handle_error(e: Exception, command_name: str, verbose: bool) -> None: ...  # prints, typer.Exit(1)\n130: ```\n131: \n132: ## Runtime classes\n133: \n134: ### `PackRuntime` (`agentcube/runtime/pack_runtime.py`)\n135: \n136: ```python\n137: class PackRuntime:\n138:     def __init__(self, verbose: bool = False) -> None: ...\n139:     def pack(self, workspace_path: Path, **options: Any) -> Dict[str, Any]: ...\n140:     def _validate_workspace_structure(self, workspace_path: Path) -> None: ...\n141:     def _load_or_create_metadata(self, workspace_path: Path, options: Dict[str, Any]) -> AgentMetadata: ...\n142:     def _apply_option_overrides(self, metadata: AgentMetadata, options: Dict[str, Any]) -> AgentMetadata: ...\n143:     def _validate_language_compatibility(self, workspace_path: Path, metadata: AgentMetadata) -> None: ...\n144:     def _validate_python_compatibility(self, workspace_path: Path) -> None: ...\n145:     def _validate_java_compatibility(self, workspace_path: Path) -> None: ...\n146:     def _process_dependencies(self, workspace_path: Path, metadata: AgentMetadata) -> None: ...\n147:     def _process_python_dependencies(self, workspace_path: Path) -> None: ...\n148:     def _process_java_dependencies(self, workspace_path: Path) -> None: ...\n149:     def _generate_dockerfile(self, workspace_path: Path, metadata: AgentMetadata) -> Optional[Path]: ...\n150:     def _generate_python_dockerfile(self, metadata: AgentMetadata) -> str: ...\n151:     def _generate_java_dockerfile(self, metadata: AgentMetadata) -> str: ...\n152:     def _update_pack_metadata(self, workspace_path: Path, metadata: AgentMetadata, dockerfile_path: Optional[Path]) -> None: ...\n153:     def _prepare_output_path(self, workspace_path: Path, output_path: Optional[str]) -> Path: ...\n154:     def _infer_entrypoint(self, workspace_path: Path, language: str) -> str: ...\n155: ```\n156: \n157: ### `BuildRuntime` (`agentcube/runtime/build_runtime.py`)\n158: \n159: ```python\n160: class BuildRuntime:\n161:     def __init__(self, verbose: bool = False) -> None: ...\n162:     def build(self, workspace_path: Path, **options: Any) -> Dict[str, Any]: ...\n163:     def _increment_version(self, workspace_path: Path, metadata) -> Any: ...\n164:     def _validate_build_prerequisites(self, workspace_path: Path) -> None: ...\n165:     def _build_local(self, workspace_path: Path, metadata, options: Dict[str, Any]) -> Dict[str, Any]: ...\n166:     def _build_cloud(self, workspace_path: Path, metadata, options: Dict[str, Any]) -> Dict[str, Any]: ...\n167:     def _update_build_metadata(self, workspace_path: Path, metadata, build_result: Dict[str, str], tag: str = \"latest\") -> None: ...\n168: ```\n169: \n170: ### `PublishRuntime` (`agentcube/runtime/publish_runtime.py`)\n171: \n172: ```python\n173: class PublishRuntime:\n174:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None: ...\n175:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]: ...\n176:     def _publish_cr_to_k8s(self, workspace_path: Path, metadata, **options: Any) -> Dict[str, Any]: ...\n177:     def _publish_k8s(self, workspace_path: Path, metadata, **options: Any) -> Dict[str, Any]: ...\n178:     def _prepare_image_for_publishing(self, workspace_path: Path, metadata, options: Dict[str, Any]) -> str: ...\n179:     def _prepare_local_image(self, workspace_path: Path, metadata, options: Dict[str, Any]) -> str: ...\n180:     def _prepare_cloud_image(self, workspace_path: Path, metadata, options: Dict[str, Any]) -> str: ...\n181:     def _update_publish_metadata(self, workspace_path: Path, agent_info: Dict[str, Any]) -> None: ...\n182: ```\n183: \n184: ### `InvokeRuntime` (`agentcube/runtime/invoke_runtime.py`)\n185: \n186: ```python\n187: class InvokeRuntime:\n188:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None: ...\n189:     def invoke(self, workspace_path: Path, payload: Dict[str, Any], headers: Optional[Dict[str, str]] = None) -> Any: ...\n190:     def _validate_invoke_prerequisites(self, workspace_path: Path) -> Tuple[Any, str, str]: ...\n191:     async def _invoke_agent_via_agentcube(self, agent_id: str, payload: Dict[str, Any], headers: Optional[Dict[str, str]], endpoint: str, workspace_path: Path) -> Any: ...\n192:     async def _direct_http_invocation(self, endpoint: str, payload: Dict[str, Any], headers: Optional[Dict[str, str]], workspace_path: Path) -> Dict[str, Any]: ...\n193: ```\n194: \n195: **Implementation note:** `_invoke_agent_via_agentcube` only assigns `response` inside `if endpoint.startswith(\"http\"):`; if the condition is false, `return response` may raise `UnboundLocalError` (as of extracted source).\n196: \n197: ### `StatusRuntime` (`agentcube/runtime/status_runtime.py`)\n198: \n199: ```python\n200: class StatusRuntime:\n201:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None: ...\n202:     def get_status(self, workspace_path: Path, provider: Optional[str] = None) -> Dict[str, Any]: ...\n203:     def _get_k8s_status(self, metadata) -> Dict[str, Any]: ...\n204:     def _get_cr_k8s_status(self, metadata) -> Dict[str, Any]: ...\n205: ```\n206: \n207: ## AR-023: `invoke` command — Technical Implementation\n208: \n209: ### Command Flow\n210: \n211: ```\n212: ┌─────────────────┐     ┌──────────────────┐     ┌─────────────────┐\n213: │  CLI (main.py)  │────▶│  InvokeRuntime    │────▶│  HTTP Client    │\n214: │  - parse args   │     │  - validate       │     │  - POST /invoke │\n215: │  - parse JSON   │     │  - build URL      │     │  - headers      │\n216: │  - parse headers│     │  - invoke         │     │  - response     │\n217: └─────────────────┘     └──────────────────┘     └─────────────────┘\n218: ```\n219: \n220: ### CLI Layer (`agentcube/cli/main.py`)\n221: \n222: **Function signature:**\n223: ```python\n224: def invoke(\n225:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n226:     payload: str = typer.Option(\"{}\", \"--payload\", help=\"JSON-formatted input passed to the agent\"),\n227:     header_list: Optional[List[str]] = typer.Option(None, \"--header\", help=\"Custom HTTP headers (e.g., 'Authorization: Bearer token'). Can be specified multiple times.\"),\n228:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\"),\n229:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n230: ) -> None:\n231: ```\n232: \n233: **Implementation:**\n234: ```python\n235: def invoke(\n236:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", ...),\n237:     payload: str = typer.Option(\"{}\", \"--payload\", ...),\n238:     header_list: Optional[List[str]] = typer.Option(None, \"--header\", ...),\n239:     provider: str = typer.Option(\"agentcube\", \"--provider\", ...),\n240:     verbose: bool = typer.Option(False, \"--verbose\", ...),\n241: ) -> None:\n242:     import json\n243:     from pathlib import Path\n244:     from rich.console import Console\n245:     from rich.progress import Progress, SpinnerColumn, TextColumn\n246:     \n247:     console = Console()\n248:     workspace_path = Path(workspace).expanduser().resolve()\n249:     \n250:     # Parse payload JSON (early validation)\n251:     try:\n252:         payload_dict = json.loads(payload)\n253:     except json.JSONDecodeError as e:\n254:         console.print(f\"[red]Error: Invalid JSON payload: {e}[/red]\")\n255:         raise typer.Exit(1)\n256:     \n257:     # Parse headers\n258:     headers = {}\n259:     if header_list:\n260:         for header in header_list:\n261:             if \":\" not in header:\n262:                 console.print(f\"[red]Error: Invalid header format '{header}'. Expected 'key:value'[/red]\")\n263:                 raise typer.Exit(1)\n264:             key, value = header.split(\":\", 1)\n265:             headers[key.strip()] = value.strip()\n266:     \n267:     # Execute with progress indicator\n268:     with Progress(\n269:         SpinnerColumn(),\n270:         TextColumn(\"[progress.description]{task.description}\"),\n271:         console=console,\n272:     ) as progress:\n273:         task = progress.add_task(\"Invoking agent...\", total=None)\n274:         try:\n275:             runtime = InvokeRuntime(verbose=verbose, provider=provider)\n276:             result = runtime.invoke(workspace_path, payload_dict, headers if headers else None)\n277:             progress.update(task, completed=True)\n278:             console.print(\"[green]✓ Invocation successful[/green]\")\n279:             # Display result (format based on response type)\n280:             if isinstance(result, dict):\n281:                 console.print_json(json.dumps(result, indent=2))\n282:             else:\n283:                 console.print(result)\n284:         except Exception as e:\n285:             progress.update(task, completed=True)\n286:             _handle_error(e, \"invoking agent\", verbose)\n287: ```\n288: \n289: ### Runtime Layer (`agentcube/runtime/invoke_runtime.py`)\n290: \n291: **Class structure:**\n292: ```python\n293: import httpx\n294: import asyncio\n295: from pathlib import Path\n296: from typing import Any, Dict, Optional, Tuple\n297: from agentcube.services.metadata_service import MetadataService\n298: from agentcube.services.agentcube_provider import AgentCubeProvider\n299: from agentcube.services.k8s_provider import KubernetesProvider\n300: \n301: class InvokeRuntime:\n302:     SESSION_HEADER = \"x-agentcube-session-id\"\n303:     \n304:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n305:         self.verbose = verbose\n306:         self.provider = provider\n307:         self.metadata_service = MetadataService(verbose=verbose)\n308:         self.logger = logging.getLogger(__name__)\n309:     \n310:     def invoke(\n311:         self,\n312:         workspace_path: Path,\n313:         payload: Dict[str, Any],\n314:         headers: Optional[Dict[str, str]] = None\n315:     ) -> Any:\n316:         # Validate prerequisites and get metadata + endpoint\n317:         metadata, endpoint, agent_type = self._validate_invoke_prerequisites(workspace_path)\n318:         \n319:         # Merge session_id from metadata if available\n320:         if headers is None:\n321:             headers = {}\n322:         if metadata.session_id:\n323:             headers[self.SESSION_HEADER] = metadata.session_id\n324:         \n325:         # Route based on provider\n326:         if self.provider == \"agentcube\":\n327:             return asyncio.run(\n328:                 self._invoke_agent_via_agentcube(\n329:                     agent_id=metadata.agent_id,\n330:                     payload=payload,\n331:                     headers=headers,\n332:                     endpoint=endpoint,\n333:                     workspace_path=workspace_path\n334:                 )\n335:             )\n336:         elif self.provider == \"k8s\":\n337:             return asyncio.run(\n338:                 self._direct_http_invocation(\n339:                     endpoint=endpoint,\n340:                     payload=payload,\n341:                     headers=headers,\n342:                     workspace_path=workspace_path\n343:                 )\n344:             )\n345:         else:\n346:             raise ValueError(f\"Unknown provider: {self.provider}\")\n347:     \n348:     def _validate_invoke_prerequisites(\n349:         self,\n350:         workspace_path: Path\n351:     ) -> Tuple[Any, str, str]:\n352:         \"\"\"Validate workspace and return (metadata, endpoint, agent_type).\"\"\"\n353:         # Load metadata\n354:         metadata = self.metadata_service.load_metadata(workspace_path)\n355:         \n356:         # Check if published\n357:         if not metadata.agent_id:\n358:             raise ValueError(\n359:                 \"Agent has not been published. Run 'kubectl-agentcube publish' first.\"\n360:             )\n361:         \n362:         # Determine endpoint based on deployment type\n363:         if metadata.k8s_deployment:\n364:             deployment_type = metadata.k8s_deployment.get(\"type\", \"unknown\")\n365:             if deployment_type == \"AgentRuntime\":\n366:                 # AgentRuntime CR: construct invocation URL\n367:                 namespace = metadata.k8s_deployment.get(\"namespace\", \"default\")\n368:                 agent_name = metadata.k8s_deployment.get(\"name\", metadata.agent_name)\n369:                 router_url = metadata.router_url or metadata.k8s_deployment.get(\"router_url\")\n370:                 if not router_url:\n371:                     raise ValueError(\n372:                         \"router_url is required for AgentRuntime invocation. \"\n373:                         \"Ensure it is set in agent_metadata.yaml\"\n374:                     )\n375:                 endpoint = (\n376:                     f\"{router_url}/v1/namespaces/{namespace}/\"\n377:                     f\"agent-runtimes/{agent_name}/invocations/\"\n378:                 )\n379:                 return metadata, endpoint, \"agentruntime\"\n380:             elif deployment_type == \"Deployment\":\n381:                 # Standard K8s Deployment: use agent_endpoint\n382:                 if not metadata.agent_endpoint:\n383:                     raise ValueError(\n384:                         \"agent_endpoint is required for Deployment invocation. \"\n385:                         \"Ensure it is set in agent_metadata.yaml\"\n386:                     )\n387:                 return metadata, metadata.agent_endpoint, \"deployment\"\n388:             else:\n389:                 raise ValueError(f\"Unknown deployment type: {deployment_type}\")\n390:         else:\n391:             # Fallback to agent_endpoint\n392:             if not metadata.agent_endpoint:\n393:                 raise ValueError(\n394:                     \"No agent_endpoint found in metadata. \"\n395:                     \"Agent may not be published correctly.\"\n396:                 )\n397:             return metadata, metadata.agent_endpoint, \"unknown\"\n398:     \n399:     async def _invoke_agent_via_agentcube(\n400:         self,\n401:         agent_id: str,\n402:         payload: Dict[str, Any],\n403:         headers: Optional[Dict[str, str]],\n404:         endpoint: str,\n405:         workspace_path: Path\n406:     ) -> Any:\n407:         \"\"\"Invoke agent through AgentCube Router.\"\"\"\n408:         if not endpoint.startswith(\"http\"):\n409:             # Fix for UnboundLocalError: initialize response\n410:             raise ValueError(f\"Invalid endpoint URL: {endpoint}\")\n411:         \n412:         async with httpx.AsyncClient() as client:\n413:             response = await client.post(\n414:                 endpoint,\n415:                 json=payload,\n416:                 headers=headers,\n417:                 timeout=120.0\n418:             )\n419:             response.raise_for_status()\n420:             return response.json()\n421:     \n422:     async def _direct_http_invocation(\n423:         self,\n424:         endpoint: str,\n425:         payload: Dict[str, Any],\n426:         headers: Optional[Dict[str, str]],\n427:         workspace_path: Path\n428:     ) -> Dict[str, Any]:\n429:         \"\"\"Direct HTTP invocation for standard K8s Deployment.\"\"\"\n430:         async with httpx.AsyncClient() as client:\n431:             response = await client.post(\n432:                 endpoint,\n433:                 json=payload,\n434:                 headers=headers,\n435:                 timeout=120.0\n436:             )\n437:             response.raise_for_status()\n438:             return response.json()\n439: ```\n440: \n441: ### Error Handling\n442: \n443: | Error | Source | CLI Output | Exit Code |\n444: |-------|--------|------------|-----------|\n445: | Invalid JSON payload | `json.loads()` | `[red]Error: Invalid JSON payload: {details}[/red]` | 1 |\n446: | Invalid header format | Header parsing | `[red]Error: Invalid header format '{header}'. Expected 'key:value'[/red]` | 1 |\n447: | Agent not published | `_validate_invoke_prerequisites` | `[red]Error invoking agent: Agent has not been published...[/red]` | 1 |\n448: | Missing router_url | `_validate_invoke_prerequisites` | `[red]Error invoking agent: router_url is required...[/red]` | 1 |\n449: | Missing agent_endpoint | `_validate_invoke_prerequisites` | `[red]Error invoking agent: agent_endpoint is required...[/red]` | 1 |\n450: | HTTP error | `httpx` | `[red]Error invoking agent: {status_code} {reason}[/red]` | 1 |\n451: | Timeout | `httpx.TimeoutException` | `[red]Error invoking agent: Request timed out after 120s[/red]` | 1 |\n452: \n453: ## AR-023: `status` command — Technical Implementation\n454: \n455: ### Command Flow\n456: \n457: ```\n458: ┌─────────────────┐     ┌──────────────────┐     ┌─────────────────┐\n459: │  CLI (main.py)  │────▶│  StatusRuntime    │────▶│  Provider       │\n460: │  - parse args   │     │  - get_status     │     │  - K8s API      │\n461: │  - display      │     │  - route          │     │  - CRD API      │\n462: └─────────────────┘     └──────────────────┘     └──────────────────┘\n463:                               │\n464:                               ▼\n465:                        ┌─────────────────┐\n466:                        │  Rich Table     │\n467:                        │  - status       │\n468:                        │  - endpoint     │\n469:                        │  - pods         │\n470:                        └─────────────────┘\n471: ```\n472: \n473: ### CLI Layer (`agentcube/cli/main.py`)\n474: \n475: **Function signature:**\n476: ```python\n477: def status(\n478:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n479:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\"),\n480:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n481: ) -> None:\n482: ```\n483: \n484: **Implementation:**\n485: ```python\n486: def status(\n487:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", ...),\n488:     provider: str = typer.Option(\"agentcube\", \"--provider\", ...),\n489:     verbose: bool = typer.Option(False, \"--verbose\", ...),\n490: ) -> None:\n491:     from pathlib import Path\n492:     from rich.console import Console\n493:     from rich.table import Table\n494:     from rich.progress import Progress, SpinnerColumn, TextColumn\n495:     \n496:     console = Console()\n497:     workspace_path = Path(workspace).expanduser().resolve()\n498:     \n499:     with Progress(\n500:         SpinnerColumn(),\n501:         TextColumn(\"[progress.description]{task.description}\"),\n502:         console=console,\n503:     ) as progress:\n504:         task = progress.add_task(\"Fetching agent status...\", total=None)\n505:         try:\n506:             runtime = StatusRuntime(verbose=verbose, provider=provider)\n507:             status_info = runtime.get_status(workspace_path, provider=provider)\n508:             progress.update(task, completed=True)\n509:             \n510:             # Check for not_published status\n511:             if status_info.get(\"status\") == \"not_published\":\n512:                 console.print(\"[yellow]⚠ Agent has not been published[/yellow]\")\n513:                 console.print(\n514:                     \"\\nRun [bold]kubectl-agentcube publish[/bold] to deploy your agent.\\n\"\n515:                 )\n516:                 raise typer.Exit(1)\n517:             \n518:             # Check for error status\n519:             if status_info.get(\"status\") == \"error\":\n520:                 console.print(f\"[red]✗ Status error: {status_info.get('error', 'Unknown error')}[/red]\")\n521:                 raise typer.Exit(1)\n522:             \n523:             # Display status table\n524:             table = Table(title=f\"Agent Status: {status_info.get('agent_name', 'Unknown')}\")\n525:             table.add_column(\"Property\", style=\"cyan\")\n526:             table.add_column(\"Value\", style=\"green\")\n527:             \n528:             # Core status\n529:             table.add_row(\"Status\", status_info.get(\"status\", \"unknown\"))\n530:             if status_info.get(\"agent_endpoint\"):\n531:                 table.add_row(\"Endpoint\", status_info[\"agent_endpoint\"])\n532:             if status_info.get(\"deployment_type\"):\n533:                 table.add_row(\"Deployment Type\", status_info[\"deployment_type\"])\n534:             if status_info.get(\"namespace\"):\n535:                 table.add_row(\"Namespace\", status_info[\"namespace\"])\n536:             \n537:             # Pod status (if available)\n538:             if \"pods\" in status_info:\n539:                 pod_info = status_info[\"pods\"]\n540:                 table.add_row(\n541:                     \"Pods\",\n542:                     f\"{pod_info.get('ready', 0)}/{pod_info.get('total', 0)} ready\"\n543:                 )\n544:             \n545:             # Replicas (for K8s deployment)\n546:             if status_info.get(\"replicas\") is not None:\n547:                 table.add_row(\"Replicas\", str(status_info[\"replicas\"]))\n548:             \n549:             # Session info (if available)\n550:             if status_info.get(\"session_id\"):\n551:                 table.add_row(\"Session ID\", status_info[\"session_id\"])\n552:             \n553:             console.print(table)\n554:             \n555:         except Exception as e:\n556:             progress.update(task, completed=True)\n557:             _handle_error(e, \"fetching status\", verbose)\n558: ```\n559: \n560: ### Runtime Layer (`agentcube/runtime/status_runtime.py`)\n561: \n562: **Class structure:**\n563: ```python\n564: import logging\n565: from pathlib import Path\n566: from typing import Any, Dict, Optional\n567: from agentcube.services.metadata_service import MetadataService\n568: from agentcube.services.k8s_provider import KubernetesProvider\n569: from agentcube.services.agentcube_provider import AgentCubeProvider\n570: \n571: class StatusRuntime:\n572:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n573:         self.verbose = verbose\n574:         self.provider = provider\n575:         self.metadata_service = MetadataService(verbose=verbose)\n576:         self.logger = logging.getLogger(__name__)\n577:     \n578:     def get_status(\n579:         self,\n580:         workspace_path: Path,\n581:         provider: Optional[str] = None\n582:     ) -> Dict[str, Any]:\n583:         \"\"\"Get comprehensive agent status.\"\"\"\n584:         if provider is None:\n585:             provider = self.provider\n586:         \n587:         # Load metadata\n588:         try:\n589:             metadata = self.metadata_service.load_metadata(workspace_path)\n590:         except FileNotFoundError:\n591:             return {\n592:                 \"status\": \"not_found\",\n593:                 \"error\": f\"Metadata not found at {workspace_path}\"\n594:             }\n595:         \n596:         # Check if published\n597:         if not metadata.agent_id:\n598:             return {\n599:                 \"status\": \"not_published\",\n600:                 \"agent_name\": metadata.agent_name\n601:             }\n602:         \n603:         # Build base status\n604:         status_info = {\n605:             \"agent_name\": metadata.agent_name,\n606:             \"agent_id\": metadata.agent_id,\n607:             \"session_id\": metadata.session_id,\n608:             \"deployment_type\": metadata.k8s_deployment.get(\"type\", \"unknown\") if metadata.k8s_deployment else \"unknown\",\n609:             \"namespace\": metadata.k8s_deployment.get(\"namespace\", \"default\") if metadata.k8s_deployment else \"default\",\n610:         }\n611:         \n612:         # Route to appropriate status getter\n613:         if metadata.k8s_deployment:\n614:             deployment_type = metadata.k8s_deployment.get(\"type\", \"unknown\")\n615:             if deployment_type == \"AgentRuntime\":\n616:                 cr_status = self._get_cr_k8s_status(metadata)\n617:                 status_info.update(cr_status)\n618:             elif deployment_type == \"Deployment\":\n619:                 k8s_status = self._get_k8s_status(metadata)\n620:                 status_info.update(k8s_status)\n621:             else:\n622:                 status_info[\"status\"] = \"unknown_deployment_type\"\n623:         else:\n624:             status_info[\"status\"] = \"unknown\"\n625:         \n626:         return status_info\n627:     \n628:     def _get_k8s_status(self, metadata) -> Dict[str, Any]:\n629:         \"\"\"Get status for standard K8s Deployment.\"\"\"\n630:         try:\n631:             k8s_provider = KubernetesProvider(\n632:                 namespace=metadata.k8s_deployment.get(\"namespace\", \"default\"),\n633:                 verbose=self.verbose\n634:             )\n635:             \n636:             deployment_name = metadata.k8s_deployment.get(\"deployment_name\")\n637:             if not deployment_name:\n638:                 return {\"status\": \"error\", \"error\": \"deployment_name not found in metadata\"}\n639:             \n640:             # Get deployment status\n641:             deployment_info = k8s_provider.get_agent_status(deployment_name)\n642:             \n643:             # Extract pod information\n644:             pods = deployment_info.get(\"pods\", [])\n645:             ready_pods = sum(1 for p in pods if p.get(\"ready\", False))\n646:             \n647:             return {\n648:                 \"status\": deployment_info.get(\"status\", \"unknown\"),\n649:                 \"agent_endpoint\": metadata.agent_endpoint,\n650:                 \"replicas\": deployment_info.get(\"replicas\", 1),\n651:                 \"pods\": {\n652:                     \"total\": len(pods),\n653:                     \"ready\": ready_pods,\n654:                     \"details\": pods\n655:                 }\n656:             }\n657:         except Exception as e:\n658:             self.logger.error(f\"Error getting K8s status: {e}\")\n659:             return {\n660:                 \"status\": \"error\",\n661:                 \"error\": str(e)\n662:             }\n663:     \n664:     def _get_cr_k8s_status(self, metadata) -> Dict[str, Any]:\n665:         \"\"\"Get status for AgentRuntime CR.\"\"\"\n666:         try:\n667:             agentcube_provider = AgentCubeProvider(\n668:                 namespace=metadata.k8s_deployment.get(\"namespace\", \"default\"),\n669:                 verbose=self.verbose\n670:             )\n671:             \n672:             agent_name = metadata.k8s_deployment.get(\"name\", metadata.agent_name)\n673:             \n674:             # Get AgentRuntime CR\n675:             cr_object = agentcube_provider.get_agent_runtime(\n676:                 name=agent_name,\n677:                 namespace=metadata.k8s_deployment.get(\"namespace\", \"default\")\n678:             )\n679:             \n680:             if cr_object is None:\n681:                 return {\n682:                     \"status\": \"not_found\",\n683:                     \"error\": f\"AgentRuntime '{agent_name}' not found in namespace '{metadata.k8s_deployment.get('namespace', 'default')}'\"\n684:                 }\n685:             \n686:             # Extract status from CR\n687:             cr_status = cr_object.get(\"status\", {})\n688:             status = cr_status.get(\"status\", \"created_no_status\")\n689:             endpoint = cr_status.get(\"agentEndpoint\", metadata.agent_endpoint)\n690:             \n691:             return {\n692:                 \"status\": status,\n693:                 \"agent_endpoint\": endpoint,\n694:                 \"session_id\": metadata.session_id,\n695:             }\n696:         except Exception as e:\n697:             self.logger.error(f\"Error getting CR status: {e}\")\n698:             return {\n699:                 \"status\": \"error\",\n700:                 \"error\": str(e)\n701:             }\n702: ```\n703: \n704: ### Status Response Schema\n705: \n706: ```python\n707: # Successful status response (AgentRuntime CR)\n708: {\n709:     \"agent_name\": \"hello-agent\",\n710:     \"agent_id\": \"agent-12345\",\n711:     \"session_id\": \"session-abcde\",\n712:     \"status\": \"ready\",  # ready, pending, error, not_found\n713:     \"agent_endpoint\": \"http://router.example.com/v1/...\",\n714:     \"deployment_type\": \"AgentRuntime\",\n715:     \"namespace\": \"default\"\n716: }\n717: \n718: # Successful status response (K8s Deployment)\n719: {\n720:     \"agent_name\": \"hello-agent\",\n721:     \"agent_id\": \"agent-12345\",\n722:     \"session_id\": \"session-abcde\",\n723:     \"status\": \"ready\",\n724:     \"agent_endpoint\": \"http://node:30080\",\n725:     \"deployment_type\": \"Deployment\",\n726:     \"namespace\": \"default\",\n727:     \"replicas\": 1,\n728:     \"pods\": {\n729:         \"total\": 1,\n730:         \"ready\": 1,\n731:         \"details\": [\n732:             {\"name\": \"hello-agent-xxx\", \"ready\": True, \"phase\": \"Running\"}\n733:         ]\n734:     }\n735: }\n736: \n737: # Not published response\n738: {\n739:     \"status\": \"not_published\",\n740:     \"agent_name\": \"hello-agent\"\n741: }\n742: \n743: # Error response\n744: {\n745:     \"status\": \"error\",\n746:     \"error\": \"Docker is not available\"\n747: }\n748: ```\n749: \n750: ### Error Handling\n751: \n752: | Error | Source | CLI Output | Exit Code |\n753: |-------|--------|------------|-----------|\n754: | Metadata not found | `MetadataService.load_metadata` | `[red]Error fetching status: Metadata not found at {path}[/red]` | 1 |\n755: | Agent not published | `get_status` check | `[yellow]⚠ Agent has not been published[/yellow]` + guidance | 1 |\n756: | CR not found | `_get_cr_k8s_status` | `[red]Error fetching status: AgentRuntime 'xxx' not found...[/red]` | 1 |\n757: | K8s API error | `KubernetesProvider` | `[red]Error fetching status: {error}[/red]` | 1 |\n758: | Status error | CR/Deployment status | `[red]✗ Status error: {error}[/red]` | 1 |\n759: \n760: ## `DockerService` (`agentcube/services/docker_service.py`)\n761: \n762: ```python\n763: class DockerService:\n764:     def __init__(self, verbose: bool = False) -> None: ...\n765:     def check_docker_available(self) -> bool: ...\n766:     def build_image(\n767:         self,\n768:         dockerfile_path: Path,\n769:         context_path: Path,\n770:         image_name: str,\n771:         tag: str = \"latest\",\n772:         build_args: Optional[Dict[str, str]] = None,\n773:     ) -> Dict[str, str]: ...\n774:     def get_image_info(self, image_name: str) -> Dict[str, str]: ...\n775:     def _get_image_info(self, image_name: str) -> Dict[str, str]: ...\n776:     def _format_size(self, size_bytes: int) -> str: ...\n777:     def push_image(\n778:         self,\n779:         image_name: str,\n780:         registry_url: Optional[str] = None,\n781:         username: Optional[str] = None,\n782:         password: Optional[str] = None,\n783:     ) -> Dict[str, str]: ...\n784:     def _docker_login_sdk(self, registry: Optional[str], username: str, password: str) -> None: ...\n785:     def _tag_image_sdk(self, source_image: str, target_image: str) -> None: ...\n786:     def remove_image(self, image_name: str) -> bool: ...\n787: ```\n788: \n789: ## `MetadataService` (`agentcube/services/metadata_service.py`)\n790: \n791: ```python\n792: class MetadataService:\n793:     def __init__(self, verbose: bool = False) -> None: ...\n794:     def load_metadata(self, workspace_path: Path) -> AgentMetadata: ...\n795:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None: ...\n796:     def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata: ...\n797:     def validate_workspace(self, workspace_path: Path) -> bool: ...\n798:     def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None: ...\n799:     def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None: ...\n800: ```\n801: \n802: ## `KubernetesProvider` (`agentcube/services/k8s_provider.py`)\n803: \n804: ```python\n805: class KubernetesProvider:\n806:     def __init__(\n807:         self,\n808:         namespace: str = \"default\",\n809:         verbose: bool = False,\n810:         kubeconfig: Optional[str] = None,\n811:     ) -> None: ...\n812:     def _ensure_namespace(self) -> None: ...\n813:     def deploy_agent(\n814:         self,\n815:         agent_name: str,\n816:         image_url: str,\n817:         port: int,\n818:         entrypoint: Optional[str] = None,\n819:         replicas: int = 1,\n820:         node_port: Optional[int] = None,\n821:         env_vars: Optional[Dict[str, str]] = None,\n822:     ) -> Dict[str, Any]: ...\n823:     def _create_deployment(\n824:         self,\n825:         name: str,\n826:         image_url: str,\n827:         port: int,\n828:         entrypoint: Optional[str],\n829:         replicas: int,\n830:         env_vars: Optional[Dict[str, str]],\n831:     ) -> Dict[str, Any]: ...\n832:     def _create_service(self, name: str, port: int, node_port: Optional[int]) -> Dict[str, Any]: ...\n833:     def wait_for_deployment_ready(self, name: str, timeout: int = 120) -> None: ...\n834:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]: ...\n835:     def delete_agent(self, agent_name: str) -> Dict[str, Any]: ...\n836:     def _sanitize_name(self, name: str) -> str: ...\n837: ```\n838: \n839: ## `AgentCubeProvider` (`agentcube/services/agentcube_provider.py`)\n840: \n841: ```python\n842: class AgentCubeProvider:\n843:     def __init__(\n844:         self,\n845:         namespace: str = \"default\",\n846:         verbose: bool = False,\n847:         kubeconfig: Optional[str] = None,\n848:     ) -> None: ...\n849:     def _ensure_namespace(self) -> None: ...\n850:     def deploy_agent_runtime(\n851:         self,\n852:         agent_name: str,\n853:         image_url: str,\n854:         port: int,\n855:         entrypoint: Optional[str] = None,\n856:         env_vars: Optional[Dict[str, str]] = None,\n857:         workload_manager_url: Optional[str] = None,\n858:         router_url: Optional[str] = None,\n859:         readiness_probe_path: Optional[str] = None,\n860:         readiness_probe_port: Optional[int] = None,\n861:     ) -> Dict[str, Any]: ...\n862:     def _sanitize_name(self, name: str) -> str: ...\n863:     def get_agent_runtime(self, name: str, namespace: str) -> Optional[Dict[str, Any]]: ...\n864: ```\n865: \n866: CR API: `group=\"runtime.agentcube.volcano.sh\"`, `version=\"v1alpha1\"`, `plural=\"agentruntimes\"`.\n867: \n868: ## `AgentMetadata` (Pydantic `BaseModel`)\n869: \n870: | Field | Type | Default | `Field(..., description=...)` |\n871: |-------|------|---------|--------------------------------|\n872: | `agent_name` | `str` | (required) | Unique name identifying the agent |\n873: | `description` | `Optional[str]` | `None` | Human-readable summary |\n874: | `language` | `str` | `\"python\"` | Programming language used |\n875: | `entrypoint` | `str` | (required) | Command to launch the agent |\n876: | `port` | `int` | `8080` | Port exposed by the agent runtime |\n877: | `build_mode` | `str` | `\"local\"` | Build strategy: local or cloud |\n878: | `region` | `Optional[str]` | `None` | Deployment region |\n879: | `version` | `Optional[str]` | `None` | Semantic version string for publishing |\n880: | `image` | `Optional[Dict[str, Any]]` | `None` | Container image information |\n881: | `auth` | `Optional[Dict[str, Any]]` | `None` | Authentication configuration |\n882: | `requirements_file` | `Optional[str]` | `\"requirements.txt\"` | Python dependency file |\n883: | `registry_url` | `Optional[str]` | `\"\"` | Registry URL for image publishing |\n884: | `registry_username` | `Optional[str]` | `\"\"` | Registry username |\n885: | `registry_password` | `Optional[str]` | `\"\"` | Registry password |\n886: | `agent_endpoint` | `Optional[str]` | `None` | Agent endpoint URL |\n887: | `workload_manager_url` | `Optional[str]` | `None` | URL for the Workload Manager |\n888: | `router_url` | `Optional[str]` | `None` | URL for the Router |\n889: | `readiness_probe_path` | `Optional[str]` | `None` | Path for the readiness probe |\n890: | `readiness_probe_port` | `Optional[int]` | `None` | Port for the readiness probe |\n891: | `agent_id` | `Optional[str]` | `None` | Agent ID assigned by AgentCube |\n892: | `session_id` | `Optional[str]` | `None` | The session ID for the agent |\n893: | `k8s_deployment` | `Optional[Dict[str, Any]]` | `None` | Kubernetes deployment information |\n894: \n895: Validators: `validate_language` → `['python','java']` lowercase; `validate_build_mode` → `['local','cloud']` lowercase; `validate_port` → `1..65535`.\n896: \n897: ## `MetadataOptions` (`agentcube/models/pack_models.py`)\n898: \n899: Dataclass fields (all `Optional` unless noted):\n900: \n901: | Field | Type | Default |\n902: |-------|------|---------|\n903: | `agent_name` | `Optional[str]` | `None` |\n904: | `language` | `Optional[str]` | `'python'` |\n905: | `entrypoint` | `Optional[str]` | `None` |\n906: | `port` | `Optional[int]` | `8080` |\n907: | `build_mode` | `Optional[str]` | `'local'` |\n908: | `requirements_file` | `Optional[str]` | `None` |\n909: | `description` | `Optional[str]` | `None` |\n910: | `workload_manager_url` | `Optional[str]` | `\"\"` |\n911: | `router_url` | `Optional[str]` | `\"\"` |\n912: | `readiness_probe_path` | `Optional[str]` | `\"\"` |\n913: | `readiness_probe_port` | `Optional[int]` | `8080` |\n914: | `registry_url` | `Optional[str]` | `\"\"` |\n915: | `registry_username` | `Optional[str]` | `\"\"` |\n916: | `registry_password` | `Optional[str]` | `\"\"` |\n917: | `agent_endpoint` | `Optional[str]` | `\"\"` |\n918: \n919: ```python\n920: @classmethod\n921: def from_options(cls, options: Dict[str, Any]) -> \"MetadataOptions\": ...\n922: ```\n923: \n924: ## Dependencies (`cmd/cli/pyproject.toml`)\n925: \n926: **`[project]` dependencies:**\n927: \n928: - `typer[all]>=0.9.0`\n929: - `pydantic>=2.0.0`\n930: - `pyyaml>=6.0`\n931: - `httpx>=0.24.0`\n932: - `docker>=6.0.0`\n933: - `rich>=13.0.0`\n934: - `packaging>=23.0`\n935: - `importlib-resources>=6.0.0`\n936: - `semver>=3.0.0`\n937: \n938: **Optional `[project.optional-dependencies]`:**\n939: \n940: - `k8s`: `kubernetes>=28.0.0`\n941: - `dev`: `pytest>=7.4.0`, `pytest-asyncio>=0.21.0`, `pytest-cov>=4.1.0`, `ruff>=0.1.0`, `mypy>=1.5.0`, `pre-commit>=3.3.0`, `kubernetes>=28.0.0`\n942: - `test`: `pytest>=7.4.0`, `pytest-asyncio>=0.21.0`, `pytest-cov>=4.1.0`, `pytest-mock>=3.11.0`, `httpx-mock>=0.10.0`\n943: \n944: **Python:** `requires-python = \">=3.10\"`.\n945: \n946: ## Top-level exports (`agentcube/__init__.py`)\n947: \n948: - `__version__ = \"0.1.0\"`\n949: - `__author__ = \"AgentCube Community\"`\n950: - `__email__ = \"agentcube@volcano.sh\"`\n951: - Imports: `app`, `PackRuntime`, `BuildRuntime`, `PublishRuntime`, `InvokeRuntime`\n952: - `__all__` = `[\"app\", \"PackRuntime\", \"BuildRuntime\", \"PublishRuntime\", \"InvokeRuntime\"]`  \n953:   (`StatusRuntime` is not exported here.)\n\n(End of file - total 953 lines)\n</content>","metadata":{"preview":"# AgentCube CLI (cli-toolkit) — Design\n\nSource root: `/tmp/agentcube-ref/cmd/cli/`.\n\n## Package layout (every module path and role)\n\n| Path | Role |\n|------|------|\n| `pyproject.toml` | Project metadata, dependencies, console script mapping |\n| `agentcube/__init__.py` | Package version `__version__`, exports `app`, runtimes |\n| `agentcube/cli/__init__.py` | CLI subpackage marker |\n| `agentcube/cli/main.py` | Typer `app`, all commands, `_handle_error`, `version_callback` |\n| `agentcube/models/pack_models.py` | `MetadataOptions` dataclass |\n| `agentcube/runtime/__init__.py` | Re-exports runtimes + `MetadataOptions` |\n| `agentcube/runtime/pack_runtime.py` | `PackRuntime` |\n| `agentcube/runtime/build_runtime.py` | `BuildRuntime` |\n| `agentcube/runtime/publish_runtime.py` | `PublishRuntime` |\n| `agentcube/runtime/invoke_runtime.py` | `InvokeRuntime` |\n| `agentcube/runtime/status_runtime.py` | `StatusRuntime` |\n| `agentcube/services/__init__.py` | Services package docstring |","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cli-toolkit/design.md","time":{"start":1775871152311,"end":1775871152330}}}}
{"type":"tool_use","timestamp":1775871152338,"sessionID":"ses_285d4e5d8ffeGvC3RFNaeyAxdb","part":{"id":"prt_d7a2b47250014yxq5b7xk5zN5d","messageID":"msg_d7a2b362c001fhwZrmQgK7VHzK","sessionID":"ses_285d4e5d8ffeGvC3RFNaeyAxdb","type":"tool","tool":"read","callID":"toolu_adb8565d52274683b1b019d9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/tests/test_docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/tests/test_docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for DockerService.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: from pathlib import Path\n7: from typing import Any, Dict\n8: from unittest.mock import MagicMock, Mock, patch\n9: \n10: import pytest\n11: from docker.errors import APIError, DockerException\n12: \n13: from agentcube.services.docker_service import DockerService\n14: \n15: \n16: @pytest.fixture\n17: def mock_docker_client() -> MagicMock:\n18:     \"\"\"Create a mock Docker client.\"\"\"\n19:     client = MagicMock()\n20:     client.images = MagicMock()\n21:     return client\n22: \n23: \n24: @pytest.fixture\n25: def docker_service(mock_docker_client: MagicMock) -> DockerService:\n26:     \"\"\"Create a DockerService instance with mocked client.\"\"\"\n27:     with patch(\"docker.from_env\", return_value=mock_docker_client):\n28:         service = DockerService(verbose=False)\n29:         return service\n30: \n31: \n32: @pytest.fixture\n33: def docker_service_verbose(mock_docker_client: MagicMock) -> DockerService:\n34:     \"\"\"Create a verbose DockerService instance.\"\"\"\n35:     with patch(\"docker.from_env\", return_value=mock_docker_client):\n36:         service = DockerService(verbose=True)\n37:         return service\n38: \n39: \n40: class TestDockerServiceInit:\n41:     \"\"\"Test DockerService initialization.\"\"\"\n42: \n43:     def test_init_creates_client(self) -> None:\n44:         \"\"\"Test that __init__ creates Docker client.\"\"\"\n45:         with patch(\"docker.from_env\") as mock_from_env:\n46:             service = DockerService()\n47:             mock_from_env.assert_called_once()\n48:             assert service._client is not None\n49: \n50:     def test_init_handles_docker_unavailable(self) -> None:\n51:         \"\"\"Test that __init__ handles Docker being unavailable.\"\"\"\n52:         with patch(\"docker.from_env\") as mock_from_env:\n53:             mock_from_env.side_effect = DockerException(\"Docker not running\")\n54:             service = DockerService()\n55:             assert service._client is None\n56: \n57:     def test_init_verbose_sets_logging(self) -> None:\n58:         \"\"\"Test that verbose mode enables debug logging.\"\"\"\n59:         with patch(\"docker.from_env\"), patch(\"logging.basicConfig\") as mock_config:\n60:             DockerService(verbose=True)\n61:             mock_config.assert_called_with(level=logging.DEBUG)\n62: \n63:     def test_init_non_verbose_no_logging_config(self) -> None:\n64:         \"\"\"Test that non-verbose mode doesn't configure logging.\"\"\"\n65:         with patch(\"docker.from_env\"), patch(\"logging.basicConfig\") as mock_config:\n66:             DockerService(verbose=False)\n67:             mock_config.assert_not_called()\n68: \n69: \n70: class TestCheckDockerAvailable:\n71:     \"\"\"Test Docker availability checking.\"\"\"\n72: \n73:     def test_available_when_docker_running(\n74:         self, docker_service: DockerService, mock_docker_client: MagicMock\n75:     ) -> None:\n76:         \"\"\"Test returns True when Docker is available.\"\"\"\n77:         mock_docker_client.ping.return_value = True\n78:         assert docker_service.check_docker_available() is True\n79: \n80:     def test_unavailable_when_client_none(self) -> None:\n81:         \"\"\"Test returns False when client is None.\"\"\"\n82:         service = DockerService()\n83:         service._client = None\n84:         assert service.check_docker_available() is False\n85: \n86:     def test_unavailable_when_ping_fails(\n87:         self, docker_service: DockerService, mock_docker_client: MagicMock\n88:     ) -> None:\n89:         \"\"\"Test returns False when ping raises exception.\"\"\"\n90:         mock_docker_client.ping.side_effect = DockerException(\"Not running\")\n91:         assert docker_service.check_docker_available() is False\n92: \n93:     def test_unavailable_when_api_error(\n94:         self, docker_service: DockerService, mock_docker_client: MagicMock\n95:     ) -> None:\n96:         \"\"\"Test returns False when ping raises APIError.\"\"\"\n97:         mock_docker_client.ping.side_effect = APIError(\"Connection refused\")\n98:         assert docker_service.check_docker_available() is False\n99: \n100: \n101: class TestBuildImage:\n102:     \"\"\"Test image building.\"\"\"\n103: \n104:     def test_build_success(\n105:         self,\n106:         docker_service: DockerService,\n107:         mock_docker_client: MagicMock,\n108:         tmp_path: Path,\n109:     ) -> None:\n110:         \"\"\"Test successful image build.\"\"\"\n111:         dockerfile = tmp_path / \"Dockerfile\"\n112:         dockerfile.write_text(\"FROM alpine:latest\\n\")\n113: \n114:         mock_image = MagicMock()\n115:         mock_image.attrs = {\n116:             \"Id\": \"sha256:abc123def456789012345678901234567890\",\n117:             \"Size\": 125000000,\n118:         }\n119: \n120:         mock_docker_client.images.build.return_value = (mock_image, [])\n121:         mock_docker_client.images.get.return_value = mock_image\n122: \n123:         result = docker_service.build_image(\n124:             dockerfile_path=dockerfile,\n125:             context_path=tmp_path,\n126:             image_name=\"test-image\",\n127:             tag=\"latest\",\n128:         )\n129: \n130:         assert result[\"image_name\"] == \"test-image:latest\"\n131:         assert \"image_id\" in result\n132:         assert \"image_size\" in result\n133:         assert \"build_time\" in result\n134:         assert result[\"image_id\"] == \"abc123def456\"\n135: \n136:     def test_build_raises_when_docker_unavailable(\n137:         self, docker_service: DockerService, tmp_path: Path\n138:     ) -> None:\n139:         \"\"\"Test build raises RuntimeError when Docker unavailable.\"\"\"\n140:         dockerfile = tmp_path / \"Dockerfile\"\n141:         dockerfile.write_text(\"FROM alpine\\n\")\n142: \n143:         with patch.object(docker_service, \"check_docker_available\", return_value=False):\n144:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n145:                 docker_service.build_image(\n146:                     dockerfile_path=dockerfile,\n147:                     context_path=tmp_path,\n148:                     image_name=\"test\",\n149:                 )\n150: \n151:     def test_build_with_args(\n152:         self,\n153:         docker_service: DockerService,\n154:         mock_docker_client: MagicMock,\n155:         tmp_path: Path,\n156:     ) -> None:\n157:         \"\"\"Test build passes build arguments.\"\"\"\n158:         dockerfile = tmp_path / \"Dockerfile\"\n159:         dockerfile.write_text(\"FROM alpine\\n\")\n160: \n161:         mock_image = MagicMock()\n162:         mock_image.attrs = {\"Id\": \"sha256:abc123\", \"Size\": 100}\n163: \n164:         mock_docker_client.images.build.return_value = (mock_image, [])\n165:         mock_docker_client.images.get.return_value = mock_image\n166: \n167:         docker_service.build_image(\n168:             dockerfile_path=dockerfile,\n169:             context_path=tmp_path,\n170:             image_name=\"test\",\n171:             build_args={\"ARG1\": \"value1\", \"ARG2\": \"value2\"},\n172:         )\n173: \n174:         call_args = mock_docker_client.images.build.call_args\n175:         assert call_args[1][\"buildargs\"] == {\"ARG1\": \"value1\", \"ARG2\": \"value2\"}\n176: \n177:     def test_build_with_custom_tag(\n178:         self,\n179:         docker_service: DockerService,\n180:         mock_docker_client: MagicMock,\n181:         tmp_path: Path,\n182:     ) -> None:\n183:         \"\"\"Test build uses custom tag.\"\"\"\n184:         dockerfile = tmp_path / \"Dockerfile\"\n185:         dockerfile.write_text(\"FROM alpine\\n\")\n186: \n187:         mock_image = MagicMock()\n188:         mock_image.attrs = {\"Id\": \"sha256:abc123\", \"Size\": 100}\n189: \n190:         mock_docker_client.images.build.return_value = (mock_image, [])\n191:         mock_docker_client.images.get.return_value = mock_image\n192: \n193:         result = docker_service.build_image(\n194:             dockerfile_path=dockerfile,\n195:             context_path=tmp_path,\n196:             image_name=\"my-agent\",\n197:             tag=\"v1.0.0\",\n198:         )\n199: \n200:         assert result[\"image_name\"] == \"my-agent:v1.0.0\"\n201: \n202:     def test_build_handles_api_error(\n203:         self,\n204:         docker_service: DockerService,\n205:         mock_docker_client: MagicMock,\n206:         tmp_path: Path,\n207:     ) -> None:\n208:         \"\"\"Test build handles APIError.\"\"\"\n209:         dockerfile = tmp_path / \"Dockerfile\"\n210:         dockerfile.write_text(\"FROM alpine\\n\")\n211: \n212:         mock_docker_client.images.build.side_effect = APIError(\"Build failed\")\n213: \n214:         with pytest.raises(RuntimeError, match=\"Failed to build Docker image\"):\n215:             docker_service.build_image(\n216:                 dockerfile_path=dockerfile,\n217:                 context_path=tmp_path,\n218:                 image_name=\"test\",\n219:             )\n220: \n221:     def test_build_handles_docker_exception(\n222:         self,\n223:         docker_service: DockerService,\n224:         mock_docker_client: MagicMock,\n225:         tmp_path: Path,\n226:     ) -> None:\n227:         \"\"\"Test build handles DockerException.\"\"\"\n228:         dockerfile = tmp_path / \"Dockerfile\"\n229:         dockerfile.write_text(\"FROM alpine\\n\")\n230: \n231:         mock_docker_client.images.build.side_effect = DockerException(\"Daemon error\")\n232: \n233:         with pytest.raises(RuntimeError, match=\"Failed to build Docker image\"):\n234:             docker_service.build_image(\n235:                 dockerfile_path=dockerfile,\n236:                 context_path=tmp_path,\n237:                 image_name=\"test\",\n238:             )\n239: \n240:     def test_build_tracks_build_time(\n241:         self,\n242:         docker_service: DockerService,\n243:         mock_docker_client: MagicMock,\n244:         tmp_path: Path,\n245:     ) -> None:\n246:         \"\"\"Test build tracks and returns build time.\"\"\"\n247:         dockerfile = tmp_path / \"Dockerfile\"\n248:         dockerfile.write_text(\"FROM alpine\\n\")\n249: \n250:         mock_image = MagicMock()\n251:         mock_image.attrs = {\"Id\": \"sha256:abc123\", \"Size\": 100}\n252: \n253:         mock_docker_client.images.build.return_value = (mock_image, [])\n254:         mock_docker_client.images.get.return_value = mock_image\n255: \n256:         result = docker_service.build_image(\n257:             dockerfile_path=dockerfile,\n258:             context_path=tmp_path,\n259:             image_name=\"test\",\n260:         )\n261: \n262:         assert \"build_time\" in result\n263:         assert result[\"build_time\"].endswith(\"s\")\n264:         build_time_value = float(result[\"build_time\"].rstrip(\"s\"))\n265:         assert build_time_value >= 0\n266: \n267: \n268: class TestGetImageInfo:\n269:     \"\"\"Test image info retrieval.\"\"\"\n270: \n271:     def test_get_info_success(\n272:         self, docker_service: DockerService, mock_docker_client: MagicMock\n273:     ) -> None:\n274:         \"\"\"Test successful image info retrieval.\"\"\"\n275:         mock_image = MagicMock()\n276:         mock_image.attrs = {\n277:             \"Id\": \"sha256:abcdef123456789012345678901234567890\",\n278:             \"Size\": 256000000,\n279:         }\n280: \n281:         mock_docker_client.images.get.return_value = mock_image\n282: \n283:         result = docker_service.get_image_info(\"test-image:latest\")\n284: \n285:         assert result[\"image_name\"] == \"test-image:latest\"\n286:         assert result[\"image_id\"] == \"abcdef123456\"\n287:         assert result[\"image_size\"] == \"244.14 MB\"\n288:         assert result[\"size_bytes\"] == \"256000000\"\n289: \n290:     def test_get_info_not_found(\n291:         self, docker_service: DockerService, mock_docker_client: MagicMock\n292:     ) -> None:\n293:         \"\"\"Test returns empty dict when image not found.\"\"\"\n294:         mock_docker_client.images.get.side_effect = DockerException(\"Not found\")\n295:         result = docker_service.get_image_info(\"nonexistent\")\n296:         assert result == {}\n297: \n298:     def test_get_info_api_error(\n299:         self, docker_service: DockerService, mock_docker_client: MagicMock\n300:     ) -> None:\n301:         \"\"\"Test returns empty dict on APIError.\"\"\"\n302:         mock_docker_client.images.get.side_effect = APIError(\"Not found\")\n303:         result = docker_service.get_image_info(\"nonexistent\")\n304:         assert result == {}\n305: \n306:     def test_get_info_key_error(\n307:         self, docker_service: DockerService, mock_docker_client: MagicMock\n308:     ) -> None:\n309:         \"\"\"Test returns empty dict on KeyError.\"\"\"\n310:         mock_image = MagicMock()\n311:         mock_image.attrs = {}\n312: \n313:         mock_docker_client.images.get.return_value = mock_image\n314:         result = docker_service.get_image_info(\"test\")\n315:         assert result == {}\n316: \n317: \n318: class TestFormatSize:\n319:     \"\"\"Test size formatting.\"\"\"\n320: \n321:     def test_format_bytes(self, docker_service: DockerService) -> None:\n322:         \"\"\"Test formatting bytes.\"\"\"\n323:         assert docker_service._format_size(500) == \"500.00 B\"\n324: \n325:     def test_format_kb(self, docker_service: DockerService) -> None:\n326:         \"\"\"Test formatting kilobytes.\"\"\"\n327:         assert docker_service._format_size(1024) == \"1.00 KB\"\n328: \n329:     def test_format_mb(self, docker_service: DockerService) -> None:\n330:         \"\"\"Test formatting megabytes.\"\"\"\n331:         assert docker_service._format_size(1048576) == \"1.00 MB\"\n332: \n333:     def test_format_gb(self, docker_service: DockerService) -> None:\n334:         \"\"\"Test formatting gigabytes.\"\"\"\n335:         assert docker_service._format_size(1073741824) == \"1.00 GB\"\n336: \n337:     def test_format_tb(self, docker_service: DockerService) -> None:\n338:         \"\"\"Test formatting terabytes.\"\"\"\n339:         assert docker_service._format_size(1099511627776) == \"1.00 TB\"\n340: \n341:     def test_format_zero(self, docker_service: DockerService) -> None:\n342:         \"\"\"Test formatting zero bytes.\"\"\"\n343:         assert docker_service._format_size(0) == \"0.00 B\"\n344: \n345:     def test_format_large_mb(self, docker_service: DockerService) -> None:\n346:         \"\"\"Test formatting large MB value.\"\"\"\n347:         assert docker_service._format_size(125000000) == \"119.21 MB\"\n348: \n349: \n350: class TestPushImage:\n351:     \"\"\"Test image pushing.\"\"\"\n352: \n353:     def test_push_success(\n354:         self, docker_service: DockerService, mock_docker_client: MagicMock\n355:     ) -> None:\n356:         \"\"\"Test successful image push.\"\"\"\n357:         mock_logs = iter([\n358:             {\"status\": \"Pushing layer abc123\"},\n359:             {\"status\": \"Pushed\", \"id\": \"abc123\"},\n360:         ])\n361: \n362:         mock_docker_client.images.push.return_value = mock_logs\n363: \n364:         result = docker_service.push_image(\"test-image:latest\")\n365: \n366:         assert result[\"pushed_image\"] == \"test-image:latest\"\n367:         assert \"push_time\" in result\n368:         assert result[\"push_time\"].endswith(\"s\")\n369: \n370:     def test_push_with_registry(\n371:         self, docker_service: DockerService, mock_docker_client: MagicMock\n372:     ) -> None:\n373:         \"\"\"Test push with registry URL tags image correctly.\"\"\"\n374:         mock_logs = iter([{\"status\": \"Pushed\"}])\n375:         mock_image = MagicMock()\n376: \n377:         mock_docker_client.images.push.return_value = mock_logs\n378:         mock_docker_client.images.get.return_value = mock_image\n379: \n380:         docker_service.push_image(\n381:             \"test-image:latest\",\n382:             registry_url=\"registry.example.com\",\n383:         )\n384: \n385:         mock_docker_client.images.get.assert_called()\n386:         mock_image.tag.assert_called()\n387: \n388:     def test_push_with_credentials(\n389:         self, docker_service: DockerService, mock_docker_client: MagicMock\n390:     ) -> None:\n391:         \"\"\"Test push with credentials logs in first.\"\"\"\n392:         mock_logs = iter([{\"status\": \"Pushed\"}])\n393: \n394:         mock_docker_client.images.push.return_value = mock_logs\n395: \n396:         docker_service.push_image(\n397:             \"test-image:latest\",\n398:             username=\"user123\",\n399:             password=\"pass456\",\n400:         )\n401: \n402:         mock_docker_client.login.assert_called_once()\n403: \n404:     def test_push_raises_when_docker_unavailable(\n405:         self, docker_service: DockerService\n406:     ) -> None:\n407:         \"\"\"Test push raises RuntimeError when Docker unavailable.\"\"\"\n408:         with patch.object(docker_service, \"check_docker_available\", return_value=False):\n409:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n410:                 docker_service.push_image(\"test-image\")\n411: \n412:     def test_push_handles_error_in_logs(\n413:         self, docker_service: DockerService, mock_docker_client: MagicMock\n414:     ) -> None:\n415:         \"\"\"Test push raises error when error found in logs.\"\"\"\n416:         mock_logs = iter([\n417:             {\"status\": \"Pushing\"},\n418:             {\"error\": \"unauthorized: authentication required\"},\n419:         ])\n420: \n421:         mock_docker_client.images.push.return_value = mock_logs\n422: \n423:         with pytest.raises(RuntimeError, match=\"Failed to push image\"):\n424:             docker_service.push_image(\"test-image\")\n425: \n426:     def test_push_with_registry_and_credentials(\n427:         self, docker_service: DockerService, mock_docker_client: MagicMock\n428:     ) -> None:\n429:         \"\"\"Test push with both registry and credentials.\"\"\"\n430:         mock_logs = iter([{\"status\": \"Pushed\"}])\n431:         mock_image = MagicMock()\n432: \n433:         mock_docker_client.images.push.return_value = mock_logs\n434:         mock_docker_client.images.get.return_value = mock_image\n435: \n436:         result = docker_service.push_image(\n437:             \"my-agent:v1.0.0\",\n438:             registry_url=\"registry.example.com\",\n439:             username=\"user\",\n440:             password=\"pass\",\n441:         )\n442: \n443:         assert result[\"pushed_image\"] == \"registry.example.com/my-agent:v1.0.0\"\n444:         mock_docker_client.login.assert_called_once()\n445: \n446:     def test_push_handles_api_error(\n447:         self, docker_service: DockerService, mock_docker_client: MagicMock\n448:     ) -> None:\n449:         \"\"\"Test push handles APIError.\"\"\"\n450:         mock_docker_client.images.push.side_effect = APIError(\"Push failed\")\n451: \n452:         with pytest.raises(RuntimeError, match=\"Failed to push Docker image\"):\n453:             docker_service.push_image(\"test-image\")\n454: \n455: \n456: class TestDockerLogin:\n457:     \"\"\"Test Docker registry login.\"\"\"\n458: \n459:     def test_login_success(\n460:         self, docker_service: DockerService, mock_docker_client: MagicMock\n461:     ) -> None:\n462:         \"\"\"Test successful registry login.\"\"\"\n463:         docker_service._docker_login_sdk(\n464:             registry=\"registry.example.com\",\n465:             username=\"user\",\n466:             password=\"pass\",\n467:         )\n468:         mock_docker_client.login.assert_called_once_with(\n469:             username=\"user\",\n470:             password=\"pass\",\n471:             registry=\"registry.example.com\",\n472:         )\n473: \n474:     def test_login_default_registry(\n475:         self, docker_service: DockerService, mock_docker_client: MagicMock\n476:     ) -> None:\n477:         \"\"\"Test login uses Docker Hub when no registry specified.\"\"\"\n478:         docker_service._docker_login_sdk(\n479:             registry=None,\n480:             username=\"user\",\n481:             password=\"pass\",\n482:         )\n483:         mock_docker_client.login.assert_called_once_with(\n484:             username=\"user\",\n485:             password=\"pass\",\n486:             registry=\"https://index.docker.io/v1/\",\n487:         )\n488: \n489:     def test_login_raises_on_api_error(\n490:         self, docker_service: DockerService, mock_docker_client: MagicMock\n491:     ) -> None:\n492:         \"\"\"Test login raises RuntimeError on APIError.\"\"\"\n493:         mock_docker_client.login.side_effect = APIError(\"Authentication failed\")\n494: \n495:         with pytest.raises(RuntimeError, match=\"Failed to log in\"):\n496:             docker_service._docker_login_sdk(\n497:                 registry=\"registry.example.com\",\n498:                 username=\"user\",\n499:                 password=\"wrong\",\n500:             )\n501: \n502:     def test_login_raises_on_docker_exception(\n503:         self, docker_service: DockerService, mock_docker_client: MagicMock\n504:     ) -> None:\n505:         \"\"\"Test login raises RuntimeError on DockerException.\"\"\"\n506:         mock_docker_client.login.side_effect = DockerException(\"Connection refused\")\n507: \n508:         with pytest.raises(RuntimeError, match=\"Failed to log in\"):\n509:             docker_service._docker_login_sdk(\n510:                 registry=\"registry.example.com\",\n511:                 username=\"user\",\n512:                 password=\"pass\",\n513:             )\n514: \n515: \n516: class TestTagImage:\n517:     \"\"\"Test image tagging.\"\"\"\n518: \n519:     def test_tag_success(\n520:         self, docker_service: DockerService, mock_docker_client: MagicMock\n521:     ) -> None:\n522:         \"\"\"Test successful image tag.\"\"\"\n523:         mock_image = MagicMock()\n524: \n525:         mock_docker_client.images.get.return_value = mock_image\n526: \n527:         docker_service._tag_image_sdk(\"source:latest\", \"target:latest\")\n528: \n529:         mock_image.tag.assert_called_once_with(\"target:latest\", force=True)\n530: \n531:     def test_tag_raises_on_api_error(\n532:         self, docker_service: DockerService, mock_docker_client: MagicMock\n533:     ) -> None:\n534:         \"\"\"Test tag raises RuntimeError on APIError.\"\"\"\n535:         mock_docker_client.images.get.side_effect = APIError(\"Not found\")\n536: \n537:         with pytest.raises(RuntimeError, match=\"Failed to tag Docker image\"):\n538:             docker_service._tag_image_sdk(\"source:latest\", \"target:latest\")\n539: \n540:     def test_tag_raises_on_docker_exception(\n541:         self, docker_service: DockerService, mock_docker_client: MagicMock\n542:     ) -> None:\n543:         \"\"\"Test tag raises RuntimeError on DockerException.\"\"\"\n544:         mock_docker_client.images.get.side_effect = DockerException(\"Error\")\n545: \n546:         with pytest.raises(RuntimeError, match=\"Failed to tag Docker image\"):\n547:             docker_service._tag_image_sdk(\"source:latest\", \"target:latest\")\n548: \n549: \n550: class TestRemoveImage:\n551:     \"\"\"Test image removal.\"\"\"\n552: \n553:     def test_remove_success(\n554:         self, docker_service: DockerService, mock_docker_client: MagicMock\n555:     ) -> None:\n556:         \"\"\"Test successful image removal.\"\"\"\n557:         result = docker_service.remove_image(\"test-image\")\n558:         assert result is True\n559:         mock_docker_client.images.remove.assert_called_once_with(\n560:             \"test-image\", force=True\n561:         )\n562: \n563:     def test_remove_failure_returns_false(\n564:         self, docker_service: DockerService, mock_docker_client: MagicMock\n565:     ) -> None:\n566:         \"\"\"Test removal returns False on failure.\"\"\"\n567:         mock_docker_client.images.remove.side_effect = DockerException(\"Cannot remove\")\n568:         result = docker_service.remove_image(\"test-image\")\n569:         assert result is False\n570: \n571:     def test_remove_failure_api_error(\n572:         self, docker_service: DockerService, mock_docker_client: MagicMock\n573:     ) -> None:\n574:         \"\"\"Test removal returns False on APIError.\"\"\"\n575:         mock_docker_client.images.remove.side_effect = APIError(\"In use\")\n576:         result = docker_service.remove_image(\"test-image\")\n577:         assert result is False\n578: \n579: \n580: class TestClientProperty:\n581:     \"\"\"Test Docker client property.\"\"\"\n582: \n583:     def test_client_returns_existing_client(\n584:         self, docker_service: DockerService, mock_docker_client: MagicMock\n585:     ) -> None:\n586:         \"\"\"Test client property returns existing client.\"\"\"\n587:         assert docker_service.client is mock_docker_client\n588: \n589:     def test_client_creates_new_client_when_none(self) -> None:\n590:         \"\"\"Test client property creates new client when None.\"\"\"\n591:         service = DockerService()\n592:         service._client = None\n593: \n594:         with patch(\"docker.from_env\") as mock_from_env:\n595:             mock_client = MagicMock()\n596:             mock_from_env.return_value = mock_client\n597: \n598:             result = service.client\n599:             assert result is mock_client\n600:             mock_from_env.assert_called_once()\n601: \n602:     def test_client_raises_when_docker_unavailable(self) -> None:\n603:         \"\"\"Test client property raises RuntimeError when Docker unavailable.\"\"\"\n604:         service = DockerService()\n605:         service._client = None\n606: \n607:         with patch(\"docker.from_env\") as mock_from_env:\n608:             mock_from_env.side_effect = DockerException(\"Not running\")\n609: \n610:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n611:                 _ = service.client\n612: \n613: \n614: class TestIntegrationPatterns:\n615:     \"\"\"Integration test patterns for DockerService.\"\"\"\n616: \n617:     def test_build_and_push_workflow(\n618:         self,\n619:         docker_service: DockerService,\n620:         mock_docker_client: MagicMock,\n621:         tmp_path: Path,\n622:     ) -> None:\n623:         \"\"\"Test typical build-then-push workflow.\"\"\"\n624:         dockerfile = tmp_path / \"Dockerfile\"\n625:         dockerfile.write_text(\"FROM alpine:latest\\n\")\n626: \n627:         mock_image = MagicMock()\n628:         mock_image.attrs = {\"Id\": \"sha256:build123\", \"Size\": 100000}\n629: \n630:         mock_docker_client.images.build.return_value = (mock_image, [])\n631:         mock_docker_client.images.get.return_value = mock_image\n632: \n633:         build_result = docker_service.build_image(\n634:             dockerfile_path=dockerfile,\n635:             context_path=tmp_path,\n636:             image_name=\"my-agent\",\n637:             tag=\"v1.0.0\",\n638:         )\n639: \n640:         assert \"my-agent:v1.0.0\" == build_result[\"image_name\"]\n641: \n642:         mock_docker_client.images.push.return_value = iter([{\"status\": \"Pushed\"}])\n643: \n644:         push_result = docker_service.push_image(\n645:             \"my-agent:v1.0.0\",\n646:             registry_url=\"registry.example.com\",\n647:             username=\"user\",\n648:             password=\"pass\",\n649:         )\n650: \n651:         assert \"registry.example.com/my-agent:v1.0.0\" == push_result[\"pushed_image\"]\n652: \n653:     def test_get_info_then_remove(\n654:         self, docker_service: DockerService, mock_docker_client: MagicMock\n655:     ) -> None:\n656:         \"\"\"Test getting image info then removing it.\"\"\"\n657:         mock_image = MagicMock()\n658:         mock_image.attrs = {\n659:             \"Id\": \"sha256:abc123\",\n660:             \"Size\": 50000,\n661:         }\n662: \n663:         mock_docker_client.images.get.return_value = mock_image\n664: \n665:         info = docker_service.get_image_info(\"temp-image:latest\")\n666:         assert info[\"image_name\"] == \"temp-image:latest\"\n667: \n668:         result = docker_service.remove_image(\"temp-image:latest\")\n669:         assert result is True\n670: \n671:     def test_build_with_none_build_args(\n672:         self,\n673:         docker_service: DockerService,\n674:         mock_docker_client: MagicMock,\n675:         tmp_path: Path,\n676:     ) -> None:\n677:         \"\"\"Test build with None build_args uses empty dict.\"\"\"\n678:         dockerfile = tmp_path / \"Dockerfile\"\n679:         dockerfile.write_text(\"FROM alpine\\n\")\n680: \n681:         mock_image = MagicMock()\n682:         mock_image.attrs = {\"Id\": \"sha256:abc123\", \"Size\": 100}\n683: \n684:         mock_docker_client.images.build.return_value = (mock_image, [])\n685:         mock_docker_client.images.get.return_value = mock_image\n686: \n687:         docker_service.build_image(\n688:             dockerfile_path=dockerfile,\n689:             context_path=tmp_path,\n690:             image_name=\"test\",\n691:             build_args=None,\n692:         )\n693: \n694:         call_args = mock_docker_client.images.build.call_args\n695:         assert call_args[1][\"buildargs\"] == {}\n\n(End of file - total 695 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for DockerService.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict\nfrom unittest.mock import MagicMock, Mock, patch\n\nimport pytest\nfrom docker.errors import APIError, DockerException\n\nfrom agentcube.services.docker_service import DockerService\n\n\n@pytest.fixture\ndef mock_docker_client() -> MagicMock:\n    \"\"\"Create a mock Docker client.\"\"\"\n    client = MagicMock()\n    client.images = MagicMock()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/tests/test_docker_service.py","time":{"start":1775871152309,"end":1775871152336}}}}
{"type":"tool_use","timestamp":1775871152360,"sessionID":"ses_285d4e5d8ffeGvC3RFNaeyAxdb","part":{"id":"prt_d7a2b4193001c5BCNeonHR9U2U","messageID":"msg_d7a2b362c001fhwZrmQgK7VHzK","sessionID":"ses_285d4e5d8ffeGvC3RFNaeyAxdb","type":"tool","tool":"read","callID":"toolu_44cfd9ae88684241a2a0e223","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Service for Docker operations.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: import time\n7: from pathlib import Path\n8: from typing import Any, Dict, Optional\n9: \n10: import docker\n11: from docker.errors import APIError, DockerException\n12: \n13: logger = logging.getLogger(__name__)\n14: \n15: \n16: class DockerService:\n17:     \"\"\"Service for Docker operations including build, push, and image management.\n18:     \n19:     This class provides a unified interface for Docker operations:\n20:     - Building images from Dockerfiles\n21:     - Pushing images to registries with authentication\n22:     - Getting image information and metadata\n23:     - Tagging and removing images\n24:     - Checking Docker daemon availability\n25:     \n26:     Attributes:\n27:         verbose: Enable verbose logging if True\n28:         \n29:     Example:\n30:         >>> from agentcube.services.docker_service import DockerService\n31:         >>> docker = DockerService(verbose=True)\n32:         >>> if docker.check_docker_available():\n33:         ...     result = docker.build_image(\n34:         ...         dockerfile_path=Path(\"Dockerfile\"),\n35:         ...         context_path=Path(\".\"),\n36:         ...         image_name=\"my-agent\",\n37:         ...         tag=\"v1.0.0\"\n38:         ...     )\n39:         >>> print(result[\"image_id\"])\n40:     \"\"\"\n41: \n42:     def __init__(self, verbose: bool = False) -> None:\n43:         \"\"\"Initialize the Docker service.\n44:         \n45:         Args:\n46:             verbose: Enable verbose logging if True. When enabled, detailed\n47:                 operation logs are written to stderr for debugging purposes.\n48:                 \n49:         Raises:\n50:             ImportError: If docker package is not installed\n51:             \n52:         Example:\n53:             >>> # Basic initialization\n54:             >>> docker = DockerService()\n55:             >>> \n56:             >>> # Verbose mode for debugging\n57:             >>> docker_verbose = DockerService(verbose=True)\n58:         \"\"\"\n59:         self.verbose = verbose\n60:         self._client: Optional[docker.DockerClient] = None\n61:         \n62:         if verbose:\n63:             logging.basicConfig(level=logging.DEBUG)\n64:         \n65:         try:\n66:             self._client = docker.from_env()\n67:             logger.debug(\"Docker client initialized successfully\")\n68:         except DockerException as e:\n69:             logger.warning(f\"Docker daemon not available: {e}\")\n70:             self._client = None\n71: \n72:     @property\n73:     def client(self) -> docker.DockerClient:\n74:         \"\"\"Get or create Docker client.\n75:         \n76:         Returns:\n77:             Docker client instance for interacting with Docker daemon\n78:             \n79:         Raises:\n80:             RuntimeError: If Docker is not available (daemon not running,\n81:                 Docker not installed, or connection refused)\n82:                 \n83:         Example:\n84:             >>> docker = DockerService()\n85:             >>> client = docker.client  # Creates client if not exists\n86:             >>> version = client.version()\n87:         \"\"\"\n88:         if self._client is None:\n89:             try:\n90:                 self._client = docker.from_env()\n91:             except DockerException as e:\n92:                 raise RuntimeError(f\"Docker is not available: {e}\") from e\n93:         return self._client\n94: \n95:     def check_docker_available(self) -> bool:\n96:         \"\"\"Check if Docker daemon is available and running.\n97:         \n98:         This method performs a non-intrusive ping test to verify that the\n99:         Docker daemon is accessible. It returns False gracefully if Docker\n100:         is not installed, not running, or not accessible due to permissions.\n101:         \n102:         Returns:\n103:             True if Docker daemon is available and responding, False otherwise.\n104:             False indicates that Docker operations will fail.\n105:             \n106:         Example:\n107:             >>> docker = DockerService()\n108:             >>> if docker.check_docker_available():\n109:             ...     print(\"Docker is ready\")\n110:             ... else:\n111:             ...     print(\"Please start Docker daemon\")\n112:         \"\"\"\n113:         if self._client is None:\n114:             logger.debug(\"Docker client not initialized\")\n115:             return False\n116:         \n117:         try:\n118:             self._client.ping()\n119:             logger.debug(\"Docker daemon is available\")\n120:             return True\n121:         except (DockerException, APIError) as e:\n122:             logger.debug(f\"Docker daemon not available: {e}\")\n123:             return False\n124: \n125:     def build_image(\n126:         self,\n127:         dockerfile_path: Path,\n128:         context_path: Path,\n129:         image_name: str,\n130:         tag: str = \"latest\",\n131:         build_args: Optional[Dict[str, str]] = None,\n132:     ) -> Dict[str, str]:\n133:         \"\"\"Build a Docker image from a Dockerfile.\n134:         \n135:         This method builds a Docker image using the specified Dockerfile and\n136:         build context. It supports custom build arguments and tracks build\n137:         time for performance monitoring. The built image can be used locally\n138:         or pushed to a registry.\n139:         \n140:         Args:\n141:             dockerfile_path: Path to the Dockerfile. Must be a valid file\n142:                 that exists and contains valid Dockerfile syntax.\n143:             context_path: Path to the build context directory. All files\n144:                 referenced in the Dockerfile (COPY, ADD) must be under this\n145:                 directory.\n146:             image_name: Name for the built image (e.g., \"my-agent\",\n147:                 \"registry.example.com/my-agent\").\n148:             tag: Image tag (default: \"latest\"). Common tags include version\n149:                 numbers (\"v1.0.0\"), environment names (\"dev\", \"prod\"), or\n150:                 git commits (\"abc123\").\n151:             build_args: Optional dictionary of build arguments to pass to\n152:                 the Docker build process. Keys and values must be strings.\n153:                 Example: {\"VERSION\": \"1.0.0\", \"ENV\": \"production\"}\n154:                 \n155:         Returns:\n156:             Dictionary containing:\n157:                 - image_name: Full image name with tag (e.g., \"my-agent:v1.0.0\")\n158:                 - image_id: Short image ID (12 hexadecimal characters)\n159:                 - image_size: Human-readable size (e.g., \"125.50 MB\")\n160:                 - build_time: Build duration in seconds (e.g., \"15.23s\")\n161:                 \n162:         Raises:\n163:             RuntimeError: If Docker is not available, Dockerfile doesn't exist,\n164:                 or build fails. The exception message includes details about\n165:                 the failure cause.\n166:                 \n167:         Example:\n168:             >>> from pathlib import Path\n169:             >>> docker = DockerService()\n170:             >>> result = docker.build_image(\n171:             ...     dockerfile_path=Path(\"Dockerfile\"),\n172:             ...     context_path=Path(\".\"),\n173:             ...     image_name=\"my-agent\",\n174:             ...     tag=\"v1.0.0\",\n175:             ...     build_args={\"VERSION\": \"1.0.0\"}\n176:             ... )\n177:             >>> print(f\"Built {result['image_name']} ({result['image_size']})\")\n178:         \"\"\"\n179:         if not self.check_docker_available():\n180:             raise RuntimeError(\"Docker is not available or not running. \"\n181:                              \"Please ensure Docker daemon is running: sudo systemctl start docker\")\n182: \n183:         logger.info(f\"Building image {image_name}:{tag} from {dockerfile_path}\")\n184:         full_image_name = f\"{image_name}:{tag}\"\n185:         start_time = time.time()\n186: \n187:         try:\n188:             image, build_logs = self.client.images.build(\n189:                 path=str(context_path),\n190:                 dockerfile=str(dockerfile_path),\n191:                 tag=full_image_name,\n192:                 buildargs=build_args or {},\n193:                 rm=True,\n194:                 forcerm=True,\n195:             )\n196: \n197:             build_time = time.time() - start_time\n198:             logger.info(f\"Image built successfully in {build_time:.2f}s\")\n199: \n200:             image_info = self._get_image_info(full_image_name)\n201:             image_info[\"build_time\"] = f\"{build_time:.2f}s\"\n202: \n203:             if self.verbose and build_logs:\n204:                 for log in build_logs:\n205:                     if isinstance(log, dict) and \"stream\" in log:\n206:                         stream_value = log.get(\"stream\")\n207:                         if isinstance(stream_value, str):\n208:                             logger.debug(f\"Build log: {stream_value.strip()}\")\n209: \n210:             return image_info\n211: \n212:         except APIError as e:\n213:             logger.error(f\"Docker build API error: {e}\")\n214:             raise RuntimeError(f\"Failed to build Docker image: API error - {e}\") from e\n215:         except DockerException as e:\n216:             logger.error(f\"Docker build failed: {e}\")\n217:             raise RuntimeError(f\"Failed to build Docker image: {e}\") from e\n218:         except Exception as e:\n219:             logger.error(f\"Unexpected error during build: {e}\")\n220:             raise RuntimeError(f\"Failed to build Docker image: {e}\") from e\n221: \n222:     def get_image_info(self, image_name: str) -> Dict[str, str]:\n223:         \"\"\"Get information about a Docker image.\n224:         \n225:         This method retrieves metadata about a Docker image including its ID,\n226:         size, and other attributes. It's useful for verifying builds, checking\n227:         image sizes, or getting the image ID for tagging/pushing operations.\n228:         \n229:         Args:\n230:             image_name: Name of the Docker image (e.g., \"my-agent:latest\" or\n231:                 \"registry.example.com/my-agent:v1.0.0\"). The image must exist\n232:                 locally.\n233:                 \n234:         Returns:\n235:             Dictionary containing:\n236:                 - image_name: Image name as provided\n237:                 - image_id: Short image ID (12 hexadecimal characters)\n238:                 - image_size: Human-readable size (e.g., \"125.50 MB\")\n239:                 - size_bytes: Size in bytes as string (e.g., \"131072000\")\n240:             Returns empty dict if image is not found or an error occurs.\n241:             \n242:         Example:\n243:             >>> docker = DockerService()\n244:             >>> info = docker.get_image_info(\"my-agent:v1.0.0\")\n245:             >>> if info:\n246:             ...     print(f\"Image {info['image_id']} is {info['image_size']}\")\n247:             ... else:\n248:             ...     print(\"Image not found\")\n249:         \"\"\"\n250:         return self._get_image_info(image_name)\n251: \n252:     def _get_image_info(self, image_name: str) -> Dict[str, str]:\n253:         \"\"\"Internal method to get image details.\n254:         \n255:         This is the internal implementation for retrieving image metadata.\n256:         It handles all error cases gracefully and returns an empty dict\n257:         when the image cannot be found or inspected.\n258:         \n259:         Args:\n260:             image_name: Name of the Docker image to inspect\n261:             \n262:         Returns:\n263:             Dictionary with image details (see get_image_info) or empty dict\n264:             if image not found or an error occurs.\n265:             \n266:         Note:\n267:             This method is internal and may change without notice. Use\n268:             get_image_info() for external access.\n269:         \"\"\"\n270:         try:\n271:             image = self.client.images.get(image_name)\n272:             attrs = image.attrs\n273: \n274:             image_id = attrs[\"Id\"].split(\":\")[-1][:12]\n275:             size_bytes = attrs.get(\"Size\", 0)\n276: \n277:             return {\n278:                 \"image_name\": image_name,\n279:                 \"image_id\": image_id,\n280:                 \"image_size\": self._format_size(size_bytes),\n281:                 \"size_bytes\": str(size_bytes),\n282:             }\n283: \n284:         except (DockerException, APIError) as e:\n285:             logger.warning(f\"Failed to get image info for {image_name}: {e}\")\n286:             return {}\n287:         except KeyError as e:\n288:             logger.warning(f\"Unexpected image attributes structure: {e}\")\n289:             return {}\n290: \n291:     def _format_size(self, size_bytes: int) -> str:\n292:         \"\"\"Format size in human-readable format.\n293:         \n294:         Converts a size in bytes to a human-readable string with appropriate\n295:         units (B, KB, MB, GB, or TB). The result is formatted to 2 decimal\n296:         places for consistency.\n297:         \n298:         Args:\n299:             size_bytes: Size in bytes. Must be non-negative. Large values\n300:                 (over 1TB) are supported but rare for Docker images.\n301:                 \n302:         Returns:\n303:             Human-readable size string with unit. Examples:\n304:                 - 500 -> \"500.00 B\"\n305:                 - 1024 -> \"1.00 KB\"\n306:                 - 1048576 -> \"1.00 MB\"\n307:                 - 1073741824 -> \"1.00 GB\"\n308:                 \n309:         Example:\n310:             >>> docker = DockerService()\n311:             >>> docker._format_size(125000000)\n312:             '119.21 MB'\n313:         \"\"\"\n314:         size_float: float = float(size_bytes)\n315:         for unit in [\"B\", \"KB\", \"MB\", \"GB\"]:\n316:             if size_float < 1024:\n317:                 return f\"{size_float:.2f} {unit}\"\n318:             size_float /= 1024\n319:         return f\"{size_float:.2f} TB\"\n320: \n321:     def push_image(\n322:         self,\n323:         image_name: str,\n324:         registry_url: Optional[str] = None,\n325:         username: Optional[str] = None,\n326:         password: Optional[str] = None,\n327:     ) -> Dict[str, str]:\n328:         \"\"\"Push a Docker image to a registry.\n329:         \n330:         This method pushes a locally-built Docker image to a container registry.\n331:         It supports both public registries (Docker Hub) and private registries\n332:         with authentication. If a registry URL is provided, the image is\n333:         automatically tagged before pushing.\n334:         \n335:         Args:\n336:             image_name: Local image name (e.g., \"my-agent:latest\"). The image\n337:                 must exist locally before pushing.\n338:             registry_url: Registry URL (e.g., \"registry.example.com\" or\n339:                 \"gcr.io/my-project\"). If None, pushes to Docker Hub. The URL\n340:                 should not include the protocol (https://).\n341:             username: Registry username for authentication. Required for\n342:                 private registries. Optional for Docker Hub public repos.\n343:             password: Registry password for authentication. Should be provided\n344:                 via environment variable or secret management in production.\n345:                 \n346:         Returns:\n347:             Dictionary containing:\n348:                 - pushed_image: Full pushed image name including registry\n349:                     (e.g., \"registry.example.com/my-agent:v1.0.0\")\n350:                 - push_time: Push duration in seconds (e.g., \"45.67s\")\n351:                 \n352:         Raises:\n353:             RuntimeError: If Docker is not available, image doesn't exist,\n354:                 authentication fails, or push fails. The exception message\n355:                 includes specific error details from Docker.\n356:                 \n357:         Example:\n358:             >>> import os\n359:             >>> docker = DockerService()\n360:             >>> result = docker.push_image(\n361:             ...     image_name=\"my-agent:v1.0.0\",\n362:             ...     registry_url=\"registry.example.com\",\n363:             ...     username=os.getenv(\"REGISTRY_USER\"),\n364:             ...     password=os.getenv(\"REGISTRY_PASS\")\n365:             ... )\n366:             >>> print(f\"Pushed {result['pushed_image']} in {result['push_time']}\")\n367:             \n368:         Note:\n369:             - For Docker Hub, use username \"docker login\" credentials\n370:             - For private registries, ensure CA certificates are installed\n371:             - Large images may take several minutes to push\n372:             - Network interruptions will cause the push to fail\n373:         \"\"\"\n374:         if not self.check_docker_available():\n375:             raise RuntimeError(\"Docker is not available or not running\")\n376: \n377:         start_time = time.time()\n378: \n379:         target_image = image_name\n380:         if registry_url:\n381:             target_image = f\"{registry_url}/{image_name}\"\n382:             logger.info(f\"Tagging image for registry: {target_image}\")\n383:             self._tag_image_sdk(image_name, target_image)\n384: \n385:         if username and password:\n386:             logger.info(f\"Authenticating with registry: {registry_url or 'default'}\")\n387:             self._docker_login_sdk(registry_url, username, password)\n388:         elif registry_url and not username:\n389:             logger.warning(\"Registry URL provided but no credentials. \"\n390:                          \"Push may fail for private registries.\")\n391: \n392:         logger.info(f\"Pushing image {target_image}\")\n393: \n394:         try:\n395:             push_logs = self.client.images.push(target_image, stream=True, decode=True)\n396: \n397:             for line in push_logs:\n398:                 if \"error\" in line:\n399:                     error_msg = line.get(\"error\", \"Unknown error\")\n400:                     logger.error(f\"Push error: {error_msg}\")\n401:                     raise RuntimeError(f\"Failed to push image: {error_msg}\")\n402:                 if \"status\" in line:\n403:                     status = line[\"status\"]\n404:                     if self.verbose:\n405:                         progress = line.get(\"progress\", \"\")\n406:                         logger.debug(f\"Push status: {status} {progress}\")\n407:                     elif status == \"Pushed\":\n408:                         logger.info(f\"Layer pushed: {line.get('id', 'unknown')}\")\n409: \n410:             push_time = time.time() - start_time\n411:             logger.info(f\"Image pushed successfully in {push_time:.2f}s\")\n412: \n413:             return {\n414:                 \"pushed_image\": target_image,\n415:                 \"push_time\": f\"{push_time:.2f}s\",\n416:             }\n417: \n418:         except APIError as e:\n419:             logger.error(f\"Docker push API error: {e}\")\n420:             raise RuntimeError(f\"Failed to push Docker image: API error - {e}\") from e\n421:         except DockerException as e:\n422:             logger.error(f\"Docker push failed: {e}\")\n423:             raise RuntimeError(f\"Failed to push Docker image: {e}\") from e\n424: \n425:     def _docker_login_sdk(self, registry: Optional[str], username: str, password: str) -> None:\n426:         \"\"\"Log in to Docker registry.\n427:         \n428:         This method authenticates with a Docker registry using the provided\n429:         credentials. The login session is stored in Docker's configuration\n430:         and persists for subsequent operations.\n431:         \n432:         Args:\n433:             registry: Registry URL (e.g., \"registry.example.com\"). Use None\n434:                 or omit for Docker Hub (https://index.docker.io/v1/).\n435:             username: Registry username. Must be a valid account with push\n436:                 permissions for the target repository.\n437:             password: Registry password or access token. For security, use\n438:                 access tokens instead of account passwords when available.\n439:                 \n440:         Raises:\n441:             RuntimeError: If authentication fails due to invalid credentials,\n442:                 network issues, or registry unavailability. The exception\n443:                 message includes the specific error from Docker.\n444:                 \n445:         Example:\n446:             >>> docker = DockerService()\n447:             >>> docker._docker_login_sdk(\n448:             ...     registry=\"registry.example.com\",\n449:             ...     username=\"myuser\",\n450:             ...     password=\"mytoken\"\n451:             ... )\n452:             \n453:         Note:\n454:             - Credentials are stored in ~/.docker/config.json\n455:             - Use access tokens instead of passwords when possible\n456:             - Logout with `docker logout` when done\n457:         \"\"\"\n458:         try:\n459:             registry_url = registry or \"https://index.docker.io/v1/\"\n460:             self.client.login(\n461:                 username=username,\n462:                 password=password,\n463:                 registry=registry_url,\n464:             )\n465:             logger.info(f\"Successfully logged in to registry: {registry or 'Docker Hub'}\")\n466:         except APIError as e:\n467:             logger.error(f\"Docker login failed: {e}\")\n468:             raise RuntimeError(f\"Failed to log in to Docker registry: {e}\") from e\n469:         except DockerException as e:\n470:             logger.error(f\"Docker login failed: {e}\")\n471:             raise RuntimeError(f\"Failed to log in to Docker registry: {e}\") from e\n472: \n473:     def _tag_image_sdk(self, source_image: str, target_image: str) -> None:\n474:         \"\"\"Tag a Docker image.\n475:         \n476:         This method creates a new tag for an existing Docker image. Tagging\n477:         is commonly used to rename images for registry pushes or to create\n478:         multiple tags for the same image (e.g., \"v1.0.0\" and \"latest\").\n479:         \n480:         Args:\n481:             source_image: Source image name (e.g., \"my-agent:latest\"). The\n482:                 image must exist locally.\n483:             target_image: Target image name (e.g., \"registry.example.com/my-agent:v1.0.0\").\n484:                 This is the new tag that will be created.\n485:                 \n486:         Raises:\n487:             RuntimeError: If the source image doesn't exist or tagging fails.\n488:                 The exception message includes details about the failure.\n489:                 \n490:         Example:\n491:             >>> docker = DockerService()\n492:             >>> docker._tag_image_sdk(\n493:             ...     source_image=\"my-agent:latest\",\n494:             ...     target_image=\"registry.example.com/my-agent:v1.0.0\"\n495:             ... )\n496:         \"\"\"\n497:         try:\n498:             image = self.client.images.get(source_image)\n499:             image.tag(target_image, force=True)\n500:             logger.info(f\"Tagged {source_image} as {target_image}\")\n501:         except APIError as e:\n502:             logger.error(f\"Docker tag failed: {e}\")\n503:             raise RuntimeError(f\"Failed to tag Docker image: {e}\") from e\n504:         except DockerException as e:\n505:             logger.error(f\"Docker tag failed: {e}\")\n506:             raise RuntimeError(f\"Failed to tag Docker image: {e}\") from e\n507: \n508:     def remove_image(self, image_name: str) -> bool:\n509:         \"\"\"Remove a Docker image.\n510:         \n511:         This method deletes a Docker image from the local system. It uses\n512:         force mode to remove the image even if it's referenced by stopped\n513:         containers. Use with caution as this operation is irreversible.\n514:         \n515:         Args:\n516:             image_name: Name of the image to remove (e.g., \"my-agent:latest\").\n517:                 The image must exist locally.\n518:                 \n519:         Returns:\n520:             True if the image was successfully removed, False if the image\n521:             doesn't exist or removal fails. False is returned gracefully\n522:             instead of raising an exception to simplify cleanup operations.\n523:             \n524:         Example:\n525:             >>> docker = DockerService()\n526:             >>> if docker.remove_image(\"my-agent:old\"):\n527:             ...     print(\"Cleanup successful\")\n528:             ... else:\n529:             ...     print(\"Image not found or removal failed\")\n530:         \"\"\"\n531:         try:\n532:             self.client.images.remove(image_name, force=True)\n533:             logger.info(f\"Removed image {image_name}\")\n534:             return True\n535:         except APIError as e:\n536:             logger.warning(f\"Failed to remove image {image_name}: {e}\")\n537:             return False\n538:         except DockerException as e:\n539:             logger.warning(f\"Failed to remove image {image_name}: {e}\")\n540:             return False\n\n(End of file - total 540 lines)\n</content>","metadata":{"preview":"\"\"\"Service for Docker operations.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport docker\nfrom docker.errors import APIError, DockerException\n\nlogger = logging.getLogger(__name__)\n\n\nclass DockerService:\n    \"\"\"Service for Docker operations including build, push, and image management.\n    \n    This class provides a unified interface for Docker operations:\n    - Building images from Dockerfiles","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/docker_service.py","time":{"start":1775871152305,"end":1775871152357}}}}
