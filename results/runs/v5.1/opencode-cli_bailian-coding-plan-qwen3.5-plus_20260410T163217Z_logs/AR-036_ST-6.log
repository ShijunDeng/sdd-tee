f, provider):\n119:         \"\"\"Test provider Python source path.\"\"\"\n120:         assert \"extra\" in provider\n121:         assert \"python\" in provider[\"extra\"]\n122:         assert provider[\"extra\"][\"python\"][\"source\"] == \"provider/agentcube.py\"\n123: \n124: \n125: class TestToolSchema:\n126:     \"\"\"Tests for tools/agentcube-code-interpreter.yaml schema.\"\"\"\n127:     \n128:     @pytest.fixture\n129:     def tool_schema(self):\n130:         \"\"\"Load the tool schema.\"\"\"\n131:         tool_path = Path(__file__).parent.parent / \"tools\" / \"agentcube-code-interpreter.yaml\"\n132:         with open(tool_path) as f:\n133:             return yaml.safe_load(f)\n134:     \n135:     def test_tool_identity(self, tool_schema):\n136:         \"\"\"Test tool identity.\"\"\"\n137:         identity = tool_schema[\"identity\"]\n138:         assert identity[\"name\"] == \"agentcube-code-interpreter\"\n139:         assert identity[\"author\"] == \"agentcube\"\n140:     \n141:     def test_tool_required_parameters(self, tool_schema):\n142:         \"\"\"Test tool has required parameters.\"\"\"\n143:         params = {p[\"name\"]: p for p in tool_schema[\"parameters\"]}\n144:         \n145:         assert \"router_url\" in params\n146:         assert params[\"router_url\"][\"required\"] is True\n147:         assert params[\"router_url\"][\"type\"] == \"string\"\n148:         \n149:         assert \"workload_manager_url\" in params\n150:         assert params[\"workload_manager_url\"][\"required\"] is True\n151:         assert params[\"workload_manager_url\"][\"type\"] == \"string\"\n152:     \n153:     def test_tool_optional_parameters(self, tool_schema):\n154:         \"\"\"Test tool has optional parameters.\"\"\"\n155:         params = {p[\"name\"]: p for p in tool_schema[\"parameters\"]}\n156:         \n157:         assert \"language\" in params\n158:         assert params[\"language\"][\"required\"] is False\n159:         \n160:         assert \"code\