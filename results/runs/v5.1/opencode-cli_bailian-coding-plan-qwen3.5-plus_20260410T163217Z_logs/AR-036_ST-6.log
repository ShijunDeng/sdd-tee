ython\\\" in lang_opts}')\nprint(f'Has javascript: {\\\"javascript\\\" in lang_opts}')\nprint(f'Has typescript: {\\\"typescript\\\" in lang_opts}')\n\"\n","description":"Verify tool parameters against spec"},"output":"=== Tool Parameter Check ===\nrouter_url: type✓, req✓, form✓\nworkload_manager_url: type✓, req✓, form✓\nlanguage: type✓, req✓, form✓\ncode: type✓, req✓, form✓\ncommand: type✓, req✓, form✓\nsession_id: type✓, req✓, form✓\nsession_reuse: type✓, req✓, form✓\ncode_interpreter_id: type✓, req✓, form✓\n\n=== Language Options ===\nOptions: ['python', 'javascript', 'typescript']\nHas python: True\nHas javascript: True\nHas typescript: True\n","metadata":{"output":"=== Tool Parameter Check ===\nrouter_url: type✓, req✓, form✓\nworkload_manager_url: type✓, req✓, form✓\nlanguage: type✓, req✓, form✓\ncode: type✓, req✓, form✓\ncommand: type✓, req✓, form✓\nsession_id: type✓, req✓, form✓\nsession_reuse: type✓, req✓, form✓\ncode_interpreter_id: type✓, req✓, form✓\n\n=== Language Options ===\nOptions: ['python', 'javascript', 'typescript']\nHas python: True\nHas javascript: True\nHas typescript: True\n","exit":0,"description":"Verify tool parameters against spec","truncated":false},"title":"Verify tool parameters against spec","time":{"start":1775886487955,"end":1775886488035}}}}
