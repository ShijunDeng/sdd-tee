tions.md\n","metadata":{"output":"total 96\ndrwxr-xr-x  2 root root  4096 Apr 11 16:10 .\ndrwxr-xr-x 12 root root  4096 Apr 11 16:10 ..\n-rw-r--r--  1 root root  4043 Apr 11 15:41 components.md\n-rw-r--r--  1 root root  9383 Apr 11 15:41 data-flow.md\n-rw-r--r--  1 root root 10363 Apr 11 16:10 deployment.md\n-rw-r--r--  1 root root 43689 Apr 11 16:06 design.md\n-rw-r--r--  1 root root  5086 Apr 11 15:41 overview.md\n-rw-r--r--  1 root root  4540 Apr 11 15:41 security.md\ntotal 52\ndrwxr-xr-x  2 root root 4096 Apr 11 16:14 .\ndrwxr-xr-x 12 root root 4096 Apr 11 16:10 ..\n-rw-r--r--  1 root root 8149 Apr 11 16:14 picod.md\n-rw-r--r--  1 root root 2302 Apr 11 16:11 README.md\n-rw-r--r--  1 root root 5358 Apr 11 16:11 router.md\n-rw-r--r--  1 root root 7246 Apr 11 16:14 sandbox-manager.md\n-rw-r--r--  1 root root 7694 Apr 11 16:12 store.md\n-rw-r--r--  1 root root 7416 Apr 11 16:12 workload-manager.md\ntotal 36\ndrwxr-xr-x  2 root root 4096 Apr 11 16:16 .\ndrwxr-xr-x 12 root root 4096 Apr 11 16:10 ..\n-rw-r--r--  1 root root 6322 Apr 11 16:15 coding-standards.md\n-rw-r--r--  1 root root 8437 Apr 11 16:16 error-handling.md\n-rw-r--r--  1 root root 5711 Apr 11 16:15 naming-conventions.md\n","exit":0,"description":"List architecture, API, and design doc directories","truncated":false},"title":"List architecture, API, and design doc directories","time":{"start":1775895529696,"end":1775895529777}}}}
