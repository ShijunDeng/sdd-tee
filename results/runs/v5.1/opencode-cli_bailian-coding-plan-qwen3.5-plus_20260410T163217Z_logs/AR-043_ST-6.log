dboxes\n47:     Precreate(ctx context.Context, spec *SandboxSpec, count int) error\n48:     \n49:     // Acquire acquires a sandbox from warm pool\n50:     Acquire(ctx context.Context) (*SandboxInfo, error)\n51:     \n52:     // Refill refills warm pool\n53:     Refill(ctx context.Context, spec *SandboxSpec) error\n54:     \n55:     // Size returns current warm pool size\n56:     Size(ctx context.Context) (int, error)\n57: }\n58: ```\n59: \n60: ## Data Structures\n61: \n62: ### SandboxInfo\n63: \n64: ```go\n65: type SandboxInfo struct {\n66:     // Name is the sandbox name\n67:     Name string `json:\"name\"`\n68:     \n69:     // Namespace is the Kubernetes namespace\n70:     Namespace string `json:\"namespace\"`\n71:     \n72:     // UID is the unique identifier\n73:     UID types.UID `json:\"uid\"`\n74:     \n75:     // RuntimeType is the runtime type\n76:     RuntimeType string `json:\"runtimeType\"`\n77:     \n78:     // SessionID is the associated session\n79:     SessionID string `json:\"sessionId,omitempty\"`\n80:     \n81:     // Status is the current status\n82:     Status SandboxStatus `json:\"status\"`\n83:     \n84:     // CreatedAt is the creation time\n85:     CreatedAt time.Time `json:\"createdAt\"`\n86:     \n87:     // ExpiresAt is the expiration time\n88:     ExpiresAt time.Time `json:\"expiresAt,omitempty\"`\n89:     \n90:     // LastActivity is the last activity time\n91:     LastActivity time.Time `json:\"lastActivity,omitempty\"`\n92: }\n93: ```\n94: \n95: ### SandboxSpec\n96: \n97: ```go\n98: type SandboxSpec struct {\n99:     // Image is the container image\n100:     Image string `json:\"image\"`\n\n(Showing lines 1-100 of 311. Use offset=101 to continue.)\n</content>","metadata":{"preview":"---\nid: sandbox-manager-api\ntitle: Sandbox Manager API\nslug: /api-reference/sandbox-manager\nsidebar_label: Sandbox Manager API\n---\n\n# Sandbox Manager API\n\nThe Sandbox Manager API provides sandbox lifecycle management and warm pool operations.\n\