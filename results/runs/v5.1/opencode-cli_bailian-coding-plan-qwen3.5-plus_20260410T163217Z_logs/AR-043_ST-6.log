(\n\t\"context\"\n\t\"errors\"\n\t\"time\"\n\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\nconst (\n\tsessionPrefix        = \"session:\"\n\texpiryIndexKey       = \"session:expiry\"\n\tlastActivityIndexKey = \"session:last_activity\"\n)\n\nvar ErrNotFound = errors.New(\"store: not found\")\n\ntype Store interface {\n\tPing(ctx context.Context) error","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/store/store.go","time":{"start":1775895561371,"end":1775895561402}}}}
{"type":"tool_use","timestamp":1775895561408,"sessionID":"ses_284611580ffeIf38TurH3phN6H","part":{"id":"prt_d7b9fb162001q8R3o16oYm00Ag","messageID":"msg_d7b9f9de3001p60ZncBQ1hKxm1","sessionID":"ses_284611580ffeIf38TurH3phN6H","type":"tool","tool":"read","callID":"toolu_4ed6d46b92b8407591bd4050","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/docs/docs/api/router.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/docs/docs/api/router.md</path>\n<type>file</type>\n<content>\n1: ---\n2: id: router-api\n3: title: Router API\n4: slug: /api-reference/router\n5: sidebar_label: Router API\n6: ---\n7: \n8: # Router API\n9: \n10: The Router API provides session management and request routing capabilities.\n11: \n12: ## Base URL\n13: \n14: ```\n15: http://router:8080/api/v1\n16: ```\n17: \n18: ## Authentication\n19: \n20: All endpoints require JWT authentication:\n21: \n22: ```http\n23: Authorization: Bearer <token>\n24: ```\n25: \n26: ## Endpoints\n27: \n28: ### Sessions\n29: \n30: #### Create Session\n31: \n32: Creates a new session and provisions a sandbox.\n33: \n34: **Endpoint:**\n35: \n36: ```http\n37: POST /sessions\n38: ```\n39: \n40: **Request:**\n41: \n42: ```json\n43: {\n44:   \"sessionId\": \"session-123\",\n45:   \"runtime\": \"python-3.11\",\n46:   \"resources\": {\n47:     \"cpu\": \"100m\",\n48:     \"memory\": \"256Mi\"\n49:   },\n50:   \"metadata\": {\n51:     \"user\": \"alice\",\n52:     \"project\": \"demo\"\n53:   }\n54: }\n55: ```\n56: \n57: **Response:**\n58: \n59: ```json\n60: {\n61:   \"sessionId\": \"session-123\",\n62:   \"sandboxId\": \"sandbox-abc-456\",\n63:   \"status\": \"provisioning\",\n64:   \"endpoints\": [],\n65:   \"createdAt\": \"2026-04-11T15:30:00Z\",\n66:   \"expiresAt\": \"2026-04-11T16:30:00Z\"\n67: }\n68: ```\n69: \n70: **Status Codes:**\n71: \n72: - `201 Created` - Session created successfully\n73: - `400 Bad Request` - Invalid input\n74: - `409 Conflict` - Session already exists\n75: - `429 Too Many Requests` - Session limit reached\n76: \n77: #### Get Session\n78: \n79: Retrieves session information.\n80: \n81: **Endpoint:**\n82: \n83: ```http\n84: GET /sessions/{sessionId}\n85: ```\n86: \n87: **Response:**\n88: \n89: ```json\n90: {\n91:   \"sessionId\": \"session-123\",\n92:   \"sandboxId\": \"sandbox-abc-456\",\n93:   \"status\": \"running\",\n94:   \"endpoints\": [\n95:     {\n96:       \"name\": \"http\",\n97:       \"url\": \"http://sandbox-abc-456.default.svc:8080\"\n98:     }\n99:   ],\n100:   \"createdAt\": \"2026-04-11T15:30:00Z\",\n101:   \"expiresAt\": \"2026-04-11T16:30:00Z\",\n102:   \"lastActivity\": \"2026-04-11T15:35:00Z\"\n103: }\n104: ```\n105: \n106: **Status Codes:**\n107: \n108: - `200 OK` - Success\n109: - `404 Not Found` - Session not found\n110: \n111: #### Delete Session\n112: \n113: Terminates a session and cleans up resources.\n114: \n115: **Endpoint:**\n116: \n117: ```http\n118: DELETE /sessions/{sessionId}\n119: ```\n120: \n121: **Response:**\n122: \n123: ```http\n124: HTTP/1.1 204 No Content\n125: ```\n126: \n127: **Status Codes:**\n128: \n129: - `204 No Content` - Session deleted successfully\n130: - `404 Not Found` - Session not found\n131: \n132: ### Proxy\n133: \n134: #### Proxy Request\n135: \n136: Forwards requests to the sandbox instance.\n137: \n138: **Endpoint:**\n139: \n140: ```http\n141: POST /proxy/{sandboxId}/*\n142: ```\n143: \n144: **Headers:**\n145: \n146: ```http\n147: X-Session-ID: session-123\n148: ```\n149: \n150: **Behavior:**\n151: \n152: 1. Extract session ID from header or path\n153: 2. Validate session exists and is active\n154: 3. Lookup sandbox endpoint from session store\n155: 4. Forward request to sandbox\n156: 5. Return sandbox response\n157: \n158: ### Health\n159: \n160: #### Health Check\n161: \n162: Liveness probe endpoint.\n163: \n164: **Endpoint:**\n165: \n166: ```http\n167: GET /healthz\n168: ```\n169: \n170: **Response:**\n171: \n172: ```json\n173: {\n174:   \"status\": \"healthy\",\n175:   \"timestamp\": \"2026-04-11T15:30:00Z\"\n176: }\n177: ```\n178: \n179: #### Readiness Check\n180: \n181: Readiness probe endpoint.\n182: \n183: **Endpoint:**\n184: \n185: ```http\n186: GET /ready\n187: ```\n188: \n189: **Response:**\n190: \n191: ```json\n192: {\n193:   \"status\": \"ready\",\n194:   \"checks\": {\n195:     \"redis\": \"ok\",\n196:     \"workloadManager\": \"ok\"\n197:   }\n198: }\n199: ```\n200: \n201: ## Client Examples\n202: \n203: ### Python SDK\n204: \n205: ```python\n206: from agentcube import Client\n207: \n208: client = Client(base_url=\"http://router:8080\", token=\"your-token\")\n209: \n210: # Create session\n211: session = client.create_session(\n212:     session_id=\"session-123\",\n213:     runtime=\"python-3.11\",\n214:     resources={\n215:         \"cpu\": \"100m\",\n216:         \"memory\": \"256Mi\"\n217:     },\n218:     metadata={\n219:         \"user\": \"alice\",\n220:         \"project\": \"demo\"\n221:     }\n222: )\n223: \n224: print(f\"Session ID: {session.id}\")\n225: print(f\"Sandbox ID: {session.sandbox_id}\")\n226: print(f\"Status: {session.status}\")\n227: \n228: # Get session info\n229: session = client.get_session(\"session-123\")\n230: print(f\"Endpoints: {session.endpoints}\")\n231: \n232: # Delete session\n233: client.delete_session(\"session-123\")\n234: ```\n235: \n236: ### Go Client\n237: \n238: ```go\n239: import (\n240:     \"github.com/volcano-sh/agentcube/client-go\"\n241:     \"github.com/volcano-sh/agentcube/client-go/api/v1\"\n242: )\n243: \n244: client := clientgo.NewClient(\"http://router:8080\", \"your-token\")\n245: \n246: // Create session\n247: req := &apiv1.CreateSessionRequest{\n248:     SessionID: \"session-123\",\n249:     Runtime:   \"python-3.11\",\n250:     Resources: &apiv1.ResourceRequirements{\n251:         CPU:    \"100m\",\n252:         Memory: \"256Mi\",\n253:     },\n254: }\n255: \n256: resp, err := client.CreateSession(context.Background(), req)\n257: if err != nil {\n258:     log.Fatal(err)\n259: }\n260: \n261: fmt.Printf(\"Session ID: %s\\n\", resp.SessionID)\n262: fmt.Printf(\"Sandbox ID: %s\\n\", resp.SandboxID)\n263: \n264: // Get session\n265: session, err := client.GetSession(context.Background(), \"session-123\")\n266: \n267: // Delete session\n268: err = client.DeleteSession(context.Background(), \"session-123\")\n269: ```\n270: \n271: ### cURL Examples\n272: \n273: ```bash\n274: # Create session\n275: curl -X POST http://router:8080/api/v1/sessions \\\n276:   -H \"Authorization: Bearer $TOKEN\" \\\n277:   -H \"Content-Type: application/json\" \\\n278:   -d '{\n279:     \"sessionId\": \"session-123\",\n280:     \"runtime\": \"python-3.11\"\n281:   }'\n282: \n283: # Get session\n284: curl http://router:8080/api/v1/sessions/session-123 \\\n285:   -H \"Authorization: Bearer $TOKEN\"\n286: \n287: # Delete session\n288: curl -X DELETE http://router:8080/api/v1/sessions/session-123 \\\n289:   -H \"Authorization: Bearer $TOKEN\"\n290: ```\n291: \n292: ## Error Codes\n293: \n294: | Code | HTTP Status | Description |\n295: |------|-------------|-------------|\n296: | `SESSION_NOT_FOUND` | 404 | Session does not exist |\n297: | `SESSION_EXISTS` | 409 | Session already exists |\n298: | `SESSION_LIMIT_REACHED` | 429 | Maximum sessions per client exceeded |\n299: | `SANDBOX_NOT_FOUND` | 404 | Sandbox not found |\n300: | `SANDBOX_NOT_READY` | 503 | Sandbox is not ready |\n301: | `INVALID_INPUT` | 400 | Invalid request parameters |\n302: | `UNAUTHORIZED` | 401 | Missing or invalid authentication |\n303: | `RATE_LIMIT_EXCEEDED` | 429 | Rate limit exceeded |\n304: \n305: ## Related Documents\n306: \n307: - [Workload Manager API](/api-reference/workload-manager)\n308: - [Store API](/api-reference/store)\n309: - [Authentication Guide](/advanced/authentication)\n\n(End of file - total 309 lines)\n</content>","metadata":{"preview":"---\nid: router-api\ntitle: Router API\nslug: /api-reference/router\nsidebar_label: Router API\n---\n\n# Router API\n\nThe Router API provides session management and request routing capabilities.\n\n## Base URL\n\n```\nhttp://router:8080/api/v1\n```\n\n## Authentication\n\nAll endpoints require JWT authentication:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/docs/docs/api/router.md","time":{"start":1775895561376,"end":1775895561406}}}}
{"type":"tool_use","timestamp":1775895561410,"sessionID":"ses_284611580ffeIf38TurH3phN6H","part":{"id":"prt_d7b9fb695001UTXaChLBnqJh7Q","messageID":"msg_d7b9f9de3001p60ZncBQ1hKxm1","sessionID":"ses_284611580ffeIf38TurH3phN6H","type":"tool","tool":"read","callID":"toolu_2b6ae816a0d74c8fb23f04fd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/docs/docs/api/store.md","limit":100},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/docs/docs/api/store.md</path>\n<type>file</type>\n<content>\n1: ---\n2: id: store-api\n3: title: Store API\n4: slug: /api-reference/store\n5: sidebar_label: Store API\n6: ---\n7: \n8: # Store API\n9: \n10: The Store API provides session state storage with Redis/Valkey backends.\n11: \n12: ## Package\n13: \n14: ```go\n15: import \"github.com/volcano-sh/agentcube/pkg/store\"\n16: ```\n17: \n18: ## Interface\n19: \n20: ```go\n21: type Store interface {\n22:     // Ping checks store connectivity\n23:     Ping(ctx context.Context) error\n24:     \n25:     // GetSandboxBySessionID retrieves sandbox by session ID\n26:     GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n27:     \n28:     // StoreSandbox persists new sandbox\n29:     StoreSandbox(ctx context.Context, info *types.SandboxInfo) error\n30:     \n31:     // UpdateSandbox updates existing sandbox\n32:     UpdateSandbox(ctx context.Context, info *types.SandboxInfo) error\n33:     \n34:     // DeleteSandboxBySessionID removes sandbox\n35:     DeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n36:     \n37:     // ListExpiredSandboxes returns sandboxes expired before time\n38:     ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n39:     \n40:     // ListInactiveSandboxes returns sandboxes inactive before time\n41:     ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\n42:     \n43:     // UpdateSessionLastActivity updates last activity time\n44:     UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n45:     \n46:     // Close closes the store connection\n47:     Close() error\n48: }\n49: ```\n50: \n51: ## Data Structures\n52: \n53: ### SandboxInfo\n54: \n55: ```go\n56: type SandboxInfo struct {\n57:     // Kind is the type of resource\n58:     Kind string `json:\"kind\"`\n59:     \n60:     // SandboxID is the unique identifier for the sandbox\n61:     SandboxID string `json:\"sandboxId\"`\n62:     \n63:     // SandboxNamespace is the Kubernetes namespace\n64:     SandboxNamespace string `json:\"sandboxNamespace\"`\n65:     \n66:     // Name is the human-readable name\n67:     Name string `json:\"name\"`\n68:     \n69:     // EntryPoints are the access endpoints\n70:     EntryPoints []SandboxEntryPoint `json:\"entryPoints\"`\n71:     \n72:     // SessionID is the associated session identifier\n73:     SessionID string `json:\"sessionId\"`\n74:     \n75:     // CreatedAt is the creation timestamp\n76:     CreatedAt time.Time `json:\"createdAt\"`\n77:     \n78:     // ExpiresAt is the expiration timestamp\n79:     ExpiresAt time.Time `json:\"expiresAt\"`\n80:     \n81:     // Status is the current state\n82:     Status string `json:\"status\"`\n83:     \n84:     // LastActivity is the last activity timestamp\n85:     LastActivity time.Time `json:\"lastActivity,omitempty\"`\n86: }\n87: ```\n88: \n89: ### SandboxEntryPoint\n90: \n91: ```go\n92: type SandboxEntryPoint struct {\n93:     // Path is the URL path\n94:     Path string `json:\"path\"`\n95:     \n96:     // Protocol is the protocol (http, https, ws, wss)\n97:     Protocol string `json:\"protocol\"`\n98:     \n99:     // Endpoint is the full endpoint URL\n100:     Endpoint string `json:\"endpoint\"`\n\n(Showing lines 1-100 of 321. Use offset=101 to continue.)\n</content>","metadata":{"preview":"---\nid: store-api\ntitle: Store API\nslug: /api-reference/store\nsidebar_label: Store API\n---\n\n# Store API\n\nThe Store API provides session state storage with Redis/Valkey backends.\n\n## Package\n\n```go\nimport \"github.com/volcano-sh/agentcube/pkg/store\"\n```\n\n## Interface\n\n```go","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/docs/docs/api/store.md","time":{"start":1775895561379,"end":1775895561409}}}}
