0:     \n51:     // Env are environment variables\n52:     Env []string `json:\"env,omitempty\"`\n53:     \n54:     // Dir is the working directory\n55:     Dir string `json:\"dir,omitempty\"`\n56:     \n57:     // Stdin is the standard input\n58:     Stdin io.Reader `json:\"-\"`\n59: }\n60: ```\n61: \n62: ### CommandResult\n63: \n64: ```go\n65: type CommandResult struct {\n66:     // ExitCode is the process exit code\n67:     ExitCode int `json:\"exitCode\"`\n68:     \n69:     // Stdout is the standard output\n70:     Stdout []byte `json:\"stdout,omitempty\"`\n71:     \n72:     // Stderr is the standard error\n73:     Stderr []byte `json:\"stderr,omitempty\"`\n74:     \n75:     // Duration is the execution duration\n76:     Duration time.Duration `json:\"duration\"`\n77:     \n78:     // OOMKilled indicates if process was OOM killed\n79:     OOMKilled bool `json:\"oomKilled\"`\n80:     \n81:     // Timeout indicates if execution timed out\n82:     Timeout bool `json:\"timeout\"`\n83: }\n84: ```\n85: \n86: ### Process\n87: \n88: ```go\n89: type Process struct {\n90:     // PID is the process ID\n91:     PID int `json:\"pid\"`\n92:     \n93:     // Command is the executed command\n94:     Command string `json:\"command\"`\n95:     \n96:     // StartTime is when the process started\n97:     StartTime time.Time `json:\"startTime\"`\n98:     \n99:     // Wait returns the exit status\n100:     Wait() (*CommandResult, error)\n\n(Showing lines 1-100 of 460. Use offset=101 to continue.)\n</content>","metadata":{"preview":"---\nid: picod-api\ntitle: PicoD API\nslug: /api-reference/picod\nsidebar_label: PicoD API\n---\n\n# PicoD API\n\nPicoD is an in-sandbox daemon for command execution and process management.\n\n## Package\n\n```go\nimport \"github.com/volcano-sh/agentcube/pkg/picod\"\n```\n\n## Interface\n\n```go","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/docs/docs/api/picod.md","time":{"start":1775895571944,"end":1775895571962}}}}
