:     \"development\": [\n541:       \"last 3 chrome version\",\n542:       \"last 3 firefox version\",\n543:       \"last 5 safari version\"\n544:     ]\n545:   },\n546:   \"engines\": {\n547:     \"node\": \">=18.0\"\n548:   }\n549: }\n550: ```\n551: \n552: ### 4.3 иҮӘе®ҡд№үз»„д»¶\n553: \n554: #### 4.3.1 CRD иЎЁж јз»„д»¶ (`src/components/CRDTable/index.tsx`)\n555: \n556: ```typescript\n557: import React from 'react';\n558: import styles from './styles.module.css';\n559: \n560: interface FieldSpec {\n561:   name: string;\n562:   type: string;\n563:   required: boolean;\n564:   description: string;\n565: }\n566: \n567: interface CRDTableProps {\n568:   crdName: string;\n569:   fields: FieldSpec[];\n570: }\n571: \n572: export function CRDTable({crdName, fields}: CRDTableProps) {\n573:   return (\n574:     <div className={styles.crdTable}>\n575:       <h3>{crdName}</h3>\n576:       <table>\n577:         <thead>\n578:           <tr>\n579:             <th>Field</th>\n580:             <th>Type</th>\n581:             <th>Required</th>\n582:             <th>Description</th>\n583:           </tr>\n584:         </thead>\n585:         <tbody>\n586:           {fields.map((field) => (\n587:             <tr key={field.name}>\n588:               <td><code>{field.name}</code></td>\n589:               <td><code>{field.type}</code></td>\n590:               <td>{field.required ? 'вң…' : 'вқҢ'}</td>\n591:               <td>{field.description}</td>\n592:             </tr>\n593:           ))}\n594:         </tbody>\n595:       </table>\n596:     </div>\n597:   );\n598: }\n599: \n600: export default CRDTable;\n601: ```\n602: \n603: #### 4.3.2 жһ¶жһ„еӣҫз»„д»¶ (`src/components/ArchitectureDiagram/index.tsx`)\n604: \n605: ```typescript\n606: import React from 'react';\n607: import styles from './styles.module.css';\n608: \n609: interface ArchitectureDiagramProps {\n610:   src: string;\n611:   alt: string;\n612: }\n613: \n614: export function ArchitectureDiagram({src, alt}: ArchitectureDiagramProps) {\n615:   return (\n616:     <div className={styles.diagramContainer}>\n617:       <img src={src} alt={alt} className={styles.diagram} />\n618:     </div>\n619:   );\n620: }\n621: \n622: export default ArchitectureDiagram;\n623: ```\n624: \n625: ### 4.4 зӨәдҫӢж–ҮжЎЈеҶ…е®№\n626: \n627: #### 4.4.1 жҰӮиҝ°ж–ҮжЎЈ (`docs/intro/01-overview.md`)\n628: \n629: ```markdown\n630: ---\n631: sidebar_label: Overview\n632: title: AgentCube Overview\n633: description: Introduction to AgentCube - Kubernetes-native sandbox orchestration for AI agents\n634: ---\n635: \n636: # AgentCube Overview\n637: \n638: ## What is AgentCube?\n639: \n640: AgentCube is a **Kubernetes-native sandbox orchestration platform** designed for AI agents. It provides:\n641: \n642: - **Isolated Execution**: Each agent runs in its own sandboxed environment\n643: - **Session Management**: Automatic session binding and lifecycle management\n644: - **Resource Efficiency**: Warm pool mechanism for fast startup and resource reuse\n645: - **Multi-tenant Support**: Namespace isolation and RBAC-based access control\n646: \n647: ## Key Features\n648: \n649: | Feature | Description |\n650: |---------|-------------|\n651: | AgentRuntime | Declarative agent deployment and management |\n652: | CodeInterpreter | Secure code execution with resource limits |\n653: | Router | Intelligent request routing and session affinity |\n654: | WorkloadManager | Kubernetes-native workload orchestration |\n655: \n656: ## Architecture\n657: \n658: ```\n659: в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n660: в”Ӯ   Client     в”Ӯ\n661: в””в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n662:        в”Ӯ\n663:        в–ј\n664: в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n665: в”Ӯ    Router    в”Ӯв—„в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n666: в””в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ        в”Ӯ\n667:        в”Ӯ                в”Ӯ\n668:        в–ј                в”Ӯ\n669: в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ   в”Ңв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”җ\n670: в”Ӯ  Workload    в”Ӯ   в”Ӯ  Redis  в”Ӯ\n671: в”Ӯ   Manager    в”Ӯ   в”Ӯ (Store) в”Ӯ\n672: в””в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ   в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n673:        в”Ӯ\n674:        в–ј\n675: в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n676: в”Ӯ   Sandbox    в”Ӯ\n677: в”Ӯ     Pods     в”Ӯ\n678: в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n679: ```\n680: \n681: ## Quick Links\n682: \n683: - [Quick Start](./03-quickstart.md) - Get started in 5 minutes\n684: - [Architecture](../architecture) - Deep dive into architecture\n685: - [CRD Reference](../crd-reference/agent-runtime) - API reference\n686: ```\n687: \n688: #### 4.4.2 CRD еҸӮиҖғж–ҮжЎЈ (`docs/crd-reference/agent-runtime.md`)\n689: \n690: ```markdown\n691: ---\n692: sidebar_label: AgentRuntime\n693: title: AgentRuntime CRD\n694: description: AgentRuntime custom resource definition reference\n695: ---\n696: \n697: # AgentRuntime CRD\n698: \n699: The `AgentRuntime` resource defines an AI agent's runtime configuration.\n700: \n701: ## API Version\n702: \n703: `runtime.agentcube.volcano.sh/v1alpha1`\n704: \n705: ## Kind\n706: \n707: `AgentRuntime`\n708: \n709: ## Example\n710: \n711: ```yaml\n712: apiVersion: runtime.agentcube.volcano.sh/v1alpha1\n713: kind: AgentRuntime\n714: metadata:\n715:   name: echo-agent\n716:   namespace: default\n717:   labels:\n718:     agentcube/expose: \"true\"\n719: spec:\n720:   image: volcanosh/echo-agent:latest\n721:   command: [\"python\", \"-m\", \"echo_agent\"]\n722:   sessionTimeout: \"5m\"\n723:   resources:\n724:     requests:\n725:       cpu: \"0.1\"\n726:       memory: \"64Mi\"\n727:     limits:\n728:       cpu: \"0.5\"\n729:       memory: \"128Mi\"\n730: ```\n731: \n732: ## Specification\n733: \n734: <CRDTable \n735:   crdName=\"AgentRuntimeSpec\"\n736:   fields={[\n737:     {name: \"image\", type: \"string\", required: true, description: \"Container image\"},\n738:     {name: \"command\", type: \"string[]\", required: false, description: \"Container command\"},\n739:     {name: \"sessionTimeout\", type: \"string\", required: false, description: \"Session TTL\"},\n740:     {name: \"resources\", type: \"ResourceRequirements\", required: false, description: \"Resource limits\"},\n741:   ]}\n742: />\n743: \n744: ## Status\n745: \n746: The `status` subresource reflects the current state of the AgentRuntime.\n747: \n748: ```yaml\n749: status:\n750:   ready: true\n751:   backendURL: \"http://echo-agent-svc:8080\"\n752:   phase: Running\n753:   conditions:\n754:     - type: Ready\n755:       status: \"True\"\n756:       lastTransitionTime: \"2024-01-01T00:00:00Z\"\n757: ```\n758: ```\n759: \n760: ### 4.5 CI/CD йӣҶжҲҗ\n761: \n762: #### 4.5.1 GitHub Actions Workflow (`.github/workflows/docs.yml`)\n763: \n764: ```yaml\n765: name: Deploy Documentation\n766: \n767: on:\n768:   push:\n769:     branches:\n770:       - main\n771:     paths:\n772:       - 'docs/**'\n773:   workflow_dispatch:\n774: \n775: permissions:\n776:   contents: write\n777: \n778: jobs:\n779:   deploy:\n780:     runs-on: ubuntu-latest\n781:     defaults:\n782:       run:\n783:         working-directory: ./docs\n784:     steps:\n785:       - uses: actions/checkout@v4\n786:       \n787:       - name: Setup Node.js\n788:         uses: actions/setup-node@v4\n789:         with:\n790:           node-version: '18'\n791:           cache: 'npm'\n792:           cache-dependency-path: docs/package-lock.json\n793:       \n794:       - name: Install dependencies\n795:         run: npm ci\n796:       \n797:       - name: Build documentation\n798:         run: npm run build\n799:       \n800:       - name: Deploy to GitHub Pages\n801:         uses: peaceiris/actions-gh-pages@v4\n802:         with:\n803:           github_token: ${{ secrets.GITHUB_TOKEN }}\n804:           publish_dir: ./docs/build\n805:           cname: docs.agentcube.io  # Optional: custom domain\n806: ```\n807: \n808: #### 4.5.2 ж–ҮжЎЈжӣҙж–°жЈҖжҹҘи„ҡжң¬ (`docs/scripts/check-ar-docs.sh`)\n809: \n810: ```bash\n811: #!/bin/bash\n812: \n813: # Check if all AR proposals have corresponding docs\n814: \n815: DOCS_DIR=\"docs/requirements\"\n816: CHANGES_DIR=\"changes\"\n817: \n818: echo \"Checking AR documentation coverage...\"\n819: \n820: for ar_dir in $CHANGES_DIR/AR-*; do\n821:     ar_name=$(basename $ar_dir)\n822:     proposal=\"$ar_dir/proposal.md\"\n823:     doc_file=\"$DOCS_DIR/$(echo $ar_name | tr '[:upper:]' '[:lower:]').md\"\n824:     \n825:     if [ -f \"$proposal\" ] && [ ! -f \"$doc_file\" ]; then\n826:         echo \"вҡ пёҸ  Missing doc for $ar_name\"\n827:     fi\n828: done\n829: \n830: echo \"Check complete.\"\n831: ```\n832: \n833: ## 5. Impact Analysis\n834: \n835: ### 5.1 дҫқиө–\n836: \n837: | еҢ…/е·Ҙе…· | з”ЁйҖ” | зүҲжң¬ |\n838: |---------|------|------|\n839: | Node.js | иҝҗиЎҢж—¶ | >=18.0 |\n840: | Docusaurus | ж–ҮжЎЈжЎҶжһ¶ | 3.6.0+ |\n841: | React | UI жЎҶжһ¶ | 18.2.0+ |\n842: | TypeScript | зұ»еһӢзі»з»ҹ | 5.3.3+ |\n843: | Algolia DocSearch | жҗңзҙўжңҚеҠЎ | - |\n844: | GitHub Pages | жүҳз®ЎжңҚеҠЎ | - |\n845: \n846: ### 5.2 еҸ—еҪұе“Қз»„д»¶\n847: \n848: 1. **зҺ°жңүж–ҮжЎЈ** - йңҖиҰҒиҝҒз§»е’ҢйҮҚз»„еҲ°ж–°зҡ„зӣ®еҪ•з»“жһ„\n849: 2. **CI/CD Pipeline** - ж–°еўһж–ҮжЎЈжһ„е»әе’ҢйғЁзҪІжөҒзЁӢ\n850: 3. **ејҖеҸ‘жөҒзЁӢ** - ж–°еўһж–ҮжЎЈзј–еҶҷе’Ңе®ЎжҹҘзҺҜиҠӮ\n851: \n852: ### 5.3 еҗ‘еҗҺе…је®№жҖ§\n853: \n854: - зҺ°жңү Markdown ж–ҮжЎЈеҸҜзӣҙжҺҘиҝҒз§»\n855: - еҺҹжңүж–ҮжЎЈй“ҫжҺҘйңҖиҰҒйҮҚе®ҡеҗ‘й…ҚзҪ®\n856: - е»әи®®и®ҫзҪ® 301 йҮҚе®ҡеҗ‘йҒҝе…Қй“ҫжҺҘеӨұж•Ҳ\n857: \n858: ### 5.4 йЈҺйҷ©иҜ„дј°\n859: \n860: | йЈҺйҷ© | еҸҜиғҪжҖ§ | еҪұе“Қ | зј“и§ЈжҺӘж–Ҫ |\n861: |------|--------|------|----------|\n862: | Docusaurus еӯҰд№ жӣІзәҝ | дёӯ | дҪҺ | иҜҰз»Ҷж–ҮжЎЈе’ҢзӨәдҫӢ |\n863: | ж–ҮжЎЈиҝҒз§»е·ҘдҪңйҮҸеӨ§ | й«ҳ | дёӯ | еҲҶйҳ¶ж®өиҝҒз§» |\n864: | Algolia жҗңзҙўй…ҚзҪ®еӨҚжқӮ | дёӯ | дҪҺ | дҪҝз”ЁзӨҫеҢәзҙўеј• |\n865: | еӨҡиҜӯиЁҖзҝ»иҜ‘жҲҗжң¬й«ҳ | дёӯ | дёӯ | дјҳе…Ҳдёӯж–ҮпјҢйҖҗжӯҘзҝ»иҜ‘ |\n866: | зүҲжң¬з®ЎзҗҶеӨҚжқӮ | дҪҺ | дёӯ | дҪҝз”Ё Docusaurus зүҲжң¬жҸ’д»¶ |\n867: \n868: ## 6. Alternatives Considered\n869: \n870: ### 6.1 ж–№жЎҲ A: дҪҝз”Ё MkDocs (дёҚйҮҮз”Ё)\n871: \n872: **жҸҸиҝ°**: дҪҝз”Ё Python з”ҹжҖҒзҡ„ MkDocs + Material дё»йўҳ\n873: \n874: **дјҳзӮ№**:\n875: - Python жҠҖжңҜж ҲпјҢдёҺ SDK дёҖиҮҙ\n876: - Material дё»йўҳеҠҹиғҪдё°еҜҢ\n877: - й…ҚзҪ®з®ҖеҚ•\n878: \n879: **зјәзӮ№**:\n880: - зүҲжң¬жҺ§еҲ¶йңҖиҰҒйўқеӨ–жҸ’д»¶\n881: - еӣҪйҷ…еҢ–ж”ҜжҢҒиҫғејұ\n882: - иҮӘе®ҡд№үз»„д»¶иғҪеҠӣжңүйҷҗ\n883: \n884: **дёҚйҮҮз”ЁеҺҹеӣ **: Docusaurus еңЁзүҲжң¬жҺ§еҲ¶е’ҢеӣҪйҷ…еҢ–ж–№йқўжӣҙжҲҗзҶҹ\n885: \n886: ### 6.2 ж–№жЎҲ B: дҪҝз”Ё Hugo (дёҚйҮҮз”Ё)\n887: \n888: **жҸҸиҝ°**: дҪҝз”Ё Go зј–еҶҷзҡ„йқҷжҖҒз«ҷзӮ№з”ҹжҲҗеҷЁ Hugo\n889: \n890: **дјҳзӮ№**:\n891: - жһ„е»әйҖҹеәҰжһҒеҝ«\n892: - Go жҠҖжңҜж ҲпјҢдёҺеҗҺз«ҜдёҖиҮҙ\n893: - дё»йўҳдё°еҜҢ\n894: \n895: **зјәзӮ№**:\n896: - Go template еӯҰд№ жӣІзәҝ\n897: - MDX ж”ҜжҢҒйңҖиҰҒйўқеӨ–й…ҚзҪ®\n898: - ж–ҮжЎЈз”ҹжҖҒиҫғе°Ҹ\n899: \n900: **дёҚйҮҮз”ЁеҺҹеӣ **: Docusaurus зҡ„ React з”ҹжҖҒжӣҙйҖӮеҗҲиҮӘе®ҡд№үз»„д»¶ејҖеҸ‘\n901: \n902: ### 6.3 ж–№жЎҲ C: дҪҝз”Ё GitBook (дёҚйҮҮз”Ё)\n903: \n904: **жҸҸиҝ°**: дҪҝз”Ё SaaS жңҚеҠЎ GitBook\n905: \n906: **дјҳзӮ№**:\n907: - ејҖз®ұеҚіз”Ё\n908: - еҚҸдҪңеҠҹиғҪејәеӨ§\n909: - ж— йңҖз»ҙжҠӨеҹәзЎҖи®ҫж–Ҫ\n910: \n911: **зјәзӮ№**:\n912: - д»ҳиҙ№жңҚеҠЎ\n913: - иҮӘе®ҡд№үиғҪеҠӣжңүйҷҗ\n914: - ж•°жҚ®дёҚеңЁиҮӘе·ұжҺ§еҲ¶дёӢ\n915: \n916: **дёҚйҮҮз”ЁеҺҹеӣ **: ејҖжәҗйЎ№зӣ®еә”дҪҝз”ЁејҖжәҗе·Ҙе…·пјҢдё”йңҖиҰҒе®Ңе…ЁжҺ§еҲ¶\n917: \n918: ### 6.4 ж–№жЎҲ D: дҪҝз”Ё VitePress (дёҚйҮҮз”Ё)\n919: \n920: **жҸҸиҝ°**: дҪҝз”Ё Vue з”ҹжҖҒзҡ„ VitePress\n921: \n922: **дјҳзӮ№**:\n923: - жһ„е»әйҖҹеәҰеҝ«\n924: - Vue 3 з”ҹжҖҒ\n925: - й…ҚзҪ®з®ҖжҙҒ\n926: \n927: **зјәзӮ№**:\n928: - зүҲжң¬жҺ§еҲ¶йңҖиҰҒйўқеӨ–е·ҘдҪң\n929: - дјҒдёҡйҮҮз”ЁжЎҲдҫӢиҫғе°‘\n930: - жҸ’д»¶з”ҹжҖҒдёҚеҰӮ Docusaurus\n931: \n932: **дёҚйҮҮз”ЁеҺҹеӣ **: Docusaurus еңЁж–ҮжЎЈз«ҷзӮ№йўҶеҹҹжӣҙжҲҗзҶҹ\n933: \n934: ## 7. Implementation Plan\n935: \n936: ### Phase 1: еҹәзЎҖжЎҶжһ¶жҗӯе»ә (4h)\n937: ```\n938: - [ ] еҲӣе»ә docs/ зӣ®еҪ•з»“жһ„\n939: - [ ] еҲқе§ӢеҢ– Docusaurus йЎ№зӣ®\n940: - [ ] й…ҚзҪ® docusaurus.config.ts\n941: - [ ] й…ҚзҪ® sidebars.ts\n942: - [ ] и®ҫзҪ® package.json е’Ң TypeScript\n943: - [ ] еҲӣе»әеҹәзЎҖйҰ–йЎө\n944: ```\n945: \n946: ### Phase 2: ж ёеҝғж–ҮжЎЈеҲӣе»ә (8h)\n947: ```\n948: - [ ] зј–еҶҷ Introduction ж–ҮжЎЈ\n949: - [ ] зј–еҶҷ Core Concepts ж–ҮжЎЈ\n950: - [ ] зј–еҶҷ CRD Reference ж–ҮжЎЈ\n951: - [ ] зј–еҶҷ Deployment ж–ҮжЎЈ\n952: - [ ] иҝҒз§»зҺ°жңү AR ж–ҮжЎЈ\n953: ```\n954: \n955: ### Phase 3: иҮӘе®ҡд№үз»„д»¶ејҖеҸ‘ (4h)\n956: ```\n957: - [ ] ејҖеҸ‘ CRDTable з»„д»¶\n958: - [ ] ејҖеҸ‘ ArchitectureDiagram з»„д»¶\n959: - [ ] ејҖеҸ‘ CodeExecutor з»„д»¶пјҲеҸҜйҖүпјү\n960: - [ ] й…ҚзҪ®иҮӘе®ҡд№ү CSS\n961: ```\n962: \n963: ### Phase 4: еӣҪйҷ…еҢ–й…ҚзҪ® (3h)\n964: ```\n965: - [ ] й…ҚзҪ® i18n жҸ’д»¶\n966: - [ ] еҲӣе»әиӢұж–Үзҝ»иҜ‘йӘЁжһ¶\n967: - [ ] й…ҚзҪ®иҜӯиЁҖеҲҮжҚўеҷЁ\n968: - [ ] зҝ»иҜ‘ж ёеҝғйЎөйқўпјҲйҰ–йЎөгҖҒеҝ«йҖҹејҖе§Ӣпјү\n969: ```\n970: \n971: ### Phase 5: CI/CD йӣҶжҲҗ (3h)\n972: ```\n973: - [ ] й…ҚзҪ® GitHub Actions\n974: - [ ] и®ҫзҪ® GitHub Pages йғЁзҪІ\n975: - [ ] й…ҚзҪ®иҮӘе®ҡд№үеҹҹеҗҚпјҲеҸҜйҖүпјү\n976: - [ ] й…ҚзҪ® Algolia DocSearch\n977: ```\n978: \n979: ### Phase 6: жөӢиҜ•е’ҢйӘҢж”¶ (2h)\n980: ```\n981: - [ ] жң¬ең°жһ„е»әжөӢиҜ•\n982: - [ ] з§»еҠЁз«Ҝе“Қеә”жөӢиҜ•\n983: - [ ] й“ҫжҺҘжЈҖжҹҘ\n984: - [ ] жҖ§иғҪдјҳеҢ–\n985: ```\n986: \n987: **жҖ»йў„дј°ж—¶й—ҙ**: 24 е°Ҹж—¶\n988: \n989: ## 8. Acceptance Criteria\n990: \n991: - [ ] Docusaurus з«ҷзӮ№еҸҜд»Ҙжң¬ең°еҗҜеҠЁ (`npm start`)\n992: - [ ] жүҖжңүж ёеҝғж–ҮжЎЈзұ»еҲ«жңүеҶ…е®№пјҲIntroduction, Concepts, CRD Reference, Deploymentпјү\n993: - [ ] иҮіе°‘ 5 дёӘ AR ж–ҮжЎЈиҝҒз§»е®ҢжҲҗ\n994: - [ ] дҫ§иҫ№ж ҸеҜјиҲӘз»“жһ„жё…жҷ°\n995: - [ ] еӣҪйҷ…еҢ–еҲҮжҚўжӯЈеёёе·ҘдҪң\n996: - [ ] GitHub Actions иҮӘеҠЁйғЁзҪІжҲҗеҠҹ\n997: - [ ] з§»еҠЁз«ҜжҳҫзӨәжӯЈеёё\n998: - [ ] жҗңзҙўеҠҹиғҪеҸҜз”ЁпјҲAlgolia жҲ–жң¬ең°жҗңзҙўпјү\n999: - [ ] иҮӘе®ҡд№үз»„д»¶пјҲCRDTableпјүеҸҜз”Ё\n1000: - [ ] ж–ҮжЎЈжһ„е»әж—¶й—ҙ < 2 еҲҶй’ҹ\n1001: \n1002: ## 9. Success Criteria\n1003: \n1004: 1. вң… ж–ҮжЎЈз«ҷжҲҗеҠҹйғЁзҪІе№¶еҸҜи®ҝй—®\n1005: 2. вң… жүҖжңүж ёеҝғж–ҮжЎЈе®Ңж•ҙдё”еҮҶзЎ®\n1006: 3. вң… еҜјиҲӘе’ҢжҗңзҙўдҪ“йӘҢиүҜеҘҪ\n1007: 4. вң… еӨҡиҜӯиЁҖеҲҮжҚўжӯЈеёё\n1008: 5. вң… CI/CD иҮӘеҠЁеҢ–иҝҗиЎҢ\n1009: 6. вң… ж–°жҲҗе‘ҳеҸҜд»ҘеҸӮиҖғж–ҮжЎЈеҝ«йҖҹдёҠжүӢ\n1010: 7. вң… ж–ҮжЎЈжӣҙж–°жөҒзЁӢйЎәз•…\n1011: \n1012: ## 10. Dependencies\n1013: \n1014: - Node.js 18+\n1015: - npm жҲ– yarn\n1016: - GitHub Pages и®ҝй—®жқғйҷҗ\n1017: - Algolia DocSearch иҙҰеҸ·пјҲеҸҜйҖүпјү\n1018: \n1019: ## 11. References\n1020: \n1021: - [Docusaurus е®ҳж–№ж–ҮжЎЈ](https://docusaurus.io/)\n1022: - [project.md](../../project.md) - йЎ№зӣ®дёҠдёӢж–Ү\n1023: - [design.md](../../design.md) - и®ҫи®Ўи§„иҢғ\n1024: - `changes/AR-*/proposal.md` - жһ¶жһ„йңҖжұӮж–ҮжЎЈ\n1025: - [Volcano ж–ҮжЎЈ](https://volcano.sh/docs/) - еҸӮиҖғж–ҮжЎЈйЈҺж ј\n1026: \n1027: (End of file - total 652 lines)\n\n(End of file - total 1027 lines)\n</content>","metadata":{"preview":"# AR-042: Docusaurus ж–ҮжЎЈз«ҷжЎҶжһ¶\n\n## 1. Purpose\n\nдёә AgentCube йЎ№зӣ®жһ„е»әеҹәдәҺ Docusaurus 3.x зҡ„зҺ°д»ЈеҢ–ж–ҮжЎЈз«ҷзӮ№жЎҶжһ¶пјҢжҸҗдҫӣз»ҹдёҖгҖҒеҸҜз»ҙжҠӨгҖҒжҳ“жү©еұ•зҡ„жҠҖжңҜж–ҮжЎЈеҹәзЎҖи®ҫж–ҪгҖӮ\n\nжң¬жҸҗжЎҲй’ҲеҜ№ AR-042 йңҖжұӮпјҢе»әз«Ӣд»ҘдёӢж ёеҝғиғҪеҠӣпјҡ\n\n1. **ж–ҮжЎЈз«ҷзӮ№еҹәзЎҖжһ¶жһ„** - еҹәдәҺ Docusaurus 3.x зҡ„йқҷжҖҒз«ҷзӮ№з”ҹжҲҗе’ҢйғЁзҪІ\n2. **жҠҖжңҜи§„иҢғж–ҮжЎЈеҢ–** - е°ҶзҺ°жңү AR (Architecture Requirement) ж–ҮжЎЈгҖҒи®ҫи®Ўи§„иҢғгҖҒAPI ж–ҮжЎЈж•ҙеҗҲеҲ°з»ҹдёҖз«ҷзӮ№\n3. **еӨҡзүҲжң¬ж”ҜжҢҒ** - ж”ҜжҢҒеӨҡзүҲжң¬ж–ҮжЎЈе№¶еӯҳпјҲеҰӮ v0.1.x, v0.2.x зӯүпјү\n4. **дёӯиӢұж–ҮеӣҪйҷ…еҢ–** - ж”ҜжҢҒдёӯж–Үе’ҢиӢұж–Үж–ҮжЎЈеҲҮжҚў\n5. **жҗңзҙўе’ҢеҜјиҲӘ** - йӣҶжҲҗ Algolia DocSearch е’Ңз»“жһ„еҢ–еҜјиҲӘ\n6. **CI/CD йӣҶжҲҗ** - иҮӘеҠЁеҢ–жһ„е»әе’ҢйғЁзҪІеҲ° GitHub Pages\n\nжң¬ж–ҮжЎЈз«ҷе°ҶдҪңдёә AgentCube йЎ№зӣ®зҡ„е®ҳж–№ж–ҮжЎЈе…ҘеҸЈпјҢжңҚеҠЎдәҺејҖеҸ‘иҖ…гҖҒиҝҗз»ҙдәәе‘ҳе’ҢжҠҖжңҜеҶізӯ–иҖ…гҖӮ\n\n## 2. Scope\n\n**Module:** `docs/`  ","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/changes/AR-042/proposal.md","time":{"start":1775894210860,"end":1775894210893}}}}
