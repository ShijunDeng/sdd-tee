v0.15.1 // indirect\n69: \tgithub.com/ugorji/go/codec v1.3.1 // indirect\n70: \tgithub.com/x448/float16 v0.8.4 // indirect\n71: \tgithub.com/yuin/gopher-lua v1.1.1 // indirect\n72: \tgo.mongodb.org/mongo-driver/v2 v2.5.0 // indirect\n73: \tgo.uber.org/atomic v1.11.0 // indirect\n74: \tgo.uber.org/multierr v1.11.0 // indirect\n75: \tgo.uber.org/zap v1.26.0 // indirect\n76: \tgo.yaml.in/yaml/v2 v2.4.3 // indirect\n77: \tgo.yaml.in/yaml/v3 v3.0.4 // indirect\n78: \tgolang.org/x/arch v0.22.0 // indirect\n79: \tgolang.org/x/crypto v0.48.0 // indirect\n80: \tgolang.org/x/exp v0.0.0-20230515195305-f3d0a9c9a5cc // indirect\n81: \tgolang.org/x/net v0.51.0 // indirect\n82: \tgolang.org/x/oauth2 v0.30.0 // indirect\n83: \tgolang.org/x/sys v0.41.0 // indirect\n84: \tgolang.org/x/term v0.40.0 // indirect\n85: \tgolang.org/x/text v0.34.0 // indirect\n86: \tgolang.org/x/time v0.9.0 // indirect\n87: \tgomodules.xyz/jsonpatch/v2 v2.4.0 // indirect\n88: \tgoogle.golang.org/protobuf v1.36.10 // indirect\n89: \tgopkg.in/evanphx/json-patch.v4 v4.13.0 // indirect\n90: \tgopkg.in/inf.v0 v0.9.1 // indirect\n91: \tk8s.io/apiextensions-apiserver v0.31.0 // indirect\n92: \tk8s.io/kube-openapi v0.0.0-20250910181357-589584f1c912 // indirect\n93: \tk8s.io/utils v0.0.0-20251002143259-bc988d571ff4 // indirect\n94: \tsigs.k8s.io/json v0.0.0-20250730193827-2d320260d730 // indirect\n95: \tsigs.k8s.io/randfill v1.0.0 // indirect\n96: \tsigs.k8s.io/structured-merge-diff/v6 v6.3.0 // indirect\n97: \tsigs.k8s.io/yaml v1.6.0 // indirect\n98: )\n\n(End of file - total 98 lines)\n</content>","metadata":{"preview":"module github.com/volcano-sh/agentcube\n\ngo 1.25.0\n\nrequire (\n\tgithub.com/alicebob/miniredis/v2 v2.37.0\n\tgithub.com/gin-gonic/gin v1.12.0\n\tgithub.com/golang-jwt/jwt/v5 v5.3.1\n\tgithub.com/google/uuid v1.6.0\n\tgithub.com/prometheus/client_golang v1.23.2\n\tgithub.com/redis/go-redis/v9 v9.18.0\n\tgithub.com/stretchr/testify v1.11.1\n\tgithub.com/valkey-io/valkey-go v1.0.73\n\tgopkg.in/yaml.v3 v3.0.1\n\tk8s.io/api v0.35.3\n\tk8s.io/apimachinery v0.35.3\n\tk8s.io/client-go v0.35.3\n\tk8s.io/klog/v2 v2.130.1\n\tsigs.k8s.io/controller-runtime v0.19.2\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/go.mod","time":{"start":1775864055037,"end":1775864055063}}}}
