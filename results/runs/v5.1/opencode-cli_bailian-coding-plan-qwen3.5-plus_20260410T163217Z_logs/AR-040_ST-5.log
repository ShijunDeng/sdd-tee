{"type":"tool_use","timestamp":1775890600502,"sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","part":{"id":"prt_d7b53fb1f001N7fihkDevaCbMT","messageID":"msg_d7b53efaf001ZLzoyK4IW409vi","sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","type":"tool","tool":"read","callID":"toolu_b5305cd88bab488c9f6d792a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_control_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_control_plane.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Unit tests for ControlPlaneClient.\"\"\"\n2: \n3: import os\n4: import pytest\n5: from unittest.mock import Mock, patch\n6: \n7: from agentcube.clients import ControlPlaneClient\n8: from agentcube.exceptions import SessionError\n9: \n10: \n11: class TestControlPlaneClientInit:\n12:     \"\"\"Tests for ControlPlaneClient.__init__().\"\"\"\n13:     \n14:     @patch('agentcube.clients.control_plane.create_session')\n15:     def test_init_with_explicit_url(self, mock_create_session):\n16:         \"\"\"GIVEN workload_manager_url is provided\n17:            WHEN client initializes\n18:            THEN URL is set correctly\"\"\"\n19:         mock_create_session.return_value = Mock()\n20:         \n21:         client = ControlPlaneClient(\n22:             workload_manager_url=\"http://wm:8080\",\n23:             namespace=\"default\"\n24:         )\n25:         \n26:         assert client.workload_manager_url == \"http://wm:8080\"\n27:         assert client.namespace == \"default\"\n28:     \n29:     @patch('agentcube.clients.control_plane.create_session')\n30:     @patch('os.getenv', return_value=\"http://from-env:8080\")\n31:     def test_workload_manager_url_from_env(self, mock_getenv, mock_create_session):\n32:         \"\"\"GIVEN workload_manager_url not provided but env var set\n33:            WHEN client initializes\n34:            THEN URL from env\"\"\"\n35:         mock_create_session.return_value = Mock()\n36:         \n37:         client = ControlPlaneClient(\n38:             workload_manager_url=None,\n39:             namespace=\"default\"\n40:         )\n41:         \n42:         assert client.workload_manager_url == \"http://from-env:8080\"\n43:     \n44:     @patch('os.getenv', return_value=None)\n45:     def test_missing_workload_manager_url_raises(self, mock_getenv):\n46:         \"\"\"GIVEN neither workload_manager_url nor env var\n47:            WHEN client initializes\n48:            THEN ValueError raised\"\"\"\n49:         with pytest.raises(ValueError, match=\"workload_manager_url must be provided\"):\n50:             ControlPlaneClient(workload_manager_url=None)\n51:     \n52:     @patch('agentcube.clients.control_plane.create_session')\n53:     def test_timeout_defaults(self, mock_create_session):\n54:         \"\"\"GIVEN timeout/connect_timeout not specified\n55:            WHEN client initializes\n56:            THEN defaults applied\"\"\"\n57:         mock_create_session.return_value = Mock()\n58:         \n59:         client = ControlPlaneClient(\n60:             workload_manager_url=\"http://wm:8080\"\n61:         )\n62:         \n63:         assert client.timeout == 120\n64:         assert client.connect_timeout == 5.0\n65:     \n66:     @patch('agentcube.clients.control_plane.create_session')\n67:     def test_namespace_default(self, mock_create_session):\n68:         \"\"\"GIVEN namespace not specified\n69:            WHEN client initializes\n70:            THEN defaults to 'default'\"\"\"\n71:         mock_create_session.return_value = Mock()\n72:         \n73:         client = ControlPlaneClient(\n74:             workload_manager_url=\"http://wm:8080\"\n75:         )\n76:         \n77:         assert client.namespace == \"default\"\n78:     \n79:     @patch('agentcube.clients.control_plane.create_session')\n80:     def test_session_created_with_pooling(self, mock_create_session):\n81:         \"\"\"GIVEN client initializes\n82:            WHEN create_session called\n83:            THEN pool_connections=10 and pool_maxsize=10\"\"\"\n84:         mock_create_session.return_value = Mock()\n85:         \n86:         client = ControlPlaneClient(\n87:             workload_manager_url=\"http://wm:8080\"\n88:         )\n89:         \n90:         mock_create_session.assert_called_once_with(\n91:             pool_connections=10,\n92:             pool_maxsize=10,\n93:         )\n94:     \n95:     @patch('agentcube.clients.control_plane.create_session')\n96:     @patch('os.getenv', return_value=\"/custom/token/path\")\n97:     def test_token_path_from_env(self, mock_getenv, mock_create_session):\n98:         \"\"\"GIVEN token_path not provided but env var set\n99:            WHEN client initializes\n100:            THEN token_path from env\"\"\"\n101:         mock_create_session.return_value = Mock()\n102:         \n103:         client = ControlPlaneClient(\n104:             workload_manager_url=\"http://wm:8080\",\n105:             token_path=None\n106:         )\n107:         \n108:         assert client.token_path == \"/custom/token/path\"\n109: \n110: \n111: class TestControlPlaneClientCreateSession:\n112:     \"\"\"Tests for ControlPlaneClient.create_session().\"\"\"\n113:     \n114:     @patch('agentcube.clients.control_plane.create_session')\n115:     @patch('agentcube.clients.control_plane.read_token_from_file')\n116:     def test_successful_create_session(self, mock_read_token, mock_create_session):\n117:         \"\"\"GIVEN Workload Manager responds with session_id\n118:            WHEN create_session called\n119:            THEN session_id returned and stored\"\"\"\n120:         mock_read_token.return_value = \"test-token\"\n121:         mock_session = Mock()\n122:         mock_session.post.return_value.json.return_value = {\n123:             \"session_id\": \"created-session-123\"\n124:         }\n125:         mock_create_session.return_value = mock_session\n126:         \n127:         client = ControlPlaneClient(\n128:             workload_manager_url=\"http://wm:8080\",\n129:             namespace=\"default\"\n130:         )\n131:         \n132:         result = client.create_session()\n133:         \n134:         assert result == \"created-session-123\"\n135:         assert client.session_id == \"created-session-123\"\n136:     \n137:     @patch('agentcube.clients.control_plane.create_session')\n138:     @patch('agentcube.clients.control_plane.read_token_from_file')\n139:     def test_create_session_makes_post_request(self, mock_read_token, mock_create_session):\n140:         \"\"\"GIVEN create_session called\n141:            WHEN request sent\n142:            THEN POST to correct URL with auth headers\"\"\"\n143:         mock_read_token.return_value = \"test-token\"\n144:         mock_session = Mock()\n145:         mock_session.post.return_value.json.return_value = {\n146:             \"session_id\": \"session-123\"\n147:         }\n148:         mock_create_session.return_value = mock_session\n149:         \n150:         client = ControlPlaneClient(\n151:             workload_manager_url=\"http://wm:8080\",\n152:             namespace=\"test-ns\"\n153:         )\n154:         \n155:         client.create_session()\n156:         \n157:         mock_session.post.assert_called_once()\n158:         call_args = mock_session.post.call_args\n159:         assert call_args[0][0] == \"http://wm:8080/v1/namespaces/test-ns/sessions/\"\n160:         assert call_args[1]['headers'] == {\"Authorization\": \"Bearer test-token\"}\n161:     \n162:     @patch('agentcube.clients.control_plane.create_session')\n163:     @patch('agentcube.clients.control_plane.read_token_from_file')\n164:     def test_create_session_missing_session_id_raises(self, mock_read_token, mock_create_session):\n165:         \"\"\"GIVEN Response lacks session_id field\n166:            WHEN create_session called\n167:            THEN SessionError raised\"\"\"\n168:         mock_read_token.return_value = \"test-token\"\n169:         mock_session = Mock()\n170:         mock_session.post.return_value.json.return_value = {}\n171:         mock_create_session.return_value = mock_session\n172:         \n173:         client = ControlPlaneClient(\n174:             workload_manager_url=\"http://wm:8080\"\n175:         )\n176:         \n177:         with pytest.raises(SessionError, match=\"Response missing session_id field\"):\n178:             client.create_session()\n179:     \n180:     @patch('agentcube.clients.control_plane.create_session')\n181:     @patch('agentcube.clients.control_plane.read_token_from_file')\n182:     def test_create_session_http_error_raises(self, mock_read_token, mock_create_session):\n183:         \"\"\"GIVEN HTTP error occurs\n184:            WHEN create_session called\n185:            THEN SessionError raised\"\"\"\n186:         mock_read_token.return_value = \"test-token\"\n187:         mock_session = Mock()\n188:         mock_session.post.side_effect = Exception(\"HTTP error\")\n189:         mock_create_session.return_value = mock_session\n190:         \n191:         client = ControlPlaneClient(\n192:             workload_manager_url=\"http://wm:8080\"\n193:         )\n194:         \n195:         with pytest.raises(SessionError):\n196:             client.create_session()\n197: \n198: \n199: class TestControlPlaneClientDeleteSession:\n200:     \"\"\"Tests for ControlPlaneClient.delete_session().\"\"\"\n201:     \n202:     @patch('agentcube.clients.control_plane.create_session')\n203:     @patch('agentcube.clients.control_plane.read_token_from_file')\n204:     def test_successful_delete_session(self, mock_read_token, mock_create_session):\n205:         \"\"\"GIVEN session exists\n206:            WHEN delete_session called\n207:            THEN session deleted\"\"\"\n208:         mock_read_token.return_value = \"test-token\"\n209:         mock_session = Mock()\n210:         mock_session.delete.return_value.status_code = 200\n211:         mock_create_session.return_value = mock_session\n212:         \n213:         client = ControlPlaneClient(\n214:             workload_manager_url=\"http://wm:8080\"\n215:         )\n216:         \n217:         client.delete_session(\"session-123\")\n218:         \n219:         mock_session.delete.assert_called_once()\n220:     \n221:     @patch('agentcube.clients.control_plane.create_session')\n222:     @patch('agentcube.clients.control_plane.read_token_from_file')\n223:     def test_delete_session_404_is_success(self, mock_read_token, mock_create_session):\n224:         \"\"\"GIVEN session not found (404)\n225:            WHEN delete_session called\n226:            THEN treated as success (no exception)\"\"\"\n227:         mock_read_token.return_value = \"test-token\"\n228:         mock_session = Mock()\n229:         mock_session.delete.return_value.status_code = 404\n230:         mock_create_session.return_value = mock_session\n231:         \n232:         client = ControlPlaneClient(\n233:             workload_manager_url=\"http://wm:8080\"\n234:         )\n235:         \n236:         client.delete_session(\"session-123\")\n237:     \n238:     @patch('agentcube.clients.control_plane.create_session')\n239:     @patch('agentcube.clients.control_plane.read_token_from_file')\n240:     def test_delete_session_uses_stored_session_id(self, mock_read_token, mock_create_session):\n241:         \"\"\"GIVEN session_id not provided but stored\n242:            WHEN delete_session called\n243:            THEN stored session_id used\"\"\"\n244:         mock_read_token.return_value = \"test-token\"\n245:         mock_session = Mock()\n246:         mock_session.delete.return_value.status_code = 200\n247:         mock_create_session.return_value = mock_session\n248:         \n249:         client = ControlPlaneClient(\n250:             workload_manager_url=\"http://wm:8080\"\n251:         )\n252:         client.session_id = \"stored-session\"\n253:         \n254:         client.delete_session()\n255:         \n256:         call_args = mock_session.delete.call_args\n257:         assert \"stored-session\" in call_args[0][0]\n258:     \n259:     @patch('agentcube.clients.control_plane.create_session')\n260:     @patch('agentcube.clients.control_plane.read_token_from_file')\n261:     def test_delete_session_no_session_id_warns(self, mock_read_token, mock_create_session):\n262:         \"\"\"GIVEN no session_id provided or stored\n263:            WHEN delete_session called\n264:            THEN logs warning and returns\"\"\"\n265:         mock_read_token.return_value = \"test-token\"\n266:         mock_session = Mock()\n267:         mock_create_session.return_value = mock_session\n268:         \n269:         client = ControlPlaneClient(\n270:             workload_manager_url=\"http://wm:8080\"\n271:         )\n272:         \n273:         client.delete_session()\n274:         \n275:         mock_session.delete.assert_not_called()\n276: \n277: \n278: class TestControlPlaneClientClose:\n279:     \"\"\"Tests for ControlPlaneClient.close().\"\"\"\n280:     \n281:     @patch('agentcube.clients.control_plane.create_session')\n282:     def test_close_calls_session_close(self, mock_create_session):\n283:         \"\"\"GIVEN close() called\n284:            WHEN method executes\n285:            THEN session.close() called\"\"\"\n286:         mock_session = Mock()\n287:         mock_create_session.return_value = mock_session\n288:         \n289:         client = ControlPlaneClient(\n290:             workload_manager_url=\"http://wm:8080\"\n291:         )\n292:         \n293:         client.close()\n294:         \n295:         mock_session.close.assert_called_once()\n\n(End of file - total 295 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for ControlPlaneClient.\"\"\"\n\nimport os\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube.clients import ControlPlaneClient\nfrom agentcube.exceptions import SessionError\n\n\nclass TestControlPlaneClientInit:\n    \"\"\"Tests for ControlPlaneClient.__init__().\"\"\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_init_with_explicit_url(self, mock_create_session):\n        \"\"\"GIVEN workload_manager_url is provided\n           WHEN client initializes\n           THEN URL is set correctly\"\"\"\n        mock_create_session.return_value = Mock()\n        ","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_control_plane.py","time":{"start":1775890600476,"end":1775890600500}}}}
{"type":"tool_use","timestamp":1775890600503,"sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","part":{"id":"prt_d7b54001a001dJkXL8v3aunlSI","messageID":"msg_d7b53efaf001ZLzoyK4IW409vi","sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","type":"tool","tool":"read","callID":"toolu_170f206e43cf4f41918660f9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_exceptions.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_exceptions.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Unit tests for AgentCube exceptions.\"\"\"\n2: \n3: import pytest\n4: \n5: from agentcube.exceptions import (\n6:     AgentCubeError,\n7:     CommandExecutionError,\n8:     SessionError,\n9:     DataPlaneError,\n10: )\n11: \n12: \n13: class TestAgentCubeError:\n14:     \"\"\"Tests for AgentCubeError base exception.\"\"\"\n15:     \n16:     def test_is_exception(self):\n17:         \"\"\"GIVEN AgentCubeError instantiated\n18:            WHEN checked\n19:            THEN is Exception subclass\"\"\"\n20:         assert issubclass(AgentCubeError, Exception)\n21:     \n22:     def test_can_be_raised(self):\n23:         \"\"\"GIVEN AgentCubeError raised\n24:            WHEN caught\n25:            THEN exception handled\"\"\"\n26:         with pytest.raises(AgentCubeError):\n27:             raise AgentCubeError(\"test error\")\n28:     \n29:     def test_with_message(self):\n30:         \"\"\"GIVEN AgentCubeError with message\n31:            WHEN str() called\n32:            THEN message returned\"\"\"\n33:         error = AgentCubeError(\"test message\")\n34:         assert str(error) == \"test message\"\n35: \n36: \n37: class TestCommandExecutionError:\n38:     \"\"\"Tests for CommandExecutionError exception.\"\"\"\n39:     \n40:     def test_is_agentcube_error(self):\n41:         \"\"\"GIVEN CommandExecutionError\n42:            WHEN checked\n43:            THEN is AgentCubeError subclass\"\"\"\n44:         assert issubclass(CommandExecutionError, AgentCubeError)\n45:     \n46:     def test_with_command_and_exit_code(self):\n47:         \"\"\"GIVEN CommandExecutionError with command and exit code\n48:            WHEN str() called\n49:            THEN message includes command and exit code\"\"\"\n50:         error = CommandExecutionError(\n51:             command=\"python script.py\",\n52:             exit_code=1\n53:         )\n54:         assert \"python script.py\" in str(error)\n55:         assert \"exited with code 1\" in str(error)\n56:     \n57:     def test_with_output(self):\n58:         \"\"\"GIVEN CommandExecutionError with output\n59:            WHEN str() called\n60:            THEN message includes output\"\"\"\n61:         error = CommandExecutionError(\n62:             command=\"python script.py\",\n63:             exit_code=1,\n64:             output=\"RuntimeError: something went wrong\"\n65:         )\n66:         assert \"RuntimeError: something went wrong\" in str(error)\n67:     \n68:     def test_without_output(self):\n69:         \"\"\"GIVEN CommandExecutionError without output\n70:            WHEN str() called\n71:            THEN message does not include colon after exit code\"\"\"\n72:         error = CommandExecutionError(\n73:             command=\"python script.py\",\n74:             exit_code=1,\n75:             output=None\n76:         )\n77:         assert \"exited with code 1\" in str(error)\n78:         assert \"exited with code 1:\" not in str(error)\n79:     \n80:     def test_attributes_stored(self):\n81:         \"\"\"GIVEN CommandExecutionError created\n82:            WHEN attributes accessed\n83:            THEN command, exit_code, output available\"\"\"\n84:         error = CommandExecutionError(\n85:             command=\"test-cmd\",\n86:             exit_code=42,\n87:             output=\"test output\"\n88:         )\n89:         \n90:         assert error.command == \"test-cmd\"\n91:         assert error.exit_code == 42\n92:         assert error.output == \"test output\"\n93:     \n94:     def test_can_be_raised(self):\n95:         \"\"\"GIVEN CommandExecutionError raised\n96:            WHEN caught as AgentCubeError\n97:            THEN exception handled\"\"\"\n98:         with pytest.raises(AgentCubeError):\n99:             raise CommandExecutionError(\"cmd\", 1)\n100:         \n101:         with pytest.raises(CommandExecutionError):\n102:             raise CommandExecutionError(\"cmd\", 1)\n103: \n104: \n105: class TestSessionError:\n106:     \"\"\"Tests for SessionError exception.\"\"\"\n107:     \n108:     def test_is_agentcube_error(self):\n109:         \"\"\"GIVEN SessionError\n110:            WHEN checked\n111:            THEN is AgentCubeError subclass\"\"\"\n112:         assert issubclass(SessionError, AgentCubeError)\n113:     \n114:     def test_can_be_raised(self):\n115:         \"\"\"GIVEN SessionError raised\n116:            WHEN caught\n117:            THEN exception handled\"\"\"\n118:         with pytest.raises(SessionError):\n119:             raise SessionError(\"session creation failed\")\n120:     \n121:     def test_with_message(self):\n122:         \"\"\"GIVEN SessionError with message\n123:            WHEN str() called\n124:            THEN message returned\"\"\"\n125:         error = SessionError(\"test message\")\n126:         assert str(error) == \"test message\"\n127: \n128: \n129: class TestDataPlaneError:\n130:     \"\"\"Tests for DataPlaneError exception.\"\"\"\n131:     \n132:     def test_is_agentcube_error(self):\n133:         \"\"\"GIVEN DataPlaneError\n134:            WHEN checked\n135:            THEN is AgentCubeError subclass\"\"\"\n136:         assert issubclass(DataPlaneError, AgentCubeError)\n137:     \n138:     def test_can_be_raised(self):\n139:         \"\"\"GIVEN DataPlaneError raised\n140:            WHEN caught\n141:            THEN exception handled\"\"\"\n142:         with pytest.raises(DataPlaneError):\n143:             raise DataPlaneError(\"data plane operation failed\")\n144:     \n145:     def test_with_message(self):\n146:         \"\"\"GIVEN DataPlaneError with message\n147:            WHEN str() called\n148:            THEN message returned\"\"\"\n149:         error = DataPlaneError(\"test message\")\n150:         assert str(error) == \"test message\"\n151: \n152: \n153: class TestExceptionHierarchy:\n154:     \"\"\"Tests for exception hierarchy relationships.\"\"\"\n155:     \n156:     def test_command_execution_error_catch_as_agentcube(self):\n157:         \"\"\"GIVEN CommandExecutionError raised\n158:            WHEN caught as AgentCubeError\n159:            THEN caught successfully\"\"\"\n160:         try:\n161:             raise CommandExecutionError(\"cmd\", 1)\n162:         except AgentCubeError as e:\n163:             assert isinstance(e, CommandExecutionError)\n164:     \n165:     def test_session_error_catch_as_agentcube(self):\n166:         \"\"\"GIVEN SessionError raised\n167:            WHEN caught as AgentCubeError\n168:            THEN caught successfully\"\"\"\n169:         try:\n170:             raise SessionError(\"error\")\n171:         except AgentCubeError as e:\n172:             assert isinstance(e, SessionError)\n173:     \n174:     def test_data_plane_error_catch_as_agentcube(self):\n175:         \"\"\"GIVEN DataPlaneError raised\n176:            WHEN caught as AgentCubeError\n177:            THEN caught successfully\"\"\"\n178:         try:\n179:             raise DataPlaneError(\"error\")\n180:         except AgentCubeError as e:\n181:             assert isinstance(e, DataPlaneError)\n182:     \n183:     def test_all_exceptions_are_python_exceptions(self):\n184:         \"\"\"GIVEN all custom exceptions\n185:            WHEN checked\n186:            THEN all are Exception subclasses\"\"\"\n187:         assert issubclass(AgentCubeError, Exception)\n188:         assert issubclass(CommandExecutionError, Exception)\n189:         assert issubclass(SessionError, Exception)\n190:         assert issubclass(DataPlaneError, Exception)\n\n(End of file - total 190 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for AgentCube exceptions.\"\"\"\n\nimport pytest\n\nfrom agentcube.exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    SessionError,\n    DataPlaneError,\n)\n\n\nclass TestAgentCubeError:\n    \"\"\"Tests for AgentCubeError base exception.\"\"\"\n    \n    def test_is_exception(self):\n        \"\"\"GIVEN AgentCubeError instantiated\n           WHEN checked\n           THEN is Exception subclass\"\"\"\n        assert issubclass(AgentCubeError, Exception)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_exceptions.py","time":{"start":1775890600479,"end":1775890600502}}}}
