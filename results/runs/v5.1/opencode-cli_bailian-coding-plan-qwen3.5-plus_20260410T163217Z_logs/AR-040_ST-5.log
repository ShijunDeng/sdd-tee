{"type":"tool_use","timestamp":1775890733359,"sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","part":{"id":"prt_d7b55aa48001rEWzCQYGZolTzq","messageID":"msg_d7b559e05001YJG119sjDnEJ6C","sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","type":"tool","tool":"write","callID":"toolu_b58285d8c51447afa1b5dda4","state":{"status":"completed","input":{"content":"\"\"\"Unit tests for HTTP utilities.\"\"\"\n\nimport pytest\nfrom unittest.mock import Mock, patch\nfrom requests.adapters import HTTPAdapter\nfrom urllib3.util.retry import Retry\n\nfrom agentcube.utils.http import create_session\n\n\nclass TestCreateSession:\n    \"\"\"Tests for create_session() function.\"\"\"\n    \n    def test_returns_requests_session(self):\n        \"\"\"GIVEN create_session called\n           WHEN result checked\n           THEN returns requests.Session instance\"\"\"\n        session = create_session()\n        \n        assert isinstance(session, Mock) or hasattr(session, 'mount')\n    \n    @patch('agentcube.utils.http.requests.Session')\n    @patch('agentcube.utils.http.HTTPAdapter')\n    @patch('agentcube.utils.http.Retry')\n    def test_default_pool_settings(self, mock_retry, mock_adapter, mock_session):\n        \"\"\"GIVEN create_session called with defaults\n           WHEN session configured\n           THEN pool_connections=10 and pool_maxsize=10\"\"\"\n        mock_session_instance = Mock()\n        mock_session.return_value = mock_session_instance\n        mock_adapter_instance = Mock()\n        mock_adapter.return_value = mock_adapter_instance\n        mock_retry_instance = Mock()\n        mock_retry.return_value = mock_retry_instance\n        \n        session = create_session()\n        \n        # Verify Retry was created with correct defaults\n        mock_retry.assert_called_once()\n        retry_call_args = mock_retry.call_args\n        assert retry_call_args[1]['total'] == 0\n        assert retry_call_args[1]['backoff_factor'] == 0.1\n        assert retry_call_args[1]['status_forcelist'] == [429, 500, 502, 503, 504]\n    \n    @patch('agentcube.utils.http.requests.Session')\n    @patch('agentcube.utils.http.HTTPAdapter')\n    @patch('agentkube.utils.http.Retry')\n    def test_custom_pool_settings(self, mock_retry, mock_adapter, mock_session):\n        \"\"\"GIVEN create_session called with custom pool settings\n           WHEN session configured\n           THEN custom settings used\"\"\"\n        mock_session_instance = Mock()\n        mock_session.return_value = mock_session_instance\n        mock_adapter_instance = Mock()\n        mock_adapter.return_value = mock_adapter_instance\n        mock_retry_instance = Mock()\n        mock_retry.return_value = mock_retry_instance\n        \n        session = create_session(pool_connections=20, pool_maxsize=50)\n        \n        # Verify Retry was created\n        mock_retry.assert_called_once()\n        \n        # Verify adapter was created with custom settings\n        mock_adapter.assert_called_once()\n        adapter_call_args = mock_adapter.call_args\n        assert adapter_call_args[1]['pool_connections'] == 20\n        assert adapter_call_args[1]['pool_maxsize'] == 50\n    \n    @patch('agentcube.utils.http.requests.Session')\n    @patch('agentcube.utils.http.HTTPAdapter')\n    @patch('agentcube.utils.http.Retry')\n    def test_retry_enabled_with_max_retries(self, mock_retry, mock_adapter, mock_session):\n        \"\"\"GIVEN create_session called with max_retries=3\n           WHEN session configured\n           THEN Retry with total=3\"\"\"\n        mock_session_instance = Mock()\n        mock_session.return_value = mock_session_instance\n        mock_adapter_instance = Mock()\n        mock_adapter.return_value = mock_adapter_instance\n        mock_retry_instance = Mock()\n        mock_retry.return_value = mock_retry_instance\n        \n        session = create_session(max_retries=3)\n        \n        mock_retry.assert_called_once()\n        retry_call_args = mock_retry.call_args\n        assert retry_call_args[1]['total'] == 3\n    \n    @patch('agentcube.utils.http.requests.Session')\n    @patch('agentcube.utils.http.HTTPAdapter')\n    def test_adapters_mounted(self, mock_adapter, mock_session):\n        \"\"\"GIVEN create_session called\n           WHEN session configured\n           THEN http and https adapters mounted\"\"\"\n        mock_session_instance = Mock()\n        mock_session.return_value = mock_session_instance\n        mock_adapter_instance = Mock()\n        mock_adapter.return_value = mock_adapter_instance\n        \n        session = create_session()\n        \n        mock_session_instance.mount.assert_any_call(\"http://\", mock_adapter_instance)\n        mock_session_instance.mount.assert_any_call(\"https://\", mock_adapter_instance)\n    \n    @patch('agentcube.utils.http.requests.Session')\n    @patch('agentcube.utils.http.HTTPAdapter')\n    @patch('agentcube.utils.http.Retry')\n    def test_retry_allowed_methods(self, mock_retry, mock_adapter, mock_session):\n        \"\"\"GIVEN create_session called\n           WHEN Retry configured\n           THEN all HTTP methods allowed\"\"\"\n        mock_session_instance = Mock()\n        mock_session.return_value = mock_session_instance\n        mock_adapter_instance = Mock()\n        mock_adapter.return_value = mock_adapter_instance\n        mock_retry_instance = Mock()\n        mock_retry.return_value = mock_retry_instance\n        \n        create_session()\n        \n        mock_retry.assert_called_once()\n        retry_call_args = mock_retry.call_args\n        allowed_methods = retry_call_args[1]['allowed_methods']\n        assert \"HEAD\" in allowed_methods\n        assert \"GET\" in allowed_methods\n        assert \"PUT\" in allowed_methods\n        assert \"DELETE\" in allowed_methods\n        assert \"OPTIONS\" in allowed_methods\n        assert \"TRACE\" in allowed_methods\n        assert \"POST\" in allowed_methods\n\n\nclass TestRetryConfiguration:\n    \"\"\"Tests for retry strategy configuration.\"\"\"\n    \n    def test_retry_status_codes(self):\n        \"\"\"GIVEN retry strategy created\n           WHEN status_forcelist checked\n           THEN includes common retry status codes\"\"\"\n        retry = Retry(\n            total=0,\n            backoff_factor=0.1,\n            status_forcelist=[429, 500, 502, 503, 504],\n            allowed_methods=[\"HEAD\", \"GET\", \"PUT\", \"DELETE\", \"OPTIONS\", \"TRACE\", \"POST\"],\n        )\n        \n        assert 429 in retry.status_forcelist\n        assert 500 in retry.status_forcelist\n        assert 502 in retry.status_forcelist\n        assert 503 in retry.status_forcelist\n        assert 504 in retry.status_forcelist\n    \n    def test_retry_backoff_factor(self):\n        \"\"\"GIVEN retry strategy created\n           WHEN backoff_factor checked\n           THEN equals 0.1\"\"\"\n        retry = Retry(\n            total=0,\n            backoff_factor=0.1,\n            status_forcelist=[429, 500, 502, 503, 504],\n            allowed_methods=[\"HEAD\", \"GET\", \"PUT\", \"DELETE\", \"OPTIONS\", \"TRACE\", \"POST\"],\n        )\n        \n        assert retry.backoff_factor == 0.1\n","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_http_utils.py"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/__init__.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/exceptions.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/agent_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/code_interpreter.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/agent_runtime_data_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/code_interpreter_data_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/control_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/utils/http.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/utils/log.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/utils/utils.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_agent_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_control_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_exceptions.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_agent_runtime_data_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter_data_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/__init__.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/integration/test_agent_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_http_utils.py":[]},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_http_utils.py","exists":false,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_http_utils.py","time":{"start":1775890732936,"end":1775890733355}}}}
