{"type":"tool_use","timestamp":1775890764395,"sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","part":{"id":"prt_d7b5622cc00192PSQA3rRp0lpg","messageID":"msg_d7b561968001mBnWT3MDKG7cRv","sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","type":"tool","tool":"write","callID":"toolu_e789f5e839bb43ea93f97b9f","state":{"status":"completed","input":{"content":"\"\"\"Unit tests for logging utilities.\"\"\"\n\nimport logging\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube.utils.log import get_logger\n\n\nclass TestGetLogger:\n    \"\"\"Tests for get_logger() function.\"\"\"\n    \n    def test_returns_logger_instance(self):\n        \"\"\"GIVEN get_logger called with name\n           WHEN result checked\n           THEN returns logging.Logger instance\"\"\"\n        logger = get_logger(\"test.logger\")\n        \n        assert isinstance(logger, logging.Logger)\n    \n    def test_logger_name(self):\n        \"\"\"GIVEN get_logger called with name\n           WHEN logger.name checked\n           THEN name matches\"\"\"\n        logger = get_logger(\"test.module.name\")\n        \n        assert logger.name == \"test.module.name\"\n    \n    def test_default_level_is_info(self):\n        \"\"\"GIVEN get_logger called without level\n           WHEN logger.level checked\n           THEN level is INFO\"\"\"\n        logger = get_logger(\"test.logger\")\n        \n        assert logger.level == logging.INFO\n    \n    def test_custom_level_string(self):\n        \"\"\"GIVEN get_logger called with level=\"DEBUG\"\n           WHEN logger.level checked\n           THEN level is DEBUG\"\"\"\n        logger = get_logger(\"test.logger\", level=\"DEBUG\")\n        \n        assert logger.level == logging.DEBUG\n    \n    def test_custom_level_uppercase(self):\n        \"\"\"GIVEN get_logger called with level=\"WARNING\"\n           WHEN logger.level checked\n           THEN level is WARNING\"\"\"\n        logger = get_logger(\"test.logger\", level=\"WARNING\")\n        \n        assert logger.level == logging.WARNING\n    \n    def test_custom_level_lowercase(self):\n        \"\"\"GIVEN get_logger called with level=\"debug\"\n           WHEN logger.level checked\n           THEN level is DEBUG (case insensitive)\"\"\"\n        logger = get_logger(\"test.logger\", level=\"debug\")\n        \n        assert logger.level == logging.DEBUG\n    \n    def test_critical_level(self):\n        \"\"\"GIVEN get_logger called with level=\"CRITICAL\"\n           WHEN logger.level checked\n           THEN level is CRITICAL\"\"\"\n        logger = get_logger(\"test.logger\", level=\"CRITICAL\")\n        \n        assert logger.level == logging.CRITICAL\n    \n    def test_error_level(self):\n        \"\"\"GIVEN get_logger called with level=\"ERROR\"\n           WHEN logger.level checked\n           THEN level is ERROR\"\"\"\n        logger = get_logger(\"test.logger\", level=\"ERROR\")\n        \n        assert logger.level == logging.ERROR\n    \n    @patch('agentcube.utils.log.logging.StreamHandler')\n    @patch('agentcube.utils.log.logging.Formatter')\n    def test_creates_handler(self, mock_formatter, mock_handler):\n        \"\"\"GIVEN get_logger called for new logger\n           WHEN logger created\n           THEN StreamHandler added\"\"\"\n        mock_handler_instance = Mock()\n        mock_handler.return_value = mock_handler_instance\n        mock_formatter_instance = Mock()\n        mock_formatter.return_value = mock_formatter_instance\n        \n        logger = get_logger(\"new.unique.logger.name\")\n        \n        # Handler should be created and added\n        mock_handler.assert_called_once()\n        mock_formatter.assert_called_once()\n        mock_handler_instance.setFormatter.assert_called_once()\n    \n    @patch('agentcube.utils.log.logging.StreamHandler')\n    @patch('agentcube.utils.log.logging.Formatter')\n    def test_formatter_format(self, mock_formatter, mock_handler):\n        \"\"\"GIVEN logger created\n           WHEN formatter created\n           THEN format includes timestamp, name, level, message\"\"\"\n        mock_handler_instance = Mock()\n        mock_handler.return_value = mock_handler_instance\n        mock_formatter_instance = Mock()\n        mock_formatter.return_value = mock_formatter_instance\n        \n        logger = get_logger(\"test.logger\")\n        \n        # Check formatter was created with correct format\n        mock_formatter.assert_called_once()\n        format_string = mock_formatter.call_args[0][0]\n        assert \"%(asctime)s\" in format_string\n        assert \"%(name)s\" in format_string\n        assert \"%(levelname)s\" in format_string\n        assert \"%(message)s\" in format_string\n    \n    def test_handler_not_added_multiple_times(self):\n        \"\"\"GIVEN get_logger called twice with same name\n           WHEN handlers checked\n           THEN only one handler added\"\"\"\n        logger1 = get_logger(\"singleton.logger.test\")\n        logger2 = get_logger(\"singleton.logger.test\")\n        \n        assert logger1 is logger2\n        assert len(logger1.handlers) == 1\n    \n    def test_get_logger_with_module_name(self):\n        \"\"\"GIVEN get_logger called with __name__\n           WHEN logger used\n           THEN works correctly\"\"\"\n        logger = get_logger(__name__)\n        \n        assert logger is not None\n        assert logger.level == logging.INFO\n\n\nclass TestLoggerFunctionality:\n    \"\"\"Tests for logger functionality.\"\"\"\n    \n    def test_logger_can_log_info(self, caplog):\n        \"\"\"GIVEN logger at INFO level\n           WHEN info message logged\n           THEN message captured\"\"\"\n        logger = get_logger(\"test.info.logger\", level=\"INFO\")\n        \n        with caplog.at_level(logging.INFO):\n            logger.info(\"Test info message\")\n        \n        assert \"Test info message\" in caplog.text\n    \n    def test_logger_can_log_debug(self, caplog):\n        \"\"\"GIVEN logger at DEBUG level\n           WHEN debug message logged\n           THEN message captured\"\"\"\n        logger = get_logger(\"test.debug.logger\", level=\"DEBUG\")\n        \n        with caplog.at_level(logging.DEBUG):\n            logger.debug(\"Test debug message\")\n        \n        assert \"Test debug message\" in caplog.text\n    \n    def test_logger_can_log_warning(self, caplog):\n        \"\"\"GIVEN logger at INFO level\n           WHEN warning message logged\n           THEN message captured\"\"\"\n        logger = get_logger(\"test.warning.logger\")\n        \n        with caplog.at_level(logging.WARNING):\n            logger.warning(\"Test warning message\")\n        \n        assert \"Test warning message\" in caplog.text\n    \n    def test_logger_can_log_error(self, caplog):\n        \"\"\"GIVEN logger at INFO level\n           WHEN error message logged\n           THEN message captured\"\"\"\n        logger = get_logger(\"test.error.logger\")\n        \n        with caplog.at_level(logging.ERROR):\n            logger.error(\"Test error message\")\n        \n        assert \"Test error message\" in caplog.text\n    \n    def test_logger_can_log_critical(self, caplog):\n        \"\"\"GIVEN logger at INFO level\n           WHEN critical message logged\n           THEN message captured\"\"\"\n        logger = get_logger(\"test.critical.logger\")\n        \n        with caplog.at_level(logging.CRITICAL):\n            logger.critical(\"Test critical message\")\n        \n        assert \"Test critical message\" in caplog.text\n    \n    def test_debug_not_logged_at_info_level(self, caplog):\n        \"\"\"GIVEN logger at INFO level\n           WHEN debug message logged\n           THEN message NOT captured\"\"\"\n        logger = get_logger(\"test.no.debug.logger\", level=\"INFO\")\n        \n        with caplog.at_level(logging.INFO):\n            logger.debug(\"Test debug message\")\n        \n        assert \"Test debug message\" not in caplog.text\n","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_log_utils.py"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/__init__.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/exceptions.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/agent_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/code_interpreter.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/agent_runtime_data_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/code_interpreter_data_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/control_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/utils/http.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/utils/log.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/utils/utils.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_agent_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter.py":[],"/home/dsj/benchmark/workspace