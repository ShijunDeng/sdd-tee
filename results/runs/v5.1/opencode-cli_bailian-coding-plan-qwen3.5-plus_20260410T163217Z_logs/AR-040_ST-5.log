bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_control_plane.py","before":"\"\"\"Unit tests for ControlPlaneClient.\"\"\"\n\nimport os\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube.clients import ControlPlaneClient\nfrom agentcube.exceptions import SessionError\n\n\nclass TestControlPlaneClientInit:\n    \"\"\"Tests for ControlPlaneClient.__init__().\"\"\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_init_with_explicit_url(self, mock_create_session):\n        \"\"\"GIVEN workload_manager_url is provided\n           WHEN client initializes\n           THEN URL is set correctly\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            namespace=\"default\"\n        )\n        \n        assert client.workload_manager_url == \"http://wm:8080\"\n        assert client.namespace == \"default\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('os.getenv', return_value=\"http://from-env:8080\")\n    def test_workload_manager_url_from_env(self, mock_getenv, mock_create_session):\n        \"\"\"GIVEN workload_manager_url not provided but env var set\n           WHEN client initializes\n           THEN URL from env\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=None,\n            namespace=\"default\"\n        )\n        \n        assert client.workload_manager_url == \"http://from-env:8080\"\n    \n    @patch('os.getenv', return_value=None)\n    def test_missing_workload_manager_url_raises(self, mock_getenv):\n        \"\"\"GIVEN neither workload_manager_url nor env var\n           WHEN client initializes\n           THEN ValueError raised\"\"\"\n        with pytest.raises(ValueError, match=\"workload_manager_url must be provided\"):\n            ControlPlaneClient(workload_manager_url=None)\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_timeout_defaults(self, mock_create_session):\n        \"\"\"GIVEN timeout/connect_timeout not specified\n           WHEN client initializes\n           THEN defaults applied\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_namespace_default(self, mock_create_session):\n        \"\"\"GIVEN namespace not specified\n           WHEN client initializes\n           THEN defaults to 'default'\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.namespace == \"default\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_session_created_with_pooling(self, mock_create_session):\n        \"\"\"GIVEN client initializes\n           WHEN create_session called\n           THEN pool_connections=10 and pool_maxsize=10\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        mock_create_session.assert_called_once_with(\n            pool_connections=10,\n            pool_maxsize=10,\n        )\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('os.getenv', return_value=\"/custom/token/path\")\n    def test_token_path_from_env(self, mock_getenv, mock_create_session):\n        \"\"\"GIVEN token_path not provided but env var set\n           WHEN client initializes\n           THEN token_path from env\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            token_path=None\n        )\n        \n        assert client.token_path == \"/custom/token/path\"\n\n\nclass TestControlPlaneClientCreateSession:\n    \"\"\"Tests for ControlPlaneClient.create_session().\"\"\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_successful_create_session(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN Workload Manager responds with session_id\n           WHEN create_session called\n           THEN session_id returned and stored\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.post.return_value.json.return_value = {\n            \"session_id\": \"created-session-123\"\n        }\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            namespace=\"default\"\n        )\n        \n        result = client.create_session()\n        \n        assert result == \"created-session-123\"\n        assert client.session_id == \"created-session-123\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_create_session_makes_post_request(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN create_session called\n           WHEN request sent\n           THEN POST to correct URL with auth headers\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.post.return_value.json.return_value = {\n            \"session_id\": \"session-123\"\n        }\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            namespace=\"test-ns\"\n        )\n        \n        client.create_session()\n        \n        mock_session.post.assert_called_once()\n        call_args = mock_session.post.call_args\n        assert call_args[0][0] == \"http://wm:8080/v1/namespaces/test-ns/sessions/\"\n        assert call_args[1]['headers'] == {\"Authorization\": \"Bearer test-token\"}\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_create_session_missing_session_id_raises(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN Response lacks session_id field\n           WHEN create_session called\n           THEN SessionError raised\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.post.return_value.json.return_value = {}\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        with pytest.raises(SessionError, match=\"Response missing session_id field\"):\n            client.create_session()\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_create_session_http_error_raises(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN HTTP error occurs\n           WHEN create_session called\n           THEN SessionError raised\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.post.side_effect = Exception(\"HTTP error\")\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        with pytest.raises(SessionError):\n            client.create_session()\n\n\nclass TestControlPlaneClientDeleteSession:\n    \"\"\"Tests for ControlPlaneClient.delete_session().\"\"\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_successful_delete_session(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN session exists\n           WHEN delete_session called\n           THEN session deleted\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.delete.return_value.status_code = 200\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.delete_session(\"session-123\")\n        \n        mock_session.delete.assert_called_once()\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_delete_session_404_is_success(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN session not found (404)\n           WHEN delete_session called\n           THEN treated as success (no exception)\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.delete.return_value.status_code = 404\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.delete_session(\"session-123\")\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_delete_session_uses_stored_session_id(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN session_id not provided but stored\n           WHEN delete_session called\n           THEN stored session_id used\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.delete.return_value.status_code = 200\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.session_id = \"stored-session\"\n        \n        client.delete_session()\n        \n        call_args = mock_session.delete.call_args\n        assert \"stored-session\" in call_args[0][0]\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_delete_session_no_session_id_warns(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN no session_id provided or stored\n           WHEN delete_session called\n           THEN logs warning and returns\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.delete_session()\n        \n        mock_session.delete.assert_not_called()\n\n\nclass TestControlPlaneClientClose:\n    \"\"\"Tests for ControlPlaneClient.close().\"\"\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_close_calls_session_close(self, mock_create_session):\n        \"\"\"GIVEN close() called\n           WHEN method executes\n           THEN session.close() called\"\"\"\n        mock_session = Mock()\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.close()\n        \n        mock_session.close.assert_called_once()\n","after":"\"\"\"Unit tests for ControlPlaneClient.\"\"\"\n\nimport os\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube.clients import ControlPlaneClient\nfrom agentcube.exceptions import SessionError\n\n\nclass TestControlPlaneClientInit:\n    \"\"\"Tests for ControlPlaneClient.__init__().\"\"\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_init_with_explicit_url(self, mock_create_session):\n        \"\"\"GIVEN workload_manager_url is provided\n           WHEN client initializes\n           THEN URL is set correctly\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            namespace=\"default\"\n        )\n        \n        assert client.workload_manager_url == \"http://wm:8080\"\n        assert client.namespace == \"default\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('os.getenv', return_value=\"http://from-env:8080\")\n    def test_workload_manager_url_from_env(self, mock_getenv, mock_create_session):\n        \"\"\"GIVEN workload_manager_url not provided but env var set\n           WHEN client initializes\n           THEN URL from env\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=None,\n            namespace=\"default\"\n        )\n        \n        assert client.workload_manager_url == \"http://from-env:8080\"\n    \n    @patch('os.getenv', return_value=None)\n    def test_missing_workload_manager_url_raises(self, mock_getenv):\n        \"\"\"GIVEN neither workload_manager_url nor env var\n           WHEN client initializes\n           THEN ValueError raised\"\"\"\n        with pytest.raises(ValueError, match=\"workload_manager_url must be provided\"):\n            ControlPlaneClient(workload_manager_url=None)\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_timeout_defaults(self, mock_create_session):\n        \"\"\"GIVEN timeout/connect_timeout not specified\n           WHEN client initializes\n           THEN defaults applied\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_namespace_default(self, mock_create_session):\n        \"\"\"GIVEN namespace not specified\n           WHEN client initializes\n           THEN defaults to 'default'\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.namespace == \"default\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_session_created_with_pooling(self, mock_create_session):\n        \"\"\"GIVEN client initializes\n           WHEN create_session called\n           THEN pool_connections=10 and pool_maxsize=10\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        mock_create_session.assert_called_once_with(\n            pool_connections=10,\n            pool_maxsize=10,\n        )\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('os.getenv', return_value=\"/custom/token/path\")\n    def test_token_path_from_env(self, mock_getenv, mock_create_session):\n        \"\"\"GIVEN token_path not provided but env var set\n           WHEN client initializes\n           THEN token_path from env\"\"\"\n        mock_create_session.return_value = Mock()\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            token_path=None\n        )\n        \n        assert client.token_path == \"/custom/token/path\"\n\n\nclass TestControlPlaneClientCreateSession:\n    \"\"\"Tests for ControlPlaneClient.create_session().\"\"\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_successful_create_session(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN Workload Manager responds with session_id\n           WHEN create_session called\n           THEN session_id returned and stored\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.post.return_value.json.return_value = {\n            \"session_id\": \"created-session-123\"\n        }\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            namespace=\"default\"\n        )\n        \n        result = client.create_session()\n        \n        assert result == \"created-session-123\"\n        assert client.session_id == \"created-session-123\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_create_session_makes_post_request(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN create_session called\n           WHEN request sent\n           THEN POST to correct URL with auth headers\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.post.return_value.json.return_value = {\n            \"session_id\": \"session-123\"\n        }\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            namespace=\"test-ns\"\n        )\n        \n        client.create_session()\n        \n        mock_session.post.assert_called_once()\n        call_args = mock_session.post.call_args\n        assert call_args[0][0] == \"http://wm:8080/v1/namespaces/test-ns/sessions/\"\n        assert call_args[1]['headers'] == {\"Authorization\": \"Bearer test-token\"}\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_create_session_missing_session_id_raises(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN Response lacks session_id field\n           WHEN create_session called\n           THEN SessionError raised\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.post.return_value.json.return_value = {}\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        with pytest.raises(SessionError, match=\"Response missing session_id field\"):\n            client.create_session()\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_create_session_http_error_raises(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN HTTP error occurs\n           WHEN create_session called\n           THEN SessionError raised\"\"\"\n        import requests\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.post.side_effect = requests.HTTPError(\"HTTP error\")\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        with pytest.raises(SessionError):\n            client.create_session()\n\n\nclass TestControlPlaneClientDeleteSession:\n    \"\"\"Tests for ControlPlaneClient.delete_session().\"\"\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_successful_delete_session(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN session exists\n           WHEN delete_session called\n           THEN session deleted\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.delete.return_value.status_code = 200\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.delete_session(\"session-123\")\n        \n        mock_session.delete.assert_called_once()\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_delete_session_404_is_success(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN session not found (404)\n           WHEN delete_session called\n           THEN treated as success (no exception)\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.delete.return_value.status_code = 404\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.delete_session(\"session-123\")\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_delete_session_uses_stored_session_id(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN session_id not provided but stored\n           WHEN delete_session called\n           THEN stored session_id used\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_session.delete.return_value.status_code = 200\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.session_id = \"stored-session\"\n        \n        client.delete_session()\n        \n        call_args = mock_session.delete.call_args\n        assert \"stored-session\" in call_args[0][0]\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    @patch('agentcube.clients.control_plane.read_token_from_file')\n    def test_delete_session_no_session_id_warns(self, mock_read_token, mock_create_session):\n        \"\"\"GIVEN no session_id provided or stored\n           WHEN delete_session called\n           THEN logs warning and returns\"\"\"\n        mock_read_token.return_value = \"test-token\"\n        mock_session = Mock()\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.delete_session()\n        \n        mock_session.delete.assert_not_called()\n\n\nclass TestControlPlaneClientClose:\n    \"\"\"Tests for ControlPlaneClient.close().\"\"\"\n    \n    @patch('agentcube.clients.control_plane.create_session')\n    def test_close_calls_session_close(self, mock_create_session):\n        \"\"\"GIVEN close() called\n           WHEN method executes\n           THEN session.close() called\"\"\"\n        mock_session = Mock()\n        mock_create_session.return_value = mock_session\n        \n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.close()\n        \n        mock_session.close.assert_called_once()\n","additions":2,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_control_plane.py","time":{"start":1775890671770,"end":1775890672274}}}}
