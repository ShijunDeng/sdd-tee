home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_control_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_exceptions.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_agent_runtime_data_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter_data_plane.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/__init__.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/integration/test_agent_runtime.py":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter.py\n@@ -48,21 +48,22 @@\n     assert client.router_url == \"http://router-from-env:8080\"\n \n @patch('agentcube.code_interpreter.ControlPlaneClient')\n @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n-@patch('os.getenv', side_effect=[None, \"http://wm-from-env:8080\"])\n+@patch('os.getenv', side_effect=[\"http://router:8080\", \"http://wm-from-env:8080\"])\n def test_workload_manager_url_from_env(self, mock_getenv, mock_dp, mock_cp):\n     \"\"\"GIVEN workload_manager_url not provided but env var set\n        WHEN client initializes\n        THEN workload_manager_url from env\"\"\"\n     mock_cp.return_value.create_session.return_value = \"session-123\"\n     mock_dp.return_value = Mock()\n     \n     client = CodeInterpreterClient(\n-        router_url=\"http://router:8080\",\n+        router_url=None,\n         workload_manager_url=None\n     )\n     \n+    assert client.router_url == \"http://router:8080\"\n     assert client.workload_manager_url == \"http://wm-from-env:8080\"\n \n @patch('os.getenv', return_value=None)\n def test_missing_router_url_raises(self, mock_getenv):\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter.py","before":"\"\"\"Unit tests for CodeInterpreterClient.\"\"\"\n\nimport os\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube import CodeInterpreterClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\nclass TestCodeInterpreterClientInit:\n    \"\"\"Tests for CodeInterpreterClient.__init__().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_init_with_explicit_urls(self, mock_dp, mock_cp):\n        \"\"\"GIVEN router_url and workload_manager_url provided\n           WHEN client initializes\n           THEN URLs set correctly\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n            namespace=\"test\"\n        )\n        \n        assert client.router_url == \"http://router:8080\"\n        assert client.workload_manager_url == \"http://wm:8080\"\n        assert client.namespace == \"test\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    @patch('os.getenv', return_value=\"http://router-from-env:8080\")\n    def test_router_url_from_env(self, mock_getenv, mock_dp, mock_cp):\n        \"\"\"GIVEN router_url not provided but env var set\n           WHEN client initializes\n           THEN router_url from env\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=None,\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.router_url == \"http://router-from-env:8080\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    @patch('os.getenv', side_effect=[None, \"http://wm-from-env:8080\"])\n    def test_workload_manager_url_from_env(self, mock_getenv, mock_dp, mock_cp):\n        \"\"\"GIVEN workload_manager_url not provided but env var set\n           WHEN client initializes\n           THEN workload_manager_url from env\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=None\n        )\n        \n        assert client.workload_manager_url == \"http://wm-from-env:8080\"\n    \n    @patch('os.getenv', return_value=None)\n    def test_missing_router_url_raises(self, mock_getenv):\n        \"\"\"GIVEN router_url not provided and env var not set\n           WHEN client initializes\n           THEN ValueError raised\"\"\"\n        with pytest.raises(ValueError, match=\"router_url must be provided\"):\n            CodeInterpreterClient(\n                router_url=None,\n                workload_manager_url=\"http://wm:8080\"\n            )\n    \n    @patch('os.getenv', side_effect=[\"http://router:8080\", None])\n    def test_missing_workload_manager_url_raises(self, mock_getenv):\n        \"\"\"GIVEN workload_manager_url not provided and env var not set\n           WHEN client initializes\n           THEN ValueError raised\"\"\"\n        with pytest.raises(ValueError, match=\"workload_manager_url must be provided\"):\n            CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=None\n            )\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_timeout_defaults(self, mock_dp, mock_cp):\n        \"\"\"GIVEN timeout/connect_timeout not specified\n           WHEN client initializes\n           THEN defaults applied\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_namespace_default(self, mock_dp, mock_cp):\n        \"\"\"GIVEN namespace not specified\n           WHEN client initializes\n           THEN defaults to 'default'\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.namespace == \"default\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_init_without_session_id_creates_session(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id not provided\n           WHEN client initializes\n           THEN create_session called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"new-session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.session_id == \"new-session-123\"\n        mock_cp.return_value.create_session.assert_called_once()\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_init_with_explicit_session_id(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id provided\n           WHEN client initializes\n           THEN create_session NOT called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"new-session\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n            session_id=\"explicit-session\"\n        )\n        \n        assert client.session_id == \"explicit-session\"\n        mock_cp.return_value.create_session.assert_not_called()\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_verbose_sets_debug_level(self, mock_dp, mock_cp):\n        \"\"\"GIVEN verbose=True\n           WHEN client initializes\n           THEN logger level is DEBUG\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n            verbose=True\n        )\n        \n        assert client.logger.level == 10  # DEBUG level\n\n\nclass TestCodeInterpreterClientContextManager:\n    \"\"\"Tests for CodeInterpreterClient context manager protocol.\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_context_manager_enter(self, mock_dp, mock_cp):\n        \"\"\"GIVEN with statement used\n           WHEN entering context\n           THEN returns self\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        with client as c:\n            assert c is client\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_context_manager_exit_calls_close(self, mock_dp, mock_cp):\n        \"\"\"GIVEN context block exits\n           WHEN __exit__ called\n           THEN close() is called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.close = Mock()\n        \n        with client:\n            pass\n        \n        client.close.assert_called_once()\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_context_manager_exit_with_exception(self, mock_dp, mock_cp):\n        \"\"\"GIVEN context block raises exception\n           WHEN __exit__ called\n           THEN close() still called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.close = Mock()\n        \n        with pytest.raises(ValueError):\n            with client:\n                raise ValueError(\"test error\")\n        \n        client.close.assert_called_once()\n\n\nclass TestCodeInterpreterClientExecute:\n    \"\"\"Tests for CodeInterpreterClient.execute().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_with_code(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id initialized\n           WHEN execute called with code\n           THEN dp_client.execute called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value.execute.return_value = Mock(\n            json=lambda: {\"output\": \"hello\", \"exit_code\": 0}\n        )\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        result = client.execute(\"print('hello')\")\n        \n        mock_dp.return_value.execute.assert_called_once_with(\n            session_id=\"session-123\",\n            code=\"print('hello')\",\n            language=\"python\",\n            timeout=None\n        )\n        assert result == {\"output\": \"hello\", \"exit_code\": 0}\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_with_language(self, mock_dp, mock_cp):\n        \"\"\"GIVEN execute called with language\n           WHEN request sent\n           THEN language passed to dp_client\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value.execute.return_value = Mock(\n            json=lambda: {\"output\": \"hello\", \"exit_code\": 0}\n        )\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.execute(\"puts 'hello'\", language=\"ruby\")\n        \n        call_args = mock_dp.return_value.execute.call_args\n        assert call_args[1]['language'] == \"ruby\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_with_timeout_override(self, mock_dp, mock_cp):\n        \"\"\"GIVEN execute called with timeout=60\n           WHEN request sent\n           THEN timeout=60 passed to dp_client\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value.execute.return_value = Mock(\n            json=lambda: {\"output\": \"hello\", \"exit_code\": 0}\n        )\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.execute(\"print('hello')\", timeout=60)\n        \n        call_args = mock_dp.return_value.execute.call_args\n        assert call_args[1]['timeout'] == 60\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_returns_parsed_json(self, mock_dp, mock_cp):\n        \"\"\"GIVEN dp_client.execute returns response\n           WHEN execute completes\n           THEN parsed JSON returned\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_response = Mock()\n        mock_response.json.return_value = {\n            \"output\": \"2\",\n            \"exit_code\": 0,\n            \"stdout\": \"2\\n\"\n        }\n        mock_dp.return_value.execute.return_value = mock_response\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        result = client.execute(\"print(1 + 1)\")\n        \n        assert result == {\"output\": \"2\", \"exit_code\": 0, \"stdout\": \"2\\n\"}\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_nonzero_exit_raises(self, mock_dp, mock_cp):\n        \"\"\"GIVEN code execution returns non-zero exit code\n           WHEN execute completes\n           THEN CommandExecutionError raised\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_response = Mock()\n        mock_response.json.return_value = {\n            \"output\": \"error\",\n            \"exit_code\": 1,\n            \"stderr\": \"RuntimeError\"\n        }\n        mock_dp.return_value.execute.return_value = mock_response\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        with pytest.raises(CommandExecutionError) as exc_info:\n            client.execute(\"raise RuntimeError()\")\n        \n        assert exc_info.value.exit_code == 1\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_without_session_raises(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id is None\n           WHEN execute called\n           THEN ValueError raised\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.session_id = None\n        \n        with pytest.raises(ValueError, match=\"CodeInterpreter session_id is not initialized\"):\n            client.execute(\"print('hello')\")\n\n\nclass TestCodeInterpreterClientUploadFile:\n    \"\"\"Tests for CodeInterpreterClient.upload_file().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_upload_file(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id initialized\n           WHEN upload_file called\n           THEN dp_client.upload_file called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value.upload_file.return_value = Mock(\n            json=lambda: {\"status\": \"uploaded\"}\n        )\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        result = client.upload_file(\"data.txt\", b\"test data\")\n        \n        mock_dp.return_value.upload_file.assert_called_once_with(\n            session_id=\"session-123\",\n            file_path=\"data.txt\",\n            file_content=b\"test data\",\n            timeout=None\n        )\n        assert result == {\"status\": \"uploaded\"}\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_upload_file_without_session_raises(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id is None\n           WHEN upload_file called\n           THEN ValueError raised\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.session_id = None\n        \n        with pytest.raises(ValueError, match=\"CodeInterpreter session_id is not initialized\"):\n            client.upload_file(\"data.txt\", b\"test data\")\n\n\nclass TestCodeInterpreterClientDownloadFile:\n    \"\"\"Tests for CodeInterpreterClient.download_file().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_download_file(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id initialized\n           WHEN download_file called\n           THEN dp_client.download_file called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_response = Mock()\n        mock_response.content = b\"file content\"\n        mock_dp.return_value.download_file.return_value = mock_response\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        result = client.download_file(\"data.txt\")\n        \n        mock_dp.return_value.download_file.assert_called_once_with(\n            session_id=\"session-123\",\n            file_path=\"data.txt\",\n            timeout=None\n        )\n        assert result == b\"file content\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_download_file_without_session_raises(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id is None\n           WHEN download_file called\n           THEN ValueError raised\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.session_id = None\n        \n        with pytest.raises(ValueError, match=\"CodeInterpreter session_id is not initialized\"):\n            client.download_file(\"data.txt\")\n\n\nclass TestCodeInterpreterClientClose:\n    \"\"\"Tests for CodeInterpreterClient.close().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_close_calls_dp_client_close(self, mock_dp, mock_cp):\n        \"\"\"GIVEN close() called\n           WHEN method executes\n           THEN dp_client.close() called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.close()\n        \n        mock_dp.return_value.close.assert_called_once()\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_close_calls_cp_client_delete_session(self, mock_dp, mock_cp):\n        \"\"\"GIVEN close() called\n           WHEN method executes\n           THEN cp_client.delete_session() called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.close()\n        \n        mock_cp.return_value.delete_session.assert_called_once_with(\"session-123\")\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_close_calls_cp_client_close(self, mock_dp, mock_cp):\n        \"\"\"GIVEN close() called\n           WHEN method executes\n           THEN cp_client.close() called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.close()\n        \n        mock_cp.return_value.close.assert_called_once()\n","after":"\"\"\"Unit tests for CodeInterpreterClient.\"\"\"\n\nimport os\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube import CodeInterpreterClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\nclass TestCodeInterpreterClientInit:\n    \"\"\"Tests for CodeInterpreterClient.__init__().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_init_with_explicit_urls(self, mock_dp, mock_cp):\n        \"\"\"GIVEN router_url and workload_manager_url provided\n           WHEN client initializes\n           THEN URLs set correctly\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n            namespace=\"test\"\n        )\n        \n        assert client.router_url == \"http://router:8080\"\n        assert client.workload_manager_url == \"http://wm:8080\"\n        assert client.namespace == \"test\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    @patch('os.getenv', return_value=\"http://router-from-env:8080\")\n    def test_router_url_from_env(self, mock_getenv, mock_dp, mock_cp):\n        \"\"\"GIVEN router_url not provided but env var set\n           WHEN client initializes\n           THEN router_url from env\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=None,\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.router_url == \"http://router-from-env:8080\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    @patch('os.getenv', side_effect=[\"http://router:8080\", \"http://wm-from-env:8080\"])\n    def test_workload_manager_url_from_env(self, mock_getenv, mock_dp, mock_cp):\n        \"\"\"GIVEN workload_manager_url not provided but env var set\n           WHEN client initializes\n           THEN workload_manager_url from env\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=None,\n            workload_manager_url=None\n        )\n        \n        assert client.router_url == \"http://router:8080\"\n        assert client.workload_manager_url == \"http://wm-from-env:8080\"\n    \n    @patch('os.getenv', return_value=None)\n    def test_missing_router_url_raises(self, mock_getenv):\n        \"\"\"GIVEN router_url not provided and env var not set\n           WHEN client initializes\n           THEN ValueError raised\"\"\"\n        with pytest.raises(ValueError, match=\"router_url must be provided\"):\n            CodeInterpreterClient(\n                router_url=None,\n                workload_manager_url=\"http://wm:8080\"\n            )\n    \n    @patch('os.getenv', side_effect=[\"http://router:8080\", None])\n    def test_missing_workload_manager_url_raises(self, mock_getenv):\n        \"\"\"GIVEN workload_manager_url not provided and env var not set\n           WHEN client initializes\n           THEN ValueError raised\"\"\"\n        with pytest.raises(ValueError, match=\"workload_manager_url must be provided\"):\n            CodeInterpreterClient(\n                router_url=\"http://router:8080\",\n                workload_manager_url=None\n            )\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_timeout_defaults(self, mock_dp, mock_cp):\n        \"\"\"GIVEN timeout/connect_timeout not specified\n           WHEN client initializes\n           THEN defaults applied\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_namespace_default(self, mock_dp, mock_cp):\n        \"\"\"GIVEN namespace not specified\n           WHEN client initializes\n           THEN defaults to 'default'\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.namespace == \"default\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_init_without_session_id_creates_session(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id not provided\n           WHEN client initializes\n           THEN create_session called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"new-session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        assert client.session_id == \"new-session-123\"\n        mock_cp.return_value.create_session.assert_called_once()\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_init_with_explicit_session_id(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id provided\n           WHEN client initializes\n           THEN create_session NOT called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"new-session\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n            session_id=\"explicit-session\"\n        )\n        \n        assert client.session_id == \"explicit-session\"\n        mock_cp.return_value.create_session.assert_not_called()\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_verbose_sets_debug_level(self, mock_dp, mock_cp):\n        \"\"\"GIVEN verbose=True\n           WHEN client initializes\n           THEN logger level is DEBUG\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\",\n            verbose=True\n        )\n        \n        assert client.logger.level == 10  # DEBUG level\n\n\nclass TestCodeInterpreterClientContextManager:\n    \"\"\"Tests for CodeInterpreterClient context manager protocol.\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_context_manager_enter(self, mock_dp, mock_cp):\n        \"\"\"GIVEN with statement used\n           WHEN entering context\n           THEN returns self\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        with client as c:\n            assert c is client\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_context_manager_exit_calls_close(self, mock_dp, mock_cp):\n        \"\"\"GIVEN context block exits\n           WHEN __exit__ called\n           THEN close() is called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.close = Mock()\n        \n        with client:\n            pass\n        \n        client.close.assert_called_once()\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_context_manager_exit_with_exception(self, mock_dp, mock_cp):\n        \"\"\"GIVEN context block raises exception\n           WHEN __exit__ called\n           THEN close() still called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.close = Mock()\n        \n        with pytest.raises(ValueError):\n            with client:\n                raise ValueError(\"test error\")\n        \n        client.close.assert_called_once()\n\n\nclass TestCodeInterpreterClientExecute:\n    \"\"\"Tests for CodeInterpreterClient.execute().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_with_code(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id initialized\n           WHEN execute called with code\n           THEN dp_client.execute called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value.execute.return_value = Mock(\n            json=lambda: {\"output\": \"hello\", \"exit_code\": 0}\n        )\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        result = client.execute(\"print('hello')\")\n        \n        mock_dp.return_value.execute.assert_called_once_with(\n            session_id=\"session-123\",\n            code=\"print('hello')\",\n            language=\"python\",\n            timeout=None\n        )\n        assert result == {\"output\": \"hello\", \"exit_code\": 0}\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_with_language(self, mock_dp, mock_cp):\n        \"\"\"GIVEN execute called with language\n           WHEN request sent\n           THEN language passed to dp_client\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value.execute.return_value = Mock(\n            json=lambda: {\"output\": \"hello\", \"exit_code\": 0}\n        )\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.execute(\"puts 'hello'\", language=\"ruby\")\n        \n        call_args = mock_dp.return_value.execute.call_args\n        assert call_args[1]['language'] == \"ruby\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_with_timeout_override(self, mock_dp, mock_cp):\n        \"\"\"GIVEN execute called with timeout=60\n           WHEN request sent\n           THEN timeout=60 passed to dp_client\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value.execute.return_value = Mock(\n            json=lambda: {\"output\": \"hello\", \"exit_code\": 0}\n        )\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.execute(\"print('hello')\", timeout=60)\n        \n        call_args = mock_dp.return_value.execute.call_args\n        assert call_args[1]['timeout'] == 60\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_returns_parsed_json(self, mock_dp, mock_cp):\n        \"\"\"GIVEN dp_client.execute returns response\n           WHEN execute completes\n           THEN parsed JSON returned\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_response = Mock()\n        mock_response.json.return_value = {\n            \"output\": \"2\",\n            \"exit_code\": 0,\n            \"stdout\": \"2\\n\"\n        }\n        mock_dp.return_value.execute.return_value = mock_response\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        result = client.execute(\"print(1 + 1)\")\n        \n        assert result == {\"output\": \"2\", \"exit_code\": 0, \"stdout\": \"2\\n\"}\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_nonzero_exit_raises(self, mock_dp, mock_cp):\n        \"\"\"GIVEN code execution returns non-zero exit code\n           WHEN execute completes\n           THEN CommandExecutionError raised\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_response = Mock()\n        mock_response.json.return_value = {\n            \"output\": \"error\",\n            \"exit_code\": 1,\n            \"stderr\": \"RuntimeError\"\n        }\n        mock_dp.return_value.execute.return_value = mock_response\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        with pytest.raises(CommandExecutionError) as exc_info:\n            client.execute(\"raise RuntimeError()\")\n        \n        assert exc_info.value.exit_code == 1\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_execute_without_session_raises(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id is None\n           WHEN execute called\n           THEN ValueError raised\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.session_id = None\n        \n        with pytest.raises(ValueError, match=\"CodeInterpreter session_id is not initialized\"):\n            client.execute(\"print('hello')\")\n\n\nclass TestCodeInterpreterClientUploadFile:\n    \"\"\"Tests for CodeInterpreterClient.upload_file().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_upload_file(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id initialized\n           WHEN upload_file called\n           THEN dp_client.upload_file called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value.upload_file.return_value = Mock(\n            json=lambda: {\"status\": \"uploaded\"}\n        )\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        result = client.upload_file(\"data.txt\", b\"test data\")\n        \n        mock_dp.return_value.upload_file.assert_called_once_with(\n            session_id=\"session-123\",\n            file_path=\"data.txt\",\n            file_content=b\"test data\",\n            timeout=None\n        )\n        assert result == {\"status\": \"uploaded\"}\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_upload_file_without_session_raises(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id is None\n           WHEN upload_file called\n           THEN ValueError raised\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.session_id = None\n        \n        with pytest.raises(ValueError, match=\"CodeInterpreter session_id is not initialized\"):\n            client.upload_file(\"data.txt\", b\"test data\")\n\n\nclass TestCodeInterpreterClientDownloadFile:\n    \"\"\"Tests for CodeInterpreterClient.download_file().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_download_file(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id initialized\n           WHEN download_file called\n           THEN dp_client.download_file called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_response = Mock()\n        mock_response.content = b\"file content\"\n        mock_dp.return_value.download_file.return_value = mock_response\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        result = client.download_file(\"data.txt\")\n        \n        mock_dp.return_value.download_file.assert_called_once_with(\n            session_id=\"session-123\",\n            file_path=\"data.txt\",\n            timeout=None\n        )\n        assert result == b\"file content\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_download_file_without_session_raises(self, mock_dp, mock_cp):\n        \"\"\"GIVEN session_id is None\n           WHEN download_file called\n           THEN ValueError raised\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        client.session_id = None\n        \n        with pytest.raises(ValueError, match=\"CodeInterpreter session_id is not initialized\"):\n            client.download_file(\"data.txt\")\n\n\nclass TestCodeInterpreterClientClose:\n    \"\"\"Tests for CodeInterpreterClient.close().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_close_calls_dp_client_close(self, mock_dp, mock_cp):\n        \"\"\"GIVEN close() called\n           WHEN method executes\n           THEN dp_client.close() called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.close()\n        \n        mock_dp.return_value.close.assert_called_once()\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_close_calls_cp_client_delete_session(self, mock_dp, mock_cp):\n        \"\"\"GIVEN close() called\n           WHEN method executes\n           THEN cp_client.delete_session() called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.close()\n        \n        mock_cp.return_value.delete_session.assert_called_once_with(\"session-123\")\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_close_calls_cp_client_close(self, mock_dp, mock_cp):\n        \"\"\"GIVEN close() called\n           WHEN method executes\n           THEN cp_client.close() called\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"\n        mock_dp.return_value = Mock()\n        \n        client = CodeInterpreterClient(\n            router_url=\"http://router:8080\",\n            workload_manager_url=\"http://wm:8080\"\n        )\n        \n        client.close()\n        \n        mock_cp.return_value.close.assert_called_once()\n","additions":3,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter.py","time":{"start":1775890646603,"end":1775890647230}}}}
