{"type":"tool_use","timestamp":1775890582765,"sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","part":{"id":"prt_d7b53b70f001amoVwxi4w15Kq9","messageID":"msg_d7b53a93e001TeP4PbsNu5GapJ","sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","type":"tool","tool":"read","callID":"toolu_26a3172867fe425688053c85","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/control_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/control_plane.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Control Plane Client for the agentcube SDK.\"\"\"\n2: \n3: import logging\n4: import os\n5: from typing import Any, Dict, Optional\n6: from urllib.parse import urljoin\n7: \n8: import requests\n9: \n10: from ..exceptions import SessionError\n11: from ..utils.http import create_session\n12: from ..utils.log import get_logger\n13: from ..utils.utils import read_token_from_file\n14: \n15: \n16: class ControlPlaneClient:\n17:     \"\"\"Client for interacting with the Workload Manager (control plane).\n18:     \n19:     This client handles session lifecycle management including creating\n20:     and deleting sessions via the Workload Manager API.\n21:     \n22:     Attributes:\n23:         workload_manager_url: Workload Manager base URL\n24:         namespace: Kubernetes namespace\n25:         session_id: Current session identifier\n26:         timeout: Request timeout in seconds\n27:         connect_timeout: Connection timeout in seconds\n28:         session: HTTP session with connection pooling\n29:         logger: Module logger\n30:     \n31:     Example usage:\n32:         # Create a session\n33:         client = ControlPlaneClient(\n34:             workload_manager_url=\"http://workload-manager:8080\",\n35:             namespace=\"default\"\n36:         )\n37:         try:\n38:             session_id = client.create_session()\n39:             print(f\"Created session: {session_id}\")\n40:         finally:\n41:             client.delete_session(session_id)\n42:             client.close()\n43:     \"\"\"\n44:     \n45:     def __init__(\n46:         self,\n47:         workload_manager_url: Optional[str] = None,\n48:         namespace: str = \"default\",\n49:         timeout: float = 120.0,\n50:         connect_timeout: float = 5.0,\n51:         pool_connections: int = 10,\n52:         pool_maxsize: int = 10,\n53:         token_path: Optional[str] = None,\n54:     ) -> None:\n55:         \"\"\"Initialize ControlPlaneClient.\n56:         \n57:         Args:\n58:             workload_manager_url: Workload Manager base URL. Resolves from\n59:                                 arg or WORKLOAD_MANAGER_URL env var.\n60:             namespace: Kubernetes namespace (default: \"default\")\n61:             timeout: Request timeout in seconds (default: 120)\n62:             connect_timeout: Connection timeout in seconds (default: 5.0)\n63:             pool_connections: Number of connection pool slots (default: 10)\n64:             pool_maxsize: Maximum connections per host (default: 10)\n65:             token_path: Path to Kubernetes SA token file. If None, uses\n66:                        default path or WORKLOAD_MANAGER_TOKEN_PATH env var.\n67:         \n68:         Raises:\n69:             ValueError: If workload_manager_url not provided and\n70:                        WORKLOAD_MANAGER_URL env var not set\n71:         \"\"\"\n72:         self.namespace = namespace\n73:         self.timeout = timeout\n74:         self.connect_timeout = connect_timeout\n75:         self.logger = get_logger(__name__)\n76:         \n77:         self.workload_manager_url: str = workload_manager_url or os.getenv(\"WORKLOAD_MANAGER_URL\")  # type: ignore\n78:         if not self.workload_manager_url:\n79:             raise ValueError(\n80:                 \"workload_manager_url must be provided or \"\n81:                 \"WORKLOAD_MANAGER_URL environment variable must be set\"\n82:             )\n83:         \n84:         token_path = token_path or os.getenv(\"WORKLOAD_MANAGER_TOKEN_PATH\")\n85:         self.token_path = token_path\n86:         \n87:         self.session = create_session(\n88:             pool_connections=pool_connections,\n89:             pool_maxsize=pool_maxsize,\n90:         )\n91:         \n92:         self.session_id: Optional[str] = None\n93:         \n94:         self.logger.debug(\n95:             f\"Initialized ControlPlaneClient with workload_manager_url: {self.workload_manager_url}\"\n96:         )\n97:     \n98:     def _get_auth_headers(self) -> Dict[str, str]:\n99:         \"\"\"Get authentication headers for API requests.\n100:         \n101:         Returns:\n102:             Dict containing Authorization header with Bearer token\n103:         \"\"\"\n104:         token = read_token_from_file(self.token_path)\n105:         return {\"Authorization\": f\"Bearer {token}\"}\n106:     \n107:     def create_session(self) -> str:\n108:         \"\"\"Create a new session with the Workload Manager.\n109:         \n110:         Makes a POST request to create a session and stores the\n111:         returned session_id.\n112:         \n113:         Returns:\n114:             Session ID from the response\n115:         \n116:         Raises:\n117:             SessionError: If session creation fails\n118:             requests.RequestException: On HTTP errors\n119:         \"\"\"\n120:         url = urljoin(\n121:             self.workload_manager_url,\n122:             f\"/v1/namespaces/{self.namespace}/sessions/\",\n123:         )\n124:         \n125:         self.logger.debug(f\"Creating session at {url}\")\n126:         \n127:         try:\n128:             response = self.session.post(\n129:                 url,\n130:                 headers=self._get_auth_headers(),\n131:                 timeout=(self.connect_timeout, self.timeout),\n132:             )\n133:             response.raise_for_status()\n134:             \n135:             data = response.json()\n136:             self.session_id = data.get(\"session_id\")\n137:             \n138:             if not self.session_id:\n139:                 raise SessionError(\"Response missing session_id field\")\n140:             \n141:             self.logger.debug(f\"Created session: {self.session_id}\")\n142:             return self.session_id\n143:             \n144:         except requests.HTTPError as e:\n145:             raise SessionError(f\"Failed to create session: {e}\") from e\n146:         except requests.RequestException as e:\n147:             raise SessionError(f\"Network error creating session: {e}\") from e\n148:     \n149:     def delete_session(self, session_id: Optional[str] = None) -> None:\n150:         \"\"\"Delete a session from the Workload Manager.\n151:         \n152:         Args:\n153:             session_id: Session ID to delete. If None, uses the\n154:                        session_id from create_session().\n155:         \n156:         Raises:\n157:             SessionError: If session deletion fails\n158:             requests.RequestException: On HTTP errors\n159:         \n160:         Note:\n161:             A 404 response is treated as success (session already deleted).\n162:         \"\"\"\n163:         sid = session_id or self.session_id\n164:         if not sid:\n165:             self.logger.warning(\"No session_id provided for deletion\")\n166:             return\n167:         \n168:         url = urljoin(\n169:             self.workload_manager_url,\n170:             f\"/v1/namespaces/{self.namespace}/sessions/{sid}/\",\n171:         )\n172:         \n173:         self.logger.debug(f\"Deleting session {sid} at {url}\")\n174:         \n175:         try:\n176:             response = self.session.delete(\n177:                 url,\n178:                 headers=self._get_auth_headers(),\n179:                 timeout=(self.connect_timeout, self.timeout),\n180:             )\n181:             \n182:             if response.status_code == 404:\n183:                 self.logger.debug(f\"Session {sid} not found (already deleted)\")\n184:                 return\n185:             \n186:             response.raise_for_status()\n187:             self.logger.debug(f\"Deleted session: {sid}\")\n188:             \n189:         except requests.HTTPError as e:\n190:             raise SessionError(f\"Failed to delete session {sid}: {e}\") from e\n191:         except requests.RequestException as e:\n192:             raise SessionError(f\"Network error deleting session {sid}: {e}\") from e\n193:     \n194:     def close(self) -> None:\n195:         \"\"\"Close the underlying HTTP session.\n196:         \n197:         This method should be called when the client is no longer needed\n198:         to release connection pool resources.\n199:         \"\"\"\n200:         self.session.close()\n201:         self.logger.debug(\"ControlPlaneClient closed\")\n\n(End of file - total 201 lines)\n</content>","metadata":{"preview":"\"\"\"Control Plane Client for the agentcube SDK.\"\"\"\n\nimport logging\nimport os\nfrom typing import Any, Dict, Optional\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom ..exceptions import SessionError\nfrom ..utils.http import create_session\nfrom ..utils.log import get_logger\nfrom ..utils.utils import read_token_from_file\n\n\nclass ControlPlaneClient:\n    \"\"\"Client for interacting with the Workload Manager (control plane).\n    \n    This client handles session lifecycle management including creating\n    and deleting sessions via the Workload Manager API.","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/control_plane.py","time":{"start":1775890582736,"end":1775890582763}}}}
