{"type":"tool_use","timestamp":1775890607482,"sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","part":{"id":"prt_d7b5425d1001hmGSGZMlvNleiR","messageID":"msg_d7b541272001uXs5vn7s4IZNhR","sessionID":"ses_284acb481ffeOhIeCq8x1sVp7S","type":"tool","tool":"read","callID":"toolu_88ecf1e96348484cbf77f66a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_agent_runtime_data_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_agent_runtime_data_plane.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Unit tests for AgentRuntimeDataPlaneClient.\"\"\"\n2: \n3: import pytest\n4: from unittest.mock import Mock, patch, MagicMock\n5: from agentcube.clients import AgentRuntimeDataPlaneClient\n6: \n7: \n8: class TestAgentRuntimeDataPlaneClientInit:\n9:     \"\"\"Tests for AgentRuntimeDataPlaneClient.__init__().\"\"\"\n10:     \n11:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n12:     def test_base_url_computation(self, mock_create_session):\n13:         \"\"\"GIVEN router_url, namespace, agent_name provided\n14:            WHEN client initializes\n15:            THEN base_url computed correctly\"\"\"\n16:         mock_create_session.return_value = Mock()\n17:         \n18:         client = AgentRuntimeDataPlaneClient(\n19:             router_url=\"http://router:8080\",\n20:             namespace=\"default\",\n21:             agent_name=\"test-agent\"\n22:         )\n23:         \n24:         expected = \"http://router:8080/v1/namespaces/default/agent-runtimes/test-agent/invocations/\"\n25:         assert client.base_url == expected\n26:     \n27:     def test_session_header_constant(self):\n28:         \"\"\"GIVEN class constant accessed\n29:            WHEN SESSION_HEADER read\n30:            THEN equals lowercase header name\"\"\"\n31:         assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n32:     \n33:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n34:     def test_timeout_defaults(self, mock_create_session):\n35:         \"\"\"GIVEN timeout/connect_timeout not specified\n36:            WHEN client initializes\n37:            THEN defaults applied\"\"\"\n38:         mock_create_session.return_value = Mock()\n39:         \n40:         client = AgentRuntimeDataPlaneClient(\n41:             router_url=\"http://router:8080\",\n42:             namespace=\"default\",\n43:             agent_name=\"test-agent\"\n44:         )\n45:         \n46:         assert client.timeout == 120\n47:         assert client.connect_timeout == 5.0\n48:     \n49:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n50:     def test_session_created_with_pooling(self, mock_create_session):\n51:         \"\"\"GIVEN client initializes\n52:            WHEN create_session called\n53:            THEN pool_connections=10 and pool_maxsize=10\"\"\"\n54:         mock_create_session.return_value = Mock()\n55:         \n56:         client = AgentRuntimeDataPlaneClient(\n57:             router_url=\"http://router:8080\",\n58:             namespace=\"default\",\n59:             agent_name=\"test-agent\"\n60:         )\n61:         \n62:         mock_create_session.assert_called_once_with(\n63:             pool_connections=10,\n64:             pool_maxsize=10,\n65:         )\n66: \n67: \n68: class TestAgentRuntimeDataPlaneClientBootstrap:\n69:     \"\"\"Tests for AgentRuntimeDataPlaneClient.bootstrap_session_id().\"\"\"\n70:     \n71:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n72:     def test_successful_bootstrap(self, mock_create_session):\n73:         \"\"\"GIVEN Router responds with session header\n74:            WHEN bootstrap_session_id called\n75:            THEN header value returned\"\"\"\n76:         mock_headers = {}\n77:         mock_session = Mock()\n78:         mock_session.headers = mock_headers\n79:         mock_session.get.return_value.headers = {\n80:             \"x-agentcube-session-id\": \"bootstrapped-session-123\"\n81:         }\n82:         mock_create_session.return_value = mock_session\n83:         \n84:         client = AgentRuntimeDataPlaneClient(\n85:             router_url=\"http://router:8080\",\n86:             namespace=\"default\",\n87:             agent_name=\"test-agent\"\n88:         )\n89:         \n90:         result = client.bootstrap_session_id()\n91:         \n92:         assert result == \"bootstrapped-session-123\"\n93:     \n94:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n95:     def test_missing_header_raises(self, mock_create_session):\n96:         \"\"\"GIVEN Response lacks session header\n97:            WHEN bootstrap_session_id called\n98:            THEN ValueError raised\"\"\"\n99:         mock_headers = {}\n100:         mock_session = Mock()\n101:         mock_session.headers = mock_headers\n102:         mock_session.get.return_value.headers = {}\n103:         mock_create_session.return_value = mock_session\n104:         \n105:         client = AgentRuntimeDataPlaneClient(\n106:             router_url=\"http://router:8080\",\n107:             namespace=\"default\",\n108:             agent_name=\"test-agent\"\n109:         )\n110:         \n111:         with pytest.raises(ValueError, match=\"Missing required response header: x-agentcube-session-id\"):\n112:             client.bootstrap_session_id()\n113:     \n114:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n115:     def test_bootstrap_makes_get_request(self, mock_create_session):\n116:         \"\"\"GIVEN bootstrap_session_id called\n117:            WHEN request sent\n118:            THEN GET to base_url with timeout tuple\"\"\"\n119:         mock_headers = {}\n120:         mock_session = Mock()\n121:         mock_session.headers = mock_headers\n122:         mock_session.get.return_value.headers = {\n123:             \"x-agentcube-session-id\": \"session-123\"\n124:         }\n125:         mock_create_session.return_value = mock_session\n126:         \n127:         client = AgentRuntimeDataPlaneClient(\n128:             router_url=\"http://router:8080\",\n129:             namespace=\"default\",\n130:             agent_name=\"test-agent\"\n131:         )\n132:         \n133:         client.bootstrap_session_id()\n134:         \n135:         mock_session.get.assert_called_once_with(\n136:             client.base_url,\n137:             timeout=(client.connect_timeout, client.timeout)\n138:         )\n139:     \n140:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n141:     def test_bootstrap_sets_session_header(self, mock_create_session):\n142:         \"\"\"GIVEN bootstrap succeeds\n143:            WHEN session header checked\n144:            THEN it is set to bootstrapped value\"\"\"\n145:         mock_headers = {}\n146:         mock_session = Mock()\n147:         mock_session.headers = mock_headers\n148:         mock_session.get.return_value.headers = {\n149:             \"x-agentcube-session-id\": \"bootstrapped-456\"\n150:         }\n151:         mock_create_session.return_value = mock_session\n152:         \n153:         client = AgentRuntimeDataPlaneClient(\n154:             router_url=\"http://router:8080\",\n155:             namespace=\"default\",\n156:             agent_name=\"test-agent\"\n157:         )\n158:         \n159:         client.bootstrap_session_id()\n160:         \n161:         assert mock_session.headers[\"x-agentcube-session-id\"] == \"bootstrapped-456\"\n162: \n163: \n164: class TestAgentRuntimeDataPlaneClientInvoke:\n165:     \"\"\"Tests for AgentRuntimeDataPlaneClient.invoke().\"\"\"\n166:     \n167:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n168:     def test_invoke_sends_post_request(self, mock_create_session):\n169:         \"\"\"GIVEN invoke called with payload\n170:            WHEN request sent\n171:            THEN POST to base_url with JSON body\"\"\"\n172:         mock_session = Mock()\n173:         mock_session.post.return_value = Mock()\n174:         mock_create_session.return_value = mock_session\n175:         \n176:         client = AgentRuntimeDataPlaneClient(\n177:             router_url=\"http://router:8080\",\n178:             namespace=\"default\",\n179:             agent_name=\"test-agent\"\n180:         )\n181:         \n182:         payload = {\"message\": \"hello\", \"data\": [1, 2, 3]}\n183:         client.invoke(session_id=\"test-session\", payload=payload)\n184:         \n185:         mock_session.post.assert_called_once()\n186:         call_args = mock_session.post.call_args\n187:         assert call_args[0][0] == client.base_url\n188:         assert call_args[1]['json'] == payload\n189:     \n190:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n191:     def test_invoke_sets_session_header(self, mock_create_session):\n192:         \"\"\"GIVEN invoke called\n193:            WHEN headers constructed\n194:            THEN x-agentcube-session-id included\"\"\"\n195:         mock_session = Mock()\n196:         mock_session.post.return_value = Mock()\n197:         mock_create_session.return_value = mock_session\n198:         \n199:         client = AgentRuntimeDataPlaneClient(\n200:             router_url=\"http://router:8080\",\n201:             namespace=\"default\",\n202:             agent_name=\"test-agent\"\n203:         )\n204:         \n205:         client.invoke(session_id=\"test-session\", payload={\"test\": \"data\"})\n206:         \n207:         headers = mock_session.post.call_args[1]['headers']\n208:         assert headers[\"x-agentcube-session-id\"] == \"test-session\"\n209:     \n210:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n211:     def test_invoke_sets_content_type_header(self, mock_create_session):\n212:         \"\"\"GIVEN invoke called\n213:            WHEN headers constructed\n214:            THEN Content-Type: application/json included\"\"\"\n215:         mock_session = Mock()\n216:         mock_session.post.return_value = Mock()\n217:         mock_create_session.return_value = mock_session\n218:         \n219:         client = AgentRuntimeDataPlaneClient(\n220:             router_url=\"http://router:8080\",\n221:             namespace=\"default\",\n222:             agent_name=\"test-agent\"\n223:         )\n224:         \n225:         client.invoke(session_id=\"test-session\", payload={\"test\": \"data\"})\n226:         \n227:         headers = mock_session.post.call_args[1]['headers']\n228:         assert headers[\"Content-Type\"] == \"application/json\"\n229:     \n230:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n231:     def test_invoke_timeout_default(self, mock_create_session):\n232:         \"\"\"GIVEN invoke called without timeout\n233:            WHEN request sent\n234:            THEN timeout tuple with instance default used\"\"\"\n235:         mock_session = Mock()\n236:         mock_session.post.return_value = Mock()\n237:         mock_create_session.return_value = mock_session\n238:         \n239:         client = AgentRuntimeDataPlaneClient(\n240:             router_url=\"http://router:8080\",\n241:             namespace=\"default\",\n242:             agent_name=\"test-agent\",\n243:             timeout=120,\n244:             connect_timeout=5.0\n245:         )\n246:         \n247:         client.invoke(session_id=\"test-session\", payload={\"test\": \"data\"})\n248:         \n249:         timeout = mock_session.post.call_args[1]['timeout']\n250:         assert timeout == (5.0, 120)\n251:     \n252:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n253:     def test_invoke_timeout_override(self, mock_create_session):\n254:         \"\"\"GIVEN invoke called with timeout=60\n255:            WHEN request sent\n256:            THEN timeout tuple uses override\"\"\"\n257:         mock_session = Mock()\n258:         mock_session.post.return_value = Mock()\n259:         mock_create_session.return_value = mock_session\n260:         \n261:         client = AgentRuntimeDataPlaneClient(\n262:             router_url=\"http://router:8080\",\n263:             namespace=\"default\",\n264:             agent_name=\"test-agent\"\n265:         )\n266:         \n267:         client.invoke(session_id=\"test-session\", payload={\"test\": \"data\"}, timeout=60)\n268:         \n269:         timeout = mock_session.post.call_args[1]['timeout']\n270:         assert timeout == (client.connect_timeout, 60)\n271:     \n272:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n273:     def test_invoke_returns_response(self, mock_create_session):\n274:         \"\"\"GIVEN invoke completes successfully\n275:            WHEN response received\n276:            THEN requests.Response object returned\"\"\"\n277:         mock_session = Mock()\n278:         mock_response = Mock()\n279:         mock_session.post.return_value = mock_response\n280:         mock_create_session.return_value = mock_session\n281:         \n282:         client = AgentRuntimeDataPlaneClient(\n283:             router_url=\"http://router:8080\",\n284:             namespace=\"default\",\n285:             agent_name=\"test-agent\"\n286:         )\n287:         \n288:         result = client.invoke(session_id=\"test-session\", payload={\"test\": \"data\"})\n289:         \n290:         assert result is mock_response\n291: \n292: \n293: class TestAgentRuntimeDataPlaneClientClose:\n294:     \"\"\"Tests for AgentRuntimeDataPlaneClient.close().\"\"\"\n295:     \n296:     @patch('agentcube.clients.agent_runtime_data_plane.create_session')\n297:     def test_close_calls_session_close(self, mock_create_session):\n298:         \"\"\"GIVEN close() called\n299:            WHEN method executes\n