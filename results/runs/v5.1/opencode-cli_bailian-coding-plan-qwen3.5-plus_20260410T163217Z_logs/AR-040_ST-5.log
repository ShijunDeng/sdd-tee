ections: int = 10,\n40:         pool_maxsize: int = 10,\n41:     ) -> None:\n42:         \"\"\"Initialize AgentRuntimeDataPlaneClient.\n43:         \n44:         Args:\n45:             router_url: Router base URL\n46:             namespace: Kubernetes namespace\n47:             agent_name: Target agent runtime name\n48:             timeout: Request timeout in seconds (default: 120)\n49:             connect_timeout: Connection timeout in seconds (default: 5.0)\n50:             pool_connections: Number of connection pool slots (default: 10)\n51:             pool_maxsize: Maximum connections per host (default: 10)\n52:         \"\"\"\n53:         self.timeout = timeout\n54:         self.connect_timeout = connect_timeout\n55:         self.logger = get_logger(__name__)\n56:         \n57:         base_path = f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n58:         self.base_url = urljoin(router_url, base_path)\n59:         \n60:         self.session = create_session(\n61:             pool_connections=pool_connections,\n62:             pool_maxsize=pool_maxsize,\n63:         )\n64:         \n65:         self.logger.debug(f\"Initialized AgentRuntimeDataPlaneClient with base_url: {self.base_url}\")\n66:     \n67:     def bootstrap_session_id(self) -> str:\n68:         \"\"\"Bootstrap a new session ID from the invocation endpoint.\n69:         \n70:         Makes a GET request to the base invocation URL to obtain\n71:         a session ID from the response header.\n72:         \n73:         Returns:\n74:             Session ID from x-agentcube-session-id header\n75:         \n76:         Raises:\n77:             ValueError: If x-agentcube-session-id header is missing from response\n78:             requests.RequestException: On HTTP errors\n79:         \"\"\"\n80:         self.logger.debug(f\"Bootstrapping session from {self.base_url}\")\n81:         \n82:         response = self.session.get(\n83:             self.base_url,\n84:             timeout=(self.connect_timeout, self.timeout),\n85:         )\n86:         response.raise_for_status()\n87:         \n88:         session_id = response.headers.get(self.SESSION_HEADER)\n89:         if not session_id:\n90:             raise ValueError(\n91:                 \"Missing required response header: x-agentcube-session-id\"\n92:             )\n93:         \n94:         self.session.headers[self.SESSION_HEADER] = session_id\n95:         self.logger.debug(f\"Bootstrapped session_id: {session_id}\")\n96:         \n97:         return session_id\n98:     \n99:     def invoke(\n100:         self,\n101:         session_id: str,\n102:         payload: Dict[str, Any],\n103:         timeout: Optional[float] = None,\n104:     ) -> requests.Response:\n105:         \"\"\"Invoke the agent runtime with a JSON payload.\n106:         \n107:         Args:\n108:             session_id: Session identifier for request header\n109:             payload: JSON-serializable dict to send\n110:             timeout: Optional timeout override in seconds. If None, uses instance default\n111:         \n112:         Returns:\n113:             requests.Response object from the POST request\n114:         \n115:         Raises:\n116:             requests.HTTPError: On HTTP error status codes\n117:             requests.RequestException: On network errors\n118:         \"\"\"\n119:         headers = {\n120:             self.SESSION_HEADER: session_id,\n121:             \"Content-Type\": \"application/json\",\n122:         }\n123:         \n124:         if timeout is None:\n125:             effective_timeout = (self.connect_timeout, self.timeout)\n126:         else:\n127:             effective_timeout = (self.connect_timeout, timeout)\n128:         \n129:         self.logger.debug(f\"POST {self.base_url} with payload: {payload}\")\n130:         \n131:         response = self.session.post(\n132:             self.base_url,\n133:             json=payload,\n134:             headers=headers,\n135:             timeout=effective_timeout,\n136:         )\n137:         \n138:         response.raise_for_status()\n139:         return response\n140:     \n141:     def close(self) -> None:\n142:         \"\"\"Close the underlying HTTP session.\n143:         \n144:         This method should be called when the client is no longer needed\n145:         to release connection pool resources.\n146:         \"\"\"\n147:         self.session.close()\n148:         self.logger.debug(\"AgentRuntimeDataPlaneClient closed\")\n\n(End of file - total 148 lines)\n</content>","metadata":{"preview":"\"\"\"Agent Runtime Data Plane Client for the agentcube SDK.\"\"\"\n\nimport logging\nfrom typing import Any, Dict, Optional\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom ..utils.http import create_session\nfrom ..utils.log import get_logger\n\n\nclass AgentRuntimeDataPlaneClient:\n    \"\"\"Low-level HTTP client for Agent Runtime data plane operations.\n    \n    This client handles direct HTTP communication with the Router's\n    Agent Runtime invocation endpoint.\n    \n    Attributes:\n        router_url: Router base URL","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/clients/agent_runtime_data_plane.py","time":{"start":1775890582746,"end":1775890582767}}}}
