gentcube.code_interpreter.ControlPlaneClient')\n34:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n35:     @patch('os.getenv', return_value=\"http://router-from-env:8080\")\n36:     def test_router_url_from_env(self, mock_getenv, mock_dp, mock_cp):\n37:         \"\"\"GIVEN router_url not provided but env var set\n38:            WHEN client initializes\n39:            THEN router_url from env\"\"\"\n40:         mock_cp.return_value.create_session.return_value = \"session-123\"\n41:         mock_dp.return_value = Mock()\n42:         \n43:         client = CodeInterpreterClient(\n44:             router_url=None,\n45:             workload_manager_url=\"http://wm:8080\"\n46:         )\n47:         \n48:         assert client.router_url == \"http://router-from-env:8080\"\n49:     \n50:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n51:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n52:     @patch('os.getenv', side_effect=[None, \"http://wm-from-env:8080\"])\n53:     def test_workload_manager_url_from_env(self, mock_getenv, mock_dp, mock_cp):\n54:         \"\"\"GIVEN workload_manager_url not provided but env var set\n55:            WHEN client initializes\n56:            THEN workload_manager_url from env\"\"\"\n57:         mock_cp.return_value.create_session.return_value = \"session-123\"\n58:         mock_dp.return_value = Mock()\n59:         \n60:         client = CodeInterpreterClient(\n61:             router_url=\"http://router:8080\",\n62:             workload_manager_url=None\n63:         )\n64:         \n65:         assert client.workload_manager_url == \"http://wm-from-env:8080\"\n66:     \n67:     @patch('os.getenv', return_value=None)\n68:     def test_missing_router_url_raises(self, mock_getenv):\n69:         \"\"\"GIVEN router_url not provided and env var not set\n70:            WHEN client initializes\n71:            THEN ValueError raised\"\"\"\n72:         with pytest.raises(ValueError, match=\"router_url must be provided\"):\n73:             CodeInterpreterClient(\n74:                 router_url=None,\n75:                 workload_manager_url=\"http://wm:8080\"\n76:             )\n77:     \n78:     @patch('os.getenv', side_effect=[\"http://router:8080\", None])\n79:     def test_missing_workload_manager_url_raises(self, mock_getenv):\n80:         \"\"\"GIVEN workload_manager_url not provided and env var not set\n81:            WHEN client initializes\n82:            THEN ValueError raised\"\"\"\n83:         with pytest.raises(ValueError, match=\"workload_manager_url must be provided\"):\n84:             CodeInterpreterClient(\n85:                 router_url=\"http://router:8080\",\n86:                 workload_manager_url=None\n87:             )\n88:     \n89:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n90:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n91:     def test_timeout_defaults(self, mock_dp, mock_cp):\n92:         \"\"\"GIVEN timeout/connect_timeout not specified\n93:            WHEN client initializes\n94:            THEN defaults applied\"\"\"\n95:         mock_cp.return_value.create_session.return_value = \"session-123\"\n96:         mock_dp.return_value = Mock()\n97:         \n98:         client = CodeInterpreterClient(\n99:             router_url=\"http://router:8080\",\n100:             workload_manager_url=\"http://wm:8080\"\n101:         )\n102:         \n103:         assert client.timeout == 120\n104:         assert client.connect_timeout == 5.0\n105:     \n106:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n107:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n108:     def test_namespace_default(self, mock_dp, mock_cp):\n109:         \"\"\"GIVEN namespace not specified\n110:            WHEN client initializes\n111:            THEN defaults to 'default'\"\"\"\n112:         mock_cp.return_value.create_session.return_value = \"session-123\"\n113:         mock_dp.return_value = Mock()\n114:         \n115:         client = CodeInterpreterClient(\n116:             router_url=\"http://router:8080\",\n117:             workload_manager_url=\"http://wm:8080\"\n118:         )\n119:         \n120:         assert client.namespace == \"default\"\n121:     \n122:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n123:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n124:     def test_init_without_session_id_creates_session(self, mock_dp, mock_cp):\n125:         \"\"\"GIVEN session_id not provided\n126:            WHEN client initializes\n127:            THEN create_session called\"\"\"\n128:         mock_cp.return_value.create_session.return_value = \"new-session-123\"\n129:         mock_dp.return_value = Mock()\n130:         \n131:         client = CodeInterpreterClient(\n132:             router_url=\"http://router:8080\",\n133:             workload_manager_url=\"http://wm:8080\"\n134:         )\n135:         \n136:         assert client.session_id == \"new-session-123\"\n137:         mock_cp.return_value.create_session.assert_called_once()\n138:     \n139:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n140:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n141:     def test_init_with_explicit_session_id(self, mock_dp, mock_cp):\n142:         \"\"\"GIVEN session_id provided\n143:            WHEN client initializes\n144:            THEN create_session NOT called\"\"\"\n145:         mock_cp.return_value.create_session.return_value = \"new-session\"\n146:         mock_dp.return_value = Mock()\n147:         \n148:         client = CodeInterpreterClient(\n149:             router_url=\"http://router:8080\",\n150:             workload_manager_url=\"http://wm:8080\",\n151:             session_id=\"explicit-session\"\n152:         )\n153:         \n154:         assert client.session_id == \"explicit-session\"\n155:         mock_cp.return_value.create_session.assert_not_called()\n156:     \n157:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n158:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n159:     def test_verbose_sets_debug_level(self, mock_dp, mock_cp):\n160:         \"\"\"GIVEN verbose=True\n161:            WHEN client initializes\n162:            THEN logger level is DEBUG\"\"\"\n163:         mock_cp.return_value.create_session.return_value = \"session-123\"\n164:         mock_dp.return_value = Mock()\n165:         \n166:         client = CodeInterpreterClient(\n167:             router_url=\"http://router:8080\",\n168:             workload_manager_url=\"http://wm:8080\",\n169:             verbose=True\n170:         )\n171:         \n172:         assert client.logger.level == 10  # DEBUG level\n173: \n174: \n175: class TestCodeInterpreterClientContextManager:\n176:     \"\"\"Tests for CodeInterpreterClient context manager protocol.\"\"\"\n177:     \n178:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n179:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n180:     def test_context_manager_enter(self, mock_dp, mock_cp):\n181:         \"\"\"GIVEN with statement used\n182:            WHEN entering context\n183:            THEN returns self\"\"\"\n184:         mock_cp.return_value.create_session.return_value = \"session-123\"\n185:         mock_dp.return_value = Mock()\n186:         \n187:         client = CodeInterpreterClient(\n188:             router_url=\"http://router:8080\",\n189:             workload_manager_url=\"http://wm:8080\"\n190:         )\n191:         \n192:         with client as c:\n193:             assert c is client\n194:     \n195:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n196:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n197:     def test_context_manager_exit_calls_close(self, mock_dp, mock_cp):\n198:         \"\"\"GIVEN context block exits\n199:            WHEN __exit__ called\n200:            THEN close() is called\"\"\"\n201:         mock_cp.return_value.create_session.return_value = \"session-123\"\n202:         mock_dp.return_value = Mock()\n203:         \n204:         client = CodeInterpreterClient(\n205:             router_url=\"http://router:8080\",\n206:             workload_manager_url=\"http://wm:8080\"\n207:         )\n208:         client.close = Mock()\n209:         \n210:         with client:\n211:             pass\n212:         \n213:         client.close.assert_called_once()\n214:     \n215:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n216:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n217:     def test_context_manager_exit_with_exception(self, mock_dp, mock_cp):\n218:         \"\"\"GIVEN context block raises exception\n219:            WHEN __exit__ called\n220:            THEN close() still called\"\"\"\n221:         mock_cp.return_value.create_session.return_value = \"session-123\"\n222:         mock_dp.return_value = Mock()\n223:         \n224:         client = CodeInterpreterClient(\n225:             router_url=\"http://router:8080\",\n226:             workload_manager_url=\"http://wm:8080\"\n227:         )\n228:         client.close = Mock()\n229:         \n230:         with pytest.raises(ValueError):\n231:             with client:\n232:                 raise ValueError(\"test error\")\n233:         \n234:         client.close.assert_called_once()\n235: \n236: \n237: class TestCodeInterpreterClientExecute:\n238:     \"\"\"Tests for CodeInterpreterClient.execute().\"\"\"\n239:     \n240:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n241:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n242:     def test_execute_with_code(self, mock_dp, mock_cp):\n243:         \"\"\"GIVEN session_id initialized\n244:            WHEN execute called with code\n245:            THEN dp_client.execute called\"\"\"\n246:         mock_cp.return_value.create_session.return_value = \"session-123\"\n247:         mock_dp.return_value.execute.return_value = Mock(\n248:             json=lambda: {\"output\": \"hello\", \"exit_code\": 0}\n249:         )\n250:         \n251:         client = CodeInterpreterClient(\n252:             router_url=\"http://router:8080\",\n253:             workload_manager_url=\"http://wm:8080\"\n254:         )\n255:         \n256:         result = client.execute(\"print('hello')\")\n257:         \n258:         mock_dp.return_value.execute.assert_called_once_with(\n259:             session_id=\"session-123\",\n260:             code=\"print('hello')\",\n261:             language=\"python\",\n262:             timeout=None\n263:         )\n264:         assert result == {\"output\": \"hello\", \"exit_code\": 0}\n265:     \n266:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n267:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n268:     def test_execute_with_language(self, mock_dp, mock_cp):\n269:         \"\"\"GIVEN execute called with language\n270:            WHEN request sent\n271:            THEN language passed to dp_client\"\"\"\n272:         mock_cp.return_value.create_session.return_value = \"session-123\"\n273:         mock_dp.return_value.execute.return_value = Mock(\n274:             json=lambda: {\"output\": \"hello\", \"exit_code\": 0}\n275:         )\n276:         \n277:         client = CodeInterpreterClient(\n278:             router_url=\"http://router:8080\",\n279:             workload_manager_url=\"http://wm:8080\"\n280:         )\n281:         \n282:         client.execute(\"puts 'hello'\", language=\"ruby\")\n283:         \n284:         call_args = mock_dp.return_value.execute.call_args\n285:         assert call_args[1]['language'] == \"ruby\"\n286:     \n287:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n288:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n289:     def test_execute_with_timeout_override(self, mock_dp, mock_cp):\n290:         \"\"\"GIVEN execute called with timeout=60\n291:            WHEN request sent\n292:            THEN timeout=60 passed to dp_client\"\"\"\n293:         mock_cp.return_value.create_session.return_value = \"session-123\"\n294:         mock_dp.return_value.execute.return_value = Mock(\n295:             json=lambda: {\"output\": \"hello\", \"exit_code\": 0}\n296:         )\n297:         \n298:         client = CodeInterpreterClient(\n299:             router_url=\"http://router:8080\",\n300:             workload_manager_url=\"http://wm:8080\"\n301:         )\n302:         \n303:         client.execute(\"print('hello')\", timeout=60)\n304:         \n305:         call_args = mock_dp.return_value.execute.call_args\n306:         assert call_args[1]['timeout'] == 60\n307:     \n308:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n309:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n310:     def test_execute_returns_parsed_json(self, mock_dp, mock_cp):\n311:         \"\"\"GIVEN dp_client.execute returns response\n312:            WHEN execute completes\n313:            THEN parsed JSON returned\"\"\"\n314:         mock_cp.return_value.create_session.return_value = \"session-123\"\n315:         mock_response = Mock()\n316:         mock_response.json.return_value = {\n317:             \"output\": \"2\",\n318:             \"exit_code\": 0,\n319:             \"stdout\": \"2\\n\"\n320:         }\n321:         mock_dp.return_value.execute.return_value = mock_response\n322:         \n323:         client = CodeInterpreterClient(\n324:             router_url=\"http://router:8080\",\n325:             workload_manager_url=\"http://wm:8080\"\n326:         )\n327:         \n328:         result = client.execute(\"print(1 + 1)\")\n329:         \n330:         assert result == {\"output\": \"2\", \"exit_code\": 0, \"stdout\": \"2\\n\"}\n331:     \n332:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n333:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n334:     def test_execute_nonzero_exit_raises(self, mock_dp, mock_cp):\n335:         \"\"\"GIVEN code execution returns non-zero exit code\n336:            WHEN execute completes\n337:            THEN CommandExecutionError raised\"\"\"\n338:         mock_cp.return_value.create_session.return_value = \"session-123\"\n339:         mock_response = Mock()\n340:         mock_response.json.return_value = {\n341:             \"output\": \"error\",\n342:             \"exit_code\": 1,\n343:             \"stderr\": \"RuntimeError\"\n344:         }\n345:         mock_dp.return_value.execute.return_value = mock_response\n346:         \n347:         client = CodeInterpreterClient(\n348:             router_url=\"http://router:8080\",\n349:             workload_manager_url=\"http://wm:8080\"\n350:         )\n351:         \n352:         with pytest.raises(CommandExecutionError) as exc_info:\n353:             client.execute(\"raise RuntimeError()\")\n354:         \n355:         assert exc_info.value.exit_code == 1\n356:     \n357:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n358:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n359:     def test_execute_without_session_raises(self, mock_dp, mock_cp):\n360:         \"\"\"GIVEN session_id is None\n361:            WHEN execute called\n362:            THEN ValueError raised\"\"\"\n363:         mock_cp.return_value.create_session.return_value = \"session-123\"\n364:         mock_dp.return_value = Mock()\n365:         \n366:         client = CodeInterpreterClient(\n367:             router_url=\"http://router:8080\",\n368:             workload_manager_url=\"http://wm:8080\"\n369:         )\n370:         client.session_id = None\n371:         \n372:         with pytest.raises(ValueError, match=\"CodeInterpreter session_id is not initialized\"):\n373:             client.execute(\"print('hello')\")\n374: \n375: \n376: class TestCodeInterpreterClientUploadFile:\n377:     \"\"\"Tests for CodeInterpreterClient.upload_file().\"\"\"\n378:     \n379:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n380:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n381:     def test_upload_file(self, mock_dp, mock_cp):\n382:         \"\"\"GIVEN session_id initialized\n383:            WHEN upload_file called\n384:            THEN dp_client.upload_file called\"\"\"\n385:         mock_cp.return_value.create_session.return_value = \"session-123\"\n386:         mock_dp.return_value.upload_file.return_value = Mock(\n387:             json=lambda: {\"status\": \"uploaded\"}\n388:         )\n389:         \n390:         client = CodeInterpreterClient(\n391:             router_url=\"http://router:8080\",\n392:             workload_manager_url=\"http://wm:8080\"\n393:         )\n394:         \n395:         result = client.upload_file(\"data.txt\", b\"test data\")\n396:         \n397:         mock_dp.return_value.upload_file.assert_called_once_with(\n398:             session_id=\"session-123\",\n399:             file_path=\"data.txt\",\n400:             file_content=b\"test data\",\n401:             timeout=None\n402:         )\n403:         assert result == {\"status\": \"uploaded\"}\n404:     \n405:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n406:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n407:     def test_upload_file_without_session_raises(self, mock_dp, mock_cp):\n408:         \"\"\"GIVEN session_id is None\n409:            WHEN upload_file called\n410:            THEN ValueError raised\"\"\"\n411:         mock_cp.return_value.create_session.return_value = \"session-123\"\n412:         mock_dp.return_value = Mock()\n413:         \n414:         client = CodeInterpreterClient(\n415:             router_url=\"http://router:8080\",\n416:             workload_manager_url=\"http://wm:8080\"\n417:         )\n418:         client.session_id = None\n419:         \n420:         with pytest.raises(ValueError, match=\"CodeInterpreter session_id is not initialized\"):\n421:             client.upload_file(\"data.txt\", b\"test data\")\n422: \n423: \n424: class TestCodeInterpreterClientDownloadFile:\n425:     \"\"\"Tests for CodeInterpreterClient.download_file().\"\"\"\n426:     \n427:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n428:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n429:     def test_download_file(self, mock_dp, mock_cp):\n430:         \"\"\"GIVEN session_id initialized\n431:            WHEN download_file called\n432:            THEN dp_client.download_file called\"\"\"\n433:         mock_cp.return_value.create_session.return_value = \"session-123\"\n434:         mock_response = Mock()\n435:         mock_response.content = b\"file content\"\n436:         mock_dp.return_value.download_file.return_value = mock_response\n437:         \n438:         client = CodeInterpreterClient(\n439:             router_url=\"http://router:8080\",\n440:             workload_manager_url=\"http://wm:8080\"\n441:         )\n442:         \n443:         result = client.download_file(\"data.txt\")\n444:         \n445:         mock_dp.return_value.download_file.assert_called_once_with(\n446:             session_id=\"session-123\",\n447:             file_path=\"data.txt\",\n448:             timeout=None\n449:         )\n450:         assert result == b\"file content\"\n451:     \n452:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n453:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n454:     def test_download_file_without_session_raises(self, mock_dp, mock_cp):\n455:         \"\"\"GIVEN session_id is None\n456:            WHEN download_file called\n457:            THEN ValueError raised\"\"\"\n458:         mock_cp.return_value.create_session.return_value = \"session-123\"\n459:         mock_dp.return_value = Mock()\n460:         \n461:         client = CodeInterpreterClient(\n462:             router_url=\"http://router:8080\",\n463:             workload_manager_url=\"http://wm:8080\"\n464:         )\n465:         client.session_id = None\n466:         \n467:         with pytest.raises(ValueError, match=\"CodeInterpreter session_id is not initialized\"):\n468:             client.download_file(\"data.txt\")\n469: \n470: \n471: class TestCodeInterpreterClientClose:\n472:     \"\"\"Tests for CodeInterpreterClient.close().\"\"\"\n473:     \n474:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n475:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n476:     def test_close_calls_dp_client_close(self, mock_dp, mock_cp):\n477:         \"\"\"GIVEN close() called\n478:            WHEN method executes\n479:            THEN dp_client.close() called\"\"\"\n480:         mock_cp.return_value.create_session.return_value = \"session-123\"\n481:         mock_dp.return_value = Mock()\n482:         \n483:         client = CodeInterpreterClient(\n484:             router_url=\"http://router:8080\",\n485:             workload_manager_url=\"http://wm:8080\"\n486:         )\n487:         \n488:         client.close()\n489:         \n490:         mock_dp.return_value.close.assert_called_once()\n491:     \n492:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n493:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n494:     def test_close_calls_cp_client_delete_session(self, mock_dp, mock_cp):\n495:         \"\"\"GIVEN close() called\n496:            WHEN method executes\n497:            THEN cp_client.delete_session() called\"\"\"\n498:         mock_cp.return_value.create_session.return_value = \"session-123\"\n499:         mock_dp.return_value = Mock()\n500:         \n501:         client = CodeInterpreterClient(\n502:             router_url=\"http://router:8080\",\n503:             workload_manager_url=\"http://wm:8080\"\n504:         )\n505:         \n506:         client.close()\n507:         \n508:         mock_cp.return_value.delete_session.assert_called_once_with(\"session-123\")\n509:     \n510:     @patch('agentcube.code_interpreter.ControlPlaneClient')\n511:     @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n512:     def test_close_calls_cp_client_close(self, mock_dp, mock_cp):\n513:         \"\"\"GIVEN close() called\n514:            WHEN method executes\n515:            THEN cp_client.close() called\"\"\"\n516:         mock_cp.return_value.create_session.return_value = \"session-123\"\n517:         mock_dp.return_value = Mock()\n518:         \n519:         client = CodeInterpreterClient(\n520:             router_url=\"http://router:8080\",\n521:             workload_manager_url=\"http://wm:8080\"\n522:         )\n523:         \n524:         client.close()\n525:         \n526:         mock_cp.return_value.close.assert_called_once()\n\n(End of file - total 526 lines)\n</content>","metadata":{"preview":"\"\"\"Unit tests for CodeInterpreterClient.\"\"\"\n\nimport os\nimport pytest\nfrom unittest.mock import Mock, patch\n\nfrom agentcube import CodeInterpreterClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\nclass TestCodeInterpreterClientInit:\n    \"\"\"Tests for CodeInterpreterClient.__init__().\"\"\"\n    \n    @patch('agentcube.code_interpreter.ControlPlaneClient')\n    @patch('agentcube.code_interpreter.CodeInterpreterDataPlaneClient')\n    def test_init_with_explicit_urls(self, mock_dp, mock_cp):\n        \"\"\"GIVEN router_url and workload_manager_url provided\n           WHEN client initializes\n           THEN URLs set correctly\"\"\"\n        mock_cp.return_value.create_session.return_value = \"session-123\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/tests/unit/test_code_interpreter.py","time":{"start":1775890591607,"end":1775890591622}}}}
