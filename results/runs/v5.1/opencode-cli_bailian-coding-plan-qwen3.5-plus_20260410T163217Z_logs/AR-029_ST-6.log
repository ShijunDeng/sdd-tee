  logger.debug(f\"Reading token from {path}\")\n38:     \n39:     with open(path, \"r\") as f:\n40:         token = f.read().strip()\n41:     \n42:     logger.debug(f\"Successfully read token from {path}\")\n43:     return token\n\n(End of file - total 43 lines)\n</content>","metadata":{"preview":"\"\"\"Utility functions for the agentcube SDK.\"\"\"\n\nimport os\nfrom typing import Optional\n\nfrom .log import get_logger\n\nlogger = get_logger(__name__)\n\nSERVICE_ACCOUNT_TOKEN_PATH = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n\n\ndef read_token_from_file(token_path: Optional[str] = None) -> str:\n    \"\"\"Read a Kubernetes service account token from a file.\n    \n    This function reads the token from the specified file path, or from\n    the default Kubernetes service account token location if not specified.\n    \n    Args:\n        token_path: Path to the token file. If None, uses the default","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/sdk-python/agentcube/utils/utils.py","time":{"start":1775878278108,"end":1775878278134}}}}
