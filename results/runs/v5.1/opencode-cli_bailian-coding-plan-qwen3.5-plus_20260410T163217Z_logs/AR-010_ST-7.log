ssionRequest contains parameters for creating a new session\ntype CreateSessionRequest struct {\n\tNamespace   string\n\tKind        string\n\tBackendName string\n\tBackendURL  string\n\tUserID      string\n\tMetadata    map[string]string\n}","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/session/manager.go","time":{"start":1775850916273,"end":1775850916285}}}}
