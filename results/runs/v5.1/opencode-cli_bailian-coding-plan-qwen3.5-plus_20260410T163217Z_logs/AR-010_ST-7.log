1 to continue.)\n</content>","metadata":{"preview":"package session\n\nimport (\n\t\"crypto/rand\"\n\t\"encoding/base64\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n)\n\n// SessionState represents the current state of a session\ntype SessionState string\n\nconst (\n\t// SessionStateActive indicates the session is actively being used\n\tSessionStateActive SessionState = \"Active\"\n\t// SessionStateIdle indicates the session has been idle for some time\n\tSessionStateIdle SessionState = \"Idle\"\n\t// SessionStateExpired indicates the session has expired\n\tSessionStateExpired SessionState = \"Expired\"","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/router/session/types.go","time":{"start":1775850916270,"end":1775850916282}}}}
