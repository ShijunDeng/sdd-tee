tif value := lookupEnv(key); value != \"\" {\n45: \t\treturn value\n46: \t}\n47: \treturn defaultValue\n48: }\n49: \n50: func lookupEnv(key string) string {\n51: \t// Simplified env lookup - in real code use os.Getenv\n52: \treturn \"\"\n53: }\n54: \n55: // NewTestClient creates a new HTTP client for E2E tests\n56: func NewTestClient(config *TestConfig) *http.Client {\n57: \treturn &http.Client{\n58: \t\tTimeout: config.Timeout,\n59: \t}\n60: }\n61: \n62: // GenerateRandomID generates a random identifier for test resources\n63: func GenerateRandomID(prefix string) string {\n64: \tbytes := make([]byte, 8)\n65: \tif _, err := rand.Read(bytes); err != nil {\n66: \t\treturn fmt.Sprintf(\"%s-%d\", prefix, time.Now().UnixNano())\n67: \t}\n68: \treturn fmt.Sprintf(\"%s-%s\", prefix, hex.EncodeToString(bytes))\n69: }\n70: \n71: // WaitForCondition waits for a condition to be true with timeout\n72: func WaitForCondition(name string, condition func() bool, timeout time.Duration, interval time.Duration) error {\n73: \tstart := time.Now()\n74: \tfor time.Since(start) < timeout {\n75: \t\tif condition() {\n76: \t\t\treturn nil\n77: \t\t}\n78: \t\ttime.Sleep(interval)\n79: \t}\n80: \treturn fmt.Errorf(\"timeout waiting for condition: %s\", name)\n81: }\n82: \n83: // RetryWithBackoff retries a function with exponential backoff\n84: func RetryWithBackoff(name string, fn func() error, maxRetries int, initialDelay time.Duration) error {\n85: \tvar lastErr error\n86: \tdelay := initialDelay\n87: \n88: \tfor i := 0; i < maxRetries; i++ {\n89: \t\tif err := fn(); err == nil {\n90: \t\t\treturn nil\n91: \t\t} else {\n92: \t\t\tlastErr = err\n93: \t\t}\n94: \t\ttime.Sleep(delay)\n95: \t\tdelay *= 2\n96: \t}\n97: \n98: \treturn fmt.Errorf(\"failed after %d retries: %w\", maxRetries, lastErr)\n99: }\n100: \n101: // CheckEndpointHealth checks if an endpoint is healthy\n102: func CheckEndpointHealth(client *http.Client, url string) error {\n103: \tresp, err := client.Get(url)\n104: \tif err != nil {\n105: \t\treturn err\n106: \t}\n107: \tdefer resp.Body.Close()\n108: \n109: \tif resp.StatusCode != http.StatusOK {\n110: \t\tbody, _ := io.ReadAll(resp.Body)\n111: \t\treturn fmt.Errorf(\"health check failed: status=%d, body=%s\", resp.StatusCode, string(body))\n112: \t}\n113: \n114: \treturn nil\n115: }\n116: \n117: // WaitForEndpoint waits for an endpoint to become available\n118: func WaitForEndpoint(client *http.Client, url string, timeout time.Duration) error {\n119: \treturn WaitForCondition(\n120: \t\tfmt.Sprintf(\"endpoint %s\", url),\n121: \t\tfunc() bool {\n122: \t\t\treturn CheckEndpointHealth(client, url) == nil\n123: \t\t},\n124: \t\ttimeout,\n125: \t\t2*time.Second,\n126: \t)\n127: }\n128: \n129: // CreateTestSession creates a test session\n130: func CreateTestSession(client *http.Client, baseURL string, interpreter string, namespace string, token string) (string, error) {\n131: \treturn \"\", nil\n132: }\n133: \n134: // DeleteTestSession deletes a test session\n135: func DeleteTestSession(client *http.Client, baseURL string, sessionID string, token string) error {\n136: \treturn nil\n137: }\n\n(End of file - total 137 lines)\n</content>","metadata":{"preview":"// Copyright 2026 AgentCube Authors\n// E2E test helpers and utilities\n\npackage e2e\n\nimport (\n\t\"crypto/rand\"\n\t\"encoding/hex\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"time\"\n)\n\n// TestConfig holds E2E test configuration\ntype TestConfig struct {\n\tWorkloadManagerURL string\n\tRouterURL          string\n\tAPIToken           string\n\tNamespace          string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/helpers.go","time":{"start":1775892237578,"end":1775892237604}}}}
