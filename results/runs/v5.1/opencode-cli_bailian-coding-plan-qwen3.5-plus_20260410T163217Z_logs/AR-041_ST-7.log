{"type":"tool_use","timestamp":1775892246335,"sessionID":"ses_284932f3fffeWOnPF3XoJZVqgw","part":{"id":"prt_d7b6d1dea001VuCcB9w67uXSYE","messageID":"msg_d7b6d0d61001nHLghDdHeNkSC8","sessionID":"ses_284932f3fffeWOnPF3XoJZVqgw","type":"tool","tool":"read","callID":"toolu_0b38f44090a84625b99d299d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/test_codeinterpreter.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/test_codeinterpreter.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"\n3: E2E tests for AgentCube CodeInterpreter\n4: Comprehensive test suite for AgentCube E2E validation\n5: \"\"\"\n6: \n7: import os\n8: import sys\n9: import json\n10: import time\n11: import unittest\n12: import urllib.request\n13: import urllib.error\n14: import urllib.parse\n15: from typing import Dict, Any, Optional\n16: from concurrent.futures import ThreadPoolExecutor, as_completed\n17: \n18: \n19: class E2ETestClient:\n20:     \"\"\"HTTP client for E2E tests.\"\"\"\n21: \n22:     def __init__(self, base_url: str, api_token: str = ''):\n23:         self.base_url = base_url.rstrip('/')\n24:         self.api_token = api_token\n25:         self.timeout = 30\n26: \n27:     def request(\n28:         self,\n29:         method: str,\n30:         path: str,\n31:         data: Optional[Dict[str, Any]] = None,\n32:         headers: Optional[Dict[str, str]] = None\n33:     ) -> Dict[str, Any]:\n34:         \"\"\"Make HTTP request.\"\"\"\n35:         url = f\"{self.base_url}{path}\"\n36:         \n37:         req_headers = {\n38:             'Content-Type': 'application/json',\n39:         }\n40:         \n41:         if self.api_token:\n42:             req_headers['Authorization'] = f'Bearer {self.api_token}'\n43:         \n44:         if headers:\n45:             req_headers.update(headers)\n46:         \n47:         body = json.dumps(data).encode('utf-8') if data else None\n48:         \n49:         req = urllib.request.Request(\n50:             url,\n51:             data=body,\n52:             headers=req_headers,\n53:             method=method\n54:         )\n55:         \n56:         try:\n57:             with urllib.request.urlopen(req, timeout=self.timeout) as response:\n58:                 response_body = response.read().decode()\n59:                 if response_body:\n60:                     return json.loads(response_body)\n61:                 return {}\n62:         except urllib.error.HTTPError as e:\n63:             error_body = e.read().decode() if e.fp else ''\n64:             raise Exception(f\"HTTP {e.code}: {error_body}\")\n65:         except urllib.error.URLError as e:\n66:             raise Exception(f\"URL Error: {e.reason}\")\n67: \n68: \n69: class TestCodeInterpreter(unittest.TestCase):\n70:     \"\"\"Test cases for CodeInterpreter E2E tests.\"\"\"\n71: \n72:     @classmethod\n73:     def setUpClass(cls):\n74:         \"\"\"Set up test fixtures.\"\"\"\n75:         cls.workload_manager_url = os.environ.get(\n76:             'WORKLOAD_MANAGER_URL', 'http://localhost:8080'\n77:         )\n78:         cls.router_url = os.environ.get('ROUTER_URL', 'http://localhost:8081')\n79:         cls.api_token = os.environ.get('API_TOKEN', '')\n80:         cls.namespace = os.environ.get('AGENTCUBE_NAMESPACE', 'agentcube')\n81:         \n82:         cls.wm_client = E2ETestClient(cls.workload_manager_url, cls.api_token)\n83:         cls.router_client = E2ETestClient(cls.router_url, cls.api_token)\n84:         \n85:         print(f\"\\n{'='*60}\")\n86:         print(f\"E2E Test Configuration:\")\n87:         print(f\"  Workload Manager: {cls.workload_manager_url}\")\n88:         print(f\"  Router: {cls.router_url}\")\n89:         print(f\"  Namespace: {cls.namespace}\")\n90:         print(f\"{'='*60}\\n\")\n91: \n92:     def test_01_workload_manager_health(self):\n93:         \"\"\"Test workload manager health endpoint.\"\"\"\n94:         try:\n95:             result = self.wm_client.request('GET', '/health')\n96:             self.assertIn('status', result)\n97:             print(f\"✓ Workload Manager health: {result.get('status', 'unknown')}\")\n98:         except Exception as e:\n99:             self.fail(f\"Workload Manager health check failed: {e}\")\n100: \n101:     def test_02_router_health_live(self):\n102:         \"\"\"Test router live health endpoint.\"\"\"\n103:         try:\n104:             self.router_client.request('GET', '/health/live')\n105:             print(\"✓ Router live health check passed\")\n106:         except Exception as e:\n107:             self.fail(f\"Router live health check failed: {e}\")\n108: \n109:     def test_03_router_health_ready(self):\n110:         \"\"\"Test router ready health endpoint.\"\"\"\n111:         try:\n112:             result = self.router_client.request('GET', '/health/ready')\n113:             self.assertTrue(result.get('ready', False), \"Router is not ready\")\n114:             print(\"✓ Router ready check passed\")\n115:         except Exception as e:\n116:             print(f\"⚠ Router ready check skipped: {e}\")\n117:             self.skipTest(str(e))\n118: \n119:     def test_04_invoke_echo_agent(self):\n120:         \"\"\"Test echo agent invocation.\"\"\"\n121:         payload = {\n122:             'message': 'Hello from E2E test!'\n123:         }\n124:         \n125:         try:\n126:             result = self.router_client.request(\n127:                 'POST',\n128:                 '/invoke/echo-agent',\n129:                 data=payload\n130:             )\n131:             self.assertEqual(result.get('status'), 'success')\n132:             print(f\"✓ Echo agent invocation successful\")\n133:             print(f\"  Response: {json.dumps(result, indent=2)}\")\n134:         except Exception as e:\n135:             self.fail(f\"Echo agent invocation failed: {e}\")\n136: \n137:     def test_05_code_interpreter_basic(self):\n138:         \"\"\"Test basic code interpreter execution.\"\"\"\n139:         payload = {\n140:             'code': 'print(\"Hello from Python E2E test\")',\n141:             'language': 'python'\n142:         }\n143:         \n144:         try:\n145:             result = self.router_client.request(\n146:                 'POST',\n147:                 '/invoke/e2e-code-interpreter',\n148:                 data=payload\n149:             )\n150:             self.assertIn('status', result)\n151:             print(f\"✓ Code interpreter execution successful\")\n152:             print(f\"  Result: {json.dumps(result, indent=2)}\")\n153:         except Exception as e:\n154:             self.fail(f\"Code interpreter execution failed: {e}\")\n155: \n156:     def test_06_code_interpreter_math(self):\n157:         \"\"\"Test code interpreter with mathematical computation.\"\"\"\n158:         payload = {\n159:             'code': '''\n160: import math\n161: result = math.sqrt(144)\n162: print(f\"Square root of 144 is {result}\")\n163: {\"result\": result}\n164: ''',\n165:             'language': 'python'\n166:         }\n167:         \n168:         try:\n169:             result = self.router_client.request(\n170:                 'POST',\n171:                 '/invoke/e2e-code-interpreter',\n172:                 data=payload\n173:             )\n174:             print(f\"✓ Math computation successful\")\n175:             print(f\"  Output: {result}\")\n176:         except Exception as e:\n177:             print(f\"⚠ Math computation skipped: {e}\")\n178:             self.skipTest(str(e))\n179: \n180:     def test_07_code_interpreter_data_processing(self):\n181:         \"\"\"Test code interpreter with data processing.\"\"\"\n182:         payload = {\n183:             'code': '''\n184: import json\n185: data = [1, 2, 3, 4, 5]\n186: result = {\n187:     \"sum\": sum(data),\n188:     \"avg\": sum(data) / len(data),\n189:     \"max\": max(data),\n190:     \"min\": min(data)\n191: }\n192: print(json.dumps(result))\n193: ''',\n194:             'language': 'python'\n195:         }\n196:         \n197:         try:\n198:             result = self.router_client.request(\n199:                 'POST',\n200:                 '/invoke/e2e-code-interpreter',\n201:                 data=payload\n202:             )\n203:             print(f\"✓ Data processing successful\")\n204:             print(f\"  Output: {result}\")\n205:         except Exception as e:\n206:             print(f\"⚠ Data processing skipped: {e}\")\n207:             self.skipTest(str(e))\n208: \n209:     def test_08_session_creation(self):\n210:         \"\"\"Test session creation for code interpreter.\"\"\"\n211:         payload = {\n212:             'interpreter': 'e2e-code-interpreter',\n213:             'namespace': self.namespace,\n214:             'ttl': '120s'\n215:         }\n216:         \n217:         try:\n218:             result = self.wm_client.request(\n219:                 'POST',\n220:                 '/api/v1/sessions',\n221:                 data=payload\n222:             )\n223:             self.assertIn('sessionId', result)\n224:             session_id = result['sessionId']\n225:             print(f\"✓ Session created: {session_id}\")\n226:             \n227:             session_payload = {'code': 'print(\"Session test\")'}\n228:             session_result = self.router_client.request(\n229:                 'POST',\n230:                 f'/session/{session_id}',\n231:                 data=session_payload\n232:             )\n233:             print(f\"✓ Session invocation successful\")\n234:             \n235:             self.wm_client.request('DELETE', f'/api/v1/sessions/{session_id}')\n236:             print(f\"✓ Session cleaned up\")\n237:             \n238:         except Exception as e:\n239:             error_msg = str(e)\n240:             if '404' in error_msg or 'not found' in error_msg.lower():\n241:                 print(f\"⚠ Sessions API not available\")\n242:                 self.skipTest(\"Sessions API not available\")\n243:             else:\n244:                 print(f\"⚠ Session creation skipped: {e}\")\n245:                 self.skipTest(str(e))\n246: \n247:     def test_09_concurrent_invocations(self):\n248:         \"\"\"Test concurrent agent invocations.\"\"\"\n249:         concurrency = 5\n250:         results = {'success': 0, 'failed': 0, 'errors': []}\n251:         \n252:         def invoke_agent(task_id: int) -> bool:\n253:             payload = {'message': f'Concurrent test {task_id}'}\n254:             try:\n255:                 result = self.router_client.request(\n256:                     'POST',\n257:                     '/invoke/echo-agent',\n258:                     data=payload\n259:                 )\n260:                 return result.get('status') == 'success'\n261:             except Exception as e:\n262:                 results['errors'].append(f\"Task {task_id}: {e}\")\n263:                 return False\n264:         \n265:         with ThreadPoolExecutor(max_workers=concurrency) as executor:\n266:             futures = [executor.submit(invoke_agent, i) for i in range(concurrency)]\n267:             \n268:             for future in as_completed(futures):\n269:                 if future.result():\n270:                     results['success'] += 1\n271:                 else:\n272:                     results['failed'] += 1\n273:         \n274:         print(f\"✓ Concurrent test: {results['success']}/{concurrency} succeeded\")\n275:         \n276:         if results['errors']:\n277:             print(f\"  Errors: {results['errors']}\")\n278:         \n279:         self.assertGreaterEqual(\n280:             results['success'],\n281:             concurrency - 1,\n282:             f\"Expected at least {concurrency-1} successes\"\n283:         )\n284: \n285:     def test_10_invalid_agent_invocation(self):\n286:         \"\"\"Test invalid agent invocation handling.\"\"\"\n287:         payload = {'message': 'Test invalid agent'}\n288:         \n289:         try:\n290:             self.router_client.request(\n291:                 'POST',\n292:                 '/invoke/non-existent-agent',\n293:                 data=payload\n294:             )\n295:             self.fail(\"Expected error for non-existent agent\")\n296:         except Exception as e:\n297:             error_msg = str(e)\n298:             if '404' in error_msg or '400' in error_msg:\n299:                 print(f\"✓ Invalid agent correctly rejected: {error_msg}\")\n300:             else:\n301:                 print(f\"⚠ Unexpected error: {e}\")\n302: \n303:     def test_11_malformed_request(self):\n304:         \"\"\"Test malformed request handling.\"\"\"\n305:         try:\n306:             url = f\"{self.router_url}/invoke/echo-agent\"\n307:             req_headers = {'Content-Type': 'application/json'}\n308:             if self.api_token:\n309:                 req_headers['Authorization'] = f'Bearer {self.api_token}'\n310:             \n311:             req = urllib.request.Request(\n312:                 url,\n313:                 data=b'invalid json{',\n314:                 headers=req_headers,\n315:                 method='POST'\n316:             )\n317:             \n318:             urllib.request.urlopen(req, timeout=10)\n319:             print(\"⚠ Malformed request not rejected\")\n320:         except urllib.error.HTTPError as e:\n321:             if e.code == 400:\n322:                 print(f\"✓ Malformed request correctly rejected with 400\")\n323:             else:\n324:                 print(f\"⚠ Malformed request returned {e.code}\")\n325:         except Exception as e:\n326:             print(f\"⚠ Malformed request test: {e}\")\n327: \n328:     def test_12_metrics_endpoint(self):\n329:         \"\"\"Test metrics endpoint availability.\"\"\"\n330:         try:\n331:             url = f\"{self.workload_manager_url}/metrics\"\n332:             req = urllib.request.Request(url)\n333:             with urllib.request.urlopen(req, timeout=10) as response:\n334:                 body = response.read().decode()\n335:                 self.assertGreater(len(body), 0, \"Metrics body is empty\")\n336:                 print(f\"✓ Metrics endpoint returned {len(body)} bytes\")\n337:         except Exception as e:\n338:             print(f\"⚠ Metrics endpoint not available: {e}\")\n339:             self.skipTest(str(e))\n340: \n341:     def test_13_router_metrics(self):\n342:         \"\"\"Test router metrics endpoint.\"\"\"\n343:         try:\n344:             url = f\"{self.router_url}/metrics\"\n345:             req = urllib.request.Request(url)\n346:             with urllib.request.urlopen(req, timeout=10) as response:\n347:                 body = response.read().decode()\n348:                 self.assertGreater(len(body), 0, \"Router metrics body is empty\")\n349:                 print(f\"✓ Router metrics endpoint returned {len(body)} bytes\")\n350:         except Exception as e:\n351:             print(f\"⚠ Router metrics not available: {e}\")\n352:             self.skipTest(str(e))\n353: \n354:     def test_14_warm_pool_latency(self):\n355:         \"\"\"Test warm pool code interpreter latency.\"\"\"\n356:         payload = {\n357:             'code': 'import time; start = time.time(); print(f\"Latency: {time.time() - start:.3f}s\")',\n358:             'language': 'python'\n359:         }\n360:         \n361:         try:\n362:             start_time = time.time()\n363:             result = self.router_client.request(\n364:                 'POST',\n365:                 '/invoke/e2e-code-interpreter-warmpool',\n366:                 data=payload\n367:             )\n368:             elapsed = time.time() - start_time\n369:             \n370:             print(f\"✓ Warm pool response in {elapsed:.3f}s\")\n371:             print(f\"  Result: {result}\")\n372:             \n373:             if elapsed > 5.0:\n374:                 print(f\"⚠ Warning: Warm pool latency higher than expected\")\n375:                 \n376:         except Exception as e:\n377:             error_msg = str(e)\n378:             if '404' in error_msg or 'not found' in error_msg.lower():\n379:                 print(f\"⚠ Warm pool interpreter not configured\")\n380:                 self.skipTest(\"Warm pool not configured\")\n381:             else:\n382:                 print(f\"⚠ Warm pool test skipped: {e}\")\n383:                 self.skipTest(str(e))\n384: \n385:     def test_15_code_execution_timeout(self):\n386:         \"\"\"Test code execution with timeout handling.\"\"\"\n387:         payload = {\n388:             'code': 'import time; time.sleep(2); print(\"Completed\")',\n389:             'language': 'python',\n390:             'timeout': '5s'\n391:         }\n392:         \n393:         try:\n394:             result = self.router_client.request(\n395:                 'POST',\n396:                 '/invoke/e2e-code-interpreter',\n397:                 data=payload\n398:             )\n399:             print(f\"✓ Timeout handling test passed\")\n400:             print(f\"  Result: {result}\")\n401:         except Exception as e:\n402:             print(f\"⚠ Timeout test skipped: {e}\")\n403:             self.skipTest(str(e))\n404: \n405:     def test_16_code_with_output_capture(self):\n406:         \"\"\"Test code execution with stdout/stderr capture.\"\"\"\n407:         payload = {\n408:             'code': '''\n409: import sys\n410: print(\"stdout output\", flush=True)\n411: print(\"stderr output\", file=sys.stderr, flush=True)\n412: {\"status\": \"success\"}\n413: ''',\n414:             'language': 'python'\n415:         }\n416:         \n417:         try:\n418:             result = self.router_client.request(\n419:                 'POST',\n420:                 '/invoke/e2e-code-interpreter',\n421:                 data=payload\n422:             )\n423:             print(f\"✓ Output capture test passed\")\n424:             print(f\"  Result: {result}\")\n425:         except Exception as e:\n426:             print(f\"⚠ Output capture test skipped: {e}\")\n427:             self.skipTest(str(e))\n428: \n429:     def test_17_multi_step_code_execution(self):\n430:         \"\"\"Test multi-step code execution in same session.\"\"\"\n431:         steps = [\n432:             {'code': 'x = 10', 'language': 'python'},\n433:             {'code': 'y = 20', 'language': 'python'},\n434:             {'code': 'print(f\"Sum: {x + y}\")', 'language': 'python'},\n435:         ]\n436:         \n437:         results = []\n438:         for i, step in enumerate(steps):\n439:             try:\n440:                 result = self.router_client.request(\n441:                     'POST',\n442:                     '/invoke/e2e-code-interpreter',\n443:                     data=step\n444:                 )\n445:                 results.append(result)\n446:                 print(f\"✓ Step {i+1} completed\")\n447:             except Exception as e:\n448:                 print(f\"⚠ Step {i+1} failed: {e}\")\n449:                 break\n450:         \n451:         self.assertEqual(len(results), len(steps), \"Not all steps completed\")\n452: \n453:     def test_18_code_interpreter_error_handling(self):\n454:         \"\"\"Test code interpreter error handling.\"\"\"\n455:         payload = {\n456:             'code': 'raise ValueError(\"Intentional error for testing\")',\n457:             'language': 'python'\n458:         }\n459:         \n460:         try:\n461:             result = self.router_client.request(\n462:                 'POST',\n463:                 '/invoke/e2e-code-interpreter',\n464:                 data=payload\n465:             )\n466:             print(f\"✓ Error handling test: {result.get('status', 'unknown')}\")\n467:             print(f\"  Error info: {result}\")\n468:         except Exception as e:\n469:             error_msg = str(e)\n470:             if '500' in error_msg or 'error' in error_msg.lower():\n471:                 print(f\"✓ Error correctly reported: {error_msg}\")\n472:             else:\n473:                 print(f\"⚠ Unexpected error response: {e}\")\n474: \n475:     def test_19_agent_runtime_status(self):\n476:         \"\"\"Test agent runtime status query.\"\"\"\n477:         try:\n478:             url = f\"{self.workload_manager_url}/api/v1/runtimes\"\n479:             req = urllib.request.Request(url)\n480:             if self.api_token:\n481:                 req.add_header('Authorization', f'Bearer {self.api_token}')\n482:             \n483:             with urllib.request.urlopen(req, timeout=10) as response:\n484:                 result = json.loads(response.read().decode())\n485:                 print(f\"✓ Agent runtime status query successful\")\n486:                 print(f\"  Runtimes: {len(result.get('items', []))}\")\n487:         except Exception as e:\n488:             error_msg = str(e)\n489:             if '404' in error_msg:\n490:                 print(f\"⚠ Runtime status API not available\")\n491:                 self.skipTest(\"Runtime status API not available\")\n492:             else:\n493:                 print(f\"⚠ Runtime status query skipped: {e}\")\n494:                 self.skipTest(str(e))\n495: \n496:     def test_20_load_balancing(self):\n497:         \"\"\"Test load balancing across multiple instances.\"\"\"\n498:         invocation_count = 10\n499:         instance_ids = []\n500:         \n501:         for i in range(invocation_count):\n502:             payload = {'message': f'Load test {i}'}\n503:             try:\n504:                 result = self.router_client.request(\n505:                     'POST',\n506:                     '/invoke/echo-agent',\n507:                     data=payload\n508:                 )\n509:                 if 'instance' in result:\n510:                     instance_ids.append(result['instance'])\n511:             except Exception as e:\n512:                 print(f\"⚠ Load test invocation {i} failed: {e}\")\n513:         \n514:         if instance_ids:\n515:             unique_instances = set(instance_ids)\n516:             print(f\"✓ Load balancing test: {len(unique_instances)} instance(s) used\")\n517:             print(f\"  Distribution: {instance_ids}\")\n518:         else:\n519:             print(f\"⚠ Load balancing test: No instance IDs returned\")\n520: \n521: \n522: class TestNamespaceIsolation(unittest.TestCase):\n523:     \"\"\"Tests for namespace isolation and multi-tenancy.\"\"\"\n524: \n525:     @classmethod\n526:     def setUpClass(cls):\n527:         \"\"\"Set up test fixtures.\"\"\"\n528:         cls.workload_manager_url = os.environ.get(\n529:             'WORKLOAD_MANAGER_URL', 'http://localhost:8080'\n530:         )\n531:         cls.api_token = os.environ.get('API_TOKEN', '')\n532:         cls.namespace = os.environ.get('AGENTCUBE_NAMESPACE', 'agentcube')\n533:         cls.client = E2ETestClient(cls.workload_manager_url, cls.api_token)\n534: \n535:     def test_namespace_specific_interpreter(self):\n536:         \"\"\"Test interpreter access with namespace specification.\"\"\"\n537:         payload = {\n538:             'interpreter': 'e2e-code-interpreter',\n539:             'namespace': self.namespace,\n540:             'code': 'print(\"Namespace test\")'\n541:         }\n542:         \n543:         try:\n544:             result = self.client.request(\n545:                 'POST',\n546:                 '/api/v1/invoke',\n547:                 data=payload\n548:             )\n549:             print(f\"✓ Namespace-specific invocation successful\")\n550:         except Exception as e:\n551:             print(f\"⚠ Namespace test skipped: {e}\")\n552:             self.skipTest(str(e))\n553: \n554: \n555: class TestResourceManagement(unittest.TestCase):\n556:     \"\"\"Tests for resource management and quotas.\"\"\"\n557: \n558:     @classmethod\n559:     def setUpClass(cls):\n560:         \"\"\"Set up test fixtures.\"\"\"\n561:         cls.workload_manager_url = os.environ.get(\n562:             'WORKLOAD_MANAGER_URL', 'http://localhost:8080'\n563:         )\n564:         cls.api_token = os.environ.get('API_TOKEN', '')\n565:         cls.client = E2ETestClient(cls.workload_manager_url, cls.api_token)\n566: \n567:     def test_resource_quota_enforcement(self):\n568:         \"\"\"Test resource quota enforcement.\"\"\"\n569:         payload = {\n570:             'interpreter': 'e2e-code-interpreter',\n571:             'resources': {\n572:                 'cpu': '100m',\n573:                 'memory': '128Mi'\n574:             }\n575:         }\n576:         \n577:         try:\n578:             result = self.client.request(\n579:                 'POST',\n580:                 '/api/v1/sessions',\n581:                 data=payload\n582:             )\n583:             print(f\"✓ Resource quota test passed\")\n584:         except Exception as e:\n585:             error_msg = str(e)\n586:             if 'quota' in error_msg.lower() or 'resource' in error_msg.lower():\n587:                 print(f\"✓ Resource quota enforced: {error_msg}\")\n588:             else:\n589:                 print(f\"⚠ Resource quota test skipped: {e}\")\n590:                 self.skipTest(str(e))\n591: \n592: \n593: if __name__ == '__main__':\n594:     if '--verbose' not in sys.argv and '-v' not in sys.argv:\n595:         sys.argv.append('--verbose')\n596:     \n597:     unittest.main(verbosity=2)\n\n(End of file - total 597 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"\nE2E tests for AgentCube CodeInterpreter\nComprehensive test suite for AgentCube E2E validation\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport time\nimport unittest\nimport urllib.request\nimport urllib.error\nimport urllib.parse\nfrom typing import Dict, Any, Optional\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\n\n\nclass E2ETestClient:\n    \"\"\"HTTP client for E2E tests.\"\"\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/test_codeinterpreter.py","time":{"start":1775892246319,"end":1775892246332}}}}
{"type":"tool_use","timestamp":1775892246338,"sessionID":"ses_284932f3fffeWOnPF3XoJZVqgw","part":{"id":"prt_d7b6d224d001SGDOWhlg68LJuW","messageID":"msg_d7b6d0d61001nHLghDdHeNkSC8","sessionID":"ses_284932f3fffeWOnPF3XoJZVqgw","type":"tool","tool":"read","callID":"toolu_b8af516a0e2448b0837162e2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/run_e2e.sh"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/run_e2e.sh</path>\n<type>file</type>\n<content>\n1: #!/bin/bash\n2: # E2E test runner for AgentCube\n3: # This script sets up a Kind cluster, installs dependencies, and runs E2E tests\n4: # with enhanced error handling, reporting, and cleanup\n5: \n6: set -euo pipefail\n7: \n8: # Load configuration\n9: source \"$(dirname \"$0\")/config.env\"\n10: \n11: # Test state tracking\n12: TEST_START_TIME=\"\"\n13: TEST_RESULTS=()\n14: TEST_FAILURES=0\n15: TEST_SKIPPED=0\n16: \n17: # Colors for output\n18: RED='\\033[0;31m'\n19: GREEN='\\033[0;32m'\n20: YELLOW='\\033[1;33m'\n21: BLUE='\\033[0;34m'\n22: MAGENTA='\\033[0;35m'\n23: CYAN='\\033[0;36m'\n24: NC='\\033[0m' # No Color\n25: BOLD='\\033[1m'\n26: \n27: # Logging functions\n28: log_info() {\n29:     echo -e \"${GREEN}${BOLD}[INFO]${NC} $1\"\n30: }\n31: \n32: log_warn() {\n33:     echo -e \"${YELLOW}[WARN]${NC} $1\"\n34: }\n35: \n36: log_error() {\n37:     echo -e \"${RED}${BOLD}[ERROR]${NC} $1\" >&2\n38: }\n39: \n40: log_debug() {\n41:     if [ \"${E2E_DEBUG:-false}\" = \"true\" ]; then\n42:         echo -e \"${CYAN}[DEBUG]${NC} $1\"\n43:     fi\n44: }\n45: \n46: log_step() {\n47:     echo -e \"${BLUE}${BOLD}[STEP]${NC} $1\"\n48: }\n49: \n50: log_success() {\n51:     echo -e \"${GREEN}${BOLD}[SUCCESS]${NC} $1\"\n52: }\n53: \n54: log_test_result() {\n55:     local test_name=\"$1\"\n56:     local status=\"$2\"\n57:     local duration=\"${3:-0}\"\n58:     \n59:     case \"$status\" in\n60:         PASS)\n61:             echo -e \"${GREEN}✓${NC} $test_name (${duration}s)\"\n62:             TEST_RESULTS+=(\"PASS:$test_name:$duration\")\n63:             ;;\n64:         FAIL)\n65:             echo -e \"${RED}✗${NC} $test_name (${duration}s)\"\n66:             TEST_RESULTS+=(\"FAIL:$test_name:$duration\")\n67:             ((TEST_FAILURES++)) || true\n68:             ;;\n69:         SKIP)\n70:             echo -e \"${YELLOW}⊘${NC} $test_name\"\n71:             TEST_RESULTS+=(\"SKIP:$test_name:0\")\n72:             ((TEST_SKIPPED++)) || true\n73:             ;;\n74:     esac\n75: }\n76: \n77: # Collect component logs on failure\n78: collect_component_logs() {\n79:     log_step \"Collecting component logs...\"\n80:     mkdir -p \"$ARTIFACTS_PATH\"\n81:     \n82:     local log_timestamp\n83:     log_timestamp=$(date +%Y%m%d_%H%M%S)\n84:     \n85:     # Collect workload manager logs\n86:     if kubectl -n \"$AGENTCUBE_NAMESPACE\" logs -l app=workloadmanager > \"$ARTIFACTS_PATH/workloadmanager_${log_timestamp}.log\" 2>/dev/null; then\n87:         log_debug \"Collected workload manager logs\"\n88:     else\n89:         log_warn \"Failed to collect workload manager logs\"\n90:     fi\n91:     kubectl -n \"$AGENTCUBE_NAMESPACE\" describe pod -l app=workloadmanager > \"$ARTIFACTS_PATH/workloadmanager_describe_${log_timestamp}.txt\" 2>/dev/null || true\n92:     \n93:     # Collect router logs\n94:     if kubectl -n \"$AGENTCUBE_NAMESPACE\" logs -l app=agentcube-router > \"$ARTIFACTS_PATH/router_${log_timestamp}.log\" 2>/dev/null; then\n95:         log_debug \"Collected router logs\"\n96:     else\n97:         log_warn \"Failed to collect router logs\"\n98:     fi\n99:     kubectl -n \"$AGENTCUBE_NAMESPACE\" describe pod -l app=agentcube-router > \"$ARTIFACTS_PATH/router_describe_${log_timestamp}.txt\" 2>/dev/null || true\n100:     \n101:     # Collect sandbox pod logs\n102:     if kubectl -n \"$AGENTCUBE_NAMESPACE\" logs -l app=agent-sandbox-controller > \"$ARTIFACTS_PATH/sandbox_${log_timestamp}.log\" 2>/dev/null; then\n103:         log_debug \"Collected sandbox logs\"\n104:     else\n105:         log_warn \"Failed to collect sandbox logs\"\n106:     fi\n107:     kubectl -n \"$AGENTCUBE_NAMESPACE\" describe pod -l app=agent-sandbox-controller > \"$ARTIFACTS_PATH/sandbox_describe_${log_timestamp}.txt\" 2>/dev/null || true\n108:     \n109:     # Collect events\n110:     kubectl -n \"$AGENTCUBE_NAMESPACE\" get events > \"$ARTIFACTS_PATH/events_${log_timestamp}.txt\" 2>/dev/null || true\n111:     \n112:     # Collect pod statuses\n113:     kubectl -n \"$AGENTCUBE_NAMESPACE\" get pods -o wide > \"$ARTIFACTS_PATH/pods_${log_timestamp}.txt\" 2>/dev/null || true\n114:     \n115:     log_info \"Logs collected in $ARTIFACTS_PATH\"\n116: }\n117: \n118: # Generate test report\n119: generate_test_report() {\n120:     local report_file=\"$ARTIFACTS_PATH/test_report_$(date +%Y%m%d_%H%M%S).md\"\n121:     \n122:     cat > \"$report_file\" << EOF\n123: # AgentCube E2E Test Report\n124: \n125: **Date:** $(date -Iseconds)\n126: **Cluster:** $E2E_CLUSTER_NAME\n127: **Namespace:** $AGENTCUBE_NAMESPACE\n128: \n129: ## Summary\n130: \n131: - **Total Tests:** ${#TEST_RESULTS[@]}\n132: - **Passed:** $(printf '%s\\n' \"${TEST_RESULTS[@]}\" | grep -c \"^PASS:\" || echo 0)\n133: - **Failed:** $TEST_FAILURES\n134: - **Skipped:** $TEST_SKIPPED\n135: \n136: ## Test Results\n137: \n138: EOF\n139: \n140:     for result in \"${TEST_RESULTS[@]}\"; do\n141:         IFS=':' read -r status name duration <<< \"$result\"\n142:         case \"$status\" in\n143:             PASS)\n144:                 echo \"- ✓ **$name** (${duration}s)\" >> \"$report_file\"\n145:                 ;;\n146:             FAIL)\n147:                 echo \"- ✗ **$name** (${duration}s)\" >> \"$report_file\"\n148:                 ;;\n149:             SKIP)\n150:                 echo \"- ⊘ **$name**\" >> \"$report_file\"\n151:                 ;;\n152:         esac\n153:     done\n154: \n155:     if [ $TEST_FAILURES -gt 0 ]; then\n156:         echo -e \"\\n## Failures\\n\" >> \"$report_file\"\n157:         echo \"See log files in $ARTIFACTS_PATH for details.\" >> \"$report_file\"\n158:     fi\n159: \n160:     log_info \"Test report generated: $report_file\"\n161: }\n162: \n163: # Cleanup function\n164: cleanup() {\n165:     local exit_code=$?\n166:     \n167:     if [ \"$E2E_PRESERVE_CLUSTER\" = \"true\" ]; then\n168:         log_warn \"Preserving cluster for debugging (E2E_PRESERVE_CLUSTER=true)\"\n169:     else\n170:         log_step \"Cleaning up...\"\n171:         \n172:         # Kill port-forward processes\n173:         pkill -f \"kubectl.*port-forward\" 2>/dev/null || true\n174:         \n175:         if [ \"$E2E_CLEAN_CLUSTER\" = \"true\" ]; then\n176:             log_info \"Deleting Kind cluster...\"\n177:             kind delete cluster --name \"$E2E_CLUSTER_NAME\" 2>/dev/null || true\n178:         fi\n179:     fi\n180:     \n181:     if [ $exit_code -ne 0 ]; then\n182:         log_error \"E2E tests failed with exit code: $exit_code\"\n183:         collect_component_logs\n184:         generate_test_report\n185:     else\n186:         log_success \"All E2E tests passed!\"\n187:         generate_test_report\n188:     fi\n189:     \n190:     exit $exit_code\n191: }\n192: \n193: # Check prerequisites\n194: check_prerequisites() {\n195:     log_step \"Checking prerequisites...\"\n196:     \n197:     local missing=()\n198:     \n199:     command -v kind >/dev/null 2>&1 || missing+=(\"kind\")\n200:     command -v kubectl >/dev/null 2>&1 || missing+=(\"kubectl\")\n201:     command -v helm >/dev/null 2>&1 || missing+=(\"helm\")\n202:     command -v docker >/dev/null 2>&1 || missing+=(\"docker\")\n203:     command -v python3 >/dev/null 2>&1 || missing+=(\"python3\")\n204:     command -v go >/dev/null 2>&1 || missing+=(\"go\")\n205:     \n206:     if [ ${#missing[@]} -gt 0 ]; then\n207:         log_error \"Missing prerequisites: ${missing[*]}\"\n208:         exit 1\n209:     fi\n210:     \n211:     log_success \"All prerequisites installed\"\n212: }\n213: \n214: # Run setup\n215: run_setup() {\n216:     log_step \"Setting up E2E environment...\"\n217:     \n218:     # Check if cluster exists\n219:     if kind get clusters 2>/dev/null | grep -q \"^${E2E_CLUSTER_NAME}$\"; then\n220:         if [ \"$E2E_CLEAN_CLUSTER\" = \"true\" ]; then\n221:             log_info \"Deleting existing cluster...\"\n222:             kind delete cluster --name \"$E2E_CLUSTER_NAME\"\n223:         else\n224:             log_warn \"Using existing cluster\"\n225:         fi\n226:     fi\n227:     \n228:     # Create Kind cluster\n229:     log_info \"Creating Kind cluster '$E2E_CLUSTER_NAME'...\"\n230:     kind create cluster --name \"$E2E_CLUSTER_NAME\"\n231:     \n232:     # Download and apply agent-sandbox manifests\n233:     log_info \"Installing agent-sandbox ${AGENT_SANDBOX_VERSION}...\"\n234:     mkdir -p /tmp/agent-sandbox\n235:     wget -q \"https://github.com/kubernetes-sigs/agent-sandbox/releases/download/${AGENT_SANDBOX_VERSION}/manifest.yaml\" -O /tmp/agent-sandbox/manifest.yaml || {\n236:         log_warn \"Failed to download agent-sandbox manifest, using local copy\"\n237:     }\n238:     wget -q \"https://github.com/kubernetes-sigs/agent-sandbox/releases/download/${AGENT_SANDBOX_VERSION}/extensions.yaml\" -O /tmp/agent-sandbox/extensions.yaml || {\n239:         log_warn \"Failed to download agent-sandbox extensions, using local copy\"\n240:     }\n241:     \n242:     if [ -f /tmp/agent-sandbox/manifest.yaml ]; then\n243:         kubectl apply --validate=false -f /tmp/agent-sandbox/manifest.yaml\n244:     fi\n245:     if [ -f /tmp/agent-sandbox/extensions.yaml ]; then\n246:         kubectl apply --validate=false -f /tmp/agent-sandbox/extensions.yaml\n247:     fi\n248:     \n249:     # Pull required images\n250:     log_info \"Pulling required images...\"\n251:     docker pull \"registry.k8s.io/agent-sandbox/agent-sandbox-controller:${AGENT_SANDBOX_VERSION}\" || true\n252:     docker pull python:3.9-slim || true\n253:     docker pull \"$REDIS_IMAGE\" || true\n254:     \n255:     # Build local images\n256:     log_info \"Building local images...\"\n257:     make docker-build || {\n258:         log_error \"Failed to build workload manager image\"\n259:         exit 1\n260:     }\n261:     make docker-build-router || {\n262:         log_error \"Failed to build router image\"\n263:         exit 1\n264:     }\n265:     make docker-build-picod || true\n266:     \n267:     # Load images to Kind\n268:     log_info \"Loading images to Kind cluster...\"\n269:     kind load docker-image \"workloadmanager:latest\" --name \"$E2E_CLUSTER_NAME\"\n270:     kind load docker-image \"agentcube-router:latest\" --name \"$E2E_CLUSTER_NAME\"\n271:     kind load docker-image \"picod:latest\" --name \"$E2E_CLUSTER_NAME\" 2>/dev/null || true\n272:     kind load docker-image \"$REDIS_IMAGE\" --name \"$E2E_CLUSTER_NAME\"\n273:     kind load docker-image \"registry.k8s.io/agent-sandbox/agent-sandbox-controller:${AGENT_SANDBOX_VERSION}\" --name \"$E2E_CLUSTER_NAME\"\n274:     \n275:     # Create namespace\n276:     kubectl create namespace \"$AGENTCUBE_NAMESPACE\" --dry-run=client -o yaml | kubectl apply -f -\n277:     \n278:     # Install Redis\n279:     log_info \"Installing Redis...\"\n280:     kubectl -n \"$AGENTCUBE_NAMESPACE\" run redis --image=\"$REDIS_IMAGE\" --port=6379 --dry-run=client -o yaml | kubectl apply -f -\n281:     kubectl -n \"$AGENTCUBE_NAMESPACE\" expose pod redis --port=6379 --target-port=6379 --dry-run=client -o yaml | kubectl apply -f -\n282:     \n283:     # Wait for Redis\n284:     log_info \"Waiting for Redis to be ready...\"\n285:     kubectl -n \"$AGENTCUBE_NAMESPACE\" wait --for=condition=ready pod/redis --timeout=120s || {\n286:         log_warn \"Redis not ready, continuing anyway\"\n287:     }\n288:     \n289:     # Install AgentCube via Helm\n290:     log_info \"Installing AgentCube chart...\"\n291:     helm upgrade --install agentcube manifests/charts/base \\\n292:         --namespace \"$AGENTCUBE_NAMESPACE\" \\\n293:         --create-namespace \\\n294:         --set redis.host=\"redis.${AGENTCUBE_NAMESPACE}.svc.cluster.local\" \\\n295:         --set redis.port=6379 \\\n296:         --set redis.password=\"\" \\\n297:         --set workloadmanager.image.repository=workloadmanager \\\n298:         --set workloadmanager.image.tag=latest \\\n299:         --set router.image.repository=agentcube-router \\\n300:         --set router.image.tag=latest \\\n301:         --set router.rbac.create=true \\\n302:         --set router.serviceAccountName=agentcube-router \\\n303:         --set-json='workloadmanager.extraEnv=[{\"name\":\"REDIS_PASSWORD_REQUIRED\",\"value\":\"false\"},{\"name\":\"JWT_KEY_SECRET_NAMESPACE\",\"value\":\"agentcube\"}]' \\\n304:         --set-json='router.extraEnv=[{\"name\":\"REDIS_PASSWORD_REQUIRED\",\"value\":\"false\"}]' \\\n305:         --wait --timeout 5m || {\n306:         log_error \"Failed to install AgentCube\"\n307:         exit 1\n308:     }\n309:     \n310:     # Apply fixtures\n311:     log_info \"Applying E2E fixtures...\"\n312:     kubectl apply -f test/e2e/echo_agent.yaml\n313:     kubectl apply -f test/e2e/e2e_code_interpreter.yaml\n314:     kubectl apply -f test/e2e/e2e_code_interpreter_warmpool.yaml || log_warn \"Failed to apply warm pool fixture\"\n315:     kubectl apply -f test/e2e/stress_test_agent.yaml || log_warn \"Failed to apply stress test fixture\"\n316:     kubectl apply -f test/e2e/multi_session_agent.yaml || log_warn \"Failed to apply multi-session fixture\"\n317:     kubectl apply -f test/e2e/e2e_advanced_interpreter.yaml || log_warn \"Failed to apply advanced interpreter fixture\"\n318:     \n319:     # Generate short TTL agent\n320:     sed 's/sessionTimeout: \"5m\"/sessionTimeout: \"30s\"/' test/e2e/echo_agent.yaml | \\\n321:         sed 's/name: echo-age