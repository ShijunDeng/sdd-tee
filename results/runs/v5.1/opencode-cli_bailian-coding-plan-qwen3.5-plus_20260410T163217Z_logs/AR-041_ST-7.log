if [ \"$E2E_SKIP_SETUP\" != \"true\" ]; then\n462:         run_setup\n463:     fi\n464:     \n465:     run_tests\n466:     print_summary\n467: }\n468: \n469: # Parse command line arguments\n470: while [[ $# -gt 0 ]]; do\n471:     case $1 in\n472:         --skip-setup)\n473:             E2E_SKIP_SETUP=true\n474:             shift\n475:             ;;\n476:         --preserve-cluster)\n477:             E2E_PRESERVE_CLUSTER=true\n478:             shift\n479:             ;;\n480:         --clean-cluster)\n481:             E2E_CLEAN_CLUSTER=true\n482:             shift\n483:             ;;\n484:         --debug)\n485:             E2E_DEBUG=true\n486:             shift\n487:             ;;\n488:         --help|-h)\n489:             echo \"Usage: $0 [OPTIONS]\"\n490:             echo \"\"\n491:             echo \"Options:\"\n492:             echo \"  --skip-setup       Skip cluster setup\"\n493:             echo \"  --preserve-cluster Don't delete cluster after tests\"\n494:             echo \"  --clean-cluster    Delete existing cluster before tests\"\n495:             echo \"  --debug           Enable debug logging\"\n496:             echo \"  --help, -h        Show this help message\"\n497:             exit 0\n498:             ;;\n499:         *)\n500:             log_error \"Unknown option: $1\"\n501:             exit 1\n502:             ;;\n503:     esac\n504: done\n505: \n506: main \"$@\"\n\n(End of file - total 506 lines)\n</content>","metadata":{"preview":"#!/bin/bash\n# E2E test runner for AgentCube\n# This script sets up a Kind cluster, installs dependencies, and runs E2E tests\n# with enhanced error handling, reporting, and cleanup\n\nset -euo pipefail\n\n# Load configuration\nsource \"$(dirname \"$0\")/config.env\"\n\n# Test state tracking\nTEST_START_TIME=\"\"\nTEST_RESULTS=()\nTEST_FAILURES=0\nTEST_SKIPPED=0\n\n# Colors for output\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cl