ts\ndrwxr-xr-x 10 root root     4096 Apr 11 07:39 pkg\n-rw-r--r--  1 root root     1674 Mar 21 15:53 project.md\n-rw-r--r--  1 root root    31518 Apr 11 10:36 proposal_ar_027.md\n-rw-r--r--  1 root root    26004 Apr 11 10:55 proposal_ar_028.md\n-rw-r--r--  1 root root    23214 Apr 11 09:38 proposal.md\ndrwxr-xr-x  3 root root     4096 Apr 11 08:33 .pytest_cache\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 python-sdk\ndrwxr-xr-x  4 root root     4096 Apr 11 02:04 sandbox-orchestration\n-rw-r--r--  1 root root    18687 Apr 11 10:57 .sdd_prompt.md\ndrwxr-xr-x  2 root root     4096 Apr 11 10:57 sdk-python\ndrwxr-xr-x  2 root root     4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 session-store\ndrwxr-xr-x  2 root root     4096 Mar 25 09:51 testing\n-rw-r--r--  1 root root     1983 Mar 25 09:36 test_spec.md\n-rw-r--r--  1 root root     8552 Apr 11 01:56 verification-report.md\n","exit":0,"description":"List workspace directory contents","truncated":false},"title":"List workspace directory contents","time":{"start":1775876279019,"end":1775876279226}}}}
