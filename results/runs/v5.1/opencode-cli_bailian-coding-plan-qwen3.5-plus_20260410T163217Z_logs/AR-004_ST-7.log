ource not found\"\n43: \tcase apierrors.IsAlreadyExists(err):\n44: \t\treturn http.StatusConflict, 40901, \"resource already exists\"\n45: \tcase apierrors.IsConflict(err):\n46: \t\treturn http.StatusConflict, 40902, \"resourceVersion conflict\"\n47: \tcase apierrors.IsInvalid(err):\n48: \t\treturn http.StatusBadRequest, 40003, err.Error()\n49: \tdefault:\n50: \t\treturn http.StatusInternalServerError, 50002, \"kubernetes API error\"\n51: \t}\n52: }\n53: \n54: func (h *AgentRuntimeHandler) CreateAgentRuntime(c *gin.Context) {\n55: \tvar ar runtimev1alpha1.AgentRuntime\n56: \tif err := c.ShouldBindJSON(&ar); err != nil {\n57: \t\tresponse.Error(c, http.StatusBadRequest, 40002, \"invalid JSON: \"+err.Error())\n58: \t\treturn\n59: \t}\n60: \n61: \tns, err := getNamespace(c)\n62: \tif err != nil {\n63: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n64: \t\treturn\n65: \t}\n66: \tif ns == \"\" && ar.Namespace == \"\" {\n67: \t\tresponse.Error(c, http.StatusBadRequest, 40001, \"missing required parameter: namespace\")\n68: \t\treturn\n69: \t}\n70: \tif ns != \"\" {\n71: \t\tar.Namespace = ns\n72: \t}\n73: \n74: \tif ar.Name == \"\" {\n75: \t\tresponse.Error(c, http.StatusBadRequest, 40003, \"metadata.name is required\")\n76: \t\treturn\n77: \t}\n78: \n79: \tif ar.Spec.Container.Image == \"\" {\n80: \t\tresponse.Error(c, http.StatusBadRequest, 40003, \"spec.container.image is required\")\n81: \t\treturn\n82: \t}\n83: \n84: \tar.TypeMeta = metav1.TypeMeta{\n85: \t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n86: \t\tKind:       \"AgentRuntime\",\n87: \t}\n88: \n89: \tunstructuredObj, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&ar)\n90: \tif err != nil {\n91: \t\tresponse.Error(c, http.StatusInternalServerError, 50001, \"failed to convert to unstructured: \"+err.Error())\n92: \t\treturn\n93: \t}\n94: \n95: \tcreated, err := h.resource.Namespace(ar.Namespace).Create(c.Request.Context(), &unstructured