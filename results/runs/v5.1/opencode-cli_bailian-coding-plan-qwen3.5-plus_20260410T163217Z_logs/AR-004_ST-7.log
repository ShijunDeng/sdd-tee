\tcfg.ResyncPeriod = d\n53: \t}\n54: \n55: \tif debug := os.Getenv(\"WORKLOAD_MANAGER_DEBUG\"); debug == \"true\" {\n56: \t\tcfg.Debug = true\n57: \t}\n58: \n59: \treturn cfg, nil\n60: }\n\n(End of file - total 60 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"time\"\n)\n\ntype Config struct {\n\tPort         int\n\tKubeConfig   string\n\tNamespace    string\n\tResyncPeriod time.Duration\n\tDebug        bool\n}\n\nfunc DefaultConfig() *Config {\n\treturn &Config{\n\t\tPort:         8080,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/config.go","time":{"start":1775842621946,"end":1775842621987}}}}
