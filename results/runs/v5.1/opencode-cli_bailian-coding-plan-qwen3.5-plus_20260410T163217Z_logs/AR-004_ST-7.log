: \t\tciGroup.GET(\"\", ciHandler.ListCodeInterpreters)\n38: \t\tciGroup.GET(\"/:name\", ciHandler.GetCodeInterpreter)\n39: \t\tciGroup.PUT(\"/:name\", ciHandler.UpdateCodeInterpreter)\n40: \t\tciGroup.DELETE(\"/:name\", ciHandler.DeleteCodeInterpreter)\n41: \t}\n42: }\n\n(End of file - total 42 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/dynamic\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/middleware\"\n)\n\ntype Dependencies struct {\n\tClient dynamic.Interface\n}\n\nfunc SetupRoutes(engine *gin.Engine, deps *Dependencies, health *handler.HealthHandler) {\n\tengine.Use(gin.Recovery())\n\tengine.Use(gin.Logger())\n\tengine.Use(middleware.RequestIDMiddleware())\n\n\tengine.GET(\"/healthz\", health.HealthzHandler)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/routes.go","time":{"start":1775842621941,"end":1775842621985}}}}
