: }\n57: \n58: func WithSecurityOpts(opts *SecurityOptions) Option {\n59: \treturn func(p *PicoD) {\n60: \t\tp.securityOpts = opts\n61: \t}\n62: }\n63: \n64: func WithLogger(logger klog.Logger) Option {\n65: \treturn func(p *PicoD) {\n66: \t\tklog.SetLogger(logger)\n67: \t\tp.logger = logger\n68: \t}\n69: }\n70: \n71: func WithFileQuota(quota *FileQuota) Option {\n72: \treturn func(p *PicoD) {\n73: \t\tp.fileQuota = quota\n74: \t}\n75: }\n76: \n77: func (p *PicoD) Run(ctx context.Context, cmd *Command) (*CommandResult, error) {\n78: \tklog.V(4).InfoS(\"executing command\", \"path\", cmd.Path, \"args\", cmd.Args)\n79: \n80: \tresult, err := p.executor.Run(ctx, cmd)\n81: \n82: \tif err != nil {\n83: \t\tklog.ErrorS(err, \"command execution failed\", \"path\", cmd.Path)\n84: \t} else {\n85: \t\tklog.V(4).InfoS(\"command completed\", \"path\", cmd.Path, \"exitCode\", result.ExitCode, \"duration\", result.Duration)\n86: \t}\n87: \n88: \treturn result, err\n89: }\n90: \n91: func (p *PicoD) Start(ctx context.Context, cmd *Command) (*Process, error) {\n92: \tklog.V(4).InfoS(\"starting command\", \"path\", cmd.Path, \"args\", cmd.Args)\n93: \n94: \tprocess, err := p.executor.Start(ctx, cmd)\n95: \tif err != nil {\n96: \t\tklog.ErrorS(err, \"failed to start command\", \"path\", cmd.Path)\n97: \t}\n98: \n99: \treturn process, err\n100: }\n\n(Showing lines 1-100 of 153. Use offset=101 to continue.)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\n\t\"k8s.io/klog/v2\"\n)\n\ntype PicoD struct {\n\tsandboxID    string\n\tworkDir      string\n\tlimits       *ResourceLimits\n\tsecurityOpts *SecurityOptions\n\texecutor     *Executor\n\tfileQuota    *FileQuota\n\tfs           FileSystem\n\tlogger       klog.Logger","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/picod/picod.go","time":{"start":1775889297995,"end":1775889298017}}}}
