().Set(\"X-Trace-Id\", traceID)\n50: \t\tc.Next()\n51: \t}\n52: }\n53: \n54: func FormatDuration(ms int64) string {\n55: \treturn fmt.Sprintf(\"%dms\", ms)\n56: }\n57: \n58: func AuthMiddleware(jwtManager *JWTManager) gin.HandlerFunc {\n59: \treturn func(c *gin.Context) {\n60: \t\tauthHeader := c.GetHeader(\"Authorization\")\n61: \t\tif authHeader == \"\" {\n62: \t\t\tc.JSON(401, gin.H{\n63: \t\t\t\t\"error\": \"missing authorization header\",\n64: \t\t\t\t\"code\":  \"UNAUTHORIZED\",\n65: \t\t\t})\n66: \t\t\tc.Abort()\n67: \t\t\treturn\n68: \t\t}\n69: \n70: \t\tparts := strings.SplitN(authHeader, \" \", 2)\n71: \t\tif len(parts) != 2 || parts[0] != \"Bearer\" || parts[1] == \"\" {\n72: \t\t\tc.JSON(401, gin.H{\n73: \t\t\t\t\"error\": \"invalid authorization format\",\n74: \t\t\t\t\"code\":  \"UNAUTHORIZED\",\n75: \t\t\t})\n76: \t\t\tc.Abort()\n77: \t\t\treturn\n78: \t\t}\n79: \n80: \t\ttoken := parts[1]\n81: \t\tclaims, err := jwtManager.ParseAndValidateToken(token)\n82: \t\tif err != nil {\n83: \t\t\terrMsg := err.Error()\n84: \t\t\tif strings.Contains(errMsg, \"token is expired\") {\n85: \t\t\t\tc.JSON(401, gin.H{\n86: \t\t\t\t\t\"error\": \"token is expired\",\n87: \t\t\t\t\t\"code\":  \"TOKEN_EXPIRED\",\n88: \t\t\t\t})\n89: \t\t\t} else {\n90: \t\t\t\tc.JSON(401, gin.H{\n91: \t\t\t\t\t\"error\": \"invalid token\",\n92: \t\t\t\t\t\"code\":  \"UNAUTHORIZED\",\n93: \t\t\t\t})\n94: \t\t\t}\n95: \t\t\tc.Abort()\n96: \t\t\treturn\n97: \t\t}\n98: \n99: \t\tc.Set(\"claims\", claims)\n100: \t\tc.Next()\n101: \t}\n102: }\n\n(End of file - total 102 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"log/slog\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n)\n\nfunc ConcurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n\tsem := make(chan struct{}, maxConcurrent)\n\treturn func(c *gin.Context) {\n\t\tselect {\n\t\tcase sem <- struct{}{}:\n\t\t\tdefer func() { <-sem }()\n\t\t\tc.Next()\n\t\tdefault:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/middleware.go","time":{"start":1775852342241,"end":1775852342259}}}}
