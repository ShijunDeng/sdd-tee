{"type":"tool_use","timestamp":1775891962915,"sessionID":"ses_2849df3aeffec83aH4jGcJVeZm","part":{"id":"prt_d7b677ecd001Rr0fXb1xoIoj06","messageID":"msg_d7b6775ba0012QA67Wfi5uzcwz","sessionID":"ses_2849df3aeffec83aH4jGcJVeZm","type":"tool","tool":"write","callID":"toolu_240ef88b00e94877b0c6f7a1","state":{"status":"completed","input":{"content":"#!/bin/bash\n# E2E test runner for AgentCube\n# This script sets up a Kind cluster, installs dependencies, and runs E2E tests\n# with enhanced error handling, reporting, and cleanup\n\nset -euo pipefail\n\n# Load configuration\nsource \"$(dirname \"$0\")/config.env\"\n\n# Test state tracking\nTEST_START_TIME=\"\"\nTEST_RESULTS=()\nTEST_FAILURES=0\nTEST_SKIPPED=0\n\n# Colors for output\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nMAGENTA='\\033[0;35m'\nCYAN='\\033[0;36m'\nNC='\\033[0m' # No Color\nBOLD='\\033[1m'\n\n# Logging functions\nlog_info() {\n    echo -e \"${GREEN}${BOLD}[INFO]${NC} $1\"\n}\n\nlog_warn() {\n    echo -e \"${YELLOW}[WARN]${NC} $1\"\n}\n\nlog_error() {\n    echo -e \"${RED}${BOLD}[ERROR]${NC} $1\" >&2\n}\n\nlog_debug() {\n    if [ \"${E2E_DEBUG:-false}\" = \"true\" ]; then\n        echo -e \"${CYAN}[DEBUG]${NC} $1\"\n    fi\n}\n\nlog_step() {\n    echo -e \"${BLUE}${BOLD}[STEP]${NC} $1\"\n}\n\nlog_success() {\n    echo -e \"${GREEN}${BOLD}[SUCCESS]${NC} $1\"\n}\n\nlog_test_result() {\n    local test_name=\"$1\"\n    local status=\"$2\"\n    local duration=\"${3:-0}\"\n    \n    case \"$status\" in\n        PASS)\n            echo -e \"${GREEN}✓${NC} $test_name (${duration}s)\"\n            TEST_RESULTS+=(\"PASS:$test_name:$duration\")\n            ;;\n        FAIL)\n            echo -e \"${RED}✗${NC} $test_name (${duration}s)\"\n            TEST_RESULTS+=(\"FAIL:$test_name:$duration\")\n            ((TEST_FAILURES++)) || true\n            ;;\n        SKIP)\n            echo -e \"${YELLOW}⊘${NC} $test_name\"\n            TEST_RESULTS+=(\"SKIP:$test_name:0\")\n            ((TEST_SKIPPED++)) || true\n            ;;\n    esac\n}\n\n# Collect component logs on failure\ncollect_component_logs() {\n    log_step \"Collecting component logs...\"\n    mkdir -p \"$ARTIFACTS_PATH\"\n    \n    local log_timestamp\n    log_timestamp=$(date +%Y%m%d_%H%M%S)\n    \n    # Collect workload manager logs\n    if kubectl -n \"$AGENTCUBE_NAMESPACE\" logs -l app=workloadmanager > \"$ARTIFACTS_PATH/workloadmanager_${log_timestamp}.log\" 2>/dev/null; then\n        log_debug \"Collected workload manager logs\"\n    else\n        log_warn \"Failed to collect workload manager logs\"\n    fi\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" describe pod -l app=workloadmanager > \"$ARTIFACTS_PATH/workloadmanager_describe_${log_timestamp}.txt\" 2>/dev/null || true\n    \n    # Collect router logs\n    if kubectl -n \"$AGENTCUBE_NAMESPACE\" logs -l app=agentcube-router > \"$ARTIFACTS_PATH/router_${log_timestamp}.log\" 2>/dev/null; then\n        log_debug \"Collected router logs\"\n    else\n        log_warn \"Failed to collect router logs\"\n    fi\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" describe pod -l app=agentcube-router > \"$ARTIFACTS_PATH/router_describe_${log_timestamp}.txt\" 2>/dev/null || true\n    \n    # Collect sandbox pod logs\n    if kubectl -n \"$AGENTCUBE_NAMESPACE\" logs -l app=agent-sandbox-controller > \"$ARTIFACTS_PATH/sandbox_${log_timestamp}.log\" 2>/dev/null; then\n        log_debug \"Collected sandbox logs\"\n    else\n        log_warn \"Failed to collect sandbox logs\"\n    fi\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" describe pod -l app=agent-sandbox-controller > \"$ARTIFACTS_PATH/sandbox_describe_${log_timestamp}.txt\" 2>/dev/null || true\n    \n    # Collect events\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" get events > \"$ARTIFACTS_PATH/events_${log_timestamp}.txt\" 2>/dev/null || true\n    \n    # Collect pod statuses\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" get pods -o wide > \"$ARTIFACTS_PATH/pods_${log_timestamp}.txt\" 2>/dev/null || true\n    \n    log_info \"Logs collected in $ARTIFACTS_PATH\"\n}\n\n# Generate test report\ngenerate_test_report() {\n    local report_file=\"$ARTIFACTS_PATH/test_report_$(date +%Y%m%d_%H%M%S).md\"\n    \n    cat > \"$report_file\" << EOF\n# AgentCube E2E Test Report\n\n**Date:** $(date -Iseconds)\n**Cluster:** $E2E_CLUSTER_NAME\n**Namespace:** $AGENTCUBE_NAMESPACE\n\n## Summary\n\n- **Total Tests:** ${#TEST_RESULTS[@]}\n- **Passed:** $(printf '%s\\n' \"${TEST_RESULTS[@]}\" | grep -c \"^PASS:\" || echo 0)\n- **Failed:** $TEST_FAILURES\n- **Skipped:** $TEST_SKIPPED\n\n## Test Results\n\nEOF\n\n    for result in \"${TEST_RESULTS[@]}\"; do\n        IFS=':' read -r status name duration <<< \"$result\"\n        case \"$status\" in\n            PASS)\n                echo \"- ✓ **$name** (${duration}s)\" >> \"$report_file\"\n                ;;\n            FAIL)\n                echo \"- ✗ **$name** (${duration}s)\" >> \"$report_file\"\n                ;;\n            SKIP)\n                echo \"- ⊘ **$name**\" >> \"$report_file\"\n                ;;\n        esac\n    done\n\n    if [ $TEST_FAILURES -gt 0 ]; then\n        echo -e \"\\n## Failures\\n\" >> \"$report_file\"\n        echo \"See log files in $ARTIFACTS_PATH for details.\" >> \"$report_file\"\n    fi\n\n    log_info \"Test report generated: $report_file\"\n}\n\n# Cleanup function\ncleanup() {\n    local exit_code=$?\n    \n    if [ \"$E2E_PRESERVE_CLUSTER\" = \"true\" ]; then\n        log_warn \"Preserving cluster for debugging (E2E_PRESERVE_CLUSTER=true)\"\n    else\n        log_step \"Cleaning up...\"\n        \n        # Kill port-forward processes\n        pkill -f \"kubectl.*port-forward\" 2>/dev/null || true\n        \n        if [ \"$E2E_CLEAN_CLUSTER\" = \"true\" ]; then\n            log_info \"Deleting Kind cluster...\"\n            kind delete cluster --name \"$E2E_CLUSTER_NAME\" 2>/dev/null || true\n        fi\n    fi\n    \n    if [ $exit_code -ne 0 ]; then\n        log_error \"E2E tests failed with exit code: $exit_code\"\n        collect_component_logs\n        generate_test_report\n    else\n        log_success \"All E2E tests passed!\"\n        generate_test_report\n    fi\n    \n    exit $exit_code\n}\n\n# Check prerequisites\ncheck_prerequisites() {\n    log_step \"Checking prerequisites...\"\n    \n    local missing=()\n    \n    command -v kind >/dev/null 2>&1 || missing+=(\"kind\")\n    command -v kubectl >/dev/null 2>&1 || missing+=(\"kubectl\")\n    command -v helm >/dev/null 2>&1 || missing+=(\"helm\")\n    command -v docker >/dev/null 2>&1 || missing+=(\"docker\")\n    command -v python3 >/dev/null 2>&1 || missing+=(\"python3\")\n    command -v go >/dev/null 2>&1 || missing+=(\"go\")\n    \n    if [ ${#missing[@]} -gt 0 ]; then\n        log_error \"Missing prerequisites: ${missing[*]}\"\n        exit 1\n    fi\n    \n    log_success \"All prerequisites installed\"\n}\n\n# Run setup\nrun_setup() {\n    log_step \"Setting up E2E environment...\"\n    \n    # Check if cluster exists\n    if kind get clusters 2>/dev/null | grep -q \"^${E2E_CLUSTER_NAME}$\"; then\n        if [ \"$E2E_CLEAN_CLUSTER\" = \"true\" ]; then\n            log_info \"Deleting existing cluster...\"\n            kind delete cluster --name \"$E2E_CLUSTER_NAME\"\n        else\n            log_warn \"Using existing cluster\"\n        fi\n    fi\n    \n    # Create Kind cluster\n    log_info \"Creating Kind cluster '$E2E_CLUSTER_NAME'...\"\n    kind create cluster --name \"$E2E_CLUSTER_NAME\"\n    \n    # Download and apply agent-sandbox manifests\n    log_info \"Installing agent-sandbox ${AGENT_SANDBOX_VERSION}...\"\n    mkdir -p /tmp/agent-sandbox\n    wget -q \"https://github.com/kubernetes-sigs/agent-sandbox/releases/download/${AGENT_SANDBOX_VERSION}/manifest.yaml\" -O /tmp/agent-sandbox/manifest.yaml || {\n        log_warn \"Failed to download agent-sandbox manifest, using local copy\"\n    }\n    wget -q \"https://github.com/kubernetes-sigs/agent-sandbox/releases/download/${AGENT_SANDBOX_VERSION}/extensions.yaml\" -O /tmp/agent-sandbox/extensions.yaml || {\n        log_warn \"Failed to download agent-sandbox extensions, using local copy\"\n    }\n    \n    if [ -f /tmp/agent-sandbox/manifest.yaml ]; then\n        kubectl apply --validate=false -f /tmp/agent-sandbox/manifest.yaml\n    fi\n    if [ -f /tmp/agent-sandbox/extensions.yaml ]; then\n        kubectl apply --validate=false -f /tmp/agent-sandbox/extensions.yaml\n    fi\n    \n    # Pull required images\n    log_info \"Pulling required images...\"\n    docker pull \"registry.k8s.io/agent-sandbox/agent-sandbox-controller:${AGENT_SANDBOX_VERSION}\" || true\n    docker pull python:3.9-slim || true\n    docker pull \"$REDIS_IMAGE\" || true\n    \n    # Build local images\n    log_info \"Building local images...\"\n    make docker-build || {\n        log_error \"Failed to build workload manager image\"\n        exit 1\n    }\n    make docker-build-router || {\n        log_error \"Failed to build router image\"\n        exit 1\n    }\n    make docker-build-picod || true\n    \n    # Load images to Kind\n    log_info \"Loading images to Kind cluster...\"\n    kind load docker-image \"workloadmanager:latest\" --name \"$E2E_CLUSTER_NAME\"\n    kind load docker-image \"agentcube-router:latest\" --name \"$E2E_CLUSTER_NAME\"\n    kind load docker-image \"picod:latest\" --name \"$E2E_CLUSTER_NAME\" 2>/dev/null || true\n    kind load docker-image \"$REDIS_IMAGE\" --name \"$E2E_CLUSTER_NAME\"\n    kind load docker-image \"registry.k8s.io/agent-sandbox/agent-sandbox-controller:${AGENT_SANDBOX_VERSION}\" --name \"$E2E_CLUSTER_NAME\"\n    \n    # Create namespace\n    kubectl create namespace \"$AGENTCUBE_NAMESPACE\" --dry-run=client -o yaml | kubectl apply -f -\n    \n    # Install Redis\n    log_info \"Installing Redis...\"\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" run redis --image=\"$REDIS_IMAGE\" --port=6379 --dry-run=client -o yaml | kubectl apply -f -\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" expose pod redis --port=6379 --target-port=6379 --dry-run=client -o yaml | kubectl apply -f -\n    \n    # Wait for Redis\n    log_info \"Waiting for Redis to be ready...\"\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" wait --for=condition=ready pod/redis --timeout=120s || {\n        log_warn \"Redis not ready, continuing anyway\"\n    }\n    \n    # Install AgentCube via Helm\n    log_info \"Installing AgentCube chart...\"\n    helm upgrade --install agentcube manifests/charts/base \\\n        --namespace \"$AGENTCUBE_NAMESPACE\" \\\n        --create-namespace \\\n        --set redis.host=\"redis.${AGENTCUBE_NAMESPACE}.svc.cluster.local\" \\\n        --set redis.port=6379 \\\n        --set redis.password=\"\" \\\n        --set workloadmanager.image.repository=workloadmanager \\\n        --set workloadmanager.image.tag=latest \\\n        --set router.image.repository=agentcube-router \\\n        --set router.image.tag=latest \\\n        --set router.rbac.create=true \\\n        --set router.serviceAccountName=agentcube-router \\\n        --set-json='workloadmanager.extraEnv=[{\"name\":\"REDIS_PASSWORD_REQUIRED\",\"value\":\"false\"},{\"name\":\"JWT_KEY_SECRET_NAMESPACE\",\"value\":\"agentcube\"}]' \\\n        --set-json='router.extraEnv=[{\"name\":\"REDIS_PASSWORD_REQUIRED\",\"value\":\"false\"}]' \\\n        --wait --timeout 5m || {\n        log_error \"Failed to install AgentCube\"\n        exit 1\n    }\n    \n    # Apply fixtures\n    log_info \"Applying E2E fixtures...\"\n    kubectl apply -f test/e2e/echo_agent.yaml\n    kubectl apply -f test/e2e/e2e_code_interpreter.yaml\n    kubectl apply -f test/e2e/e2e_code_interpreter_warmpool.yaml || log_warn \"Failed to apply warm pool fixture\"\n    kubectl apply -f test/e2e/stress_test_agent.yaml || log_warn \"Failed to apply stress test fixture\"\n    kubectl apply -f test/e2e/multi_session_agent.yaml || log_warn \"Failed to apply multi-session fixture\"\n    kubectl apply -f test/e2e/e2e_advanced_interpreter.yaml || log_warn \"Failed to apply advanced interpreter fixture\"\n    \n    # Generate short TTL agent\n    sed 's/sessionTimeout: \"5m\"/sessionTimeout: \"30s\"/' test/e2e/echo_agent.yaml | \\\n        sed 's/name: echo-agent/name: echo-agent-short-ttl/' | \\\n        kubectl apply -f - || log_warn \"Failed to create short TTL agent\"\n    \n    # Wait for deployments\n    log_info \"Waiting for deployments to be ready...\"\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" rollout status deployment/workloadmanager --timeout=120s || {\n        log_error \"WorkloadManager deployment failed\"\n        exit 1\n    }\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" rollout status deployment/agentcube-router --timeout=120s || {\n        log_error \"Router deployment failed\"\n        exit 1\n    }\n    \n    # Set up port forwarding\n    log_info \"Setting up port forwarding...\"\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" port-forward svc/workloadmanager ${WORKLOAD_MANAGER_LOCAL_PORT}:8080 >/dev/null 2>&1 &\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" port-forward svc/agentcube-router ${ROUTER_LOCAL_PORT}:8080 >/dev/null 2>&1\n    sleep 5\n    \n    # Health checks\n    log_info \"Running health checks...\"\n    if ! curl -s \"http://localhost:${WORKLOAD_MANAGER_LOCAL_PORT}/health\" > /dev/null; then\n        log_error \"WorkloadManager health check failed\"\n        exit 1\n    fi\n    \n    if ! curl -s \"http://localhost:${ROUTER_LOCAL_PORT}/health/live\" > /dev/null; then\n        log_error \"Router health check failed\"\n        exit 1\n    fi\n    \n    # Create service account and token for tests\n    log_info \"Creating test service account...\"\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" create sa e2e-test --dry-run=client -o yaml | kubectl apply -f -\n    kubectl -n \"$AGENTCUBE_NAMESPACE\" create clusterrolebinding e2e-test-binding \\\n        --clusterrole=workloadmanager \\\n        --serviceaccount=\"$AGENTCUBE_NAMESPACE\":e2e-test \\\n        --dry-run=client -o yaml | kubectl apply -f -\n    export API_TOKEN=$(kubectl -n \"$AGENTCUBE_NAMESPACE\" create token e2e-test --duration=24h)\n    \n    # Set up Python virtual environment\n    log_info \"Setting up Python virtual environment...\"\n    if [ ! -d \"$E2E_VENV_DIR\" ]; then\n        python3 -m venv \"$E2E_VENV_DIR\"\n        \"$E2E_VENV_DIR/bin/pip\" install --upgrade pip\n        \"$E2E_VENV_DIR/bin/pip\" install -e ./sdk-python || log_warn \"Failed to install agentcube SDK\"\n    fi\n    \n    # Verify agentcube import\n    \"$E2E_VENV_DIR/bin/python\" -c \"import agentcube\" || log_warn \"agentcube module not available\"\n    \n    log_success \"E2E environment setup complete!\"\n}\n\n# Run E2E tests\nrun_tests() {\n    log_step \"Running E2E tests...\"\n    TEST_START_TIME=$(date +%s)\n    \n    # Export environment variables\n    export WORKLOAD_MANAGER_URL=\"http://localhost:${WORKLOAD_MANAGER_LOCAL_PORT}\"\n    export ROUTER_URL=\"http://localhost:${ROUTER_LOCAL_PORT}\"\n    export API_TOKEN\n    export AGENTCUBE_NAMESPACE\n    export E2E_TIMEOUT\n    export E2E_CONCURRENCY\n    \n    # Run Go tests\n    log_info \"Running Go E2E tests...\"\n    if go test -v -timeout=10m ./test/e2e/... -run \"^Test\"; then\n        log_test_result \"Go E2E Tests\" \"PASS\" \"$(($(date +%s) - TEST_START_TIME))\"\n    else\n        log_test_result \"Go E2E Tests\" \"FAIL\" \"$(($(date +%s) - TEST_START_TIME))\"\n        collect_component_logs\n        exit 1\n    fi\n    \n    # Run Python tests\n    log_info \"Running Python E2E tests...\"\n    cd test/e2e\n    if \"$E2E_VENV_DIR/bin/python\" test_codeinterpreter.py --verbose; then\n        log_test_result \"Python E2E Tests\" \"PASS\" \"$(($(date +%s) - TEST_START_TIME))\"\n    else\n        log_test_result \"Python E2E Tests\" \"FAIL\" \"$(($(date +%s) - TEST_START_TIME))\"\n        cd ..\n        collect_component_logs\n        exit 1\n    fi\n    cd ..\n    \n    log_success \"All E2E tests completed successfully!\"\n}\n\n# Print summary\nprint_summary() {\n    local total_time=$(($(date +%s) - TEST_START_TIME))\n    \n    echo \"\"\n    echo -e \"${BOLD}========================================${NC}\"\n    echo -e \"${BOLD}E2E Test Summary${NC}\"\n    echo -e \"${BOLD}========================================${NC}\"\n    echo -e \"Total Tests:    ${#TEST_RESULTS[@]}\"\n    echo -e \"${GREEN}Passed:         $(printf '%s\\n' \"${TEST_RESULTS[@]}\" | grep -c \"^PASS:\" || echo 0)${NC}\"\n    echo -e \"${RED}Failed:         $TEST_FAILURES${NC}\"\n    echo -e \"${YELLOW}Skipped:        $TEST_SKIPPED${NC}\"\n    echo -e \"Total Time:     ${total_time}s\"\n    echo -e \"${BOLD}========================================${NC}\"\n    \n    if [ $TEST_FAILURES -gt 0 ]; then\n        echo -e \"${RED}STATUS: FAILED${NC}\"\n        return 1\n    else\n        echo -e \"${GREEN}STATUS: PASSED${NC}\"\n        return 0\n    fi\n}\n\n# Main\nmain() {\n    trap cleanup EXIT\n    \n    TEST_START_TIME=$(date +%s)\n    \n    echo -e \"${BOLD}${CYAN}\"\n    echo \"=========================================\"\n    echo \"  AgentCube E2E Test Suite\"\n    echo \"=========================================\"\n    echo -e \"${NC}\"\n    \n    log_info \"Configuration:\"\n    log_info \"  Cluster: $E2E_CLUSTER_NAME\"\n    log_info \"  Namespace: $AGENTCUBE_NAMESPACE\"\n    log_info \"  Artifacts: $ARTIFACTS_PATH\"\n    log_info \"  Clean Cluster: $E2E_CLEAN_CLUSTER\"\n    log_info \"  Skip Setup: $E2E_SKIP_SETUP\"\n    echo \"\"\n    \n    check_prerequisites\n    \n    if [ \"$E2E_SKIP_SETUP\" != \"true\" ]; then\n        run_setup\n    fi\n    \n    run_tests\n    print_summary\n}\n\n# Parse command line arguments\nwhile [[ $# -gt 0 ]]; do\n    case $1 in\n        --skip-setup)\n            E2E_SKIP_SETUP=true\n            shift\n            ;;\n        --preserve-cluster)\n            E2E_PRESERVE_CLUSTER=true\n            shift\n            ;;\n        --clean-cluster)\n            E2E_CLEAN_CLUSTER=true\n            shift\n            ;;\n        