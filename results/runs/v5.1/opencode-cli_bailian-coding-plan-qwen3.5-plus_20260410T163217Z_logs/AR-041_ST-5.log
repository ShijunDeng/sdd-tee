.5-plus_20260410T163217Z/test/e2e/e2e_advanced_interpreter.yaml":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_code_interpreter_warmpool.yaml":[]},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/run_e2e.sh","exists":true,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/run_e2e.sh","time":{"start":1775891962685,"end":1775891962908}}}}
