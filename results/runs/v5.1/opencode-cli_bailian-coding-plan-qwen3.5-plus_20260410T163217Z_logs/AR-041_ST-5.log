{"type":"tool_use","timestamp":1775891774623,"sessionID":"ses_2849df3aeffec83aH4jGcJVeZm","part":{"id":"prt_d7b649a2f001Rq7gmnXnkc3rs3","messageID":"msg_d7b6490c3001F0EVV5fuJN3ZaE","sessionID":"ses_2849df3aeffec83aH4jGcJVeZm","type":"tool","tool":"write","callID":"toolu_5b6f3072f7194bd4b9395cd2","state":{"status":"completed","input":{"content":"#!/usr/bin/env python3\n\"\"\"\nE2E tests for AgentCube CodeInterpreter\nComprehensive test suite for AgentCube E2E validation\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport time\nimport unittest\nimport urllib.request\nimport urllib.error\nimport urllib.parse\nfrom typing import Dict, Any, Optional\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\n\n\nclass E2ETestClient:\n    \"\"\"HTTP client for E2E tests.\"\"\"\n\n    def __init__(self, base_url: str, api_token: str = ''):\n        self.base_url = base_url.rstrip('/')\n        self.api_token = api_token\n        self.timeout = 30\n\n    def request(\n        self,\n        method: str,\n        path: str,\n        data: Optional[Dict[str, Any]] = None,\n        headers: Optional[Dict[str, str]] = None\n    ) -> Dict[str, Any]:\n        \"\"\"Make HTTP request.\"\"\"\n        url = f\"{self.base_url}{path}\"\n        \n        req_headers = {\n            'Content-Type': 'application/json',\n        }\n        \n        if self.api_token:\n            req_headers['Authorization'] = f'Bearer {self.api_token}'\n        \n        if headers:\n            req_headers.update(headers)\n        \n        body = json.dumps(data).encode('utf-8') if data else None\n        \n        req = urllib.request.Request(\n            url,\n            data=body,\n            headers=req_headers,\n            method=method\n        )\n        \n        try:\n            with urllib.request.urlopen(req, timeout=self.timeout) as response:\n                response_body = response.read().decode()\n                if response_body:\n                    return json.loads(response_body)\n                return {}\n        except urllib.error.HTTPError as e:\n            error_body = e.read().decode() if e.fp else ''\n            raise Exception(f\"HTTP {e.code}: {error_body}\")\n        except urllib.error.URLError as e:\n            raise Exception(f\"URL Error: {e.reason}\")\n\n\nclass TestCodeInterpreter(unittest.TestCase):\n    \"\"\"Test cases for CodeInterpreter E2E tests.\"\"\"\n\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up test fixtures.\"\"\"\n        cls.workload_manager_url = os.environ.get(\n            'WORKLOAD_MANAGER_URL', 'http://localhost:8080'\n        )\n        cls.router_url = os.environ.get('ROUTER_URL', 'http://localhost:8081')\n        cls.api_token = os.environ.get('API_TOKEN', '')\n        cls.namespace = os.environ.get('AGENTCUBE_NAMESPACE', 'agentcube')\n        \n        cls.wm_client = E2ETestClient(cls.workload_manager_url, cls.api_token)\n        cls.router_client = E2ETestClient(cls.router_url, cls.api_token)\n        \n        print(f\"\\n{'='*60}\")\n        print(f\"E2E Test Configuration:\")\n        print(f\"  Workload Manager: {cls.workload_manager_url}\")\n        print(f\"  Router: {cls.router_url}\")\n        print(f\"  Namespace: {cls.namespace}\")\n        print(f\"{'='*60}\\n\")\n\n    def test_01_workload_manager_health(self):\n        \"\"\"Test workload manager health endpoint.\"\"\"\n        try:\n            result = self.wm_client.request('GET', '/health')\n            self.assertIn('status', result)\n            print(f\"✓ Workload Manager health: {result.get('status', 'unknown')}\")\n        except Exception as e:\n            self.fail(f\"Workload Manager health check failed: {e}\")\n\n    def test_02_router_health_live(self):\n        \"\"\"Test router live health endpoint.\"\"\"\n        try:\n            self.router_client.request('GET', '/health/live')\n            print(\"✓ Router live health check passed\")\n        except Exception as e:\n            self.fail(f\"Router live health check failed: {e}\")\n\n    def test_03_router_health_ready(self):\n        \"\"\"Test router ready health endpoint.\"\"\"\n        try:\n            result = self.router_client.request('GET', '/health/ready')\n            self.assertTrue(result.get('ready', False), \"Router is not ready\")\n            print(\"✓ Router ready check passed\")\n        except Exception as e:\n            print(f\"⚠ Router ready check skipped: {e}\")\n            self.skipTest(str(e))\n\n    def test_04_invoke_echo_agent(self):\n        \"\"\"Test echo agent invocation.\"\"\"\n        payload = {\n            'message': 'Hello from E2E test!'\n        }\n        \n        try:\n            result = self.router_client.request(\n                'POST',\n                '/invoke/echo-agent',\n                data=payload\n            )\n            self.assertEqual(result.get('status'), 'success')\n            print(f\"✓ Echo agent invocation successful\")\n            print(f\"  Response: {json.dumps(result, indent=2)}\")\n        except Exception as e:\n            self.fail(f\"Echo agent invocation failed: {e}\")\n\n    def test_05_code_interpreter_basic(self):\n        \"\"\"Test basic code interpreter execution.\"\"\"\n        payload = {\n            'code': 'print(\"Hello from Python E2E test\")',\n            'language': 'python'\n        }\n        \n        try:\n            result = self.router_client.request(\n                'POST',\n                '/invoke/e2e-code-interpreter',\n                data=payload\n            )\n            self.assertIn('status', result)\n            print(f\"✓ Code interpreter execution successful\")\n            print(f\"  Result: {json.dumps(result, indent=2)}\")\n        except Exception as e:\n            self.fail(f\"Code interpreter execution failed: {e}\")\n\n    def test_06_code_interpreter_math(self):\n        \"\"\"Test code interpreter with mathematical computation.\"\"\"\n        payload = {\n            'code': '''\nimport math\nresult = math.sqrt(144)\nprint(f\"Square root of 144 is {result}\")\n{\"result\": result}\n''',\n            'language': 'python'\n        }\n        \n        try:\n            result = self.router_client.request(\n                'POST',\n                '/invoke/e2e-code-interpreter',\n                data=payload\n            )\n            print(f\"✓ Math computation successful\")\n            print(f\"  Output: {result}\")\n        except Exception as e:\n            print(f\"⚠ Math computation skipped: {e}\")\n            self.skipTest(str(e))\n\n    def test_07_code_interpreter_data_processing(self):\n        \"\"\"Test code interpreter with data processing.\"\"\"\n        payload = {\n            'code': '''\nimport json\ndata = [1, 2, 3, 4, 5]\nresult = {\n    \"sum\": sum(data),\n    \"avg\": sum(data) / len(data),\n    \"max\": max(data),\n    \"min\": min(data)\n}\nprint(json.dumps(result))\n''',\n            'language': 'python'\n        }\n        \n        try:\n            result = self.router_client.request(\n                'POST',\n                '/invoke/e2e-code-interpreter',\n                data=payload\n            )\n            print(f\"✓ Data processing successful\")\n            print(f\"  Output: {result}\")\n        except Exception as e:\n            print(f\"⚠ Data processing skipped: {e}\")\n            self.skipTest(str(e))\n\n    def test_08_session_creation(self):\n        \"\"\"Test session creation for code interpreter.\"\"\"\n        payload = {\n            'interpreter': 'e2e-code-interpreter',\n            'namespace': self.namespace,\n            'ttl': '120s'\n        }\n        \n        try:\n            result = self.wm_client.request(\n                'POST',\n                '/api/v1/sessions',\n                data=payload\n            )\n            self.assertIn('sessionId', result)\n            session_id = result['sessionId']\n            print(f\"✓ Session created: {session_id}\")\n            \n            session_payload = {'code': 'print(\"Session test\")'}\n            session_result = self.router_client.request(\n                'POST',\n                f'/session/{session_id}',\n                data=session_payload\n            )\n            print(f\"✓ Session invocation successful\")\n            \n            self.wm_client.request('DELETE', f'/api/v1/sessions/{session_id}')\n            print(f\"✓ Session cleaned up\")\n            \n        except Exception as e:\n            error_msg = str(e)\n            if '404' in error_msg or 'not found' in error_msg.lower():\n                print(f\"⚠ Sessions API not available\")\n                self.skipTest(\"Sessions API not available\")\n            else:\n                print(f\"⚠ Session creation skipped: {e}\")\n                self.skipTest(str(e))\n\n    def test_09_concurrent_invocations(self):\n        \"\"\"Test concurrent agent invocations.\"\"\"\n        concurrency = 5\n        results = {'success': 0, 'failed': 0, 'errors': []}\n        \n        def invoke_agent(task_id: int) -> bool:\n            payload = {'message': f'Concurrent test {task_id}'}\n            try:\n                result = self.router_client.request(\n                    'POST',\n                    '/invoke/echo-agent',\n                    data=payload\n                )\n                return result.get('status') == 'success'\n            except Exception as e:\n                results['errors'].append(f\"Task {task_id}: {e}\")\n                return False\n        \n        with ThreadPoolExecutor(max_workers=concurrency) as executor:\n            futures = [executor.submit(invoke_agent, i) for i in range(concurrency)]\n            \n            for future in as_completed(futures):\n                if future.result():\n                    results['success'] += 1\n                else:\n                    results['failed'] += 1\n        \n        print(f\"✓ Concurrent test: {results['success']}/{concurrency} succeeded\")\n        \n        if results['errors']:\n            print(f\"  Errors: {results['errors']}\")\n        \n        self.assertGreaterEqual(\n            results['success'],\n            concurrency - 1,\n            f\"Expected at least {concurrency-1} successes\"\n        )\n\n    def test_10_invalid_agent_invocation(self):\n        \"\"\"Test invalid agent invocation handling.\"\"\"\n        payload = {'message': 'Test invalid agent'}\n        \n        try:\n            self.router_client.request(\n                'POST',\n                '/invoke/non-existent-agent',\n                data=payload\n            )\n            self.fail(\"Expected error for non-existent agent\")\n        except Exception as e:\n            error_msg = str(e)\n            if '404' in error_msg or '400' in error_msg:\n                print(f\"✓ Invalid agent correctly rejected: {error_msg}\")\n            else:\n                print(f\"⚠ Unexpected error: {e}\")\n\n    def test_11_malformed_request(self):\n        \"\"\"Test malformed request handling.\"\"\"\n        try:\n            url = f\"{self.router_url}/invoke/echo-agent\"\n            req_headers = {'Content-Type': 'application/json'}\n            if self.api_token:\n                req_headers['Authorization'] = f'Bearer {self.api_token}'\n            \n            req = urllib.request.Request(\n                url,\n                data=b'invalid json{',\n                headers=req_headers,\n                method='POST'\n            )\n            \n            urllib.request.urlopen(req, timeout=10)\n            print(\"⚠ Malformed request not rejected\")\n        except urllib.error.HTTPError as e:\n            if e.code == 400:\n                print(f\"✓ Malformed request correctly rejected with 400\")\n            else:\n                print(f\"⚠ Malformed request returned {e.code}\")\n        except Exception as e:\n            print(f\"⚠ Malformed request test: {e}\")\n\n    def test_12_metrics_endpoint(self):\n        \"\"\"Test metrics endpoint availability.\"\"\"\n        try:\n            url = f\"{self.workload_manager_url}/metrics\"\n            req = urllib.request.Request(url)\n            with urllib.request.urlopen(req, timeout=10) as response:\n                body = response.read().decode()\n                self.assertGreater(len(body), 0, \"Metrics body is empty\")\n                print(f\"✓ Metrics endpoint returned {len(body)} bytes\")\n        except Exception as e:\n            print(f\"⚠ Metrics endpoint not available: {e}\")\n            self.skipTest(str(e))\n\n    def test_13_router_metrics(self):\n        \"\"\"Test router metrics endpoint.\"\"\"\n        try:\n            url = f\"{self.router_url}/metrics\"\n            req = urllib.request.Request(url)\n            with urllib.request.urlopen(req, timeout=10) as response:\n                body = response.read().decode()\n                self.assertGreater(len(body), 0, \"Router metrics body is empty\")\n                print(f\"✓ Router metrics endpoint returned {len(body)} bytes\")\n        except Exception as e:\n            print(f\"⚠ Router metrics not available: {e}\")\n            self.skipTest(str(e))\n\n    def test_14_warm_pool_latency(self):\n        \"\"\"Test warm pool code interpreter latency.\"\"\"\n        payload = {\n            'code': 'import time; start = time.time(); print(f\"Latency: {time.time() - start:.3f}s\")',\n            'language': 'python'\n        }\n        \n        try:\n            start_time = time.time()\n            result = self.router_client.request(\n                'POST',\n                '/invoke/e2e-code-interpreter-warmpool',\n                data=payload\n            )\n            elapsed = time.time() - start_time\n            \n            print(f\"✓ Warm pool response in {elapsed:.3f}s\")\n            print(f\"  Result: {result}\")\n            \n            if elapsed > 5.0:\n                print(f\"⚠ Warning: Warm pool latency higher than expected\")\n                \n        except Exception as e:\n            error_msg = str(e)\n            if '404' in error_msg or 'not found' in error_msg.lower():\n                print(f\"⚠ Warm pool interpreter not configured\")\n                self.skipTest(\"Warm pool not configured\")\n            else:\n                print(f\"⚠ Warm pool test skipped: {e}\")\n                self.skipTest(str(e))\n\n    def test_15_code_execution_timeout(self):\n        \"\"\"Test code execution with timeout handling.\"\"\"\n        payload = {\n            'code': 'import time; time.sleep(2); print(\"Completed\")',\n            'language': 'python',\n            'timeout': '5s'\n        }\n        \n        try:\n            result = self.router_client.request(\n                'POST',\n                '/invoke/e2e-code-interpreter',\n                data=payload\n            )\n            print(f\"✓ Timeout handling test passed\")\n            print(f\"  Result: {result}\")\n        except Exception as e:\n            print(f\"⚠ Timeout test skipped: {e}\")\n            self.skipTest(str(e))\n\n    def test_16_code_with_output_capture(self):\n        \"\"\"Test code execution with stdout/stderr capture.\"\"\"\n        payload = {\n            'code': '''\nimport sys\nprint(\"stdout output\", flush=True)\nprint(\"stderr output\", file=sys.stderr, flush=True)\n{\"status\": \"success\"}\n''',\n            'language': 'python'\n        }\n        \n        try:\n            result = self.router_client.request(\n                'POST',\n                '/invoke/e2e-code-interpreter',\n                data=payload\n            )\n            print(f\"✓ Output capture test passed\")\n            print(f\"  Result: {result}\")\n        except Exception as e:\n            print(f\"⚠ Output capture test skipped: {e}\")\n            self.skipTest(str(e))\n\n    def test_17_multi_step_code_execution(self):\n        \"\"\"Test multi-step code execution in same session.\"\"\"\n        steps = [\n            {'code': 'x = 10', 'language': 'python'},\n            {'code': 'y = 20', 'language': 'python'},\n            {'code': 'print(f\"Sum: {x + y}\")', 'language': 'python'},\n        ]\n        \n        results = []\n        for i, step in enumerate(steps):\n            try:\n                result = self.router_client.request(\n                    'POST',\n                    '/invoke/e2e-code-interpreter',\n                    data=step\n                )\n                results.append(result)\n                print(f\"✓ Step {i+1} completed\")\n            except Exception as e:\n                print(f\"⚠ Step {i+1} failed: {e}\")\n                break\n        \n        self.assertEqual(len(results), len(steps), \"Not all steps completed\")\n\n    def test_18_code_interpreter_error_handling(self):\n        \"\"\"Test code interpreter error handling.\"\"\"\n        payload = {\n            'code': 'raise ValueError(\"Intentional error for testing\")',\n            'language': 'python'\n        }\n        \n        try:\n            result = self.router_client.request(\n                'POST',\n                '/invoke/e2e-code-interpreter',\n                data=payload\n            )\n            print(f\"✓ Error handling test: {result.get('status', 'unknown')}\")\n            print(f\"  Error info: {result}\")\n        except Exception as e:\n            error_msg = str(e)\n            if '500' in error_msg or 'error' in error_msg.lower():\n                print(f\"✓ Error correctly reported: {error_msg}\")\n            else:\n                print(f\"⚠ Unexpected error response: {e}\")\n\n    def test_19_agent_runtime_status(self):\n        \"\"\"Test agent runtime status query.\"\"\"\n        try:\n            url = f\"{self.workload_manager_url}/api/v1/runtimes\"\n            req = urllib.request.Request(url)\n            if self.api_token:\n                req.add_header('Authorization', f'Bearer {self.api_token}')\n            \n            with urllib.request.urlopen(req, timeout=10) as response:\n                result = json.loads(response.read().decode())\n                print(f\"✓ Agent runtime status query successful\")\n                print(f\"  Runtimes: {len(result.get('items', []))}\")\n        except Exception as e:\n            error_msg = str(e)\n            if '404' in error_msg:\n                print(f\"⚠ Runtime status API not available\")\n                self.skipTest(\"Runtime status API not available\")\n            else:\n                print(f\"⚠ Runtime status query skipped: {e}\")\n                self.skipTest(str(e))\n\n    def test_20_load_balancing(self):\n        \"\"\"Test load balancing across multiple instances.\"\"\"\n        invocation_count = 10\n        instance_ids = []\n        \n        for i in range(invocation_count):\n            payload = {'message': f'Load test {i}'}\n            try:\n                result = self.router_client.request(\n                    'POST',\n                    '/invoke/echo-agent',\n                    data=payload\n                )\n                if 'instance' in result:\n                    instance_ids.append(result['instance'])\n            except Exception as e:\n                print(f\"⚠ Load test invocation {i} failed: {e}\")\n        \n        if instance_ids:\n            unique_instances = set(instance_ids)\n            print(f\"✓ Load balancing test: {len(unique_instances)} instance(s) used\")\n            print(f\"  Distribution: {instance_ids}\")\n        else:\n            print(f\"⚠ Load balancing test: No instance IDs returned\")\n\n\nclass TestNamespaceIsolation(unittest.TestCase):\n    \"\"\"Tests for namespace isolation and multi-tenancy.\"\"\"\n\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up test fixtures.\"\"\"\n        cls.workload_manager_url = os.environ.get(\n            'WORKLOAD_MANAGER_URL', 'http://localhost:8080'\n        )\n        cls.api_token = os.environ.get('API_TOKEN', '')\n        cls.namespace = os.environ.get('AGENTCUBE_NAMESPACE', 'agentcube')\n        cls.client = E2ETestClient(cls.workload_manager_url, cls.api_token)\n\n    def test_namespace_specific_interpreter(self):\n        \"\"\"Test interpreter access with namespace specification.\"\"\"\n        payload = {\n            'interpreter': 'e2e-code-interpreter',\n            'namespace': self.namespace,\n            'code': 'print(\"Namespace test\")'\n        }\n        \n        try:\n            result = self.client.request(\n                'POST',\n                '/api/v1/invoke',\n                data=payload\n            )\n            print(f\"✓ Namespace-specific invocation successful\")\n        except Exception as e:\n            print(f\"⚠ Namespace test skipped: {e}\")\n            self.skipTest(str(e))\n\n\nclass TestResourceManagement(unittest.TestCase):\n    \"\"\"Tests for resource management and quotas.\"\"\"\n\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up test fixtures.\"\"\"\n        cls.workload_manager_url = os.environ.get(\n            'WORKLOAD_MANAGER_URL', 'http://localhost:8080'\n        )\n        cls.api_token = os.environ.get('API_TOKEN', '')\n        cls.client = E2ETestClient(cls.workload_manager_url, cls.api_token)\n\n    def test_resource_quota_enforcement(self):\n        \"\"\"Test resource quota enforcement.\"\"\"\n        payload = {\n            'interpreter': 'e2e-code-interpreter',\n            'resources': {\n                'cpu': '100m',\n                'memory': '128Mi'\n            }\n        }\n        \n        try:\n            result = self.client.request(\n                'POST',\n                '/api/v1/sessions',\n                data=payload\n            )\n            print(f\"✓ Resource quota test passed\")\n        except Exception as e:\n            error_msg = str(e)\n            if 'quota' in error_msg.lower() or 'resource' in error_msg.lower():\n                print(f\"✓ Resource quota enforced: {error_msg}\")\n            else:\n                print(f\"⚠ Resource quota test skipped: {e}\")\n                self.skipTest(str(e))\n\n\nif __name__ == '__main__':\n    if '--verbose' not in sys.argv and '-v' not in sys.argv:\n        sys.argv.append('--verbose')\n    \n    unittest.main(verbosity=2)\n","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/test_codeinterpreter.py"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/client-go/listers/runtime/v1alpha1/agentruntime.go\">\nERROR [27:16] undefined: labels\nERROR [27:37] undefined: runtimev1alpha1\nERROR [39:44] undefined: labels\nERROR [39:65] undefined: runtimev1alpha1\nERROR [40:14] undefined: runtimev1alpha1\nERROR [42:27] undefined: runtimev1alpha1\nERROR [52:16] undefined: labels\nERROR [52:37] undefined: runtimev1alpha1\nERROR [53:21] undefined: runtimev1alpha1\nERROR [61:52] undefined: labels\nERROR [61:73] undefined: runtimev1alpha1\nERROR [62:14] undefined: runtimev1alpha1\nERROR [64:27] undefined: runtimev1alpha1\nERROR [69:57] undefined: runtimev1alpha1\nERROR [72:15] undefined: errors\nERROR [72:34] undefined: runtimev1alpha1\nERROR [77:15] undefined: runtimev1alpha1\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/client-go/clientset/versioned/typed/runtime/v1alpha1/fake/fake_runtime_client.go\">\nERROR [26:3] undefined: testing\nERROR [30:9] cannot use &FakeAgentRuntimes{…} (value of type *FakeAgentRuntimes) as \"github.com/volcano-sh/agentcube/client-go/clientset/versioned/typed/runtime/v1alpha1\".AgentRuntimeInterface value in return statement: *FakeAgentRuntimes does not implement \"github.com/volcano-sh/agentcube/