{"type":"tool_use","timestamp":1775891673488,"sessionID":"ses_2849df3aeffec83aH4jGcJVeZm","part":{"id":"prt_d7b631bb1001h5NR31F7qK34x5","messageID":"msg_d7b630763001hOKzeqJEMq3lBx","sessionID":"ses_2849df3aeffec83aH4jGcJVeZm","type":"tool","tool":"write","callID":"toolu_1cb5ece3b1c14b28b23d0ea6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/test/e2e/e2e_test.go","content":"// Copyright 2026 AgentCube Authors\n// E2E tests for AgentCube\n\npackage e2e\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/tools/clientcmd\"\n)\n\nvar (\n\tworkloadManagerURL string\n\trouterURL          string\n\tapiToken           string\n\tclient             *http.Client\n\tk8sClient          *kubernetes.Clientset\n\tnamespace          string\n)\n\nfunc TestMain(m *testing.M) {\n\tworkloadManagerURL = os.Getenv(\"WORKLOAD_MANAGER_URL\")\n\trouterURL = os.Getenv(\"ROUTER_URL\")\n\tapiToken = os.Getenv(\"API_TOKEN\")\n\tnamespace = os.Getenv(\"AGENTCUBE_NAMESPACE\")\n\n\tif workloadManagerURL == \"\" {\n\t\tworkloadManagerURL = \"http://localhost:8080\"\n\t}\n\tif routerURL == \"\" {\n\t\trouterURL = \"http://localhost:8081\"\n\t}\n\tif namespace == \"\" {\n\t\tnamespace = \"agentcube\"\n\t}\n\tif apiToken == \"\" {\n\t\tfmt.Println(\"Warning: API_TOKEN not set\")\n\t}\n\n\tclient = &http.Client{\n\t\tTimeout: 30 * time.Second,\n\t}\n\n\tkubeconfig := os.Getenv(\"KUBECONFIG\")\n\tif kubeconfig == \"\" {\n\t\thome, _ := os.UserHomeDir()\n\t\tkubeconfig = fmt.Sprintf(\"%s/.kube/config\", home)\n\t}\n\n\tconfig, err := clientcmd.BuildConfigFromFlags(\"\", kubeconfig)\n\tif err == nil {\n\t\tk8sClient, _ = kubernetes.NewForConfig(config)\n\t}\n\n\tos.Exit(m.Run())\n}\n\nfunc TestHealthCheck(t *testing.T) {\n\tresp, err := client.Get(workloadManagerURL + \"/health\")\n\tif err != nil {\n\t\tt.Fatalf(\"Health check failed: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tt.Fatalf(\"Health check returned status: %d\", resp.StatusCode)\n\t}\n\n\tbody, err := io.ReadAll(resp.Body)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to read response body: %v\", err)\n\t}\n\n\tvar health struct {\n\t\tStatus string `json:\"status\"`\n\t}\n\tif err := json.Unmarshal(body, &health); err != nil {\n\t\tt.Fatalf(\"Failed to parse health response: %v\", err)\n\t}\n\n\tif health.Status != \"ok\" && health.Status != \"healthy\" {\n\t\tt.Logf(\"Health status: %s\", health.Status)\n\t}\n}\n\nfunc TestRouterHealth(t *testing.T) {\n\tresp, err := client.Get(routerURL + \"/health/live\")\n\tif err != nil {\n\t\tt.Fatalf(\"Router health check failed: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tt.Fatalf(\"Router health check returned status: %d\", resp.StatusCode)\n\t}\n}\n\nfunc TestRouterReady(t *testing.T) {\n\tresp, err := client.Get(routerURL + \"/health/ready\")\n\tif err != nil {\n\t\tt.Fatalf(\"Router ready check failed: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tt.Fatalf(\"Router ready check returned status: %d\", resp.StatusCode)\n\t}\n\n\tbody, err := io.ReadAll(resp.Body)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to read response body: %v\", err)\n\t}\n\n\tvar ready struct {\n\t\tReady bool `json:\"ready\"`\n\t}\n\tif err := json.Unmarshal(body, &ready); err != nil {\n\t\tt.Fatalf(\"Failed to parse ready response: %v\", err)\n\t}\n\n\tif !ready.Ready {\n\t\tt.Fatal(\"Router is not ready\")\n\t}\n}\n\nfunc TestInvokeEchoAgent(t *testing.T) {\n\tmessage := map[string]string{\n\t\t\"message\": \"Hello, echo agent!\",\n\t}\n\tbody, _ := json.Marshal(message)\n\n\treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/echo-agent\", bytes.NewReader(body))\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create request: %v\", err)\n\t}\n\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tif apiToken != \"\" {\n\t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n\t}\n\n\tresp, err := client.Do(req)\n\tif err != nil {\n\t\tt.Fatalf(\"Invoke request failed: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tt.Fatalf(\"Invoke returned status: %d, body: %s\", resp.StatusCode, string(body))\n\t}\n\n\tvar result map[string]interface{}\n\tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n\t\tt.Fatalf(\"Failed to decode response: %v\", err)\n\t}\n\n\tt.Logf(\"Echo agent response: %+v\", result)\n\n\tif status, ok := result[\"status\"].(string); !ok || status != \"success\" {\n\t\tt.Errorf(\"Expected status 'success', got '%v'\", result[\"status\"])\n\t}\n}\n\nfunc TestCodeInterpreter(t *testing.T) {\n\tcode := map[string]string{\n\t\t\"code\": \"print('Hello from code interpreter')\",\n\t}\n\tbody, _ := json.Marshal(code)\n\n\treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/e2e-code-interpreter\", bytes.NewReader(body))\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create request: %v\", err)\n\t}\n\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tif apiToken != \"\" {\n\t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n\t}\n\n\tresp, err := client.Do(req)\n\tif err != nil {\n\t\tt.Fatalf(\"Code interpreter request failed: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tt.Fatalf(\"Code interpreter returned status: %d, body: %s\", resp.StatusCode, string(body))\n\t}\n\n\tvar result map[string]interface{}\n\tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n\t\tt.Fatalf(\"Failed to decode response: %v\", err)\n\t}\n\n\tt.Logf(\"Code interpreter response: %+v\", result)\n}\n\nfunc TestSessionLifecycle(t *testing.T) {\n\tif k8sClient == nil {\n\t\tt.Skip(\"Kubernetes client not available\")\n\t}\n\n\tctx := context.Background()\n\n\tpods, err := k8sClient.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n\t\tLabelSelector: \"app=workloadmanager\",\n\t})\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to list pods: %v\", err)\n\t}\n\n\tif len(pods.Items) == 0 {\n\t\tt.Fatal(\"No workload manager pods found\")\n\t}\n\n\tfor _, pod := range pods.Items {\n\t\tif pod.Status.Phase == corev1.PodRunning {\n\t\t\tt.Logf(\"Found running workload manager pod: %s\", pod.Name)\n\t\t\treturn\n\t\t}\n\t}\n\n\tt.Fatal(\"No running workload manager pods found\")\n}\n\nfunc TestSessionCreationAndDeletion(t *testing.T) {\n\tsessionPayload := map[string]interface{}{\n\t\t\"interpreter\": \"e2e-code-interpreter\",\n\t\t\"namespace\":   namespace,\n\t\t\"ttl\":         \"60s\",\n\t}\n\tbody, _ := json.Marshal(sessionPayload)\n\n\treq, err := http.NewRequest(\"POST\", workloadManagerURL+\"/api/v1/sessions\", bytes.NewReader(body))\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create session request: %v\", err)\n\t}\n\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tif apiToken != \"\" {\n\t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n\t}\n\n\tresp, err := client.Do(req)\n\tif err != nil {\n\t\tt.Skipf(\"Session creation not available: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode == http.StatusNotFound {\n\t\tt.Skip(\"Sessions API not available\")\n\t}\n\n\tif resp.StatusCode != http.StatusOK && resp.StatusCode != http.StatusCreated {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tt.Fatalf(\"Session creation returned status: %d, body: %s\", resp.StatusCode, string(body))\n\t}\n\n\tvar result map[string]interface{}\n\tif err := json.NewDecoder(resp.Body).Decode(&result); err != nil {\n\t\tt.Fatalf(\"Failed to decode session response: %v\", err)\n\t}\n\n\tsessionID, ok := result[\"sessionId\"].(string