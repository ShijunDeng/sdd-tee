oncurrency; i++ {\n\t\tgo func(id int) {\n\t\t\tmessage := map[string]string{\n\t\t\t\t\"message\": fmt.Sprintf(\"Concurrent test %d\", id),\n\t\t\t}\n\t\t\tbody, _ := json.Marshal(message)\n\n\t\t\treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/echo-agent\", bytes.NewReader(body))\n\t\t\tif err != nil {\n\t\t\t\terrors <- err\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\t\t\tif apiToken != \"\" {\n\t\t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n\t\t\t}\n\n\t\t\tresp, err := client.Do(req)\n\t\t\tif err != nil {\n\t\t\t\terrors <- err\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdefer resp.Body.Close()\n\n\t\t\tif resp.StatusCode != http.StatusOK {\n\t\t\t\tbody, _ := io.ReadAll(resp.Body)\n\t\t\t\terrors <- fmt.Errorf(\"status %d: %s\", resp.StatusCode, string(body))\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tsuccesses <- true\n\t\t}(i)\n\t}\n\n\tsuccessCount := 0\n\terrorCount := 0\n\n\tfor i := 0; i < concurrency; i++ {\n\t\tselect {\n\t\tcase <-successes:\n\t\t\tsuccessCount++\n\t\tcase err := <-errors:\n\t\t\tt.Logf(\"Concurrent invocation error: %v\", err)\n\t\t\terrorCount++\n\t\tcase <-time.After(10 * time.Second):\n\t\t\tt.Fatal(\"Timeout waiting for concurrent invocations\")\n\t\t}\n\t}\n\n\tt.Logf(\"Concurrent test: %d successes, %d errors\", successCount, errorCount)\n\n\tif successCount < concurrency-1 {\n\t\tt.Errorf(\"Expected at least %d successes, got %d\", concurrency-1, successCount)\n\t}\n}\n\nfunc TestInvalidAgentInvocation(t *testing.T) {\n\tmessage := map[string]string{\n\t\t\"message\": \"Test invalid agent\",\n\t}\n\tbody, _ := json.Marshal(message)\n\n\treq, err := http.NewRequest(\"POST\", routerURL+\"/invoke/non-existent-agent\", bytes.NewReader(body))\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create request: %v\", err)\n\t}\n\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tif apiToken != \"\" {\n\t\treq.Header.Set(\"Authorization\", \"Bearer \"+apiToken)\n\t}\n\n\tresp, 