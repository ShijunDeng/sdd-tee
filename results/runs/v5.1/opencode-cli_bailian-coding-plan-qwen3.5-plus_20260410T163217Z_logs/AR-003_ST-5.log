{"type":"tool_use","timestamp":1775840740090,"sessionID":"ses_287a9e322ffeNAC5ZIgQUZgpZk","part":{"id":"prt_d785b21e0001Sm8mDqgsKxZfcC","messageID":"msg_d785b15ce001gNlypdeSmlHAGE","sessionID":"ses_287a9e322ffeNAC5ZIgQUZgpZk","type":"tool","tool":"edit","callID":"toolu_a7ce2fdaa61b460d93ec08d7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation_test.go","newString":"func TestValidateContainerSpec_ValidImageFormats(t *testing.T) {\n\tvalidImages := []string{\n\t\t\"nginx:latest\",\n\t\t\"volcanosh/picod:v1.0\",\n\t\t\"gcr.io/project/image:tag\",\n\t\t\"docker.io/library/alpine:3.18\",\n\t\t\"quay.io/repo/img:1.0.0\",\n\t\t\"image\",\n\t\t\"image:tag\",\n\t}\n\n\tfor _, img := range validImages {\n\t\tspec := &ContainerSpec{Image: img}\n\t\tfldPath := field.NewPath(\"container\")\n\n\t\terrs := ValidateContainerSpec(spec, fldPath)\n\t\tassert.Empty(t, errs, \"Image %q should be valid\", img)\n\t}\n}","oldString":"func TestValidateContainerSpec_ValidImageFormats(t *testing.T) {\n\tvalidImages := []string{\n\t\t\"nginx:latest\",\n\t\t\"volcanosh/picod:v1.0\",\n\t\t\"gcr.io/project/image:tag\",\n\t\t\"docker.io/library/alpine:3.18\",\n\t\t\"quay.io/repo/img:1.0.0\",\n\t\t\"image\",\n\t\t\"image:tag\",\n\t\t\"my-registry.io:5000/my-image:v2\",\n\t}\n\n\tfor _, img := range validImages {\n\t\tspec := &ContainerSpec{Image: img}\n\t\tfldPath := field.NewPath(\"container\")\n\n\t\terrs := ValidateContainerSpec(spec, fldPath)\n\t\tassert.Empty(t, errs, \"Image %q should be valid\", img)\n\t}\n}"},"output":"Edit applied successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/register.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/register.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/doc.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/defaults.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation_test.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation_test.go\n@@ -550,9 +550,8 @@\n \t\"docker.io/library/alpine:3.18\",\n \t\"quay.io/repo/img:1.0.0\",\n \t\"image\",\n \t\"image:tag\",\n-\t\"my-registry.io:5000/my-image:v2\",\n }\n \n for _, img := range validImages {\n \tspec := &ContainerSpec{Image: img}\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation_test.go","before":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"k8s.io/apimachinery/pkg/util/validation/field\"\n)\n\nfunc TestValidateAgentRuntime_Valid(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tContainer: ContainerSpec{\n\t\t\t\tImage: \"nginx:latest\",\n\t\t\t},\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tCPU:    \"1\",\n\t\t\t\tMemory: \"1Gi\",\n\t\t\t},\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t\tImage:   \"volcanosh/picod:latest\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs, \"Expected no errors for valid AgentRuntime\")\n}\n\nfunc TestValidateAgentRuntime_InvalidImage(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tContainer: ContainerSpec{\n\t\t\t\tImage: \"invalid image!@#\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"image\")\n}\n\nfunc TestValidateAgentRuntime_InvalidCPU(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tCPU: \"invalid-cpu\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tfieldErr := errs[0]\n\tassert.Equal(t, field.ErrorTypeInvalid, fieldErr.Type)\n\tassert.Contains(t, fieldErr.Field, \"cpu\")\n}\n\nfunc TestValidateAgentRuntime_InvalidMemory(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tMemory: \"invalid-memory\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tfieldErr := errs[0]\n\tassert.Equal(t, field.ErrorTypeInvalid, fieldErr.Type)\n\tassert.Contains(t, fieldErr.Field, \"memory\")\n}\n\nfunc TestValidateAgentRuntime_InvalidCIDR(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tNetwork: &NetworkPolicy{\n\t\t\t\tEgressRules: []NetworkRule{\n\t\t\t\t\t{CIDR: \"invalid-cidr\"},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"cidr\")\n}\n\nfunc TestValidateAgentRuntime_InvalidURL(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tLifecycle: &LifecycleHook{\n\t\t\t\tPreStart: \"not-a-url\",\n\t\t\t\tPostStop: \"also-not-url\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"preStart\")\n\tassert.Contains(t, errs.ToAggregate().Error(), \"postStop\")\n}\n\nfunc TestValidateAgentRuntime_ValidCIDR(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tNetwork: &NetworkPolicy{\n\t\t\t\tEgressRules: []NetworkRule{\n\t\t\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{80, 443}},\n\t\t\t\t},\n\t\t\t\tIngressRules: []NetworkRule{\n\t\t\t\t\t{CIDR: \"192.168.0.0/16\"},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs)\n}\n\nfunc TestValidateAgentRuntime_ValidLifecycleHooks(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tLifecycle: &LifecycleHook{\n\t\t\t\tPreStart: \"https://example.com/prestart\",\n\t\t\t\tPostStop: \"http://example.com/poststop\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs)\n}\n\nfunc TestValidateAgentRuntime_NilFields(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources:       nil,\n\t\t\tNetwork:         nil,\n\t\t\tLifecycle:       nil,\n\t\t\tCodeInterpreter: nil,\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs, \"Nil fields should not cause errors\")\n}\n\nfunc TestValidateAgentRuntimeStatusUpdate_ValidTransitions(t *testing.T) {\n\ttestCases := []struct {\n\t\toldPhase AgentRuntimePhase\n\t\tnewPhase AgentRuntimePhase\n\t\tvalid    bool\n\t}{\n\t\t{\"\", AgentRuntimePhasePending, true},\n\t\t{AgentRuntimePhasePending, AgentRuntimePhaseRunning, true},\n\t\t{AgentRuntimePhasePending, AgentRuntimePhaseFailed, true},\n\t\t{AgentRuntimePhasePending, AgentRuntimePhaseTerminating, true},\n\t\t{AgentRuntimePhaseRunning, AgentRuntimePhaseFailed, true},\n\t\t{AgentRuntimePhaseRunning, AgentRuntimePhaseTerminating, true},\n\t\t{AgentRuntimePhaseTerminating, AgentRuntimePhaseTerminating, true},\n\t\t{AgentRuntimePhaseRunning, AgentRuntimePhasePending, false},\n\t\t{AgentRuntimePhaseFailed, AgentRuntimePhaseRunning, false},\n\t}\n\n\tfor _, tc := range testCases {\n\t\toldObj := &AgentRuntime{Status: AgentRuntimeStatus{Phase: tc.oldPhase}}\n\t\tnewObj := &AgentRuntime{Status: AgentRuntimeStatus{Phase: tc.newPhase}}\n\n\t\terrs := ValidateAgentRuntimeStatusUpdate(oldObj, newObj)\n\n\t\tif tc.valid {\n\t\t\tassert.Empty(t, errs, \"Expected valid transition from %s to %s\", tc.oldPhase, tc.newPhase)\n\t\t} else {\n\t\t\tassert.NotEmpty(t, errs, \"Expected invalid transition from %s to %s\", tc.oldPhase, tc.newPhase)\n\t\t}\n\t}\n}\n\nfunc TestValidateAgentRuntimePhase(t *testing.T) {\n\tvalidPhases := []AgentRuntimePhase{\n\t\t\"\",\n\t\tAgentRuntimePhasePending,\n\t\tAgentRuntimePhaseRunning,\n\t\tAgentRuntimePhaseFailed,\n\t\tAgentRuntimePhaseTerminating,\n\t}\n\n\tfor _, phase := range validPhases {\n\t\terr := ValidateAgentRuntimePhase(phase)\n\t\tassert.NoError(t, err, \"Phase %q should be valid\", phase)\n\t}\n\n\tinvalidPhase := AgentRuntimePhase(\"Invalid\")\n\terr := ValidateAgentRuntimePhase(invalidPhase)\n\tassert.Error(t, err, \"Invalid phase should return error\")\n}\n\nfunc TestValidateCodeInterpreter_Nil(t *testing.T) {\n\tvar ci *CodeInterpreterSpec\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.Empty(t, errs, \"Nil CodeInterpreter should not cause errors\")\n}\n\nfunc TestValidateCodeInterpreter_Valid(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: true,\n\t\tImage:   \"volcanosh/picod:latest\",\n\t\tResources: &ResourceQuota{\n\t\t\tCPU:    \"500m\",\n\t\t\tMemory: \"512Mi\",\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.Empty(t, errs, \"Valid CodeInterpreter should not cause errors\")\n}\n\nfunc TestValidateCodeInterpreter_InvalidImage(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: true,\n\t\tImage:   \"invalid image!@#\",\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"image\")\n}\n\nfunc TestValidateCodeInterpreter_ValidImageNotEnabled(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: false,\n\t\tImage:   \"invalid image!@#\",\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.Empty(t, errs, \"Invalid image should only be validated when enabled\")\n}\n\nfunc TestValidateCodeInterpreter_InvalidResources(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: true,\n\t\tImage:   \"volcanosh/picod:latest\",\n\t\tResources: &ResourceQuota{\n\t\t\tCPU: \"invalid-cpu\",\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"cpu\")\n}\n\nfunc TestValidateCodeInterpreter_EmptyImage(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: true,\n\t\tImage:   \"\",\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.Empty(t, errs, \"Empty image should be allowed (will use default)\")\n}\n\nfunc TestValidateCodeInterpreter_ValidImageFormats(t *testing.T) {\n\tvalidImages := []string{\n\t\t\"nginx:latest\",\n\t\t\"volcanosh/picod:v1.0\",\n\t\t\"gcr.io/project/image:tag\",\n\t\t\"docker.io/library/alpine:3.18\",\n\t\t\"quay.io/repo/img:1.0.0\",\n\t\t\"image\",\n\t\t\"image:tag\",\n\t}\n\n\tfor _, img := range validImages {\n\t\tci := &CodeInterpreterSpec{\n\t\t\tEnabled: true,\n\t\t\tImage:   img,\n\t\t}\n\t\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\t\terrs := validateCodeInterpreter(ci, fldPath)\n\t\tassert.Empty(t, errs, \"Image %q should be valid\", img)\n\t}\n}\n\nfunc TestValidateResourceQuota_Nil(t *testing.T) {\n\tvar quota *ResourceQuota\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.Empty(t, errs, \"Nil ResourceQuota should not cause errors\")\n}\n\nfunc TestValidateResourceQuota_Valid(t *testing.T) {\n\tquota := &ResourceQuota{\n\t\tCPU:     \"1\",\n\t\tMemory:  \"1Gi\",\n\t\tStorage: \"10Gi\",\n\t}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.Empty(t, errs, \"Valid ResourceQuota should not cause errors\")\n}\n\nfunc TestValidateResourceQuota_EmptyFields(t *testing.T) {\n\tquota := &ResourceQuota{}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.Empty(t, errs, \"Empty ResourceQuota should not cause errors\")\n}\n\nfunc TestValidateResourceQuota_InvalidCPU(t *testing.T) {\n\tquota := &ResourceQuota{\n\t\tCPU: \"invalid-cpu\",\n\t}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"cpu\")\n}\n\nfunc TestValidateResourceQuota_InvalidMemory(t *testing.T) {\n\tquota := &ResourceQuota{\n\t\tMemory: \"invalid-memory\",\n\t}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"memory\")\n}\n\nfunc TestValidateResourceQuota_InvalidStorage(t *testing.T) {\n\tquota := &ResourceQuota{\n\t\tStorage: \"invalid-storage\",\n\t}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"storage\")\n}\n\nfunc TestValidateResourceQuota_ValidFormats(t *testing.T) {\n\ttestCases := []struct {\n\t\tname  string\n\t\tquota *ResourceQuota\n\t}{\n\t\t{\n\t\t\tname:  \"millicpu\",\n\t\t\tquota: &ResourceQuota{CPU: \"500m\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"corecpu\",\n\t\t\tquota: &ResourceQuota{CPU: \"2\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"memoryMi\",\n\t\t\tquota: &ResourceQuota{Memory: \"512Mi\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"memoryGi\",\n\t\t\tquota: &ResourceQuota{Memory: \"2Gi\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"storageKi\",\n\t\t\tquota: &ResourceQuota{Storage: \"100Ki\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"storageTi\",\n\t\t\tquota: &ResourceQuota{Storage: \"1Ti\"},\n\t\t},\n\t}\n\n\tfor _, tc := range testCases {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tfldPath := field.NewPath(\"resources\")\n\t\t\terrs := ValidateResourceQuota(tc.quota, fldPath)\n\t\t\tassert.Empty(t, errs, \"ResourceQuota with %s should be valid\", tc.name)\n\t\t})\n\t}\n}\n\nfunc TestValidateNetworkPolicy_Nil(t *testing.T) {\n\tvar policy *NetworkPolicy\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.Empty(t, errs, \"Nil NetworkPolicy should not cause errors\")\n}\n\nfunc TestValidateNetworkPolicy_Empty(t *testing.T) {\n\tpolicy := &NetworkPolicy{}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.Empty(t, errs, \"Empty NetworkPolicy should not cause errors\")\n}\n\nfunc TestValidateNetworkPolicy_ValidCIDR(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"10.0.0.0/8\"},\n\t\t\t{CIDR: \"192.168.1.0/24\", Ports: []int32{80, 443}},\n\t\t},\n\t\tIngressRules: []NetworkRule{\n\t\t\t{CIDR: \"172.16.0.0/12\"},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.Empty(t, errs, \"Valid NetworkPolicy should not cause errors\")\n}\n\nfunc TestValidateNetworkPolicy_InvalidCIDR(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"invalid-cidr\"},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"cidr\")\n}\n\nfunc TestValidateNetworkPolicy_InvalidPort(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{0, 80}},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"ports\")\n}\n\nfunc TestValidateNetworkPolicy_PortOutOfRange(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{70000}},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"ports\")\n}\n\nfunc TestValidateNetworkPolicy_ValidPorts(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{1, 80, 443, 65535}},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.Empty(t, errs, \"Valid ports should not cause errors\")\n}\n\nfunc TestValidateContainerSpec_Nil(t *testing.T) {\n\tvar spec *ContainerSpec\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.Empty(t, errs, \"Nil ContainerSpec should not cause errors\")\n}\n\nfunc TestValidateContainerSpec_Empty(t *testing.T) {\n\tspec := &ContainerSpec{}\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.Empty(t, errs, \"Empty ContainerSpec should not cause errors\")\n}\n\nfunc TestValidateContainerSpec_ValidImage(t *testing.T) {\n\tspec := &ContainerSpec{\n\t\tImage: \"nginx:latest\",\n\t}\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.Empty(t, errs, \"Valid ContainerSpec should not cause errors\")\n}\n\nfunc TestValidateContainerSpec_InvalidImage(t *testing.T) {\n\tspec := &ContainerSpec{\n\t\tImage: \"invalid image!@#\",\n\t}\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"image\")\n}\n\nfunc TestValidateContainerSpec_ValidImageFormats(t *testing.T) {\n\tvalidImages := []string{\n\t\t\"nginx:latest\",\n\t\t\"volcanosh/picod:v1.0\",\n\t\t\"gcr.io/project/image:tag\",\n\t\t\"docker.io/library/alpine:3.18\",\n\t\t\"quay.io/repo/img:1.0.0\",\n\t\t\"image\",\n\t\t\"image:tag\",\n\t\t\"my-registry.io:5000/my-image:v2\",\n\t}\n\n\tfor _, img := range validImages {\n\t\tspec := &ContainerSpec{Image: img}\n\t\tfldPath := field.NewPath(\"container\")\n\n\t\terrs := ValidateContainerSpec(spec, fldPath)\n\t\tassert.Empty(t, errs, \"Image %q should be valid\", img)\n\t}\n}\n\nfunc TestValidateContainerSpec_WithCommandAndArgs(t *testing.T) {\n\tspec := &ContainerSpec{\n\t\tImage:   \"nginx:latest\",\n\t\tCommand: []string{\"/bin/sh\"},\n\t\tArgs:    []string{\"-c\", \"echo hello\"},\n\t}\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.Empty(t, errs, \"ContainerSpec with command and args should be valid\")\n}\n\nfunc TestValidateLifecycleHook_Nil(t *testing.T) {\n\tvar hook *LifecycleHook\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Empty(t, errs, \"Nil LifecycleHook should not cause errors\")\n}\n\nfunc TestValidateLifecycleHook_Empty(t *testing.T) {\n\thook := &LifecycleHook{}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Empty(t, errs, \"Empty LifecycleHook should not cause errors\")\n}\n\nfunc TestValidateLifecycleHook_ValidHTTP(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"http://example.com/prestart\",\n\t\tPostStop: \"http://example.com/poststop\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Empty(t, errs, \"Valid HTTP URLs should not cause errors\")\n}\n\nfunc TestValidateLifecycleHook_ValidHTTPS(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"https://example.com/prestart\",\n\t\tPostStop: \"https://example.com/poststop\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Empty(t, errs, \"Valid HTTPS URLs should not cause errors\")\n}\n\nfunc TestValidateLifecycleHook_InvalidPreStart(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"not-a-url\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"preStart\")\n}\n\nfunc TestValidateLifecycleHook_InvalidPostStop(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPostStop: \"also-not-url\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"postStop\")\n}\n\nfunc TestValidateLifecycleHook_BothInvalid(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"invalid1\",\n\t\tPostStop: \"invalid2\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Len(t, errs, 2, \"Both invalid URLs should produce two errors\")\n\tassert.Contains(t, errs.ToAggregate().Error(), \"preStart\")\n\tassert.Contains(t, errs.ToAggregate().Error(), \"postStop\")\n}\n\nfunc TestValidateLifecycleHook_OneValidOneInvalid(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"https://valid.com\",\n\t\tPostStop: \"invalid\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Len(t, errs, 1, \"Only one invalid URL should produce one error\")\n\tassert.Contains(t, errs[0].Field, \"postStop\")\n}\n","after":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"k8s.io/apimachinery/pkg/util/validation/field\"\n)\n\nfunc TestValidateAgentRuntime_Valid(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tContainer: ContainerSpec{\n\t\t\t\tImage: \"nginx:latest\",\n\t\t\t},\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tCPU:    \"1\",\n\t\t\t\tMemory: \"1Gi\",\n\t\t\t},\n\t\t\tCodeInterpreter: &CodeInterpreterSpec{\n\t\t\t\tEnabled: true,\n\t\t\t\tImage:   \"volcanosh/picod:latest\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs, \"Expected no errors for valid AgentRuntime\")\n}\n\nfunc TestValidateAgentRuntime_InvalidImage(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tContainer: ContainerSpec{\n\t\t\t\tImage: \"invalid image!@#\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"image\")\n}\n\nfunc TestValidateAgentRuntime_InvalidCPU(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tCPU: \"invalid-cpu\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tfieldErr := errs[0]\n\tassert.Equal(t, field.ErrorTypeInvalid, fieldErr.Type)\n\tassert.Contains(t, fieldErr.Field, \"cpu\")\n}\n\nfunc TestValidateAgentRuntime_InvalidMemory(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources: &ResourceQuota{\n\t\t\t\tMemory: \"invalid-memory\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tfieldErr := errs[0]\n\tassert.Equal(t, field.ErrorTypeInvalid, fieldErr.Type)\n\tassert.Contains(t, fieldErr.Field, \"memory\")\n}\n\nfunc TestValidateAgentRuntime_InvalidCIDR(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tNetwork: &NetworkPolicy{\n\t\t\t\tEgressRules: []NetworkRule{\n\t\t\t\t\t{CIDR: \"invalid-cidr\"},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"cidr\")\n}\n\nfunc TestValidateAgentRuntime_InvalidURL(t *testing.T) {\n\tinvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tLifecycle: &LifecycleHook{\n\t\t\t\tPreStart: \"not-a-url\",\n\t\t\t\tPostStop: \"also-not-url\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(invalid)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"preStart\")\n\tassert.Contains(t, errs.ToAggregate().Error(), \"postStop\")\n}\n\nfunc TestValidateAgentRuntime_ValidCIDR(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tNetwork: &NetworkPolicy{\n\t\t\t\tEgressRules: []NetworkRule{\n\t\t\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{80, 443}},\n\t\t\t\t},\n\t\t\t\tIngressRules: []NetworkRule{\n\t\t\t\t\t{CIDR: \"192.168.0.0/16\"},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs)\n}\n\nfunc TestValidateAgentRuntime_ValidLifecycleHooks(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tLifecycle: &LifecycleHook{\n\t\t\t\tPreStart: \"https://example.com/prestart\",\n\t\t\t\tPostStop: \"http://example.com/poststop\",\n\t\t\t},\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs)\n}\n\nfunc TestValidateAgentRuntime_NilFields(t *testing.T) {\n\tvalid := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tResources:       nil,\n\t\t\tNetwork:         nil,\n\t\t\tLifecycle:       nil,\n\t\t\tCodeInterpreter: nil,\n\t\t},\n\t}\n\n\terrs := ValidateAgentRuntime(valid)\n\tassert.Empty(t, errs, \"Nil fields should not cause errors\")\n}\n\nfunc TestValidateAgentRuntimeStatusUpdate_ValidTransitions(t *testing.T) {\n\ttestCases := []struct {\n\t\toldPhase AgentRuntimePhase\n\t\tnewPhase AgentRuntimePhase\n\t\tvalid    bool\n\t}{\n\t\t{\"\", AgentRuntimePhasePending, true},\n\t\t{AgentRuntimePhasePending, AgentRuntimePhaseRunning, true},\n\t\t{AgentRuntimePhasePending, AgentRuntimePhaseFailed, true},\n\t\t{AgentRuntimePhasePending, AgentRuntimePhaseTerminating, true},\n\t\t{AgentRuntimePhaseRunning, AgentRuntimePhaseFailed, true},\n\t\t{AgentRuntimePhaseRunning, AgentRuntimePhaseTerminating, true},\n\t\t{AgentRuntimePhaseTerminating, AgentRuntimePhaseTerminating, true},\n\t\t{AgentRuntimePhaseRunning, AgentRuntimePhasePending, false},\n\t\t{AgentRuntimePhaseFailed, AgentRuntimePhaseRunning, false},\n\t}\n\n\tfor _, tc := range testCases {\n\t\toldObj := &AgentRuntime{Status: AgentRuntimeStatus{Phase: tc.oldPhase}}\n\t\tnewObj := &AgentRuntime{Status: AgentRuntimeStatus{Phase: tc.newPhase}}\n\n\t\terrs := ValidateAgentRuntimeStatusUpdate(oldObj, newObj)\n\n\t\tif tc.valid {\n\t\t\tassert.Empty(t, errs, \"Expected valid transition from %s to %s\", tc.oldPhase, tc.newPhase)\n\t\t} else {\n\t\t\tassert.NotEmpty(t, errs, \"Expected invalid transition from %s to %s\", tc.oldPhase, tc.newPhase)\n\t\t}\n\t}\n}\n\nfunc TestValidateAgentRuntimePhase(t *testing.T) {\n\tvalidPhases := []AgentRuntimePhase{\n\t\t\"\",\n\t\tAgentRuntimePhasePending,\n\t\tAgentRuntimePhaseRunning,\n\t\tAgentRuntimePhaseFailed,\n\t\tAgentRuntimePhaseTerminating,\n\t}\n\n\tfor _, phase := range validPhases {\n\t\terr := ValidateAgentRuntimePhase(phase)\n\t\tassert.NoError(t, err, \"Phase %q should be valid\", phase)\n\t}\n\n\tinvalidPhase := AgentRuntimePhase(\"Invalid\")\n\terr := ValidateAgentRuntimePhase(invalidPhase)\n\tassert.Error(t, err, \"Invalid phase should return error\")\n}\n\nfunc TestValidateCodeInterpreter_Nil(t *testing.T) {\n\tvar ci *CodeInterpreterSpec\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.Empty(t, errs, \"Nil CodeInterpreter should not cause errors\")\n}\n\nfunc TestValidateCodeInterpreter_Valid(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: true,\n\t\tImage:   \"volcanosh/picod:latest\",\n\t\tResources: &ResourceQuota{\n\t\t\tCPU:    \"500m\",\n\t\t\tMemory: \"512Mi\",\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.Empty(t, errs, \"Valid CodeInterpreter should not cause errors\")\n}\n\nfunc TestValidateCodeInterpreter_InvalidImage(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: true,\n\t\tImage:   \"invalid image!@#\",\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"image\")\n}\n\nfunc TestValidateCodeInterpreter_ValidImageNotEnabled(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: false,\n\t\tImage:   \"invalid image!@#\",\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.Empty(t, errs, \"Invalid image should only be validated when enabled\")\n}\n\nfunc TestValidateCodeInterpreter_InvalidResources(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: true,\n\t\tImage:   \"volcanosh/picod:latest\",\n\t\tResources: &ResourceQuota{\n\t\t\tCPU: \"invalid-cpu\",\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Contains(t, errs.ToAggregate().Error(), \"cpu\")\n}\n\nfunc TestValidateCodeInterpreter_EmptyImage(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tEnabled: true,\n\t\tImage:   \"\",\n\t}\n\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\terrs := validateCodeInterpreter(ci, fldPath)\n\tassert.Empty(t, errs, \"Empty image should be allowed (will use default)\")\n}\n\nfunc TestValidateCodeInterpreter_ValidImageFormats(t *testing.T) {\n\tvalidImages := []string{\n\t\t\"nginx:latest\",\n\t\t\"volcanosh/picod:v1.0\",\n\t\t\"gcr.io/project/image:tag\",\n\t\t\"docker.io/library/alpine:3.18\",\n\t\t\"quay.io/repo/img:1.0.0\",\n\t\t\"image\",\n\t\t\"image:tag\",\n\t}\n\n\tfor _, img := range validImages {\n\t\tci := &CodeInterpreterSpec{\n\t\t\tEnabled: true,\n\t\t\tImage:   img,\n\t\t}\n\t\tfldPath := field.NewPath(\"codeInterpreter\")\n\n\t\terrs := validateCodeInterpreter(ci, fldPath)\n\t\tassert.Empty(t, errs, \"Image %q should be valid\", img)\n\t}\n}\n\nfunc TestValidateResourceQuota_Nil(t *testing.T) {\n\tvar quota *ResourceQuota\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.Empty(t, errs, \"Nil ResourceQuota should not cause errors\")\n}\n\nfunc TestValidateResourceQuota_Valid(t *testing.T) {\n\tquota := &ResourceQuota{\n\t\tCPU:     \"1\",\n\t\tMemory:  \"1Gi\",\n\t\tStorage: \"10Gi\",\n\t}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.Empty(t, errs, \"Valid ResourceQuota should not cause errors\")\n}\n\nfunc TestValidateResourceQuota_EmptyFields(t *testing.T) {\n\tquota := &ResourceQuota{}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.Empty(t, errs, \"Empty ResourceQuota should not cause errors\")\n}\n\nfunc TestValidateResourceQuota_InvalidCPU(t *testing.T) {\n\tquota := &ResourceQuota{\n\t\tCPU: \"invalid-cpu\",\n\t}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"cpu\")\n}\n\nfunc TestValidateResourceQuota_InvalidMemory(t *testing.T) {\n\tquota := &ResourceQuota{\n\t\tMemory: \"invalid-memory\",\n\t}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"memory\")\n}\n\nfunc TestValidateResourceQuota_InvalidStorage(t *testing.T) {\n\tquota := &ResourceQuota{\n\t\tStorage: \"invalid-storage\",\n\t}\n\tfldPath := field.NewPath(\"resources\")\n\n\terrs := ValidateResourceQuota(quota, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"storage\")\n}\n\nfunc TestValidateResourceQuota_ValidFormats(t *testing.T) {\n\ttestCases := []struct {\n\t\tname  string\n\t\tquota *ResourceQuota\n\t}{\n\t\t{\n\t\t\tname:  \"millicpu\",\n\t\t\tquota: &ResourceQuota{CPU: \"500m\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"corecpu\",\n\t\t\tquota: &ResourceQuota{CPU: \"2\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"memoryMi\",\n\t\t\tquota: &ResourceQuota{Memory: \"512Mi\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"memoryGi\",\n\t\t\tquota: &ResourceQuota{Memory: \"2Gi\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"storageKi\",\n\t\t\tquota: &ResourceQuota{Storage: \"100Ki\"},\n\t\t},\n\t\t{\n\t\t\tname:  \"storageTi\",\n\t\t\tquota: &ResourceQuota{Storage: \"1Ti\"},\n\t\t},\n\t}\n\n\tfor _, tc := range testCases {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tfldPath := field.NewPath(\"resources\")\n\t\t\terrs := ValidateResourceQuota(tc.quota, fldPath)\n\t\t\tassert.Empty(t, errs, \"ResourceQuota with %s should be valid\", tc.name)\n\t\t})\n\t}\n}\n\nfunc TestValidateNetworkPolicy_Nil(t *testing.T) {\n\tvar policy *NetworkPolicy\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.Empty(t, errs, \"Nil NetworkPolicy should not cause errors\")\n}\n\nfunc TestValidateNetworkPolicy_Empty(t *testing.T) {\n\tpolicy := &NetworkPolicy{}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.Empty(t, errs, \"Empty NetworkPolicy should not cause errors\")\n}\n\nfunc TestValidateNetworkPolicy_ValidCIDR(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"10.0.0.0/8\"},\n\t\t\t{CIDR: \"192.168.1.0/24\", Ports: []int32{80, 443}},\n\t\t},\n\t\tIngressRules: []NetworkRule{\n\t\t\t{CIDR: \"172.16.0.0/12\"},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.Empty(t, errs, \"Valid NetworkPolicy should not cause errors\")\n}\n\nfunc TestValidateNetworkPolicy_InvalidCIDR(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"invalid-cidr\"},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"cidr\")\n}\n\nfunc TestValidateNetworkPolicy_InvalidPort(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{0, 80}},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"ports\")\n}\n\nfunc TestValidateNetworkPolicy_PortOutOfRange(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{70000}},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"ports\")\n}\n\nfunc TestValidateNetworkPolicy_ValidPorts(t *testing.T) {\n\tpolicy := &NetworkPolicy{\n\t\tEgressRules: []NetworkRule{\n\t\t\t{CIDR: \"10.0.0.0/8\", Ports: []int32{1, 80, 443, 65535}},\n\t\t},\n\t}\n\tfldPath := field.NewPath(\"network\")\n\n\terrs := ValidateNetworkPolicy(policy, fldPath)\n\tassert.Empty(t, errs, \"Valid ports should not cause errors\")\n}\n\nfunc TestValidateContainerSpec_Nil(t *testing.T) {\n\tvar spec *ContainerSpec\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.Empty(t, errs, \"Nil ContainerSpec should not cause errors\")\n}\n\nfunc TestValidateContainerSpec_Empty(t *testing.T) {\n\tspec := &ContainerSpec{}\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.Empty(t, errs, \"Empty ContainerSpec should not cause errors\")\n}\n\nfunc TestValidateContainerSpec_ValidImage(t *testing.T) {\n\tspec := &ContainerSpec{\n\t\tImage: \"nginx:latest\",\n\t}\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.Empty(t, errs, \"Valid ContainerSpec should not cause errors\")\n}\n\nfunc TestValidateContainerSpec_InvalidImage(t *testing.T) {\n\tspec := &ContainerSpec{\n\t\tImage: \"invalid image!@#\",\n\t}\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"image\")\n}\n\nfunc TestValidateContainerSpec_ValidImageFormats(t *testing.T) {\n\tvalidImages := []string{\n\t\t\"nginx:latest\",\n\t\t\"volcanosh/picod:v1.0\",\n\t\t\"gcr.io/project/image:tag\",\n\t\t\"docker.io/library/alpine:3.18\",\n\t\t\"quay.io/repo/img:1.0.0\",\n\t\t\"image\",\n\t\t\"image:tag\",\n\t}\n\n\tfor _, img := range validImages {\n\t\tspec := &ContainerSpec{Image: img}\n\t\tfldPath := field.NewPath(\"container\")\n\n\t\terrs := ValidateContainerSpec(spec, fldPath)\n\t\tassert.Empty(t, errs, \"Image %q should be valid\", img)\n\t}\n}\n\nfunc TestValidateContainerSpec_WithCommandAndArgs(t *testing.T) {\n\tspec := &ContainerSpec{\n\t\tImage:   \"nginx:latest\",\n\t\tCommand: []string{\"/bin/sh\"},\n\t\tArgs:    []string{\"-c\", \"echo hello\"},\n\t}\n\tfldPath := field.NewPath(\"container\")\n\n\terrs := ValidateContainerSpec(spec, fldPath)\n\tassert.Empty(t, errs, \"ContainerSpec with command and args should be valid\")\n}\n\nfunc TestValidateLifecycleHook_Nil(t *testing.T) {\n\tvar hook *LifecycleHook\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Empty(t, errs, \"Nil LifecycleHook should not cause errors\")\n}\n\nfunc TestValidateLifecycleHook_Empty(t *testing.T) {\n\thook := &LifecycleHook{}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Empty(t, errs, \"Empty LifecycleHook should not cause errors\")\n}\n\nfunc TestValidateLifecycleHook_ValidHTTP(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"http://example.com/prestart\",\n\t\tPostStop: \"http://example.com/poststop\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Empty(t, errs, \"Valid HTTP URLs should not cause errors\")\n}\n\nfunc TestValidateLifecycleHook_ValidHTTPS(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"https://example.com/prestart\",\n\t\tPostStop: \"https://example.com/poststop\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Empty(t, errs, \"Valid HTTPS URLs should not cause errors\")\n}\n\nfunc TestValidateLifecycleHook_InvalidPreStart(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"not-a-url\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"preStart\")\n}\n\nfunc TestValidateLifecycleHook_InvalidPostStop(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPostStop: \"also-not-url\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.NotEmpty(t, errs)\n\tassert.Equal(t, field.ErrorTypeInvalid, errs[0].Type)\n\tassert.Contains(t, errs[0].Field, \"postStop\")\n}\n\nfunc TestValidateLifecycleHook_BothInvalid(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"invalid1\",\n\t\tPostStop: \"invalid2\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Len(t, errs, 2, \"Both invalid URLs should produce two errors\")\n\tassert.Contains(t, errs.ToAggregate().Error(), \"preStart\")\n\tassert.Contains(t, errs.ToAggregate().Error(), \"postStop\")\n}\n\nfunc TestValidateLifecycleHook_OneValidOneInvalid(t *testing.T) {\n\thook := &LifecycleHook{\n\t\tPreStart: \"https://valid.com\",\n\t\tPostStop: \"invalid\",\n\t}\n\tfldPath := field.NewPath(\"lifecycle\")\n\n\terrs := ValidateLifecycleHook(hook, fldPath)\n\tassert.Len(t, errs, 1, \"Only one invalid URL should produce one error\")\n\tassert.Contains(t, errs[0].Field, \"postStop\")\n}\n","additions":0,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/validation_test.go","time":{"start":1775840739894,"end":1775840740087}}}}
