================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types.go\n@@ -35,8 +35,9 @@\n \tAgentRuntimePhaseTerminating AgentRuntimePhase = \"Terminating\"\n )\n \n // AgentRuntimeConditionType is the type of a runtime condition.\n+// +k8s:deepcopy-gen=false\n type AgentRuntimeConditionType string\n \n const (\n \t// AgentRuntimeConditionReady indicates the runtime is ready to serve requests.\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/types.go","before":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\n// AgentRuntimePhase is the lifecycle phase of an AgentRuntime.\ntype AgentRuntimePhase string\n\nconst (\n\t// AgentRuntimePhasePending indicates the runtime is being provisioned.\n\tAgentRuntimePhasePending AgentRuntimePhase = \"Pending\"\n\t// AgentRuntimePhaseRunning indicates the runtime is running.\n\tAgentRuntimePhaseRunning AgentRuntimePhase = \"Running\"\n\t// AgentRuntimePhaseFailed indicates the runtime failed to start.\n\tAgentRuntimePhaseFailed AgentRuntimePhase = \"Failed\"\n\t// AgentRuntimePhaseTerminating indicates the runtime is being terminated.\n\tAgentRuntimePhaseTerminating AgentRuntimePhase = \"Terminating\"\n)\n\n// AgentRuntimeConditionType is the type of a runtime condition.\ntype AgentRuntimeConditionType string\n\nconst (\n\t// AgentRuntimeConditionReady indicates the runtime is ready to serve requests.\n\tAgentRuntimeConditionReady AgentRuntimeConditionType = \"Ready\"\n\t// AgentRuntimeConditionSandboxCreated indicates the sandbox pod has been created.\n\tAgentRuntimeConditionSandboxCreated AgentRuntimeConditionType = \"SandboxCreated\"\n\t// AgentRuntimeConditionCodeInterpreterReady indicates the code interpreter is attached and ready.\n\tAgentRuntimeConditionCodeInterpreterReady AgentRuntimeConditionType = \"CodeInterpreterReady\"\n)\n\n// AgentRuntimeCondition represents the state of a runtime condition.\ntype AgentRuntimeCondition struct {\n\t// Type is the type of the condition.\n\tType AgentRuntimeConditionType `json:\"type\" protobuf:\"bytes,1,opt,name=type,casttype=AgentRuntimeConditionType\"`\n\t// Status is the status of the condition (True, False, Unknown).\n\tStatus corev1.ConditionStatus `json:\"status\" protobuf:\"bytes,2,opt,name=status,casttype=k8s.io/api/core/v1.ConditionStatus\"`\n\t// Reason is a one-word CamelCase reason for the condition's last transition.\n\t// +optional\n\tReason string `json:\"reason,omitempty\" protobuf:\"bytes,3,opt,name=reason\"`\n\t// Message is a human-readable message indicating details about last transition.\n\t// +optional\n\tMessage string `json:\"message,omitempty\" protobuf:\"bytes,4,opt,name=message\"`\n\t// LastTransitionTime is the last time the condition transitioned from one status to another.\n\tLastTransitionTime metav1.Time `json:\"lastTransitionTime\" protobuf:\"bytes,5,opt,name=lastTransitionTime\"`\n}\n\n// CodeInterpreterSpec defines the configuration for an embedded code interpreter.\ntype CodeInterpreterSpec struct {\n\t// Enabled indicates whether to attach a code interpreter.\n\t// +optional\n\tEnabled bool `json:\"enabled,omitempty\" protobuf:\"varint,1,opt,name=enabled\"`\n\t// Image is the container image for the code interpreter.\n\t// +optional\n\tImage string `json:\"image,omitempty\" protobuf:\"bytes,2,opt,name=image\"`\n\t// Resources defines the resource requirements for the code interpreter.\n\t// +optional\n\tResources *ResourceQuota `json:\"resources,omitempty\" protobuf:\"bytes,3,opt,name=resources\"`\n}\n\n// ResourceQuota defines resource limits and requests.\ntype ResourceQuota struct {\n\t// CPU is the CPU limit in cores (e.g., \"500m\" for 0.5 CPU).\n\t// +optional\n\tCPU string `json:\"cpu,omitempty\" protobuf:\"bytes,1,opt,name=cpu\"`\n\t// Memory is the memory limit in bytes (e.g., \"512Mi\", \"1Gi\").\n\t// +optional\n\tMemory string `json:\"memory,omitempty\" protobuf:\"bytes,2,opt,name=memory\"`\n\t// Storage is the storage limit in bytes (e.g., \"1Gi\", \"10Gi\").\n\t// +optional\n\tStorage string `json:\"storage,omitempty\" protobuf:\"bytes,3,opt,name=storage\"`\n}\n\n// NetworkPolicy defines network access rules for the runtime.\ntype NetworkPolicy struct {\n\t// EgressRules defines allowed egress destinations.\n\t// +optional\n\tEgressRules []NetworkRule `json:\"egressRules,omitempty\" protobuf:\"bytes,1,rep,name=egressRules\"`\n\t// IngressRules defines allowed ingress sources.\n\t// +optional\n\tIngressRules []NetworkRule `json:\"ingressRules,omitempty\" protobuf:\"bytes,2,rep,name=ingressRules\"`\n}\n\n// NetworkRule defines a single network rule.\ntype NetworkRule struct {\n\t// CIDR is the IP CIDR block (e.g., \"10.0.0.0/8\").\n\t// +optional\n\tCIDR string `json:\"cidr,omitempty\" protobuf:\"bytes,1,opt,name=cidr\"`\n\t// Ports is the list of allowed ports.\n\t// +optional\n\tPorts []int32 `json:\"ports,omitempty\" protobuf:\"varint,2,rep,name=ports\"`\n\t// Protocol is the network protocol (TCP, UDP).\n\t// +optional\n\tProtocol corev1.Protocol `json:\"protocol,omitempty\" protobuf:\"bytes,3,opt,name=protocol,casttype=k8s.io/api/core/v1.Protocol\"`\n}\n\n// LifecycleHook defines lifecycle callbacks for the runtime.\ntype LifecycleHook struct {\n\t// PreStart is the URL to call before the runtime starts.\n\t// +optional\n\tPreStart string `json:\"preStart,omitempty\" protobuf:\"bytes,1,opt,name=preStart\"`\n\t// PostStop is the URL to call after the runtime stops.\n\t// +optional\n\tPostStop string `json:\"postStop,omitempty\" protobuf:\"bytes,2,opt,name=postStop\"`\n}\n\n// ContainerSpec defines the container configuration for the runtime.\ntype ContainerSpec struct {\n\t// Image is the container image to run.\n\t// +optional\n\tImage string `json:\"image,omitempty\" protobuf:\"bytes,1,opt,name=image\"`\n\t// Command is the command to run in the container.\n\t// +optional\n\tCommand []string `json:\"command,omitempty\" protobuf:\"bytes,2,rep,name=command\"`\n\t// Args are the arguments to the command.\n\t// +optional\n\tArgs []string `json:\"args,omitempty\" protobuf:\"bytes,3,rep,name=args\"`\n\t// Env is the list of environment variables.\n\t// +optional\n\tEnv []corev1.EnvVar `json:\"env,omitempty\" protobuf:\"bytes,4,rep,name=env\"`\n\t// WorkingDir is the working directory for the container.\n\t// +optional\n\tWorkingDir string `json:\"workingDir,omitempty\" protobuf:\"bytes,5,opt,name=workingDir\"`\n}\n\n// AgentRuntimeSpec defines the desired state of an AgentRuntime.\ntype AgentRuntimeSpec struct {\n\t// Container defines the container configuration.\n\t// +optional\n\tContainer ContainerSpec `json:\"container,omitempty\" protobuf:\"bytes,1,opt,name=container\"`\n\t// Resources defines the resource quotas for the runtime.\n\t// +optional\n\tResources *ResourceQuota `json:\"resources,omitempty\" protobuf:\"bytes,2,opt,name=resources\"`\n\t// Network defines the network policies.\n\t// +optional\n\tNetwork *NetworkPolicy `json:\"network,omitempty\" protobuf:\"bytes,3,opt,name=network\"`\n\t// Lifecycle defines lifecycle hooks.\n\t// +optional\n\tLifecycle *LifecycleHook `json:\"lifecycle,omitempty\" protobuf:\"bytes,4,opt,name=lifecycle\"`\n\t// CodeInterpreter defines the embedded code interpreter configuration.\n\t// +optional\n\tCodeInterpreter *CodeInterpreterSpec `json:\"codeInterpreter,omitempty\" protobuf:\"bytes,5,opt,name=codeInterpreter\"`\n}\n\n// AgentRuntimeStatus defines the observed state of an AgentRuntime.\ntype AgentRuntimeStatus struct {\n\t// Phase is the current phase of the runtime.\n\t// +optional\n\tPhase AgentRuntimePhase `json:\"phase,omitempty\" protobuf:\"bytes,1,opt,name=phase,casttype=AgentRuntimePhase\"`\n\t// Conditions represent the latest available observations of the runtime state.\n\t// +optional\n\tConditions []AgentRuntimeCondition `json:\"conditions,omitempty\" protobuf:\"bytes,2,rep,name=conditions\"`\n\t// SandboxRef is the reference to the sandbox pod.\n\t// +optional\n\tSandboxRef *corev1.ObjectReference `json:\"sandboxRef,omitempty\" protobuf:\"bytes,3,opt,name=sandboxRef\"`\n\t// StartTime is the time when the runtime started.\n\t// +optional\n\tStartTime *metav1.Time `json:\"startTime,omitempty\" protobuf:\"bytes,4,opt,name=startTime\"`\n\t// LastTransitionTime is the last time the phase transitioned.\n\t// +optional\n\tLastTransitionTime *metav1.Time `json:\"lastTransitionTime,omitempty\" protobuf:\"bytes,5,opt,name=lastTransitionTime\"`\n}\n\n// +genclient\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\n// +kubebuilder:subresource:status\n// +kubebuilder:printcolumn:name=\"NAME\",type=\"string\",JSONPath=\".metadata.name\",description=\"Name of the runtime\"\n// +kubebuilder:printcolumn:name=\"PHASE\",type=\"string\",JSONPath=\".status.phase\",description=\"Current phase\"\n// +kubebuilder:printcolumn:name=\"SANDBOX\",type=\"string\",JSONPath=\".status.sandboxRef.name\",description=\"Sandbox pod name\"\n// +kubebuilder:printcolumn:name=\"AGE\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"