s is a reusable pattern for reporting status conditions in CRDs.\ntype AgentRuntimeCondition struct {\n\t// Type is the type of the condition.\n\tType AgentRuntimeConditionType `json:\"type\" protobuf:\"bytes,1,opt,name=type,casttype=AgentRuntimeConditionType\"`\n\t// Status is the status of the condition (True, False, Unknown).\n\tStatus corev1.ConditionStatus `json:\"status\" protobuf:\"bytes,2,opt,name=status,casttype=k8s.io/api/core/v1.ConditionStatus\"`\n\t// Reason is a one-word CamelCase reason for the condition's last transition.\n\t// +optional\n\tReason string `json:\"reason,omitempty\" protobuf:\"bytes,3,opt,name=reason\"`\n\t// Message is a human-readable message indicating details about last transition.\n\t// +optional\n\tMessage string `json:\"message,omitempty\" protobuf:\"bytes,4,opt,name=message\"`\n\t// LastTransitionTime is the last time the condition transitioned from one status to another.\n\tLastTransitionTime metav1.Time `json:\"lastTransitionTime\" protobuf:\"bytes,5,opt,name=lastTransitionTime\"`\n}\n\n// CodeInterpreterSpec defines the configuration for an embedded code interpreter.\n// This type is specific to AgentRuntime but may be reused by other CRDs that need\n// code interpreter functionality.\ntype CodeInterpreterSpec struct {\n\t// Enabled indicates whether to attach a code interpreter.\n\t// +optional\n\tEnabled bool `json:\"enabled,omitempty\" protobuf:\"varint,1,opt,name=enabled\"`\n\t// Image is the container image for the code interpreter.\n\t// +optional\n\tImage string `json:\"image,omitempty\" protobuf:\"bytes,2,opt,name=image\"`\n\t// Resources defines the resource requirements for the code interpreter.\n\t// +optional\n\tResources *ResourceQuota `json:\"resources,omitempty\" protobuf:\"bytes,3,opt,name=resources\"`\n}\n\n// ResourceQuota defines resource limits and requests.\ntype ResourceQuota struct {\n\t// CPU is the CPU limit in cores (e.g., \"500m\" for 0.5 CPU).\n\t// +optional\n\tCPU string `json:\"cpu,omitempty\" protobuf:\"bytes,1,opt,name=cpu\"`\n\t// Memory is the memory limit in bytes (e.g., \"512Mi\", \"1Gi\").\n\t// +optional\n\tMemory string `json:\"memory,omitempty\" protobuf:\"bytes,2,opt,name=memory\"`\n\t// Storage is the storage limit in bytes (e.g., \"1Gi\", \"10Gi\").\n\t// +optional\n\tStorage string `json:\"storage,omitempty\" protobuf:\"bytes,3,opt,name=storage\"`\n}\n\n// NetworkPolicy defines network access rules for the runtime.\ntype NetworkPolicy struct {\n\t// EgressRules defines allowed egress destinations.\n\t// +optional\n\tEgressRules []NetworkRule `json:\"egressRules,omitempty\" protobuf:\"bytes,1,rep,name=egressRules\"`\n\t// IngressRules defines allowed ingress sources.\n\t// +optional\n\tIngressRules []NetworkRule `json:\"ingressRules,omitempty\" protobuf:\"bytes,2,rep,name=ingressRules\"`\n}\n\n// NetworkRule defines a single network rule.\ntype NetworkRule struct {\n\t// CIDR is the IP CIDR block (e.g., \"10.0.0.0/8\").\n\t// +optional\n\tCIDR string `json:\"cidr,omitempty\" protobuf:\"bytes,1,opt,name=cidr\"`\n\t// Ports is the list of allowed ports.\n\t// +optional\n\tPorts []int32 `json:\"ports,omitempty\" protobuf:\"varint,2,rep,name=ports\"`\n\t// Protocol is the network protocol (TCP, UDP).\n\t// +optional\n\tProtocol corev1.Protocol `json:\"protocol,omitempty\" protobuf:\"bytes,3,opt,name=protocol,casttype=k8s.io/api/core/v1.Protocol\"`\n}\n\n// LifecycleHook defines lifecycle callbacks for the runtime.\ntype LifecycleHook struct {\n\t// PreStart is the URL to call before the runtime starts.\n\t// +optional\n\tPreStart string `json:\"preStart,omitempty\" protobuf:\"bytes,1,opt,name=preStart\"`\n\t// PostStop is the URL to call after the runtime stops.\n\t// +optional\n\tPostStop string `json:\"postStop,omitempty\" protobuf:\"bytes,2,opt,name=postStop\"`\n}\n\n// ContainerSpec defines the container configuration for the runtime.\ntype ContainerSpec struct {\n\t// Image is the container image to run.\n\t// +optional\n\tImage string `json