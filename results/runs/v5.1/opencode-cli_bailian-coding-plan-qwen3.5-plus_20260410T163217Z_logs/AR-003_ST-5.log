ContainerSpec(&spec.Container, field.NewPath(\"container\"))...)\n//\t    return allErrs\n//\t}\n//\n// +k8s:openapi-gen=true\n// +k8s:deepcopy-gen=package\n// +groupName=runtime.agentcube.volcano.sh\n// +versionName=v1alpha1\npackage v1alpha1\n","additions":40,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/apis/runtime/v1alpha1/doc.go","time":{"start":1775840492278,"end":1775840492479}}}}
