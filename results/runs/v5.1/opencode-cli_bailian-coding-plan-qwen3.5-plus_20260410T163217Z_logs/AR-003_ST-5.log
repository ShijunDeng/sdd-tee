nil {\n\t\treturn allErrs\n\t}\n\n\tif quota.CPU != \"\" {\n\t\tif _, err := resource.ParseQuantity(quota.CPU); err != nil {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"cpu\"),\n\t\t\t\tquota.CPU,\n\t\t\t\t\"must be a valid resource quantity\",\n\t\t\t))\n\t\t}\n\t}\n\n\tif quota.Memory != \"\" {\n\t\tif _, err := resource.ParseQuantity(quota.Memory); err != nil {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"memory\"),\n\t\t\t\tquota.Memory,\n\t\t\t\t\"must be a valid resource quantity\",\n\t\t\t))\n\t\t}\n\t}\n\n\tif quota.Storage != \"\" {\n\t\tif _, err := resource.ParseQuantity(quota.Storage); err != nil {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"storage\"),\n\t\t\t\tquota.Storage,\n\t\t\t\t\"must be a valid resource quantity\",\n\t\t\t))\n\t\t}\n\t}\n\n\treturn allErrs\n}\n\n// ValidateResourceQuota validates resource quota fields.\n// This is a SHARED validation function intended for reuse across multiple CRDs.\nfunc ValidateResourceQuota(quota *ResourceQuota, fldPath *field.Path) field.ErrorList {\n\tallErrs := field.ErrorList{}\n\n\tif quota == nil {\n\t\treturn allErrs\n\t}\n\n\tif quota.CPU != \"\" {\n\t\tif _, err := resource.ParseQuantity(quota.CPU); err != nil {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"cpu\"),\n\t\t\t\tquota.CPU,\n\t\t\t\t\"must be a valid resource quantity\",\n\t\t\t))\n\t\t}\n\t}\n\n\tif quota.Memory != \"\" {\n\t\tif _, err := resource.ParseQuantity(quota.Memory); err != nil {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"memory\"),\n\t\t\t\tquota.Memory,\n\t\t\t\t\"must be a valid resource quantity\",\n\t\t\t))\n\t\t}\n\t}\n\n\tif quota.Storage != \"\" {\n\t\tif _, err := resource.ParseQuantity(quota.Storage); err != nil {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"storage\"),\n\t\t\t\tquota.Storage,\n\t\t\t\t\"must be a valid resource quantity\",\n\t\t\t))\n\t\t}\n\t}\n\n\treturn allErrs\n}\n\nfunc validateNetworkPolicy(policy *NetworkPolicy, fldPath *field.Path) field.ErrorList {\n\tallErrs := field.ErrorList{}\n\n\tif policy == nil {\n\t\treturn allErrs\n\t}\n\n\tfor i, rule := range policy.EgressRules {\n\t\tif rule.CIDR != \"\" && !cidrRegex.MatchString(rule.CIDR) {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"egressRules\").Index(i).Child(\"cidr\"),\n\t\t\t\trule.CIDR,\n\t\t\t\t\"must be a valid CIDR block\",\n\t\t\t))\n\t\t}\n\n\t\tfor _, port := range rule.Ports {\n\t\t\tif port < 1 || port > 65535 {\n\t\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\t\tfldPath.Child(\"egressRules\").Index(i).Child(\"ports\").Index(0),\n\t\t\t\t\tport,\n\t\t\t\t\t\"must be between 1 and 65535\",\n\t\t\t\t))\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, rule := range policy.IngressRules {\n\t\tif rule.CIDR != \"\" && !cidrRegex.MatchString(rule.CIDR) {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"ingressRules\").Index(i).Child(\"cidr\"),\n\t\t\t\trule.CIDR,\n\t\t\t\t\"must be a valid CIDR block\",\n\t\t\t))\n\t\t}\n\t}\n\n\treturn allErrs\n}\n\n// ValidateNetworkPolicy validates network policy configuration.\n// This is a SHARED validation function intended for reuse across multiple CRDs.\nfunc ValidateNetworkPolicy(policy *NetworkPolicy, fldPath *field.Path) field.ErrorList {\n\tallErrs := field.ErrorList{}\n\n\tif policy == nil {\n\t\treturn allErrs\n\t}\n\n\tfor i, rule := range policy.EgressRules {\n\t\tif rule.CIDR != \"\" && !cidrRegex.MatchString(rule.CIDR) {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"egressRules\").Index(i).Child(\"cidr\"),\n\t\t\t\trule.CIDR,\n\t\t\t\t\"must be a valid CIDR block\",\n\t\t\t))\n\t\t}\n\n\t\tfor j, port := range rule.Ports {\n\t\t\tif port < 1 || port > 65535 {\n\t\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\t\tfldPath.Child(\"egressRules\").Index(i).Child(\"ports\").Index(j),\n\t\t\t\t\tport,\n\t\t\t\t\t\"must be between 1 and 65535\",\n\t\t\t\t))\n\t\t\t}\n\t\t}\n\t}\n\n\tfor i, rule := range policy.IngressRules {\n\t\tif rule.CIDR != \"\" && !cidrRegex.MatchString(rule.CIDR) {\n\t\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\t\tfldPath.Child(\"ingressRules\").Index(i).Child(\"cidr\"),\n\t\t\t\trule.CIDR,\n\t\t\t\t\"must be a valid CIDR block\",\n\t\t\t))\n\t\t}\n\t}\n\n\treturn allErrs\n}\n\nfunc validateLifecycleHook(hook *LifecycleHook, fldPath *field.Path) field.ErrorList {\n\tallErrs := field.ErrorList{}\n\n\tif hook == nil {\n\t\treturn allErrs\n\t}\n\n\tif hook.PreStart != \"\" && !isValidURL(hook.PreStart) {\n\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\tfldPath.Child(\"preStart\"),\n\t\t\thook.PreStart,\n\t\t\t\"must be a valid URL\",\n\t\t))\n\t}\n\n\tif hook.PostStop != \"\" && !isValidURL(hook.PostStop) {\n\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\tfldPath.Child(\"postStop\"),\n\t\t\thook.PostStop,\n\t\t\t\"must be a valid URL\",\n\t\t))\n\t}\n\n\treturn allErrs\n}\n\nfunc validateCodeInterpreter(ci *CodeInterpreterSpec, fldPath *field.Path) field.ErrorList {\n\tallErrs := field.ErrorList{}\n\n\tif ci == nil {\n\t\treturn allErrs\n\t}\n\n\tif ci.Enabled && ci.Image != \"\" && !imageRegex.MatchString(ci.Image) {\n\t\tallErrs = append(allErrs, field.Invalid(\n\t\t\tfldPath.Child(\"image\"),\n\t\t\tci.Image,\n\t\t\t\"must be a valid container image name\",\n\t\t))\n\t}\n\n\tallErrs = append(allErrs, validateResourceQuota(ci.Resources, fldPath.Child(\"resources\"))...)\n\n\treturn allErrs\n}\n\nfunc isValidURL(url string) bool {\n\treturn strings.HasPrefix(url, \"http://\") || strings.HasPrefix(url, \"https://\")\n}\n\nfunc ValidateAgentRuntimeStatusUpdate(oldObj, newObj *AgentRuntime) field.ErrorList {\n\tallErrs := field.ErrorList{}\n\tstatusPath := field.NewPath(\"status\")\n\n\tvalidTransitions := map[AgentRuntimePhase][]AgentRuntimePhase{\n\t\t\"\":                           {AgentRuntimePhasePending},\n\t\tAgentRuntimePhasePending:     {AgentRuntimePhaseRunning, AgentRuntimePhaseFailed, AgentRuntimePhaseTerminating},\n\t\tAgentRuntimePhaseRunning:     {AgentRuntimePhaseFailed, AgentRuntimePhaseTerminating},\n\t\tAgentRuntimePhaseFailed:      {},\n\t\tAgentRuntimePhaseTerminating: {AgentRuntimePhaseTerminating},\n\t}\n\n\toldPhase := oldObj.Status.Phase\n\tnewPhase := newObj.Status.Phase\n\n\tif allowed, ok := validTransitions[oldPhase]; ok {\n\t\tvalid := false\n\t\tfor _, p := range allowed {\n\t\t\tif p == newPhase {\n\t\t\t\tvalid = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !valid && oldPhase != newPhase {\n\t\t\tallErrs = append(allErrs, field.Forbidden(\n\t\t\t\tstatusPath.Child(\"phase\"),\n\t\t\t\tfmt.Sprintf(\"invalid phase transition from %s to %s\", oldPhase, newPhase),\n\t\t\t))\n\t\t}\n\t}\n\n\treturn allErrs\n}\n\nfunc ValidateAgentRuntimePhase(phase AgentRuntimePhase) error {\n\tswitch phase {\n\tcase \"\", AgentRuntimePhasePending, AgentRuntimePhaseRunning, AgentRuntimePhaseFailed, AgentRuntimePhaseTerminating:\n\t\treturn nil\n\tdefault:\n\t\treturn errors.New(\"invalid phase\")\n\t}\n}\n","after":"/*\nCopyright 2026 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage v1alpha1\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strings\"\n\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\t\"k8s.io/apimachinery/pkg/util/validation/field\"\n)\n\nvar (\n\timageRegex = regexp.MustCompile(`^[a-zA-Z0-9][a-zA-Z0-9._/-]*(:[a-zA-Z0-9._-]+)?$`)\n\tcidrRegex  = 