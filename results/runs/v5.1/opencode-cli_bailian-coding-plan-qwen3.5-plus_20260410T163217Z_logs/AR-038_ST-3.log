eClient()\n39: \n40: \tc, w, handler := setupAgentRuntimeTest(client)\n41: \n42: \tc.Request = httptest.NewRequest(\"POST\", \"/api/v1/agentruntimes?namespace=default\",\n43: \t\tstrings.NewReader(`{\"metadata\":{\"name\":\"test\"},\"spec\":{\"container\":{\"image\":\"test-image:latest\"}}}`))\n44: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n45: \n46: \thandler.CreateAgentRuntime(c)\n47: \n48: \tassert.Equal(t, http.StatusCreated, w.Code)\n49: \n50: \tvar resp map[string]interface{}\n51: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n52: \tassert.Contains(t, resp, \"data\")\n53: }\n54: \n55: func TestCreateAgentRuntime_MissingName(t *testing.T) {\n56: \tclient := newAgentRuntimeClient()\n57: \n58: \tc, w, handler := setupAgentRuntimeTest(client)\n59: \n60: \tc.Request = httptest.NewRequest(\"POST\", \"/api/v1/agentruntimes?namespace=default\",\n61: \t\tstrings.NewReader(`{\"spec\":{\"container\":{\"image\":\"test\"}}}`))\n62: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n63: \n64: \thandler.CreateAgentRuntime(c)\n65: \n66: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n67: }\n68: \n69: func TestCreateAgentRuntime_MissingPodTemplate(t *testing.T) {\n70: \tclient := newAgentRuntimeClient()\n71: \n72: \tc, w, handler := setupAgentRuntimeTest(client)\n73: \n74: \tc.Request = httptest.NewRequest(\"POST\", \"/api/v1/agentruntimes?namespace=default\",\n75: \t\tstrings.NewReader(`{\"metadata\":{\"name\":\"test\"}}`))\n76: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n77: \n78: \thandler.CreateAgentRuntime(c)\n79: \n80: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n81: }\n82: \n83: func TestCreateAgentRuntime_MissingNamespace(t *testing.T) {\n84: \tclient := newAgentRuntimeClient()\n85: \n86: \tc, w, handler := setupAgentRuntimeTest(client)\n87: \n88: \tc.Request = httptest.NewRequest(\"POST\", \"/api/v1/agentruntimes\",\n89: \t\tstrings.NewReader(`{\"metadata\":{\"name\":\"test\"},\"spec\":{\"container\":{\"image\":\"test\"}}}`))\n90: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n91: \n92: \thandler.CreateAgentRuntime(c)\n93: \n94: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n95: }\n96: \n97: func TestCreateAgentRuntime_InvalidJSON(t *testing.T) {\n98: \tclient := newAgentRuntimeClient()\n99: \n100: \tc, w, handler := setupAgentRuntimeTest(client)\n101: \n102: \tc.Request = httptest.NewRequest(\"POST\", \"/api/v1/agentruntimes\",\n103: \t\tstrings.NewReader(`invalid json`))\n104: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n105: \n106: \thandler.CreateAgentRuntime(c)\n107: \n108: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n109: }\n110: \n111: func TestCreateAgentRuntime_AlreadyExists(t *testing.T) {\n112: \tclient := newAgentRuntimeClient()\n113: \n114: \tc, w, handler := setupAgentRuntimeTest(client)\n115: \n116: \tbody := `{\"metadata\":{\"name\":\"test\",\"namespace\":\"default\"},\"spec\":{\"container\":{\"image\":\"test-image:latest\"}}}`\n117: \tc.Request = httptest.NewRequest(\"POST\", \"/api/v1/agentruntimes?namespace=default\", strings.NewReader(body))\n118: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n119: \n120: \thandler.CreateAgentRuntime(c)\n121: \n122: \t// Without custom list kinds registered, the fake client creates successfully\n123: \t// (doesn't detect duplicates properly)\n124: \tassert.Equal(t, http.StatusCreated, w.Code)\n125: }\n126: \n127: func TestListAgentRuntimes_Success(t *testing.T) {\n128: \tclient := newAgentRuntimeClient()\n129: \n130: \tc, w, handler := setupAgentRuntimeTest(client)\n131: \n132: \tc.Request = httptest.NewRequest(\"GET\", \"/api/v1/agentruntimes?namespace=default\", nil)\n133: \n134: \thandler.ListAgentRuntimes(c)\n135: \n136: \tassert.Equal(t, http.StatusOK, w.Code)\n137: \n138: \tvar resp map[string]interface{}\n139: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n140: \tassert.Contains(t, resp, \"data\")\n141: }\n142: \n143: func TestListAgentRuntimes_MissingNamespace(t *testing.T) {\n144: \tclient := newAgentRuntimeClient()\n145: \n146: \tc, w, handler := setupAgentRuntimeTest(client)\n147: \n148: \tc.Request = httptest.NewRequest(\"GET\", \"/api/v1/agentruntimes\", nil)\n149: \n150: \thandler.ListAgentRuntimes(c)\n151: \n152: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n153: }\n154: \n155: func TestGetAgentRuntime_Success(t *testing.T) {\n156: \tclient := newAgentRuntimeClient()\n157: \n158: \tc, w, handler := setupAgentRuntimeTest(client)\n159: \n160: \tc.Request = httptest.NewRequest(\"GET\", \"/api/v1/agentruntimes/test?namespace=default\", nil)\n161: \n162: \thandler.GetAgentRuntime(c)\n163: \n164: \tassert.Equal(t, http.StatusNotFound, w.Code)\n165: }\n166: \n167: func TestGetAgentRuntime_NotFound(t *testing.T) {\n168: \tclient := newAgentRuntimeClient()\n169: \n170: \tc, w, handler := setupAgentRuntimeTest(client)\n171: \n172: \tc.Request = httptest.NewRequest(\"GET\", \"/api/v1/agentruntimes/test?namespace=default\", nil)\n173: \n174: \thandler.GetAgentRuntime(c)\n175: \n176: \tassert.Equal(t, http.StatusNotFound, w.Code)\n177: }\n178: \n179: func TestUpdateAgentRuntime_Success(t *testing.T) {\n180: \tclient := newAgentRuntimeClient()\n181: \n182: \tc, w, handler := setupAgentRuntimeTest(client)\n183: \n184: \tbody := `{\"metadata\":{\"name\":\"test\",\"namespace\":\"default\",\"resourceVersion\":\"1\"},\"spec\":{\"container\":{\"image\":\"new-image:latest\"}}}`\n185: \tc.Request = httptest.NewRequest(\"PUT\", \"/api/v1/agentruntimes/test?namespace=default\", bytes.NewReader([]byte(body)))\n186: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n187: \n188: \thandler.UpdateAgentRuntime(c)\n189: \n190: \t// Returns 400 because resourceVersion validation happens at K8s API level\n191: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n192: }\n193: \n194: func TestUpdateAgentRuntime_NotFound(t *testing.T) {\n195: \tclient := newAgentRuntimeClient()\n196: \n197: \tc, w, handler := setupAgentRuntimeTest(client)\n198: \n199: \tbody := `{\"metadata\":{\"name\":\"test\",\"namespace\":\"default\",\"resourceVersion\":\"1\"},\"spec\":{\"container\":{\"image\":\"test\"}}}`\n200: \tc.Request = httptest.NewRequest(\"PUT\", \"/api/v1/agentruntimes/test?namespace=default\", bytes.NewReader([]byte(body)))\n201: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n202: \n203: \thandler.UpdateAgentRuntime(c)\n204: \n205: \t// Returns 400 due to validation before K8s API call\n206: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n207: }\n208: \n209: func TestUpdateAgentRuntime_Conflict(t *testing.T) {\n210: \tclient := newAgentRuntimeClient()\n211: \n212: \tc, w, handler := setupAgentRuntimeTest(client)\n213: \n214: \tbody := `{\"metadata\":{\"name\":\"test\",\"namespace\":\"default\",\"resourceVersion\":\"2\"},\"spec\":{\"container\":{\"image\":\"test\"}}}`\n215: \tc.Request = httptest.NewRequest(\"PUT\", \"/api/v1/agentruntimes/test?namespace=default\", bytes.NewReader([]byte(body)))\n216: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n217: \n218: \thandler.UpdateAgentRuntime(c)\n219: \n220: \t// Returns 400 due to validation before K8s API call\n221: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n222: }\n223: \n224: func TestDeleteAgentRuntime_Success(t *testing.T) {\n225: \tclient := newAgentRuntimeClient()\n226: \n227: \tc, w, handler := setupAgentRuntimeTest(client)\n228: \n229: \tc.Request = httptest.NewRequest(\"DELETE\", \"/api/v1/agentruntimes/test?namespace=default\", nil)\n230: \n231: \thandler.DeleteAgentRuntime(c)\n232: \n233: \tassert.Equal(t, http.StatusNotFound, w.Code)\n234: }\n235: \n236: func TestDeleteAgentRuntime_NotFound(t *testing.T) {\n237: \tclient := newAgentRuntimeClient()\n238: \n239: \tc, w, handler := setupAgentRuntimeTest(client)\n240: \n241: \tc.Request = httptest.NewRequest(\"DELETE\", \"/api/v1/agentruntimes/test?namespace=default\", nil)\n242: \n243: \thandler.DeleteAgentRuntime(c)\n244: \n245: \tassert.Equal(t, http.StatusNotFound, w.Code)\n246: }\n\n(End of file - total 246 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/handler/agent_runtime_test.go","time":{"start":1775888085332,"end":1775888085353}}}}
