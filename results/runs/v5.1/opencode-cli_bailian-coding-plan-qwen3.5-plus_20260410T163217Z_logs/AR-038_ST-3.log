6: \t\t\"app.kubernetes.io/name\":       \"agentcube\",\n47: \t\t\"app.kubernetes.io/component\":  \"sandbox\",\n48: \t\t\"agentcube.volcano.sh/runtime\": ar.Name,\n49: \t\t\"agentcube.volcano.sh/type\":    \"agentruntime\",\n50: \t}\n51: \tfor k, v := range ar.Labels {\n52: \t\tlabels[k] = v\n53: \t}\n54: \n55: \tannotations := map[string]string{\n56: \t\t\"agentcube.volcano.sh/created-at\": time.Now().Format(time.RFC3339),\n57: \t}\n58: \tfor k, v := range ar.Annotations {\n59: \t\tannotations[k] = v\n60: \t}\n61: \n62: \tpod := &corev1.Pod{\n63: \t\tObjectMeta: metav1.ObjectMeta{\n64: \t\t\tName:        podName,\n65: \t\t\tNamespace:   ar.Namespace,\n66: \t\t\tLabels:      labels,\n67: \t\t\tAnnotations: annotations,\n68: \t\t},\n69: \t\tSpec: p.buildPodSpec(ar),\n70: \t}\n71: \n72: \tif err := SetControllerReference(pod, ar, AgentRuntimeGVK); err != nil {\n73: \t\treturn nil, fmt.Errorf(\"failed to set owner reference: %w\", err)\n74: \t}\n75: \n76: \treturn pod, nil\n77: }\n78: \n79: func (p *SandboxProcessor) BuildCodeInterpreterPod(ci *runtimev1alpha1.CodeInterpreter) (*corev1.Pod, error) {\n80: \tpodName := fmt.Sprintf(\"sandbox-%s\", ci.Name)\n81: \n82: \tlabels := map[string]string{\n83: \t\t\"app.kubernetes.io/name\":           \"agentcube\",\n84: \t\t\"app.kubernetes.io/component\":      \"sandbox\",\n85: \t\t\"agentcube.volcano.sh/interpreter\": ci.Name,\n86: \t\t\"agentcube.volcano.sh/type\":        \"codeinterpreter\",\n87: \t}\n88: \tfor k, v := range ci.Labels {\n89: \t\tlabels[k] = v\n90: \t}\n91: \n92: \tannotations := map[string]string{\n93: \t\t\"agentcube.volcano.sh/created-at\": time.Now().Format(time.RFC3339),\n94: \t}\n95: \tfor k, v := range ci.Annotations {\n96: \t\tannotations[k] = v\n97: \t}\n98: \n99: \tpod := &corev1.Pod{\n100: \t\tObjectMeta: metav1.ObjectMeta{\n101: \t\t\tName:        podName,\n102: \t\t\tNamespace:   ci.Namespace,\n103: \t\t\tLabels:      labels,\n104: \t\t\tAnnotations: annotations,\n105: \t\t},\n106: \t\tSpec: p.buildCodeInterpreterPodSpec(ci),\n107: \t}\n108: \n109: \tif err := SetControllerReference(pod, ci, CodeInterpreterGVK); err != nil {\n110: \t\treturn nil, fmt.Errorf(\"failed to set owner reference: %w\", err)\n111: \t}\n112: \n113: \treturn pod, nil\n114: }\n115: \n116: func (p *SandboxProcessor) buildPodSpec(ar *runtimev1alpha1.AgentRuntime) corev1.PodSpec {\n117: \tspec := corev1.PodSpec{\n118: \t\tContainers: []corev1.Container{\n119: \t\t\t{\n120: \t\t\t\tName:         \"sandbox\",\n121: \t\t\t\tImage:        ar.Spec.Container.Image,\n122: \t\t\t\tCommand:      ar.Spec.Container.Command,\n123: \t\t\t\tArgs:         ar.Spec.Container.Args,\n124: \t\t\t\tEnv:          ar.Spec.Container.Env,\n125: \t\t\t\tResources:    p.buildResourceRequirements(ar.Spec.Resources),\n126: \t\t\t\tPorts:        p.buildContainerPorts(ar.Spec.Network),\n127: \t\t\t\tVolumeMounts: p.buildVolumeMounts(nil),\n128: \t\t\t},\n129: \t\t},\n130: \t\tVolumes:       p.buildVolumes(nil),\n131: \t\tRestartPolicy: corev1.RestartPolicyNever,\n132: \t}\n133: \n134: \tif ar.Spec.CodeInterpreter != nil && ar.Spec.CodeInterpreter.Enabled {\n135: \t\tspec.Containers = append(spec.Containers, p.buildCodeInterpreterContainer(ar.Spec.CodeInterpreter))\n136: \t}\n137: \n138: \treturn spec\n139: }\n140: \n141: func (p *SandboxProcessor) buildCodeInterpreterPodSpec(ci *runtimev1alpha1.CodeInterpreter) corev1.PodSpec {\n142: \treturn corev1.PodSpec{\n143: \t\tContainers: []corev1.Container{\n144: \t\t\t{\n145: \t\t\t\tName:      \"code-interpreter\",\n146: \t\t\t\tImage:     ci.Spec.Image,\n147: \t\t\t\tResources: p.buildResourceRequirements(ci.Spec.Resources),\n148: \t\t\t},\n149: \t\t},\n150: \t\tRestartPolicy: corev1.RestartPolicyNever,\n151: \t}\n152: }\n153: \n154: func (p *SandboxProcessor) buildResourceRequirements(quota *runtimev1alpha1.ResourceQuota) corev1.ResourceRequirements {\n155: \tif quota == nil {\n156: \t\treturn corev1.ResourceRequirements{}\n157: \t}\n158: \n159: \tresources := corev1.ResourceRequirements{\n160: \t\tRequests: corev1.ResourceList{},\n161: \t\tLimits:   corev1.ResourceList{},\n162: \t}\n163: \n164: \tif quota.CPU != \"\" {\n165: \t\tresources.Requests[corev1.ResourceCPU] = resource.MustParse(quota.CPU)\n166: \t\tresources.Limits[corev1.ResourceCPU] = resource.MustParse(quota.CPU)\n167: \t}\n168: \n169: \tif quota.Memory != \"\" {\n170: \t\tresources.Requests[corev1.ResourceMemory] = resource.MustParse(quota.Memory)\n171: \t\tresources.Limits[corev1.ResourceMemory] = resource.MustParse(quota.Memory)\n172: \t}\n173: \n174: \tif quota.Storage != \"\" {\n175: \t\tresources.Requests[corev1.ResourceStorage] = resource.MustParse(quota.Storage)\n176: \t}\n177: \n178: \treturn resources\n179: }\n180: \n181: func (p *SandboxProcessor) buildContainerPorts(network *runtimev1alpha1.NetworkPolicy) []corev1.ContainerPort {\n182: \tif network == nil || len(network.IngressRules) == 0 {\n183: \t\treturn []corev1.ContainerPort{\n184: \t\t\t{\n185: \t\t\t\tName:          \"http\",\n186: \t\t\t\tContainerPort: 8080,\n187: \t\t\t\tProtocol:      corev1.ProtocolTCP,\n188: \t\t\t},\n189: \t\t}\n190: \t}\n191: \n192: \tports := make([]corev1.ContainerPort, 0)\n193: \tfor _, rule := range network.IngressRules {\n194: \t\tfor _, port := range rule.Ports {\n195: \t\t\tports = append(ports, corev1.ContainerPort{\n196: \t\t\t\tContainerPort: port,\n197: \t\t\t\tProtocol:      rule.Protocol,\n198: \t\t\t})\n199: \t\t}\n200: \t}\n201: \n202: \tif len(ports) == 0 {\n203: \t\tports = append(ports, corev1.ContainerPort{\n204: \t\t\tName:          \"http\",\n205: \t\t\tContainerPort: 8080,\n206: \t\t\tProtocol:      corev1.ProtocolTCP,\n207: \t\t})\n208: \t}\n209: \n210: \treturn ports\n211: }\n212: \n213: func (p *SandboxProcessor) buildVolumeMounts(volumes []interface{}) []corev1.VolumeMount {\n214: \treturn []corev1.VolumeMount{}\n215: }\n216: \n217: func (p *SandboxProcessor) buildVolumes(volumes []interface{}) []corev1.Volume {\n218: \treturn []corev1.Volume{}\n219: }\n220: \n221: func (p *SandboxProcessor) buildCodeInterpreterContainer(ciSpec *runtimev1alpha1.CodeInterpreterSpec) corev1.Container {\n222: \treturn corev1.Container{\n223: \t\tName:      \"code-interpreter\",\n224: \t\tImage:     ciSpec.Image,\n225: \t\tResources: p.buildResourceRequirements(ciSpec.Resources),\n226: \t}\n227: }\n228: \n229: func (p *SandboxProcessor) NeedsUpdate(pod *corev1.Pod, ar *runtimev1alpha1.AgentRuntime) bool {\n230: \tif len(pod.Spec.Containers) == 0 {\n231: \t\treturn true\n232: \t}\n233: \n234: \tif pod.Spec.Containers[0].Image != ar.Spec.Container.Image {\n235: \t\treturn true\n236: \t}\n237: \n238: \tif !reflect.DeepEqual(pod.Spec.Containers[0].Resources, p.buildResourceRequirements(ar.Spec.Resources)) {\n239: \t\treturn true\n240: \t}\n241: \n242: \tif !reflect.DeepEqual(pod.Spec.Containers[0].Env, ar.Spec.Container.Env) {\n243: \t\treturn true\n244: \t}\n245: \n246: \treturn false\n247: }\n248: \n249: func (p *SandboxProcessor) NeedsUpdateCodeInterpreter(pod *corev1.Pod, ci *runtimev1alpha1.CodeInterpreter) bool {\n250: \tif len(pod.Spec.Containers) == 0 {\n251: \t\treturn true\n252: \t}\n253: \n254: \tif pod.Spec.Containers[0].Image != ci.Spec.Image {\n255: \t\treturn true\n256: \t}\n257: \n258: \tif !reflect.DeepEqual(pod.Spec.Containers[0].Resources, p.buildResourceRequirements(ci.Spec.Resources)) {\n259: \t\treturn true\n260: \t}\n261: \n262: \treturn false\n263: }\n264: \n265: func (p *SandboxProcessor) UpdateSandboxPod(ctx context.Context, pod *corev1.Pod, ar *runtimev1alpha1.AgentRuntime) (*corev1.Pod, error) {\n266: \tif err := p.k8sClient.CoreV1().Pods(pod.Namespace).Delete(ctx, pod.Name, metav1.DeleteOptions{}); err != nil {\n267: \t\treturn nil, fmt.Errorf(\"failed to delete pod: %w\", err)\n268: \t}\n269: \n270: \tnewPod, err := p.BuildSandboxPod(ar)\n271: \tif err != nil {\n272: \t\treturn nil, fmt.Errorf(\"failed to build new pod: %w\", err)\n273: \t}\n274: \n275: \tcreatedPod, err := p.k8sClient.CoreV1().Pods(ar.Namespace).Create(ctx, newPod, metav1.CreateOptions{})\n276: \tif err != nil {\n277: \t\treturn nil, fmt.Errorf(\"failed to create new pod: %w\", err)\n278: \t}\n279: \n280: \treturn createdPod, nil\n281: }\n282: \n283: func (p *SandboxProcessor) UpdateCodeInterpreterPod(ctx context.Context, pod *corev1.Pod, ci *runtimev1alpha1.CodeInterpreter) (*corev1.Pod, error) {\n284: \tif err := p.k8sClient.CoreV1().Pods(pod.Namespace).Delete(ctx, pod.Name, metav1.DeleteOptions{}); err != nil {\n285: \t\treturn nil, fmt.Errorf(\"failed to delete pod: %w\", err)\n286: \t}\n287: \n288: \tnewPod, err := p.BuildCodeInterpreterPod(ci)\n289: \tif err != nil {\n290: \t\treturn nil, fmt.Errorf(\"failed to build new pod: %w\", err)\n291: \t}\n292: \n293: \tcreatedPod, err := p.k8sClient.CoreV1().Pods(ci.Namespace).Create(ctx, newPod, metav1.CreateOptions{})\n294: \tif err != nil {\n295: \t\treturn nil, fmt.Errorf(\"failed to create new pod: %w\", err)\n296: \t}\n297: \n298: \treturn createdPod, nil\n299: }\n\n(End of file - total 299 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/kubernetes\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nvar (\n\tAgentRuntimeGVK = schema.GroupVersionKind{\n\t\tGroup:   \"runtime.agentcube.volcano.sh\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/reconciler/sandbox_processor.go","time":{"start":1775888074383,"end":1775888074409}}}}
