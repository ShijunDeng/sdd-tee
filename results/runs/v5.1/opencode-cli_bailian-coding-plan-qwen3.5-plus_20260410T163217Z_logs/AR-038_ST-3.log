t\tUID:       pod.UID,\n93: \t\t}\n94: \t\tciCopy.Status.Conditions = u.buildConditionsFromPod(pod)\n95: \n96: \t\tif pod.Status.Phase == corev1.PodRunning && pod.Status.StartTime != nil {\n97: \t\t\tciCopy.Status.StartTime = pod.Status.StartTime\n98: \t\t}\n99: \t}\n100: \n101: \tif reflect.DeepEqual(ci.Status, ciCopy.Status) {\n102: \t\treturn nil\n103: \t}\n104: \n105: \tnow := metav1.Now()\n106: \tciCopy.Status.LastTransitionTime = &now\n107: \n108: \treturn u.updateCodeInterpreterStatusSubresource(ctx, ciCopy)\n109: }\n110: \n111: func (u *StatusUpdater) updateAgentRuntimeStatusSubresource(ctx context.Context, ar *runtimev1alpha1.AgentRuntime) error {\n112: \tarUnstructured, err := u.runtimeToUnstructured(ar)\n113: \tif err != nil {\n114: \t\treturn fmt.Errorf(\"failed to convert AgentRuntime to unstructured: %w\", err)\n115: \t}\n116: \n117: \tstatusMap := make(map[string]interface{})\n118: \tstatusBytes, _ := json.Marshal(ar.Status)\n119: \tjson.Unmarshal(statusBytes, &statusMap)\n120: \n121: \tarUnstructured.Object[\"status\"] = statusMap\n122: \n123: \tgvr := schema.GroupVersionResource{\n124: \t\tGroup:    \"runtime.agentcube.volcano.sh\",\n125: \t\tVersion:  \"v1alpha1\",\n126: \t\tResource: \"agentruntimes\",\n127: \t}\n128: \n129: \t_, err = u.dynamicClient.Resource(gvr).Namespace(ar.Namespace).UpdateStatus(ctx, arUnstructured, metav1.UpdateOptions{})\n130: \treturn err\n131: }\n132: \n133: func (u *StatusUpdater) updateCodeInterpreterStatusSubresource(ctx context.Context, ci *runtimev1alpha1.CodeInterpreter) error {\n134: \tciUnstructured, err := u.runtimeToUnstructured(ci)\n135: \tif err != nil {\n136: \t\treturn fmt.Errorf(\"failed to convert CodeInterpreter to unstructured: %w\", err)\n137: \t}\n138: \n139: \tstatusMap := make(map[string]interface{})\n140: \tstatusBytes, _ := json.Marshal(ci.Status)\n141: \tjson.Unmarshal(statusBytes, &statusMap)\n142: \n143: \tciUnstructured.Object[\"status\"] = statusMap\n144: \n145: \tgvr := schema.GroupVersionResource{\n146: \t\tGroup:    \"runtime.agentcube.volcano.sh\",\n147: \t\tVersion:  \"v1alpha1\",\n148: \t\tResource: \"codeinterpreters\",\n149: \t}\n150: \n151: \t_, err = u.dynamicClient.Resource(gvr).Namespace(ci.Namespace).UpdateStatus(ctx, ciUnstructured, metav1.UpdateOptions{})\n152: \treturn err\n153: }\n154: \n155: func (u *StatusUpdater) runtimeToUnstructured(obj interface{}) (*unstructured.Unstructured, error) {\n156: \tdata, err := json.Marshal(obj)\n157: \tif err != nil {\n158: \t\treturn nil, err\n159: \t}\n160: \n161: \tunstructuredObj := &unstructured.Unstructured{}\n162: \tif err := json.Unmarshal(data, unstructuredObj); err != nil {\n163: \t\treturn nil, err\n164: \t}\n165: \n166: \treturn unstructuredObj, nil\n167: }\n168: \n169: func mapPodPhaseToRuntimePhase(podPhase corev1.PodPhase) runtimev1alpha1.AgentRuntimePhase {\n170: \tswitch podPhase {\n171: \tcase corev1.PodPending:\n172: \t\treturn runtimev1alpha1.AgentRuntimePhasePending\n173: \tcase corev1.PodRunning:\n174: \t\treturn runtimev1alpha1.AgentRuntimePhaseRunning\n175: \tcase corev1.PodFailed:\n176: \t\treturn runtimev1alpha1.AgentRuntimePhaseFailed\n177: \tcase corev1.PodSucceeded:\n178: \t\treturn runtimev1alpha1.AgentRuntimePhasePending\n179: \tcase corev1.PodUnknown:\n180: \t\treturn runtimev1alpha1.AgentRuntimePhasePending\n181: \tdefault:\n182: \t\treturn runtimev1alpha1.AgentRuntimePhasePending\n183: \t}\n184: }\n185: \n186: func (u *StatusUpdater) buildConditionsFromPod(pod *corev1.Pod) []runtimev1alpha1.AgentRuntimeCondition {\n187: \tconditions := make([]runtimev1alpha1.AgentRuntimeCondition, 0, len(pod.Status.Conditions))\n188: \n189: \tfor _, pc := range pod.Status.Conditions {\n190: \t\tconditions = append(conditions, runtimev1alpha1.AgentRuntimeCondition{\n191: \t\t\tType:               runtimev1alpha1.AgentRuntimeConditionType(pc.Type),\n192: \t\t\tStatus:             pc.Status,\n193: \t\t\tReason:             pc.Reason,\n194: \t\t\tMessage:            pc.Message,\n195: \t\t