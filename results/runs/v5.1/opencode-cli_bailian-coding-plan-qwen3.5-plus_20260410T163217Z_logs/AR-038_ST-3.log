,\n96: \t\tBlockOwnerDeletion: &blockOwnerDeletion,\n97: \t}\n98: }\n99: \n100: func IsOwnerReferenceEqual(ref1, ref2 metav1.OwnerReference) bool {\n101: \treturn ref1.UID == ref2.UID &&\n102: \t\tref1.Kind == ref2.Kind &&\n103: \t\tref1.Name == ref2.Name &&\n104: \t\tref1.APIVersion == ref2.APIVersion\n105: }\n106: \n107: func NewOwnerReference(apiVersion, kind, name string, uid types.UID, controller bool) metav1.OwnerReference {\n108: \tblockOwnerDeletion := controller\n109: \treturn metav1.OwnerReference{\n110: \t\tAPIVersion:         apiVersion,\n111: \t\tKind:               kind,\n112: \t\tName:               name,\n113: \t\tUID:                uid,\n114: \t\tController:         &controller,\n115: \t\tBlockOwnerDeletion: &blockOwnerDeletion,\n116: \t}\n117: }\n118: \n119: func GetOwnerName(object metav1.Object) string {\n120: \tfor _, ref := range object.GetOwnerReferences() {\n121: \t\tif ref.Controller != nil && *ref.Controller {\n122: \t\t\treturn ref.Name\n123: \t\t}\n124: \t}\n125: \treturn \"\"\n126: }\n127: \n128: func GetOwnerKind(object metav1.Object) string {\n129: \tfor _, ref := range object.GetOwnerReferences() {\n130: \t\tif ref.Controller != nil && *ref.Controller {\n131: \t\t\treturn ref.Kind\n132: \t\t}\n133: \t}\n134: \treturn \"\"\n135: }\n136: \n137: func HasFinalizer(object metav1.Object, finalizer string) bool {\n138: \tfor _, f := range object.GetFinalizers() {\n139: \t\tif f == finalizer {\n140: \t\t\treturn true\n141: \t\t}\n142: \t}\n143: \treturn false\n144: }\n145: \n146: func AddFinalizer(object metav1.Object, finalizer string) {\n147: \tfinalizers := object.GetFinalizers()\n148: \tif !HasFinalizer(object, finalizer) {\n149: \t\tfinalizers = append(finalizers, finalizer)\n150: \t\tobject.SetFinalizers(finalizers)\n151: \t}\n152: }\n153: \n154: func RemoveFinalizer(object metav1.Object, finalizer string) {\n155: \tfinalizers := object.GetFinalizers()\n156: \tnewFinalizers := make([]string, 0, len(finalizers))\n157: \tfor _, f := range finalizers {\n158: \t\tif f != finalizer {\n159: \t\t\tnewFinalizers = append(newFinalizers, f)\n160: \t\t}\n161: \t}\n162: \tobject.SetFinalizers(newFinalizers)\n163: }\n164: \n165: func IsBeingDeleted(object metav1.Object) bool {\n166: \treturn object.GetDeletionTimestamp() != nil\n167: }\n168: \n169: func IsReadyToCleanup(object metav1.Object) bool {\n170: \tif !IsBeingDeleted(object) {\n171: \t\treturn false\n172: \t}\n173: \n174: \tfinalizers := object.GetFinalizers()\n175: \treturn len(finalizers) == 0\n176: }\n\n(End of file - total 176 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/apimachinery/pkg/types\"\n)\n\nfunc SetControllerReference(owner, object metav1.Object, ownerGVK schema.GroupVersionKind) error {\n\townerRef := metav1.OwnerReference{\n\t\tAPIVersion:         ownerGVK.GroupVersion().String(),\n\t\tKind:               ownerGVK.Kind,\n\t\tName:               owner.GetName(),\n\t\tUID:                owner.GetUID(),\n\t\tController:         boolPtr(true),\n\t\tBlockOwnerDeletion: boolPtr(true),\n\t}\n\tobject.SetOwnerReferences(append(object.GetOwnerReferences(), ownerRef))\n\treturn nil\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/reconciler/owner_reference.go","time":{"start":1775888085326,"end":1775888085349}}}}
