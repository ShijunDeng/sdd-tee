{"type":"tool_use","timestamp":1775846444774,"sessionID":"ses_2874e3a02ffeM2bj7rWe1qljUQ","part":{"id":"prt_d78b243fc001ZSmkziS2y0laoM","messageID":"msg_d78b2340b0011nPHETKa9WJmlP","sessionID":"ses_2874e3a02ffeM2bj7rWe1qljUQ","type":"tool","tool":"read","callID":"toolu_164e06a2e27a4034b06b7811","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/reconciler/agentruntime_reconciler.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/reconciler/agentruntime_reconciler.go</path>\n<type>file</type>\n<content>\n1: package reconciler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"time\"\n7: \n8: \tcorev1 \"k8s.io/api/core/v1\"\n9: \tk8s_errors \"k8s.io/apimachinery/pkg/api/errors\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: \t\"k8s.io/apimachinery/pkg/labels\"\n12: \t\"k8s.io/client-go/dynamic\"\n13: \t\"k8s.io/client-go/kubernetes\"\n14: \tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n15: \t\"k8s.io/client-go/tools/cache\"\n16: \t\"k8s.io/client-go/tools/record\"\n17: \t\"k8s.io/client-go/util/workqueue\"\n18: \n19: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n20: )\n21: \n22: type AgentRuntimeReconciler struct {\n23: \tdynamicClient dynamic.Interface\n24: \tk8sClient     kubernetes.Interface\n25: \tarLister      dynamic.NamespaceableResourceInterface\n26: \tpodLister     corev1lister.PodLister\n27: \tpodIndexer    cache.Indexer\n28: \trecorder      record.EventRecorder\n29: \tworkqueue     workqueue.RateLimitingInterface\n30: \tmetrics       *ReconcilerMetrics\n31: \tconfig        *ReconcilerConfig\n32: \tprocessor     *SandboxProcessor\n33: \tstatusUpdater *StatusUpdater\n34: }\n35: \n36: func NewAgentRuntimeReconciler(\n37: \tdynamicClient dynamic.Interface,\n38: \tk8sClient kubernetes.Interface,\n39: \tpodLister corev1lister.PodLister,\n40: \tpodIndexer cache.Indexer,\n41: \trecorder record.EventRecorder,\n42: \tmetrics *ReconcilerMetrics,\n43: \tconfig *ReconcilerConfig,\n44: ) *AgentRuntimeReconciler {\n45: \tworkqueue := workqueue.NewNamedRateLimitingQueue(\n46: \t\tworkqueue.DefaultControllerRateLimiter(),\n47: \t\t\"agentruntimes\",\n48: \t)\n49: \n50: \tarResource := dynamicClient.Resource(\n51: \t\truntimev1alpha1.SchemeGroupVersion.WithResource(\"agentruntimes\"),\n52: \t)\n53: \n54: \treconciler := &AgentRuntimeReconciler{\n55: \t\tdynamicClient: dynamicClient,\n56: \t\tk8sClient:     k8sClient,\n57: \t\tarLister:      arResource,\n58: \t\tpodLister:     podLister,\n59: \t\tpodIndexer:    podIndexer,\n60: \t\trecorder:      recorder,\n61: \t\tworkqueue:     workqueue,\n62: \t\tmetrics:       metrics,\n63: \t\tconfig:        config,\n64: \t\tprocessor:     NewSandboxProcessor(k8sClient),\n65: \t\tstatusUpdater: NewStatusUpdater(dynamicClient),\n66: \t}\n67: \n68: \treturn reconciler\n69: }\n70: \n71: func (r *AgentRuntimeReconciler) Run(ctx context.Context) {\n72: \tdefer r.workqueue.ShutDown()\n73: \n74: \tfor r.processNextWorkItem(ctx) {\n75: \t}\n76: }\n77: \n78: func (r *AgentRuntimeReconciler) processNextWorkItem(ctx context.Context) bool {\n79: \tobj, shutdown := r.workqueue.Get()\n80: \tif shutdown {\n81: \t\treturn false\n82: \t}\n83: \n84: \tdefer r.workqueue.Done(obj)\n85: \n86: \treq, ok := obj.(Request)\n87: \tif !ok {\n88: \t\tr.workqueue.Forget(obj)\n89: \t\treturn true\n90: \t}\n91: \n92: \tif result, err := r.Reconcile(ctx, req); err != nil {\n93: \t\tr.metrics.RecordError()\n94: \t\tr.workqueue.AddRateLimited(obj)\n95: \t} else if result.Requeue {\n96: \t\tif result.RequeueAfter > 0 {\n97: \t\t\tr.workqueue.Forget(obj)\n98: \t\t\tr.workqueue.AddAfter(obj, result.RequeueAfter)\n99: \t\t} else {\n100: \t\t\tr.workqueue.AddRateLimited(obj)\n101: \t\t}\n102: \t} else {\n103: \t\tr.workqueue.Forget(obj)\n104: \t}\n105: \n106: \treturn true\n107: }\n108: \n109: func (r *AgentRuntimeReconciler) Reconcile(ctx context.Context, req Request) (Result, error) {\n110: \tstartTime := time.Now()\n111: \tdefer func() {\n112: \t\tr.metrics.ObserveReconcileDuration(time.Since(startTime))\n113: \t\tr.metrics.RecordReconcile()\n114: \t}()\n115: \n116: \tar, err := r.getAgentRuntime(req.Namespace, req.Name)\n117: \tif err != nil {\n118: \t\tif k8s_errors.IsNotFound(err) {\n119: \t\t\treturn Result{}, nil\n120: \t\t}\n121: \t\treturn Result{}, fmt.Errorf(\"failed to get AgentRuntime: %w\", err)\n122: \t}\n123: \n124: \tif !ar.DeletionTimestamp.IsZero() {\n125: \t\treturn r.reconcileDeletion(ctx, ar)\n126: \t}\n127: \n128: \tpod, err := r.reconcileSandboxPod(ctx, ar)\n129: \tif err != nil {\n130: \t\tr.recorder.Eventf(ar, corev1.EventTypeWarning, ErrPodCreationFailed, \"Failed to create sandbox pod: %v\", err)\n131: \n132: \t\tif IsRetryableError(err) {\n133: \t\t\treturn Result{RequeueAfter: CalculateBackoff(1)}, nil\n134: \t\t}\n135: \t\treturn Result{}, err\n136: \t}\n137: \n138: \tif err := r.statusUpdater.UpdateAgentRuntimeStatus(ctx, ar, pod); err != nil {\n139: \t\tr.recorder.Eventf(ar, corev1.EventTypeWarning, ErrStatusUpdateFailed, \"Failed to update status: %v\", err)\n140: \n141: \t\tif IsRetryableError(err) {\n142: \t\t\treturn Result{RequeueAfter: CalculateBackoff(2)}, nil\n143: \t\t}\n144: \t\treturn Result{}, err\n145: \t}\n146: \n147: \tr.recorder.Eventf(ar, corev1.EventTypeNormal, \"Reconciled\", \"Successfully reconciled AgentRuntime\")\n148: \n149: \treturn Result{}, nil\n150: }\n151: \n152: func (r *AgentRuntimeReconciler) getAgentRuntime(namespace, name string) (*runtimev1alpha1.AgentRuntime, error) {\n153: \tarMap, err := r.arLister.Namespace(namespace).Get(context.Background(), name, metav1.GetOptions{})\n154: \tif err != nil {\n155: \t\treturn nil, err\n156: \t}\n157: \n158: \tar := &runtimev1alpha1.AgentRuntime{}\n159: \tar.Name = arMap.GetName()\n160: \tar.Namespace = arMap.GetNamespace()\n161: \tar.Labels = arMap.GetLabels()\n162: \tar.Annotations = arMap.GetAnnotations()\n163: \tar.Finalizers = arMap.GetFinalizers()\n164: \n165: \tspecRaw, _ := arMap.MarshalJSON()\n166: \tif err := json.Unmarshal(specRaw, ar); err != nil {\n167: \t\treturn nil, fmt.Errorf(\"failed to unmarshal AgentRuntime: %w\", err)\n168: \t}\n169: \n170: \treturn ar, nil\n171: }\n172: \n173: func (r *AgentRuntimeReconciler) reconcileDeletion(ctx context.Context, ar *runtimev1alpha1.AgentRuntime) (Result, error) {\n174: \tpod, err := r.getSandboxPod(ar.Namespace, ar.Name)\n175: \tif err != nil && !k8s_errors.IsNotFound(err) {\n176: \t\treturn Result{}, fmt.Errorf(\"failed to get pod: %w\", err)\n177: \t}\n178: \n179: \tif pod != nil {\n180: \t\tif err := r.k8sClient.CoreV1().Pods(ar.Namespace).Delete(ctx, pod.Name, metav1.DeleteOptions{}); err != nil && !k8s_errors.IsNotFound(err) {\n181: \t\t\treturn Result{}, fmt.Errorf(\"failed to delete pod: %w\", err)\n182: \t\t}\n183: \t}\n184: \n185: \treturn Result{}, nil\n186: }\n187: \n188: func (r *AgentRuntimeReconciler) reconcileSandboxPod(ctx context.Context, ar *runtimev1alpha1.AgentRuntime) (*corev1.Pod, error) {\n189: \tpod, err := r.getSandboxPod(ar.Namespace, ar.Name)\n190: \tif err != nil && !k8s_errors.IsNotFound(err) {\n191: \t\treturn nil, fmt.Errorf(\"failed to get pod: %w\", err)\n192: \t}\n193: \n194: \tif pod == nil {\n195: \t\tnewPod, err := r.processor.BuildSandboxPod(ar)\n196: \t\tif err != nil {\n197: \t\t\treturn nil, fmt.Errorf(\"failed to build pod: %w\", err)\n198: \t\t}\n199: \n200: \t\tcreatedPod, err := r.k8sClient.CoreV1().Pods(ar.Namespace).Create(ctx, newPod, metav1.CreateOptions{})\n201: \t\tif err != nil {\n202: \t\t\treturn nil, fmt.Errorf(\"failed to create pod: %w\", err)\n203: \t\t}\n204: \n205: \t\treturn createdPod, nil\n206: \t}\n207: \n208: \tif r.processor.NeedsUpdate(pod, ar) {\n209: \t\tupdatedPod, err := r.processor.UpdateSandboxPod(ctx, pod, ar)\n210: \t\tif err != nil {\n211: \t\t\treturn nil, fmt.Errorf(\"failed to update pod: %w\", err)\n212: \t\t}\n213: \t\treturn updatedPod, nil\n214: \t}\n215: \n216: \treturn pod, nil\n217: }\n218: \n219: func (r *AgentRuntimeReconciler) getSandboxPod(namespace, arName string) (*corev1.Pod, error) {\n220: \tpodName := fmt.Sprintf(\"sandbox-%s\", arName)\n221: \n222: \tpod, err := r.podLister.Pods(namespace).Get(podName)\n223: \tif err == nil {\n224: \t\treturn pod, nil\n225: \t}\n226: \n227: \tif !k8s_errors.IsNotFound(err) {\n228: \t\treturn nil, err\n229: \t}\n230: \n231: \tselector := labels.SelectorFromSet(labels.Set{\n232: \t\t\"agentcube.volcano.sh/runtime\": arName,\n233: \t})\n234: \n235: \tpodList, err := r.podLister.Pods(namespace).List(selector)\n236: \tif err != nil {\n237: \t\treturn nil, err\n238: \t}\n239: \n240: \tif len(podList) > 0 {\n241: \t\treturn podList[0], nil\n242: \t}\n243: \n244: \treturn nil, k8s_errors.NewNotFound(corev1.Resource(\"pods\"), podName)\n245: }\n246: \n247: func (r *AgentRuntimeReconciler) EnqueueAgentRuntime(obj interface{}) {\n248: \tenqueueObject(r.workqueue, obj)\n249: }\n250: \n251: func (r *AgentRuntimeReconciler) EnqueueUpdate(oldObj, newObj interface{}) {\n252: \tenqueueUpdate(r.workqueue, oldObj, newObj)\n253: }\n254: \n255: func (r *AgentRuntimeReconciler) EnqueueDelete(obj interface{}) {\n256: \tenqueueDelete(r.workqueue, obj)\n257: }\n258: \n259: func (r *AgentRuntimeReconciler) EnqueueOwnedPod(obj interface{}) {\n260: \tpod, ok := obj.(*corev1.Pod)\n261: \tif !ok {\n262: \t\treturn\n263: \t}\n264: \n265: \townerRef := metav1.GetControllerOf(pod)\n266: \tif ownerRef == nil || ownerRef.Kind != \"AgentRuntime\" {\n267: \t\treturn\n268: \t}\n269: \n270: \tr.workqueue.Add(Request{\n271: \t\tNamespace: pod.Namespace,\n272: \t\tName:      ownerRef.Name,\n273: \t})\n274: }\n275: \n276: func (r *AgentRuntimeReconciler) EnqueueOwnedPodUpdate(oldObj, newObj interface{}) {\n277: \tnewPod, ok := newObj.(*corev1.Pod)\n278: \tif !ok {\n279: \t\treturn\n280: \t}\n281: \n282: \townerRef := metav1.GetControllerOf(newPod)\n283: \tif ownerRef == nil || ownerRef.Kind != \"AgentRuntime\" {\n284: \t\treturn\n285: \t}\n286: \n287: \tr.workqueue.Add(Request{\n288: \t\tNamespace: newPod.Namespace,\n289: \t\tName:      ownerRef.Name,\n290: \t})\n291: }\n292: \n293: func (r *AgentRuntimeReconciler) EnqueueOwnedPodDelete(obj interface{}) {\n294: \tvar pod *corev1.Pod\n295: \n296: \ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n297: \tif ok {\n298: \t\tpod, ok = tombstone.Obj.(*corev1.Pod)\n299: \t\tif !ok {\n300: \t\t\treturn\n301: \t\t}\n302: \t} else {\n303: \t\tpod, ok = obj.(*corev1.Pod)\n304: \t\tif !ok {\n305: \t\t\treturn\n306: \t\t}\n307: \t}\n308: \n309: \townerRef := metav1.GetControllerOf(pod)\n310: \tif ownerRef == nil || ownerRef.Kind != \"AgentRuntime\" {\n311: \t\treturn\n312: \t}\n313: \n314: \tr.workqueue.Add(Request{\n315: \t\tNamespace: pod.Namespace,\n316: \t\tName:      ownerRef.Name,\n317: \t})\n318: }\n\n(End of file - total 318 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tk8s_errors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/client-go/tools/record\"\n\t\"k8s.io/client-go/util/workqueue\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/reconciler/agentruntime_reconciler.go","time":{"start":1775846444758,"end":1775846444773}}}}
