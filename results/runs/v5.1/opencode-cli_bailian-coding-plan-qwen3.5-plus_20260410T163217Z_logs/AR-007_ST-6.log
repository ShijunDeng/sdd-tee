ler.ListAgentRuntimes)\n36: \t\tarGroup.GET(\"/:name\", arHandler.GetAgentRuntime)\n37: \t\tarGroup.PUT(\"/:name\", arHandler.UpdateAgentRuntime)\n38: \t\tarGroup.DELETE(\"/:name\", arHandler.DeleteAgentRuntime)\n39: \t}\n40: \n41: \tciGroup := engine.Group(\"/api/v1/codeinterpreters\")\n42: \t{\n43: \t\tciHandler := handler.NewCodeInterpreterHandler(deps.Client)\n44: \t\tciGroup.POST(\"\", ciHandler.CreateCodeInterpreter)\n45: \t\tciGroup.GET(\"\", ciHandler.ListCodeInterpreters)\n46: \t\tciGroup.GET(\"/:name\", ciHandler.GetCodeInterpreter)\n47: \t\tciGroup.PUT(\"/:name\", ciHandler.UpdateCodeInterpreter)\n48: \t\tciGroup.DELETE(\"/:name\", ciHandler.DeleteCodeInterpreter)\n49: \t}\n50: \n51: \tsandboxGroup := engine.Group(\"/v1\")\n52: \t{\n53: \t\tsandboxHandler := handler.NewSandboxHandler(\n54: \t\t\tdeps.Client,\n55: \t\t\tdeps.K8sClient,\n56: \t\t\tdeps.PodLister,\n57: \t\t\tdeps.ARLister,\n58: \t\t\tdeps.CILister,\n59: \t\t\t\"default\",\n60: \t\t)\n61: \t\tsandboxGroup.POST(\"/agent-runtime\", sandboxHandler.HandleAgentRuntimeCreate)\n62: \t\tsandboxGroup.POST(\"/code-interpreter\", sandboxHandler.HandleCodeInterpreterCreate)\n63: \t}\n64: }\n65: \n66: type informerListerAdapter struct {\n67: \tinformer runtimev1alpha1.AgentRuntimeInformer\n68: }\n69: \n70: func (a *informerListerAdapter) AgentRuntimes(namespace string) processor.AgentRuntimeNamespaceLister {\n71: \treturn a.informer.Lister().AgentRuntimes(namespace)\n72: }\n73: \n74: type codeInterpreterListerAdapter struct {\n75: \tinformer runtimev1alpha1.CodeInterpreterInformer\n76: }\n77: \n78: func (a *codeInterpreterListerAdapter) CodeInterpreters(namespace string) processor.CodeInterpreterNamespaceLister {\n79: \treturn a.informer.Lister().CodeInterpreters(namespace)\n80: }\n\n(End of file - total 80 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\tcorev1lister \"k8s.i