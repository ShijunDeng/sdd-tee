ewObj.(metav1.Object)\n54: \tif !ok {\n55: \t\treturn\n56: \t}\n57: \n58: \tif oldMeta.GetResourceVersion() == newMeta.GetResourceVersion() {\n59: \t\treturn\n60: \t}\n61: \n62: \tqueue.Add(Request{\n63: \t\tNamespace: newMeta.GetNamespace(),\n64: \t\tName:      newMeta.GetName(),\n65: \t})\n66: }\n67: \n68: func enqueueDelete(queue workqueue.RateLimitingInterface, obj interface{}) {\n69: \ttombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n70: \tif ok {\n71: \t\tobj = tombstone.Obj\n72: \t}\n73: \n74: \tmeta, ok := obj.(metav1.Object)\n75: \tif !ok {\n76: \t\treturn\n77: \t}\n78: \n79: \tqueue.Add(Request{\n80: \t\tNamespace: meta.GetNamespace(),\n81: \t\tName:      meta.GetName(),\n82: \t})\n83: }\n84: \n85: func getOwnerReference(obj metav1.Object, ownerKind, ownerName string) *metav1.OwnerReference {\n86: \tfor _, ref := range obj.GetOwnerReferences() {\n87: \t\tif ref.Kind == ownerKind && ref.Name == ownerName {\n88: \t\t\treturn &ref\n89: \t\t}\n90: \t}\n91: \treturn nil\n92: }\n93: \n94: func isControlledBy(obj metav1.Object, owner types.UID) bool {\n95: \tfor _, ref := range obj.GetOwnerReferences() {\n96: \t\tif ref.Controller != nil && *ref.Controller && ref.UID == owner {\n97: \t\t\treturn true\n98: \t\t}\n99: \t}\n100: \treturn false\n101: }\n\n(End of file - total 101 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/client-go/util/workqueue\"\n)\n\ntype Request struct {\n\tNamespace string\n\tName      string\n}\n\ntype Result struct {\n\tRequeue      bool\n\tRequeueAfter time.Duration","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/reconciler/interface.go","time":{"start":1775846444760,"end":1775846444775}}}}
