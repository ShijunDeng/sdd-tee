ling this will ensure there is only one active controller manager.\")\n39: \n40: \topts := zap.Options{\n41: \t\tDevelopment: true,\n42: \t}\n43: \topts.BindFlags(flag.CommandLine)\n44: \tflag.Parse()\n45: \n46: \tctrl.SetLogger(zap.New(zap.UseFlagOptions(&opts)))\n47: \n48: \tmgr, err := ctrl.NewManager(ctrl.GetConfigOrDie(), ctrl.Options{\n49: \t\tScheme: scheme,\n50: \t\tMetrics: metricsserver.Options{\n51: \t\t\tBindAddress: metricsAddr,\n52: \t\t},\n53: \t\tHealthProbeBindAddress: probeAddr,\n54: \t\tLeaderElection:         enableLeaderElection,\n55: \t\tLeaderElectionID:       \"agentd-leader\",\n56: \t})\n57: \tif err != nil {\n58: \t\tsetupLog.Error(err, \"unable to start manager\")\n59: \t\tos.Exit(1)\n60: \t}\n61: \n62: \tif err = (&agentd.Reconciler{\n63: \t\tClient: mgr.GetClient(),\n64: \t\tScheme: mgr.GetScheme(),\n65: \t}).SetupWithManager(mgr); err != nil {\n66: \t\tsetupLog.Error(err, \"unable to create controller\", \"controller\", \"Agentd\")\n67: \t\tos.Exit(1)\n68: \t}\n69: \n70: \tsetupLog.Info(\"starting manager\")\n71: \tif err := mgr.Start(signals.SetupSignalHandler()); err != nil {\n72: \t\tsetupLog.Error(err, \"problem running manager\")\n73: \t\tos.Exit(1)\n74: \t}\n75: }\n\n(End of file - total 75 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"flag\"\n\t\"os\"\n\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tutilruntime \"k8s.io/apimachinery/pkg/util/runtime\"\n\tclientgoscheme \"k8s.io/client-go/kubernetes/scheme\"\n\t_ \"k8s.io/client-go/plugin/pkg/client/auth\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/log/zap\"\n\t\"sigs.k8s.io/controller-runtime/pkg/manager/signals\"\n\tmetricsserver \"sigs.k8s.io/controller-runtime/pkg/metrics/server\"\n\n\tagentd \"github.com/volcano-sh/agentcube/pkg/agentd\"\n)\n\nvar (\n\tscheme   = runtime.NewScheme()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/agentd/mai