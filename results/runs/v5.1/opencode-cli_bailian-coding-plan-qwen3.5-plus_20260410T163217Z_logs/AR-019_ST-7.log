\n50: \t\t\treturn runQuotaSet(cfg)\n51: \t\t},\n52: \t}\n53: \n54: \tcmd.Flags().StringVar(&defaultCPU, \"cpu\", \"1\", \"default CPU request\")\n55: \tcmd.Flags().StringVar(&defaultMemory, \"memory\", \"512Mi\", \"default memory request\")\n56: \tcmd.Flags().StringVar(&maxCPU, \"max-cpu\", \"4\", \"maximum CPU limit\")\n57: \tcmd.Flags().StringVar(&maxMemory, \"max-memory\", \"4Gi\", \"maximum memory limit\")\n58: \tcmd.Flags().Int64Var(&maxSandboxes, \"max-sandboxes\", 10, \"maximum number of sandboxes\")\n59: \n60: \treturn cmd\n61: }\n62: \n63: func newQuotaGetCmd() *cobra.Command {\n64: \tcmd := &cobra.Command{\n65: \t\tUse:   \"get <namespace>\",\n66: \t\tShort: \"Get resource quota for a namespace\",\n67: \t\tArgs:  cobra.ExactArgs(1),\n68: \t\tRunE: func(cmd *cobra.Command, args []string) error {\n69: \t\t\treturn runQuotaGet(args[0])\n70: \t\t},\n71: \t}\n72: \n73: \treturn cmd\n74: }\n75: \n76: func newQuotaListCmd() *cobra.Command {\n77: \tcmd := &cobra.Command{\n78: \t\tUse:   \"list\",\n79: \t\tShort: \"List all resource quotas\",\n80: \t\tRunE: func(cmd *cobra.Command, args []string) error {\n81: \t\t\treturn runQuotaList()\n82: \t\t},\n83: \t}\n84: \n85: \treturn cmd\n86: }\n87: \n88: type QuotaConfig struct {\n89: \tNamespace     string\n90: \tDefaultCPU    string\n91: \tDefaultMemory string\n92: \tMaxCPU        string\n93: \tMaxMemory     string\n94: \tMaxSandboxes  int64\n95: }\n96: \n97: func runQuotaSet(cfg *QuotaConfig) error {\n98: \tif err := cliutil.ValidateNamespace(cfg.Namespace); err != nil {\n99: \t\treturn err\n100: \t}\n101: \n102: \tcliConfig, err := cliutil.LoadConfig()\n103: \tif err != nil {\n104: \t\treturn err\n105: \t}\n106: \n107: \tkubeClient, err := cliConfig.GetKubeClient()\n108: \tif err != nil {\n109: \t\treturn err\n110: \t}\n111: \n112: \tctx := context.Background()\n113: \n114: \t_, err = kubeClient.CoreV1().Namespaces().Get(ctx, cfg.Namespace, metav1.GetOptions{})\n115: \tif err != nil {\n116: \t\treturn fmt.Errorf(\"namespace %q not found: %w\", cfg.Namespace, err)\n117: \t}\n118: \n119: \tquota := &corev1.ResourceQuota{\n120: \t\tObjectMeta: metav1.ObjectMeta{\n121: \t\t\tName:      \"agentcube-quota\",\n122: \t\t\tNamespace: cfg.Namespace,\n123: \t\t},\n124: \t\tSpec: corev1.ResourceQuotaSpec{\n125: \t\t\tHard: corev1.ResourceList{\n126: \t\t\t\tcorev1.ResourceRequestsCPU:    resource.MustParse(cfg.DefaultCPU),\n127: \t\t\t\tcorev1.ResourceRequestsMemory: resource.MustParse(cfg.DefaultMemory),\n128: \t\t\t\tcorev1.ResourceLimitsCPU:      resource.MustParse(cfg.MaxCPU),\n129: \t\t\t\tcorev1.ResourceLimitsMemory:   resource.MustParse(cfg.MaxMemory),\n130: \t\t\t\tcorev1.ResourcePods:           *resource.NewQuantity(cfg.MaxSandboxes, resource.DecimalSI),\n131: \t\t\t},\n132: \t\t},\n133: \t}\n134: \n135: \texisting, err := kubeClient.CoreV1().ResourceQuotas(cfg.Namespace).Get(ctx, \"agentcube-quota\", metav1.GetOptions{})\n136: \tif err != nil {\n137: \t\tif _, err = kubeClient.CoreV1().ResourceQuotas(cfg.Namespace).Create(ctx, quota, metav1.CreateOptions{}); err != nil {\n138: \t\t\treturn fmt.Errorf(\"failed to create quota: %w\", err)\n139: \t\t}\n140: \t\tfmt.Printf(\"Resource quota created for namespace %q\\n\", cfg.Namespace)\n141: \t} else {\n142: \t\texisting.Spec = quota.Spec\n143: \t\tif _, err = kubeClient.CoreV1().ResourceQuotas(cfg.Namespace).Update(ctx, existing, metav1.UpdateOptions{}); err != nil {\n144: \t\t\treturn fmt.Errorf(\"failed to update quota: %w\", err)\n145: \t\t}\n146: \t\tfmt.Printf(\"Resource quota updated for namespace %q\\n\", cfg.Namespace)\n147: \t}\n148: \n149: \treturn nil\n150: }\n151: \n152: func runQuotaGet(ns string) error {\n153: \tcliConfig, err := cliutil.LoadConfig()\n154: \tif err != nil {\n155: \t\treturn err\n156: \t}\n157: \n158: \tkubeClient, err := cliConfig.GetKubeClient()\n159: \tif err != nil {\n160: \t\treturn err\n161: \t}\n162: \n163: \tctx := context.Background()\n164: \tquota, err := kubeClient.CoreV1().ResourceQuotas(ns).Get(ctx, \"agentcube-quota\", metav1.GetOptions{})\n165: \tif err != nil {\n166: \t\treturn fmt.Errorf(\"failed to get quota: %w\", err)\n167: \t}\n168: \n169: \tfmt.Printf(\"Namespace: %s\\n\", ns)\n170: \tfmt.Printf(\"Quota Name: %s\\n\", quota.Name)\n171: \tfmt.Println(\"\\nHard Limits:\")\n172: \tfor k, v := range quota.Spec.Hard {\n173: \t\tfmt.Printf(\"  %s: %s\\n\", k, v.String())\n174: \t}\n175: \n176: \treturn nil\n177: }\n178: \n179: func runQuotaList() error {\n180: \tcliConfig, err := cliutil.LoadConfig()\n181: \tif err != nil {\n182: \t\treturn err\n183: \t}\n184: \n185: \tkubeClient, err := cliConfig.GetKubeClient()\n186: \tif err != nil {\n187: \t\treturn err\n188: \t}\n189: \n190: \tctx := context.Background()\n191: \tquotaList, err := kubeClient.CoreV1().ResourceQuotas(\"\").List(ctx, metav1.ListOptions{})\n192: \tif err != nil {\n193: \t\treturn fmt.Errorf(\"failed to list quotas: %w\", err)\n194: \t}\n195: \n196: \trows := make([][]string, 0, len(quotaList.Items))\n197: \tfor _, quota := range quotaList.Items {\n198: \t\tcpu, hasCPU := quota.Spec.Hard[corev1.ResourceLimitsCPU]\n199: \t\tmemory, hasMemory := quota.Spec.Hard[corev1.ResourceLimitsMemory]\n200: \n201: \t\tcpuStr := \"-\"\n202: \t\tmemoryStr := \"-\"\n203: \t\tif hasCPU {\n204: \t\t\tcpuStr = cpu.String()\n205: \t\t}\n206: \t\tif hasMemory {\n207: \t\t\tmemoryStr = memory.String()\n208: \t\t}\n209: \n210: \t\trows = append(rows, []string{quota.Namespace, quota.Name, cpuStr, memoryStr})\n211: \t}\n212: \n213: \theaders := []string{\"NAMESPACE\", \"NAME\", \"CPU LIMIT\", \"MEMORY LIMIT\"}\n214: \treturn cliutil.PrintTable(rows, headers)\n215: }\n\n(End of file - total 215 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"github.com/spf13/cobra\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/cliutil\"\n)\n\nvar (\n