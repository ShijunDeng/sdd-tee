lient, err := cliConfig.GetKubeClient()\n56: \tif err != nil {\n57: \t\treturn err\n58: \t}\n59: \n60: \tctx := context.Background()\n61: \n62: \t_, err = kubeClient.CoreV1().Namespaces().List(ctx, metav1.ListOptions{Limit: 1})\n63: \tif err != nil {\n64: \t\treturn fmt.Errorf(\"API server unreachable: %w\", err)\n65: \t}\n66: \n67: \tfmt.Println(\"✓ API server is reachable\")\n68: \tfmt.Println(\"✓ Cluster is healthy\")\n69: \treturn nil\n70: }\n71: \n72: func runHealthReport() error {\n73: \tcliConfig, err := cliutil.LoadConfig()\n74: \tif err != nil {\n75: \t\treturn err\n76: \t}\n77: \n78: \tkubeClient, err := cliConfig.GetKubeClient()\n79: \tif err != nil {\n80: \t\treturn err\n81: \t}\n82: \n83: \tctx := context.Background()\n84: \n85: \tnsList, err := kubeClient.CoreV1().Namespaces().List(ctx, metav1.ListOptions{})\n86: \tif err != nil {\n87: \t\treturn err\n88: \t}\n89: \n90: \tnodeList, err := kubeClient.CoreV1().Nodes().List(ctx, metav1.ListOptions{})\n91: \tif err != nil {\n92: \t\treturn err\n93: \t}\n94: \n95: \tfmt.Println(\"Cluster Health Report\")\n96: \tfmt.Println(\"====================\")\n97: \tfmt.Printf(\"Total Namespaces: %d\\n\", len(nsList.Items))\n98: \tfmt.Printf(\"Total Nodes: %d\\n\", len(nodeList.Items))\n99: \n100: \trows := make([][]string, 0, len(nodeList.Items))\n101: \tfor _, node := range nodeList.Items {\n102: \t\tready := \"Unknown\"\n103: \t\tfor _, condition := range node.Status.Conditions {\n104: \t\t\tif condition.Type == \"Ready\" {\n105: \t\t\t\tif condition.Status == \"True\" {\n106: \t\t\t\t\tready = \"Ready\"\n107: \t\t\t\t} else {\n108: \t\t\t\t\tready = \"NotReady\"\n109: \t\t\t\t}\n110: \t\t\t\tbreak\n111: \t\t\t}\n112: \t\t}\n113: \n114: \t\tcpuCap := node.Status.Capacity.Cpu().String()\n115: \t\tmemCap := node.Status.Capacity.Memory().String()\n116: \n117: \t\trows = append(rows, []string{node.Name, ready, cpuCap, memCap})\n118: \t}\n119: \n120: \theaders := []string{\"NODE\", \"STATUS\", \"CPU\", \"MEMORY\"}\n121: \treturn cliutil.PrintTable(rows, headers)\n122: }\n\n(End of file - total 122 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"github.com/spf13/cobra\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/cliutil\"\n)\n\nfunc newHealthCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"health\",\n\t\tShort: \"Health checks and diagnostics\",\n\t}\n\n\tcmd.AddCommand(newHealthCheckCmd())\n\tcmd.AddCommand(newHealthReportCmd())","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/agentcube-admin/health.go","time":{"start":1775864992039,"end":1775864992051}}}}
