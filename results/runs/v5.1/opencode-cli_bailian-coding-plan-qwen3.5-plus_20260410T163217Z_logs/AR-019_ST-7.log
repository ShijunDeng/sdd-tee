\n54: func newPortForwardCmd() *cobra.Command {\n55: \tcmd := &cobra.Command{\n56: \t\tUse:   \"port-forward <sandbox-name> <local-port>:<remote-port>\",\n57: \t\tShort: \"Forward a local port to a sandbox\",\n58: \t\tArgs:  cobra.ExactArgs(2),\n59: \t\tRunE: func(cmd *cobra.Command, args []string) error {\n60: \t\t\treturn runPortForward(args[0], args[1])\n61: \t\t},\n62: \t}\n63: \n64: \treturn cmd\n65: }\n66: \n67: func newSessionsCmd() *cobra.Command {\n68: \tcmd := &cobra.Command{\n69: \t\tUse:   \"sessions\",\n70: \t\tShort: \"Manage sessions\",\n71: \t}\n72: \n73: \tcmd.AddCommand(newSessionsListCmd())\n74: \tcmd.AddCommand(newSessionsKillCmd())\n75: \n76: \treturn cmd\n77: }\n78: \n79: func newSessionsListCmd() *cobra.Command {\n80: \treturn &cobra.Command{\n81: \t\tUse:   \"list\",\n82: \t\tShort: \"List active sessions\",\n83: \t\tRunE: func(cmd *cobra.Command, args []string) error {\n84: \t\t\treturn runSessionsList()\n85: \t\t},\n86: \t}\n87: }\n88: \n89: func newSessionsKillCmd() *cobra.Command {\n90: \tcmd := &cobra.Command{\n91: \t\tUse:   \"kill <session-id>\",\n92: \t\tShort: \"Kill a session\",\n93: \t\tArgs:  cobra.ExactArgs(1),\n94: \t\tRunE: func(cmd *cobra.Command, args []string) error {\n95: \t\t\treturn runSessionsKill(args[0])\n96: \t\t},\n97: \t}\n98: \n99: \treturn cmd\n100: }\n101: \n102: func runConnect(sandboxName string) error {\n103: \tfmt.Printf(\"Connecting to sandbox %q with shell %s...\\n\", sandboxName, shellType)\n104: \tfmt.Println(\"(In production, this would establish an interactive shell session)\")\n105: \treturn nil\n106: }\n107: \n108: func runExec(sandboxName string, command []string) error {\n109: \tfmt.Printf(\"Executing %v in sandbox %q...\\n\", command, sandboxName)\n110: \tfmt.Println(\"(In production, this would execute the command and return output)\")\n111: \treturn nil\n112: }\n113: \n114: func runCp(src, dst string) error {\n115: \tfmt.Printf(\"Copying from %s to %s...\\n\", src, dst)\n116: \tfmt.Println(\"(In 