\t\tRunE: func(cmd *cobra.Command, args []string) error {\n53: \t\t\treturn runCleanupFailed()\n54: \t\t},\n55: \t}\n56: \n57: \tcmd.Flags().StringVar(&cleanupNS, \"namespace\", \"\", \"namespace to cleanup\")\n58: \tcmd.Flags().BoolVar(&forceCleanup, \"force\", false, \"force cleanup without confirmation\")\n59: \n60: \treturn cmd\n61: }\n62: \n63: func runCleanupIdle() error {\n64: \tfmt.Printf(\"Cleaning up idle resources older than %s...\\n\", olderThan)\n65: \tfmt.Println(\"Cleanup completed (no resources found)\")\n66: \treturn nil\n67: }\n68: \n69: func runCleanupFailed() error {\n70: \tif cleanupNS == \"\" {\n71: \t\tfmt.Println(\"Cleaning up failed resources in all namespaces...\")\n72: \t} else {\n73: \t\tfmt.Printf(\"Cleaning up failed resources in namespace %q...\\n\", cleanupNS)\n74: \t}\n75: \n76: \tcliConfig, err := cliutil.LoadConfig()\n77: \tif err != nil {\n78: \t\treturn err\n79: \t}\n80: \n81: \tclient, err := cliConfig.GetDynamicClient()\n82: \tif err != nil {\n83: \t\treturn err\n84: \t}\n85: \n86: \tctx := context.Background()\n87: \n88: \tgvr := schema.GroupVersionResource{\n89: \t\tGroup:    \"runtime.agentcube.volcano.sh\",\n90: \t\tVersion:  \"v1alpha1\",\n91: \t\tResource: \"codeinterpreters\",\n92: \t}\n93: \n94: \tlistOpts := metav1.ListOptions{}\n95: \tif cleanupNS != \"\" {\n96: \t\tlistOpts.FieldSelector = fmt.Sprintf(\"metadata.namespace=%s\", cleanupNS)\n97: \t}\n98: \n99: \tlist, err := client.Resource(gvr).Namespace(\"\").List(ctx, listOpts)\n100: \tif err != nil {\n101: \t\treturn err\n102: \t}\n103: \n104: \tdeletedCount := 0\n105: \tfor _, item := range list.Items {\n106: \t\tphase, _, _ := unstructured.NestedString(item.Object, \"status\", \"phase\")\n107: \t\tif phase == \"Failed\" {\n108: \t\t\terr := client.Resource(gvr).Namespace(item.GetNamespace()).Delete(ctx, item.GetName(), metav1.DeleteOptions{})\n109: \t\t\tif err != nil {\n110: \t\t\t\tfmt.Printf(\"Warning: failed to delete %s/%s: %v\\n\", item.GetNamespace(), item.GetName(), err)\n111: \t\t\t} else {\n112: \t\t\t\tdeletedCount++\n113: \t\t\t}\n114: \t\t}\n115: \t}\n116: \n117: \tfmt.Printf(\"Deleted %d failed resources\\n\", deletedCount)\n118: \treturn nil\n119: }\n\n(End of file - total 119 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/spf13/cobra\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/cliutil\"\n)\n\nvar (\n\tolderThan    time.Duration\n\tcleanupNS    string\n\tforceCleanup bool\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/agentcube-admin/cleanup.go","time":{"start":1775864981582,"end":1775864981609}}}}
