 \t}\n317: \n318: \treturn cliutil.PrintObject(result, outputFormat)\n319: }\n320: \n321: func runRuntimeDelete(opts *RuntimeDeleteOptions) error {\n322: \tif err := cliutil.ValidateSandboxName(opts.Name); err != nil {\n323: \t\treturn err\n324: \t}\n325: \n326: \tcfg, err := cliutil.LoadConfig()\n327: \tif err != nil {\n328: \t\treturn err\n329: \t}\n330: \tcfg.Namespace = opts.Namespace\n331: \n332: \tclient, err := cfg.GetDynamicClient()\n333: \tif err != nil {\n334: \t\treturn err\n335: \t}\n336: \n337: \tgvr := schema.GroupVersionResource{\n338: \t\tGroup:    \"runtime.agentcube.volcano.sh\",\n339: \t\tVersion:  \"v1alpha1\",\n340: \t\tResource: \"agentruntimes\",\n341: \t}\n342: \n343: \tctx := context.Background()\n344: \terr = client.Resource(gvr).Namespace(opts.Namespace).Delete(ctx, opts.Name, metav1.DeleteOptions{})\n345: \tif err != nil {\n346: \t\treturn fmt.Errorf(\"failed to delete runtime: %w\", err)\n347: \t}\n348: \n349: \treturn cliutil.PrintStatus(fmt.Sprintf(\"runtime %q deleted\", opts.Name), outputFormat)\n350: }\n351: \n352: func printRuntimeTable(items []unstructured.Unstructured) error {\n353: \trows := make([][]string, 0, len(items))\n354: \n355: \tfor _, item := range items {\n356: \t\tname := item.GetName()\n357: \t\tns := item.GetNamespace()\n358: \t\tphase, _, _ := unstructured.NestedString(item.Object, \"status\", \"phase\")\n359: \t\tif phase == \"\" {\n360: \t\t\tphase = \"Unknown\"\n361: \t\t}\n362: \n363: \t\trows = append(rows, []string{name, ns, phase})\n364: \t}\n365: \n366: \theaders := []string{\"NAME\", \"NAMESPACE\", \"PHASE\"}\n367: \treturn cliutil.PrintTable(rows, headers)\n368: }\n\n(End of file - total 368 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/spf13/cobra\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime/sche