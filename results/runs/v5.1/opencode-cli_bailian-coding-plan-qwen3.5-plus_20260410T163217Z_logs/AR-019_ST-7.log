xy status\",\n44: \t\tRunE: func(cmd *cobra.Command, args []string) error {\n45: \t\t\tfmt.Println(\"Proxy status: running\")\n46: \t\t\tfmt.Printf(\"Listen: %s:%d\\n\", proxyListenAddr, proxyListenPort)\n47: \t\t\treturn nil\n48: \t\t},\n49: \t}\n50: }\n51: \n52: func newStopCmd() *cobra.Command {\n53: \treturn &cobra.Command{\n54: \t\tUse:   \"stop\",\n55: \t\tShort: \"Stop the proxy server\",\n56: \t\tRunE: func(cmd *cobra.Command, args []string) error {\n57: \t\t\tfmt.Println(\"Proxy stopped\")\n58: \t\t\treturn nil\n59: \t\t},\n60: \t}\n61: }\n62: \n63: func runProxy() error {\n64: \tif !proxyAPIServer && (proxyResourceType == \"\" || proxyResourceName == \"\") {\n65: \t\treturn fmt.Errorf(\"either --api-server or --resource and --name must be specified\")\n66: \t}\n67: \n68: \tproxy := httputil.NewSingleHostReverseProxy(&url.URL{Scheme: \"https\", Host: \"kubernetes.default.svc\"})\n69: \n70: \tbaseHandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n71: \t\tif proxyAuthToken != \"\" {\n72: \t\t\tif token := r.Header.Get(\"Authorization\"); token != \"Bearer \"+proxyAuthToken {\n73: \t\t\t\thttp.Error(w, \"unauthorized\", http.StatusUnauthorized)\n74: \t\t\t\treturn\n75: \t\t\t}\n76: \t\t}\n77: \t\tproxy.ServeHTTP(w, r)\n78: \t})\n79: \n80: \tserver := &http.Server{\n81: \t\tAddr:    fmt.Sprintf(\"%s:%d\", proxyListenAddr, proxyListenPort),\n82: \t\tHandler: baseHandler,\n83: \t}\n84: \n85: \tgo func() {\n86: \t\tsigChan := make(chan os.Signal, 1)\n87: \t\tsignal.Notify(sigChan, syscall.SIGINT, syscall.SIGTERM)\n88: \t\t<-sigChan\n89: \t\tfmt.Println(\"\\nShutting down proxy...\")\n90: \t\tserver.Close()\n91: \t\tos.Exit(0)\n92: \t}()\n93: \n94: \tfmt.Printf(\"Starting proxy on %s:%d\\n\", proxyListenAddr, proxyListenPort)\n95: \n96: \tvar err error\n97: \tif proxyTLS && proxyTLSCert != \"\" && proxyTLSKey != \"\" {\n98: \t\terr = server.ListenAndServeTLS(proxyTLSCert, proxyTLSKey)\n99: \t} else {\n100: \t\terr = server.ListenAndServe()\n101: \t}\n102: \n103: \treturn err\n104: }\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\n\t\"github.com/spf13/cobra\"\n)\n\nvar (\n\tproxyResourceType string\n\tproxyResourceName string\n\tproxyAPIServer    bool\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/agentcube-proxy/proxy.go","time":{"start":1775864981584,"end":1775864981610}}}}
