: bool = False,\n266:         kubeconfig: Optional[str] = None,\n267:     ) -> None: ...\n268:     def _ensure_namespace(self) -> None: ...\n269:     def deploy_agent(\n270:         self,\n271:         agent_name: str,\n272:         image_url: str,\n273:         port: int,\n274:         entrypoint: Optional[str] = None,\n275:         replicas: int = 1,\n276:         node_port: Optional[int] = None,\n277:         env_vars: Optional[Dict[str, str]] = None,\n278:     ) -> Dict[str, Any]: ...\n279:     def _create_deployment(\n280:         self,\n281:         name: str,\n282:         image_url: str,\n283:         port: int,\n284:         entrypoint: Optional[str],\n285:         replicas: int,\n286:         env_vars: Optional[Dict[str, str]],\n287:     ) -> Dict[str, Any]: ...\n288:     def _create_service(self, name: str, port: int, node_port: Optional[int]) -> Dict[str, Any]: ...\n289:     def wait_for_deployment_ready(self, name: str, timeout: int = 120) -> None: ...\n290:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]: ...\n291:     def delete_agent(self, agent_name: str) -> Dict[str, Any]: ...\n292:     def _sanitize_name(self, name: str) -> str: ...\n293: ```\n294: \n295: ## `AgentCubeProvider` (`agentcube/services/agentcube_provider.py`)\n296: \n297: ```python\n298: class AgentCubeProvider:\n299:     def __init__(\n300:         self,\n301:         namespace: str = \"default\",\n302:         verbose: bool = False,\n303:         kubeconfig: Optional[str] = None,\n304:     ) -> None: ...\n305:     def _ensure_namespace(self) -> None: ...\n306:     def deploy_agent_runtime(\n307:         self,\n308:         agent_name: str,\n309:         image_url: str,\n310:         port: int,\n311:         entrypoint: Optional[str] = None,\n312:         env_vars: Optional[Dict[str, str]] = None,\n313:         workload_manager_url: Optional[str] = None,\n314:         router_url: Optional[str] = None,\n315:         readiness_probe_path: Optional[str] = None,\n316:         readiness_probe_port: Optional[int] = None,\n317:     ) -> Dict[str, Any]: ...\n318:     def _sanitize_name(self, name: str) -> str: ...\n319:     def get_agent_runtime(self, name: str, namespace: str) -> Optional[Dict[str, Any]]: ...\n320: ```\n321: \n322: CR API: `group=\"runtime.agentcube.volcano.sh\"`, `version=\"v1alpha1\"`, `plural=\"agentruntimes\"`.\n323: \n324: ## `AgentMetadata` (Pydantic `BaseModel`)\n325: \n326: | Field | Type | Default | `Field(..., description=...)` |\n327: |-------|------|---------|--------------------------------|\n328: | `agent_name` | `str` | (required) | Unique name identifying the agent |\n329: | `description` | `Optional[str]` | `None` | Human-readable summary |\n330: | `language` | `str` | `\"python\"` | Programming language used |\n331: | `entrypoint` | `str` | (required) | Command to launch the agent |\n332: | `port` | `int` | `8080` | Port exposed by the agent runtime |\n333: | `build_mode` | `str` | `\"local\"` | Build strategy: local or cloud |\n334: | `region` | `Optional[str]` | `None` | Deployment region |\n335: | `version` | `Optional[str]` | `None` | Semantic version string for publishing |\n336: | `image` | `Optional[Dict[str, Any]]` | `None` | Container image information |\n337: | `auth` | `Optional[Dict[str, Any]]` | `None` | Authentication configuration |\n338: | `requirements_file` | `Optional[str]` | `\"requirements.txt\"` | Python dependency file |\n339: | `registry_url` | `Optional[str]` | `\"\"` | Registry URL for image publishing |\n340: | `registry_username` | `Optional[str]` | `\"\"` | Registry username |\n341: | `registry_password` | `Optional[str]` | `\"\"` | Registry password |\n342: | `agent_endpoint` | `Optional[str]` | `None` | Agent endpoint URL |\n343: | `workload_manager_url` | `Optional[str]` | `None` | URL for the Workload Manager |\n344: | `router_url` | `Optional[str]` | `None` | URL for the Router |\n345: | `readiness_probe_path` | `Optional[str]` | `None` | Path for the readiness probe |\n346: | `readiness_probe_port` | `Optional[int]` | `None` | Port for the readiness probe |\n347: | `agent_id` | `Optional[str]` | `None` | Agent ID assigned by AgentCube |\n348: | `session_id` | `Optional[str]` | `None` | The session ID for the agent |\n349: | `k8s_deployment` | `Optional[Dict[str, Any]]` | `None` | Kubernetes deployment information |\n350: \n351: Validators: `validate_language` → `['python','java']` lowercase; `validate_build_mode` → `['local','cloud']` lowercase; `validate_port` → `1..65535`.\n352: \n353: ## `MetadataOptions` (`agentcube/models/pack_models.py`)\n354: \n355: Dataclass fields (all `Optional` unless noted):\n356: \n357: | Field | Type | Default |\n358: |-------|------|---------|\n359: | `agent_name` | `Optional[str]` | `None` |\n360: | `language` | `Optional[str]` | `'python'` |\n361: | `entrypoint` | `Optional[str]` | `None` |\n362: | `port` | `Optional[int]` | `8080` |\n363: | `build_mode` | `Optional[str]` | `'local'` |\n364: | `requirements_file` | `Optional[str]` | `None` |\n365: | `description` | `Optional[str]` | `None` |\n366: | `workload_manager_url` | `Optional[str]` | `\"\"` |\n367: | `router_url` | `Optional[str]` | `\"\"` |\n368: | `readiness_probe_path` | `Optional[str]` | `\"\"` |\n369: | `readiness_probe_port` | `Optional[int]` | `8080` |\n370: | `registry_url` | `Optional[str]` | `\"\"` |\n371: | `registry_username` | `Optional[str]` | `\"\"` |\n372: | `registry_password` | `Optional[str]` | `\"\"` |\n373: | `agent_endpoint` | `Optional[str]` | `\"\"` |\n374: \n375: ```python\n376: @classmethod\n377: def from_options(cls, options: Dict[str, Any]) -> \"MetadataOptions\": ...\n378: ```\n379: \n380: ## Dependencies (`cmd/cli/pyproject.toml`)\n381: \n382: **`[project]` dependencies:**\n383: \n384: - `typer[all]>=0.9.0`\n385: - `pydantic>=2.0.0`\n386: - `pyyaml>=6.0`\n387: - `httpx>=0.24.0`\n388: - `docker>=6.0.0`\n389: - `rich>=13.0.0`\n390: - `packaging>=23.0`\n391: - `importlib-resources>=6.0.0`\n392: - `semver>=3.0.0`\n393: \n394: **Optional `[project.optional-dependencies]`:**\n395: \n396: - `k8s`: `kubernetes>=28.0.0`\n397: - `dev`: `pytest>=7.4.0`, `pytest-asyncio>=0.21.0`, `pytest-cov>=4.1.0`, `ruff>=0.1.0`, `mypy>=1.5.0`, `pre-commit>=3.3.0`, `kubernetes>=28.0.0`\n398: - `test`: `pytest>=7.4.0`, `pytest-asyncio>=0.21.0`, `pytest-cov>=4.1.0`, `pytest-mock>=3.11.0`, `httpx-mock>=0.10.0`\n399: \n400: **Python:** `requires-python = \">=3.10\"`.\n401: \n402: ## Top-level exports (`agentcube/__init__.py`)\n403: \n404: - `__version__ = \"0.1.0\"`\n405: - `__author__ = \"AgentCube Community\"`\n406: - `__email__ = \"agentcube@volcano.sh\"`\n407: - Imports: `app`, `PackRuntime`, `BuildRuntime`, `PublishRuntime`, `InvokeRuntime`\n408: - `__all__` = `[\"app\", \"PackRuntime\", \"BuildRuntime\", \"PublishRuntime\", \"InvokeRuntime\"]`  \n409:   (`StatusRuntime` is not exported here.)\n410: \n411: \n412: --- cli-toolkit/spec.md ---\n413: # AgentCube CLI (cli-toolkit) Specification\n414: \n415: ## Purpose\n416: \n417: Command-line tool (`kubectl-agentcube`) for packaging, building, publishing, invoking, and checking status of AI agents against AgentCube or standard Kubernetes.\n418: \n419: ## Requirements\n420: \n421: ### Requirement: Global CLI options\n422: The system SHALL expose a Typer application named `agentcube` with global options on the root callback.\n423: \n424: #### Scenario: Version display\n425: - **GIVEN** the CLI is installed and importable\n426: - **WHEN** the user passes `--version` (eager option, `Optional[bool]`, default `None`)\n427: - **THEN** the CLI SHALL print `AgentCube CLI (kubectl agentcube) version: {__version__}` (Rich markup) and exit without running a subcommand (`typer.Exit()`), where `__version__` is `0.1.0` from `agentcube.__init__`\n428: \n429: #### Scenario: Global verbose logging\n430: - **GIVEN** the user passes `--verbose` / `-v` (`bool`, default `False`) on the root callback\n431: - **WHEN** the callback runs\n432: - **THEN** the system SHALL call `logging.basicConfig(level=logging.DEBUG)`\n433: \n434: ### Requirement: `pack` command\n435: The system SHALL provide `pack` to validate and prepare a workspace, merge CLI overrides into metadata, optionally generate a `Dockerfile`, and report paths.\n436: \n437: #### Scenario: Options and defaults\n438: - **GIVEN** the user runs `pack`\n439: - **WHEN** options are omitted\n440: - **THEN** the CLI SHALL use: `workspace` = `\".\"` (`-f` / `--workspace`, `str`); `agent_name` = `None` (`--agent-name`, `Optional[str]`); `language` = `None` (`--language`); `entrypoint` = `None` (`--entrypoint`); `port` = `None` (`--port`, `Optional[int]`); `build_mode` = `None` (`--build-mode`); `description` = `None` (`--description`); `output` = `None` (`--output`); `verbose` = `False` (`--verbose`, command-local)\n441: \n442: #### Scenario: Successful pack\n443: - **GIVEN** a valid workspace path\n444: - **WHEN** `pack` completes without exception\n445: - **THEN** the CLI SHALL print success with `agent_name`, resolved `workspace_path`, and `metadata_path` (reported as `{final_workspace}/agent_metadata.yaml`), using a Rich `Progress` spinner during work\n446: \n447: #### Scenario: Pack failure handling\n448: - **GIVEN** `PackRuntime.pack` raises\n449: - **WHEN** `verbose` is `True`\n450: - **THEN** the CLI SHALL print `Error packaging agent: {e}` in red, print a full traceback, and exit with code `1`\n451: \n452: ### Requirement: `build` command\n453: The system SHALL build a container image from a packaged workspace using local Docker when `build_mode` is `local` (default in metadata), with optional proxy and tag derived from metadata version.\n454: \n455: #### Scenario: Options and defaults\n456: - **GIVEN** the user runs `build`\n457: - **WHEN** options are omitted\n458: - **THEN** defaults SHALL be: `workspace` = `\".\"` (`-f` / `--workspace`); `proxy` = `None` (`-p` / `--proxy`); `cloud_provider` = `None` (`--cloud-provider`); `output` = `None` (`--output`); `verbose` = `False` (`--verbose`)\n459: \n460: #### Scenario: Local Docker build prerequisites\n461: - **GIVEN** `build_mode` resolves to `local`\n462: - **WHEN** Docker is unavailable\n463: - **THEN** `BuildRuntime` SHALL raise `RuntimeError(\"Docker is not available or not running\")` surfaced via CLI error handling\n464: \n465: #### Scenario: Version increment on build\n466: - **GIVEN** a successful local build path\n467: - **WHEN** `BuildRuntime.build` runs\n468: - **THEN** the system SHALL increment `metadata.version` (patch bump for `X.Y.Z`, or append `.1` / fallback `{version}-1`) before build and revert the version in metadata if build fails\n469: \n470: ### Requirement: `publish` command\n471: The system SHALL publish/deploy using provider `agentcube` (AgentRuntime CR) or `k8s` (Deployment + NodePort Service), preparing the image via Docker push or explicit image URL as implemented in `PublishRuntime`.\n472: \n473: #### Scenario: Options and defaults\n474: - **GIVEN** the user runs `publish`\n475: - **THEN** defaults SHALL include: `workspace` = `\".\"`; `version` = `None` (`--version`); `image_url` = `None` (`--image-url`); `image_username` = `None` (`--image-username`); `image_password` = `None` (`--image-password`); `description` = `None`; `region` = `None` (`--region`); `cloud_provider` = `None`; `provider` = `\"agentcube\"` (`--provider`); `node_port` = `None` (`--node-port`, `Optional[int]`); `replicas` = `None` (`--replicas`); `namespace` = `None` (`--namespace`); `verbose` = `False`\n476: \n477: #### Scenario: AgentCube provider prerequisites\n478: - **GIVEN** `provider` is `agentcube`\n479: - **WHEN** metadata lacks `router_url` or `workload_manager_url`\n480: - **THEN** the system SHALL raise `ValueError` with message requiring both fields in `agent_metadata.yaml`\n481: \n482: #### Scenario: Standard Kubernetes publish flow\n483: - **GIVEN** `provider` is `k8s` and Kubernetes client initializes\n484: - **WHEN** publish proceeds\n485: - **THEN** the system SHALL call `KubernetesProvider.deploy_agent`, then `wait_for_deployment_ready(..., timeout=120)`, updating metadata with deployment info; on readiness failure it SHALL raise `RuntimeError` after recording error in metadata\n486: \n487: ### Requirement: `invoke` command\n488: The system SHALL POST JSON to the published agent endpoint, parse `--payload` as JSON, merge optional `--header` entries, and for AgentRuntime CR deployments rewrite the URL to `{base}/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/` when `k8s_deployment.type == \"AgentRuntime\"`.\n489: \n490: #### Scenario: Options and defaults\n491: - **GIVEN** the user runs `invoke`\n492: - **THEN** defaults SHALL be: `workspace` = `\".\"`; `payload` = `\"{}\"` (`--payload`, `str`); `header_list` = `None` (`--header`, repeatable `List[str]`); `provider` = `\"agentcube\"`; `verbose` = `False`\n493: \n494: #### Scenario: Invalid payload\n495: - **GIVEN** `payload` is not valid JSON\n496: - **WHEN** the command parses it\n497: - **THEN** the CLI SHALL print invalid JSON in red and exit with code `1` (before `_handle_error`)\n498: \n499: #### Scenario: Invalid header format\n500: - **GIVEN** a header string without a single `:` separator\n501: - **WHEN** headers are parsed\n502: - **THEN** the CLI SHALL print expected `key:value` format and exit with code `1`\n503: \n504: #### Scenario: Session header on invoke\n505: - **GIVEN** metadata contains `session_id`\n506: - **WHEN** `InvokeRuntime.invoke` runs\n507: - **THEN** the HTTP client SHALL add header `X-Agentcube-Session-Id` (same spelling as response handling) to the request\n508: \n509: ### Requirement: `status` command\n510: The system SHALL load workspace metadata and display agent status in a Rich `Table`, exiting with code `1` when status is `not_published` or `error`.\n511: \n512: #### Scenario: Options and defaults\n513: - **GIVEN** the user runs `status`\n514: - **THEN** defaults SHALL be: `workspace` = `\".\"`; `provider` = `\"agentcube\"`; `verbose` = `False`\n515: \n516: #### Scenario: Not published\n517: - **GIVEN** metadata has no `agent_id`\n518: - **WHEN** `get_status` returns `status == \"not_published\"`\n519: - **THEN** the CLI SHALL print guidance to publish first and exit with code `1`\n520: \n521: ### Requirement: Workspace validation (pack path)\n522: The system SHALL validate that the workspace path exists and is a directory; for Python, require at least one `*.py` file; for Java, require `pom.xml`.\n523: \n524: #### Scenario: Missing workspace\n525: - **GIVEN** `workspace_path` does not exist\n526: - **WHEN** `PackRuntime._validate_workspace_structure` runs\n527: - **THEN** the system SHALL raise `ValueError` with a message that the directory does not exist\n528: \n529: #### Scenario: Python workspace without Python files\n530: - **GIVEN** `metadata.language == \"python\"`\n531: - **WHEN** no `*.py` exists in the workspace root\n532: - **THEN** the system SHALL raise `ValueError(\"No Python files found in workspace\")`\n533: \n534: ### Requirement: Metadata file format\n535: The system SHALL persist agent configuration as YAML. The primary filename SHALL be `agent_metadata.yaml`; loading SHALL fall back to `agent.yaml` then `metadata.yaml` if the primary file is missing.\n536: \n537: #### Scenario: Save location\n538: - **GIVEN** metadata is saved\n539: - **WHEN** `MetadataService.save_metadata` runs\n540: - **THEN** the file SHALL be written to `{workspace}/agent_metadata.yaml` using `yaml.dump` with `default_flow_style=False`, `indent=2`, `sort_keys=False`, excluding `None` fields via `model_dump(exclude_none=True)`\n541: \n542: #### Scenario: Schema validation\n543: - **GIVEN** YAML is loaded\n544: - **WHEN** fields violate `AgentMetadata` validators\n545: - **THEN** Pydantic SHALL reject unsupported `language` / `build_mode` or invalid `port` range\n546: \n547: ### Requirement: Docker integration\n548: The system SHALL use the Docker SDK (`docker.from_env()`) to build images, push to a registry when configured, and optionally remove images.\n549: \n550: #### Scenario: Build image\n551: - **GIVEN** Docker is running\n552: - **WHEN** `DockerService.build_image` is called\n553: - **THEN** it SHALL tag `{image_name}:{tag}`, pass optional `buildargs` from proxy settings, and return `image_name`, `image_id`, `image_size`, `build_time`\n554: \n555: #### Scenario: Push image\n556: - **GIVEN** a local image name and optional `registry_url` / credentials\n557: - **WHEN** `DockerService.push_image` runs\n558: - **THEN** it SHALL login if username and password are provided, retag when needed, stream push logs, and return `pushed_image` and `push_time`\n559: \n560: #### Scenario: Remove image\n561: - **GIVEN** `DockerService.remove_image(image_name)` is called\n562: - **WHEN** removal succeeds\n563: - **THEN** it SHALL return `True`; on failure it SHALL log a warning and return `False`\n564: \n565: ### Requirement: Kubernetes — standard provider\n566: The system SHALL create or patch `Deployment` and `NodePort` `Service`, wait for rollout, report pod status, and support deletion.\n567: \n568: #### Scenario: Deploy agent\n569: - **GIVEN** `KubernetesProvider.deploy_agent` is called\n570: - **WHEN** resources are applied\n571: - **THEN** the result SHALL include `deployment_name`, `service_name`, `namespace`, `replicas`, `container_port`, `node_port`, `service_url` as `http://localhost:{node_port}`\n572: \n573: #### Scenario: Wait for ready\n574: - **GIVEN** a deployment name\n575: - **WHEN** `wait_for_deployment_ready` exceeds `timeout` seconds (default `120`)\n576: - **THEN** it SHALL raise `TimeoutError`\n577: \n578: #### Scenario: Delete agent\n579: - **GIVEN** `delete_agent` is called\n580: - **WHEN** deletion completes\n581: - **THEN** it SHALL return `{\"status\": \"deleted\", \"deployment_name\", \"namespace\"}` ignoring 404 on individual deletes\n582: \n583: ### Requirement: Kubernetes — AgentCube AgentRuntime CR\n584: The system SHALL create or patch an `AgentRuntime` custom object in group `runtime.agentcube.volcano.sh`, version `v1alpha1`, plural `agentruntimes`.\n585: \n586: #### Scenario: Deploy CR\n587: - **GIVEN** required readiness probe fields exist in metadata\n588: - **WHEN** `AgentCubeProvider.deploy_agent_runtime` runs\n589: - **THEN** it SHALL embed `WORKLOAD_MANAGER_URL` / `ROUTER_URL` from parameters or environment when missing in `env_vars`, set `sessionTimeout` to `\"15m\"` and `maxSessionDuration` to `\"8h\"`, and reference `imagePullSecrets` `[{\"name\": \"default-secret\"}]`\n590: \n591: ### Requirement: AgentCube provider integration (CLI)\n592: The system SHALL use `AgentCubeProvider` for `provider=agentcube` publish/status flows and `KubernetesProvider` for `provider=k8s`.\n593: \n594: #### Scenario: Status for AgentRuntime\n595: - **GIVEN** `provider` is `agentcube` and the CR exists\n596: - **WHEN** `StatusRuntime._get_cr_k8s_status` runs\n597: - **THEN** status SHALL be read from `cr_object[\"status\"]` when present (`status`, `agentEndpoint`), else `created_no_status`, else `not_found_in_k8s`\n598: \n599: ### Requirement: Error handling patterns\n600: The system SHALL use `_handle_error(e, command_name, verbose)` for subcommand exceptions: print `Error {command_name}: {e}` in red; if `verbose`, print traceback; raise `typer.Exit(1)`.\n601: \n602: #### Scenario: Subcommand verbose vs global verbose\n603: - **GIVEN** a subcommand’s local `--verbose` is `True` but global `-v` was not passed\n604: - **WHEN** an error occurs in that subcommand\n605: - **THEN** traceback SHALL still be printed because `_handle_error` receives the subcommand’s `verbose` flag\n606: \n607: ---\n608: \n609: **Note:** The implementation uses `agent_metadata.yaml` as the canonical metadata filename (with `agent.yaml` / `metadata.yaml` fallbacks for load). Documentation that refers to `agentcube.yaml` SHALL be treated as naming drift unless a separate file is introduced in code.\n610: \n611: \n612: --- deployment/client-go.md ---\n613: # client-go library\n614: \n615: Generated Kubernetes client code for API group **`runtime.agentcube.volcano.sh` / `v1alpha1`**, module path **`github.com/volcano-sh/agentcube/client-go`**. Source reference: `/tmp/agentcube-ref/client-go/`.\n616: \n617: ## Clientset\n618: \n619: ### `Interface` (`clientset/versioned/clientset.go`)\n620: \n621: ```go\n622: type Interface interface {\n623: \tDiscovery() discovery.DiscoveryInterface\n624: \tRuntimeV1alpha1() runtimev1alpha1.RuntimeV1alpha1Interface\n625: }\n626: ```\n627: \n628: ### `Clientset` struct\n629: \n630: Embeds `*discovery.DiscoveryClient` and holds `runtimeV1alpha1 *runtimev1alpha1.RuntimeV1alpha1Client`.\n631: \n632: **Constructors**\n633: \n634: - `NewForConfig(c *rest.Config) (*Clientset, error)`\n635: - `NewForConfigAndClient(c *rest.Config, httpClient *http.Client) (*Clientset, error)`\n636: - `NewForConfigOrDie(c *rest.Config) *Clientset`\n637: - `New(c rest.Interface) *Clientset`\n638: \n639: **Group accessor:** `RuntimeV1alpha1() runtimev1alpha1.RuntimeV1alpha1Interface`\n640: \n641: ---\n642: \n643: ## Typed client — `runtime/v1alpha1`\n644: \n645: ### `RuntimeV1alpha1Interface` (`clientset/versioned/typed/runtime/v1alpha1/runtime_client.go`)\n646: \n647: ```go\n648: type RuntimeV1alpha1Interface interface {\n649: \tRESTClient() rest.Interface\n650: \tAgentRuntimesGetter\n651: \tCodeInterpretersGetter\n652: }\n653: ```\n654: \n655: `RuntimeV1alpha1Client` implements this interface. REST defaults: `GroupVersion` = `pkg/apis/runtime/v1alpha1`.SchemeGroupVersion, `APIPath` = `/apis`, negotiated serializer from `clientset/versioned/scheme`.\n656: \n657: ### `AgentRuntimesGetter` / `AgentRuntimeInterface` (`.../agentruntime.go`)\n658: \n659: ```go\n660: type AgentRuntimesGetter interface {\n661: \tAgentRuntimes(namespace string) AgentRuntimeInterface\n662: }\n663: \n664: type AgentRuntimeInterface interface {\n665: \tCreate(ctx context.Context, agentRuntime *runtimev1alpha1.AgentRuntime, opts metav1.CreateOptions) (*runtimev1alpha1.AgentRuntime, error)\n666: \tUpdate(ctx context.Context, agentRuntime *runtimev1alpha1.AgentRuntime, opts metav1.UpdateOptions) (*runtimev1alpha1.AgentRuntime, error)\n667: \tUpdateStatus(ctx context.Context, agentRuntime *runtimev1alpha1.AgentRuntime, opts metav1.UpdateOptions) (*runtimev1alpha1.AgentRuntime, error)\n668: \tDelete(ctx context.Context, name string, opts metav1.DeleteOptions) error\n669: \tDeleteCollection(ctx context.Context, opts metav1.DeleteOptions, listOpts metav1.ListOptions) error\n670: \tGet(ctx context.Context, name string, opts metav1.GetOptions) (*runtimev1alpha1.AgentRuntime, error)\n671: \tList(ctx context.Context, opts metav1.ListOptions) (*runtimev1alpha1.AgentRuntimeList, error)\n672: \tWatch(ctx context.Context, opts metav1.ListOptions) (watch.Interface, error)\n673: \tPatch(ctx context.Context, name string, pt types.PatchType, data []byte, opts metav1.PatchOptions, subresources ...string) (*runtimev1alpha1.AgentRuntime, error)\n674: \tAgentRuntimeExpansion\n675: }\n676: ```\n677: \n678: REST resource plural: **`agentruntimes`**.\n679: \n680: ### `CodeInterpretersGetter` / `CodeInterpreterInterface` (`.../codeinterpreter.go`)\n681: \n682: Same method shape as `AgentRuntimeInterface`, types `*runtimev1alpha1.CodeInterpreter` / `CodeInterpreterList`. REST resource plural: **`codeinterpreters`**.\n683: \n684: ### Expansion hooks (`generated_expansion.go`)\n685: \n686: ```go\n687: type AgentRuntimeExpansion interface{}\n688: type CodeInterpreterExpansion interface{}\n689: ```\n690: \n691: (Empty — reserved for custom methods.)\n692: \n693: ### Fake clients (`typed/runtime/v1alpha1/fake/`)\n694: \n695: `fake_runtime_client.go`, `fake_agentruntime.go`, `fake_codeinterpreter.go` — test doubles implementing the typed interfaces; `doc.go` markers.\n696: \n697: ---\n698: \n699: ## Scheme (`clientset/versioned/scheme/`)\n700: \n701: | File | Role |\n702: |------|------|\n703: | `register.go` | Builds `Scheme`, `Codecs`, `ParameterCodec`; `AddToScheme` registers `runtime/v1alpha1` types |\n704: | `doc.go` | Package doc |\n705: \n706: ---\n707: \n708: ## Informer factory\n709: \n710: ### `SharedInformerFactory` (`informers/externalversions/factory.go`)\n711: \n712: ```go\n713: type SharedInformerFactory interface {\n714: \tinternalinterfaces.SharedInformerFactory\n715: \tStart(stopCh <-chan struct{})\n716: \tShutdown()\n717: \tWaitForCacheSync(stopCh <-chan struct{}) map[reflect.Type]bool\n718: \tForResource(resource schema.GroupVersionResource) (GenericInformer, error)\n719: \tInformerFor(obj runtime.Object, newFunc internalinterfaces.NewInformerFunc) cache.SharedIndexInformer\n720: \tRuntime() externalversionsruntime.Interface\n721: }\n722: ```\n723: \n724: **Constructors / options**\n725: \n726: - `NewSharedInformerFactory(client versioned.Interface, defaultResync time.Duration)`\n727: - `NewSharedInformerFactoryWithOptions(client, defaultResync, options ...SharedInformerOption)`\n728: - `NewFilteredSharedInformerFactory` (deprecated alias to WithOptions)\n729: - Options: `WithCustomResyncConfig`, `WithTweakListOptions`, `WithNamespace`, `WithTransform`\n730: \n731: ### Group interface (`informers/externalversions/runtime/interface.go`)\n732: \n733: ```go\n734: type Interface interface {\n735: \tV1alpha1() v1alpha1.Interface\n736: }\n737: ```\n738: \n739: `New(factory, namespace, tweakListOptions)` returns group accessor.\n740: \n741: ### Version interface (`informers/externalversions/runtime/v1alpha1/interface.go`)\n742: \n743: ```go\n744: type Interface interface {\n745: \tAgentRuntimes() AgentRuntimeInformer\n746: \tCodeInterpreters() CodeInterpreterInformer\n747: }\n748: ```\n749: \n750: ### Per-type informers (`.../runtime/v1alpha1/agentruntime.go`, `codeinterpreter.go`)\n751: \n752: Example (`AgentRuntimeInformer`):\n753: \n754: ```go\n755: type AgentRuntimeInformer interface {\n756: \tInformer() cache.SharedIndexInformer\n757: \tLister() runtimev1alpha1.AgentRuntimeLister\n758: }\n759: ```\n760: \n761: Also provides `NewAgentRuntimeInformer`, `NewFilteredAgentRuntimeInformer`, and analogous constructors for CodeInterpreter.\n762: \n763: ### Generic resource routing (`informers/externalversions/generic.go`)\n764: \n765: `ForResource` switches on:\n766: \n767: - `v1alpha1.SchemeGroupVersion.WithResource(\"agentruntimes\")` → `f.Runtime().V1alpha1().AgentRuntimes().Informer()`\n768: - `...WithResource(\"codeinterpreters\")` → `...CodeInterpreters().Informer()`\n769: \n770: ### `internalinterfaces` (`informers/externalversions/internalinterfaces/factory_interfaces.go`)\n771: \n772: ```go\n773: type NewInformerFunc func(versioned.Interface, time.Duration) cache.SharedIndexInformer\n774: type SharedInformerFactory interface {\n775: \tStart(stopCh <-chan struct{})\n776: \tInformerFor(obj runtime.Object, newFunc NewInformerFunc) cache.SharedIndexInformer\n777: }\n778: type TweakListOptionsFunc func(*metav1.ListOptions)\n779: ```\n780: \n781: ---\n782: \n783: ## Listers (`listers/runtime/v1alpha1/`)\n784: \n785: ### `AgentRuntimeLister` / `AgentRuntimeNamespaceLister` (`agentruntime.go`)\n786: \n787: ```go\n788: type AgentRuntimeLister interface {\n789: \tList(selector labels.Selector) ([]*runtimev1alpha1.AgentRuntime, error)\n790: \tAgentRuntimes(namespace string) AgentRuntimeNamespaceLister\n791: \tAgentRuntimeListerExpansion\n792: }\n793: \n794: type AgentRuntimeNamespaceLister interface {\n795: \tList(selector labels.Selector) ([]*runtimev1alpha1.AgentRuntime, error)\n796: \tGet(name string) (*runtimev1alpha1.AgentRuntime, error)\n797: \tAgentRuntimeNamespaceListerExpansion\n798: }\n799: ```\n800: \n801: `NewAgentRuntimeLister` uses `runtimev1alpha1.Resource(\"agentruntime\").GroupResource()`.\n802: \n803: ### `CodeInterpreterLister` / `CodeInterpreterNamespaceLister` (`codeinterpreter.go`)\n804: \n805: Same pattern for `CodeInterpreter`; `NewCodeInterpreterLister` uses `Resource(\"codeinterpreter\").GroupResource()`.\n806: \n807: ### Expansion (`expansion_generated.go`)\n808: \n809: Empty expansion interfaces for listers and namespace listers (all four types).\n810: \n811: ---\n812: \n813: ## Fake clientset (`clientset/versioned/fake/`)\n814: \n815: | File | Role |\n816: |------|------|\n817: | `clientset_generated.go` | `NewSimpleClientset`, `NewClientset` — in-memory fake `Clientset` |\n818: | `register.go` | Scheme registration for fakes |\n819: | `doc.go` | Package doc |\n820: \n821: ---\n822: \n823: ## File index (all paths under `client-go/`)\n824: \n825: | Path | Role |\n826: |------|------|\n827: | `clientset/versioned/clientset.go` | `Clientset`, `Interface`, constructors |\n828: | `clientset/versioned/scheme/register.go` | Scheme / codecs for generated client |\n829: | `clientset/versioned/scheme/doc.go` | Doc |\n830: | `clientset/versioned/fake/clientset_generated.go` | Fake clientset implementation |\n831: | `clientset/versioned/fake/register.go` | Fake scheme wiring |\n832: | `clientset/versioned/fake/doc.go` | Doc |\n833: | `clientset/versioned/typed/runtime/v1alpha1/runtime_client.go` | `RuntimeV1alpha1Client`, `RuntimeV1alpha1Interface` |\n834: | `clientset/versioned/typed/runtime/v1alpha1/agentruntime.go` | `AgentRuntimeInterface`, typed REST client |\n835: | `clientset/versioned/typed/runtime/v1alpha1/codeinterpreter.go` | `CodeInterpreterInterface`, typed REST client |\n836: | `clientset/versioned/typed/runtime/v1alpha1/generated_expansion.go` | Expansion interfaces |\n837: | `clientset/versioned/typed/runtime/v1alpha1/doc.go` | Doc |\n838: | `clientset/versioned/typed/runtime/v1alpha1/fake/fake_runtime_client.go` | Fake runtime group client |\n839: | `clientset/versioned/typed/runtime/v1alpha1/fake/fake_agentruntime.go` | Fake AgentRuntime client |\n840: | `clientset/versioned/typed/runtime/v1alpha1/fake/fake_codeinterpreter.go` | Fake CodeInterpreter client |\n841: | `clientset/versioned/typed/runtime/v1alpha1/fake/doc.go` | Doc |\n842: | `informers/externalversions/factory.go` | `SharedInformerFactory`, options, `Start`/`Shutdown`/`WaitForCacheSync` |\n843: | `informers/externalversions/generic.go` | `GenericInformer`, `ForResource` |\n844: | `informers/externalversions/runtime/interface.go` | Group `runtime` informer accessor |\n845: | `informers/externalversions/runtime/v1alpha1/interface.go` | `v1alpha1` informer accessors |\n846: | `informers/externalversions/runtime/v1alpha1/agentruntime.go` | AgentRuntime informer + constructor |\n847: | `informers/externalversions/runtime/v1alpha1/codeinterpreter.go` | CodeInterpreter informer + constructor |\n848: | `informers/externalversions/internalinterfaces/factory_interfaces.go` | Small factory interface + `NewInformerFunc`, `TweakListOptionsFunc` |\n849: | `listers/runtime/v1alpha1/agentruntime.go` | `AgentRuntimeLister`, namespace lister |\n850: | `listers/runtime/v1alpha1/codeinterpreter.go` | `CodeInterpreterLister`, namespace lister |\n851: | `listers/runtime/v1alpha1/expansion_generated.go` | Lister expansion interfaces |\n852: \n853: **Regeneration:** `make gen-client` → `hack/update-codegen.sh` (`k8s.io/code-generator` v0.34.1, `--with-watch`, output package `github.com/volcano-sh/agentcube/client-go`).\n854: \n855: \n856: --- python-sdk/design.md ---\n857: # AgentCube Python SDK — Design\n858: \n859: Source root: `/tmp/agentcube-ref/sdk-python/`.\n860: \n861: ## Package layout\n862: \n863: | Path | Role |\n864: |------|------|\n865: | `pyproject.toml` | Package `agentcube-sdk`, dependencies |\n866: | `agentcube/__init__.py` | Public exports |\n867: | `agentcube/code_interpreter.py` | `CodeInterpreterClient` |\n868: | `agentcube/agent_runtime.py` | `AgentRuntimeClient` |\n869: | `agentcube/exceptions.py` | Exception classes |\n870: | `agentcube/clients/__init__.py` | Re-exports client classes |\n871: | `agentcube/clients/control_plane.py` | `ControlPlaneClient` |\n872: | `agentcube/clients/code_interpreter_data_plane.py` | `CodeInterpreterDataPlaneClient` |\n873: | `agentcube/clients/agent_runtime_data_plane.py` | `AgentRuntimeDataPlaneClient` |\n874: | `agentcube/utils/http.py` | `create_session` |\n875: | `agentcube/utils/utils.py` | `read_token_from_file` |\n876: | `agentcube/utils/log.py` | `get_logger` |\n877: | `agentcube/utils/__init__.py` | Empty (module marker) |\n878: | `examples/basic_usage.py`, `examples/agent_runtime_usage.py`, `scripts/e2e_picod_test.py`, `tests/*.py` | Non-library artifacts |\n879: \n880: ## Public exports (`agentcube/__init__.py`)\n881: \n882: ```python\n883: from .code_interpreter import CodeInterpreterClient\n884: from .agent_runtime import AgentRuntimeClient\n885: \n886: __all__ = [\"CodeInterpreterClient\", \"AgentRuntimeClient\"]\n887: ```\n888: \n889: `agentcube/clients/__init__.py` additionally exports (not in root `__all__`):\n890: \n891: ```python\n892: __all__ = [\n893:     \"ControlPlaneClient\",\n894:     \"CodeInterpreterDataPlaneClient\",\n895:     \"AgentRuntimeDataPlaneClient\",\n896: ]\n897: ```\n898: \n899: ## Configuration (no single `Configuration` class)\n900: \n901: There is **no** dedicated configuration dataclass. Defaults and environment resolution are distributed across:\n902: \n903: | Component | Resolved settings |\n904: |-----------|-------------------|\n905: | `ControlPlaneClient` | `base_url` ← `workload_manager_url` or `WORKLOAD_MANAGER_URL`; `Authorization` ← `auth_token` or SA token file; `timeout=120`, `connect_timeout=5.0`, `pool_connections=10`, `pool_maxsize=10` |\n906: | `CodeInterpreterClient` | `router_url` ← arg or `ROUTER_URL` (required); `workload_manager_url` / `auth_token` passed to `ControlPlaneClient`; `name`, `namespace`, `ttl`, `verbose`, `session_id` |\n907: | `CodeInterpreterDataPlaneClient` | `timeout=120`, `connect_timeout=5.0`, `pool_connections=10`, `pool_maxsize=10`; `base_url` from `base_url` **or** `router_url`+`namespace`+`cr_name` |\n908: | `AgentRuntimeClient` | `router_url` ← arg or `ROUTER_URL`; `timeout=120`, `connect_timeout=5.0` passed to data plane |\n909: | `AgentRuntimeDataPlaneClient` | same timeout defaults as above |\n910: \n911: ## `CodeInterpreterClient` (`agentcube/code_interpreter.py`)\n912: \n913: ```python\n914: class CodeInterpreterClient:\n915:     def __init__(\n916:         self,\n917:         name: str = \"my-interpreter\",\n918:         namespace: str = \"default\",\n919:         ttl: int = 3600,\n920:         workload_manager_url: Optional[str] = None,\n921:         router_url: Optional[str] = None,\n922:         auth_token: Optional[str] = None,\n923:         verbose: bool = False,\n924:         session_id: Optional[str] = None,\n925:     ): ...\n926: \n927:     def _init_data_plane(self) -> None: ...\n928: \n929:     def __enter__(self): ...\n930:     def __exit__(self, exc_type, exc_val, exc_tb) -> None: ...\n931: \n932:     def stop(self) -> None: ...\n933: \n934:     def execute_command(self, command: str, timeout: Optional[float] = None) -> str: ...\n935:     def run_code(self, language: str, code: str, timeout: Optional[float] = None) -> str: ...\n936:     def write_file(self, content: str, remote_path: str) -> None: ...\n937:     def upload_file(self, local_path: str, remote_path: str) -> None: ...\n938:     def download_file(self, remote_path: str, local_path: str) -> None: ...\n939:     def list_files(self, path: str = \".\"): ...\n940: ```\n941: \n942: **Fields set on instance:** `name`, `namespace`, `ttl`, `verbose`, `logger`, `cp_client`, `router_url`, `session_id`, `dp_client`.\n943: \n944: ## `AgentRuntimeClient` (`agentcube/agent_runtime.py`)\n945: \n946: ```python\n947: class AgentRuntimeClient:\n948:     def __init__(\n949:         self,\n950:         agent_name: str,\n951:         namespace: str = \"default\",\n952:         router_url: Optional[str] = None,\n953:         verbose: bool = False,\n954:         session_id: Optional[str] = None,\n955:         timeout: int = 120,\n956:         connect_timeout: float = 5.0,\n957:     ): ...\n958: \n959:     def __enter__(self): ...\n960:     def __exit__(self, exc_type, exc_val, exc_tb) -> None: ...\n961: \n962:     def invoke(self, payload: Dict[str, Any], timeout: Optional[float] = None) -> Any: ...\n963: \n964:     def close(self) -> None: ...\n965: ```\n966: \n967: **Fields:** `agent_name`, `namespace`, `timeout`, `connect_timeout`, `logger`, `router_url`, `session_id`, `dp_client`.\n968: \n969: ## `ControlPlaneClient` (`agentcube/clients/control_plane.py`)\n970: \n971: ```python\n972: class ControlPlaneClient:\n973:     def __init__(\n974:         self,\n975:         workload_manager_url: Optional[str] = None,\n976:         auth_token: Optional[str] = None,\n977:         timeout: int = 120,\n978:         connect_timeout: float = 5.0,\n979:         pool_connections: int = 10,\n980:         pool_maxsize: int = 10,\n981:     ): ...\n982: \n983:     def create_session(\n984:         self,\n985:         name: str = \"my-interpreter\",\n986:         namespace: str = \"default\",\n987:         metadata: Optional[Dict[str, Any]] = None,\n988:         ttl: int = 3600,\n989:     ) -> str: ...\n990: \n991:     def delete_session(self, session_id: str) -> bool: ...\n992: \n993:     def close(self) -> None: ...\n994: ```\n995: \n996: ### Control plane — HTTP\n997: \n998: | Method | Path | Notes |\n999: |--------|------|-------|\n1000: | `POST` | `{base_url}/v1/code-interpreter` | JSON body: `name`, `namespace`, `ttl`, `metadata` |\n1001: | `DELETE` | `{base_url}/v1/code-interpreter/sessions/{session_id}` | 404 treated as success in `delete_session` |\n1002: \n1003: **Headers (default on `self.session`):**\n1004: \n1005: - `Content-Type`: `application/json`\n1006: - `Authorization`: `Bearer {token}` if token non-empty\n1007: \n1008: **Timeout:** `(connect_timeout, timeout)` on each request.\n1009: \n1010: ## `CodeInterpreterDataPlaneClient` (`agentcube/clients/code_interpreter_data_plane.py`)\n1011: \n1012: ```python\n1013: class CodeInterpreterDataPlaneClient:\n1014:     def __init__(\n1015:         self,\n1016:         session_id: str,\n1017:         router_url: Optional[str] = None,\n1018:         namespace: Optional[str] = None,\n1019:         cr_name: Optional[str] = None,\n1020:         base_url: Optional[str] = None,\n1021:         timeout: int = 120,\n1022:         connect_timeout: float = 5.0,\n1023:         pool_connections: int = 10,\n1024:         pool_maxsize: int = 10,\n1025:     ): ...\n1026: \n1027:     def _request(self, method: str, endpoint: str, body: Optional[bytes] = None, **kwargs) -> requests.Response: ...\n1028: \n1029:     def execute_command(self, command: Union[str, List[str]], timeout: Optional[float] = None) -> str: ...\n1030:     def run_code(self, language: str, code: str, timeout: Optional[float] = None) -> str: ...\n1031:     def write_file(self, content: str, remote_path: str) -> None: ...\n1032:     def upload_file(self, local_path: str, remote_path: str) -> None: ...\n1033:     def download_file(self, remote_path: str, local_path: str) -> None: ...\n1034:     def list_files(self, path: str = \".\") -> Any: ...\n1035:     def close(self) -> None: ...\n1036: ```\n1037: \n1038: ### Data plane (Code Interpreter) — base URL\n1039: \n1040: If `base_url` is not provided:\n1041: \n1042: ```text\n1043: base_path = \"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\"\n1044: self.base_url = urljoin(router_url, base_path)\n1045: ```\n1046: \n1047: ### Data plane — HTTP (relative to `self.base_url`)\n1048: \n1049: | Method | Relative path | Body / params |\n1050: |--------|---------------|---------------|\n1051: | `POST` | `api/execute` | JSON `{\"command\": [...], \"timeout\": \"<n>s\"}` |\n1052: | `POST` | `api/files` | JSON `{\"path\", \"content\" (base64), \"mode\": \"0644\"}` |\n1053: | `POST` | `api/files` (multipart) | `files={'file': ...}`, `data={'path', 'mode'}` |\n1054: | `GET` | `api/files/{clean_path}` | `stream=True` for download (`clean_path = remote_path.lstrip(\"/\")`) |\n1055: | `GET` | `api/files` | query `path` |\n1056: \n1057: **Headers:**\n1058: \n1059: - Default session header: `x-agentcube-session-id: {session_id}`\n1060: - JSON requests: `Content-Type: application/json` when `body` is set in `_request`\n1061: - Multipart upload: `x-agentcube-session-id` only (no JSON Content-Type on the outer request)\n1062: \n1063: **Note:** Docstring states Router handles JWT; SDK does not set `Authorization` on data plane.\n1064: \n1065: ## `AgentRuntimeDataPlaneClient` (`agentcube/clients/agent_runtime_data_plane.py`)\n1066: \n1067: ```python\n1068: class AgentRuntimeDataPlaneClient:\n1069:     SESSION_HEADER = \"x-agentcube-session-id\"\n1070: \n1071:     def __init__(\n1072:         self,\n1073:         router_url: str,\n1074:         namespace: str,\n1075:         agent_name: str,\n1076:         timeout: int = 120,\n1077:         connect_timeout: float = 5.0,\n1078:         pool_connections: int = 10,\n1079:         pool_maxsize: int = 10,\n1080:     ): ...\n1081: \n1082:     def bootstrap_session_id(self) -> str: ...\n1083: \n1084:     def invoke(\n1085:         self,\n1086:         session_id: str,\n1087:         payload: Dict[str, Any],\n1088:         timeout: Optional[float] = None,\n1089:     ) -> requests.Response: ...\n1090: \n1091:     def close(self) -> None: ...\n1092: ```\n1093: \n1094: ### Data plane (Agent Runtime) — base URL\n1095: \n1096: ```text\n1097: base_path = f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n1098: self.base_url = urljoin(router_url, base_path)\n1099: ```\n1100: \n1101: ### Data plane — HTTP\n1102: \n1103: | Method | URL | Headers | Body |\n1104: |--------|-----|---------|------|\n1105: | `GET` | `self.base_url` | (session default headers only) | — |\n1106: | `POST` | `self.base_url` | `x-agentcube-session-id`, `Content-Type: application/json` | `json=payload` |\n1107: \n1108: **Timeouts:** `(connect_timeout, timeout)` where `timeout` for `invoke` read side is the method argument or `self.timeout`.\n1109: \n1110: ## `create_session` (`agentcube/utils/http.py`)\n1111: \n1112: ```python\n1113: def create_session(\n1114:     pool_connections: int = 10,\n1115:     pool_maxsize: int = 10,\n1116: ) -> requests.Session: ...\n1117: ```\n1118: \n1119: Mounts `HTTPAdapter` for `http://` and `https://`.\n1120: \n1121: ## `read_token_from_file` (`agentcube/utils/utils.py`)\n1122: \n1123: ```python\n1124: def read_token_from_file(file_path: str) -> str: ...\n1125: ```\n1126: \n1127: Returns file contents stripped, or `\"\"` on `FileNotFoundError`.\n1128: \n1129: ## `get_logger` (`agentcube/utils/log.py`)\n1130: \n1131: ```python\n1132: def get_logger(name: str, level: Union[int, str] = logging.INFO) -> logging.Logger: ...\n1133: ```\n1134: \n1135: ## Exception hierarchy (`agentcube/exceptions.py`)\n1136: \n1137: ```python\n1138: class AgentCubeError(Exception):\n1139:     \"\"\"Base exception for AgentCube SDK\"\"\"\n1140:     pass\n1141: \n1142: class CommandExecutionError(AgentCubeError):\n\n(Output capped at 50 KB. Showing lines 1-1142. Use offset=1143 to continue.)\n</content>","metadata":{"preview":"Write delta-spec.md (GIVEN/WHEN/THEN scenarios) for the agentcube project:\n\nAR: AR-022 — CLI publish 命令\nModule: cmd/cli\nLanguage: Python\nSize: L\n\nBase specs:\n--- cli-toolkit/design.md ---\n# AgentCube CLI (cli-toolkit) — Design\n\nSource root: `/tmp/agentcube-ref/cmd/cli/`.\n\n## Package layout (every module path and role)\n\n| Path | Role |\n|------|------|\n| `pyproject.toml` | Project metadata, dependencies, console script mapping |\n| `agentcube/__init__.py` | Package version `__version__`, exports `app`, runtimes |\n| `agentcube/cli/__init__.py` | CLI subpackage marker |","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/.sdd_prompt.md","time":{"start":1775868046763,"end":1775868046789}}}}
