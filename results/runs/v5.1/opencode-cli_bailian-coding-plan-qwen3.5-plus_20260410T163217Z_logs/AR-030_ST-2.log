type: object\n119:                               x-kubernetes-map-type: atomic\n120:                             resourceFieldRef:\n121:                               description: |-\n122:                                 Selects a resource of a container: only supports limits.cpu and limits.memory\n123:                                 and requests.cpu and requests.memory.\n124:                               properties:\n125:                                 containerName:\n126:                                   description: Container name: required for volumes,\n127:                                     optional for env vars.\n128:                                   type: string\n129:                                 divisor:\n130:                                   anyOf:\n131:                                   - type: integer\n132:                                   - type: string\n133:                                   description: Specifies the output format of the\n134:                                     exposed resources.\n135:                                   pattern: ^(\\+|-)?(([0-9]+(\\.[0-9]*)?)|(\\.[0-9]+))(([KMGTPE]i)|[numkMGTPE]|([eE](\\+|-)?(([0-9]+(\\.[0-9]*)?)|(\\.[0-9]+))))?$\n136:                                   x-kubernetes-int-or-string: true\n137:                                 resource:\n138:                                   description: Required: resource to select.\n139:                                   type: string\n140:                               required:\n141:                               - resource\n142:                               type: object\n143:                               x-kubernetes-map-type: atomic\n144:                             secretKeyRef:\n145:                               description: Selects a key of a secret.\n146:                               properties:\n147:                                 key:\n148:                                   description: The key of the secret to select from.\n149:                                   type: string\n150:                                 name:\n151:                                   default: \"\"\n152:                                   description: |-\n153:                                     Name of the referent.\n154:                                   type: string\n155:                                 optional:\n156:                                   description: Specify whether the Secret or its key\n157:                                     must be defined.\n158:                                   type: boolean\n159:                               required:\n160:                               - key\n161:                               type: object\n162:                               x-kubernetes-map-type: atomic\n163:                           type: object\n164:                       required:\n165:                       - name\n166:                       type: object\n167:                     type: array\n168:                   image:\n169:                     description: Image is the container image to run.\n170:                     type: string\n171:                   workingDir:\n172:                     description: WorkingDir is the working directory for the container.\n173:                     type: string\n174:                 type: object\n175:               codeInterpreter:\n176:                 description: CodeInterpreter defines the embedded code interpreter\n177:                   configuration.\n178:                 properties:\n179:                   enabled:\n180:                     description: Enabled indicates whether to attach a code interpreter.\n181:                     type: boolean\n182:                   image:\n183:                     description: Image is the container image for the code interpreter.\n184:                     type: string\n185:                   resources:\n186:                     description: Resources defines the resource requirements for the\n187:                       code interpreter.\n188:                     properties:\n189:                       cpu:\n190:                         description: CPU is the CPU limit in cores (e.g., \"500m\" for\n191:                           0.5 CPU).\n192:                         type: string\n193:                       memory:\n194:                         description: Memory is the memory limit in bytes (e.g., \"512Mi\",\n195:                           \"1Gi\").\n196:                         type: string\n197:                       storage:\n198:                         description: Storage is the storage limit in bytes (e.g., \"1Gi\",\n199:                           \"10Gi\").\n200:                         type: string\n201:                     type: object\n202:                 type: object\n203:               lifecycle:\n204:                 description: Lifecycle defines lifecycle hooks.\n205:                 properties:\n206:                   postStop:\n207:                     description: PostStop is the URL to call after the runtime stops.\n208:                     type: string\n209:                   preStart:\n210:                     description: PreStart is the URL to call before the runtime starts.\n211:                     type: string\n212:                 type: object\n213:               network:\n214:                 description: Network defines the network policies.\n215:                 properties:\n216:                   egressRules:\n217:                     description: EgressRules defines allowed egress destinations.\n218:                     items:\n219:                       properties:\n220:                         cidr:\n221:                           description: CIDR is the IP CIDR block (e.g., \"10.0.0.0/8\").\n222:                           type: string\n223:                         ports:\n224:                           description: Ports is the list of allowed ports.\n225:                           items:\n226:                             format: int32\n227:                             type: integer\n228:                           type: array\n229:                         protocol:\n230:                           description: Protocol is the network protocol (TCP, UDP).\n231:                           type: string\n232:                       type: object\n233:                     type: array\n234:                   ingressRules:\n235:                     description: IngressRules defines allowed ingress sources.\n236:                     items:\n237:                       properties:\n238:                         cidr:\n239:                           description: CIDR is the IP CIDR block (e.g., \"10.0.0.0/8\").\n240:                           type: string\n241:                         ports:\n242:                           description: Ports is the list of allowed ports.\n243:                           items:\n244:                             format: int32\n245:                             type: integer\n246:                           type: array\n247:                         protocol:\n248:                           description: Protocol is the network protocol (TCP, UDP).\n249:                           type: string\n250:                       type: object\n251:                     type: array\n252:                 type: object\n253:               resources:\n254:                 description: Resources defines the resource quotas for the runtime.\n255:                 properties:\n256:                   cpu:\n257:                     description: CPU is the CPU limit in cores (e.g., \"500m\" for 0.5\n258:                       CPU).\n259:                     type: string\n260:                   memory:\n261:                     description: Memory is the memory limit in bytes (e.g., \"512Mi\",\n262:                       \"1Gi\").\n263:                     type: string\n264:                   storage:\n265:                     description: Storage is the storage limit in bytes (e.g., \"1Gi\",\n266:                       \"10Gi\").\n267:                     type: string\n268:                 type: object\n269:             type: object\n270:           status:\n271:             description: AgentRuntimeStatus defines the observed state of an AgentRuntime.\n272:             properties:\n273:               conditions:\n274:                 description: Conditions represent the latest available observations\n275:                   of the runtime state.\n276:                 items:\n277:                   description: AgentRuntimeCondition represents the state of a runtime\n278:                     condition.\n279:                   properties:\n280:                     lastTransitionTime:\n281:                       description: LastTransitionTime is the last time the condition\n282:                         transitioned from one status to another.\n283:                       format: date-time\n284:                       type: string\n285:                     message:\n286:                       description: Message is a human-readable message indicating\n287:                         details about last transition.\n288:                       type: string\n289:                     reason:\n290:                       description: Reason is a one-word CamelCase reason for the condition's\n291:                         last transition.\n292:                       type: string\n293:                     status:\n294:                       description: Status is the status of the condition (True, False,\n295:                         Unknown).\n296:                       type: string\n297:                     type:\n298:                       description: Type is the type of the condition.\n299:                       type: string\n300:                   required:\n301:                   - lastTransitionTime\n302:                   - status\n303:                   - type\n304:                   type: object\n305:                 type: array\n306:               lastTransitionTime:\n307:                 description: LastTransitionTime is the last time the phase transitioned.\n308:                 format: date-time\n309:                 type: string\n310:               phase:\n311:                 description: Phase is the current phase of the runtime.\n312:                 type: string\n313:               sandboxRef:\n314:                 description: SandboxRef is the reference to the sandbox pod.\n315:                 properties:\n316:                   apiVersion:\n317:                     description: API version of the referent.\n318:                     type: string\n319:                   fieldPath:\n320:                     description: |-\n321:                       If referring to a piece of an object instead of an entire object, this string\n322:                       should contain a valid JSON/Go field access statement.\n323:                     type: string\n324:                   kind:\n325:                     description: |-\n326:                       Kind of the referent.\n327:                     type: string\n328:                   name:\n329:                     description: |-\n330:                       Name of the referent.\n331:                     type: string\n332:                   namespace:\n333:                     description: |-\n334:                       Namespace of the referent.\n335:                     type: string\n336:                   resourceVersion:\n337:                     description: |-\n338:                       Specific resourceVersion to which this reference is made, if any.\n339:                     type: string\n340:                   uid:\n341:                     description: |-\n342:                       UID of the referent.\n343:                     type: string\n344:                 type: object\n345:               startTime:\n346:                 description: StartTime is the time when the runtime started.\n347:                 format: date-time\n348:                 type: string\n349:             type: object\n350:         type: object\n351:     served: true\n352:     storage: true\n353:     subresources:\n354:       status: {}\n\n(End of file - total 354 lines)\n</content>","metadata":{"preview":"---\napiVersion: apiextensions.k8s.io/v1\nkind: CustomResourceDefinition\nmetadata:\n  name: agentruntimes.runtime.agentcube.volcano.sh\n  annotations:\n    controller-gen.kubebuilder.io/version: v0.15.0\nspec:\n  group: runtime.agentcube.volcano.sh\n  names:\n    categories: []\n    kind: AgentRuntime\n    listKind: AgentRuntimeList\n    plural: agentruntimes\n    shortNames:\n    - ar\n    singular: agentruntime\n  scope: Namespaced\n  versions:\n  - additionalPrinterColumns:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/manifests/charts/base/crds/agentruntime.yaml","time":{"start":1775878684223,"end":1775878684266}}}}
