s:\n      - list\n      - watch\n      - get\n  - apiGroups:\n      - apps\n    resources:\n      - statefulsets\n    verbs:\n      - list\n      - watch\n      - get\n  - apiGroups:\n      - coordination.k8s.io\n    resources:\n      - leases\n    verbs:\n      - get\n      - create\n      - update\n      - watch\n  - apiGroups:\n      - resource.k8s.io\n    resources:\n      - resourceclaims\n    verbs:\n      - get\n      - list\n      - watch\n      - create\n      - update\n      - patch\n  - apiGroups:\n      - resource.k8s.io\n    resources:\n      - resourceclaims/status\n    verbs:\n      - update\n  - apiGroups:\n      - resource.k8s.io\n    resources:\n      - deviceclasses\n    verbs:\n      - get\n      - list\n      - watch\n      - create\n  - apiGroups:\n      - resource.k8s.io\n    resources:\n      - resourceslices\n    verbs:\n      - get\n      - list\n      - watch\n      - create\n  - apiGroups:\n      - shard.volcano.sh\n    resources:\n      - nodeshards\n    verbs:\n      - list\n      - watch\n      - get\n      - update\n---\napiVersion: rbac.authorization.k8s.io/v1\nkind: ClusterRoleBinding\nmetadata:\n  name: volcano-agent-scheduler-role\nroleRef:\n  apiGroup: rbac.authorization.k8s.io\n  kind: ClusterRole\n  name: volcano-agent-scheduler\nsubjects:\n  - kind: ServiceAccount\n    name: volcano-agent-scheduler\n    namespace: {{ .Release.Namespace }}\n---\napiVersion: v1\nkind: Service\nmetadata:\n  name: volcano-agent-scheduler-service\n  namespace: {{ .Release.Namespace }}\n  annotations:\n    prometheus.io/scrape: \"true\"\n    prometheus.io/port: \"8080\"\nspec:\n  selector:\n    app: volcano-agent-scheduler\n  ports:\n    - port: 8080\n      targetPort: 8080\n      protocol: TCP\n---\napiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: volcano-agent-scheduler\n  namespace: {{ .Release.Namespace }}\nspec:\n  replicas: {{ .Values.volcano.scheduler.replicas }}\n  selector:\n    matchLabels:\n      app: volcano-agent-scheduler\n  template:\n    metadata:\n      labels:\n        app: volcano-agent-scheduler\n    spec:\n      serviceAccountName: volcano-agent-scheduler\n      containers:\n        - name: volcano-agent-scheduler\n          image: \"{{ .Values.volcano.scheduler.image.repository }}:{{ .Values.volcano.scheduler.image.tag }}\"\n          imagePullPolicy: {{ .Values.volcano.scheduler.image.pullPolicy }}\n          args:\n            - --scheduler-name=agent-scheduler\n            - --kubeconfig=/etc/kubernetes/kubeconfig\n          ports:\n            - containerPort: 8080\n              protocol: TCP\n          securityContext:\n            runAsUser: 1000\n            runAsGroup: 1000\n          volumeMounts:\n            - name: config-volume\n              mountPath: /etc/volcano\n            - name: tmp-volume\n              mountPath: /tmp\n      volumes:\n        - name: config-volume\n          configMap:\n            name: volcano-agent-scheduler-configmap\n        - name: tmp-volume\n          emptyDir: {}\n{{- end }}\n","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/manifests/charts/base/templates/volcano-agent-scheduler-development.yaml"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/manifests/charts/base/templates/workloadmanager.yaml\">\nERROR [16:9] Block collections are not allowed within flow collections\nERROR [16:11] Missing , or : between flow map items\nERROR [17:1] All mapping items must start at the same column\nERROR [18:11] Block collections are not allowed within flow collections\nERROR [18:13] Missing , or : between flow map items\nERROR [19:1] All mapping items must start at the same column\nERROR [19:7] Implicit keys need to be on a single line\nERROR [19:9] Block collections are not allowed within flow collections\nERROR [19:11] Missing , or : be