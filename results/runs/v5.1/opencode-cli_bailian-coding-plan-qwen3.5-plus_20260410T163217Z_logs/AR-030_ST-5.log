{"type":"tool_use","timestamp":1775879326997,"sessionID":"ses_2855a9203ffebYGUS0ExwEQGNY","part":{"id":"prt_d7aa784650019iIab7tbKClHh7","messageID":"msg_d7aa761f3001Ha7976EsjfUCWx","sessionID":"ses_2855a9203ffebYGUS0ExwEQGNY","type":"tool","tool":"write","callID":"toolu_27f97e9516a44c4c88f6034c","state":{"status":"completed","input":{"content":"{{- if .Values.volcano.scheduler.enabled }}\napiVersion: v1\nkind: ServiceAccount\nmetadata:\n  name: volcano-agent-scheduler\n  namespace: {{ .Release.Namespace }}\n---\napiVersion: v1\nkind: ConfigMap\nmetadata:\n  name: volcano-agent-scheduler-configmap\n  namespace: {{ .Release.Namespace }}\ndata:\n  agent-scheduler.conf: |\n    actions: allocate\n    tiers:\n      - name: default\n        plugins:\n          - name: predicates\n          - name: nodeorder\n---\napiVersion: rbac.authorization.k8s.io/v1\nkind: ClusterRole\nmetadata:\n  name: volcano-agent-scheduler\nrules:\n  - apiGroups:\n      - apiextensions.k8s.io\n    resources:\n      - customresourcedefinitions\n    verbs:\n      - create\n      - get\n      - list\n      - watch\n      - delete\n  - apiGroups:\n      - \"\"\n    resources:\n      - events\n    verbs:\n      - create\n      - list\n      - watch\n      - update\n      - patch\n  - apiGroups:\n      - \"\"\n    resources:\n      - pods\n    verbs:\n      - get\n      - list\n      - watch\n      - patch\n      - delete\n  - apiGroups:\n      - \"\"\n    resources:\n      - pods/status\n    verbs:\n      - update\n  - apiGroups:\n      - \"\"\n    resources:\n      - pods/binding\n    verbs:\n      - create\n  - apiGroups:\n      - \"\"\n    resources:\n      - persistentvolumeclaims\n    verbs:\n      - list\n      - watch\n      - update\n  - apiGroups:\n      - \"\"\n    resources:\n      - persistentvolumes\n    verbs:\n      - list\n      - watch\n      - update\n  - apiGroups:\n      - \"\"\n    resources:\n      - namespaces\n    verbs:\n      - list\n      - watch\n      - get\n  - apiGroups:\