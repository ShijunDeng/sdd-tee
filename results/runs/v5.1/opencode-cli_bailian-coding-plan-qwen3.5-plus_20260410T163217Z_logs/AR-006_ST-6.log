r,\n40: \t\tnamespace:     namespace,\n41: \t}\n42: }\n43: \n44: func (h *SandboxHandler) HandleAgentRuntimeCreate(c *gin.Context) {\n45: \tvar req types.CreateSandboxRequest\n46: \tif err := c.ShouldBindJSON(&req); err != nil {\n47: \t\tresponse.Error(c, http.StatusBadRequest, 40002, \"Invalid request body\")\n48: \t\treturn\n49: \t}\n50: \n51: \tif err := req.Validate(); err != nil {\n52: \t\tresponse.Error(c, http.StatusBadRequest, 40003, err.Error())\n53: \t\treturn\n54: \t}\n55: \n56: \treq.Kind = \"AgentRuntime\"\n57: \n58: \truntime, err := processor.GetAgentRuntime(h.arLister, req.Namespace, req.Name)\n59: \tif err != nil {\n60: \t\tif err == processor.ErrAgentRuntimeNotFound {\n61: \t\t\tresponse.Error(c, http.StatusNotFound, 40401, \"agent runtime not found\")\n62: \t\t\treturn\n63: \t\t}\n64: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n65: \t\treturn\n66: \t}\n67: \n68: \tproc := processor.NewSandboxProcessor(h.dynamicClient, h.k8sClient, h.podLister, h.arLister, h.ciLister, h.namespace)\n69: \n70: \tsessionID, err := proc.GenerateSessionID()\n71: \tif err != nil {\n72: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n73: \t\treturn\n74: \t}\n75: \n76: \tsandbox, err := proc.BuildSandboxObject(runtime, sessionID)\n77: \tif err != nil {\n78: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n79: \t\treturn\n80: \t}\n81: \n82: \tuserClient := h.dynamicClient.Resource(processor.SandboxGVR).Namespace(runtime.Namespace)\n83: \n84: \tinfo, err := proc.CreateSandbox(c.Request.Context(), sandbox, false, userClient, sessionID)\n85: \tif err != nil {\n86: \t\tif err == processor.ErrSandboxCreationTimeout {\n87: \t\t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n88: \t\t\treturn\n89: \t\t}\n90: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n91: \t\treturn\n92: \t}\n93: \n94: \tresp := types.CreateSandboxResponse{\n95: \t\tSessionID:   info.SessionID,\n96: \t\tSandboxID:   info.SandboxID,\n97: \t\tSandboxName: info.SandboxName,\n98: \t\tEntryPoints: info.EntryPoints,\n99: \t}\n100: \n101: \tresponse.JSON(c, http.StatusOK, resp)\n102: }\n103: \n104: func (h *SandboxHandler) HandleCodeInterpreterCreate(c *gin.Context) {\n105: \tvar req types.CreateSandboxRequest\n106: \tif err := c.ShouldBindJSON(&req); err != nil {\n107: \t\tresponse.Error(c, http.StatusBadRequest, 40002, \"Invalid request body\")\n108: \t\treturn\n109: \t}\n110: \n111: \tif err := req.Validate(); err != nil {\n112: \t\tresponse.Error(c, http.StatusBadRequest, 40003, err.Error())\n113: \t\treturn\n114: \t}\n115: \n116: \treq.Kind = \"CodeInterpreter\"\n117: \n118: \tinterpreter, err := processor.GetCodeInterpreter(h.ciLister, req.Namespace, req.Name)\n119: \tif err != nil {\n120: \t\tif err == processor.ErrCodeInterpreterNotFound {\n121: \t\t\tresponse.Error(c, http.StatusNotFound, 40401, \"code interpreter not found\")\n122: \t\t\treturn\n123: \t\t}\n124: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n125: \t\treturn\n126: \t}\n127: \n128: \tproc := processor.NewSandboxProcessor(h.dynamicClient, h.k8sClient, h.podLister, h.arLister, h.ciLister, h.namespace)\n129: \n130: \tsessionID, err := proc.GenerateSessionID()\n131: \tif err != nil {\n132: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n133: \t\treturn\n134: \t}\n135: \n136: \tvar sandbox *unstructured.Unstructured\n137: \tisWarmPool := false\n138: \n139: \tsandbox, err = proc.BuildCodeInterpreterSandbox(interpreter, sessionID)\n140: \tif err != nil {\n141: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n142: \t\treturn\n143: \t}\n144: \n145: \tuserClient := h.dynamicClient.Resource(processor.SandboxGVR).Namespace(interpreter.Namespace)\n146: \n147: \tinfo, err := proc.CreateSandbox(c.Request.Context(), sandbox, isWarmPool, userClient, sessionID)\n148: \tif err != nil {\n149: \t\tif err == processor.ErrSandboxCreationTimeout {\n150: \t\t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n151: \t\t\treturn\n152: \t\t}\n153: \t\tresponse.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n154: \t\treturn\n155: \t}\n156: \n157: \tresp := types.CreateSandboxResponse{\n158: \t\tSessionID:   info.SessionID,\n159: \t\tSandboxID:   info.SandboxID,\n160: \t\tSandboxName: info.SandboxName,\n161: \t\tEntryPoints: info.EntryPoints,\n162: \t}\n163: \n164: \tresponse.JSON(c, http.StatusOK, resp)\n165: }\n\n(End of file - total 165 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\tcorev1lister \"k8s.io/client-go/listers/core/v1\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/processor\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\ntype SandboxHandler struct {\n\tdynamicClient dynamic.Interface\n\tk8sClient     kubernetes.Interface\n\tpodLister     corev1lister.PodLister","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/pkg/workloadmanager/handler/sandbox.go","time":{"start":1775845029489,"end":1775845029514}}}}
