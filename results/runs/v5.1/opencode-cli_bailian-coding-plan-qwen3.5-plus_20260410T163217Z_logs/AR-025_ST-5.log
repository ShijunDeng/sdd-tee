 4096 Apr 11 08:33 .pytest_cache\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 python-sdk\ndrwxr-xr-x  4 root root     4096 Apr 11 02:04 sandbox-orchestration\n-rw-r--r--  1 root root    59827 Apr 11 09:38 .sdd_prompt.md\ndrwxr-xr-x  2 root root     4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 session-store\ndrwxr-xr-x  2 root root     4096 Mar 25 09:51 testing\n-rw-r--r--  1 root root     1983 Mar 25 09:36 test_spec.md\n-rw-r--r--  1 root root     8552 Apr 11 01:56 verification-report.md\n","exit":0,"description":"List workspace directory","truncated":false},"title":"List workspace directory","time":{"start":1775871696675,"end":1775871696700}}}}
