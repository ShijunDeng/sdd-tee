==\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py\n@@ -106,15 +106,8 @@\n     \n     if not workspace_path.is_dir():\n         raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n     \n-    metadata = self.load_metadata(workspace_path)\n-\n-    if metadata.language == \"python\":\n-        self._validate_python_workspace(workspace_path, metadata)\n-    elif metadata.language == \"java\":\n-        self._validate_java_workspace(workspace_path, metadata)\n-\n     return True\n \n def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n     \"\"\"Validate Python workspace.\"\"\"\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py","before":"\"\"\"Agent metadata service and models.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Agent metadata model for agent_metadata.yaml.\"\"\"\n\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: Optional[str] = Field(None, description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n    region: Optional[str] = Field(None, description=\"Deployment region\")\n    version: Optional[str] = Field(None, description=\"Semantic version string for publishing\")\n    image: Optional[Dict[str, Any]] = Field(None, description=\"Container image information\")\n    auth: Optional[Dict[str, Any]] = Field(None, description=\"Authentication configuration\")\n    requirements_file: Optional[str] = Field(\"requirements.txt\", description=\"Python dependency file\")\n    registry_url: Optional[str] = Field(\"\", description=\"Registry URL for image publishing\")\n    registry_username: Optional[str] = Field(\"\", description=\"Registry username\")\n    registry_password: Optional[str] = Field(\"\", description=\"Registry password\")\n    agent_endpoint: Optional[str] = Field(None, description=\"Agent endpoint URL\")\n    workload_manager_url: Optional[str] = Field(None, description=\"URL for the Workload Manager\")\n    router_url: Optional[str] = Field(None, description=\"URL for the Router\")\n    readiness_probe_path: Optional[str] = Field(None, description=\"Path for the readiness probe\")\n    readiness_probe_port: Optional[int] = Field(None, description=\"Port for the readiness probe\")\n    agent_id: Optional[str] = Field(None, description=\"Agent ID assigned by AgentCube\")\n    session_id: Optional[str] = Field(None, description=\"The session ID for the agent\")\n    k8s_deployment: Optional[Dict[str, Any]] = Field(None, description=\"Kubernetes deployment information\")\n\n    @field_validator(\"language\")\n    @classmethod\n    def validate_language(cls, v: str) -> str:\n        if v.lower() not in [\"python\", \"java\"]:\n            raise ValueError(f\"Language must be 'python' or 'java', got '{v}'\")\n        return v.lower()\n\n    @field_validator(\"build_mode\")\n    @classmethod\n    def validate_build_mode(cls, v: str) -> str:\n        if v.lower() not in [\"local\", \"cloud\"]:\n            raise ValueError(f\"Build mode must be 'local' or 'cloud', got '{v}'\")\n        return v.lower()\n\n    @field_validator(\"port\")\n    @classmethod\n    def validate_port(cls, v: int) -> int:\n        if not 1 <= v <= 65535:\n            raise ValueError(f\"Port must be between 1 and 65535, got '{v}'\")\n        return v\n\n\nclass MetadataService:\n    \"\"\"Service for loading and saving agent metadata.\"\"\"\n\n    METADATA_FILES = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose\n\n    def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n        \"\"\"Load metadata from workspace directory.\"\"\"\n        for filename in self.METADATA_FILES:\n            metadata_file = workspace_path / filename\n            if metadata_file.exists():\n                with open(metadata_file, \"r\") as f:\n                    data = yaml.safe_load(f)\n                return AgentMetadata(**data)\n\n        raise FileNotFoundError(\n            f\"No metadata file found. Expected one of: {', '.join(self.METADATA_FILES)}\"\n        )\n\n    def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Save metadata to workspace directory.\"\"\"\n        metadata_file = workspace_path / \"agent_metadata.yaml\"\n        with open(metadata_file, \"w\") as f:\n            yaml.dump(\n                metadata.model_dump(exclude_none=True),\n                f,\n                default_flow_style=False,\n                indent=2,\n                sort_keys=False,\n            )\n\n    def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n        \"\"\"Update metadata with provided fields.\"\"\"\n        metadata = self.load_metadata(workspace_path)\n        updated_data = metadata.model_dump()\n        updated_data.update(updates)\n        updated_metadata = AgentMetadata(**updated_data)\n        self.save_metadata(workspace_path, updated_metadata)\n        return updated_metadata\n\n    def validate_workspace(self, workspace_path: Path) -> bool:\n        \"\"\"Validate workspace structure.\"\"\"\n        if not workspace_path.exists():\n            raise FileNotFoundError(f\"Workspace directory does not exist: {workspace_path}\")\n        \n        if not workspace_path.is_dir():\n            raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n        \n        metadata = self.load_metadata(workspace_path)\n\n        if metadata.language == \"python\":\n            self._validate_python_workspace(workspace_path, metadata)\n        elif metadata.language == \"java\":\n            self._validate_java_workspace(workspace_path, metadata)\n\n        return True\n\n    def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Validate Python workspace.\"\"\"\n        py_files = list(workspace_path.glob(\"*.py\"))\n        if not py_files:\n            raise ValueError(\"No Python files found in workspace\")\n\n    def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Validate Java workspace.\"\"\"\n        pom_xml = workspace_path / \"pom.xml\"\n        if not pom_xml.exists():\n            raise ValueError(\"pom.xml not found in workspace\")\n","after":"\"\"\"Agent metadata service and models.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Agent metadata model for agent_metadata.yaml.\"\"\"\n\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: Optional[str] = Field(None, description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n    region: Optional[str] = Field(None, description=\"Deployment region\")\n    version: Optional[str] = Field(None, description=\"Semantic version string for publishing\")\n    image: Optional[Dict[str, Any]] = Field(None, description=\"Container image information\")\n    auth: Optional[Dict[str, Any]] = Field(None, description=\"Authentication configuration\")\n    requirements_file: Optional[str] = Field(\"requirements.txt\", description=\"Python dependency file\")\n    registry_url: Optional[str] = Field(\"\", description=\"Registry URL for image publishing\")\n    registry_username: Optional[str] = Field(\"\", description=\"Registry username\")\n    registry_password: Optional[str] = Field(\"\", description=\"Registry password\")\n    agent_endpoint: Optional[str] = Field(None, description=\"Agent endpoint URL\")\n    workload_manager_url: Optional[str] = Field(None, description=\"URL for the Workload Manager\")\n    router_url: Optional[str] = Field(None, description=\"URL for the Router\")\n    readiness_probe_path: Optional[str] = Field(None, description=\"Path for the readiness probe\")\n    readiness_probe_port: Optional[int] = Field(None, description=\"Port for the readiness probe\")\n    agent_id: Optional[str] = Field(None, description=\"Agent ID assigned by AgentCube\")\n    session_id: Optional[str] = Field(None, description=\"The session ID for the agent\")\n    k8s_deployment: Optional[Dict[str, Any]] = Field(None, description=\"Kubernetes deployment information\")\n\n    @field_validator(\"language\")\n    @classmethod\n    def validate_language(cls, v: str) -> str:\n        if v.lower() not in [\"python\", \"java\"]:\n            raise ValueError(f\"Language must be 'python' or 'java', got '{v}'\")\n        return v.lower()\n\n    @field_validator(\"build_mode\")\n    @classmethod\n    def validate_build_mode(cls, v: str) -> str:\n        if v.lower() not in [\"local\", \"cloud\"]:\n            raise ValueError(f\"Build mode must be 'local' or 'cloud', got '{v}'\")\n        return v.lower()\n\n    @field_validator(\"port\")\n    @classmethod\n    def validate_port(cls, v: int) -> int:\n        if not 1 <= v <= 65535:\n            raise ValueError(f\"Port must be between 1 and 65535, got '{v}'\")\n        return v\n\n\nclass MetadataService:\n    \"\"\"Service for loading and saving agent metadata.\"\"\"\n\n    METADATA_FILES = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose\n\n    def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n        \"\"\"Load metadata from workspace directory.\"\"\"\n        for filename in self.METADATA_FILES:\n            metadata_file = workspace_path / filename\n            if metadata_file.exists():\n                with open(metadata_file, \"r\") as f:\n                    data = yaml.safe_load(f)\n                return AgentMetadata(**data)\n\n        raise FileNotFoundError(\n            f\"No metadata file found. Expected one of: {', '.join(self.METADATA_FILES)}\"\n        )\n\n    def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Save metadata to workspace directory.\"\"\"\n        metadata_file = workspace_path / \"agent_metadata.yaml\"\n        with open(metadata_file, \"w\") as f:\n            yaml.dump(\n                metadata.model_dump(exclude_none=True),\n                f,\n                default_flow_style=False,\n                indent=2,\n                sort_keys=False,\n            )\n\n    def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n        \"\"\"Update metadata with provided fields.\"\"\"\n        metadata = self.load_metadata(workspace_path)\n        updated_data = metadata.model_dump()\n        updated_data.update(updates)\n        updated_metadata = AgentMetadata(**updated_data)\n        self.save_metadata(workspace_path, updated_metadata)\n        return updated_metadata\n\n    def validate_workspace(self, workspace_path: Path) -> bool:\n        \"\"\"Validate workspace structure.\"\"\"\n        if not workspace_path.exists():\n            raise FileNotFoundError(f\"Workspace directory does not exist: {workspace_path}\")\n        \n        if not workspace_path.is_dir():\n            raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n        \n        return True\n\n    def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Validate Python workspace.\"\"\"\n        py_files = list(workspace_path.glob(\"*.py\"))\n        if not py_files:\n            raise ValueError(\"No Python files found in workspace\")\n\n    def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Validate Java workspace.\"\"\"\n        pom_xml = workspace_path / \"pom.xml\"\n        if not pom_xml.exists():\n            raise ValueError(\"pom.xml not found in workspace\")\n","additions":0,"deletions":7},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775871824662,"end":1775871825406}}}}
