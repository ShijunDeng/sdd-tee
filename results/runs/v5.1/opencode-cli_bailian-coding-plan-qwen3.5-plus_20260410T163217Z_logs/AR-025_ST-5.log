ription\", \"language\", \"port\", \"region\", \"version\", \"image\", \"auth\", \"requirements_file\", \"registry_url\", \"registry_username\", \"registry_password\", \"agent_endpoint\", \"readiness_probe_path\", \"readiness_probe_port\", \"agent_id\", \"session_id\", \"k8s_deployment\"","severity":1,"code":"reportCallIssue","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportCallIssue"}},{"range":{"start":{"line":384,"character":19},"end":{"line":388,"character":9}},"message":"Arguments missing for parameters \"description\", \"language\", \"build_mode\", \"region\", \"version\", \"image\", \"auth\", \"requirements_file\", \"registry_url\", \"registry_username\", \"registry_password\", \"agent_endpoint\", \"workload_manager_url\", \"router_url\", \"readiness_probe_path\", \"readiness_probe_port\", \"agent_id\", \"session_id\", \"k8s_deployment\"","severity":1,"code":"reportCallIssue","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportCallIssue"}},{"range":{"start":{"line":412,"character":23},"end":{"line":420,"character":13}},"message":"Arguments missing for parameters \"description\", \"region\", \"version\", \"image\", \"auth\", \"requirements_file\", \"registry_url\", \"registry_username\", \"registry_password\", \"agent_endpoint\", \"readiness_probe_path\", \"readiness_probe_port\", \"agent_id\", \"session_id\", \"k8s_deployment\"","severity":1,"code":"reportCallIssue","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportCallIssue"}}]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/tests/test_publish_runtime.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/tests/test_publish_runtime.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/tests/test_publish_runtime.py\n@@ -318,8 +318,9 @@\n runtime = PublishRuntime()\n \n metadata = AgentMetadata(\n     agent_name=\"test-agent\",\n+    entrypoint=\"python main.py\",\n     build_mode=\"cloud\",\n )\n \n with pytest.raises(ValueError, match=\"router_url and 'workload_manager_url\"):\n@@ -330,8 +331,9 @@\n runtime = PublishRuntime()\n \n metadata = AgentMetadata(\n     agent_name=\"test-agent\",\n+    entrypoint=\"python main.py\",\n     build_mode=\"cloud\",\n )\n \n with pytest.raises(ValueError, match=\"Cloud build mode requires --image-url\"):\n@@ -342,8 +344,9 @@\n runtime = PublishRuntime()\n \n metadata = AgentMetadata(\n     agent_name=\"test-agent\",\n+    entrypoint=\"python main.py\",\n     build_mode=\"cloud\",\n     workload_manager_url=\"http://wm:8080\",\n     router_url=\"http://router:8080\",\n )\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/tests/test_publish_runtime.py","before":"\"\"\"Tests for PublishRuntime.\"\"\"\n\nfrom __future__ import annotations\n\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\nimport pytest\nimport yaml\n\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass TestPublishRuntimeInit:\n    \"\"\"Test PublishRuntime initialization.\"\"\"\n\n    def test_init_default(self):\n        \"\"\"Test default initialization.\"\"\"\n        runtime = PublishRuntime()\n        assert runtime.verbose is False\n        assert runtime.provider == \"agentcube\"\n        assert runtime.metadata_service is not None\n        assert runtime.docker_service is not None\n\n    def test_init_with_options(self):\n        \"\"\"Test initialization with options.\"\"\"\n        runtime = PublishRuntime(verbose=True, provider=\"k8s\")\n        assert runtime.verbose is True\n        assert runtime.provider == \"k8s\"\n\n\nclass TestPublishRuntimePublish:\n    \"\"\"Test PublishRuntime.publish method.\"\"\"\n\n    @pytest.fixture\n    def packaged_workspace(self):\n        \"\"\"Create a temporary packaged workspace.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"\"\"\nfrom flask import Flask\napp = Flask(__name__)\n\n@app.route(\"/health\")\ndef health():\n    return {\"status\": \"healthy\"}\n\nif __name__ == \"__main__\":\n    app.run(host=\"0.0.0.0\", port=8080)\n\"\"\")\n            (workspace / \"requirements.txt\").write_text(\"flask>=2.0.0\\n\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n                build_mode=\"local\",\n                workload_manager_url=\"http://workload-manager:8080\",\n                router_url=\"http://router:8080\",\n            )\n\n            metadata_service = MetadataService()\n            metadata_service.save_metadata(workspace, metadata)\n\n            yield workspace\n\n    def test_publish_to_agentcube(self, packaged_workspace):\n        \"\"\"Test publishing to AgentCube provider.\"\"\"\n        with patch.object(PublishRuntime, '_publish_cr_to_k8s') as mock_publish:\n            mock_publish.return_value = {\n                \"agent_name\": \"test-agent\",\n                \"agent_id\": \"test-agent\",\n                \"deployment_type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n                \"image_url\": \"test-agent:latest\",\n                \"status\": \"running\",\n                \"endpoint\": \"http://test-agent:8080\",\n                \"router_url\": \"http://router:8080\",\n                \"workload_manager_url\": \"http://workload-manager:8080\",\n            }\n\n            runtime = PublishRuntime(provider=\"agentcube\")\n            with patch.object(runtime, '_prepare_image_for_publishing', return_value=\"test:latest\"):\n                result = runtime.publish(packaged_workspace)\n\n            assert result[\"agent_name\"] == \"test-agent\"\n            assert result[\"deployment_type\"] == \"AgentRuntime\"\n            assert result[\"status\"] == \"running\"\n\n    def test_publish_to_k8s(self, packaged_workspace):\n        \"\"\"Test publishing to standard Kubernetes provider.\"\"\"\n        with patch.object(PublishRuntime, '_publish_k8s') as mock_publish:\n            mock_publish.return_value = {\n                \"agent_name\": \"test-agent\",\n                \"agent_id\": \"test-agent\",\n                \"deployment_type\": \"Kubernetes\",\n                \"namespace\": \"default\",\n                \"image_url\": \"test-agent:latest\",\n                \"deployment_name\": \"test-agent\",\n                \"service_name\": \"test-agent\",\n                \"node_port\": 30080,\n                \"service_url\": \"http://localhost:30080\",\n                \"replicas\": 1,\n                \"status\": \"running\",\n            }\n\n            runtime = PublishRuntime(provider=\"k8s\")\n            result = runtime.publish(packaged_workspace, image_url=\"test:latest\")\n\n            assert result[\"agent_name\"] == \"test-agent\"\n            assert result[\"deployment_type\"] == \"Kubernetes\"\n            assert result[\"node_port\"] == 30080\n\n    def test_publish_unsupported_provider(self, packaged_workspace):\n        \"\"\"Test publishing with unsupported provider.\"\"\"\n        runtime = PublishRuntime(provider=\"unsupported\")\n        with pytest.raises(ValueError, match=\"Unsupported provider: unsupported\"):\n            with patch.object(runtime, '_prepare_image_for_publishing', return_value=\"test:latest\"):\n                runtime.publish(packaged_workspace)\n\n    def test_publish_with_option_overrides(self, packaged_workspace):\n        \"\"\"Test publishing with CLI option overrides.\"\"\"\n        with patch.object(PublishRuntime, '_publish_cr_to_k8s') as mock_publish:\n            mock_publish.return_value = {\n                \"agent_name\": \"test-agent\",\n                \"agent_id\": \"test-agent\",\n                \"deployment_type\": \"AgentRuntime\",\n                \"namespace\": \"production\",\n                \"image_url\": \"test-agent:v1.0.0\",\n                \"status\": \"running\",\n            }\n\n            runtime = PublishRuntime(provider=\"agentcube\")\n            with patch.object(runtime, '_prepare_image_for_publishing', return_value=\"test:latest\"):\n                result = runtime.publish(\n                    packaged_workspace,\n                    version=\"v1.0.0\",\n                    description=\"Updated description\",\n                    namespace=\"production\",\n                )\n\n            assert result[\"namespace\"] == \"production\"\n\n    def test_publish_agentcube_missing_urls(self, packaged_workspace):\n        \"\"\"Test AgentCube publish with missing required URLs.\"\"\"\n        runtime = PublishRuntime(provider=\"agentcube\")\n        \n        metadata_no_urls = AgentMetadata(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=8080,\n            build_mode=\"cloud\",\n        )\n        metadata_service = MetadataService()\n        metadata_service.save_metadata(packaged_workspace, metadata_no_urls)\n        \n        with pytest.raises(ValueError, match=\"router_url and 'workload_manager_url\"):\n            runtime.publish(packaged_workspace, image_url=\"test:latest\")\n\n    def test_publish_k8s_invalid_node_port(self, packaged_workspace):\n        \"\"\"Test K8s publish with invalid NodePort.\"\"\"\n        runtime = PublishRuntime(provider=\"k8s\")\n        \n        with pytest.raises(ValueError, match=\"NodePort must be between\"):\n            runtime.publish(packaged_workspace, image_url=\"test:latest\", node_port=8080)\n\n\nclass TestPublishRuntimePrepareImage:\n    \"\"\"Test image preparation methods.\"\"\"\n\n    def test_prepare_local_image_with_url(self):\n        \"\"\"Test local image preparation with provided URL.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            runtime = PublishRuntime()\n            \n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                build_mode=\"local\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n            \n            result = runtime._prepare_image_for_publishing(\n                workspace, metadata, {\"image_url\": \"registry.io/test-agent:latest\"}\n            )\n            \n            assert result == \"registry.io/test-agent:latest\"\n\n    def test_prepare_cloud_image_with_url(self):\n        \"\"\"Test cloud image preparation with provided URL.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            runtime = PublishRuntime()\n            \n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                build_mode=\"cloud\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n            \n            result = runtime._prepare_image_for_publishing(\n                workspace, metadata, {\"image_url\": \"cloud-registry.io/test-agent:v1\"}\n            )\n            \n            assert result == \"cloud-registry.io/test-agent:v1\"\n\n    def test_prepare_cloud_image_missing_url(self):\n        \"\"\"Test cloud image preparation without URL raises error.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            runtime = PublishRuntime()\n            \n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                build_mode=\"cloud\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n            \n            with pytest.raises(ValueError, match=\"Cloud build mode requires --image-url\"):\n                runtime._prepare_image_for_publishing(workspace, metadata, {})\n\n\nclass TestPublishRuntimeBuildEnvVars:\n    \"\"\"Test environment variable building.\"\"\"\n\n    def test_build_env_vars_complete(self):\n        \"\"\"Test building complete environment variables.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            workload_manager_url=\"http://wm:8080\",\n            router_url=\"http://router:8080\",\n            agent_endpoint=\"http://endpoint:8080\",\n        )\n        \n        env_vars = runtime._build_agent_env_vars(metadata)\n        \n        assert env_vars[\"WORKLOAD_MANAGER_URL\"] == \"http://wm:8080\"\n        assert env_vars[\"ROUTER_URL\"] == \"http://router:8080\"\n        assert env_vars[\"AGENT_ENDPOINT\"] == \"http://endpoint:8080\"\n\n    def test_build_env_vars_empty(self):\n        \"\"\"Test building empty environment variables.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n        )\n        \n        env_vars = runtime._build_agent_env_vars(metadata)\n        \n        assert env_vars == {}\n\n\nclass TestPublishRuntimeUpdateMetadata:\n    \"\"\"Test metadata update functionality.\"\"\"\n\n    def test_update_publish_metadata(self):\n        \"\"\"Test updating metadata after publish.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            \n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n            \n            metadata_service = MetadataService()\n            metadata_service.save_metadata(workspace, metadata)\n            \n            runtime = PublishRuntime()\n            \n            agent_info = {\n                \"agent_id\": \"test-agent-id\",\n                \"session_id\": \"session-123\",\n                \"endpoint\": \"http://test-agent:8080\",\n                \"image_url\": \"test-agent:latest\",\n                \"deployment_type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n            \n            runtime._update_publish_metadata(workspace, agent_info)\n            \n            updated_metadata = metadata_service.load_metadata(workspace)\n            assert updated_metadata.agent_id == \"test-agent-id\"\n            assert updated_metadata.session_id == \"session-123\"\n            assert updated_metadata.agent_endpoint == \"http://test-agent:8080\"\n            assert updated_metadata.image is not None\n            assert updated_metadata.image[\"url\"] == \"test-agent:latest\"\n\n\nclass TestPublishRuntimeValidation:\n    \"\"\"Test validation methods.\"\"\"\n\n    def test_validate_prerequisites_local_no_docker(self):\n        \"\"\"Test validation fails when Docker is not available.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            build_mode=\"local\",\n        )\n        \n        with patch.object(runtime.docker_service, 'check_docker_available', return_value=False):\n            with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n                runtime._validate_publish_prerequisites(metadata, {})\n\n    def test_validate_prerequisites_agentcube_missing_urls(self):\n        \"\"\"Test AgentCube validation fails with missing URLs.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            build_mode=\"cloud\",\n        )\n        \n        with pytest.raises(ValueError, match=\"router_url and 'workload_manager_url\"):\n            runtime._validate_publish_prerequisites(metadata, {})\n\n    def test_validate_prerequisites_cloud_missing_image_url(self):\n        \"\"\"Test cloud validation fails without image URL.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            build_mode=\"cloud\",\n        )\n        \n        with pytest.raises(ValueError, match=\"Cloud build mode requires --image-url\"):\n            runtime._validate_publish_prerequisites(metadata, {})\n\n    def test_validate_prerequisites_pass(self):\n        \"\"\"Test validation passes with correct config.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            build_mode=\"cloud\",\n            workload_manager_url=\"http://wm:8080\",\n            router_url=\"http://router:8080\",\n        )\n        \n        with patch.object(runtime.docker_service, 'check_docker_available', return_value=True):\n            runtime._validate_publish_prerequisites(metadata, {\"image_url\": \"test:latest\"})\n\n\nclass TestPublishRuntimeGenerateSessionId:\n    \"\"\"Test session ID generation.\"\"\"\n\n    def test_generate_session_id_format(self):\n        \"\"\"Test session ID format.\"\"\"\n        runtime = PublishRuntime()\n        session_id = runtime._generate_session_id()\n        \n        assert len(session_id) == 32\n        assert session_id.isalnum()\n\n    def test_generate_session_id_unique(self):\n        \"\"\"Test session IDs are unique.\"\"\"\n        runtime = PublishRuntime()\n        \n        ids = [runtime._generate_session_id() for _ in range(100)]\n        \n        assert len(set(ids)) == 100\n\n\nclass TestPublishRuntimeApplyOptions:\n    \"\"\"Test applying publish options.\"\"\"\n\n    def test_apply_publish_options(self):\n        \"\"\"Test applying publish options to metadata.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            port=8080,\n        )\n        \n        options = {\n            \"version\": \"v1.0.0\",\n            \"description\": \"Test description\",\n            \"region\": \"us-west-2\",\n        }\n        \n        runtime._apply_publish_options(metadata, options)\n        \n        assert metadata.version == \"v1.0.0\"\n\n\nclass TestPublishRuntimeIntegration:\n    \"\"\"Integration tests for PublishRuntime.\"\"\"\n\n    @pytest.fixture\n    def full_workspace(self):\n        \"\"\"Create a complete workspace for integration testing.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n            (workspace / \"requirements.txt\").write_text(\"flask>=2.0.0\\n\")\n\n            metadata = AgentMetadata(\n                agent_name=\"integration-test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n                build_mode=\"cloud\",\n                workload_manager_url=\"http://wm:8080\",\n                router_url=\"http://router:8080\",\n            )\n\n            MetadataService().save_metadata(workspace, metadata)\n            yield workspace\n\n    def test_full_publish_flow_agentcube_mocked(self, full_workspace):\n        \"\"\"Test full publish flow to AgentCube with mocked providers.\"\"\"\n        with patch('agentcube.services.agentcube_provider.AgentCubeProvider') as MockProvider:\n            mock_provider_instance = MagicMock()\n            mock_provider_instance.deploy_agent_runtime.return_value = {\n                \"status\": \"created\",\n                \"agent_name\": \"integration-test-agent\",\n                \"namespace\": \"default\",\n            }\n            mock_provider_instance.get_agent_runtime_status.return_value = {\n                \"status\": \"running\",\n                \"agent_endpoint\": \"http://agent:8080\",\n            }\n            MockProvider.return_value = mock_provider_instance\n\n            runtime = PublishRuntime(provider=\"agentcube\")\n            \n            with patch.object(runtime, '_prepare_image_for_publishing', return_value=\"test:latest\"):\n                result = runtime.publish(full_workspace, image_url=\"test:latest\")\n\n            assert result[\"agent_name\"] == \"integration-test-agent\"\n            assert result[\"deployment_type\"] == \"AgentRuntime\"\n\n    def test_full_publish_flow_k8s_mocked(self, full_workspace):\n        \"\"\"Test full publish flow to K8s with mocked providers.\"\"\"\n        with patch('agentcube.services.k8s_provider.KubernetesProvider') as MockProvider:\n            mock_provider_instance = MagicMock()\n            mock_provider_instance.deploy_agent.return_value = {\n                \"deployment_name\": \"integration-test-agent\",\n                \"service_name\": \"integration-test-agent\",\n                \"node_port\": 30080,\n                \"service_url\": \"http://localhost:30080\",\n            }\n            mock_provider_instance.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"ready_replicas\": 1,\n            }\n            MockProvider.return_value = mock_provider_instance\n\n            runtime = PublishRuntime(provider=\"k8s\")\n            \n            result = runtime.publish(full_workspace, image_url=\"test:latest\")\n\n            assert result[\"agent_name\"] == \"integration-test-agent\"\n            assert result[\"deployment_type\"] == \"Kubernetes\"\n            assert result[\"node_port\"] == 30080\n","after":"\"\"\"Tests for PublishRuntime.\"\"\"\n\nfrom __future__ import annotations\n\nimport tempfile\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\nimport pytest\nimport yaml\n\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass TestPublishRuntimeInit:\n    \"\"\"Test PublishRuntime initialization.\"\"\"\n\n    def test_init_default(self):\n        \"\"\"Test default initialization.\"\"\"\n        runtime = PublishRuntime()\n        assert runtime.verbose is False\n        assert runtime.provider == \"agentcube\"\n        assert runtime.metadata_service is not None\n        assert runtime.docker_service is not None\n\n    def test_init_with_options(self):\n        \"\"\"Test initialization with options.\"\"\"\n        runtime = PublishRuntime(verbose=True, provider=\"k8s\")\n        assert runtime.verbose is True\n        assert runtime.provider == \"k8s\"\n\n\nclass TestPublishRuntimePublish:\n    \"\"\"Test PublishRuntime.publish method.\"\"\"\n\n    @pytest.fixture\n    def packaged_workspace(self):\n        \"\"\"Create a temporary packaged workspace.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"\"\"\nfrom flask import Flask\napp = Flask(__name__)\n\n@app.route(\"/health\")\ndef health():\n    return {\"status\": \"healthy\"}\n\nif __name__ == \"__main__\":\n    app.run(host=\"0.0.0.0\", port=8080)\n\"\"\")\n            (workspace / \"requirements.txt\").write_text(\"flask>=2.0.0\\n\")\n\n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n                build_mode=\"local\",\n                workload_manager_url=\"http://workload-manager:8080\",\n                router_url=\"http://router:8080\",\n            )\n\n            metadata_service = MetadataService()\n            metadata_service.save_metadata(workspace, metadata)\n\n            yield workspace\n\n    def test_publish_to_agentcube(self, packaged_workspace):\n        \"\"\"Test publishing to AgentCube provider.\"\"\"\n        with patch.object(PublishRuntime, '_publish_cr_to_k8s') as mock_publish:\n            mock_publish.return_value = {\n                \"agent_name\": \"test-agent\",\n                \"agent_id\": \"test-agent\",\n                \"deployment_type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n                \"image_url\": \"test-agent:latest\",\n                \"status\": \"running\",\n                \"endpoint\": \"http://test-agent:8080\",\n                \"router_url\": \"http://router:8080\",\n                \"workload_manager_url\": \"http://workload-manager:8080\",\n            }\n\n            runtime = PublishRuntime(provider=\"agentcube\")\n            with patch.object(runtime, '_prepare_image_for_publishing', return_value=\"test:latest\"):\n                result = runtime.publish(packaged_workspace)\n\n            assert result[\"agent_name\"] == \"test-agent\"\n            assert result[\"deployment_type\"] == \"AgentRuntime\"\n            assert result[\"status\"] == \"running\"\n\n    def test_publish_to_k8s(self, packaged_workspace):\n        \"\"\"Test publishing to standard Kubernetes provider.\"\"\"\n        with patch.object(PublishRuntime, '_publish_k8s') as mock_publish:\n            mock_publish.return_value = {\n                \"agent_name\": \"test-agent\",\n                \"agent_id\": \"test-agent\",\n                \"deployment_type\": \"Kubernetes\",\n                \"namespace\": \"default\",\n                \"image_url\": \"test-agent:latest\",\n                \"deployment_name\": \"test-agent\",\n                \"service_name\": \"test-agent\",\n                \"node_port\": 30080,\n                \"service_url\": \"http://localhost:30080\",\n                \"replicas\": 1,\n                \"status\": \"running\",\n            }\n\n            runtime = PublishRuntime(provider=\"k8s\")\n            result = runtime.publish(packaged_workspace, image_url=\"test:latest\")\n\n            assert result[\"agent_name\"] == \"test-agent\"\n            assert result[\"deployment_type\"] == \"Kubernetes\"\n            assert result[\"node_port\"] == 30080\n\n    def test_publish_unsupported_provider(self, packaged_workspace):\n        \"\"\"Test publishing with unsupported provider.\"\"\"\n        runtime = PublishRuntime(provider=\"unsupported\")\n        with pytest.raises(ValueError, match=\"Unsupported provider: unsupported\"):\n            with patch.object(runtime, '_prepare_image_for_publishing', return_value=\"test:latest\"):\n                runtime.publish(packaged_workspace)\n\n    def test_publish_with_option_overrides(self, packaged_workspace):\n        \"\"\"Test publishing with CLI option overrides.\"\"\"\n        with patch.object(PublishRuntime, '_publish_cr_to_k8s') as mock_publish:\n            mock_publish.return_value = {\n                \"agent_name\": \"test-agent\",\n                \"agent_id\": \"test-agent\",\n                \"deployment_type\": \"AgentRuntime\",\n                \"namespace\": \"production\",\n                \"image_url\": \"test-agent:v1.0.0\",\n                \"status\": \"running\",\n            }\n\n            runtime = PublishRuntime(provider=\"agentcube\")\n            with patch.object(runtime, '_prepare_image_for_publishing', return_value=\"test:latest\"):\n                result = runtime.publish(\n                    packaged_workspace,\n                    version=\"v1.0.0\",\n                    description=\"Updated description\",\n                    namespace=\"production\",\n                )\n\n            assert result[\"namespace\"] == \"production\"\n\n    def test_publish_agentcube_missing_urls(self, packaged_workspace):\n        \"\"\"Test AgentCube publish with missing required URLs.\"\"\"\n        runtime = PublishRuntime(provider=\"agentcube\")\n        \n        metadata_no_urls = AgentMetadata(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=8080,\n            build_mode=\"cloud\",\n        )\n        metadata_service = MetadataService()\n        metadata_service.save_metadata(packaged_workspace, metadata_no_urls)\n        \n        with pytest.raises(ValueError, match=\"router_url and 'workload_manager_url\"):\n            runtime.publish(packaged_workspace, image_url=\"test:latest\")\n\n    def test_publish_k8s_invalid_node_port(self, packaged_workspace):\n        \"\"\"Test K8s publish with invalid NodePort.\"\"\"\n        runtime = PublishRuntime(provider=\"k8s\")\n        \n        with pytest.raises(ValueError, match=\"NodePort must be between\"):\n            runtime.publish(packaged_workspace, image_url=\"test:latest\", node_port=8080)\n\n\nclass TestPublishRuntimePrepareImage:\n    \"\"\"Test image preparation methods.\"\"\"\n\n    def test_prepare_local_image_with_url(self):\n        \"\"\"Test local image preparation with provided URL.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            runtime = PublishRuntime()\n            \n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                build_mode=\"local\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n            \n            result = runtime._prepare_image_for_publishing(\n                workspace, metadata, {\"image_url\": \"registry.io/test-agent:latest\"}\n            )\n            \n            assert result == \"registry.io/test-agent:latest\"\n\n    def test_prepare_cloud_image_with_url(self):\n        \"\"\"Test cloud image preparation with provided URL.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            runtime = PublishRuntime()\n            \n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                build_mode=\"cloud\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n            \n            result = runtime._prepare_image_for_publishing(\n                workspace, metadata, {\"image_url\": \"cloud-registry.io/test-agent:v1\"}\n            )\n            \n            assert result == \"cloud-registry.io/test-agent:v1\"\n\n    def test_prepare_cloud_image_missing_url(self):\n        \"\"\"Test cloud image preparation without URL raises error.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            runtime = PublishRuntime()\n            \n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                build_mode=\"cloud\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n            \n            with pytest.raises(ValueError, match=\"Cloud build mode requires --image-url\"):\n                runtime._prepare_image_for_publishing(workspace, metadata, {})\n\n\nclass TestPublishRuntimeBuildEnvVars:\n    \"\"\"Test environment variable building.\"\"\"\n\n    def test_build_env_vars_complete(self):\n        \"\"\"Test building complete environment variables.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            workload_manager_url=\"http://wm:8080\",\n            router_url=\"http://router:8080\",\n            agent_endpoint=\"http://endpoint:8080\",\n        )\n        \n        env_vars = runtime._build_agent_env_vars(metadata)\n        \n        assert env_vars[\"WORKLOAD_MANAGER_URL\"] == \"http://wm:8080\"\n        assert env_vars[\"ROUTER_URL\"] == \"http://router:8080\"\n        assert env_vars[\"AGENT_ENDPOINT\"] == \"http://endpoint:8080\"\n\n    def test_build_env_vars_empty(self):\n        \"\"\"Test building empty environment variables.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n        )\n        \n        env_vars = runtime._build_agent_env_vars(metadata)\n        \n        assert env_vars == {}\n\n\nclass TestPublishRuntimeUpdateMetadata:\n    \"\"\"Test metadata update functionality.\"\"\"\n\n    def test_update_publish_metadata(self):\n        \"\"\"Test updating metadata after publish.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            \n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n            \n            metadata_service = MetadataService()\n            metadata_service.save_metadata(workspace, metadata)\n            \n            runtime = PublishRuntime()\n            \n            agent_info = {\n                \"agent_id\": \"test-agent-id\",\n                \"session_id\": \"session-123\",\n                \"endpoint\": \"http://test-agent:8080\",\n                \"image_url\": \"test-agent:latest\",\n                \"deployment_type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n            \n            runtime._update_publish_metadata(workspace, agent_info)\n            \n            updated_metadata = metadata_service.load_metadata(workspace)\n            assert updated_metadata.agent_id == \"test-agent-id\"\n            assert updated_metadata.session_id == \"session-123\"\n            assert updated_metadata.agent_endpoint == \"http://test-agent:8080\"\n            assert updated_metadata.image is not None\n            assert updated_metadata.image[\"url\"] == \"test-agent:latest\"\n\n\nclass TestPublishRuntimeValidation:\n    \"\"\"Test validation methods.\"\"\"\n\n    def test_validate_prerequisites_local_no_docker(self):\n        \"\"\"Test validation fails when Docker is not available.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            build_mode=\"local\",\n        )\n        \n        with patch.object(runtime.docker_service, 'check_docker_available', return_value=False):\n            with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n                runtime._validate_publish_prerequisites(metadata, {})\n\n    def test_validate_prerequisites_agentcube_missing_urls(self):\n        \"\"\"Test AgentCube validation fails with missing URLs.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            build_mode=\"cloud\",\n        )\n        \n        with pytest.raises(ValueError, match=\"router_url and 'workload_manager_url\"):\n            runtime._validate_publish_prerequisites(metadata, {})\n\n    def test_validate_prerequisites_cloud_missing_image_url(self):\n        \"\"\"Test cloud validation fails without image URL.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            build_mode=\"cloud\",\n        )\n        \n        with pytest.raises(ValueError, match=\"Cloud build mode requires --image-url\"):\n            runtime._validate_publish_prerequisites(metadata, {})\n\n    def test_validate_prerequisites_pass(self):\n        \"\"\"Test validation passes with correct config.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            build_mode=\"cloud\",\n            workload_manager_url=\"http://wm:8080\",\n            router_url=\"http://router:8080\",\n        )\n        \n        with patch.object(runtime.docker_service, 'check_docker_available', return_value=True):\n            runtime._validate_publish_prerequisites(metadata, {\"image_url\": \"test:latest\"})\n\n\nclass TestPublishRuntimeGenerateSessionId:\n    \"\"\"Test session ID generation.\"\"\"\n\n    def test_generate_session_id_format(self):\n        \"\"\"Test session ID format.\"\"\"\n        runtime = PublishRuntime()\n        session_id = runtime._generate_session_id()\n        \n        assert len(session_id) == 32\n        assert session_id.isalnum()\n\n    def test_generate_session_id_unique(self):\n        \"\"\"Test session IDs are unique.\"\"\"\n        runtime = PublishRuntime()\n        \n        ids = [runtime._generate_session_id() for _ in range(100)]\n        \n        assert len(set(ids)) == 100\n\n\nclass TestPublishRuntimeApplyOptions:\n    \"\"\"Test applying publish options.\"\"\"\n\n    def test_apply_publish_options(self):\n        \"\"\"Test applying publish options to metadata.\"\"\"\n        runtime = PublishRuntime()\n        \n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            port=8080,\n        )\n        \n        options = {\n            \"version\": \"v1.0.0\",\n            \"description\": \"Test description\",\n            \"region\": \"us-west-2\",\n        }\n        \n        runtime._apply_publish_options(metadata, options)\n        \n        assert metadata.version == \"v1.0.0\"\n\n\nclass TestPublishRuntimeIntegration:\n    \"\"\"Integration tests for PublishRuntime.\"\"\"\n\n    @pytest.fixture\n    def full_workspace(self):\n        \"\"\"Create a complete workspace for integration testing.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            (workspace / \"main.py\").write_text(\"print('hello')\")\n            (workspace / \"requirements.txt\").write_text(\"flask>=2.0.0\\n\")\n\n            metadata = AgentMetadata(\n                agent_name=\"integration-test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n                build_mode=\"cloud\",\n                workload_manager_url=\"http://wm:8080\",\n                router_url=\"http://router:8080\",\n            )\n\n            MetadataService().save_metadata(workspace, metadata)\n            yield workspace\n\n    def test_full_publish_flow_agentcube_mocked(self, full_workspace):\n        \"\"\"Test full publish flow to AgentCube with mocked providers.\"\"\"\n        with patch('agentcube.services.agentcube_provider.AgentCubeProvider') as MockProvider:\n            mock_provider_instance = MagicMock()\n            mock_provider_instance.deploy_agent_runtime.return_value = {\n                \"status\": \"created\",\n                \"agent_name\": \"integration-test-agent\",\n                \"namespace\": \"default\",\n            }\n            mock_provider_instance.get_agent_runtime_status.return_value = {\n                \"status\": \"running\",\n                \"agent_endpoint\": \"http://agent:8080\",\n            }\n            MockProvider.return_value = mock_provider_instance\n\n            runtime = PublishRuntime(provider=\"agentcube\")\n            \n            with patch.object(runtime, '_prepare_image_for_publishing', return_value=\"test:latest\"):\n                result = runtime.publish(full_workspace, image_url=\"test:latest\")\n\n            assert result[\"agent_name\"] == \"integration-test-agent\"\n            assert result[\"deployment_type\"] == \"AgentRuntime\"\n\n    def test_full_publish_flow_k8s_mocked(self, full_workspace):\n        \"\"\"Test full publish flow to K8s with mocked providers.\"\"\"\n        with patch('agentcube.services.k8s_provider.KubernetesProvider') as MockProvider:\n            mock_provider_instance = MagicMock()\n            mock_provider_instance.deploy_agent.return_value = {\n                \"deployment_name\": \"integration-test-agent\",\n                \"service_name\": \"integration-test-agent\",\n                \"node_port\": 30080,\n                \"service_url\": \"http://localhost:30080\",\n            }\n            mock_provider_instance.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"ready_replicas\": 1,\n            }\n            MockProvider.return_value = mock_provider_instance\n\n            runtime = PublishRuntime(provider=\"k8s\")\n            \n            result = runtime.publish(full_workspace, image_url=\"test:latest\")\n\n            assert result[\"agent_name\"] == \"integration-test-agent\"\n            assert result[\"deployment_type\"] == \"Kubernetes\"\n            assert result[\"node_port\"] == 30080\n","additions":3,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/tests/test_publish_runtime.py","time":{"start":1775871873590,"end":1775871874293}}}}
