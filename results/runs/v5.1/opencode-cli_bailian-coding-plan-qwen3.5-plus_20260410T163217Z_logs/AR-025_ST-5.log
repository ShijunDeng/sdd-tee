{"type":"tool_use","timestamp":1775872045736,"sessionID":"ses_285cc90bdffeFYBHSMMEeHfoxo","part":{"id":"prt_d7a38ed39001LlGI5MV390ehAU","messageID":"msg_d7a38d4c2001fV08h6qmcS9FgO","sessionID":"ses_285cc90bdffeFYBHSMMEeHfoxo","type":"tool","tool":"read","callID":"toolu_b1ef8ee83697469693f21850","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Agent metadata service and models.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from pathlib import Path\n6: from typing import Any, Dict, Optional\n7: \n8: import yaml\n9: from pydantic import BaseModel, Field, field_validator\n10: \n11: \n12: class AgentMetadata(BaseModel):\n13:     \"\"\"Agent metadata model for agent_metadata.yaml.\"\"\"\n14: \n15:     model_config = {\"extra\": \"allow\", \"validate_assignment\": True}\n16: \n17:     agent_name: str\n18:     description: Optional[str] = None\n19:     language: str = \"python\"\n20:     entrypoint: Optional[str] = None\n21:     port: int = 8080\n22:     build_mode: str = \"local\"\n23:     region: Optional[str] = None\n24:     version: Optional[str] = None\n25:     image: Optional[Dict[str, Any]] = None\n26:     auth: Optional[Dict[str, Any]] = None\n27:     requirements_file: Optional[str] = \"requirements.txt\"\n28:     registry_url: Optional[str] = \"\"\n29:     registry_username: Optional[str] = \"\"\n30:     registry_password: Optional[str] = \"\"\n31:     agent_endpoint: Optional[str] = None\n32:     workload_manager_url: Optional[str] = None\n33:     router_url: Optional[str] = None\n34:     readiness_probe_path: Optional[str] = None\n35:     readiness_probe_port: Optional[int] = None\n36:     agent_id: Optional[str] = None\n37:     session_id: Optional[str] = None\n38:     k8s_deployment: Optional[Dict[str, Any]] = None\n39: \n40:     @field_validator(\"language\")\n41:     @classmethod\n42:     def validate_language(cls, v: str) -> str:\n43:         if v.lower() not in [\"python\", \"java\"]:\n44:             raise ValueError(f\"Language must be 'python' or 'java', got '{v}'\")\n45:         return v.lower()\n46: \n47:     @field_validator(\"build_mode\")\n48:     @classmethod\n49:     def validate_build_mode(cls, v: str) -> str:\n50:         if v.lower() not in [\"local\", \"cloud\"]:\n51:             raise ValueError(f\"Build mode must be 'local' or 'cloud', got '{v}'\")\n52:         return v.lower()\n53: \n54:     @field_validator(\"port\")\n55:     @classmethod\n56:     def validate_port(cls, v: int) -> int:\n57:         if not 1 <= v <= 65535:\n58:             raise ValueError(f\"Port must be between 1 and 65535, got '{v}'\")\n59:         return v\n60: \n61: \n62: class MetadataService:\n63:     \"\"\"Service for loading and saving agent metadata.\"\"\"\n64: \n65:     METADATA_FILES = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n66: \n67:     def __init__(self, verbose: bool = False) -> None:\n68:         self.verbose = verbose\n69: \n70:     def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n71:         \"\"\"Load metadata from workspace directory.\"\"\"\n72:         for filename in self.METADATA_FILES:\n73:             metadata_file = workspace_path / filename\n74:             if metadata_file.exists():\n75:                 with open(metadata_file, \"r\") as f:\n76:                     data = yaml.safe_load(f)\n77:                 return AgentMetadata(**data)\n78: \n79:         raise FileNotFoundError(\n80:             f\"No metadata file found. Expected one of: {', '.join(self.METADATA_FILES)}\"\n81:         )\n82: \n83:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n84:         \"\"\"Save metadata to workspace directory.\"\"\"\n85:         metadata_file = workspace_path / \"agent_metadata.yaml\"\n86:         with open(metadata_file, \"w\") as f:\n87:             yaml.dump(\n88:                 metadata.model_dump(exclude_none=True),\n89:                 f,\n90:                 default_flow_style=False,\n91:                 indent=2,\n92:                 sort_keys=False,\n93:             )\n94: \n95:     def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n96:         \"\"\"Update metadata with provided fields.\"\"\"\n97:         metadata = self.load_metadata(workspace_path)\n98:         updated_data = metadata.model_dump()\n99:         updated_data.update(updates)\n100:         updated_metadata = AgentMetadata(**updated_data)\n101:         self.save_metadata(workspace_path, updated_metadata)\n102:         return updated_metadata\n103: \n104:     def validate_workspace(self, workspace_path: Path) -> bool:\n105:         \"\"\"Validate workspace structure.\"\"\"\n106:         if not workspace_path.exists():\n107:             raise FileNotFoundError(f\"Workspace directory does not exist: {workspace_path}\")\n108:         \n109:         if not workspace_path.is_dir():\n110:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n111:         \n112:         return True\n113: \n114:     def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n115:         \"\"\"Validate Python workspace.\"\"\"\n116:         py_files = list(workspace_path.glob(\"*.py\"))\n117:         if not py_files:\n118:             raise ValueError(\"No Python files found in workspace\")\n119: \n120:     def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n121:         \"\"\"Validate Java workspace.\"\"\"\n122:         pom_xml = workspace_path / \"pom.xml\"\n123:         if not pom_xml.exists():\n124:             raise ValueError(\"pom.xml not found in workspace\")\n\n(End of file - total 124 lines)\n</content>","metadata":{"preview":"\"\"\"Agent metadata service and models.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Agent metadata model for agent_metadata.yaml.\"\"\"\n\n    model_config = {\"extra\": \"allow\", \"validate_assignment\": True}\n\n    agent_name: str\n    description: Optional[str] = None\n    language: str = \"python\"\n    entrypoint: Optional[str] = None","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-qwen3.5-plus_20260410T163217Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775872045726,"end":1775872045735}}}}
