{"type":"tool_use","timestamp":1775884967171,"sessionID":"ses_28504be3fffeAI67laka6We2j7","part":{"id":"prt_d7afe13da001Vf6MhRnFPndGDh","messageID":"msg_d7afdeddf001RE19FMCaudfctV","sessionID":"ses_28504be3fffeAI67laka6We2j7","type":"tool","tool":"read","callID":"call_21bdd1381eaf491789f90e57","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/example/pcap-analyzer/pcap_analyzer.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/example/pcap-analyzer/pcap_analyzer.py</path>\n<type>file</type>\n<content>\n1: import os\n2: import sys\n3: import time\n4: import tempfile\n5: from typing import Any, Dict, List, Optional\n6: \n7: from fastapi import FastAPI, UploadFile, File, Form, HTTPException\n8: from pydantic import BaseModel\n9: import uvicorn\n10: \n11: from langchain_openai import ChatOpenAI\n12: from langgraph.prebuilt import create_react_agent\n13: from langchain_core.messages import HumanMessage, AIMessage\n14: \n15: # Configuration constants\n16: API_KEY = os.environ.get(\"OPENAI_API_KEY\")\n17: API_BASE_URL = os.environ.get(\"OPENAI_API_BASE\", \"https://api.siliconflow.cn/v1\")\n18: MODEL_NAME = os.environ.get(\"OPENAI_MODEL\", \"Qwen/QwQ-32B\")\n19: CODEINTERPRETER_NAME = os.environ.get(\"CODEINTERPRETER_NAME\", \"my-interpreter\")\n20: SANDBOX_NAMESPACE = os.environ.get(\"SANDBOX_NAMESPACE\", \"default\")\n21: SANDBOX_WARMUP_SEC = int(os.environ.get(\"SANDBOX_WARMUP_SEC\", \"5\"))\n22: SERVER_HOST = \"0.0.0.0\"\n23: SERVER_PORT = 8000\n24: SERVER_RELOAD = True\n25: \n26: # Global agent instances\n27: PLANNER = None\n28: REPORTER = None\n29: \n30: \n31: class SandboxRunner:\n32:     \"\"\"Executes commands and manages files in an AgentCube sandbox.\"\"\"\n33: \n34:     def __init__(\n35:         self,\n36:         name: str = \"my-interpreter\",\n37:         namespace: str = \"default\",\n38:         warmup_sec: int = 5,\n39:     ):\n40:         self.name = name\n41:         self.namespace = namespace\n42:         self.warmup_sec = warmup_sec\n43:         self.client = None\n44: \n45:     def _ensure_client(self):\n46:         if self.client is None:\n47:             from agentcube.code_interpreter import CodeInterpreterClient\n48:             self.client = CodeInterpreterClient(\n49:                 name=self.name,\n50:                 namespace=self.namespace,\n51:             )\n52:             if self.warmup_sec > 0:\n53:                 time.sleep(self.warmup_sec)\n54: \n55:     def upload_file(self, local_path: str, remote_path: str) -> bool:\n56:         try:\n57:             self._ensure_client()\n58:             self.client.upload_file(local_path, remote_path)\n59:             return True\n60:         except Exception:\n61:             return False\n62: \n63:     def upload_bytes(self, data: bytes, remote_path: str) -> bool:\n64:         try:\n65:             self._ensure_client()\n66:             with tempfile.NamedTemporaryFile(delete=False, mode=\"wb\") as f:\n67:                 f.write(data)\n68:                 tmp_path = f.name\n69:             self.client.upload_file(tmp_path, remote_path)\n70:             os.unlink(tmp_path)\n71:             return True\n72:         except Exception:\n73:             return False\n74: \n75:     def run(self, command: str) -> Dict[str, Any]:\n76:         self._ensure_client()\n77:         try:\n78:             output = self.client.execute_command(command)\n79:             return {\n80:                 \"success\": True,\n81:                 \"output\": output,\n82:                 \"error\": None,\n83:                 \"exit_code\": 0,\n84:             }\n85:         except Exception as e:\n86:             return {\n87:                 \"success\": False,\n88:                 \"output\": None,\n89:                 \"error\": str(e),\n90:                 \"exit_code\": 1,\n91:             }\n92: \n93:     def stop(self):\n94:         if self.client is not None:\n95:             try:\n96:                 self.client.stop()\n97:             except Exception:\n98:                 pass\n99:             self.client = None\n100: \n101: \n102: def build_react_agent(llm, system_prompt: str):\n103:     \"\"\"Build a ReAct agent with the given LLM and system prompt.\"\"\"\n104:     return create_react_agent(llm, [], prompt=system_prompt)\n105: \n106: \n107: def invoke_react_agent(agent, user_text: str) -> str:\n108:     \"\"\"Invoke a ReAct agent with user text and return the response.\"\"\"\n109:     response = agent.invoke({\"messages\": [HumanMessage(content=user_text)]})\n110:     if \"messages\" in response:\n111:         last_msg = response[\"messages\"][-1]\n112:         if hasattr(last_msg, \"content\"):\n113:             return last_msg.content\n114:     return str(response)\n115: \n116: \n117: def build_planner_agent(llm):\n118:     \"\"\"Build a planner agent for generating analysis scripts.\"\"\"\n119:     system_prompt = (\n120:         \"You are a PCAP analysis planner. Given a description of a PCAP file, \"\n121:         \"generate a Python script that analyzes the PCAP file using scapy or similar tools. \"\n122:         \"The script should read the PCAP file from /workspace/input.pcap, \"\n123:         \"perform analysis, and print results to stdout. \"\n124:         \"Output ONLY the Python script, no explanations.\"\n125:     )\n126:     return build_react_agent(llm, system_prompt)\n127: \n128: \n129: def build_reporter_agent(llm):\n130:     \"\"\"Build a reporter agent for generating analysis reports.\"\"\"\n131:     system_prompt = (\n132:         \"You are a PCAP analysis reporter. Given execution results from a PCAP analysis script, \"\n133:         \"generate a comprehensive report summarizing the findings. \"\n134:         \"Include key statistics, notable patterns, and any anomalies detected.\"\n135:     )\n136:     return build_react_agent(llm, system_prompt)\n137: \n138: \n139: def _plan_script(agent, pcap_local_path: str) -> str:\n140:     \"\"\"Generate an analysis script using the planner agent.\"\"\"\n141:     prompt = (\n142:         f\"Generate a Python script to analyze the PCAP file located at {pcap_local_path}. \"\n143:         \"The script should read the PCAP, extract key information (protocols, IPs, ports, packet sizes), \"\n144:         \"and print a summary. Output only the script code.\"\n145:     )\n146:     return invoke_react_agent(agent, prompt)\n147: \n148: \n149: def _repair_script(agent, prev_script: str, results: List[Dict[str, Any]]) -> str:\n150:     \"\"\"Repair a failed script using the planner agent.\"\"\"\n151:     error_info = \"\"\n152:     for r in results:\n153:         if r.get(\"error\"):\n154:             error_info += f\"\\nError: {r['error']}\"\n155:     prompt = (\n156:         f\"The following script failed during execution:\\n\\n{prev_script}\\n\\n\"\n157:         f\"Errors encountered:{error_info}\\n\\n\"\n158:         \"Please fix the script and output only the corrected Python code.\"\n159:     )\n160:     return invoke_react_agent(agent, prompt)\n161: \n162: \n163: def _execute_once_in_runner(\n164:     runner: SandboxRunner, pcap_local_path: str, script: str\n165: ) -> List[Dict[str, Any]]:\n166:     \"\"\"Upload PCAP and execute the script in the sandbox.\"\"\"\n167:     results = []\n168: \n169:     runner.upload_file(pcap_local_path, \"/workspace/input.pcap\")\n170: \n171:     with tempfile.NamedTemporaryFile(\n172:         delete=False, mode=\"w\", suffix=\".py\"\n173:     ) as f:\n174:         f.write(script)\n175:         script_path = f.name\n176: \n177:     try:\n178:         runner.upload_file(script_path, \"/workspace/analyze.py\")\n179:         result = runner.run(\"python3 /workspace/analyze.py\")\n180:         results.append(result)\n181:     finally:\n182:         os.unlink(script_path)\n183: \n184:     return results\n185: \n186: \n187: def _analyze_with_retries(\n188:     planner,\n189:     reporter,\n190:     runner: SandboxRunner,\n191:     pcap_local_path: str,\n192:     max_retries: int = 2,\n193: ) -> Dict[str, Any]:\n194:     \"\"\"Run analysis with planning, execution, and repair retries.\"\"\"\n195:     script = _plan_script(planner, pcap_local_path)\n196:     results = []\n197: \n198:     for attempt in range(max_retries + 1):\n199:         try:\n200:             results = _execute_once_in_runner(runner, pcap_local_path, script)\n201:             all_success = all(r.get(\"success\") for r in results)\n202:             if all_success:\n203:                 break\n204:         except Exception:\n205:             pass\n206: \n207:         if attempt < max_retries:\n208:             script = _repair_script(planner, script, results)\n209: \n210:     report = _report(reporter, results)\n211: \n212:     return {\n213:         \"script\": script,\n214:         \"results\": results,\n215:         \"report\": report,\n216:     }\n217: \n218: \n219: def _report(agent, results: List[Dict[str, Any]]) -> str:\n220:     \"\"\"Generate a report from execution results using the reporter agent.\"\"\"\n221:     results_str = \"\\n\".join(str(r) for r in results)\n222:     prompt = (\n223:         f\"Based on the following PCAP analysis execution results, generate a report:\\n\\n{results_str}\"\n224:     )\n225:     return invoke_react_agent(agent, prompt)\n226: \n227: \n228: class AnalyzeResponse(BaseModel):\n229:     script: str\n230:     results: List[Dict[str, Any]]\n231:     report: str\n232: \n233: \n234: app = FastAPI(title=\"PCAP Analyzer ‚Äî Env-Only Config\")\n235: \n236: \n237: @app.on_event(\"startup\")\n238: async def on_startup():\n239:     global PLANNER, REPORTER\n240: \n241:     if not API_KEY:\n242:         raise ValueError(\n243:             \"OPENAI_API_KEY environment variable is required. \"\n244:             \"Please set it before starting the application.\"\n245:         )\n246: \n247:     llm = ChatOpenAI(\n248:         openai_api_key=API_KEY,\n249:         openai_api_base=API_BASE_URL,\n250:         model_name=MODEL_NAME,\n251:     )\n252: \n253:     PLANNER = build_planner_agent(llm)\n254:     REPORTER = build_reporter_agent(llm)\n255: \n256: \n257: @app.post(\"/analyze\", response_model=AnalyzeResponse)\n258: async def analyze_endpoint(\n259:     pcap_file: UploadFile = File(None),\n260:     pcap_path: str = Form(None),\n261: ):\n262:     if pcap_file is None and pcap_path is None:\n263:         raise HTTPException(\n264:             status_code=400,\n265:             detail=\"Either pcap_file (upload) or pcap_path (form field) must be provided\",\n266:         )\n267: \n268:     local_path = None\n269:     try:\n270:         if pcap_file is not None:\n271:             with tempfile.NamedTemporaryFile(\n272:                 delete=False, suffix=\".pcap\"\n273:             ) as f:\n274:                 content = await pcap_file.read()\n275:                 f.write(content)\n276:                 local_path = f.name\n277:         else:\n278:             local_path = pcap_path\n279: \n280:         runner = SandboxRunner(\n281:             name=CODEINTERPRETER_NAME,\n282:             namespace=SANDBOX_NAMESPACE,\n283:             warmup_sec=SANDBOX_WARMUP_SEC,\n284:         )\n285: \n286:         try:\n287:             analysis = _analyze_with_retries(\n288:                 planner=PLANNER,\n289:                 reporter=REPORTER,\n290:                 runner=runner,\n291:                 pcap_local_path=local_path,\n292:                 max_retries=2,\n293:             )\n294:         finally:\n295:             runner.stop()\n296: \n297:         return AnalyzeResponse(\n298:             script=analysis[\"script\"],\n299:             results=analysis[\"results\"],\n300:             report=analysis[\"report\"],\n301:         )\n302: \n303:     except HTTPException:\n304:         raise\n305:     except Exception as e:\n306:         raise HTTPException(status_code=500, detail=str(e))\n307:     finally:\n308:         if pcap_file is not None and local_path is not None:\n309:             try:\n310:                 os.unlink(local_path)\n311:             except OSError:\n312:                 pass\n313: \n314: \n315: if __name__ == \"__main__\":\n316:     uvicorn.run(\n317:         \"pcap_analyzer:app\",\n318:         host=SERVER_HOST,\n319:         port=SERVER_PORT,\n320:         reload=SERVER_RELOAD,\n321:     )\n\n(End of file - total 321 lines)\n</content>","metadata":{"preview":"import os\nimport sys\nimport time\nimport tempfile\nfrom typing import Any, Dict, List, Optional\n\nfrom fastapi import FastAPI, UploadFile, File, Form, HTTPException\nfrom pydantic import BaseModel\nimport uvicorn\n\nfrom langchain_openai import ChatOpenAI\nfrom langgraph.prebuilt import create_react_agent\nfrom langchain_core.messages import HumanMessage, AIMessage\n\n# Configuration constants\nAPI_KEY = os.environ.get(\"OPENAI_API_KEY\")\nAPI_BASE_URL = os.environ.get(\"OPENAI_API_BASE\", \"https://api.siliconflow.cn/v1\")\nMODEL_NAME = os.environ.get(\"OPENAI_MODEL\", \"Qwen/QwQ-32B\")\nCODEINTERPRETER_NAME = os.environ.get(\"CODEINTERPRETER_NAME\", \"my-interpreter\")\nSANDBOX_NAMESPACE = os.environ.get(\"SANDBOX_NAMESPACE\", \"default\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/example/pcap-analyzer/pcap_analyzer.py","time":{"start":1775884967162,"end":1775884967169}}}}
