\trequire.NoError(t, err)\n233: \n234: \tvar resp SandboxStatusResponse\n235: \terr = json.Unmarshal(dataBytes, &resp)\n236: \trequire.NoError(t, err)\n237: \n238: \tassert.Equal(t, \"session-123\", resp.SessionID)\n239: \tassert.Equal(t, \"sandbox-abc\", resp.SandboxName)\n240: \tassert.Equal(t, \"running\", resp.Status)\n241: \tassert.False(t, resp.IsExpired)\n242: \tassert.NotNil(t, resp.TimeToExpiry)\n243: }\n244: \n245: func TestLifecycleManager_ListSandboxes_Empty(t *testing.T) {\n246: \tgin.SetMode(gin.ReleaseMode)\n247: \tw := httptest.NewRecorder()\n248: \tc, _ := gin.CreateTestContext(w)\n249: \tc.Request = httptest.NewRequest(http.MethodGet, \"/sandboxes\", nil)\n250: \n251: \tstore := newMockStore()\n252: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n253: \n254: \tmgr.ListSandboxes(c)\n255: \n256: \tassert.Equal(t, http.StatusOK, w.Code)\n257: \n258: \tvar wrapper response.SuccessResponse\n259: \terr := json.Unmarshal(w.Body.Bytes(), &wrapper)\n260: \trequire.NoError(t, err)\n261: \n262: \tdataBytes, err := json.Marshal(wrapper.Data)\n263: \trequire.NoError(t, err)\n264: \n265: \tvar resp ListSandboxesResponse\n266: \terr = json.Unmarshal(dataBytes, &resp)\n267: \trequire.NoError(t, err)\n268: \n269: \tassert.Equal(t, 0, resp.Total)\n270: \tassert.Empty(t, resp.Items)\n271: }\n272: \n273: func TestLifecycleManager_ListSandboxes_WithItems(t *testing.T) {\n274: \tgin.SetMode(gin.ReleaseMode)\n275: \tw := httptest.NewRecorder()\n276: \tc, _ := gin.CreateTestContext(w)\n277: \tc.Request = httptest.NewRequest(http.MethodGet, \"/sandboxes\", nil)\n278: \n279: \tstore := newMockStore()\n280: \tctx := context.Background()\n281: \tstore.StoreSandbox(ctx, &SandboxInfo{\n282: \t\tSessionID:   \"session-1\",\n283: \t\tSandboxName: \"sandbox-1\",\n284: \t\tNamespace:   \"default\",\n285: \t\tKind:        SandboxesKind,\n286: \t\tStatus:      \"running\",\n287: \t\tCreatedAt:   time.Now(),\n288: \t\tExpiresAt:   time.Now().Add(1 * time.Hour),\n289