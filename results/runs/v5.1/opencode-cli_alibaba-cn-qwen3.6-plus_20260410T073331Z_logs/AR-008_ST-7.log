: }\n410: \n411: func TestLifecycleManager_ExtendSandboxTTL_InvalidBody(t *testing.T) {\n412: \tgin.SetMode(gin.ReleaseMode)\n413: \tw := httptest.NewRecorder()\n414: \tc, _ := gin.CreateTestContext(w)\n415: \tc.Request = httptest.NewRequest(http.MethodPost, \"/extend/session-123\", nil)\n416: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n417: \n418: \tstore := newMockStore()\n419: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n420: \n421: \tmgr.ExtendSandboxTTL(c)\n422: \n423: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n424: }\n425: \n426: func TestLifecycleManager_ExtendSandboxTTL_SessionNotFound(t *testing.T) {\n427: \tgin.SetMode(gin.ReleaseMode)\n428: \tw := httptest.NewRecorder()\n429: \tc, _ := gin.CreateTestContext(w)\n430: \tbody := `{\"extensionDuration\": 3600000000000}`\n431: \tc.Request = httptest.NewRequest(http.MethodPost, \"/extend/session-123\", bytes.NewBufferString(body))\n432: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n433: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n434: \n435: \tstore := newMockStore()\n436: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n437: \n438: \tmgr.ExtendSandboxTTL(c)\n439: \n440: \tassert.Equal(t, http.StatusNotFound, w.Code)\n441: }\n442: \n443: func TestLifecycleManager_ExtendSandboxTTL_ExpiredSandbox(t *testing.T) {\n444: \tgin.SetMode(gin.ReleaseMode)\n445: \tw := httptest.NewRecorder()\n446: \tc, _ := gin.CreateTestContext(w)\n447: \tbody := `{\"extensionDuration\": 3600000000000}`\n448: \tc.Request = httptest.NewRequest(http.MethodPost, \"/extend/session-123\", bytes.NewBufferString(body))\n449: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n450: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n451: \n452: \tstore := newMockStore()\n453: \tctx := context.Background()\n454: \tstore.StoreSandbox(ctx, &SandboxInfo{\n455: \t\tSessionID: \"session-123\",\n456: \t\tExpiresAt: time.Now().Add(-1 * time.Hour),\n457: \t})\n458: \n459: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n460: \n461: \tmgr.ExtendSandboxTTL(c)\n462: \n463: \tassert.Equal(t, http.StatusGone, w.Code)\n464: }\n465: \n466: func TestLifecycleManager_ExtendSandboxTTL_Success(t *testing.T) {\n467: \tgin.SetMode(gin.ReleaseMode)\n468: \tw := httptest.NewRecorder()\n469: \tc, _ := gin.CreateTestContext(w)\n470: \tbody := `{\"extensionDuration\": 7200000000000}`\n471: \tc.Request = httptest.NewRequest(http.MethodPost, \"/extend/session-123\", bytes.NewBufferString(body))\n472: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n473: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n474: \n475: \tstore := newMockStore()\n476: \tctx := context.Background()\n477: \tstore.StoreSandbox(ctx, &SandboxInfo{\n478: \t\tSessionID: \"session-123\",\n479: \t\tExpiresAt: time.Now().Add(1 * time.Hour),\n480: \t})\n481: \n482: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n483: \n484: \tmgr.ExtendSandboxTTL(c)\n485: \n486: \tassert.Equal(t, http.StatusOK, w.Code)\n487: \n488: \tvar wrapper response.SuccessResponse\n489: \terr := json.Unmarshal(w.Body.Bytes(), &wrapper)\n490: \trequire.NoError(t, err)\n491: \n492: \tdataBytes, err := json.Marshal(wrapper.Data)\n493: \trequire.NoError(t, err)\n494: \n495: \tvar resp ExtendTTLResponse\n496: \terr = json.Unmarshal(dataBytes, &resp)\n497: \trequire.NoError(t, err)\n498: \n499: \tassert.Equal(t, \"session-123\", resp.SessionID)\n500: \tassert.True(t, resp.NewExpiry.After(time.Now()))\n501: }\n502: \n503: func TestSandboxStatusResponse_JSONSerialization(t *testing.T) {\n504: \tnow := time.Now()\n505: \texpiresAt := now.Add(1 * time.Hour)\n506: \ttimeToExpiry := 1 * time.Hour\n507: \n508: \tresp := &SandboxStatusResponse{\n509: \t\tSessionID:    \"session-123\",\n510: \t\tSandboxName:  \"sandbox-abc\",\n511: \t\tSandboxID:    \"uid-456\",\n512: \t\tStatus:       \"running\",\n513: \t\tCreatedAt:    now,\n514: \t\tExpiresAt:    expiresAt,\n515: \t\tTimeToExpiry: &timeToExpiry,\n516: \t\tIsExpired:    false,\n517: \t\tEntryPoints: []EntryPoint{\n518: \t\t\t{Path: \"/\", Protocol: \"HTTP\", Endpoint: \"10.0.0.1:8080\"},\n519: \t\t},\n520: \t}\n521: \n522: \tdata, err := json.Marshal(resp)\n523: \trequire.NoError(t, err)\n524: \n525: \tvar decoded SandboxStatusResponse\n526: \terr = json.Unmarshal(data, &decoded)\n527: \trequire.NoError(t, err)\n528: \n529: \tassert.Equal(t, resp.SessionID, decoded.SessionID)\n530: \tassert.Equal(t, resp.IsExpired, decoded.IsExpired)\n531: \tassert.False(t, decoded.IsExpired)\n532: }\n533: \n534: func TestSandboxListItem_JSONSerialization(t *testing.T) {\n535: \tnow := time.Now()\n536: \texpiresAt := now.Add(1 * time.Hour)\n537: \ttimeToExpiry := 1 * time.Hour\n538: \n539: \titem := SandboxListItem{\n540: \t\tSessionID:    \"session-123\",\n541: \t\tSandboxName:  \"sandbox-abc\",\n542: \t\tWorkloadName: \"my-runtime\",\n543: \t\tNamespace:    \"default\",\n544: \t\tKind:         SandboxesKind,\n545: \t\tStatus:       \"running\",\n546: \t\tCreatedAt:    now,\n547: \t\tExpiresAt:    expiresAt,\n548: \t\tTimeToExpiry: &timeToExpiry,\n549: \t\tIsExpired:    false,\n550: \t}\n551: \n552: \tdata, err := json.Marshal(item)\n553: \trequire.NoError(t, err)\n554: \n555: \tvar decoded SandboxListItem\n556: \terr = json.Unmarshal(data, &decoded)\n557: \trequire.NoError(t, err)\n558: \n559: \tassert.Equal(t, item.SessionID, decoded.SessionID)\n560: \tassert.Equal(t, item.Namespace, decoded.Namespace)\n561: }\n562: \n563: func TestListSandboxesResponse_JSONSerialization(t *testing.T) {\n564: \tresp := &ListSandboxesResponse{\n565: \t\tTotal: 2,\n566: \t\tItems: []SandboxListItem{\n567: \t\t\t{SessionID: \"session-1\", SandboxName: \"sandbox-1\"},\n568: \t\t\t{SessionID: \"session-2\", SandboxName: \"sandbox-2\"},\n569: \t\t},\n570: \t}\n571: \n572: \tdata, err := json.Marshal(resp)\n573: \trequire.NoError(t, err)\n574: \n575: \tvar decoded ListSandboxesResponse\n576: \terr = json.Unmarshal(data, &decoded)\n577: \trequire.NoError(t, err)\n578: \n579: \tassert.Equal(t, 2, decoded.Total)\n580: \tassert.Len(t, decoded.Items, 2)\n581: }\n582: \n583: func TestExtendTTLResponse_JSONSerialization(t *testing.T) {\n584: \tnow := time.Now()\n585: \tresp := &ExtendTTLResponse{\n586: \t\tSessionID: \"session-123\",\n587: \t\tNewExpiry: now,\n588: \t}\n589: \n590: \tdata, err := json.Marshal(resp)\n591: \trequire.NoError(t, err)\n592: \n593: \tvar decoded ExtendTTLResponse\n594: \terr = json.Unmarshal(data, &decoded)\n595: \trequire.NoError(t, err)\n596: \n597: \tassert.Equal(t, resp.SessionID, decoded.SessionID)\n598: \tassert.True(t, resp.NewExpiry.Equal(decoded.NewExpiry))\n599: }\n600: \n601: func TestLifecycleManager_CleanupExpiredSandboxes(t *testing.T) {\n602: \tstore := newMockStore()\n603: \tctx := context.Background()\n604: \n605: \tstore.StoreSandbox(ctx, &SandboxInfo{\n606: \t\tSessionID:   \"expired-1\",\n607: \t\tSandboxName: \"sandbox-expired-1\",\n608: \t\tNamespace:   \"default\",\n609: \t\tKind:        SandboxesKind,\n610: \t\tExpiresAt:   time.Now().Add(-1 * time.Hour),\n611: \t})\n612: \tstore.StoreSandbox(ctx, &SandboxInfo{\n613: \t\tSessionID:   \"active-1\",\n614: \t\tSandboxName: \"sandbox-active-1\",\n615: \t\tNamespace:   \"default\",\n616: \t\tKind:        SandboxesKind,\n617: \t\tExpiresAt:   time.Now().Add(1 * time.Hour),\n618: \t})\n619: \n620: \tscheme := runtime.NewScheme()\n621: \tdynClient := fake.NewSimpleDynamicClient(scheme)\n622: \n623: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n624: \t\tStore:         store,\n625: \t\tDynamicClient: dynClient,\n626: \t})\n627: \n628: \tmgr.cleanupExpiredSandboxes(ctx)\n629: \n630: \tlist, err := store.ListSandboxes(ctx)\n631: \trequire.NoError(t, err)\n632: \n633: \tassert.Len(t, list, 1)\n634: \tassert.Equal(t, \"active-1\", list[0].SessionID)\n635: }\n636: \n637: func TestLifecycleManager_IsExpired_BoundaryConditions(t *testing.T) {\n638: \tstore := newMockStore()\n639: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n640: \t\tStore:      store,\n641: \t\tDefaultTTL: 1 * time.Hour,\n642: \t})\n643: \n644: \tnow := time.Now()\n645: \n646: \ttestCases := []struct {\n647: \t\tname     string\n648: \t\tinfo     *SandboxInfo\n649: \t\tnow      time.Time\n650: \t\texpected bool\n651: \t}{\n652: \t\t{\n653: \t\t\tname:     \"expires exactly now\",\n654: \t\t\tinfo:     &SandboxInfo{ExpiresAt: now},\n655: \t\t\tnow:      now,\n656: \t\t\texpected: true,\n657: \t\t},\n658: \t\t{\n659: \t\t\tname:     \"expires 1 second from now\",\n660: \t\t\tinfo:     &SandboxInfo{ExpiresAt: now.Add(1 * time.Second)},\n661: \t\t\tnow:      now,\n662: \t\t\texpected: false,\n663: \t\t},\n664: \t\t{\n665: \t\t\tname:     \"expired 1 second ago\",\n666: \t\t\tinfo:     &SandboxInfo{ExpiresAt: now.Add(-1 * time.Second)},\n667: \t\t\tnow:      now,\n668: \t\t\texpected: true,\n669: \t\t},\n670: \t\t{\n671: \t\t\tname:     \"created exactly TTL ago\",\n672: \t\t\tinfo:     &SandboxInfo{CreatedAt: now.Add(-1 * time.Hour)},\n673: \t\t\tnow:      now,\n674: \t\t\texpected: true,\n675: \t\t},\n676: \t\t{\n677: \t\t\tname:     \"created 1 second before TTL\",\n678: \t\t\tinfo:     &SandboxInfo{CreatedAt: now.Add(-1*time.Hour - 1*time.Second)},\n679: \t\t\tnow:      now,\n680: \t\t\texpected: true,\n681: \t\t},\n682: \t\t{\n683: \t\t\tname:     \"created 1 second after TTL start\",\n684: \t\t\tinfo:     &SandboxInfo{CreatedAt: now.Add(-59 * time.Minute)},\n685: \t\t\tnow:      now,\n686: \t\t\texpected: false,\n687: \t\t},\n688: \t}\n689: \n690: \tfor _, tc := range testCases {\n691: \t\tt.Run(tc.name, func(t *testing.T) {\n692: \t\t\tresult := mgr.isExpired(tc.info, tc.now)\n693: \t\t\tassert.Equal(t, tc.expected, result)\n694: \t\t})\n695: \t}\n696: }\n\n(End of file - total 696 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle_test.go","time":{"start":1775825581020,"end":1775825581028}}}}
