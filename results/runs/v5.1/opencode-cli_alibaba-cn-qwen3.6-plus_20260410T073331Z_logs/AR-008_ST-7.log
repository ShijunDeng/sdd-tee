tLifecycleManager_IsExpired_WithExpiresAt(t *testing.T) {\n47: \tstore := newMockStore()\n48: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n49: \n50: \tnow := time.Now()\n51: \n52: \tinfo := &SandboxInfo{\n53: \t\tSessionID: \"test\",\n54: \t\tExpiresAt: now.Add(1 * time.Hour),\n55: \t}\n56: \tassert.False(t, mgr.isExpired(info, now))\n57: \n58: \tinfo.ExpiresAt = now.Add(-1 * time.Hour)\n59: \tassert.True(t, mgr.isExpired(info, now))\n60: }\n61: \n62: func TestLifecycleManager_IsExpired_WithCreatedAt(t *testing.T) {\n63: \tstore := newMockStore()\n64: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n65: \t\tStore:      store,\n66: \t\tDefaultTTL: 1 * time.Hour,\n67: \t})\n68: \n69: \tnow := time.Now()\n70: \n71: \tinfo := &SandboxInfo{\n72: \t\tSessionID: \"test\",\n73: \t\tCreatedAt: now.Add(-30 * time.Minute),\n74: \t}\n75: \tassert.False(t, mgr.isExpired(info, now))\n76: \n77: \tinfo.CreatedAt = now.Add(-2 * time.Hour)\n78: \tassert.True(t, mgr.isExpired(info, now))\n79: }\n80: \n81: func TestLifecycleManager_IsExpired_NoTimestamps(t *testing.T) {\n82: \tstore := newMockStore()\n83: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n84: \n85: \tinfo := &SandboxInfo{\n86: \t\tSessionID: \"test\",\n87: \t}\n88: \tassert.False(t, mgr.isExpired(info, time.Now()))\n89: }\n90: \n91: func TestLifecycleManager_StartStop(t *testing.T) {\n92: \tstore := newMockStore()\n93: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n94: \t\tStore:         store,\n95: \t\tCheckInterval: 100 * time.Millisecond,\n96: \t})\n97: \n98: \tctx, cancel := context.WithCancel(context.Background())\n99: \tdefer cancel()\n100: \n101: \tmgr.Start(ctx)\n102: \tassert.True(t, mgr.running)\n103: \n104: \tmgr.Stop()\n105: \tassert.False(t, mgr.running)\n106: }\n107: \n108: func TestLifecycleManager_StartIdempotent(t *testing.T) {\n109: \tstore := newMockStore()\n110: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n111: \t\tStore: store,\n112: \t})\n113: \n114: \tctx := context.Background()\n115: \n116: \tmgr.Start(ctx)\n117: \tstopCh1 := mgr.stopCh\n118: \n119: \tmgr.Start(ctx)\n120: \tassert.Equal(t, stopCh1, mgr.stopCh)\n121: \n122: \tmgr.Stop()\n123: }\n124: \n125: func TestExtendTTLRequest_Validate_Positive(t *testing.T) {\n126: \treq := &ExtendTTLRequest{\n127: \t\tExtensionDuration: 2 * time.Hour,\n128: \t}\n129: \terr := req.Validate()\n130: \tassert.NoError(t, err)\n131: }\n132: \n133: func TestExtendTTLRequest_Validate_Negative(t *testing.T) {\n134: \treq := &ExtendTTLRequest{\n135: \t\tExtensionDuration: -1 * time.Hour,\n136: \t}\n137: \terr := req.Validate()\n138: \tassert.Error(t, err)\n139: \tassert.Contains(t, err.Error(), \"must be positive\")\n140: }\n141: \n142: func TestExtendTTLRequest_Validate_Zero(t *testing.T) {\n143: \treq := &ExtendTTLRequest{\n144: \t\tExtensionDuration: 0,\n145: \t}\n146: \terr := req.Validate()\n147: \tassert.Error(t, err)\n148: \tassert.Contains(t, err.Error(), \"must be positive\")\n149: }\n150: \n151: func TestExtendTTLRequest_Validate_ExceedsMax(t *testing.T) {\n152: \treq := &ExtendTTLRequest{\n153: \t\tExtensionDuration: 25 * time.Hour,\n154: \t}\n155: \terr := req.Validate()\n156: \tassert.Error(t, err)\n157: \tassert.Contains(t, err.Error(), \"cannot exceed 24 hours\")\n158: }\n159: \n160: func TestExtendTTLRequest_Validate_MaxAllowed(t *testing.T) {\n161: \treq := &ExtendTTLRequest{\n162: \t\tExtensionDuration: 24 * time.Hour,\n163: \t}\n164: \terr := req.Validate()\n165: \tassert.NoError(t, err)\n166: }\n167: \n168: func TestLifecycleManager_GetSandboxStatus_MissingSessionID(t *testing.T) {\n169: \tgin.SetMode(gin.ReleaseMode)\n170: \tw := httptest.NewRecorder()\n171: \tc, _ := gin.CreateTestContext(w)\n172: \tc.Request = httptest.NewRequest(http.MethodGet, \"/status/\", nil)\n173: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"\"}}\n174: \n175: \tstore := newMockStore()\n176: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n177: \n178