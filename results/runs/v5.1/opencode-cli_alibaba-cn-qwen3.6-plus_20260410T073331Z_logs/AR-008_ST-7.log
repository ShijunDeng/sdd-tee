 for orphan scan\",\n  Line 329: \t\t\t\tslog.Error(\"failed to delete orphan CR\",\n  Line 343: \t\t\tslog.Info(\"orphan_cr_deleted\",\n  Line 359: func (m *LifecycleManager) cleanupGhostEntries(ctx context.Context) (int, error) {\n  Line 362: \t\tslog.Error(\"failed to list sandboxes for ghost scan\", \"error\", err)\n  Line 371: \t\t\tslog.Error(\"failed to resolve GVR for ghost scan\",\n  Line 385: \t\t\tslog.Error(\"failed to check CR existence for ghost scan\",\n  Line 395: \t\t\tslog.Error(\"failed to delete ghost entry from store\",\n  Line 408: \t\tslog.Info(\"ghost_entry_cleaned\",\n  Line 438: \tif info.LastActivityAt.IsZero() {\n  Line 446: \tdeadline := info.LastActivityAt.Add(m.defaultIdleTimeout)\n  Line 465: \tsandboxInfo.LastActivityAt = now\n  Line 467: \t\tslog.Error(\"failed to update LastActivityAt on status check\",\n  Line 482: \tisIdle := m.isIdleExpired(sandboxInfo, m.defaultIdleTimeout, now)\n  Line 491: \t\tLastActivityAt: sandboxInfo.LastActivityAt,\n  Line 509: \tLastActivityAt time.Time      `json:\"lastActivityAt\"`\n  Line 550: \t\tisIdle := m.isIdleExpired(sb, m.defaultIdleTimeout, now)\n  Line 561: \t\t\tLastActivityAt: sb.LastActivityAt,\n  Line 584: \tLastActivityAt time.Time      `json:\"lastActivityAt\"`\n  Line 627: \tsandboxInfo.LastActivityAt = now\n\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/models.go:\n  Line 65: \tLastActivityAt time.Time    `json:\"lastActivityAt\"`\n\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/metrics_test.go:\n  Line 67: func TestPrometheusMetricsRecorder_GCMetricsRegistered(t *testing.T) {","metadata":{"matches":39,"truncated":false},"title":"LastActivityAt|isIdleExpired|cleanupOrphanCRs|cleanupGhostEntries|GCMetrics|slog\\.","time":{"start":1775825543194,"end":1775825543199}}}}
