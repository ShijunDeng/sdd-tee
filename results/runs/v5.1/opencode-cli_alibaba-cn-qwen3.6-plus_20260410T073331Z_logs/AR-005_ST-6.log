{"type":"tool_use","timestamp":1775817504650,"sessionID":"ses_2890a6e7dffe9T5kkBD0w6nhaS","part":{"id":"prt_d76f8b2fb00162ouoeBffsGuTI","messageID":"msg_d76f88d23001jcPchc5HKiSaZW","sessionID":"ses_2890a6e7dffe9T5kkBD0w6nhaS","type":"tool","tool":"read","callID":"call_e8482d1a6a8d415b826c31ee","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"log\"\n7: \t\"math/rand\"\n8: \t\"net/http\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"github.com/google/uuid\"\n13: \tcorev1 \"k8s.io/api/core/v1\"\n14: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n15: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n16: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n17: \t\"k8s.io/apimachinery/pkg/labels\"\n18: \t\"k8s.io/apimachinery/pkg/runtime\"\n19: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n20: \t\"k8s.io/client-go/dynamic\"\n21: \t\"k8s.io/client-go/informers\"\n22: \t\"k8s.io/client-go/kubernetes\"\n23: \n24: \t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n25: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n26: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n27: )\n28: \n29: type Store interface {\n30: \tStoreSandbox(ctx context.Context, info *SandboxInfo) error\n31: \tUpdateSandbox(ctx context.Context, sessionID string, info *SandboxInfo) error\n32: }\n33: \n34: type SandboxReconcilerWatcher interface {\n35: \tWatchSandboxOnce(namespace, name string) (<-chan SandboxStatus, error)\n36: }\n37: \n38: type TokenCache interface {\n39: \tGetOrCreateUserK8sClient(namespace, saName, token string) (dynamic.Interface, error)\n40: }\n41: \n42: type SandboxCreateHandlerDeps struct {\n43: \tDynamicClient     dynamic.Interface\n44: \tClientset         clientset.Interface\n45: \tInformerFactory   informers.SharedInformerFactory\n46: \tStore             Store\n47: \tReconciler        SandboxReconcilerWatcher\n48: \tTokenCache        TokenCache\n49: \tUserClientFactory UserClientFactory\n50: \tEnableAuth        bool\n51: }\n52: \n53: type UserClientFactory interface {\n54: \tCreateUserClient(token string) (dynamic.Interface, error)\n55: }\n56: \n57: type SandboxCreateHandler struct {\n58: \tdynamicClient     dynamic.Interface\n59: \tclientset         clientset.Interface\n60: \tinformerFactory   informers.SharedInformerFactory\n61: \tstore             Store\n62: \treconciler        SandboxReconcilerWatcher\n63: \ttokenCache        TokenCache\n64: \tuserClientFactory UserClientFactory\n65: \tenableAuth        bool\n66: }\n67: \n68: func NewSandboxCreateHandler(deps *SandboxCreateHandlerDeps) *SandboxCreateHandler {\n69: \treturn &SandboxCreateHandler{\n70: \t\tdynamicClient:     deps.DynamicClient,\n71: \t\tclientset:         deps.Clientset,\n72: \t\tinformerFactory:   deps.InformerFactory,\n73: \t\tstore:             deps.Store,\n74: \t\treconciler:        deps.Reconciler,\n75: \t\ttokenCache:        deps.TokenCache,\n76: \t\tuserClientFactory: deps.UserClientFactory,\n77: \t\tenableAuth:        deps.EnableAuth,\n78: \t}\n79: }\n80: \n81: func (h *SandboxCreateHandler) getDynamicClient(c *gin.Context) (dynamic.Interface, error) {\n82: \tif !h.enableAuth {\n83: \t\treturn h.dynamicClient, nil\n84: \t}\n85: \n86: \ttoken := c.GetHeader(\"Authorization\")\n87: \tif token == \"\" {\n88: \t\treturn nil, fmt.Errorf(\"authorization token is required\")\n89: \t}\n90: \tif len(token) > 7 && token[:7] == \"Bearer \" {\n91: \t\ttoken = token[7:]\n92: \t}\n93: \n94: \tnamespace := c.GetString(\"namespace\")\n95: \tsaName := c.GetString(\"serviceAccountName\")\n96: \n97: \tif h.tokenCache != nil {\n98: \t\treturn h.tokenCache.GetOrCreateUserK8sClient(namespace, saName, token)\n99: \t}\n100: \n101: \tif h.userClientFactory != nil {\n102: \t\treturn h.userClientFactory.CreateUserClient(token)\n103: \t}\n104: \n105: \treturn nil, fmt.Errorf(\"no user client factory available\")\n106: }\n107: \n108: func (h *SandboxCreateHandler) CreateAgentRuntimeSandbox(c *gin.Context) {\n109: \tvar sandboxReq CreateSandboxRequest\n110: \tif err := c.ShouldBindJSON(&sandboxReq); err != nil {\n111: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n112: \t\treturn\n113: \t}\n114: \n115: \tsandboxReq.Kind = AgentRuntimeKind\n116: \n117: \tif err := sandboxReq.Validate(); err != nil {\n118: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n119: \t\treturn\n120: \t}\n121: \n122: \tarLister := h.informerFactory.Runtime().V1alpha1().AgentRuntimes().Lister()\n123: \ttemplate, err := arLister.AgentRuntimes(sandboxReq.Namespace).Get(sandboxReq.Name)\n124: \tif err != nil {\n125: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"AgentRuntime %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n126: \t\treturn\n127: \t}\n128: \n129: \tif template.Spec.Template == nil {\n130: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"podTemplate is required\")\n131: \t\treturn\n132: \t}\n133: \n134: \tsessionID := generateSessionID()\n135: \tsandboxName := generateSandboxName(sandboxReq.Name)\n136: \n137: \tsandboxCR, err := h.buildAgentRuntimeSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace)\n138: \tif err != nil {\n139: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n140: \t\treturn\n141: \t}\n142: \n143: \tsandboxInfo := &SandboxInfo{\n144: \t\tSessionID:    sessionID,\n145: \t\tSandboxName:  sandboxName,\n146: \t\tWorkloadName: sandboxReq.Name,\n147: \t\tNamespace:    sandboxReq.Namespace,\n148: \t\tKind:         AgentRuntimeKind,\n149: \t\tStatus:       \"pending\",\n150: \t\tCreatedAt:    time.Now(),\n151: \t}\n152: \n153: \tif err := h.store.StoreSandbox(c.Request.Context(), sandboxInfo); err != nil {\n154: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n155: \t\treturn\n156: \t}\n157: \n158: \twatcherCh, err := h.reconciler.WatchSandboxOnce(sandboxReq.Namespace, sandboxName)\n159: \tif err != nil {\n160: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n161: \t\treturn\n162: \t}\n163: \n164: \tdynClient, err := h.getDynamicClient(c)\n165: \tif err != nil {\n166: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n167: \t\treturn\n168: \t}\n169: \n170: \tcreatedCR, err := dynClient.Resource(SandboxGVR).Namespace(sandboxReq.Namespace).Create(c.Request.Context(), sandboxCR, metav1.CreateOptions{})\n171: \tif err != nil {\n172: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n173: \t\treturn\n174: \t}\n175: \n176: \tctx, cancel := context.WithTimeout(c.Request.Context(), 2*time.Minute)\n177: \tdefer cancel()\n178: \n179: \tselect {\n180: \tcase status := <-watcherCh:\n181: \t\tif status.Error != nil {\n182: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n183: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, status.Error.Error())\n184: \t\t\treturn\n185: \t\t}\n186: \t\tif status.Status != \"running\" {\n187: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n188: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n189: \t\t\treturn\n190: \t\t}\n191: \tcase <-ctx.Done():\n192: \t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n193: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n194: \t\treturn\n195: \t}\n196: \n197: \tpodIP, err := h.resolvePodIP(c.Request.Context(), sandboxName, sandboxReq.Namespace, sandboxCR, h.clientset.CoreV1().(*kubernetes.Clientset))\n198: \tif err != nil {\n199: \t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n200: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())\n201: \t\treturn\n202: \t}\n203: \n204: \tports := template.Spec.Ports\n205: \tentryPoints := h.buildEntryPoints(podIP, ports)\n206: \n207: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n208: \tsandboxInfo.PodIP = podIP\n209: \tsandboxInfo.EntryPoints = entryPoints\n210: \tsandboxInfo.Status = \"running\"\n211: \n212: \tif err := h.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n213: \t\tlog.Printf(\"failed to update sandbox in store: %v\", err)\n214: \t}\n215: \n216: \tresp := &CreateSandboxResponse{\n217: \t\tSessionID:   sessionID,\n218: \t\tSandboxID:   sandboxInfo.SandboxID,\n219: \t\tSandboxName: sandboxName,\n220: \t\tEntryPoints: entryPoints,\n221: \t}\n222: \n223: \tresponse.JSON(c, http.StatusOK, resp)\n224: }\n225: \n226: func (h *SandboxCreateHandler) CreateCodeInterpreterSandbox(c *gin.Context) {\n227: \tvar sandboxReq CreateSandboxRequest\n228: \tif err := c.ShouldBindJSON(&sandboxReq); err != nil {\n229: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n230: \t\treturn\n231: \t}\n232: \n233: \tsandboxReq.Kind = CodeInterpreterKind\n234: \n235: \tif err := sandboxReq.Validate(); err != nil {\n236: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n237: \t\treturn\n238: \t}\n239: \n240: \tciLister := h.informerFactory.Runtime().V1alpha1().CodeInterpreters().Lister()\n241: \ttemplate, err := ciLister.CodeInterpreters(sandboxReq.Namespace).Get(sandboxReq.Name)\n242: \tif err != nil {\n243: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"CodeInterpreter %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n244: \t\treturn\n245: \t}\n246: \n247: \tif template.Spec.Template == nil {\n248: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"template is required\")\n249: \t\treturn\n250: \t}\n251: \n252: \tsessionID := generateSessionID()\n253: \tsandboxName := generateSandboxName(sandboxReq.Name)\n254: \n255: \tports := getPortsOrDefaults(template.Spec.Ports)\n256: \n257: \tvar sandboxCR *unstructured.Unstructured\n258: \tvar entryKind string\n259: \tvar err error\n260: \n261: \tsandboxCR, entryKind, err = h.buildCodeInterpreterSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace, ports)\n262: \tif err != nil {\n263: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n264: \t\treturn\n265: \t}\n266: \n267: \tif template.Spec.AuthMode == runtimev1alpha1.AuthModePicoD {\n268: \t\tif err := h.injectPicodAuthEnv(sandboxCR, sandboxReq.Namespace, h.clientset.CoreV1().(*kubernetes.Clientset)); err != nil {\n269: \t\t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n270: \t\t\treturn\n271: \t\t}\n272: \t}\n273: \n274: \tsandboxInfo := &SandboxInfo{\n275: \t\tSessionID:    sessionID,\n276: \t\tSandboxName:  sandboxName,\n277: \t\tWorkloadName: sandboxReq.Name,\n278: \t\tNamespace:    sandboxReq.Namespace,\n279: \t\tKind:         entryKind,\n280: \t\tStatus:       \"pending\",\n281: \t\tCreatedAt:    time.Now(),\n282: \t}\n283: \n284: \tif err := h.store.StoreSandbox(c.Request.Context(), sandboxInfo); err != nil {\n285: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n286: \t\treturn\n287: \t}\n288: \n289: \twatcherCh, err := h.reconciler.WatchSandboxOnce(sandboxReq.Namespace, sandboxName)\n290: \tif err != nil {\n291: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n292: \t\treturn\n293: \t}\n294: \n295: \tdynClient, err := h.getDynamicClient(c)\n296: \tif err != nil {\n297: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n298: \t\treturn\n299: \t}\n300: \n301: \tvar gvr schema.GroupVersionResource\n302: \tif entryKind == SandboxClaimsKind {\n303: \t\tgvr = SandboxClaimGVR\n304: \t} else {\n305: \t\tgvr = SandboxGVR\n306: \t}\n307: \n308: \tcreatedCR, err := dynClient.Resource(gvr).Namespace(sandboxReq.Namespace).Create(c.Request.Context(), sandboxCR, metav1.CreateOptions{})\n309: \tif err != nil {\n310: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n311: \t\treturn\n312: \t}\n313: \n314: \tctx, cancel := context.WithTimeout(c.Request.Context(), 2*time.Minute)\n315: \tdefer cancel()\n316: \n317: \tselect {\n318: \tcase status := <-watcherCh:\n319: \t\tif status.Error != nil {\n320: \t\t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n321: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, status.Error.Error())\n322: \t\t\treturn\n323: \t\t}\n324: \t\tif status.Status != \"running\" {\n325: \t\t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n326: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n327: \t\t\treturn\n328: \t\t}\n329: \tcase <-ctx.Done():\n330: \t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n331: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n332: \t\treturn\n333: \t}\n334: \n335: \tpodIP, err := h.resolvePodIP(c.Request.Context(), sandboxName, sandboxReq.Namespace, sandboxCR, h.clientset.CoreV1().(*kubernetes.Clientset))\n336: \tif err != nil {\n337: \t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n338: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())\n339: \t\treturn\n340: \t}\n341: \n342: \tentryPoints := h.buildEntryPoints(podIP, ports)\n343: \n344: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n345: \tsandboxInfo.PodIP = podIP\n346: \tsandboxInfo.EntryPoints = entryPoints\n347: \tsandboxInfo.Status = \"running\"\n348: \n349: \tif err := h.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n350: \t\tlog.Printf(\"failed to update sandbox in store: %v\", err)\n351: \t}\n352: \n353: \tresp := &CreateSandboxResponse{\n354: \t\tSessionID:   sessionID,\n355: \t\tSandboxID:   sandboxInfo.SandboxID,\n356: \t\tSandboxName: sandboxName,\n357: \t\tEntryPoints: entryPoints,\n358: \t}\n359: \n360: \tresponse.JSON(c, http.StatusOK, resp)\n361: }\n362: \n363: func (h *SandboxCreateHandler) rollbackCR(ctx context.Context, gvr schema.GroupVersionResource, namespace, name string, dynClient dynamic.Interface) error {\n364: \trollbackCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n365: \tdefer cancel()\n366: \n367: \terr := dynClient.Resource(gvr).Namespace(namespace).Delete(rollbackCtx, name, metav1.DeleteOptions{})\n368: \tif err != nil && apierrors.IsNotFound(err) {\n369: \t\treturn nil\n370: \t}\n371: \treturn err\n372: }\n373: \n374: func (h *SandboxCreateHandler) buildAgentRuntimeSandboxCR(template *runtimev1alpha1.AgentRuntime, sessionID, sandboxName, workloadName, namespace string) (*unstructured.Unstructured, error) {\n375: \tcr := &unstructured.Unstructured{}\n376: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n377: \tcr.SetKind(\"Sandbox\")\n378: \tcr.SetName(sandboxName)\n379: \tcr.SetNamespace(namespace)\n380: \n381: \tcr.SetLabels(map[string]string{\n382: \t\tLabelManagedBy:    LabelManagedByValue,\n383: \t\tLabelSessionID:    sessionID,\n384: \t\tLabelWorkloadName: workloadName,\n385: \t\tLabelSandboxName:  sandboxName,\n386: \t})\n387: \n388: \tidleTimeout := DefaultSandboxIdleTimeout\n389: \tif template.Spec.SessionTimeout != nil {\n390: \t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n391: \t}\n392: \tcr.SetAnnotations(map[string]string{\n393: \t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n394: \t})\n395: \n396: \tttl := DefaultSandboxTTL\n397: \tif template.Spec.MaxSessionDuration != nil {\n398: \t\tttl = template.Spec.MaxSessionDuration.Duration.Hours()\n399: \t}\n400: \tshutdownTime := time.Now().Add(time.Duration(ttl) * time.Hour)\n401: \n402: \tspec := map[string]interface{}{\n403: \t\t\"replicas\": int64(1),\n404: \t\t\"lifecycle\": map[string]interface{}{\n405: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n406: \t\t},\n407: \t}\n408: \n409: \tvar ports []interface{}\n410: \tfor _, p := range template.Spec.Ports {\n411: \t\tports = append(ports, map[string]interface{}{\n412: \t\t\t\"name\":     p.Name,\n413: \t\t\t\"port\":     int64(p.Port),\n414: \t\t\t\"protocol\": string(p.Protocol),\n415: \t\t})\n416: \t}\n417: \tif len(ports) > 0 {\n418: \t\tspec[\"ports\"] = ports\n419: \t}\n420: \n421: \tpodSpec := template.Spec.Template.Spec\n422: \tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n423: \tif err != nil {\n424: \t\treturn nil, fmt.Errorf(\"failed to convert pod spec: %w\", err)\n425: \t}\n426: \tspec[\"podTemplate\"] = podSpecMap\n427: \n428: \tcr.Object[\"spec\"] = spec\n429: \n430: \treturn cr, nil\n431: }\n432: \n433: func (h *SandboxCreateHandler) buildCodeInterpreterSandboxCR(template *runtimev1alpha1.CodeInterpreter, sessionID, sandboxName, workloadName, namespace string, ports []runtimev1alpha1.TargetPort) (*unstructure