tassert.NotPanics(t, func() { r.IncGCCleanupErrors(\"ttl_expired\") })\n38: \tassert.NotPanics(t, func() { r.IncGCCleanupErrors(\"orphan_cr\") })\n39: }\n40: \n41: func TestPrometheusMetricsRecorder_ObserveGCCycleDuration(t *testing.T) {\n42: \tr := newTestMetricsRecorder(t)\n43: \n44: \tassert.NotPanics(t, func() { r.ObserveGCCycleDuration(5 * time.Second) })\n45: \tassert.NotPanics(t, func() { r.ObserveGCCycleDuration(10 * time.Second) })\n46: }\n47: \n48: func TestMetricsRecorder_NilReceiver_GCMethods(t *testing.T) {\n49: \tvar r *PrometheusMetricsRecorder\n50: \n51: \tassert.NotPanics(t, func() { r.IncGCCleanupTotal(\"ttl_expired\") })\n52: \tassert.NotPanics(t, func() { r.ObserveGCCleanupDuration(\"idle\", 100*time.Millisecond) })\n53: \tassert.NotPanics(t, func() { r.IncGCCleanupErrors(\"orphan_cr\") })\n54: \tassert.NotPanics(t, func() { r.ObserveGCCycleDuration(5 * time.Second) })\n55: }\n56: \n57: func TestPrometheusMetricsRecorder_NilReceiver_ExistingMethods(t *testing.T) {\n58: \tvar r *PrometheusMetricsRecorder\n59: \n60: \tassert.NotPanics(t, func() { r.IncReconcileTotal(\"agentruntime\", \"success\") })\n61: \tassert.NotPanics(t, func() { r.ObserveReconcileDuration(\"agentruntime\", 100*time.Millisecond) })\n62: \tassert.NotPanics(t, func() { r.IncReconcileErrors(\"agentruntime\", \"store_unreachable\") })\n63: \tassert.NotPanics(t, func() { r.SetWorkqueueDepth(5) })\n64: \tassert.NotPanics(t, func() { r.IncWorkqueueAdds(\"agentruntime\") })\n65: }\n66: \n67: func TestPrometheusMetricsRecorder_GCMetricsRegistered(t *testing.T) {\n68: \treg := prometheus.NewRegistry()\n69: \t_ = NewPrometheusMetricsRecorder(reg)\n70: \n71: \tmfs, err := reg.Gather()\n72: \trequire.NoError(t, err)\n73: \n74: \tmetricNames := make(map[string]bool)\n75: \tfor _, mf := range mfs {\n76: \t\tmetricNames[mf.GetName()] = true\n77: \t}\n78: \n79: \tassert.True(t, metricNames[\"gc_cleanup_total\"])\n80: \tassert.True(t, metricNames[\"gc_cleanup_duration_seconds\"])\n81: \tassert.True(t, metricNames[\"gc_cleanup_errors_total\"])\n82: \tassert.True(t, metricNames[\"gc_cycle_duration_seconds\"])\n83: }\n\n(End of file - total 83 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/prometheus/client_golang/prometheus\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc newTestMetricsRecorder(t *testing.T) *PrometheusMetricsRecorder {\n\tt.Helper()\n\treg := prometheus.NewRegistry()\n\treturn NewPrometheusMetricsRecorder(reg)\n}\n\nfunc TestPrometheusMetricsRecorder_IncGCCleanupTotal(t *testing.T) {\n\tr := newTestMetricsRecorder(t)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/metrics_test.go","time":{"start":1775886394155,"end":1775886394162}}}}
