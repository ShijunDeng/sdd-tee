Obj\n40: \t} else {\n41: \t\trealObj = obj\n42: \t}\n43: \tkey, err := cache.MetaNamespaceKeyFunc(realObj)\n44: \tif err != nil {\n45: \t\tlog.Printf(\"[reconciler] failed to get key for AgentRuntime delete: %v\", err)\n46: \t\treturn\n47: \t}\n48: \tr.workqueue.Add(key)\n49: \tif r.metricsRecorder != nil {\n50: \t\tr.metricsRecorder.IncWorkqueueAdds(resourceTypeAgentRuntime)\n51: \t\tr.metricsRecorder.SetWorkqueueDepth(r.workqueue.Len())\n52: \t}\n53: }\n54: \n55: func (r *SandboxReconciler) onCodeInterpreterAdd(obj interface{}) {\n56: \tkey, err := cache.MetaNamespaceKeyFunc(obj)\n57: \tif err != nil {\n58: \t\tlog.Printf(\"[reconciler] failed to get key for CodeInterpreter add: %v\", err)\n59: \t\treturn\n60: \t}\n61: \tr.workqueue.Add(key)\n62: \tif r.metricsRecorder != nil {\n63: \t\tr.metricsRecorder.IncWorkqueueAdds(resourceTypeCodeInterpreter)\n64: \t\tr.metricsRecorder.SetWorkqueueDepth(r.workqueue.Len())\n65: \t}\n66: }\n67: \n68: func (r *SandboxReconciler) onCodeInterpreterUpdate(oldObj, newObj interface{}) {\n69: \tkey, err := cache.MetaNamespaceKeyFunc(newObj)\n70: \tif err != nil {\n71: \t\tlog.Printf(\"[reconciler] failed to get key for CodeInterpreter update: %v\", err)\n72: \t\treturn\n73: \t}\n74: \tr.workqueue.Add(key)\n75: \tif r.metricsRecorder != nil {\n76: \t\tr.metricsRecorder.IncWorkqueueAdds(resourceTypeCodeInterpreter)\n77: \t\tr.metricsRecorder.SetWorkqueueDepth(r.workqueue.Len())\n78: \t}\n79: }\n80: \n81: func (r *SandboxReconciler) onCodeInterpreterDelete(obj interface{}) {\n82: \tvar realObj interface{}\n83: \tif tombstone, ok := obj.(cache.DeletedFinalStateUnknown); ok {\n84: \t\trealObj = tombstone.Obj\n85: \t} else {\n86: \t\trealObj = obj\n87: \t}\n88: \tkey, err := cache.MetaNamespaceKeyFunc(realObj)\n89: \tif err != nil {\n90: \t\tlog.Printf(\"[reconciler] failed to get key for CodeInterpreter delete: %v\", err)\n91: \t\treturn\n92: \t}\n93: \tr.workqueue.Add(key)\n94: \tif r.metricsRecorder != nil {\n95: \t\tr.metricsRecorder.IncWorkqueueAdds(resourceTypeCodeInterpreter)\n96: \t\tr.metricsRecorder.SetWorkqueueDepth(r.workqueue.Len())\n97: \t}\n98: }\n99: \n100: func (r *SandboxReconciler) onPodAdd(obj interface{}) {\n101: \tpod, ok := obj.(*corev1.Pod)\n102: \tif !ok {\n103: \t\treturn\n104: \t}\n105: \tsandboxName := pod.Labels[\"runtime.agentcube.io/sandbox-name\"]\n106: \tif sandboxName == \"\" {\n107: \t\treturn\n108: \t}\n109: \tkey, err := cache.MetaNamespaceKeyFunc(obj)\n110: \tif err != nil {\n111: \t\tlog.Printf(\"[reconciler] failed to get key for Pod add: %v\", err)\n112: \t\treturn\n113: \t}\n114: \tr.workqueue.Add(key)\n115: \tif r.metricsRecorder != nil {\n116: \t\tr.metricsRecorder.IncWorkqueueAdds(resourceTypePod)\n117: \t\tr.metricsRecorder.SetWorkqueueDepth(r.workqueue.Len())\n118: \t}\n119: }\n120: \n121: func (r *SandboxReconciler) onPodUpdate(oldObj, newObj interface{}) {\n122: \toldPod, ok := oldObj.(*corev1.Pod)\n123: \tif !ok {\n124: \t\treturn\n125: \t}\n126: \tnewPod, ok := newObj.(*corev1.Pod)\n127: \tif !ok {\n128: \t\treturn\n129: \t}\n130: \tsandboxName := newPod.Labels[\"runtime.agentcube.io/sandbox-name\"]\n131: \tif sandboxName == \"\" {\n132: \t\treturn\n133: \t}\n134: \n135: \toldRunning := oldPod.Status.Phase == corev1.PodRunning\n136: \tnewRunning := newPod.Status.Phase == corev1.PodRunning\n137: \tipChanged := oldPod.Status.PodIP != newPod.Status.PodIP\n138: \n139: \tif (!oldRunning && newRunning) || ipChanged {\n140: \t\tkey, err := cache.MetaNamespaceKeyFunc(newObj)\n141: \t\tif err != nil {\n142: \t\t\tlog.Printf(\"[reconciler] failed to get key for Pod update: %v\", err)\n143: \t\t\treturn\n144: \t\t}\n145: \t\tr.workqueue.Add(key)\n146: \t\tif r.metricsRecorder != nil {\n147: \t\t\tr.metricsRecorder.IncWorkqueueAdds(resourceTypePod)\n148: \t\t\tr.metricsRecorder.SetWorkqueueDepth(r.workqueue.Len())\n149: \t\t}\n150: \t}\n151: }\n152: \n153: func (r *SandboxReconciler) onPodDelete(obj interface{}) {\n154: \tvar realObj interface{}\n155: \tif tombstone, ok := obj.(cache.DeletedFinalStateUnknown); ok {\n156: \t\trealObj = tombstone.Obj\n157: \t} else {\n158: \t\trealObj = obj\n159: \t}\n160: \tpod, ok := realObj.(*corev1.Pod)\n161: \tif !ok {\n162: \t\treturn\n163: \t}\n164: \tlog.Printf(\"[reconciler] pod deleted: %s/%s (sandbox-name: %s)\", pod.Namespace, pod.Name, pod.Labels[\"runtime.agentcube.io/sandbox-name\"])\n165: }\n\n(End of file - total 165 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"log\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/client-go/tools/cache\"\n)\n\nfunc (r *SandboxReconciler) onAgentRuntimeAdd(obj interface{}) {\n\tkey, err := cache.MetaNamespaceKeyFunc(obj)\n\tif err != nil {\n\t\tlog.Printf(\"[reconciler] failed to get key for AgentRuntime add: %v\", err)\n\t\treturn\n\t}\n\tr.workqueue.Add(key)\n\tif r.metricsRecorder != nil {\n\t\tr.metricsRecorder.IncWorkqueueAdds(resourceTypeAgentRuntime)\n\t\tr.metricsRecorder.SetWorkqueueDepth(r.workqueue.Len())\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/event_handlers.go","time":{"start":1775886366106,"end":1775886366112}}}}
