informerFactory: deps.InformerFactory,\n43: \t\tstore:           deps.Store,\n44: \t\tenableAuth:      deps.EnableAuth,\n45: \t\ttokenCache:      deps.TokenCache,\n46: \t}\n47: }\n48: \n49: func (h *SandboxDeleteHandler) getDynamicClient(c *gin.Context) (dynamic.Interface, error) {\n50: \tif !h.enableAuth {\n51: \t\treturn h.dynamicClient, nil\n52: \t}\n53: \n54: \ttoken := c.GetHeader(\"Authorization\")\n55: \tif token == \"\" {\n56: \t\treturn nil, fmt.Errorf(\"authorization token is required\")\n57: \t}\n58: \tif len(token) > 7 && token[:7] == \"Bearer \" {\n59: \t\ttoken = token[7:]\n60: \t}\n61: \n62: \tnamespace := c.GetString(\"namespace\")\n63: \tsaName := c.GetString(\"serviceAccountName\")\n64: \n65: \tif h.tokenCache != nil {\n66: \t\treturn h.tokenCache.GetOrCreateUserK8sClient(namespace, saName, token)\n67: \t}\n68: \n69: \treturn nil, fmt.Errorf(\"no token cache available\")\n70: }\n71: \n72: type DeleteSandboxRequest struct {\n73: \tSessionID string `json:\"sessionId\"`\n74: \tNamespace string `json:\"namespace\"`\n75: }\n76: \n77: func (r *DeleteSandboxRequest) Validate() error {\n78: \tif r.SessionID == \"\" {\n79: \t\treturn fmt.Errorf(\"sessionId is required\")\n80: \t}\n81: \tif r.Namespace == \"\" {\n82: \t\treturn fmt.Errorf(\"namespace is required\")\n83: \t}\n84: \treturn nil\n85: }\n86: \n87: type DeleteSandboxResponse struct {\n88: \tSessionID   string `json:\"sessionId\"`\n89: \tSandboxName string `json:\"sandboxName\"`\n90: \tDeleted     bool   `json:\"deleted\"`\n91: \tMessage     string `json:\"message,omitempty\"`\n92: }\n93: \n94: func (h *SandboxDeleteHandler) DeleteSandbox(c *gin.Context) {\n95: \tvar req DeleteSandboxRequest\n96: \tif err := c.ShouldBindJSON(&req); err != nil {\n97: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n98: \t\treturn\n99: \t}\n100: \n101: \tif err := req.Validate(); err != nil {\n102: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n103: \t\treturn\n104: \t}\n105: \n106: \tsandboxInfo, err := h.store.GetSandbox(c.Request.Context(), req.SessionID)\n107: \tif err != nil {\n108: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox session %s not found\", req.SessionID))\n109: \t\treturn\n110: \t}\n111: \n112: \tgvr, err := h.resolveGVR(sandboxInfo.Kind)\n113: \tif err != nil {\n114: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n115: \t\treturn\n116: \t}\n117: \n118: \tdynClient, err := h.getDynamicClient(c)\n119: \tif err != nil {\n120: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n121: \t\treturn\n122: \t}\n123: \n124: \tdeleteCtx, cancel := context.WithTimeout(c.Request.Context(), 30*time.Second)\n125: \tdefer cancel()\n126: \n127: \terr = dynClient.Resource(gvr).Namespace(sandboxInfo.Namespace).Delete(deleteCtx, sandboxInfo.SandboxName, metav1.DeleteOptions{})\n128: \tif err != nil {\n129: \t\tif apierrors.IsNotFound(err) {\n130: \t\t\tif err := h.store.DeleteSandbox(c.Request.Context(), req.SessionID); err != nil {\n131: \t\t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"failed to cleanup sandbox from store\")\n132: \t\t\t\treturn\n133: \t\t\t}\n134: \t\t\tresponse.JSON(c, http.StatusOK, &DeleteSandboxResponse{\n135: \t\t\t\tSessionID:   req.SessionID,\n136: \t\t\t\tSandboxName: sandboxInfo.SandboxName,\n137: \t\t\t\tDeleted:     true,\n138: \t\t\t\tMessage:     \"sandbox already deleted, cleaned up from store\",\n139: \t\t\t})\n140: \t\t\treturn\n141: \t\t}\n142: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, fmt.Sprintf(\"failed to delete sandbox: %v\", err))\n143: \t\treturn\n144: \t}\n145: \n146: \tif err := h.store.DeleteSandbox(c.Request.Context(), req.SessionID); err != nil {\n147: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, fmt.Sprintf(\"sandbox deleted but failed to cleanup store: %v\", err))\n148: \t\treturn\n149: \t}\n150: \n151: \tresponse.JSON(c, http.StatusOK, &DeleteSandboxResponse{\n152: \t\tSessionID:   req.SessionID,\n153: \t\tSandboxName: sandboxInfo.SandboxName,\n154: \t\tDeleted:     true,\n155: \t})\n156: }\n157: \n158: func (h *SandboxDeleteHandler) DeleteSandboxByName(c *gin.Context) {\n159: \tname := c.Param(\"name\")\n160: \tif name == \"\" {\n161: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"sandbox name is required\")\n162: \t\treturn\n163: \t}\n164: \n165: \tnamespace := c.Query(\"namespace\")\n166: \tif namespace == \"\" {\n167: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"namespace query parameter is required\")\n168: \t\treturn\n169: \t}\n170: \n171: \tkind := c.Query(\"kind\")\n172: \tif kind == \"\" {\n173: \t\tkind = SandboxesKind\n174: \t}\n175: \n176: \tgvr, err := h.resolveGVR(kind)\n177: \tif err != nil {\n178: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n179: \t\treturn\n180: \t}\n181: \n182: \tdynClient, err := h.getDynamicClient(c)\n183: \tif err != nil {\n184: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n185: \t\treturn\n186: \t}\n187: \n188: \tdeleteCtx, cancel := context.WithTimeout(c.Request.Context(), 30*time.Second)\n189: \tdefer cancel()\n190: \n191: \terr = dynClient.Resource(gvr).Namespace(namespace).Delete(deleteCtx, name, metav1.DeleteOptions{})\n192: \tif err != nil {\n193: \t\tif apierrors.IsNotFound(err) {\n194: \t\t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox %s/%s not found\", namespace, name))\n195: \t\t\treturn\n196: \t\t}\n197: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, fmt.Sprintf(\"failed to delete sandbox: %v\", err))\n198: \t\treturn\n199: \t}\n200: \n201: \tresponse.JSON(c, http.StatusOK, &DeleteSandboxResponse{\n202: \t\tSandboxName: name,\n203: \t\tDeleted:     true,\n204: \t})\n205: }\n206: \n207: func (h *SandboxDeleteHandler) resolveGVR(kind string) (schema.GroupVersionResource, error) {\n208: \tswitch kind {\n209: \tcase SandboxesKind:\n210: \t\treturn SandboxGVR, nil\n211: \tcase SandboxClaimsKind:\n212: \t\treturn SandboxClaimGVR, nil\n213: \tdefault:\n214: \t\treturn schema.GroupVersionResource{}, fmt.Errorf(\"unknown sandbox kind: %s\", kind)\n215: \t}\n216: }\n\n(End of file - total 216 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/informers\"\n\n\t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n)\n\ntype SandboxDeleteHandlerDeps struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete.go","time":{"start":1775886375940,"end":1775886375947}}}}
