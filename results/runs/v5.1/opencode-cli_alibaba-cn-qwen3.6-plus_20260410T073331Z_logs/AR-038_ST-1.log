: \t})\n290: \tstore.StoreSandbox(ctx, &SandboxInfo{\n291: \t\tSessionID:   \"session-2\",\n292: \t\tSandboxName: \"sandbox-2\",\n293: \t\tNamespace:   \"test\",\n294: \t\tKind:        SandboxesKind,\n295: \t\tStatus:      \"pending\",\n296: \t\tCreatedAt:   time.Now(),\n297: \t\tExpiresAt:   time.Now().Add(2 * time.Hour),\n298: \t})\n299: \n300: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n301: \n302: \tmgr.ListSandboxes(c)\n303: \n304: \tassert.Equal(t, http.StatusOK, w.Code)\n305: \n306: \tvar wrapper response.SuccessResponse\n307: \terr := json.Unmarshal(w.Body.Bytes(), &wrapper)\n308: \trequire.NoError(t, err)\n309: \n310: \tdataBytes, err := json.Marshal(wrapper.Data)\n311: \trequire.NoError(t, err)\n312: \n313: \tvar resp ListSandboxesResponse\n314: \terr = json.Unmarshal(dataBytes, &resp)\n315: \trequire.NoError(t, err)\n316: \n317: \tassert.Equal(t, 2, resp.Total)\n318: }\n319: \n320: func TestLifecycleManager_ListSandboxes_FilterByNamespace(t *testing.T) {\n321: \tgin.SetMode(gin.ReleaseMode)\n322: \tw := httptest.NewRecorder()\n323: \tc, _ := gin.CreateTestContext(w)\n324: \tc.Request = httptest.NewRequest(http.MethodGet, \"/sandboxes?namespace=default\", nil)\n325: \n326: \tstore := newMockStore()\n327: \tctx := context.Background()\n328: \tstore.StoreSandbox(ctx, &SandboxInfo{\n329: \t\tSessionID: \"session-1\",\n330: \t\tNamespace: \"default\",\n331: \t})\n332: \tstore.StoreSandbox(ctx, &SandboxInfo{\n333: \t\tSessionID: \"session-2\",\n334: \t\tNamespace: \"test\",\n335: \t})\n336: \n337: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n338: \n339: \tmgr.ListSandboxes(c)\n340: \n341: \tassert.Equal(t, http.StatusOK, w.Code)\n342: \n343: \tvar wrapper response.SuccessResponse\n344: \terr := json.Unmarshal(w.Body.Bytes(), &wrapper)\n345: \trequire.NoError(t, err)\n346: \n347: \tdataBytes, err := json.Marshal(wrapper.Data)\n348: \trequire.NoError(t, err)\n349: \n350: \tvar resp ListSandboxesResponse\n351: \terr = json.Unmarshal(dataBytes, &resp)\n352: \trequire.NoError(t, err)\n353: \n354: \tassert.Equal(t, 1, resp.Total)\n355: \tassert.Equal(t, \"session-1\", resp.Items[0].SessionID)\n356: }\n357: \n358: func TestLifecycleManager_ListSandboxes_FilterByStatus(t *testing.T) {\n359: \tgin.SetMode(gin.ReleaseMode)\n360: \tw := httptest.NewRecorder()\n361: \tc, _ := gin.CreateTestContext(w)\n362: \tc.Request = httptest.NewRequest(http.MethodGet, \"/sandboxes?status=running\", nil)\n363: \n364: \tstore := newMockStore()\n365: \tctx := context.Background()\n366: \tstore.StoreSandbox(ctx, &SandboxInfo{\n367: \t\tSessionID: \"session-1\",\n368: \t\tStatus:    \"running\",\n369: \t})\n370: \tstore.StoreSandbox(ctx, &SandboxInfo{\n371: \t\tSessionID: \"session-2\",\n372: \t\tStatus:    \"pending\",\n373: \t})\n374: \n375: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n376: \n377: \tmgr.ListSandboxes(c)\n378: \n379: \tassert.Equal(t, http.StatusOK, w.Code)\n380: \n381: \tvar wrapper response.SuccessResponse\n382: \terr := json.Unmarshal(w.Body.Bytes(), &wrapper)\n383: \trequire.NoError(t, err)\n384: \n385: \tdataBytes, err := json.Marshal(wrapper.Data)\n386: \trequire.NoError(t, err)\n387: \n388: \tvar resp ListSandboxesResponse\n389: \terr = json.Unmarshal(dataBytes, &resp)\n390: \trequire.NoError(t, err)\n391: \n392: \tassert.Equal(t, 1, resp.Total)\n393: \tassert.Equal(t, \"running\", resp.Items[0].Status)\n394: }\n395: \n396: func TestLifecycleManager_ExtendSandboxTTL_MissingSessionID(t *testing.T) {\n397: \tgin.SetMode(gin.ReleaseMode)\n398: \tw := httptest.NewRecorder()\n399: \tc, _ := gin.CreateTestContext(w)\n400: \tc.Request = httptest.NewRequest(http.MethodPost, \"/extend/\", nil)\n401: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"\"}}\n402: \n403: \tstore := newMockStore()\n404: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n405: \n406: \tmgr.ExtendSandboxTTL(c)\n407: \n408: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n409: }\n410: \n411: func TestLifecycleManager_ExtendSandboxTTL_InvalidBody(t *testing.T) {\n412: \tgin.SetMode(gin.ReleaseMode)\n413: \tw := httptest.NewRecorder()\n414: \tc, _ := gin.CreateTestContext(w)\n415: \tc.Request = httptest.NewRequest(http.MethodPost, \"/extend/session-123\", nil)\n416: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n417: \n418: \tstore := newMockStore()\n419: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n420: \n421: \tmgr.ExtendSandboxTTL(c)\n422: \n423: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n424: }\n425: \n426: func TestLifecycleManager_ExtendSandboxTTL_SessionNotFound(t *testing.T) {\n427: \tgin.SetMode(gin.ReleaseMode)\n428: \tw := httptest.NewRecorder()\n429: \tc, _ := gin.CreateTestContext(w)\n430: \tbody := `{\"extensionDuration\": 3600000000000}`\n431: \tc.Request = httptest.NewRequest(http.MethodPost, \"/extend/session-123\", bytes.NewBufferString(body))\n432: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n433: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n434: \n435: \tstore := newMockStore()\n436: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n437: \n438: \tmgr.ExtendSandboxTTL(c)\n439: \n440: \tassert.Equal(t, http.StatusNotFound, w.Code)\n441: }\n442: \n443: func TestLifecycleManager_ExtendSandboxTTL_ExpiredSandbox(t *testing.T) {\n444: \tgin.SetMode(gin.ReleaseMode)\n445: \tw := httptest.NewRecorder()\n446: \tc, _ := gin.CreateTestContext(w)\n447: \tbody := `{\"extensionDuration\": 3600000000000}`\n448: \tc.Request = httptest.NewRequest(http.MethodPost, \"/extend/session-123\", bytes.NewBufferString(body))\n449: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n450: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n451: \n452: \tstore := newMockStore()\n453: \tctx := context.Background()\n454: \tstore.StoreSandbox(ctx, &SandboxInfo{\n455: \t\tSessionID: \"session-123\",\n456: \t\tExpiresAt: time.Now().Add(-1 * time.Hour),\n457: \t})\n458: \n459: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n460: \n461: \tmgr.ExtendSandboxTTL(c)\n462: \n463: \tassert.Equal(t, http.StatusGone, w.Code)\n464: }\n465: \n466: func TestLifecycleManager_ExtendSandboxTTL_Success(t *testing.T) {\n467: \tgin.SetMode(gin.ReleaseMode)\n468: \tw := httptest.NewRecorder()\n469: \tc, _ := gin.CreateTestContext(w)\n470: \tbody := `{\"extensionDuration\": 7200000000000}`\n471: \tc.Request = httptest.NewRequest(http.MethodPost, \"/extend/session-123\", bytes.NewBufferString(body))\n472: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n473: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n474: \n475: \tstore := newMockStore()\n476: \tctx := context.Background()\n477: \tstore.StoreSandbox(ctx, &SandboxInfo{\n478: \t\tSessionID: \"session-123\",\n479: \t\tExpiresAt: time.Now().Add(1 * time.Hour),\n480: \t})\n481: \n482: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n483: \n484: \tmgr.ExtendSandboxTTL(c)\n485: \n486: \tassert.Equal(t, http.StatusOK, w.Code)\n487: \n488: \tvar wrapper response.SuccessResponse\n489: \terr := json.Unmarshal(w.Body.Bytes(), &wrapper)\n490: \trequire.NoError(t, err)\n491: \n492: \tdataBytes, err := json.Marshal(wrapper.Data)\n493: \trequire.NoError(t, err)\n494: \n495: \tvar resp ExtendTTLResponse\n496: \terr = json.Unmarshal(dataBytes, &resp)\n497: \trequire.NoError(t, err)\n498: \n499: \tassert.Equal(t, \"session-123\", resp.SessionID)\n500: \tassert.True(t, resp.NewExpiry.After(time.Now()))\n501: }\n502: \n503: func TestSandboxStatusResponse_JSONSerialization(t *testing.T) {\n504: \tnow := time.Now()\n505: \texpiresAt := now.Add(1 * time.Hour)\n506: \ttimeToExpiry := 1 * time.Hour\n507: \n508: \tresp := &SandboxStatusResponse{\n509: \t\tSessionID:    \"session-123\",\n510: \t\tSandboxName:  \"sandbox-abc\",\n511: \t\tSandboxID:    \"uid-456\",\n512: \t\tStatus:       \"running\",\n513: \t\tCreatedAt:    now,\n514: \t\tExpiresAt:    expiresAt,\n515: \t\tTimeToExpiry: &timeToExpiry,\n516: \t\tIsExpired:    false,\n517: \t\tEntryPoints: []EntryPoint{\n518: \t\t\t{Path: \"/\", Protocol: \"HTTP\", Endpoint: \"10.0.0.1:8080\"},\n519: \t\t},\n520: \t}\n521: \n522: \tdata, err := json.Marshal(resp)\n523: \trequire.NoError(t, err)\n524: \n525: \tvar decoded SandboxStatusResponse\n526: \terr = json.Unmarshal(data, &decoded)\n527: \trequire.NoError(t, err)\n528: \n529: \tassert.Equal(t, resp.SessionID, decoded.SessionID)\n530: \tassert.Equal(t, resp.IsExpired, decoded.IsExpired)\n531: \tassert.False(t, decoded.IsExpired)\n532: }\n533: \n534: func TestSandboxListItem_JSONSerialization(t *testing.T) {\n535: \tnow := time.Now()\n536: \texpiresAt := now.Add(1 * time.Hour)\n537: \ttimeToExpiry := 1 * time.Hour\n538: \n539: \titem := SandboxListItem{\n540: \t\tSessionID:    \"session-123\",\n541: \t\tSandboxName:  \"sandbox-abc\",\n542: \t\tWorkloadName: \"my-runtime\",\n543: \t\tNamespace:    \"default\",\n544: \t\tKind:         SandboxesKind,\n545: \t\tStatus:       \"running\",\n546: \t\tCreatedAt:    now,\n547: \t\tExpiresAt:    expiresAt,\n548: \t\tTimeToExpiry: &timeToExpiry,\n549: \t\tIsExpired:    false,\n550: \t}\n551: \n552: \tdata, err := json.Marshal(item)\n553: \trequire.NoError(t, err)\n554: \n555: \tvar decoded SandboxListItem\n556: \terr = json.Unmarshal(data, &decoded)\n557: \trequire.NoError(t, err)\n558: \n559: \tassert.Equal(t, item.SessionID, decoded.SessionID)\n560: \tassert.Equal(t, item.Namespace, decoded.Namespace)\n561: }\n562: \n563: func TestListSandboxesResponse_JSONSerialization(t *testing.T) {\n564: \tresp := &ListSandboxesResponse{\n565: \t\tTotal: 2,\n566: \t\tItems: []SandboxListItem{\n567: \t\t\t{SessionID: \"session-1\", SandboxName: \"sandbox-1\"},\n568: \t\t\t{SessionID: \"session-2\", SandboxName: \"sandbox-2\"},\n569: \t\t},\n570: \t}\n571: \n572: \tdata, err := json.Marshal(resp)\n573: \trequire.NoError(t, err)\n574: \n575: \tvar decoded ListSandboxesResponse\n576: \terr = json.Unmarshal(data, &decoded)\n577: \trequire.NoError(t, err)\n578: \n579: \tassert.Equal(t, 2, decoded.Total)\n580: \tassert.Len(t, decoded.Items, 2)\n581: }\n582: \n583: func TestExtendTTLResponse_JSONSerialization(t *testing.T) {\n584: \tnow := time.Now()\n585: \tresp := &ExtendTTLResponse{\n586: \t\tSessionID: \"session-123\",\n587: \t\tNewExpiry: now,\n588: \t}\n589: \n590: \tdata, err := json.Marshal(resp)\n591: \trequire.NoError(t, err)\n592: \n593: \tvar decoded ExtendTTLResponse\n594: \terr = json.Unmarshal(data, &decoded)\n595: \trequire.NoError(t, err)\n596: \n597: \tassert.Equal(t, resp.SessionID, decoded.SessionID)\n598: \tassert.True(t, resp.NewExpiry.Equal(decoded.NewExpiry))\n599: }\n600: \n601: func TestLifecycleManager_CleanupExpiredSandboxes(t *testing.T) {\n602: \tstore := newMockStore()\n603: \tctx := context.Background()\n604: \n605: \tstore.StoreSandbox(ctx, &SandboxInfo{\n606: \t\tSessionID:   \"expired-1\",\n607: \t\tSandboxName: \"sandbox-expired-1\",\n608: \t\tNamespace:   \"default\",\n609: \t\tKind:        SandboxesKind,\n610: \t\tExpiresAt:   time.Now().Add(-1 * time.Hour),\n611: \t})\n612: \tstore.StoreSandbox(ctx, &SandboxInfo{\n613: \t\tSessionID:   \"active-1\",\n614: \t\tSandboxName: \"sandbox-active-1\",\n615: \t\tNamespace:   \"default\",\n616: \t\tKind:        SandboxesKind,\n617: \t\tExpiresAt:   time.Now().Add(1 * time.Hour),\n618: \t})\n619: \n620: \tscheme := runtime.NewScheme()\n621: \tdynClient := fake.NewSimpleDynamicClient(scheme)\n622: \n623: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n624: \t\tStore:         store,\n625: \t\tDynamicClient: dynClient,\n626: \t})\n627: \n628: \tmgr.cleanupExpiredSandboxes(ctx)\n629: \n630: \tlist, err := store.ListSandboxes(ctx)\n631: \trequire.NoError(t, err)\n632: \n633: \tassert.Len(t, list, 1)\n634: \tassert.Equal(t, \"active-1\", list[0].SessionID)\n635: }\n636: \n637: func TestLifecycleManager_IsExpired_BoundaryConditions(t *testing.T) {\n638: \tstore := newMockStore()\n639: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n640: \t\tStore:      store,\n641: \t\tDefaultTTL: 1 * time.Hour,\n642: \t})\n643: \n644: \tnow := time.Now()\n645: \n646: \ttestCases := []struct {\n647: \t\tname     string\n648: \t\tinfo     *SandboxInfo\n649: \t\tnow      time.Time\n650: \t\texpected bool\n651: \t}{\n652: \t\t{\n653: \t\t\tname:     \"expires exactly now\",\n654: \t\t\tinfo:     &SandboxInfo{ExpiresAt: now},\n655: \t\t\tnow:      now,\n656: \t\t\texpected: true,\n657: \t\t},\n658: \t\t{\n659: \t\t\tname:     \"expires 1 second from now\",\n660: \t\t\tinfo:     &SandboxInfo{ExpiresAt: now.Add(1 * time.Second)},\n661: \t\t\tnow:      now,\n662: \t\t\texpected: false,\n663: \t\t},\n664: \t\t{\n665: \t\t\tname:     \"expired 1 second ago\",\n666: \t\t\tinfo:     &SandboxInfo{ExpiresAt: now.Add(-1 * time.Second)},\n667: \t\t\tnow:      now,\n668: \t\t\texpected: true,\n669: \t\t},\n670: \t\t{\n671: \t\t\tname:     \"created exactly TTL ago\",\n672: \t\t\tinfo:     &SandboxInfo{CreatedAt: now.Add(-1 * time.Hour)},\n673: \t\t\tnow:      now,\n674: \t\t\texpected: true,\n675: \t\t},\n676: \t\t{\n677: \t\t\tname:     \"created 1 second before TTL\",\n678: \t\t\tinfo:     &SandboxInfo{CreatedAt: now.Add(-1*time.Hour - 1*time.Second)},\n679: \t\t\tnow:      now,\n680: \t\t\texpected: true,\n681: \t\t},\n682: \t\t{\n683: \t\t\tname:     \"created 1 second after TTL start\",\n684: \t\t\tinfo:     &SandboxInfo{CreatedAt: now.Add(-59 * time.Minute)},\n685: \t\t\tnow:      now,\n686: \t\t\texpected: false,\n687: \t\t},\n688: \t}\n689: \n690: \tfor _, tc := range testCases {\n691: \t\tt.Run(tc.name, func(t *testing.T) {\n692: \t\t\tresult := mgr.isExpired(tc.info, tc.now)\n693: \t\t\tassert.Equal(t, tc.expected, result)\n694: \t\t})\n695: \t}\n696: }\n\n(End of file - total 696 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle_test.go","time":{"start":1775886390125,"end":1775886390133}}}}
{"type":"tool_use","timestamp":1775886391500,"sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","part":{"id":"prt_d7b13d448001PjMN1767SlWdLk","messageID":"msg_d7b13b828001a9kq9BzBQHaRN1","sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","type":"tool","tool":"read","callID":"call_e01ed9e86a4d401bb752a12a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"encoding/json\"\n7: \t\"errors\"\n8: \t\"net/http\"\n9: \t\"net/http/httptest\"\n10: \t\"testing\"\n11: \t\"time\"\n12: \n13: \t\"github.com/gin-gonic/gin\"\n14: \t\"github.com/stretchr/testify/assert\"\n15: \t\"github.com/stretchr/testify/require\"\n16: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n17: )\n18: \n19: type mockStore struct {\n20: \tsandboxes map[string]*SandboxInfo\n21: }\n22: \n23: func newMockStore() *mockStore {\n24: \treturn &mockStore{\n25: \t\tsandboxes: make(map[string]*SandboxInfo),\n26: \t}\n27: }\n28: \n29: func (m *mockStore) StoreSandbox(ctx context.Context, info *SandboxInfo) error {\n30: \tm.sandboxes[info.SessionID] = info\n31: \treturn nil\n32: }\n33: \n34: func (m *mockStore) UpdateSandbox(ctx context.Context, sessionID string, info *SandboxInfo) error {\n35: \tif _, exists := m.sandboxes[sessionID]; !exists {\n36: \t\treturn errors.New(\"sandbox not found\")\n37: \t}\n38: \tm.sandboxes[sessionID] = info\n39: \treturn nil\n40: }\n41: \n42: func (m *mockStore) GetSandbox(ctx context.Context, sessionID string) (*SandboxInfo, error) {\n43: \tinfo, exists := m.sandboxes[sessionID]\n44: \tif !exists {\n45: \t\treturn nil, errors.New(\"sandbox not found\")\n46: \t}\n47: \treturn info, nil\n48: }\n49: \n50: func (m *mockStore) DeleteSandbox(ctx context.Context, sessionID string) error {\n51: \tif _, exists := m.sandboxes[sessionID]; !exists {\n52: \t\treturn errors.New(\"sandbox not found\")\n53: \t}\n54: \tdelete(m.sandboxes, sessionID)\n55: \treturn nil\n56: }\n57: \n58: func (m *mockStore) ListSandboxes(ctx context.Context) ([]*SandboxInfo, error) {\n59: \tresult := make([]*SandboxInfo, 0, len(m.sandboxes))\n60: \tfor _, info := range m.sandboxes {\n61: \t\tresult = append(result, info)\n62: \t}\n63: \treturn result, nil\n64: }\n65: \n66: func TestDeleteSandboxRequest_Validate_SessionIDRequired(t *testing.T) {\n67: \treq := &DeleteSandboxRequest{\n68: \t\tNamespace: \"default\",\n69: \t}\n70: \terr := req.Validate()\n71: \tassert.Error(t, err)\n72: \tassert.Contains(t, err.Error(), \"sessionId is required\")\n73: }\n74: \n75: func TestDeleteSandboxRequest_Validate_NamespaceRequired(t *testing.T) {\n76: \treq := &DeleteSandboxRequest{\n77: \t\tSessionID: \"test-session\",\n78: \t}\n79: \terr := req.Validate()\n80: \tassert.Error(t, err)\n81: \tassert.Contains(t, err.Error(), \"namespace is required\")\n82: }\n83: \n84: func TestDeleteSandboxRequest_Validate_Valid(t *testing.T) {\n85: \treq := &DeleteSandboxRequest{\n86: \t\tSessionID: \"test-session\",\n87: \t\tNamespace: \"default\",\n88: \t}\n89: \terr := req.Validate()\n90: \tassert.NoError(t, err)\n91: }\n92: \n93: func TestSandboxDeleteHandler_ResolveGVR_Sandboxes(t *testing.T) {\n94: \thandler := &SandboxDeleteHandler{}\n95: \tgvr, err := handler.resolveGVR(SandboxesKind)\n96: \trequire.NoError(t, err)\n97: \tassert.Equal(t, SandboxGVR, gvr)\n98: }\n99: \n100: func TestSandboxDeleteHandler_ResolveGVR_SandboxClaims(t *testing.T) {\n101: \thandler := &SandboxDeleteHandler{}\n102: \tgvr, err := handler.resolveGVR(SandboxClaimsKind)\n103: \trequire.NoError(t, err)\n104: \tassert.Equal(t, SandboxClaimGVR, gvr)\n105: }\n106: \n107: func TestSandboxDeleteHandler_ResolveGVR_UnknownKind(t *testing.T) {\n108: \thandler := &SandboxDeleteHandler{}\n109: \t_, err := handler.resolveGVR(\"UnknownKind\")\n110: \tassert.Error(t, err)\n111: \tassert.Contains(t, err.Error(), \"unknown sandbox kind\")\n112: }\n113: \n114: func TestDeleteSandbox_InvalidRequestBody(t *testing.T) {\n115: \tgin.SetMode(gin.ReleaseMode)\n116: \tw := httptest.NewRecorder()\n117: \tc, _ := gin.CreateTestContext(w)\n118: \tc.Request = httptest.NewRequest(http.MethodPost, \"/delete\", nil)\n119: \n120: \tstore := newMockStore()\n121: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{\n122: \t\tStore: store,\n123: \t})\n124: \n125: \thandler.DeleteSandbox(c)\n126: \n127: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n128: \n129: \tvar resp map[string]interface{}\n130: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n131: \trequire.NoError(t, err)\n132: \tassert.Equal(t, \"Invalid request body\", resp[\"error\"])\n133: }\n134: \n135: func TestDeleteSandbox_MissingSessionID(t *testing.T) {\n136: \tgin.SetMode(gin.ReleaseMode)\n137: \tw := httptest.NewRecorder()\n138: \tc, _ := gin.CreateTestContext(w)\n139: \tc.Request = httptest.NewRequest(http.MethodPost, \"/delete\", bytes.NewBufferString(`{\"namespace\": \"default\"}`))\n140: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n141: \n142: \tstore := newMockStore()\n143: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{\n144: \t\tStore: store,\n145: \t})\n146: \n147: \thandler.DeleteSandbox(c)\n148: \n149: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n150: }\n151: \n152: func TestDeleteSandbox_SessionNotFound(t *testing.T) {\n153: \tgin.SetMode(gin.ReleaseMode)\n154: \tw := httptest.NewRecorder()\n155: \tc, _ := gin.CreateTestContext(w)\n156: \tc.Request = httptest.NewRequest(http.MethodPost, \"/delete\", bytes.NewBufferString(`{\"sessionId\": \"nonexistent\", \"namespace\": \"default\"}`))\n157: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n158: \n159: \tstore := newMockStore()\n160: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{\n161: \t\tStore: store,\n162: \t})\n163: \n164: \thandler.DeleteSandbox(c)\n165: \n166: \tassert.Equal(t, http.StatusNotFound, w.Code)\n167: }\n168: \n169: func TestDeleteSandboxByName_MissingName(t *testing.T) {\n170: \tgin.SetMode(gin.ReleaseMode)\n171: \tw := httptest.NewRecorder()\n172: \tc, _ := gin.CreateTestContext(w)\n173: \tc.Request = httptest.NewRequest(http.MethodDelete, \"/sandboxes/\", nil)\n174: \tc.Params = gin.Params{{Key: \"name\", Value: \"\"}}\n175: \n176: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{})\n177: \n178: \thandler.DeleteSandboxByName(c)\n179: \n180: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n181: }\n182: \n183: func TestDeleteSandboxByName_MissingNamespace(t *testing.T) {\n184: \tgin.SetMode(gin.ReleaseMode)\n185: \tw := httptest.NewRecorder()\n186: \tc, _ := gin.CreateTestContext(w)\n187: \tc.Request = httptest.NewRequest(http.MethodDelete, \"/sandboxes/test-sandbox\", nil)\n188: \tc.Params = gin.Params{{Key: \"name\", Value: \"test-sandbox\"}}\n189: \tc.Request.URL.RawQuery = \"\"\n190: \n191: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{})\n192: \n193: \thandler.DeleteSandboxByName(c)\n194: \n195: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n196: }\n197: \n198: func TestDeleteSandboxResponse_JSONSerialization(t *testing.T) {\n199: \tresp := &DeleteSandboxResponse{\n200: \t\tSessionID:   \"test-session\",\n201: \t\tSandboxName: \"test-sandbox\",\n202: \t\tDeleted:     true,\n203: \t\tMessage:     \"sandbox deleted successfully\",\n204: \t}\n205: \n206: \tdata, err := json.Marshal(resp)\n207: \trequire.NoError(t, err)\n208: \n209: \tvar decoded DeleteSandboxResponse\n210: \terr = json.Unmarshal(data, &decoded)\n211: \trequire.NoError(t, err)\n212: \n213: \tassert.Equal(t, resp.SessionID, decoded.SessionID)\n214: \tassert.Equal(t, resp.SandboxName, decoded.SandboxName)\n215: \tassert.Equal(t, resp.Deleted, decoded.Deleted)\n216: \tassert.Equal(t, resp.Message, decoded.Message)\n217: }\n218: \n219: func TestSandboxInfo_WithAllFields(t *testing.T) {\n220: \tnow := time.Now()\n221: \texpiresAt := now.Add(8 * time.Hour)\n222: \n223: \tinfo := &SandboxInfo{\n224: \t\tSessionID:    \"session-123\",\n225: \t\tSandboxName:  \"sandbox-abc\",\n226: \t\tSandboxID:    \"uid-456\",\n227: \t\tWorkloadName: \"my-runtime\",\n228: \t\tNamespace:    \"default\",\n229: \t\tKind:         SandboxesKind,\n230: \t\tPodIP:        \"10.0.0.1\",\n231: \t\tEntryPoints: []EntryPoint{\n232: \t\t\t{Path: \"/\", Protocol: \"HTTP\", Endpoint: \"10.0.0.1:8080\"},\n233: \t\t},\n234: \t\tCreatedAt: now,\n235: \t\tExpiresAt: expiresAt,\n236: \t\tStatus:    \"running\",\n237: \t}\n238: \n239: \tassert.Equal(t, \"session-123\", info.SessionID)\n240: \tassert.Equal(t, \"sandbox-abc\", info.SandboxName)\n241: \tassert.Equal(t, \"running\", info.Status)\n242: \tassert.False(t, info.ExpiresAt.IsZero())\n243: }\n244: \n245: func TestDeleteSandboxRequest_AllFieldsSet(t *testing.T) {\n246: \treq := &DeleteSandboxRequest{\n247: \t\tSessionID: \"session-123\",\n248: \t\tNamespace: \"test-namespace\",\n249: \t}\n250: \n251: \tassert.NoError(t, req.Validate())\n252: \tassert.Equal(t, \"session-123\", req.SessionID)\n253: \tassert.Equal(t, \"test-namespace\", req.Namespace)\n254: }\n255: \n256: func TestMockStore_StoreAndGet(t *testing.T) {\n257: \tstore := newMockStore()\n258: \tctx := context.Background()\n259: \n260: \tinfo := &SandboxInfo{\n261: \t\tSessionID:   \"test-session\",\n262: \t\tSandboxName: \"test-sandbox\",\n263: \t\tNamespace:   \"default\",\n264: \t\tKind:        SandboxesKind,\n265: \t\tCreatedAt:   time.Now(),\n266: \t\tStatus:      \"running\",\n267: \t}\n268: \n269: \terr := store.StoreSandbox(ctx, info)\n270: \trequire.NoError(t, err)\n271: \n272: \tretrieved, err := store.GetSandbox(ctx, \"test-session\")\n273: \trequire.NoError(t, err)\n274: \tassert.Equal(t, info.SessionID, retrieved.SessionID)\n275: \tassert.Equal(t, info.SandboxName, retrieved.SandboxName)\n276: }\n277: \n278: func TestMockStore_Update(t *testing.T) {\n279: \tstore := newMockStore()\n280: \tctx := context.Background()\n281: \n282: \tinfo := &SandboxInfo{\n283: \t\tSessionID:   \"test-session\",\n284: \t\tSandboxName: \"test-sandbox\",\n285: \t\tNamespace:   \"default\",\n286: \t\tKind:        SandboxesKind,\n287: \t\tCreatedAt:   time.Now(),\n288: \t\tStatus:      \"pending\",\n289: \t}\n290: \n291: \terr := store.StoreSandbox(ctx, info)\n292: \trequire.NoError(t, err)\n293: \n294: \tinfo.Status = \"running\"\n295: \terr = store.UpdateSandbox(ctx, \"test-session\", info)\n296: \trequire.NoError(t, err)\n297: \n298: \tretrieved, err := store.GetSandbox(ctx, \"test-session\")\n299: \trequire.NoError(t, err)\n300: \tassert.Equal(t, \"running\", retrieved.Status)\n301: }\n302: \n303: func TestMockStore_UpdateNonExistent(t *testing.T) {\n304: \tstore := newMockStore()\n305: \tctx := context.Background()\n306: \n307: \tinfo := &SandboxInfo{\n308: \t\tSessionID:   \"test-session\",\n309: \t\tSandboxName: \"test-sandbox\",\n310: \t}\n311: \n312: \terr := store.UpdateSandbox(ctx, \"nonexistent\", info)\n313: \tassert.Error(t, err)\n314: }\n315: \n316: func TestMockStore_Delete(t *testing.T) {\n317: \tstore := newMockStore()\n318: \tctx := context.Background()\n319: \n320: \tinfo := &SandboxInfo{\n321: \t\tSessionID:   \"test-session\",\n322: \t\tSandboxName: \"test-sandbox\",\n323: \t}\n324: \n325: \terr := store.StoreSandbox(ctx, info)\n326: \trequire.NoError(t, err)\n327: \n328: \terr = store.DeleteSandbox(ctx, \"test-session\")\n329: \trequire.NoError(t, err)\n330: \n331: \t_, err = store.GetSandbox(ctx, \"test-session\")\n332: \tassert.Error(t, err)\n333: }\n334: \n335: func TestMockStore_DeleteNonExistent(t *testing.T) {\n336: \tstore := newMockStore()\n337: \tctx := context.Background()\n338: \n339: \terr := store.DeleteSandbox(ctx, \"nonexistent\")\n340: \tassert.Error(t, err)\n341: }\n342: \n343: func TestMockStore_List(t *testing.T) {\n344: \tstore := newMockStore()\n345: \tctx := context.Background()\n346: \n347: \tstore.StoreSandbox(ctx, &SandboxInfo{SessionID: \"session-1\", SandboxName: \"sandbox-1\", Namespace: \"default\"})\n348: \tstore.StoreSandbox(ctx, &SandboxInfo{SessionID: \"session-2\", SandboxName: \"sandbox-2\", Namespace: \"test\"})\n349: \n350: \tlist, err := store.ListSandboxes(ctx)\n351: \trequire.NoError(t, err)\n352: \tassert.Len(t, list, 2)\n353: }\n354: \n355: func TestMockStore_ListEmpty(t *testing.T) {\n356: \tstore := newMockStore()\n357: \tctx := context.Background()\n358: \n359: \tlist, err := store.ListSandboxes(ctx)\n360: \trequire.NoError(t, err)\n361: \tassert.Empty(t, list)\n362: }\n363: \n364: func TestResolveGVR_AllKnownKinds(t *testing.T) {\n365: \thandler := &SandboxDeleteHandler{}\n366: \n367: \ttestCases := []struct {\n368: \t\tkind        string\n369: \t\texpectedGVR schema.GroupVersionResource\n370: \t\texpectError bool\n371: \t}{\n372: \t\t{SandboxesKind, SandboxGVR, false},\n373: \t\t{SandboxClaimsKind, SandboxClaimGVR, false},\n374: \t\t{\"Unknown\", schema.GroupVersionResource{}, true},\n375: \t\t{\"\", schema.GroupVersionResource{}, true},\n376: \t}\n377: \n378: \tfor _, tc := range testCases {\n379: \t\tgvr, err := handler.resolveGVR(tc.kind)\n380: \t\tif tc.expectError {\n381: \t\t\tassert.Error(t, err, \"kind: %s\", tc.kind)\n382: \t\t} else {\n383: \t\t\tassert.NoError(t, err, \"kind: %s\", tc.kind)\n384: \t\t\tassert.Equal(t, tc.expectedGVR, gvr, \"kind: %s\", tc.kind)\n385: \t\t}\n386: \t}\n387: }\n\n(End of file - total 387 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n)\n\ntype mockStore struct {\n\tsandboxes map[string]*SandboxInfo","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go","time":{"start":1775886391491,"end":1775886391498}}}}
{"type":"tool_use","timestamp":1775886392883,"sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","part":{"id":"prt_d7b13d9530013lSKRKS1TxbLFH","messageID":"msg_d7b13b828001a9kq9BzBQHaRN1","sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","type":"tool","tool":"read","callID":"call_6c292ba006fa4d48915dad18","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/metrics.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/metrics.go</path>\n<type>file</type>\n<content>\n1: package reconciler\n2: \n3: import (\n4: \t\"time\"\n5: \n6: \t\"github.com/prometheus/client_golang/prometheus\"\n7: )\n8: \n9: type PrometheusMetricsRecorder struct {\n10: \treconcileTotal    *prometheus.CounterVec\n11: \treconcileDuration *prometheus.HistogramVec\n12: \treconcileErrors   *prometheus.CounterVec\n13: \tworkqueueDepth    prometheus.Gauge\n14: \tworkqueueAdds     *prometheus.CounterVec\n15: \n16: \tgcCleanupTotal    *prometheus.CounterVec\n17: \tgcCleanupDuration *prometheus.HistogramVec\n18: \tgcCleanupErrors   *prometheus.CounterVec\n19: \tgcCycleDuration   *prometheus.HistogramVec\n20: }\n21: \n22: func NewPrometheusMetricsRecorder(reg prometheus.Registerer) *PrometheusMetricsRecorder {\n23: \tr := &PrometheusMetricsRecorder{\n24: \t\treconcileTotal: prometheus.NewCounterVec(prometheus.CounterOpts{\n25: \t\t\tName: \"reconcile_total\",\n26: \t\t\tHelp: \"Total number of reconciliations\",\n27: \t\t}, []string{\"resource_type\", \"result\"}),\n28: \t\treconcileDuration: prometheus.NewHistogramVec(prometheus.HistogramOpts{\n29: \t\t\tName:    \"reconcile_duration_seconds\",\n30: \t\t\tHelp:    \"Reconciliation duration distribution\",\n31: \t\t\tBuckets: []float64{0.01, 0.05, 0.1, 0.5, 1, 5, 10, 30},\n32: \t\t}, []string{\"resource_type\"}),\n33: \t\treconcileErrors: prometheus.NewCounterVec(prometheus.CounterOpts{\n34: \t\t\tName: \"reconcile_errors_total\",\n35: \t\t\tHelp: \"Total number of reconciliation errors\",\n36: \t\t}, []string{\"resource_type\", \"error_type\"}),\n37: \t\tworkqueueDepth: prometheus.NewGauge(prometheus.GaugeOpts{\n38: \t\t\tName: \"workqueue_depth\",\n39: \t\t\tHelp: \"Current workqueue depth\",\n40: \t\t}),\n41: \t\tworkqueueAdds: prometheus.NewCounterVec(prometheus.CounterOpts{\n42: \t\t\tName: \"workqueue_adds_total\",\n43: \t\t\tHelp: \"Total number of workqueue adds\",\n44: \t\t}, []string{\"resource_type\"}),\n45: \t\tgcCleanupTotal: prometheus.NewCounterVec(prometheus.CounterOpts{\n46: \t\t\tName: \"gc_cleanup_total\",\n47: \t\t\tHelp: \"Total number of GC cleanup operations\",\n48: \t\t}, []string{\"reason\"}),\n49: \t\tgcCleanupDuration: prometheus.NewHistogramVec(prometheus.HistogramOpts{\n50: \t\t\tName:    \"gc_cleanup_duration_seconds\",\n51: \t\t\tHelp:    \"GC cleanup duration distribution\",\n52: \t\t\tBuckets: []float64{0.01, 0.05, 0.1, 0.5, 1, 5, 10, 30},\n53: \t\t}, []string{\"reason\"}),\n54: \t\tgcCleanupErrors: prometheus.NewCounterVec(prometheus.CounterOpts{\n55: \t\t\tName: \"gc_cleanup_errors_total\",\n56: \t\t\tHelp: \"Total number of GC cleanup errors\",\n57: \t\t}, []string{\"reason\"}),\n58: \t\tgcCycleDuration: prometheus.NewHistogramVec(prometheus.HistogramOpts{\n59: \t\t\tName:    \"gc_cycle_duration_seconds\",\n60: \t\t\tHelp:    \"GC cycle duration distribution\",\n61: \t\t\tBuckets: []float64{1, 5, 10, 30, 60, 120, 300},\n62: \t\t}, nil),\n63: \t}\n64: \n65: \tif reg != nil {\n66: \t\treg.MustRegister(r.reconcileTotal)\n67: \t\treg.MustRegister(r.reconcileDuration)\n68: \t\treg.MustRegister(r.reconcileErrors)\n69: \t\treg.MustRegister(r.workqueueDepth)\n70: \t\treg.MustRegister(r.workqueueAdds)\n71: \t\treg.MustRegister(r.gcCleanupTotal)\n72: \t\treg.MustRegister(r.gcCleanupDuration)\n73: \t\treg.MustRegister(r.gcCleanupErrors)\n74: \t\treg.MustRegister(r.gcCycleDuration)\n75: \t}\n76: \n77: \treturn r\n78: }\n79: \n80: func (r *PrometheusMetricsRecorder) IncReconcileTotal(resourceType string, result string) {\n81: \tif r == nil {\n82: \t\treturn\n83: \t}\n84: \tr.reconcileTotal.WithLabelValues(resourceType, result).Inc()\n85: }\n86: \n87: func (r *PrometheusMetricsRecorder) ObserveReconcileDuration(resourceType string, duration time.Duration) {\n88: \tif r == nil {\n89: \t\treturn\n90: \t}\n91: \tr.reconcileDuration.WithLabelValues(resourceType).Observe(duration.Seconds())\n92: }\n93: \n94: func (r *PrometheusMetricsRecorder) IncReconcileErrors(resourceType string, errorType string) {\n95: \tif r == nil {\n96: \t\treturn\n97: \t}\n98: \tr.reconcileErrors.WithLabelValues(resourceType, errorType).Inc()\n99: }\n100: \n101: func (r *PrometheusMetricsRecorder) SetWorkqueueDepth(depth int) {\n102: \tif r == nil {\n103: \t\treturn\n104: \t}\n105: \tr.workqueueDepth.Set(float64(depth))\n106: }\n107: \n108: func (r *PrometheusMetricsRecorder) IncWorkqueueAdds(resourceType string) {\n109: \tif r == nil {\n110: \t\treturn\n111: \t}\n112: \tr.workqueueAdds.WithLabelValues(resourceType).Inc()\n113: }\n114: \n115: func (r *PrometheusMetricsRecorder) IncGCCleanupTotal(reason string) {\n116: \tif r == nil {\n117: \t\treturn\n118: \t}\n119: \tr.gcCleanupTotal.WithLabelValues(reason).Inc()\n120: }\n121: \n122: func (r *PrometheusMetricsRecorder) ObserveGCCleanupDuration(reason string, duration time.Duration) {\n123: \tif r == nil {\n124: \t\treturn\n125: \t}\n126: \tr.gcCleanupDuration.WithLabelValues(reason).Observe(duration.Seconds())\n127: }\n128: \n129: func (r *PrometheusMetricsRecorder) IncGCCleanupErrors(reason string) {\n130: \tif r == nil {\n131: \t\treturn\n132: \t}\n133: \tr.gcCleanupErrors.WithLabelValues(reason).Inc()\n134: }\n135: \n136: func (r *PrometheusMetricsRecorder) ObserveGCCycleDuration(duration time.Duration) {\n137: \tif r == nil {\n138: \t\treturn\n139: \t}\n140: \tr.gcCycleDuration.WithLabelValues().Observe(duration.Seconds())\n141: }\n\n(End of file - total 141 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"time\"\n\n\t\"github.com/prometheus/client_golang/prometheus\"\n)\n\ntype PrometheusMetricsRecorder struct {\n\treconcileTotal    *prometheus.CounterVec\n\treconcileDuration *prometheus.HistogramVec\n\treconcileErrors   *prometheus.CounterVec\n\tworkqueueDepth    prometheus.Gauge\n\tworkqueueAdds     *prometheus.CounterVec\n\n\tgcCleanupTotal    *prometheus.CounterVec\n\tgcCleanupDuration *prometheus.HistogramVec\n\tgcCleanupErrors   *prometheus.CounterVec\n\tgcCycleDuration   *prometheus.HistogramVec\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/metrics.go","time":{"start":1775886392874,"end":1775886392881}}}}
