qual(t, \"test\", result[\"name\"])\n46: }\n47: \n48: func TestError_BadRequest(t *testing.T) {\n49: \tgin.SetMode(gin.ReleaseMode)\n50: \tw := httptest.NewRecorder()\n51: \tc, _ := gin.CreateTestContext(w)\n52: \n53: \tError(c, http.StatusBadRequest, 40001, \"missing parameter\")\n54: \n55: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n56: \n57: \tvar resp ErrorResponse\n58: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n59: \tassert.NoError(t, err)\n60: \tassert.Equal(t, \"missing parameter\", resp.Error)\n61: \tassert.Equal(t, 40001, resp.Code)\n62: \tassert.Empty(t, resp.RequestID)\n63: }\n64: \n65: func TestError_NotFound(t *testing.T) {\n66: \tgin.SetMode(gin.ReleaseMode)\n67: \tw := httptest.NewRecorder()\n68: \tc, _ := gin.CreateTestContext(w)\n69: \n70: \tError(c, http.StatusNotFound, 40401, \"not found\")\n71: \n72: \tassert.Equal(t, http.StatusNotFound, w.Code)\n73: \n74: \tvar resp ErrorResponse\n75: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n76: \tassert.NoError(t, err)\n77: \tassert.Equal(t, 40401, resp.Code)\n78: }\n79: \n80: func TestError_Internal(t *testing.T) {\n81: \tgin.SetMode(gin.ReleaseMode)\n82: \tw := httptest.NewRecorder()\n83: \tc, _ := gin.CreateTestContext(w)\n84: \n85: \tError(c, http.StatusInternalServerError, 50001, \"internal error\")\n86: \n87: \tassert.Equal(t, http.StatusInternalServerError, w.Code)\n88: \n89: \tvar resp ErrorResponse\n90: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n91: \tassert.NoError(t, err)\n92: \tassert.Equal(t, 50001, resp.Code)\n93: }\n94: \n95: func TestError_WithRequestID(t *testing.T) {\n96: \tgin.SetMode(gin.ReleaseMode)\n97: \tw := httptest.NewRecorder()\n98: \tc, _ := gin.CreateTestContext(w)\n99: \n100: \tErrorWithID(c, http.StatusBadRequest, 40001, \"bad request\", \"test-request-id\")\n101: \n102: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n103: \n104: \tvar resp ErrorResponse\n105: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n106: \tassert.NoError(t, err)\n107: \tassert.Equal(t, \"bad request\", resp.Error)\n108: \tassert.Equal(t, 40001, resp.Code)\n109: \tassert.Equal(t, \"test-request-id\", resp.RequestID)\n110: }\n\n(End of file - total 110 lines)\n</content>","metadata":{"preview":"package response\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestJSON_Success(t *testing.T) {\n\tgin.SetMode(gin.ReleaseMode)\n\tw := httptest.NewRecorder()\n\tc, _ := gin.CreateTestContext(w)\n\n\tdata := map[string]string{\"key\": \"value\"}\n\tJSON(c, http.StatusOK, data)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/response/response_test.go","time":{"start":1775886388885,"end":1775886388892}}}}
{"type":"tool_use","timestamp":1775886390135,"sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","part":{"id":"prt_d7b13cf3e001gD4ijCHdKzBBVO","messageID":"msg_d7b13b828001a9kq9BzBQHaRN1","sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","type":"tool","tool":"read","callID":"call_e82e9f6cd2fb45138c7b15d8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle_test.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"encoding/json\"\n7: \t\"net/http\"\n8: \t\"net/http/httptest\"\n9: \t\"testing\"\n10: \t\"time\"\n11: \n12: \t\"github.com/gin-gonic/gin\"\n13: \t\"github.com/stretchr/testify/assert\"\n14: \t\"github.com/stretchr/testify/require\"\n15: \t\"k8s.io/apimachinery/pkg/runtime\"\n16: \t\"k8s.io/client-go/dynamic/fake\"\n17: \n18: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n19: )\n20: \n21: func TestLifecycleManager_New_DefaultValues(t *testing.T) {\n22: \tstore := newMockStore()\n23: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n24: \t\tStore: store,\n25: \t})\n26: \n27: \tassert.NotNil(t, mgr)\n28: \tassert.Equal(t, 5*time.Minute, mgr.checkInterval)\n29: \tassert.Equal(t, 8*time.Hour, mgr.defaultTTL)\n30: \tassert.False(t, mgr.running)\n31: }\n32: \n33: func TestLifecycleManager_New_CustomValues(t *testing.T) {\n34: \tstore := newMockStore()\n35: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n36: \t\tStore:         store,\n37: \t\tCheckInterval: 10 * time.Minute,\n38: \t\tDefaultTTL:    4 * time.Hour,\n39: \t})\n40: \n41: \tassert.NotNil(t, mgr)\n42: \tassert.Equal(t, 10*time.Minute, mgr.checkInterval)\n43: \tassert.Equal(t, 4*time.Hour, mgr.defaultTTL)\n44: }\n45: \n46: func TestLifecycleManager_IsExpired_WithExpiresAt(t *testing.T) {\n47: \tstore := newMockStore()\n48: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n49: \n50: \tnow := time.Now()\n51: \n52: \tinfo := &SandboxInfo{\n53: \t\tSessionID: \"test\",\n54: \t\tExpiresAt: now.Add(1 * time.Hour),\n55: \t}\n56: \tassert.False(t, mgr.isExpired(info, now))\n57: \n58: \tinfo.ExpiresAt = now.Add(-1 * time.Hour)\n59: \tassert.True(t, mgr.isExpired(info, now))\n60: }\n61: \n62: func TestLifecycleManager_IsExpired_WithCreatedAt(t *testing.T) {\n63: \tstore := newMockStore()\n64: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n65: \t\tStore:      store,\n66: \t\tDefaultTTL: 1 * time.Hour,\n67: \t})\n68: \n69: \tnow := time.Now()\n70: \n71: \tinfo := &SandboxInfo{\n72: \t\tSessionID: \"test\",\n73: \t\tCreatedAt: now.Add(-30 * time.Minute),\n74: \t}\n75: \tassert.False(t, mgr.isExpired(info, now))\n76: \n77: \tinfo.CreatedAt = now.Add(-2 * time.Hour)\n78: \tassert.True(t, mgr.isExpired(info, now))\n79: }\n80: \n81: func TestLifecycleManager_IsExpired_NoTimestamps(t *testing.T) {\n82: \tstore := newMockStore()\n83: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n84: \n85: \tinfo := &SandboxInfo{\n86: \t\tSessionID: \"test\",\n87: \t}\n88: \tassert.False(t, mgr.isExpired(info, time.Now()))\n89: }\n90: \n91: func TestLifecycleManager_StartStop(t *testing.T) {\n92: \tstore := newMockStore()\n93: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n94: \t\tStore:         store,\n95: \t\tCheckInterval: 100 * time.Millisecond,\n96: \t})\n97: \n98: \tctx, cancel := context.WithCancel(context.Background())\n99: \tdefer cancel()\n100: \n101: \tmgr.Start(ctx)\n102: \tassert.True(t, mgr.running)\n103: \n104: \tmgr.Stop()\n105: \tassert.False(t, mgr.running)\n106: }\n107: \n108: func TestLifecycleManager_StartIdempotent(t *testing.T) {\n109: \tstore := newMockStore()\n110: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{\n111: \t\tStore: store,\n112: \t})\n113: \n114: \tctx := context.Background()\n115: \n116: \tmgr.Start(ctx)\n117: \tstopCh1 := mgr.stopCh\n118: \n119: \tmgr.Start(ctx)\n120: \tassert.Equal(t, stopCh1, mgr.stopCh)\n121: \n122: \tmgr.Stop()\n123: }\n124: \n125: func TestExtendTTLRequest_Validate_Positive(t *testing.T) {\n126: \treq := &ExtendTTLRequest{\n127: \t\tExtensionDuration: 2 * time.Hour,\n128: \t}\n129: \terr := req.Validate()\n130: \tassert.NoError(t, err)\n131: }\n132: \n133: func TestExtendTTLRequest_Validate_Negative(t *testing.T) {\n134: \treq := &ExtendTTLRequest{\n135: \t\tExtensionDuration: -1 * time.Hour,\n136: \t}\n137: \terr := req.Validate()\n138: \tassert.Error(t, err)\n139: \tassert.Contains(t, err.Error(), \"must be positive\")\n140: }\n141: \n142: func TestExtendTTLRequest_Validate_Zero(t *testing.T) {\n143: \treq := &ExtendTTLRequest{\n144: \t\tExtensionDuration: 0,\n145: \t}\n146: \terr := req.Validate()\n147: \tassert.Error(t, err)\n148: \tassert.Contains(t, err.Error(), \"must be positive\")\n149: }\n150: \n151: func TestExtendTTLRequest_Validate_ExceedsMax(t *testing.T) {\n152: \treq := &ExtendTTLRequest{\n153: \t\tExtensionDuration: 25 * time.Hour,\n154: \t}\n155: \terr := req.Validate()\n156: \tassert.Error(t, err)\n157: \tassert.Contains(t, err.Error(), \"cannot exceed 24 hours\")\n158: }\n159: \n160: func TestExtendTTLRequest_Validate_MaxAllowed(t *testing.T) {\n161: \treq := &ExtendTTLRequest{\n162: \t\tExtensionDuration: 24 * time.Hour,\n163: \t}\n164: \terr := req.Validate()\n165: \tassert.NoError(t, err)\n166: }\n167: \n168: func TestLifecycleManager_GetSandboxStatus_MissingSessionID(t *testing.T) {\n169: \tgin.SetMode(gin.ReleaseMode)\n170: \tw := httptest.NewRecorder()\n171: \tc, _ := gin.CreateTestContext(w)\n172: \tc.Request = httptest.NewRequest(http.MethodGet, \"/status/\", nil)\n173: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"\"}}\n174: \n175: \tstore := newMockStore()\n176: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n177: \n178: \tmgr.GetSandboxStatus(c)\n179: \n180: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n181: }\n182: \n183: func TestLifecycleManager_GetSandboxStatus_NotFound(t *testing.T) {\n184: \tgin.SetMode(gin.ReleaseMode)\n185: \tw := httptest.NewRecorder()\n186: \tc, _ := gin.CreateTestContext(w)\n187: \tc.Request = httptest.NewRequest(http.MethodGet, \"/status/session-123\", nil)\n188: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n189: \n190: \tstore := newMockStore()\n191: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n192: \n193: \tmgr.GetSandboxStatus(c)\n194: \n195: \tassert.Equal(t, http.StatusNotFound, w.Code)\n196: }\n197: \n198: func TestLifecycleManager_GetSandboxStatus_Success(t *testing.T) {\n199: \tgin.SetMode(gin.ReleaseMode)\n200: \tw := httptest.NewRecorder()\n201: \tc, _ := gin.CreateTestContext(w)\n202: \tc.Request = httptest.NewRequest(http.MethodGet, \"/status/session-123\", nil)\n203: \tc.Params = gin.Params{{Key: \"sessionID\", Value: \"session-123\"}}\n204: \n205: \tstore := newMockStore()\n206: \tctx := context.Background()\n207: \tstore.StoreSandbox(ctx, &SandboxInfo{\n208: \t\tSessionID:   \"session-123\",\n209: \t\tSandboxName: \"sandbox-abc\",\n210: \t\tSandboxID:   \"uid-456\",\n211: \t\tNamespace:   \"default\",\n212: \t\tKind:        SandboxesKind,\n213: \t\tStatus:      \"running\",\n214: \t\tCreatedAt:   time.Now().Add(-1 * time.Hour),\n215: \t\tExpiresAt:   time.Now().Add(7 * time.Hour),\n216: \t\tEntryPoints: []EntryPoint{\n217: \t\t\t{Path: \"/\", Protocol: \"HTTP\", Endpoint: \"10.0.0.1:8080\"},\n218: \t\t},\n219: \t})\n220: \n221: \tmgr := NewLifecycleManager(&LifecycleManagerDeps{Store: store})\n222: \n223: \tmgr.GetSandboxStatus(c)\n224: \n225: \tassert.Equal(t, http.StatusOK, w.Code)\n226: \n227: \tvar wrapper response.SuccessResponse\n228: \terr := json.Unmarshal(w.Body.Bytes(), &wrapper)\n229: \trequire.NoError(t, err)\n230: \n231: \tdataBytes, err := json.Marshal(wrapper.Data)\n232: 