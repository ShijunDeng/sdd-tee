 \t}\n40: \n41: \tif r.podInformer != nil {\n42: \t\t_, podErr := r.podInformer.Lister().Pods(namespace).Get(name)\n43: \t\tif podErr == nil {\n44: \t\t\treturn r.reconcilePod(key)\n45: \t\t}\n46: \t\tif !apierrors.IsNotFound(podErr) && podErr != nil {\n47: \t\t\treturn fmt.Errorf(\"failed to get Pod: %w\", podErr)\n48: \t\t}\n49: \t}\n50: \n51: \treturn nil\n52: }\n53: \n54: func (r *SandboxReconciler) processNextWorkItem() bool {\n55: \tobj, shutdown := r.workqueue.Get()\n56: \tif shutdown {\n57: \t\treturn false\n58: \t}\n59: \n60: \tvar key string\n61: \tvar ok bool\n62: \tif key, ok = obj.(string); !ok {\n63: \t\tr.workqueue.Done(obj)\n64: \t\tr.workqueue.Forget(obj)\n65: \t\treturn true\n66: \t}\n67: \n68: \tstartTime := time.Now()\n69: \terr := r.syncHandler(key)\n70: \tduration := time.Since(startTime)\n71: \n72: \tresourceType := r.determineResourceType(key)\n73: \n74: \tif r.metricsRecorder != nil {\n75: \t\tr.metricsRecorder.ObserveReconcileDuration(resourceType, duration)\n76: \t}\n77: \n78: \tif err != nil {\n79: \t\tif r.metricsRecorder != nil {\n80: \t\t\tr.metricsRecorder.IncReconcileTotal(resourceType, resultError)\n81: \t\t}\n82: \t\tnumRequeues := r.workqueue.NumRequeues(key)\n83: \t\tif numRequeues >= maxRetries {\n84: \t\t\tlog.Printf(\"[reconciler] max retries (%d) exceeded for key %s: %v\", maxRetries, key, err)\n85: \t\t\tr.workqueue.Forget(key)\n86: \t\t\truntime.HandleError(fmt.Errorf(\"max retries exceeded for key %s: %w\", key, err))\n87: \t\t} else {\n88: \t\t\tlog.Printf(\"[reconciler] error syncing key %s (attempt %d/%d): %v\", key, numRequeues+1, maxRetries, err)\n89: \t\t\tr.workqueue.AddRateLimited(key)\n90: \t\t}\n91: \t\tr.workqueue.Done(key)\n92: \t\treturn true\n93: \t}\n94: \n95: \tif r.metricsRecorder != nil {\n96: \t\tr.metricsRecorder.IncReconcileTotal(resourceType, resultSuccess)\n97: \t}\n98: \tr.workqueue.Forget(key)\n99: \tr.workqueue.Done(key)\n100: \treturn true\n101: }\n102: \n103: func (r *SandboxReconciler) runWorker() {\n104: \tfor r.processNextWorkItem() {\n105: \t}\n106: }\n107: \n108: func (r *SandboxReconciler) determineResourceType(key string) string {\n109: \tnamespace, name, err := cache.SplitMetaNamespaceKey(key)\n110: \tif err != nil {\n111: \t\treturn resourceTypeAgentRuntime\n112: \t}\n113: \n114: \t_, err = r.arLister.AgentRuntimes(namespace).Get(name)\n115: \tif err == nil {\n116: \t\treturn resourceTypeAgentRuntime\n117: \t}\n118: \n119: \t_, err = r.ciLister.CodeInterpreters(namespace).Get(name)\n120: \tif err == nil {\n121: \t\treturn resourceTypeCodeInterpreter\n122: \t}\n123: \n124: \treturn resourceTypePod\n125: }\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"fmt\"\n\t\"log\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/util/runtime\"\n\t\"k8s.io/client-go/tools/cache\"\n)\n\nfunc (r *SandboxReconciler) syncHandler(key string) error {\n\tnamespace, name, err := cache.SplitMetaNamespaceKey(key)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"invalid key %q: %w\", key, err)\n\t}\n\n\t_, arErr := r.arLister.AgentRuntimes(namespace).Get(name)\n\tif arErr == nil {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/sync.go","time":{"start":1775886354748,"end":1775886354761}}}}
