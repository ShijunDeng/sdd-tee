5: \t\tif r.metricsRecorder != nil {\n46: \t\t\tr.metricsRecorder.IncReconcileErrors(resourceTypeAgentRuntime, errorTypeListerFailure)\n47: \t\t}\n48: \t\treturn fmt.Errorf(\"failed to get AgentRuntime %s/%s: %w\", namespace, name, err)\n49: \t}\n50: \n51: \tsessionID := ar.Labels[\"runtime.agentcube.io/session-id\"]\n52: \tif sessionID == \"\" {\n53: \t\tlog.Printf(\"[reconciler] AgentRuntime %s/%s missing session-id label, skipping\", namespace, name)\n54: \t\treturn nil\n55: \t}\n56: \n57: \tctx := context.Background()\n58: \n59: \tif ar.DeletionTimestamp != nil {\n60: \t\tlog.Printf(\"[reconciler] AgentRuntime %s/%s is being deleted, cleaning up session %s\", namespace, name, sessionID)\n61: \t\tif err := r.store.DeleteSandboxBySessionID(ctx, sessionID); err != nil {\n62: \t\t\tif r.metricsRecorder != nil {\n63: \t\t\t\tr.metricsRecorder.IncReconcileErrors(resourceTypeAgentRuntime, errorTypeStoreUnreachable)\n64: \t\t\t}\n65: \t\t\treturn fmt.Errorf(\"failed to delete sandbox by session %s: %w\", sessionID, err)\n66: \t\t}\n67: \t\treturn nil\n68: \t}\n69: \n70: \tstatus := mapConditionToStatus(ar.Status.Conditions)\n71: \n72: \texisting, err := r.store.GetSandbox(ctx, sessionID)\n73: \tif err != nil {\n74: \t\tif isNotFoundError(err) {\n75: \t\t\tinfo := &handler.SandboxInfo{\n76: \t\t\t\tSessionID:    sessionID,\n77: \t\t\t\tSandboxName:  ar.Labels[\"runtime.agentcube.io/sandbox-name\"],\n78: \t\t\t\tWorkloadName: ar.Labels[\"runtime.agentcube.io/workload-name\"],\n79: \t\t\t\tNamespace:    namespace,\n80: \t\t\t\tKind:         \"AgentRuntime\",\n81: \t\t\t\tStatus:       status,\n82: \t\t\t\tCreatedAt:    time.Now(),\n83: \t\t\t}\n84: \t\t\tif err := r.store.StoreSandbox(ctx, sessionID, info); err != nil {\n85: \t\t\t\tif r.metricsRecorder != nil {\n86: \t\t\t\t\tr.metricsRecorder.IncReconcileErrors(resourceTypeAgentRuntime, errorTypeStoreUnreachable)\n87: \t\t\t\t}\n88: \t\t\t\treturn fmt.Errorf(\"failed to store sandbox for session %s: %w\", sessionID, err)