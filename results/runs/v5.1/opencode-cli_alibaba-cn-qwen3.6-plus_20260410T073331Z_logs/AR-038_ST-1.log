ncode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/metrics.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/constants.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/sync.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/response/response_test.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle_test.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/response/response.go","metadata":{"count":21,"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z","time":{"start":1775886329617,"end":1775886329627}}}}
