{"type":"tool_use","timestamp":1775886372585,"sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","part":{"id":"prt_d7b138b45001V3fHTbkhg1PcON","messageID":"msg_d7b137636001Tmc6ahP0rTlnqH","sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","type":"tool","tool":"read","callID":"call_f994b129eccb477ba3a384b5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"log/slog\"\n7: \t\"net/http\"\n8: \t\"strconv\"\n9: \t\"sync\"\n10: \t\"time\"\n11: \n12: \t\"github.com/gin-gonic/gin\"\n13: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n14: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n15: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n16: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n17: \t\"k8s.io/client-go/dynamic\"\n18: \n19: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n20: )\n21: \n22: type LifecycleManagerDeps struct {\n23: \tDynamicClient      dynamic.Interface\n24: \tStore              Store\n25: \tCheckInterval      time.Duration\n26: \tDefaultTTL         time.Duration\n27: \tDefaultIdleTimeout time.Duration\n28: \tMetricsRecorder    MetricsRecorder\n29: }\n30: \n31: type LifecycleManager struct {\n32: \tdynamicClient      dynamic.Interface\n33: \tstore              Store\n34: \tcheckInterval      time.Duration\n35: \tdefaultTTL         time.Duration\n36: \tdefaultIdleTimeout time.Duration\n37: \tmetricsRecorder    MetricsRecorder\n38: \tstopCh             chan struct{}\n39: \tmu                 sync.Mutex\n40: \trunning            bool\n41: }\n42: \n43: func NewLifecycleManager(deps *LifecycleManagerDeps) *LifecycleManager {\n44: \tcheckInterval := deps.CheckInterval\n45: \tif checkInterval == 0 {\n46: \t\tcheckInterval = 5 * time.Minute\n47: \t}\n48: \tdefaultTTL := deps.DefaultTTL\n49: \tif defaultTTL == 0 {\n50: \t\tdefaultTTL = 8 * time.Hour\n51: \t}\n52: \tdefaultIdleTimeout := deps.DefaultIdleTimeout\n53: \tif defaultIdleTimeout == 0 {\n54: \t\tdefaultIdleTimeout = DefaultIdleTimeout\n55: \t}\n56: \n57: \treturn &LifecycleManager{\n58: \t\tdynamicClient:      deps.DynamicClient,\n59: \t\tstore:              deps.Store,\n60: \t\tcheckInterval:      checkInterval,\n61: \t\tdefaultTTL:         defaultTTL,\n62: \t\tdefaultIdleTimeout: defaultIdleTimeout,\n63: \t\tmetricsRecorder:    deps.MetricsRecorder,\n64: \t\tstopCh:             make(chan struct{}),\n65: \t}\n66: }\n67: \n68: func (m *LifecycleManager) Start(ctx context.Context) {\n69: \tm.mu.Lock()\n70: \tif m.running {\n71: \t\tm.mu.Unlock()\n72: \t\treturn\n73: \t}\n74: \tm.running = true\n75: \tm.mu.Unlock()\n76: \n77: \tgo m.runCleanupLoop(ctx)\n78: }\n79: \n80: func (m *LifecycleManager) Stop() {\n81: \tm.mu.Lock()\n82: \tdefer m.mu.Unlock()\n83: \tif !m.running {\n84: \t\treturn\n85: \t}\n86: \tm.running = false\n87: \tclose(m.stopCh)\n88: \tm.stopCh = make(chan struct{})\n89: }\n90: \n91: func (m *LifecycleManager) runCleanupLoop(ctx context.Context) {\n92: \tticker := time.NewTicker(m.checkInterval)\n93: \tdefer ticker.Stop()\n94: \n95: \tfor {\n96: \t\tselect {\n97: \t\tcase <-ctx.Done():\n98: \t\t\treturn\n99: \t\tcase <-m.stopCh:\n100: \t\t\treturn\n101: \t\tcase <-ticker.C:\n102: \t\t\tm.runGCCycle(ctx)\n103: \t\t}\n104: \t}\n105: }\n106: \n107: func (m *LifecycleManager) runGCCycle(ctx context.Context) {\n108: \tcycleStart := time.Now()\n109: \n110: \tslog.Info(\"gc_cycle_start\",\n111: \t\t\"check_interval\", m.checkInterval.String(),\n112: \t\t\"default_ttl\", m.defaultTTL.String(),\n113: \t\t\"default_idle_timeout\", m.defaultIdleTimeout.String(),\n114: \t)\n115: \n116: \tvar ttlCleaned, idleCleaned, orphanCleaned, ghostCleaned, errors int\n117: \n118: \tttlCleaned, idleCleaned, err := m.cleanupExpiredSandboxes(ctx)\n119: \tif err != nil {\n120: \t\tslog.Error(\"gc_error\", \"sub_task\", \"ttl_idle_cleanup\", \"error\", err)\n121: \t\terrors++\n122: \t}\n123: \n124: \torphanCleaned, err = m.cleanupOrphanCRs(ctx)\n125: \tif err != nil {\n126: \t\tslog.Error(\"gc_error\", \"sub_task\", \"orphan_scan\", \"error\", err)\n127: \t\terrors++\n128: \t}\n129: \n130: \tghostCleaned, err = m.cleanupGhostEntries(ctx)\n131: \tif err != nil {\n132: \t\tslog.Error(\"gc_error\", \"sub_task\", \"ghost_scan\", \"error\", err)\n133: \t\terrors++\n134: \t}\n135: \n136: \tduration := time.Since(cycleStart)\n137: \n138: \tslog.Info(\"gc_cycle_complete\",\n139: \t\t\"duration_ms\", duration.Milliseconds(),\n140: \t\t\"ttl_cleaned\", ttlCleaned,\n141: \t\t\"idle_cleaned\", idleCleaned,\n142: \t\t\"orphan_cleaned\", orphanCleaned,\n143: \t\t\"ghost_cleaned\", ghostCleaned,\n144: \t\t\"errors\", errors,\n145: \t)\n146: \n147: \tif m.metricsRecorder != nil {\n148: \t\tm.metricsRecorder.ObserveGCCycleDuration(duration)\n149: \t}\n150: }\n151: \n152: func (m *LifecycleManager) cleanupExpiredSandboxes(ctx context.Context) (int, int, error) {\n153: \tsandboxes, err := m.store.ListSandboxes(ctx)\n154: \tif err != nil {\n155: \t\tslog.Error(\"failed to list sandboxes for cleanup\", \"error\", err)\n156: \t\treturn 0, 0, fmt.Errorf(\"failed to list sandboxes: %w\", err)\n157: \t}\n158: \n159: \tnow := time.Now()\n160: \tvar ttlCleaned, idleCleaned int\n161: \n162: \tfor _, sb := range sandboxes {\n163: \t\tif m.isExpired(sb, now) {\n164: \t\t\tif err := m.deleteSandbox(ctx, sb, GRCleanupReasonTTLExpired); err != nil {\n165: \t\t\t\tslog.Error(\"failed to delete expired sandbox\",\n166: \t\t\t\t\t\"sessionID\", sb.SessionID,\n167: \t\t\t\t\t\"sandboxName\", sb.SandboxName,\n168: \t\t\t\t\t\"namespace\", sb.Namespace,\n169: \t\t\t\t\t\"reason\", GRCleanupReasonTTLExpired,\n170: \t\t\t\t\t\"error\", err,\n171: \t\t\t\t)\n172: \t\t\t\tif m.metricsRecorder != nil {\n173: \t\t\t\t\tm.metricsRecorder.IncGCCleanupErrors(GRCleanupReasonTTLExpired)\n174: \t\t\t\t}\n175: \t\t\t} else {\n176: \t\t\t\tttlCleaned++\n177: \t\t\t}\n178: \t\t\tcontinue\n179: \t\t}\n180: \n181: \t\tif m.isIdleExpired(sb, m.defaultIdleTimeout, now) {\n182: \t\t\tif err := m.deleteSandbox(ctx, sb, GRCleanupReasonIdle); err != nil {\n183: \t\t\t\tslog.Error(\"failed to delete idle sandbox\",\n184: \t\t\t\t\t\"sessionID\", sb.SessionID,\n185: \t\t\t\t\t\"sandboxName\", sb.SandboxName,\n186: \t\t\t\t\t\"namespace\", sb.Namespace,\n187: \t\t\t\t\t\"reason\", GRCleanupReasonIdle,\n188: \t\t\t\t\t\"error\", err,\n189: \t\t\t\t)\n190: \t\t\t\tif m.metricsRecorder != nil {\n191: \t\t\t\t\tm.metricsRecorder.IncGCCleanupErrors(GRCleanupReasonIdle)\n192: \t\t\t\t}\n193: \t\t\t} else {\n194: \t\t\t\tidleCleaned++\n195: \t\t\t}\n196: \t\t}\n197: \t}\n198: \n199: \treturn ttlCleaned, idleCleaned, nil\n200: }\n201: \n202: func (m *LifecycleManager) isExpired(info *SandboxInfo, now time.Time) bool {\n203: \tif !info.ExpiresAt.IsZero() {\n204: \t\treturn !now.Before(info.ExpiresAt)\n205: \t}\n206: \n207: \tif !info.CreatedAt.IsZero() {\n208: \t\treturn !now.Before(info.CreatedAt.Add(m.defaultTTL))\n209: \t}\n210: \n211: \treturn false\n212: }\n213: \n214: func (m *LifecycleManager) isIdleExpired(info *SandboxInfo, idleTimeout time.Duration, now time.Time) bool {\n215: \tif info.LastActivityAt.IsZero() {\n216: \t\treturn false\n217: \t}\n218: \n219: \tif info.Status != \"running\" {\n220: \t\treturn false\n221: \t}\n222: \n223: \treturn now.After(info.LastActivityAt.Add(idleTimeout))\n224: }\n225: \n226: func (m *LifecycleManager) deleteSandbox(ctx context.Context, info *SandboxInfo, reason string) error {\n227: \tstart := time.Now()\n228: \n229: \tgvr, err := m.resolveGVR(info.Kind)\n230: \tif err != nil {\n231: \t\tif m.metricsRecorder != nil {\n232: \t\t\tm.metricsRecorder.IncGCCleanupErrors(reason)\n233: \t\t}\n234: \t\treturn fmt.Errorf(\"failed to resolve GVR for kind %s: %w\", info.Kind, err)\n235: \t}\n236: \n237: \tdeleteCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n238: \tdefer cancel()\n239: \n240: \terr = m.dynamicClient.Resource(gvr).Namespace(info.Namespace).Delete(deleteCtx, info.SandboxName, metav1.DeleteOptions{})\n241: \tcrDeleted := true\n242: \tif err != nil {\n243: \t\tif apierrors.IsNotFound(err) {\n244: \t\t\tcrDeleted = false\n245: \t\t\tslog.Info(\"sandbox CR already deleted from cluster\",\n246: \t\t\t\t\"sessionID\", info.SessionID,\n247: \t\t\t\t\"sandboxName\", info.SandboxName,\n248: \t\t\t\t\"namespace\", info.Namespace,\n249: \t\t\t\t\"reason\", reason,\n250: \t\t\t)\n251: \t\t} else {\n252: \t\t\tif m.metricsRecorder != nil {\n253: \t\t\t\tm.metricsRecorder.IncGCCleanupErrors(reason)\n254: \t\t\t}\n255: \t\t\treturn fmt.Errorf(\"failed to delete sandbox from cluster: %w\", err)\n256: \t\t}\n257: \t}\n258: \n259: \tif err := m.store.DeleteSandbox(ctx, info.SessionID); err != nil {\n260: \t\tif m.metricsRecorder != nil {\n261: \t\t\tm.metricsRecorder.IncGCCleanupErrors(reason)\n262: \t\t}\n263: \t\treturn fmt.Errorf(\"failed to delete sandbox from store: %w\", err)\n264: \t}\n265: \n266: \tactualReason := reason\n267: \tif !crDeleted {\n268: \t\tactualReason = GRCleanupReasonGhostEntry\n269: \t}\n270: \n271: \tif m.metricsRecorder != nil {\n272: \t\tm.metricsRecorder.IncGCCleanupTotal(actualReason)\n273: \t\tm.metricsRecorder.ObserveGCCleanupDuration(actualReason, time.Since(start))\n274: \t}\n275: \n276: \tslog.Info(\"sandbox_deleted\",\n277: \t\t\"sessionID\", info.SessionID,\n278: \t\t\"sandboxName\", info.SandboxName,\n279: \t\t\"namespace\", info.Namespace,\n280: \t\t\"kind\", info.Kind,\n281: \t\t\"reason\", actualReason,\n282: \t)\n283: \n284: \treturn nil\n285: }\n286: \n287: func (m *LifecycleManager) cleanupOrphanCRs(ctx context.Context) (int, error) {\n288: \tif m.dynamicClient == nil {\n289: \t\treturn 0, nil\n290: \t}\n291: \n292: \tgvrs := []schema.GroupVersionResource{AgentRuntimeGVR, CodeInterpreterGVR}\n293: \tvar cleaned int\n294: \n295: \tfor _, gvr := range gvrs {\n296: \t\tlistOpts := metav1.ListOptions{\n297: \t\t\tLabelSelector: fmt.Sprintf(\"%s=%s\", LabelSessionID, \"\"),\n298: \t\t}\n299: \n300: \t\tlist, err := m.dynamicClient.Resource(gvr).List(ctx, listOpts)\n301: \t\tif err != nil {\n302: \t\t\tslog.Error(\"failed to list CRs for orphan scan\",\n303: \t\t\t\t\"gvr\", gvr.String(),\n304: \t\t\t\t\"error\", err,\n305: \t\t\t)\n306: \t\t\treturn cleaned, fmt.Errorf(\"failed to list %s: %w\", gvr.Resource, err)\n307: \t\t}\n308: \n309: \t\tfor _, item := range list.Items {\n310: \t\t\tif cleaned >= MaxOrphanScanLimit {\n311: \t\t\t\treturn cleaned, nil\n312: \t\t\t}\n313: \n314: \t\t\tsessionID := item.GetLabels()[LabelSessionID]\n315: \t\t\tif sessionID == \"\" {\n316: \t\t\t\tcontinue\n317: \t\t\t}\n318: \n319: \t\t\t_, err := m.store.GetSandbox(ctx, sessionID)\n320: \t\t\tif err == nil {\n321: \t\t\t\tcontinue\n322: \t\t\t}\n323: \n324: \t\t\tdeleteCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n325: \t\t\terr = m.dynamicClient.Resource(gvr).Namespace(item.GetNamespace()).Delete(deleteCtx, item.GetName(), metav1.DeleteOptions{})\n326: \t\t\tcancel()\n327: \n328: \t\t\tif err != nil && !apierrors.IsNotFound(err) {\n329: \t\t\t\tslog.Error(\"failed to delete orphan CR\",\n330: \t\t\t\t\t\"sessionID\", sessionID,\n331: \t\t\t\t\t\"crName\", item.GetName(),\n332: \t\t\t\t\t\"namespace\", item.GetNamespace(),\n333: \t\t\t\t\t\"kind\", gvr.Resource,\n334: \t\t\t\t\t\"error\", err,\n335: \t\t\t\t)\n336: \t\t\t\tif m.metricsRecorder != nil {\n337: \t\t\t\t\tm.metricsRecorder.IncGCCleanupErrors(GRCleanupReasonOrphanCR)\n338: \t\t\t\t}\n339: \t\t\t\tcontinue\n340: \t\t\t}\n341: \n342: \t\t\tcleaned++\n343: \t\t\tslog.Info(\"orphan_cr_deleted\",\n344: \t\t\t\t\"sessionID\", sessionID,\n345: \t\t\t\t\"crName\", item.GetName(),\n346: \t\t\t\t\"namespace\", item.GetNamespace(),\n347: \t\t\t\t\"kind\", gvr.Resource,\n348: \t\t\t)\n349: \n350: \t\t\tif m.metricsRecorder != nil {\n351: \t\t\t\tm.metricsRecorder.IncGCCleanupTotal(GRCleanupReasonOrphanCR)\n352: \t\t\t}\n353: \t\t}\n354: \t}\n355: \n356: \treturn cleaned, nil\n357: }\n358: \n359: func (m *LifecycleManager) cleanupGhostEntries(ctx context.Context) (int, error) {\n360: \tsandboxes, err := m.store.ListSandboxes(ctx)\n361: \tif err != nil {\n362: \t\tslog.Error(\"failed to list sandboxes for ghost scan\", \"error\", err)\n363: \t\treturn 0, fmt.Errorf(\"failed to list sandboxes: %w\", err)\n364: \t}\n365: \n366: \tvar cleaned int\n367: \n368: \tfor _, sb := range sandboxes {\n369: \t\tgvr, err := m.resolveGVR(sb.Kind)\n370: \t\tif err != nil {\n371: \t\t\tslog.Error(\"failed to resolve GVR for ghost scan\",\n372: \t\t\t\t\"sessionID\", sb.SessionID,\n373: \t\t\t\t\"kind\", sb.Kind,\n374: \t\t\t\t\"error\", err,\n375: \t\t\t)\n376: \t\t\tcontinue\n377: \t\t}\n378: \n379: \t\t_, err = m.dynamicClient.Resource(gvr).Namespace(sb.Namespace).Get(ctx, sb.SandboxName, metav1.GetOptions{})\n380: \t\tif err == nil {\n381: \t\t\tcontinue\n382: \t\t}\n383: \n384: \t\tif !apierrors.IsNotFound(err) {\n385: \t\t\tslog.Error(\"failed to check CR existence for ghost scan\",\n386: \t\t\t\t\"sessionID\", sb.SessionID,\n387: \t\t\t\t\"sandboxName\", sb.SandboxName,\n388: \t\t\t\t\"namespace\", sb.Namespace,\n389: \t\t\t\t\"error\", err,\n390: \t\t\t)\n391: \t\t\tcontinue\n392: \t\t}\n393: \n394: \t\tif err := m.store.DeleteSandbox(ctx, sb.SessionID); err != nil {\n395: \t\t\tslog.Error(\"failed to delete ghost entry from store\",\n396: \t\t\t\t\"sessionID\", sb.SessionID,\n397: \t\t\t\t\"sandboxName\", sb.SandboxName,\n398: \t\t\t\t\"kind\", sb.Kind,\n399: \t\t\t\t\"error\", err,\n400: \t\t\t)\n401: \t\t\tif m.metricsRecorder != nil {\n402: \t\t\t\tm.metricsRecorder.IncGCCleanupErrors(GRCleanupReasonGhostEntry)\n403: \t\t\t}\n404: \t\t\tcontinue\n405: \t\t}\n406: \n407: \t\tcleaned++\n408: \t\tslog.Info(\"ghost_entry_cleaned\",\n409: \t\t\t\"sessionID\", sb.SessionID,\n410: \t\t\t\"sandboxName\", sb.SandboxName,\n411: \t\t\t\"kind\", sb.Kind,\n412: \t\t)\n413: \n414: \t\tif m.metricsRecorder != nil {\n415: \t\t\tm.metricsRecorder.IncGCCleanupTotal(GRCleanupReasonGhostEntry)\n416: \t\t}\n417: \t}\n418: \n419: \treturn cleaned, nil\n420: }\n421: \n422: func (m *LifecycleManager) resolveGVR(kind string) (schema.GroupVersionResource, error) {\n423: \tswitch kind {\n424: \tcase SandboxesKind:\n425: \t\treturn SandboxGVR, nil\n426: \tcase SandboxClaimsKind:\n427: \t\treturn SandboxClaimGVR, nil\n428: \tcase AgentRuntimeKind:\n429: \t\treturn AgentRuntimeGVR, nil\n430: \tcase CodeInterpreterKind:\n431: \t\treturn CodeInterpreterGVR, nil\n432: \tdefault:\n433: \t\treturn schema.GroupVersionResource{}, fmt.Errorf(\"unknown sandbox kind: %s\", kind)\n434: \t}\n435: }\n436: \n437: func (m *LifecycleManager) calculateTimeToIdle(info *SandboxInfo, now time.Time) *time.Duration {\n438: \tif info.LastActivityAt.IsZero() {\n439: \t\treturn nil\n440: \t}\n441: \n442: \tif info.Status != \"running\" {\n443: \t\treturn nil\n444: \t}\n445: \n446: \tdeadline := info.LastActivityAt.Add(m.defaultIdleTimeout)\n447: \tremaining := deadline.Sub(now)\n448: \treturn &remaining\n449: }\n450: \n451: func (m *LifecycleManager) GetSandboxStatus(c *gin.Context) {\n452: \tsessionID := c.Param(\"sessionID\")\n453: \tif sessionID == \"\" {\n454: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"sessionID is required\")\n455: \t\treturn\n456: \t}\n457: \n458: \tsandboxInfo, err := m.store.GetSandbox(c.Request.Context(), sessionID)\n459: \tif err != nil {\n460: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox session %s not found\", sessionID))\n461: \t\treturn\n462: \t}\n463: \n464: \tnow := time.Now()\n465: \tsandboxInfo.LastActivityAt = now\n466: \tif err := m.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n467: \t\tslog.Error(\"failed to update LastActivityAt on status check\",\n468: \t\t\t\"sessionID\", sessionID,\n469: \t\t\t\"error\", err,\n470: \t\t)\n471: \t}\n472: \n473: \tvar timeToExpiry *time.Duration\n474: \tif !sandboxInfo.ExpiresAt.IsZero() {\n475: \t\tremaining := sandboxInfo.ExpiresAt.Sub(now)\n476: \t\tif remaining > 0 {\n477: \t\t\ttimeToExpiry = &remaining\n478: \t\t}\n479: \t}\n480: \n481: \ttimeToIdle := m.calculateTimeToIdle(sandboxInfo, now)\n482: \tisIdle := m.isIdleExpired(sandboxInfo, m.defaultIdleTimeout, now)\n483: \n484: \tresp := &SandboxStatusResponse{\n485: \t\tSessionID:      sandboxInfo.SessionID,\n486: \t\tSandboxName:    sandboxInfo.SandboxName,\n487: \t\tSandboxID:      sandboxInfo.SandboxID,\n488: \t\tStatus:         sandboxInfo.Status,\n489: \t\tCreatedAt:      sandboxInfo.CreatedAt,\n490: \t\tExpiresAt:      sandboxInfo.ExpiresAt,\n491: \t\tLastActivityAt: sandboxInfo.LastActivityAt,\n492: \t\tTimeToExpiry:   timeToExpiry,\n493: \t\tTimeToIdle:     timeToIdle,\n494: \t\tIsExpired:      m.isExpired(sandboxInfo, now),\n495: \t\tIsIdle:         isIdle,\n496: \t\tEntryPoints:    sandboxInfo.EntryPoints,\n497: \t}\n498: \n499: \tresponse.JSON(c, http.StatusOK, resp)\n500: }\n501: \n502: type SandboxStatusResponse struct {\n503: \tSessionID      string         `json:\"sessionId\"`\n504: \tSandboxName    string         `json:\"sandboxName\"`\n505: \tSandboxID      string         `json:\"sandboxId\"`\n506: \tStatus         string         `json:\"status\"`\n507: \tCreatedAt      time.Time      `json:\"createdAt\"`\n508: \tExpiresAt      time.Time      `json:\"expiresAt\"`\n509: \tLastActivityAt time.Time      `json:\"lastActivityAt\"`\n510: \tTimeToExpiry   *time.Duration `json:\"timeToExpiry,omitempty\"`\n511: \tTimeToIdle     *time.Duration `json:\"timeToIdle,omitempty\"`\n512: \tIsExpired      bool           `json:\"isExpired\"`\n513: \tIsIdle         bool           `json:\"isIdle\"`\n514: \tEntryPoints    []EntryPoint   `json:\"entryPoints,omitempty\"`\n515: }\n516: \n517: func (m *LifecycleManager) ListSandboxes(c *gin.Context) {\n518: \tnamespace := c.Query(\"namespace\")\n519: \tstatusFilter := c.Query(\"status\")\n520: \n521: \tsandboxes, err := m.store.ListSandboxes(c.Request.Context())\n522: \tif err != nil {\n523: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"failed to list sandboxes\")\n524: \t\treturn\n525: \t}\n526: \n527: \tvar filtered []*SandboxInfo\n528: \tfor _, sb := range sandboxes {\n529: \t\tif namespace != \"\" && sb.Namespace != namespace {\n530: \t\t\tcontinue\n531: \t\t}\n532: \t\tif statusFilter != \"\" && sb.Status != statusFilter {\n533: \t\t\tcontinue\n534: \t\t}\n535: \t\tfiltered = append(filtered, sb)\n536: \t}\n537: \n538: \tnow := time.Now()\n539: \titems := make([]SandboxListItem, 0, len(filtered))\n540: \tfor _, sb := range filtered {\n541: \t\tvar timeToExpiry *time.Duration\n542: \t\tif !sb.ExpiresAt.IsZero() {\n543: \t\t\tremaining := sb.ExpiresAt.Sub(now)\n544: \t\t\tif remaining > 0 {\n545: \t\t\t\ttimeToExpiry = &remaining\n546: \t\t\t}\n547: \t\t}\n548: \n549: \t\ttimeToIdle := m.calculateTimeToIdle(sb, now)\n550: \t\tisIdle := m.isIdleExpired(sb, m.defaultIdleTimeout, now)\n551: \n552: \t\titems = append(items, SandboxListItem{\n553: \t\t\tSessionID:      sb.SessionID,\n554: \t\t\tSandboxName:    sb.SandboxName,\n555: \t\t\tWorkloadName:   sb.WorkloadName,\n556: \t\t\tNamespace:      sb.Namespace,\n557: \t\t\tKind:           sb.Kind,\n558: \t\t\tStatus:         sb.Status,\n559: \t\t\tCreatedAt:      sb.CreatedAt,\n560: \t\t\tExpiresAt:      sb.ExpiresAt,\n561: \t\t\tLastActivityAt: sb.LastActivityAt,\n562: \t\t\tTimeToExpiry:   timeToExpiry,\n563: \t\t\tTimeToIdle:     timeToIdle,\n564: \t\t\tIsExpired:      m.isExpired(sb, now),\n565: \t\t\tIsIdle:         isIdle,\n566: \t\t})\n567: \t}\n568: \n569: \tresponse.JSON(c, http.StatusOK, &ListSandboxesResponse{\n570: \t\tTotal: len(items),\n571: \t\tItems: items,\n572: \t})\n573: }\n574: \n575: type SandboxListItem struct {\n576: \tSessionID      string         `json:\"sessionId\"`\n577: \tSandboxName    string         `json:\"sandboxName\"`\n578: \tWorkloadName   string         `json:\"workloadName\"`\n579: \tNamespace      string         `json:\"namespace\"`\n580: \tKind           string         `json:\"kind\"`\n581: \tStatus         string         `json:\"status\"`\n582: \tCreatedAt      time.Time      `json:\"createdAt\"`\n583: \tExpiresAt      time.Time      `json:\"expiresAt\"`\n584: \tLastActivityAt time.Time      `json:\"lastActivityAt\"`\n585: \tTimeToExpiry   *time.Duration `json:\"timeToExpiry,omitempty\"`\n586: \tTimeToIdle     *time.Duration `json:\"timeToIdle,omitempty\"`\n587: \tIsExpired      bool           `json:\"isExpired\"`\n588: \tIsIdle         bool           `json:\"isIdle\"`\n589: }\n590: \n591: type ListSandboxesResponse struct {\n592: \tTotal int               `json:\"total\"`\n593: \tItems []SandboxListItem `json:\"items\"`\n594: }\n595: \n596: func (m *LifecycleManager) ExtendSandboxTTL(c *gin.Context) {\n597: \tsessionID := c.Param(\"sessionID\")\n598: \tif sessionID == \"\" {\n599: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"sessionID is required\")\n600: \t\treturn\n601: \t}\n602: \n603: \tvar req ExtendTTLRequest\n604: \tif err := c.ShouldBindJSON(&req); err != nil {\n605: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n606: \t\treturn\n607: \t}\n608: \n609: \tif err := req.Validate(); err != nil {\n610: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n611: \t\treturn\n612: \t}\n613: \n614: \tsandboxInfo, err := m.store.GetSandbox(c.Request.Context(), sessionID)\n615: \tif err != nil {\n616: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox session %s not found\", sessionID))\n617: \t\treturn\n618: \t}\n619: \n620: \tnow := time.Now()\n621: \tif m.isExpired(sandboxInfo, now) {\n622: \t\tresponse.Error(c, http.StatusGone, http.StatusGone, \"sandbox has already expired and cannot be extended\")\n623: \t\treturn\n624: \t}\n625: \n626: \tsandboxInfo.ExpiresAt = now.Add(req.ExtensionDuration)\n627: \tsandboxInfo.LastActivityAt = now\n628: \tif err := m.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n629: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"failed to update sandbox TTL\")\n630: \t\treturn\n631: \t}\n632: \n633: \tresponse.JSON(c, http.StatusOK, &ExtendTTLResponse{\n634: \t\tSessionID: sessionID,\n635: \t\tNewExpiry: sandboxInfo.ExpiresAt,\n636: \t})\n637: }\n638: \n639: type ExtendTTLRequest struct {\n640: \tExtensionDuration time.Duration `json:\"extensionDuration\"`\n641: }\n642: \n643: func (r *ExtendTTLRequest) Validate() error {\n644: \tif r.ExtensionDuration <= 0 {\n645: \t\treturn fmt.Errorf(\"extensionDuration must be positive\")\n646: \t}\n647: \tif r.ExtensionDuration > 24*time.Hour {\n648: \t\treturn fmt.Errorf(\"extensionDuration cannot exceed 24 hours\")\n649: \t}\n650: \treturn nil\n651: }\n652: \n653: type ExtendTTLResponse struct {\n654: \tSessionID string    `json:\"sessionId\"`\n655: \tNewExpiry time.Time `json:\"newExpiry\"`\n656: }\n657: \n658: func parseIdleTimeoutFromAnnotations(annotations map[string]string, defaultTimeout time.Duration) time.Duration {\n659: \tif annotations == nil {\n660: \t\treturn defaultTimeout\n661: \t}\n662: \n663: \tval, ok := annotations[AnnotationIdleTimeout]\n664: \tif !ok {\n665: \t\treturn defaultTimeout\n666: \t}\n667: \n668: \tminutes, err := strconv.Atoi(val)\n669: \tif err != nil {\n670: \t\treturn defaultTimeout\n671: \t}\n672: \n673: \treturn time.Duration(minutes) * time.Minute\n674: }\n675: \n676: func extractIdleTimeoutFromCR(cr *unstructured.Unstructured, defaultTimeout time.Duration) time.Duration {\n677: \tannotations := cr.GetAnnotations()\n678: \treturn parseIdleTimeoutFromAnnotations(annotations, defaultTimeout)\n679: }\n\n(End of file - total 679 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log/slog\"\n\t\"net/http\"\n\t\"strconv\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle.go","time":{"start":1775886372574,"end":1775886372583}}}}
{"type":"tool_use","timestamp":1775886374725,"sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","part":{"id":"prt_d7b138f89001L1hUAgZ5V2yQnR","messageID":"msg_d7b137636001Tmc6ahP0rTlnqH","sessionID":"ses_284ed3b31ffePFwSZ2jyZMfBMF","type":"tool","tool":"read","callID":"call_8c889ce8a078483ca9a60de3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"log\"\n7: \t\"math/rand\"\n8: \t\"net/http\"\n9: \t\"reflect\"\n10: \t\"time\"\n11: \n12: \t\"github.com/gin-gonic/gin\"\n13: \t\"github.com/google/uuid\"\n14: \tcorev1 \"k8s.io/api/core/v1\"\n15: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n16: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n17: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n18: \t\"k8s.io/apimachinery/pkg/labels\"\n19: \t\"k8s.io/apimachinery/pkg/runtime\"\n20: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n21: \t\"k8s.io/client-go/dynamic\"\n22: \t\"k8s.io/client-go/kubernetes\"\n23: \n24: \t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n25: \t\"github.com/volcano-sh/agentcube/client-go/informers/externalversions\"\n26: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n27: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n28: )\n29: \n30: type Store interface {\n31: \tStoreSandbox(ctx context.Context, info *SandboxInfo) error\n32: \tUpdateSandbox(ctx context.Context, sessionID string, info *SandboxInfo) error\n33: \tGetSandbox(ctx context.Context, sessionID string) (*SandboxInfo, error)\n34: \tDeleteSandbox(ctx context.Context, sessionID string) error\n35: \tListSandboxes(ctx context.Context) ([]*SandboxInfo, error)\n36: }\n37: \n38: type SandboxReconcilerWatcher interface {\n39: \tWatchSandboxOnce(namespace, name string) (<-chan SandboxStatus, error)\n40: }\n41: \n42: type TokenCache interface {\n43: \tGetOrCreateUserK8sClient(namespace, saName, token string) (dynamic.Interface, error)\n44: }\n45: \n46: type SandboxCreateHandlerDeps struct {\n47: \tDynamicClient     dynamic.Interface\n48: \tClientset         clientset.Interface\n49: \tKubeClientset     kubernetes.Interface\n50: \tInformerFactory   externalversions.SharedInformerFactory\n51: \tStore             Store\n52: \tReconciler        SandboxReconcilerWatcher\n53: \tTokenCache        TokenCache\n54: \tUserClientFactory UserClientFactory\n55: \tEnableAuth        bool\n56: }\n57: \n58: type UserClientFactory interface {\n59: \tCreateUserClient(token string) (dynamic.Interface, error)\n60: }\n61: \n62: type SandboxCreateHandler struct {\n63: \tdynamicClient     dynamic.Interface\n64: \tclientset         clientset.Interface\n65: \tkubeClientset     kubernetes.Interface\n66: \tinformerFactory   externalversions.SharedInformerFactory\n67: \tstore             Store\n68: \treconciler        SandboxReconcilerWatcher\n69: \ttokenCache        TokenCache\n70: \tuserClientFactory UserClientFactory\n71: \tenableAuth        bool\n72: }\n73: \n74: func NewSandboxCreateHandler(deps *SandboxCreateHandlerDeps) *SandboxCreateHandler {\n75: \treturn &SandboxCreateHandler{\n76: \t\tdynamicClient:     deps.DynamicClient,\n77: \t\tclientset:         deps.Clientset,\n78: \t\tkubeClientset:     deps.KubeClientset,\n79: \t\tinformerFactory:   deps.InformerFactory,\n80: \t\tstore:             deps.Store,\n81: \t\treconciler:        deps.Reconciler,\n82: \t\ttokenCache:        deps.TokenCache,\n83: \t\tuserClientFactory: deps.UserClientFactory,\n84: \t\tenableAuth:        deps.EnableAuth,\n85: \t}\n86: }\n87: \n88: func (h *SandboxCreateHandler) getDynamicClient(c *gin.Context) (dynamic.Interface, error) {\n89: \tif !h.enableAuth {\n90: \t\treturn h.dynamicClient, nil\n91: \t}\n92: \n93: \ttoken := c.GetHeader(\"Authorization\")\n94: \tif token == \"\" {\n95: \t\treturn nil, fmt.Errorf(\"authorization token is required\")\n96: \t}\n97: \tif len(token) > 7 && token[:7] == \"Bearer \" {\n98: \t\ttoken = token[7:]\n99: \t}\n100: \n101: \tnamespace := c.GetString(\"namespace\")\n102: \tsaName := c.GetString(\"serviceAccountName\")\n103: \n104: \tif h.tokenCache != nil {\n105: \t\treturn h.tokenCache.GetOrCreateUserK8sClient(namespace, saName, token)\n106: \t}\n107: \n108: \tif h.userClientFactory != nil {\n109: \t\treturn h.userClientFactory.CreateUserClient(token)\n110: \t}\n111: \n112: \treturn nil, fmt.Errorf(\"no user client factory available\")\n113: }\n114: \n115: func (h *SandboxCreateHandler) CreateAgentRuntimeSandbox(c *gin.Context) {\n116: \tvar sandboxReq CreateSandboxRequest\n117: \tif err := c.ShouldBindJSON(&sandboxReq); err != nil {\n118: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n119: \t\treturn\n120: \t}\n121: \n122: \tsandboxReq.Kind = AgentRuntimeKind\n123: \n124: \tif err := sandboxReq.Validate(); err != nil {\n125: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n126: \t\treturn\n127: \t}\n128: \n129: \tarLister := h.informerFactory.Runtime().V1alpha1().AgentRuntimes().Lister()\n130: \ttemplate, err := arLister.AgentRuntimes(sandboxReq.Namespace).Get(sandboxReq.Name)\n131: \tif err != nil {\n132: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"AgentRuntime %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n133: \t\treturn\n134: \t}\n135: \n136: \tif template.Spec.Template == nil {\n137: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"podTemplate is required\")\n138: \t\treturn\n139: \t}\n140: \n141: \tsessionID := generateSessionID()\n142: \tsandboxName := generateSandboxName(sandboxReq.Name)\n143: \n144: \tsandboxCR, err := h.buildAgentRuntimeSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace)\n145: \tif err != nil {\n146: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n147: \t\treturn\n148: \t}\n149: \n150: \tsandboxInfo := &SandboxInfo{\n151: \t\tSessionID:    sessionID,\n152: \t\tSandboxName:  sandboxName,\n153: \t\tWorkloadName: sandboxReq.Name,\n154: \t\tNamespace:    sandboxReq.Namespace,\n155: \t\tKind:         AgentRuntimeKind,\n156: \t\tStatus:       \"pending\",\n157: \t\tCreatedAt:    time.Now(),\n158: \t}\n159: \n160: \tif err := h.store.StoreSandbox(c.Request.Context(), sandboxInfo); err != nil {\n161: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n162: \t\treturn\n163: \t}\n164: \n165: \twatcherCh, err := h.reconciler.WatchSandboxOnce(sandboxReq.Namespace, sandboxName)\n166: \tif err != nil {\n167: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n168: \t\treturn\n169: \t}\n170: \n171: \tdynClient, err := h.getDynamicClient(c)\n172: \tif err != nil {\n173: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n174: \t\treturn\n175: \t}\n176: \n177: \tcreatedCR, err := dynClient.Resource(SandboxGVR).Namespace(sandboxReq.Namespace).Create(c.Request.Context(), sandboxCR, metav1.CreateOptions{})\n178: \tif err != nil {\n179: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n180: \t\treturn\n181: \t}\n182: \n183: \tctx, cancel := context.WithTimeout(c.Request.Context(), 2*time.Minute)\n184: \tdefer cancel()\n185: \n186: \tselect {\n187: \tcase status := <-watcherCh:\n188: \t\tif status.Error != nil {\n189: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n190: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, status.Error.Error())\n191: \t\t\treturn\n192: \t\t}\n193: \t\tif status.Status != \"running\" {\n194: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n195: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n196: \t\t\treturn\n197: \t\t}\n198: \tcase <-ctx.Done():\n199: \t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n200: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n201: \t\treturn\n202: \t}\n203: \n204: \tpodIP, err := h.resolvePodIP(c.Request.Context(), sandboxName, sandboxReq.Namespace, sandboxCR, h.kubeClientset)\n205: \tif err != nil {\n206: \t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n207: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())\n208: \t\treturn\n209: \t}\n210: \n211: \tports := template.Spec.Ports\n212: \tentryPoints := h.buildEntryPoints(podIP, ports)\n213: \n214: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n215: \tsandboxInfo.PodIP = podIP\n216: \tsandboxInfo.EntryPoints = entryPoints\n217: \tsandboxInfo.Status = \"running\"\n218: \n219: \tif err := h.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n220: \t\tlog.Printf(\"failed to update sandbox in store: %v\", err)\n221: \t}\n222: \n223: \tresp := &CreateSandboxResponse{\n224: \t\tSessionID:   sessionID,\n225: \t\tSandboxID:   sandboxInfo.SandboxID,\n226: \t\tSandboxName: sandboxName,\n227: \t\tEntryPoints: entryPoints,\n228: \t}\n229: \n230: \tresponse.JSON(c, http.StatusOK, resp)\n231: }\n232: \n233: func (h *SandboxCreateHandler) CreateCodeInterpreterSandbox(c *gin.Context) {\n234: \tvar sandboxReq CreateSandboxRequest\n235: \tif err := c.ShouldBindJSON(&sandboxReq); err != nil {\n236: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n237: \t\treturn\n238: \t}\n239: \n240: \tsandboxReq.Kind = CodeInterpreterKind\n241: \n242: \tif err := sandboxReq.Validate(); err != nil {\n243: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n244: \t\treturn\n245: \t}\n246: \n247: \tciLister := h.informerFactory.Runtime().V1alpha1().CodeInterpreters().Lister()\n248: \ttemplate, err := ciLister.CodeInterpreters(sandboxReq.Namespace).Get(sandboxReq.Name)\n249: \tif err != nil {\n250: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"CodeInterpreter %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n251: \t\treturn\n252: \t}\n253: \n254: \tif template.Spec.Template == nil {\n255: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"template is required\")\n256: \t\treturn\n257: \t}\n258: \n259: \tsessionID := generateSessionID()\n260: \tsandboxName := generateSandboxName(sandboxReq.Name)\n261: \n262: \tports := getPortsOrDefaults(template.Spec.Ports)\n263: \n264: \tvar sandboxCR *unstructured.Unstructured\n265: \tvar entryKind string\n266: \n267: \tsandboxCR, entryKind, err = h.buildCodeInterpreterSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace, ports)\n268: \tif err != nil {\n269: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n270: \t\treturn\n271: \t}\n272: \n273: \tif template.Spec.AuthMode == runtimev1alpha1.AuthModePicoD {\n274: \t\tif err := h.injectPicodAuthEnv(sandboxCR, sandboxReq.Namespace, h.kubeClientset); err != nil {\n275: \t\t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n276: \t\t\treturn\n277: \t\t}\n278: \t}\n279: \n280: \tsandboxInfo := &SandboxInfo{\n281: \t\tSessionID:    sessionID,\n282: \t\tSandboxName:  sandboxName,\n283: \t\tWorkloadName: sandboxReq.Name,\n284: \t\tNamespace:    sandboxReq.Namespace,\n285: \t\tKind:         entryKind,\n286: \t\tStatus:       \"pending\",\n287: \t\tCreatedAt:    time.Now(),\n288: \t}\n289: \n290: \tif err := h.store.StoreSandbox(c.Request.Context(), sandboxInfo); err != nil {\n291: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n292: \t\treturn\n293: \t}\n294: \n295: \twatcherCh, err := h.reconciler.WatchSandboxOnce(sandboxReq.Namespace, sandboxName)\n296: \tif err != nil {\n297: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n298: \t\treturn\n299: \t}\n300: \n301: \tdynClient, err := h.getDynamicClient(c)\n302: \tif err != nil {\n303: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n304: \t\treturn\n305: \t}\n306: \n307: \tvar gvr schema.GroupVersionResource\n308: \tif entryKind == SandboxClaimsKind {\n309: \t\tgvr = SandboxClaimGVR\n310: \t} else {\n311: \t\tgvr = SandboxGVR\n312: \t}\n313: \n314: \tcreatedCR, err := dynClient.Resource(gvr).Namespace(sandboxReq.Namespace).Create(c.Request.Context(), sandboxCR, metav1.CreateOptions{})\n315: \tif err != nil {\n316: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n317: \t\treturn\n318: \t}\n319: \n320: \tctx, cancel := context.WithTimeout(c.Request.Context(), 2*time.Minute)\n321: \tdefer cancel()\n322: \n323: \tselect {\n324: \tcase status := <-watcherCh:\n325: \t\tif status.Error != nil {\n326: \t\t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n327: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, status.Error.Error())\n328: \t\t\treturn\n329: \t\t}\n330: \t\tif status.Status != \"running\" {\n331: \t\t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n332: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n333: \t\t\treturn\n334: \t\t}\n335: \tcase <-ctx.Done():\n336: \t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n337: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n338: \t\treturn\n339: \t}\n340: \n341: \tpodIP, err := h.resolvePodIP(c.Request.Context(), sandboxName, sandboxReq.Namespace, sandboxCR, h.kubeClientset)\n342: \tif err != nil {\n343: \t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n344: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())\n345: \t\treturn\n346: \t}\n347: \n348: \tentryPoints := h.buildEntryPoints(podIP, ports)\n349: \n350: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n351: \tsandboxInfo.PodIP = podIP\n352: \tsandboxInfo.EntryPoints = entryPoints\n353: \tsandboxInfo.Status = \"running\"\n354: \n355: \tif err := h.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n356: \t\tlog.Printf(\"failed to update sandbox in store: %v\", err)\n357: \t}\n358: \n359: \tresp := &CreateSandboxResponse{\n360: \t\tSessionID:   sessionID,\n361: \t\tSandboxID:   sandboxInfo.SandboxID,\n362: \t\tSandboxName: sandboxName,\n363: \t\tEntryPoints: entryPoints,\n364: \t}\n365: \n366: \tresponse.JSON(c, http.StatusOK, resp)\n367: }\n368: \n369: func (h *SandboxCreateHandler) rollbackCR(ctx context.Context, gvr schema.GroupVersionResource, namespace, name string, dynClient dynamic.Interface) error {\n370: \trollbackCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n371: \tdefer cancel()\n372: \n373: \terr := dynClient.Resource(gvr).Namespace(namespace).Delete(rollbackCtx, name, metav1.DeleteOptions{})\n374: \tif err != nil && apierrors.IsNotFound(err) {\n375: \t\treturn nil\n376: \t}\n377: \treturn err\n378: }\n379: \n380: func (h *SandboxCreateHandler) buildAgentRuntimeSandboxCR(template *runtimev1alpha1.AgentRuntime, sessionID, sandboxName, workloadName, namespace string) (*unstructured.Unstructured, error) {\n381: \tcr := &unstructured.Unstructured{}\n382: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n383: \tcr.SetKind(\"Sandbox\")\n384: \tcr.SetName(sandboxName)\n385: \tcr.SetNamespace(namespace)\n386: \n387: \tcr.SetLabels(map[string]string{\n388: \t\tLabelManagedBy:    LabelManagedByValue,\n389: \t\tLabelSessionID:    sessionID,\n390: \t\tLabelWorkloadName: workloadName,\n391: \t\tLabelSandboxName:  sandboxName,\n392: \t})\n393: \n394: \tidleTimeout := DefaultSandboxIdleTimeout\n395: \tif template.Spec.SessionTimeout != nil {\n396: \t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n397: \t}\n398: \tcr.SetAnnotations(map[string]string{\n399: \t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n400: \t})\n401: \n402: \tttl := DefaultSandboxTTL\n403: \tif template.Spec.MaxSessionDuration != nil {\n404: \t\tttl = int(template.Spec.MaxSessionDuration.Duration.Hours())\n405: \t}\n406: \tshutdownTime := time.Now().Add(time.Duration(ttl) * time.Hour)\n407: \n408: \tspec := map[string]interface{}{\n409: \t\t\"replicas\": int64(1),\n410: \t\t\"lifecycle\": map[string]interface{}{\n411: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n412: \t\t},\n413: \t}\n414: \n415: \tvar ports []interface{}\n416: \tfor _, p := range template.Spec.Ports {\n417: \t\tports = append(ports, map[string]interface{}{\n418: \t\t\t\"name\":     p.Name,\n419: \t\t\t\"port\":     int64(p.Port),\n420: \t\t\t\"protocol\": string(p.Protocol),\n421: \t\t})\n422: \t}\n423: \tif len(ports) > 0 {\n424: \t\tspec[\"ports\"] = ports\n425: \t}\n426: \n427: \tpodSpec := template.Spec.Template.Spec\n428: \tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n429: \tif err != nil {\n430: \t\treturn nil, fmt.Errorf(\"failed to convert pod spec: %w\", err)\n431: \t}\n432: \tspec[\"podTemplate\"] = podSpecMap\n433: \n434: \tcr.Object[\"spec\"] = spec\n435: \n436: \treturn cr, nil\n437: }\n438: \n439: func (h *SandboxCreateHandler) buildCodeInterpreterSandboxCR(template *runtimev1alpha1.CodeInterpreter, sessionID, sandboxName, workloadName, namespace string, ports []runtimev1alpha1.TargetPort) (*unstructured.Unstructured, string, error) {\n440: \twarmPoolSize := int32(0)\n441: \tif template.Spec.WarmPoolSize != nil {\n442: \t\twarmPoolSize = *template.Spec.WarmPoolSize\n443: \t}\n444: \n445: \tif warmPoolSize > 0 {\n446: \t\tcr := &unstructured.Unstructured{}\n447: \t\tcr.SetAPIVersion(\"extensions.agents.x-k8s.io/v1alpha1\")\n448: \t\tcr.SetKind(\"SandboxClaim\")\n449: \t\tcr.SetName(sandboxName)\n450: \t\tcr.SetNamespace(namespace)\n451: \n452: \t\tcr.SetLabels(map[string]string{\n453: \t\t\tLabelManagedBy:    LabelManagedByValue,\n454: \t\t\tLabelSessionID:    sessionID,\n455: \t\t\tLabelWorkloadName: workloadName,\n456: \t\t\tLabelSandboxName:  sandboxName,\n457: \t\t})\n458: \n459: \t\tidleTimeout := DefaultSandboxIdleTimeout\n460: \t\tif template.Spec.SessionTimeout != nil {\n461: \t\t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n462: \t\t}\n463: \t\tcr.SetAnnotations(map[string]string{\n464: \t\t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n465: \t\t})\n466: \n467: \t\treturn cr, SandboxClaimsKind, nil\n468: \t}\n469: \n470: \tcr := &unstructured.Unstructured{}\n471: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n472: \tcr.SetKind(\"Sandbox\")\n473: \tcr.SetName(sandboxName)\n474: \tcr.SetNamespace(namespace)\n475: \n476: \tcr.SetLabels(map[string]string{\n477: \t\tLabelManagedBy:    LabelManagedByValue,\n478: \t\tLabelSessionID:    sessionID,\n479: \t\tLabelWorkloadName: workloadName,\n480: \t\tLabelSandboxName:  sandboxName,\n481: \t})\n482: \n483: \tidleTimeout := DefaultSandboxIdleTimeout\n484: \tif template.Spec.SessionTimeout != nil {\n485: \t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n486: \t}\n487: \tcr.SetAnnotations(map[string]string{\n488: \t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n489: \t})\n490: \n491: \tttl := DefaultSandboxTTL\n492: \tif template.Spec.MaxSessionDuration != nil {\n493: \t\tttl = int(template.Spec.MaxSessionDuration.Duration.Hours())\n494: \t}\n495: \tshutdownTime := time.Now().Add(time.Duration(ttl) * time.Hour)\n496: \n497: \tspec := map[string]interface{}{\n498: \t\t\"replicas\": int64(1),\n499: \t\t\"lifecycle\": map[string]interface{}{\n500: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n501: \t\t},\n502: \t}\n503: \n504: \tvar portsList []interface{}\n505: \tfor _, p := range ports {\n506: \t\tportsList = append(portsList, map[string]interface{}{\n507: \t\t\t\"name\":     p.Name,\n508: \t\t\t\"port\":     int64(p.Port),\n509: \t\t\t\"protocol\": string(p.Protocol),\n510: \t\t})\n511: \t}\n512: \tif len(portsList) > 0 {\n513: \t\tspec[\"ports\"] = portsList\n514: \t}\n515: \n516: \ttmpl := template.Spec.Template\n517: \tcontainer := corev1.Container{\n518: \t\tName:  \"code-interpreter\",\n519: \t\tImage: tmpl.Image,\n520: \t}\n521: \tif tmpl.ImagePullPolicy != \"\" {\n522: \t\tcontainer.ImagePullPolicy = tmpl.ImagePullPolicy\n523: \t}\n524: \tif len(tmpl.Environment) > 0 {\n525: \t\tcontainer.Env = tmpl.Environment\n526: \t}\n527: \tif len(tmpl.Command) > 0 {\n528: \t\tcontainer.Command = tmpl.Command\n529: \t}\n530: \tif len(tmpl.Args) > 0 {\n531: \t\tcontainer.Args = tmpl.Args\n532: \t}\n533: \tif !reflect.DeepEqual(tmpl.Resources, corev1.ResourceRequirements{}) {\n534: \t\tcontainer.Resources = tmpl.Resources\n535: \t}\n536: \n537: \tpodSpec := corev1.PodSpec{\n538: \t\tContainers: []corev1.Container{container},\n539: \t}\n540: \tif tmpl.RuntimeClassName != nil {\n541: \t\tpodSpec.RuntimeClassName = tmpl.RuntimeClassName\n542: \t}\n543: \tif len(tmpl.ImagePullSecrets) > 0 {\n544: \t\tpodSpec.ImagePullSecrets = tmpl.ImagePullSecrets\n545: \t}\n546: \n547: \tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n548: \tif err != nil {\n549: \t\treturn nil, \"\", fmt.Errorf(\"failed to convert pod spec: %w\", err)\n550: \t}\n551: \tspec[\"podTemplate\"] = podSpecMap\n552: \n553: \tcr.Object[\"spec\"] = spec\n554: \n555: \treturn cr, SandboxesKind, nil\n556: }\n557: \n558: func getPortsOrDefaults(ports []runtimev1alpha1.TargetPort) []runtimev1alpha1.TargetPort {\n559: \tif len(ports) == 0 {\n560: \t\treturn []runtimev1alpha1.TargetPort{\n561: \t\t\t{Port: 8080, Protocol: runtimev1alpha1.ProtocolTypeHTTP, PathPrefix: \"/\"},\n562: \t\t}\n563: \t}\n564: \treturn ports\n565: }\n566: \n567: func (h *SandboxCreateHandler) injectPicodAuthEnv(cr *unstructured.Unstructured, namespace string, clientset kubernetes.Interface) error {\n568: \tsecret, err := clientset.CoreV1().Secrets(namespace).Get(context.Background(), IdentitySecretName, metav1.GetOptions{})\n569: \tif err != nil {\n570: \t\tif apierrors.IsNotFound(err) {\n571: \t\t\treturn fmt.Errorf(\"public key not yet loaded from Router Secret\")\n572: \t\t}\n573: \t\treturn fmt.Errorf(\"failed to get secret: %w\", err)\n574: \t}\n575: \n576: \tpublicKey, ok := secret.Data[PublicKeyDataKey]\n577: \tif !ok || len(publicKey) == 0 {\n578: \t\treturn fmt.Errorf(\"public key not yet loaded from Router Secret\")\n579: \t}\n580: \n581: \tspec, ok := cr.Object[\"spec\"].(map[string]interface{})\n582: \tif !ok {\n583: \t\treturn fmt.Errorf(\"spec not found in CR\")\n584: \t}\n585: \n586: \tpodTemplate, ok := spec[\"podTemplate\"].(map[string]interface{})\n587: \tif !ok {\n588: \t\treturn fmt.Errorf(\"podTemplate not found in spec\")\n589: \t}\n590: \n591: \tcontainers, ok := podTemplate[\"containers\"].([]interface{})\n592: \tif !ok || len(containers) == 0 {\n593: \t\treturn fmt.Errorf(\"containers not found in podTemplate\")\n594: \t}\n595: \n596: \tfirstContainer, ok := containers[0].(map[string]interface{})\n597: \tif !ok {\n598: \t\treturn fmt.Errorf(\"invalid container format\")\n599: \t}\n600: \n601: \tenvVars, ok := firstContainer[\"env\"].([]interface{})\n602: \tif !ok {\n603: \t\tenvVars = []interface{}{}\n604: \t}\n605: \n606: \tnewEnv := map[string]interface{}{\n607: \t\t\"name\":  \"PICOD_AUTH_PUBLIC_KEY\",\n608: \t\t\"value\": string(publicKey),\n609: \t}\n610: \n611: \tfirstContainer[\"env\"] = append(envVars, newEnv)\n612: \tcontainers[0] = firstContainer\n613: \tpodTemplate[\"containers\"] = containers\n614: \tspec[\"podTemplate\"] = podTemplate\n615: \tcr.Object[\"spec\"] = spec\n616: \n617: \treturn nil\n618: }\n619: \n620: func (h *SandboxCreateHandler) resolvePodIP(ctx context.Context, sandboxName, namespace string, sandboxCR *unstructured.Unstructured, clientset kubernetes.Interface) (string, error) {\n621: \tpod, err := clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n622: \tif err == nil && pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n623: \t\treturn pod.Status.PodIP, nil\n624: \t}\n625: \n626: \tannotations := sandboxCR.GetAnnotations()\n627: \tif podName, ok := annotations[AnnotationSandboxPodName]; ok && podName != \"\" {\n628: \t\tpod, err := clientset.CoreV1().Pods(namespace).Get(ctx, podName, metav1.GetOptions{})\n629: \t\tif err == nil {\n630: \t\t\tif pod.Status.Phase != corev1.PodRunning {\n631: \t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n632: \t\t\t}\n633: \t\t\tif pod.Status.PodIP == \"\" {\n634: \t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n635: \t\t\t}\n636: \t\t\treturn pod.Status.PodIP, nil\n637: \t\t}\n638: \t}\n639: \n640: \tpods, err := clientset.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n641: \t\tLabelSelector: labels.SelectorFromSet(labels.Set{\n642: \t\t\tLabelSandboxName: sandboxName,\n643: \t\t}).String(),\n644: \t})\n645: \tif err != nil {\n646: \t\treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n647: \t}\n648: \n649: \tfor _, p := range pods.Items {\n650: \t\tfor _, ownerRef := range p.OwnerReferences {\n651: \t\t\tif ownerRef.Kind == \"Sandbox\" && ownerRef.Name == sandboxName {\n652: \t\t\t\tif p.Status.Phase != corev1.PodRunning {\n653: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n654: \t\t\t\t}\n655: \t\t\t\tif p.Status.PodIP == \"\" {\n656: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n657: \t\t\t\t}\n658: \t\t\t\treturn p.Status.PodIP, nil\n659: \t\t\t}\n660: \t\t}\n661: \t}\n662: \n663: \treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n664: }\n665: \n666: func (h *SandboxCreateHandler) buildEntryPoints(podIP string, ports []runtimev1alpha1.TargetPort) []EntryPoint {\n667: \tvar entryPoints []EntryPoint\n668: \tfor _, p := range ports {\n669: \t\tentryPoints = append(entryPoints, EntryPoint{\n670: \t\t\tPath:     p.PathPrefix,\n671: \t\t\tProtocol: string(p.Protocol),\n672: \t\t\tEndpoint: fmt.Sprintf(\"%s:%d\", podIP, p.Port),\n673: \t\t})\n674: \t}\n675: \treturn entryPoints\n676: }\n677: \n678: func generateSessionID() string {\n679: \treturn uuid.New().String()\n680: }\n681: \n682: func generateSandboxName(workloadName string) string {\n683: \treturn fmt.Sprintf(\"%s-%s\", workloadName, RandString(8))\n684: }\n685: \n686: func RandString(n int) string {\n687: \tconst charset = \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\"\n688: \tb := make([]byte, n)\n689: \tfor i := range b {\n690: \t\tb[i] = charset[rand.Intn(len(charset))]\n691: \t}\n692: \treturn string(b)\n693: }\n\n(End of file - total 693 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"reflect\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime\"