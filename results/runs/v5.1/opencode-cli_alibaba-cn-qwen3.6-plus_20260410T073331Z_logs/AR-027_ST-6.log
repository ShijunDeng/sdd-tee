= \"application/json\"\n38:         if token:\n39:             self.session.headers[\"Authorization\"] = f\"Bearer {token}\"\n40: \n41:         self.timeout = timeout\n42:         self.connect_timeout = connect_timeout\n43: \n44:     def create_session(\n45:         self,\n46:         name: str = \"my-interpreter\",\n47:         namespace: str = \"default\",\n48:         metadata: Optional[Dict[str, Any]] = None,\n49:         ttl: int = 3600,\n50:     ) -> str:\n51:         \"\"\"Create a code interpreter session.\n52: \n53:         POST {base_url}/v1/code-interpreter\n54:         \"\"\"\n55:         body = {\n56:             \"name\": name,\n57:             \"namespace\": namespace,\n58:             \"ttl\": ttl,\n59:             \"metadata\": metadata,\n60:         }\n61:         url = f\"{self.base_url}/v1/code-interpreter\"\n62:         resp = self.session.post(\n63:             url, json=body, timeout=(self.connect_timeout, self.timeout)\n64:         )\n65:         resp.raise_for_status()\n66:         data = resp.json()\n67:         session_id = data.get(\"sessionId\")\n68:         if session_id is None:\n69:             raise ValueError(\"Response missing 'sessionId' field\")\n70:         return session_id\n71: \n72:     def delete_session(self, session_id: str) -> bool:\n73:         \"\"\"Delete a code interpreter session.\n74: \n75:         DELETE {base_url}/v1/code-interpreter/sessions/{session_id}\n76:         404 is treated as success.\n77:         \"\"\"\n78:         url = f\"{self.base_url}/v1/code-interpreter/sessions/{session_id}\"\n79:         try:\n80:             resp = self.session.delete(\n81:                 url, timeout=(self.connect_timeout, self.timeout)\n82:             )\n83:             if resp.status_code == 404:\n84:                 return True\n85:             resp.raise_for_status()\n86:             return True\n87:         except requests.RequestException:\n88:             return False\n89: \n90:     def close(self) -> None:\n91:         \"\"\"Close the HTTP session.\"\"\"\n92:         self.session.close()\n\n(End of file - total 92 lines)\n</content>","metadata":{"preview":"import os\nfrom typing import Any, Dict, Optional\n\nimport requests\n\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.utils import read_token_from_file\n\nSA_TOKEN_PATH = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n\n\nclass ControlPlaneClient:\n    \"\"\"Client for the Workload Manager control plane API.\"\"\"\n\n    def __init__(\n        self,\n        workload_manager_url: Optional[str] = None,\n        auth_token: Optional[str] = None,\n        timeout: int = 120,\n        connect_timeout: float = 5.0,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/clients/control_plane.py","time":{"start":1775865169594,"end":1775865169600}}}}
{"type":"tool_use","timestamp":1775865170968,"sessionID":"ses_28631b237ffeiglOkSv3x6xHo2","part":{"id":"prt_d79d0074a001y156TOQYxBszs9","messageID":"msg_d79cfe340001Qf61qJI74tbdf0","sessionID":"ses_28631b237ffeiglOkSv3x6xHo2","type":"tool","tool":"read","callID":"call_794f5ad0f29d4decb6723aef","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/clients/code_interpreter_data_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/clients/code_interpreter_data_plane.py</path>\n<type>file</type>\n<content>\n1: import base64\n2: import os\n3: from typing import Any, List, Optional, Union\n4: from urllib.parse import urljoin\n5: \n6: import requests\n7: \n8: from agentcube.utils.http import create_session\n9: \n10: \n11: class CodeInterpreterDataPlaneClient:\n12:     \"\"\"Client for the Code Interpreter data plane API via the Router.\"\"\"\n13: \n14:     def __init__(\n15:         self,\n16:         session_id: str,\n17:         router_url: Optional[str] = None,\n18:         namespace: Optional[str] = None,\n19:         cr_name: Optional[str] = None,\n20:         base_url: Optional[str] = None,\n21:         timeout: int = 120,\n22:         connect_timeout: float = 5.0,\n23:         pool_connections: int = 10,\n24:         pool_maxsize: int = 10,\n25:     ):\n26:         self.session_id = session_id\n27:         self.timeout = timeout\n28:         self.connect_timeout = connect_timeout\n29: \n30:         if base_url is not None:\n31:             self.base_url = base_url\n32:         else:\n33:             base_path = f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\"\n34:             self.base_url = urljoin(router_url, base_path)\n35: \n36:         self.session = create_session(\n37:             pool_connections=pool_connections, pool_maxsize=pool_maxsize\n38:         )\n39:         self.session.headers[\"x-agentcube-session-id\"] = session_id\n40: \n41:     def _request(\n42:         self, method: str, endpoint: str, body: Optional[bytes] = None, **kwargs\n43:     ) -> requests.Response:\n44:         \"\"\"Make an HTTP request to the data plane.\"\"\"\n45:         url = f\"{self.base_url}{endpoint}\"\n46:         headers = {}\n47:         if body is not None:\n48:             headers[\"Content-Type\"] = \"application/json\"\n49:         timeout = kwargs.pop(\"timeout\", (self.connect_timeout, self.timeout))\n50:         resp = self.session.request(\n51:             method, url, data=body, headers=headers, timeout=timeout, **kwargs\n52:         )\n53:         resp.raise_for_status()\n54:         return resp\n55: \n56:     def execute_command(\n57:         self, command: Union[str, List[str]], timeout: Optional[float] = None\n58:     ) -> str:\n59:         \"\"\"Execute a shell command in the sandbox.\n60: \n61:         POST api/execute with JSON {\"command\": [...], \"timeout\": \"<n>s\"}\n62:         \"\"\"\n63:         if isinstance(command, str):\n64:             command = [command]\n65: \n66:         timeout_value = timeout if timeout is not None else self.timeout\n67:         body = {\n68:             \"command\": command,\n69:             \"timeout\": f\"{int(timeout_value)}s\",\n70:         }\n71:         import json\n72: \n73:         read_timeout = timeout_value + 2.0\n74:         resp = self._request(\n75:             \"POST\",\n76:             \"api/execute\",\n77:             body=json.dumps(body).encode(\"utf-8\"),\n78:             timeout=(self.connect_timeout, read_timeout),\n79:         )\n80:         data = resp.json()\n81:         exit_code = data.get(\"exit_code\", 0)\n82:         if exit_code != 0:\n83:             from agentcube.exceptions import CommandExecutionError\n84: \n85:             raise CommandExecutionError(\n86:                 exit_code=exit_code,\n87:                 stderr=data.get(\"stderr\", \"\"),\n88:                 command=command,\n89:             )\n90:         return data.get(\"stdout\", \"\")\n91: \n92:     def run_code(\n93:         self, language: str, code: str, timeout: Optional[float] = None\n94:     ) -> str:\n95:         \"\"\"Run code in the specified language.\"\"\"\n96:         lang = language.lower()\n97:         if lang in (\"python\", \"py\", \"python3\"):\n98:             import time\n99: \n100:             timestamp = int(time.time() * 1000)\n101:             remote_path = f\"/tmp/code_{timestamp}.py\"\n102:             self.write_file(code, remote_path)\n103:             return self.execute_command(f\"python3 {remote_path}\", timeout=timeout)\n104:         else:\n105:             raise ValueError(f\"Unsupported language: {language}\")\n106: \n107:     def write_file(self, content: str, remote_path: str) -> None:\n108:         \"\"\"Write content to a file in the sandbox.\n109: \n110:         POST api/files with JSON {\"path\", \"content\" (base64), \"mode\": \"0644\"}\n111:         \"\"\"\n112:         import json\n113: \n114:         encoded = base64.b64encode(content.encode(\"utf-8\")).decode(\"utf-8\")\n115:         body = {\n116:             \"path\": remote_path,\n117:             \"content\": encoded,\n118:             \"mode\": \"0644\",\n119:         }\n120:         self._request(\n121:             \"POST\",\n122:             \"api/files\",\n123:             body=json.dumps(body).encode(\"utf-8\"),\n124:         )\n125: \n126:     def upload_file(self, local_path: str, remote_path: str) -> None:\n127:         \"\"\"Upload a local file to the sandbox.\n128: \n129:         POST multipart to api/files\n130:         \"\"\"\n131:         url = f\"{self.base_url}api/files\"\n132:         with open(local_path, \"rb\") as f:\n133:             files = {\"file\": (os.path.basename(local_path), f)}\n134:             data = {\"path\": remote_path, \"mode\": \"0644\"}\n135:             headers = {\"x-agentcube-session-id\": self.session_id}\n136:             resp = self.session.post(\n137:                 url,\n138:                 files=files,\n139:                 data=data,\n140:                 headers=headers,\n141:                 timeout=(self.connect_timeout, self.timeout),\n142:             )\n143:             resp.raise_for_status()\n144: \n145:     def download_file(self, remote_path: str, local_path: str) -> None:\n146:         \"\"\"Download a file from the sandbox.\n147: \n148:         GET api/files/{clean_path} with stream=True\n149:         \"\"\"\n150:         clean_path = remote_path.lstrip(\"/\")\n151:         url = f\"{self.base_url}api/files/{clean_path}\"\n152:         resp = self.session.get(\n153:             url,\n154:             stream=True,\n155:             timeout=(self.connect_timeout, self.timeout),\n156:         )\n157:         resp.raise_for_status()\n158:         with open(local_path, \"wb\") as f:\n159:             for chunk in resp.iter_content(chunk_size=8192):\n160:                 f.write(chunk)\n161: \n162:     def list_files(self, path: str = \".\") -> Any:\n163:         \"\"\"List files in the sandbox.\n164: \n165:         GET api/files?path={path}\n166:         \"\"\"\n167:         resp = self._request(\n168:             \"GET\",\n169:             \"api/files\",\n170:             params={\"path\": path},\n171:         )\n172:         return resp.json()\n173: \n174:     def close(self) -> None:\n175:         \"\"\"Close the HTTP session.\"\"\"\n176:         self.session.close()\n\n(End of file - total 176 lines)\n</content>","metadata":{"preview":"import base64\nimport os\nfrom typing import Any, List, Optional, Union\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom agentcube.utils.http import create_session\n\n\nclass CodeInterpreterDataPlaneClient:\n    \"\"\"Client for the Code Interpreter data plane API via the Router.\"\"\"\n\n    def __init__(\n        self,\n        session_id: str,\n        router_url: Optional[str] = None,\n        namespace: Optional[str] = None,\n        cr_name: Optional[str] = None,\n        base_url: Optional[str] = None,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/clients/code_interpreter_data_plane.py","time":{"start":1775865170960,"end":1775865170966}}}}
