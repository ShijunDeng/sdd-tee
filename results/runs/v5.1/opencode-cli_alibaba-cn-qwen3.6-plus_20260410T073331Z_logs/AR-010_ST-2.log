, sessionID string) (*types.SandboxInfo, error)\n\tListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error)\n\tUpdateSessionLastActivity(ctx context.Context, sessionID string, lastActivityTime interface{}) error\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store.go","time":{"start":1775828522251,"end":1775828522261}}}}
{"type":"tool_use","timestamp":1775828523483,"sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","part":{"id":"prt_d77a0d59a001cGeYwxQvs2G63O","messageID":"msg_d77a0c013001ayfaEnX27879p2","sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","type":"tool","tool":"read","callID":"call_5d08d88cf07e485fb7065eaf","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/informer.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/informer.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"time\"\n5: \n6: \t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n7: \tinformers \"github.com/volcano-sh/agentcube/client-go/informers/externalversions\"\n8: \truntimeinformers \"github.com/volcano-sh/agentcube/client-go/informers/externalversions/runtime/v1alpha1\"\n9: \t\"k8s.io/apimachinery/pkg/util/runtime\"\n10: \t\"k8s.io/client-go/tools/cache\"\n11: \t\"k8s.io/klog/v2\"\n12: )\n13: \n14: type InformerManager struct {\n15: \tfactory                 informers.SharedInformerFactory\n16: \tagentRuntimeInformer    runtimeinformers.AgentRuntimeInformer\n17: \tcodeInterpreterInformer runtimeinformers.CodeInterpreterInformer\n18: \trouter                  Router\n19: }\n20: \n21: func NewInformerManager(clientset clientset.Interface, router Router) *InformerManager {\n22: \tfactory := informers.NewSharedInformerFactory(30 * time.Second)\n23: \tagentRuntimeInformer := factory.Runtime().V1alpha1().AgentRuntimes()\n24: \tcodeInterpreterInformer := factory.Runtime().V1alpha1().CodeInterpreters()\n25: \n26: \tim := &InformerManager{\n27: \t\tfactory:                 factory,\n28: \t\tagentRuntimeInformer:    agentRuntimeInformer,\n29: \t\tcodeInterpreterInformer: codeInterpreterInformer,\n30: \t\trouter:                  router,\n31: \t}\n32: \n33: \tagentRuntimeInformer.Informer().AddEventHandler(cache.ResourceEventHandlerFuncs{\n34: \t\tAddFunc:    im.onAgentRuntimeAdded,\n35: \t\tUpdateFunc: im.onAgentRuntimeUpdated,\n36: \t\tDeleteFunc: im.onAgentRuntimeDeleted,\n37: \t})\n38: \n39: \tcodeInterpreterInformer.Informer().AddEventHandler(cache.ResourceEventHandlerFuncs{\n40: \t\tAddFunc:    im.onCodeInterpreterAdded,\n41: \t\tUpdateFunc: im.onCodeInterpreterUpdated,\n42: \t\tDeleteFunc: im.onCodeInterpreterDeleted,\n43: \t})\n44: \n45: \treturn im\n46: }\n47: \n48: func (im *InformerManager) Start(stopCh <-chan struct{}) {\n49: \tim.factory.Start(stopCh)\n50: \tsynced := im.factory.WaitForCacheSync(stopCh)\n51: \tfor informerType, synced := range synced {\n52: \t\tif !synced {\n53: \t\t\tklog.Errorf(\"failed to sync informer cache for %s\", informerType)\n54: \t\t}\n55: \t}\n56: }\n57: \n58: func (im *InformerManager) onAgentRuntimeAdded(obj interface{}) {\n59: \tklog.V(4).Infof(\"AgentRuntime added: %v\", obj)\n60: }\n61: \n62: func (im *InformerManager) onAgentRuntimeUpdated(oldObj, newObj interface{}) {\n63: \tklog.V(4).Infof(\"AgentRuntime updated: %v\", newObj)\n64: }\n65: \n66: func (im *InformerManager) onAgentRuntimeDeleted(obj interface{}) {\n67: \tklog.V(4).Infof(\"AgentRuntime deleted: %v\", obj)\n68: }\n69: \n70: func (im *InformerManager) onCodeInterpreterAdded(obj interface{}) {\n71: \tklog.V(4).Infof(\"CodeInterpreter added: %v\", obj)\n72: }\n73: \n74: func (im *InformerManager) onCodeInterpreterUpdated(oldObj, newObj interface{}) {\n75: \tklog.V(4).Infof(\"CodeInterpreter updated: %v\", newObj)\n76: }\n77: \n78: func (im *InformerManager) onCodeInterpreterDeleted(obj interface{}) {\n79: \tklog.V(4).Infof(\"CodeInterpreter deleted: %v\", obj)\n80: }\n81: \n82: func init() {\n83: \truntime.ReallyCrash = false\n84: }\n\n(End of file - total 84 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n\tinformers \"github.com/volcano-sh/agentcube/client-go/informers/externalversions\"\n\truntimeinformers \"github.com/volcano-sh/agentcube/client-go/informers/externalversions/runtime/v1alpha1\"\n\t\"k8s.io/apimachinery/pkg/util/runtime\"\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype InformerManager struct {\n\tfactory                 informers.SharedInformerFactory\n\tagentRuntimeInformer    runtimeinformers.AgentRuntimeInformer\n\tcodeInterpreterInformer runtimeinformers.CodeInterpreterInformer\n\trouter                  Router\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/informer.go","time":{"start":1775828523477,"end":1775828523482}}}}
{"type":"step_finish","timestamp":1775828523575,"sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","part":{"id":"prt_d77a0da1e0013BSTMd8J8vOUhx","reason":"tool-calls","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","messageID":"msg_d77a0c013001ayfaEnX27879p2","sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","type":"step-finish","tokens":{"total":50602,"input":50349,"output":210,"reasoning":43,"cache":{"write":0,"read":0}},"cost":0.014314027}}
{"type":"step_start","timestamp":1775828525093,"sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","part":{"id":"prt_d77a0e022001Tc583c91AWWkIc","messageID":"msg_d77a0da4f001gkam5kTcp2rr3M","sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","type":"step-start"}}
{"type":"tool_use","timestamp":1775828526750,"sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","part":{"id":"prt_d77a0e2b90010F27fz0X2DK6OG","messageID":"msg_d77a0da4f001gkam5kTcp2rr3M","sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","type":"tool","tool":"read","callID":"call_38f9f686cefa4632ace1590b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/session-routing/spec.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/session-routing/spec.md</path>\n<type>file</type>\n<content>\n1: # Session Routing Specification\n2: \n3: ## Purpose\n4: Route HTTP invocation traffic to sandboxes by session: resolve or create sessions via the workload manager, track activity in the store, reverse-proxy to pod endpoints, and sign outbound requests with JWT when targeting sandboxes.\n5: \n6: ## Requirements\n7: \n8: ### Requirement: Session resolution and creation\n9: The system SHALL read session id from request header `x-agentcube-session-id`. When the header is empty, the system SHALL POST to the workload manager to create a sandbox. When non-empty, the system SHALL load `SandboxInfo` from the store by session id.\n10: \n11: #### Scenario: Missing session triggers workload manager create\n12: - **GIVEN** `WORKLOAD_MANAGER_URL` is set and an invocation request has no `x-agentcube-session-id`\n13: - **WHEN** `GetSandboxBySession` runs for `AgentRuntimeKind`\n14: - **THEN** the client POSTs JSON `{\"kind\":\"AgentRuntime\",\"name\":...,\"namespace\":...}` to `{WORKLOAD_MANAGER_URL}/v1/agent-runtime`\n15: \n16: #### Scenario: Unknown session returns not found\n17: - **GIVEN** a non-empty session id not present in store\n18: - **WHEN** the store returns `ErrNotFound`\n19: - **THEN** the error maps to `NewSessionNotFoundError(sessionID)` and the HTTP handler responds using API status (typically 404)\n20: \n21: ### Requirement: Workload manager URL and auth token for creates\n22: The system SHALL require environment variable `WORKLOAD_MANAGER_URL` at session manager construction (non-empty). When the file `/var/run/secrets/kubernetes.io/serviceaccount/token` exists and is readable, the system SHALL attach `Authorization: Bearer <trimmed contents>` to create requests.\n23: \n24: #### Scenario: Missing WORKLOAD_MANAGER_URL fails startup\n25: - **GIVEN** `WORKLOAD_MANAGER_URL` is unset\n26: - **WHEN** `NewSessionManager` is called\n27: - **THEN** it returns error `WORKLOAD_MANAGER_URL environment variable is not set`\n28: \n29: ### Requirement: Create response validation\n30: The system SHALL accept workload manager HTTP 200 with body `CreateSandboxResponse`; SHALL reject with internal error if `sessionId` in body is empty; SHALL build in-memory `SandboxInfo` with `SandboxID`, `Name` (= `sandboxName`), `SessionID`, `EntryPoints` from the response (other fields may be zero).\n31: \n32: #### Scenario: Non-OK from workload manager\n33: - **GIVEN** workload manager returns HTTP 404\n34: - **WHEN** the session manager handles the response\n35: - **THEN** the error is `NewSandboxTemplateNotFoundError(namespace, name, kind)`\n36: \n37: ### Requirement: Reverse proxy to sandbox\n38: The system SHALL determine upstream URL from `SandboxInfo.EntryPoints` by first matching `path` prefix against the invocation path; if none match, SHALL use the first entry point. The system SHALL build URL by prefixing `protocol` (lowercase) and `://` to `endpoint` when protocol is set and endpoint lacks a scheme. The system SHALL use `httputil.NewSingleHostReverseProxy`, shared `http.Transport` on the proxy, and custom `Director` to set path, host, forwarding headers, and optional JWT.\n39: \n40: #### Scenario: No entry points\n41: - **GIVEN** `EntryPoints` is empty\n42: - **WHEN** upstream is determined\n43: - **THEN** the handler responds 404 JSON `{\"error\":\"no entry point found for sandbox\"}`\n44: \n45: ### Requirement: JWT injection for sandbox kinds\n46: For sandbox kinds `Sandbox` and `SandboxClaim`, the system SHALL generate a JWT before proxying and SHALL set `Authorization: Bearer <token>` on the proxied request.\n47: \n48: #### Scenario: Signing failure\n49: - **GIVEN** JWT generation returns an error\n50: - **WHEN** forwarding is attempted\n51: - **THEN** the handler responds 500 with JSON containing `\"code\":\"JWT_SIGNING_FAILED\"` and `\"error\":\"failed to sign request\"`\n52: \n53: ### Requirement: Forwarding headers and response header\n54: The system SHALL set `X-Forwarded-Host` from the incoming request host, `X-Forwarded-Proto` to `https` when TLS is present else `http`, and `X-Forwarded-For` by appending client IP to any existing values. The system SHALL set response header `x-agentcube-session-id` to the resolved session id on all proxied responses.\n55: \n56: #### Scenario: Path normalization\n57: - **GIVEN** the Gin path param is non-empty and lacks a leading slash\n58: - **WHEN** the director runs\n59: - **THEN** the outbound path is prefixed with `/`\n60: \n61: ### Requirement: Proxy error mapping\n62: The system SHALL map proxy errors containing `connection refused` to 502 `{\"error\":\"sandbox unreachable\"}`, containing `timeout` to 504 `{\"error\":\"sandbox timeout\"}`, and other errors to 502 `{\"error\":\"sandbox unreachable\"}`.\n63: \n64: #### Scenario: Downstream connection refused\n65: - **GIVEN** the reverse proxy fails with an error whose message includes `connection refused`\n66: - **WHEN** `ErrorHandler` runs\n67: - **THEN** status is 502 and error text is `sandbox unreachable`\n68: \n69: ### Requirement: Last-activity updates\n70: The system SHALL call `UpdateSessionLastActivity` with `time.Now()` after successfully resolving the sandbox and again after `forwardToSandbox` returns (twice per successful invoke path). Failures SHALL be logged as warnings only.\n71: \n72: #### Scenario: Store update failure does not block proxy\n73: - **GIVEN** `UpdateSessionLastActivity` returns an error\n74: - **WHEN** handling continues\n75: - **THEN** the proxy still runs if sandbox resolution succeeded\n76: \n77: ### Requirement: Health endpoints\n78: The system SHALL expose `GET /health/live` returning 200 `{\"status\":\"alive\"}`. The system SHALL expose `GET /health/ready` returning 200 `{\"status\":\"ready\"}` when session manager is non-nil, else 503 with `status` and `error` fields.\n79: \n80: #### Scenario: Ready depends on session manager\n81: - **GIVEN** `sessionManager` is nil\n82: - **WHEN** `GET /health/ready` is served\n83: - **THEN** status is 503 and body includes `\"error\":\"session manager not available\"`\n84: \n85: ### Requirement: Concurrency limiting\n86: The system SHALL apply a semaphore middleware to `/v1/*` routes with capacity `MaxConcurrentRequests` (default 1000 when config value ≤ 0). When no slot is available, the system SHALL respond 429 JSON `{\"error\":\"server overloaded, please try again later\",\"code\":\"SERVER_OVERLOADED\"}` and abort.\n87: \n88: #### Scenario: Default limit when zero in config\n89: - **GIVEN** `NewServer` receives `MaxConcurrentRequests` 0\n90: - **WHEN** the server is constructed\n91: - **THEN** the effective limit is set to 1000 before route registration\n92: \n93: ### Requirement: Invocation route surface\n94: The system SHALL register GET and POST for `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` and for `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path`, with Gin logger, recovery, and concurrency middleware on the `/v1` group only.\n95: \n96: #### Scenario: Kind passed to session lookup\n97: - **GIVEN** agent-runtime invocation\n98: - **WHEN** `handleInvoke` runs\n99: - **THEN** kind argument is `AgentRuntime` (`types.AgentRuntimeKind`)\n100: \n101: ### Requirement: HTTP server behavior\n102: The system SHALL serve with `h2c` and `http2.Server`, `ReadTimeout` 30s, `IdleTimeout` 90s; on context cancel SHALL shutdown within 10s. Optional TLS SHALL require both cert and key paths.\n103: \n104: #### Scenario: TLS misconfiguration\n105: - **GIVEN** `EnableTLS` true and empty cert path\n106: - **WHEN** `Start` runs\n107: - **THEN** it returns error stating cert/key not provided\n108: \n109: ### Requirement: Identity secret bootstrap for JWT\n110: On server creation the system SHALL construct `JWTManager`, call `TryStoreOrLoadJWTKeySecret`, and fail server creation if that returns error (except in-cluster skip path returns nil when not in cluster).\n111: \n112: #### Scenario: In-cluster secret creation\n113: - **GIVEN** in-cluster config succeeds and secret does not exist\n114: - **WHEN** `TryStoreOrLoadJWTKeySecret` runs\n115: - **THEN** it creates opaque secret `picod-router-identity` in namespace from `AGENTCUBE_NAMESPACE` or `default` with keys `private.pem` and `public.pem`\n\n(End of file - total 115 lines)\n</content>","metadata":{"preview":"# Session Routing Specification\n\n## Purpose\nRoute HTTP invocation traffic to sandboxes by session: resolve or create sessions via the workload manager, track activity in the store, reverse-proxy to pod endpoints, and sign outbound requests with JWT when targeting sandboxes.\n\n## Requirements\n\n### Requirement: Session resolution and creation\nThe system SHALL read session id from request header `x-agentcube-session-id`. When the header is empty, the system SHALL POST to the workload manager to create a sandbox. When non-empty, the system SHALL load `SandboxInfo` from the store by session id.\n\n#### Scenario: Missing session triggers workload manager create\n- **GIVEN** `WORKLOAD_MANAGER_URL` is set and an invocation request has no `x-agentcube-session-id`\n- **WHEN** `GetSandboxBySession` runs for `AgentRuntimeKind`\n- **THEN** the client POSTs JSON `{\"kind\":\"AgentRuntime\",\"name\":...,\"namespace\":...}` to `{WORKLOAD_MANAGER_URL}/v1/agent-runtime`\n\n#### Scenario: Unknown session returns not found\n- **GIVEN** a non-empty session id not present in store\n- **WHEN** the store returns `ErrNotFound`\n- **THEN** the error maps to `NewSessionNotFoundError(sessionID)` and the HTTP handler responds using API status (typically 404)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/session-routing/spec.md","time":{"start":1775828526743,"end":1775828526748}}}}
{"type":"tool_use","timestamp":1775828528077,"sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","part":{"id":"prt_d77a0e76f001yrADcus8jiRXzB","messageID":"msg_d77a0da4f001gkam5kTcp2rr3M","sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","type":"tool","tool":"read","callID":"call_d46d02cd6db646f1a84e78cc","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/session-store/spec.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/session-store/spec.md</path>\n<type>file</type>\n<content>\n1: # Session Store Specification\n2: \n3: ## Purpose\n4: Persist sandbox metadata keyed by session id, index sessions by expiry and last activity for garbage collection, and support Redis or Valkey backends selected by configuration.\n5: \n6: ## Requirements\n7: \n8: ### Requirement: Store interface contract\n9: The system SHALL provide a `Store` interface implemented by Redis and Valkey providers with methods: `Ping`, `GetSandboxBySessionID`, `StoreSandbox`, `UpdateSandbox`, `DeleteSandboxBySessionID`, `ListExpiredSandboxes`, `ListInactiveSandboxes`, `UpdateSessionLastActivity`, and `Close`.\n10: \n11: #### Scenario: Ping verifies connectivity\n12: - **GIVEN** a healthy Redis/Valkey server\n13: - **WHEN** `Ping(ctx)` is called\n14: - **THEN** the implementation issues PING and requires string response `PONG`\n15: \n16: ### Requirement: Not found semantics\n17: The system SHALL return package error `ErrNotFound` (message `store: not found`) when a session key is absent on read or when last-activity update targets a missing session.\n18: \n19: #### Scenario: Get missing session\n20: - **GIVEN** no key `session:{id}` in backend\n21: - **WHEN** `GetSandboxBySessionID` runs\n22: - **THEN** error is `ErrNotFound` (Redis: `Nil`; Valkey: `IsValkeyNil`)\n23: \n24: ### Requirement: Session key naming\n25: The system SHALL use string prefix `session:` concatenated with the session id as the primary key for JSON document storage.\n26: \n27: #### Scenario: Key construction\n28: - **GIVEN** session id `abc`\n29: - **WHEN** the store writes sandbox data\n30: - **THEN** the string key is `session:abc`\n31: \n32: ### Requirement: Expiry index\n33: The system SHALL maintain sorted set key `session:expiry` with member = session id and score = `ExpiresAt` Unix seconds. `StoreSandbox` SHALL add the member with the sandbox expiry score. `DeleteSandboxBySessionID` SHALL remove the member.\n34: \n35: #### Scenario: List expired uses ZRANGEBYSCORE\n36: - **GIVEN** `ListExpiredSandboxes(ctx, before, limit)` with limit > 0\n37: - **WHEN** the implementation queries the index\n38: - **THEN** it selects members with scores from negative infinity through `before.Unix()`, limited to `limit` entries\n39: \n40: ### Requirement: Last-activity index\n41: The system SHALL maintain sorted set key `session:last_activity` with member = session id and score = last activity Unix seconds. `StoreSandbox` SHALL ZADD with score `time.Now().Unix()` on initial store. `UpdateSessionLastActivity` SHALL ZADD with the provided timestamp (or now if zero). `DeleteSandboxBySessionID` SHALL ZREM the member.\n42: \n43: #### Scenario: List inactive uses activity index\n44: - **GIVEN** `ListInactiveSandboxes(ctx, before, limit)`\n45: - **WHEN** executed\n46: - **THEN** members with last-activity score ≤ `before.Unix()` are returned up to `limit`\n47: \n48: ### Requirement: StoreSandbox atomicity and validation\n49: The system SHALL reject nil sandbox or zero `ExpiresAt`. The system SHALL execute SETNX on session key, ZADD expiry, and ZADD last_activity in one pipeline/multi block. The system SHALL fail if any command in the batch errors.\n50: \n51: #### Scenario: Nil sandbox rejected\n52: - **GIVEN** `StoreSandbox(ctx, nil)`\n53: - **WHEN** called\n54: - **THEN** error indicates sandbox is nil\n55: \n56: ### Requirement: UpdateSandbox semantics\n57: The system SHALL update only the session JSON value using SET with XX (key must exist). The system SHALL NOT modify expiry or last-activity ZSET entries in this operation.\n58: \n59: #### Scenario: Missing key on update\n60: - **GIVEN** session key does not exist\n61: - **WHEN** `UpdateSandbox` runs\n62: - **THEN** Redis: SETXX returns false → error `key not exists`; Valkey: response not OK → same error class\n63: \n64: ### Requirement: DeleteSandboxBySessionID cleanup\n65: The system SHALL delete session key and remove session id from both sorted sets in one pipeline/multi.\n66: \n67: #### Scenario: Full removal\n68: - **GIVEN** an existing session\n69: - **WHEN** delete succeeds\n70: - **THEN** GET session key returns not found and ZSETs no longer contain the member\n71: \n72: ### Requirement: List loaders tolerate missing keys\n73: When listing by ZSET returns session ids, the system SHALL load JSON per id; SHALL skip entries where the string key is missing (Redis pipeline GET nil, Valkey MGET empty string) without failing the whole batch.\n74: \n75: #### Scenario: Orphan ZSET member\n76: - **GIVEN** a session id in ZSET without a hash/string value\n77: - **WHEN** `loadSandboxesBySessionIDs` runs\n78: - **THEN** that id is omitted from the returned slice\n79: \n80: ### Requirement: UpdateSessionLastActivity preconditions\n81: The system SHALL reject empty session id. If `at` is zero time, the system SHALL use `time.Now()`. The system SHALL verify the session key exists before ZADD; if absent, SHALL return `ErrNotFound`.\n82: \n83: #### Scenario: Activity bump for unknown session\n84: - **GIVEN** no `session:{id}` key\n85: - **WHEN** `UpdateSessionLastActivity` is called\n86: - **THEN** return `ErrNotFound`\n87: \n88: ### Requirement: Provider selection via STORE_TYPE\n89: The system SHALL read `STORE_TYPE` case-insensitively; if unset, SHALL default to `redis`. Supported values SHALL be `redis` and `valkey`; any other value SHALL fail initialization.\n90: \n91: #### Scenario: Default redis\n92: - **GIVEN** `STORE_TYPE` is not set\n93: - **WHEN** `Storage()` first initializes\n94: - **THEN** Redis implementation is constructed\n95: \n96: ### Requirement: Redis environment and password policy\n97: The system SHALL require `REDIS_ADDR`. The system SHALL require non-empty `REDIS_PASSWORD` unless `REDIS_PASSWORD_REQUIRED` is set case-insensitively to `false`.\n98: \n99: #### Scenario: Password required by default\n100: - **GIVEN** `REDIS_ADDR` set and `REDIS_PASSWORD` empty and `REDIS_PASSWORD_REQUIRED` unset\n101: - **WHEN** Redis store initializes\n102: - **THEN** initialization fails with error stating password required\n103: \n104: ### Requirement: Valkey environment and options\n105: The system SHALL require `VALKEY_ADDR` (comma-separated addresses split for `InitAddress`). The system SHALL require non-empty `VALKEY_PASSWORD` unless `VALKEY_PASSWORD_REQUIRED=false`. The system SHALL set `DisableCache` true when `VALKEY_DISABLE_CACHE` parses as true; SHALL set `ForceSingleClient` true when `VALKEY_FORCE_SINGLE` parses as true.\n106: \n107: #### Scenario: Optional client flags\n108: - **GIVEN** `VALKEY_DISABLE_CACHE=true`\n109: - **WHEN** Valkey client options are built\n110: - **THEN** `DisableCache` is true on `ClientOption`\n111: \n112: ### Requirement: Singleton access\n113: The system SHALL expose `func Storage() Store` using `sync.Once`; failed init SHALL log fatal via klog.\n114: \n115: #### Scenario: Single initialization\n116: - **GIVEN** multiple goroutines call `Storage()`\n117: - **WHEN** they run concurrently\n118: - **THEN** `initStore` executes exactly once\n\n(End of file - total 118 lines)\n</content>","metadata":{"preview":"# Session Store Specification\n\n## Purpose\nPersist sandbox metadata keyed by session id, index sessions by expiry and last activity for garbage collection, and support Redis or Valkey backends selected by configuration.\n\n## Requirements\n\n### Requirement: Store interface contract\nThe system SHALL provide a `Store` interface implemented by Redis and Valkey providers with methods: `Ping`, `GetSandboxBySessionID`, `StoreSandbox`, `UpdateSandbox`, `DeleteSandboxBySessionID`, `ListExpiredSandboxes`, `ListInactiveSandboxes`, `UpdateSessionLastActivity`, and `Close`.\n\n#### Scenario: Ping verifies connectivity\n- **GIVEN** a healthy Redis/Valkey server\n- **WHEN** `Ping(ctx)` is called\n- **THEN** the implementation issues PING and requires string response `PONG`\n\n### Requirement: Not found semantics\nThe system SHALL return package error `ErrNotFound` (message `store: not found`) when a session key is absent on read or when last-activity update targets a missing session.\n\n#### Scenario: Get missing session\n- **GIVEN** no key `session:{id}` in backend","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/session-store/spec.md","time":{"start":1775828528061,"end":1775828528074}}}}
{"type":"step_finish","timestamp":1775828528098,"sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","part":{"id":"prt_d77a0ebcc001FxQ5tOe0Ck4ul6","reason":"tool-calls","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","messageID":"msg_d77a0da4f001gkam5kTcp2rr3M","sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","type":"step-finish","tokens":{"total":53894,"input":53728,"output":140,"reasoning":26,"cache":{"write":0,"read":0}},"cost":0.015102994}}
{"type":"step_start","timestamp":1775828533663,"sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","part":{"id":"prt_d77a1019c001uTzGUHzF16ftUL","messageID":"msg_d77a0ebf9001xgBhWAs55cPeuQ","sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","type":"step-start"}}
{"type":"tool_use","timestamp":1775828663175,"sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","part":{"id":"prt_d77a1120f00128oNfC8n9oqoKV","messageID":"msg_d77a0ebf9001xgBhWAs55cPeuQ","sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","type":"tool","tool":"write","callID":"call_a3c4155a1693470888ba8c71","state":{"status":"completed","input":{"content":"# AR-010: Router 会话管理 — Delta Spec\n\n## Purpose\n\n为 `pkg/router` 模块实现完整的会话管理能力，在 AR-009（HTTP 反向代理核心）的基础上，扩展 SessionManager 接口、实现 Redis/Valkey Store 后端、激活 Informer 事件处理器、引入会话生命周期 GC，并增强代理流程的会话感知能力。本变更是对 AR-007（Reconciler 控制器）的下游消费方，同时依赖 session-store spec 中定义的存储契约。\n\n## Requirements\n\n### Requirement: SessionManager 接口扩展\n\nThe system SHALL 在 `pkg/router/session_manager.go` 中扩展 `SessionManager` 接口，新增以下方法：\n\n```go\ntype SessionManager interface {\n    // 现有方法（AR-009）\n    GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)\n\n    // 新增方法（AR-010）\n    CreateSession(ctx context.Context, info *types.SandboxInfo) error\n    UpdateSession(ctx context.Context, sessionID string, info *types.SandboxInfo) error\n    DeleteSession(ctx context.Context, sessionID string) error\n    UpdateLastActivity(ctx context.Context, sessionID string) error\n    ListSessions(ctx context.Context) (map[string]*types.SandboxInfo, error)\n}\n```\n\n`CreateSession` SHALL 调用 `store.StoreSandbox` 将会话元数据写入存储后端。\n\n`UpdateSession` SHALL 调用 `store.UpdateSandbox` 更新已存在会话的元数据。\n\n`DeleteSession` SHALL 调用 `store.DeleteSandboxBySessionID` 删除会话及关联索引。\n\n`UpdateLastActivity` SHALL 调用 `store.UpdateSessionLastActivity` 更新最后活跃时间。\n\n`ListSessions` SHALL 调用 `store.ListSandboxes` 返回所有活跃会话。\n\n#### Scenario: CreateSession 写入存储\n\n- **GIVEN** `SandboxInfo{SessionID: \"sess-001\", SandboxName: \"my-runtime-abc\", Kind: \"AgentRuntime\"}`\n- **WHEN** `CreateSession(ctx, info)` 被调用\n- **THEN** `store.StoreSandbox(ctx, \"sess-001\", info)` 被调用且返回 nil\n\n#### Scenario: UpdateSession 更新已存在会话\n\n- **GIVEN** 存储中存在 `sess-001` 条目\n- **WHEN** `UpdateSession(ctx, \"sess-001\", updatedInfo)` 被调用\n- **THEN** `store.UpdateSandbox(ctx, \"sess-001\", updatedInfo)` 被调用\n\n#### Scenario: DeleteSession 清理会话\n\n- **GIVEN** 存储中存在 `sess-001` 条目\n- **WHEN** `DeleteSession(ctx, \"sess-001\")` 被调用\n- **THEN** `store.DeleteSandboxBySessionID(ctx, \"sess-001\")` 被调用\n\n#### Scenario: UpdateLastActivity 更新活跃时间\n\n- **GIVEN** 存储中存在 `sess-001` 条目\n- **WHEN** `UpdateLastActivity(ctx, \"sess-001\")` 被调用\n- **THEN** `store.UpdateSessionLastActivity(ctx, \"sess-001\", time.Now())` 被调用\n\n#### Scenario: ListSessions 返回所有会话\n\n- **GIVEN** 存储中存在 `sess-001` 和 `sess-002` 条目\n- **WHEN** `ListSessions(ctx)` 被调用\n- **THEN** 返回包含两个条目的 map，key 为 sessionID\n\n---\n\n### Requirement: Redis/Valkey Store 实现\n\nThe system SHALL 在 `pkg/store/` 下实现 Redis 和 Valkey 两种后端，满足 session-store spec 中定义的契约：\n\n**接口契约：**\n\n| 方法 | 行为 |\n|------|------|\n| `StoreSandbox(ctx, sessionID, info)` | SETNX session key + ZADD expiry + ZADD last_activity（原子管道） |\n| `UpdateSandbox(ctx, sessionID, info)` | SET XX（仅更新已存在的 key，不修改 ZSET） |\n| `DeleteSandboxBySessionID(ctx, sessionID)` | DEL session key + ZREM expiry + ZREM last_activity（原子管道） |\n| `GetSandbox(ctx, sessionID)` | GET session key，不存在返回 `ErrNotFound` |\n| `ListSandboxes(ctx)` | 遍历 `session:expiry` ZSET 加载所有会话 |\n| `UpdateSessionLastActivity(ctx, sessionID, at)` | 验证 session key 存在后 ZADD last_activity |\n\n**Key 命名规范：**\n- 主键：`session:{sessionID}`（JSON 文档）\n- 过期索引：`session:expiry`（sorted set，score = ExpiresAt Unix 秒）\n- 活跃索引：`session:last_activity`（sorted set，score = last activity Unix 秒）\n\n**Provider 选择：**\n- 环境变量 `STORE_TYPE`（大小写不敏感），未设置时默认 `redis`\n- 支持值：`redis`、`valkey`，其他值初始化失败\n\n**Redis 配置：**\n- 必需：`REDIS_ADDR`\n- 默认要求密码：`REDIS_PASSWORD` 非空，除非 `REDIS_PASSWORD_REQUIRED=false`\n\n**Valkey 配置：**\n- 必需：`VALKEY_ADDR`（逗号分隔，split 为 `InitAddress`）\n- 默认要求密码：`VALKEY_PASSWORD` 非空，除非 `VALKEY_PASSWORD_REQUIRED=false`\n- 可选：`VALKEY_DISABLE_CACHE=true` → `DisableCache`，`VALKEY_FORCE_SINGLE=true` → `ForceSingleClient`\n\n**单例访问：**\n- `Storage()` 使用 `sync.Once` 初始化\n- 初始化失败时通过 `klog.Fatal` 记录\n\n#### Scenario: 默认 Provider 为 Redis\n\n- **GIVEN** `STORE_TYPE` 未设置\n- **WHEN** `Storage()` 首次调用\n- **THEN** 构造 Redis 实现\n\n#### Scenario: 主键命名\n\n- **GIVEN** sessionID 为 `abc`\n- **WHEN** Store 写入会话数据\n- **THEN** Redis key 为 `session:abc`\n\n#### Scenario: 过期索引 ZADD\n\n- **GIVEN** SandboxInfo 的 ExpiresAt 为 `2026-04-10T10:00:00Z`（Unix 秒 1744279200）\n- **WHEN** `StoreSandbox` 执行\n- **THEN** `session:expiry` ZSET 中 member `abc` 的 score 为 `1744279200`\n\n#### Scenario: 活跃索引 ZADD\n\n- **GIVEN** 当前时间为 `2026-04-10T09:00:00Z`（Unix 秒 1744275600）\n- **WHEN** `StoreSandbox` 执行\n- **THEN** `session:last_activity` ZSET 中 member `abc` 的 score 为 `1744275600`\n\n#### Scenario: 获取不存在的会话返回 ErrNotFound\n\n- **GIVEN** `session:unknown` key 不存在\n- **WHEN** `GetSandbox(ctx, \"unknown\")` 被调用\n- **THEN** 返回 `ErrNotFound`\n\n#### Scenario: nil Sandbox 被拒绝\n\n- **GIVEN** `StoreSandbox(ctx, \"sess-001\", nil)`\n- **WHEN** 被调用\n- **THEN** 返回错误，指示 sandbox 为 nil\n\n#### Scenario: UpdateSandbox 对不存在的 key 返回错误\n\n- **GIVEN** `session:unknown` key 不存在\n- **WHEN** `UpdateSandbox(ctx, \"unknown\", info)` 被调用\n- **THEN** 返回错误（Redis: SET XX 返回 false → `key not exists`）\n\n#### Scenario: 删除操作清理所有关联 key\n\n- **GIVEN** 会话 `sess-001` 存在于主键和两个 ZSET 中\n- **WHEN** `DeleteSandboxBySessionID(ctx, \"sess-001\")` 执行成功\n- **THEN** `GET session:sess-001` 返回 nil，两个 ZSET 中均不包含 `sess-001`\n\n#### Scenario: Valkey 多地址解析\n\n- **GIVEN** `VALKEY_ADDR = \"valkey1:6379,valkey2:6379,valkey3:6379\"`\n- **WHEN** Valkey Store 初始化\n- **THEN** `InitAddress` 包含三个地址\n\n#### Scenario: 不支持的 STORE_TYPE 初始化失败\n\n- **GIVEN** `STORE_TYPE = \"memcached\"`\n- **WHEN** `Storage()` 首次调用\n- **THEN** 初始化失败，记录 fatal 日志\n\n#### Scenario: 并发调用 Storage() 仅初始化一次\n\n- **GIVEN** 多个 goroutine 同时调用 `Storage()`\n- **WHEN** 执行完成\n- **THEN** `initStore` 仅执行一次，所有调用返回同一实例\n\n---\n\n### Requirement: StoreSandbox 原子性\n\nThe system SHALL 在 `StoreSandbox` 中使用 Redis pipeline 或 Valkey multi block 确保以下操作的原子性：\n1. SETNX `session:{sessionID}` 写入 JSON 文档\n2. ZADD `session:expiry` 添加过期索引\n3. ZADD `session:last_activity` 添加活跃索引\n\n若管道中任一命令失败，整个操作 SHALL 失败，不产生部分写入。\n\n#### Scenario: 原子写入成功\n\n- **GIVEN** Redis/Valkey 连接正常\n- **WHEN** `StoreSandbox(ctx, \"sess-001\", validInfo)` 被调用\n- **THEN** 三个命令在一个管道中执行，全部成功\n\n#### Scenario: 原子写入部分失败回滚\n\n- **GIVEN** Redis/Valkey 在管道执行过程中断开连接\n- **WHEN** `StoreSandbox` 执行\n- **THEN** 返回错误，不产生部分写入（SETNX 未执行则 ZSET 不写入）\n\n---\n\n### Requirement: UpdateSessionLastActivity 前置检查\n\nThe system SHALL 在 `UpdateSessionLastActivity` 中执行以下检查：\n1. 若 `sessionID` 为空，返回错误\n2. 若 `at` 为零时间（`time.IsZero()`），使用 `time.Now()`\n3. 验证 `session:{sessionID}` key 存在，不存在返回 `ErrNotFound`\n4. 执行 ZADD `session:last_activity` 更新活跃索引\n\n#### Scenario: 空 sessionID 被拒绝\n\n- **GIVEN** `sessionID = \"\"`\n- **WHEN** `UpdateSessionLastActivity(ctx, \"\", time.Now())` 被调用\n- **THEN** 返回错误\n\n#### Scenario: 零时间自动使用当前时间\n\n- **GIVEN** `at = time.Time{}`（零时间）\n- **WHEN** `UpdateSessionLastActivity(ctx, \"sess-001\", at)` 被调用\n- **THEN** 使用 `time.Now()` 作为 score\n\n#### Scenario: 未知会话的活跃时间更新\n\n- **GIVEN** `session:sess-unknown` key 不存在\n- **WHEN** `UpdateSessionLastActivity(ctx, \"sess-unknown\", time.Now())` 被调用\n- **THEN** 返回 `ErrNotFound`\n\n---\n\n### Requirement: ListExpiredSandboxes 与 ListInactiveSandboxes\n\nThe system SHALL 在 Store 接口中新增以下方法（供 GC 使用）：\n\n```go\nListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)\nListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)\n```\n\n`ListExpiredSandboxes` SHALL 使用 `ZRANGEBYSCORE session:expiry -inf <before.Unix()> LIMIT 0 <limit>` 查询过期会话 ID，然后批量加载 JSON 文档。\n\n`ListInactiveSandboxes` SHALL 使用 `ZRANGEBYSCORE session:last_activity -inf <before.Unix()> LIMIT 0 <limit>` 查询不活跃会话 ID，然后批量加载 JSON 文档。\n\n加载 JSON 时若某个 session ID 对应的主键不存在（孤立 ZSET 成员），SHALL 跳过该条目而不使整个批次失败。\n\n#### Scenario: 查询过期会话\n\n- **GIVEN** `session:expiry` 中有 `sess-001`（score=1000）和 `sess-002`（score=2000）\n- **WHEN** `ListExpiredSandboxes(ctx, time.Unix(1500, 0), 10)` 被调用\n- **THEN** 返回 `sess-001` 的 SandboxInfo，不包含 `sess-002`\n\n#### Scenario: 孤立 ZSET 成员被跳过\n\n- **GIVEN** `session:expiry` 中有 `sess-orphan`，但 `session:sess-orphan` key 不存在\n- **WHEN** `ListExpiredSandboxes` 执行\n- **THEN** `sess-orphan` 被跳过，不返回错误\n\n---\n\n### Requirement: Informer 事件处理器激活\n\nThe system SHALL 在 `pkg/router/informer.go` 中将 Informer 事件处理器从 stub 改为实际更新会话缓存和路由表：\n\n**AgentRuntime 事件处理：**\n\n| 事件 | 行为 |\n|------|------|\n| `AddFunc` | 从 CR labels 提取 `runtime.agentcube.io/session-id`，构建 `SandboxInfo`，调用 `router.AddRoute` 注册路由 |\n| `UpdateFunc` | 比较新旧 CR 的 `status.conditions`，若 `Ready` 条件变更，调用 `store.UpdateSandbox` 更新会话状态 |\n| `DeleteFunc` | 从 CR labels 或 tombstone 提取 session-id，调用 `router.RemoveRoute` 和 `store.DeleteSandboxBySessionID` |\n\n**CodeInterpreter 事件处理：**\n\n| 事件 | 行为 |\n|------|------|\n| `AddFunc` | 同 AgentRuntime AddFunc，Kind 标识为 `CodeInterpreter` |\n| `UpdateFunc` | 同 AgentRuntime UpdateFunc，额外处理 Warm Pool 激活事件（`spec.warmPoolSize` 从 0 变为 >0） |\n| `DeleteFunc` | 同 AgentRuntime DeleteFunc |\n\n**Label 提取：**\n- `runtime.agentcube.io/session-id` → `SandboxInfo.SessionID`\n- `runtime.agentcube.io/sandbox-name` → `SandboxInfo.SandboxName`\n- `runtime.agentcube.io/workload-name` → `SandboxInfo.WorkloadName`\n\n**状态映射（CR conditions → Store status）：**\n\n| Ready Condition | Store Status |\n|-----------------|--------------|\n| 缺失             | `pending`    |\n| `status: Unknown` | `pending`    |\n| `status: True`   | `running`    |\n| `status: False`, `reason: Terminated` | `terminated` |\n| `status: False`, 其他 reason | `pending` |\n\n#### Scenario: AgentRuntime 新增时注册路由\n\n- **GIVEN** 新的 AgentRuntime CR `default/my-runtime`，labels 包含 `runtime.agentcube.io/session-id: sess-001`\n- **WHEN** `onAgentRuntimeAdded` 被触发\n- **THEN** 构建 `SandboxInfo{SessionID: \"sess-001\", Kind: \"AgentRuntime\", Status: \"pending\"}`\n- **AND** `router.AddRoute` 被调用注册对应路由\n\n#### Scenario: AgentRuntime 状态从 Pending 变为 Running\n\n- **GIVEN** AgentRuntime CR 的 `status.conditions` 中 `Ready` 条件从缺失变为 `True`\n- **WHEN** `onAgentRuntimeUpdated` 被触发\n- **THEN** `store.UpdateSandbox` 被调用，将会话状态更新为 `running`\n\n#### Scenario: AgentRuntime 删除时清理路由和存储\n\n- **GIVEN** AgentRuntime CR `default/my-runtime` 被删除，labels 包含 `runtime.agentcube.io/session-id: sess-001`\n- **WHEN** `onAgentRuntimeDeleted` 被触发\n- **THEN** `router.RemoveRoute` 被调用移除路由\n- **AND** `store.DeleteSandboxBySessionID(ctx, \"sess-001\")` 被调用\n\n#### Scenario: CodeInterpreter Warm Pool 激活\n\n- **GIVEN** CodeInterpreter CR 的 `spec.warmPoolSize` 从 0 变为 5\n- **WHEN** `onCodeInterpreterUpdated` 被触发\n- **THEN** 记录 Warm Pool 激活日志，包含 pool size 值\n\n#### Scenario: Tombstone 处理\n\n- **GIVEN** informer 在缓存未同步时收到删除事件，obj 为 `cache.DeletedFinalStateUnknown`\n- **WHEN** `DeleteFunc` 被触发\n- **THEN** 从 `DeletedFinalStateUnknown.Obj` 提取对象并生成 session-id\n\n#### Scenario: 无 session-id label 的 CR 被忽略\n\n- **GIVEN** AgentRuntime CR 无 `runtime.agentcube.io/session-id` label\n- **WHEN** `onAgentRuntimeAdded` 被触发\n- **THEN** 记录警告日志，不执行 Store 或 Router 操作\n\n---\n\n### Requirement: 会话生命周期 GC\n\nThe system SHALL 在 `pkg/router/session_lifecycle.go` 中实现 `LifecycleManager`：\n\n```go\ntype LifecycleManager struct {\n    store         store.Store\n    checkInterval time.Duration\n    idleTimeout   time.Duration\n    maxDuration   time.Duration\n    clientset     clientset.Interface\n}\n```\n\n`Start(ctx)` SHALL 启动后台 GC 协程，按 `checkInterval` 周期执行以下清理：\n\n1. **TTL 过期清理（cleanupExpired）**：调用 `store.ListExpiredSandboxes(ctx, time.Now(), batchSize)`，对每个过期会话调用 `store.DeleteSandboxBySessionID`\n2. **空闲超时清理（cleanupIdle）**：调用 `store.ListInactiveSandboxes(ctx, time.Now().Add(-idleTimeout), batchSize)`，对每个不活跃会话调用 `store.DeleteSandboxBySessionID`\n3. **孤儿 CR 清理（cleanupOrphans）**：遍历 `store.ListSandboxes` 中的会话，通过 Lister 验证对应 CR 是否存在，若 CR 不存在则清理 Store 条目\n4. **幽灵条目清理（cleanupGhosts）**：通过 Lister 列出所有 AgentRuntime/CodeInterpreter CR，验证 Store 中是否有对应条目，若 Store 中缺失则补建\n\n`Stop()` SHALL 发送停止信号并等待 GC 协程退出（超时 10 秒）。\n\n**默认配置：**\n- `checkInterval`: 5 分钟\n- `idleTimeout`: 30 分钟（可被 CR 的 `spec.sessionTimeout` 覆盖）\n- `maxDuration`: 24 小时（可被 CR 的 `spec.maxSessionDuration` 覆盖）\n- `batchSize`: 100\n\n#### Scenario: TTL 过期会话被清理\n\n- **GIVEN** 会话 `sess-001` 的 ExpiresAt 已过\n- **WHEN** GC 周期执行 `cleanupExpired`\n- **THEN** `store.DeleteSandboxBySessionID(ctx, \"sess-001\")` 被调用\n\n#### Scenario: 空闲超时会话被清理\n\n- **GIVEN** 会话 `sess-002` 的 LastActivityAt 为 35 分钟前，idleTimeout 为 30 分钟\n- **WHEN** GC 周期执行 `cleanupIdle`\n- **THEN** `store.DeleteSandboxBySessionID(ctx, \"sess-002\")` 被调用\n\n#### Scenario: 孤儿 CR 条目被清理\n\n- **GIVEN** Store 中存在 `sess-003`，但对应 AgentRuntime CR 已被删除\n- **WHEN** GC 周期执行 `cleanupOrphans`\n- **THEN** `store.DeleteSandboxBySessionID(ctx, \"sess-003\")` 被调用\n\n#### Scenario: 幽灵条目被补建\n\n- **GIVEN** AgentRuntime CR `default/my-runtime` 存在且携带 session-id，但 Store 中无对应条目\n- **WHEN** GC 周期执行 `cleanupGhosts`\n- **THEN** `store.StoreSandbox` 被调用补建会话条目\n\n#### Scenario: GC 协程优雅停止\n\n- **GIVEN** GC 协程正在运行\n- **WHEN** `Stop()` 被调用\n- **THEN** GC 协程在 10 秒内退出\n\n#### Scenario: Store 不可用时 GC 不 panic\n\n- **GIVEN** Redis/Valkey 连接断开\n- **WHEN** GC 周期执行\n- **THEN** 记录错误日志，不 panic，下个周期重试\n\n---\n\n### Requirement: 代理流程会话感知增强\n\nThe system SHALL 在 `pkg/router/proxy.go` 中增强代理逻辑：\n\n**成功路径（两次 LastActivityAt 更新）：**\n1. 解析 session ID 后调用 `UpdateLastActivity(ctx, sessionID)`（第一次）\n2. 执行 `forwardToSandbox` 反向代理\n3. 代理成功后再次调用 `UpdateLastActivity(ctx, sessionID)`（第二次）\n\n**错误处理：**\n- `UpdateLastActivity` 失败 SHALL 仅记录 warning 日志，不阻断代理流程\n- 会话状态为 `terminated` 时，代理请求 SHALL 返回 410 Gone `{\"error\":\"session has been terminated\"}`\n\n**JWT 注入增强：**\n- 对于 Sandbox/SandboxClaim kind 的入口点，在代理前生成 JWT 并注入 `Authorization: Bearer <token>`\n- JWT 签名失败 SHALL 返回 500 `{\"code\":\"JWT_SIGNING_FAILED\",\"error\":\"failed to sign request\"}`\n\n**响应头注入：**\n- 所有代理响应 SHALL 携带 `x-agentcube-session-id` header，值为解析后的 session ID\n\n#### Scenario: 成功路径调用两次 UpdateLastActivity\n\n- **GIVEN** session ID 为 `sess-001`，sandbox 解析成功且代理转发成功\n- **WHEN** invoke handler 完成\n- **THEN** `UpdateLastActivity` 被调用两次（解析后和转发后）\n\n#### Scenario: LastActivity 更新失败不阻断代理\n\n- **GIVEN** `UpdateLastActivity` 返回错误（Store 不可用）\n- **WHEN** sandbox 解析成功\n- **THEN** 代理仍然执行，错误仅被记录为 warning\n\n#### Scenario: 已终止会话返回 410\n\n- **GIVEN** 会话 `sess-001` 的 Status 为 `terminated`\n- **WHEN** 代理请求到达\n- **THEN** 响应 410，body 为 JSON `{\"error\":\"session has been terminated\"}`\n\n#### Scenario: 代理响应携带 session ID header\n\n- **GIVEN** session ID 为 `sess-001`\n- **WHEN** 代理响应返回\n- **THEN** 响应 header 包含 `x-agentcube-session-id: sess-001`\n\n---\n\n### Requirement: SessionManager 与 Store 集成\n\nThe system SHALL 在 `NewSessionManager` 中注入 Store 实例：\n\n```go\nfunc NewSessionManager(storeClient store.Store) (SessionManager, error)\n```\n\n`GetSandboxBySession` 的会话解析流程 SHALL：\n1. 若 `sessionID` 非空：调用 `storeClient.GetSandbox(ctx, sessionID)` 获取 `SandboxInfo`\n2. 若 Store 返回 `ErrNotFound`：返回 `NewSessionNotFoundError(sessionID)`\n3. 若 `sessionID` 为空：POST 到 WorkloadManager 创建 sandbox（AR-009 已有逻辑）\n4. 创建成功后调用 `CreateSession(ctx, newInfo)` 写入 Store\n\n#### Scenario: 创建沙箱后写入 Store\n\n- **GIVEN** 空 sessionID，WorkloadManager 创建成功返回 `CreateSandboxResponse{SessionID: \"sess-new\", ...}`\n- **WHEN** `GetSandboxBySession(ctx, \"\", \"default\", \"my-runtime\", \"AgentRuntime\")` 被调用\n- **THEN** 构建 `SandboxInfo`\n- **AND** `CreateSession(ctx, newInfo)` 被调用写入 Store\n\n#### Scenario: 已知 sessionID 从 Store 获取\n\n- **GIVEN** Store 中存在 `sess-001` 条目\n- **WHEN** `GetSandboxBySession(ctx, \"sess-001\", \"default\", \"my-runtime\", \"AgentRuntime\")` 被调用\n- **THEN** 返回对应的 `*types.SandboxInfo`\n\n---\n\n### Requirement: Server 集成会话管理组件\n\nThe system SHALL 在 `pkg/router/server.go` 中扩展 `Server` 结构体，新增以下字段：\n\n```go\ntype Server struct {\n    // 现有字段（AR-009）\n    config         *Config\n    engine         *gin.Engine\n    httpServer     *http.Server\n    sessionManager SessionManager\n    storeClient    store.Store\n    httpTransport  *http.Transport\n    jwtManager     *JWTManager\n\n    // 新增字段（AR-010）\n    informerManager *InformerManager\n    lifecycleManager *LifecycleManager\n}\n```\n\n`NewServer` SHALL 在构造函数中：\n1. 初始化 `store.Store` 实例（通过 `store.Storage()`）\n2. 构造 `InformerManager` 并传入 `router` 引用\n3. 构造 `LifecycleManager` 并传入 `store` 和 `clientset`\n4. 注册路由（含 informer 和 lifecycle 组件）\n\n`Start()` SHALL 在 HTTP 服务器启动前：\n1. 启动 `InformerManager`（`im.Start(stopCh)`）\n2. 启动 `LifecycleManager`（`lm.Start(ctx)`）\n\n`Shutdown(ctx)` SHALL 按以下顺序执行：\n1. 停止 `LifecycleManager`\n2. 停止 `InformerManager`\n3. 优雅关闭 HTTP 服务器\n\n#### Scenario: Server 启动时 Informer 和 GC 同时运行\n\n- **GIVEN** `NewServer` 构造完成\n- **WHEN** `Start()` 被调用\n- **THEN** `InformerManager.Start` 和 `LifecycleManager.Start` 在 HTTP 服务器监听前被调用\n\n#### Scenario: Server 关闭时按序停止组件\n\n- **GIVEN** Server 正在运行\n- **WHEN** `Shutdown(ctx)` 被调用\n- **THEN** `LifecycleManager.Stop` 先执行，然后 `InformerManager` 停止，最后 HTTP 服务器关闭\n\n---\n\n### Requirement: Config 扩展会话相关配置\n\nThe system SHALL 在 `pkg/router/config.go` 中扩展 `Config` 结构体，新增以下字段：\n\n| 字段 | 类型 | 默认值 | 说明 |\n|------|------|--------|------|\n| `SessionCheckInterval time.Duration` | `time.Duration` | `5 * time.Minute` | GC 检查间隔 |\n| `SessionIdleTimeout time.Duration` | `time.Duration` | `30 * time.Minute` | 空闲超时 |\n| `SessionMaxDuration time.Duration` | `time.Duration` | `24 * time.Hour` | 最大会话时长 |\n| `StoreType string` | `string` | `\"\"`（使用环境变量） | 存储类型（redis/valkey） |\n\nCLI 标志 SHALL 支持：\n\n| Flag | 类型 | 默认值 |\n|------|------|--------|\n| `-session-check-interval` | duration | `5m` |\n| `-session-idle-timeout` | duration | `30m` |\n| `-session-max-duration` | duration | `24h` |\n| `-store-type` | string | `\"\"` |\n\n#### Scenario: 默认会话配置\n\n- **GIVEN** 未传入会话相关 CLI 标志\n- **WHEN** `NewDefaultConfig()` 被调用\n- **THEN** `SessionCheckInterval = 5m`，`SessionIdleTimeout = 30m`，`SessionMaxDuration = 24h`\n\n#### Scenario: 自定义会话超时\n\n- **GIVEN** CLI 标志 `-session-idle-timeout=1h -session-max-duration=48h`\n- **WHEN** `main()` 解析标志\n- **THEN** `Config.SessionIdleTimeout = 1h`，`Config.SessionMaxDuration = 48h`\n\n---\n\n### Requirement: 编译与测试门禁\n\nThe system SHALL 满足以下门禁：\n1. `go build ./pkg/router/...` 编译通过\n2. `go build ./pkg/store/...` 编译通过\n3. `go test ./pkg/router/... -v` 全部通过\n4. `go test ./pkg/store/... -v` 全部通过\n5. `go test -race ./pkg/router/...` 无 data race 告警\n6. `go test -race ./pkg/store/...` 无 data race 告警\n7. 无 `log.Printf` 残留（使用 `slog` 或 `klog`）\n\n#### Scenario: pkg/router 编译通过\n\n- **GIVEN** 所有 router 代码已编写完成\n- **WHEN** `go build ./pkg/router/...` 执行\n- **THEN** 无编译错误\n\n#### Scenario: pkg/store 编译通过\n\n- **GIVEN** 所有 store 代码已编写完成\n- **WHEN** `go build ./pkg/store/...` 执行\n- **THEN** 无编译错误\n\n#### Scenario: 所有单元测试通过\n\n- **GIVEN** 测试用例已编写（含 SessionManager、Store、Informer、LifecycleManager）\n- **WHEN** `go test ./pkg/router/... ./pkg/store/... -v` 执行\n- **THEN** 所有测试通过\n\n#### Scenario: Race detector 无告警\n\n- **GIVEN** 并发场景测试已覆盖（Store 原子操作、Informer 回调、GC 协程）\n- **WHEN** `go test -race ./pkg/router/... ./pkg/store/...` 执行\n- **THEN** 无 data race 告警\n\n#### Scenario: 无 log.Printf 残留\n\n- **GIVEN** 所有日志已使用 `slog` 或 `klog`\n- **WHEN** `grep -rn 'log\\.Printf' pkg/router/ pkg/store/` 执行\n- **THEN** 无匹配结果\n","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/changes/AR-010/delta-spec.md"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/agentruntime.go\">\nERROR [51:25] undefined: LabelSessionID\nERROR [77:29] undefined: LabelSandboxName\nERROR [78:29] undefined: LabelWorkloadName\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workl