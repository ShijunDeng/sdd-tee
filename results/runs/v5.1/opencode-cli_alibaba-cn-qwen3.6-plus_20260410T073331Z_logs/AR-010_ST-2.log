{"type":"tool_use","timestamp":1775828521059,"sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","part":{"id":"prt_d77a0cc1e0015nOOOXrXafCMuK","messageID":"msg_d77a0c013001ayfaEnX27879p2","sessionID":"ses_28861d206ffeUXLqwqLBe1XLeC","type":"tool","tool":"read","callID":"call_28eaac2a27c84a6386a5d9af","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/session_manager.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/session_manager.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"encoding/json\"\n7: \t\"fmt\"\n8: \t\"io\"\n9: \t\"net/http\"\n10: \t\"os\"\n11: \t\"time\"\n12: \n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n15: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n16: \t\"golang.org/x/net/http2\"\n17: )\n18: \n19: type SessionManager interface {\n20: \tGetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)\n21: }\n22: \n23: type manager struct {\n24: \tstoreClient     store.Store\n25: \tworkloadMgrAddr string\n26: \thttpClient      *http.Client\n27: }\n28: \n29: func NewSessionManager(storeClient store.Store) (SessionManager, error) {\n30: \taddr := os.Getenv(\"WORKLOAD_MANAGER_URL\")\n31: \tif addr == \"\" {\n32: \t\treturn nil, fmt.Errorf(\"WORKLOAD_MANAGER_URL environment variable is not set\")\n33: \t}\n34: \n35: \ttransport := &http.Transport{\n36: \t\tMaxIdleConnsPerHost: 100,\n37: \t\tDisableCompression:  false,\n38: \t}\n39: \tif err := http2.ConfigureTransport(transport); err == nil {\n40: \t\ttransport2 := transport.TLSClientConfig\n41: \t\t_ = transport2\n42: \t}\n43: \n44: \thttpClient := &http.Client{\n45: \t\tTimeout:   2 * time.Minute,\n46: \t\tTransport: transport,\n47: \t}\n48: \n49: \treturn &manager{\n50: \t\tstoreClient:     storeClient,\n51: \t\tworkloadMgrAddr: addr,\n52: \t\thttpClient:      httpClient,\n53: \t}, nil\n54: }\n55: \n56: func (m *manager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n57: \tif sessionID != \"\" {\n58: \t\tinfo, err := m.storeClient.GetSandbox(ctx, sessionID)\n59: \t\tif err != nil {\n60: \t\t\tif err == store.ErrNotFound {\n61: \t\t\t\treturn nil, NewSessionNotFoundError(sessionID)\n62: \t\t\t}\n63: \t\t\treturn nil, err\n64: \t\t}\n65: \t\treturn info, nil\n66: \t}\n67: \n68: \treturn m.createSandbox(ctx, namespace, name, kind)\n69: }\n70: \n71: func (m *manager) createSandbox(ctx context.Context, namespace, name, kind string) (*types.SandboxInfo, error) {\n72: \tvar endpoint string\n73: \tswitch kind {\n74: \tcase types.AgentRuntimeKind:\n75: \t\tendpoint = fmt.Sprintf(\"%s/v1/agent-runtime\", m.workloadMgrAddr)\n76: \tcase types.CodeInterpreterKind:\n77: \t\tendpoint = fmt.Sprintf(\"%s/v1/code-interpreter\", m.workloadMgrAddr)\n78: \tdefault:\n79: \t\tendpoint = fmt.Sprintf(\"%s/v1/agent-runtime\", m.workloadMgrAddr)\n80: \t}\n81: \n82: \treqBody := handler.CreateSandboxRequest{\n83: \t\tKind:      kind,\n84: \t\tName:      name,\n85: \t\tNamespace: namespace,\n86: \t}\n87: \tbodyBytes, err := json.Marshal(reqBody)\n88: \tif err != nil {\n89: \t\treturn nil, err\n90: \t}\n91: \n92: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(bodyBytes))\n93: \tif err != nil {\n94: \t\treturn nil, err\n95: \t}\n96: \treq.Header.Set(\"Content-Type\", \"application/json\")\n97: \n98: \ttokenPath := \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n99: \tif tokenData, err := os.ReadFile(tokenPath); err == nil {\n100: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+string(tokenData))\n101: \t}\n102: \n103: \tresp, err := m.httpClient.Do(req)\n104: \tif err != nil {\n105: \t\treturn nil, err\n106: \t}\n107: \tdefer resp.Body.Close()\n108: \n109: \tif resp.StatusCode != http.StatusOK {\n110: \t\treturn nil, NewSandboxTemplateNotFoundError(namespace, name, kind)\n111: \t}\n112: \n113: \tvar createResp handler.CreateSandboxResponse\n114: \tif err := json.NewDecoder(resp.Body).Decode(&createResp); err != nil {\n115: \t\treturn nil, fmt.Errorf(\"failed to decode response: %w\", err)\n116: \t}\n117: \n118: \tif createResp.SessionID == \"\" {\n119: \t\treturn nil, fmt.Errorf(\"empty session ID in response\")\n120: \t}\n121: \n122: \tinfo := &types.SandboxInfo{\n123: \t\tSessionID:   createResp.SessionID,\n124: \t\tSandboxID:   createResp.SandboxID,\n125: \t\tSandboxName: createResp.SandboxName,\n126: \t\tEntryPoints: make([]types.EntryPoint, len(createResp.EntryPoints)),\n127: \t\tKind:        kind,\n128: \t\tNamespace:   namespace,\n129: \t}\n130: \tfor i, ep := range createResp.EntryPoints {\n131: \t\tinfo.EntryPoints[i] = types.EntryPoint{\n132: \t\t\tPath:     ep.Path,\n133: \t\t\tProtocol: ep.Protocol,\n134: \t\t\tEndpoint: ep.Endpoint,\n135: \t\t}\n136: \t}\n137: \n138: \treturn info, nil\n139: }\n140: \n141: var _ io.Reader = (*bytes.Reader)(nil)\n\n(End of file - total 141 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\t\"golang.org/x/net/http2\"\n)\n\ntype SessionManager interface {\n\tGetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/session_manager.go","time":{"start":1775828521044,"end":1775828521057}}}}
