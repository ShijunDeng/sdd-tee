n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestNewFileManager_Defaults(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tfm, err := NewFileManager(tmpDir, FileConfig{})\n\trequire.NoError(t, err)\n\trequire.NotNil(t, fm)\n\n\tfmImpl := fm.(*fileManager)\n\tassert.Equal(t, DefaultMaxChunkSize, fmImpl.maxChunkSize)\n\tassert.Equal(t, DefaultMaxBatchSize, fmImpl.maxBatchSize)\n\tassert.Equal(t, DefaultMaxSearchResults, fmImpl.maxSearchResults)\n\tassert.Equal(t, DefaultMaxSearchDepth, fmImpl.maxSearchDepth)\n}\n\nfunc TestNewFileManager_CustomConfig(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tcfg := FileConfig{\n\t\tMaxChunkSize:     16 << 20,\n\t\tMaxBatchSize:     50,\n\t\tMaxSearchResults: 200,\n\t\tMaxSearchDepth:   20,\n\t}\n\tfm, err := NewFileManager(tmpDir, cfg)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, fm)\n\n\tfmImpl := fm.(*fileManager)\n\tassert.Equal(t, int64(16<<20), fmImpl.maxChunkSize)\n\tassert.Equal(t, 50, fmImpl.maxBatchSize)\n\tassert.Equal(t, 200, fmImpl.maxSearchResults)\n\tassert.Equal(t, 20, fmImpl.maxSearchDepth)\n}\n\nfunc TestNewFileManager_InvalidWorkspace(t *testing.T) {\n\t_, err := NewFileManager(\"\", FileConfig{})\n\trequire.Error(t, err)\n}\n\nfunc TestNewFileManager_ResolvesWorkspace(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tfm, err := NewFileManager(tmpDir, FileConfig{})\n\trequire.NoError(t, err)\n\n\tfmImpl := fm.(*fileManager)\n\tabsPath, _ := filepath.Abs(tmpDir)\n\tassert.Equal(t, absPath, fmImpl.resolvedWorkspace)\n}\n\nfunc TestNewFileManager_CreatesTempDir(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tfm, err := NewFileManager(tmpDir, FileConfig{})\n\trequire.NoError(t, err)\n\n\tfmImpl := fm.(*fileManager)\n\tinfo, err := os.Stat(fmImpl.tempDir)\n\trequire.NoError(t, err)\n\tassert.True(t, info.IsDir())\n}\n","after":"package files\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestNewFileManager_Defaults(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tfm, err := NewFileManager(tmpDir, FileConfig{})\n\trequire.NoError(t, err)\n\trequire.NotNil(t, fm)\n\n\tfmImpl := fm.(*fileManager)\n\tassert.Equal(t, int64(DefaultMaxChunkSize), fmImpl.maxChunkSize)\n\tassert.Equal(t, DefaultMaxBatchSize, fmImpl.maxBatchSize)\n\tassert.Equal(t, DefaultMaxSearchResults, fmImpl.maxSearchResults)\n\tassert.Equal(t, DefaultMaxSearchDepth, fmImpl.maxSearchDepth)\n}\n\nfunc TestNewFileManager_CustomConfig(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tcfg := FileConfig{\n\t\tMaxChunkSize:     16 << 20,\n\t\tMaxBatchSize:     50,\n\t\tMaxSearchResults: 200,\n\t\tMaxSearchDepth:   20,\n\t}\n\tfm, err := NewFileManager(tmpDir, cfg)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, fm)\n\n\tfmImpl := fm.(*fileManager)\n\tassert.Equal(t, int64(16<<20), fmImpl.maxChunkSize)\n\tassert.Equal(t, 50, fmImpl.maxBatchSize)\n\tassert.Equal(t, 200, fmImpl.maxSearchResults)\n\tassert.Equal(t, 20, fmImpl.maxSearchDepth)\n}\n\nfunc TestNewFileManager_InvalidWorkspace(t *testing.T) {\n\t_, err := NewFileManager(\"\", FileConfig{})\n\trequire.Error(t, err)\n}\n\nfunc TestNewFileManager_ResolvesWorkspace(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tfm, err := NewFileManager(tmpDir, FileConfig{})\n\trequire.NoError(t, err)\n\n\tfmImpl := fm.(*fileManager)\n\tabsPath, _ := filepath.Abs(tmpDir)\n\tassert.Equal(t, absPath, fmImpl.resolvedWorkspace)\n}\n\nfunc TestNewFileManager_CreatesTempDir(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tfm, err := NewFileManager(tmpDir, FileConfig{})\n\trequire.NoError(t, err)\n\n\tfmImpl := fm.(*fileManager)\n\tinfo, err := os.Stat(fmImpl.tempDir)\n\trequire.NoError(t, err)\n\tassert.True(t, info.IsDir())\n}\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/picod/files/manager_test.go","time":{"start":1775844940531,"end":1775844940717}}}}
