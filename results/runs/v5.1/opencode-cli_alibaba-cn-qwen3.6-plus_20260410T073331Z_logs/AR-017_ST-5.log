blicKeyEnvVar, generateTestPublicKey(t))\n46: \tdefer os.Unsetenv(PublicKeyEnvVar)\n47: \n48: \tconfig := Config{Port: 0, Workspace: t.TempDir()}\n49: \tserver := NewServer(config)\n50: \n51: \treq := httptest.NewRequest(http.MethodGet, \"/health\", nil)\n52: \tw := httptest.NewRecorder()\n53: \tserver.engine.ServeHTTP(w, req)\n54: \n55: \tassert.Equal(t, http.StatusOK, w.Code)\n56: }\n57: \n58: func TestServer_Routes_APIRequiresAuth(t *testing.T) {\n59: \tgin.SetMode(gin.TestMode)\n60: \n61: \tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n62: \tdefer os.Unsetenv(PublicKeyEnvVar)\n63: \n64: \tconfig := Config{Port: 0, Workspace: t.TempDir()}\n65: \tserver := NewServer(config)\n66: \n67: \treq := httptest.NewRequest(http.MethodPost, \"/api/execute\", nil)\n68: \tw := httptest.NewRecorder()\n69: \tserver.engine.ServeHTTP(w, req)\n70: \n71: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n72: }\n73: \n74: func TestServer_Routes_AllRegistered(t *testing.T) {\n75: \tgin.SetMode(gin.TestMode)\n76: \n77: \tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n78: \tdefer os.Unsetenv(PublicKeyEnvVar)\n79: \n80: \tconfig := Config{Port: 0, Workspace: t.TempDir()}\n81: \tserver := NewServer(config)\n82: \n83: \troutes := server.engine.Routes()\n84: \texpectedRoutes := map[string]bool{\n85: \t\t\"GET    /health\":          false,\n86: \t\t\"POST   /api/execute\":     false,\n87: \t\t\"POST   /api/files\":       false,\n88: \t\t\"GET    /api/files\":       false,\n89: \t\t\"GET    /api/files/*path\": false,\n90: \t}\n91: \n92: \tfor _, route := range routes {\n93: \t\tkey := route.Method + \"   \" + route.Path\n94: \t\tif _, ok := expectedRoutes[key]; ok {\n95: \t\t\texpectedRoutes[key] = true\n96: \t\t}\n97: \t}\n98: \n99: \tfor route, found := range expectedRoutes {\n100: \t\tassert.True(t, found, \"Expected route not found: %s\", route)\n101: \t}\n102: }\n\n(End of file - total 102 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"net/http\