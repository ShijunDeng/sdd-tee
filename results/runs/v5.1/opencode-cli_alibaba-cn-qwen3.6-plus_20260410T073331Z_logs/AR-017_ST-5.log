 \n45: \ttmpDir := t.TempDir()\n46: \trelPath := filepath.Base(tmpDir)\n47: \n48: \tconfig := Config{Port: 0, Workspace: relPath}\n49: \tserver := NewServer(config)\n50: \trequire.NotNil(t, server)\n51: \n52: \tabsPath, _ := filepath.Abs(relPath)\n53: \tassert.Equal(t, absPath, server.workspaceDir)\n54: }\n\n(End of file - total 54 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestParseFlags_Defaults(t *testing.T) {\n\tos.Args = []string{\"test\"}\n\tconfig := ParseFlags()\n\tassert.Equal(t, 8080, config.Port)\n\tassert.Equal(t, \"\", config.Workspace)\n}\n\nfunc TestParseFlags_CustomValues(t *testing.T) {\n\tos.Args = []string{\"test\", \"-port\", \"9090\", \"-workspace\", \"/tmp/picod-workspace\"}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/picod/config_test.go","time":{"start":1775844891530,"end":1775844891540}}}}
