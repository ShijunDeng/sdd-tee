egisterRoutes()\n56: \n57: \treturn s\n58: }\n59: \n60: func (s *Server) registerRoutes() {\n61: \tapi := s.engine.Group(\"/api\")\n62: \tapi.Use(s.authManager.AuthMiddleware())\n63: \t{\n64: \t\tapi.POST(\"/execute\", s.ExecuteHandler)\n65: \t\tapi.POST(\"/files\", s.UploadFileHandler)\n66: \t\tapi.GET(\"/files\", s.ListFilesHandler)\n67: \t\tapi.GET(\"/files/*path\", s.DownloadFileHandler)\n68: \t}\n69: \ts.engine.GET(\"/health\", s.HealthCheckHandler)\n70: }\n71: \n72: func (s *Server) Run() error {\n73: \tserver := &http.Server{\n74: \t\tAddr:              fmt.Sprintf(\":%d\", s.config.Port),\n75: \t\tHandler:           s.engine,\n76: \t\tReadHeaderTimeout: 10 * time.Second,\n77: \t}\n78: \treturn server.ListenAndServe()\n79: }\n80: \n81: func (s *Server) HealthCheckHandler(c *gin.Context) {\n82: \tc.JSON(http.StatusOK, gin.H{\n83: \t\t\"status\":  \"ok\",\n84: \t\t\"service\": \"PicoD\",\n85: \t\t\"version\": \"0.0.1\",\n86: \t\t\"uptime\":  time.Since(s.startTime).String(),\n87: \t})\n88: }\n\n(End of file - total 88 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tengine       *gin.Engine\n\tconfig       Config\n\tauthManager  *AuthManager\n\tstartTime    time.Time\n\tworkspaceDir string\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/picod/server.go","time":{"start":1775844954232,"end":1775844954240}}}}
