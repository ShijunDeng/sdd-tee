setenv(PublicKeyEnvVar)\n\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\n\trequire.NotNil(t, server)\n\tassert.NotNil(t, server.engine)\n\tassert.Equal(t, config, server.config)\n\tassert.NotNil(t, server.authManager)\n\tassert.False(t, server.startTime.IsZero())\n\tassert.NotEmpty(t, server.workspaceDir)\n}\n\nfunc TestNewServer_StartTimeSetAtConstruction(t *testing.T) {\n\tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tbefore := time.Now()\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\tafter := time.Now()\n\n\tassert.True(t, !server.startTime.Before(before) && !server.startTime.After(after))\n}\n\nfunc TestServer_Routes_HealthEndpointPublic(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\n\treq := httptest.NewRequest(http.MethodGet, \"/health\", nil)\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n}\n\nfunc TestServer_Routes_APIRequiresAuth(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\n\treq := httptest.NewRequest(http.MethodPost, \"/api/execute\", nil)\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusUnauthorized, w.Code)\n}\n\nfunc TestServer_Routes_AllRegistered(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\n\troutes := server.engine.Routes()\n\texpectedRoutes := map[string]bool{\n\t\t\"GET    /health\":          false,\n\t\t\"POST   /api/execute\":     false,\n\t\t\"POST   /api/files\":       false,\n\t\t\"GET    /api/files\":       false,\n\t\t\"GET    /api/files/*path\": false,\n\t}\n\n\tfor _, route := range routes {\n\t\tkey := route.Method + \"   \" + route.Path\n\t\tif _, ok := expectedRoutes[key]; ok {\n\t\t\texpectedRoutes[key] = true\n\t\t}\n\t}\n\n\tfor route, found := range expectedRoutes {\n\t\tassert.True(t, found, \"Expected route not found: %s\", route)\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestNewServer_InitializesAllFields(t *testing.T) {\n\tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\n\trequire.NotNil(t, server)\n\tassert.NotNil(t, server.engine)\n\tassert.Equal(t, config, server.config)\n\tassert.NotNil(t, server.authManager)\n\tassert.False(t, server.startTime.IsZero())\n\tassert.NotEmpty(t, server.workspaceDir)\n}\n\nfunc TestNewServer_StartTimeSetAtConstruction(t *testing.T) {\n\tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tbefore := time.Now()\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\tafter := time.Now()\n\n\tassert.True(t, !server.startTime.Before(before) && !server.startTime.After(after))\n}\n\nfunc TestServer_Routes_HealthEndpointPublic(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\n\treq := httptest.NewRequest(http.MethodGet, \"/health\", nil)\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n}\n\nfunc TestServer_Routes_APIRequiresAuth(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\n\treq := httptest.NewRequest(http.MethodPost, \"/api/execute\", nil)\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusUnauthorized, w.Code)\n}\n\nfunc TestServer_Routes_AllRegistered(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tos.Setenv(PublicKeyEnvVar, generateTestPublicKey(t))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tconfig := Config{Port: 0, Workspace: t.TempDir()}\n\tserver := NewServer(config)\n\n\troutes := server.engine.Routes()\n\tfoundRoutes := make(map[string]bool)\n\tfor _, route := range routes {\n\t\tkey := route.Method + \" \" + route.Path\n\t\tfoundRoutes[key] = true\n\t}\n\n\texpectedRoutes := []string{\n\t\t\"GET /health\",\n\t\t\"POST /api/execute\",\n\t\t\"POST /api/files\",\n\t\t\"GET /api/files\",\n\t\t\"GET /api/files/*path\",\n\t}\n\n\tfor _, expected := range expectedRoutes {\n\t\tassert.True(t, foundRoutes[expected], \"Expected route not found: %s\", expected)\n\t}\n\n\tfor route, found := range expectedRoutes {\n\t\tassert.True(t, found, \"Expected route not found: %s\", route)\n\t}\n}\n","additions":14,"deletions":11},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/picod/server_test.go","time":{"start":1775844977921,"end":1775844978110}}}}
