r_types_test.go # CodeInterpreter type tests\n        └── zz_generated.deepcopy.go     # Auto-generated DeepCopy methods\n```\n\nThere is only one API group (`runtime`) under `pkg/apis/`.\n\n---\n\n## 2. Go Module Path\n\n```\ngithub.com/volcano-sh/agentcube\n```\n\nGo version: `1.24.4`\n\n---\n\n## 3. Key Type Definition Files\n\n### `doc.go`\n```go\n// +k8s:deepcopy-gen=package\n// +groupName=runtime.agentcube.volcano.sh\npackage v1alpha1\n```\n\n### `groupversion_info.go`\n```go\npackage v1alpha1\n\nimport (\n    \"k8s.io/apimachinery/pkg/runtime/schema\"\n    \"sigs.k8s.io/controller-runtime/pkg/scheme\"\n)\n\nvar (\n    GroupVersion = schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"}\n    SchemeBuilder = &scheme.Builder{GroupVersion: GroupVersion}\n    AddToScheme = SchemeBuilder.AddToScheme\n)\n```\n\n### `register.go`\n```go\npackage v1alpha1\n\nimport \"k8s.io/apimachinery/pkg/runtime/schema\"\n\nvar (\n    CodeInterpreterKind             = \"CodeInterpreter\"\n    CodeInterpreterGroupKind        = GroupVersion.WithKind(\"CodeInterpreter\")\n    CodeInterpreterListKind         = \"CodeInterpreterList\"\n    CodeInterpreterGroupVersionKind = GroupVersion.WithKind(\"CodeInterpreter\")\n)\n\nvar (\n    AgentRuntimeKind             = \"AgentRuntime\"\n    AgentRuntimeListKind         = \"AgentRuntimeList\"\n    AgentRuntimeGroupVersionKind = GroupVersion.WithKind(\"AgentRuntime\")\n)\n\nvar SchemeGroupVersion = GroupVersion\n\nfunc Resource(resource string) schema.GroupVersionResource {\n    return GroupVersion.WithResource(resource)\n}\n```\n\n### `agent_type.go` (AgentRuntime CRD)\n```go\npackage v1alpha1\n\nimport (\n    corev1 \"k8s.io/api/core/v1\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\n// +genclient\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\n// +kubebuilder:subresource:status\n// +kubebuilder:resource:scope=Namespaced,plural=agentruntimes\n// +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n\ntype AgentRuntime struct {\n    metav1.TypeMeta   `json:\",inline\"`\n    metav1.ObjectMeta `json:\"metadata,omitempty\"`\n    Spec   AgentRuntimeSpec   `json:\"spec\"`\n    Status AgentRuntimeStatus `json:\"status,omitempty\"`\n}\n\ntype AgentRuntimeSpec struct {\n    Ports              []TargetPort     `json:\"targetPort,omitempty\"`\n    Template           *SandboxTemplate `json:\"podTemplate\"`\n    SessionTimeout     *metav1.Duration `json:\"sessionTimeout,omitempty\"`\n    MaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\"`\n}\n\ntype SandboxTemplate struct {\n    Labels      map[string]string `json:\"labels,omitempty\"`\n    Annotations map[string]string `json:\"annotations,omitempty\"`\n    Spec        corev1.PodSpec    `json:\"spec\"`\n}\n\ntype AgentRuntimeStatus struct {\n    Conditions []metav1.Condition `json:\"conditions,omitempty\"`\n}\n\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\ntype AgentRuntimeList struct {\n    metav1.TypeMeta `json:\",inline\"`\n    metav1.ListMeta `json:\"metadata,omitempty\"`\n    Items           []AgentRuntime `json:\"items\"`\n}\n\nfunc init() {\n    SchemeBuilder.Register(&AgentRuntime{}, &AgentRuntimeList{})\n}\n```\n\n### `codeinterpreter_types.go` (CodeInterpreter CRD + Shared Types)\n```go\npackage v1alpha1\n\nimport (\n    corev1 \"k8s.io/api/core/v1\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\ntype ProtocolType string\n\nconst (\n    ProtocolTypeHTTP  ProtocolType = \"HTTP\"\n    ProtocolTypeHTTPS ProtocolType = \"HTTPS\"\n)\n\ntype AuthModeType string\n\nconst (\n    AuthModePicoD AuthModeType = \"picod\"\n    AuthModeNone  AuthModeType = \"none\"\n)\n\ntype TargetPort struct {\n    PathPrefix string       `json:\"pathPrefix,omitempty\"`\n    Name       string       `json:\"name,omitempty\"`\n    Port       uint32       `json:\"port\"`\n    Protocol   ProtocolType `json:\"protocol\"`\n}\n\n// +genclient\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\n// +kubebuilder:subresource:status\n// +kubebuilder:resource:scope=Namespaced\n// +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\ntype CodeInterpreter struct {\n    metav1.TypeMeta   `json:\",inline\"`\n    metav1.ObjectMeta `json:\"metadata,omitempty\"`\n    Spec   CodeInterpreterSpec   `json:\"spec\"`\n    Status CodeInterpreterStatus `json:\"status,omitempty\"`\n}\n\ntype CodeInterpreterSpec struct {\n    Ports              []TargetPort                    `json:\"ports,omitempty\"`\n    Template           *CodeInterpreterSandboxTemplate `json:\"template\"`\n    SessionTimeout     *metav1.Duration                `json:\"sessionTimeout,omitempty\"`\n    MaxSessionDuration *metav1.Duration                `json:\"maxSessionDuration,omitempty\"`\n    WarmPoolSize       *int32                          `json:\"warmPoolSize,omitempty\"`\n    AuthMode           AuthModeType                    `json:\"authMode,omitempty\"`\n}\n\ntype CodeInterpreterStatus struct {\n    Conditions []metav1.Condition `json:\"conditions,omitempty\"`\n    Ready      bool               `json:\"ready,omitempty\"`\n}\n\ntype CodeInterpreterSandboxTemplate struct {\n    Labels           map[string]string             `json:\"labels,omitempty\"`\n    Annotations      map[string]string             `json:\"annotations,omitempty\"`\n    RuntimeClassName *string                       `json:\"runtimeClassName,omitempty\"`\n    Image            string                        `json:\"image,omitempty\"`\n    ImagePullPolicy  corev1.PullPolicy             `json:\"imagePullPolicy,omitempty\"`\n    ImagePullSecrets []corev1.LocalObjectReference `json:\"imagePullSecrets,omitempty\"`\n    Environment      []corev1.EnvVar               `json:\"environment,omitempty\"`\n    Command          []string                      `json:\"command,omitempty\"`\n    Args             []string                      `json:\"args,omitempty\"`\n    Resources        corev1.ResourceRequirements   `json:\"resources,omitempty\"`\n}\n\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\ntype CodeInterpreterList struct {\n    metav1.TypeMeta `json:\",inline\"`\n    metav1.ListMeta `json:\"metadata,omitempty\"`\n    Items           []CodeInterpreter `json:\"items\"`\n}\n\nfunc init() {\n    SchemeBuilder.Register(&CodeInterpreter{}, &CodeInterpreterList{})\n}\n```\n\n---\n\n## 4. Existing design.md Files\n\nFound **12 design.md files** across the project:\n\n| Path | Topic |\n|------|-------|\n| `changes/AR-001/design.md` | CRD AgentRuntime type definition (comprehensive, 636 lines) |\n| `changes/AR-002/design.md` | CRD CodeInterpreter type definition (skeleton, 57 lines) |\n| `ci-cd/design.md` | CI/CD design |\n| `cli-toolkit/design.md` | CLI toolkit design |\n| `code-execution/design.md` | Code execution design |\n| `deployment/design.md` | Deployment design |\n| `idle-cleanup/design.md` | Idle cleanup design |\n| `integrations/design.md` | Integrations design |\n| `python-sdk/design.md` | Python SDK design |\n| `sandbox-orchestration/design.md` | Sandbox orchestration design (475 lines, very detailed) |\n| `session-routing/design.md` | Session routing design |\n| `session-store/design.md` | Session store design |\n\nThere is **no top-level `docs/` directory**. Design docs live alongside feature directories or in `changes/` subdirectories.\n\nThe most comprehensive design doc is `changes/AR-001/design.md`, which follows this structure:\n1. Architecture (positioning, package structure, dependencies, codegen toolchain)\n2. Data structures (with code snippets, field tables, relationship diagrams)\n3. API contract (GVK, GVR, REST endpoints, example YAML, scheme registration)\n4. Error handling (validation errors, app-level errors, defaults, concurrency)\n5. Test strategy (unit tests, file layout, test commands, TDD mapping)\n6. Implementation steps (file creation order, verification checklist)\n7. Follow-up changes (dependency table for downstream work)\n\n---\n\n## 5. Conventions Summary\n\nFrom examining the existing code, here are the established conventions:\n\n- **API Group**: `runtime.agentcube.volcano.sh`\n- **Version**: `v1alpha1`\n- **File naming**: `<kind>_types.go` or `<kind>_type.go` for type definitions, `<file>_test.go` for tests\n- **Kubebuilder markers**: `+genclient`, `+k8s:deepcopy-gen:interfaces=...`, `+kubebuilder:object:root=true`, `+kubebuilder:subresource:status`, `+kubebuilder:resource:scope=Namespaced`, `+kubebuilder:printcolumn`\n- **CRD root struct**: Embeds `metav1.TypeMeta` and `metav1.ObjectMeta`, has `Spec` and `Status` fields\n- **List struct**: Embeds `metav1.TypeMeta` and `metav1.ListMeta`, has `Items []<Kind>` field\n- **Registration**: `SchemeBuilder.Register(&Kind{}, &KindList{})` in `init()`\n- **Shared types**: `TargetPort`, `ProtocolType`, `AuthModeType` defined in `codeinterpreter_types.go` and reused by `AgentRuntime`\n- **Testing**: Uses `github.com/stretchr/testify/assert`, tests cover defaults, DeepCopy isolation, scheme registration, and GVK/GVR constants\n</task_result>","metadata":{"sessionId":"ses_28981711effekmYEbOG4xOwDpq","model":{"modelID":"qwen3.6-plus","providerID":"alibaba-cn"},"truncated":false},"title":"Explore agentcube pkg/apis","time":{"start":1775809498846,"end":1775809603691}}}}
{"type":"step_finish","timestamp":1775809603738,"sessionID":"ses_289819b18ffeZtw3FTFq54Ocwf","part":{"id":"prt_d7680286d001r425aLfLPtnNwB","reason":"tool-calls","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","messageID":"msg_d767e7105001YG4liuQ4eTbxGq","sessionID":"ses_289819b18ffeZtw3FTFq54Ocwf","type":"step-finish","tokens":{"total":19585,"input":19254,"output":208,"reasoning":123,"cache":{"write":0,"read":0}},"cost":0.005860585}}
