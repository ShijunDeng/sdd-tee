{"type":"tool_use","timestamp":1775857793887,"sessionID":"ses_286a11efcffeHfT23emAoG4Wgn","part":{"id":"prt_d795f76d5001vVhbPkVjEYSBz2","messageID":"msg_d795f6f0a001qkFC3GF3U69Mxd","sessionID":"ses_286a11efcffeHfT23emAoG4Wgn","type":"tool","tool":"read","callID":"call_846cd5435ded4e1caaf27ccf","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/build_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/build_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"BuildRuntime - orchestrates the container image build lifecycle.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import re\n6: import time\n7: from pathlib import Path\n8: from typing import Any, Dict\n9: \n10: import semver\n11: \n12: from agentcube.services.docker_service import DockerService\n13: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n14: \n15: \n16: class BuildRuntime:\n17:     \"\"\"Orchestrates version increment, prerequisite validation, building, and metadata update.\"\"\"\n18: \n19:     def __init__(self, verbose: bool = False) -> None:\n20:         self.verbose = verbose\n21:         self.metadata_service = MetadataService(verbose=verbose)\n22: \n23:     def build(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n24:         \"\"\"Main entry point: load metadata, increment version, validate, build, and update.\"\"\"\n25:         metadata = self.metadata_service.load_metadata(workspace_path)\n26:         if metadata is None:\n27:             raise ValueError(\"Workspace has not been packaged. Run 'pack' first.\")\n28: \n29:         original_version = metadata.version\n30:         self._increment_version(workspace_path, metadata)\n31: \n32:         try:\n33:             self._validate_build_prerequisites(workspace_path, metadata)\n34: \n35:             if options.get(\"cloud_provider\"):\n36:                 build_result = self._build_cloud(workspace_path, metadata, options)\n37:             elif metadata.build_mode == \"cloud\":\n38:                 build_result = self._build_cloud(workspace_path, metadata, options)\n39:             else:\n40:                 build_result = self._build_local(workspace_path, metadata, options)\n41: \n42:             tag = metadata.version or \"latest\"\n43:             self._update_build_metadata(workspace_path, metadata, build_result, tag)\n44: \n45:             return build_result\n46: \n47:         except Exception:\n48:             metadata.version = original_version\n49:             self.metadata_service.save_metadata(workspace_path, metadata)\n50:             raise\n51: \n52:     def _increment_version(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n53:         \"\"\"Increment the semantic version in metadata.\"\"\"\n54:         current = metadata.version\n55:         if not current:\n56:             metadata.version = \"0.0.1\"\n57:         elif re.match(r\"^\\d+\\.\\d+\\.\\d+$\", current):\n58:             parts = current.split(\".\")\n59:             parts[2] = str(int(parts[2]) + 1)\n60:             metadata.version = \".\".join(parts)\n61:         else:\n62:             try:\n63:                 v = semver.Version.parse(current)\n64:                 metadata.version = str(v.bump_patch())\n65:             except ValueError:\n66:                 metadata.version = f\"{current}-1\"\n67: \n68:     def _validate_build_prerequisites(\n69:         self, workspace_path: Path, metadata: AgentMetadata\n70:     ) -> None:\n71:         \"\"\"Validate that all prerequisites for building are met.\"\"\"\n72:         metadata_path = workspace_path / \"agent_metadata.yaml\"\n73:         if not metadata_path.exists():\n74:             raise ValueError(f\"Metadata file not found: {metadata_path}\")\n75: \n76:         dockerfile_path = workspace_path / \"Dockerfile\"\n77:         if not dockerfile_path.exists():\n78:             raise ValueError(\"Dockerfile not found. Run 'pack' first.\")\n79: \n80:         if metadata.build_mode == \"local\":\n81:             docker_service = DockerService(verbose=self.verbose)\n82:             if not docker_service.check_docker_available():\n83:                 raise RuntimeError(\"Docker is not available or not running\")\n84: \n85:     def _build_local(\n86:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n87:     ) -> Dict[str, Any]:\n88:         \"\"\"Execute a local Docker build.\"\"\"\n89:         docker_service = DockerService(verbose=self.verbose)\n90: \n91:         if metadata.image and metadata.image.get(\"name\"):\n92:             image_name = metadata.image[\"name\"]\n93:         else:\n94:             image_name = metadata.agent_name\n95: \n96:         tag = metadata.version or \"latest\"\n97: \n98:         build_args = None\n99:         proxy = options.get(\"proxy\")\n100:         if proxy:\n101:             build_args = {\"HTTP_PROXY\": proxy, \"HTTPS_PROXY\": proxy}\n102: \n103:         dockerfile_path = workspace_path / \"Dockerfile\"\n104:         result = docker_service.build_image(\n105:             dockerfile_path=dockerfile_path,\n106:             context_path=workspace_path,\n107:             image_name=image_name,\n108:             tag=tag,\n109:             build_args=build_args,\n110:         )\n111:         return result\n112: \n113:     def _build_cloud(\n114:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n115:     ) -> Dict[str, Any]:\n116:         \"\"\"Execute a cloud build via the specified provider.\"\"\"\n117:         cloud_provider = options.get(\"cloud_provider\")\n118: \n119:         if not cloud_provider:\n120:             raise ValueError(\"Cloud provider must be specified. Use --cloud-provider option.\")\n121: \n122:         if self.verbose:\n123:             print(f\"Starting cloud build with provider: {cloud_provider}\")\n124: \n125:         return {\n126:             \"image_name\": metadata.agent_name,\n127:             \"image_id\": \"pending\",\n128:             \"image_size\": \"N/A\",\n129:             \"build_time\": \"N/A\",\n130:             \"cloud_provider\": cloud_provider,\n131:             \"job_id\": f\"build-{metadata.agent_name}-{int(time.time())}\",\n132:         }\n133: \n134:     def _update_build_metadata(\n135:         self,\n136:         workspace_path: Path,\n137:         metadata: AgentMetadata,\n138:         build_result: Dict[str, Any],\n139:         tag: str,\n140:     ) -> None:\n141:         \"\"\"Update metadata with build results and persist.\"\"\"\n142:         image_info: Dict[str, Any] = {\n143:             \"name\": build_result.get(\"image_name\", metadata.agent_name),\n144:             \"id\": build_result.get(\"image_id\"),\n145:             \"tag\": tag,\n146:         }\n147: \n148:         if \"build_time\" in build_result:\n149:             image_info[\"build_time\"] = build_result[\"build_time\"]\n150: \n151:         metadata = metadata.model_copy(update={\"image\": image_info})\n152:         self.metadata_service.save_metadata(workspace_path, metadata)\n\n(End of file - total 152 lines)\n</content>","metadata":{"preview":"\"\"\"BuildRuntime - orchestrates the container image build lifecycle.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict\n\nimport semver\n\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass BuildRuntime:\n    \"\"\"Orchestrates version increment, prerequisite validation, building, and metadata update.\"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/build_runtime.py","time":{"start":1775857793876,"end":1775857793885}}}}
{"type":"tool_use","timestamp":1775857800661,"sessionID":"ses_286a11efcffeHfT23emAoG4Wgn","part":{"id":"prt_d795f7d79001FH3ibDGs8SHDgX","messageID":"msg_d795f6f0a001qkFC3GF3U69Mxd","sessionID":"ses_286a11efcffeHfT23emAoG4Wgn","type":"tool","tool":"read","callID":"call_9433fadca8da4abea2a9fe4a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Publish runtime for deploying agents to Kubernetes.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from pathlib import Path\n6: from typing import Any, Dict\n7: \n8: from agentcube.services.agentcube_provider import AgentCubeProvider\n9: from agentcube.services.docker_service import DockerService\n10: from agentcube.services.k8s_provider import KubernetesProvider\n11: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n12: \n13: \n14: class PublishRuntime:\n15:     \"\"\"Runtime for publishing agents to Kubernetes clusters.\"\"\"\n16: \n17:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n18:         self.verbose = verbose\n19:         self.provider = provider\n20: \n21:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n22:         \"\"\"Publish an agent to a Kubernetes cluster.\n23: \n24:         Args:\n25:             workspace_path: Path to the packaged agent workspace.\n26:             **options: CLI options (version, image_url, provider, etc.).\n27: \n28:         Returns:\n29:             Dict with deployment information.\n30: \n31:         Raises:\n32:             ValueError: If workspace is invalid or required options are missing.\n33:             RuntimeError: If Docker is unavailable or deployment times out.\n34:         \"\"\"\n35:         if not workspace_path.exists():\n36:             raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n37:         if not workspace_path.is_dir():\n38:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n39: \n40:         service = MetadataService(verbose=self.verbose)\n41:         metadata = service.load_metadata(workspace_path)\n42:         if metadata is None:\n43:             raise ValueError(\"Workspace has not been packaged. Run 'pack' first.\")\n44: \n45:         for key in [\"version\", \"description\", \"region\"]:\n46:             value = options.get(key)\n47:             if value is not None:\n48:                 setattr(metadata, key, value)\n49: \n50:         node_port = options.get(\"node_port\")\n51:         if node_port is not None and not (30000 <= node_port <= 32767):\n52:             raise ValueError(\"NodePort must be between 30000 and 32767\")\n53: \n54:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n55:         options[\"image_url\"] = image_url\n56: \n57:         if self.provider == \"agentcube\":\n58:             result = self._publish_cr_to_k8s(workspace_path, metadata, **options)\n59:         elif self.provider == \"k8s\":\n60:             result = self._publish_k8s(workspace_path, metadata, **options)\n61:         else:\n62:             raise ValueError(f\"Unsupported provider: {self.provider}\")\n63: \n64:         self._update_publish_metadata(workspace_path, result)\n65: \n66:         return result\n67: \n68:     def _prepare_image_for_publishing(\n69:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n70:     ) -> str:\n71:         \"\"\"Prepare the container image for publishing based on build mode.\"\"\"\n72:         if metadata.build_mode == \"local\":\n73:             return self._prepare_local_image(workspace_path, metadata, options)\n74:         elif metadata.build_mode == \"cloud\":\n75:             return self._prepare_cloud_image(workspace_path, metadata, options)\n76:         else:\n77:             raise ValueError(f\"Unsupported build mode: {metadata.build_mode}\")\n78: \n79:     def _prepare_local_image(\n80:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n81:     ) -> str:\n82:         \"\"\"Prepare a local Docker image for publishing by pushing to a registry.\"\"\"\n83:         docker_service = DockerService(verbose=self.verbose)\n84: \n85:         if not docker_service.check_docker_available():\n86:             raise RuntimeError(\"Docker is not available or not running\")\n87: \n88:         image_url = options.get(\"image_url\")\n89:         if not image_url:\n90:             if metadata.image and metadata.image.get(\"url\"):\n91:                 image_url = metadata.image[\"url\"]\n92:             else:\n93:                 raise ValueError(\"Image URL is required for local build mode\")\n94: \n95:         version = metadata.version or \"latest\"\n96:         image_tag = f\"{image_url}:{version}\"\n97: \n98:         username = options.get(\"image_username\") or metadata.registry_username\n99:         password = options.get(\"image_password\") or metadata.registry_password\n100:         registry_url = options.get(\"registry_url\") or metadata.registry_url\n101: \n102:         if username and password:\n103:             docker_service._docker_login_sdk(registry_url or \"\", username, password)\n104: \n105:         result = docker_service.push_image(image_tag, registry_url or \"\", username, password)\n106:         return result.get(\"pushed_image\", image_tag)\n107: \n108:     def _prepare_cloud_image(\n109:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n110:     ) -> str:\n111:         \"\"\"Resolve the image URL for cloud build mode.\"\"\"\n112:         image_url = options.get(\"image_url\")\n113:         if image_url:\n114:             return image_url\n115: \n116:         if metadata.image and metadata.image.get(\"url\"):\n117:             return metadata.image[\"url\"]\n118: \n119:         raise ValueError(\"Image URL is required for cloud build mode\")\n120: \n121:     def _publish_cr_to_k8s(\n122:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n123:     ) -> Dict[str, Any]:\n124:         \"\"\"Publish an agent as an AgentRuntime Custom Resource.\"\"\"\n125:         if not metadata.router_url:\n126:             raise ValueError(\n127:                 \"router_url and workload_manager_url are required in agent_metadata.yaml for AgentCube provider\"\n128:             )\n129:         if not metadata.workload_manager_url:\n130:             raise ValueError(\n131:                 \"router_url and workload_manager_url are required in agent_metadata.yaml for AgentCube provider\"\n132:             )\n133:         if not metadata.readiness_probe_path:\n134:             raise ValueError(\"readiness_probe_path is required in agent_metadata.yaml for AgentCube provider\")\n135:         if not metadata.readiness_probe_port:\n136:             raise ValueError(\"readiness_probe_port is required in agent_metadata.yaml for AgentCube provider\")\n137: \n138:         namespace = options.get(\"namespace\") or \"default\"\n139:         provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n140: \n141:         result = provider.deploy_agent_runtime(\n142:             agent_name=metadata.agent_name,\n143:             image_url=options.get(\"image_url\", \"\"),\n144:             port=metadata.port,\n145:             entrypoint=metadata.entrypoint,\n146:             env_vars={},\n147:             workload_manager_url=metadata.workload_manager_url,\n148:             router_url=metadata.router_url,\n149:             readiness_probe_path=metadata.readiness_probe_path,\n150:             readiness_probe_port=metadata.readiness_probe_port,\n151:         )\n152: \n153:         return {\n154:             \"agent_id\": result.get(\"name\"),\n155:             \"agent_endpoint\": result.get(\"endpoint\"),\n156:             \"namespace\": namespace,\n157:             \"k8s_deployment\": {\n158:                 \"type\": \"AgentRuntime\",\n159:                 \"namespace\": namespace,\n160:                 \"cr_name\": result.get(\"name\"),\n161:             },\n162:         }\n163: \n164:     def _publish_k8s(\n165:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n166:     ) -> Dict[str, Any]:\n167:         \"\"\"Publish an agent as a standard Kubernetes Deployment + Service.\"\"\"\n168:         namespace = options.get(\"namespace\") or \"default\"\n169:         replicas = options.get(\"replicas\") or 1\n170:         node_port = options.get(\"node_port\")\n171: \n172:         provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n173: \n174:         result = provider.deploy_agent(\n175:             agent_name=metadata.agent_name,\n176:             image_url=options.get(\"image_url\", \"\"),\n177:             port=metadata.port,\n178:             entrypoint=metadata.entrypoint,\n179:             replicas=replicas,\n180:             node_port=node_port,\n181:             env_vars={},\n182:         )\n183: \n184:         try:\n185:             provider.wait_for_deployment_ready(result[\"deployment_name\"], timeout=120)\n186:         except TimeoutError:\n187:             raise RuntimeError(\n188:                 f\"Deployment {result['deployment_name']} did not become ready within 120s\"\n189:             )\n190: \n191:         return {\n192:             \"deployment_name\": result[\"deployment_name\"],\n193:             \"service_name\": result[\"service_name\"],\n194:             \"service_url\": result[\"service_url\"],\n195:             \"namespace\": namespace,\n196:             \"replicas\": replicas,\n197:             \"node_port\": result.get(\"node_port\"),\n198:             \"k8s_deployment\": {\n199:                 \"type\": \"Deployment\",\n200:                 \"namespace\": namespace,\n201:                 \"deployment_name\": result[\"deployment_name\"],\n202:                 \"service_url\": result[\"service_url\"],\n203:             },\n204:         }\n205: \n206:     def _update_publish_metadata(\n207:         self, workspace_path: Path, agent_info: Dict[str, Any]\n208:     ) -> None:\n209:         \"\"\"Update workspace metadata with publish results.\"\"\"\n210:         service = MetadataService(verbose=self.verbose)\n211:         updates: Dict[str, Any] = {\n212:             \"agent_id\": agent_info.get(\"agent_id\"),\n213:             \"agent_endpoint\": agent_info.get(\"agent_endpoint\") or agent_info.get(\"service_url\"),\n214:             \"k8s_deployment\": agent_info.get(\"k8s_deployment\"),\n215:         }\n216:         service.update_metadata(workspace_path, updates)\n\n(End of file - total 216 lines)\n</content>","metadata":{"preview":"\"\"\"Publish runtime for deploying agents to Kubernetes.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass PublishRuntime:\n    \"\"\"Runtime for publishing agents to Kubernetes clusters.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/publish_runtime.py","time":{"start":1775857800650,"end":1775857800659}}}}
{"type":"tool_use","timestamp":1775857802996,"sessionID":"ses_286a11efcffeHfT23emAoG4Wgn","part":{"id":"prt_d795f9884001sduhfNDrF97A7j","messageID":"msg_d795f6f0a001qkFC3GF3U69Mxd","sessionID":"ses_286a11efcffeHfT23emAoG4Wgn","type":"tool","tool":"read","callID":"call_a4cfeaa0ecef45f6834ca8d1","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/services/test_docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/services/test_docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for DockerService.\"\"\"\n2: \n3: from pathlib import Path\n4: from unittest.mock import MagicMock, patch\n5: \n6: import pytest\n7: \n8: from agentcube.services.docker_service import DockerService\n9: \n10: \n11: class TestDockerServiceCheckDockerAvailableRunning:\n12:     def test_docker_running_returns_true(self) -> None:\n13:         mock_client = MagicMock()\n14:         mock_client.ping.return_value = True\n15:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n16:             service = DockerService()\n17:             assert service.check_docker_available() is True\n18: \n19: \n20: class TestDockerServiceCheckDockerAvailableNotRunning:\n21:     def test_docker_not_running_returns_false(self) -> None:\n22:         with patch(\"agentcube.services.docker_service.docker.from_env\", side_effect=Exception(\"Cannot connect\")):\n23:             service = DockerService()\n24:             assert service.check_docker_available() is False\n25: \n26:     def test_docker_ping_raises_returns_false(self) -> None:\n27:         mock_client = MagicMock()\n28:         mock_client.ping.side_effect = Exception(\"Daemon not running\")\n29:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n30:             service = DockerService()\n31:             assert service.check_docker_available() is False\n32: \n33: \n34: class TestDockerServiceBuildImageSuccess:\n35:     def test_build_image_returns_correct_dict(self) -> None:\n36:         mock_image = MagicMock()\n37:         mock_image.id = \"sha256:abc123def456\"\n38:         mock_image.short_id = \"sha256:abc123\"\n39: \n40:         mock_image_info = MagicMock()\n41:         mock_image_info.attrs = {\"Size\": 52428800}\n42: \n43:         mock_client = MagicMock()\n44:         mock_client.images.build.return_value = (mock_image, [])\n45:         mock_client.images.get.return_value = mock_image_info\n46: \n47:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n48:             service = DockerService()\n49:             result = service.build_image(\n50:                 dockerfile_path=Path(\"/tmp/Dockerfile\"),\n51:                 context_path=Path(\"/tmp\"),\n52:                 image_name=\"test-agent\",\n53:                 tag=\"1.0.0\",\n54:             )\n55: \n56:         assert result[\"image_name\"] == \"test-agent\"\n57:         assert result[\"image_id\"] == \"sha256:abc123\"\n58:         assert result[\"image_size\"] == \"50.0 MB\"\n59:         assert result[\"build_time\"].endswith(\"s\")\n60: \n61: \n62: class TestDockerServiceBuildImageWithProxy:\n63:     def test_build_image_passes_proxy_buildargs(self) -> None:\n64:         mock_image = MagicMock()\n65:         mock_image.id = \"sha256:abc123\"\n66:         mock_image.short_id = \"sha256:abc\"\n67: \n68:         mock_image_info = MagicMock()\n69:         mock_image_info.attrs = {\"Size\": 0}\n70: \n71:         mock_client = MagicMock()\n72:         mock_client.images.build.return_value = (mock_image, [])\n73:         mock_client.images.get.return_value = mock_image_info\n74: \n75:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n76:             service = DockerService()\n77:             build_args = {\"HTTP_PROXY\": \"http://proxy:8080\", \"HTTPS_PROXY\": \"http://proxy:8080\"}\n78:             service.build_image(\n79:                 dockerfile_path=Path(\"/tmp/Dockerfile\"),\n80:                 context_path=Path(\"/tmp\"),\n81:                 image_name=\"test-agent\",\n82:                 tag=\"1.0.0\",\n83:                 build_args=build_args,\n84:             )\n85: \n86:         mock_client.images.build.assert_called_once()\n87:         call_kwargs = mock_client.images.build.call_args[1]\n88:         assert call_kwargs[\"buildargs\"] == build_args\n89: \n90: \n91: class TestDockerServiceBuildImageFailure:\n92:     def test_build_error_propagates(self) -> None:\n93:         import docker.errors\n94: \n95:         with patch(\"agentcube.services.docker_service.docker.from_env\") as mock_from_env:\n96:             mock_from_env.side_effect = docker.errors.BuildError(\"Build failed\", [])\n97:             service = DockerService()\n98:             with pytest.raises(docker.errors.BuildError):\n99:                 service.build_image(\n100:                     dockerfile_path=Path(\"/tmp/Dockerfile\"),\n101:                     context_path=Path(\"/tmp\"),\n102:                     image_name=\"test-agent\",\n103:                     tag=\"1.0.0\",\n104:                 )\n105: \n106: \n107: class TestDockerServiceFormatSizeBytes:\n108:     def test_zero_bytes(self) -> None:\n109:         service = DockerService()\n110:         assert service._format_size(0) == \"0 B\"\n111: \n112:     def test_bytes_under_1kb(self) -> None:\n113:         service = DockerService()\n114:         assert service._format_size(512) == \"512 B\"\n115: \n116: \n117: class TestDockerServiceFormatSizeKB:\n118:     def test_one_kb(self) -> None:\n119:         service = DockerService()\n120:         assert service._format_size(1024) == \"1.0 KB\"\n121: \n122:     def test_half_kb(self) -> None:\n123:         service = DockerService()\n124:         assert service._format_size(1536) == \"1.5 KB\"\n125: \n126: \n127: class TestDockerServiceFormatSizeMB:\n128:     def test_one_mb(self) -> None:\n129:         service = DockerService()\n130:         assert service._format_size(1048576) == \"1.0 MB\"\n131: \n132: \n133: class TestDockerServiceFormatSizeGB:\n134:     def test_one_gb(self) -> None:\n135:         service = DockerService()\n136:         assert service._format_size(1073741824) == \"1.0 GB\"\n137: \n138: \n139: class TestDockerService_PushImage_Success:\n140:     def test_push_image_returns_correct_result(self) -> None:\n141:         mock_client = MagicMock()\n142:         mock_client.images.push.return_value = None\n143:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n144:             service = DockerService()\n145:             result = service.push_image(\n146:                 image_tag=\"registry.example.com/my-agent:v1.0.0\",\n147:                 registry_url=\"registry.example.com\",\n148:             )\n149:         assert result[\"pushed_image\"] == \"registry.example.com/my-agent:v1.0.0\"\n150:         assert result[\"status\"] == \"success\"\n151:         mock_client.images.push.assert_called_once_with(\n152:             \"registry.example.com/my-agent\", tag=\"v1.0.0\", auth_config=None\n153:         )\n154: \n155: \n156: class TestDockerService_PushImage_WithCredentials:\n157:     def test_push_image_passes_auth_config(self) -> None:\n158:         mock_client = MagicMock()\n159:         mock_client.images.push.return_value = None\n160:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n161:             service = DockerService()\n162:             service.push_image(\n163:                 image_tag=\"registry.example.com/my-agent:v1.0.0\",\n164:                 registry_url=\"registry.example.com\",\n165:                 username=\"user\",\n166:                 password=\"pass\",\n167:             )\n168:         mock_client.images.push.assert_called_once_with(\n169:             \"registry.example.com/my-agent\",\n170:             tag=\"v1.0.0\",\n171:             auth_config={\"username\": \"user\", \"password\": \"pass\"},\n172:         )\n173: \n174: \n175: class TestDockerService_PushImage_Failure:\n176:     def test_push_image_raises_api_error(self) -> None:\n177:         import docker.errors\n178: \n179:         mock_client = MagicMock()\n180:         mock_client.images.push.side_effect = docker.errors.APIError(\"push failed\")\n181:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n182:             service = DockerService()\n183:             with pytest.raises(docker.errors.APIError):\n184:                 service.push_image(\n185:                     image_tag=\"registry.example.com/my-agent:v1.0.0\",\n186:                     registry_url=\"registry.example.com\",\n187:                 )\n188: \n189: \n190: class TestDockerService_DockerLoginSdk_Success:\n191:     def test_login_returns_true(self) -> None:\n192:         mock_client = MagicMock()\n193:         mock_client.login.return_value = {\"Status\": \"Login Succeeded\"}\n194:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n195:             service = DockerService()\n196:             result = service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n197:         assert result is True\n198:         mock_client.login.assert_called_once_with(\n199:             username=\"user\", password=\"pass\", registry=\"registry.example.com\"\n200:         )\n201: \n202: \n203: class TestDockerService_DockerLoginSdk_Failure:\n204:     def test_login_raises_on_failure(self) -> None:\n205:         import docker.errors\n206: \n207:         mock_client = MagicMock()\n208:         mock_client.login.side_effect = docker.errors.APIError(\"login failed\")\n209:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n210:             service = DockerService()\n211:             with pytest.raises(docker.errors.APIError):\n212:                 service._docker_login_sdk(\"registry.example.com\", \"user\", \"wrong-pass\")\n213: \n214: \n215: class TestDockerService_TagImageSdk_Success:\n216:     def test_tag_image_returns_true(self) -> None:\n217:         mock_image = MagicMock()\n218:         mock_image.tag.return_value = True\n219:         mock_client = MagicMock()\n220:         mock_client.images.get.return_value = mock_image\n221:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n222:             service = DockerService()\n223:             result = service._tag_image_sdk(\"my-agent:latest\", \"registry.example.com/my-agent:v1.0.0\")\n224:         assert result is True\n225:         mock_client.images.get.assert_called_once_with(\"my-agent:latest\")\n226:         mock_image.tag.assert_called_once_with(\"registry.example.com/my-agent\", tag=\"v1.0.0\")\n\n(End of file - total 226 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for DockerService.\"\"\"\n\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.services.docker_service import DockerService\n\n\nclass TestDockerServiceCheckDockerAvailableRunning:\n    def test_docker_running_returns_true(self) -> None:\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n            service = DockerService()\n            assert service.check_docker_available() is True\n\n\nclass TestDockerServiceCheckDockerAvailableNotRunning:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/services/test_docker_service.py","time":{"start":1775857802986,"end":1775