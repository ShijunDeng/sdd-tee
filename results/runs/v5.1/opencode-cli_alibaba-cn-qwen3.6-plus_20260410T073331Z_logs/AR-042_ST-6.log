-primary-darker: #277148;\n  --ifm-color-primary-darkest: #205d3b;\n  --ifm-color-primary-light: #33925d;\n  --ifm-color-primary-lighter: #359962;\n  --ifm-color-primary-lightest: #3cad6e;\n  --ifm-code-font-size: 95%;\n  --docusaurus-highlighted-code-line-bg: rgba(0, 0, 0, 0.1);\n  --ifm-navbar-background-color: #ffffff;\n  --ifm-footer-background-color: #1b1b1d;\n  --ifm-footer-color: #ffffff;\n  --ifm-footer-link-color: #ffffff;","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/docs/src/css/custom.css","time":{"start":1775899023998,"end":1775899024006}}}}
{"type":"tool_use","timestamp":1775899025322,"sessionID":"ses_2842d085bffed8MeVZzVoGA6fX","part":{"id":"prt_d7bd49b1b001zxJWg5juX8l1P2","messageID":"msg_d7bd48927001SNVLT36D6No7vc","sessionID":"ses_2842d085bffed8MeVZzVoGA6fX","type":"tool","tool":"read","callID":"call_748a1c33ecc940f180f3bb26","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/docs/docs/getting-started/installation.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/docs/docs/getting-started/installation.md</path>\n<type>file</type>\n<content>\n1: ---\n2: sidebar_position: 1\n3: title: Installation\n4: description: Install AgentCube on your Kubernetes cluster using Helm\n5: keywords: [installation, helm, kubernetes, setup]\n6: ---\n7: \n8: # Installation\n9: \n10: This guide walks you through installing AgentCube on your Kubernetes cluster using Helm.\n11: \n12: ## Prerequisites\n13: \n14: Before installing AgentCube, ensure you have:\n15: \n16: - A Kubernetes cluster (v1.24 or later)\n17: - `kubectl` configured to access your cluster\n18: - Helm 3.x installed\n19: - Redis or Valkey instance available (or use the bundled one)\n20: \n21: ## Install via Helm\n22: \n23: ### 1. Add the Helm Repository\n24: \n25: ```bash\n26: helm repo add agentcube https://volcano-sh.github.io/agentcube/charts\n27: helm repo update\n28: ```\n29: \n30: ### 2. Create a Namespace\n31: \n32: ```bash\n33: kubectl create namespace agentcube-system\n34: ```\n35: \n36: ### 3. Install the Chart\n37: \n38: ```bash\n39: helm install agentcube agentcube/agentcube \\\n40:   --namespace agentcube-system \\\n41:   --set redis.enabled=true\n42: ```\n43: \n44: ### 4. Verify Installation\n45: \n46: ```bash\n47: kubectl get pods -n agentcube-system\n48: ```\n49: \n50: You should see the following pods running:\n51: \n52: ```\n53: NAME                                READY   STATUS    RESTARTS   AGE\n54: agentcube-router-xxxxxxxxxx-xxxxx   1/1     Running   0          2m\n55: agentcube-workloadmanager-xxxx-xx   1/1     Running   0          2m\n56: agentcube-redis-xxxxxxxxxx-xxxxx    1/1     Running   0          2m\n57: ```\n58: \n59: ## Configuration Options\n60: \n61: ### Minimal Configuration\n62: \n63: ```yaml\n64: # values.yaml\n65: router:\n66:   replicas: 2\n67: \n68: workloadManager:\n69:   replicas: 1\n70: \n71: redis:\n72:   enabled: true\n73: ```\n74: \n75: ### Production Configuration\n76: \n77: ```yaml\n78: # values-prod.yaml\n79: router:\n80:   replicas: 3\n81:   resources:\n82:     requests:\n83:       cpu: 500m\n84:       memory: 512Mi\n85:     limits:\n86:       cpu: '1'\n87:       memory: 1Gi\n88: \n89: workloadManager:\n90:   replicas: 2\n91:   resources:\n92:     requests:\n93:       cpu: 500m\n94:       memory: 512Mi\n95:     limits:\n96:       cpu: '1'\n97:       memory: 1Gi\n98: \n99: redis:\n100:   enabled: false\n101:   externalUrl: 'redis://redis-master.redis.svc:6379'\n102: \n103: agentd:\n104:   enabled: true\n105:   idleTimeout: 30m\n106: ```\n107: \n108: ### Install with Custom Values\n109: \n110: ```bash\n111: helm install agentcube agentcube/agentcube \\\n112:   --namespace agentcube-system \\\n113:   -f values-prod.yaml\n114: ```\n115: \n116: ## External Redis/Valkey\n117: \n118: If you have an existing Redis or Valkey instance, configure AgentCube to use it:\n119: \n120: ```yaml\n121: redis:\n122:   enabled: false\n123:   externalUrl: 'redis://<host>:<port>'\n124:   externalPassword: '<password>'\n125: ```\n126: \n127: ## Uninstall\n128: \n129: ```bash\n130: helm uninstall agentcube --namespace agentcube-system\n131: kubectl delete namespace agentcube-system\n132: ```\n133: \n134: ## Next Steps\n135: \n136: - Follow the [Quick Start](./quick-start.md) guide to create your first sandbox\n137: - Review the [Configuration](./configuration.md) reference for all available options\n\n(End of file - total 137 lines)\n</content>","metadata":{"preview":"---\nsidebar_position: 1\ntitle: Installation\ndescription: Install AgentCube on your Kubernetes cluster using Helm\nkeywords: [installation, helm, kubernetes, setup]\n---\n\n# Installation\n\nThis guide walks you through installing AgentCube on your Kubernetes cluster using Helm.\n\n## Prerequisites\n\nBefore installing AgentCube, ensure you have:\n\n- A Kubernetes cluster (v1.24 or later)\n- `kubectl` configured to access your cluster\n- Helm 3.x installed\n- Redis or Valkey instance available (or use the bundled one)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/docs/docs/getting-started/installation.md","time":{"start":1775899025314,"end":1775899025321}}}}
