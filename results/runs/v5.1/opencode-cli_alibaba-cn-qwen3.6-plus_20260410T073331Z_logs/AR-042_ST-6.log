age=\"yaml\">{yamlExample}</CodeBlock>\n44:         </div>\n45:       )}\n46:       {!yamlExample && (\n47:         <div className=\"k8s-resource__yaml\">\n48:           <CodeBlock language=\"yaml\">{defaultYaml}</CodeBlock>\n49:         </div>\n50:       )}\n51:     </div>\n52:   );\n53: }\n\n(End of file - total 53 lines)\n</content>","metadata":{"preview":"import React from 'react';\nimport CodeBlock from '@theme/CodeBlock';\n\nexport interface K8sResourceProps {\n  group: string;\n  version: string;\n  kind: string;\n  scope: 'Namespaced' | 'Cluster';\n  yamlExample?: string;\n}\n\nexport default function K8sResource({\n  group,\n  version,\n  kind,\n  scope,\n  yamlExample,\n}: K8sResourceProps): JSX.Element {\n  const apiVersion = `${group}/${version}`;\n  const scopeClass =","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/docs/src/components/K8sResource/index.tsx","time":{"start":1775899004304,"end":1775899004310}}}}
