stPublicKey(t)\n49: \tos.Setenv(PublicKeyEnvVar, pubKey)\n50: \tdefer os.Unsetenv(PublicKeyEnvVar)\n51: \n52: \tam := newAuthManager()\n53: \terr := am.LoadPublicKeyFromEnv()\n54: \trequire.NoError(t, err)\n55: \tassert.NotNil(t, am.publicKey)\n56: }\n57: \n58: func TestAuthManager_LoadPublicKeyFromEnv_MissingEnv(t *testing.T) {\n59: \tos.Unsetenv(PublicKeyEnvVar)\n60: \tam := newAuthManager()\n61: \terr := am.LoadPublicKeyFromEnv()\n62: \trequire.Error(t, err)\n63: \tassert.Contains(t, err.Error(), \"not set\")\n64: }\n65: \n66: func TestAuthManager_LoadPublicKeyFromEnv_InvalidPEM(t *testing.T) {\n67: \tos.Setenv(PublicKeyEnvVar, \"not-a-pem-block\")\n68: \tdefer os.Unsetenv(PublicKeyEnvVar)\n69: \n70: \tam := newAuthManager()\n71: \terr := am.LoadPublicKeyFromEnv()\n72: \trequire.Error(t, err)\n73: \tassert.Contains(t, err.Error(), \"failed to decode PEM block\")\n74: }\n75: \n76: func TestAuthManager_LoadPublicKeyFromEnv_NonRSAKey(t *testing.T) {\n77: \tecKey, err := rsa.GenerateKey(rand.Reader, 2048)\n78: \trequire.NoError(t, err)\n79: \tpubBytes, err := x509.MarshalPKIXPublicKey(&ecKey.PublicKey)\n80: \trequire.NoError(t, err)\n81: \tpemBlock := &pem.Block{\n82: \t\tType:  \"PUBLIC KEY\",\n83: \t\tBytes: pubBytes,\n84: \t}\n85: \tpemStr := string(pem.EncodeToMemory(pemBlock))\n86: \n87: \tos.Setenv(PublicKeyEnvVar, pemStr)\n88: \tdefer os.Unsetenv(PublicKeyEnvVar)\n89: \n90: \tam := newAuthManager()\n91: \terr = am.LoadPublicKeyFromEnv()\n92: \trequire.NoError(t, err)\n93: \tassert.NotNil(t, am.publicKey)\n94: }\n95: \n96: func TestAuthMiddleware_MissingAuthHeader(t *testing.T) {\n97: \tgin.SetMode(gin.TestMode)\n98: \n99: \tam := newAuthManager()\n100: \tkey := generateTestPrivateKey(t)\n101: \tpubBytes, _ := x509.MarshalPKIXPublicKey(&key.PublicKey)\n102: \tam.publicKey = &key.PublicKey\n103: \t_ = pubBytes\n104: \n105: \tengine := gin.New()\n106: \tengine.GET(\"/test\", am.AuthMiddleware(), func(c *gin.Context) {\n107: \t\tc.JSON(200, gin.H{\"ok\": true})\n108: \t})\n109: \n110: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n111: \tw := httptest.NewRecorder()\n112: \tengine.ServeHTTP(w, req)\n113: \n114: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n115: }\n116: \n117: func TestAuthMiddleware_MalformedAuthHeader(t *testing.T) {\n118: \tgin.SetMode(gin.TestMode)\n119: \n120: \tam := newAuthManager()\n121: \tam.publicKey = &generateTestPrivateKey(t).PublicKey\n122: \n123: \tengine := gin.New()\n124: \tengine.GET(\"/test\", am.AuthMiddleware(), func(c *gin.Context) {\n125: \t\tc.JSON(200, gin.H{\"ok\": true})\n126: \t})\n127: \n128: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n129: \treq.Header.Set(\"Authorization\", \"InvalidFormat\")\n130: \tw := httptest.NewRecorder()\n131: \tengine.ServeHTTP(w, req)\n132: \n133: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n134: }\n135: \n136: func TestAuthMiddleware_ValidToken(t *testing.T) {\n137: \tgin.SetMode(gin.TestMode)\n138: \n139: \tkey := generateTestPrivateKey(t)\n140: \tam := newAuthManager()\n141: \tam.publicKey = &key.PublicKey\n142: \n143: \tnow := time.Now()\n144: \tclaims := jwt.MapClaims{\n145: \t\t\"exp\": jwt.NewNumericDate(now.Add(5 * time.Minute)),\n146: \t\t\"iat\": jwt.NewNumericDate(now),\n147: \t}\n148: \ttoken := signTestToken(t, key, claims)\n149: \n150: \tengine := gin.New()\n151: \tengine.GET(\"/test\", am.AuthMiddleware(), func(c *gin.Context) {\n152: \t\tc.JSON(200, gin.H{\"ok\": true})\n153: \t})\n154: \n155: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n156: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n157: \tw := httptest.NewRecorder()\n158: \tengine.ServeHTTP(w, req)\n159: \n160: \tassert.Equal(t, http.StatusOK, w.Code)\n161: }\n162: \n163: func TestAuthMiddleware_ExpiredToken(t *testing.T) {\n164: \tgin.SetMode(gin.TestMode)\n165: \n166: \tkey := generateTestPrivateKey(t)\n167: \tam := newAuthManager()\n168: \tam.publicKey = &key.PublicKey\n169: \n170: \tnow := time.Now()\n171: \tclaims := jwt.MapClaims{\n172: \t\t\"exp\": jwt.NewNumericDate(now.Add(-5 * time.Minute)),\n173: \t\t\"iat\": jwt.NewNumericDate(now.Add(-10 * time.Minute)),\n174: \t}\n175: \ttoken := signTestToken(t, key, claims)\n176: \n177: \tengine := gin.New()\n178: \tengine.GET(\"/test\", am.AuthMiddleware(), func(c *gin.Context) {\n179: \t\tc.JSON(200, gin.H{\"ok\": true})\n180: \t})\n181: \n182: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n183: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n184: \tw := httptest.NewRecorder()\n185: \tengine.ServeHTTP(w, req)\n186: \n187: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n188: }\n189: \n190: func TestAuthMiddleware_NonRSASigningMethod(t *testing.T) {\n191: \tgin.SetMode(gin.TestMode)\n192: \n193: \tkey := generateTestPrivateKey(t)\n194: \tam := newAuthManager()\n195: \tam.publicKey = &key.PublicKey\n196: \n197: \tnow := time.Now()\n198: \tclaims := jwt.MapClaims{\n199: \t\t\"exp\": jwt.NewNumericDate(now.Add(5 * time.Minute)),\n200: \t\t\"iat\": jwt.NewNumericDate(now),\n201: \t}\n202: \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n203: \ttokenString, err := token.SignedString([]byte(\"secret\"))\n204: \trequire.NoError(t, err)\n205: \n206: \tengine := gin.New()\n207: \tengine.GET(\"/test\", am.AuthMiddleware(), func(c *gin.Context) {\n208: \t\tc.JSON(200, gin.H{\"ok\": true})\n209: \t})\n210: \n211: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n212: \treq.Header.Set(\"Authorization\", \"Bearer \"+tokenString)\n213: \tw := httptest.NewRecorder()\n214: \tengine.ServeHTTP(w, req)\n215: \n216: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n217: }\n218: \n219: func TestAuthMiddleware_MaxBodySize(t *testing.T) {\n220: \tgin.SetMode(gin.TestMode)\n221: \n222: \tkey := generateTestPrivateKey(t)\n223: \tam := newAuthManager()\n224: \tam.publicKey = &key.PublicKey\n225: \n226: \tnow := time.Now()\n227: \tclaims := jwt.MapClaims{\n228: \t\t\"exp\": jwt.NewNumericDate(now.Add(5 * time.Minute)),\n229: \t\t\"iat\": jwt.NewNumericDate(now),\n230: \t}\n231: \ttoken := signTestToken(t, key, claims)\n232: \n233: \tbodyWrapped := false\n234: \tengine := gin.New()\n235: \tengine.POST(\"/test\", am.AuthMiddleware(), func(c *gin.Context) {\n236: \t\tbodyWrapped = c.Request.Body != nil\n237: \t\tc.JSON(200, gin.H{\"ok\": true})\n238: \t})\n239: \n240: \treq := httptest.NewRequest(http.MethodPost, \"/test\", nil)\n241: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n242: \tw := httptest.NewRecorder()\n243: \tengine.ServeHTTP(w, req)\n244: \n245: \tassert.True(t, bodyWrapped, \"Body should be wrapped after auth middleware\")\n246: \tassert.Equal(t, http.StatusOK, w.Code)\n247: }\n\n(End of file - total 247 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc generateTestPrivateKey(t *testing.T) *rsa.PrivateKey {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/picod/auth_test.go","time":{"start":1775843605006,"end":1775843605014}}}}
