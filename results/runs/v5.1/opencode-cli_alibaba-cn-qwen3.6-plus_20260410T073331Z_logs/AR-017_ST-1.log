time.Time `json:\"modified\"`\n45: \tMode     string    `json:\"mode\"`\n46: \tIsDir    bool      `json:\"is_dir\"`\n47: }\n48: \n49: type ListFilesResponse struct {\n50: \tFiles []FileEntry `json:\"files\"`\n51: }\n\n(End of file - total 51 lines)\n</content>","metadata":{"preview":"package picod\n\nimport \"time\"\n\nconst (\n\tTimeoutExitCode = 124\n\tMaxBodySize     = 32 << 20\n\tPublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"\n\tmaxFileMode     = 0777\n)\n\ntype ExecuteRequest struct {\n\tCommand    []string          `json:\"command\" binding:\"required\"`\n\tTimeout    string            `json:\"timeout\"`\n\tWorkingDir string            `json:\"working_dir\"`\n\tEnv        map[string]string `json:\"env\"`\n}\n\ntype ExecuteResponse struct {\n\tStdout    string    `json:\"stdout\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/picod/types.go","time":{"start":1775843606100,"end":1775843606107}}}}
{"type":"tool_use","timestamp":1775843607193,"sessionID":"ses_2877b9e1effesWMei9GCvRu7ve","part":{"id":"prt_d7886fed6001UiWnceILT4c1nm","messageID":"msg_d7886d352001IaLhVa64e2eEsU","sessionID":"ses_2877b9e1effesWMei9GCvRu7ve","type":"tool","tool":"read","callID":"call_3ad228575e4e4ae6bb48ca54","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/pem\"\n9: \t\"errors\"\n10: \t\"os\"\n11: \t\"time\"\n12: \n13: \t\"github.com/golang-jwt/jwt/v5\"\n14: \tcorev1 \"k8s.io/api/core/v1\"\n15: \tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n16: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n17: \t\"k8s.io/client-go/kubernetes\"\n18: \t\"k8s.io/client-go/rest\"\n19: \t\"k8s.io/klog/v2\"\n20: )\n21: \n22: const (\n23: \trsaKeySize         = 2048\n24: \tjwtExpiration      = 5 * time.Minute\n25: \tIdentitySecretName = \"picod-router-identity\"\n26: \tPrivateKeyDataKey  = \"private.pem\"\n27: \tPublicKeyDataKey   = \"public.pem\"\n28: )\n29: \n30: var IdentityNamespace = \"default\"\n31: \n32: func init() {\n33: \tif ns := os.Getenv(\"AGENTCUBE_NAMESPACE\"); ns != \"\" {\n34: \t\tIdentityNamespace = ns\n35: \t}\n36: }\n37: \n38: type JWTManager struct {\n39: \tprivateKey *rsa.PrivateKey\n40: \tpublicKey  *rsa.PublicKey\n41: \tclientset  kubernetes.Interface\n42: \tconfig     *JWTConfig\n43: }\n44: \n45: func NewJWTManager(config *JWTConfig) (*JWTManager, error) {\n46: \tprivateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n47: \tif err != nil {\n48: \t\treturn nil, err\n49: \t}\n50: \n51: \tif config == nil {\n52: \t\tconfig = &JWTConfig{\n53: \t\t\tExpiration: 5 * time.Minute,\n54: \t\t\tIssuer:     \"agentcube-router\",\n55: \t\t\tLeeway:     1 * time.Minute,\n56: \t\t}\n57: \t}\n58: \n59: \treturn &JWTManager{\n60: \t\tprivateKey: privateKey,\n61: \t\tpublicKey:  &privateKey.PublicKey,\n62: \t\tconfig:     config,\n63: \t}, nil\n64: }\n65: \n66: func (m *JWTManager) PublicKey() *rsa.PublicKey {\n67: \treturn m.publicKey\n68: }\n69: \n70: func (m *JWTManager) GenerateToken(claims map[string]interface{}) (string, error) {\n71: \tnow := time.Now()\n72: \ttokenClaims := jwt.MapClaims{\n73: \t\t\"exp\": now.Add(m.config.Expiration).Unix(),\n74: \t\t\"iat\": now.Unix(),\n75: \t\t\"iss\": m.config.Issuer,\n76: \t}\n77: \tfor k, v := range claims {\n78: \t\ttokenClaims[k] = v\n79: \t}\n80: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n81: \treturn token.SignedString(m.privateKey)\n82: }\n83: \n84: func (m *JWTManager) ParseAndValidateToken(tokenString string) (jwt.MapClaims, error) {\n85: \tif tokenString == \"\" {\n86: \t\treturn nil, errors.New(\"invalid token: empty string\")\n87: \t}\n88: \n89: \ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n90: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n91: \t\t\treturn nil, jwt.ErrTokenSignatureInvalid\n92: \t\t}\n93: \t\treturn m.publicKey, nil\n94: \t}, jwt.WithLeeway(m.config.Leeway))\n95: \n96: \tif err != nil {\n97: \t\tif errors.Is(err, jwt.ErrTokenExpired) {\n98: \t\t\treturn nil, errors.New(\"token is expired\")\n99: \t\t}\n100: \t\tif errors.Is(err, jwt.ErrTokenSignatureInvalid) {\n101: \t\t\treturn nil, errors.New(\"invalid signature\")\n102: \t\t}\n103: \t\tif errors.Is(err, jwt.ErrTokenMalformed) {\n104: \t\t\treturn nil, errors.New(\"invalid token\")\n105: \t\t}\n106: \t\treturn nil, err\n107: \t}\n108: \n109: \tif claims, ok := token.Claims.(jwt.MapClaims); ok && token.Valid {\n110: \t\tiss, err := claims.GetIssuer()\n111: \t\tif err != nil || iss != m.config.Issuer {\n112: \t\t\treturn nil, errors.New(\"invalid issuer\")\n113: \t\t}\n114: \t\treturn claims, nil\n115: \t}\n116: \n117: \treturn nil, errors.New(\"invalid token\")\n118: }\n119: \n120: func (m *JWTManager) TryStoreOrLoadJWTKeySecret(ctx context.Context) error {\n121: \tif m.clientset == nil {\n122: \t\tconfig, err := rest.InClusterConfig()\n123: \t\tif err != nil {\n124: \t\t\tklog.Warningf(\"not running in-cluster, using ephemeral keys: %v\", err)\n125: \t\t\treturn nil\n126: \t\t}\n127: \t\tm.clientset, err = kubernetes.NewForConfig(config)\n128: \t\tif err != nil {\n129: \t\t\tklog.Warningf(\"failed to create in-cluster clientset, using ephemeral keys: %v\", err)\n130: \t\t\treturn nil\n131: \t\t}\n132: \t}\n133: \n134: \tsecret := &corev1.Secret{\n135: \t\tObjectMeta: metav1.ObjectMeta{\n136: \t\t\tName:      IdentitySecretName,\n137: \t\t\tNamespace: IdentityNamespace,\n138: \t\t\tLabels: map[string]string{\n139: \t\t\t\t\"app\":       \"agentcube\",\n140: \t\t\t\t\"component\": \"router\",\n141: \t\t\t},\n142: \t\t},\n143: \t\tType: \"Opaque\",\n144: \t\tData: map[string][]byte{\n145: \t\t\tPrivateKeyDataKey: pem.EncodeToMemory(&pem.Block{\n146: \t\t\t\tType:  \"RSA PRIVATE KEY\",\n147: \t\t\t\tBytes: x509.MarshalPKCS1PrivateKey(m.privateKey),\n148: \t\t\t}),\n149: \t\t\tPublicKeyDataKey: pem.EncodeToMemory(&pem.Block{\n150: \t\t\t\tType:  \"PUBLIC KEY\",\n151: \t\t\t\tBytes: x509.MarshalPKCS1PublicKey(m.publicKey),\n152: \t\t\t}),\n153: \t\t},\n154: \t}\n155: \n156: \t_, err := m.clientset.CoreV1().Secrets(IdentityNamespace).Create(ctx, secret, metav1.CreateOptions{})\n157: \tif err != nil {\n158: \t\tif k8serrors.IsAlreadyExists(err) {\n159: \t\t\texisting, getErr := m.clientset.CoreV1().Secrets(IdentityNamespace).Get(ctx, IdentitySecretName, metav1.GetOptions{})\n160: \t\t\tif getErr != nil {\n161: \t\t\t\treturn getErr\n162: \t\t\t}\n163: \t\t\treturn m.loadPrivateKeyPEM(existing.Data[PrivateKeyDataKey])\n164: \t\t}\n165: \t\treturn err\n166: \t}\n167: \treturn nil\n168: }\n169: \n170: func (m *JWTManager) loadPrivateKeyPEM(data []byte) error {\n171: \tblock, _ := pem.Decode(data)\n172: \tif block == nil {\n173: \t\treturn nil\n174: \t}\n175: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n176: \tif err != nil {\n177: \t\treturn err\n178: \t}\n179: \tm.privateKey = privateKey\n180: \tm.publicKey = &privateKey.PublicKey\n181: \treturn nil\n182: }\n\n(End of file - total 182 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go","time":{"start":1775843607185,"end":1775843607192}}}}
