= object  # type: ignore[misc, assignment]\n37:     V1PodSpec = object  # type: ignore[misc, assignment]\n38:     V1PodTemplateSpec = object  # type: ignore[misc, assignment]\n39:     V1Service = object  # type: ignore[misc, assignment]\n40:     V1ServicePort = object  # type: ignore[misc, assignment]\n41:     V1ServiceSpec = object  # type: ignore[misc, assignment]\n42:     V1ServiceStatus = object  # type: ignore[misc, assignment]\n43: \n44: \n45: class KubernetesProvider:\n46:     \"\"\"Provider for deploying agents as standard Kubernetes Deployment + Service.\"\"\"\n47: \n48:     def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n49:         self.namespace = namespace\n50:         self.verbose = verbose\n51:         self._apps_api = client.AppsV1Api()\n52:         self._core_api = client.CoreV1Api()\n53: \n54:     def deploy_agent(\n55:         self,\n56:         agent_name: str,\n57:         image_url: str,\n58:         port: int,\n59:         entrypoint: str,\n60:         replicas: int = 1,\n61:         node_port: Optional[int] = None,\n62:         env_vars: Optional[Dict[str, str]] = None,\n63:     ) -> Dict[str, Any]:\n64:         \"\"\"Deploy a Kubernetes Deployment and NodePort Service.\n65: \n66:         Args:\n67:             agent_name: Name of the agent.\n68:             image_url: Container image URL.\n69:             port: Port the agent listens on.\n70:             entrypoint: Command to start the agent (shell string).\n71:             replicas: Number of replicas (default: 1).\n72:             node_port: Specific NodePort (30000-32767), or None for auto-assign.\n73:             env_vars: Environment variables for the container.\n74: \n75:         Returns:\n76:             Dict with deployment_name, service_name, service_url, node_port.\n77:         \"\"\"\n78:         sanitized_name = agent_name.lower().replace(\"_\", \"-\").replace(\".\", \"-\")\n79: \n80:         env_list = []\n81:         if env_vars:\n82:             for key, value in env_vars.items():\n83:                 env_list.append(V1EnvVar(name=key, value=value))\n84: \n85:         entrypoint_cmd = entrypoint.split() if entrypoint else []\n86: \n87:         container = V1Container(\n88:             name=sanitized_name,\n89:             image=image_url,\n90:             ports=[V1ContainerPort(container_port=port)],\n91:             command=entrypoint_cmd[:1] if entrypoint_cmd else None,\n92:             args=entrypoint_cmd[1:] if len(entrypoint_cmd) > 1 else None,\n93:             env=env_list if env_list else None,\n94:         )\n95: \n96:         pod_spec = V1PodSpec(containers=[container])\n97:         pod_template = V1PodTemplateSpec(\n98:             metadata=V1ObjectMeta(labels={\"app\": sanitized_name}),\n99:             spec=pod_spec,\n100:         )\n101:         deployment_spec = V1DeploymentSpec(\n102:             replicas=replicas,\n103:             selector={\"matchLabels\": {\"app\": sanitized_name}},\n104:             template=pod_template,\n105:         )\n106:         deployment = V1Deployment(\n107:             api_version=\"apps/v1\",\n108:             kind=\"Deployment\",\n109:             metadata=V1ObjectMeta(name=sanitized_name, namespace=self.namespace),\n110:             spec=deployment_spec,\n111:         )\n112: \n113:         self._apps_api.create_namespaced_deployment(\n114:             namespace=self.namespace,\n115:             body=deployment,\n116:         )\n117: \n118:         service_ports = [V1ServicePort(port=port, target_port=port)]\n119:         if node_port is not None:\n120:             service_ports[0].node_port = node_port\n121: \n122:         service_spec = V1ServiceSpec(\n123:             selector={\"app\": sanitized_name},\n124:             ports=service_ports,\n125:             type=\"NodePort\",\n126:         )\n127:         service = V1Service(\n128:             api_version=\"v1\",\n129:             kind=\"Service\",\n130:             metadata=V1ObjectMeta(name=sanitized_name, namespace=self.namespace),\n131:             spec=service_spec,\n132:         )\n133: \n134:         created_service = self._core_api.create_namespaced_service(\n135:             namespace=self.namespace,\n136:             body=service,\n137:         )\n138: \n139:         actual_node_port = node_port\n140:         if actual_node_port is None and created_service.spec.ports:\n141:             actual_node_port = created_service.spec.ports[0].node_port\n142: \n143:         service_url = f\"http://localhost:{actual_node_port}\"\n144: \n145:         return {\n146:             \"deployment_name\": sanitized_name,\n147:             \"service_name\": sanitized_name,\n148:             \"service_url\": service_url,\n149:             \"node_port\": actual_node_port,\n150:         }\n151: \n152:     def wait_for_deployment_ready(self, deployment_name: str, timeout: int = 120) -> None:\n153:         \"\"\"Wait for a deployment to become ready.\n154: \n155:         Args:\n156:             deployment_name: Name of the deployment.\n157:             timeout: Maximum seconds to wait (default: 120).\n158: \n159:         Raises:\n160:             TimeoutError: If the deployment does not become ready within timeout.\n161:         \"\"\"\n162:         start_time = time.time()\n163:         while time.time() - start_time < timeout:\n164:             deployment = self._apps_api.read_namespaced_deployment_status(\n165:                 name=deployment_name,\n166:                 namespace=self.namespace,\n167:             )\n168:             status = deployment.status\n169:             if (\n170:                 status.ready_replicas is not None\n171:                 and status.replicas is not None\n172:                 and status.ready_replicas == status.replicas\n173:             ):\n174:                 return\n175:             time.sleep(2)\n176: \n177:         raise TimeoutError(\n178:             f\"Deployment {deployment_name} did not become ready within {timeout}s\"\n179:         )\n180: \n181:     def delete_agent(self, agent_name: str) -> None:\n182:         \"\"\"Delete a Deployment and Service by name.\n183: \n184:         Ignores 404 errors if resources do not exist.\n185: \n186:         Args:\n187:             agent_name: Name of the agent resources to delete.\n188:         \"\"\"\n189:         try:\n190:             self._apps_api.delete_namespaced_deployment(\n191:                 name=agent_name,\n192:                 namespace=self.namespace,\n193:             )\n194:         except ApiException as e:\n195:             if e.status != 404:\n196:                 raise\n197: \n198:         try:\n199:             self._core_api.delete_namespaced_service(\n200:                 name=agent_name,\n201:                 namespace=self.namespace,\n202:             )\n203:         except ApiException as e:\n204:             if e.status != 404:\n205:                 raise\n\n(End of file - total 205 lines)\n</content>","metadata":{"preview":"\"\"\"Kubernetes provider for deploying standard Deployment + NodePort Service.\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Any, Dict, Optional\n\ntry:\n    from kubernetes import client, config\n    from kubernetes.client.rest import ApiException\n    from kubernetes.client import (\n        V1Container,\n        V1ContainerPort,\n        V1Deployment,\n        V1DeploymentSpec,\n        V1DeploymentStatus,\n        V1EnvVar,\n        V1ObjectMeta,\n        V1PodSpec,\n        V1PodTemplateSpec,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/k8s_provider.py","time":{"start":1775855185080,"end":1775855185099}}}}
{"type":"tool_use","timestamp":1775855188995,"sessionID":"ses_286c8d4fbffe4UkAR6BFerFisn","part":{"id":"prt_d7937acfc001fmUmCIK5vOqHdi","messageID":"msg_d79378bbb0016uGIV9T6JlJ5IS","sessionID":"ses_286c8d4fbffe4UkAR6BFerFisn","type":"tool","tool":"read","callID":"call_3323f63f77f542ffb63583b7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/agentcube_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/agentcube_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"AgentCube provider for deploying AgentRuntime Custom Resources.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import os\n6: import re\n7: from typing import Any, Dict, Optional\n8: \n9: try:\n10:     from kubernetes import client, config\n11:     from kubernetes.client.rest import ApiException\n12: except ImportError:\n13:     client = None  # type: ignore[misc]\n14:     config = None  # type: ignore[misc]\n15:     ApiException = Exception  # type: ignore[misc, assignment]\n16: \n17: \n18: class AgentCubeProvider:\n19:     \"\"\"Provider for deploying agents as AgentRuntime Custom Resources.\"\"\"\n20: \n21:     CRD_GROUP = \"runtime.agentcube.volcano.sh\"\n22:     CRD_VERSION = \"v1alpha1\"\n23:     CRD_PLURAL = \"agentruntimes\"\n24: \n25:     def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n26:         self.namespace = namespace\n27:         self.verbose = verbose\n28:         self._custom_api = client.CustomObjectsApi()\n29: \n30:     def _sanitize_name(self, name: str) -> str:\n31:         \"\"\"Sanitize a name for use as a Kubernetes resource name.\n32: \n33:         Replaces invalid characters with '-' and truncates to 63 characters.\n34:         \"\"\"\n35:         sanitized = re.sub(r\"[^a-z0-9\\-]\", \"-\", name.lower())\n36:         sanitized = sanitized.strip(\"-\")\n37:         if len(sanitized) > 63:\n38:             sanitized = sanitized[:63].rstrip(\"-\")\n39:         return sanitized\n40: \n41:     def deploy_agent_runtime(\n42:         self,\n43:         agent_name: str,\n44:         image_url: str,\n45:         port: int,\n46:         entrypoint: str,\n47:         env_vars: Dict[str, str],\n48:         workload_manager_url: str,\n49:         router_url: str,\n50:         readiness_probe_path: str,\n51:         readiness_probe_port: int,\n52:     ) -> Dict[str, Any]:\n53:         \"\"\"Deploy an AgentRuntime Custom Resource to Kubernetes.\n54: \n55:         Args:\n56:             agent_name: Name of the agent.\n57:             image_url: Container image URL.\n58:             port: Port the agent listens on.\n59:             entrypoint: Command to start the agent.\n60:             env_vars: Environment variables for the container.\n61:             workload_manager_url: URL for the Workload Manager.\n62:             router_url: URL for the Router.\n63:             readiness_probe_path: Path for readiness probe.\n64:             readiness_probe_port: Port for readiness probe.\n65: \n66:         Returns:\n67:             Dict with 'name' and 'endpoint' keys.\n68:         \"\"\"\n69:         sanitized_name = self._sanitize_name(agent_name)\n70: \n71:         resolved_env = []\n72:         for key, value in env_vars.items():\n73:             resolved_env.append({\"name\": key, \"value\": value})\n74: \n75:         for key in [\"WORKLOAD_MANAGER_URL\", \"ROUTER_URL\"]:\n76:             env_value = os.environ.get(key)\n77:             if env_value and not any(e[\"name\"] == key for e in resolved_env):\n78:                 resolved_env.append({\"name\": key, \"value\": env_value})\n79: \n80:         cr_spec = {\n81:             \"apiVersion\": f\"{self.CRD_GROUP}/{self.CRD_VERSION}\",\n82:             \"kind\": \"AgentRuntime\",\n83:             \"metadata\": {\n84:                 \"name\": sanitized_name,\n85:                 \"namespace\": self.namespace,\n86:             },\n87:             \"spec\": {\n88:                 \"image\": image_url,\n89:                 \"port\": port,\n90:                 \"entrypoint\": entrypoint,\n91:                 \"env\": resolved_env,\n92:                 \"workloadManagerUrl\": workload_manager_url,\n93:                 \"routerUrl\": router_url,\n94:                 \"readinessProbe\": {\n95:                     \"path\": readiness_probe_path,\n96:                     \"port\": readiness_probe_port,\n97:                 },\n98:                 \"sessionTimeout\": \"15m\",\n99:                 \"maxSessionDuration\": \"8h\",\n100:                 \"imagePullSecrets\": [{\"name\": \"default-secret\"}],\n101:             },\n102:         }\n103: \n104:         self._custom_api.create_namespaced_custom_object(\n105:             group=self.CRD_GROUP,\n106:             version=self.CRD_VERSION,\n107:             namespace=self.namespace,\n108:             plural=self.CRD_PLURAL,\n109:             body=cr_spec,\n110:         )\n111: \n112:         endpoint = f\"{router_url}/v1/agents/{sanitized_name}\"\n113:         return {\"name\": sanitized_name, \"endpoint\": endpoint}\n114: \n115:     def get_agent_runtime(self, name: str) -> Optional[Dict[str, Any]]:\n116:         \"\"\"Retrieve an existing AgentRuntime CR by name.\n117: \n118:         Args:\n119:             name: The CR name.\n120: \n121:         Returns:\n122:             The CR dict if found, None otherwise.\n123:         \"\"\"\n124:         try:\n125:             return self._custom_api.get_namespaced_custom_object(\n126:                 group=self.CRD_GROUP,\n127:                 version=self.CRD_VERSION,\n128:                 namespace=self.namespace,\n129:                 plural=self.CRD_PLURAL,\n130:                 name=name,\n131:             )\n132:         except ApiException as e:\n133:             if e.status == 404:\n134:                 return None\n135:             raise\n\n(End of file - total 135 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube provider for deploying AgentRuntime Custom Resources.\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nimport re\nfrom typing import Any, Dict, Optional\n\ntry:\n    from kubernetes import client, config\n    from kubernetes.client.rest import ApiException\nexcept ImportError:\n    client = None  # type: ignore[misc]\n    config = None  # type: ignore[misc]\n    ApiException = Exception  # type: ignore[misc, assignment]\n\n\nclass AgentCubeProvider:\n    \"\"\"Provider for deploying agents as AgentRuntime Custom Resources.\"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/agentcube_provider.py","time":{"start":1775855188987,"end":1775855188994}}}}
