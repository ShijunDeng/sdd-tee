\n48: \n49: [tool.pytest.ini_options]\n50: testpaths = [\"tests\"]\n51: \n52: [tool.ruff]\n53: line-length = 120\n54: target-version = \"py310\"\n55: \n56: [tool.ruff.lint]\n57: select = [\"E\", \"F\", \"W\", \"I\"]\n58: \n59: [tool.mypy]\n60: python_version = \"3.10\"\n61: warn_return_any = true\n62: warn_unused_configs = true\n63: disallow_untyped_defs = false\n\n(End of file - total 63 lines)\n</content>","metadata":{"preview":"[build-system]\nrequires = [\"setuptools>=68.0\", \"wheel\"]\nbuild-backend = \"setuptools.build_meta\"\n\n[project]\nname = \"agentcube\"\nversion = \"0.1.0\"\ndescription = \"AgentCube CLI - A developer tool for AI agent lifecycle management\"\nrequires-python = \">=3.10\"\ndependencies = [\n    \"typer[all]>=0.9.0\",\n    \"pydantic>=2.0.0\",\n    \"pyyaml>=6.0\",\n    \"httpx>=0.24.0\",\n    \"docker>=6.0.0\",\n    \"rich>=13.0.0\",\n    \"packaging>=23.0\",\n    \"importlib-resources>=6.0.0\",\n    \"semver>=3.0.0\",\n]","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/pyproject.toml","time":{"start":1775855173894,"end":1775855173900}}}}
