oreSandbox(ctx context.Context, sessionID string, info *handler.SandboxInfo) error\n44: \tUpdateSandbox(ctx context.Context, sessionID string, info *handler.SandboxInfo) error\n45: \tDeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n46: \tGetSandbox(ctx context.Context, sessionID string) (*handler.SandboxInfo, error)\n47: \tListSandboxes(ctx context.Context) (map[string]*handler.SandboxInfo, error)\n48: }\n49: \n50: type MetricsRecorder interface {\n51: \tIncReconcileTotal(resourceType string, result string)\n52: \tObserveReconcileDuration(resourceType string, duration time.Duration)\n53: \tIncReconcileErrors(resourceType string, errorType string)\n54: \tSetWorkqueueDepth(depth int)\n55: \tIncWorkqueueAdds(resourceType string)\n56: }\n57: \n58: type ReconcilerDeps struct {\n59: \tClientset       clientset.Interface\n60: \tInformerFactory externalversions.SharedInformerFactory\n61: \tARLister        listers.AgentRuntimeLister\n62: \tCILister        listers.CodeInterpreterLister\n63: \tPodInformer     coreinformers.PodInformer\n64: \tStore           Store\n65: \tWorkers         int\n66: \tMetricsRecorder MetricsRecorder\n67: }\n\n(End of file - total 67 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n\t\"github.com/volcano-sh/agentcube/client-go/informers/externalversions\"\n\tlisters \"github.com/volcano-sh/agentcube/client-go/listers/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\tcoreinformers \"k8s.io/client-go/informers/core/v1\"\n)\n\nconst (\n\tresourceTypeAgentRuntime    = \"agentruntime\"\n\tresourceTypeCodeInterpreter = \"codeinterpreter\"\n\tresourceTypePod             = \"pod\"\n\n\tresultSuccess = \"success\"\n\tresultError   = \"error\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/types.go","time":{"start":1775823783975,"end":1775823783987}}}}
