\"`\n44: \tWorkloadName string       `json:\"workloadName\"`\n45: \tNamespace    string       `json:\"namespace\"`\n46: \tKind         string       `json:\"kind\"`\n47: \tPodIP        string       `json:\"podIp,omitempty\"`\n48: \tEntryPoints  []EntryPoint `json:\"entryPoints,omitempty\"`\n49: \tCreatedAt    time.Time    `json:\"createdAt\"`\n50: \tExpiresAt    time.Time    `json:\"expiresAt\"`\n51: \tStatus       string       `json:\"status\"`\n52: }\n53: \n54: type SandboxStatus struct {\n55: \tStatus string\n56: \tError  error\n57: }\n\n(End of file - total 57 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"fmt\"\n\t\"time\"\n)\n\ntype CreateSandboxRequest struct {\n\tKind      string `json:\"kind\"`\n\tName      string `json:\"name\"`\n\tNamespace string `json:\"namespace\"`\n}\n\nfunc (r *CreateSandboxRequest) Validate() error {\n\tif r.Kind != AgentRuntimeKind && r.Kind != CodeInterpreterKind {\n\t\treturn fmt.Errorf(\"invalid kind %q: must be %s or %s\", r.Kind, AgentRuntimeKind, CodeInterpreterKind)\n\t}\n\tif r.Namespace == \"\" {\n\t\treturn fmt.Errorf(\"namespace is required\")\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/models.go","time":{"start":1775823776184,"end":1775823776190}}}}
