{"type":"tool_use","timestamp":1775823775317,"sessionID":"ses_288aad8b6ffedrU4WEylBNcrTt","part":{"id":"prt_d77586304001Ikwbjeh8tq5FBL","messageID":"msg_d775839c00017lu5sGztM0sLjz","sessionID":"ses_288aad8b6ffedrU4WEylBNcrTt","type":"tool","tool":"read","callID":"call_02d3883e7a7746489ec1b8fc","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"log\"\n7: \t\"net/http\"\n8: \t\"sync\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n13: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n14: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n15: \t\"k8s.io/client-go/dynamic\"\n16: \n17: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n18: )\n19: \n20: type LifecycleManagerDeps struct {\n21: \tDynamicClient dynamic.Interface\n22: \tStore         Store\n23: \tCheckInterval time.Duration\n24: \tDefaultTTL    time.Duration\n25: }\n26: \n27: type LifecycleManager struct {\n28: \tdynamicClient dynamic.Interface\n29: \tstore         Store\n30: \tcheckInterval time.Duration\n31: \tdefaultTTL    time.Duration\n32: \tstopCh        chan struct{}\n33: \tmu            sync.Mutex\n34: \trunning       bool\n35: }\n36: \n37: func NewLifecycleManager(deps *LifecycleManagerDeps) *LifecycleManager {\n38: \tcheckInterval := deps.CheckInterval\n39: \tif checkInterval == 0 {\n40: \t\tcheckInterval = 5 * time.Minute\n41: \t}\n42: \tdefaultTTL := deps.DefaultTTL\n43: \tif defaultTTL == 0 {\n44: \t\tdefaultTTL = 8 * time.Hour\n45: \t}\n46: \n47: \treturn &LifecycleManager{\n48: \t\tdynamicClient: deps.DynamicClient,\n49: \t\tstore:         deps.Store,\n50: \t\tcheckInterval: checkInterval,\n51: \t\tdefaultTTL:    defaultTTL,\n52: \t\tstopCh:        make(chan struct{}),\n53: \t}\n54: }\n55: \n56: func (m *LifecycleManager) Start(ctx context.Context) {\n57: \tm.mu.Lock()\n58: \tif m.running {\n59: \t\tm.mu.Unlock()\n60: \t\treturn\n61: \t}\n62: \tm.running = true\n63: \tm.mu.Unlock()\n64: \n65: \tgo m.runCleanupLoop(ctx)\n66: }\n67: \n68: func (m *LifecycleManager) Stop() {\n69: \tm.mu.Lock()\n70: \tdefer m.mu.Unlock()\n71: \tif !m.running {\n72: \t\treturn\n73: \t}\n74: \tm.running = false\n75: \tclose(m.stopCh)\n76: \tm.stopCh = make(chan struct{})\n77: }\n78: \n79: func (m *LifecycleManager) runCleanupLoop(ctx context.Context) {\n80: \tticker := time.NewTicker(m.checkInterval)\n81: \tdefer ticker.Stop()\n82: \n83: \tfor {\n84: \t\tselect {\n85: \t\tcase <-ctx.Done():\n86: \t\t\treturn\n87: \t\tcase <-m.stopCh:\n88: \t\t\treturn\n89: \t\tcase <-ticker.C:\n90: \t\t\tm.cleanupExpiredSandboxes(ctx)\n91: \t\t}\n92: \t}\n93: }\n94: \n95: func (m *LifecycleManager) cleanupExpiredSandboxes(ctx context.Context) {\n96: \tsandboxes, err := m.store.ListSandboxes(ctx)\n97: \tif err != nil {\n98: \t\tlog.Printf(\"failed to list sandboxes for cleanup: %v\", err)\n99: \t\treturn\n100: \t}\n101: \n102: \tnow := time.Now()\n103: \tvar expired []*SandboxInfo\n104: \tfor _, sb := range sandboxes {\n105: \t\tif m.isExpired(sb, now) {\n106: \t\t\texpired = append(expired, sb)\n107: \t\t}\n108: \t}\n109: \n110: \tfor _, sb := range expired {\n111: \t\tif err := m.deleteSandbox(ctx, sb); err != nil {\n112: \t\t\tlog.Printf(\"failed to delete expired sandbox %s/%s: %v\", sb.Namespace, sb.SandboxName, err)\n113: \t\t}\n114: \t}\n115: }\n116: \n117: func (m *LifecycleManager) isExpired(info *SandboxInfo, now time.Time) bool {\n118: \tif !info.ExpiresAt.IsZero() {\n119: \t\treturn !now.Before(info.ExpiresAt)\n120: \t}\n121: \n122: \tif !info.CreatedAt.IsZero() {\n123: \t\treturn !now.Before(info.CreatedAt.Add(m.defaultTTL))\n124: \t}\n125: \n126: \treturn false\n127: }\n128: \n129: func (m *LifecycleManager) deleteSandbox(ctx context.Context, info *SandboxInfo) error {\n130: \tgvr, err := m.resolveGVR(info.Kind)\n131: \tif err != nil {\n132: \t\treturn fmt.Errorf(\"failed to resolve GVR for kind %s: %w\", info.Kind, err)\n133: \t}\n134: \n135: \tdeleteCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n136: \tdefer cancel()\n137: \n138: \terr = m.dynamicClient.Resource(gvr).Namespace(info.Namespace).Delete(deleteCtx, info.SandboxName, metav1.DeleteOptions{})\n139: \tif err != nil {\n140: \t\tif apierrors.IsNotFound(err) {\n141: \t\t\tlog.Printf(\"sandbox %s/%s already deleted from cluster\", info.Namespace, info.SandboxName)\n142: \t\t} else {\n143: \t\t\treturn fmt.Errorf(\"failed to delete sandbox from cluster: %w\", err)\n144: \t\t}\n145: \t}\n146: \n147: \tif err := m.store.DeleteSandbox(ctx, info.SessionID); err != nil {\n148: \t\treturn fmt.Errorf(\"failed to delete sandbox from store: %w\", err)\n149: \t}\n150: \n151: \tlog.Printf(\"cleaned up expired sandbox %s/%s (session: %s)\", info.Namespace, info.SandboxName, info.SessionID)\n152: \treturn nil\n153: }\n154: \n155: func (m *LifecycleManager) resolveGVR(kind string) (schema.GroupVersionResource, error) {\n156: \tswitch kind {\n157: \tcase SandboxesKind:\n158: \t\treturn SandboxGVR, nil\n159: \tcase SandboxClaimsKind:\n160: \t\treturn SandboxClaimGVR, nil\n161: \tdefault:\n162: \t\treturn schema.GroupVersionResource{}, fmt.Errorf(\"unknown sandbox kind: %s\", kind)\n163: \t}\n164: }\n165: \n166: func (m *LifecycleManager) GetSandboxStatus(c *gin.Context) {\n167: \tsessionID := c.Param(\"sessionID\")\n168: \tif sessionID == \"\" {\n169: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"sessionID is required\")\n170: \t\treturn\n171: \t}\n172: \n173: \tsandboxInfo, err := m.store.GetSandbox(c.Request.Context(), sessionID)\n174: \tif err != nil {\n175: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox session %s not found\", sessionID))\n176: \t\treturn\n177: \t}\n178: \n179: \tnow := time.Now()\n180: \tvar timeToExpiry *time.Duration\n181: \tif !sandboxInfo.ExpiresAt.IsZero() {\n182: \t\tremaining := sandboxInfo.ExpiresAt.Sub(now)\n183: \t\tif remaining > 0 {\n184: \t\t\ttimeToExpiry = &remaining\n185: \t\t}\n186: \t}\n187: \n188: \tresp := &SandboxStatusResponse{\n189: \t\tSessionID:    sandboxInfo.SessionID,\n190: \t\tSandboxName:  sandboxInfo.SandboxName,\n191: \t\tSandboxID:    sandboxInfo.SandboxID,\n192: \t\tStatus:       sandboxInfo.Status,\n193: \t\tCreatedAt:    sandboxInfo.CreatedAt,\n194: \t\tExpiresAt:    sandboxInfo.ExpiresAt,\n195: \t\tTimeToExpiry: timeToExpiry,\n196: \t\tIsExpired:    m.isExpired(sandboxInfo, now),\n197: \t\tEntryPoints:  sandboxInfo.EntryPoints,\n198: \t}\n199: \n200: \tresponse.JSON(c, http.StatusOK, resp)\n201: }\n202: \n203: type SandboxStatusResponse struct {\n204: \tSessionID    string         `json:\"sessionId\"`\n205: \tSandboxName  string         `json:\"sandboxName\"`\n206: \tSandboxID    string         `json:\"sandboxId\"`\n207: \tStatus       string         `json:\"status\"`\n208: \tCreatedAt    time.Time      `json:\"createdAt\"`\n209: \tExpiresAt    time.Time      `json:\"expiresAt\"`\n210: \tTimeToExpiry *time.Duration `json:\"timeToExpiry,omitempty\"`\n211: \tIsExpired    bool           `json:\"isExpired\"`\n212: \tEntryPoints  []EntryPoint   `json:\"entryPoints,omitempty\"`\n213: }\n214: \n215: func (m *LifecycleManager) ListSandboxes(c *gin.Context) {\n216: \tnamespace := c.Query(\"namespace\")\n217: \tstatusFilter := c.Query(\"status\")\n218: \n219: \tsandboxes, err := m.store.ListSandboxes(c.Request.Context())\n220: \tif err != nil {\n221: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"failed to list sandboxes\")\n222: \t\treturn\n223: \t}\n224: \n225: \tvar filtered []*SandboxInfo\n226: \tfor _, sb := range sandboxes {\n227: \t\tif namespace != \"\" && sb.Namespace != namespace {\n228: \t\t\tcontinue\n229: \t\t}\n230: \t\tif statusFilter != \"\" && sb.Status != statusFilter {\n231: \t\t\tcontinue\n232: \t\t}\n233: \t\tfiltered = append(filtered, sb)\n234: \t}\n235: \n236: \tnow := time.Now()\n237: \titems := make([]SandboxListItem, 0, len(filtered))\n238: \tfor _, sb := range filtered {\n239: \t\tvar timeToExpiry *time.Duration\n240: \t\tif !sb.ExpiresAt.IsZero() {\n241: \t\t\tremaining := sb.ExpiresAt.Sub(now)\n242: \t\t\tif remaining > 0 {\n243: \t\t\t\ttimeToExpiry = &remaining\n244: \t\t\t}\n245: \t\t}\n246: \t\titems = append(items, SandboxListItem{\n247: \t\t\tSessionID:    sb.SessionID,\n248: \t\t\tSandboxName:  sb.SandboxName,\n249: \t\t\tWorkloadName: sb.WorkloadName,\n250: \t\t\tNamespace:    sb.Namespace,\n251: \t\t\tKind:         sb.Kind,\n252: \t\t\tStatus:       sb.Status,\n253: \t\t\tCreatedAt:    sb.CreatedAt,\n254: \t\t\tExpiresAt:    sb.ExpiresAt,\n255: \t\t\tTimeToExpiry: timeToExpiry,\n256: \t\t\tIsExpired:    m.isExpired(sb, now),\n257: \t\t})\n258: \t}\n259: \n260: \tresponse.JSON(c, http.StatusOK, &ListSandboxesResponse{\n261: \t\tTotal: len(items),\n262: \t\tItems: items,\n263: \t})\n264: }\n265: \n266: type SandboxListItem struct {\n267: \tSessionID    string         `json:\"sessionId\"`\n268: \tSandboxName  string         `json:\"sandboxName\"`\n269: \tWorkloadName string         `json:\"workloadName\"`\n270: \tNamespace    string         `json:\"namespace\"`\n271: \tKind         string         `json:\"kind\"`\n272: \tStatus       string         `json:\"status\"`\n273: \tCreatedAt    time.Time      `json:\"createdAt\"`\n274: \tExpiresAt    time.Time      `json:\"expiresAt\"`\n275: \tTimeToExpiry *time.Duration `json:\"timeToExpiry,omitempty\"`\n276: \tIsExpired    bool           `json:\"isExpired\"`\n277: }\n278: \n279: type ListSandboxesResponse struct {\n280: \tTotal int               `json:\"total\"`\n281: \tItems []SandboxListItem `json:\"items\"`\n282: }\n283: \n284: func (m *LifecycleManager) ExtendSandboxTTL(c *gin.Context) {\n285: \tsessionID := c.Param(\"sessionID\")\n286: \tif sessionID == \"\" {\n287: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"sessionID is required\")\n288: \t\treturn\n289: \t}\n290: \n291: \tvar req ExtendTTLRequest\n292: \tif err := c.ShouldBindJSON(&req); err != nil {\n293: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n294: \t\treturn\n295: \t}\n296: \n297: \tif err := req.Validate(); err != nil {\n298: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n299: \t\treturn\n300: \t}\n301: \n302: \tsandboxInfo, err := m.store.GetSandbox(c.Request.Context(), sessionID)\n303: \tif err != nil {\n304: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox session %s not found\", sessionID))\n305: \t\treturn\n306: \t}\n307: \n308: \tnow := time.Now()\n309: \tif m.isExpired(sandboxInfo, now) {\n310: \t\tresponse.Error(c, http.StatusGone, http.StatusGone, \"sandbox has already expired and cannot be extended\")\n311: \t\treturn\n312: \t}\n313: \n314: \tsandboxInfo.ExpiresAt = now.Add(req.ExtensionDuration)\n315: \tif err := m.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n316: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"failed to update sandbox TTL\")\n317: \t\treturn\n318: \t}\n319: \n320: \tresponse.JSON(c, http.StatusOK, &ExtendTTLResponse{\n321: \t\tSessionID: sessionID,\n322: \t\tNewExpiry: sandboxInfo.ExpiresAt,\n323: \t})\n324: }\n325: \n326: type ExtendTTLRequest struct {\n327: \tExtensionDuration time.Duration `json:\"extensionDuration\"`\n328: }\n329: \n330: func (r *ExtendTTLRequest) Validate() error {\n331: \tif r.ExtensionDuration <= 0 {\n332: \t\treturn fmt.Errorf(\"extensionDuration must be positive\")\n333: \t}\n334: \tif r.ExtensionDuration > 24*time.Hour {\n335: \t\treturn fmt.Errorf(\"extensionDuration cannot exceed 24 hours\")\n336: \t}\n337: \treturn nil\n338: }\n339: \n340: type ExtendTTLResponse struct {\n341: \tSessionID string    `json:\"sessionId\"`\n342: \tNewExpiry time.Time `json:\"newExpiry\"`\n343: }\n\n(End of file - total 343 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n)\n\ntype LifecycleManagerDeps struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle.go","time":{"start":1775823775302,"end":1775823775315}}}}
