{"type":"tool_use","timestamp":1775879635474,"sessionID":"ses_2855687fcffeNYLesVAG34165B","part":{"id":"prt_d7aac944e001hPJCWWK9aq6qey","messageID":"msg_d7aac1d180010n0u9dhKgqa8ED","sessionID":"ses_2855687fcffeNYLesVAG34165B","type":"tool","tool":"write","callID":"call_2001f26e2ecc4ed0ab25d2e1","state":{"status":"completed","input":{"content":"name: Test Coverage\n\non:\n  pull_request:\n    branches:\n      - main\n      - release-*\n  merge_group:\n  workflow_call:\n    secrets:\n      CODECOV_TOKEN:\n        required: false\n\njobs:\n  coverage:\n    name: Go Test Coverage\n    runs-on: ubuntu-latest\n    steps:\n      - name: Checkout repository\n        uses: actions/checkout@v4\n\n      - name: Detect changed paths\n        uses: dorny/paths-filter@v3\n        id: changes\n        with:\n          filters: |\n            coverage:\n              - '**'\n              - '!*.md'\n              - '!*.svg'\n              - '!*.png'\n\n      - name: Free disk space\n        if: steps.changes.outputs.coverage == 'true'\n        run: |\n          sudo rm -rf /usr/share/dotnet\n          sudo rm -rf /usr/local/lib/android\n          sudo rm -rf /opt/ghc\n          sudo rm -rf /opt/hostedtoolcache/CodeQL\n\n      - name: Set up Go\n        if: steps.changes.outputs.coverage == 'true'\n        uses: actions/setup-go@v5\n        with:\n          go-version: \"1.24\"\n\n      - name: Run coverage tests\n        if: steps.changes.outputs.coverage == 'true'\n        run: go test -race -v -coverprofile=coverage.out -coverpkg=./pkg/... ./pkg/...\n\n      - name: Upload coverage report\n        if: steps.changes.outputs.coverage == 'true'\n        uses: actions/upload-artifact@v4\n        with:\n          name: go-coverage\n          path: coverage.out\n\n      - name: Upload coverage to Codecov\n        if: steps.changes.outputs.coverage == 'true' && env.CODECOV_TOKEN != ''\n        uses: codecov/codecov-action@v5\n        with:\n          files: coverage.out\n          token