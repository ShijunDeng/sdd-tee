{"type":"tool_use","timestamp":1775812676380,"sessionID":"ses_289540255ffeDCnDWkCcTgdoP8","part":{"id":"prt_d76af0673001pJo35bRgMqE1Ta","messageID":"msg_d76aee9f1001L7IOukM51DPHy3","sessionID":"ses_289540255ffeDCnDWkCcTgdoP8","type":"tool","tool":"read","callID":"call_5a11fdc52ec047b7b73929c2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go</path>\n<type>file</type>\n<content>\n1: package v1alpha1\n2: \n3: import (\n4: \t\"testing\"\n5: \t\"time\"\n6: \n7: \t\"github.com/stretchr/testify/assert\"\n8: \tcorev1 \"k8s.io/api/core/v1\"\n9: \t\"k8s.io/apimachinery/pkg/api/resource\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: )\n12: \n13: func TestCodeInterpreterSpecDefaults(t *testing.T) {\n14: \tci := &CodeInterpreterSpec{\n15: \t\tTemplate: &CodeInterpreterSandboxTemplate{},\n16: \t}\n17: \n18: \tassert.Empty(t, ci.Ports)\n19: \tassert.Nil(t, ci.SessionTimeout)\n20: \tassert.Nil(t, ci.MaxSessionDuration)\n21: \tassert.Nil(t, ci.WarmPoolSize)\n22: \tassert.Equal(t, AuthModeType(\"\"), ci.AuthMode)\n23: }\n24: \n25: func TestCodeInterpreterSandboxTemplateDeepCopy(t *testing.T) {\n26: \truntimeClass := \"kuasar-vmm\"\n27: \toriginal := &CodeInterpreterSandboxTemplate{\n28: \t\tLabels:           map[string]string{\"app\": \"test\"},\n29: \t\tAnnotations:      map[string]string{\"key\": \"value\"},\n30: \t\tRuntimeClassName: &runtimeClass,\n31: \t\tImage:            \"python:3.11\",\n32: \t\tImagePullPolicy:  corev1.PullIfNotPresent,\n33: \t\tCommand:          []string{\"python\", \"-m\", \"http.server\"},\n34: \t\tArgs:             []string{\"8080\"},\n35: \t}\n36: \n37: \tcp := original.DeepCopy()\n38: \n39: \tassert.Equal(t, original.Image, cp.Image)\n40: \tassert.Equal(t, original.Labels[\"app\"], cp.Labels[\"app\"])\n41: \tassert.Equal(t, *original.RuntimeClassName, *cp.RuntimeClassName)\n42: \n43: \tcp.Labels[\"app\"] = \"modified\"\n44: \tassert.Equal(t, \"test\", original.Labels[\"app\"])\n45: \n46: \tcp.Image = \"modified:latest\"\n47: \tassert.Equal(t, \"python:3.11\", original.Image)\n48: }\n49: \n50: func TestCodeInterpreterDeepCopy(t *testing.T) {\n51: \toriginal := &CodeInterpreter{\n52: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n53: \t\tSpec: CodeInterpreterSpec{\n54: \t\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n55: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n56: \t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n57: \t\t\t\tImage:  \"python:3.11\",\n58: \t\t\t},\n59: \t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n60: \t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n61: \t\t\tWarmPoolSize:       ptrInt32(3),\n62: \t\t\tAuthMode:           AuthModePicoD,\n63: \t\t},\n64: \t\tStatus: CodeInterpreterStatus{\n65: \t\t\tReady: true,\n66: \t\t},\n67: \t}\n68: \n69: \tcp := original.DeepCopy()\n70: \n71: \tassert.Equal(t, original.Name, cp.Name)\n72: \tassert.Equal(t, original.Spec.WarmPoolSize, cp.Spec.WarmPoolSize)\n73: \tassert.Equal(t, original.Spec.AuthMode, cp.Spec.AuthMode)\n74: \tassert.Equal(t, original.Status.Ready, cp.Status.Ready)\n75: \n76: \tcp.Spec.WarmPoolSize = ptrInt32(5)\n77: \tassert.Equal(t, int32(3), *original.Spec.WarmPoolSize)\n78: }\n79: \n80: func TestCodeInterpreterListDeepCopy(t *testing.T) {\n81: \toriginal := &CodeInterpreterList{\n82: \t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n83: \t\tItems: []CodeInterpreter{\n84: \t\t\t{\n85: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n86: \t\t\t\tSpec: CodeInterpreterSpec{\n87: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n88: \t\t\t\t\t\tImage: \"python:3.11\",\n89: \t\t\t\t\t},\n90: \t\t\t\t},\n91: \t\t\t},\n92: \t\t},\n93: \t}\n94: \n95: \tcp := original.DeepCopy()\n96: \n97: \tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n98: \tassert.Equal(t, len(original.Items), len(cp.Items))\n99: \tassert.Equal(t, original.Items[0].Name, cp.Items[0].Name)\n100: \n101: \tcp.Items[0].Name = \"modified\"\n102: \tassert.Equal(t, \"ci1\", original.Items[0].Name)\n103: }\n104: \n105: func ptrInt32(i int32) *int32 {\n106: \treturn &i\n107: }\n108: \n109: func TestCodeInterpreterStatusDefaults(t *testing.T) {\n110: \tstatus := CodeInterpreterStatus{}\n111: \n112: \tassert.Empty(t, status.Conditions)\n113: \tassert.False(t, status.Ready)\n114: }\n115: \n116: func TestCodeInterpreterStatusWithConditions(t *testing.T) {\n117: \tstatus := CodeInterpreterStatus{\n118: \t\tConditions: []metav1.Condition{\n119: \t\t\t{\n120: \t\t\t\tType:               \"Ready\",\n121: \t\t\t\tStatus:             metav1.ConditionTrue,\n122: \t\t\t\tReason:             \"SandboxRunning\",\n123: \t\t\t\tMessage:            \"Code interpreter sandbox is running\",\n124: \t\t\t\tLastTransitionTime: metav1.Now(),\n125: \t\t\t},\n126: \t\t},\n127: \t\tReady: true,\n128: \t}\n129: \n130: \tassert.Len(t, status.Conditions, 1)\n131: \tassert.Equal(t, \"Ready\", status.Conditions[0].Type)\n132: \tassert.Equal(t, metav1.ConditionTrue, status.Conditions[0].Status)\n133: \tassert.Equal(t, \"SandboxRunning\", status.Conditions[0].Reason)\n134: \tassert.True(t, status.Ready)\n135: }\n136: \n137: func TestCodeInterpreterStatusDeepCopy(t *testing.T) {\n138: \toriginal := &CodeInterpreterStatus{\n139: \t\tConditions: []metav1.Condition{\n140: \t\t\t{\n141: \t\t\t\tType:   \"Ready\",\n142: \t\t\t\tStatus: metav1.ConditionTrue,\n143: \t\t\t\tReason: \"SandboxRunning\",\n144: \t\t\t},\n145: \t\t},\n146: \t\tReady: true,\n147: \t}\n148: \n149: \tcp := original.DeepCopy()\n150: \n151: \tassert.Equal(t, original.Conditions[0].Type, cp.Conditions[0].Type)\n152: \tassert.Equal(t, original.Conditions[0].Reason, cp.Conditions[0].Reason)\n153: \tassert.Equal(t, original.Ready, cp.Ready)\n154: \n155: \tcp.Conditions[0].Reason = \"Modified\"\n156: \tassert.Equal(t, \"SandboxRunning\", original.Conditions[0].Reason)\n157: \n158: \tcp.Ready = false\n159: \tassert.True(t, original.Ready)\n160: }\n161: \n162: func TestCodeInterpreterSpecDeepCopy(t *testing.T) {\n163: \toriginal := &CodeInterpreterSpec{\n164: \t\tPorts: []TargetPort{\n165: \t\t\t{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP},\n166: \t\t\t{Name: \"api\", Port: 3000, Protocol: ProtocolTypeHTTPS},\n167: \t\t},\n168: \t\tTemplate: &CodeInterpreterSandboxTemplate{\n169: \t\t\tLabels: map[string]string{\"app\": \"test\"},\n170: \t\t\tImage:  \"python:3.11\",\n171: \t\t},\n172: \t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n173: \t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n174: \t\tWarmPoolSize:       ptrInt32(3),\n175: \t\tAuthMode:           AuthModePicoD,\n176: \t}\n177: \n178: \tcp := original.DeepCopy()\n179: \n180: \tassert.Equal(t, original.Ports[0].Port, cp.Ports[0].Port)\n181: \tassert.Equal(t, original.SessionTimeout.Duration, cp.SessionTimeout.Duration)\n182: \tassert.Equal(t, original.WarmPoolSize, cp.WarmPoolSize)\n183: \n184: \tcp.Ports[0].Port = 9090\n185: \tassert.Equal(t, uint32(8080), original.Ports[0].Port)\n186: \n187: \tcp.WarmPoolSize = ptrInt32(10)\n188: \tassert.Equal(t, int32(3), *original.WarmPoolSize)\n189: \n190: \tcp.Template.Labels[\"app\"] = \"modified\"\n191: \tassert.Equal(t, \"test\", original.Template.Labels[\"app\"])\n192: }\n193: \n194: func TestCodeInterpreterSpecDeepCopyNilFields(t *testing.T) {\n195: \toriginal := &CodeInterpreterSpec{\n196: \t\tTemplate: &CodeInterpreterSandboxTemplate{\n197: \t\t\tImage: \"python:3.11\",\n198: \t\t},\n199: \t}\n200: \n201: \tcp := original.DeepCopy()\n202: \n203: \tassert.Nil(t, cp.SessionTimeout)\n204: \tassert.Nil(t, cp.MaxSessionDuration)\n205: \tassert.Nil(t, cp.WarmPoolSize)\n206: \tassert.Empty(t, cp.Ports)\n207: \tassert.Equal(t, AuthModeType(\"\"), cp.AuthMode)\n208: }\n209: \n210: func TestCodeInterpreterSandboxTemplateAllFields(t *testing.T) {\n211: \truntimeClass := \"kuasar-vmm\"\n212: \ttemplate := &CodeInterpreterSandboxTemplate{\n213: \t\tLabels:           map[string]string{\"app\": \"code-interpreter\"},\n214: \t\tAnnotations:      map[string]string{\"agentcube.io/version\": \"1\"},\n215: \t\tRuntimeClassName: &runtimeClass,\n216: \t\tImage:            \"python:3.11-slim\",\n217: \t\tImagePullPolicy:  corev1.PullAlways,\n218: \t\tImagePullSecrets: []corev1.LocalObjectReference{\n219: \t\t\t{Name: \"registry-secret\"},\n220: \t\t},\n221: \t\tEnvironment: []corev1.EnvVar{\n222: \t\t\t{Name: \"PYTHONPATH\", Value: \"/app\"},\n223: \t\t\t{Name: \"DEBUG\", Value: \"false\"},\n224: \t\t},\n225: \t\tCommand: []string{\"python\", \"-m\", \"http.server\"},\n226: \t\tArgs:    []string{\"8080\"},\n227: \t\tResources: corev1.ResourceRequirements{\n228: \t\t\tRequests: corev1.ResourceList{\n229: \t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n230: \t\t\t\tcorev1.ResourceMemory: parseQuantity(\"2Gi\"),\n231: \t\t\t},\n232: \t\t\tLimits: corev1.ResourceList{\n233: \t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"2\"),\n234: \t\t\t\tcorev1.ResourceMemory: parseQuantity(\"4Gi\"),\n235: \t\t\t},\n236: \t\t},\n237: \t}\n238: \n239: \tassert.Equal(t, \"code-interpreter\", template.Labels[\"app\"])\n240: \tassert.Equal(t, \"1\", template.Annotations[\"agentcube.io/version\"])\n241: \tassert.Equal(t, \"kuasar-vmm\", *template.RuntimeClassName)\n242: \tassert.Equal(t, \"python:3.11-slim\", template.Image)\n243: \tassert.Equal(t, corev1.PullAlways, template.ImagePullPolicy)\n244: \tassert.Len(t, template.ImagePullSecrets, 1)\n245: \tassert.Equal(t, \"registry-secret\", template.ImagePullSecrets[0].Name)\n246: \tassert.Len(t, template.Environment, 2)\n247: \tassert.Equal(t, \"/app\", template.Environment[0].Value)\n248: \tassert.Len(t, template.Command, 3)\n249: \tassert.Len(t, template.Args, 1)\n250: \tassert.NotNil(t, template.Resources.Requests)\n251: \tassert.NotNil(t, template.Resources.Limits)\n252: }\n253: \n254: func TestCodeInterpreterSandboxTemplateDeepCopyIsolation(t *testing.T) {\n255: \truntimeClass := \"gvisor\"\n256: \toriginal := &CodeInterpreterSandboxTemplate{\n257: \t\tLabels:           map[string]string{\"app\": \"test\"},\n258: \t\tAnnotations:      map[string]string{\"key\": \"value\"},\n259: \t\tRuntimeClassName: &runtimeClass,\n260: \t\tImage:            \"python:3.11\",\n261: \t\tImagePullPolicy:  corev1.PullIfNotPresent,\n262: \t\tImagePullSecrets: []corev1.LocalObjectReference{{Name: \"secret1\"}},\n263: \t\tEnvironment:      []corev1.EnvVar{{Name: \"VAR\", Value: \"val\"}},\n264: \t\tCommand:          []string{\"python\"},\n265: \t\tArgs:             []string{\"script.py\"},\n266: \t}\n267: \n268: \tcp := original.DeepCopy()\n269: \n270: \tcp.Labels[\"app\"] = \"modified\"\n271: \tassert.Equal(t, \"test\", original.Labels[\"app\"])\n272: \n273: \tcp.Annotations[\"key\"] = \"modified\"\n274: \tassert.Equal(t, \"value\", original.Annotations[\"key\"])\n275: \n276: \t*cp.RuntimeClassName = \"modified\"\n277: \tassert.Equal(t, \"gvisor\", *original.RuntimeClassName)\n278: \n279: \tcp.ImagePullSecrets[0].Name = \"modified\"\n280: \tassert.Equal(t, \"secret1\", original.ImagePullSecrets[0].Name)\n281: \n282: \tcp.Environment[0].Value = \"modified\"\n283: \tassert.Equal(t, \"val\", original.Environment[0].Value)\n284: \n285: \tcp.Command[0] = \"modified\"\n286: \tassert.Equal(t, \"python\", original.Command[0])\n287: \n288: \tcp.Args[0] = \"modified\"\n289: \tassert.Equal(t, \"script.py\", original.Args[0])\n290: }\n291: \n292: func TestCodeInterpreterSandboxTemplateDeepCopyNilFields(t *testing.T) {\n293: \toriginal := &CodeInterpreterSandboxTemplate{\n294: \t\tImage: \"python:3.11\",\n295: \t}\n296: \n297: \tcp := original.DeepCopy()\n298: \n299: \tassert.Nil(t, cp.Labels)\n300: \tassert.Nil(t, cp.Annotations)\n301: \tassert.Nil(t, cp.RuntimeClassName)\n302: \tassert.Empty(t, cp.ImagePullSecrets)\n303: \tassert.Empty(t, cp.Environment)\n304: \tassert.Empty(t, cp.Command)\n305: \tassert.Empty(t, cp.Args)\n306: }\n307: \n308: func TestCodeInterpreterWithAllFields(t *testing.T) {\n309: \tci := &CodeInterpreter{\n310: \t\tTypeMeta: metav1.TypeMeta{\n311: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n312: \t\t\tKind:       \"CodeInterpreter\",\n313: \t\t},\n314: \t\tObjectMeta: metav1.ObjectMeta{\n315: \t\t\tName:      \"python-interpreter\",\n316: \t\t\tNamespace: \"default\",\n317: \t\t\tLabels:    map[string]string{\"app\": \"code-interpreter\"},\n318: \t\t},\n319: \t\tSpec: CodeInterpreterSpec{\n320: \t\t\tPorts: []TargetPort{\n321: \t\t\t\t{\n322: \t\t\t\t\tName:       \"web\",\n323: \t\t\t\t\tPort:       8080,\n324: \t\t\t\t\tProtocol:   ProtocolTypeHTTP,\n325: \t\t\t\t\tPathPrefix: \"/\",\n326: \t\t\t\t},\n327: \t\t\t},\n328: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n329: \t\t\t\tLabels:      map[string]string{\"app\": \"python-interpreter\"},\n330: \t\t\t\tAnnotations: map[string]string{\"agentcube.io/runtime\": \"python-3.11\"},\n331: \t\t\t\tImage:       \"python:3.11-slim\",\n332: \t\t\t\tCommand:     []string{\"python\", \"-m\", \"http.server\"},\n333: \t\t\t\tArgs:        []string{\"8080\"},\n334: \t\t\t},\n335: \t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n336: \t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n337: \t\t\tWarmPoolSize:       ptrInt32(3),\n338: \t\t\tAuthMode:           AuthModePicoD,\n339: \t\t},\n340: \t\tStatus: CodeInterpreterStatus{\n341: \t\t\tConditions: []metav1.Condition{\n342: \t\t\t\t{\n343: \t\t\t\t\tType:   \"Ready\",\n344: \t\t\t\t\tStatus: metav1.ConditionTrue,\n345: \t\t\t\t\tReason: \"SandboxRunning\",\n346: \t\t\t\t},\n347: \t\t\t},\n348: \t\t\tReady: true,\n349: \t\t},\n350: \t}\n351: \n352: \tassert.Equal(t, \"runtime.agentcube.volcano.sh/v1alpha1\", ci.APIVersion)\n353: \tassert.Equal(t, \"CodeInterpreter\", ci.Kind)\n354: \tassert.Equal(t, \"python-interpreter\", ci.Name)\n355: \tassert.Equal(t, \"default\", ci.Namespace)\n356: \tassert.Len(t, ci.Spec.Ports, 1)\n357: \tassert.Equal(t, uint32(8080), ci.Spec.Ports[0].Port)\n358: \tassert.Equal(t, ProtocolTypeHTTP, ci.Spec.Ports[0].Protocol)\n359: \tassert.Equal(t, \"/\", ci.Spec.Ports[0].PathPrefix)\n360: \tassert.NotNil(t, ci.Spec.Template)\n361: \tassert.Equal(t, \"python:3.11-slim\", ci.Spec.Template.Image)\n362: \tassert.Equal(t, 15*time.Minute, ci.Spec.SessionTimeout.Duration)\n363: \tassert.Equal(t, 8*time.Hour, ci.Spec.MaxSessionDuration.Duration)\n364: \tassert.Equal(t, int32(3), *ci.Spec.WarmPoolSize)\n365: \tassert.Equal(t, AuthModePicoD, ci.Spec.AuthMode)\n366: \tassert.True(t, ci.Status.Ready)\n367: \tassert.Len(t, ci.Status.Conditions, 1)\n368: }\n369: \n370: func TestCodeInterpreterWithNilTemplate(t *testing.T) {\n371: \tci := &CodeInterpreter{\n372: \t\tSpec: CodeInterpreterSpec{\n373: \t\t\tTemplate: nil,\n374: \t\t},\n375: \t}\n376: \n377: \tassert.Nil(t, ci.Spec.Template)\n378: \tassert.Nil(t, ci.Spec.SessionTimeout)\n379: \tassert.Nil(t, ci.Spec.MaxSessionDuration)\n380: \tassert.Nil(t, ci.Spec.WarmPoolSize)\n381: \tassert.Equal(t, AuthModeType(\"\"), ci.Spec.AuthMode)\n382: }\n383: \n384: func TestCodeInterpreterWithEmptyPorts(t *testing.T) {\n385: \tci := &CodeInterpreter{\n386: \t\tSpec: CodeInterpreterSpec{\n387: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n388: \t\t\t\tImage: \"python:3.11\",\n389: \t\t\t},\n390: \t\t},\n391: \t}\n392: \n393: \tassert.Empty(t, ci.Spec.Ports)\n394: \tassert.Nil(t, ci.Spec.SessionTimeout)\n395: \tassert.Nil(t, ci.Spec.MaxSessionDuration)\n396: }\n397: \n398: func TestCodeInterpreterListItems(t *testing.T) {\n399: \tlist := &CodeInterpreterList{\n400: \t\tListMeta: metav1.ListMeta{\n401: \t\t\tResourceVersion: \"12345\",\n402: \t\t\tContinue:        \"token\",\n403: \t\t},\n404: \t\tItems: []CodeInterpreter{\n405: \t\t\t{\n406: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n407: \t\t\t\tSpec: CodeInterpreterSpec{\n408: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n409: \t\t\t\t},\n410: \t\t\t\tStatus: CodeInterpreterStatus{Ready: true},\n411: \t\t\t},\n412: \t\t\t{\n413: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci2\", Namespace: \"kube-system\"},\n414: \t\t\t\tSpec: CodeInterpreterSpec{\n415: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.10\"},\n416: \t\t\t\t},\n417: \t\t\t\tStatus: CodeInterpreterStatus{Ready: false},\n418: \t\t\t},\n419: \t\t},\n420: \t}\n421: \n422: \tassert.Equal(t, \"12345\", list.ListMeta.ResourceVersion)\n423: \tassert.Len(t, list.Items, 2)\n424: \tassert.Equal(t, \"ci1\", list.Items[0].Name)\n425: \tassert.Equal(t, \"default\", list.Items[0].Namespace)\n426: \tassert.True(t, list.Items[0].Status.Ready)\n427: \tassert.Equal(t, \"ci2\", list.Items[1].Name)\n428: \tassert.Equal(t, \"kube-system\", list.Items[1].Namespace)\n429: \tassert.False(t, list.Items[1].Status.Ready)\n430: }\n431: \n432: func TestCodeInterpreterListDeepCopyIsolation(t *testing.T) {\n433: \toriginal := &CodeInterpreterList{\n434: \t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n435: \t\tItems: []CodeInterpreter{\n436: \t\t\t{\n437: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n438: \t\t\t\tSpec: CodeInterpreterSpec{\n439: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n440: \t\t\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n441: \t\t\t\t\t\tImage:  \"python:3.11\",\n442: \t\t\t\t\t},\n443: \t\t\t\t\tWarmPoolSize: ptrInt32(2),\n444: \t\t\t\t},\n445: \t\t\t},\n446: \t\t},\n447: \t}\n448: \n449: \tcp := original.DeepCopy()\n450: \n451: \tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n452: \tassert.Len(t, cp.Items, 1)\n453: \n454: \tcp.Items[0].Name = \"modified\"\n455: \tassert.Equal(t, \"ci1\", original.Items[0].Name)\n456: \n457: \tcp.Items[0].Spec.Template.Labels[\"app\"] = \"modified\"\n458: \tassert.Equal(t, \"test\", original.Items[0].Spec.Template.Labels[\"app\"])\n459: \n460: \t*cp.Items[0].Spec.WarmPoolSize = 10\n461: \tassert.Equal(t, int32(2), *original.Items[0].Spec.WarmPoolSize)\n462: }\n463: \n464: func TestCodeInterpreterDeepCopyNilStatus(t *testing.T) {\n465: \toriginal := &CodeInterpreter{\n466: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\"},\n467: \t\tSpec: CodeInterpreterSpec{\n468: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n469: \t\t},\n470: \t}\n471: \n472: \tcp := original.DeepCopy()\n473: \n474: \tassert.Equal(t, original.Name, cp.Name)\n475: \tassert.Equal(t, original.Spec.Template.Image, cp.Spec.Template.Image)\n476: \tassert.False(t, cp.Status.Ready)\n477: \tassert.Empty(t, cp.Status.Conditions)\n478: }\n479: \n480: func TestCodeInterpreterDeepCopyPortsIsolation(t *testing.T) {\n481: \toriginal := &CodeInterpreter{\n482: \t\tSpec: CodeInterpreterSpec{\n483: \t\t\tPorts: []TargetPort{\n484: \t\t\t\t{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP},\n485: \t\t\t},\n486: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n487: \t\t},\n488: \t}\n489: \n490: \tcp := original.DeepCopy()\n491: \n492: \tcp.Spec.Ports[0].Port = 9090\n493: \tcp.Spec.Ports[0].Name = \"modified\"\n494: \n495: \tassert.Equal(t, uint32(8080), original.Spec.Ports[0].Port)\n496: \tassert.Equal(t, \"web\", original.Spec.Ports[0].Name)\n497: }\n498: \n499: func TestCodeInterpreterSpecWarmPoolSizeOmitEmpty(t *testing.T) {\n500: \tspec := &CodeInterpreterSpec{\n501: \t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n502: \t}\n503: \n504: \tassert.Nil(t, spec.WarmPoolSize)\n505: \n506: \tspecWithPool := &CodeInterpreterSpec{\n507: \t\tTemplate:     &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n508: \t\tWarmPoolSize: ptrInt32(5),\n509: \t}\n510: \n511: \tassert.NotNil(t, specWithPool.WarmPoolSize)\n512: \tassert.Equal(t, int32(5), *specWithPool.WarmPoolSize)\n513: }\n514: \n515: func TestCodeInterpreterSpecAuthModeDefault(t *testing.T) {\n516: \tspec := &CodeInterpreterSpec{\n517: \t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n518: \t}\n519: \n520: \tassert.Equal(t, AuthModeType(\"\"), spec.AuthMode)\n521: \n522: \tspecWithAuth := &CodeInterpreterSpec{\n523: \t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n524: \t\tAuthMode: AuthModeNone,\n525: \t}\n526: \n527: \tassert.Equal(t, AuthModeNone, specWithAuth.AuthMode)\n528: }\n529: \n530: func TestCodeInterpreterSpecSessionTimeoutDuration(t *testing.T) {\n531: \tspec := &CodeInterpreterSpec{\n532: \t\tTemplate:       &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n533: \t\tSessionTimeout: &metav1.Duration{Duration: 15 * time.Minute},\n534: \t}\n535: \n536: \tassert.Equal(t, 15*time.Minute, spec.SessionTimeout.Duration)\n537: \tassert.Equal(t, \"15m0s\", spec.SessionTimeout.Duration.String())\n538: }\n539: \n540: func TestCodeInterpreterSpecMaxSessionDuration(t *testing.T) {\n541: \tspec := &CodeInterpreterSpec{\n542: \t\tTemplate:           &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n543: \t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n544: \t}\n545: \n546: \tassert.Equal(t, 8*time.Hour, spec.MaxSessionDuration.Duration)\n547: \tassert.Equal(t, \"8h0m0s\", spec.MaxSessionDuration.Duration.String())\n548: }\n549: \n550: func TestCodeInterpreterSandboxTemplateResources(t *testing.T) {\n551: \ttemplate := &CodeInterpreterSandboxTemplate{\n552: \t\tImage: \"python:3.11\",\n553: \t\tResources: corev1.ResourceRequirements{\n554: \t\t\tRequests: corev1.ResourceList{\n555: \t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n556: \t\t\t\tcorev1.ResourceMemory: parseQuantity(\"2Gi\"),\n557: \t\t\t},\n558: \t\t},\n559: \t}\n560: \n561: \tassert.NotNil(t, template.Resources.Requests)\n562: \tassert.Equal(t, \"1\", template.Resources.Requests.Cpu().String())\n563: \tassert.Equal(t, \"2Gi\", template.Resources.Requests.Memory().String())\n564: }\n565: \n566: func TestCodeInterpreterSandboxTemplateRuntimeClassName(t *testing.T) {\n567: \truntimeClass := \"kuasar-vmm\"\n568: \ttemplate := &CodeInterpreterSandboxTemplate{\n569: \t\tImage:            \"python:3.11\",\n570: \t\tRuntimeClassName: &runtimeClass,\n571: \t}\n572: \n573: \tassert.Equal(t, \"kuasar-vmm\", *template.RuntimeClassName)\n574: \n575: \ttemplateNoRuntime := &CodeInterpreterSandboxTemplate{\n576: \t\tImage: \"python:3.11\",\n577: \t}\n578: \n579: \tassert.Nil(t, templateNoRuntime.RuntimeClassName)\n580: }\n581: \n582: func TestCodeInterpreterSandboxTemplateEnvironment(t *testing.T) {\n583: \ttemplate := &CodeInterpreterSandboxTemplate{\n584: \t\tImage: \"python:3.11\",\n585: \t\tEnvironment: []corev1.EnvVar{\n586: \t\t\t{Name: \"PYTHONPATH\", Value: \"/app\"},\n587: \t\t\t{Name: \"DEBUG\", Value: \"false\"},\n588: \t\t},\n589: \t}\n590: \n591: \tassert.Len(t, template.Environment, 2)\n592: \tassert.Equal(t, \"PYTHONPATH\", template.Environment[0].Name)\n593: \tassert.Equal(t, \"/app\", template.Environment[0].Value)\n594: }\n595: \n596: func TestCodeInterpreterSandboxTemplateImagePullSecrets(t *testing.T) {\n597: \ttemplate := &CodeInterpreterSandboxTemplate{\n598: \t\tImage: \"python:3.11\",\n599: \t\tImagePullSecrets: []corev1.LocalObjectReference{\n600: \t\t\t{Name: \"registry-secret\"},\n601: \t\t\t{Name: \"docker-config\"},\n602: \t\t},\n603: \t}\n604: \n605: \tassert.Len(t, template.ImagePullSecrets, 2)\n606: \tassert.Equal(t, \"registry-secret\", template.ImagePullSecrets[0].Name)\n607: \tassert.Equal(t, \"docker-config\", template.ImagePullSecrets[1].Name)\n608: }\n609: \n610: func TestCodeInterpreterListEmpty(t *testing.T) {\n611: \tlist := &CodeInterpreterList{}\n612: \n613: \tassert.Empty(t, list.Items)\n614: \tassert.Empty(t, list.ListMeta.ResourceVersion)\n615: }\n616: \n617: func TestCodeInterpreterDeepCopyObject(t *testing.T) {\n618: \tci := &CodeInterpreter{\n619: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n620: \t\tSpec: CodeInterpreterSpec{\n621: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n622: \t\t},\n623: \t}\n624: \n625: \tobj := ci.DeepCopyObject()\n626: \tassert.NotNil(t, obj)\n627: \n628: \tcopied, ok := obj.(*CodeInterpreter)\n629: \tassert.True(t, ok)\n630: \tassert.Equal(t, ci.Name, copied.Name)\n631: \tassert.Equal(t, ci.Spec.Template.Image, copied.Spec.Template.Image)\n632: }\n633: \n634: func TestCodeInterpreterListDeepCopyObject(t *testing.T) {\n635: \tlist := &CodeInterpreterList{\n636: \t\tListMeta: metav1.ListMeta{ResourceVersion: \"1234\"},\n637: \t\tItems: []CodeInterpreter{\n638: \t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci1\"}},\n639: \t\t},\n640: \t}\n641: \n642: \tobj := list.DeepCopyObject()\n643: \tassert.NotNil(t, obj)\n644: \n645: \tcopied, ok := obj.(*CodeInterpreterList)\n646: \tassert.True(t, ok)\n647: \tassert.Equal(t, list.ListMeta.ResourceVersion, copied.ListMeta.ResourceVersion)\n648: \tassert.Len(t, copied.Items, 1)\n649: }\n650: \n651: func parseQuantity(s string) resource.Quantity {\n652: \tq, _ := resource.ParseQuantity(s)\n653: \treturn q\n654: }\n\n(End of file - total 654 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestCodeInterpreterSpecDefaults(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{},\n\t}\n\n\tassert.Empty(t, ci.Ports)\n\tassert.Nil(t, ci.SessionTimeout)\n\tassert.Nil(t, ci.MaxSessionDuration)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-