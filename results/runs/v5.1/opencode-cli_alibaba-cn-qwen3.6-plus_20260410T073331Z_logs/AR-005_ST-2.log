e,omitempty\"`\n30: }\n31: \n32: type CodeInterpreterStatus struct {\n33: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n34: \tReady      bool               `json:\"ready,omitempty\"`\n35: }\n36: \n37: type CodeInterpreterSandboxTemplate struct {\n38: \tLabels           map[string]string             `json:\"labels,omitempty\"`\n39: \tAnnotations      map[string]string             `json:\"annotations,omitempty\"`\n40: \tRuntimeClassName *string                       `json:\"runtimeClassName,omitempty\"`\n41: \tImage            string                        `json:\"image,omitempty\"`\n42: \tImagePullPolicy  corev1.PullPolicy             `json:\"imagePullPolicy,omitempty\"`\n43: \tImagePullSecrets []corev1.LocalObjectReference `json:\"imagePullSecrets,omitempty\"`\n44: \tEnvironment      []corev1.EnvVar               `json:\"environment,omitempty\"`\n45: \tCommand          []string                      `json:\"command,omitempty\"`\n46: \tArgs             []string                      `json:\"args,omitempty\"`\n47: \tResources        corev1.ResourceRequirements   `json:\"resources,omitempty\"`\n48: }\n49: \n50: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n51: // +kubebuilder:object:root=true\n52: \n53: type CodeInterpreterList struct {\n54: \tmetav1.TypeMeta `json:\",inline\"`\n55: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n56: \tItems           []CodeInterpreter `json:\"items\"`\n57: }\n58: \n59: func init() {\n60: \tSchemeBuilder.Register(&CodeInterpreter{}, &CodeInterpreterList{})\n61: }\n\n(End of file - total 61 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\n// +genclient\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\n// +kubebuilder:subresource:status\n// +kubebuilder:resource:scope=Namespaced,plural=codeinterpreters\n// +kubebuilder:printcol