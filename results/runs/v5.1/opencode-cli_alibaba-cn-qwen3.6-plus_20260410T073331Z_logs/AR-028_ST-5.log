RL and HTTP session\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneClientBaseUrl:\n    def test_base_url_is_correctly_constructed(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"my-ns\",\n            agent_name=\"my-agent\",\n        )\n        assert client.base_url == (\n            \"https://router.example.com/v1/namespaces/my-ns/\"\n            \"agent-runtimes/my-agent/invocations/\"\n        )\n\n    def test_base_url_with_trailing_slash_on_router(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com/\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        assert client.base_url == (\n            \"https://router.example.com/v1/namespaces/ns/\"\n            \"agent-runtimes/agent/invocations/\"\n        )\n\n    def test_session_header_constant(self):\n        assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n\n    def test_session_has_http_adapter_with_correct_pool_settings(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        http_adapter = client.session.adapters[\"http://\"]\n        https_adapter = client.session.adapters[\"https://\"]\n        assert isinstance(http_adapter, HTTPAdapter)\n        assert isinstance(https_adapter, HTTPAdapter)\n        assert http_adapter._pool_connections == 10\n        assert http_adapter._pool_maxsize == 10\n\n    def test_custom_pool_settings(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n            pool_connections=20,\n            pool_maxsize=30,\n        )\n        adapter = client.session.adapters[\"http://\"]\n        assert adapter._pool_connections == 20\n        assert adapter._pool_maxsize == 30\n\n    def test_constructor_stores_all_fields_with_explicit_arguments(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"custom-ns\",\n            agent_name=\"custom-agent\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n        assert client.router_url == \"https://router.example.com\"\n        assert client.namespace == \"custom-ns\"\n        assert client.agent_name == \"custom-agent\"\n        assert client.timeout == 60\n        assert client.connect_timeout == 3.0\n\n    def test_constructor_uses_default_timeout_values(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n\n\n# ---------------------------------------------------------------------------\n# T-2: AgentRuntimeDataPlaneClient — bootstrap_session_id\n# ---------------------------------------------------------------------------\n\n\nclass TestBootstrapSessionId:\n    def test_bootstrap_returns_session_id_when_header_present(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.headers = {\"x-agentcube-session-id\": \"abc-123\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        result = client.bootstrap_session_id()\n\n        client.session.get.assert_called_once_with(\n            client.base_url,\n            timeout=(5.0, 120),\n        )\n        assert result == \"abc-123\"\n\n    def test_bootstrap_raises_value_error_when_header_missing(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.headers = {}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(ValueError) as exc_info:\n            client.bootstrap_session_id()\n\n        assert \"Missing required response header: x-agentcube-session-id\" in str(\n            exc_info.value\n        )\n\n    def test_bootstrap_raises_http_error_on_non_2xx(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock(\n            side_effect=requests.HTTPError(\"500 Server Error\")\n        )\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(requests.HTTPError):\n            client.bootstrap_session_id()\n\n    def test_bootstrap_calls_raise_for_status(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.headers = {\"x-agentcube-session-id\": \"session-1\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        client.bootstrap_session_id()\n\n        mock_resp.raise_for_status.assert_called_once()\n\n\n# ---------------------------------------------------------------------------\n# T-3: AgentRuntimeDataPlaneClient — invoke\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneInvoke:\n    def test_invoke_posts_correct_url_with_session_header_and_json_body(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        payload = {\"action\": \"run\", \"input\": \"hello\"}\n        result = client.invoke(session_id=\"sess-1\", payload=payload)\n\n        client.session.post.assert_called_once_with(\n            client.base_url,\n            json=payload,\n            headers={\n                \"x-agentcube-session-id\": \"sess-1\",\n                \"Content-Type\": \"application/json\",\n            },\n            timeout=(5.0, 120),\n        )\n        assert result is mock_resp\n\n    def test_invoke_with_timeout_none_uses_default_read_timeout(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.invoke(session_id=\"sess-1\", payload={\"key\": \"val\"}, timeout=None)\n\n        _, kwargs = client.session.post.call_args\n        assert kwargs[\"timeout\"] == (5.0, 120)\n\n    def test_invoke_with_explicit_timeout_uses_provided_value(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.invoke(session_id=\"sess-1\", payload={\"key\": \"val\"}, timeout=60.0)\n\n        _, kwargs = client.session.post.call_args\n        assert kwargs[\"timeout\"] == (5.0, 60.0)\n\n    def test_invoke_returns_raw_response(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        result = client.invoke(session_id=\"sess-1\", payload={})\n\n        assert result is mock_resp\n\n    def test_invoke_calls_raise_for_status(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.invoke(session_id=\"sess-1\", payload={})\n\n        mock_resp.raise_for_status.assert_called_once()\n\n\n# ---------------------------------------------------------------------------\n# T-4: AgentRuntimeDataPlaneClient — close\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneClose:\n    def test_close_closes_underlying_http_session(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n\n        client.session.close.assert_called_once()\n\n    def test_close_is_idempotent(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n        client.close()\n        client.close()\n\n        assert client.session.close.call_count == 3\n\n\n# ---------------------------------------------------------------------------\n# T-5: AgentRuntimeClient — Initialization with defaults\n# ---------------------------------------------------------------------------\n\n\nclass TestClientInitDefaults:\n    @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n    def test_constructor_with_only_agent_name_uses_all_defaults(self, mock_bootstrap):\n        with patch.dict(os.environ, {\"ROUTER_URL\": \"https://router.example.com\"}):\n            client = AgentRuntimeClient(agent_name=\"my-agent\")\n\n        assert client.agent_name == \"my-agent\"\n        assert client.namespace == \"default\"\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        assert client.verbose is False\n        assert client.session_id == \"bootstrapped-session\"\n        assert client.router_url == \"https://router.example.com\"\n\n    @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n    def test_constructor_with_explicit_args_stores_all_fields(self, mock_bootstrap):\n        client = AgentRuntimeClient(\n            agent_name=\"explicit-agent\",\n            namespace=\"explicit-ns\",\n            router_url=\"https://explicit-router.com\",\n            verbose=True,\n            session_id=\"pre-existing-session\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n\n        assert client.agent_name == \"explicit-agent\"\n        assert client.namespace == \"explicit-ns\"\n        assert client.timeout == 60\n        assert client.connect_timeout == 3.0\n        assert client.router_url == \"https://explicit-router.com\"\n        assert client.session_id == \"pre-existing-session\"\n        mock_bootstrap.assert_not_called()\n\n    @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n    def test_constructor_resolves_router_url_from_env(self, mock_bootstrap):\n        with patch.dict(os.environ, {\"ROUTER_URL\": \"https://env-router.com\"}):\n            client = AgentRuntimeClient(agent_name=\"my-agent\")\n\n        assert client.router_url == \"https://env-router.com\"\n\n    def test_constructor_raises_value_error_when_no_router_url(self):\n        with patch.dict(os.environ, {}, clear=True):\n            # Ensure ROUTER_URL is not set\n            os.environ.pop(\"ROUTER_URL\", None)\n            with pytest.raises(ValueError) as exc_info:\n                AgentRuntimeClient(agent_name=\"my-agent\")\n\n        assert \"router_url must be provided or ROUTER_URL env var must be set\" in str(\n            exc_info.value\n        )\n\n    @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n    def test_dp_client_is_constructed_with_resolved_params(self, mock_bootstrap):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                namespace=\"my-ns\",\n                router_url=\"https://router.example.com\",\n                timeout=90,\n                connect_timeout=4.0,\n            )\n\n            mock_dp_cls.assert_called_once_with(\n                router_url=\"https://router.example.com\",\n                namespace=\"my-ns\",\n                agent_name=\"my-agent\",\n                timeout=90,\n                connect_timeout=4.0,\n            )\n            assert client.dp_client is mock_dp_instance\n\n\n# ---------------------------------------------------------------------------\n# T-6: AgentRuntimeClient — Session bootstrapping and reuse\n# ---------------------------------------------------------------------------\n\n\nclass TestClientSession:\n    def test_session_id_none_triggers_bootstrap(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"bootstrapped-123\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n                session_id=None,\n            )\n\n            mock_dp_instance.bootstrap_session_id.assert_called_once()\n            assert client.session_id == \"bootstrapped-123\"\n\n    def test_session_id_provided_skips_bootstrap(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n                session_id=\"existing-session-id\",\n            )\n\n            mock_dp_instance.bootstrap_session_id.assert_not_called()\n            assert client.session_id == \"existing-session-id\"\n\n    def test_verbose_true_creates_logger_with_debug_level(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n                verbose=True,\n            )\n\n            assert client.logger.level == 10  # logging.DEBUG\n\n    def test_verbose_false_creates_logger_with_info_level(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n                verbose=False,\n            )\n\n            assert client.logger.level == 20  # logging.INFO\n\n\n# ---------------------------------------------------------------------------\n# T-7: AgentRuntimeClient — Context manager\n# ---------------------------------------------------------------------------\n\n\nclass TestContextManager:\n    def test_enter_returns_self(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            assert client.__enter__() is client\n\n    def test_exit_with_no_exception_calls_close(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n            client.close = MagicMock()\n\n            client.__exit__(None, None, None)\n\n            client.close.assert_called_once()\n\n    def test_exit_with_exception_calls_close_and_re_raises(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n            client.close = MagicMock()\n\n            exc_type = ValueError\n            exc_val = ValueError(\"test error\")\n            exc_tb = None\n\n            result = client.__exit__(exc_type, exc_val, exc_tb)\n\n            client.close.assert_called_once()\n            assert result is None  # does not suppress exception\n\n    def test_context_manager_with_statement_normal_flow(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            with AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            ) as client:\n                assert client.session_id == \"session-1\"\n\n            mock_dp_instance.close.assert_called_once()\n\n    def test_context_manager_with_statement_exception_flow(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            with pytest.raises(RuntimeError):\n                with AgentRuntimeClient(\n                    agent_name=\"my-agent\",\n                    router_url=\"https://router.example.com\",\n                ) as client:\n                    raise RuntimeError(\"boom\")\n\n            mock_dp_instance.close.assert_called_once()\n\n\n# ---------------------------------------------------------------------------\n# T-8: AgentRuntimeClient — invoke\n# ---------------------------------------------------------------------------\n\n\nclass TestClientInvoke:\n    def test_invoke_with_valid_session_calls_dp_invoke_and_returns_parsed_json(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            mock_response = MagicMock(spec=requests.Response)\n            mock_response.json.return_value = {\"result\": \"ok\", \"status\": 200}\n            mock_dp_instance.invoke.return_value = mock_response\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            result = client.invoke({\"action\": \"run\"})\n\n            mock_dp_instance.invoke.assert_called_once_with(\n                session_id=\"session-1\",\n                payload={\"action\": \"run\"},\n                timeout=None,\n            )\n            assert result == {\"result\": \"ok\", \"status\": 200}\n\n    def test_invoke_with_session_id_none_raises_value_error(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = None\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            with pytest.raises(ValueError) as exc_info:\n                client.invoke({\"action\": \"run\"})\n\n            assert \"AgentRuntime session_id is not initialized\" in str(exc_info.value)\n\n    def test_invoke_with_custom_timeout_passes_timeout_to_data_plane(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            mock_response = MagicMock(spec=requests.Response)\n            mock_response.json.return_value = {\"result\": \"ok\"}\n            mock_dp_instance.invoke.return_value = mock_response\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            client.invoke({\"action\": \"run\"}, timeout=30.0)\n\n            mock_dp_instance.invoke.assert_called_once_with(\n                session_id=\"session-1\",\n                payload={\"action\": \"run\"},\n                timeout=30.0,\n            )\n\n    def test_invoke_with_timeout_none_passes_none_to_data_plane(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            mock_response = MagicMock(spec=requests.Response)\n            mock_response.json.return_value = {\"result\": \"ok\"}\n            mock_dp_instance.invoke.return_value = mock_response\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            client.invoke({\"action\": \"run\"}, timeout=None)\n\n            mock_dp_instance.invoke.assert_called_once_with(\n                session_id=\"session-1\",\n                payload={\"action\": \"run\"},\n                timeout=None,\n            )\n\n    def test_invoke_with_empty_session_id_raises_value_error(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            with pytest.raises(ValueError) as exc_info:\n                client.invoke({\"action\": \"run\"})\n\n            assert \"AgentRuntime session_id is not initialized\" in str(exc_info.value)\n\n\n# ---------------------------------------------------------------------------\n# T-9: AgentRuntimeClient — close\n# ---------------------------------------------------------------------------\n\n\nclass TestClientClose:\n    def test_close_delegates_to_dp_client_close(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            client.close()\n\n            mock_dp_instance.close.assert_called_once()\n\n    def test_close_is_idempotent(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            client.close()\n            client.close()\n            client.close()\n\n            assert mock_dp_instance.close.call_count == 3\n\n\n# ---------------------------------------------------------------------------\n# T-10: Integration tests\n# ---------------------------------------------------------------------------\n\n\nclass TestAgentRuntimeIntegration:\n    def test_full_lifecycle_with_context_manager(self):\n        \"\"\"Full lifecycle: init -> bootstrap -> invoke -> cleanup.\"\"\"\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-lifecycle\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            mock_response = MagicMock(spec=requests.Response)\n            mock_response.json.return_value = {\"output\": \"hello world\"}\n            mock_dp_instance.invoke.return_value = mock_response\n\n            with AgentRuntimeClient(\n                agent_name=\"test-agent\",\n                namespace=\"test-ns\",\n                router_url=\"https://router.test.com\",\n            ) as client:\n                assert client.session_id == \"session-lifecycle\"\n                result = client.invoke({\"message\": \"hello\"})\n                assert result == {\"output\": \"hello world\"}\n\n            mock_dp_instance.bootstrap_session_id.assert_called_once()\n            mock_dp_instance.invoke.assert_called_once()\n            mock_dp_instance.close.assert_called_once()\n\n    def test_pre_provisioned_session_skips_bootstrap(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_cls.return_value = mock_dp_instance\n\n            mock_response = MagicMock(spec=requests.Response)\n            mock_response.json.return_value = {\"output\": \"result\"}\n            mock_dp_instance.invoke.return_value = mock_response\n\n            with AgentRuntimeClient(\n                agent_name=\"test-agent\",\n                router_url=\"https://router.test.com\",\n                session_id=\"pre-provisioned\",\n            ) as client:\n                assert client.session_id == \"pre-provisioned\"\n                result = client.invoke({\"query\": \"test\"})\n                assert result == {\"output\": \"result\"}\n\n            mock_dp_instance.bootstrap_session_id.assert_not_called()\n            mock_dp_instance.invoke.assert_called_once()\n            mock_dp_instance.close.assert_called_once()\n\n    def test_invoke_with_custom_timeout(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-timeout\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            mock_response = MagicMock(spec=requests.Response)\n            mock_response.json.return_value = {\"status\": \"done\"}\n            mock_dp_instance.invoke.return_value = mock_response\n\n            with AgentRuntimeClient(\n                agent_name=\"test-agent\",\n                router_url=\"https://router.test.com\",\n                timeout=60,\n                connect_timeout=3.0,\n            ) as client:\n                client.invoke({\"task\": \"long_running\"}, timeout=30.0)\n\n            mock_dp_instance.invoke.assert_called_once_with(\n                session_id=\"session-timeout\",\n                payload={\"task\": \"long_running\"},\n                timeout=30.0,\n            )\n\n    def test_context_manager_exit_with_exception_still_closes_session(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-exception\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            with pytest.raises(ValueError):\n                with AgentRuntimeClient(\n                    agent_name=\"test-agent\",\n                    router_url=\"https://router.test.com\",\n                ) as client:\n                    assert client.session_id == \"session-exception\"\n                    raise ValueError(\"something went wrong\")\n\n            mock_dp_instance.close.assert_called_once()\n\n    def test_missing_router_url_raises_value_error(self):\n        with patch.dict(os.environ, {}, clear=True):\n            os.environ.pop(\"ROUTER_URL\", None)\n            with pytest.raises(ValueError) as exc_info:\n                AgentRuntimeClient(\n                    agent_name=\"test-agent\",\n                )\n\n            assert \"router_url must be provided or ROUTER_URL env var must be set\" in str(\n                exc_info.value\n            )\n\n    def test_bootstrap_session_id_missing_header_raises_value_error(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.side_effect = ValueError(\n                \"Missing required response header: x-agentcube-session-id\"\n            )\n            mock_dp_cls.return_value = mock_dp_instance\n\n            with pytest.raises(ValueError) as exc_info:\n                AgentRuntimeClient(\n                    agent_name=\"test-agent\",\n                    router_url=\"https://router.test.com\",\n                )\n\n            assert \"Missing required response header: x-agentcube-session-id\" in str(\n                exc_info.value\n            )\n","after":"\"\"\"Tests for AgentRuntimeDataPlaneClient and AgentRuntimeClient.\"\"\"\n\nimport os\nfrom unittest.mock import MagicMock, patch, PropertyMock\n\nimport pytest\nimport requests\nfrom requests.adapters import HTTPAdapter\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n\n\n# ---------------------------------------------------------------------------\n# T-1: AgentRuntimeDataPlaneClient — Base URL and HTTP session\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneClientBaseUrl:\n    def test_base_url_is_correctly_constructed(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"my-ns\",\n            agent_name=\"my-agent\",\n        )\n        assert client.base_url == (\n            \"https://router.example.com/v1/namespaces/my-ns/\"\n            \"agent-runtimes/my-agent/invocations/\"\n        )\n\n    def test_base_url_with_trailing_slash_on_router(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com/\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        assert client.base_url == (\n            \"https://router.example.com/v1/namespaces/ns/\"\n            \"agent-runtimes/agent/invocations/\"\n        )\n\n    def test_session_header_constant(self):\n        assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n\n    def test_session_has_http_adapter_with_correct_pool_settings(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        http_adapter = client.session.adapters[\"http://\"]\n        https_adapter = client.session.adapters[\"https://\"]\n        assert isinstance(http_adapter, HTTPAdapter)\n        assert isinstance(https_adapter, HTTPAdapter)\n        assert http_adapter._pool_connections == 10\n        assert http_adapter._pool_maxsize == 10\n\n    def test_custom_pool_settings(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n            pool_connections=20,\n            pool_maxsize=30,\n        )\n        adapter = client.session.adapters[\"http://\"]\n        assert adapter._pool_connections == 20\n        assert adapter._pool_maxsize == 30\n\n    def test_constructor_stores_all_fields_with_explicit_arguments(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"custom-ns\",\n            agent_name=\"custom-agent\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n        assert client.router_url == \"https://router.example.com\"\n        assert client.namespace == \"custom-ns\"\n        assert client.agent_name == \"custom-agent\"\n        assert client.timeout == 60\n        assert client.connect_timeout == 3.0\n\n    def test_constructor_uses_default_timeout_values(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n\n\n# ---------------------------------------------------------------------------\n# T-2: AgentRuntimeDataPlaneClient — bootstrap_session_id\n# ---------------------------------------------------------------------------\n\n\nclass TestBootstrapSessionId:\n    def test_bootstrap_returns_session_id_when_header_present(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.headers = {\"x-agentcube-session-id\": \"abc-123\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        result = client.bootstrap_session_id()\n\n        client.session.get.assert_called_once_with(\n            client.base_url,\n            timeout=(5.0, 120),\n        )\n        assert result == \"abc-123\"\n\n    def test_bootstrap_raises_value_error_when_header_missing(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.headers = {}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(ValueError) as exc_info:\n            client.bootstrap_session_id()\n\n        assert \"Missing required response header: x-agentcube-session-id\" in str(\n            exc_info.value\n        )\n\n    def test_bootstrap_raises_http_error_on_non_2xx(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock(\n            side_effect=requests.HTTPError(\"500 Server Error\")\n        )\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(requests.HTTPError):\n            client.bootstrap_session_id()\n\n    def test_bootstrap_calls_raise_for_status(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.headers = {\"x-agentcube-session-id\": \"session-1\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        client.bootstrap_session_id()\n\n        mock_resp.raise_for_status.assert_called_once()\n\n\n# ---------------------------------------------------------------------------\n# T-3: AgentRuntimeDataPlaneClient — invoke\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneInvoke:\n    def test_invoke_posts_correct_url_with_session_header_and_json_body(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        payload = {\"action\": \"run\", \"input\": \"hello\"}\n        result = client.invoke(session_id=\"sess-1\", payload=payload)\n\n        client.session.post.assert_called_once_with(\n            client.base_url,\n            json=payload,\n            headers={\n                \"x-agentcube-session-id\": \"sess-1\",\n                \"Content-Type\": \"application/json\",\n            },\n            timeout=(5.0, 120),\n        )\n        assert result is mock_resp\n\n    def test_invoke_with_timeout_none_uses_default_read_timeout(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.invoke(session_id=\"sess-1\", payload={\"key\": \"val\"}, timeout=None)\n\n        _, kwargs = client.session.post.call_args\n        assert kwargs[\"timeout\"] == (5.0, 120)\n\n    def test_invoke_with_explicit_timeout_uses_provided_value(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.invoke(session_id=\"sess-1\", payload={\"key\": \"val\"}, timeout=60.0)\n\n        _, kwargs = client.session.post.call_args\n        assert kwargs[\"timeout\"] == (5.0, 60.0)\n\n    def test_invoke_returns_raw_response(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        result = client.invoke(session_id=\"sess-1\", payload={})\n\n        assert result is mock_resp\n\n    def test_invoke_calls_raise_for_status(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.invoke(session_id=\"sess-1\", payload={})\n\n        mock_resp.raise_for_status.assert_called_once()\n\n\n# ---------------------------------------------------------------------------\n# T-4: AgentRuntimeDataPlaneClient — close\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneClose:\n    def test_close_closes_underlying_http_session(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n\n        client.session.close.assert_called_once()\n\n    def test_close_is_idempotent(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"https://router.example.com\",\n            namespace=\"ns\",\n            agent_name=\"agent\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n        client.close()\n        client.close()\n\n        assert client.session.close.call_count == 3\n\n\n# ---------------------------------------------------------------------------\n# T-5: AgentRuntimeClient — Initialization with defaults\n# ---------------------------------------------------------------------------\n\n\nclass TestClientInitDefaults:\n    @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n    def test_constructor_with_only_agent_name_uses_all_defaults(self, mock_bootstrap):\n        with patch.dict(os.environ, {\"ROUTER_URL\": \"https://router.example.com\"}):\n            client = AgentRuntimeClient(agent_name=\"my-agent\")\n\n        assert client.agent_name == \"my-agent\"\n        assert client.namespace == \"default\"\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        assert client.session_id == \"bootstrapped-session\"\n        assert client.router_url == \"https://router.example.com\"\n\n    @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n    def test_constructor_with_explicit_args_stores_all_fields(self, mock_bootstrap):\n        client = AgentRuntimeClient(\n            agent_name=\"explicit-agent\",\n            namespace=\"explicit-ns\",\n            router_url=\"https://explicit-router.com\",\n            verbose=True,\n            session_id=\"pre-existing-session\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n\n        assert client.agent_name == \"explicit-agent\"\n        assert client.namespace == \"explicit-ns\"\n        assert client.timeout == 60\n        assert client.connect_timeout == 3.0\n        assert client.router_url == \"https://explicit-router.com\"\n        assert client.session_id == \"pre-existing-session\"\n        mock_bootstrap.assert_not_called()\n\n    @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n    def test_constructor_resolves_router_url_from_env(self, mock_bootstrap):\n        with patch.dict(os.environ, {\"ROUTER_URL\": \"https://env-router.com\"}):\n            client = AgentRuntimeClient(agent_name=\"my-agent\")\n\n        assert client.router_url == \"https://env-router.com\"\n\n    def test_constructor_raises_value_error_when_no_router_url(self):\n        with patch.dict(os.environ, {}, clear=True):\n            # Ensure ROUTER_URL is not set\n            os.environ.pop(\"ROUTER_URL\", None)\n            with pytest.raises(ValueError) as exc_info:\n                AgentRuntimeClient(agent_name=\"my-agent\")\n\n        assert \"router_url must be provided or ROUTER_URL env var must be set\" in str(\n            exc_info.value\n        )\n\n    @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n    def test_dp_client_is_constructed_with_resolved_params(self, mock_bootstrap):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                namespace=\"my-ns\",\n                router_url=\"https://router.example.com\",\n                timeout=90,\n                connect_timeout=4.0,\n            )\n\n            mock_dp_cls.assert_called_once_with(\n                router_url=\"https://router.example.com\",\n                namespace=\"my-ns\",\n                agent_name=\"my-agent\",\n                timeout=90,\n                connect_timeout=4.0,\n            )\n            assert client.dp_client is mock_dp_instance\n\n\n# ---------------------------------------------------------------------------\n# T-6: AgentRuntimeClient — Session bootstrapping and reuse\n# ---------------------------------------------------------------------------\n\n\nclass TestClientSession:\n    def test_session_id_none_triggers_bootstrap(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"bootstrapped-123\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n                session_id=None,\n            )\n\n            mock_dp_instance.bootstrap_session_id.assert_called_once()\n            assert client.session_id == \"bootstrapped-123\"\n\n    def test_session_id_provided_skips_bootstrap(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n                session_id=\"existing-session-id\",\n            )\n\n            mock_dp_instance.bootstrap_session_id.assert_not_called()\n            assert client.session_id == \"existing-session-id\"\n\n    def test_verbose_true_creates_logger_with_debug_level(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n                verbose=True,\n            )\n\n            assert client.logger.level == 10  # logging.DEBUG\n\n    def test_verbose_false_creates_logger_with_info_level(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",