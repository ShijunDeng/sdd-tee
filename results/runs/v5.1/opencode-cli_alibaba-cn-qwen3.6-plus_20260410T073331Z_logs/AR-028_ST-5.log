):\n40:         err = CommandExecutionError(exit_code=42, stderr=\"not found\")\n41:         assert \"42\" in str(err)\n42:         assert \"not found\" in str(err)\n43: \n44:     def test_message_format(self):\n45:         err = CommandExecutionError(exit_code=1, stderr=\"fail\")\n46:         assert str(err) == \"Command failed (exit 1): fail\"\n47: \n48:     def test_is_subclass_of_agent_cube_error(self):\n49:         assert issubclass(CommandExecutionError, AgentCubeError)\n50: \n51:     def test_catchable_as_agent_cube_error(self):\n52:         with pytest.raises(AgentCubeError):\n53:             raise CommandExecutionError(exit_code=1, stderr=\"err\")\n54: \n55: \n56: class TestSessionError:\n57:     def test_is_subclass_of_agent_cube_error(self):\n58:         assert issubclass(SessionError, AgentCubeError)\n59: \n60:     def test_has_correct_docstring(self):\n61:         assert SessionError.__doc__ == \"Raised when session creation or management fails\"\n62: \n63:     def test_catchable_as_agent_cube_error(self):\n64:         with pytest.raises(AgentCubeError):\n65:             raise SessionError(\"session failed\")\n66: \n67: \n68: class TestDataPlaneError:\n69:     def test_is_subclass_of_agent_cube_error(self):\n70:         assert issubclass(DataPlaneError, AgentCubeError)\n71: \n72:     def test_has_correct_docstring(self):\n73:         assert DataPlaneError.__doc__ == \"Raised when Data Plane operations fail\"\n74: \n75:     def test_catchable_as_agent_cube_error(self):\n76:         with pytest.raises(AgentCubeError):\n77:             raise DataPlaneError(\"data plane failed\")\n\n(End of file - total 77 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for exception hierarchy.\"\"\"\n\nimport pytest\n\nfrom agentcube.exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    DataPlaneError,\n    SessionError,\n)\n\n\nclass TestAgentCubeError:\n    def test_is_exception(self):\n        assert issubclass(AgentCubeError, Exception)\n\n    def test_can_be_raised_and_caught(self):\n        with pytest.raises(AgentCubeError):\n            raise AgentCubeError(\"test error\")\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_exceptions.py","time":{"start":1775866530950,"end":1775866530955}}}}
{"type":"tool_use","timestamp":1775866532182,"sessionID":"ses_2861e6a03ffecr342jf4RlEgzT","part":{"id":"prt_d79e4cd14001NsI3OwKgbyJvJx","messageID":"msg_d79e4840e0015tBIYPnYpMk6rP","sessionID":"ses_2861e6a03ffecr342jf4RlEgzT","type":"tool","tool":"read","callID":"call_e10b13cc3ac4456c99f5253a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_utils.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_utils.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for utility helpers.\"\"\"\n2: \n3: import logging\n4: import os\n5: import tempfile\n6: from unittest.mock import MagicMock, patch\n7: \n8: import pytest\n9: \n10: from agentcube.utils.http import create_session\n11: from agentcube.utils.log import get_logger\n12: from agentcube.utils.utils import read_token_from_file\n13: \n14: \n15: class TestCreateSession:\n16:     def test_returns_requests_session(self):\n17:         import requests\n18: \n19:         session = create_session()\n20:         assert isinstance(session, requests.Session)\n21: \n22:     def test_mounts_http_adapter(self):\n23:         from requests.adapters import HTTPAdapter\n24: \n25:         session = create_session()\n26:         assert isinstance(session.adapters[\"http://\"], HTTPAdapter)\n27:         assert isinstance(session.adapters[\"https://\"], HTTPAdapter)\n28: \n29:     def test_custom_pool_connections(self):\n30:         session = create_session(pool_connections=20, pool_maxsize=30)\n31:         adapter = session.adapters[\"http://\"]\n32:         assert adapter._pool_connections == 20\n33:         assert adapter._pool_maxsize == 30\n34: \n35:     def test_default_pool_values(self):\n36:         session = create_session()\n37:         adapter = session.adapters[\"http://\"]\n38:         assert adapter._pool_connections == 10\n39:         assert adapter._pool_maxsize == 10\n40: \n41:     def test_session_can_be_closed(self):\n42:         session = create_session()\n43:         session.close()\n44: \n45: \n46: class TestReadTokenFromFile:\n47:     def test_returns_token_content_when_file_exists(self):\n48:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".token\") as f:\n49:             f.write(\"my-secret-token\\n\")\n50:             f.flush()\n51:             token_path = f.name\n52:         try:\n53:             result = read_token_from_file(token_path)\n54:             assert result == \"my-secret-token\"\n55:         finally:\n56:             os.unlink(token_path)\n57: \n58:     def test_strips_whitespace(self):\n59:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".token\") as f:\n60:             f.write(\"  token-with-spaces  \\n\")\n61:             f.flush()\n62:             token_path = f.name\n63:         try:\n64:             result = read_token_from_file(token_path)\n65:             assert result == \"token-with-spaces\"\n66:         finally:\n67:             os.unlink(token_path)\n68: \n69:     def test_returns_empty_string_when_file_not_found(self):\n70:         result = read_token_from_file(\"/nonexistent/path/token\")\n71:         assert result == \"\"\n72: \n73: \n74: class TestGetLogger:\n75:     def test_returns_logger_instance(self):\n76:         logger = get_logger(\"test_logger\")\n77:         assert isinstance(logger, logging.Logger)\n78: \n79:     def test_default_level_is_info(self):\n80:         logger = get_logger(\"test_logger_info\")\n81:         assert logger.level == logging.INFO\n82: \n83:     def test_verbose_sets_debug_level(self):\n84:         logger = get_logger(\"test_logger_debug\", level=logging.DEBUG)\n85:         assert logger.level == logging.DEBUG\n86: \n87:     def test_can_set_level_by_string(self):\n88:         logger = get_logger(\"test_logger_str\", level=\"DEBUG\")\n89:         assert logger.level == logging.DEBUG\n90: \n91:     def test_can_set_level_by_int(self):\n92:         logger = get_logger(\"test_logger_int\", level=logging.WARNING)\n93:         assert logger.level == logging.WARNING\n\n(End of file - total 93 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for utility helpers.\"\"\"\n\nimport logging\nimport os\nimport tempfile\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.log import get_logger\nfrom agentcube.utils.utils import read_token_from_file\n\n\nclass TestCreateSession:\n    def test_returns_requests_session(self):\n        import requests\n\n        session = create_session()\n        assert isinstance(session, requests.Session)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_utils.py","time":{"start":1775866532174,"end":1775866532180}}}}
