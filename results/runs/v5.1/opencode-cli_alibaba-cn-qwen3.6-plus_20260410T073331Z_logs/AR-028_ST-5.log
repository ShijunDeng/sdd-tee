ck_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            with pytest.raises(ValueError) as exc_info:\n                client.invoke({\"action\": \"run\"})\n\n            assert \"AgentRuntime session_id is not initialized\" in str(exc_info.value)\n\n\n# ---------------------------------------------------------------------------\n# T-9: AgentRuntimeClient — close\n# ---------------------------------------------------------------------------\n\n\nclass TestClientClose:\n    def test_close_delegates_to_dp_client_close(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            client.close()\n\n            mock_dp_instance.close.assert_called_once()\n\n    def test_close_is_idempotent(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            client = AgentRuntimeClient(\n                agent_name=\"my-agent\",\n                router_url=\"https://router.example.com\",\n            )\n\n            client.close()\n            client.close()\n            client.close()\n\n            assert mock_dp_instance.close.call_count == 3\n\n\n# ---------------------------------------------------------------------------\n# T-10: Integration tests\n# ---------------------------------------------------------------------------\n\n\nclass TestAgentRuntimeIntegration:\n    def test_full_lifecycle_with_context_manager(self):\n        \"\"\"Full lifecycle: init -> bootstrap -> invoke -> cleanup.\"\"\"\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-lifecycle\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            mock_response = MagicMock(spec=requests.Response)\n            mock_response.json.return_value = {\"output\": \"hello world\"}\n            mock_dp_instance.invoke.return_value = mock_response\n\n            with AgentRuntimeClient(\n                agent_name=\"test-agent\",\n                namespace=\"test-ns\",\n                router_url=\"https://router.test.com\",\n            ) as client:\n                assert client.session_id == \"session-lifecycle\"\n                result = client.invoke({\"message\": \"hello\"})\n                assert result == {\"output\": \"hello world\"}\n\n            mock_dp_instance.bootstrap_session_id.assert_called_once()\n            mock_dp_instance.invoke.assert_called_once()\n            mock_dp_instance.close.assert_called_once()\n\n    def test_pre_provisioned_session_skips_bootstrap(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_cls.return_value = mock_dp_instance\n\n            mock_response = MagicMock(spec=requests.Response)\n            mock_response.json.return_value = {\"output\": \"result\"}\n            mock_dp_instance.invoke.return_value = mock_response\n\n            with AgentRuntimeClient(\n                agent_name=\"test-agent\",\n                router_url=\"https://router.test.com\",\n                session_id=\"pre-provisioned\",\n            ) as client:\n                assert client.session_id == \"pre-provisioned\"\n                result = client.invoke({\"query\": \"test\"})\n                assert result == {\"output\": \"result\"}\n\n            mock_dp_instance.bootstrap_session_id.assert_not_called()\n            mock_dp_instance.invoke.assert_called_once()\n            mock_dp_instance.close.assert_called_once()\n\n    def test_invoke_with_custom_timeout(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-timeout\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            mock_response = MagicMock(spec=requests.Response)\n            mock_response.json.return_value = {\"status\": \"done\"}\n            mock_dp_instance.invoke.return_value = mock_response\n\n            with AgentRuntimeClient(\n                agent_name=\"test-agent\",\n                router_url=\"https://router.test.com\",\n                timeout=60,\n                connect_timeout=3.0,\n            ) as client:\n                client.invoke({\"task\": \"long_running\"}, timeout=30.0)\n\n            mock_dp_instance.invoke.assert_called_once_with(\n                session_id=\"session-timeout\",\n                payload={\"task\": \"long_running\"},\n                timeout=30.0,\n            )\n\n    def test_context_manager_exit_with_exception_still_closes_session(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.return_value = \"session-exception\"\n            mock_dp_cls.return_value = mock_dp_instance\n\n            with pytest.raises(ValueError):\n                with AgentRuntimeClient(\n                    agent_name=\"test-agent\",\n                    router_url=\"https://router.test.com\",\n                ) as client:\n                    assert client.session_id == \"session-exception\"\n                    raise ValueError(\"something went wrong\")\n\n            mock_dp_instance.close.assert_called_once()\n\n    def test_missing_router_url_raises_value_error(self):\n        with patch.dict(os.environ, {}, clear=True):\n            os.environ.pop(\"ROUTER_URL\", None)\n            with pytest.raises(ValueError) as exc_info:\n                AgentRuntimeClient(\n                    agent_name=\"test-agent\",\n                )\n\n            assert \"router_url must be provided or ROUTER_URL env var must be set\" in str(\n                exc_info.value\n            )\n\n    def test_bootstrap_session_id_missing_header_raises_value_error(self):\n        with patch(\n            \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n        ) as mock_dp_cls:\n            mock_dp_instance = MagicMock()\n            mock_dp_instance.bootstrap_session_id.side_effect = ValueError(\n                \"Missing required response header: x-agentcube-session-id\"\n            )\n            mock_dp_cls.return_value = mock_dp_instance\n\n            with pytest.raises(ValueError) as exc_info:\n                AgentRuntimeClient(\n                    agent_name=\"test-agent\",\n                    router_url=\"https://router.test.com\",\n                )\n\n            assert \"Missing required response header: x-agentcube-session-id\" in str(\n                exc_info.value\n            )\n","additions":0,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_agent_runtime.py","time":{"start":1775866723095,"end":1775866723766}}}}
