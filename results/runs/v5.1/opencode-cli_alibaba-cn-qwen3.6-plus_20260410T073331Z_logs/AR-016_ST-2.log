er\",\n225: \t\t\t\"code\":  http.StatusBadRequest,\n226: \t\t})\n227: \t\treturn\n228: \t}\n229: \n230: \tsafePath, err := s.sanitizePath(path)\n231: \tif err != nil {\n232: \t\tc.JSON(http.StatusBadRequest, gin.H{\n233: \t\t\t\"error\": fmt.Sprintf(\"Invalid path: %v\", err),\n234: \t\t\t\"code\":  http.StatusBadRequest,\n235: \t\t})\n236: \t\treturn\n237: \t}\n238: \n239: \tentries, err := os.ReadDir(safePath)\n240: \tif err != nil {\n241: \t\tif os.IsNotExist(err) {\n242: \t\t\tc.JSON(http.StatusNotFound, gin.H{\n243: \t\t\t\t\"error\": \"Directory not found\",\n244: \t\t\t\t\"code\":  http.StatusNotFound,\n245: \t\t\t})\n246: \t\t} else {\n247: \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n248: \t\t\t\t\"error\": fmt.Sprintf(\"Failed to read directory: %v\", err),\n249: \t\t\t\t\"code\":  http.StatusInternalServerError,\n250: \t\t\t})\n251: \t\t}\n252: \t\treturn\n253: \t}\n254: \n255: \tvar files []FileEntry\n256: \tfor _, entry := range entries {\n257: \t\tinfo, err := entry.Info()\n258: \t\tif err != nil {\n259: \t\t\tcontinue\n260: \t\t}\n261: \t\tfiles = append(files, FileEntry{\n262: \t\t\tName:     info.Name(),\n263: \t\t\tSize:     info.Size(),\n264: \t\t\tModified: info.ModTime(),\n265: \t\t\tMode:     info.Mode().String(),\n266: \t\t\tIsDir:    info.IsDir(),\n267: \t\t})\n268: \t}\n269: \n270: \tc.JSON(http.StatusOK, ListFilesResponse{Files: files})\n271: }\n272: \n273: func (s *Server) DownloadFileHandler(c *gin.Context) {\n274: \tpath := c.Param(\"path\")\n275: \tpath = strings.TrimPrefix(path, \"/\")\n276: \n277: \tsafePath, err := s.sanitizePath(path)\n278: \tif err != nil {\n279: \t\tc.JSON(http.StatusBadRequest, gin.H{\n280: \t\t\t\"error\": fmt.Sprintf(\"Invalid path: %v\", err),\n281: \t\t\t\"code\":  http.StatusBadRequest,\n282: \t\t})\n283: \t\treturn\n284: \t}\n285: \n286: \tinfo, err := os.Stat(safePath)\n287: \tif err != nil {\n288: \t\tif os.IsNotExist(err) {\n289: \t\t\tc.JSON(http.StatusNotFound, gin.H{\n290: \t\t\t\t\"error\": \"File not found\",\n291: \t\t\t\t\"code\":  http.StatusNotFound,\n292: \t\t\t})\n293: \t\t} else {\n294: \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n295: \t\t\t\t\"error\": fmt.Sprintf(\"Failed to stat file: %v\", err),\n296: \t\t\t\t\"code\":  http.StatusInternalServerError,\n297: \t\t\t})\n298: \t\t}\n299: \t\treturn\n300: \t}\n301: \n302: \tif info.IsDir() {\n303: \t\tc.JSON(http.StatusBadRequest, gin.H{\n304: \t\t\t\"error\": \"Path is a directory, not a file\",\n305: \t\t\t\"code\":  http.StatusBadRequest,\n306: \t\t})\n307: \t\treturn\n308: \t}\n309: \n310: \tcontentType := mime.TypeByExtension(filepath.Ext(safePath))\n311: \tif contentType == \"\" {\n312: \t\tcontentType = \"application/octet-stream\"\n313: \t}\n314: \n315: \tc.Header(\"Content-Description\", \"File Transfer\")\n316: \tc.Header(\"Content-Transfer-Encoding\", \"binary\")\n317: \tc.Header(\"Content-Disposition\", fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filepath.Base(safePath)))\n318: \tc.Header(\"Content-Type\", contentType)\n319: \n320: \tc.File(safePath)\n321: }\n322: \n323: func parseFileMode(modeStr string) os.FileMode {\n324: \tif modeStr == \"\" {\n325: \t\treturn 0644\n326: \t}\n327: \n328: \tval, err := strconv.ParseUint(modeStr, 8, 32)\n329: \tif err != nil {\n330: \t\treturn 0644\n331: \t}\n332: \n333: \tmode := os.FileMode(val)\n334: \tif mode > maxFileMode {\n335: \t\treturn 0644\n336: \t}\n337: \n338: \treturn mode\n339: }\n\n(End of file - total 339 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"encoding/base64\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nfunc (s *Server) sanitizePath(p string) (string, error) {\n\tif s.workspaceDir == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workspace directory not initialized\")\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/p