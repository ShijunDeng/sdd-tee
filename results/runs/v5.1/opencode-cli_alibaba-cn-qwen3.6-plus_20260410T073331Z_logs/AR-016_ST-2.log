ed: workspace jail violation\")\n45: \t}\n46: \n47: \tresolvedFinalPath, err := filepath.EvalSymlinks(fullPathCandidate)\n48: \tif err == nil {\n49: \t\trelPath2, relErr2 := filepath.Rel(resolvedWorkspace, resolvedFinalPath)\n50: \t\tif relErr2 != nil {\n51: \t\t\treturn \"\", fmt.Errorf(\"access denied: workspace jail violation\")\n52: \t\t}\n53: \t\tif strings.HasPrefix(relPath2, \"..\"+sep) || relPath2 == \"..\" {\n54: \t\t\treturn \"\", fmt.Errorf(\"access denied: workspace jail violation\")\n55: \t\t}\n56: \t\treturn resolvedFinalPath, nil\n57: \t}\n58: \n59: \treturn fullPathCandidate, nil\n60: }\n61: \n62: func (s *Server) UploadFileHandler(c *gin.Context) {\n63: \tcontentType := c.ContentType()\n64: \tif strings.HasPrefix(contentType, \"multipart/form-data\") {\n65: \t\ts.handleMultipartUpload(c)\n66: \t} else {\n67: \t\ts.handleJSONBase64Upload(c)\n68: \t}\n69: }\n70: \n71: func (s *Server) handleMultipartUpload(c *gin.Context) {\n72: \trelPath := c.PostForm(\"path\")\n73: \tif relPath == \"\" {\n74: \t\tc.JSON(http.StatusBadRequest, gin.H{\n75: \t\t\t\"error\": \"Missing 'path' form field\",\n76: \t\t\t\"code\":  http.StatusBadRequest,\n77: \t\t})\n78: \t\treturn\n79: \t}\n80: \n81: \tfileHeader, err := c.FormFile(\"file\")\n82: \tif err != nil {\n83: \t\tc.JSON(http.StatusBadRequest, gin.H{\n84: \t\t\t\"error\": \"Missing 'file' form field\",\n85: \t\t\t\"code\":  http.StatusBadRequest,\n86: \t\t})\n87: \t\treturn\n88: \t}\n89: \n90: \tmodeStr := c.PostForm(\"mode\")\n91: \tfileMode := parseFileMode(modeStr)\n92: \n93: \tsafePath, err := s.sanitizePath(relPath)\n94: \tif err != nil {\n95: \t\tc.JSON(http.StatusBadRequest, gin.H{\n96: \t\t\t\"error\": fmt.Sprintf(\"Invalid path: %v\", err),\n97: \t\t\t\"code\":  http.StatusBadRequest,\n98: \t\t})\n99: \t\treturn\n100: \t}\n101: \n102: \tif err := os.MkdirAll(filepath.Dir(safePath), 0755); err != nil {\n103: \t\tc.JSON(http.StatusInternalServerError, gin.H{\n104: \t\t\t\"error\": fmt.Sprintf(\"Failed to cre