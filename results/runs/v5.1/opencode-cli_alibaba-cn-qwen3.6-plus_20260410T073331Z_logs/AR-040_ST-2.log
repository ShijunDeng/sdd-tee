e_url.\"\"\"\n38:         with pytest.raises(ValueError):\n39:             CodeInterpreterDataPlaneClient(\n40:                 session_id=\"test-session\",\n41:                 namespace=\"default\",\n42:                 cr_name=\"test\"\n43:             )\n44: \n45:     def test_init_sets_session_header(self):\n46:         \"\"\"Test that session ID is set in headers.\"\"\"\n47:         client = CodeInterpreterDataPlaneClient(\n48:             session_id=\"test-session\",\n49:             base_url=\"http://test-base\"\n50:         )\n51:         assert client.session.headers.get(\"x-agentcube-session-id\") == \"test-session\"\n52: \n53:     def test_init_default_timeouts(self):\n54:         \"\"\"Test initialization with default timeouts.\"\"\"\n55:         client = CodeInterpreterDataPlaneClient(\n56:             session_id=\"test-session\",\n57:             base_url=\"http://test-base\"\n58:         )\n59:         assert client.timeout == 120\n60:         assert client.connect_timeout == 5.0\n61: \n62: \n63: class TestCodeInterpreterDataPlaneClientExecuteCommand:\n64:     \"\"\"Tests for CodeInterpreterDataPlaneClient.execute_command method.\"\"\"\n65: \n66:     def test_execute_command_success(self):\n67:         \"\"\"Test successful command execution.\"\"\"\n68:         client = CodeInterpreterDataPlaneClient(\n69:             session_id=\"test-session\",\n70:             base_url=\"http://test-base\"\n71:         )\n72: \n73:         mock_response = MagicMock()\n74:         mock_response.json.return_value = {\n75:             \"stdout\": \"output\",\n76:             \"stderr\": \"\",\n77:             \"exit_code\": 0\n78:         }\n79:         mock_response.raise_for_status = MagicMock()\n80:         client.session.request = MagicMock(return_value=mock_response)\n81: \n82:         result = client.execute_command(\"ls -la\")\n83: \n84:         assert result == \"output\"\n85: \n86:     def test_execute_command_string_command(self):\n87:         \"\"\"Test command execution with string command.\"\"\"\n88:         client = CodeInterpreterDataPlaneClient(\n89:             session_id=\"test-session\",\n90:             base_url=\"http://test-base\"\n91:         )\n92: \n93:         mock_response = MagicMock()\n94:         mock_response.json.return_value = {\n95:             \"stdout\": \"output\",\n96:             \"stderr\": \"\",\n97:             \"exit_code\": 0\n98:         }\n99:         mock_response.raise_for_status = MagicMock()\n100:         client.session.request = MagicMock(return_value=mock_response)\n101: \n102:         client.execute_command(\"ls -la\")\n103: \n104:         call_args = client.session.request.call_args\n105:         body = json.loads(call_args[1][\"data\"])\n106:         assert body[\"command\"] == [\"ls -la\"]\n107: \n108:     def test_execute_command_list_command(self):\n109:         \"\"\"Test command execution with list command.\"\"\"\n110:         client = CodeInterpreterDataPlaneClient(\n111:             session_id=\"test-session\",\n112:             base_url=\"http://test-base\"\n113:         )\n114: \n115:         mock_response = MagicMock()\n116:         mock_response.json.return_value = {\n117:             \"stdout\": \"output\",\n118:             \"stderr\": \"\",\n119:             \"exit_code\": 0\n120:         }\n121:         mock_response.raise_for_status = MagicMock()\n122:         client.session.request = MagicMock(return_value=mock_response)\n123: \n124:         client.execute_command([\"ls\", \"-la\"])\n125: \n126:         call_args = client.session.request.call_args\n127:         body = json.loads(call_args[1][\"data\"])\n128:         assert body[\"command\"] == [\"ls\", \"-la\"]\n129: \n130:     def test_execute_command_non_zero_exit(self):\n131:         \"\"\"Test command execution with non-zero exit code.\"\"\"\n132:         client = CodeInterpreterDataPlaneClient(\n133:             session_id=\"test-session\",\n134:             base_url=\"http://test-base\"\n135:         )\n136: \n137:         mock_response = MagicMock()\n138:         mock_response.json.return_value = {\n139:             \"stdout\": \"\",\n140:             \"stderr\": \"Error occurred\",\n141:             \"exit_code\": 1\n142:         }\n143:         mock_response.raise_for_status = MagicMock()\n144:         client.session.request = MagicMock(return_value=mock_response)\n145: \n146:         with pytest.raises(CommandExecutionError) as exc_info:\n147:             client.execute_command(\"failing-command\")\n148: \n149:         assert exc_info.value.exit_code == 1\n150:         assert exc_info.value.stderr == \"Error occurred\"\n151: \n152:     def test_execute_command_with_timeout(self):\n153:         \"\"\"Test command execution with timeout.\"\"\"\n154:         client = CodeInterpreterDataPlaneClient(\n155:             session_id=\"test-session\",\n156:             base_url=\"http://test-base\"\n157:         )\n158: \n159:         mock_response = MagicMock()\n160:         mock_response.json.return_value = {\n161:             \"stdout\": \"output\",\n162:             \"stderr\": \"\",\n163:             \"exit_code\": 0\n164:         }\n165:         mock_response.raise_for_status = MagicMock()\n166:         client.session.request = MagicMock(return_value=mock_response)\n167: \n168:         client.execute_command(\"ls\", timeout=30)\n169: \n170:         call_args = client.session.request.call_args\n171:         body = json.loads(call_args[1][\"data\"])\n172:         assert body[\"timeout\"] == \"30s\"\n173: \n174: \n175: class TestCodeInterpreterDataPlaneClientRunCode:\n176:     \"\"\"Tests for CodeInterpreterDataPlaneClient.run_code method.\"\"\"\n177: \n178:     def test_run_code_python(self):\n179:         \"\"\"Test running Python code.\"\"\"\n180:         client = CodeInterpreterDataPlaneClient(\n181:             session_id=\"test-session\",\n182:             base_url=\"http://test-base\"\n183:         )\n184: \n185:         client.write_file = MagicMock()\n186:         client.execute_command = MagicMock(return_value=\"Python output\")\n187: \n188:         result = client.run_code(\"python\", \"print('hello')\")\n189: \n190:         assert result == \"Python output\"\n191:         client.write_file.assert_called_once()\n192:         client.execute_command.assert_called_once()\n193: \n194:     def test_run_code_py(self):\n195:         \"\"\"Test running Python code with py language.\"\"\"\n196:         client = CodeInterpreterDataPlaneClient(\n197:             session_id=\"test-session\",\n198:             base_url=\"http://test-base\"\n199:         )\n200: \n201:         client.write_file = MagicMock()\n202:         client.execute_command = MagicMock(return_value=\"Python output\")\n203: \n204:         result = client.run_code(\"py\", \"print('hello')\")\n205: \n206:         assert result == \"Python output\"\n207: \n208:     def test_run_code_python3(self):\n209:         \"\"\"Test running Python code with python3 language.\"\"\"\n210:         client = CodeInterpreterDataPlaneClient(\n211:             session_id=\"test-session\",\n212:             base_url=\"http://test-base\"\n213:         )\n214: \n215:         client.write_file = MagicMock()\n216:         client.execute_command = MagicMock(return_value=\"Python output\")\n217: \n218:         result = client.run_code(\"python3\", \"print('hello')\")\n219: \n220:         assert result == \"Python output\"\n221: \n222:     def test_run_code_unsupported_language(self):\n223:         \"\"\"Test running unsupported language.\"\"\"\n224:         client = CodeInterpreterDataPlaneClient(\n225:             session_id=\"test-session\",\n226:             base_url=\"http://test-base\"\n227:         )\n228: \n229:         with pytest.raises(ValueError, match=\"Unsupported language\"):\n230:             client.run_code(\"javascript\", \"console.log('hello')\")\n231: \n232: \n233: class TestCodeInterpreterDataPlaneClientWriteFile:\n234:     \"\"\"Tests for CodeInterpreterDataPlaneClient.write_file method.\"\"\"\n235: \n236:     def test_write_file_success(self):\n237:         \"\"\"Test successful file write.\"\"\"\n238:         client = CodeInterpreterDataPlaneClient(\n239:             session_id=\"test-session\",\n240:             base_url=\"http://test-base\"\n241:         )\n242: \n243:         mock_response = MagicMock()\n244:         mock_response.raise_for_status = MagicMock()\n245:         client.session.request = MagicMock(return_value=mock_response)\n246: \n247:         client.write_file(\"content\", \"/path/to/file\")\n248: \n249:         call_args = client.session.request.call_args\n250:         body = json.loads(call_args[1][\"data\"])\n251:         assert body[\"path\"] == \"/path/to/file\"\n252:         assert body[\"mode\"] == \"0644\"\n253:         assert base64.b64decode(body[\"content\"]).decode(\"utf-8\") == \"content\"\n254: \n255: \n256: class TestCodeInterpreterDataPlaneClientUploadFile:\n257:     \"\"\"Tests for CodeInterpreterDataPlaneClient.upload_file method.\"\"\"\n258: \n259:     def test_upload_file_success(self, tmp_path):\n260:         \"\"\"Test successful file upload.\"\"\"\n261:         client = CodeInterpreterDataPlaneClient(\n262:             session_id=\"test-session\",\n263:             base_url=\"http://test-base\"\n264:         )\n265: \n266:         test_file = tmp_path / \"test.txt\"\n267:         test_file.write_text(\"test content\")\n268: \n269:         mock_response = MagicMock()\n270:         mock_response.raise_for_status = MagicMock()\n271:         client.session.post = MagicMock(return_value=mock_response)\n272: \n273:         client.upload_file(str(test_file), \"/remote/path\")\n274: \n275:         client.session.post.assert_called_once()\n276:         call_kwargs = client.session.post.call_args[1]\n277:         assert call_kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"test-session\"\n278: \n279: \n280: class TestCodeInterpreterDataPlaneClientDownloadFile:\n281:     \"\"\"Tests for CodeInterpreterDataPlaneClient.download_file method.\"\"\"\n282: \n283:     def test_download_file_success(self, tmp_path):\n284:         \"\"\"Test successful file download.\"\"\"\n285:         client = CodeInterpreterDataPlaneClient(\n286:             session_id=\"test-session\",\n287:             base_url=\"http://test-base\"\n288:         )\n289: \n290:         mock_response = MagicMock()\n291:         mock_response.iter_content = MagicMock(return_value=[b\"chunk1\", b\"chunk2\"])\n292:         mock_response.raise_for_status = MagicMock()\n293:         client.session.request = MagicMock(return_value=mock_response)\n294: \n295:         local_path = tmp_path / \"downloaded.txt\"\n296:         client.download_file(\"/remote/path\", str(local_path))\n297: \n298:         assert local_path.read_text() == \"chunk1chunk2\"\n299: \n300: \n301: class TestCodeInterpreterDataPlaneClientListFiles:\n302:     \"\"\"Tests for CodeInterpreterDataPlaneClient.list_files method.\"\"\"\n303: \n304:     def test_list_files_success(self):\n305:         \"\"\"Test successful file listing.\"\"\"\n306:         client = CodeInterpreterDataPlaneClient(\n307:             session_id=\"test-session\",\n308:             base_url=\"http://test-base\"\n309:         )\n310: \n311:         mock_response = MagicMock()\n312:         mock_response.json.return_value = {\"files\": [\"file1.txt\", \"file2.txt\"]}\n313:         mock_response.raise_for_status = MagicMock()\n314:         client.session.request = MagicMock(return_value=mock_response)\n315: \n316:         result = client.list_files(\"/path\")\n317: \n318:         assert \"files\" in result\n319:         client.session.request.assert_called_once()\n320: \n321: \n322: class TestCodeInterpreterDataPlaneClientClose:\n323:     \"\"\"Tests for CodeInterpreterDataPlaneClient.close method.\"\"\"\n324: \n325:     def test_close(self):\n326:         \"\"\"Test closing the client.\"\"\"\n327:         client = CodeInterpreterDataPlaneClient(\n328:             session_id=\"test-session\",\n329:             base_url=\"http://test-base\"\n330:         )\n331: \n332:         client.session.close = MagicMock()\n333:         client.close()\n334: \n335:         client.session.close.assert_called_once()\n\n(End of file - total 335 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nimport base64\nimport json\nimport os\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\nimport requests\n\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\nclass TestCodeInterpreterDataPlaneClientInit:\n    \"\"\"Tests for CodeInterpreterDataPlaneClient initialization.\"\"\"\n\n    def test_init_with_base_url(self):\n        \"\"\"Test initialization with explicit base URL.\"\"\"\n        client = CodeInterpreterDataPlaneClient(","truncated":false,"loaded":[]},"title":"sdk-python/tests/test_code_interpreter_data_plane.py","time":{"start":1775892470202,"end":1775892470209}}}}
