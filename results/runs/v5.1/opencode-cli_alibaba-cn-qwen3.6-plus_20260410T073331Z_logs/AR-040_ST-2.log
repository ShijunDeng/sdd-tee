e.agent_runtime.AgentRuntimeDataPlaneClient\"):\n145:                 client = AgentRuntimeClient(agent_name=\"test-agent\")\n146:                 client.session_id = None\n147: \n148:                 with pytest.raises(ValueError, match=\"session_id is not initialized\"):\n149:                     client.invoke({\"key\": \"value\"})\n150: \n151:     def test_invoke_with_timeout(self):\n152:         \"\"\"Test invocation with custom timeout.\"\"\"\n153:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n154:             with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp:\n155:                 client = AgentRuntimeClient(agent_name=\"test-agent\")\n156:                 mock_response = MagicMock()\n157:                 mock_response.json.return_value = {\"result\": \"success\"}\n158:                 client.dp_client = mock_dp.return_value\n159:                 client.dp_client.invoke = MagicMock(return_value=mock_response)\n160: \n161:                 result = client.invoke({\"key\": \"value\"}, timeout=60)\n162: \n163:                 assert result == {\"result\": \"success\"}\n164: \n165: \n166: class TestAgentRuntimeClientClose:\n167:     \"\"\"Tests for AgentRuntimeClient.close method.\"\"\"\n168: \n169:     def test_close(self):\n170:         \"\"\"Test closing the client.\"\"\"\n171:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n172:             with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp:\n173:                 client = AgentRuntimeClient(agent_name=\"test-agent\")\n174:                 client.dp_client = mock_dp.return_value\n175:                 client.dp_client.close = MagicMock()\n176: \n177:                 client.close()\n178: \n179:                 client.dp_client.close.assert_called_once()\n\n(End of file - total 179 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentRuntimeClient.\"\"\"\n\nimport os\nfrom unittest.mock import