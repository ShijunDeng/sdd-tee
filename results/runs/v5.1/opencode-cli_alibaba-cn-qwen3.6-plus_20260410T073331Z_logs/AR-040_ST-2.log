"}):\n36:             client = ControlPlaneClient(workload_manager_url=\"http://explicit-url\")\n37:             assert client.base_url == \"http://explicit-url\"\n38: \n39:     def test_init_with_auth_token(self):\n40:         \"\"\"Test initialization with auth token.\"\"\"\n41:         client = ControlPlaneClient(\n42:             workload_manager_url=\"http://test-url\",\n43:             auth_token=\"test-token\"\n44:         )\n45:         assert client.session.headers.get(\"Authorization\") == \"Bearer test-token\"\n46: \n47:     def test_init_without_auth_token(self):\n48:         \"\"\"Test initialization without auth token.\"\"\"\n49:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n50:             mock_read.return_value = \"\"\n51:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n52:             assert \"Authorization\" not in client.session.headers\n53: \n54:     def test_init_default_timeouts(self):\n55:         \"\"\"Test initialization with default timeouts.\"\"\"\n56:         client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n57:         assert client.timeout == 120\n58:         assert client.connect_timeout == 5.0\n59: \n60:     def test_init_custom_timeouts(self):\n61:         \"\"\"Test initialization with custom timeouts.\"\"\"\n62:         client = ControlPlaneClient(\n63:             workload_manager_url=\"http://test-url\",\n64:             timeout=60,\n65:             connect_timeout=3.0\n66:         )\n67:         assert client.timeout == 60\n68:         assert client.connect_timeout == 3.0\n69: \n70: \n71: class TestControlPlaneClientCreateSession:\n72:     \"\"\"Tests for ControlPlaneClient.create_session method.\"\"\"\n73: \n74:     def test_create_session_success(self):\n75:         \"\"\"Test successful session creation.\"\"\"\n76:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n77:             mock_read.return_value = \"\"\n78:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n79: \n80:             mock_response = MagicMock()\n81:             mock_response.json.return_value = {\"data\": {\"sessionId\": \"test-session-id\"}}\n82:             mock_response.raise_for_status = MagicMock()\n83:             client.session.post = MagicMock(return_value=mock_response)\n84: \n85:             session_id = client.create_session()\n86: \n87:             assert session_id == \"test-session-id\"\n88:             client.session.post.assert_called_once()\n89: \n90:     def test_create_session_with_params(self):\n91:         \"\"\"Test session creation with custom parameters.\"\"\"\n92:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n93:             mock_read.return_value = \"\"\n94:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n95: \n96:             mock_response = MagicMock()\n97:             mock_response.json.return_value = {\"data\": {\"sessionId\": \"test-session-id\"}}\n98:             mock_response.raise_for_status = MagicMock()\n99:             client.session.post = MagicMock(return_value=mock_response)\n100: \n101:             client.create_session(\n102:                 name=\"custom-name\",\n103:                 namespace=\"custom-namespace\",\n104:                 ttl=7200,\n105:                 metadata={\"key\": \"value\"}\n106:             )\n107: \n108:             call_args = client.session.post.call_args\n109:             payload = call_args[1][\"json\"]\n110:             assert payload[\"name\"] == \"custom-name\"\n111:             assert payload[\"namespace\"] == \"custom-namespace\"\n112:             assert payload[\"ttl\"] == 7200\n113:             assert payload[\"metadata\"] == {\"key\": \"value\"}\n114: \n115:     def test_create_session_missing_session_id(self):\n116:         \"\"\"Test session creation with missing session ID in response.\"\"\"\n117:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n118:             mock_read.return_value = \"\"\n119:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n120: \n121:             mock_response = MagicMock()\n122:             mock_response.json.return_value = {\"data\": {}}\n123:             mock_response.raise_for_status = MagicMock()\n124:             client.session.post = MagicMock(return_value=mock_response)\n125: \n126:             with pytest.raises(ValueError, match=\"sessionId\"):\n127:                 client.create_session()\n128: \n129:     def test_create_session_http_error(self):\n130:         \"\"\"Test session creation with HTTP error.\"\"\"\n131:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n132:             mock_read.return_value = \"\"\n133:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n134: \n135:             client.session.post = MagicMock(side_effect=requests.exceptions.HTTPError())\n136: \n137:             with pytest.raises(requests.exceptions.HTTPError):\n138:                 client.create_session()\n139: \n140: \n141: class TestControlPlaneClientDeleteSession:\n142:     \"\"\"Tests for ControlPlaneClient.delete_session method.\"\"\"\n143: \n144:     def test_delete_session_success(self):\n145:         \"\"\"Test successful session deletion.\"\"\"\n146:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n147:             mock_read.return_value = \"\"\n148:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n149: \n150:             mock_response = MagicMock()\n151:             mock_response.status_code = 200\n152:             mock_response.raise_for_status = MagicMock()\n153:             client.session.delete = MagicMock(return_value=mock_response)\n154: \n155:             result = client.delete_session(\"test-session-id\")\n156: \n157:             assert result is True\n158: \n159:     def test_delete_session_not_found(self):\n160:         \"\"\"Test session deletion when session doesn't exist (404).\"\"\"\n161:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n162:             mock_read.return_value = \"\"\n163:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n164: \n165:             mock_response = MagicMock()\n166:             mock_response.status_code = 404\n167:             client.session.delete = MagicMock(return_value=mock_response)\n168: \n169:             result = client.delete_session(\"test-session-id\")\n170: \n171:             assert result is True\n172: \n173:     def test_delete_session_error(self):\n174:         \"\"\"Test session deletion with error.\"\"\"\n175:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n176:             mock_read.return_value = \"\"\n177:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n178: \n179:             client.session.delete = MagicMock(\n180:                 side_effect=requests.exceptions.RequestException()\n181:             )\n182: \n183:             result = client.delete_session(\"test-session-id\")\n184: \n185:             assert result is False\n186: \n187:     def test_delete_session_http_error(self):\n188:         \"\"\"Test session deletion with HTTP error.\"\"\"\n189:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n190:             mock_read.return_value = \"\"\n191:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n192: \n193:             mock_response = MagicMock()\n194:             mock_response.status_code = 500\n195:             mock_response.raise_for_status = MagicMock(\n196:                 side_effect=requests.exceptions.HTTPError()\n197:             )\n198:             client.session.delete = MagicMock(return_value=mock_response)\n199: \n200:             result = client.delete_session(\"test-session-id\")\n201: \n202:             assert result is False\n203: \n204: \n205: class TestControlPlaneClientClose:\n206:     \"\"\"Tests for ControlPlaneClient.close method.\"\"\"\n207: \n208:     def test_close(self):\n209:         \"\"\"Test closing the client.\"\"\"\n210:         with patch(\"agentcube.clients.control_plane.read_token_from_file\") as mock_read:\n211:             mock_read.return_value = \"\"\n212:             client = ControlPlaneClient(workload_manager_url=\"http://test-url\")\n213: \n214:             client.session.close = MagicMock()\n215:             client.close()\n216: \n217:             client.session.close.assert_called_once()\n\n(End of file - total 217 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for ControlPlaneClient.\"\"\"\n\nimport os\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\nimport requests\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\nfrom agentcube.exceptions import AgentCubeError\n\n\nclass TestControlPlaneClientInit:\n    \"\"\"Tests for ControlPlaneClient initialization.\"\"\"\n\n    def test_init_requires_url(self):\n        \"\"\"Test that initialization requires URL.\"\"\"\n        with patch.dict(os.environ, {}, clear=True):\n            with pytest.raises(ValueError, match=\"WORKLOAD_MANAGER_URL\"):\n                ControlPlaneClient()","truncated":false,"loaded":[]},"title":"sdk-python/tests/test_control_plane.py","time":{"start":1775892469518,"end":1775892469525}}}}
