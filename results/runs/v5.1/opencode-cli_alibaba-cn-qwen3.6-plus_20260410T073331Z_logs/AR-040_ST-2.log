{"type":"tool_use","timestamp":1775892468295,"sessionID":"ses_284909cb8ffeOsd4or1kukodLL","part":{"id":"prt_d7b70905d0017lYz9SjMN7X5pZ","messageID":"msg_d7b7083fc001DCY0X21s53GkBA","sessionID":"ses_284909cb8ffeOsd4or1kukodLL","type":"tool","tool":"read","callID":"call_e1320cc49f27433096a16add","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/sdk-python/tests/test_code_interpreter_client.py"},"output":"<path>/home/dsj/benchmark/sdk-python/tests/test_code_interpreter_client.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterClient.\"\"\"\n2: \n3: import os\n4: from unittest.mock import patch, MagicMock\n5: \n6: import pytest\n7: \n8: from agentcube.code_interpreter import CodeInterpreterClient\n9: \n10: \n11: class TestCodeInterpreterClientInit:\n12:     \"\"\"Tests for CodeInterpreterClient initialization.\"\"\"\n13: \n14:     def test_init_requires_router_url(self):\n15:         \"\"\"Test that initialization requires router URL.\"\"\"\n16:         with patch.dict(os.environ, {}, clear=True):\n17:             with pytest.raises(ValueError, match=\"ROUTER_URL\"):\n18:                 CodeInterpreterClient()\n19: \n20:     def test_init_with_router_url(self):\n21:         \"\"\"Test initialization with explicit router URL.\"\"\"\n22:         with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n23:             client = CodeInterpreterClient(router_url=\"http://router\")\n24:             assert client.router_url == \"http://router\"\n25: \n26:     def test_init_with_env_router_url(self):\n27:         \"\"\"Test initialization with environment variable router URL.\"\"\"\n28:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://env-router\"}):\n29:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n30:                 client = CodeInterpreterClient()\n31:                 assert client.router_url == \"http://env-router\"\n32: \n33:     def test_init_default_values(self):\n34:         \"\"\"Test initialization with default values.\"\"\"\n35:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n36:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n37:                 client = CodeInterpreterClient()\n38:                 assert client.name == \"my-interpreter\"\n39:                 assert client.namespace == \"default\"\n40:                 assert client.ttl == 3600\n41: \n42:     def test_init_custom_values(self):\n43:         \"\"\"Test initialization with custom values.\"\"\"\n44:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n45:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n46:                 client = CodeInterpreterClient(\n47:                     name=\"custom-name\",\n48:                     namespace=\"custom-ns\",\n49:                     ttl=7200\n50:                 )\n51:                 assert client.name == \"custom-name\"\n52:                 assert client.namespace == \"custom-ns\"\n53:                 assert client.ttl == 7200\n54: \n55:     def test_init_creates_control_plane_client(self):\n56:         \"\"\"Test that control plane client is created.\"\"\"\n57:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n58:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\") as mock_cp:\n59:                 CodeInterpreterClient()\n60:                 mock_cp.assert_called_once()\n61: \n62:     def test_init_with_session_id(self):\n63:         \"\"\"Test initialization with existing session ID.\"\"\"\n64:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n65:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n66:                 client = CodeInterpreterClient(session_id=\"existing-session\")\n67:                 assert client.session_id == \"existing-session\"\n68: \n69: \n70: class TestCodeInterpreterClientContextManager:\n71:     \"\"\"Tests for CodeInterpreterClient context manager.\"\"\"\n72: \n73:     def test_context_manager_enter(self):\n74:         \"\"\"Test context manager entry.\"\"\"\n75:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n76:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n77:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\"):\n78:                     with CodeInterpreterClient() as client:\n79:                         assert client is not None\n80: \n81:     def test_context_manager_exit_calls_stop(self):\n82:         \"\"\"Test that context manager exit calls stop.\"\"\"\n83:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n84:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n85:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\") as mock_dp:\n86:                     client = CodeInterpreterClient()\n87:                     client.dp_client = mock_dp.return_value\n88:                     client.dp_client.close = MagicMock()\n89:                     client.cp_client.delete_session = MagicMock()\n90:                     client.cp_client.close = MagicMock()\n91: \n92:                     client.stop()\n93: \n94:                     client.dp_client.close.assert_called_once()\n95: \n96: \n97: class TestCodeInterpreterClientStop:\n98:     \"\"\"Tests for CodeInterpreterClient.stop method.\"\"\"\n99: \n100:     def test_stop_closes_data_plane(self):\n101:         \"\"\"Test that stop closes data plane client.\"\"\"\n102:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n103:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n104:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\") as mock_dp:\n105:                     client = CodeInterpreterClient()\n106:                     client.dp_client = mock_dp.return_value\n107:                     client.dp_client.close = MagicMock()\n108:                     client.cp_client.delete_session = MagicMock()\n109:                     client.cp_client.close = MagicMock()\n110: \n111:                     client.stop()\n112: \n113:                     client.dp_client.close.assert_called_once()\n114: \n115:     def test_stop_deletes_session(self):\n116:         \"\"\"Test that stop deletes session.\"\"\"\n117:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n118:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n119:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\"):\n120:                     client = CodeInterpreterClient()\n121:                     client.session_id = \"test-session\"\n122:                     client.cp_client.delete_session = MagicMock()\n123:                     client.cp_client.close = MagicMock()\n124: \n125:                     client.stop()\n126: \n127:                     client.cp_client.delete_session.assert_called_once_with(\"test-session\")\n128: \n129:     def test_stop_closes_control_plane(self):\n130:         \"\"\"Test that stop closes control plane client.\"\"\"\n131:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n132:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\") as mock_cp:\n133:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\"):\n134:                     client = CodeInterpreterClient()\n135:                     client.cp_client = mock_cp.return_value\n136:                     client.cp_client.close = MagicMock()\n137:                     client.cp_client.delete_session = MagicMock()\n138: \n139:                     client.stop()\n140: \n141:                     client.cp_client.close.assert_called_once()\n142: \n143: \n144: class TestCodeInterpreterClientExecuteCommand:\n145:     \"\"\"Tests for CodeInterpreterClient.execute_command method.\"\"\"\n146: \n147:     def test_execute_command_delegates(self):\n148:         \"\"\"Test that execute_command delegates to data plane.\"\"\"\n149:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n150:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n151:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\") as mock_dp:\n152:                     client = CodeInterpreterClient()\n153:                     client.dp_client = mock_dp.return_value\n154:                     client.dp_client.execute_command = MagicMock(return_value=\"output\")\n155: \n156:                     result = client.execute_command(\"ls\", timeout=30)\n157: \n158:                     assert result == \"output\"\n159:                     client.dp_client.execute_command.assert_called_once_with(\"ls\", 30)\n160: \n161: \n162: class TestCodeInterpreterClientRunCode:\n163:     \"\"\"Tests for CodeInterpreterClient.run_code method.\"\"\"\n164: \n165:     def test_run_code_delegates(self):\n166:         \"\"\"Test that run_code delegates to data plane.\"\"\"\n167:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n168:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n169:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\") as mock_dp:\n170:                     client = CodeInterpreterClient()\n171:                     client.dp_client = mock_dp.return_value\n172:                     client.dp_client.run_code = MagicMock(return_value=\"output\")\n173: \n174:                     result = client.run_code(\"python\", \"print('hello')\", timeout=30)\n175: \n176:                     assert result == \"output\"\n177:                     client.dp_client.run_code.assert_called_once_with(\"python\", \"print('hello')\", 30)\n178: \n179: \n180: class TestCodeInterpreterClientFileOperations:\n181:     \"\"\"Tests for CodeInterpreterClient file operations.\"\"\"\n182: \n183:     def test_write_file_delegates(self):\n184:         \"\"\"Test that write_file delegates to data plane.\"\"\"\n185:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n186:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n187:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\") as mock_dp:\n188:                     client = CodeInterpreterClient()\n189:                     client.dp_client = mock_dp.return_value\n190:                     client.dp_client.write_file = MagicMock()\n191: \n192:                     client.write_file(\"content\", \"/path\")\n193: \n194:                     client.dp_client.write_file.assert_called_once_with(\"content\", \"/path\")\n195: \n196:     def test_upload_file_delegates(self):\n197:         \"\"\"Test that upload_file delegates to data plane.\"\"\"\n198:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n199:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n200:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\") as mock_dp:\n201:                     client = CodeInterpreterClient()\n202:                     client.dp_client = mock_dp.return_value\n203:                     client.dp_client.upload_file = MagicMock()\n204: \n205:                     client.upload_file(\"/local\", \"/remote\")\n206: \n207:                     client.dp_client.upload_file.assert_called_once_with(\"/local\", \"/remote\")\n208: \n209:     def test_download_file_delegates(self):\n210:         \"\"\"Test that download_file delegates to data plane.\"\"\"\n211:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n212:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n213:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\") as mock_dp:\n214:                     client = CodeInterpreterClient()\n215:                     client.dp_client = mock_dp.return_value\n216:                     client.dp_client.download_file = MagicMock()\n217: \n218:                     client.download_file(\"/remote\", \"/local\")\n219: \n220:                     client.dp_client.download_file.assert_called_once_with(\"/remote\", \"/local\")\n221: \n222:     def test_list_files_delegates(self):\n223:         \"\"\"Test that list_files delegates to data plane.\"\"\"\n224:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n225:             with patch(\"agentcube.code_interpreter.ControlPlaneClient\"):\n226:                 with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\") as mock_dp:\n227:                     client = CodeInterpreterClient()\n228:                     client.dp_client = mock_dp.return_value\n229:                     client.dp_client.list_files = MagicMock(return_value={\"files\": []})\n230: \n231:                     result = client.list_files(\"/path\")\n232: \n233:                     assert result == {\"files\": []}\n234:                     client.dp_client.list_files.assert_called_once_with(\"/path\")\n\n(End of file - total 234 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterClient.\"\"\"\n\nimport os\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\n\nfrom agentcube.code_interpreter import CodeInterpreterClient\n\n\nclass TestCodeInterpreterClientInit:\n    \"\"\"Tests for CodeInterpreterClient initialization.\"\"\"\n\n    def test_init_requires_router_url(self):\n        \"\"\"Test that initialization requires router URL.\"\"\"\n        with patch.dict(os.environ, {}, clear=True):\n            with pytest.raises(ValueError, match=\"ROUTER_URL\"):\n                CodeInterpreterClient()\n\n    def test_init_with_router_url(self):","truncated":false,"loaded":[]},"title":"sdk-python/tests/test_code_interpreter_clie