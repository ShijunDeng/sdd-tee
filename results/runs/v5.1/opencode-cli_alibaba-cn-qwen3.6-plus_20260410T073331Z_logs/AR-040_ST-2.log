\",\n38:             agent_name=\"test-agent\",\n39:             timeout=60,\n40:             connect_timeout=3.0\n41:         )\n42:         assert client.timeout == 60\n43:         assert client.connect_timeout == 3.0\n44: \n45: \n46: class TestAgentRuntimeDataPlaneClientBootstrapSessionId:\n47:     \"\"\"Tests for AgentRuntimeDataPlaneClient.bootstrap_session_id method.\"\"\"\n48: \n49:     def test_bootstrap_session_id_success(self):\n50:         \"\"\"Test successful session ID bootstrap.\"\"\"\n51:         client = AgentRuntimeDataPlaneClient(\n52:             router_url=\"http://router\",\n53:             namespace=\"default\",\n54:             agent_name=\"test-agent\"\n55:         )\n56: \n57:         mock_response = MagicMock()\n58:         mock_response.headers = {\"x-agentcube-session-id\": \"bootstrapped-session\"}\n59:         mock_response.raise_for_status = MagicMock()\n60:         client.session.get = MagicMock(return_value=mock_response)\n61: \n62:         session_id = client.bootstrap_session_id()\n63: \n64:         assert session_id == \"bootstrapped-session\"\n65:         client.session.get.assert_called_once()\n66: \n67:     def test_bootstrap_session_id_missing_header(self):\n68:         \"\"\"Test bootstrap when header is missing.\"\"\"\n69:         client = AgentRuntimeDataPlaneClient(\n70:             router_url=\"http://router\",\n71:             namespace=\"default\",\n72:             agent_name=\"test-agent\"\n73:         )\n74: \n75:         mock_response = MagicMock()\n76:         mock_response.headers = {}\n77:         mock_response.raise_for_status = MagicMock()\n78:         client.session.get = MagicMock(return_value=mock_response)\n79: \n80:         with pytest.raises(ValueError, match=\"x-agentcube-session-id\"):\n81:             client.bootstrap_session_id()\n82: \n83:     def test_bootstrap_session_id_http_error(self):\n84:         \"\"\"Test bootstrap with HTTP error.\"\"\"\n85:         client = AgentRuntimeDataPlaneClient(\n86:             router_url=\"http://router\",\n87:             namespace=\"default\",\n88:             agent_name=\"test-agent\"\n89:         )\n90: \n91:         client.session.get = MagicMock(side_effect=requests.exceptions.HTTPError())\n92: \n93:         with pytest.raises(requests.exceptions.HTTPError):\n94:             client.bootstrap_session_id()\n95: \n96: \n97: class TestAgentRuntimeDataPlaneClientInvoke:\n98:     \"\"\"Tests for AgentRuntimeDataPlaneClient.invoke method.\"\"\"\n99: \n100:     def test_invoke_success(self):\n101:         \"\"\"Test successful invocation.\"\"\"\n102:         client = AgentRuntimeDataPlaneClient(\n103:             router_url=\"http://router\",\n104:             namespace=\"default\",\n105:             agent_name=\"test-agent\"\n106:         )\n107: \n108:         mock_response = MagicMock()\n109:         mock_response.raise_for_status = MagicMock()\n110:         client.session.post = MagicMock(return_value=mock_response)\n111: \n112:         response = client.invoke(\n113:             session_id=\"test-session\",\n114:             payload={\"key\": \"value\"}\n115:         )\n116: \n117:         assert response == mock_response\n118:         client.session.post.assert_called_once()\n119: \n120:     def test_invoke_sets_session_header(self):\n121:         \"\"\"Test that session header is set.\"\"\"\n122:         client = AgentRuntimeDataPlaneClient(\n123:             router_url=\"http://router\",\n124:             namespace=\"default\",\n125:             agent_name=\"test-agent\"\n126:         )\n127: \n128:         mock_response = MagicMock()\n129:         mock_response.raise_for_status = MagicMock()\n130:         client.session.post = MagicMock(return_value=mock_response)\n131: \n132:         client.invoke(\n133:             session_id=\"test-session\",\n134:             payload={\"key\": \"value\"}\n135:         )\n136: \n137:         assert client.session.headers.get(\"x-agentcube-session-id\") == \"test-session\"\n138: \n139:     def test_invoke_sets_content_type(self):\n140:         \"\"\"Test that content type is set.\"\"\"\n141:         client = AgentRuntimeDataPlaneClient(\n142:             router_url=\"http://router\",\n143:             namespace=\"default\",\n144:             agent_name=\"test-agent\"\n145:         )\n146: \n147:         mock_response = MagicMock()\n148:         mock_response.raise_for_status = MagicMock()\n149:         client.session.post = MagicMock(return_value=mock_response)\n150: \n151:         client.invoke(\n152:             session_id=\"test-session\",\n153:             payload={\"key\": \"value\"}\n154:         )\n155: \n156:         assert client.session.headers.get(\"Content-Type\") == \"application/json\"\n157: \n158:     def test_invoke_with_timeout(self):\n159:         \"\"\"Test invocation with custom timeout.\"\"\"\n160:         client = AgentRuntimeDataPlaneClient(\n161:             router_url=\"http://router\",\n162:             namespace=\"default\",\n163:             agent_name=\"test-agent\"\n164:         )\n165: \n166:         mock_response = MagicMock()\n167:         mock_response.raise_for_status = MagicMock()\n168:         client.session.post = MagicMock(return_value=mock_response)\n169: \n170:         client.invoke(\n171:             session_id=\"test-session\",\n172:             payload={\"key\": \"value\"},\n173:             timeout=60\n174:         )\n175: \n176:         call_kwargs = client.session.post.call_args[1]\n177:         assert call_kwargs[\"timeout\"] == (5.0, 60)\n178: \n179: \n180: class TestAgentRuntimeDataPlaneClientClose:\n181:     \"\"\"Tests for AgentRuntimeDataPlaneClient.close method.\"\"\"\n182: \n183:     def test_close(self):\n184:         \"\"\"Test closing the client.\"\"\"\n185:         client = AgentRuntimeDataPlaneClient(\n186:             router_url=\"http://router\",\n187:             namespace=\"default\",\n188:             agent_name=\"test-agent\"\n189:         )\n190: \n191:         client.session.close = MagicMock()\n192:         client.close()\n193: \n194:         client.session.close.assert_called_once()\n195: \n196:     def test_session_header_constant(self):\n197:         \"\"\"Test that SESSION_HEADER constant is defined correctly.\"\"\"\n198:         assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n\n(End of file - total 198 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentRuntimeDataPlaneClient.\"\"\"\n\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\nimport requests\n\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n\n\nclass TestAgentRuntimeDataPlaneClientInit:\n    \"\"\"Tests for AgentRuntimeDataPlaneClient initialization.\"\"\"\n\n    def test_init_sets_base_url(self):\n        \"\"\"Test that base URL is constructed correctly.\"\"\"\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router\",\n            namespace=\"default\",\n            agent_name=\"test-agent\"\n        )","truncated":false,"loaded":[]},"title":"sdk-python/tests/test_agent_runtime_data_plane.py","time":{"start":1775892470818,"end":1775892470823}}}}
{"type":"tool_use","timestamp":1775892471447,"sessionID":"ses_284909cb8ffeOsd4or1kukodLL","part":{"id":"prt_d7b709cf2001PleQL9kgkjngwQ","messageID":"msg_d7b7083fc001DCY0X21s53GkBA","sessionID":"ses_284909cb8ffeOsd4or1kukodLL","type":"tool","tool":"read","callID":"call_1634f0daccbb4b23963501c2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/sdk-python/tests/test_exceptions.py"},"output":"<path>/home/dsj/benchmark/sdk-python/tests/test_exceptions.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for AgentCube SDK exceptions.\"\"\"\n2: \n3: import pytest\n4: from agentcube.exceptions import (\n5:     AgentCubeError,\n6:     CommandExecutionError,\n7:     SessionError,\n8:     DataPlaneError,\n9: )\n10: \n11: \n12: class TestAgentCubeError:\n13:     \"\"\"Tests for AgentCubeError base exception.\"\"\"\n14: \n15:     def test_agent_cube_error_can_be_raised(self):\n16:         \"\"\"Test that AgentCubeError can be raised.\"\"\"\n17:         with pytest.raises(AgentCubeError):\n18:             raise AgentCubeError(\"Test error\")\n19: \n20:     def test_agent_cube_error_message(self):\n21:         \"\"\"Test that AgentCubeError stores message correctly.\"\"\"\n22:         error = AgentCubeError(\"Test error message\")\n23:         assert str(error) == \"Test error message\"\n24: \n25: \n26: class TestCommandExecutionError:\n27:     \"\"\"Tests for CommandExecutionError exception.\"\"\"\n28: \n29:     def test_command_execution_error_basic(self):\n30:         \"\"\"Test basic CommandExecutionError creation.\"\"\"\n31:         error = CommandExecutionError(\n32:             exit_code=1,\n33:             stderr=\"Error output\",\n34:             command=\"ls -la\"\n35:         )\n36:         assert error.exit_code == 1\n37:         assert error.stderr == \"Error output\"\n38:         assert error.command == \"ls -la\"\n39: \n40:     def test_command_execution_error_message(self):\n41:         \"\"\"Test CommandExecutionError message format.\"\"\"\n42:         error = CommandExecutionError(\n43:             exit_code=2,\n44:             stderr=\"File not found\",\n45:         )\n46:         assert \"exit 2\" in str(error)\n47:         assert \"File not found\" in str(error)\n48: \n49:     def test_command_execution_error_without_command(self):\n50:         \"\"\"Test CommandExecutionError with None command.\"\"\"\n51:         error = CommandExecutionError(\n52:             exit_code=1,\n53:             stderr=\"Error\",\n54:             command=None\n55:         )\n56:         assert error.command is None\n57: \n58:     def test_command_execution_error_is_agent_cube_error(self):\n59:         \"\"\"Test that CommandExecutionError is subclass of AgentCubeError.\"\"\"\n60:         error = CommandExecutionError(exit_code=1, stderr=\"Error\")\n61:         assert isinstance(error, AgentCubeError)\n62: \n63:     def test_command_execution_error_can_be_caught_as_agent_cube_error(self):\n64:         \"\"\"Test that CommandExecutionError can be caught as AgentCubeError.\"\"\"\n65:         with pytest.raises(AgentCubeError):\n66:             raise CommandExecutionError(exit_code=1, stderr=\"Error\")\n67: \n68: \n69: class TestSessionError:\n70:     \"\"\"Tests for SessionError exception.\"\"\"\n71: \n72:     def test_session_error_can_be_raised(self):\n73:         \"\"\"Test that SessionError can be raised.\"\"\"\n74:         with pytest.raises(SessionError):\n75:             raise SessionError(\"Session failed\")\n76: \n77:     def test_session_error_message(self):\n78:         \"\"\"Test that SessionError stores message correctly.\"\"\"\n79:         error = SessionError(\"Session creation failed\")\n80:         assert str(error) == \"Session creation failed\"\n81: \n82:     def test_session_error_is_agent_cube_error(self):\n83:         \"\"\"Test that SessionError is subclass of AgentCubeError.\"\"\"\n84:         error = SessionError(\"Error\")\n85:         assert isinstance(error, AgentCubeError)\n86: \n87: \n88: class TestDataPlaneError:\n89:     \"\"\"Tests for DataPlaneError exception.\"\"\"\n90: \n91:     def test_data_plane_error_can_be_raised(self):\n92:         \"\"\"Test that DataPlaneError can be raised.\"\"\"\n93:         with pytest.raises(DataPlaneError):\n94:             raise DataPlaneError(\"Data plane failed\")\n95: \n96:     def test_data_plane_error_message(self):\n97:         \"\"\"Test that DataPlaneError stores message correctly.\"\"\"\n98:         error = DataPlaneError(\"Operation failed\")\n99:         assert str(error) == \"Operation failed\"\n100: \n101:     def test_data_plane_error_is_agent_cube_error(self):\n102:         \"\"\"Test that DataPlaneError is subclass of AgentCubeError.\"\"\"\n103:         error = DataPlaneError(\"Error\")\n104:         assert isinstance(error, AgentCubeError)\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentCube SDK exceptions.\"\"\"\n\nimport pytest\nfrom agentcube.exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    SessionError,\n    DataPlaneError,\n)\n\n\nclass TestAgentCubeError:\n    \"\"\"Tests for AgentCubeError base exception.\"\"\"\n\n    def test_agent_cube_error_can_be_raised(self):\n        \"\"\"Test that AgentCubeError can be raised.\"\"\"\n        with pytest.raises(AgentCubeError):\n            raise AgentCubeError(\"Test error\")\n\n    def test_agent_cube_error_message(self):","truncated":false,"loaded":[]},"title":"sdk-python/tests/test_exceptions.py","time":{"start":1775892471441,"end":1775892471446}}}}
{"type":"tool_use","timestamp":1775892472066,"sessionID":"ses_284909cb8ffeOsd4or1kukodLL","part":{"id":"prt_d7b709f14001EbVcuRyKkPIBS5","messageID":"msg_d7b7083fc001DCY0X21s53GkBA","sessionID":"ses_284909cb8ffeOsd4or1kukodLL","type":"tool","tool":"read","callID":"call_40b1f5a373324985a454b97c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/sdk-python/tests/test_utils.py"},"output":"<path>/home/dsj/benchmark/sdk-python/tests/test_utils.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for AgentCube SDK utility functions.\"\"\"\n2: \n3: import logging\n4: import os\n5: import tempfile\n6: from unittest.mock import patch, MagicMock\n7: \n8: import pytest\n9: import requests\n10: \n11: from agentcube.utils.log import get_logger\n12: from agentcube.utils.utils import read_token_from_file\n13: from agentcube.utils.http import create_session\n14: \n15: \n16: class TestGetLogger:\n17:     \"\"\"Tests for get_logger function.\"\"\"\n18: \n19:     def test_get_logger_creates_logger(self):\n20:         \"\"\"Test that get_logger creates a logger.\"\"\"\n21:         logger = get_logger(\"test_logger\")\n22:         assert logger is not None\n23:         assert logger.name == \"test_logger\"\n24: \n25:     def test_get_logger_level_default(self):\n26:         \"\"\"Test that get_logger uses default INFO level.\"\"\"\n27:         logger = get_logger(\"test_logger_default\")\n28:         assert logger.level == logging.INFO\n29: \n30:     def test_get_logger_level_custom(self):\n31:         \"\"\"Test that get_logger uses custom level.\"\"\"\n32:         logger = get_logger(\"test_logger_debug\", level=logging.DEBUG)\n33:         assert logger.level == logging.DEBUG\n34: \n35:     def test_get_logger_level_string(self):\n36:         \"\"\"Test that get_logger accepts string level.\"\"\"\n37:         logger = get_logger(\"test_logger_string\", level=\"DEBUG\")\n38:         assert logger.level == logging.DEBUG\n39: \n40:     def test_get_logger_has_handler(self):\n41:         \"\"\"Test that get_logger adds a handler.\"\"\"\n42:         logger = get_logger(\"test_logger_handler\")\n43:         assert len(logger.handlers) > 0\n44: \n45:     def test_get_logger_multiple_calls_same_logger(self):\n46:         \"\"\"Test that multiple calls return same logger but don't add duplicate handlers.\"\"\"\n47:         logger1 = get_logger(\"test_logger_multi\")\n48:         logger2 = get_logger(\"test_logger_multi\")\n49:         assert logger1 is logger2\n50: \n51: \n52: class TestReadTokenFromFile:\n53:     \"\"\"Tests for read_token_from_file function.\"\"\"\n54: \n55:     def test_read_token_from_file_success(self):\n56:         \"\"\"Test reading token from existing file.\"\"\"\n57:         with tempfile.NamedTemporaryFile(mode='w', delete=False) as f:\n58:             f.write(\"test-token-123\\n\")\n59:             temp_path = f.name\n60: \n61:         try:\n62:             token = read_token_from_file(temp_path)\n63:             assert token == \"test-token-123\"\n64:         finally:\n65:             os.unlink(temp_path)\n66: \n67:     def test_read_token_from_file_strips_whitespace(self):\n68:         \"\"\"Test that read_token_from_file strips whitespace.\"\"\"\n69:         with tempfile.NamedTemporaryFile(mode='w', delete=False) as f:\n70:             f.write(\"  token-with-spaces  \\n\")\n71:             temp_path = f.name\n72: \n73:         try:\n74:             token = read_token_from_file(temp_path)\n75:             assert token == \"token-with-spaces\"\n76:         finally:\n77:             os.unlink(temp_path)\n78: \n79:     def test_read_token_from_file_not_found(self):\n80:         \"\"\"Test that read_token_from_file returns empty string for missing file.\"\"\"\n81:         token = read_token_from_file(\"/nonexistent/path/token\")\n82:         assert token == \"\"\n83: \n84:     def test_read_token_from_file_empty_file(self):\n85:         \"\"\"Test reading from empty file.\"\"\"\n86:         with tempfile.NamedTemporaryFile(mode='w', delete=False) as f:\n87:             temp_path = f.name\n88: \n89:         try:\n90:             token = read_token_from_file(temp_path)\n91:             assert token == \"\"\n92:         finally:\n93:             os.unlink(temp_path)\n94: \n95: \n96: class TestCreateSession:\n97:     \"\"\"Tests for create_session function.\"\"\"\n98: \n99:     def test_create_session_creates_session(self):\n100:         \"\"\"Test that create_session creates a requests Session.\"\"\"\n101:         session = create_session()\n102:         assert isinstance(session, requests.Session)\n103: \n104:     def test_create_session_default_pool_size(self):\n105:         \"\"\"Test create_session with default pool sizes.\"\"\"\n106:         session = create_session()\n107:         adapter = session.get_adapter('https://')\n108:         assert adapter is not None\n109: \n110:     def test_create_session_custom_pool_size(self):\n111:         \"\"\"Test create_session with custom pool sizes.\"\"\"\n112:         session = create_session(pool_connections=20, pool_maxsize=30)\n113:         assert isinstance(session, requests.Session)\n114: \n115:     def test_create_session_has_http_adapter(self):\n116:         \"\"\"Test that created session has HTTP adapters mounted.\"\"\"\n117:         session = create_session()\n118:         assert session.get_adapter('http://') is not None\n119:         assert session.get_adapter('https://') is not None\n\n(End of file - total 119 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentCube SDK utility functions.\"\"\"\n\nimport logging\nimport os\nimport tempfile\nfrom unittest.mock import patch, MagicMock\n\nimport pytest\nimport requests\n\nfrom agentcube.utils.log import get_logger\nfrom agentcube.utils.utils import read_token_from_file\nfrom agentcube.utils.http import create_session\n\n\nclass TestGetLogger:\n    \"\"\"Tests for get_logger function.\"\"\"\n\n    def test_get_logger_creates_logger(self):\n        \"\"\"Test that get_logger creates a logger.\"\"\"","truncated":false,"loaded":[]},"title":"sdk-python/tests/test_utils.py","time":{"start":1775892472058,"end":1775892472065}}}}
{"type":"tool_use","timestamp":1775892472677,"sessionID":"ses_284909cb8ffeOsd4or1kukodLL","part":{"id":"prt_d7b70a178001UDc5fRFZoFGZHp","messageID":"msg_d7b7083fc001DCY0X21s53GkBA","sessionID":"ses_284909cb8ffeOsd4or1kukodLL","type":"tool","tool":"read","callID":"call_9b21d97056224274ad0624a4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/sdk-python/tests/README.md"},"output":"<path>/home/dsj/benchmark/sdk-python/tests/README.md</path>\n<type>file</type>\n<content>\n1: # AgentCube SDK Tests\n2: \n3: This directory contains unit tests for the AgentCube Python SDK.\n4: \n5: ## Running Tests\n6: \n7: ```bash\n8: cd sdk-python\n9: pip install -e .\n10: pip install pytest pytest-cov\n11: pytest tests/\n12: ```\n13: \n14: ## Test Files\n15: \n16: - `test_exceptions.py` - Tests for exception hierarchy\n17: - `test_utils.py` - Tests for utility functions\n18: - `test_control_plane.py` - Tests for ControlPlaneClient\n19: - `test_code_interpreter_data_plane.py` - Tests for CodeInterpreterDataPlaneClient\n20: - `test_agent_runtime_data_plane.py` - Tests for AgentRuntimeDataPlaneClient\n21: - `test_code_interpreter_client.py` - Tests for CodeInterpreterClient\n22: - `test_agent_runtime_client.py` - Tests for AgentRuntimeClient\n\n(End of file - total 22 lines)\n</content>","metadata":{"preview":"# AgentCube SDK Tests\n\nThis directory contains unit tests for the AgentCube Python SDK.\n\n## Running Tests\n\n```bash\ncd sdk-python\npip install -e .\npip install pytest pytest-cov\npytest tests/\n```\n\n## Test Files\n\n- `test_exceptions.py` - Tests for exception hierarchy\n- `test_utils.py` - Tests for utility functions\n- `test_control_plane.py` - Tests for ControlPlaneClient\n- `test_code_interpreter_data_plane.py` - Tests for CodeInterpreterDataPlaneClient\n- `test_agent_runtime_data_plane.py` - Tests for AgentRuntimeDataPlaneClient","truncated":false,"loaded":[]},"title":"sdk-python/tests/README.md","time":{"start":1775892472670,"end":1775892472675}}}