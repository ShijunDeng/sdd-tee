       assert client.router_url == \"http://env-router\"\n35: \n36:     def test_init_default_values(self):\n37:         \"\"\"Test initialization with default values.\"\"\"\n38:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n39:             with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"):\n40:                 client = AgentRuntimeClient(agent_name=\"test-agent\")\n41:                 assert client.agent_name == \"test-agent\"\n42:                 assert client.namespace == \"default\"\n43:                 assert client.timeout == 120\n44:                 assert client.connect_timeout == 5.0\n45: \n46:     def test_init_custom_values(self):\n47:         \"\"\"Test initialization with custom values.\"\"\"\n48:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n49:             with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"):\n50:                 client = AgentRuntimeClient(\n51:                     agent_name=\"test-agent\",\n52:                     namespace=\"custom-ns\",\n53:                     timeout=60,\n54:                     connect_timeout=3.0\n55:                 )\n56:                 assert client.namespace == \"custom-ns\"\n57:                 assert client.timeout == 60\n58:                 assert client.connect_timeout == 3.0\n59: \n60:     def test_init_bootstraps_session_id(self):\n61:         \"\"\"Test that initialization bootstraps session ID.\"\"\"\n62:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n63:             with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp:\n64:                 mock_dp.return_value.bootstrap_session_id = MagicMock(\n65:                     return_value=\"bootstrapped-session\"\n66:                 )\n67:                 client = AgentRuntimeClient(agent_name=\"test-agent\")\n68:                 assert client.session_id == \"bootstrapped-session\"\n69:                 mock_dp.return_value.bootstrap_session_id.assert_called_once()\n70: \n71:     def test_init_with_existing_session_id(self):\n72:         \"\"\"Test initialization with existing session ID.\"\"\"\n73:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n74:             with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp:\n75:                 client = AgentRuntimeClient(\n76:                     agent_name=\"test-agent\",\n77:                     session_id=\"existing-session\"\n78:                 )\n79:                 assert client.session_id == \"existing-session\"\n80:                 mock_dp.return_value.bootstrap_session_id.assert_not_called()\n81: \n82: \n83: class TestAgentRuntimeClientContextManager:\n84:     \"\"\"Tests for AgentRuntimeClient context manager.\"\"\"\n85: \n86:     def test_context_manager_enter(self):\n87:         \"\"\"Test context manager entry.\"\"\"\n88:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n89:             with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"):\n90:                 with AgentRuntimeClient(agent_name=\"test-agent\") as client:\n91:                     assert client is not None\n92: \n93:     def test_context_manager_exit_calls_close(self):\n94:         \"\"\"Test that context manager exit calls close.\"\"\"\n95:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://router\"}):\n96:             with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp:\n97:                 client = AgentRuntimeClient(agent_name=\"test-agent\")\n98:                 client.dp_client = mock_dp.return_value\n99:                 client.dp_client.close = MagicMock()\n100: \n101:                 client.close()\n102: \n103:                 client.dp_client.close.assert_called_once()\n104: \n105: \n106: class TestAgentRuntimeClientInvoke:\n107:     \"\"\"Tests for AgentRuntimeClient.invoke method.\"\"\"\n108: \n109:     def test