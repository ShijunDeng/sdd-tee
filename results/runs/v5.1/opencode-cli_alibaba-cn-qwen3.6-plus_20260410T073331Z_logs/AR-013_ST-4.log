{"type":"tool_use","timestamp":1775834891025,"sessionID":"ses_2880187b1ffeUWngSS3Bdj3DMX","part":{"id":"prt_d780201eb001pxbefYNXtidrgJ","messageID":"msg_d7801e483001arvnZSHGX4baPT","sessionID":"ses_2880187b1ffeUWngSS3Bdj3DMX","type":"tool","tool":"read","callID":"call_f1edeee2833447acb5eeb35b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"errors\"\n6: \t\"time\"\n7: \n8: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n9: \t\"k8s.io/klog/v2\"\n10: )\n11: \n12: var ErrNotFound = errors.New(\"sandbox not found\")\n13: \n14: type Store interface {\n15: \tStoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error\n16: \tUpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error\n17: \tDeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n18: \tGetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n19: \tListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error)\n20: \tUpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n21: \n22: \tListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)\n23: \tListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)\n24: \tPing(ctx context.Context) error\n25: \tClose() error\n26: }\n27: \n28: func Storage() Store {\n29: \tinitStoreOnce.Do(func() {\n30: \t\tif err := initStore(); err != nil {\n31: \t\t\tklog.Fatalf(\"init store failed: %v\", err)\n32: \t\t}\n33: \t})\n34: \treturn storeInstance\n35: }\n\n(End of file - total 35 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\nvar ErrNotFound = errors.New(\"sandbox not found\")\n\ntype Store interface {\n\tStoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error\n\tUpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error\n\tDeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n\tGetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n\tListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error)\n\tUpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store.go","time":{"start":1775834891019,"end":1775834891024}}}}
{"type":"tool_use","timestamp":1775834892275,"sessionID":"ses_2880187b1ffeUWngSS3Bdj3DMX","part":{"id":"prt_d7802038c001nJ1y3Xoog03uyY","messageID":"msg_d7801e483001arvnZSHGX4baPT","sessionID":"ses_2880187b1ffeUWngSS3Bdj3DMX","type":"tool","tool":"read","callID":"call_b083cb74e06140d895c8c2ef","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"os\"\n7: \t\"strconv\"\n8: \t\"time\"\n9: \n10: \t\"github.com/redis/go-redis/v9\"\n11: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n12: \t\"k8s.io/klog/v2\"\n13: )\n14: \n15: type redisStore struct {\n16: \tcli                  redis.UniversalClient\n17: \tsessionPrefix        string\n18: \texpiryIndexKey       string\n19: \tlastActivityIndexKey string\n20: }\n21: \n22: func newRedisStore() Store {\n23: \taddr := os.Getenv(\"REDIS_ADDR\")\n24: \tif addr == \"\" {\n25: \t\tklog.Fatal(\"REDIS_ADDR environment variable is not set\")\n26: \t}\n27: \n28: \tpassword := os.Getenv(\"REDIS_PASSWORD\")\n29: \tpasswordRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n30: \tif passwordRequired != \"false\" && password == \"\" {\n31: \t\tklog.Fatal(\"REDIS_PASSWORD is required (set REDIS_PASSWORD_REQUIRED=false to disable)\")\n32: \t}\n33: \n34: \topts := &redis.Options{\n35: \t\tAddr:     addr,\n36: \t\tPassword: password,\n37: \t}\n38: \n39: \tcli := redis.NewClient(opts)\n40: \n41: \treturn &redisStore{\n42: \t\tcli:                  cli,\n43: \t\tsessionPrefix:        \"session:\",\n44: \t\texpiryIndexKey:       \"session:expiry\",\n45: \t\tlastActivityIndexKey: \"session:last_activity\",\n46: \t}\n47: }\n48: \n49: func (r *redisStore) Ping(ctx context.Context) error {\n50: \tpong, err := r.cli.Ping(ctx).Result()\n51: \tif err != nil {\n52: \t\treturn err\n53: \t}\n54: \tif pong != \"PONG\" {\n55: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n56: \t}\n57: \treturn nil\n58: }\n59: \n60: func (r *redisStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n61: \tkey := r.sessionPrefix + sessionID\n62: \tdata, err := r.cli.Get(ctx, key).Bytes()\n63: \tif err == redis.Nil {\n64: \t\treturn nil, ErrNotFound\n65: \t}\n66: \tif err != nil {\n67: \t\treturn nil, err\n68: \t}\n69: \treturn decodeSandboxInfo(data)\n70: }\n71: \n72: func (r *redisStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n73: \tif info == nil {\n74: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n75: \t}\n76: \n77: \tdata, err := encodeSandboxInfo(info)\n78: \tif err != nil {\n79: \t\treturn err\n80: \t}\n81: \n82: \tkey := r.sessionPrefix + sessionID\n83: \texpiryScore := float64(info.ExpiresAt.Unix())\n84: \tlastActivityScore := float64(info.LastActivityAt.Unix())\n85: \n86: \tpipe := r.cli.Pipeline()\n87: \tpipe.SetNX(ctx, key, data, 0)\n88: \tpipe.ZAdd(ctx, r.expiryIndexKey, redis.Z{Score: expiryScore, Member: sessionID})\n89: \tpipe.ZAdd(ctx, r.lastActivityIndexKey, redis.Z{Score: lastActivityScore, Member: sessionID})\n90: \n91: \t_, err = pipe.Exec(ctx)\n92: \treturn err\n93: }\n94: \n95: func (r *redisStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n96: \tif info == nil {\n97: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n98: \t}\n99: \n100: \tdata, err := encodeSandboxInfo(info)\n101: \tif err != nil {\n102: \t\treturn err\n103: \t}\n104: \n105: \tkey := r.sessionPrefix + sessionID\n106: \tresult, err := r.cli.SetXX(ctx, key, data, 0).Result()\n107: \tif err != nil {\n108: \t\treturn err\n109: \t}\n110: \tif !result {\n111: \t\treturn fmt.Errorf(\"key %s does not exist\", key)\n112: \t}\n113: \treturn nil\n114: }\n115: \n116: func (r *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n117: \tkey := r.sessionPrefix + sessionID\n118: \n119: \tpipe := r.cli.Pipeline()\n120: \tpipe.Del(ctx, key)\n121: \tpipe.ZRem(ctx, r.expiryIndexKey, sessionID)\n122: \tpipe.ZRem(ctx, r.lastActivityIndexKey, sessionID)\n123: \n124: \t_, err := pipe.Exec(ctx)\n125: \treturn err\n126: }\n127: \n128: func (r *redisStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n129: \tsessionIDs, err := r.cli.ZRange(ctx, r.expiryIndexKey, 0, -1).Result()\n130: \tif err != nil {\n131: \t\treturn nil, err\n132: \t}\n133: \n134: \tresult := make(map[string]*types.SandboxInfo)\n135: \tfor _, id := range sessionIDs {\n136: \t\tinfo, err := r.GetSandbox(ctx, id)\n137: \t\tif err != nil {\n138: \t\t\tif err == ErrNotFound {\n139: \t\t\t\tcontinue\n140: \t\t\t}\n141: \t\t\treturn nil, err\n142: \t\t}\n143: \t\tresult[id] = info\n144: \t}\n145: \n146: \treturn result, nil\n147: }\n148: \n149: func (r *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n150: \tif sessionID == \"\" {\n151: \t\treturn fmt.Errorf(\"sessionID cannot be empty\")\n152: \t}\n153: \n154: \tif at.IsZero() {\n155: \t\tat = time.Now()\n156: \t}\n157: \n158: \tkey := r.sessionPrefix + sessionID\n159: \texists, err := r.cli.Exists(ctx, key).Result()\n160: \tif err != nil {\n161: \t\treturn err\n162: \t}\n163: \tif exists == 0 {\n164: \t\treturn ErrNotFound\n165: \t}\n166: \n167: \tscore := float64(at.Unix())\n168: \treturn r.cli.ZAdd(ctx, r.lastActivityIndexKey, redis.Z{Score: score, Member: sessionID}).Err()\n169: }\n170: \n171: func (r *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n172: \tif limit <= 0 {\n173: \t\treturn nil, nil\n174: \t}\n175: \n176: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n177: \tsessionIDs, err := r.cli.ZRangeByScore(ctx, r.expiryIndexKey, &redis.ZRangeBy{\n178: \t\tMin:    \"-inf\",\n179: \t\tMax:    maxScore,\n180: \t\tOffset: 0,\n181: \t\tCount:  int64(limit),\n182: \t}).Result()\n183: \tif err != nil {\n184: \t\treturn nil, err\n185: \t}\n186: \n187: \tvar result []*types.SandboxInfo\n188: \tfor _, id := range sessionIDs {\n189: \t\tinfo, err := r.GetSandbox(ctx, id)\n190: \t\tif err != nil {\n191: \t\t\tif err == ErrNotFound {\n192: \t\t\t\tcontinue\n193: \t\t\t}\n194: \t\t\treturn nil, err\n195: \t\t}\n196: \t\tresult = append(result, info)\n197: \t}\n198: \n199: \treturn result, nil\n200: }\n201: \n202: func (r *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n203: \tif limit <= 0 {\n204: \t\treturn nil, nil\n205: \t}\n206: \n207: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n208: \tsessionIDs, err := r.cli.ZRangeByScore(ctx, r.lastActivityIndexKey, &redis.ZRangeBy{\n209: \t\tMin:    \"-inf\",\n210: \t\tMax:    maxScore,\n211: \t\tOffset: 0,\n212: \t\tCount:  int64(limit),\n213: \t}).Result()\n214: \tif err != nil {\n215: \t\treturn nil, err\n216: \t}\n217: \n218: \tvar result []*types.SandboxInfo\n219: \tfor _, id := range sessionIDs {\n220: \t\tinfo, err := r.GetSandbox(ctx, id)\n221: \t\tif err != nil {\n222: \t\t\tif err == ErrNotFound {\n223: \t\t\t\tcontinue\n224: \t\t\t}\n225: \t\t\treturn nil, err\n226: \t\t}\n227: \t\tresult = append(result, info)\n228: \t}\n229: \n230: \treturn result, nil\n231: }\n232: \n233: func (r *redisStore) Close() error {\n234: \treturn r.cli.Close()\n235: }\n\n(End of file - total 235 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  redis.UniversalClient\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go","time":{"start":1775834892259,"end":1775834892272}}}}
{"type":"tool_use","timestamp":1775834892970,"sessionID":"ses_2880187b1ffeUWngSS3Bdj3DMX","part":{"id":"prt_d780208a80016D9D8hbFlQx8TK","messageID":"msg_d7801e483001arvnZSHGX4baPT","sessionID":"ses_2880187b1ffeUWngSS3Bdj3DMX","type":"tool","tool":"read","callID":"call_0fade6e4efc343c4a1f31c9d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis_test.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"testing\"\n6: \t\"time\"\n7: \n8: \t\"github.com/alicebob/miniredis/v2\"\n9: \t\"github.com/redis/go-redis/v9\"\n10: \t\"github.com/stretchr/testify/assert\"\n11: \t\"github.com/stretchr/testify/require\"\n12: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n13: )\n14: \n15: func newTestRedisStore(t *testing.T) (*redisStore, *miniredis.Miniredis) {\n16: \tt.Helper()\n17: \tmr, err := miniredis.Run()\n18: \trequire.NoError(t, err)\n19: \tt.Cleanup(func() { mr.Close() })\n20: \n21: \tcli := redis.NewClient(&redis.Options{\n22: \t\tAddr: mr.Addr(),\n23: \t})\n24: \tt.Cleanup(func() { cli.Close() })\n25: \n26: \treturn &redisStore{\n27: \t\tcli:                  cli,\n28: \t\tsessionPrefix:        \"session:\",\n29: \t\texpiryIndexKey:       \"session:expiry\",\n30: \t\tlastActivityIndexKey: \"session:last_activity\",\n31: \t}, mr\n32: }\n33: \n34: func testSandboxInfo(sessionID string) *types.SandboxInfo {\n35: \tnow := time.Now().UTC()\n36: \treturn &types.SandboxInfo{\n37: \t\tSessionID:      sessionID,\n38: \t\tSandboxName:    \"test-sandbox\",\n39: \t\tSandboxID:      \"sb-123\",\n40: \t\tWorkloadName:   \"agent-runtime\",\n41: \t\tNamespace:      \"default\",\n42: \t\tKind:           \"AgentRuntime\",\n43: \t\tPodIP:          \"10.0.0.1\",\n44: \t\tEntryPoints:    []types.EntryPoint{{Path: \"/api\", Protocol: \"http\", Endpoint: \"http://10.0.0.1:8080\"}},\n45: \t\tCreatedAt:      now,\n46: \t\tExpiresAt:      now.Add(24 * time.Hour),\n47: \t\tStatus:         \"running\",\n48: \t\tLastActivityAt: now.Add(5 * time.Minute),\n49: \t}\n50: }\n51: \n52: func TestRedisStore_Ping(t *testing.T) {\n53: \tstore, _ := newTestRedisStore(t)\n54: \tctx := context.Background()\n55: \n56: \terr := store.Ping(ctx)\n57: \trequire.NoError(t, err)\n58: }\n59: \n60: func TestRedisStore_GetSandbox_NotFound(t *testing.T) {\n61: \tstore, _ := newTestRedisStore(t)\n62: \tctx := context.Background()\n63: \n64: \tresult, err := store.GetSandbox(ctx, \"nonexistent\")\n65: \tassert.ErrorIs(t, err, ErrNotFound)\n66: \tassert.Nil(t, result)\n67: }\n68: \n69: func TestRedisStore_StoreSandbox_NilInfo(t *testing.T) {\n70: \tstore, _ := newTestRedisStore(t)\n71: \tctx := context.Background()\n72: \n73: \terr := store.StoreSandbox(ctx, \"sess-001\", nil)\n74: \trequire.Error(t, err)\n75: \tassert.Contains(t, err.Error(), \"sandbox info cannot be nil\")\n76: }\n77: \n78: func TestRedisStore_StoreSandbox_Success(t *testing.T) {\n79: \tstore, mr := newTestRedisStore(t)\n80: \tctx := context.Background()\n81: \tinfo := testSandboxInfo(\"sess-001\")\n82: \n83: \terr := store.StoreSandbox(ctx, \"sess-001\", info)\n84: \trequire.NoError(t, err)\n85: \n86: \tdata, err := mr.Get(\"session:sess-001\")\n87: \trequire.NoError(t, err)\n88: \trequire.NotEmpty(t, data)\n89: \n90: \texpiryMembers, err := mr.ZMembers(\"session:expiry\")\n91: \trequire.NoError(t, err)\n92: \tassert.Contains(t, expiryMembers, \"sess-001\")\n93: \n94: \tactivityMembers, err := mr.ZMembers(\"session:last_activity\")\n95: \trequire.NoError(t, err)\n96: \tassert.Contains(t, activityMembers, \"sess-001\")\n97: }\n98: \n99: func TestRedisStore_StoreSandbox_RoundTrip(t *testing.T) {\n100: \tstore, _ := newTestRedisStore(t)\n101: \tctx := context.Background()\n102: \tinfo := testSandboxInfo(\"sess-002\")\n103: \n104: \terr := store.StoreSandbox(ctx, \"sess-002\", info)\n105: \trequire.NoError(t, err)\n106: \n107: \tresult, err := store.GetSandbox(ctx, \"sess-002\")\n108: \trequire.NoError(t, err)\n109: \trequire.NotNil(t, result)\n110: \n111: \tassert.Equal(t, info.SessionID, result.SessionID)\n112: \tassert.Equal(t, info.SandboxName, result.SandboxName)\n113: \tassert.Equal(t, info.SandboxID, result.SandboxID)\n114: \tassert.Equal(t, info.Namespace, result.Namespace)\n115: \tassert.Equal(t, info.Kind, result.Kind)\n116: \tassert.Equal(t, info.Status, result.Status)\n117: \tassert.Equal(t, info.PodIP, result.PodIP)\n118: \tassert.Len(t, result.EntryPoints, len(info.EntryPoints))\n119: }\n120: \n121: func TestRedisStore_UpdateSandbox_NilInfo(t *testing.T) {\n122: \tstore, _ := newTestRedisStore(t)\n123: \tctx := context.Background()\n124: \n125: \terr := store.UpdateSandbox(ctx, \"sess-001\", nil)\n126: \trequire.Error(t, err)\n127: \tassert.Contains(t, err.Error(), \"sandbox info cannot be nil\")\n128: }\n129: \n130: func TestRedisStore_UpdateSandbox_KeyNotExists(t *testing.T) {\n131: \tstore, _ := newTestRedisStore(t)\n132: \tctx := context.Background()\n133: \tinfo := testSandboxInfo(\"sess-003\")\n134: \n135: \terr := store.UpdateSandbox(ctx, \"sess-003\", info)\n136: \trequire.Error(t, err)\n137: \tassert.Contains(t, err.Error(), \"does not exist\")\n138: }\n139: \n140: func TestRedisStore_UpdateSandbox_Success(t *testing.T) {\n141: \tstore, _ := newTestRedisStore(t)\n142: \tctx := context.Background()\n143: \tinfo := testSandboxInfo(\"sess-004\")\n144: \n145: \terr := store.StoreSandbox(ctx, \"sess-004\", info)\n146: \trequire.NoError(t, err)\n147: \n148: \tupdated := *info\n149: \tupdated.Status = \"updated\"\n150: \tupdated.PodIP = \"10.0.0.2\"\n151: \n152: \terr = store.UpdateSandbox(ctx, \"sess-004\", &updated)\n153: \trequire.NoError(t, err)\n154: \n155: \tresult, err := store.GetSandbox(ctx, \"sess-004\")\n156: \trequire.NoError(t, err)\n157: \tassert.Equal(t, \"updated\", result.Status)\n158: \tassert.Equal(t, \"10.0.0.2\", result.PodIP)\n159: }\n160: \n161: func TestRedisStore_DeleteSandboxBySessionID(t *testing.T) {\n162: \tstore, mr := newTestRedisStore(t)\n163: \tctx := context.Background()\n164: \tinfo := testSandboxInfo(\"sess-005\")\n165: \n166: \terr := store.StoreSandbox(ctx, \"sess-005\", info)\n167: \trequire.NoError(t, err)\n168: \n169: \terr = store.DeleteSandboxBySessionID(ctx, \"sess-005\")\n170: \trequire.NoError(t, err)\n171: \n172: \tresult, err := store.GetSandbox(ctx, \"sess-005\")\n173: \tassert.ErrorIs(t, err, ErrNotFound)\n174: \tassert.Nil(t, result)\n175: \n176: \texists := mr.Exists(\"session:sess-005\")\n177: \tassert.False(t, exists)\n178: \n179: \texpiryMembers, err := mr.ZMembers(\"session:expiry\")\n180: \trequire.NoError(t, err)\n181: \tassert.NotContains(t, expiryMembers, \"sess-005\")\n182: \n183: \tactivityMembers, err := mr.ZMembers(\"session:last_activity\")\n184: \trequire.NoError(t, err)\n185: \tassert.NotContains(t, activityMembers, \"sess-005\")\n186: }\n187: \n188: func TestRedisStore_ListSandboxes(t *testing.T) {\n189: \tstore, _ := newTestRedisStore(t)\n190: \tctx := context.Background()\n191: \n192: \tinfo1 := testSandboxInfo(\"sess-010\")\n193: \tinfo2 := testSandboxInfo(\"sess-011\")\n194: \n195: \terr := store.StoreSandbox(ctx, \"sess-010\", info1)\n196: \trequire.NoError(t, err)\n197: \terr = store.StoreSandbox(ctx, \"sess-011\", info2)\n198: \trequire.NoError(t, err)\n199: \n200: \tresult, err := store.ListSandboxes(ctx)\n201: \trequire.NoError(t, err)\n202: \tassert.Len(t, result, 2)\n203: \tassert.Contains(t, result, \"sess-010\")\n204: \tassert.Contains(t, result, \"sess-011\")\n205: }\n206: \n207: func TestRedisStore_ListSandboxes_OrphanZSETMember(t *testing.T) {\n208: \tstore, mr := newTestRedisStore(t)\n209: \tctx := context.Background()\n210: \n211: \tinfo := testSandboxInfo(\"sess-020\")\n212: \terr := store.StoreSandbox(ctx, \"sess-020\", info)\n213: \trequire.NoError(t, err)\n214: \n215: \tmr.Del(\"session:sess-020\")\n216: \n217: \tresult, err := store.ListSandboxes(ctx)\n218: \trequire.NoError(t, err)\n219: \tassert.Len(t, result, 0)\n220: }\n221: \n222: func TestRedisStore_ListSandboxes_Empty(t *testing.T) {\n223: \tstore, _ := newTestRedisStore(t)\n224: \tctx := context.Background()\n225: \n226: \tresult, err := store.ListSandboxes(ctx)\n227: \trequire.NoError(t, err)\n228: \tassert.Empty(t, result)\n229: }\n230: \n231: func TestRedisStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n232: \tstore, _ := newTestRedisStore(t)\n233: \tctx := context.Background()\n234: \n235: \terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n236: \trequire.Error(t, err)\n237: \tassert.Contains(t, err.Error(), \"sessionID cannot be empty\")\n238: }\n239: \n240: func TestRedisStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n241: \tstore, mr := newTestRedisStore(t)\n242: \tctx := context.Background()\n243: \tinfo := testSandboxInfo(\"sess-030\")\n244: \n245: \terr := store.StoreSandbox(ctx, \"sess-030\", info)\n246: \trequire.NoError(t, err)\n247: \n248: \tbefore := time.Now()\n249: \terr = store.UpdateSessionLastActivity(ctx, \"sess-030\", time.Time{})\n250: \trequire.NoError(t, err)\n251: \n252: \tscore, err := mr.ZScore(\"session:last_activity\", \"sess-030\")\n253: \trequire.NoError(t, err)\n254: \tassert.GreaterOrEqual(t, score, float64(before.Unix()))\n255: }\n256: \n257: func TestRedisStore_UpdateSessionLastActivity_NotFound(t *testing.T) {\n258: \tstore, _ := newTestRedisStore(t)\n259: \tctx := context.Background()\n260: \n261: \terr := store.UpdateSessionLastActivity(ctx, \"nonexistent\", time.Now())\n262: \tassert.ErrorIs(t, err, ErrNotFound)\n263: }\n264: \n265: func TestRedisStore_UpdateSessionLastActivity_Success(t *testing.T) {\n266: \tstore, mr := newTestRedisStore(t)\n267: \tctx := context.Background()\n268: \tinfo := testSandboxInfo(\"sess-031\")\n269: \n270: \terr := store.StoreSandbox(ctx, \"sess-031\", info)\n271: \trequire.NoError(t, err)\n272: \n273: \tnewTime := time.Now().Add(10 * time.Minute)\n274: \terr = store.UpdateSessionLastActivity(ctx, \"sess-031\", newTime)\n275: \trequire.NoError(t, err)\n276: \n277: \tscore, err := mr.ZScore(\"session:last_activity\", \"sess-031\")\n278: \trequire.NoError(t, err)\n279: \tassert.Equal(t, float64(newTime.Unix()), score)\n280: }\n281: \n282: func TestRedisStore_ListExpiredSandboxes_LimitZero(t *testing.T) {\n283: \tstore, _ := newTestRedisStore(t)\n284: \tctx := context.Background()\n285: \n286: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n287: \trequire.NoError(t, err)\n288: \tassert.Nil(t, result)\n289: }\n290: \n291: func TestRedisStore_ListExpiredSandboxes_LimitNegative(t *testing.T) {\n292: \tstore, _ := newTestRedisStore(t)\n293: \tctx := context.Background()\n294: \n295: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n296: \trequire.NoError(t, err)\n297: \tassert.Nil(t, result)\n298: }\n299: \n300: func TestRedisStore_ListExpiredSandboxes(t *testing.T) {\n301: \tstore, _ := newTestRedisStore(t)\n302: \tctx := context.Background()\n303: \tnow := time.Now().UTC()\n304: \n305: \texpired := testSandboxInfo(\"sess-expired\")\n306: \texpired.ExpiresAt = now.Add(-2 * time.Hour)\n307: \terr := store.StoreSandbox(ctx, \"sess-expired\", expired)\n308: \trequire.NoError(t, err)\n309: \n310: \tactive := testSandboxInfo(\"sess-active\")\n311: \tactive.ExpiresAt = now.Add(2 * time.Hour)\n312: \terr = store.StoreSandbox(ctx, \"sess-active\", active)\n313: \trequire.NoError(t, err)\n314: \n315: \tresult, err := store.ListExpiredSandboxes(ctx, now, 10)\n316: \trequire.NoError(t, err)\n317: \trequire.Len(t, result, 1)\n318: \tassert.Equal(t, \"sess-expired\", result[0].SessionID)\n319: }\n320: \n321: func TestRedisStore_ListExpiredSandboxes_Limit(t *testing.T) {\n322: \tstore, _ := newTestRedisStore(t)\n323: \tctx := context.Background()\n324: \tnow := time.Now().UTC()\n325: \n326: \tfor i := 0; i < 5; i++ {\n327: \t\tinfo := testSandboxInfo(\"sess-exp-\" + string(rune('0'+i)))\n328: \t\tinfo.ExpiresAt = now.Add(-time.Duration(i+1) * time.Hour)\n329: \t\terr := store.StoreSandbox(ctx, \"sess-exp-\"+string(rune('0'+i)), info)\n330: \t\trequire.NoError(t, err)\n331: \t}\n332: \n333: \tresult, err := store.ListExpiredSandboxes(ctx, now, 3)\n334: \trequire.NoError(t, err)\n335: \tassert.LessOrEqual(t, len(result), 3)\n336: }\n337: \n338: func TestRedisStore_ListExpiredSandboxes_OrphanMember(t *testing.T) {\n339: \tstore, mr := newTestRedisStore(t)\n340: \tctx := context.Background()\n341: \tnow := time.Now().UTC()\n342: \n343: \tinfo := testSandboxInfo(\"sess-orphan-exp\")\n344: \tinfo.ExpiresAt = now.Add(-time.Hour)\n345: \terr := store.StoreSandbox(ctx, \"sess-orphan-exp\", info)\n346: \trequire.NoError(t, err)\n347: \n348: \tmr.Del(\"session:sess-orphan-exp\")\n349: \n350: \tresult, err := store.ListExpiredSandboxes(ctx, now.Add(time.Hour), 10)\n351: \trequire.NoError(t, err)\n352: \tassert.Len(t, result, 0)\n353: }\n354: \n355: func TestRedisStore_ListInactiveSandboxes_LimitZero(t *testing.T) {\n356: \tstore, _ := newTestRedisStore(t)\n357: \tctx := context.Background()\n358: \n359: \tresult, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n360: \trequire.NoError(t, err)\n361: \tassert.Nil(t, result)\n362: }\n363: \n364: func TestRedisStore_ListInactiveSandboxes(t *testing.T) {\n365: \tstore, _ := newTestRedisStore(t)\n366: \tctx := context.Background()\n367: \tnow := time.Now().UTC()\n368: \n369: \tinactive := testSandboxInfo(\"sess-inactive\")\n370: \tinactive.LastActivityAt = now.Add(-2 * time.Hour)\n371: \terr := store.StoreSandbox(ctx, \"sess-inactive\", inactive)\n372: \trequire.NoError(t, err)\n373: \n374: \tactive := testSandboxInfo(\"sess-active-2\")\n375: \tactive.LastActivityAt = now.Add(-5 * time.Minute)\n376: \terr = store.StoreSandbox(ctx, \"sess-active-2\", active)\n377: \trequire.NoError(t, err)\n378: \n379: \tresult, err := store.ListInactiveSandboxes(ctx, now, 10)\n380: \trequire.NoError(t, err)\n381: \trequire.Len(t, result, 1)\n382: \tassert.Equal(t, \"sess-inactive\", result[0].SessionID)\n383: }\n384: \n385: func TestRedisStore_ListInactiveSandboxes_OrphanMember(t *testing.T) {\n386: \tstore, mr := newTestRedisStore(t)\n387: \tctx := context.Background()\n388: \tnow := time.Now().UTC()\n389: \n390: \tinfo := testSandboxInfo(\"sess-orphan-inactive\")\n391: \tinfo.LastActivityAt = now.Add(-time.Hour)\n392: \terr := store.StoreSandbox(ctx, \"sess-orphan-inactive\", info)\n393: \trequire.NoError(t, err)\n394: \n395: \tmr.Del(\"session:sess-orphan-inactive\")\n396: \n397: \tresult, err := store.ListInactiveSandboxes(ctx, now.Add(time.Hour), 10)\n398: \trequire.NoError(t, err)\n399: \tassert.Len(t, result, 0)\n400: }\n401: \n402: func TestRedisStore_Close(t *testing.T) {\n403: \tstore, mr := newTestRedisStore(t)\n404: \n405: \terr := store.Close()\n406: \trequire.NoError(t, err)\n407: \n408: \tmr.Close()\n409: }\n410: \n411: func TestRedisStore_ErrNotFound_Is(t *testing.T) {\n412: \tstore, _ := newTestRedisStore(t)\n413: \tctx := context.Background()\n414: \n415: \t_, err := store.GetSandbox(ctx, \"nonexistent\")\n416: \tassert.ErrorIs(t, err, ErrNotFound)\n417: }\n418: \n419: func TestRedisStore_MultipleSandboxes(t *testing.T) {\n420: \tstore, _ := newTestRedisStore(t)\n421: \tctx := context.Background()\n422: \n423: \tsessions := []string{\"multi-01\", \"multi-02\", \"multi-03\"}\n424: \tfor _, sid := range sessions {\n425: \t\tinfo := testSandboxInfo(sid)\n426: \t\terr := store.StoreSandbox(ctx, sid, info)\n427: \t\trequire.NoError(t, err)\n428: \t}\n429: \n430: \tresult, err := store.ListSandboxes(ctx)\n431: \trequire.NoError(t, err)\n432: \tassert.Len(t, result, 3)\n433: \n434: \tfor _, sid := range sessions {\n435: \t\tsandbox, err := store.GetSandbox(ctx, sid)\n436: \t\trequire.NoError(t, err)\n437: \t\tassert.Equal(t, sid, sandbox.SessionID)\n438: \t}\n439: }\n\n(End of file - total 439 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc newTestRedisStore(t *testing.T) (*redisStore, *miniredis.Miniredis) {\n\tt.Helper()\n\tmr, err := miniredis.Run()\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { mr.Close() })\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis_test.go","time":{"start":1775834892962,"end":1775834892969}}}}
