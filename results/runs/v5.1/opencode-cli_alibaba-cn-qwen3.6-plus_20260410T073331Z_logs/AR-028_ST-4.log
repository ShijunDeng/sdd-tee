{"type":"tool_use","timestamp":1775866214239,"sessionID":"ses_2862337a6ffeds16ehO2RvNRjD","part":{"id":"prt_d79dff2ed001mqnaV0X3NMF1iV","messageID":"msg_d79dfe91f001Ryylb0DP1Srvg3","sessionID":"ses_2862337a6ffeds16ehO2RvNRjD","type":"tool","tool":"read","callID":"call_a787c6a53dda432a9292c86e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/agent_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/agent_runtime.py</path>\n<type>file</type>\n<content>\n1: import os\n2: from typing import Any, Dict, Optional\n3: \n4: from agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n5: from agentcube.utils.log import get_logger\n6: \n7: \n8: class AgentRuntimeClient:\n9:     \"\"\"High-level client for Agent Runtime invocation.\n10: \n11:     Bootstraps sessions and invokes agent workloads through the Router.\n12:     \"\"\"\n13: \n14:     def __init__(\n15:         self,\n16:         agent_name: str,\n17:         namespace: str = \"default\",\n18:         router_url: Optional[str] = None,\n19:         verbose: bool = False,\n20:         session_id: Optional[str] = None,\n21:         timeout: int = 120,\n22:         connect_timeout: float = 5.0,\n23:     ):\n24:         self.agent_name = agent_name\n25:         self.namespace = namespace\n26:         self.timeout = timeout\n27:         self.connect_timeout = connect_timeout\n28:         self.logger = get_logger(\n29:             \"agentcube.agent_runtime\",\n30:             level=\"DEBUG\" if verbose else \"INFO\",\n31:         )\n32:         self.session_id = session_id\n33: \n34:         router_url = router_url or os.environ.get(\"ROUTER_URL\")\n35:         if not router_url:\n36:             raise ValueError(\n37:                 \"router_url must be provided or ROUTER_URL env var must be set\"\n38:             )\n39:         self.router_url = router_url\n40: \n41:         self.dp_client = AgentRuntimeDataPlaneClient(\n42:             router_url=self.router_url,\n43:             namespace=self.namespace,\n44:             agent_name=self.agent_name,\n45:             timeout=self.timeout,\n46:             connect_timeout=self.connect_timeout,\n47:         )\n48: \n49:         if self.session_id is None:\n50:             self.session_id = self.dp_client.bootstrap_session_id()\n51:             self.logger.debug(\n52:                 \"Bootstrapped session: %s (agent=%s, namespace=%s)\",\n53:                 self.session_id,\n54:                 agent_name,\n55:                 namespace,\n56:             )\n57: \n58:     def __enter__(self) -> \"AgentRuntimeClient\":\n59:         return self\n60: \n61:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n62:         self.close()\n63: \n64:     def invoke(\n65:         self, payload: Dict[str, Any], timeout: Optional[float] = None\n66:     ) -> Any:\n67:         \"\"\"Invoke the agent runtime with a payload.\"\"\"\n68:         if not self.session_id:\n69:             raise ValueError(\"AgentRuntime session_id is not initialized\")\n70:         resp = self.dp_client.invoke(\n71:             session_id=self.session_id,\n72:             payload=payload,\n73:             timeout=timeout,\n74:         )\n75:         return resp.json()\n76: \n77:     def close(self) -> None:\n78:         \"\"\"Close the underlying HTTP session.\"\"\"\n79:         self.dp_client.close()\n\n(End of file - total 79 lines)\n</content>","metadata":{"preview":"import os\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom agentcube.utils.log import get_logger\n\n\nclass AgentRuntimeClient:\n    \"\"\"High-level client for Agent Runtime invocation.\n\n    Bootstraps sessions and invokes agent workloads through the Router.\n    \"\"\"\n\n    def __init__(\n        self,\n        agent_name: str,\n        namespace: str = \"default\",\n        router_url: Optional[str] = None,\n        verbose: bool = False,\n        session_id: Optional[str] = None,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/agent_runtime.py","time":{"start":1775866214230,"end":1775866214237}}}}
{"type":"tool_use","timestamp":1775866215606,"sessionID":"ses_2862337a6ffeds16ehO2RvNRjD","part":{"id":"prt_d79dff7fd001tiJyPtfWuS9fED","messageID":"msg_d79dfe91f001Ryylb0DP1Srvg3","sessionID":"ses_2862337a6ffeds16ehO2RvNRjD","type":"tool","tool":"read","callID":"call_234db453301047a5be39127d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/clients/agent_runtime_data_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/clients/agent_runtime_data_plane.py</path>\n<type>file</type>\n<content>\n1: from typing import Any, Dict, Optional\n2: from urllib.parse import urljoin\n3: \n4: import requests\n5: \n6: from agentcube.utils.http import create_session\n7: \n8: \n9: class AgentRuntimeDataPlaneClient:\n10:     \"\"\"Client for the Agent Runtime data plane API via the Router.\"\"\"\n11: \n12:     SESSION_HEADER = \"x-agentcube-session-id\"\n13: \n14:     def __init__(\n15:         self,\n16:         router_url: str,\n17:         namespace: str,\n18:         agent_name: str,\n19:         timeout: int = 120,\n20:         connect_timeout: float = 5.0,\n21:         pool_connections: int = 10,\n22:         pool_maxsize: int = 10,\n23:     ):\n24:         self.router_url = router_url\n25:         self.namespace = namespace\n26:         self.agent_name = agent_name\n27:         self.timeout = timeout\n28:         self.connect_timeout = connect_timeout\n29: \n30:         base_path = f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n31:         self.base_url = urljoin(router_url, base_path)\n32: \n33:         self.session = create_session(\n34:             pool_connections=pool_connections, pool_maxsize=pool_maxsize\n35:         )\n36: \n37:     def bootstrap_session_id(self) -> str:\n38:         \"\"\"Bootstrap a session ID by GETting the invocation endpoint.\n39: \n40:         Reads x-agentcube-session-id from response header.\n41:         \"\"\"\n42:         resp = self.session.get(\n43:             self.base_url,\n44:             timeout=(self.connect_timeout, self.timeout),\n45:         )\n46:         resp.raise_for_status()\n47:         session_id = resp.headers.get(self.SESSION_HEADER)\n48:         if not session_id:\n49:             raise ValueError(\n50:                 f\"Missing required response header: {self.SESSION_HEADER}\"\n51:             )\n52:         return session_id\n53: \n54:     def invoke(\n55:         self,\n56:         session_id: str,\n57:         payload: Dict[str, Any],\n58:         timeout: Optional[float] = None,\n59:     ) -> requests.Response:\n60:         \"\"\"Invoke the agent runtime with a payload.\n61: \n62:         POST {base_url} with JSON body and session header.\n63:         \"\"\"\n64:         read_timeout = timeout if timeout is not None else self.timeout\n65:         headers = {\n66:             self.SESSION_HEADER: session_id,\n67:             \"Content-Type\": \"application/json\",\n68:         }\n69:         resp = self.session.post(\n70:             self.base_url,\n71:             json=payload,\n72:             headers=headers,\n73:             timeout=(self.connect_timeout, read_timeout),\n74:         )\n75:         resp.raise_for_status()\n76:         return resp\n77: \n78:     def close(self) -> None:\n79:         \"\"\"Close the HTTP session.\"\"\"\n80:         self.session.close()\n\n(End of file - total 80 lines)\n</content>","metadata":{"preview":"from typing import Any, Dict, Optional\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom agentcube.utils.http import create_session\n\n\nclass AgentRuntimeDataPlaneClient:\n    \"\"\"Client for the Agent Runtime data plane API via the Router.\"\"\"\n\n    SESSION_HEADER = \"x-agentcube-session-id\"\n\n    def __init__(\n        self,\n        router_url: str,\n        namespace: str,\n        agent_name: str,\n        timeout: int = 120,\n        connect_timeout: float = 5.0,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/agentcube/clients/agent_runtime_data_plane.py","time":{"start":1775866215599,"end":1775866215605}}}}
{"type":"tool_use","timestamp":1775866216842,"sessionID":"ses_2862337a6ffeds16ehO2RvNRjD","part":{"id":"prt_d79dffd42001W3b2M48dSjQ2g3","messageID":"msg_d79dfe91f001Ryylb0DP1Srvg3","sessionID":"ses_2862337a6ffeds16ehO2RvNRjD","type":"tool","tool":"read","callID":"call_6d9dc0a9dbbb45898d562ef9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/design.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/design.md</path>\n<type>file</type>\n<content>\n1: # AR-028: SDK AgentRuntimeClient вҖ” Design\n2: \n3: ## 1. Architecture\n4: \n5: ### 1.1 Purpose\n6: \n7: The `AgentRuntimeClient` is a high-level Python SDK client for invoking Agent Runtime workloads through the AgentCube Router. It provides:\n8: \n9: 1. **Session Bootstrap** вҖ” Automatically obtain or reuse `session_id` via the Router's invocation endpoint.\n10: 2. **Agent Invocation** вҖ” POST JSON payloads to agent runtime endpoints with proper session management.\n11: 3. **Resource Cleanup** вҖ” Context manager support for deterministic HTTP session cleanup.\n12: \n13: ### 1.2 Position in SDK Architecture\n14: \n15: ```\n16: в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n17: в”Ӯ                    Public Client Layer                      в”Ӯ\n18: в”Ӯ              AgentRuntimeClient (this AR)                   в”Ӯ\n19: в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\n20: в”Ӯ                  Data Plane Client                          в”Ӯ\n21: в”Ӯ              AgentRuntimeDataPlaneClient                    в”Ӯ\n22: в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\n23: в”Ӯ                    HTTP Utilities                           в”Ӯ\n24: в”Ӯ  create_session  в”Ӯ  read_token_from_file  в”Ӯ  get_logger     в”Ӯ\n25: в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n26: ```\n27: \n28: ### 1.3 Design Principles\n29: \n30: - **No single Configuration class** вҖ” Defaults and environment resolution are distributed across components.\n31: - **Context manager support** вҖ” Implements `__enter__`/`__exit__` for resource cleanup.\n32: - **Session header management** вҖ” `x-agentcube-session-id` (lowercase) is used consistently for Router requests.\n33: - **Timeout safety** вҖ” Default read timeout of 120s with connect timeout of 5.0s.\n34: \n35: ### 1.4 Package Layout\n36: \n37: ```\n38: sdk-python/\n39: в”ңв”Җв”Җ pyproject.toml                     вҖ” Package agentcube-sdk, dependencies\n40: в”ңв”Җв”Җ agentcube/\n41: в”Ӯ   в”ңв”Җв”Җ __init__.py                    вҖ” Public exports: CodeInterpreterClient, AgentRuntimeClient\n42: в”Ӯ   в”ңв”Җв”Җ agent_runtime.py               вҖ” AgentRuntimeClient (this AR)\n43: в”Ӯ   в”ңв”Җв”Җ exceptions.py                  вҖ” Exception classes\n44: в”Ӯ   в”ңв”Җв”Җ clients/\n45: в”Ӯ   в”Ӯ   в”ңв”Җв”Җ __init__.py                вҖ” Re-exports client classes\n46: в”Ӯ   в”Ӯ   в””в”Җв”Җ agent_runtime_data_plane.py    вҖ” AgentRuntimeDataPlaneClient\n47: в”Ӯ   в””в”Җв”Җ utils/\n48: в”Ӯ       в”ңв”Җв”Җ __init__.py                вҖ” Empty (module marker)\n49: в”Ӯ       в”ңв”Җв”Җ http.py                    вҖ” create_session\n50: в”Ӯ       в”ңв”Җв”Җ utils.py                   вҖ” read_token_from_file\n51: в”Ӯ       в””в”Җв”Җ log.py                     вҖ” get_logger\n52: в”ңв”Җв”Җ examples/\n53: в”Ӯ   в””в”Җв”Җ agent_runtime_usage.py         вҖ” AgentRuntimeClient usage examples\n54: в””в”Җв”Җ tests/\n55:     в””в”Җв”Җ test_agent_runtime.py          вҖ” Unit and integration tests\n56: ```\n57: \n58: ### 1.5 Dependencies\n59: \n60: ```toml\n61: dependencies = [\n62:     \"requests\",\n63:     \"PyJWT>=2.0.0\",\n64:     \"cryptography\",\n65: ]\n66: ```\n67: \n68: - `requires-python = \">=3.10\"`\n69: - Build: `setuptools>=61.0`, `wheel`; backend `setuptools.build_meta`\n70: - Packages: `where = [\".\"]`, `include = [\"agentcube*\"]`, `namespaces = false`\n71: \n72: ---\n73: \n74: ## 2. Data Structures\n75: \n76: ### 2.1 `AgentRuntimeClient` Fields\n77: \n78: | Field | Type | Description |\n79: |-------|------|-------------|\n80: | `agent_name` | `str` | Agent runtime name (required) |\n81: | `namespace` | `str` | Kubernetes namespace (default: `\"default\"`) |\n82: | `timeout` | `int` | Default read timeout in seconds (default: `120`) |\n83: | `connect_timeout` | `float` | Connect timeout in seconds (default: `5.0`) |\n84: | `logger` | `logging.Logger` | Logger instance |\n85: | `router_url` | `str` | Router base URL |\n86: | `session_id` | `Optional[str]` | Active session ID (bootstrapped or provided) |\n87: | `dp_client` | `AgentRuntimeDataPlaneClient` | Data plane HTTP client |\n88: \n89: ### 2.2 `AgentRuntimeDataPlaneClient` Fields\n90: \n91: | Field | Type | Description |\n92: |-------|------|-------------|\n93: | `SESSION_HEADER` | `str` | Class constant: `\"x-agentcube-session-id\"` |\n94: | `router_url` | `str` | Router base URL |\n95: | `namespace` | `str` | Kubernetes namespace |\n96: | `agent_name` | `str` | Agent runtime name |\n97: | `timeout` | `int` | Default read timeout (default: `120`) |\n98: | `connect_timeout` | `float` | Connect timeout (default: `5.0`) |\n99: | `base_url` | `str` | Computed invocation base URL |\n100: | `session` | `requests.Session` | HTTP session with connection pooling |\n101: \n102: ### 2.3 Exception Hierarchy\n103: \n104: ```python\n105: class AgentCubeError(Exception):\n106:     \"\"\"Base exception for AgentCube SDK\"\"\"\n107:     pass\n108: \n109: class SessionError(AgentCubeError):\n110:     \"\"\"Raised when session creation or management fails\"\"\"\n111:     pass\n112: \n113: class DataPlaneError(AgentCubeError):\n114:     \"\"\"Raised when Data Plane operations fail\"\"\"\n115:     pass\n116: ```\n117: \n118: **Note:** `SessionError` and `DataPlaneError` are defined for extension but not raised by core client modules. Callers may rely on `ValueError`, `requests` exceptions, or `CommandExecutionError` (from code interpreter).\n119: \n120: ---\n121: \n122: ## 3. API Contracts\n123: \n124: ### 3.1 Public Export\n125: \n126: #### `agentcube/__init__.py`\n127: \n128: ```python\n129: from .agent_runtime import AgentRuntimeClient\n130: \n131: __all__ = [\"CodeInterpreterClient\", \"AgentRuntimeClient\"]\n132: ```\n133: \n134: #### `agentcube/clients/__init__.py`\n135: \n136: ```python\n137: from .agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n138: \n139: __all__ = [\n140:     \"ControlPlaneClient\",\n141:     \"CodeInterpreterDataPlaneClient\",\n142:     \"AgentRuntimeDataPlaneClient\",\n143: ]\n144: ```\n145: \n146: ### 3.2 `AgentRuntimeClient` (`agentcube/agent_runtime.py`)\n147: \n148: ```python\n149: class AgentRuntimeClient:\n150:     def __init__(\n151:         self,\n152:         agent_name: str,\n153:         namespace: str = \"default\",\n154:         router_url: Optional[str] = None,\n155:         verbose: bool = False,\n156:         session_id: Optional[str] = None,\n157:         timeout: int = 120,\n158:         connect_timeout: float = 5.0,\n159:     )\n160: \n161:     def __enter__(self) -> \"AgentRuntimeClient\"\n162:     def __exit__(self, exc_type, exc_val, exc_tb) -> None\n163:     def invoke(self, payload: Dict[str, Any], timeout: Optional[float] = None) -> Any\n164:     def close(self) -> None\n165: ```\n166: \n167: #### Configuration Resolution\n168: \n169: | Setting | Source |\n170: |---------|--------|\n171: | `router_url` | Argument or `ROUTER_URL` env (required) |\n172: | `agent_name` | Argument (required) |\n173: | `namespace` | Argument (default: `\"default\"`) |\n174: | `session_id` | Argument (optional; if `None`, bootstrapped via `GET`) |\n175: | `timeout` | Argument (default: `120`) |\n176: | `connect_timeout` | Argument (default: `5.0`) |\n177: \n178: #### Lifecycle\n179: \n180: 1. **Init:**\n181:    - Resolve `router_url` from argument or `ROUTER_URL` environment variable.\n182:    - Create `AgentRuntimeDataPlaneClient` with resolved parameters.\n183:    - If `session_id` is `None`, call `dp_client.bootstrap_session_id()` via `GET` on invocation base URL.\n184:    - Read `x-agentcube-session-id` header from response; if missing, raise `ValueError(\"Missing required response header: x-agentcube-session-id\")`.\n185:    - Store bootstrapped `session_id` on instance.\n186: \n187: 2. **Invoke:**\n188:    - Validate `session_id` is truthy; if falsy, raise `ValueError(\"AgentRuntime session_id is not initialized\")`.\n189:    - Call `dp_client.invoke(session_id, payload, timeout)`.\n190:    - Return parsed JSON response.\n191: \n192: 3. **Context manager exit:**\n193:    - Call `close()` вҶ’ close underlying `requests.Session`.\n194: \n195: 4. **Close:**\n196:    - Call `dp_client.close()` to release HTTP connection pool.\n197: \n198: ### 3.3 `AgentRuntimeDataPlaneClient` (`agentcube/clients/agent_runtime_data_plane.py`)\n199: \n200: ```python\n201: class AgentRuntimeDataPlaneClient:\n202:     SESSION_HEADER = \"x-agentcube-session-id\"\n203: \n204:     def __init__(\n205:         self,\n206:         router_url: str,\n207:         namespace: str,\n208:         agent_name: str,\n209:         timeout: int = 120,\n210:         connect_timeout: float = 5.0,\n211:         pool_connections: int = 10,\n212:         pool_maxsize: int = 10,\n213:     )\n214: \n215:     def bootstrap_session_id(self) -> str\n216:     def invoke(\n217:         self,\n218:         session_id: str,\n219:         payload: Dict[str, Any],\n220:         timeout: Optional[float] = None,\n221:     ) -> requests.Response\n222:     def close(self) -> None\n223: ```\n224: \n225: #### Base URL Resolution\n226: \n227: ```python\n228: base_path = f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n229: self.base_url = urljoin(router_url, base_path)\n230: ```\n231: \n232: #### HTTP Endpoints\n233: \n234: | Method | URL | Headers | Body |\n235: |--------|-----|---------|------|\n236: | `GET` | `self.base_url` | Session default headers only | вҖ” |\n237: | `POST` | `self.base_url` | `x-agentcube-session-id`, `Content-Type: application/json` | `json=payload` |\n238: \n239: #### `bootstrap_session_id()`\n240: \n241: - Sends `GET` request to `self.base_url`.\n242: - Reads `x-agentcube-session-id` header from response.\n243: - Returns session ID string.\n244: - Raises `ValueError(\"Missing required response header: x-agentcube-session-id\")` if header is absent.\n245: \n246: #### `invoke()`\n247: \n248: - Validates `session_id` is provided.\n249: - Sends `POST` request to `self.base_url` with:\n250:   - Header: `x-agentcube-session-id: {session_id}`\n251:   - Header: `Content-Type: application/json`\n252:   - Body: JSON-serialized `payload`\n253: - Timeout: `(connect_timeout, timeout)` where `timeout` defaults to `self.timeout` (120s).\n254: - Returns `requests.Response` object.\n255: \n256: #### Timeouts\n257: \n258: - Default read timeout: `120` seconds.\n259: - Default connect timeout: `5.0` seconds.\n260: - Per-call override via `timeout` parameter in `invoke()`.\n261: - Timeout tuple: `(connect_timeout, effective_timeout)`.\n262: \n263: ---\n264: \n265: ## 4. Configuration Summary\n266: \n267: | Component | Resolved Settings |\n268: |-----------|-------------------|\n269: | `AgentRuntimeClient` | `router_url` вҶҗ arg or `ROUTER_URL`; `timeout=120`, `connect_timeout=5.0` passed to data plane |\n270: | `AgentRuntimeDataPlaneClient` | `timeout=120`, `connect_timeout=5.0`, `pool_connections=10`, `pool_maxsize=10`; `base_url` from `router_url`+`namespace`+`agent_name` |\n271: \n272: ---\n273: \n274: ## 5. Error Handling\n275: \n276: ### 5.1 Exception Flow\n277: \n278: ```\n279: ValueError                    вҶҗ Configuration errors, missing session, missing headers\n280: requests.RequestException     вҶҗ HTTP failures (connection errors, timeouts)\n281: requests.HTTPError            вҶҗ Non-2xx responses (if raised)\n282: ```\n283: \n284: ### 5.2 Error Scenarios\n285: \n286: | Scenario | Behavior |\n287: |----------|----------|\n288: | Router URL missing | Raise `ValueError` in `AgentRuntimeClient.__init__` |\n289: | Session bootstrap header missing | Raise `ValueError(\"Missing required response header: x-agentcube-session-id\")` |\n290: | Invoke without session | Raise `ValueError(\"AgentRuntime session_id is not initialized\")` |\n291: | HTTP timeout | `requests.Timeout` raised by underlying session |\n292: | Connection failure | `requests.ConnectionError` raised by underlying session |\n293: \n294: ### 5.3 Timeout Behavior\n295: \n296: | Component | Default Read Timeout | Default Connect Timeout |\n297: |-----------|---------------------|------------------------|\n298: | `AgentRuntimeDataPlaneClient` | 120s | 5.0s |\n299: | `invoke()` per-call | Method argument or `self.timeout` (120s) | 5.0s |\n300: \n301: ---\n302: \n303: ## 6. Implementation Notes\n304: \n305: ### 6.1 Session Bootstrap Flow\n306: \n307: The `AgentRuntimeClient` can operate in two modes:\n308: \n309: 1. **Pre-provisioned session:** Caller provides `session_id` in constructor.\n310: 2. **Auto-bootstrap:** Client calls `GET` on invocation base URL to obtain `session_id` from response header.\n311: \n312: The bootstrap mechanism allows the Router to manage session lifecycle and provide a valid session ID for subsequent invocations.\n313: \n314: ### 6.2 Session Header Consistency\n315: \n316: All Router requests use lowercase `x-agentcube-session-id`:\n317: \n318: - `AgentRuntimeDataPlaneClient`: Class constant `SESSION_HEADER = \"x-agentcube-session-id\"`\n319: - Set explicitly on each `POST` request in `invoke()`\n320: \n321: ### 6.3 Timeout Tuple Logic\n322: \n323: For `invoke()`:\n324: \n325: ```python\n326: effective_timeout = timeout if timeout is not None else self.timeout\n327: request_timeout = (self.connect_timeout, effective_timeout)\n328: ```\n329: \n330: This ensures the connect timeout is always applied, while the read timeout can be overridden per-call.\n331: \n332: ### 6.4 Context Manager Pattern\n333: \n334: ```python\n335: with AgentRuntimeClient(agent_name=\"my-agent\", router_url=\"http://router:8080\") as client:\n336:     response = client.invoke({\"action\": \"query\", \"data\": {\"key\": \"value\"}})\n337: # Session automatically closed on exit\n338: ```\n339: \n340: ---\n341: \n342: ## 7. Testing Strategy\n343: \n344: ### 7.1 Test Categories\n345: \n346: | Category | Scope |\n347: |----------|-------|\n348: | Unit tests | Individual client methods, mock HTTP responses |\n349: | Integration tests | Data plane interaction (mocked servers) |\n350: | E2E tests | Real environment with Router backend |\n351: \n352: ### 7.2 Key Test Scenarios\n353: \n354: #### AgentRuntimeClient Lifecycle\n355: \n356: | Test Name | Description |\n357: |-----------|-------------|\n358: | `TestAgentRuntimeClient_BootstrapSessionId` | Bootstrap session ID from GET response header |\n359: | `TestAgentRuntimeClient_InvokeWithoutSession` | Invoke validates session ID presence |\n360: | `TestAgentRuntimeClient_ContextManagerClosesSession` | Context manager closes HTTP session |\n361: | `TestAgentRuntimeClient_PreProvisionedSession` | Uses provided session_id without bootstrap |\n362: | `TestAgentRuntimeClient_MissingRouterUrl` | Raises ValueError when router_url missing |\n363: \n364: #### Session Bootstrap\n365: \n366: | Test Name | Description |\n367: |-----------|-------------|\n368: | `TestBootstrapSessionId_Success` | GET returns valid session header |\n369: | `TestBootstrapSessionId_MissingHeader` | Raises ValueError when header absent |\n370: | `TestBootstrapSessionId_NetworkError` | Handles connection failures gracefully |\n371: \n372: #### Invoke\n373: \n374: | Test Name | Description |\n375: |-----------|-------------|\n376: | `TestInvoke_Success` | POST returns valid JSON response |\n377: | `TestInvoke_WithTimeout` | Per-call timeout override applied |\n378: | `TestInvoke_DefaultTimeout` | Uses instance default timeout (120s) |\n379: | `TestInvoke_SessionHeader` | Includes x-agentcube-session-id header |\n380: | `TestInvoke_ContentTypeHeader` | Includes Content-Type: application/json |\n381: \n382: #### Timeout Behavior\n383: \n384: | Test Name | Description |\n385: |-----------|-------------|\n386: | `TestAgentRuntimeClient_InvokeTimeoutTuple` | AgentRuntimeClient invoke timeout tuple |\n387: | `TestAgentRuntimeClient_DefaultTimeouts` | Default timeouts (120s read, 5.0s connect) |\n388: \n389: ### 7.3 Mocking Strategy\n390: \n391: - Use `unittest.mock` or `pytest-mock` for `requests.Session`.\n392: - Mock `create_session` to return controlled `requests.Session` instances.\n393: - Use `responses` library or custom adapters for HTTP endpoint mocking.\n394: - Mock `GET` response with `x-agentcube-session-id` header for bootstrap tests.\n395: - Mock `POST` response with JSON payload for invoke tests.\n396: \n397: ---\n398: \n399: ## 8. Usage Examples\n400: \n401: ### 8.1 Basic Usage with Context Manager\n402: \n403: ```python\n404: from agentcube import AgentRuntimeClient\n405: \n406: with AgentRuntimeClient(\n407:     agent_name=\"my-agent\",\n408:     namespace=\"production\",\n409:     router_url=\"http://router:8080\",\n410: ) as client:\n411:     response = client.invoke({\n412:         \"action\": \"process\",\n413:         \"data\": {\"input\": \"hello world\"}\n414:     })\n415:     print(response)\n416: ```\n417: \n418: ### 8.2 Pre-provisioned Session\n419: \n420: ```python\n421: from agentcube import AgentRuntimeClient\n422: \n423: client = AgentRuntimeClient(\n424:     agent_name=\"my-agent\",\n425:     session_id=\"existing-session-id\",\n426:     router_url=\"http://router:8080\",\n427: )\n428: \n429: try:\n430:     response = client.invoke({\"action\": \"query\"})\n431: finally:\n432:     client.close()\n433: ```\n434: \n435: ### 8.3 Custom Timeout\n436: \n437: ```python\n438: from agentcube import AgentRuntimeClient\n439: \n440: with AgentRuntimeClient(\n441:     agent_name=\"my-agent\",\n442:     router_url=\"http://router:8080\",\n443:     timeout=300,  # 5 minute read timeout\n444: ) as client:\n445:     response = client.invoke(\n446:         {\"action\": \"long_running_task\"},\n447:         timeout=600  # Override to 10 minutes for this call\n448:     )\n449: ```\n\n(End of file - total 449 lines)\n</content>","metadata":{"preview":"# AR-028: SDK AgentRuntimeClient вҖ” Design\n\n## 1. Architecture\n\n### 1.1 Purpose\n\nThe `AgentRuntimeClient` is a high-level Python SDK client for invoking Agent Runtime workloads through the AgentCube Router. It provides:\n\n1. **Session Bootstrap** вҖ” Automatically obtain or reuse `session_id` via the Router's invocation endpoint.\n2. **Agent Invocation** вҖ” POST JSON payloads to agent runtime endpoints with proper session management.\n3. **Resource Cleanup** вҖ” Context manager support for deterministic HTTP session cleanup.\n\n### 1.2 Position in SDK Architecture\n\n```\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ                    Public Client Layer                      в”Ӯ\nв”Ӯ              AgentRuntimeClient (this AR)                   в”Ӯ\nв”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\nв”Ӯ                  Data Plane Client                          в”Ӯ","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/design.md","time":{"start":1775866216834,"end":1775866216840}}}}
