{"type":"tool_use","timestamp":1775857452729,"sessionID":"ses_286a623ebffexQ6eQhlYTCp58v","part":{"id":"prt_d795a422c0010vor3fZVqF5aXh","messageID":"msg_d795a3057001cvYvlP5jrhdKKx","sessionID":"ses_286a623ebffexQ6eQhlYTCp58v","type":"tool","tool":"read","callID":"call_dc85454118984c68bf0adcf7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/k8s_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/k8s_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Kubernetes provider for deploying standard Deployment + NodePort Service.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import time\n6: from typing import Any, Dict, Optional\n7: \n8: try:\n9:     from kubernetes import client, config\n10:     from kubernetes.client.rest import ApiException\n11:     from kubernetes.client import (\n12:         V1Container,\n13:         V1ContainerPort,\n14:         V1Deployment,\n15:         V1DeploymentSpec,\n16:         V1DeploymentStatus,\n17:         V1EnvVar,\n18:         V1ObjectMeta,\n19:         V1PodSpec,\n20:         V1PodTemplateSpec,\n21:         V1Service,\n22:         V1ServicePort,\n23:         V1ServiceSpec,\n24:         V1ServiceStatus,\n25:     )\n26: except ImportError:\n27:     client = None  # type: ignore[misc]\n28:     config = None  # type: ignore[misc]\n29:     ApiException = Exception  # type: ignore[misc, assignment]\n30:     V1Container = object  # type: ignore[misc, assignment]\n31:     V1ContainerPort = object  # type: ignore[misc, assignment]\n32:     V1Deployment = object  # type: ignore[misc, assignment]\n33:     V1DeploymentSpec = object  # type: ignore[misc, assignment]\n34:     V1DeploymentStatus = object  # type: ignore[misc, assignment]\n35:     V1EnvVar = object  # type: ignore[misc, assignment]\n36:     V1ObjectMeta = object  # type: ignore[misc, assignment]\n37:     V1PodSpec = object  # type: ignore[misc, assignment]\n38:     V1PodTemplateSpec = object  # type: ignore[misc, assignment]\n39:     V1Service = object  # type: ignore[misc, assignment]\n40:     V1ServicePort = object  # type: ignore[misc, assignment]\n41:     V1ServiceSpec = object  # type: ignore[misc, assignment]\n42:     V1ServiceStatus = object  # type: ignore[misc, assignment]\n43: \n44: \n45: class KubernetesProvider:\n46:     \"\"\"Provider for deploying agents as standard Kubernetes Deployment + Service.\"\"\"\n47: \n48:     def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n49:         self.namespace = namespace\n50:         self.verbose = verbose\n51:         self._apps_api = client.AppsV1Api()\n52:         self._core_api = client.CoreV1Api()\n53: \n54:     def deploy_agent(\n55:         self,\n56:         agent_name: str,\n57:         image_url: str,\n58:         port: int,\n59:         entrypoint: str,\n60:         replicas: int = 1,\n61:         node_port: Optional[int] = None,\n62:         env_vars: Optional[Dict[str, str]] = None,\n63:     ) -> Dict[str, Any]:\n64:         \"\"\"Deploy a Kubernetes Deployment and NodePort Service.\n65: \n66:         Args:\n67:             agent_name: Name of the agent.\n68:             image_url: Container image URL.\n69:             port: Port the agent listens on.\n70:             entrypoint: Command to start the agent (shell string).\n71:             replicas: Number of replicas (default: 1).\n72:             node_port: Specific NodePort (30000-32767), or None for auto-assign.\n73:             env_vars: Environment variables for the container.\n74: \n75:         Returns:\n76:             Dict with deployment_name, service_name, service_url, node_port.\n77:         \"\"\"\n78:         sanitized_name = agent_name.lower().replace(\"_\", \"-\").replace(\".\", \"-\")\n79: \n80:         env_list = []\n81:         if env_vars:\n82:             for key, value in env_vars.items():\n83:                 env_list.append(V1EnvVar(name=key, value=value))\n84: \n85:         entrypoint_cmd = entrypoint.split() if entrypoint else []\n86: \n87:         container = V1Container(\n88:             name=sanitized_name,\n89:             image=image_url,\n90:             ports=[V1ContainerPort(container_port=port)],\n91:             command=entrypoint_cmd[:1] if entrypoint_cmd else None,\n92:             args=entrypoint_cmd[1:] if len(entrypoint_cmd) > 1 else None,\n93:             env=env_list if env_list else None,\n94:         )\n95: \n96:         pod_spec = V1PodSpec(containers=[container])\n97:         pod_template = V1PodTemplateSpec(\n98:             metadata=V1ObjectMeta(labels={\"app\": sanitized_name}),\n99:             spec=pod_spec,\n100:         )\n101:         deployment_spec = V1DeploymentSpec(\n102:             replicas=replicas,\n103:             selector={\"matchLabels\": {\"app\": sanitized_name}},\n104:             template=pod_template,\n105:         )\n106:         deployment = V1Deployment(\n107:             api_version=\"apps/v1\",\n108:             kind=\"Deployment\",\n109:             metadata=V1ObjectMeta(name=sanitized_name, namespace=self.namespace),\n110:             spec=deployment_spec,\n111:         )\n112: \n113:         self._apps_api.create_namespaced_deployment(\n114:             namespace=self.namespace,\n115:             body=deployment,\n116:         )\n117: \n118:         service_ports = [V1ServicePort(port=port, target_port=port)]\n119:         if node_port is not None:\n120:             service_ports[0].node_port = node_port\n121: \n122:         service_spec = V1ServiceSpec(\n123:             selector={\"app\": sanitized_name},\n124:             ports=service_ports,\n125:             type=\"NodePort\",\n126:         )\n127:         service = V1Service(\n128:             api_version=\"v1\",\n129:             kind=\"Service\",\n130:             metadata=V1ObjectMeta(name=sanitized_name, namespace=self.namespace),\n131:             spec=service_spec,\n132:         )\n133: \n134:         created_service = self._core_api.create_namespaced_service(\n135:             namespace=self.namespace,\n136:             body=service,\n137:         )\n138: \n139:         actual_node_port = node_port\n140:         if actual_node_port is None and created_service.spec.ports:\n141:             actual_node_port = created_service.spec.ports[0].node_port\n142: \n143:         service_url = f\"http://localhost:{actual_node_port}\"\n144: \n145:         return {\n146:             \"deployment_name\": sanitized_name,\n147:             \"service_name\": sanitized_name,\n148:             \"service_url\": service_url,\n149:             \"node_port\": actual_node_port,\n150:         }\n151: \n152:     def wait_for_deployment_ready(self, deployment_name: str, timeout: int = 120) -> None:\n153:         \"\"\"Wait for a deployment to become ready.\n154: \n155:         Args:\n156:             deployment_name: Name of the deployment.\n157:             timeout: Maximum seconds to wait (default: 120).\n158: \n159:         Raises:\n160:             TimeoutError: If the deployment does not become ready within timeout.\n161:         \"\"\"\n162:         start_time = time.time()\n163:         while time.time() - start_time < timeout:\n164:             deployment = self._apps_api.read_namespaced_deployment_status(\n165:                 name=deployment_name,\n166:                 namespace=self.namespace,\n167:             )\n168:             status = deployment.status\n169:             if (\n170:                 status.ready_replicas is not None\n171:                 and status.replicas is not None\n172:                 and status.ready_replicas == status.replicas\n173:             ):\n174:                 return\n175:             time.sleep(2)\n176: \n177:         raise TimeoutError(\n178:             f\"Deployment {deployment_name} did not become ready within {timeout}s\"\n179:         )\n180: \n181:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n182:         \"\"\"Get the status of a deployed agent.\n183: \n184:         Args:\n185:             agent_name: Name of the deployment.\n186: \n187:         Returns:\n188:             Dict with status, replicas, ready_replicas, available_replicas, etc.\n189:         \"\"\"\n190:         try:\n191:             deployment = self._apps_api.read_namespaced_deployment_status(\n192:                 name=agent_name,\n193:                 namespace=self.namespace,\n194:             )\n195:             status = deployment.status\n196:             return {\n197:                 \"status\": \"running\" if (status.ready_replicas and status.ready_replicas > 0) else \"pending\",\n198:                 \"deployment_name\": agent_name,\n199:                 \"namespace\": self.namespace,\n200:                 \"replicas\": status.replicas,\n201:                 \"ready_replicas\": status.ready_replicas,\n202:                 \"available_replicas\": status.available_replicas,\n203:                 \"updated_replicas\": status.updated_replicas,\n204:             }\n205:         except ApiException as e:\n206:             if e.status == 404:\n207:                 return {\n208:                     \"status\": \"not_found\",\n209:                     \"deployment_name\": agent_name,\n210:                     \"namespace\": self.namespace,\n211:                 }\n212:             raise\n213: \n214:     def delete_agent(self, agent_name: str) -> None:\n215:         \"\"\"Delete a Deployment and Service by name.\n216: \n217:         Ignores 404 errors if resources do not exist.\n218: \n219:         Args:\n220:             agent_name: Name of the agent resources to delete.\n221:         \"\"\"\n222:         try:\n223:             self._apps_api.delete_namespaced_deployment(\n224:                 name=agent_name,\n225:                 namespace=self.namespace,\n226:             )\n227:         except ApiException as e:\n228:             if e.status != 404:\n229:                 raise\n230: \n231:         try:\n232:             self._core_api.delete_namespaced_service(\n233:                 name=agent_name,\n234:                 namespace=self.namespace,\n235:             )\n236:         except ApiException as e:\n237:             if e.status != 404:\n238:                 raise\n\n(End of file - total 238 lines)\n</content>","metadata":{"preview":"\"\"\"Kubernetes provider for deploying standard Deployment + NodePort Service.\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Any, Dict, Optional\n\ntry:\n    from kubernetes import client, config\n    from kubernetes.client.rest import ApiException\n    from kubernetes.client import (\n        V1Container,\n        V1ContainerPort,\n        V1Deployment,\n        V1DeploymentSpec,\n        V1DeploymentStatus,\n        V1EnvVar,\n        V1ObjectMeta,\n        V1PodSpec,\n        V1PodTemplateSpec,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/k8s_provider.py","time":{"start":1775857452715,"end":1775857452728}}}}
