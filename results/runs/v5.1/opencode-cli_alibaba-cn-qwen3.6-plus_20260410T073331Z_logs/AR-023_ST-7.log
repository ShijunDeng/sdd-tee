ervice.load_metadata(p)\n37: \n38:         if metadata is None or not metadata.agent_id:\n39:             return {\"status\": \"not_published\"}\n40: \n41:         if selected_provider == \"agentcube\":\n42:             return self._get_cr_k8s_status(metadata)\n43:         else:\n44:             return self._get_k8s_status(metadata)\n45: \n46:     def _get_cr_k8s_status(self, metadata: AgentMetadata) -> Dict[str, Any]:\n47:         \"\"\"Get status from AgentRuntime Custom Resource.\n48: \n49:         Args:\n50:             metadata: The agent metadata.\n51: \n52:         Returns:\n53:             Dict with CR status information.\n54:         \"\"\"\n55:         namespace = metadata.k8s_deployment.get(\"namespace\", \"default\") if metadata.k8s_deployment else \"default\"\n56:         cr_name = metadata.k8s_deployment.get(\"cr_name\", metadata.agent_name) if metadata.k8s_deployment else metadata.agent_name\n57: \n58:         provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n59:         cr_object = provider.get_agent_runtime(cr_name)\n60: \n61:         if cr_object is None:\n62:             return {\n63:                 \"status\": \"not_found_in_k8s\",\n64:                 \"agent_name\": metadata.agent_name,\n65:                 \"cr_name\": cr_name,\n66:                 \"namespace\": namespace,\n67:             }\n68: \n69:         cr_status = cr_object.get(\"status\", {})\n70:         if cr_status:\n71:             return {\n72:                 \"status\": cr_status.get(\"status\", \"unknown\"),\n73:                 \"agent_name\": metadata.agent_name,\n74:                 \"endpoint\": cr_status.get(\"agentEndpoint\", metadata.agent_endpoint),\n75:                 \"cr_name\": cr_name,\n76:                 \"namespace\": namespace,\n77:                 \"version\": metadata.version,\n78:             }\n79:         else:\n80:             return {\n81:                 \"status\": \"created_no_status\",\n82:                 \"agent_name\": metadata.agent_name,\n83:                 \"cr_name\": cr_name,\n84:                 \"namespace\": namespace,\n85:                 \"version\": metadata.version,\n86:             }\n87: \n88:     def _get_k8s_status(self, metadata: AgentMetadata) -> Dict[str, Any]:\n89:         \"\"\"Get status from standard Kubernetes deployment.\n90: \n91:         Args:\n92:             metadata: The agent metadata.\n93: \n94:         Returns:\n95:             Dict with K8s deployment status information.\n96:         \"\"\"\n97:         namespace = metadata.k8s_deployment.get(\"namespace\", \"default\") if metadata.k8s_deployment else \"default\"\n98:         deployment_name = metadata.k8s_deployment.get(\"deployment_name\", metadata.agent_name) if metadata.k8s_deployment else metadata.agent_name\n99: \n100:         provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n101:         return provider.get_agent_status(deployment_name)\n\n(End of file - total 101 lines)\n</content>","metadata":{"preview":"\"\"\"StatusRuntime for checking deployed agent status.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass StatusRuntime:\n    \"\"\"Runtime for checking agent deployment status with provider-aware logic.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider\n\n    def get_status(","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/status_runtime.py","time":{"start":1775857441227,"end":1775857441307}}}}
{"type":"tool_use","timestamp":1775857442520,"sessionID":"ses_286a623ebffexQ6eQhlYTCp58v","part":{"id":"prt_d795a1a99001KYIL13sQEDcyUt","messageID":"msg_d795a088c001UVQl0NKNwxzW4A","sessionID":"ses_286a623ebffexQ6eQhlYTCp58v","type":"tool","tool":"read","callID":"call_7d91544f7bc14c79b9fb7b03","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/cli/main.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/cli/main.py</path>\n<type>file</type>\n<content>\n1: \"\"\"AgentCube CLI entry point.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: from typing import Dict, List, Optional\n7: \n8: import typer\n9: from rich.console import Console\n10: from rich.progress import Progress, SpinnerColumn, TextColumn\n11: \n12: from pathlib import Path\n13: \n14: from agentcube import __version__\n15: from agentcube.runtime.pack_runtime import PackRuntime\n16: from agentcube.runtime.build_runtime import BuildRuntime\n17: from agentcube.runtime.publish_runtime import PublishRuntime\n18: \n19: app = typer.Typer(\n20:     name=\"agentcube\",\n21:     help=\"AgentCube CLI - A developer tool for AI agent lifecycle management.\",\n22:     no_args_is_help=True,\n23:     rich_markup_mode=\"rich\",\n24:     add_completion=False,\n25: )\n26: \n27: console = Console()\n28: \n29: \n30: def version_callback(value: Optional[bool]) -> None:\n31:     \"\"\"Print version and exit.\"\"\"\n32:     if value:\n33:         console.print(f\"agentcube {__version__}\")\n34:         raise typer.Exit()\n35: \n36: \n37: @app.callback()\n38: def main(\n39:     version: Optional[bool] = typer.Option(\n40:         None,\n41:         \"--version\",\n42:         help=\"Show version and exit.\",\n43:         callback=version_callback,\n44:         is_eager=True,\n45:     ),\n46:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Enable verbose output.\"),\n47: ) -> None:\n48:     \"\"\"AgentCube CLI - A developer tool for AI agent lifecycle management.\"\"\"\n49:     if verbose:\n50:         logging.basicConfig(level=logging.DEBUG)\n51: \n52: \n53: def _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n54:     \"\"\"Handle errors by printing a message and optionally a traceback.\"\"\"\n55:     console.print(f\"[red]Error {command_name}: {e}[/red]\")\n56:     if verbose:\n57:         console.print_exception()\n58:     raise typer.Exit(1)\n59: \n60: \n61: @app.command()\n62: def pack(\n63:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory.\", show_default=True),\n64:     agent_name: Optional[str] = typer.Option(None, \"--agent-name\", help=\"Override the agent name.\"),\n65:     language: Optional[str] = typer.Option(None, \"--language\", help=\"Programming language (python, java).\"),\n66:     entrypoint: Optional[str] = typer.Option(None, \"--entrypoint\", help=\"Override the entrypoint command.\"),\n67:     port: Optional[int] = typer.Option(None, \"--port\", help=\"Port to expose in the Dockerfile.\"),\n68:     build_mode: Optional[str] = typer.Option(None, \"--build-mode\", help=\"Build strategy: local or cloud.\"),\n69:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description.\"),\n70:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for packaged workspace.\"),\n71:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging.\"),\n72: ) -> None:\n73:     \"\"\"Package an agent workspace for the AgentCube lifecycle.\"\"\"\n74:     with Progress(\n75:         SpinnerColumn(),\n76:         TextColumn(\"[progress.description]{task.description}\"),\n77:         transient=True,\n78:     ) as progress:\n79:         task = progress.add_task(\"Packaging agent...\", total=None)\n80:         try:\n81:             runtime = PackRuntime(verbose=verbose)\n82:             from pathlib import Path\n83:             workspace_path = Path(workspace).resolve()\n84:             result = runtime.pack(\n85:                 workspace_path,\n86:                 agent_name=agent_name,\n87:                 language=language,\n88:                 entrypoint=entrypoint,\n89:                 port=port,\n90:                 build_mode=build_mode,\n91:                 description=description,\n92:                 output=output,\n93:             )\n94:             progress.update(task, description=\"Done\")\n95:             console.print(f\"[green]✓[/green] Agent '[bold]{result['agent_name']}[/bold]' packaged successfully!\")\n96:             console.print(f\"  [dim]Workspace:[/dim] {result['workspace_path']}\")\n97:             console.print(f\"  [dim]Metadata: [/dim] {result['metadata_path']}\")\n98:         except Exception as e:\n99:             _handle_error(e, \"packaging agent\", verbose)\n100: \n101: \n102: @app.command()\n103: def build(\n104:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory.\", show_default=True),\n105:     proxy: Optional[str] = typer.Option(None, \"-p\", \"--proxy\", help=\"Custom proxy URL for dependency resolution.\"),\n106:     cloud_provider: Optional[str] = typer.Option(None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei).\"),\n107:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for build artifacts.\"),\n108:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging.\"),\n109: ) -> None:\n110:     \"\"\"Build a container image from a packaged agent workspace.\"\"\"\n111:     workspace_path = Path(workspace).resolve()\n112:     try:\n113:         with Progress(\n114:             SpinnerColumn(),\n115:             TextColumn(\"[progress.description]{task.description}\"),\n116:             transient=True,\n117:         ) as progress:\n118:             progress.add_task(\"Building agent...\", total=None)\n119:             runtime = BuildRuntime(verbose=verbose)\n120:             result = runtime.build(\n121:                 workspace_path,\n122:                 proxy=proxy,\n123:                 cloud_provider=cloud_provider,\n124:                 output=output,\n125:             )\n126: \n127:         metadata = runtime.metadata_service.load_metadata(workspace_path)\n128:         agent_name = metadata.agent_name if metadata else \"unknown\"\n129:         tag = metadata.version if metadata and metadata.version else \"latest\"\n130:         image_name = result.get(\"image_name\", agent_name)\n131:         image_size = result.get(\"image_size\", \"N/A\")\n132:         build_time = result.get(\"build_time\", \"N/A\")\n133: \n134:         console.print(f\"[green]✓[/green] Agent '[bold]{agent_name}[/bold]' built successfully!\")\n135:         console.print(f\"  [dim]Image:  [/dim] {image_name}:{tag}\")\n136:         console.print(f\"  [dim]Size:   [/dim] {image_size}\")\n137:         console.print(f\"  [dim]Time:   [/dim] {build_time}\")\n138:     except Exception as e:\n139:         _handle_error(e, \"building agent\", verbose)\n140: \n141: \n142: @app.command()\n143: def publish(\n144:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory.\", show_default=True),\n145:     version: Optional[str] = typer.Option(None, \"--version\", help=\"Semantic version string (e.g., v1.0.0).\"),\n146:     image_url: Optional[str] = typer.Option(None, \"--image-url\", help=\"Image repository URL (required in local build mode).\"),\n147:     image_username: Optional[str] = typer.Option(None, \"--image-username\", help=\"Username for image repository.\"),\n148:     image_password: Optional[str] = typer.Option(None, \"--image-password\", help=\"Password for image repository.\"),\n149:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description.\"),\n150:     region: Optional[str] = typer.Option(None, \"--region\", help=\"Deployment region.\"),\n151:     cloud_provider: Optional[str] = typer.Option(None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei).\"),\n152:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: agentcube (AgentRuntime CR) or k8s (Deployment/Service).\"),\n153:     node_port: Optional[int] = typer.Option(None, \"--node-port\", help=\"Specific NodePort (30000-32767) for K8s deployment.\"),\n154:     replicas: Optional[int] = typer.Option(None, \"--replicas\", help=\"Number of replicas for K8s deployment.\"),\n155:     namespace: Optional[str] = typer.Option(None, \"--namespace\", help=\"The namespace for the deployment.\"),\n156:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging.\"),\n157: ) -> None:\n158:     \"\"\"Publish a packaged agent to a Kubernetes cluster.\"\"\"\n159:     workspace_path = Path(workspace).resolve()\n160: \n161:     if provider not in (\"agentcube\", \"k8s\"):\n162:         _handle_error(ValueError(f\"Unsupported provider: {provider}. Must be 'agentcube' or 'k8s'.\"), \"publishing agent\", verbose)\n163: \n164:     if node_port is not None and not (30000 <= node_port <= 32767):\n165:         _handle_error(ValueError(\"NodePort must be between 30000 and 32767\"), \"publishing agent\", verbose)\n166: \n167:     try:\n168:         with Progress(\n169:             SpinnerColumn(),\n170:             TextColumn(\"[progress.description]{task.description}\"),\n171:             transient=True,\n172:         ) as progress:\n173:             progress.add_task(\"Publishing agent...\", total=None)\n174:             runtime = PublishRuntime(verbose=verbose, provider=provider)\n175:             result = runtime.publish(\n176:                 workspace_path,\n177:                 version=version,\n178:                 image_url=image_url,\n179:                 image_username=image_username,\n180:                 image_password=image_password,\n181:                 description=description,\n182:                 region=region,\n183:                 cloud_provider=cloud_provider,\n184:                 node_port=node_port,\n185:                 replicas=replicas,\n186:                 namespace=namespace,\n187:             )\n188: \n189:         from agentcube.services.metadata_service import MetadataService\n190:         _meta = MetadataService(verbose=verbose).load_metadata(workspace_path)\n191:         agent_name = _meta.agent_name if _meta else \"unknown\"\n192: \n193:         if provider == \"agentcube\":\n194:             console.print(f\"[green]✓[/green] Agent '[bold]{agent_name}[/bold]' published successfully!\")\n195:             console.print(f\"  [dim]Workspace:[/dim] {workspace_path}\")\n196:             console.print(f\"  [dim]Agent ID: [/dim] {result.get('agent_id', 'N/A')}\")\n197:             console.print(f\"  [dim]Endpoint:[/dim] {result.get('agent_endpoint', 'N/A')}\")\n198:         else:\n199:             console.print(f\"[green]✓[/green] Agent '[bold]{agent_name}[/bold]' published successfully!\")\n200:             console.print(f\"  [dim]Workspace:[/dim] {workspace_path}\")\n201:             console.print(f\"  [dim]Deployment:[/dim] {result.get('deployment_name', 'N/A')}\")\n202:             console.print(f\"  [dim]Service: [/dim] {result.get('service_name', 'N/A')}\")\n203:             console.print(f\"  [dim]URL:     [/dim] {result.get('service_url', 'N/A')}\")\n204:     except Exception as e:\n205:         _handle_error(e, \"publishing agent\", verbose)\n206: \n207: \n208: @app.command()\n209: def invoke(\n210:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory.\", show_default=True),\n211:     payload: str = typer.Option(\"{}\", \"--payload\", help=\"JSON-formatted input passed to the agent.\"),\n212:     header_list: Optional[List[str]] = typer.Option(None, \"--header\", help=\"Custom HTTP headers (e.g., 'Authorization: Bearer token'). Can be specified multiple times.\"),\n213:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service).\"),\n214:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging.\"),\n215: ) -> None:\n216:     \"\"\"Invoke a deployed agent with a JSON payload.\"\"\"\n217:     import json\n218: \n219:     try:\n220:         payload_dict = json.loads(payload)\n221:     except json.JSONDecodeError as e:\n222:         console.print(f\"[red]Error: Invalid JSON payload: {e}[/red]\")\n223:         raise typer.Exit(1)\n224: \n225:     headers: Optional[Dict[str, str]] = None\n226:     if header_list:\n227:         headers = {}\n228:         for h in header_list:\n229:             if \":\" not in h:\n230:                 console.print(f\"[red]Error: Invalid header format. Expected 'key:value'.[/red]\")\n231:                 raise typer.Exit(1)\n232:             key, value = h.split(\":\", 1)\n233:             headers[key.strip()] = value.strip()\n234: \n235:     try:\n236:         from agentcube.runtime.invoke_runtime import InvokeRuntime\n237: \n238:         runtime = InvokeRuntime(verbose=verbose, provider=provider)\n239:         response = runtime.invoke(Path(workspace), payload_dict, headers)\n240: \n241:         if isinstance(response, dict):\n242:             console.print_json(json.dumps(response))\n243:         else:\n244:             console.print(str(response))\n245:     except typer.Exit:\n246:         raise\n247:     except Exception as e:\n248:         _handle_error(e, \"invoking agent\", verbose)\n249: \n250: \n251: @app.command()\n252: def status(\n253:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory.\", show_default=True),\n254:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service).\"),\n255:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging.\"),\n256: ) -> None:\n257:     \"\"\"Check the status of a deployed agent.\"\"\"\n258:     from rich.table import Table\n259: \n260:     try:\n261:         from agentcube.runtime.status_runtime import StatusRuntime\n262: \n263:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n264:         result = runtime.get_status(Path(workspace), provider)\n265: \n266:         if result.get(\"status\") == \"not_published\":\n267:             console.print(\"[yellow]Agent has not been published yet.[/yellow]\")\n268:             console.print(\"Run [bold]kubectl-agentcube publish[/bold] first to deploy the agent.\")\n269:             raise typer.Exit(1)\n270: \n271:         if result.get(\"status\") == \"error\":\n272:             console.print(f\"[red]Error: {result.get('message', 'Unknown error')}[/red]\")\n273:             raise typer.Exit(1)\n274: \n275:         table = Table(show_header=True, header_style=\"bold cyan\")\n276:         table.add_column(\"Field\", style=\"dim\")\n277:         table.add_column(\"Value\")\n278: \n279:         for key, value in result.items():\n280:             table.add_row(str(key), str(value))\n281: \n282:         console.print(table)\n283:     except typer.Exit:\n284:         raise\n285:     except Exception as e:\n286:         _handle_error(e, \"getting status\", verbose)\n\n(End of file - total 286 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube CLI entry point.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom typing import Dict, List, Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\n\nfrom pathlib import Path\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.runtime.publish_runtime import PublishRuntime\n\napp = typer.Typer(\n    name=\"agentcube\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/cli/main.py","time":{"start":1775857442511,"end":1775857442518}}}}
