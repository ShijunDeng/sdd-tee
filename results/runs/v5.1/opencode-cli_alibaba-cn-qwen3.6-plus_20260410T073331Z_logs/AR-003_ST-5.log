{"type":"tool_use","timestamp":1775812293580,"sessionID":"ses_28959beedffejL0cu1e0mvWtte","part":{"id":"prt_d76a92e5f001Jwa2hmH7xjgEzi","messageID":"msg_d76a92473001QCCsXpNXShGu9x","sessionID":"ses_28959beedffejL0cu1e0mvWtte","type":"tool","tool":"read","callID":"call_805d98b3690249b6934dab8a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go</path>\n<type>file</type>\n<content>\n1: package v1alpha1\n2: \n3: import (\n4: \t\"testing\"\n5: \t\"time\"\n6: \n7: \t\"github.com/stretchr/testify/assert\"\n8: \tcorev1 \"k8s.io/api/core/v1\"\n9: \t\"k8s.io/apimachinery/pkg/api/resource\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: )\n12: \n13: func TestProtocolTypeConstants(t *testing.T) {\n14: \tassert.Equal(t, ProtocolType(\"HTTP\"), ProtocolTypeHTTP)\n15: \tassert.Equal(t, ProtocolType(\"HTTPS\"), ProtocolTypeHTTPS)\n16: }\n17: \n18: func TestAuthModeTypeConstants(t *testing.T) {\n19: \tassert.Equal(t, AuthModeType(\"picod\"), AuthModePicoD)\n20: \tassert.Equal(t, AuthModeType(\"none\"), AuthModeNone)\n21: }\n22: \n23: func TestTargetPortDefaults(t *testing.T) {\n24: \ttp := TargetPort{\n25: \t\tPort: 8080,\n26: \t}\n27: \n28: \tassert.Equal(t, uint32(8080), tp.Port)\n29: \tassert.Empty(t, tp.PathPrefix)\n30: \tassert.Empty(t, tp.Name)\n31: \tassert.Equal(t, ProtocolType(\"\"), tp.Protocol)\n32: }\n33: \n34: func TestTargetPortWithAllFields(t *testing.T) {\n35: \ttp := TargetPort{\n36: \t\tPathPrefix: \"/api\",\n37: \t\tName:       \"api\",\n38: \t\tPort:       3000,\n39: \t\tProtocol:   ProtocolTypeHTTPS,\n40: \t}\n41: \n42: \tassert.Equal(t, \"/api\", tp.PathPrefix)\n43: \tassert.Equal(t, \"api\", tp.Name)\n44: \tassert.Equal(t, uint32(3000), tp.Port)\n45: \tassert.Equal(t, ProtocolTypeHTTPS, tp.Protocol)\n46: }\n47: \n48: func TestTargetPortDeepCopy(t *testing.T) {\n49: \toriginal := &TargetPort{\n50: \t\tPathPrefix: \"/api\",\n51: \t\tName:       \"api\",\n52: \t\tPort:       3000,\n53: \t\tProtocol:   ProtocolTypeHTTPS,\n54: \t}\n55: \n56: \tcp := original.DeepCopy()\n57: \n58: \tassert.Equal(t, original.Port, cp.Port)\n59: \tassert.Equal(t, original.Protocol, cp.Protocol)\n60: \n61: \tcp.Port = 9090\n62: \tassert.Equal(t, uint32(3000), original.Port)\n63: }\n64: \n65: func TestCodeInterpreterSpecDefaults(t *testing.T) {\n66: \tci := &CodeInterpreterSpec{\n67: \t\tTemplate: &CodeInterpreterSandboxTemplate{},\n68: \t}\n69: \n70: \tassert.Empty(t, ci.Ports)\n71: \tassert.Nil(t, ci.SessionTimeout)\n72: \tassert.Nil(t, ci.MaxSessionDuration)\n73: \tassert.Nil(t, ci.WarmPoolSize)\n74: \tassert.Equal(t, AuthModeType(\"\"), ci.AuthMode)\n75: }\n76: \n77: func TestCodeInterpreterSandboxTemplateDeepCopy(t *testing.T) {\n78: \truntimeClass := \"kuasar-vmm\"\n79: \toriginal := &CodeInterpreterSandboxTemplate{\n80: \t\tLabels:           map[string]string{\"app\": \"test\"},\n81: \t\tAnnotations:      map[string]string{\"key\": \"value\"},\n82: \t\tRuntimeClassName: &runtimeClass,\n83: \t\tImage:            \"python:3.11\",\n84: \t\tImagePullPolicy:  corev1.PullIfNotPresent,\n85: \t\tCommand:          []string{\"python\", \"-m\", \"http.server\"},\n86: \t\tArgs:             []string{\"8080\"},\n87: \t}\n88: \n89: \tcp := original.DeepCopy()\n90: \n91: \tassert.Equal(t, original.Image, cp.Image)\n92: \tassert.Equal(t, original.Labels[\"app\"], cp.Labels[\"app\"])\n93: \tassert.Equal(t, *original.RuntimeClassName, *cp.RuntimeClassName)\n94: \n95: \tcp.Labels[\"app\"] = \"modified\"\n96: \tassert.Equal(t, \"test\", original.Labels[\"app\"])\n97: \n98: \tcp.Image = \"modified:latest\"\n99: \tassert.Equal(t, \"python:3.11\", original.Image)\n100: }\n101: \n102: func TestCodeInterpreterDeepCopy(t *testing.T) {\n103: \toriginal := &CodeInterpreter{\n104: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n105: \t\tSpec: CodeInterpreterSpec{\n106: \t\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n107: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n108: \t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n109: \t\t\t\tImage:  \"python:3.11\",\n110: \t\t\t},\n111: \t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n112: \t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n113: \t\t\tWarmPoolSize:       ptrInt32(3),\n114: \t\t\tAuthMode:           AuthModePicoD,\n115: \t\t},\n116: \t\tStatus: CodeInterpreterStatus{\n117: \t\t\tReady: true,\n118: \t\t},\n119: \t}\n120: \n121: \tcp := original.DeepCopy()\n122: \n123: \tassert.Equal(t, original.Name, cp.Name)\n124: \tassert.Equal(t, original.Spec.WarmPoolSize, cp.Spec.WarmPoolSize)\n125: \tassert.Equal(t, original.Spec.AuthMode, cp.Spec.AuthMode)\n126: \tassert.Equal(t, original.Status.Ready, cp.Status.Ready)\n127: \n128: \tcp.Spec.WarmPoolSize = ptrInt32(5)\n129: \tassert.Equal(t, int32(3), *original.Spec.WarmPoolSize)\n130: }\n131: \n132: func TestCodeInterpreterListDeepCopy(t *testing.T) {\n133: \toriginal := &CodeInterpreterList{\n134: \t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n135: \t\tItems: []CodeInterpreter{\n136: \t\t\t{\n137: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n138: \t\t\t\tSpec: CodeInterpreterSpec{\n139: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n140: \t\t\t\t\t\tImage: \"python:3.11\",\n141: \t\t\t\t\t},\n142: \t\t\t\t},\n143: \t\t\t},\n144: \t\t},\n145: \t}\n146: \n147: \tcp := original.DeepCopy()\n148: \n149: \tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n150: \tassert.Equal(t, len(original.Items), len(cp.Items))\n151: \tassert.Equal(t, original.Items[0].Name, cp.Items[0].Name)\n152: \n153: \tcp.Items[0].Name = \"modified\"\n154: \tassert.Equal(t, \"ci1\", original.Items[0].Name)\n155: }\n156: \n157: func ptrInt32(i int32) *int32 {\n158: \treturn &i\n159: }\n160: \n161: func TestCodeInterpreterStatusDefaults(t *testing.T) {\n162: \tstatus := CodeInterpreterStatus{}\n163: \n164: \tassert.Empty(t, status.Conditions)\n165: \tassert.False(t, status.Ready)\n166: }\n167: \n168: func TestCodeInterpreterStatusWithConditions(t *testing.T) {\n169: \tstatus := CodeInterpreterStatus{\n170: \t\tConditions: []metav1.Condition{\n171: \t\t\t{\n172: \t\t\t\tType:               \"Ready\",\n173: \t\t\t\tStatus:             metav1.ConditionTrue,\n174: \t\t\t\tReason:             \"SandboxRunning\",\n175: \t\t\t\tMessage:            \"Code interpreter sandbox is running\",\n176: \t\t\t\tLastTransitionTime: metav1.Now(),\n177: \t\t\t},\n178: \t\t},\n179: \t\tReady: true,\n180: \t}\n181: \n182: \tassert.Len(t, status.Conditions, 1)\n183: \tassert.Equal(t, \"Ready\", status.Conditions[0].Type)\n184: \tassert.Equal(t, metav1.ConditionTrue, status.Conditions[0].Status)\n185: \tassert.Equal(t, \"SandboxRunning\", status.Conditions[0].Reason)\n186: \tassert.True(t, status.Ready)\n187: }\n188: \n189: func TestCodeInterpreterStatusDeepCopy(t *testing.T) {\n190: \toriginal := &CodeInterpreterStatus{\n191: \t\tConditions: []metav1.Condition{\n192: \t\t\t{\n193: \t\t\t\tType:   \"Ready\",\n194: \t\t\t\tStatus: metav1.ConditionTrue,\n195: \t\t\t\tReason: \"SandboxRunning\",\n196: \t\t\t},\n197: \t\t},\n198: \t\tReady: true,\n199: \t}\n200: \n201: \tcp := original.DeepCopy()\n202: \n203: \tassert.Equal(t, original.Conditions[0].Type, cp.Conditions[0].Type)\n204: \tassert.Equal(t, original.Conditions[0].Reason, cp.Conditions[0].Reason)\n205: \tassert.Equal(t, original.Ready, cp.Ready)\n206: \n207: \tcp.Conditions[0].Reason = \"Modified\"\n208: \tassert.Equal(t, \"SandboxRunning\", original.Conditions[0].Reason)\n209: \n210: \tcp.Ready = false\n211: \tassert.True(t, original.Ready)\n212: }\n213: \n214: func TestCodeInterpreterSpecDeepCopy(t *testing.T) {\n215: \toriginal := &CodeInterpreterSpec{\n216: \t\tPorts: []TargetPort{\n217: \t\t\t{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP},\n218: \t\t\t{Name: \"api\", Port: 3000, Protocol: ProtocolTypeHTTPS},\n219: \t\t},\n220: \t\tTemplate: &CodeInterpreterSandboxTemplate{\n221: \t\t\tLabels: map[string]string{\"app\": \"test\"},\n222: \t\t\tImage:  \"python:3.11\",\n223: \t\t},\n224: \t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n225: \t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n226: \t\tWarmPoolSize:       ptrInt32(3),\n227: \t\tAuthMode:           AuthModePicoD,\n228: \t}\n229: \n230: \tcp := original.DeepCopy()\n231: \n232: \tassert.Equal(t, original.Ports[0].Port, cp.Ports[0].Port)\n233: \tassert.Equal(t, original.SessionTimeout.Duration, cp.SessionTimeout.Duration)\n234: \tassert.Equal(t, original.WarmPoolSize, cp.WarmPoolSize)\n235: \n236: \tcp.Ports[0].Port = 9090\n237: \tassert.Equal(t, uint32(8080), original.Ports[0].Port)\n238: \n239: \tcp.WarmPoolSize = ptrInt32(10)\n240: \tassert.Equal(t, int32(3), *original.WarmPoolSize)\n241: \n242: \tcp.Template.Labels[\"app\"] = \"modified\"\n243: \tassert.Equal(t, \"test\", original.Template.Labels[\"app\"])\n244: }\n245: \n246: func TestCodeInterpreterSpecDeepCopyNilFields(t *testing.T) {\n247: \toriginal := &CodeInterpreterSpec{\n248: \t\tTemplate: &CodeInterpreterSandboxTemplate{\n249: \t\t\tImage: \"python:3.11\",\n250: \t\t},\n251: \t}\n252: \n253: \tcp := original.DeepCopy()\n254: \n255: \tassert.Nil(t, cp.SessionTimeout)\n256: \tassert.Nil(t, cp.MaxSessionDuration)\n257: \tassert.Nil(t, cp.WarmPoolSize)\n258: \tassert.Empty(t, cp.Ports)\n259: \tassert.Equal(t, AuthModeType(\"\"), cp.AuthMode)\n260: }\n261: \n262: func TestCodeInterpreterSandboxTemplateAllFields(t *testing.T) {\n263: \truntimeClass := \"kuasar-vmm\"\n264: \ttemplate := &CodeInterpreterSandboxTemplate{\n265: \t\tLabels:           map[string]string{\"app\": \"code-interpreter\"},\n266: \t\tAnnotations:      map[string]string{\"agentcube.io/version\": \"1\"},\n267: \t\tRuntimeClassName: &runtimeClass,\n268: \t\tImage:            \"python:3.11-slim\",\n269: \t\tImagePullPolicy:  corev1.PullAlways,\n270: \t\tImagePullSecrets: []corev1.LocalObjectReference{\n271: \t\t\t{Name: \"registry-secret\"},\n272: \t\t},\n273: \t\tEnvironment: []corev1.EnvVar{\n274: \t\t\t{Name: \"PYTHONPATH\", Value: \"/app\"},\n275: \t\t\t{Name: \"DEBUG\", Value: \"false\"},\n276: \t\t},\n277: \t\tCommand: []string{\"python\", \"-m\", \"http.server\"},\n278: \t\tArgs:    []string{\"8080\"},\n279: \t\tResources: corev1.ResourceRequirements{\n280: \t\t\tRequests: corev1.ResourceList{\n281: \t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n282: \t\t\t\tcorev1.ResourceMemory: parseQuantity(\"2Gi\"),\n283: \t\t\t},\n284: \t\t\tLimits: corev1.ResourceList{\n285: \t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"2\"),\n286: \t\t\t\tcorev1.ResourceMemory: parseQuantity(\"4Gi\"),\n287: \t\t\t},\n288: \t\t},\n289: \t}\n290: \n291: \tassert.Equal(t, \"code-interpreter\", template.Labels[\"app\"])\n292: \tassert.Equal(t, \"1\", template.Annotations[\"agentcube.io/version\"])\n293: \tassert.Equal(t, \"kuasar-vmm\", *template.RuntimeClassName)\n294: \tassert.Equal(t, \"python:3.11-slim\", template.Image)\n295: \tassert.Equal(t, corev1.PullAlways, template.ImagePullPolicy)\n296: \tassert.Len(t, template.ImagePullSecrets, 1)\n297: \tassert.Equal(t, \"registry-secret\", template.ImagePullSecrets[0].Name)\n298: \tassert.Len(t, template.Environment, 2)\n299: \tassert.Equal(t, \"/app\", template.Environment[0].Value)\n300: \tassert.Len(t, template.Command, 3)\n301: \tassert.Len(t, template.Args, 1)\n302: \tassert.NotNil(t, template.Resources.Requests)\n303: \tassert.NotNil(t, template.Resources.Limits)\n304: }\n305: \n306: func TestCodeInterpreterSandboxTemplateDeepCopyIsolation(t *testing.T) {\n307: \truntimeClass := \"gvisor\"\n308: \toriginal := &CodeInterpreterSandboxTemplate{\n309: \t\tLabels:           map[string]string{\"app\": \"test\"},\n310: \t\tAnnotations:      map[string]string{\"key\": \"value\"},\n311: \t\tRuntimeClassName: &runtimeClass,\n312: \t\tImage:            \"python:3.11\",\n313: \t\tImagePullPolicy:  corev1.PullIfNotPresent,\n314: \t\tImagePullSecrets: []corev1.LocalObjectReference{{Name: \"secret1\"}},\n315: \t\tEnvironment:      []corev1.EnvVar{{Name: \"VAR\", Value: \"val\"}},\n316: \t\tCommand:          []string{\"python\"},\n317: \t\tArgs:             []string{\"script.py\"},\n318: \t}\n319: \n320: \tcp := original.DeepCopy()\n321: \n322: \tcp.Labels[\"app\"] = \"modified\"\n323: \tassert.Equal(t, \"test\", original.Labels[\"app\"])\n324: \n325: \tcp.Annotations[\"key\"] = \"modified\"\n326: \tassert.Equal(t, \"value\", original.Annotations[\"key\"])\n327: \n328: \t*cp.RuntimeClassName = \"modified\"\n329: \tassert.Equal(t, \"gvisor\", *original.RuntimeClassName)\n330: \n331: \tcp.ImagePullSecrets[0].Name = \"modified\"\n332: \tassert.Equal(t, \"secret1\", original.ImagePullSecrets[0].Name)\n333: \n334: \tcp.Environment[0].Value = \"modified\"\n335: \tassert.Equal(t, \"val\", original.Environment[0].Value)\n336: \n337: \tcp.Command[0] = \"modified\"\n338: \tassert.Equal(t, \"python\", original.Command[0])\n339: \n340: \tcp.Args[0] = \"modified\"\n341: \tassert.Equal(t, \"script.py\", original.Args[0])\n342: }\n343: \n344: func TestCodeInterpreterSandboxTemplateDeepCopyNilFields(t *testing.T) {\n345: \toriginal := &CodeInterpreterSandboxTemplate{\n346: \t\tImage: \"python:3.11\",\n347: \t}\n348: \n349: \tcp := original.DeepCopy()\n350: \n351: \tassert.Nil(t, cp.Labels)\n352: \tassert.Nil(t, cp.Annotations)\n353: \tassert.Nil(t, cp.RuntimeClassName)\n354: \tassert.Empty(t, cp.ImagePullSecrets)\n355: \tassert.Empty(t, cp.Environment)\n356: \tassert.Empty(t, cp.Command)\n357: \tassert.Empty(t, cp.Args)\n358: }\n359: \n360: func TestCodeInterpreterWithAllFields(t *testing.T) {\n361: \tci := &CodeInterpreter{\n362: \t\tTypeMeta: metav1.TypeMeta{\n363: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n364: \t\t\tKind:       \"CodeInterpreter\",\n365: \t\t},\n366: \t\tObjectMeta: metav1.ObjectMeta{\n367: \t\t\tName:      \"python-interpreter\",\n368: \t\t\tNamespace: \"default\",\n369: \t\t\tLabels:    map[string]string{\"app\": \"code-interpreter\"},\n370: \t\t},\n371: \t\tSpec: CodeInterpreterSpec{\n372: \t\t\tPorts: []TargetPort{\n373: \t\t\t\t{\n374: \t\t\t\t\tName:       \"web\",\n375: \t\t\t\t\tPort:       8080,\n376: \t\t\t\t\tProtocol:   ProtocolTypeHTTP,\n377: \t\t\t\t\tPathPrefix: \"/\",\n378: \t\t\t\t},\n379: \t\t\t},\n380: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n381: \t\t\t\tLabels:      map[string]string{\"app\": \"python-interpreter\"},\n382: \t\t\t\tAnnotations: map[string]string{\"agentcube.io/runtime\": \"python-3.11\"},\n383: \t\t\t\tImage:       \"python:3.11-slim\",\n384: \t\t\t\tCommand:     []string{\"python\", \"-m\", \"http.server\"},\n385: \t\t\t\tArgs:        []string{\"8080\"},\n386: \t\t\t},\n387: \t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n388: \t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n389: \t\t\tWarmPoolSize:       ptrInt32(3),\n390: \t\t\tAuthMode:           AuthModePicoD,\n391: \t\t},\n392: \t\tStatus: CodeInterpreterStatus{\n393: \t\t\tConditions: []metav1.Condition{\n394: \t\t\t\t{\n395: \t\t\t\t\tType:   \"Ready\",\n396: \t\t\t\t\tStatus: metav1.ConditionTrue,\n397: \t\t\t\t\tReason: \"SandboxRunning\",\n398: \t\t\t\t},\n399: \t\t\t},\n400: \t\t\tReady: true,\n401: \t\t},\n402: \t}\n403: \n404: \tassert.Equal(t, \"runtime.agentcube.volcano.sh/v1alpha1\", ci.APIVersion)\n405: \tassert.Equal(t, \"CodeInterpreter\", ci.Kind)\n406: \tassert.Equal(t, \"python-interpreter\", ci.Name)\n407: \tassert.Equal(t, \"default\", ci.Namespace)\n408: \tassert.Len(t, ci.Spec.Ports, 1)\n409: \tassert.Equal(t, uint32(8080), ci.Spec.Ports[0].Port)\n410: \tassert.Equal(t, ProtocolTypeHTTP, ci.Spec.Ports[0].Protocol)\n411: \tassert.Equal(t, \"/\", ci.Spec.Ports[0].PathPrefix)\n412: \tassert.NotNil(t, ci.Spec.Template)\n413: \tassert.Equal(t, \"python:3.11-slim\", ci.Spec.Template.Image)\n414: \tassert.Equal(t, 15*time.Minute, ci.Spec.SessionTimeout.Duration)\n415: \tassert.Equal(t, 8*time.Hour, ci.Spec.MaxSessionDuration.Duration)\n416: \tassert.Equal(t, int32(3), *ci.Spec.WarmPoolSize)\n417: \tassert.Equal(t, AuthModePicoD, ci.Spec.AuthMode)\n418: \tassert.True(t, ci.Status.Ready)\n419: \tassert.Len(t, ci.Status.Conditions, 1)\n420: }\n421: \n422: func TestCodeInterpreterWithNilTemplate(t *testing.T) {\n423: \tci := &CodeInterpreter{\n424: \t\tSpec: CodeInterpreterSpec{\n425: \t\t\tTemplate: nil,\n426: \t\t},\n427: \t}\n428: \n429: \tassert.Nil(t, ci.Spec.Template)\n430: \tassert.Nil(t, ci.Spec.SessionTimeout)\n431: \tassert.Nil(t, ci.Spec.MaxSessionDuration)\n432: \tassert.Nil(t, ci.Spec.WarmPoolSize)\n433: \tassert.Equal(t, AuthModeType(\"\"), ci.Spec.AuthMode)\n434: }\n435: \n436: func TestCodeInterpreterWithEmptyPorts(t *testing.T) {\n437: \tci := &CodeInterpreter{\n438: \t\tSpec: CodeInterpreterSpec{\n439: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n440: \t\t\t\tImage: \"python:3.11\",\n441: \t\t\t},\n442: \t\t},\n443: \t}\n444: \n445: \tassert.Empty(t, ci.Spec.Ports)\n446: \tassert.Nil(t, ci.Spec.SessionTimeout)\n447: \tassert.Nil(t, ci.Spec.MaxSessionDuration)\n448: }\n449: \n450: func TestCodeInterpreterListItems(t *testing.T) {\n451: \tlist := &CodeInterpreterList{\n452: \t\tListMeta: metav1.ListMeta{\n453: \t\t\tResourceVersion: \"12345\",\n454: \t\t\tContinue:        \"token\",\n455: \t\t},\n456: \t\tItems: []CodeInterpreter{\n457: \t\t\t{\n458: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n459: \t\t\t\tSpec: CodeInterpreterSpec{\n460: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n461: \t\t\t\t},\n462: \t\t\t\tStatus: CodeInterpreterStatus{Ready: true},\n463: \t\t\t},\n464: \t\t\t{\n465: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci2\", Namespace: \"kube-system\"},\n466: \t\t\t\tSpec: CodeInterpreterSpec{\n467: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.10\"},\n468: \t\t\t\t},\n469: \t\t\t\tStatus: CodeInterpreterStatus{Ready: false},\n470: \t\t\t},\n471: \t\t},\n472: \t}\n473: \n474: \tassert.Equal(t, \"12345\", list.ListMeta.ResourceVersion)\n475: \tassert.Len(t, list.Items, 2)\n476: \tassert.Equal(t, \"ci1\", list.Items[0].Name)\n477: \tassert.Equal(t, \"default\", list.Items[0].Namespace)\n478: \tassert.True(t, list.Items[0].Status.Ready)\n479: \tassert.Equal(t, \"ci2\", list.Items[1].Name)\n480: \tassert.Equal(t, \"kube-system\", list.Items[1].Namespace)\n481: \tassert.False(t, list.Items[1].Status.Ready)\n482: }\n483: \n484: func TestCodeInterpreterListDeepCopyIsolation(t *testing.T) {\n485: \toriginal := &CodeInterpreterList{\n486: \t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n487: \t\tItems: []CodeInterpreter{\n488: \t\t\t{\n489: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n490: \t\t\t\tSpec: CodeInterpreterSpec{\n491: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n492: \t\t\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n493: \t\t\t\t\t\tImage:  \"python:3.11\",\n494: \t\t\t\t\t},\n495: \t\t\t\t\tWarmPoolSize: ptrInt32(2),\n496: \t\t\t\t},\n497: \t\t\t},\n498: \t\t},\n499: \t}\n500: \n501: \tcp := original.DeepCopy()\n502: \n503: \tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n504: \tassert.Len(t, cp.Items, 1)\n505: \n506: \tcp.Items[0].Name = \"modified\"\n507: \tassert.Equal(t, \"ci1\", original.Items[0].Name)\n508: \n509: \tcp.Items[0].Spec.Template.Labels[\"app\"] = \"modified\"\n510: \tassert.Equal(t, \"test\", original.Items[0].Spec.Template.Labels[\"app\"])\n511: \n512: \t*cp.Items[0].Spec.WarmPoolSize = 10\n513: \tassert.Equal(t, int32(2), *original.Items[0].Spec.WarmPoolSize)\n514: }\n515: \n516: func TestCodeInterpreterDeepCopyNilStatus(t *testing.T) {\n517: \toriginal := &CodeInterpreter{\n518: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\"},\n519: \t\tSpec: CodeInterpreterSpec{\n520: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n521: \t\t},\n522: \t}\n523: \n524: \tcp := original.DeepCopy()\n525: \n526: \tassert.Equal(t, original.Name, cp.Name)\n527: \tassert.Equal(t, original.Spec.Template.Image, cp.Spec.Template.Image)\n528: \tassert.False(t, cp.Status.Ready)\n529: \tassert.Empty(t, cp.Status.Conditions)\n530: }\n531: \n532: func TestCodeInterpreterDeepCopyPortsIsolation(t *testing.T) {\n533: \toriginal := &CodeInterpreter{\n534: \t\tSpec: CodeInterpreterSpec{\n535: \t\t\tPorts: []TargetPort{\n536: \t\t\t\t{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP},\n537: \t\t\t},\n538: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n539: \t\t},\n540: \t}\n541: \n542: \tcp := original.DeepCopy()\n543: \n544: \tcp.Spec.Ports[0].Port = 9090\n545: \tcp.Spec.Ports[0].Name = \"modified\"\n546: \n547: \tassert.Equal(t, uint32(8080), original.Spec.Ports[0].Port)\n548: \tassert.Equal(t, \"web\", original.Spec.Ports[0].Name)\n549: }\n550: \n551: func TestCodeInterpreterSpecWarmPoolSizeOmitEmpty(t *testing.T) {\n552: \tspec := &CodeInterpreterSpec{\n553: \t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n554: \t}\n555: \n556: \tassert.Nil(t, spec.WarmPoolSize)\n557: \n558: \tspecWithPool := &CodeInterpreterSpec{\n559: \t\tTemplate:     &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n560: \t\tWarmPoolSize: ptrInt32(5),\n561: \t}\n562: \n563: \tassert.NotNil(t, specWithPool.WarmPoolSize)\n564: \tassert.Equal(t, int32(5), *specWithPool.WarmPoolSize)\n565: }\n566: \n567: func TestCodeInterpreterSpecAuthModeDefault(t *testing.T) {\n568: \tspec := &CodeInterpreterSpec{\n569: \t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n570: \t}\n571: \n572: \tassert.Equal(t, AuthModeType(\"\"), spec.AuthMode)\n573: \n574: \tspecWithAuth := &CodeInterpreterSpec{\n575: \t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n576: \t\tAuthMode: AuthModeNone,\n577: \t}\n578: \n579: \tassert.Equal(t, AuthModeNone, specWithAuth.AuthMode)\n580: }\n581: \n582: func TestCodeInterpreterSpecSessionTimeoutDuration(t *testing.T) {\n583: \tspec := &CodeInterpreterSpec{\n584: \t\tTemplate:       &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n585: \t\tSessionTimeout: &metav1.Duration{Duration: 15 * time.Minute},\n586: \t}\n587: \n588: \tassert.Equal(t, 15*time.Minute, spec.SessionTimeout.Duration)\n589: \tassert.Equal(t, \"15m0s\", spec.SessionTimeout.Duration.String())\n590: }\n591: \n592: func TestCodeInterpreterSpecMaxSessionDuration(t *testing.T) {\n593: \tspec := &CodeInterpreterSpec{\n594: \t\tTemplate:           &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n595: \t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n596: \t}\n597: \n598: \tassert.Equal(t, 8*time.Hour, spec.MaxSessionDuration.Duration)\n599: \tassert.Equal(t, \"8h0m0s\", spec.MaxSessionDuration.Duration.String())\n600: }\n601: \n602: func TestCodeInterpreterSandboxTemplateResources(t *testing.T) {\n603: \ttemplate := &CodeInterpreterSandboxTemplate{\n604: \t\tImage: \"python:3.11\",\n605: \t\tResources: corev1.ResourceRequirements{\n606: \t\t\tRequests: corev1.ResourceList{\n607: \t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n608: \t\t\t\tcorev1.ResourceMemory: parseQuantity(\"2Gi\"),\n609: \t\t\t},\n610: \t\t},\n611: \t}\n612: \n613: \tassert.NotNil(t, template.Resources.Requests)\n614: \tassert.Equal(t, \"1\", template.Resources.Requests.Cpu().String())\n615: \tassert.Equal(t, \"2Gi\", template.Resources.Requests.Memory().String())\n616: }\n617: \n618: func TestCodeInterpreterSandboxTemplateRuntimeClassName(t *testing.T) {\n619: \truntimeClass := \"kuasar-vmm\"\n620: \ttemplate := &CodeInterpreterSandboxTemplate{\n621: \t\tImage:            \"python:3.11\",\n622: \t\tRuntimeClassName: &runtimeClass,\n623: \t}\n624: \n625: \tassert.Equal(t, \"kuasar-vmm\", *template.RuntimeClassName)\n626: \n627: \ttemplateNoRuntime := &CodeInterpreterSandboxTemplate{\n628: \t\tImage: \"python:3.11\",\n629: \t}\n630: \n631: \tassert.Nil(t, templateNoRuntime.RuntimeClassName)\n632: }\n633: \n634: func TestCodeInterpreterSandboxTemplateEnvironment(t *testing.T) {\n635: \ttemplate := &CodeInterpreterSandboxTemplate{\n636: \t\tImage: \"python:3.11\",\n637: \t\tEnvironment: []corev1.EnvVar{\n638: \t\t\t{Name: \"PYTHONPATH\", Value: \"/app\"},\n639: \t\t\t{Name: \"DEBUG\", Value: \"false\"},\n640: \t\t},\n641: \t}\n642: \n643: \tassert.Len(t, template.Environment, 2)\n644: \tassert.Equal(t, \"PYTHONPATH\", template.Environment[0].Name)\n645: \tassert.Equal(t, \"/app\", template.Environment[0].Value)\n646: }\n647: \n648: func TestCodeInterpreterSandboxTemplateImagePullSecrets(t *testing.T) {\n649: \ttemplate := &CodeInterpreterSandboxTemplate{\n650: \t\tImage: \"python:3.11\",\n651: \t\tImagePullSecrets: []corev1.LocalObjectReference{\n652: \t\t\t{Name: \"registry-secret\"},\n653: \t\t\t{Name: \"docker-config\"},\n654: \t\t},\n655: \t}\n656: \n657: \tassert.Len(t, template.ImagePullSecrets, 2)\n658: \tassert.Equal(t, \"registry-secret\", template.ImagePullSecrets[0].Name)\n659: \tassert.Equal(t, \"docker-config\", template.ImagePullSecrets[1].Name)\n660: }\n661: \n662: func TestProtocolTypeAsString(t *testing.T) {\n663: \tvar http ProtocolType = \"HTTP\"\n664: \tvar https ProtocolType = \"HTTPS\"\n665: \n666: \tassert.Equal(t, ProtocolTypeHTTP, http)\n667: \tassert.Equal(t, ProtocolTypeHTTPS, https)\n668: \tassert.NotEqual(t, ProtocolTypeHTTP, ProtocolTypeHTTPS)\n669: }\n670: \n671: func TestAuthModeTypeAsString(t *testing.T) {\n672: \tvar picod AuthModeType = \"picod\"\n673: \tvar none AuthModeType = \"none\"\n674: \n675: \tassert.Equal(t, AuthModePicoD, picod)\n676: \tassert.Equal(t, AuthModeNone, none)\n677: \tassert.NotEqual(t, AuthModePicoD, AuthModeNone)\n678: }\n679: \n680: func TestCodeInterpreterListEmpty(t *testing.T) {\n681: \tlist := &CodeInterpreterList{}\n682: \n683: \tassert.Empty(t, list.Items)\n684: \tassert.Empty(t, list.ListMeta.ResourceVersion)\n685: }\n686: \n687: func TestCodeInterpreterDeepCopyObject(t *testing.T) {\n688: \tci := &CodeInterpreter{\n689: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n690: \t\tSpec: CodeInterpreterSpec{\n691: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n692: \t\t},\n693: \t}\n694: \n695: \tobj := ci.DeepCopyObject()\n696: \tassert.NotNil(t, obj)\n697: \n698: \tcopied, ok := obj.(*CodeInterpreter)\n699: \tassert.True(t, ok)\n700: \tassert.Equal(t, ci.Name, copied.Name)\n701: \tassert.Equal(t, ci.Spec.Template.Image, copied.Spec.Template.Image)\n702: }\n703: \n704: func TestCodeInterpreterListDeepCopyObject(t *testing.T) {\n705: \tlist := &CodeInterpreterList{\n706: \t\tListMeta: metav1.ListMeta{ResourceVersion: \"1234\"},\n707: \t\tItems: []CodeInterpreter{\n708: \t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci1\"}},\n709: \t\t},\n710: \t}\n711: \n712: \tobj := list.DeepCopyObject()\n713: \tassert.NotNil(t, obj)\n714: \n715: \tcopied, ok := obj.(*CodeInterpreterList)\n716: \tassert.True(t, ok)\n717: \tassert.Equal(t, list.ListMeta.ResourceVersion, copied.ListMeta.ResourceVersion)\n718: \tassert.Len(t, copied.Items, 1)\n719: }\n720: \n721: func parseQuantity(s string) resource.Quantity {\n722: \tq, _ := resource.ParseQuantity(s)\n723: \treturn q\n724: }\n\n(End of file - total 724 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestProtocolTypeConstants(t *testing.T) {\n\tassert.Equal(t, ProtocolType(\"HTTP\"), ProtocolTypeHTTP)\n\tassert.Equal(t, ProtocolType(\"HTTPS\"), ProtocolTypeHTTPS)\n}\n\nfunc TestAuthModeTypeConstants(t *testing.T) {\n\tassert.Equal(t, AuthModeType(\"picod\"), AuthModePicoD)\n\tassert.Equal(t, AuthModeType(\"none\"), AuthModeNone)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go","time":{"start":1775812293571,"end":1775812293578}}}}
{"type":"tool_use","timestamp":1775812294669,"sessionID":"ses_28959beedffejL0cu1e0mvWtte","part":{"id":"prt_d76a9343d001edJtB5KwEl6Xex","messageID":"msg_d76a92473001QCCsXpNXShGu9x","sessionID":"ses_28959beedffejL0cu1e0mvWtte","type":"tool","tool":"read","callID":"call_349da15a15ad4030a313cc15","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/agent_type_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/agent_type_test.go</path>\n<type>file</type>\n<content>\n1: package v1alpha1\n2: \n3: import (\n4: \t\"testing\"\n5: \t\"time\"\n6: \n7: \t\"github.com/stretchr/testify/assert\"\n8: \tcorev1 \"k8s.io/api/core/v1\"\n9: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n10: )\n11: \n12: func TestAgentRuntimeDefaultValues(t *testing.T) {\n13: \tar := &AgentRuntime{\n14: \t\tSpec: AgentRuntimeSpec{\n15: \t\t\tTemplate: &SandboxTemplate{\n16: \t\t\t\tSpec: corev1.PodSpec{\n17: \t\t\t\t\tContainers: []corev1.Container{{Name: \"test\", Image: \"test:latest\"}},\n18: \t\t\t\t},\n19: \t\t\t},\n20: \t\t},\n21: \t}\n22: \n23: \tassert.Nil(t, ar.Spec.SessionTimeout)\n24: \tassert.Nil(t, ar.Spec.MaxSessionDuration)\n25: \tassert.Empty(t, ar.Spec.Ports)\n26: \tassert.NotNil(t, ar.Spec.Template)\n27: }\n28: \n29: func TestAgentRuntimeDeepCopy(t *testing.T) {\n30: \toriginal := &AgentRuntime{\n31: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test\", Namespace: \"default\"},\n32: \t\tSpec: AgentRuntimeSpec{\n33: \t\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n34: \t\t\tTemplate: &SandboxTemplate{\n35: \t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n36: \t\t\t\tSpec: corev1.PodSpec{\n37: \t\t\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n38: \t\t\t\t},\n39: \t\t\t},\n40: \t\t\tSessionTimeout:     &metav1.Duration{Duration: 30 * time.Minute},\n41: \t\t\tMaxSessionDuration: &metav1.Duration{Duration: 4 * time.Hour},\n42: \t\t},\n43: \t\tStatus: AgentRuntimeStatus{\n44: \t\t\tConditions: []metav1.Condition{{\n45: \t\t\t\tType:   \"Ready\",\n46: \t\t\t\tStatus: metav1.ConditionTrue,\n47: \t\t\t\tReason: \"SandboxRunning\",\n48: \t\t\t}},\n49: \t\t},\n50: \t}\n51: \n52: \tcp := original.DeepCopy()\n53: \n54: \tassert.Equal(t, original.Name, cp.Name)\n55: \tassert.Equal(t, original.Spec.Ports[0].Port, cp.Spec.Ports[0].Port)\n56: \n57: \tcp.Spec.Ports[0].Port = 9090\n58: \tassert.Equal(t, uint32(8080), original.Spec.Ports[0].Port)\n59: \n60: \tcp.Spec.Template.Labels[\"app\"] = \"modified\"\n61: \tassert.Equal(t, \"test\", original.Spec.Template.Labels[\"app\"])\n62: \n63: \tcp.Spec.Template.Annotations = map[string]string{\"new\": \"value\"}\n64: \tassert.Nil(t, original.Spec.Template.Annotations)\n65: \n66: \tcp.Status.Conditions[0].Reason = \"Modified\"\n67: \tassert.Equal(t, \"SandboxRunning\", original.Status.Conditions[0].Reason)\n68: }\n69: \n70: func TestAgentRuntimeListDeepCopy(t *testing.T) {\n71: \toriginal := &AgentRuntimeList{\n72: \t\tListMeta: metav1.ListMeta{ResourceVersion: \"1234\"},\n73: \t\tItems: []AgentRuntime{\n74: \t\t\t{\n75: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ar1\", Namespace: \"default\"},\n76: \t\t\t\tSpec: AgentRuntimeSpec{\n77: \t\t\t\t\tTemplate: &SandboxTemplate{\n78: \t\t\t\t\t\tSpec: corev1.PodSpec{\n79: \t\t\t\t\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n80: \t\t\t\t\t\t},\n81: \t\t\t\t\t},\n82: \t\t\t\t},\n83: \t\t\t},\n84: \t\t},\n85: \t}\n86: \n87: \tcp := original.DeepCopy()\n88: \n89: \tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n90: \tassert.Equal(t, len(original.Items), len(cp.Items))\n91: \tassert.Equal(t, original.Items[0].Name, cp.Items[0].Name)\n92: \n93: \tcp.Items[0].Name = \"modified\"\n94: \tassert.Equal(t, \"ar1\", original.Items[0].Name)\n95: }\n96: \n97: func TestSandboxTemplateDeepCopy(t *testing.T) {\n98: \toriginal := &SandboxTemplate{\n99: \t\tLabels:      map[string]string{\"app\": \"test\"},\n100: \t\tAnnotations: map[string]string{\"key\": \"value\"},\n101: \t\tSpec: corev1.PodSpec{\n102: \t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n103: \t\t},\n104: \t}\n105: \n106: \tcp := original.DeepCopy()\n107: \n108: \tassert.Equal(t, original.Labels[\"app\"], cp.Labels[\"app\"])\n109: \tassert.Equal(t, original.Annotations[\"key\"], cp.Annotations[\"key\"])\n110: \n111: \tcp.Labels[\"app\"] = \"modified\"\n112: \tassert.Equal(t, \"test\", original.Labels[\"app\"])\n113: }\n114: \n115: func TestAgentRuntimeSpecDeepCopy(t *testing.T) {\n116: \toriginal := &AgentRuntimeSpec{\n117: \t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n118: \t\tTemplate: &SandboxTemplate{\n119: \t\t\tLabels: map[string]string{\"app\": \"test\"},\n120: \t\t\tSpec: corev1.PodSpec{\n121: \t\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n122: \t\t\t},\n123: \t\t},\n124: \t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n125: \t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n126: \t}\n127: \n128: \tcp := original.DeepCopy()\n129: \n130: \tassert.Equal(t, original.Ports[0].Port, cp.Ports[0].Port)\n131: \tassert.Equal(t, original.SessionTimeout.Duration, cp.SessionTimeout.Duration)\n132: \n133: \tcp.Ports[0].Port = 9090\n134: \tassert.Equal(t, uint32(8080), original.Ports[0].Port)\n135: }\n136: \n137: func TestAgentRuntimeStatusDeepCopy(t *testing.T) {\n138: \toriginal := &AgentRuntimeStatus{\n139: \t\tConditions: []metav1.Condition{{\n140: \t\t\tType:               \"Ready\",\n141: \t\t\tStatus:             metav1.ConditionTrue,\n142: \t\t\tReason:             \"SandboxRunning\",\n143: \t\t\tLastTransitionTime: metav1.Now(),\n144: \t\t}},\n145: \t}\n146: \n147: \tcp := original.DeepCopy()\n148: \n149: \tassert.Equal(t, original.Conditions[0].Type, cp.Conditions[0].Type)\n150: \tassert.Equal(t, original.Conditions[0].Reason, cp.Conditions[0].Reason)\n151: \n152: \tcp.Conditions[0].Reason = \"Modified\"\n153: \tassert.Equal(t, \"SandboxRunning\", original.Conditions[0].Reason)\n154: }\n155: \n156: func TestAgentRuntimeWithNilTemplate(t *testing.T) {\n157: \tar := &AgentRuntime{\n158: \t\tSpec: AgentRuntimeSpec{\n159: \t\t\tTemplate: nil,\n160: \t\t},\n161: \t}\n162: \n163: \tassert.Nil(t, ar.Spec.Template)\n164: \tassert.Nil(t, ar.Spec.SessionTimeout)\n165: \tassert.Nil(t, ar.Spec.MaxSessionDuration)\n166: }\n167: \n168: func TestAgentRuntimeWithEmptyPorts(t *testing.T) {\n169: \tar := &AgentRuntime{\n170: \t\tSpec: AgentRuntimeSpec{\n171: \t\t\tTemplate: &SandboxTemplate{\n172: \t\t\t\tSpec: corev1.PodSpec{\n173: \t\t\t\t\tContainers: []corev1.Container{{Name: \"test\", Image: \"test:latest\"}},\n174: \t\t\t\t},\n175: \t\t\t},\n176: \t\t},\n177: \t}\n178: \n179: \tassert.Empty(t, ar.Spec.Ports)\n180: \tassert.Nil(t, ar.Spec.SessionTimeout)\n181: \tassert.Nil(t, ar.Spec.MaxSessionDuration)\n182: }\n183: \n184: func TestAgentRuntimeWithAllFields(t *testing.T) {\n185: \tar := &AgentRuntime{\n186: \t\tTypeMeta: metav1.TypeMeta{\n187: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n188: \t\t\tKind:       \"AgentRuntime\",\n189: \t\t},\n190: \t\tObjectMeta: metav1.ObjectMeta{\n191: \t\t\tName:      \"python-sandbox\",\n192: \t\t\tNamespace: \"default\",\n193: \t\t\tLabels:    map[string]string{\"app\": \"python-agent\"},\n194: \t\t},\n195: \t\tSpec: AgentRuntimeSpec{\n196: \t\t\tPorts: []TargetPort{\n197: \t\t\t\t{\n198: \t\t\t\t\tName:       \"web\",\n199: \t\t\t\t\tPort:       8080,\n200: \t\t\t\t\tProtocol:   ProtocolTypeHTTP,\n201: \t\t\t\t\tPathPrefix: \"/\",\n202: \t\t\t\t},\n203: \t\t\t},\n204: \t\t\tTemplate: &SandboxTemplate{\n205: \t\t\t\tLabels:      map[string]string{\"app\": \"python-agent\"},\n206: \t\t\t\tAnnotations: map[string]string{\"agentcube.io/runtime\": \"python-3.11\"},\n207: \t\t\t\tSpec: corev1.PodSpec{\n208: \t\t\t\t\tContainers: []corev1.Container{\n209: \t\t\t\t\t\t{\n210: \t\t\t\t\t\t\tName:      \"sandbox\",\n211: \t\t\t\t\t\t\tImage:     \"python:3.11-slim\",\n212: \t\t\t\t\t\t\tPorts:     []corev1.ContainerPort{{ContainerPort: 8080}},\n213: \t\t\t\t\t\t\tResources: corev1.ResourceRequirements{},\n214: \t\t\t\t\t\t},\n215: \t\t\t\t\t},\n216: \t\t\t\t},\n217: \t\t\t},\n218: \t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n219: \t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n220: \t\t},\n221: \t}\n222: \n223: \tassert.Equal(t, \"runtime.agentcube.volcano.sh/v1alpha1\", ar.APIVersion)\n224: \tassert.Equal(t, \"AgentRuntime\", ar.Kind)\n225: \tassert.Equal(t, \"python-sandbox\", ar.Name)\n226: \tassert.Equal(t, \"default\", ar.Namespace)\n227: \tassert.Len(t, ar.Spec.Ports, 1)\n228: \tassert.Equal(t, uint32(8080), ar.Spec.Ports[0].Port)\n229: \tassert.Equal(t, ProtocolTypeHTTP, ar.Spec.Ports[0].Protocol)\n230: \tassert.Equal(t, \"/\", ar.Spec.Ports[0].PathPrefix)\n231: \tassert.NotNil(t, ar.Spec.Template)\n232: \tassert.Equal(t, \"python-3.11\", ar.Spec.Template.Annotations[\"agentcube.io/runtime\"])\n233: \tassert.Equal(t, 15*time.Minute, ar.Spec.SessionTimeout.Duration)\n234: \tassert.Equal(t, 8*time.Hour, ar.Spec.MaxSessionDuration.Duration)\n235: }\n\n(End of file - total 235 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestAgentRuntimeDefaultValues(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{{Name: \"test\", Image: \"test:latest\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t},","truncated":false,"loaded":[]},"title":"workspaces/v5.1/openco