k/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go\n@@ -606,26 +606,8 @@\n \tassert.Equal(t, \"registry-secret\", template.ImagePullSecrets[0].Name)\n \tassert.Equal(t, \"docker-config\", template.ImagePullSecrets[1].Name)\n }\n \n-func TestProtocolTypeAsString(t *testing.T) {\n-\tvar http ProtocolType = \"HTTP\"\n-\tvar https ProtocolType = \"HTTPS\"\n-\n-\tassert.Equal(t, ProtocolTypeHTTP, http)\n-\tassert.Equal(t, ProtocolTypeHTTPS, https)\n-\tassert.NotEqual(t, ProtocolTypeHTTP, ProtocolTypeHTTPS)\n-}\n-\n-func TestAuthModeTypeAsString(t *testing.T) {\n-\tvar picod AuthModeType = \"picod\"\n-\tvar none AuthModeType = \"none\"\n-\n-\tassert.Equal(t, AuthModePicoD, picod)\n-\tassert.Equal(t, AuthModeNone, none)\n-\tassert.NotEqual(t, AuthModePicoD, AuthModeNone)\n-}\n-\n func TestCodeInterpreterListEmpty(t *testing.T) {\n \tlist := &CodeInterpreterList{}\n \n \tassert.Empty(t, list.Items)\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go","before":"package v1alpha1\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestCodeInterpreterSpecDefaults(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{},\n\t}\n\n\tassert.Empty(t, ci.Ports)\n\tassert.Nil(t, ci.SessionTimeout)\n\tassert.Nil(t, ci.MaxSessionDuration)\n\tassert.Nil(t, ci.WarmPoolSize)\n\tassert.Equal(t, AuthModeType(\"\"), ci.AuthMode)\n}\n\nfunc TestCodeInterpreterSandboxTemplateDeepCopy(t *testing.T) {\n\truntimeClass := \"kuasar-vmm\"\n\toriginal := &CodeInterpreterSandboxTemplate{\n\t\tLabels:           map[string]string{\"app\": \"test\"},\n\t\tAnnotations:      map[string]string{\"key\": \"value\"},\n\t\tRuntimeClassName: &runtimeClass,\n\t\tImage:            \"python:3.11\",\n\t\tImagePullPolicy:  corev1.PullIfNotPresent,\n\t\tCommand:          []string{\"python\", \"-m\", \"http.server\"},\n\t\tArgs:             []string{\"8080\"},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Image, cp.Image)\n\tassert.Equal(t, original.Labels[\"app\"], cp.Labels[\"app\"])\n\tassert.Equal(t, *original.RuntimeClassName, *cp.RuntimeClassName)\n\n\tcp.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Labels[\"app\"])\n\n\tcp.Image = \"modified:latest\"\n\tassert.Equal(t, \"python:3.11\", original.Image)\n}\n\nfunc TestCodeInterpreterDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\t\tImage:  \"python:3.11\",\n\t\t\t},\n\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\tWarmPoolSize:       ptrInt32(3),\n\t\t\tAuthMode:           AuthModePicoD,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tReady: true,\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Name, cp.Name)\n\tassert.Equal(t, original.Spec.WarmPoolSize, cp.Spec.WarmPoolSize)\n\tassert.Equal(t, original.Spec.AuthMode, cp.Spec.AuthMode)\n\tassert.Equal(t, original.Status.Ready, cp.Status.Ready)\n\n\tcp.Spec.WarmPoolSize = ptrInt32(5)\n\tassert.Equal(t, int32(3), *original.Spec.WarmPoolSize)\n}\n\nfunc TestCodeInterpreterListDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterList{\n\t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n\tassert.Equal(t, len(original.Items), len(cp.Items))\n\tassert.Equal(t, original.Items[0].Name, cp.Items[0].Name)\n\n\tcp.Items[0].Name = \"modified\"\n\tassert.Equal(t, \"ci1\", original.Items[0].Name)\n}\n\nfunc ptrInt32(i int32) *int32 {\n\treturn &i\n}\n\nfunc TestCodeInterpreterStatusDefaults(t *testing.T) {\n\tstatus := CodeInterpreterStatus{}\n\n\tassert.Empty(t, status.Conditions)\n\tassert.False(t, status.Ready)\n}\n\nfunc TestCodeInterpreterStatusWithConditions(t *testing.T) {\n\tstatus := CodeInterpreterStatus{\n\t\tConditions: []metav1.Condition{\n\t\t\t{\n\t\t\t\tType:               \"Ready\",\n\t\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\t\tReason:             \"SandboxRunning\",\n\t\t\t\tMessage:            \"Code interpreter sandbox is running\",\n\t\t\t\tLastTransitionTime: metav1.Now(),\n\t\t\t},\n\t\t},\n\t\tReady: true,\n\t}\n\n\tassert.Len(t, status.Conditions, 1)\n\tassert.Equal(t, \"Ready\", status.Conditions[0].Type)\n\tassert.Equal(t, metav1.ConditionTrue, status.Conditions[0].Status)\n\tassert.Equal(t, \"SandboxRunning\", status.Conditions[0].Reason)\n\tassert.True(t, status.Ready)\n}\n\nfunc TestCodeInterpreterStatusDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterStatus{\n\t\tConditions: []metav1.Condition{\n\t\t\t{\n\t\t\t\tType:   \"Ready\",\n\t\t\t\tStatus: metav1.ConditionTrue,\n\t\t\t\tReason: \"SandboxRunning\",\n\t\t\t},\n\t\t},\n\t\tReady: true,\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Conditions[0].Type, cp.Conditions[0].Type)\n\tassert.Equal(t, original.Conditions[0].Reason, cp.Conditions[0].Reason)\n\tassert.Equal(t, original.Ready, cp.Ready)\n\n\tcp.Conditions[0].Reason = \"Modified\"\n\tassert.Equal(t, \"SandboxRunning\", original.Conditions[0].Reason)\n\n\tcp.Ready = false\n\tassert.True(t, original.Ready)\n}\n\nfunc TestCodeInterpreterSpecDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterSpec{\n\t\tPorts: []TargetPort{\n\t\t\t{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP},\n\t\t\t{Name: \"api\", Port: 3000, Protocol: ProtocolTypeHTTPS},\n\t\t},\n\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\tImage:  \"python:3.11\",\n\t\t},\n\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\tWarmPoolSize:       ptrInt32(3),\n\t\tAuthMode:           AuthModePicoD,\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Ports[0].Port, cp.Ports[0].Port)\n\tassert.Equal(t, original.SessionTimeout.Duration, cp.SessionTimeout.Duration)\n\tassert.Equal(t, original.WarmPoolSize, cp.WarmPoolSize)\n\n\tcp.Ports[0].Port = 9090\n\tassert.Equal(t, uint32(8080), original.Ports[0].Port)\n\n\tcp.WarmPoolSize = ptrInt32(10)\n\tassert.Equal(t, int32(3), *original.WarmPoolSize)\n\n\tcp.Template.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Template.Labels[\"app\"])\n}\n\nfunc TestCodeInterpreterSpecDeepCopyNilFields(t *testing.T) {\n\toriginal := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\tImage: \"python:3.11\",\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Nil(t, cp.SessionTimeout)\n\tassert.Nil(t, cp.MaxSessionDuration)\n\tassert.Nil(t, cp.WarmPoolSize)\n\tassert.Empty(t, cp.Ports)\n\tassert.Equal(t, AuthModeType(\"\"), cp.AuthMode)\n}\n\nfunc TestCodeInterpreterSandboxTemplateAllFields(t *testing.T) {\n\truntimeClass := \"kuasar-vmm\"\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tLabels:           map[string]string{\"app\": \"code-interpreter\"},\n\t\tAnnotations:      map[string]string{\"agentcube.io/version\": \"1\"},\n\t\tRuntimeClassName: &runtimeClass,\n\t\tImage:            \"python:3.11-slim\",\n\t\tImagePullPolicy:  corev1.PullAlways,\n\t\tImagePullSecrets: []corev1.LocalObjectReference{\n\t\t\t{Name: \"registry-secret\"},\n\t\t},\n\t\tEnvironment: []corev1.EnvVar{\n\t\t\t{Name: \"PYTHONPATH\", Value: \"/app\"},\n\t\t\t{Name: \"DEBUG\", Value: \"false\"},\n\t\t},\n\t\tCommand: []string{\"python\", \"-m\", \"http.server\"},\n\t\tArgs:    []string{\"8080\"},\n\t\tResources: corev1.ResourceRequirements{\n\t\t\tRequests: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"2Gi\"),\n\t\t\t},\n\t\t\tLimits: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"2\"),\n\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"4Gi\"),\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Equal(t, \"code-interpreter\", template.Labels[\"app\"])\n\tassert.Equal(t, \"1\", template.Annotations[\"agentcube.io/version\"])\n\tassert.Equal(t, \"kuasar-vmm\", *template.RuntimeClassName)\n\tassert.Equal(t, \"python:3.11-slim\", template.Image)\n\tassert.Equal(t, corev1.PullAlways, template.ImagePullPolicy)\n\tassert.Len(t, template.ImagePullSecrets, 1)\n\tassert.Equal(t, \"registry-secret\", template.ImagePullSecrets[0].Name)\n\tassert.Len(t, template.Environment, 2)\n\tassert.Equal(t, \"/app\", template.Environment[0].Value)\n\tassert.Len(t, template.Command, 3)\n\tassert.Len(t, template.Args, 1)\n\tassert.NotNil(t, template.Resources.Requests)\n\tassert.NotNil(t, template.Resources.Limits)\n}\n\nfunc TestCodeInterpreterSandboxTemplateDeepCopyIsolation(t *testing.T) {\n\truntimeClass := \"gvisor\"\n\toriginal := &CodeInterpreterSandboxTemplate{\n\t\tLabels:           map[string]string{\"app\": \"test\"},\n\t\tAnnotations:      map[string]string{\"key\": \"value\"},\n\t\tRuntimeClassName: &runtimeClass,\n\t\tImage:            \"python:3.11\",\n\t\tImagePullPolicy:  corev1.PullIfNotPresent,\n\t\tImagePullSecrets: []corev1.LocalObjectReference{{Name: \"secret1\"}},\n\t\tEnvironment:      []corev1.EnvVar{{Name: \"VAR\", Value: \"val\"}},\n\t\tCommand:          []string{\"python\"},\n\t\tArgs:             []string{\"script.py\"},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tcp.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Labels[\"app\"])\n\n\tcp.Annotations[\"key\"] = \"modified\"\n\tassert.Equal(t, \"value\", original.Annotations[\"key\"])\n\n\t*cp.RuntimeClassName = \"modified\"\n\tassert.Equal(t, \"gvisor\", *original.RuntimeClassName)\n\n\tcp.ImagePullSecrets[0].Name = \"modified\"\n\tassert.Equal(t, \"secret1\", original.ImagePullSecrets[0].Name)\n\n\tcp.Environment[0].Value = \"modified\"\n\tassert.Equal(t, \"val\", original.Environment[0].Value)\n\n\tcp.Command[0] = \"modified\"\n\tassert.Equal(t, \"python\", original.Command[0])\n\n\tcp.Args[0] = \"modified\"\n\tassert.Equal(t, \"script.py\", original.Args[0])\n}\n\nfunc TestCodeInterpreterSandboxTemplateDeepCopyNilFields(t *testing.T) {\n\toriginal := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Nil(t, cp.Labels)\n\tassert.Nil(t, cp.Annotations)\n\tassert.Nil(t, cp.RuntimeClassName)\n\tassert.Empty(t, cp.ImagePullSecrets)\n\tassert.Empty(t, cp.Environment)\n\tassert.Empty(t, cp.Command)\n\tassert.Empty(t, cp.Args)\n}\n\nfunc TestCodeInterpreterWithAllFields(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreter\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"python-interpreter\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels:    map[string]string{\"app\": \"code-interpreter\"},\n\t\t},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{\n\t\t\t\t\tName:       \"web\",\n\t\t\t\t\tPort:       8080,\n\t\t\t\t\tProtocol:   ProtocolTypeHTTP,\n\t\t\t\t\tPathPrefix: \"/\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels:      map[string]string{\"app\": \"python-interpreter\"},\n\t\t\t\tAnnotations: map[string]string{\"agentcube.io/runtime\": \"python-3.11\"},\n\t\t\t\tImage:       \"python:3.11-slim\",\n\t\t\t\tCommand:     []string{\"python\", \"-m\", \"http.server\"},\n\t\t\t\tArgs:        []string{\"8080\"},\n\t\t\t},\n\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\tWarmPoolSize:       ptrInt32(3),\n\t\t\tAuthMode:           AuthModePicoD,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\tStatus: metav1.ConditionTrue,\n\t\t\t\t\tReason: \"SandboxRunning\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tReady: true,\n\t\t},\n\t}\n\n\tassert.Equal(t, \"runtime.agentcube.volcano.sh/v1alpha1\", ci.APIVersion)\n\tassert.Equal(t, \"CodeInterpreter\", ci.Kind)\n\tassert.Equal(t, \"python-interpreter\", ci.Name)\n\tassert.Equal(t, \"default\", ci.Namespace)\n\tassert.Len(t, ci.Spec.Ports, 1)\n\tassert.Equal(t, uint32(8080), ci.Spec.Ports[0].Port)\n\tassert.Equal(t, ProtocolTypeHTTP, ci.Spec.Ports[0].Protocol)\n\tassert.Equal(t, \"/\", ci.Spec.Ports[0].PathPrefix)\n\tassert.NotNil(t, ci.Spec.Template)\n\tassert.Equal(t, \"python:3.11-slim\", ci.Spec.Template.Image)\n\tassert.Equal(t, 15*time.Minute, ci.Spec.SessionTimeout.Duration)\n\tassert.Equal(t, 8*time.Hour, ci.Spec.MaxSessionDuration.Duration)\n\tassert.Equal(t, int32(3), *ci.Spec.WarmPoolSize)\n\tassert.Equal(t, AuthModePicoD, ci.Spec.AuthMode)\n\tassert.True(t, ci.Status.Ready)\n\tassert.Len(t, ci.Status.Conditions, 1)\n}\n\nfunc TestCodeInterpreterWithNilTemplate(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tTemplate: nil,\n\t\t},\n\t}\n\n\tassert.Nil(t, ci.Spec.Template)\n\tassert.Nil(t, ci.Spec.SessionTimeout)\n\tassert.Nil(t, ci.Spec.MaxSessionDuration)\n\tassert.Nil(t, ci.Spec.WarmPoolSize)\n\tassert.Equal(t, AuthModeType(\"\"), ci.Spec.AuthMode)\n}\n\nfunc TestCodeInterpreterWithEmptyPorts(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tImage: \"python:3.11\",\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Empty(t, ci.Spec.Ports)\n\tassert.Nil(t, ci.Spec.SessionTimeout)\n\tassert.Nil(t, ci.Spec.MaxSessionDuration)\n}\n\nfunc TestCodeInterpreterListItems(t *testing.T) {\n\tlist := &CodeInterpreterList{\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"12345\",\n\t\t\tContinue:        \"token\",\n\t\t},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\t\t\t},\n\t\t\t\tStatus: CodeInterpreterStatus{Ready: true},\n\t\t\t},\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci2\", Namespace: \"kube-system\"},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.10\"},\n\t\t\t\t},\n\t\t\t\tStatus: CodeInterpreterStatus{Ready: false},\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Equal(t, \"12345\", list.ListMeta.ResourceVersion)\n\tassert.Len(t, list.Items, 2)\n\tassert.Equal(t, \"ci1\", list.Items[0].Name)\n\tassert.Equal(t, \"default\", list.Items[0].Namespace)\n\tassert.True(t, list.Items[0].Status.Ready)\n\tassert.Equal(t, \"ci2\", list.Items[1].Name)\n\tassert.Equal(t, \"kube-system\", list.Items[1].Namespace)\n\tassert.False(t, list.Items[1].Status.Ready)\n}\n\nfunc TestCodeInterpreterListDeepCopyIsolation(t *testing.T) {\n\toriginal := &CodeInterpreterList{\n\t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\t\t\t\tImage:  \"python:3.11\",\n\t\t\t\t\t},\n\t\t\t\t\tWarmPoolSize: ptrInt32(2),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n\tassert.Len(t, cp.Items, 1)\n\n\tcp.Items[0].Name = \"modified\"\n\tassert.Equal(t, \"ci1\", original.Items[0].Name)\n\n\tcp.Items[0].Spec.Template.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Items[0].Spec.Template.Labels[\"app\"])\n\n\t*cp.Items[0].Spec.WarmPoolSize = 10\n\tassert.Equal(t, int32(2), *original.Items[0].Spec.WarmPoolSize)\n}\n\nfunc TestCodeInterpreterDeepCopyNilStatus(t *testing.T) {\n\toriginal := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\"},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Name, cp.Name)\n\tassert.Equal(t, original.Spec.Template.Image, cp.Spec.Template.Image)\n\tassert.False(t, cp.Status.Ready)\n\tassert.Empty(t, cp.Status.Conditions)\n}\n\nfunc TestCodeInterpreterDeepCopyPortsIsolation(t *testing.T) {\n\toriginal := &CodeInterpreter{\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP},\n\t\t\t},\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tcp.Spec.Ports[0].Port = 9090\n\tcp.Spec.Ports[0].Name = \"modified\"\n\n\tassert.Equal(t, uint32(8080), original.Spec.Ports[0].Port)\n\tassert.Equal(t, \"web\", original.Spec.Ports[0].Name)\n}\n\nfunc TestCodeInterpreterSpecWarmPoolSizeOmitEmpty(t *testing.T) {\n\tspec := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t}\n\n\tassert.Nil(t, spec.WarmPoolSize)\n\n\tspecWithPool := &CodeInterpreterSpec{\n\t\tTemplate:     &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\tWarmPoolSize: ptrInt32(5),\n\t}\n\n\tassert.NotNil(t, specWithPool.WarmPoolSize)\n\tassert.Equal(t, int32(5), *specWithPool.WarmPoolSize)\n}\n\nfunc TestCodeInterpreterSpecAuthModeDefault(t *testing.T) {\n\tspec := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t}\n\n\tassert.Equal(t, AuthModeType(\"\"), spec.AuthMode)\n\n\tspecWithAuth := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\tAuthMode: AuthModeNone,\n\t}\n\n\tassert.Equal(t, AuthModeNone, specWithAuth.AuthMode)\n}\n\nfunc TestCodeInterpreterSpecSessionTimeoutDuration(t *testing.T) {\n\tspec := &CodeInterpreterSpec{\n\t\tTemplate:       &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\tSessionTimeout: &metav1.Duration{Duration: 15 * time.Minute},\n\t}\n\n\tassert.Equal(t, 15*time.Minute, spec.SessionTimeout.Duration)\n\tassert.Equal(t, \"15m0s\", spec.SessionTimeout.Duration.String())\n}\n\nfunc TestCodeInterpreterSpecMaxSessionDuration(t *testing.T) {\n\tspec := &CodeInterpreterSpec{\n\t\tTemplate:           &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t}\n\n\tassert.Equal(t, 8*time.Hour, spec.MaxSessionDuration.Duration)\n\tassert.Equal(t, \"8h0m0s\", spec.MaxSessionDuration.Duration.String())\n}\n\nfunc TestCodeInterpreterSandboxTemplateResources(t *testing.T) {\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t\tResources: corev1.ResourceRequirements{\n\t\t\tRequests: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"2Gi\"),\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.NotNil(t, template.Resources.Requests)\n\tassert.Equal(t, \"1\", template.Resources.Requests.Cpu().String())\n\tassert.Equal(t, \"2Gi\", template.Resources.Requests.Memory().String())\n}\n\nfunc TestCodeInterpreterSandboxTemplateRuntimeClassName(t *testing.T) {\n\truntimeClass := \"kuasar-vmm\"\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tImage:            \"python:3.11\",\n\t\tRuntimeClassName: &runtimeClass,\n\t}\n\n\tassert.Equal(t, \"kuasar-vmm\", *template.RuntimeClassName)\n\n\ttemplateNoRuntime := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t}\n\n\tassert.Nil(t, templateNoRuntime.RuntimeClassName)\n}\n\nfunc TestCodeInterpreterSandboxTemplateEnvironment(t *testing.T) {\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t\tEnvironment: []corev1.EnvVar{\n\t\t\t{Name: \"PYTHONPATH\", Value: \"/app\"},\n\t\t\t{Name: \"DEBUG\", Value: \"false\"},\n\t\t},\n\t}\n\n\tassert.Len(t, template.Environment, 2)\n\tassert.Equal(t, \"PYTHONPATH\", template.Environment[0].Name)\n\tassert.Equal(t, \"/app\", template.Environment[0].Value)\n}\n\nfunc TestCodeInterpreterSandboxTemplateImagePullSecrets(t *testing.T) {\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t\tImagePullSecrets: []corev1.LocalObjectReference{\n\t\t\t{Name: \"registry-secret\"},\n\t\t\t{Name: \"docker-config\"},\n\t\t},\n\t}\n\n\tassert.Len(t, template.ImagePullSecrets, 2)\n\tassert.Equal(t, \"registry-secret\", template.ImagePullSecrets[0].Name)\n\tassert.Equal(t, \"docker-config\", template.ImagePullSecrets[1].Name)\n}\n\nfunc TestProtocolTypeAsString(t *testing.T) {\n\tvar http ProtocolType = \"HTTP\"\n\tvar https ProtocolType = \"HTTPS\"\n\n\tassert.Equal(t, ProtocolTypeHTTP, http)\n\tassert.Equal(t, ProtocolTypeHTTPS, https)\n\tassert.NotEqual(t, ProtocolTypeHTTP, ProtocolTypeHTTPS)\n}\n\nfunc TestAuthModeTypeAsString(t *testing.T) {\n\tvar picod AuthModeType = \"picod\"\n\tvar none AuthModeType = \"none\"\n\n\tassert.Equal(t, AuthModePicoD, picod)\n\tassert.Equal(t, AuthModeNone, none)\n\tassert.NotEqual(t, AuthModePicoD, AuthModeNone)\n}\n\nfunc TestCodeInterpreterListEmpty(t *testing.T) {\n\tlist := &CodeInterpreterList{}\n\n\tassert.Empty(t, list.Items)\n\tassert.Empty(t, list.ListMeta.ResourceVersion)\n}\n\nfunc TestCodeInterpreterDeepCopyObject(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\t},\n\t}\n\n\tobj := ci.DeepCopyObject()\n\tassert.NotNil(t, obj)\n\n\tcopied, ok := obj.(*CodeInterpreter)\n\tassert.True(t, ok)\n\tassert.Equal(t, ci.Name, copied.Name)\n\tassert.Equal(t, ci.Spec.Template.Image, copied.Spec.Template.Image)\n}\n\nfunc TestCodeInterpreterListDeepCopyObject(t *testing.T) {\n\tlist := &CodeInterpreterList{\n\t\tListMeta: metav1.ListMeta{ResourceVersion: \"1234\"},\n\t\tItems: []CodeInterpreter{\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci1\"}},\n\t\t},\n\t}\n\n\tobj := list.DeepCopyObject()\n\tassert.NotNil(t, obj)\n\n\tcopied, ok := obj.(*CodeInterpreterList)\n\tassert.True(t, ok)\n\tassert.Equal(t, list.ListMeta.ResourceVersion, copied.ListMeta.ResourceVersion)\n\tassert.Len(t, copied.Items, 1)\n}\n\nfunc parseQuantity(s string) resource.Quantity {\n\tq, _ := resource.ParseQuantity(s)\n\treturn q\n}\n","after":"package v1alpha1\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestCodeInterpreterSpecDefaults(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{},\n\t}\n\n\tassert.Empty(t, ci.Ports)\n\tassert.Nil(t, ci.SessionTimeout)\n\tassert.Nil(t, ci.MaxSessionDuration)\n\tassert.Nil(t, ci.WarmPoolSize)\n\tassert.Equal(t, AuthModeType(\"\"), ci.AuthMode)\n}\n\nfunc TestCodeInterpreterSandboxTemplateDeepCopy(t *testing.T) {\n\truntimeClass := \"kuasar-vmm\"\n\toriginal := &CodeInterpreterSandboxTemplate{\n\t\tLabels:           map[string]string{\"app\": \"test\"},\n\t\tAnnotations:      map[string]string{\"key\": \"value\"},\n\t\tRuntimeClassName: &runtimeClass,\n\t\tImage:            \"python:3.11\",\n\t\tImagePullPolicy:  corev1.PullIfNotPresent,\n\t\tCommand:          []string{\"python\", \"-m\", \"http.server\"},\n\t\tArgs:             []string{\"8080\"},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Image, cp.Image)\n\tassert.Equal(t, original.Labels[\"app\"], cp.Labels[\"app\"])\n\tassert.Equal(t, *original.RuntimeClassName, *cp.RuntimeClassName)\n\n\tcp.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Labels[\"app\"])\n\n\tcp.Image = \"modified:latest\"\n\tassert.Equal(t, \"python:3.11\", original.Image)\n}\n\nfunc TestCodeInterpreterDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\t\tImage:  \"python:3.11\",\n\t\t\t},\n\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\tWarmPoolSize:       ptrInt32(3),\n\t\t\tAuthMode:           AuthModePicoD,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tReady: true,\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Name, cp.Name)\n\tassert.Equal(t, original.Spec.WarmPoolSize, cp.Spec.WarmPoolSize)\n\tassert.Equal(t, original.Spec.AuthMode, cp.Spec.AuthMode)\n\tassert.Equal(t, original.Status.Ready, cp.Status.Ready)\n\n\tcp.Spec.WarmPoolSize = ptrInt32(5)\n\tassert.Equal(t, int32(3), *original.Spec.WarmPoolSize)\n}\n\nfunc TestCodeInterpreterListDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterList{\n\t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n\tassert.Equal(t, len(original.Items), len(cp.Items))\n\tassert.Equal(t, original.Items[0].Name, cp.Items[0].Name)\n\n\tcp.Items[0].Name = \"modified\"\n\tassert.Equal(t, \"ci1\", original.Items[0].Name)\n}\n\nfunc ptrInt32(i int32) *int32 {\n\treturn &i\n}\n\nfunc TestCodeInterpreterStatusDefaults(t *testing.T) {\n\tstatus := CodeInterpreterStatus{}\n\n\tassert.Empty(t, status.Conditions)\n\tassert.False(t, status.Ready)\n}\n\nfunc TestCodeInterpreterStatusWithConditions(t *testing.T) {\n\tstatus := CodeInterpreterStatus{\n\t\tConditions: []metav1.Condition{\n\t\t\t{\n\t\t\t\tType:               \"Ready\",\n\t\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\t\tReason:             \"SandboxRunning\",\n\t\t\t\tMessage:            \"Code interpreter sandbox is running\",\n\t\t\t\tLastTransitionTime: metav1.Now(),\n\t\t\t},\n\t\t},\n\t\tReady: true,\n\t}\n\n\tassert.Len(t, status.Conditions, 1)\n\tassert.Equal(t, \"Ready\", status.Conditions[0].Type)\n\tassert.Equal(t, metav1.ConditionTrue, status.Conditions[0].Status)\n\tassert.Equal(t, \"SandboxRunning\", status.Conditions[0].Reason)\n\tassert.True(t, status.Ready)\n}\n\nfunc TestCodeInterpreterStatusDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterStatus{\n\t\tConditions: []metav1.Condition{\n\t\t\t{\n\t\t\t\tType:   \"Ready\",\n\t\t\t\tStatus: metav1.ConditionTrue,\n\t\t\t\tReason: \"SandboxRunning\",\n\t\t\t},\n\t\t},\n\t\tReady: true,\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Conditions[0].Type, cp.Conditions[0].Type)\n\tassert.Equal(t, original.Conditions[0].Reason, cp.Conditions[0].Reason)\n\tassert.Equal(t, original.Ready, cp.Ready)\n\n\tcp.Conditions[0].Reason = \"Modified\"\n\tassert.Equal(t, \"SandboxRunning\", original.Conditions[0].Reason)\n\n\tcp.Ready = false\n\tassert.True(t, original.Ready)\n}\n\nfunc TestCodeInterpreterSpecDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterSpec{\n\t\tPorts: []TargetPort{\n\t\t\t{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP},\n\t\t\t{Name: \"api\", Port: 3000, Protocol: ProtocolTypeHTTPS},\n\t\t},\n\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\tImage:  \"python:3.11\",\n\t\t},\n\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\tWarmPoolSize:       ptrInt32(3),\n\t\tAuthMode:           AuthModePicoD,\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Ports[0].Port, cp.Ports[0].Port)\n\tassert.Equal(t, original.SessionTimeout.Duration, cp.SessionTimeout.Duration)\n\tassert.Equal(t, original.WarmPoolSize, cp.WarmPoolSize)\n\n\tcp.Ports[0].Port = 9090\n\tassert.Equal(t, uint32(8080), original.Ports[0].Port)\n\n\tcp.WarmPoolSize = ptrInt32(10)\n\tassert.Equal(t, int32(3), *original.WarmPoolSize)\n\n\tcp.Template.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Template.Labels[\"app\"])\n}\n\nfunc TestCodeInterpreterSpecDeepCopyNilFields(t *testing.T) {\n\toriginal := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\tImage: \"python:3.11\",\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Nil(t, cp.SessionTimeout)\n\tassert.Nil(t, cp.MaxSessionDuration)\n\tassert.Nil(t, cp.WarmPoolSize)\n\tassert.Empty(t, cp.Ports)\n\tassert.Equal(t, AuthModeType(\"\"), cp.AuthMode)\n}\n\nfunc TestCodeInterpreterSandboxTemplateAllFields(t *testing.T) {\n\truntimeClass := \"kuasar-vmm\"\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tLabels:           map[string]string{\"app\": \"code-interpreter\"},\n\t\tAnnotations:      map[string]string{\"agentcube.io/version\": \"1\"},\n\t\tRuntimeClassName: &runtimeClass,\n\t\tImage:            \"python:3.11-slim\",\n\t\tImagePullPolicy:  corev1.PullAlways,\n\t\tImagePullSecrets: []corev1.LocalObjectReference{\n\t\t\t{Name: \"registry-secret\"},\n\t\t},\n\t\tEnvironment: []corev1.EnvVar{\n\t\t\t{Name: \"PYTHONPATH\", Value: \"/app\"},\n\t\t\t{Name: \"DEBUG\", Value: \"false\"},\n\t\t},\n\t\tCommand: []string{\"python\", \"-m\", \"http.server\"},\n\t\tArgs:    []string{\"8080\"},\n\t\tResources: corev1.ResourceRequirements{\n\t\t\tRequests: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"2Gi\"),\n\t\t\t},\n\t\t\tLimits: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"2\"),\n\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"4Gi\"),\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Equal(t, \"code-interpreter\", template.Labels[\"app\"])\n\tassert.Equal(t, \"1\", template.Annotations[\"agentcube.io/version\"])\n\tassert.Equal(t, \"kuasar-vmm\", *template.RuntimeClassName)\n\tassert.Equal(t, \"python:3.11-slim\", template.Image)\n\tassert.Equal(t, corev1.PullAlways, template.ImagePullPolicy)\n\tassert.Len(t, template.ImagePullSecrets, 1)\n\tassert.Equal(t, \"registry-secret\", template.ImagePullSecrets[0].Name)\n\tassert.Len(t, template.Environment, 2)\n\tassert.Equal(t, \"/app\", template.Environment[0].Value)\n\tassert.Len(t, template.Command, 3)\n\tassert.Len(t, template.Args, 1)\n\tassert.NotNil(t, template.Resources.Requests)\n\tassert.NotNil(t, template.Resources.Limits)\n}\n\nfunc TestCodeInterpreterSandboxTemplateDeepCopyIsolation(t *testing.T) {\n\truntimeClass := \"gvisor\"\n\toriginal := &CodeInterpreterSandboxTemplate{\n\t\tLabels:           map[string]string{\"app\": \"test\"},\n\t\tAnnotations:      map[string]string{\"key\": \"value\"},\n\t\tRuntimeClassName: &runtimeClass,\n\t\tImage:            \"python:3.11\",\n\t\tImagePullPolicy:  corev1.PullIfNotPresent,\n\t\tImagePullSecrets: []corev1.LocalObjectReference{{Name: \"secret1\"}},\n\t\tEnvironment:      []corev1.EnvVar{{Name: \"VAR\", Value: \"val\"}},\n\t\tCommand:          []string{\"python\"},\n\t\tArgs:             []string{\"script.py\"},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tcp.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Labels[\"app\"])\n\n\tcp.Annotations[\"key\"] = \"modified\"\n\tassert.Equal(t, \"value\", original.Annotations[\"key\"])\n\n\t*cp.RuntimeClassName = \"modified\"\n\tassert.Equal(t, \"gvisor\", *original.RuntimeClassName)\n\n\tcp.ImagePullSecrets[0].Name = \"modified\"\n\tassert.Equal(t, \"secret1\", original.ImagePullSecrets[0].Name)\n\n\tcp.Environment[0].Value = \"modified\"\n\tassert.Equal(t, \"val\", original.Environment[0].Value)\n\n\tcp.Command[0] = \"modified\"\n\tassert.Equal(t, \"python\", original.Command[0])\n\n\tcp.Args[0] = \"modified\"\n\tassert.Equal(t, \"script.py\", original.Args[0])\n}\n\nfunc TestCodeInterpreterSandboxTemplateDeepCopyNilFields(t *testing.T) {\n\toriginal := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Nil(t, cp.Labels)\n\tassert.Nil(t, cp.Annotations)\n\tassert.Nil(t, cp.RuntimeClassName)\n\tassert.Empty(t, cp.ImagePullSecrets)\n\tassert.Empty(t, cp.Environment)\n\tassert.Empty(t, cp.Command)\n\tassert.Empty(t, cp.Args)\n}\n\nfunc TestCodeInterpreterWithAllFields(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"CodeInterpreter\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"python-interpreter\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels:    map[string]string{\"app\": \"code-interpreter\"},\n\t\t},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{\n\t\t\t\t\tName:       \"web\",\n\t\t\t\t\tPort:       8080,\n\t\t\t\t\tProtocol:   ProtocolTypeHTTP,\n\t\t\t\t\tPathPrefix: \"/\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels:      map[string]string{\"app\": \"python-interpreter\"},\n\t\t\t\tAnnotations: map[string]string{\"agentcube.io/runtime\": \"python-3.11\"},\n\t\t\t\tImage:       \"python:3.11-slim\",\n\t\t\t\tCommand:     []string{\"python\", \"-m\", \"http.server\"},\n\t\t\t\tArgs:        []string{\"8080\"},\n\t\t\t},\n\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\tWarmPoolSize:       ptrInt32(3),\n\t\t\tAuthMode:           AuthModePicoD,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\tStatus: metav1.ConditionTrue,\n\t\t\t\t\tReason: \"SandboxRunning\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tReady: true,\n\t\t},\n\t}\n\n\tassert.Equal(t, \"runtime.agentcube.volcano.sh/v1alpha1\", ci.APIVersion)\n\tassert.Equal(t, \"CodeInterpreter\", ci.Kind)\n\tassert.Equal(t, \"python-interpreter\", ci.Name)\n\tassert.Equal(t, \"default\", ci.Namespace)\n\tassert.Len(t, ci.Spec.Ports, 1)\n\tassert.Equal(t, uint32(8080), ci.Spec.Ports[0].Port)\n\tassert.Equal(t, ProtocolTypeHTTP, ci.Spec.Ports[0].Protocol)\n\tassert.Equal(t, \"/\", ci.Spec.Ports[0].PathPrefix)\n\tassert.NotNil(t, ci.Spec.Template)\n\tassert.Equal(t, \"python:3.11-slim\", ci.Spec.Template.Image)\n\tassert.Equal(t, 15*time.Minute, ci.Spec.SessionTimeout.Duration)\n\tassert.Equal(t, 8*time.Hour, ci.Spec.MaxSessionDuration.Duration)\n\tassert.Equal(t, int32(3), *ci.Spec.WarmPoolSize)\n\tassert.Equal(t, AuthModePicoD, ci.Spec.AuthMode)\n\tassert.True(t, ci.Status.Ready)\n\tassert.Len(t, ci.Status.Conditions, 1)\n}\n\nfunc TestCodeInterpreterWithNilTemplate(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tTemplate: nil,\n\t\t},\n\t}\n\n\tassert.Nil(t, ci.Spec.Template)\n\tassert.Nil(t, ci.Spec.SessionTimeout)\n\tassert.Nil(t, ci.Spec.MaxSessionDuration)\n\tassert.Nil(t, ci.Spec.WarmPoolSize)\n\tassert.Equal(t, AuthModeType(\"\"), ci.Spec.AuthMode)\n}\n\nfunc TestCodeInterpreterWithEmptyPorts(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tImage: \"python:3.11\",\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Empty(t, ci.Spec.Ports)\n\tassert.Nil(t, ci.Spec.SessionTimeout)\n\tassert.Nil(t, ci.Spec.MaxSessionDuration)\n}\n\nfunc TestCodeInterpreterListItems(t *testing.T) {\n\tlist := &CodeInterpreterList{\n\t\tListMeta: metav1.ListMeta{\n\t\t\tResourceVersion: \"12345\",\n\t\t\tContinue:        \"token\",\n\t\t},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\t\t\t},\n\t\t\t\tStatus: CodeInterpreterStatus{Ready: true},\n\t\t\t},\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci2\", Namespace: \"kube-system\"},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.10\"},\n\t\t\t\t},\n\t\t\t\tStatus: CodeInterpreterStatus{Ready: false},\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Equal(t, \"12345\", list.ListMeta.ResourceVersion)\n\tassert.Len(t, list.Items, 2)\n\tassert.Equal(t, \"ci1\", list.Items[0].Name)\n\tassert.Equal(t, \"default\", list.Items[0].Namespace)\n\tassert.True(t, list.Items[0].Status.Ready)\n\tassert.Equal(t, \"ci2\", list.Items[1].Name)\n\tassert.Equal(t, \"kube-system\", list.Items[1].Namespace)\n\tassert.False(t, list.Items[1].Status.Ready)\n}\n\nfunc TestCodeInterpreterListDeepCopyIsolation(t *testing.T) {\n\toriginal := &CodeInterpreterList{\n\t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\t\t\t\tImage:  \"python:3.11\",\n\t\t\t\t\t},\n\t\t\t\t\tWarmPoolSize: ptrInt32(2),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n\tassert.Len(t, cp.Items, 1)\n\n\tcp.Items[0].Name = \"modified\"\n\tassert.Equal(t, \"ci1\", original.Items[0].Name)\n\n\tcp.Items[0].Spec.Template.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Items[0].Spec.Template.Labels[\"app\"])\n\n\t*cp.Items[0].Spec.WarmPoolSize = 10\n\tassert.Equal(t, int32(2), *original.Items[0].Spec.WarmPoolSize)\n}\n\nfunc TestCodeInterpreterDeepCopyNilStatus(t *testing.T) {\n\toriginal := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\"},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Name, cp.Name)\n\tassert.Equal(t, original.Spec.Template.Image, cp.Spec.Template.Image)\n\tassert.False(t, cp.Status.Ready)\n\tassert.Empty(t, cp.Status.Conditions)\n}\n\nfunc TestCodeInterpreterDeepCopyPortsIsolation(t *testing.T) {\n\toriginal := &CodeInterpreter{\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP},\n\t\t\t},\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tcp.Spec.Ports[0].Port = 9090\n\tcp.Spec.Ports[0].Name = \"modified\"\n\n\tassert.Equal(t, uint32(8080), original.Spec.Ports[0].Port)\n\tassert.Equal(t, \"web\", original.Spec.Ports[0].Name)\n}\n\nfunc TestCodeInterpreterSpecWarmPoolSizeOmitEmpty(t *testing.T) {\n\tspec := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t}\n\n\tassert.Nil(t, spec.WarmPoolSize)\n\n\tspecWithPool := &CodeInterpreterSpec{\n\t\tTemplate:     &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\tWarmPoolSize: ptrInt32(5),\n\t}\n\n\tassert.NotNil(t, specWithPool.WarmPoolSize)\n\tassert.Equal(t, int32(5), *specWithPool.WarmPoolSize)\n}\n\nfunc TestCodeInterpreterSpecAuthModeDefault(t *testing.T) {\n\tspec := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t}\n\n\tassert.Equal(t, AuthModeType(\"\"), spec.AuthMode)\n\n\tspecWithAuth := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\tAuthMode: AuthModeNone,\n\t}\n\n\tassert.Equal(t, AuthModeNone, specWithAuth.AuthMode)\n}\n\nfunc TestCodeInterpreterSpecSessionTimeoutDuration(t *testing.T) {\n\tspec := &CodeInterpreterSpec{\n\t\tTemplate:       &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\tSessionTimeout: &metav1.Duration{Duration: 15 * time.Minute},\n\t}\n\n\tassert.Equal(t, 15*time.Minute, spec.SessionTimeout.Duration)\n\tassert.Equal(t, \"15m0s\", spec.SessionTimeout.Duration.String())\n}\n\nfunc TestCodeInterpreterSpecMaxSessionDuration(t *testing.T) {\n\tspec := &CodeInterpreterSpec{\n\t\tTemplate:           &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t}\n\n\tassert.Equal(t, 8*time.Hour, spec.MaxSessionDuration.Duration)\n\tassert.Equal(t, \"8h0m0s\", spec.MaxSessionDuration.Duration.String())\n}\n\nfunc TestCodeInterpreterSandboxTemplateResources(t *testing.T) {\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t\tResources: corev1.ResourceRequirements{\n\t\t\tRequests: corev1.ResourceList{\n\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"2Gi\"),\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.NotNil(t, template.Resources.Requests)\n\tassert.Equal(t, \"1\", template.Resources.Requests.Cpu().String())\n\tassert.Equal(t, \"2Gi\", template.Resources.Requests.Memory().String())\n}\n\nfunc TestCodeInterpreterSandboxTemplateRuntimeClassName(t *testing.T) {\n\truntimeClass := \"kuasar-vmm\"\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tImage:            \"python:3.11\",\n\t\tRuntimeClassName: &runtimeClass,\n\t}\n\n\tassert.Equal(t, \"kuasar-vmm\", *template.RuntimeClassName)\n\n\ttemplateNoRuntime := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t}\n\n\tassert.Nil(t, templateNoRuntime.RuntimeClassName)\n}\n\nfunc TestCodeInterpreterSandboxTemplateEnvironment(t *testing.T) {\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t\tEnvironment: []corev1.EnvVar{\n\t\t\t{Name: \"PYTHONPATH\", Value: \"/app\"},\n\t\t\t{Name: \"DEBUG\", Value: \"false\"},\n\t\t},\n\t}\n\n\tassert.Len(t, template.Environment, 2)\n\tassert.Equal(t, \"PYTHONPATH\", template.Environment[0].Name)\n\tassert.Equal(t, \"/app\", template.Environment[0].Value)\n}\n\nfunc TestCodeInterpreterSandboxTemplateImagePullSecrets(t *testing.T) {\n\ttemplate := &CodeInterpreterSandboxTemplate{\n\t\tImage: \"python:3.11\",\n\t\tImagePullSecrets: []corev1.LocalObjectReference{\n\t\t\t{Name: \"registry-secret\"},\n\t\t\t{Name: \"docker-config\"},\n\t\t},\n\t}\n\n\tassert.Len(t, template.ImagePullSecrets, 2)\n\tassert.Equal(t, \"registry-secret\", template.ImagePullSecrets[0].Name)\n\tassert.Equal(t, \"docker-config\", template.ImagePullSecrets[1].Name)\n}\n\nfunc TestCodeInterpreterListEmpty(t *testing.T) {\n\tlist := &CodeInterpreterList{}\n\n\tassert.Empty(t, list.Items)\n\tassert.Empty(t, list.ListMeta.ResourceVersion)\n}\n\nfunc TestCodeInterpreterDeepCopyObject(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{Image: \"python:3.11\"},\n\t\t},\n\t}\n\n\tobj := ci.DeepCopyObject()\n\tassert.NotNil(t, obj)\n\n\tcopied, ok := obj.(*CodeInterpreter)\n\tassert.True(t, ok)\n\tassert.Equal(t, ci.Name, copied.Name)\n\tassert.Equal(t, ci.Spec.Template.Image, copied.Spec.Template.Image)\n}\n\nfunc TestCodeInterpreterListDeepCopyObject(t *testing.T) {\n\tlist := &CodeInterpreterList{\n\t\tListMeta: metav1.ListMeta{ResourceVersion: \"1234\"},\n\t\tItems: []CodeInterpreter{\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"ci1\"}},\n\t\t},\n\t}\n\n\tobj := list.DeepCopyObject()\n\tassert.NotNil(t, obj)\n\n\tcopied, ok := obj.(*CodeInterpreterList)\n\tassert.True(t, ok)\n\tassert.Equal(t, list.ListMeta.ResourceVersion, copied.ListMeta.ResourceVersion)\n\tassert.Len(t, copied.Items, 1)\n}\n\nfunc parseQuantity(s string) resource.Quantity {\n\tq, _ := resource.ParseQuantity(s)\n\treturn q\n}\n","additions":0,"deletions":18},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go","time":{"start":1775812421607,"end":1775812421789}}}}
