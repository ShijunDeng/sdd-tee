{"type":"tool_use","timestamp":1775833106773,"sessionID":"ses_2881985fcffefoyFjb2AYpu4rN","part":{"id":"prt_d77e6c512001yVRZ6Yt2bmAWIj","messageID":"msg_d77e6be01001FP9uofFQ4oVXuD","sessionID":"ses_2881985fcffefoyFjb2AYpu4rN","type":"tool","tool":"read","callID":"call_4513dc8866e145b7b9ba5029","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"os\"\n7: \t\"strconv\"\n8: \t\"time\"\n9: \n10: \t\"github.com/redis/go-redis/v9\"\n11: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n12: \t\"k8s.io/klog/v2\"\n13: )\n14: \n15: type redisStore struct {\n16: \tcli                  redis.UniversalClient\n17: \tsessionPrefix        string\n18: \texpiryIndexKey       string\n19: \tlastActivityIndexKey string\n20: }\n21: \n22: func newRedisStore() Store {\n23: \taddr := os.Getenv(\"REDIS_ADDR\")\n24: \tif addr == \"\" {\n25: \t\tklog.Fatal(\"REDIS_ADDR environment variable is not set\")\n26: \t}\n27: \n28: \tpassword := os.Getenv(\"REDIS_PASSWORD\")\n29: \tpasswordRequired := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n30: \tif passwordRequired != \"false\" && password == \"\" {\n31: \t\tklog.Fatal(\"REDIS_PASSWORD is required (set REDIS_PASSWORD_REQUIRED=false to disable)\")\n32: \t}\n33: \n34: \topts := &redis.Options{\n35: \t\tAddr:     addr,\n36: \t\tPassword: password,\n37: \t}\n38: \n39: \tcli := redis.NewClient(opts)\n40: \n41: \treturn &redisStore{\n42: \t\tcli:                  cli,\n43: \t\tsessionPrefix:        \"session:\",\n44: \t\texpiryIndexKey:       \"session:expiry\",\n45: \t\tlastActivityIndexKey: \"session:last_activity\",\n46: \t}\n47: }\n48: \n49: func (r *redisStore) Ping(ctx context.Context) error {\n50: \tpong, err := r.cli.Ping(ctx).Result()\n51: \tif err != nil {\n52: \t\treturn err\n53: \t}\n54: \tif pong != \"PONG\" {\n55: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n56: \t}\n57: \treturn nil\n58: }\n59: \n60: func (r *redisStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n61: \tkey := r.sessionPrefix + sessionID\n62: \tdata, err := r.cli.Get(ctx, key).Bytes()\n63: \tif err == redis.Nil {\n64: \t\treturn nil, ErrNotFound\n65: \t}\n66: \tif err != nil {\n67: \t\treturn nil, err\n68: \t}\n69: \treturn decodeSandboxInfo(data)\n70: }\n71: \n72: func (r *redisStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n73: \tif info == nil {\n74: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n75: \t}\n76: \n77: \tdata, err := encodeSandboxInfo(info)\n78: \tif err != nil {\n79: \t\treturn err\n80: \t}\n81: \n82: \tkey := r.sessionPrefix + sessionID\n83: \texpiryScore := float64(info.ExpiresAt.Unix())\n84: \tlastActivityScore := float64(info.LastActivityAt.Unix())\n85: \n86: \tpipe := r.cli.Pipeline()\n87: \tpipe.SetNX(ctx, key, data, 0)\n88: \tpipe.ZAdd(ctx, r.expiryIndexKey, redis.Z{Score: expiryScore, Member: sessionID})\n89: \tpipe.ZAdd(ctx, r.lastActivityIndexKey, redis.Z{Score: lastActivityScore, Member: sessionID})\n90: \n91: \t_, err = pipe.Exec(ctx)\n92: \treturn err\n93: }\n94: \n95: func (r *redisStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n96: \tif info == nil {\n97: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n98: \t}\n99: \n100: \tdata, err := encodeSandboxInfo(info)\n101: \tif err != nil {\n102: \t\treturn err\n103: \t}\n104: \n105: \tkey := r.sessionPrefix + sessionID\n106: \tresult, err := r.cli.SetXX(ctx, key, data, 0).Result()\n107: \tif err != nil {\n108: \t\treturn err\n109: \t}\n110: \tif !result {\n111: \t\treturn fmt.Errorf(\"key %s does not exist\", key)\n112: \t}\n113: \treturn nil\n114: }\n115: \n116: func (r *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n117: \tkey := r.sessionPrefix + sessionID\n118: \n119: \tpipe := r.cli.Pipeline()\n120: \tpipe.Del(ctx, key)\n121: \tpipe.ZRem(ctx, r.expiryIndexKey, sessionID)\n122: \tpipe.ZRem(ctx, r.lastActivityIndexKey, sessionID)\n123: \n124: \t_, err := pipe.Exec(ctx)\n125: \treturn err\n126: }\n127: \n128: func (r *redisStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n129: \tsessionIDs, err := r.cli.ZRange(ctx, r.expiryIndexKey, 0, -1).Result()\n130: \tif err != nil {\n131: \t\treturn nil, err\n132: \t}\n133: \n134: \tresult := make(map[string]*types.SandboxInfo)\n135: \tfor _, id := range sessionIDs {\n136: \t\tinfo, err := r.GetSandbox(ctx, id)\n137: \t\tif err != nil {\n138: \t\t\tif err == ErrNotFound {\n139: \t\t\t\tcontinue\n140: \t\t\t}\n141: \t\t\treturn nil, err\n142: \t\t}\n143: \t\tresult[id] = info\n144: \t}\n145: \n146: \treturn result, nil\n147: }\n148: \n149: func (r *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n150: \tif sessionID == \"\" {\n151: \t\treturn fmt.Errorf(\"sessionID cannot be empty\")\n152: \t}\n153: \n154: \tif at.IsZero() {\n155: \t\tat = time.Now()\n156: \t}\n157: \n158: \tkey := r.sessionPrefix + sessionID\n159: \texists, err := r.cli.Exists(ctx, key).Result()\n160: \tif err != nil {\n161: \t\treturn err\n162: \t}\n163: \tif exists == 0 {\n164: \t\treturn ErrNotFound\n165: \t}\n166: \n167: \tscore := float64(at.Unix())\n168: \treturn r.cli.ZAdd(ctx, r.lastActivityIndexKey, redis.Z{Score: score, Member: sessionID}).Err()\n169: }\n170: \n171: func (r *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n172: \tif limit <= 0 {\n173: \t\treturn nil, nil\n174: \t}\n175: \n176: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n177: \tsessionIDs, err := r.cli.ZRangeByScore(ctx, r.expiryIndexKey, &redis.ZRangeBy{\n178: \t\tMin:    \"-inf\",\n179: \t\tMax:    maxScore,\n180: \t\tOffset: 0,\n181: \t\tCount:  int64(limit),\n182: \t}).Result()\n183: \tif err != nil {\n184: \t\treturn nil, err\n185: \t}\n186: \n187: \tvar result []*types.SandboxInfo\n188: \tfor _, id := range sessionIDs {\n189: \t\tinfo, err := r.GetSandbox(ctx, id)\n190: \t\tif err != nil {\n191: \t\t\tif err == ErrNotFound {\n192: \t\t\t\tcontinue\n193: \t\t\t}\n194: \t\t\treturn nil, err\n195: \t\t}\n196: \t\tresult = append(result, info)\n197: \t}\n198: \n199: \treturn result, nil\n200: }\n201: \n202: func (r *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n203: \tif limit <= 0 {\n204: \t\treturn nil, nil\n205: \t}\n206: \n207: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n208: \tsessionIDs, err := r.cli.ZRangeByScore(ctx, r.lastActivityIndexKey, &redis.ZRangeBy{\n209: \t\tMin:    \"-inf\",\n210: \t\tMax:    maxScore,\n211: \t\tOffset: 0,\n212: \t\tCount:  int64(limit),\n213: \t}).Result()\n214: \tif err != nil {\n215: \t\treturn nil, err\n216: \t}\n217: \n218: \tvar result []*types.SandboxInfo\n219: \tfor _, id := range sessionIDs {\n220: \t\tinfo, err := r.GetSandbox(ctx, id)\n221: \t\tif err != nil {\n222: \t\t\tif err == ErrNotFound {\n223: \t\t\t\tcontinue\n224: \t\t\t}\n225: \t\t\treturn nil, err\n226: \t\t}\n227: \t\tresult = append(result, info)\n228: \t}\n229: \n230: \treturn result, nil\n231: }\n232: \n233: func (r *redisStore) Close() error {\n234: \treturn r.cli.Close()\n235: }\n\n(End of file - total 235 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  redis.UniversalClient\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go","time":{"start":1775833106764,"end":1775833106772}}}}
{"type":"tool_use","timestamp":1775833108080,"sessionID":"ses_2881985fcffefoyFjb2AYpu4rN","part":{"id":"prt_d77e6c9d6001HyQTXajMJUMgq9","messageID":"msg_d77e6be01001FP9uofFQ4oVXuD","sessionID":"ses_2881985fcffefoyFjb2AYpu4rN","type":"tool","tool":"read","callID":"call_954e16cd1118469bb3fb1789","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"os\"\n7: \t\"strconv\"\n8: \t\"strings\"\n9: \t\"time\"\n10: \n11: \tvalkey \"github.com/valkey-io/valkey-go\"\n12: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n13: \t\"k8s.io/klog/v2\"\n14: )\n15: \n16: type valkeyStore struct {\n17: \tcli                  valkey.Client\n18: \tsessionPrefix        string\n19: \texpiryIndexKey       string\n20: \tlastActivityIndexKey string\n21: }\n22: \n23: func newValkeyStore() Store {\n24: \taddr := os.Getenv(\"VALKEY_ADDR\")\n25: \tif addr == \"\" {\n26: \t\tklog.Fatal(\"VALKEY_ADDR environment variable is not set\")\n27: \t}\n28: \n29: \taddresses := strings.Split(addr, \",\")\n30: \tfor i := range addresses {\n31: \t\taddresses[i] = strings.TrimSpace(addresses[i])\n32: \t}\n33: \n34: \tpassword := os.Getenv(\"VALKEY_PASSWORD\")\n35: \tpasswordRequired := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n36: \tif passwordRequired != \"false\" && password == \"\" {\n37: \t\tklog.Fatal(\"VALKEY_PASSWORD is required (set VALKEY_PASSWORD_REQUIRED=false to disable)\")\n38: \t}\n39: \n40: \tdisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\") == \"true\"\n41: \tforceSingle := os.Getenv(\"VALKEY_FORCE_SINGLE\") == \"true\"\n42: \n43: \tclient, err := valkey.NewClient(valkey.ClientOption{\n44: \t\tInitAddress:       addresses,\n45: \t\tPassword:          password,\n46: \t\tDisableCache:      disableCache,\n47: \t\tForceSingleClient: forceSingle,\n48: \t})\n49: \tif err != nil {\n50: \t\tklog.Fatalf(\"failed to create valkey client: %v\", err)\n51: \t}\n52: \n53: \treturn &valkeyStore{\n54: \t\tcli:                  client,\n55: \t\tsessionPrefix:        \"session:\",\n56: \t\texpiryIndexKey:       \"session:expiry\",\n57: \t\tlastActivityIndexKey: \"session:last_activity\",\n58: \t}\n59: }\n60: \n61: func (v *valkeyStore) Ping(ctx context.Context) error {\n62: \tresp, err := v.cli.Do(ctx, v.cli.B().Ping().Build()).ToString()\n63: \tif err != nil {\n64: \t\treturn err\n65: \t}\n66: \tif resp != \"PONG\" {\n67: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", resp)\n68: \t}\n69: \treturn nil\n70: }\n71: \n72: func (v *valkeyStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n73: \tkey := v.sessionPrefix + sessionID\n74: \tdata, err := v.cli.Do(ctx, v.cli.B().Get().Key(key).Build()).ToString()\n75: \tif valkey.IsValkeyNil(err) {\n76: \t\treturn nil, ErrNotFound\n77: \t}\n78: \tif err != nil {\n79: \t\treturn nil, err\n80: \t}\n81: \treturn decodeSandboxInfo([]byte(data))\n82: }\n83: \n84: func (v *valkeyStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n85: \tif info == nil {\n86: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n87: \t}\n88: \n89: \tdata, err := encodeSandboxInfo(info)\n90: \tif err != nil {\n91: \t\treturn err\n92: \t}\n93: \n94: \tkey := v.sessionPrefix + sessionID\n95: \texpiryScore := float64(info.ExpiresAt.Unix())\n96: \tlastActivityScore := float64(info.LastActivityAt.Unix())\n97: \n98: \tresults := v.cli.DoMulti(ctx,\n99: \t\tv.cli.B().Setnx().Key(key).Value(string(data)).Build(),\n100: \t\tv.cli.B().Zadd().Key(v.expiryIndexKey).ScoreMember().ScoreMember(expiryScore, sessionID).Build(),\n101: \t\tv.cli.B().Zadd().Key(v.lastActivityIndexKey).ScoreMember().ScoreMember(lastActivityScore, sessionID).Build(),\n102: \t)\n103: \n104: \tfor _, result := range results {\n105: \t\tif err := result.Error(); err != nil {\n106: \t\t\treturn err\n107: \t\t}\n108: \t}\n109: \treturn nil\n110: }\n111: \n112: func (v *valkeyStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n113: \tif info == nil {\n114: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n115: \t}\n116: \n117: \tdata, err := encodeSandboxInfo(info)\n118: \tif err != nil {\n119: \t\treturn err\n120: \t}\n121: \n122: \tkey := v.sessionPrefix + sessionID\n123: \tresp, err := v.cli.Do(ctx, v.cli.B().Set().Key(key).Value(string(data)).Xx().Build()).ToString()\n124: \tif err != nil {\n125: \t\treturn err\n126: \t}\n127: \tif resp != \"OK\" {\n128: \t\treturn fmt.Errorf(\"key %s does not exist\", key)\n129: \t}\n130: \treturn nil\n131: }\n132: \n133: func (v *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n134: \tresults := v.cli.DoMulti(ctx,\n135: \t\tv.cli.B().Del().Key(v.sessionPrefix+sessionID).Build(),\n136: \t\tv.cli.B().Zrem().Key(v.expiryIndexKey).Member(sessionID).Build(),\n137: \t\tv.cli.B().Zrem().Key(v.lastActivityIndexKey).Member(sessionID).Build(),\n138: \t)\n139: \n140: \tfor _, result := range results {\n141: \t\tif err := result.Error(); err != nil {\n142: \t\t\treturn err\n143: \t\t}\n144: \t}\n145: \treturn nil\n146: }\n147: \n148: func (v *valkeyStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n149: \tsessionIDs, err := v.cli.Do(ctx, v.cli.B().Zrange().Key(v.expiryIndexKey).Min(\"0\").Max(\"-1\").Build()).AsStrSlice()\n150: \tif err != nil {\n151: \t\treturn nil, err\n152: \t}\n153: \n154: \tresult := make(map[string]*types.SandboxInfo)\n155: \tfor _, id := range sessionIDs {\n156: \t\tinfo, err := v.GetSandbox(ctx, id)\n157: \t\tif err != nil {\n158: \t\t\tif err == ErrNotFound {\n159: \t\t\t\tcontinue\n160: \t\t\t}\n161: \t\t\treturn nil, err\n162: \t\t}\n163: \t\tresult[id] = info\n164: \t}\n165: \n166: \treturn result, nil\n167: }\n168: \n169: func (v *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n170: \tif sessionID == \"\" {\n171: \t\treturn fmt.Errorf(\"sessionID cannot be empty\")\n172: \t}\n173: \n174: \tif at.IsZero() {\n175: \t\tat = time.Now()\n176: \t}\n177: \n178: \tkey := v.sessionPrefix + sessionID\n179: \texists, err := v.cli.Do(ctx, v.cli.B().Exists().Key(key).Build()).AsInt64()\n180: \tif err != nil {\n181: \t\treturn err\n182: \t}\n183: \tif exists == 0 {\n184: \t\treturn ErrNotFound\n185: \t}\n186: \n187: \tscore := float64(at.Unix())\n188: \treturn v.cli.Do(ctx, v.cli.B().Zadd().Key(v.lastActivityIndexKey).ScoreMember().ScoreMember(score, sessionID).Build()).Error()\n189: }\n190: \n191: func (v *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n192: \tif limit <= 0 {\n193: \t\treturn nil, nil\n194: \t}\n195: \n196: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n197: \tsessionIDs, err := v.cli.Do(ctx, v.cli.B().Zrangebyscore().Key(v.expiryIndexKey).Min(\"-inf\").Max(maxScore).Limit(0, int64(limit)).Build()).AsStrSlice()\n198: \tif err != nil {\n199: \t\treturn nil, err\n200: \t}\n201: \n202: \tvar result []*types.SandboxInfo\n203: \tfor _, id := range sessionIDs {\n204: \t\tinfo, err := v.GetSandbox(ctx, id)\n205: \t\tif err != nil {\n206: \t\t\tif err == ErrNotFound {\n207: \t\t\t\tcontinue\n208: \t\t\t}\n209: \t\t\treturn nil, err\n210: \t\t}\n211: \t\tresult = append(result, info)\n212: \t}\n213: \n214: \treturn result, nil\n215: }\n216: \n217: func (v *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n218: \tif limit <= 0 {\n219: \t\treturn nil, nil\n220: \t}\n221: \n222: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n223: \tsessionIDs, err := v.cli.Do(ctx, v.cli.B().Zrangebyscore().Key(v.lastActivityIndexKey).Min(\"-inf\").Max(maxScore).Limit(0, int64(limit)).Build()).AsStrSlice()\n224: \tif err != nil {\n225: \t\treturn nil, err\n226: \t}\n227: \n228: \tvar result []*types.SandboxInfo\n229: \tfor _, id := range sessionIDs {\n230: \t\tinfo, err := v.GetSandbox(ctx, id)\n231: \t\tif err != nil {\n232: \t\t\tif err == ErrNotFound {\n233: \t\t\t\tcontinue\n234: \t\t\t}\n235: \t\t\treturn nil, err\n236: \t\t}\n237: \t\tresult = append(result, info)\n238: \t}\n239: \n240: \treturn result, nil\n241: }\n242: \n243: func (v *valkeyStore) Close() error {\n244: \tv.cli.Close()\n245: \treturn nil\n246: }\n\n(End of file - total 246 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tvalkey \"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey.go","time":{"start":1775833108066,"end":1775833108078}}}}
{"type":"tool_use","timestamp":1775833110021,"sessionID":"ses_2881985fcffefoyFjb2AYpu4rN","part":{"id":"prt_d77e6cee7001Cn3BsikCQjTGDf","messageID":"msg_d77e6be01001FP9uofFQ4oVXuD","sessionID":"ses_2881985fcffefoyFjb2AYpu4rN","type":"tool","tool":"read","callID":"call_cc2941d1cd444fc6bd9d1e24","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/changes/AR-011/tasks.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/changes/AR-011/tasks.md</path>\n<type>file</type>\n<content>\n1: # AR-011 任务清单\n2: \n3: > **Stage**: ST-3 (Design Complete)\n4: > **AR**: AR-011 — Router JWT 认证与签发\n5: > **Module**: `pkg/router`\n6: > **Language**: Go\n7: > **Size**: M\n8: \n9: ---\n10: \n11: ## T-001: JWTConfig 结构体与 Config 扩展\n12: \n13: - [ ] T-001.01 在 `pkg/router/config.go` 中定义 `JWTConfig` 结构体（包含 `Expiration`、`Issuer`、`Leeway` 字段）\n14: - [ ] T-001.02 在 `Config` 结构体中新增 `JWTExpiration`、`JWTIssuer`、`JWTLeeway` 字段\n15: - [ ] T-001.03 在 `NewDefaultConfig()` 中为新增 JWT 字段设置默认值（5m / \"agentcube-router\" / 1m）\n16: - [ ] T-001.04 编写 `config_test.go`，覆盖默认值验证和自定义值传递场景\n17: \n18: **验收**: `go test ./pkg/router/... -run Config` 全部通过；`NewDefaultConfig()` 返回的 JWT 字段值与 spec 一致\n19: \n20: ---\n21: \n22: ## T-002: JWTManager 构造函数支持配置注入\n23: \n24: - [ ] T-002.01 修改 `NewJWTManager()` 签名，接收 `config *JWTConfig` 参数\n25: - [ ] T-002.02 实现 nil 配置回退逻辑（使用默认值：Expiration=5m, Issuer=\"agentcube-router\", Leeway=1m）\n26: - [ ] T-002.03 在 `JWTManager` 结构体中新增 `config JWTConfig` 字段存储配置\n27: - [ ] T-002.04 修改 `GenerateToken()` 使用 `config.Expiration` 和 `config.Issuer` 替代硬编码常量\n28: - [ ] T-002.05 编写 `jwt_test.go`，覆盖 nil 配置和自定义配置场景\n29: \n30: **验收**: `NewJWTManager(nil)` 行为与旧版兼容；自定义配置生成的 token `exp`/`iss` 符合预期\n31: \n32: ---\n33: \n34: ## T-003: JWTManager.PublicKey() 访问器\n35: \n36: - [ ] T-003.01 实现 `func (m *JWTManager) PublicKey() *rsa.PublicKey` 方法\n37: - [ ] T-003.02 编写测试验证返回非 nil 公钥\n38: - [ ] T-003.03 编写测试验证多次调用返回同一指针地址\n39: \n40: **验收**: `jwt_test.go` 中 `TestJWTManager_PublicKey_*` 场景全部通过\n41: \n42: ---\n43: \n44: ## T-004: JWTManager.ParseAndValidateToken() 方法\n45: \n46: - [ ] T-004.01 实现 `ParseAndValidateToken(tokenString string) (jwt.MapClaims, error)` 方法\n47: - [ ] T-004.02 使用 RS256 + 内部公钥验证签名\n48: - [ ] T-004.03 启用 `exp`、`iat`、`iss` 校验（`iss` 期望值为 `config.Issuer`）\n49: - [ ] T-004.04 设置 `config.Leeway`（默认 1 分钟）宽容窗口\n50: - [ ] T-004.05 拒绝非 RS256 算法的 token\n51: - [ ] T-004.06 错误语义区分：签名无效 → `\"invalid signature\"`；过期 → `\"token is expired\"`；签发者不匹配 → `\"invalid issuer\"`；格式错误 → `\"invalid token\"`\n52: - [ ] T-004.07 编写测试：有效 token 解析成功（含自定义 claims）\n53: - [ ] T-004.08 编写测试：过期 token 返回 `\"token is expired\"`\n54: - [ ] T-004.09 编写测试：伪造签名返回 `\"invalid signature\"`\n55: - [ ] T-004.10 编写测试：非 RS256 算法返回 `\"unexpected signing method\"`\n56: - [ ] T-004.11 编写测试：签发者不匹配返回 `\"invalid issuer\"`\n57: - [ ] T-004.12 编写测试：畸形 token（`\"not-a-jwt-token\"`）返回 `\"invalid token\"`\n58: - [ ] T-004.13 编写测试：空字符串返回错误\n59: - [ ] T-004.14 编写测试：leeway 容忍时钟偏差（exp 为 30 秒前，leeway 1 分钟 → 验证通过）\n60: \n61: **验收**: `jwt_test.go` 中 `TestJWTManager_ParseAndValidateToken_*` 覆盖 delta-spec 全部 8 个 Scenario\n62: \n63: ---\n64: \n65: ## T-005: AuthMiddleware 中间件\n66: \n67: - [ ] T-005.01 在 `pkg/router/middleware.go` 中实现 `AuthMiddleware(jwtManager *JWTManager) gin.HandlerFunc`\n68: - [ ] T-005.02 从 `Authorization` header 提取 token，验证 `Bearer <token>` 格式\n69: - [ ] T-005.03 缺少 Authorization header → 401 `{\"error\": \"missing authorization header\", \"code\": \"UNAUTHORIZED\"}` + `c.Abort()`\n70: - [ ] T-005.04 非 Bearer 格式 → 401 `{\"error\": \"invalid authorization format\", \"code\": \"UNAUTHORIZED\"}` + `c.Abort()`\n71: - [ ] T-005.05 Bearer 后 token 为空 → 401 `{\"error\": \"invalid authorization format\", \"code\": \"UNAUTHORIZED\"}` + `c.Abort()`\n72: - [ ] T-005.06 调用 `jwtManager.ParseAndValidateToken(token)` 验证\n73: - [ ] T-005.07 Token 过期 → 401 `{\"error\": \"token is expired\", \"code\": \"TOKEN_EXPIRED\"}` + `c.Abort()`\n74: - [ ] T-005.08 签名无效/其他解析错误 → 401 `{\"error\": \"invalid token\", \"code\": \"UNAUTHORIZED\"}` + `c.Abort()`\n75: - [ ] T-005.09 验证通过 → `c.Set(\"claims\", claims)` + `c.Next()`\n76: - [ ] T-005.10 编写 `middleware_test.go`，使用 `gin.CreateTestContext(httptest.NewRecorder())` 模式\n77: - [ ] T-005.11 编写测试：有效 Bearer token 通过认证，claims 可被下游获取\n78: - [ ] T-005.12 编写测试：缺少 Authorization header 返回 401 UNAUTHORIZED\n79: - [ ] T-005.13 编写测试：非 Bearer 格式返回 401 invalid authorization format\n80: - [ ] T-005.14 编写测试：过期 token 返回 401 TOKEN_EXPIRED\n81: - [ ] T-005.15 编写测试：伪造 token 返回 401 UNAUTHORIZED\n82: - [ ] T-005.16 编写测试：自定义 claims（如 `session_id`）传递到下游 handler\n83: \n84: **验收**: `middleware_test.go` 覆盖 delta-spec AuthMiddleware 全部 7 个 Scenario；响应 body 与 spec 表格完全一致\n85: \n86: ---\n87: \n88: ## T-006: /v1 路由组注册 AuthMiddleware\n89: \n90: - [ ] T-006.01 在 `pkg/router/server.go` 的 `Server` 结构体中确保有 `jwtManager` 字段（如无则添加）\n91: - [ ] T-006.02 在 `NewServer()` 中初始化 `jwtManager`（使用 `NewJWTManager(&JWTConfig{...})`，从 `s.config` 读取 JWT 配置）\n92: - [ ] T-006.03 在 `registerRoutes()` 中修改 `/v1` 路由组中间件栈顺序：Logger → Recovery → AuthMiddleware → ConcurrencyLimit\n93: - [ ] T-006.04 确认 `/health/live` 和 `/health/ready` 仍在 `/v1` 组之外注册，不受 AuthMiddleware 保护\n94: - [ ] T-006.05 编写 `server_test.go`，验证中间件注册顺序\n95: - [ ] T-006.06 编写集成测试：无 Authorization header 请求 `/v1/...` 返回 401（不被 429 拦截）\n96: - [ ] T-006.07 编写集成测试：无 Authorization header 请求 `/health/live` 返回 200\n97: \n98: **验收**: 中间件栈顺序正确；health 端点公开可访问；未认证请求在并发限制之前被拦截\n99: \n100: ---\n101: \n102: ## T-007: Outbound JWT 签发回归验证\n103: \n104: - [ ] T-007.01 审查 `proxy.go` 中 `forwardToSandbox` 的 outbound JWT 签发逻辑，确认未被 T-006 改动影响\n105: - [ ] T-007.02 编写 `proxy_test.go`，验证 Sandbox 入口点转发时携带 outbound JWT\n106: - [ ] T-007.03 编写 `proxy_test.go`，验证 CodeInterpreter 入口点转发时不携带 Authorization header\n107: \n108: **验收**: outbound 签发行为与变更前一致；新增测试覆盖 delta-spec 中 2 个 outbound Scenario\n109: \n110: ---\n111: \n112: ## T-008: 编译与测试门禁\n113: \n114: - [ ] T-008.01 `go build ./pkg/router/...` 编译通过\n115: - [ ] T-008.02 `go test ./pkg/router/... -v` 全部通过\n116: - [ ] T-008.03 `go test -race ./pkg/router/...` 无 data race 告警\n117: - [ ] T-008.04 每个 `*.go` 文件有对应的 `*_test.go` 文件（jwt_test.go、middleware_test.go、server_test.go、config_test.go、proxy_test.go）\n118: - [ ] T-008.05 T/C 比率 > 0.4（测试行数 / 代码行数）\n119: - [ ] T-008.06 无 `log.Printf` 残留（使用 `klog` 或 `slog`）\n120: - [ ] T-008.07 Test-RT-1：构造无效 JWT 请求 `/v1/...`，验证返回 401 Unauthorized\n121: - [ ] T-008.08 Test-RT-2：构造过期 JWT 请求 `/v1/...`，验证返回 401 且 body 包含 `\"token is expired\"` 或 `\"TOKEN_EXPIRED\"`\n122: \n123: **验收**: 所有门禁命令执行通过；T/C 比率满足要求；Test-RT-1 和 Test-RT-2 场景有明确测试用例\n124: \n125: ---\n126: \n127: ## 依赖关系\n128: \n129: ```\n130: T-001 (Config 扩展)\n131:   └── T-002 (JWTManager 配置注入)\n132:         ├── T-003 (PublicKey 访问器)\n133:         └── T-004 (ParseAndValidateToken)\n134:               └── T-005 (AuthMiddleware)\n135:                     └── T-006 (路由注册)\n136:                           ├── T-007 (Outbound 回归)\n137:                           └── T-008 (门禁)\n138: ```\n139: \n140: ## 文件产出清单\n141: \n142: | 文件 | 状态 | 说明 |\n143: |------|------|------|\n144: | `pkg/router/config.go` | 修改 | 新增 JWTConfig、Config 扩展字段 |\n145: | `pkg/router/jwt.go` | 修改 | PublicKey()、ParseAndValidateToken()、NewJWTManager(config) |\n146: | `pkg/router/middleware.go` | 修改 | AuthMiddleware() |\n147: | `pkg/router/server.go` | 修改 | jwtManager 初始化、中间件注册 |\n148: | `pkg/router/config_test.go` | 新增 | Config 默认值与自定义值测试 |\n149: | `pkg/router/jwt_test.go` | 新增 | JWTManager 全场景测试 |\n150: | `pkg/router/middleware_test.go` | 新增 | AuthMiddleware 全场景测试 |\n151: | `pkg/router/server_test.go` | 新增 | 路由注册与中间件顺序测试 |\n152: | `pkg/router/proxy_test.go` | 新增 | Outbound JWT 回归测试 |\n\n(End of file - total 152 lines)\n</content>","metadata":{"preview":"# AR-011 任务清单\n\n> **Stage**: ST-3 (Design Complete)\n> **AR**: AR-011 — Router JWT 认证与签发\n> **Module**: `pkg/router`\n> **Language**: Go\n> **Size**: M\n\n---\n\n## T-001: JWTConfig 结构体与 Config 扩展\n\n- [ ] T-001.01 在 `pkg/router/config.go` 中定义 `JWTConfig` 结构体（包含 `Expiration`、`Issuer`、`Leeway` 字段）\n- [ ] T-001.02 在 `Config` 结构体中新增 `JWTExpiration`、`JWTIssuer`、`JWTLeeway` 字段\n- [ ] T-001.03 在 `NewDefaultConfig()` 中为新增 JWT 字段设置默认值（5m / \"agentcube-router\" / 1m）\n- [ ] T-001.04 编写 `config_test.go`，覆盖默认值验证和自定义值传递场景\n\n**验收**: `go test ./pkg/router/... -run Config` 全部通过；`NewDefaultConfig()` 返回的 JWT 字段值与 spec 一致\n\n---","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/changes/AR-011/tasks.md","time":{"start":1775833110008,"end":1775833110019}}}}
{"type":"tool_use","timestamp":1775833111057,"sessionID":"ses_2881985fcffefoyFjb2AYpu4rN","part":{"id":"prt_d77e6d66b001nIQDJCBIYdCuIJ","messageID":"msg_d77e6be01001FP9uofFQ4oVXuD","sessionID":"ses_2881985fcffefoyFjb2AYpu4rN","type":"tool","tool":"read","callID":"call_04f73379963a4096b92b6c88","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/changes/AR-010/tasks.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/changes/AR-010/tasks.md</path>\n<type>file</type>\n<content>\n1: # AR-010 任务清单\n2: \n3: > **Stage**: ST-3 (Design Complete)\n4: > **Module**: `pkg/router`, `pkg/store`\n5: > **Language**: Go\n6: > **Size**: M\n7: \n8: ---\n9: \n10: ## T-001: 扩展 Store 接口与错误定义\n11: \n12: - [ ] T-001.01 在 `pkg/store/store.go` 中扩展 `Store` 接口，新增方法：`ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)`、`ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)`、`Ping(ctx context.Context) error`、`Close() error`\n13: - [ ] T-001.02 在 `pkg/store/store.go` 中添加 `import \"time\"`\n14: - [ ] T-001.03 修改 `UpdateSessionLastActivity` 方法签名，将 `lastActivityTime interface{}` 改为 `at time.Time`\n15: - [ ] T-001.04 在 `pkg/router/errors.go` 中新增 `SessionTerminatedError` 结构体，方法 `Error() string` 返回 `\"session %q has been terminated\"`，构造函数 `NewSessionTerminatedError(sessionID string) *SessionTerminatedError`\n16: \n17: **验收**: `go build ./pkg/store/...` 编译通过；`go build ./pkg/router/...` 编译通过；`SessionTerminatedError` 可被正确实例化并返回预期错误信息\n18: \n19: ---\n20: \n21: ## T-002: 编写 Store 接口扩展单元测试\n22: \n23: - [ ] T-002.01 创建 `pkg/store/store_test.go`\n24: - [ ] T-002.02 测试 `TestErrNotFound`：验证 `errors.Is(ErrNotFound, ErrNotFound)` 为 true\n25: - [ ] T-002.03 测试 `TestStorage_ReturnsNil`：当前 `Storage()` 返回 nil（验证基线行为，后续 T-005 会改变）\n26: \n27: **验收**: `go test ./pkg/store/... -run TestErr -v` 通过；`go test ./pkg/store/... -run TestStorage -v` 通过\n28: \n29: ---\n30: \n31: ## T-003: 创建 Store 单例初始化与 Codec\n32: \n33: - [ ] T-003.01 创建 `pkg/store/singleton.go`，定义 `initStoreOnce sync.Once`、`storeInstance Store`\n34: - [ ] T-003.02 实现 `Storage() Store`：调用 `initStoreOnce.Do(func() { initStore() })`，返回 `storeInstance`\n35: - [ ] T-003.03 实现 `initStore() error`：读取 `STORE_TYPE` 环境变量（大小写不敏感），默认为 `\"redis\"`；switch 分支构造 `newRedisStore()` 或 `newValkeyStore()`，不支持的类型返回 `fmt.Errorf(\"unsupported store type: %s\", storeType)`\n36: - [ ] T-003.04 创建 `pkg/store/codec.go`，实现 `encodeSandboxInfo(info *types.SandboxInfo) ([]byte, error)`：JSON 序列化，`info == nil` 时返回错误\n37: - [ ] T-003.05 实现 `decodeSandboxInfo(data []byte) (*types.SandboxInfo, error)`：JSON 反序列化\n38: \n39: **验收**: `go build ./pkg/store/...` 编译通过；`STORE_TYPE` 未设置时默认路径为 redis；`STORE_TYPE=memcached` 时返回 unsupported 错误；`encodeSandboxInfo(nil)` 返回错误；round-trip encode→decode 结果一致\n40: \n41: ---\n42: \n43: ## T-004: 编写 Singleton 与 Codec 单元测试\n44: \n45: - [ ] T-004.01 创建 `pkg/store/singleton_test.go`\n46: - [ ] T-004.02 测试 `TestStorage_DefaultProvider`：`STORE_TYPE` 未设置时 `Storage()` 返回非 nil（需要设置合法的 REDIS_ADDR 环境变量，或 mock）\n47: - [ ] T-004.03 测试 `TestStorage_UnsupportedType`：设置 `STORE_TYPE=memcached` 后 `Storage()` 触发 `klog.Fatal`（使用 recover 捕获 panic）\n48: - [ ] T-004.04 测试 `TestStorage_ConcurrentCalls`：多个 goroutine 并发调用 `Storage()`，仅初始化一次（通过计数器验证）\n49: - [ ] T-004.05 创建 `pkg/store/codec_test.go`\n50: - [ ] T-004.06 测试 `TestEncodeSandboxInfo_Nil`：`info == nil` 时返回错误\n51: - [ ] T-004.07 测试 `TestEncodeDecode_RoundTrip`：构造 `SandboxInfo`，encode 后 decode，字段值一致\n52: \n53: **验收**: `go test ./pkg/store/... -run TestStorage -v` 全部通过；`go test ./pkg/store/... -run TestEncode -v` 全部通过；`go test ./pkg/store/... -run TestDecode -v` 全部通过\n54: \n55: ---\n56: \n57: ## T-005: 实现 Redis Store 后端\n58: \n59: - [ ] T-005.01 创建 `pkg/store/store_redis.go`\n60: - [ ] T-005.02 定义 `redisStore` 结构体，字段：`cli redis.UniversalClient`、`sessionPrefix string`（默认 `\"session:\"`）、`expiryIndexKey string`（默认 `\"session:expiry\"`）、`lastActivityIndexKey string`（默认 `\"session:last_activity\"`）\n61: - [ ] T-005.03 实现 `newRedisStore() *redisStore`：从 `REDIS_ADDR` 读取地址（必需），从 `REDIS_PASSWORD` 读取密码，检查 `REDIS_PASSWORD_REQUIRED`（默认 true），使用 `redis.NewClient` 或 `redis.NewUniversalClient` 构造客户端\n62: - [ ] T-005.04 实现 `Ping(ctx) error`：调用 `cli.Ping(ctx)`，期望返回 `\"PONG\"`\n63: - [ ] T-005.05 实现 `GetSandbox(ctx, sessionID string) (*types.SandboxInfo, error)`：`GET session:{id}`，nil 结果返回 `ErrNotFound`，否则 `decodeSandboxInfo`\n64: - [ ] T-005.06 实现 `StoreSandbox(ctx, sessionID string, info *types.SandboxInfo) error`：`info == nil` 返回错误；使用 Pipeline 执行 `SETNX key json`、`ZADD expiry ExpiresAt.Unix() sessionID`、`ZADD last_activity LastActivityAt.Unix() sessionID`；管道中任一命令失败则返回错误\n65: - [ ] T-005.07 实现 `UpdateSandbox(ctx, sessionID string, info *types.SandboxInfo) error`：`SET key json XX`（仅更新已存在 key），返回 false 时返回 `\"key not exists\"` 错误\n66: - [ ] T-005.08 实现 `DeleteSandboxBySessionID(ctx, sessionID string) error`：Pipeline 执行 `DEL key`、`ZREM expiry sessionID`、`ZREM last_activity sessionID`\n67: - [ ] T-005.09 实现 `ListSandboxes(ctx) (map[string]*types.SandboxInfo, error)`：`ZRANGE session:expiry 0 -1` 获取所有 sessionID，批量 `GET` 加载 JSON，跳过不存在的 key\n68: - [ ] T-005.10 实现 `ListExpiredSandboxes(ctx, before time.Time, limit int) ([]*types.SandboxInfo, error)`：`limit <= 0` 返回 `nil, nil`；`ZRANGEBYSCORE session:expiry -inf before.Unix() LIMIT 0 limit`，批量加载 JSON，跳过孤立成员\n69: - [ ] T-005.11 实现 `ListInactiveSandboxes(ctx, before time.Time, limit int) ([]*types.SandboxInfo, error)`：同 `ListExpiredSandboxes`，使用 `session:last_activity` ZSET\n70: - [ ] T-005.12 实现 `UpdateSessionLastActivity(ctx, sessionID string, at time.Time) error`：`sessionID` 为空返回错误；`at.IsZero()` 时使用 `time.Now()`；`EXISTS key` 验证存在性（必须为 1），否则返回 `ErrNotFound`；`ZADD last_activity at.Unix() sessionID`\n71: - [ ] T-005.13 实现 `Close() error`：调用 `cli.Close()`\n72: \n73: **验收**: `go build ./pkg/store/...` 编译通过；使用 `miniredis` 或 `alice-go/miniredis` 进行本地测试：`StoreSandbox` 原子写入三个 key、`UpdateSandbox` 对不存在的 key 返回错误、`DeleteSandboxBySessionID` 清理所有 key、`ListExpiredSandboxes` 正确查询过期条目、孤立 ZSET 成员被跳过\n74: \n75: ---\n76: \n77: ## T-006: 编写 Redis Store 单元测试\n78: \n79: - [ ] T-006.01 创建 `pkg/store/store_redis_test.go`\n80: - [ ] T-006.02 测试 `TestRedisStore_Ping`：连接 miniredis 后 Ping 返回 nil\n81: - [ ] T-006.03 测试 `TestRedisStore_GetSandbox_NotFound`：不存在的 sessionID 返回 `ErrNotFound`\n82: - [ ] T-006.04 测试 `TestRedisStore_StoreSandbox_NilInfo`：`info == nil` 时返回错误\n83: - [ ] T-006.05 测试 `TestRedisStore_StoreSandbox_AtomicWrite`：写入后主键、expiry ZSET、last_activity ZSET 均存在且值正确\n84: - [ ] T-006.06 测试 `TestRedisStore_UpdateSandbox_KeyNotExists`：对不存在的 key 调用 UpdateSandbox 返回错误\n85: - [ ] T-006.07 测试 `TestRedisStore_UpdateSandbox_Success`：先 StoreSandbox 再 UpdateSandbox，主键值被更新\n86: - [ ] T-006.08 测试 `TestRedisStore_DeleteSandboxBySessionID`：删除后主键和两个 ZSET 中均无该 sessionID\n87: - [ ] T-006.09 测试 `TestRedisStore_ListExpiredSandboxes`：插入过期和未过期条目，查询只返回过期的\n88: - [ ] T-006.10 测试 `TestRedisStore_ListInactiveSandboxes`：插入空闲和活跃条目，查询只返回空闲的\n89: - [ ] T-006.11 测试 `TestRedisStore_ListExpiredSandboxes_OrphanSkipped`：ZSET 中有 sessionID 但主键不存在时跳过该条目\n90: - [ ] T-006.12 测试 `TestRedisStore_UpdateSessionLastActivity_EmptySessionID`：空 sessionID 返回错误\n91: - [ ] T-006.13 测试 `TestRedisStore_UpdateSessionLastActivity_ZeroTime`：零时间自动使用 `time.Now()`\n92: - [ ] T-006.14 测试 `TestRedisStore_UpdateSessionLastActivity_NotFound`：不存在的 sessionID 返回 `ErrNotFound`\n93: - [ ] T-006.15 测试 `TestRedisStore_ListExpiredSandboxes_ZeroLimit`：`limit <= 0` 返回 `nil, nil`\n94: \n95: **验收**: `go test ./pkg/store/... -run TestRedisStore -v` 全部通过；`go test -race ./pkg/store/... -run TestRedisStore` 无 data race 告警\n96: \n97: ---\n98: \n99: ## T-007: 实现 Valkey Store 后端\n100: \n101: - [ ] T-007.01 创建 `pkg/store/store_valkey.go`\n102: - [ ] T-007.02 定义 `valkeyStore` 结构体，字段：`cli valkey.Client`、`sessionPrefix string`、`expiryIndexKey string`、`lastActivityIndexKey string`\n103: - [ ] T-007.03 实现 `newValkeyStore() *valkeyStore`：从 `VALKEY_ADDR` 读取地址（逗号分隔 → `InitAddress`），从 `VALKEY_PASSWORD` 读取密码，检查 `VALKEY_PASSWORD_REQUIRED`，支持 `VALKEY_DISABLE_CACHE=true` 和 `VALKEY_FORCE_SINGLE=true` 选项\n104: - [ ] T-007.04 实现 `Ping(ctx) error`：`B().Ping().ToString()` 期望 `\"PONG\"`\n105: - [ ] T-007.05 实现 `GetSandbox(ctx, sessionID string)`：`B().Get().Key(key).ToString()`，`IsValkeyNil` 时返回 `ErrNotFound`\n106: - [ ] T-007.06 实现 `StoreSandbox(ctx, sessionID, info)`：`DoMulti` 执行 `SETNX`、`ZADD expiry`、`ZADD last_activity`；`info == nil` 返回错误\n107: - [ ] T-007.07 实现 `UpdateSandbox(ctx, sessionID, info)`：`B().Set().Key(key).Value(json).Xx().ToString()` 期望 `\"OK\"`\n108: - [ ] T-007.08 实现 `DeleteSandboxBySessionID(ctx, sessionID)`：`DoMulti` 执行 `DEL`、`ZREM expiry`、`ZREM last_activity`\n109: - [ ] T-007.09 实现 `ListSandboxes(ctx)`：`B().Zrange().Key(expiry).Index(0, -1)` 获取 sessionID，批量 `GET`\n110: - [ ] T-007.10 实现 `ListExpiredSandboxes(ctx, before, limit)`：`B().Zrangebyscore().Key(expiry).Min(\"-inf\").Max(score).Limit(0, limit)`\n111: - [ ] T-007.11 实现 `ListInactiveSandboxes(ctx, before, limit)`：同 ListExpiredSandboxes，使用 `last_activity` key\n112: - [ ] T-007.12 实现 `UpdateSessionLastActivity(ctx, sessionID, at)`：`B().Exists().Key(key)` 必须为 1 → `B().Zadd().Key(last_activity).ScoreMember(score, id)`\n113: - [ ] T-007.13 实现 `Close() error`：`cli.Close()`\n114: \n115: **验收**: `go build ./pkg/store/...` 编译通过；Valkey 客户端 API 调用正确；多地址解析、DisableCache/ForceSingleClient 选项生效\n116: \n117: ---\n118: \n119: ## T-008: 编写 Valkey Store 单元测试\n120: \n121: - [ ] T-008.01 创建 `pkg/store/store_valkey_test.go`\n122: - [ ] T-008.02 测试 `TestValkeyStore_MultiAddressParsing`：`VALKEY_ADDR=\"v1:6379,v2:6379,v3:6379\"` 解析为三个 InitAddress\n123: - [ ] T-008.03 测试 `TestValkeyStore_DisableCache`：`VALKEY_DISABLE_CACHE=true` 时 DisableCache 为 true\n124: - [ ] T-008.04 测试 `TestValkeyStore_ForceSingle`：`VALKEY_FORCE_SINGLE=true` 时使用单节点客户端\n125: - [ ] T-008.05 测试 `TestValkeyStore_Sto