{"type":"tool_use","timestamp":1775893798794,"sessionID":"ses_2848078d8ffegbQQf2BEdvBcp7","part":{"id":"prt_d7b84dae5001lhrKoT7g8ziKrp","messageID":"msg_d7b84c371001ytUzxY0NhgoNs6","sessionID":"ses_2848078d8ffegbQQf2BEdvBcp7","type":"tool","tool":"read","callID":"call_afd77b8e674d4ee887924354","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_agent_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_agent_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for AgentRuntimeDataPlaneClient and AgentRuntimeClient.\"\"\"\n2: \n3: import os\n4: from unittest.mock import MagicMock, patch, PropertyMock\n5: \n6: import pytest\n7: import requests\n8: from requests.adapters import HTTPAdapter\n9: \n10: from agentcube.agent_runtime import AgentRuntimeClient\n11: from agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n12: \n13: \n14: # ---------------------------------------------------------------------------\n15: # T-1: AgentRuntimeDataPlaneClient — Base URL and HTTP session\n16: # ---------------------------------------------------------------------------\n17: \n18: \n19: class TestDataPlaneClientBaseUrl:\n20:     def test_base_url_is_correctly_constructed(self):\n21:         client = AgentRuntimeDataPlaneClient(\n22:             router_url=\"https://router.example.com\",\n23:             namespace=\"my-ns\",\n24:             agent_name=\"my-agent\",\n25:         )\n26:         assert client.base_url == (\n27:             \"https://router.example.com/v1/namespaces/my-ns/\"\n28:             \"agent-runtimes/my-agent/invocations/\"\n29:         )\n30: \n31:     def test_base_url_with_trailing_slash_on_router(self):\n32:         client = AgentRuntimeDataPlaneClient(\n33:             router_url=\"https://router.example.com/\",\n34:             namespace=\"ns\",\n35:             agent_name=\"agent\",\n36:         )\n37:         assert client.base_url == (\n38:             \"https://router.example.com/v1/namespaces/ns/\"\n39:             \"agent-runtimes/agent/invocations/\"\n40:         )\n41: \n42:     def test_session_header_constant(self):\n43:         assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n44: \n45:     def test_session_has_http_adapter_with_correct_pool_settings(self):\n46:         client = AgentRuntimeDataPlaneClient(\n47:             router_url=\"https://router.example.com\",\n48:             namespace=\"ns\",\n49:             agent_name=\"agent\",\n50:         )\n51:         http_adapter = client.session.adapters[\"http://\"]\n52:         https_adapter = client.session.adapters[\"https://\"]\n53:         assert isinstance(http_adapter, HTTPAdapter)\n54:         assert isinstance(https_adapter, HTTPAdapter)\n55:         assert http_adapter._pool_connections == 10\n56:         assert http_adapter._pool_maxsize == 10\n57: \n58:     def test_custom_pool_settings(self):\n59:         client = AgentRuntimeDataPlaneClient(\n60:             router_url=\"https://router.example.com\",\n61:             namespace=\"ns\",\n62:             agent_name=\"agent\",\n63:             pool_connections=20,\n64:             pool_maxsize=30,\n65:         )\n66:         adapter = client.session.adapters[\"http://\"]\n67:         assert adapter._pool_connections == 20\n68:         assert adapter._pool_maxsize == 30\n69: \n70:     def test_constructor_stores_all_fields_with_explicit_arguments(self):\n71:         client = AgentRuntimeDataPlaneClient(\n72:             router_url=\"https://router.example.com\",\n73:             namespace=\"custom-ns\",\n74:             agent_name=\"custom-agent\",\n75:             timeout=60,\n76:             connect_timeout=3.0,\n77:         )\n78:         assert client.router_url == \"https://router.example.com\"\n79:         assert client.namespace == \"custom-ns\"\n80:         assert client.agent_name == \"custom-agent\"\n81:         assert client.timeout == 60\n82:         assert client.connect_timeout == 3.0\n83: \n84:     def test_constructor_uses_default_timeout_values(self):\n85:         client = AgentRuntimeDataPlaneClient(\n86:             router_url=\"https://router.example.com\",\n87:             namespace=\"ns\",\n88:             agent_name=\"agent\",\n89:         )\n90:         assert client.timeout == 120\n91:         assert client.connect_timeout == 5.0\n92: \n93: \n94: # ---------------------------------------------------------------------------\n95: # T-2: AgentRuntimeDataPlaneClient — bootstrap_session_id\n96: # ---------------------------------------------------------------------------\n97: \n98: \n99: class TestBootstrapSessionId:\n100:     def test_bootstrap_returns_session_id_when_header_present(self):\n101:         client = AgentRuntimeDataPlaneClient(\n102:             router_url=\"https://router.example.com\",\n103:             namespace=\"ns\",\n104:             agent_name=\"agent\",\n105:         )\n106:         mock_resp = MagicMock(spec=requests.Response)\n107:         mock_resp.headers = {\"x-agentcube-session-id\": \"abc-123\"}\n108:         mock_resp.raise_for_status = MagicMock()\n109:         client.session.get = MagicMock(return_value=mock_resp)\n110: \n111:         result = client.bootstrap_session_id()\n112: \n113:         client.session.get.assert_called_once_with(\n114:             client.base_url,\n115:             timeout=(5.0, 120),\n116:         )\n117:         assert result == \"abc-123\"\n118: \n119:     def test_bootstrap_raises_value_error_when_header_missing(self):\n120:         client = AgentRuntimeDataPlaneClient(\n121:             router_url=\"https://router.example.com\",\n122:             namespace=\"ns\",\n123:             agent_name=\"agent\",\n124:         )\n125:         mock_resp = MagicMock(spec=requests.Response)\n126:         mock_resp.headers = {}\n127:         mock_resp.raise_for_status = MagicMock()\n128:         client.session.get = MagicMock(return_value=mock_resp)\n129: \n130:         with pytest.raises(ValueError) as exc_info:\n131:             client.bootstrap_session_id()\n132: \n133:         assert \"Missing required response header: x-agentcube-session-id\" in str(\n134:             exc_info.value\n135:         )\n136: \n137:     def test_bootstrap_raises_http_error_on_non_2xx(self):\n138:         client = AgentRuntimeDataPlaneClient(\n139:             router_url=\"https://router.example.com\",\n140:             namespace=\"ns\",\n141:             agent_name=\"agent\",\n142:         )\n143:         mock_resp = MagicMock(spec=requests.Response)\n144:         mock_resp.raise_for_status = MagicMock(\n145:             side_effect=requests.HTTPError(\"500 Server Error\")\n146:         )\n147:         client.session.get = MagicMock(return_value=mock_resp)\n148: \n149:         with pytest.raises(requests.HTTPError):\n150:             client.bootstrap_session_id()\n151: \n152:     def test_bootstrap_calls_raise_for_status(self):\n153:         client = AgentRuntimeDataPlaneClient(\n154:             router_url=\"https://router.example.com\",\n155:             namespace=\"ns\",\n156:             agent_name=\"agent\",\n157:         )\n158:         mock_resp = MagicMock(spec=requests.Response)\n159:         mock_resp.headers = {\"x-agentcube-session-id\": \"session-1\"}\n160:         mock_resp.raise_for_status = MagicMock()\n161:         client.session.get = MagicMock(return_value=mock_resp)\n162: \n163:         client.bootstrap_session_id()\n164: \n165:         mock_resp.raise_for_status.assert_called_once()\n166: \n167: \n168: # ---------------------------------------------------------------------------\n169: # T-3: AgentRuntimeDataPlaneClient — invoke\n170: # ---------------------------------------------------------------------------\n171: \n172: \n173: class TestDataPlaneInvoke:\n174:     def test_invoke_posts_correct_url_with_session_header_and_json_body(self):\n175:         client = AgentRuntimeDataPlaneClient(\n176:             router_url=\"https://router.example.com\",\n177:             namespace=\"ns\",\n178:             agent_name=\"agent\",\n179:         )\n180:         mock_resp = MagicMock(spec=requests.Response)\n181:         mock_resp.raise_for_status = MagicMock()\n182:         client.session.post = MagicMock(return_value=mock_resp)\n183: \n184:         payload = {\"action\": \"run\", \"input\": \"hello\"}\n185:         result = client.invoke(session_id=\"sess-1\", payload=payload)\n186: \n187:         client.session.post.assert_called_once_with(\n188:             client.base_url,\n189:             json=payload,\n190:             headers={\n191:                 \"x-agentcube-session-id\": \"sess-1\",\n192:                 \"Content-Type\": \"application/json\",\n193:             },\n194:             timeout=(5.0, 120),\n195:         )\n196:         assert result is mock_resp\n197: \n198:     def test_invoke_with_timeout_none_uses_default_read_timeout(self):\n199:         client = AgentRuntimeDataPlaneClient(\n200:             router_url=\"https://router.example.com\",\n201:             namespace=\"ns\",\n202:             agent_name=\"agent\",\n203:             timeout=120,\n204:             connect_timeout=5.0,\n205:         )\n206:         mock_resp = MagicMock(spec=requests.Response)\n207:         mock_resp.raise_for_status = MagicMock()\n208:         client.session.post = MagicMock(return_value=mock_resp)\n209: \n210:         client.invoke(session_id=\"sess-1\", payload={\"key\": \"val\"}, timeout=None)\n211: \n212:         _, kwargs = client.session.post.call_args\n213:         assert kwargs[\"timeout\"] == (5.0, 120)\n214: \n215:     def test_invoke_with_explicit_timeout_uses_provided_value(self):\n216:         client = AgentRuntimeDataPlaneClient(\n217:             router_url=\"https://router.example.com\",\n218:             namespace=\"ns\",\n219:             agent_name=\"agent\",\n220:             timeout=120,\n221:             connect_timeout=5.0,\n222:         )\n223:         mock_resp = MagicMock(spec=requests.Response)\n224:         mock_resp.raise_for_status = MagicMock()\n225:         client.session.post = MagicMock(return_value=mock_resp)\n226: \n227:         client.invoke(session_id=\"sess-1\", payload={\"key\": \"val\"}, timeout=60.0)\n228: \n229:         _, kwargs = client.session.post.call_args\n230:         assert kwargs[\"timeout\"] == (5.0, 60.0)\n231: \n232:     def test_invoke_returns_raw_response(self):\n233:         client = AgentRuntimeDataPlaneClient(\n234:             router_url=\"https://router.example.com\",\n235:             namespace=\"ns\",\n236:             agent_name=\"agent\",\n237:         )\n238:         mock_resp = MagicMock(spec=requests.Response)\n239:         mock_resp.raise_for_status = MagicMock()\n240:         client.session.post = MagicMock(return_value=mock_resp)\n241: \n242:         result = client.invoke(session_id=\"sess-1\", payload={})\n243: \n244:         assert result is mock_resp\n245: \n246:     def test_invoke_calls_raise_for_status(self):\n247:         client = AgentRuntimeDataPlaneClient(\n248:             router_url=\"https://router.example.com\",\n249:             namespace=\"ns\",\n250:             agent_name=\"agent\",\n251:         )\n252:         mock_resp = MagicMock(spec=requests.Response)\n253:         mock_resp.raise_for_status = MagicMock()\n254:         client.session.post = MagicMock(return_value=mock_resp)\n255: \n256:         client.invoke(session_id=\"sess-1\", payload={})\n257: \n258:         mock_resp.raise_for_status.assert_called_once()\n259: \n260: \n261: # ---------------------------------------------------------------------------\n262: # T-4: AgentRuntimeDataPlaneClient — close\n263: # ---------------------------------------------------------------------------\n264: \n265: \n266: class TestDataPlaneClose:\n267:     def test_close_closes_underlying_http_session(self):\n268:         client = AgentRuntimeDataPlaneClient(\n269:             router_url=\"https://router.example.com\",\n270:             namespace=\"ns\",\n271:             agent_name=\"agent\",\n272:         )\n273:         client.session.close = MagicMock()\n274: \n275:         client.close()\n276: \n277:         client.session.close.assert_called_once()\n278: \n279:     def test_close_is_idempotent(self):\n280:         client = AgentRuntimeDataPlaneClient(\n281:             router_url=\"https://router.example.com\",\n282:             namespace=\"ns\",\n283:             agent_name=\"agent\",\n284:         )\n285:         client.session.close = MagicMock()\n286: \n287:         client.close()\n288:         client.close()\n289:         client.close()\n290: \n291:         assert client.session.close.call_count == 3\n292: \n293: \n294: # ---------------------------------------------------------------------------\n295: # T-5: AgentRuntimeClient — Initialization with defaults\n296: # ---------------------------------------------------------------------------\n297: \n298: \n299: class TestClientInitDefaults:\n300:     @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n301:     def test_constructor_with_only_agent_name_uses_all_defaults(self, mock_bootstrap):\n302:         with patch.dict(os.environ, {\"ROUTER_URL\": \"https://router.example.com\"}):\n303:             client = AgentRuntimeClient(agent_name=\"my-agent\")\n304: \n305:         assert client.agent_name == \"my-agent\"\n306:         assert client.namespace == \"default\"\n307:         assert client.timeout == 120\n308:         assert client.connect_timeout == 5.0\n309:         assert client.session_id == \"bootstrapped-session\"\n310:         assert client.router_url == \"https://router.example.com\"\n311: \n312:     @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n313:     def test_constructor_with_explicit_args_stores_all_fields(self, mock_bootstrap):\n314:         client = AgentRuntimeClient(\n315:             agent_name=\"explicit-agent\",\n316:             namespace=\"explicit-ns\",\n317:             router_url=\"https://explicit-router.com\",\n318:             verbose=True,\n319:             session_id=\"pre-existing-session\",\n320:             timeout=60,\n321:             connect_timeout=3.0,\n322:         )\n323: \n324:         assert client.agent_name == \"explicit-agent\"\n325:         assert client.namespace == \"explicit-ns\"\n326:         assert client.timeout == 60\n327:         assert client.connect_timeout == 3.0\n328:         assert client.router_url == \"https://explicit-router.com\"\n329:         assert client.session_id == \"pre-existing-session\"\n330:         mock_bootstrap.assert_not_called()\n331: \n332:     @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n333:     def test_constructor_resolves_router_url_from_env(self, mock_bootstrap):\n334:         with patch.dict(os.environ, {\"ROUTER_URL\": \"https://env-router.com\"}):\n335:             client = AgentRuntimeClient(agent_name=\"my-agent\")\n336: \n337:         assert client.router_url == \"https://env-router.com\"\n338: \n339:     def test_constructor_raises_value_error_when_no_router_url(self):\n340:         with patch.dict(os.environ, {}, clear=True):\n341:             # Ensure ROUTER_URL is not set\n342:             os.environ.pop(\"ROUTER_URL\", None)\n343:             with pytest.raises(ValueError) as exc_info:\n344:                 AgentRuntimeClient(agent_name=\"my-agent\")\n345: \n346:         assert \"router_url must be provided or ROUTER_URL env var must be set\" in str(\n347:             exc_info.value\n348:         )\n349: \n350:     @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n351:     def test_dp_client_is_constructed_with_resolved_params(self, mock_bootstrap):\n352:         with patch(\n353:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n354:         ) as mock_dp_cls:\n355:             mock_dp_instance = MagicMock()\n356:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n357:             mock_dp_cls.return_value = mock_dp_instance\n358: \n359:             client = AgentRuntimeClient(\n360:                 agent_name=\"my-agent\",\n361:                 namespace=\"my-ns\",\n362:                 router_url=\"https://router.example.com\",\n363:                 timeout=90,\n364:                 connect_timeout=4.0,\n365:             )\n366: \n367:             mock_dp_cls.assert_called_once_with(\n368:                 router_url=\"https://router.example.com\",\n369:                 namespace=\"my-ns\",\n370:                 agent_name=\"my-agent\",\n371:                 timeout=90,\n372:                 connect_timeout=4.0,\n373:             )\n374:             assert client.dp_client is mock_dp_instance\n375: \n376: \n377: # ---------------------------------------------------------------------------\n378: # T-6: AgentRuntimeClient — Session bootstrapping and reuse\n379: # ---------------------------------------------------------------------------\n380: \n381: \n382: class TestClientSession:\n383:     def test_session_id_none_triggers_bootstrap(self):\n384:         with patch(\n385:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n386:         ) as mock_dp_cls:\n387:             mock_dp_instance = MagicMock()\n388:             mock_dp_instance.bootstrap_session_id.return_value = \"bootstrapped-123\"\n389:             mock_dp_cls.return_value = mock_dp_instance\n390: \n391:             client = AgentRuntimeClient(\n392:                 agent_name=\"my-agent\",\n393:                 router_url=\"https://router.example.com\",\n394:                 session_id=None,\n395:             )\n396: \n397:             mock_dp_instance.bootstrap_session_id.assert_called_once()\n398:             assert client.session_id == \"bootstrapped-123\"\n399: \n400:     def test_session_id_provided_skips_bootstrap(self):\n401:         with patch(\n402:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n403:         ) as mock_dp_cls:\n404:             mock_dp_instance = MagicMock()\n405:             mock_dp_cls.return_value = mock_dp_instance\n406: \n407:             client = AgentRuntimeClient(\n408:                 agent_name=\"my-agent\",\n409:                 router_url=\"https://router.example.com\",\n410:                 session_id=\"existing-session-id\",\n411:             )\n412: \n413:             mock_dp_instance.bootstrap_session_id.assert_not_called()\n414:             assert client.session_id == \"existing-session-id\"\n415: \n416:     def test_verbose_true_creates_logger_with_debug_level(self):\n417:         with patch(\n418:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n419:         ) as mock_dp_cls:\n420:             mock_dp_instance = MagicMock()\n421:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n422:             mock_dp_cls.return_value = mock_dp_instance\n423: \n424:             client = AgentRuntimeClient(\n425:                 agent_name=\"my-agent\",\n426:                 router_url=\"https://router.example.com\",\n427:                 verbose=True,\n428:             )\n429: \n430:             assert client.logger.level == 10  # logging.DEBUG\n431: \n432:     def test_verbose_false_creates_logger_with_info_level(self):\n433:         with patch(\n434:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n435:         ) as mock_dp_cls:\n436:             mock_dp_instance = MagicMock()\n437:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n438:             mock_dp_cls.return_value = mock_dp_instance\n439: \n440:             client = AgentRuntimeClient(\n441:                 agent_name=\"my-agent\",\n442:                 router_url=\"https://router.example.com\",\n443:                 verbose=False,\n444:             )\n445: \n446:             assert client.logger.level == 20  # logging.INFO\n447: \n448: \n449: # ---------------------------------------------------------------------------\n450: # T-7: AgentRuntimeClient — Context manager\n451: # ---------------------------------------------------------------------------\n452: \n453: \n454: class TestContextManager:\n455:     def test_enter_returns_self(self):\n456:         with patch(\n457:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n458:         ) as mock_dp_cls:\n459:             mock_dp_instance = MagicMock()\n460:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n461:             mock_dp_cls.return_value = mock_dp_instance\n462: \n463:             client = AgentRuntimeClient(\n464:                 agent_name=\"my-agent\",\n465:                 router_url=\"https://router.example.com\",\n466:             )\n467: \n468:             assert client.__enter__() is client\n469: \n470:     def test_exit_with_no_exception_calls_close(self):\n471:         with patch(\n472:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n473:         ) as mock_dp_cls:\n474:             mock_dp_instance = MagicMock()\n475:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n476:             mock_dp_cls.return_value = mock_dp_instance\n477: \n478:             client = AgentRuntimeClient(\n479:                 agent_name=\"my-agent\",\n480:                 router_url=\"https://router.example.com\",\n481:             )\n482:             client.close = MagicMock()\n483: \n484:             client.__exit__(None, None, None)\n485: \n486:             client.close.assert_called_once()\n487: \n488:     def test_exit_with_exception_calls_close_and_re_raises(self):\n489:         with patch(\n490:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n491:         ) as mock_dp_cls:\n492:             mock_dp_instance = MagicMock()\n493:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n494:             mock_dp_cls.return_value = mock_dp_instance\n495: \n496:             client = AgentRuntimeClient(\n497:                 agent_name=\"my-agent\",\n498:                 router_url=\"https://router.example.com\",\n499:             )\n500:             client.close = MagicMock()\n501: \n502:             exc_type = ValueError\n503:             exc_val = ValueError(\"test error\")\n504:             exc_tb = None\n505: \n506:             result = client.__exit__(exc_type, exc_val, exc_tb)\n507: \n508:             client.close.assert_called_once()\n509:             assert result is None  # does not suppress exception\n510: \n511:     def test_context_manager_with_statement_normal_flow(self):\n512:         with patch(\n513:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n514:         ) as mock_dp_cls:\n515:             mock_dp_instance = MagicMock()\n516:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n517:             mock_dp_cls.return_value = mock_dp_instance\n518: \n519:             with AgentRuntimeClient(\n520:                 agent_name=\"my-agent\",\n521:                 router_url=\"https://router.example.com\",\n522:             ) as client:\n523:                 assert client.session_id == \"session-1\"\n524: \n525:             mock_dp_instance.close.assert_called_once()\n526: \n527:     def test_context_manager_with_statement_exception_flow(self):\n528:         with patch(\n529:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n530:         ) as mock_dp_cls:\n531:             mock_dp_instance = MagicMock()\n532:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n533:             mock_dp_cls.return_value = mock_dp_instance\n534: \n535:             with pytest.raises(RuntimeError):\n536:                 with AgentRuntimeClient(\n537:                     agent_name=\"my-agent\",\n538:                     router_url=\"https://router.example.com\",\n539:                 ) as client:\n540:                     raise RuntimeError(\"boom\")\n541: \n542:             mock_dp_instance.close.assert_called_once()\n543: \n544: \n545: # ---------------------------------------------------------------------------\n546: # T-8: AgentRuntimeClient — invoke\n547: # ---------------------------------------------------------------------------\n548: \n549: \n550: class TestClientInvoke:\n551:     def test_invoke_with_valid_session_calls_dp_invoke_and_returns_parsed_json(self):\n552:         with patch(\n553:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n554:         ) as mock_dp_cls:\n555:             mock_dp_instance = MagicMock()\n556:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n557:             mock_dp_cls.return_value = mock_dp_instance\n558: \n559:             mock_response = MagicMock(spec=requests.Response)\n560:             mock_response.json.return_value = {\"result\": \"ok\", \"status\": 200}\n561:             mock_dp_instance.invoke.return_value = mock_response\n562: \n563:             client = AgentRuntimeClient(\n564:                 agent_name=\"my-agent\",\n565:                 router_url=\"https://router.example.com\",\n566:             )\n567: \n568:             result = client.invoke({\"action\": \"run\"})\n569: \n570:             mock_dp_instance.invoke.assert_called_once_with(\n571:                 session_id=\"session-1\",\n572:                 payload={\"action\": \"run\"},\n573:                 timeout=None,\n574:             )\n575:             assert result == {\"result\": \"ok\", \"status\": 200}\n576: \n577:     def test_invoke_with_session_id_none_raises_value_error(self):\n578:         with patch(\n579:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n580:         ) as mock_dp_cls:\n581:             mock_dp_instance = MagicMock()\n582:             mock_dp_instance.bootstrap_session_id.return_value = None\n583:             mock_dp_cls.return_value = mock_dp_instance\n584: \n585:             client = AgentRuntimeClient(\n586:                 agent_name=\"my-agent\",\n587:                 router_url=\"https://router.example.com\",\n588:             )\n589: \n590:             with pytest.raises(ValueError) as exc_info:\n591:                 client.invoke({\"action\": \"run\"})\n592: \n593:             assert \"AgentRuntime session_id is not initialized\" in str(exc_info.value)\n594: \n595:     def test_invoke_with_custom_timeout_passes_timeout_to_data_plane(self):\n596:         with patch(\n597:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n598:         ) as mock_dp_cls:\n599:             mock_dp_instance = MagicMock()\n600:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n601:             mock_dp_cls.return_value = mock_dp_instance\n602: \n603:             mock_response = MagicMock(spec=requests.Response)\n604:             mock_response.json.return_value = {\"result\": \"ok\"}\n605:             mock_dp_instance.invoke.return_value = mock_response\n606: \n607:             client = AgentRuntimeClient(\n608:                 agent_name=\"my-agent\",\n609:                 router_url=\"https://router.example.com\",\n610:             )\n611: \n612:             client.invoke({\"action\": \"run\"}, timeout=30.0)\n613: \n614:             mock_dp_instance.invoke.assert_called_once_with(\n615:                 session_id=\"session-1\",\n616:                 payload={\"action\": \"run\"},\n617:                 timeout=30.0,\n618:             )\n619: \n620:     def test_invoke_with_timeout_none_passes_none_to_data_plane(self):\n621:         with patch(\n622:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n623:         ) as mock_dp_cls:\n624:             mock_dp_instance = MagicMock()\n625:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n626:             mock_dp_cls.return_value = mock_dp_instance\n627: \n628:             mock_response = MagicMock(spec=requests.Response)\n629:             mock_response.json.return_value = {\"result\": \"ok\"}\n630:             mock_dp_instance.invoke.return_value = mock_response\n631: \n632:             client = AgentRuntimeClient(\n633:                 agent_name=\"my-agent\",\n634:                 router_url=\"https://router.example.com\",\n635:             )\n636: \n637:             client.invoke({\"action\": \"run\"}, timeout=None)\n638: \n639:             mock_dp_instance.invoke.assert_called_once_with(\n640:                 session_id=\"session-1\",\n641:                 payload={\"action\": \"run\"},\n642:                 timeout=None,\n643:             )\n644: \n645:     def test_invoke_with_empty_session_id_raises_value_error(self):\n646:         with patch(\n647:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n648:         ) as mock_dp_cls:\n649:             mock_dp_instance = MagicMock()\n650:             mock_dp_instance.bootstrap_session_id.return_value = \"\"\n651:             mock_dp_cls.return_value = mock_dp_instance\n652: \n653:             client = AgentRuntimeClient(\n654:                 agent_name=\"my-agent\",\n655:                 router_url=\"https://router.example.com\",\n656:             )\n657: \n658:             with pytest.raises(ValueError) as exc_info:\n659:                 client.invoke({\"action\": \"run\"})\n660: \n661:             assert \"AgentRuntime session_id is not initialized\" in str(exc_info.value)\n662: \n663: \n664: # ---------------------------------------------------------------------------\n665: # T-9: AgentRuntimeClient — close\n666: # ---------------------------------------------------------------------------\n667: \n668: \n669: class TestClientClose:\n670:     def test_close_delegates_to_dp_client_close(self):\n671:         with patch(\n672:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n673:         ) as mock_dp_cls:\n674:             mock_dp_instance = MagicMock()\n675:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n676:             mock_dp_cls.return_value = mock_dp_instance\n677: \n678:             client = AgentRuntimeClient(\n679:                 agent_name=\"my-agent\",\n680:                 router_url=\"https://router.example.com\",\n681:             )\n682: \n683:             client.close()\n684: \n685:             mock_dp_instance.close.assert_called_once()\n686: \n687:     def test_close_is_idempotent(self):\n688:         with patch(\n689:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n690:         ) as mock_dp_cls:\n691:             mock_dp_instance = MagicMock()\n692:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n693:             mock_dp_cls.return_value = mock_dp_instance\n694: \n695:             client = AgentRuntimeClient(\n696:                 agent_name=\"my-agent\",\n697:                 router_url=\"https://router.example.com\",\n698:             )\n699: \n700:             client.close()\n701:             client.close()\n702:             client.close()\n703: \n704:             assert mock_dp_instance.close.call_count == 3\n705: \n706: \n707: # ---------------------------------------------------------------------------\n708: # T-10: Integration tests\n709: # ---------------------------------------------------------------------------\n710: \n711: \n712: class TestAgentRuntimeIntegration:\n713:     def test_full_lifecycle_with_context_manager(self):\n714:         \"\"\"Full lifecycle: init -> bootstrap -> invoke -> cleanup.\"\"\"\n715:         with patch(\n716:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n717:         ) as mock_dp_cls:\n718:             mock_dp_instance = MagicMock()\n719:             mock_dp_instance.bootstrap_session_id.return_value = \"session-lifecycle\"\n720:             mock_dp_cls.return_value = mock_dp_instance\n721: \n722:             mock_response = MagicMock(spec=requests.Response)\n723:             mock_response.json.return_value = {\"output\": \"hello world\"}\n724:             mock_dp_instance.invoke.return_value = mock_response\n725: \n726:             with AgentRuntimeClient(\n727:                 agent_name=\"test-agent\",\n728:                 namespace=\"test-ns\",\n729:                 router_url=\"https://router.test.com\",\n730:             ) as client:\n731:                 assert client.session_id == \"session-lifecycle\"\n732:                 result = client.invoke({\"message\": \"hello\"})\n733:                 assert result == {\"output\": \"hello world\"}\n734: \n735:             mock_dp_instance.bootstrap_session_id.assert_called_once()\n736:             mock_dp_instance.invoke.assert_called_once()\n737:             mock_dp_instance.close.assert_called_once()\n738: \n739:     def test_pre_provisioned_session_skips_bootstrap(self):\n740:         with patch(\n741:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n742:         ) as mock_dp_cls:\n743:             mock_dp_instance = MagicMock()\n744:             mock_dp_cls.return_value = mock_dp_instance\n745: \n746:             mock_response = MagicMock(spec=requests.Response)\n747:             mock_response.json.return_value = {\"output\": \"result\"}\n748:             mock_dp_instance.invoke.return_value = mock_response\n749: \n750:             with AgentRuntimeClient(\n751:                 agent_name=\"test-agent\",\n752:                 router_url=\"https://router.test.com\",\n753:                 session_id=\"pre-provisioned\",\n754:             ) as client:\n755:                 assert client.session_id == \"pre-provisioned\"\n756:                 result = client.invoke({\"query\": \"test\"})\n757:                 assert result == {\"output\": \"result\"}\n758: \n759:             mock_dp_instance.bootstrap_session_id.assert_not_called()\n760:             mock_dp_instance.invoke.assert_called_once()\n761:             mock_dp_instance.close.assert_called_once()\n762: \n763:     def test_invoke_with_custom_timeout(self):\n764:         with patch(\n765:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n766:         ) as mock_dp_cls:\n767:             mock_dp_instance = MagicMock()\n768:             mock_dp_instance.bootstrap_session_id.return_value = \"session-timeout\"\n769:             mock_dp_cls.return_value = mock_dp_instance\n770: \n771:             mock_response = MagicMock(spec=requests.Response)\n772:             mock_response.json.return_value = {\"status\": \"done\"}\n773:             mock_dp_instance.invoke.return_value = mock_response\n774: \n775:             with AgentRuntimeClient(\n776:                 agent_name=\"test-agent\",\n777:                 router_url=\"https://router.test.com\",\n778:                 timeout=60,\n779:                 connect_timeout=3.0,\n780:             ) as client:\n781:                 client.invoke({\"task\": \"long_running\"}, timeout=30.0)\n782: \n783:             mock_dp_instance.invoke.assert_called_once_with(\n784:                 session_id=\"session-timeout\",\n785:                 payload={\"task\": \"long_running\"},\n786:                 timeout=30.0,\n787:             )\n788: \n789:     def test_context_manager_exit_with_exception_still_closes_session(self):\n790:         with patch(\n791:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n792:         ) as mock_dp_cls:\n793:             mock_dp_instance = MagicMock()\n794:             mock_dp_instance.bootstrap_session_id.return_value = \"session-exception\"\n795:             mock_dp_cls.return_value = mock_dp_instance\n796: \n797:             with pytest.raises(ValueError):\n798:                 with AgentRuntimeClient(\n799:                     agent_name=\"test-agent\",\n800:                     router_url=\"https://router.test.com\",\n801:                 ) as client:\n802:                     assert client.session_id == \"session-exception\"\n803:                     raise ValueError(\"something went wrong\")\n804: \n805:             mock_dp_instance.close.assert_called_once()\n806: \n807:     def test_missing_router_url_raises_value_error(self):\n808:         with patch.dict(os.environ, {}, clear=True):\n809:             os.environ.pop(\"ROUTER_URL\", None)\n810:             with pytest.raises(ValueError) as exc_info:\n811:                 AgentRuntimeClient(\n812:                     agent_name=\"test-agent\",\n813:                 )\n814: \n815:             assert \"router_url must be provided or ROUTER_URL env var must be set\" in str(\n816:                 exc_info.value\n817:             )\n818: \n819:     def test_bootstrap_session_id_missing_header_raises_value_error(self):\n820:         with patch(\n821:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n822:         ) as mock_dp_cls:\n823:             mock_dp_instance = MagicMock()\n824:             mock_dp_instance.bootstrap_session_id.side_effect = ValueError(\n825:                 \"Missing required response header: x-agentcube-session-id\"\n826:             )\n827:             mock_dp_cls.return_value = mock_dp_instance\n828: \n829:             with pytest.raises(ValueError) as exc_info:\n830:                 AgentRuntimeClient(\n831:                     agent_name=\"test-agent\",\n832:                     router_url=\"https://router.test.com\",\n833:                 )\n834: \n835:             assert \"Missing required response header: x-agentcube-session-id\" in str(\n836:                 exc_info.value\n837:             )\n\n(End of file - total 837 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentRuntimeDataPlaneClient and AgentRuntimeClient.\"\"\"\n\nimport os\nfrom unittest.mock import MagicMock, patch, PropertyMock\n\nimport pytest\nimport requests\nfrom requests.adapters import HTTPAdapter\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n\n\n# ---------------------------------------------------------------------------\n# T-1: AgentRuntimeDataPlaneClient — Base URL and HTTP session\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneClientBaseUrl:\n    def test_base_url_is_correctly_constructed(self):","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_agent_runtime.py","time":{"start":1775893798782,"end":1775893798791}}}}
{"type":"tool_use","timestamp":1775893800064,"sessionID":"ses_2848078d8ffegbQQf2BEdvBcp7","part":{"id":"prt_d7b84dff4001OprFSUVMYhpgam","messageID":"msg_d7b84c371001ytUzxY0NhgoNs6","sessionID":"ses_2848078d8ffegbQQf2BEdvBcp7","type":"tool","tool":"read","callID":"call_61ab752b38be4147a20d78ec","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterClient.\"\"\"\n2: \n3: import os\n4: from unittest.mock import MagicMock, patch\n5: \n6: import pytest\n7: \n8: from agentcube.code_interpreter import CodeInterpreterClient\n9: from agentcube.exceptions import CommandExecutionError\n10: \n11: \n12: # ---------------------------------------------------------------------------\n13: # T-1: CodeInterpreterClient — Initialization\n14: # ---------------------------------------------------------------------------\n15: \n16: \n17: class TestCodeInterpreterClientInit:\n18:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n19:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n20:     def test_creates_session_when_no_session_id_provided(\n21:         self, mock_dp_cls, mock_cp_cls\n22:     ):\n23:         mock_cp_instance = MagicMock()\n24:         mock_cp_instance.create_session.return_value = \"new-session-id\"\n25:         mock_cp_cls.return_value = mock_cp_instance\n26: \n27:         mock_dp_instance = MagicMock()\n28:         mock_dp_cls.return_value = mock_dp_instance\n29: \n30:         client = CodeInterpreterClient(\n31:             name=\"my-interpreter\",\n32:             namespace=\"default\",\n33:             router_url=\"http://router:8080\",\n34:         )\n35: \n36:         mock_cp_instance.create_session.assert_called_once_with(\n37:             name=\"my-interpreter\",\n38:             namespace=\"default\",\n39:             ttl=3600,\n40:         )\n41:         assert client.session_id == \"new-session-id\"\n42:         mock_dp_cls.assert_called_once()\n43:         client.stop()\n44: \n45:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n46:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n47:     def test_reuses_session_id_when_provided(self, mock_dp_cls, mock_cp_cls):\n48:         mock_cp_instance = MagicMock()\n49:         mock_cp_cls.return_value = mock_cp_instance\n50: \n51:         mock_dp_instance = MagicMock()\n52:         mock_dp_cls.return_value = mock_dp_instance\n53: \n54:         client = CodeInterpreterClient(\n55:             session_id=\"existing-session\",\n56:             router_url=\"http://router:8080\",\n57:         )\n58: \n59:         mock_cp_instance.create_session.assert_not_called()\n60:         assert client.session_id == \"existing-session\"\n61:         client.stop()\n62: \n63:     def test_router_url_required_raises_value_error(self):\n64:         with patch.dict(os.environ, {}, clear=True):\n65:             os.environ.pop(\"ROUTER_URL\", None)\n66:             with pytest.raises(ValueError) as exc_info:\n67:                 CodeInterpreterClient(session_id=\"sess-1\")\n68:         assert \"router_url must be provided\" in str(exc_info.value)\n69: \n70:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n71:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n72:     def test_router_url_from_environment(self, mock_dp_cls, mock_cp_cls):\n73:         mock_cp_instance = MagicMock()\n74:         mock_cp_cls.return_value = mock_cp_instance\n75: \n76:         mock_dp_instance = MagicMock()\n77:         mock_dp_cls.return_value = mock_dp_instance\n78: \n79:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://env-router:8080\"}):\n80:             client = CodeInterpreterClient(session_id=\"sess-1\")\n81:             assert client.router_url == \"http://env-router:8080\"\n82:             client.stop()\n83: \n84:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n85:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n86:     def test_verbose_true_creates_debug_logger(self, mock_dp_cls, mock_cp_cls):\n87:         mock_cp_instance = MagicMock()\n88:         mock_cp_cls.return_value = mock_cp_instance\n89: \n90:         mock_dp_instance = MagicMock()\n91:         mock_dp_cls.return_value = mock_dp_instance\n92: \n93:         client = CodeInterpreterClient(\n94:             session_id=\"sess-1\",\n95:             router_url=\"http://router:8080\",\n96:             verbose=True,\n97:         )\n98: \n99:         assert client.logger.level == 10  # logging.DEBUG\n100:         client.stop()\n101: \n102:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n103:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n104:     def test_verbose_false_creates_info_logger(self, mock_dp_cls, mock_cp_cls):\n105:         mock_cp_instance = MagicMock()\n106:         mock_cp_cls.return_value = mock_cp_instance\n107: \n108:         mock_dp_instance = MagicMock()\n109:         mock_dp_cls.return_value = mock_dp_instance\n110: \n111:         client = CodeInterpreterClient(\n112:             session_id=\"sess-1\",\n113:             router_url=\"http://router:8080\",\n114:             verbose=False,\n115:         )\n116: \n117:         assert client.logger.level == 20  # logging.INFO\n118:         client.stop()\n119: \n120:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n121:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n122:     def test_control_plane_client_constructed_with_params(\n123:         self, mock_dp_cls, mock_cp_cls\n124:     ):\n125:         mock_cp_instance = MagicMock()\n126:         mock_cp_instance.create_session.return_value = \"sess-1\"\n127:         mock_cp_cls.return_value = mock_cp_instance\n128: \n129:         mock_dp_instance = MagicMock()\n130:         mock_dp_cls.return_value = mock_dp_instance\n131: \n132:         client = CodeInterpreterClient(\n133:             name=\"custom-name\",\n134:             namespace=\"custom-ns\",\n135:             ttl=7200,\n136:             workload_manager_url=\"http://wm:8080\",\n137:             router_url=\"http://router:8080\",\n138:             auth_token=\"my-token\",\n139:         )\n140: \n141:         mock_cp_cls.assert_called_once_with(\n142:             workload_manager_url=\"http://wm:8080\",\n143:             auth_token=\"my-token\",\n144:             timeout=120,\n145:             connect_timeout=5.0,\n146:         )\n147:         client.stop()\n148: \n149: \n150: # ---------------------------------------------------------------------------\n151: # T-2: CodeInterpreterClient — Data plane init failure cleanup\n152: # ---------------------------------------------------------------------------\n153: \n154: \n155: class TestDataPlaneInitFailure:\n156:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n157:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n158:     def test_data_plane_init_failure_deletes_session_and_reraises(\n159:         self, mock_dp_cls, mock_cp_cls\n160:     ):\n161:         mock_cp_instance = MagicMock()\n162:         mock_cp_instance.create_session.return_value = \"new-session\"\n163:         mock_cp_cls.return_value = mock_cp_instance\n164: \n165:         mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n166: \n167:         with pytest.raises(RuntimeError):\n168:             CodeInterpreterClient(\n169:                 name=\"my-interpreter\",\n170:                 router_url=\"http://router:8080\",\n171:             )\n172: \n173:         mock_cp_instance.delete_session.assert_called_once_with(\"new-session\")\n174: \n175:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n176:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n177:     def test_data_plane_init_failure_sets_session_id_to_none(\n178:         self, mock_dp_cls, mock_cp_cls\n179:     ):\n180:         mock_cp_instance = MagicMock()\n181:         mock_cp_instance.create_session.return_value = \"new-session\"\n182:         mock_cp_cls.return_value = mock_cp_instance\n183: \n184:         mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n185: \n186:         try:\n187:             CodeInterpreterClient(\n188:                 name=\"my-interpreter\",\n189:                 router_url=\"http://router:8080\",\n190:             )\n191:         except RuntimeError:\n192:             pass\n193: \n194:         mock_cp_instance.create_session.return_value = None\n195:         assert mock_cp_instance.delete_session.called\n196: \n197: \n198: # ---------------------------------------------------------------------------\n199: # T-3: CodeInterpreterClient — Context manager\n200: # ---------------------------------------------------------------------------\n201: \n202: \n203: class TestContextManager:\n204:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n205:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n206:     def test_enter_returns_self(self, mock_dp_cls, mock_cp_cls):\n207:         mock_cp_instance = MagicMock()\n208:         mock_cp_cls.return_value = mock_cp_instance\n209: \n210:         mock_dp_instance = MagicMock()\n211:         mock_dp_cls.return_value = mock_dp_instance\n212: \n213:         client = CodeInterpreterClient(\n214:             session_id=\"sess-1\",\n215:             router_url=\"http://router:8080\",\n216:         )\n217: \n218:         assert client.__enter__() is client\n219:         client.stop()\n220: \n221:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n222:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n223:     def test_exit_calls_stop(self, mock_dp_cls, mock_cp_cls):\n224:         mock_cp_instance = MagicMock()\n225:         mock_cp_cls.return_value = mock_cp_instance\n226: \n227:         mock_dp_instance = MagicMock()\n228:         mock_dp_cls.return_value = mock_dp_instance\n229: \n230:         client = CodeInterpreterClient(\n231:             session_id=\"sess-1\",\n232:             router_url=\"http://router:8080\",\n233:         )\n234:         client.stop = MagicMock()\n235: \n236:         client.__exit__(None, None, None)\n237: \n238:         client.stop.assert_called_once()\n239: \n240:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n241:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n242:     def test_context_manager_with_statement(self, mock_dp_cls, mock_cp_cls):\n243:         mock_cp_instance = MagicMock()\n244:         mock_cp_instance.create_session.return_value = \"sess-ctx\"\n245:         mock_cp_cls.return_value = mock_cp_instance\n246: \n247:         mock_dp_instance = MagicMock()\n248:         mock_dp_cls.return_value = mock_dp_instance\n249: \n250:         with CodeInterpreterClient(\n251:             session_id=\"sess-ctx\",\n252:             router_url=\"http://router:8080\",\n253:         ) as client:\n254:             assert client.session_id == \"sess-ctx\"\n255: \n256:         mock_dp_instance.close.assert_called_once()\n257:         mock_cp_instance.delete_session.assert_called_once_with(\"sess-ctx\")\n258:         mock_cp_instance.close.assert_called_once()\n259: \n260:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n261:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n262:     def test_context_manager_exception_flow(self, mock_dp_cls, mock_cp_cls):\n263:         mock_cp_instance = MagicMock()\n264:         mock_cp_cls.return_value = mock_cp_instance\n265: \n266:         mock_dp_instance = MagicMock()\n267:         mock_dp_cls.return_value = mock_dp_instance\n268: \n269:         with pytest.raises(RuntimeError):\n270:             with CodeInterpreterClient(\n271:                 session_id=\"sess-ctx\",\n272:                 router_url=\"http://router:8080\",\n273:             ):\n274:                 raise RuntimeError(\"boom\")\n275: \n276:         mock_dp_instance.close.assert_called_once()\n277:         mock_cp_instance.delete_session.assert_called_once()\n278: \n279: \n280: # ---------------------------------------------------------------------------\n281: # T-4: CodeInterpreterClient — stop\n282: # ---------------------------------------------------------------------------\n283: \n284: \n285: class TestStop:\n286:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n287:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n288:     def stop_closes_dp_client(self, mock_dp_cls, mock_cp_cls):\n289:         mock_cp_instance = MagicMock()\n290:         mock_cp_cls.return_value = mock_cp_instance\n291: \n292:         mock_dp_instance = MagicMock()\n293:         mock_dp_cls.return_value = mock_dp_instance\n294: \n295:         client = CodeInterpreterClient(\n296:             session_id=\"sess-1\",\n297:             router_url=\"http://router:8080\",\n298:         )\n299:         client.stop()\n300: \n301:         mock_dp_instance.close.assert_called_once()\n302: \n303:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n304:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n305:     def stop_deletes_session(self, mock_dp_cls, mock_cp_cls):\n306:         mock_cp_instance = MagicMock()\n307:         mock_cp_cls.return_value = mock_cp_instance\n308: \n309:         mock_dp_instance = MagicMock()\n310:         mock_dp_cls.return_value = mock_dp_instance\n311: \n312:         client = CodeInterpreterClient(\n313:             session_id=\"sess-1\",\n314:             router_url=\"http://router:8080\",\n315:         )\n316:         client.stop()\n317: \n318:         mock_cp_instance.delete_session.assert_called_once_with(\"sess-1\")\n319: \n320:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n321:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n322:     def stop_closes_cp_client(self, mock_dp_cls, mock_cp_cls):\n323:         mock_cp_instance = MagicMock()\n324:         mock_cp_cls.return_value = mock_cp_instance\n325: \n326:         mock_dp_instance = MagicMock()\n327:         mock_dp_cls.return_value = mock_dp_instance\n328: \n329:         client = CodeInterpreterClient(\n330:             session_id=\"sess-1\",\n331:             router_url=\"http://router:8080\",\n332:         )\n333:         client.stop()\n334: \n335:         mock_cp_instance.close.assert_called_once()\n336: \n337:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n338:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n339:     def test_stop_is_idempotent(self, mock_dp_cls, mock_cp_cls):\n340:         mock_cp_instance = MagicMock()\n341:         mock_cp_cls.return_value = mock_cp_instance\n342: \n343:         mock_dp_instance = MagicMock()\n344:         mock_dp_cls.return_value = mock_dp_instance\n345: \n346:         client = CodeInterpreterClient(\n347:             session_id=\"sess-1\",\n348:             router_url=\"http://router:8080\",\n349:         )\n350:         client.stop()\n351:         client.stop()\n352:         client.stop()\n353: \n354:         assert mock_dp_instance.close.call_count == 1\n355:         assert mock_cp_instance.delete_session.call_count == 1\n356:         assert mock_cp_instance.close.call_count == 1\n357: \n358: \n359: # ---------------------------------------------------------------------------\n360: # T-5: CodeInterpreterClient — execute_command\n361: # ---------------------------------------------------------------------------\n362: \n363: \n364: class TestExecuteCommand:\n365:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n366:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n367:     def test_execute_command_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n368:         mock_cp_instance = MagicMock()\n369:         mock_cp_cls.return_value = mock_cp_instance\n370: \n371:         mock_dp_instance = MagicMock()\n372:         mock_dp_instance.execute_command.return_value = \"output\"\n373:         mock_dp_cls.return_value = mock_dp_instance\n374: \n375:         client = CodeInterpreterClient(\n376:             session_id=\"sess-1\",\n377:             router_url=\"http://router:8080\",\n378:         )\n379:         result = client.execute_command(\"echo hello\")\n380: \n381:         assert result == \"output\"\n382:         mock_dp_instance.execute_command.assert_called_once()\n383:         client.stop()\n384: \n385:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n386:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n387:     def test_execute_command_string_converted_to_list(self, mock_dp_cls, mock_cp_cls):\n388:         mock_cp_instance = MagicMock()\n389:         mock_cp_cls.return_value = mock_cp_instance\n390: \n391:         mock_dp_instance = MagicMock()\n392:         mock_dp_instance.execute_command.return_value = \"output\"\n393:         mock_dp_cls.return_value = mock_dp_instance\n394: \n395:         client = CodeInterpreterClient(\n396:             session_id=\"sess-1\",\n397:             router_url=\"http://router:8080\",\n398:         )\n399:         client.execute_command(\"echo hello\")\n400: \n401:         call_args = mock_dp_instance.execute_command.call_args\n402:         assert call_args[0][0] == [\"echo hello\"]\n403:         client.stop()\n404: \n405:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n406:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n407:     def test_execute_command_with_custom_timeout(self, mock_dp_cls, mock_cp_cls):\n408:         mock_cp_instance = MagicMock()\n409:         mock_cp_cls.return_value = mock_cp_instance\n410: \n411:         mock_dp_instance = MagicMock()\n412:         mock_dp_instance.execute_command.return_value = \"output\"\n413:         mock_dp_cls.return_value = mock_dp_instance\n414: \n415:         client = CodeInterpreterClient(\n416:             session_id=\"sess-1\",\n417:             router_url=\"http://router:8080\",\n418:         )\n419:         client.execute_command(\"sleep 10\", timeout=10.0)\n420: \n421:         call_args = mock_dp_instance.execute_command.call_args\n422:         assert call_args[1][\"timeout\"] == 12.0\n423:         client.stop()\n424: \n425:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n426:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n427:     def test_execute_command_raises_on_nonzero_exit(self, mock_dp_cls, mock_cp_cls):\n428:         mock_cp_instance = MagicMock()\n429:         mock_cp_cls.return_value = mock_cp_instance\n430: \n431:         mock_dp_instance = MagicMock()\n432:         mock_dp_instance.execute_command.side_effect = CommandExecutionError(\n433:             exit_code=1, stderr=\"error\", command=[\"ls\"]\n434:         )\n435:         mock_dp_cls.return_value = mock_dp_instance\n436: \n437:         client = CodeInterpreterClient(\n438:             session_id=\"sess-1\",\n439:             router_url=\"http://router:8080\",\n440:         )\n441: \n442:         with pytest.raises(CommandExecutionError) as exc_info:\n443:             client.execute_command(\"ls\")\n444: \n445:         assert exc_info.value.exit_code == 1\n446:         client.stop()\n447: \n448: \n449: # ---------------------------------------------------------------------------\n450: # T-6: CodeInterpreterClient — run_code\n451: # ---------------------------------------------------------------------------\n452: \n453: \n454: class TestRunCode:\n455:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n456:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n457:     def test_run_code_python_writes_file_and_executes(self, mock_dp_cls, mock_cp_cls):\n458:         mock_cp_instance = MagicMock()\n459:         mock_cp_cls.return_value = mock_cp_instance\n460: \n461:         mock_dp_instance = MagicMock()\n462:         mock_dp_instance.execute_command.return_value = \"hello\\n\"\n463:         mock_dp_cls.return_value = mock_dp_instance\n464: \n465:         client = CodeInterpreterClient(\n466:             session_id=\"sess-1\",\n467:             router_url=\"http://router:8080\",\n468:         )\n469:         result = client.run_code(\"python\", \"print('hello')\")\n470: \n471:         assert result == \"hello\\n\"\n472:         mock_dp_instance.write_file.assert_called_once()\n473:         mock_dp_instance.execute_command.assert_called_once()\n474:         client.stop()\n475: \n476:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n477:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n478:     def test_run_code_unsupported_language_raises(self, mock_dp_cls, mock_cp_cls):\n479:         mock_cp_instance = MagicMock()\n480:         mock_cp_cls.return_value = mock_cp_instance\n481: \n482:         mock_dp_instance = MagicMock()\n483:         mock_dp_cls.return_value = mock_dp_instance\n484: \n485:         client = CodeInterpreterClient(\n486:             session_id=\"sess-1\",\n487:             router_url=\"http://router:8080\",\n488:         )\n489: \n490:         with pytest.raises(ValueError) as exc_info:\n491:             client.run_code(\"ruby\", \"puts 'hi'\")\n492:         assert \"Unsupported language\" in str(exc_info.value)\n493:         client.stop()\n494: \n495: \n496: # ---------------------------------------------------------------------------\n497: # T-7: CodeInterpreterClient — File operations\n498: # ---------------------------------------------------------------------------\n499: \n500: \n501: class TestFileOperations:\n502:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n503:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n504:     def test_write_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n505:         mock_cp_instance = MagicMock()\n506:         mock_cp_cls.return_value = mock_cp_instance\n507: \n508:         mock_dp_instance = MagicMock()\n509:         mock_dp_cls.return_value = mock_dp_instance\n510: \n511:         client = CodeInterpreterClient(\n512:             session_id=\"sess-1\",\n513:             router_url=\"http://router:8080\",\n514:         )\n515:         client.write_file(\"content\", \"/tmp/test.txt\")\n516: \n517:         mock_dp_instance.write_file.assert_called_once_with(\"content\", \"/tmp/test.txt\")\n518:         client.stop()\n519: \n520:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n521:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n522:     def test_upload_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n523:         mock_cp_instance = MagicMock()\n524:         mock_cp_cls.return_value = mock_cp_instance\n525: \n526:         mock_dp_instance = MagicMock()\n527:         mock_dp_cls.return_value = mock_dp_instance\n528: \n529:         client = CodeInterpreterClient(\n530:             session_id=\"sess-1\",\n531:             router_url=\"http://router:8080\",\n532:         )\n533:         client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n534: \n535:         mock_dp_instance.upload_file.assert_called_once_with(\n536:             \"/local/file.txt\", \"/remote/file.txt\"\n537:         )\n538:         client.stop()\n539: \n540:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n541:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n542:     def test_download_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n543:         mock_cp_instance = MagicMock()\n544:         mock_cp_cls.return_value = mock_cp_instance\n545: \n546:         mock_dp_instance = MagicMock()\n547:         mock_dp_cls.return_value = mock_dp_instance\n548: \n549:         client = CodeInterpreterClient(\n550:             session_id=\"sess-1\",\n551:             router_url=\"http://router:8080\",\n552:         )\n553:         client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n554: \n555:         mock_dp_instance.download_file.assert_called_once_with(\n556:             \"/remote/file.txt\", \"/local/file.txt\"\n557:         )\n558:         client.stop()\n559: \n560:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n561:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n562:     def test_list_files_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n563:         mock_cp_instance = MagicMock()\n564:         mock_cp_cls.return_value = mock_cp_instance\n565: \n566:         mock_dp_instance = MagicMock()\n567:         mock_dp_instance.list_files.return_value = {\"files\": [\"a.txt\"]}\n568:         mock_dp_cls.return_value = mock_dp_instance\n569: \n570:         client = CodeInterpreterClient(\n571:             session_id=\"sess-1\",\n572:             router_url=\"http://router:8080\",\n573:         )\n574:         result = client.list_files(\"/tmp\")\n575: \n576:         assert result == {\"files\": [\"a.txt\"]}\n577:         mock_dp_instance.list_files.assert_called_once_with(\"/tmp\")\n578:         client.stop()\n579: \n580: \n581: # ---------------------------------------------------------------------------\n582: # T-8: CodeInterpreterClient — Integration tests\n583: # ---------------------------------------------------------------------------\n584: \n585: \n586: class TestCodeInterpreterIntegration:\n587:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n588:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n589:     def test_full_lifecycle_with_context_manager(self, mock_dp_cls, mock_cp_cls