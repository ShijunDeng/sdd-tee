-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py\n@@ -301,9 +301,9 @@\n     mock_dp_instance.close.assert_called_once()\n \n @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n-def stop_deletes_session(self, mock_dp_cls, mock_cp_cls):\n+def test_stop_deletes_session(self, mock_dp_cls, mock_cp_cls):\n     mock_cp_instance = MagicMock()\n     mock_cp_cls.return_value = mock_cp_instance\n \n     mock_dp_instance = MagicMock()\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py","before":"\"\"\"Tests for CodeInterpreterClient.\"\"\"\n\nimport os\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\n# ---------------------------------------------------------------------------\n# T-1: CodeInterpreterClient — Initialization\n# ---------------------------------------------------------------------------\n\n\nclass TestCodeInterpreterClientInit:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_creates_session_when_no_session_id_provided(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"new-session-id\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            name=\"my-interpreter\",\n            namespace=\"default\",\n            router_url=\"http://router:8080\",\n        )\n\n        mock_cp_instance.create_session.assert_called_once_with(\n            name=\"my-interpreter\",\n            namespace=\"default\",\n            ttl=3600,\n        )\n        assert client.session_id == \"new-session-id\"\n        mock_dp_cls.assert_called_once()\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_reuses_session_id_when_provided(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"existing-session\",\n            router_url=\"http://router:8080\",\n        )\n\n        mock_cp_instance.create_session.assert_not_called()\n        assert client.session_id == \"existing-session\"\n        client.stop()\n\n    def test_router_url_required_raises_value_error(self):\n        with patch.dict(os.environ, {}, clear=True):\n            os.environ.pop(\"ROUTER_URL\", None)\n            with pytest.raises(ValueError) as exc_info:\n                CodeInterpreterClient(session_id=\"sess-1\")\n        assert \"router_url must be provided\" in str(exc_info.value)\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_router_url_from_environment(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with patch.dict(os.environ, {\"ROUTER_URL\": \"http://env-router:8080\"}):\n            client = CodeInterpreterClient(session_id=\"sess-1\")\n            assert client.router_url == \"http://env-router:8080\"\n            client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_verbose_true_creates_debug_logger(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            verbose=True,\n        )\n\n        assert client.logger.level == 10  # logging.DEBUG\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_verbose_false_creates_info_logger(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            verbose=False,\n        )\n\n        assert client.logger.level == 20  # logging.INFO\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_control_plane_client_constructed_with_params(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"sess-1\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            name=\"custom-name\",\n            namespace=\"custom-ns\",\n            ttl=7200,\n            workload_manager_url=\"http://wm:8080\",\n            router_url=\"http://router:8080\",\n            auth_token=\"my-token\",\n        )\n\n        mock_cp_cls.assert_called_once_with(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"my-token\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        client.stop()\n\n\n# ---------------------------------------------------------------------------\n# T-2: CodeInterpreterClient — Data plane init failure cleanup\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneInitFailure:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_data_plane_init_failure_deletes_session_and_reraises(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"new-session\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n\n        with pytest.raises(RuntimeError):\n            CodeInterpreterClient(\n                name=\"my-interpreter\",\n                router_url=\"http://router:8080\",\n            )\n\n        mock_cp_instance.delete_session.assert_called_once_with(\"new-session\")\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_data_plane_init_failure_sets_session_id_to_none(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"new-session\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n\n        try:\n            CodeInterpreterClient(\n                name=\"my-interpreter\",\n                router_url=\"http://router:8080\",\n            )\n        except RuntimeError:\n            pass\n\n        mock_cp_instance.create_session.return_value = None\n        assert mock_cp_instance.delete_session.called\n\n\n# ---------------------------------------------------------------------------\n# T-3: CodeInterpreterClient — Context manager\n# ---------------------------------------------------------------------------\n\n\nclass TestContextManager:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_enter_returns_self(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n\n        assert client.__enter__() is client\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_exit_calls_stop(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop = MagicMock()\n\n        client.__exit__(None, None, None)\n\n        client.stop.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_context_manager_with_statement(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"sess-ctx\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with CodeInterpreterClient(\n            session_id=\"sess-ctx\",\n            router_url=\"http://router:8080\",\n        ) as client:\n            assert client.session_id == \"sess-ctx\"\n\n        mock_dp_instance.close.assert_called_once()\n        mock_cp_instance.delete_session.assert_called_once_with(\"sess-ctx\")\n        mock_cp_instance.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_context_manager_exception_flow(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with pytest.raises(RuntimeError):\n            with CodeInterpreterClient(\n                session_id=\"sess-ctx\",\n                router_url=\"http://router:8080\",\n            ):\n                raise RuntimeError(\"boom\")\n\n        mock_dp_instance.close.assert_called_once()\n        mock_cp_instance.delete_session.assert_called_once()\n\n\n# ---------------------------------------------------------------------------\n# T-4: CodeInterpreterClient — stop\n# ---------------------------------------------------------------------------\n\n\nclass TestStop:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_stop_closes_dp_client(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop()\n\n        mock_dp_instance.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def stop_deletes_session(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop()\n\n        mock_cp_instance.delete_session.assert_called_once_with(\"sess-1\")\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def stop_closes_cp_client(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop()\n\n        mock_cp_instance.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_stop_is_idempotent(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop()\n        client.stop()\n        client.stop()\n\n        assert mock_dp_instance.close.call_count == 1\n        assert mock_cp_instance.delete_session.call_count == 1\n        assert mock_cp_instance.close.call_count == 1\n\n\n# ---------------------------------------------------------------------------\n# T-5: CodeInterpreterClient — execute_command\n# ---------------------------------------------------------------------------\n\n\nclass TestExecuteCommand:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_execute_command_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"output\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        result = client.execute_command(\"echo hello\")\n\n        assert result == \"output\"\n        mock_dp_instance.execute_command.assert_called_once()\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_execute_command_string_converted_to_list(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"output\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.execute_command(\"echo hello\")\n\n        call_args = mock_dp_instance.execute_command.call_args\n        assert call_args[0][0] == [\"echo hello\"]\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_execute_command_with_custom_timeout(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"output\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.execute_command(\"sleep 10\", timeout=10.0)\n\n        call_args = mock_dp_instance.execute_command.call_args\n        assert call_args[1][\"timeout\"] == 12.0\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_execute_command_raises_on_nonzero_exit(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.side_effect = CommandExecutionError(\n            exit_code=1, stderr=\"error\", command=[\"ls\"]\n        )\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n\n        with pytest.raises(CommandExecutionError) as exc_info:\n            client.execute_command(\"ls\")\n\n        assert exc_info.value.exit_code == 1\n        client.stop()\n\n\n# ---------------------------------------------------------------------------\n# T-6: CodeInterpreterClient — run_code\n# ---------------------------------------------------------------------------\n\n\nclass TestRunCode:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_run_code_python_writes_file_and_executes(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"hello\\n\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        result = client.run_code(\"python\", \"print('hello')\")\n\n        assert result == \"hello\\n\"\n        mock_dp_instance.write_file.assert_called_once()\n        mock_dp_instance.execute_command.assert_called_once()\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_run_code_unsupported_language_raises(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n\n        with pytest.raises(ValueError) as exc_info:\n            client.run_code(\"ruby\", \"puts 'hi'\")\n        assert \"Unsupported language\" in str(exc_info.value)\n        client.stop()\n\n\n# ---------------------------------------------------------------------------\n# T-7: CodeInterpreterClient — File operations\n# ---------------------------------------------------------------------------\n\n\nclass TestFileOperations:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_write_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.write_file(\"content\", \"/tmp/test.txt\")\n\n        mock_dp_instance.write_file.assert_called_once_with(\"content\", \"/tmp/test.txt\")\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_upload_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n\n        mock_dp_instance.upload_file.assert_called_once_with(\n            \"/local/file.txt\", \"/remote/file.txt\"\n        )\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_download_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n\n        mock_dp_instance.download_file.assert_called_once_with(\n            \"/remote/file.txt\", \"/local/file.txt\"\n        )\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_list_files_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.list_files.return_value = {\"files\": [\"a.txt\"]}\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        result = client.list_files(\"/tmp\")\n\n        assert result == {\"files\": [\"a.txt\"]}\n        mock_dp_instance.list_files.assert_called_once_with(\"/tmp\")\n        client.stop()\n\n\n# ---------------------------------------------------------------------------\n# T-8: CodeInterpreterClient — Integration tests\n# ---------------------------------------------------------------------------\n\n\nclass TestCodeInterpreterIntegration:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_full_lifecycle_with_context_manager(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"lifecycle-session\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"hello\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"test-ns\",\n            router_url=\"http://router.test.com\",\n        ) as client:\n            assert client.session_id == \"lifecycle-session\"\n            result = client.execute_command(\"echo hello\")\n            assert result == \"hello\"\n\n        mock_cp_instance.create_session.assert_called_once()\n        mock_dp_instance.execute_command.assert_called_once()\n        mock_dp_instance.close.assert_called_once()\n        mock_cp_instance.delete_session.assert_called_once_with(\"lifecycle-session\")\n        mock_cp_instance.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_pre_provisioned_session_skips_control_plane(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"result\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with CodeInterpreterClient(\n            session_id=\"pre-provisioned\",\n            router_url=\"http://router.test.com\",\n        ) as client:\n            assert client.session_id == \"pre-provisioned\"\n            result = client.execute_command(\"ls\")\n            assert result == \"result\"\n\n        mock_cp_instance.create_session.assert_not_called()\n        mock_dp_instance.execute_command.assert_called_once()\n        mock_dp_instance.close.assert_called_once()\n","after":"\"\"\"Tests for CodeInterpreterClient.\"\"\"\n\nimport os\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\n# ---------------------------------------------------------------------------\n# T-1: CodeInterpreterClient — Initialization\n# ---------------------------------------------------------------------------\n\n\nclass TestCodeInterpreterClientInit:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_creates_session_when_no_session_id_provided(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"new-session-id\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            name=\"my-interpreter\",\n            namespace=\"default\",\n            router_url=\"http://router:8080\",\n        )\n\n        mock_cp_instance.create_session.assert_called_once_with(\n            name=\"my-interpreter\",\n            namespace=\"default\",\n            ttl=3600,\n        )\n        assert client.session_id == \"new-session-id\"\n        mock_dp_cls.assert_called_once()\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_reuses_session_id_when_provided(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"existing-session\",\n            router_url=\"http://router:8080\",\n        )\n\n        mock_cp_instance.create_session.assert_not_called()\n        assert client.session_id == \"existing-session\"\n        client.stop()\n\n    def test_router_url_required_raises_value_error(self):\n        with patch.dict(os.environ, {}, clear=True):\n            os.environ.pop(\"ROUTER_URL\", None)\n            with pytest.raises(ValueError) as exc_info:\n                CodeInterpreterClient(session_id=\"sess-1\")\n        assert \"router_url must be provided\" in str(exc_info.value)\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_router_url_from_environment(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with patch.dict(os.environ, {\"ROUTER_URL\": \"http://env-router:8080\"}):\n            client = CodeInterpreterClient(session_id=\"sess-1\")\n            assert client.router_url == \"http://env-router:8080\"\n            client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_verbose_true_creates_debug_logger(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            verbose=True,\n        )\n\n        assert client.logger.level == 10  # logging.DEBUG\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_verbose_false_creates_info_logger(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            verbose=False,\n        )\n\n        assert client.logger.level == 20  # logging.INFO\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_control_plane_client_constructed_with_params(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"sess-1\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            name=\"custom-name\",\n            namespace=\"custom-ns\",\n            ttl=7200,\n            workload_manager_url=\"http://wm:8080\",\n            router_url=\"http://router:8080\",\n            auth_token=\"my-token\",\n        )\n\n        mock_cp_cls.assert_called_once_with(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"my-token\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        client.stop()\n\n\n# ---------------------------------------------------------------------------\n# T-2: CodeInterpreterClient — Data plane init failure cleanup\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneInitFailure:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_data_plane_init_failure_deletes_session_and_reraises(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"new-session\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n\n        with pytest.raises(RuntimeError):\n            CodeInterpreterClient(\n                name=\"my-interpreter\",\n                router_url=\"http://router:8080\",\n            )\n\n        mock_cp_instance.delete_session.assert_called_once_with(\"new-session\")\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_data_plane_init_failure_sets_session_id_to_none(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"new-session\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n\n        try:\n            CodeInterpreterClient(\n                name=\"my-interpreter\",\n                router_url=\"http://router:8080\",\n            )\n        except RuntimeError:\n            pass\n\n        mock_cp_instance.create_session.return_value = None\n        assert mock_cp_instance.delete_session.called\n\n\n# ---------------------------------------------------------------------------\n# T-3: CodeInterpreterClient — Context manager\n# ---------------------------------------------------------------------------\n\n\nclass TestContextManager:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_enter_returns_self(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n\n        assert client.__enter__() is client\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_exit_calls_stop(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop = MagicMock()\n\n        client.__exit__(None, None, None)\n\n        client.stop.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_context_manager_with_statement(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"sess-ctx\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with CodeInterpreterClient(\n            session_id=\"sess-ctx\",\n            router_url=\"http://router:8080\",\n        ) as client:\n            assert client.session_id == \"sess-ctx\"\n\n        mock_dp_instance.close.assert_called_once()\n        mock_cp_instance.delete_session.assert_called_once_with(\"sess-ctx\")\n        mock_cp_instance.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_context_manager_exception_flow(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with pytest.raises(RuntimeError):\n            with CodeInterpreterClient(\n                session_id=\"sess-ctx\",\n                router_url=\"http://router:8080\",\n            ):\n                raise RuntimeError(\"boom\")\n\n        mock_dp_instance.close.assert_called_once()\n        mock_cp_instance.delete_session.assert_called_once()\n\n\n# ---------------------------------------------------------------------------\n# T-4: CodeInterpreterClient — stop\n# ---------------------------------------------------------------------------\n\n\nclass TestStop:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_stop_closes_dp_client(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop()\n\n        mock_dp_instance.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_stop_deletes_session(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop()\n\n        mock_cp_instance.delete_session.assert_called_once_with(\"sess-1\")\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def stop_closes_cp_client(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop()\n\n        mock_cp_instance.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_stop_is_idempotent(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.stop()\n        client.stop()\n        client.stop()\n\n        assert mock_dp_instance.close.call_count == 1\n        assert mock_cp_instance.delete_session.call_count == 1\n        assert mock_cp_instance.close.call_count == 1\n\n\n# ---------------------------------------------------------------------------\n# T-5: CodeInterpreterClient — execute_command\n# ---------------------------------------------------------------------------\n\n\nclass TestExecuteCommand:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_execute_command_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"output\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        result = client.execute_command(\"echo hello\")\n\n        assert result == \"output\"\n        mock_dp_instance.execute_command.assert_called_once()\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_execute_command_string_converted_to_list(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"output\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.execute_command(\"echo hello\")\n\n        call_args = mock_dp_instance.execute_command.call_args\n        assert call_args[0][0] == [\"echo hello\"]\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_execute_command_with_custom_timeout(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"output\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.execute_command(\"sleep 10\", timeout=10.0)\n\n        call_args = mock_dp_instance.execute_command.call_args\n        assert call_args[1][\"timeout\"] == 12.0\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_execute_command_raises_on_nonzero_exit(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.side_effect = CommandExecutionError(\n            exit_code=1, stderr=\"error\", command=[\"ls\"]\n        )\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n\n        with pytest.raises(CommandExecutionError) as exc_info:\n            client.execute_command(\"ls\")\n\n        assert exc_info.value.exit_code == 1\n        client.stop()\n\n\n# ---------------------------------------------------------------------------\n# T-6: CodeInterpreterClient — run_code\n# ---------------------------------------------------------------------------\n\n\nclass TestRunCode:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_run_code_python_writes_file_and_executes(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"hello\\n\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        result = client.run_code(\"python\", \"print('hello')\")\n\n        assert result == \"hello\\n\"\n        mock_dp_instance.write_file.assert_called_once()\n        mock_dp_instance.execute_command.assert_called_once()\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_run_code_unsupported_language_raises(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n\n        with pytest.raises(ValueError) as exc_info:\n            client.run_code(\"ruby\", \"puts 'hi'\")\n        assert \"Unsupported language\" in str(exc_info.value)\n        client.stop()\n\n\n# ---------------------------------------------------------------------------\n# T-7: CodeInterpreterClient — File operations\n# ---------------------------------------------------------------------------\n\n\nclass TestFileOperations:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_write_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.write_file(\"content\", \"/tmp/test.txt\")\n\n        mock_dp_instance.write_file.assert_called_once_with(\"content\", \"/tmp/test.txt\")\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_upload_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n\n        mock_dp_instance.upload_file.assert_called_once_with(\n            \"/local/file.txt\", \"/remote/file.txt\"\n        )\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_download_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n\n        mock_dp_instance.download_file.assert_called_once_with(\n            \"/remote/file.txt\", \"/local/file.txt\"\n        )\n        client.stop()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_list_files_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.list_files.return_value = {\"files\": [\"a.txt\"]}\n        mock_dp_cls.return_value = mock_dp_instance\n\n        client = CodeInterpreterClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n        )\n        result = client.list_files(\"/tmp\")\n\n        assert result == {\"files\": [\"a.txt\"]}\n        mock_dp_instance.list_files.assert_called_once_with(\"/tmp\")\n        client.stop()\n\n\n# ---------------------------------------------------------------------------\n# T-8: CodeInterpreterClient — Integration tests\n# ---------------------------------------------------------------------------\n\n\nclass TestCodeInterpreterIntegration:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_full_lifecycle_with_context_manager(self, mock_dp_cls, mock_cp_cls):\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"lifecycle-session\"\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"hello\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"test-ns\",\n            router_url=\"http://router.test.com\",\n        ) as client:\n            assert client.session_id == \"lifecycle-session\"\n            result = client.execute_command(\"echo hello\")\n            assert result == \"hello\"\n\n        mock_cp_instance.create_session.assert_called_once()\n        mock_dp_instance.execute_command.assert_called_once()\n        mock_dp_instance.close.assert_called_once()\n        mock_cp_instance.delete_session.assert_called_once_with(\"lifecycle-session\")\n        mock_cp_instance.close.assert_called_once()\n\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_pre_provisioned_session_skips_control_plane(\n        self, mock_dp_cls, mock_cp_cls\n    ):\n        mock_cp_instance = MagicMock()\n        mock_cp_cls.return_value = mock_cp_instance\n\n        mock_dp_instance = MagicMock()\n        mock_dp_instance.execute_command.return_value = \"result\"\n        mock_dp_cls.return_value = mock_dp_instance\n\n        with CodeInterpreterClient(\n            session_id=\"pre-provisioned\",\n            router_url=\"http://router.test.com\",\n        ) as client:\n            assert client.session_id == \"pre-provisioned\"\n            result = client.execute_command(\"ls\")\n            assert result == \"result\"\n\n        mock_cp_instance.create_session.assert_not_called()\n        mock_dp_instance.execute_command.assert_called_once()\n        mock_dp_instance.close.assert_called_once()\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py","time":{"start":1775893906186,"end":1775893906777}}}}
