6}},"message":"Cannot access attribute \"_pool_maxsize\" for class \"BaseAdapter\"\n  Attribute \"_pool_maxsize\" is unknown","severity":1,"code":"reportAttributeAccessIssue","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportAttributeAccessIssue"}}]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_control_plane.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_control_plane.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_control_plane.py\n@@ -351,9 +351,9 @@\n )\n session_id = id(client.session)\n \n mock_resp = MagicMock(spec=requests.Response)\n-mock_resp.json.return_value = {\"data\": {\"sessionId\": \"abc-123\"}}\n+mock_resp.json.return_value = {\"sessionId\": \"abc-123\"}\n mock_resp.raise_for_status = MagicMock()\n client.session.post = MagicMock(return_value=mock_resp)\n \n client.create_session()\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_control_plane.py","before":"\"\"\"Tests for ControlPlaneClient.\"\"\"\n\nimport os\nimport tempfile\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\nimport requests\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\n\n\n# ---------------------------------------------------------------------------\n# T-1: ControlPlaneClient — Constructor and URL resolution\n# ---------------------------------------------------------------------------\n\n\nclass TestControlPlaneClientInit:\n    def test_base_url_from_argument(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        assert client.base_url == \"http://wm:8080\"\n        client.close()\n\n    def test_base_url_from_environment(self):\n        with patch.dict(os.environ, {\"WORKLOAD_MANAGER_URL\": \"http://wm-env:9090\"}):\n            client = ControlPlaneClient()\n            assert client.base_url == \"http://wm-env:9090\"\n            client.close()\n\n    def test_raises_when_no_url_provided(self):\n        with patch.dict(os.environ, {}, clear=True):\n            os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n            with pytest.raises(ValueError) as exc_info:\n                ControlPlaneClient()\n        assert \"workload_manager_url must be provided\" in str(exc_info.value)\n\n    def test_auth_token_from_argument(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"my-token\",\n        )\n        assert client.session.headers[\"Authorization\"] == \"Bearer my-token\"\n        client.close()\n\n    def test_auth_token_from_sa_file(self):\n        with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".token\") as f:\n            f.write(\"sa-token\\n\")\n            f.flush()\n            token_path = f.name\n        try:\n            with patch(\n                \"agentcube.clients.control_plane.SA_TOKEN_PATH\", token_path\n            ):\n                client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n                assert client.session.headers[\"Authorization\"] == \"Bearer sa-token\"\n                client.close()\n        finally:\n            os.unlink(token_path)\n\n    def test_auth_token_file_not_found_skips_header(self):\n        with patch(\"agentcube.clients.control_plane.read_token_from_file\", return_value=\"\"):\n            client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n            assert \"Authorization\" not in client.session.headers\n            client.close()\n\n    def test_empty_token_skips_authorization_header(self):\n        with patch(\"agentcube.clients.control_plane.read_token_from_file\", return_value=\"\"):\n            client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n            assert \"Authorization\" not in client.session.headers\n            client.close()\n\n    def test_default_content_type_header(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        assert client.session.headers[\"Content-Type\"] == \"application/json\"\n        client.close()\n\n    def test_default_timeout_parameters(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        client.close()\n\n    def test_custom_timeout_parameters(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n        assert client.timeout == 60\n        assert client.connect_timeout == 3.0\n        client.close()\n\n    def test_custom_pool_settings(self):\n        from requests.adapters import HTTPAdapter\n\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            pool_connections=20,\n            pool_maxsize=30,\n        )\n        adapter = client.session.adapters[\"http://\"]\n        assert isinstance(adapter, HTTPAdapter)\n        assert adapter._pool_connections == 20\n        assert adapter._pool_maxsize == 30\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-2: ControlPlaneClient — create_session\n# ---------------------------------------------------------------------------\n\n\nclass TestCreateSession:\n    def test_successful_session_creation(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"abc-123\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        result = client.create_session(\n            name=\"test\",\n            namespace=\"ns\",\n            ttl=7200,\n            metadata={\"key\": \"val\"},\n        )\n\n        client.session.post.assert_called_once()\n        call_args = client.session.post.call_args\n        assert call_args[0][0] == \"http://wm:8080/v1/code-interpreter\"\n        assert call_args[1][\"json\"] == {\n            \"name\": \"test\",\n            \"namespace\": \"ns\",\n            \"ttl\": 7200,\n            \"metadata\": {\"key\": \"val\"},\n        }\n        assert call_args[1][\"timeout\"] == (5.0, 120)\n        assert result == \"abc-123\"\n        client.close()\n\n    def test_response_contains_session_id(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"abc-123\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        result = client.create_session()\n        assert result == \"abc-123\"\n        client.close()\n\n    def test_response_missing_session_id_raises_value_error(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"data\": {}}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(ValueError) as exc_info:\n            client.create_session()\n        assert \"sessionId\" in str(exc_info.value)\n        client.close()\n\n    def test_request_timeout_tuple(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"sess-1\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.create_session()\n\n        _, kwargs = client.session.post.call_args\n        assert kwargs[\"timeout\"] == (5.0, 120)\n        client.close()\n\n    def test_create_session_with_default_params(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"sess-1\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.create_session()\n\n        call_args = client.session.post.call_args\n        assert call_args[1][\"json\"] == {\n            \"name\": \"my-interpreter\",\n            \"namespace\": \"default\",\n            \"ttl\": 3600,\n            \"metadata\": None,\n        }\n        client.close()\n\n    def test_create_session_raises_http_error_on_failure(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock(\n            side_effect=requests.HTTPError(\"500 Server Error\")\n        )\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(requests.HTTPError):\n            client.create_session()\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-3: ControlPlaneClient — delete_session\n# ---------------------------------------------------------------------------\n\n\nclass TestDeleteSession:\n    def test_successful_deletion_returns_true(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.status_code = 200\n        mock_resp.raise_for_status = MagicMock()\n        client.session.delete = MagicMock(return_value=mock_resp)\n\n        result = client.delete_session(\"sess-1\")\n\n        assert result is True\n        client.session.delete.assert_called_once_with(\n            \"http://wm:8080/v1/code-interpreter/sessions/sess-1\",\n            timeout=(5.0, 120),\n        )\n        client.close()\n\n    def test_404_treated_as_success(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.status_code = 404\n        client.session.delete = MagicMock(return_value=mock_resp)\n\n        result = client.delete_session(\"nonexistent\")\n\n        assert result is True\n        client.close()\n\n    def test_other_error_returns_false(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.delete = MagicMock(\n            side_effect=requests.HTTPError(\"500 Server Error\")\n        )\n\n        result = client.delete_session(\"sess-1\")\n\n        assert result is False\n        client.close()\n\n    def test_connection_error_returns_false(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.delete = MagicMock(\n            side_effect=requests.ConnectionError(\"Connection refused\")\n        )\n\n        result = client.delete_session(\"sess-1\")\n\n        assert result is False\n        client.close()\n\n    def test_timeout_error_returns_false(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.delete = MagicMock(\n            side_effect=requests.Timeout(\"Request timed out\")\n        )\n\n        result = client.delete_session(\"sess-1\")\n\n        assert result is False\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-4: ControlPlaneClient — close\n# ---------------------------------------------------------------------------\n\n\nclass TestControlPlaneClose:\n    def test_close_releases_session(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n\n        client.session.close.assert_called_once()\n\n    def test_close_is_idempotent(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n        client.close()\n        client.close()\n\n        assert client.session.close.call_count == 3\n\n\n# ---------------------------------------------------------------------------\n# T-5: ControlPlaneClient — Session reuse\n# ---------------------------------------------------------------------------\n\n\nclass TestSessionReuse:\n    def test_same_session_for_multiple_requests(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        session_id = id(client.session)\n\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"data\": {\"sessionId\": \"abc-123\"}}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.create_session()\n        assert id(client.session) == session_id\n\n        mock_resp_delete = MagicMock(spec=requests.Response)\n        mock_resp_delete.status_code = 200\n        mock_resp_delete.raise_for_status = MagicMock()\n        client.session.delete = MagicMock(return_value=mock_resp_delete)\n\n        client.delete_session(\"abc-123\")\n        assert id(client.session) == session_id\n\n        client.close()\n","after":"\"\"\"Tests for ControlPlaneClient.\"\"\"\n\nimport os\nimport tempfile\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\nimport requests\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\n\n\n# ---------------------------------------------------------------------------\n# T-1: ControlPlaneClient — Constructor and URL resolution\n# ---------------------------------------------------------------------------\n\n\nclass TestControlPlaneClientInit:\n    def test_base_url_from_argument(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        assert client.base_url == \"http://wm:8080\"\n        client.close()\n\n    def test_base_url_from_environment(self):\n        with patch.dict(os.environ, {\"WORKLOAD_MANAGER_URL\": \"http://wm-env:9090\"}):\n            client = ControlPlaneClient()\n            assert client.base_url == \"http://wm-env:9090\"\n            client.close()\n\n    def test_raises_when_no_url_provided(self):\n        with patch.dict(os.environ, {}, clear=True):\n            os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n            with pytest.raises(ValueError) as exc_info:\n                ControlPlaneClient()\n        assert \"workload_manager_url must be provided\" in str(exc_info.value)\n\n    def test_auth_token_from_argument(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"my-token\",\n        )\n        assert client.session.headers[\"Authorization\"] == \"Bearer my-token\"\n        client.close()\n\n    def test_auth_token_from_sa_file(self):\n        with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".token\") as f:\n            f.write(\"sa-token\\n\")\n            f.flush()\n            token_path = f.name\n        try:\n            with patch(\n                \"agentcube.clients.control_plane.SA_TOKEN_PATH\", token_path\n            ):\n                client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n                assert client.session.headers[\"Authorization\"] == \"Bearer sa-token\"\n                client.close()\n        finally:\n            os.unlink(token_path)\n\n    def test_auth_token_file_not_found_skips_header(self):\n        with patch(\"agentcube.clients.control_plane.read_token_from_file\", return_value=\"\"):\n            client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n            assert \"Authorization\" not in client.session.headers\n            client.close()\n\n    def test_empty_token_skips_authorization_header(self):\n        with patch(\"agentcube.clients.control_plane.read_token_from_file\", return_value=\"\"):\n            client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n            assert \"Authorization\" not in client.session.headers\n            client.close()\n\n    def test_default_content_type_header(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        assert client.session.headers[\"Content-Type\"] == \"application/json\"\n        client.close()\n\n    def test_default_timeout_parameters(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        client.close()\n\n    def test_custom_timeout_parameters(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n        assert client.timeout == 60\n        assert client.connect_timeout == 3.0\n        client.close()\n\n    def test_custom_pool_settings(self):\n        from requests.adapters import HTTPAdapter\n\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            pool_connections=20,\n            pool_maxsize=30,\n        )\n        adapter = client.session.adapters[\"http://\"]\n        assert isinstance(adapter, HTTPAdapter)\n        assert adapter._pool_connections == 20\n        assert adapter._pool_maxsize == 30\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-2: ControlPlaneClient — create_session\n# ---------------------------------------------------------------------------\n\n\nclass TestCreateSession:\n    def test_successful_session_creation(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"abc-123\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        result = client.create_session(\n            name=\"test\",\n            namespace=\"ns\",\n            ttl=7200,\n            metadata={\"key\": \"val\"},\n        )\n\n        client.session.post.assert_called_once()\n        call_args = client.session.post.call_args\n        assert call_args[0][0] == \"http://wm:8080/v1/code-interpreter\"\n        assert call_args[1][\"json\"] == {\n            \"name\": \"test\",\n            \"namespace\": \"ns\",\n            \"ttl\": 7200,\n            \"metadata\": {\"key\": \"val\"},\n        }\n        assert call_args[1][\"timeout\"] == (5.0, 120)\n        assert result == \"abc-123\"\n        client.close()\n\n    def test_response_contains_session_id(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"abc-123\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        result = client.create_session()\n        assert result == \"abc-123\"\n        client.close()\n\n    def test_response_missing_session_id_raises_value_error(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"data\": {}}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(ValueError) as exc_info:\n            client.create_session()\n        assert \"sessionId\" in str(exc_info.value)\n        client.close()\n\n    def test_request_timeout_tuple(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"sess-1\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.create_session()\n\n        _, kwargs = client.session.post.call_args\n        assert kwargs[\"timeout\"] == (5.0, 120)\n        client.close()\n\n    def test_create_session_with_default_params(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"sess-1\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.create_session()\n\n        call_args = client.session.post.call_args\n        assert call_args[1][\"json\"] == {\n            \"name\": \"my-interpreter\",\n            \"namespace\": \"default\",\n            \"ttl\": 3600,\n            \"metadata\": None,\n        }\n        client.close()\n\n    def test_create_session_raises_http_error_on_failure(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock(\n            side_effect=requests.HTTPError(\"500 Server Error\")\n        )\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(requests.HTTPError):\n            client.create_session()\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-3: ControlPlaneClient — delete_session\n# ---------------------------------------------------------------------------\n\n\nclass TestDeleteSession:\n    def test_successful_deletion_returns_true(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.status_code = 200\n        mock_resp.raise_for_status = MagicMock()\n        client.session.delete = MagicMock(return_value=mock_resp)\n\n        result = client.delete_session(\"sess-1\")\n\n        assert result is True\n        client.session.delete.assert_called_once_with(\n            \"http://wm:8080/v1/code-interpreter/sessions/sess-1\",\n            timeout=(5.0, 120),\n        )\n        client.close()\n\n    def test_404_treated_as_success(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.status_code = 404\n        client.session.delete = MagicMock(return_value=mock_resp)\n\n        result = client.delete_session(\"nonexistent\")\n\n        assert result is True\n        client.close()\n\n    def test_other_error_returns_false(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.delete = MagicMock(\n            side_effect=requests.HTTPError(\"500 Server Error\")\n        )\n\n        result = client.delete_session(\"sess-1\")\n\n        assert result is False\n        client.close()\n\n    def test_connection_error_returns_false(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.delete = MagicMock(\n            side_effect=requests.ConnectionError(\"Connection refused\")\n        )\n\n        result = client.delete_session(\"sess-1\")\n\n        assert result is False\n        client.close()\n\n    def test_timeout_error_returns_false(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.delete = MagicMock(\n            side_effect=requests.Timeout(\"Request timed out\")\n        )\n\n        result = client.delete_session(\"sess-1\")\n\n        assert result is False\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-4: ControlPlaneClient — close\n# ---------------------------------------------------------------------------\n\n\nclass TestControlPlaneClose:\n    def test_close_releases_session(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n\n        client.session.close.assert_called_once()\n\n    def test_close_is_idempotent(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n        client.close()\n        client.close()\n\n        assert client.session.close.call_count == 3\n\n\n# ---------------------------------------------------------------------------\n# T-5: ControlPlaneClient — Session reuse\n# ---------------------------------------------------------------------------\n\n\nclass TestSessionReuse:\n    def test_same_session_for_multiple_requests(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        session_id = id(client.session)\n\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"abc-123\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        client.create_session()\n        assert id(client.session) == session_id\n\n        mock_resp_delete = MagicMock(spec=requests.Response)\n        mock_resp_delete.status_code = 200\n        mock_resp_delete.raise_for_status = MagicMock()\n        client.session.delete = MagicMock(return_value=mock_resp_delete)\n\n        client.delete_session(\"abc-123\")\n        assert id(client.session) == session_id\n\n        client.close()\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_control_plane.py","time":{"start":1775893874829,"end":1775893875369}}}}
