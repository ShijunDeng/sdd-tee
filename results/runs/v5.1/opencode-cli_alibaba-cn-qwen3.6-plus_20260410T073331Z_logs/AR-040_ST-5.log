ndex: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_data_plane.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_data_plane.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_data_plane.py\n@@ -166,10 +166,10 @@\n     client.session.request = MagicMock(return_value=mock_resp)\n \n     client._request(\"GET\", \"api/files\")\n \n-    _, kwargs = client.session.request.call_args\n-    assert kwargs[\"url\"] == \"http://base/api/files\"\n+    call_args = client.session.request.call_args\n+    assert call_args[0][1] == \"http://base/api/files\"\n     client.close()\n \n def test_request_with_query_params(self):\n     client = CodeInterpreterDataPlaneClient(\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_data_plane.py","before":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nimport base64\nimport json\nimport os\nimport tempfile\nfrom unittest.mock import MagicMock, mock_open, patch\n\nimport pytest\nimport requests\nfrom requests.adapters import HTTPAdapter\n\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\n# ---------------------------------------------------------------------------\n# T-1: CodeInterpreterDataPlaneClient — Constructor and base URL\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneClientInit:\n    def test_base_url_from_router_url(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client.base_url == (\n            \"http://router:8080/v1/namespaces/ns/\"\n            \"code-interpreters/my-interpreter/invocations/\"\n        )\n        client.close()\n\n    def test_base_url_explicit_override(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://custom/url/\",\n        )\n        assert client.base_url == \"http://custom/url/\"\n        client.close()\n\n    def test_explicit_base_url_ignores_router_params(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n            base_url=\"http://custom/url/\",\n        )\n        assert client.base_url == \"http://custom/url/\"\n        client.close()\n\n    def test_session_header_set(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client.session.headers[\"x-agentcube-session-id\"] == \"sess-1\"\n        client.close()\n\n    def test_default_timeouts(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        client.close()\n\n    def test_custom_timeouts(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n        assert client.timeout == 60\n        assert client.connect_timeout == 3.0\n        client.close()\n\n    def test_custom_pool_settings(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n            pool_connections=20,\n            pool_maxsize=30,\n        )\n        adapter = client.session.adapters[\"http://\"]\n        assert adapter._pool_connections == 20\n        assert adapter._pool_maxsize == 30\n        client.close()\n\n    def test_independent_sessions_across_clients(self):\n        client1 = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        client2 = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-2\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client1.session is not client2.session\n        client1.close()\n        client2.close()\n\n\n# ---------------------------------------------------------------------------\n# T-2: CodeInterpreterDataPlaneClient — _request\n# ---------------------------------------------------------------------------\n\n\nclass TestRequest:\n    def test_json_body_request_sets_content_type(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client._request(\"POST\", \"api/execute\", body=b'{\"cmd\": \"ls\"}')\n\n        client.session.request.assert_called_once()\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"headers\"][\"Content-Type\"] == \"application/json\"\n        assert kwargs[\"data\"] == b'{\"cmd\": \"ls\"}'\n        client.close()\n\n    def test_request_without_body_no_content_type_override(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client._request(\"GET\", \"api/files\")\n\n        _, kwargs = client.session.request.call_args\n        assert \"Content-Type\" not in kwargs.get(\"headers\", {})\n        client.close()\n\n    def test_request_url_construction(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client._request(\"GET\", \"api/files\")\n\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"url\"] == \"http://base/api/files\"\n        client.close()\n\n    def test_request_with_query_params(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client._request(\"GET\", \"api/files\", params={\"path\": \"/tmp\"})\n\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"params\"] == {\"path\": \"/tmp\"}\n        client.close()\n\n    def test_request_raises_on_http_error(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock(\n            side_effect=requests.HTTPError(\"500 Error\")\n        )\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(requests.HTTPError):\n            client._request(\"GET\", \"api/files\")\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-3: CodeInterpreterDataPlaneClient — execute_command\n# ---------------------------------------------------------------------------\n\n\nclass TestExecuteCommand:\n    def test_command_with_explicit_timeout(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"done\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        result = client.execute_command(\"sleep 10\", timeout=10.0)\n\n        assert result == \"done\"\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"timeout\"] == (5.0, 12.0)\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"command\"] == [\"sleep\", \"10\"]\n        assert body[\"timeout\"] == \"10s\"\n        client.close()\n\n    def test_command_with_default_timeout(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n            timeout=120,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"ok\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        result = client.execute_command(\"ls\", timeout=None)\n\n        assert result == \"ok\"\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"timeout\"] == \"120s\"\n        assert kwargs[\"timeout\"] == (5.0, 122.0)\n        client.close()\n\n    def test_command_string_split_by_whitespace(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.execute_command(\"ls -la\")\n\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"command\"] == [\"ls\", \"-la\"]\n        client.close()\n\n    def test_command_list_passed_as_is(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.execute_command([\"ls\", \"-la\", \"/tmp\"])\n\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"command\"] == [\"ls\", \"-la\", \"/tmp\"]\n        client.close()\n\n    def test_nonzero_exit_code_raises_error(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\n            \"exit_code\": 1,\n            \"stderr\": \"error occurred\",\n            \"stdout\": \"\",\n        }\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(CommandExecutionError) as exc_info:\n            client.execute_command(\"ls\")\n\n        assert exc_info.value.exit_code == 1\n        assert exc_info.value.stderr == \"error occurred\"\n        assert exc_info.value.command == [\"ls\"]\n        client.close()\n\n    def test_timeout_buffer_logic(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.execute_command(\"sleep 30\", timeout=30.0)\n\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"timeout\"] == (3.0, 32.0)\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-4: CodeInterpreterDataPlaneClient — run_code\n# ---------------------------------------------------------------------------\n\n\nclass TestRunCode:\n    def test_python_code_execution(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.write_file = MagicMock()\n        client.execute_command = MagicMock(return_value=\"hello\\n\")\n\n        result = client.run_code(\"python\", \"print('hi')\")\n\n        assert result == \"hello\\n\"\n        client.write_file.assert_called_once()\n        write_call = client.write_file.call_args\n        assert write_call[0][0] == \"print('hi')\"\n        assert write_call[0][1].endswith(\".py\")\n        client.execute_command.assert_called_once()\n        exec_call = client.execute_command.call_args\n        assert exec_call[0][0].startswith(\"python3 /tmp/code_\")\n        client.close()\n\n    def test_language_alias_py(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.write_file = MagicMock()\n        client.execute_command = MagicMock(return_value=\"ok\")\n\n        client.run_code(\"py\", \"print(1)\")\n\n        client.write_file.assert_called_once()\n        client.close()\n\n    def test_language_alias_python3(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.write_file = MagicMock()\n        client.execute_command = MagicMock(return_value=\"ok\")\n\n        client.run_code(\"python3\", \"print(1)\")\n\n        client.write_file.assert_called_once()\n        client.close()\n\n    def test_unsupported_language_raises_value_error(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n\n        with pytest.raises(ValueError) as exc_info:\n            client.run_code(\"ruby\", \"puts 'hi'\")\n        assert \"Unsupported language\" in str(exc_info.value)\n        client.close()\n\n    def test_run_code_passes_timeout(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.write_file = MagicMock()\n        client.execute_command = MagicMock(return_value=\"ok\")\n\n        client.run_code(\"python\", \"print(1)\", timeout=30.0)\n\n        client.execute_command.assert_called_once()\n        _, kwargs = client.execute_command.call_args\n        assert kwargs[\"timeout\"] == 30.0\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-5: CodeInterpreterDataPlaneClient — write_file\n# ---------------------------------------------------------------------------\n\n\nclass TestWriteFile:\n    def test_write_file_base64_encoding(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.write_file(\"hello\", \"/tmp/test.txt\")\n\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"path\"] == \"/tmp/test.txt\"\n        assert body[\"mode\"] == \"0644\"\n        assert body[\"content\"] == base64.b64encode(b\"hello\").decode(\"utf-8\")\n        client.close()\n\n    def test_write_file_empty_content(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.write_file(\"\", \"/tmp/empty.txt\")\n\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"content\"] == \"\"\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-6: CodeInterpreterDataPlaneClient — upload_file\n# ---------------------------------------------------------------------------\n\n\nclass TestUploadFile:\n    def test_multipart_upload_with_session_header(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".txt\") as f:\n            f.write(\"test content\")\n            f.flush()\n            local_path = f.name\n\n        try:\n            client.upload_file(local_path, \"/remote/path.txt\")\n\n            client.session.post.assert_called_once()\n            _, kwargs = client.session.post.call_args\n            assert kwargs[\"data\"][\"path\"] == \"/remote/path.txt\"\n            assert kwargs[\"data\"][\"mode\"] == \"0644\"\n            assert kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"sess-1\"\n        finally:\n            os.unlink(local_path)\n        client.close()\n\n    def test_upload_file_url_construction(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".txt\") as f:\n            f.write(\"content\")\n            f.flush()\n            local_path = f.name\n\n        try:\n            client.upload_file(local_path, \"/remote/file.txt\")\n\n            call_args = client.session.post.call_args\n            assert call_args[0][0] == \"http://base/api/files\"\n        finally:\n            os.unlink(local_path)\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-7: CodeInterpreterDataPlaneClient — download_file\n# ---------------------------------------------------------------------------\n\n\nclass TestDownloadFile:\n    def test_streaming_download(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        mock_resp.iter_content.return_value = [b\"chunk1\", b\"chunk2\"]\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with tempfile.NamedTemporaryFile(delete=False, suffix=\".txt\") as f:\n            local_path = f.name\n\n        try:\n            client.download_file(\"/remote/path.txt\", local_path)\n\n            client.session.get.assert_called_once_with(\n                \"http://base/api/files/remote/path.txt\",\n                stream=True,\n                timeout=(5.0, 120),\n            )\n            with open(local_path, \"rb\") as f:\n                assert f.read() == b\"chunk1chunk2\"\n        finally:\n            os.unlink(local_path)\n        client.close()\n\n    def test_clean_path_strips_leading_slash(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        mock_resp.iter_content.return_value = [b\"data\"]\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with tempfile.NamedTemporaryFile(delete=False) as f:\n            local_path = f.name\n\n        try:\n            client.download_file(\"/absolute/path.txt\", local_path)\n\n            call_args = client.session.get.call_args\n            assert call_args[0][0] == \"http://base/api/files/absolute/path.txt\"\n        finally:\n            os.unlink(local_path)\n        client.close()\n\n    def test_download_raises_on_http_error(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock(\n            side_effect=requests.HTTPError(\"404 Not Found\")\n        )\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(requests.HTTPError):\n            client.download_file(\"/nonexistent.txt\", \"/tmp/out.txt\")\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-8: CodeInterpreterDataPlaneClient — list_files\n# ---------------------------------------------------------------------------\n\n\nclass TestListFiles:\n    def test_list_files_with_path(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"files\": [\"a.txt\", \"b.txt\"]}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        result = client.list_files(\"/some/path\")\n\n        assert result == {\"files\": [\"a.txt\", \"b.txt\"]}\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"params\"] == {\"path\": \"/some/path\"}\n        client.close()\n\n    def test_list_files_default_path(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"files\": [\"file1\"]}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.list_files()\n\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"params\"] == {\"path\": \".\"}\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-9: CodeInterpreterDataPlaneClient — close\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneClose:\n    def test_close_releases_session(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n\n        client.session.close.assert_called_once()\n\n    def test_close_is_idempotent(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n        client.close()\n        client.close()\n\n        assert client.session.close.call_count == 3\n","after":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nimport base64\nimport json\nimport os\nimport tempfile\nfrom unittest.mock import MagicMock, mock_open, patch\n\nimport pytest\nimport requests\nfrom requests.adapters import HTTPAdapter\n\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\n# ---------------------------------------------------------------------------\n# T-1: CodeInterpreterDataPlaneClient — Constructor and base URL\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneClientInit:\n    def test_base_url_from_router_url(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client.base_url == (\n            \"http://router:8080/v1/namespaces/ns/\"\n            \"code-interpreters/my-interpreter/invocations/\"\n        )\n        client.close()\n\n    def test_base_url_explicit_override(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://custom/url/\",\n        )\n        assert client.base_url == \"http://custom/url/\"\n        client.close()\n\n    def test_explicit_base_url_ignores_router_params(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n            base_url=\"http://custom/url/\",\n        )\n        assert client.base_url == \"http://custom/url/\"\n        client.close()\n\n    def test_session_header_set(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client.session.headers[\"x-agentcube-session-id\"] == \"sess-1\"\n        client.close()\n\n    def test_default_timeouts(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        client.close()\n\n    def test_custom_timeouts(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n        assert client.timeout == 60\n        assert client.connect_timeout == 3.0\n        client.close()\n\n    def test_custom_pool_settings(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n            pool_connections=20,\n            pool_maxsize=30,\n        )\n        adapter = client.session.adapters[\"http://\"]\n        assert adapter._pool_connections == 20\n        assert adapter._pool_maxsize == 30\n        client.close()\n\n    def test_independent_sessions_across_clients(self):\n        client1 = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        client2 = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-2\",\n            router_url=\"http://router:8080\",\n            namespace=\"ns\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client1.session is not client2.session\n        client1.close()\n        client2.close()\n\n\n# ---------------------------------------------------------------------------\n# T-2: CodeInterpreterDataPlaneClient — _request\n# ---------------------------------------------------------------------------\n\n\nclass TestRequest:\n    def test_json_body_request_sets_content_type(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client._request(\"POST\", \"api/execute\", body=b'{\"cmd\": \"ls\"}')\n\n        client.session.request.assert_called_once()\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"headers\"][\"Content-Type\"] == \"application/json\"\n        assert kwargs[\"data\"] == b'{\"cmd\": \"ls\"}'\n        client.close()\n\n    def test_request_without_body_no_content_type_override(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client._request(\"GET\", \"api/files\")\n\n        _, kwargs = client.session.request.call_args\n        assert \"Content-Type\" not in kwargs.get(\"headers\", {})\n        client.close()\n\n    def test_request_url_construction(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client._request(\"GET\", \"api/files\")\n\n        call_args = client.session.request.call_args\n        assert call_args[0][1] == \"http://base/api/files\"\n        client.close()\n\n    def test_request_with_query_params(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client._request(\"GET\", \"api/files\", params={\"path\": \"/tmp\"})\n\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"params\"] == {\"path\": \"/tmp\"}\n        client.close()\n\n    def test_request_raises_on_http_error(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock(\n            side_effect=requests.HTTPError(\"500 Error\")\n        )\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(requests.HTTPError):\n            client._request(\"GET\", \"api/files\")\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-3: CodeInterpreterDataPlaneClient — execute_command\n# ---------------------------------------------------------------------------\n\n\nclass TestExecuteCommand:\n    def test_command_with_explicit_timeout(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"done\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        result = client.execute_command(\"sleep 10\", timeout=10.0)\n\n        assert result == \"done\"\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"timeout\"] == (5.0, 12.0)\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"command\"] == [\"sleep\", \"10\"]\n        assert body[\"timeout\"] == \"10s\"\n        client.close()\n\n    def test_command_with_default_timeout(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n            timeout=120,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"ok\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        result = client.execute_command(\"ls\", timeout=None)\n\n        assert result == \"ok\"\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"timeout\"] == \"120s\"\n        assert kwargs[\"timeout\"] == (5.0, 122.0)\n        client.close()\n\n    def test_command_string_split_by_whitespace(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.execute_command(\"ls -la\")\n\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"command\"] == [\"ls\", \"-la\"]\n        client.close()\n\n    def test_command_list_passed_as_is(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.execute_command([\"ls\", \"-la\", \"/tmp\"])\n\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"command\"] == [\"ls\", \"-la\", \"/tmp\"]\n        client.close()\n\n    def test_nonzero_exit_code_raises_error(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\n            \"exit_code\": 1,\n            \"stderr\": \"error occurred\",\n            \"stdout\": \"\",\n        }\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(CommandExecutionError) as exc_info:\n            client.execute_command(\"ls\")\n\n        assert exc_info.value.exit_code == 1\n        assert exc_info.value.stderr == \"error occurred\"\n        assert exc_info.value.command == [\"ls\"]\n        client.close()\n\n    def test_timeout_buffer_logic(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"\", \"stderr\": \"\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.execute_command(\"sleep 30\", timeout=30.0)\n\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"timeout\"] == (3.0, 32.0)\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-4: CodeInterpreterDataPlaneClient — run_code\n# ---------------------------------------------------------------------------\n\n\nclass TestRunCode:\n    def test_python_code_execution(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.write_file = MagicMock()\n        client.execute_command = MagicMock(return_value=\"hello\\n\")\n\n        result = client.run_code(\"python\", \"print('hi')\")\n\n        assert result == \"hello\\n\"\n        client.write_file.assert_called_once()\n        write_call = client.write_file.call_args\n        assert write_call[0][0] == \"print('hi')\"\n        assert write_call[0][1].endswith(\".py\")\n        client.execute_command.assert_called_once()\n        exec_call = client.execute_command.call_args\n        assert exec_call[0][0].startswith(\"python3 /tmp/code_\")\n        client.close()\n\n    def test_language_alias_py(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.write_file = MagicMock()\n        client.execute_command = MagicMock(return_value=\"ok\")\n\n        client.run_code(\"py\", \"print(1)\")\n\n        client.write_file.assert_called_once()\n        client.close()\n\n    def test_language_alias_python3(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.write_file = MagicMock()\n        client.execute_command = MagicMock(return_value=\"ok\")\n\n        client.run_code(\"python3\", \"print(1)\")\n\n        client.write_file.assert_called_once()\n        client.close()\n\n    def test_unsupported_language_raises_value_error(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n\n        with pytest.raises(ValueError) as exc_info:\n            client.run_code(\"ruby\", \"puts 'hi'\")\n        assert \"Unsupported language\" in str(exc_info.value)\n        client.close()\n\n    def test_run_code_passes_timeout(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.write_file = MagicMock()\n        client.execute_command = MagicMock(return_value=\"ok\")\n\n        client.run_code(\"python\", \"print(1)\", timeout=30.0)\n\n        client.execute_command.assert_called_once()\n        _, kwargs = client.execute_command.call_args\n        assert kwargs[\"timeout\"] == 30.0\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-5: CodeInterpreterDataPlaneClient — write_file\n# ---------------------------------------------------------------------------\n\n\nclass TestWriteFile:\n    def test_write_file_base64_encoding(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.write_file(\"hello\", \"/tmp/test.txt\")\n\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"path\"] == \"/tmp/test.txt\"\n        assert body[\"mode\"] == \"0644\"\n        assert body[\"content\"] == base64.b64encode(b\"hello\").decode(\"utf-8\")\n        client.close()\n\n    def test_write_file_empty_content(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.write_file(\"\", \"/tmp/empty.txt\")\n\n        _, kwargs = client.session.request.call_args\n        body = json.loads(kwargs[\"data\"])\n        assert body[\"content\"] == \"\"\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-6: CodeInterpreterDataPlaneClient — upload_file\n# ---------------------------------------------------------------------------\n\n\nclass TestUploadFile:\n    def test_multipart_upload_with_session_header(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".txt\") as f:\n            f.write(\"test content\")\n            f.flush()\n            local_path = f.name\n\n        try:\n            client.upload_file(local_path, \"/remote/path.txt\")\n\n            client.session.post.assert_called_once()\n            _, kwargs = client.session.post.call_args\n            assert kwargs[\"data\"][\"path\"] == \"/remote/path.txt\"\n            assert kwargs[\"data\"][\"mode\"] == \"0644\"\n            assert kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"sess-1\"\n        finally:\n            os.unlink(local_path)\n        client.close()\n\n    def test_upload_file_url_construction(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".txt\") as f:\n            f.write(\"content\")\n            f.flush()\n            local_path = f.name\n\n        try:\n            client.upload_file(local_path, \"/remote/file.txt\")\n\n            call_args = client.session.post.call_args\n            assert call_args[0][0] == \"http://base/api/files\"\n        finally:\n            os.unlink(local_path)\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-7: CodeInterpreterDataPlaneClient — download_file\n# ---------------------------------------------------------------------------\n\n\nclass TestDownloadFile:\n    def test_streaming_download(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        mock_resp.iter_content.return_value = [b\"chunk1\", b\"chunk2\"]\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with tempfile.NamedTemporaryFile(delete=False, suffix=\".txt\") as f:\n            local_path = f.name\n\n        try:\n            client.download_file(\"/remote/path.txt\", local_path)\n\n            client.session.get.assert_called_once_with(\n                \"http://base/api/files/remote/path.txt\",\n                stream=True,\n                timeout=(5.0, 120),\n            )\n            with open(local_path, \"rb\") as f:\n                assert f.read() == b\"chunk1chunk2\"\n        finally:\n            os.unlink(local_path)\n        client.close()\n\n    def test_clean_path_strips_leading_slash(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock()\n        mock_resp.iter_content.return_value = [b\"data\"]\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with tempfile.NamedTemporaryFile(delete=False) as f:\n            local_path = f.name\n\n        try:\n            client.download_file(\"/absolute/path.txt\", local_path)\n\n            call_args = client.session.get.call_args\n            assert call_args[0][0] == \"http://base/api/files/absolute/path.txt\"\n        finally:\n            os.unlink(local_path)\n        client.close()\n\n    def test_download_raises_on_http_error(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.raise_for_status = MagicMock(\n            side_effect=requests.HTTPError(\"404 Not Found\")\n        )\n        client.session.get = MagicMock(return_value=mock_resp)\n\n        with pytest.raises(requests.HTTPError):\n            client.download_file(\"/nonexistent.txt\", \"/tmp/out.txt\")\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-8: CodeInterpreterDataPlaneClient — list_files\n# ---------------------------------------------------------------------------\n\n\nclass TestListFiles:\n    def test_list_files_with_path(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"files\": [\"a.txt\", \"b.txt\"]}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        result = client.list_files(\"/some/path\")\n\n        assert result == {\"files\": [\"a.txt\", \"b.txt\"]}\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"params\"] == {\"path\": \"/some/path\"}\n        client.close()\n\n    def test_list_files_default_path(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"files\": [\"file1\"]}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.request = MagicMock(return_value=mock_resp)\n\n        client.list_files()\n\n        _, kwargs = client.session.request.call_args\n        assert kwargs[\"params\"] == {\"path\": \".\"}\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-9: CodeInterpreterDataPlaneClient — close\n# ---------------------------------------------------------------------------\n\n\nclass TestDataPlaneClose:\n    def test_close_releases_session(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n\n        client.session.close.assert_called_once()\n\n    def test_close_is_idempotent(self):\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"sess-1\",\n            base_url=\"http://base/\",\n        )\n        client.session.close = MagicMock()\n\n        client.close()\n        client.close()\n        client.close()\n\n        assert client.session.close.call_count == 3\n","additions":2,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_data_plane.py","time":{"start":1775893886744,"end":1775893887410}}}}
