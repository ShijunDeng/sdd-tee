nt\n\n\n# ---------------------------------------------------------------------------\n# T-1: ControlPlaneClient — Constructor and URL resolution\n# ---------------------------------------------------------------------------\n\n\nclass TestControlPlaneClientInit:\n    def test_base_url_from_argument(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        assert client.base_url == \"http://wm:8080\"\n        client.close()\n\n    def test_base_url_from_environment(self):\n        with patch.dict(os.environ, {\"WORKLOAD_MANAGER_URL\": \"http://wm-env:9090\"}):\n            client = ControlPlaneClient()\n            assert client.base_url == \"http://wm-env:9090\"\n            client.close()\n\n    def test_raises_when_no_url_provided(self):\n        with patch.dict(os.environ, {}, clear=True):\n            os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n            with pytest.raises(ValueError) as exc_info:\n                ControlPlaneClient()\n        assert \"workload_manager_url must be provided\" in str(exc_info.value)\n\n    def test_auth_token_from_argument(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"my-token\",\n        )\n        assert client.session.headers[\"Authorization\"] == \"Bearer my-token\"\n        client.close()\n\n    def test_auth_token_from_sa_file(self):\n        with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".token\") as f:\n            f.write(\"sa-token\\n\")\n            f.flush()\n            token_path = f.name\n        try:\n            with patch(\n                \"agentcube.clients.control_plane.SA_TOKEN_PATH\", token_path\n            ):\n                client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n                assert client.session.headers[\"Authorization\"] == \"Bearer sa-token\"\n                client.close()\n        finally:\n            os.unlink(token_path)\n\n    def test_auth_token_file_not_found_skips_header(self):\n        with patch(\"agentcube.clients.control_plane.read_token_from_file\", return_value=\"\"):\n            client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n            assert \"Authorization\" not in client.session.headers\n            client.close()\n\n    def test_empty_token_skips_authorization_header(self):\n        with patch(\"agentcube.clients.control_plane.read_token_from_file\", return_value=\"\"):\n            client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n            assert \"Authorization\" not in client.session.headers\n            client.close()\n\n    def test_default_content_type_header(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        assert client.session.headers[\"Content-Type\"] == \"application/json\"\n        client.close()\n\n    def test_default_timeout_parameters(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n        client.close()\n\n    def test_custom_timeout_parameters(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            timeout=60,\n            connect_timeout=3.0,\n        )\n        assert client.timeout == 60\n        assert client.connect_timeout == 3.0\n        client.close()\n\n    def test_custom_pool_settings(self):\n        from requests.adapters import HTTPAdapter\n\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            pool_connections=20,\n            pool_maxsize=30,\n        )\n        adapter = client.session.adapters[\"http://\"]\n        assert isinstance(adapter, HTTPAdapter)\n        assert adapter._pool_connections == 20\n        assert adapter._pool_maxsize == 30\n        client.close()\n\n\n# ---------------------------------------------------------------------------\n# T-2: ControlPlaneClient — create_session\n# ---------------------------------------------------------------------------\n\n\nclass TestCreateSession:\n    def test_successful_session_creation(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"abc-123\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        result = client.create_session(\n            name=\"test\",\n            namespace=\"ns\",\n            ttl=7200,\n            metadata={\"key\": \"val\"},\n        )\n\n        client.session.post.assert_called_once()\n        call_args = client.session.post.call_args\n        assert call_args[0][0] == \"http://wm:8080/v1/code-interpreter\"\n        assert call_args[1][\"json\"] == {\n            \"name\": \"test\",\n            \"namespace\": \"ns\",\n            \"ttl\": 7200,\n            \"metadata\": {\"key\": \"val\"},\n        }\n        assert call_args[1][\"timeout\"] == (5.0, 120)\n        assert result == \"abc-123\"\n        client.close()\n\n    def test_response_contains_session_id(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            auth_token=\"test-token\",\n        )\n        mock_resp = MagicMock(spec=requests.Response)\n        mock_resp.json.return_value = {\"sessionId\": \"abc-123\"}\n        mock_resp.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_resp)\n\n        result = client.create_session()\n        assert result == \"abc-123\"\n        client.close()\n\n    def test_response_missing_session_id_raises_value_error(self):\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm:8080\",\n            