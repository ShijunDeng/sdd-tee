            )\n39:         self.router_url = router_url\n40: \n41:         self.dp_client = AgentRuntimeDataPlaneClient(\n42:             router_url=self.router_url,\n43:             namespace=self.namespace,\n44:             agent_name=self.agent_name,\n45:             timeout=self.timeout,\n46:             connect_timeout=self.connect_timeout,\n47:         )\n48: \n49:         if self.session_id is None:\n50:             self.session_id = self.dp_client.bootstrap_session_id()\n51:             self.logger.debug(\n52:                 \"Bootstrapped session: %s (agent=%s, namespace=%s)\",\n53:                 self.session_id,\n54:                 agent_name,\n55:                 namespace,\n56:             )\n57: \n58:     def __enter__(self) -> \"AgentRuntimeClient\":\n59:         return self\n60: \n61:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n62:         self.close()\n63: \n64:     def invoke(\n65:         self, payload: Dict[str, Any], timeout: Optional[float] = None\n66:     ) -> Any:\n67:         \"\"\"Invoke the agent runtime with a payload.\"\"\"\n68:         if not self.session_id:\n69:             raise ValueError(\"AgentRuntime session_id is not initialized\")\n70:         resp = self.dp_client.invoke(\n71:             session_id=self.session_id,\n72:             payload=payload,\n73:             timeout=timeout,\n74:         )\n75:         return resp.json()\n76: \n77:     def close(self) -> None:\n78:         \"\"\"Close the underlying HTTP session.\"\"\"\n79:         self.dp_client.close()\n\n(End of file - total 79 lines)\n</content>","metadata":{"preview":"import os\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom agentcube.utils.log import get_logger\n\n\nclass AgentRuntimeClient:\n    \"\"\"High-level client for Agent Runtime invocation.\n\n    Bootstraps sessions and invokes agent workloads through the Router.\n    \"\"\"\n\n    def __init__(\n     