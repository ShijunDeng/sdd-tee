4 | `TestResolvePodIP_NoIP` | resolvePodIP | Pod running but no IP → error |\n624: | 25 | `TestResolvePodIP_NotFound` | resolvePodIP | No pod found → error |\n625: | 26 | `TestBuildEntryPoints_SinglePort` | buildEntryPoints | One port → one entry point |\n626: | 27 | `TestBuildEntryPoints_MultiplePorts` | buildEntryPoints | Multiple ports → multiple entry points |\n627: | 28 | `TestBuildEntryPoints_EmptyPorts` | buildEntryPoints | Empty → empty result |\n628: | 29 | `TestGenerateSessionID_IsUUID` | generateSessionID | Returns valid UUID format |\n629: | 30 | `TestGenerateSandboxName_Format` | generateSandboxName | Format: `{workloadName}-{8 random chars}` |\n630: | 31 | `TestRandString_Length` | RandString | Returns string of requested length |\n631: | 32 | `TestRandString_Charset` | RandString | Only contains allowed charset chars |\n632: \n633: #### `models_test.go` — Data Models\n634: \n635: | # | Test Name | Function | Description |\n636: |---|-----------|----------|-------------|\n637: | 1 | `TestCreateSandboxRequest_Validate_Valid` | Validate | Valid request passes |\n638: | 2 | `TestCreateSandboxRequest_Validate_InvalidKind` | Validate | Invalid kind → error |\n639: | 3 | `TestCreateSandboxRequest_Validate_EmptyName` | Validate | Empty name → error |\n640: | 4 | `TestCreateSandboxRequest_Validate_EmptyNamespace` | Validate | Empty namespace → error |\n641: | 5 | `TestCreateSandboxRequest_Validate_AllEmpty` | Validate | All empty → error mentions all fields |\n642: | 6 | `TestCreateSandboxResponse_JSONSerialization` | JSON marshal/unmarshal | Round-trip serialization |\n643: | 7 | `TestSandboxInfo_JSONSerialization` | JSON marshal/unmarshal | Full struct round-trip |\n644: | 8 | `TestEntryPoint_JSONSerialization` | JSON marshal/unmarshal | Round-trip |\n645: | 9 | `TestSandboxStatus_WithError` | SandboxInfo | Error field set |\n646: | 10 | `TestSandboxStatus_WithStatus` | SandboxInfo | Status field set |\n647: \n648: #### `reconciler/fixtures_test.go` — Shared Test Infrastructure\n649: \n650: Contains all mock types and fixture builders described in Section 2.\n651: \n652: #### `reconciler_test.go` — SandboxReconciler Core\n653: \n654: | # | Test Name | Function | Description |\n655: |---|-----------|----------|-------------|\n656: | 1 | `TestNewSandboxReconciler_NilStore_Panics` | NewSandboxReconciler | Store=nil → panic |\n657: | 2 | `TestNewSandboxReconciler_NilClientset_Panics` | NewSandboxReconciler | Clientset=nil → panic |\n658: | 3 | `TestNewSandboxReconciler_NilInformerFactory_Panics` | NewSandboxReconciler | InformerFactory=nil → panic |\n659: | 4 | `TestNewSandboxReconciler_DefaultWorkers` | NewSandboxReconciler | Workers=0 → defaults to 2 |\n660: | 5 | `TestNewSandboxReconciler_CustomWorkers` | NewSandboxReconciler | Workers=5 → uses 5 |\n661: | 6 | `TestNewSandboxReconciler_WithMetricsRecorder` | NewSandboxReconciler | MetricsRecorder set |\n662: | 7 | `TestNewSandboxReconciler_EventHandlersRegistered` | registerEventHandlers | Verifies informers have event handlers |\n663: | 8 | `TestEnqueue_WithNamespace` | Enqueue | Key = \"ns/name\", metrics recorded |\n664: | 9 | `TestEnqueue_WithoutNamespace` | Enqueue | Key = \"name\", metrics recorded |\n665: | 10 | `TestEnqueue_NilMetricsRecorder` | Enqueue | No panic with nil metrics |\n666: | 11 | `TestRun_DuplicateCall_Ignored` | Run | Second Run call logs and returns |\n667: | 12 | `TestWatchSandboxOnce_ARFound_Running` | WatchSandboxOnce | AR with Ready=True → \"running\" |\n668: | 13 | `TestWatchSandboxOnce_ARFound_Pending` | WatchSandboxOnce | AR with Ready=False → \"pending\" |\n669: | 14 | `TestWatchSandboxOnce_CIFound_Running` | WatchSandboxOnce | CI with Ready=True → \"running\" |\n670: | 15 | `TestWatchSandboxOnce_NotFound_Timeout` | WatchSandboxOnce | Neither found → timeout error |\n671: | 16 | `TestWatchSandboxOnce_WithNamespace` | WatchSandboxOnce | Namespace included in key |\n672: \n673: #### `sync_test.go` — Sync Loop\n674: \n675: | # | Test Name | Function | Description |\n676: |---|-----------|----------|-------------|\n677: | 1 | `TestSyncHandler_AgentRuntimeFound` | syncHandler | AR exists → calls reconcileAgentRuntime |\n678: | 2 | `TestSyncHandler_CodeInterpreterFound` | syncHandler | CI exists → calls reconcileCodeInterpreter |\n679: | 3 | `TestSyncHandler_PodFound` | syncHandler | Pod exists → calls reconcilePod |\n680: | 4 | `TestSyncHandler_NoneFound` | syncHandler | Nothing found → nil |\n681: | 5 | `TestSyncHandler_InvalidKey` | syncHandler | Bad key format → error |\n682: | 6 | `TestSyncHandler_ARListerError` | syncHandler | Lister error → error with metrics |\n683: | 7 | `TestSyncHandler_CIListerError` | syncHandler | Lister error → error with metrics |\n684: | 8 | `TestProcessNextWorkItem_Success` | processNextWorkItem | Valid key, no error → Forget + Done |\n685: | 9 | `TestProcessNextWorkItem_Error_Retry` | processNextWorkItem | Error → AddRateLimited + Done |\n686: | 10 | `TestProcessNextWorkItem_Error_MaxRetries` | processNextWorkItem | 15+ retries → Forget + HandleError |\n687: | 11 | `TestProcessNextWorkItem_InvalidObjectType` | processNextWorkItem | Non-string item → Done + Forget |\n688: | 12 | `TestProcessNextWorkItem_MetricsRecorded` | processNextWorkItem | Duration and total metrics recorded |\n689: | 13 | `TestProcessNextWorkItem_Shutdown` | processNextWorkItem | Queue shutdown → returns false |\n690: | 14 | `TestDetermineResourceType_AgentRuntime` | determineResourceType | AR exists → \"agentruntime\" |\n691: | 15 | `TestDetermineResourceType_CodeInterpreter` | determineResourceType | CI exists → \"codeinterpreter\" |\n692: | 16 | `TestDetermineResourceType_Pod` | determineResourceType | Neither → \"pod\" |\n693: | 17 | `TestDetermineResourceType_InvalidKey` | determineResourceType | Bad key → \"agentruntime\" default |\n694: | 18 | `TestRunWorker_ProcessesItems` | runWorker | Processes until queue empty |\n695: \n696: #### `agentruntime_test.go` — AgentRuntime Reconciliation\n697: \n698: | # | Test Name | Function | Description |\n699: |---|-----------|----------|-------------|\n700: | 1 | `TestReconcileAgentRuntime_InvalidKey` | reconcileAgentRuntime | Bad key → error |\n701: | 2 | `TestReconcileAgentRuntime_NotFound` | reconcileAgentRuntime | IsNotFound → nil (cleanup) |\n702: | 3 | `TestReconcileAgentRuntime_ListerError` | reconcileAgentRuntime | Lister error → error + metrics |\n703: | 4 | `TestReconcileAgentRuntime_MissingSessionID` | reconcileAgentRuntime | No session-id label → log + nil |\n704: | 5 | `TestReconcileAgentRuntime_DeletionTimestamp` | reconcileAgentRuntime | Being deleted → DeleteSandboxBySessionID |\n705: | 6 | `TestReconcileAgentRuntime_DeletionTimestamp_StoreError` | reconcileAgentRuntime | Delete fails → error + metrics |\n706: | 7 | `TestReconcileAgentRuntime_NewSandbox` | reconcileAgentRuntime | Not in store → StoreSandbox |\n707: | 8 | `TestReconcileAgentRuntime_NewSandbox_StoreError` | reconcileAgentRuntime | StoreSandbox fails → error + metrics |\n708: | 9 | `TestReconcileAgentRuntime_StatusUpdate_PendingToRunning` | reconcileAgentRuntime | Status changed → UpdateSandbox |\n709: | 10 | `TestReconcileAgentRuntime_StatusUpdate_RunningToTerminated` | reconcileAgentRuntime | Terminated → UpdateSandbox + DeleteSandboxBySessionID |\n710: | 11 | `TestReconcileAgentRuntime_StatusUpdate_Terminated_DeleteFails` | reconcileAgentRuntime | Delete after termination fails → error |\n711: | 12 | `TestReconcileAgentRuntime_StatusUpdate_UpdateFails` | reconcileAgentRuntime | UpdateSandbox error → error + metrics |\n712: | 13 | `TestReconcileAgentRuntime_NoStatusChange` | reconcileAgentRuntime | Status same → no store call |\n713: | 14 | `TestReconcileAgentRuntime_GetSandboxError` | reconcileAgentRuntime | GetSandbox non-NotFound error → error + metrics |\n714: | 15 | `TestMapConditionToStatus_Empty` | mapConditionToStatus | No conditions → \"pending\" |\n715: | 16 | `TestMapConditionToStatus_ReadyTrue` | mapConditionToStatus | Ready=True → \"running\" |\n716: | 17 | `TestMapConditionToStatus_ReadyFalse_Terminated` | mapConditionToStatus | Ready=False, Terminated → \"terminated\" |\n717: | 18 | `TestMapConditionToStatus_ReadyFalse_Other` | mapConditionToStatus | Ready=False, other → \"pending\" |\n718: | 19 | `TestMapConditionToStatus_ReadyUnknown` | mapConditionToStatus | Ready=Unknown → \"pending\" |\n719: | 20 | `TestMapConditionToStatus_NoReadyCondition` | mapConditionToStatus | Other condition type → \"pending\" |\n720: | 21 | `TestIsNotFoundError_Nil` | isNotFoundError | nil → false |\n721: | 22 | `TestIsNotFoundError_SandboxNotFound` | isNotFoundError | \"sandbox not found\" → true |\n722: | 23 | `TestIsNotFoundError_APINotFound` | isNotFoundError | apierrors.IsNotFound → true |\n723: | 24 | `TestIsNotFoundError_Other` | isNotFoundError | Other error → false |\n724: \n725: #### `codeinterpreter_test.go` — CodeInterpreter Reconciliation\n726: \n727: | # | Test Name | Function | Description |\n728: |---|-----------|----------|-------------|\n729: | 1 | `TestReconcileCodeInterpreter_InvalidKey` | reconcileCodeInterpreter | Bad key → error |\n730: | 2 | `TestReconcileCodeInterpreter_NotFound` | reconcileCodeInterpreter | IsNotFound → nil |\n731: | 3 | `TestReconcileCodeInterpreter_ListerError` | reconcileCodeInterpreter | Lister error → error + metrics |\n732: | 4 | `TestReconcileCodeInterpreter_MissingSessionID` | reconcileCodeInterpreter | No session-id label → log + nil |\n733: | 5 | `TestReconcileCodeInterpreter_DeletionTimestamp` | reconcileCodeInterpreter | Being deleted → DeleteSandboxBySessionID |\n734: | 6 | `TestReconcileCodeInterpreter_NewSandbox` | reconcileCodeInterpreter | Not in store → StoreSandbox |\n735: | 7 | `TestReconcileCodeInterpreter_StatusUpdate` | reconcileCodeInterpreter | Status changed → UpdateSandbox |\n736: | 8 | `TestReconcileCodeInterpreter_Terminated` | reconcileCodeInterpreter | Terminated → UpdateSandbox + DeleteSandboxBySessionID |\n737: | 9 | `TestReconcileCodeInterpreter_NoStatusChange` | reconcileCodeInterpreter | Status same → no store call |\n738: | 10 | `TestReconcileCodeInterpreter_WarmPoolActive` | reconcileCodeInterpreter | WarmPoolSize > 0 → log message |\n739: | 11 | `TestReconcileCodeInterpreter_WarmPoolNil` | reconcileCodeInterpreter | WarmPoolSize nil → no warm pool log |\n740: \n741: #### `pod_test.go` — Pod Reconciliation\n742: \n743: | # | Test Name | Function | Description |\n744: |---|-----------|----------|-------------|\n745: | 1 | `TestReconcilePod_InvalidKey` | reconcilePod | Bad key → error |\n746: | 2 | `TestReconcilePod_NotFound` | reconcilePod | IsNotFound → nil |\n747: | 3 | `TestReconcilePod_ListerError` | reconcilePod | Lister error → error + metrics |\n748: | 4 | `TestReconcilePod_NoSandboxLabel` | reconcilePod | No sandbox-name label → nil |\n749: | 5 | `TestReconcilePod_NotRunning` | reconcilePod | Phase != Running → nil |\n750: | 6 | `TestReconcilePod_NoPodIP` | reconcilePod | Running but no IP → nil |\n751: | 7 | `TestReconcilePod_NoMatchingSandbox` | reconcilePod | No sandbox in store → nil |\n752: | 8 | `TestReconcilePod_PodIPAlreadyMatches` | reconcilePod | Same IP → nil |\n753: | 9 | `TestReconcilePod_PodIPChanged` | reconcilePod | IP changed → UpdateSandbox with new IP + EntryPoints |\n754: | 10 | `TestReconcilePod_ListSandboxesError` | reconcilePod | Store error → error + metrics |\n755: | 11 | `TestReconcilePod_UpdateSandboxError` | reconcilePod | Update fails → error + metrics |\n756: | 12 | `TestBuildEntryPointsFromSandboxInfo` | buildEntryPointsFromSandboxInfo | Replaces IP, preserves port |\n757: | 13 | `TestBuildEntryPointsFromSandboxInfo_Empty` | buildEntryPointsFromSandboxInfo | No entry points → empty result |\n758: | 14 | `TestExtractPort_WithPort` | extractPort | `\"10.0.0.1:8080\"` → `\"8080\"` |\n759: | 15 | `TestExtractPort_NoPort` | extractPort | `\"8080\"` → `\"8080\"` |\n760: | 16 | `TestExtractPort_Empty` | extractPort | `\"\"` → `\"\"` |\n761: \n762: #### `event_handlers_test.go` — Event Handlers\n763: \n764: | # | Test Name | Function | Description |\n765: |---|-----------|----------|-------------|\n766: | 1 | `TestOnAgentRuntimeAdd_ValidObject` | onAgentRuntimeAdd | Enqueues key, records metrics |\n767: | 2 | `TestOnAgentRuntimeAdd_InvalidKey` | onAgentRuntimeAdd | MetaNamespaceKeyFunc fails → logs, no enqueue |\n768: | 3 | `TestOnAgentRuntimeUpdate_ValidObject` | onAgentRuntimeUpdate | Enqueues key from newObj |\n769: | 4 | `TestOnAgentRuntimeDelete_Normal` | onAgentRuntimeDelete | Enqueues key |\n770: | 5 | `TestOnAgentRuntimeDelete_Tombstone` | onAgentRuntimeDelete | DeletedFinalStateUnknown → extracts real obj |\n771: | 6 | `TestOnCodeInterpreterAdd_ValidObject` | onCodeInterpreterAdd | Enqueues key, records metrics |\n772: | 7 | `TestOnCodeInterpreterUpdate_ValidObject` | onCodeInterpreterUpdate | Enqueues key from newObj |\n773: | 8 | `TestOnCodeInterpreterDelete_Normal` | onCodeInterpreterDelete | Enqueues key |\n774: | 9 | `TestOnCodeInterpreterDelete_Tombstone` | onCodeInterpreterDelete | Tombstone handling |\n775: | 10 | `TestOnPodAdd_WithSandboxLabel` | onPodAdd | Has sandbox-name label → enqueue |\n776: | 11 | `TestOnPodAdd_NoSandboxLabel` | onPodAdd | No sandbox-name label → no enqueue |\n777: | 12 | `TestOnPodAdd_InvalidType` | onPodAdd | Non-Pod object → no enqueue |\n778: | 13 | `TestOnPodUpdate_NotRunningToRunning` | onPodUpdate | Phase change → enqueue |\n779: | 14 | `TestOnPodUpdate_IPChanged` | onPodUpdate | IP changed → enqueue |\n780: | 15 | `TestOnPodUpdate_NoChange` | onPodUpdate | No relevant change → no enqueue |\n781: | 16 | `TestOnPodUpdate_NoSandboxLabel` | onPodUpdate | No sandbox-name label → no enqueue |\n782: | 17 | `TestOnPodUpdate_InvalidType` | onPodUpdate | Non-Pod objects → no enqueue |\n783: | 18 | `TestOnPodDelete_Normal` | onPodDelete | Logs deletion, no enqueue |\n784: | 19 | `TestOnPodDelete_Tombstone` | onPodDelete | Tombstone handling |\n785: | 20 | `TestOnPodDelete_InvalidType` | onPodDelete | Non-Pod → no log |\n786: | 21 | `TestEventHandlers_NilMetricsRecorder` | All handlers | No panic with nil metrics |\n787: \n788: ### 5.3 Mocking Strategy\n789: \n790: | Dependency | Mock Approach | Rationale |\n791: |-----------|---------------|-----------|\n792: | `Store` (handler) | Inline struct with configurable errors | Already tested in sandbox_delete_test.go |\n793: | `Store` (reconciler) | `mockReconcilerStore` with error injection fields | Different signature, needs separate mock |\n794: | `MetricsRecorder` | `mockMetricsRecorder` with call counters | Verifies correct metrics are recorded |\n795: | `AgentRuntimeLister` | Map-backed mock with getErr injection | Avoids real informer setup |\n796: | `CodeInterpreterLister` | Map-backed mock with getErr injection | Same pattern |\n797: | `PodLister` | Map-backed mock with getErr injection | Same pattern |\n798: | `dynamic.Interface` | `dynamicfake.NewSimpleDynamicClient` with reactors | Standard K8s fake client |\n799: | `kubernetes.Interface` | `kubefake.NewSimpleClientset` | Standard K8s fake clientset |\n800: | `SandboxReconcilerWatcher` | Mock with pre-configured channel behavior | Controls watch timing/results |\n801: | `TokenCache` | Mock with configurable client/error | Isolates auth logic |\n802: | `UserClientFactory` | Mock with configurable client/error | Isolates client creation |\n803: | `SharedInformerFactory` | Partial mock (interface embedding) | Only need AddEventHandler verification |\n804: | `workqueue.RateLimitingInterface` | `workqueue.NewNamedRateLimitingQueue` (real) | Real queue is simple enough |\n805: \n806: ### 5.4 Test Execution\n807: \n808: ```bash\n809: # Run all workloadmanager tests\n810: go test ./pkg/workloadmanager/... -v -count=1\n811: \n812: # Run handler tests only\n813: go test ./pkg/workloadmanager/handler/... -v -count=1\n814: \n815: # Run reconciler tests only\n816: go test ./pkg/workloadmanager/reconciler/... -v -count=1\n817: \n818: # Run with coverage\n819: go test ./pkg/workloadmanager/... -coverprofile=coverage.out -count=1\n820: go tool cover -html=coverage.out -o coverage.html\n821: \n822: # Target: >80% statement coverage for pkg/workloadmanager\n823: ```\n824: \n825: ### 5.5 Coverage Targets\n826: \n827: | Sub-package | Current | Target |\n828: |-------------|---------|--------|\n829: | `handler/` | ~45% (delete + lifecycle) | >85% |\n830: | `reconciler/` | ~15% (metrics only) | >80% |\n831: | `response/` | ~95% | Maintain |\n832: | **Overall** | ~35% | >80% |\n833: \n834: ### 5.6 Risk Areas\n835: \n836: | Risk | Mitigation |\n837: |------|-----------|\n838: | `sandbox_create.go` has long methods with many branches | Test each branch independently with focused mocks |\n839: | Reconciler uses real informers internally | Use mock informer factory that only registers handlers; test sync logic separately from informer lifecycle |\n840: | `WatchSandboxOnce` uses goroutines with polling | Test channel behavior with mock listers; verify timeout with short deadline |\n841: | Two different Store interfaces | Clearly separate mock types; document which interface each mock implements |\n842: | `rollbackCR` has its own context timeout | Test with mock context that can be cancelled |\n843: | Random string generation (`RandString`) | Test length and charset, not specific values |\n\n(End of file - total 843 lines)\n</content>","metadata":{"preview":"# AR-038: WorkloadManager Go 单元测试 — Design\n\n## 1. Architecture\n\n### 1.1 Purpose\n\nThis AR covers comprehensive Go unit tests for the `pkg/workloadmanager` module of AgentCube. The workloadmanager package is the control plane API server responsible for sandbox lifecycle management (create, delete, reconcile) for AgentRuntime and CodeInterpreter workloads.\n\n### 1.2 Scope\n\n| Sub-package | Files | Status |\n|-------------|-------|--------|\n| `handler/sandbox_create.go` | 693 lines | **No tests** — primary gap |\n| `handler/sandbox_delete.go` | 216 lines | Covered (387 lines of tests) |\n| `handler/sandbox_lifecycle.go` | 679 lines | Covered (696 lines of tests) |\n| `handler/models.go` | 71 lines | Partially covered via delete tests |\n| `handler/constants.go` | 69 lines | Indirectly covered |\n| `reconciler/reconciler.go` | 227 lines | **No tests** — primary gap |\n| `reconciler/sync.go` | 125 lines | **No tests** — primary gap |\n| `reconciler/agentruntime.go` | 127 lines | **No tests** — primary gap |","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/design.md","time":{"start":1775892678252,"end":1775892678260}}}}
{"type":"tool_use","timestamp":1775892679623,"sessionID":"ses_2848c743dffeBSEEKFJu9e5mea","part":{"id":"prt_d7b73c6fd001r3yooKdhh9ru26","messageID":"msg_d7b73b541001eQA01Zdy7IGYzp","sessionID":"ses_2848c743dffeBSEEKFJu9e5mea","type":"tool","tool":"read","callID":"call_64f7d57a11604bfbb7ece899","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/design.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/design.md</path>\n<type>file</type>\n<content>\n1: # AgentCube Python SDK — Design\n2: \n3: Source root: `/tmp/agentcube-ref/sdk-python/`.\n4: \n5: ## Package layout\n6: \n7: | Path | Role |\n8: |------|------|\n9: | `pyproject.toml` | Package `agentcube-sdk`, dependencies |\n10: | `agentcube/__init__.py` | Public exports |\n11: | `agentcube/code_interpreter.py` | `CodeInterpreterClient` |\n12: | `agentcube/agent_runtime.py` | `AgentRuntimeClient` |\n13: | `agentcube/exceptions.py` | Exception classes |\n14: | `agentcube/clients/__init__.py` | Re-exports client classes |\n15: | `agentcube/clients/control_plane.py` | `ControlPlaneClient` |\n16: | `agentcube/clients/code_interpreter_data_plane.py` | `CodeInterpreterDataPlaneClient` |\n17: | `agentcube/clients/agent_runtime_data_plane.py` | `AgentRuntimeDataPlaneClient` |\n18: | `agentcube/utils/http.py` | `create_session` |\n19: | `agentcube/utils/utils.py` | `read_token_from_file` |\n20: | `agentcube/utils/log.py` | `get_logger` |\n21: | `agentcube/utils/__init__.py` | Empty (module marker) |\n22: | `examples/basic_usage.py`, `examples/agent_runtime_usage.py`, `scripts/e2e_picod_test.py`, `tests/*.py` | Non-library artifacts |\n23: \n24: ## Public exports (`agentcube/__init__.py`)\n25: \n26: ```python\n27: from .code_interpreter import CodeInterpreterClient\n28: from .agent_runtime import AgentRuntimeClient\n29: \n30: __all__ = [\"CodeInterpreterClient\", \"AgentRuntimeClient\"]\n31: ```\n32: \n33: `agentcube/clients/__init__.py` additionally exports (not in root `__all__`):\n34: \n35: ```python\n36: __all__ = [\n37:     \"ControlPlaneClient\",\n38:     \"CodeInterpreterDataPlaneClient\",\n39:     \"AgentRuntimeDataPlaneClient\",\n40: ]\n41: ```\n42: \n43: ## Configuration (no single `Configuration` class)\n44: \n45: There is **no** dedicated configuration dataclass. Defaults and environment resolution are distributed across:\n46: \n47: | Component | Resolved settings |\n48: |-----------|-------------------|\n49: | `ControlPlaneClient` | `base_url` ← `workload_manager_url` or `WORKLOAD_MANAGER_URL`; `Authorization` ← `auth_token` or SA token file; `timeout=120`, `connect_timeout=5.0`, `pool_connections=10`, `pool_maxsize=10` |\n50: | `CodeInterpreterClient` | `router_url` ← arg or `ROUTER_URL` (required); `workload_manager_url` / `auth_token` passed to `ControlPlaneClient`; `name`, `namespace`, `ttl`, `verbose`, `session_id` |\n51: | `CodeInterpreterDataPlaneClient` | `timeout=120`, `connect_timeout=5.0`, `pool_connections=10`, `pool_maxsize=10`; `base_url` from `base_url` **or** `router_url`+`namespace`+`cr_name` |\n52: | `AgentRuntimeClient` | `router_url` ← arg or `ROUTER_URL`; `timeout=120`, `connect_timeout=5.0` passed to data plane |\n53: | `AgentRuntimeDataPlaneClient` | same timeout defaults as above |\n54: \n55: ## `CodeInterpreterClient` (`agentcube/code_interpreter.py`)\n56: \n57: ```python\n58: class CodeInterpreterClient:\n59:     def __init__(\n60:         self,\n61:         name: str = \"my-interpreter\",\n62:         namespace: str = \"default\",\n63:         ttl: int = 3600,\n64:         workload_manager_url: Optional[str] = None,\n65:         router_url: Optional[str] = None,\n66:         auth_token: Optional[str] = None,\n67:         verbose: bool = False,\n68:         session_id: Optional[str] = None,\n69:     ): ...\n70: \n71:     def _init_data_plane(self) -> None: ...\n72: \n73:     def __enter__(self): ...\n74:     def __exit__(self, exc_type, exc_val, exc_tb) -> None: ...\n75: \n76:     def stop(self) -> None: ...\n77: \n78:     def execute_command(self, command: str, timeout: Optional[float] = None) -> str: ...\n79:     def run_code(self, language: str, code: str, timeout: Optional[float] = None) -> str: ...\n80:     def write_file(self, content: str, remote_path: str) -> None: ...\n81:     def upload_file(self, local_path: str, remote_path: str) -> None: ...\n82:     def download_file(self, remote_path: str, local_path: str) -> None: ...\n83:     def list_files(self, path: str = \".\"): ...\n84: ```\n85: \n86: **Fields set on instance:** `name`, `namespace`, `ttl`, `verbose`, `logger`, `cp_client`, `router_url`, `session_id`, `dp_client`.\n87: \n88: ## `AgentRuntimeClient` (`agentcube/agent_runtime.py`)\n89: \n90: ```python\n91: class AgentRuntimeClient:\n92:     def __init__(\n93:         self,\n94:         agent_name: str,\n95:         namespace: str = \"default\",\n96:         router_url: Optional[str] = None,\n97:         verbose: bool = False,\n98:         session_id: Optional[str] = None,\n99:         timeout: int = 120,\n100:         connect_timeout: float = 5.0,\n101:     ): ...\n102: \n103:     def __enter__(self): ...\n104:     def __exit__(self, exc_type, exc_val, exc_tb) -> None: ...\n105: \n106:     def invoke(self, payload: Dict[str, Any], timeout: Optional[float] = None) -> Any: ...\n107: \n108:     def close(self) -> None: ...\n109: ```\n110: \n111: **Fields:** `agent_name`, `namespace`, `timeout`, `connect_timeout`, `logger`, `router_url`, `session_id`, `dp_client`.\n112: \n113: ## `ControlPlaneClient` (`agentcube/clients/control_plane.py`)\n114: \n115: ```python\n116: class ControlPlaneClient:\n117:     def __init__(\n118:         self,\n119:         workload_manager_url: Optional[str] = None,\n120:         auth_token: Optional[str] = None,\n121:         timeout: int = 120,\n122:         connect_timeout: float = 5.0,\n123:         pool_connections: int = 10,\n124:         pool_maxsize: int = 10,\n125:     ): ...\n126: \n127:     def create_session(\n128:         self,\n129:         name: str = \"my-interpreter\",\n130:         namespace: str = \"default\",\n131:         metadata: Optional[Dict[str, Any]] = None,\n132:         ttl: int = 3600,\n133:     ) -> str: ...\n134: \n135:     def delete_session(self, session_id: str) -> bool: ...\n136: \n137:     def close(self) -> None: ...\n138: ```\n139: \n140: ### Control plane — HTTP\n141: \n142: | Method | Path | Notes |\n143: |--------|------|-------|\n144: | `POST` | `{base_url}/v1/code-interpreter` | JSON body: `name`, `namespace`, `ttl`, `metadata` |\n145: | `DELETE` | `{base_url}/v1/code-interpreter/sessions/{session_id}` | 404 treated as success in `delete_session` |\n146: \n147: **Headers (default on `self.session`):**\n148: \n149: - `Content-Type`: `application/json`\n150: - `Authorization`: `Bearer {token}` if token non-empty\n151: \n152: **Timeout:** `(connect_timeout, timeout)` on each request.\n153: \n154: ## `CodeInterpreterDataPlaneClient` (`agentcube/clients/code_interpreter_data_plane.py`)\n155: \n156: ```python\n157: class CodeInterpreterDataPlaneClient:\n158:     def __init__(\n159:         self,\n160:         session_id: str,\n161:         router_url: Optional[str] = None,\n162:         namespace: Optional[str] = None,\n163:         cr_name: Optional[str] = None,\n164:         base_url: Optional[str] = None,\n165:         timeout: int = 120,\n166:         connect_timeout: float = 5.0,\n167:         pool_connections: int = 10,\n168:         pool_maxsize: int = 10,\n169:     ): ...\n170: \n171:     def _request(self, method: str, endpoint: str, body: Optional[bytes] = None, **kwargs) -> requests.Response: ...\n172: \n173:     def execute_command(self, command: Union[str, List[str]], timeout: Optional[float] = None) -> str: ...\n174:     def run_code(self, language: str, code: str, timeout: Optional[float] = None) -> str: ...\n175:     def write_file(self, content: str, remote_path: str) -> None: ...\n176:     def upload_file(self, local_path: str, remote_path: str) -> None: ...\n177:     def download_file(self, remote_path: str, local_path: str) -> None: ...\n178:     def list_files(self, path: str = \".\") -> Any: ...\n179:     def close(self) -> None: ...\n180: ```\n181: \n182: ### Data plane (Code Interpreter) — base URL\n183: \n184: If `base_url` is not provided:\n185: \n186: ```text\n187: base_path = \"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\"\n188: self.base_url = urljoin(router_url, base_path)\n189: ```\n190: \n191: ### Data plane — HTTP (relative to `self.base_url`)\n192: \n193: | Method | Relative path | Body / params |\n194: |--------|---------------|---------------|\n195: | `POST` | `api/execute` | JSON `{\"command\": [...], \"timeout\": \"<n>s\"}` |\n196: | `POST` | `api/files` | JSON `{\"path\", \"content\" (base64), \"mode\": \"0644\"}` |\n197: | `POST` | `api/files` (multipart) | `files={'file': ...}`, `data={'path', 'mode'}` |\n198: | `GET` | `api/files/{clean_path}` | `stream=True` for download (`clean_path = remote_path.lstrip(\"/\")`) |\n199: | `GET` | `api/files` | query `path` |\n200: \n201: **Headers:**\n202: \n203: - Default session header: `x-agentcube-session-id: {session_id}`\n204: - JSON requests: `Content-Type: application/json` when `body` is set in `_request`\n205: - Multipart upload: `x-agentcube-session-id` only (no JSON Content-Type on the outer request)\n206: \n207: **Note:** Docstring states Router handles JWT; SDK does not set `Authorization` on data plane.\n208: \n209: ## `AgentRuntimeDataPlaneClient` (`agentcube/clients/agent_runtime_data_plane.py`)\n210: \n211: ```python\n212: class AgentRuntimeDataPlaneClient:\n213:     SESSION_HEADER = \"x-agentcube-session-id\"\n214: \n215:     def __init__(\n216:         self,\n217:         router_url: str,\n218:         namespace: str,\n219:         agent_name: str,\n220:         timeout: int = 120,\n221:         connect_timeout: float = 5.0,\n222:         pool_connections: int = 10,\n223:         pool_maxsize: int = 10,\n224:     ): ...\n225: \n226:     def bootstrap_session_id(self) -> str: ...\n227: \n228:     def invoke(\n229:         self,\n230:         session_id: str,\n231:         payload: Dict[str, Any],\n232:         timeout: Optional[float] = None,\n233:     ) -> requests.Response: ...\n234: \n235:     def close(self) -> None: ...\n236: ```\n237: \n238: ### Data plane (Agent Runtime) — base URL\n239: \n240: ```text\n241: base_path = f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n242: self.base_url = urljoin(router_url, base_path)\n243: ```\n244: \n245: ### Data plane — HTTP\n246: \n247: | Method | URL | Headers | Body |\n248: |--------|-----|---------|------|\n249: | `GET` | `self.base_url` | (session default headers only) | — |\n250: | `POST` | `self.base_url` | `x-agentcube-session-id`, `Content-Type: application/json` | `json=payload` |\n251: \n252: **Timeouts:** `(connect_timeout, timeout)` where `timeout` for `invoke` read side is the method argument or `self.timeout`.\n253: \n254: ## `create_session` (`agentcube/utils/http.py`)\n255: \n256: ```python\n257: def create_session(\n258:     pool_connections: int = 10,\n259:     pool_maxsize: int = 10,\n260: ) -> requests.Session: ...\n261: ```\n262: \n263: Mounts `HTTPAdapter` for `http://` and `https://`.\n264: \n265: ## `read_token_from_file` (`agentcube/utils/utils.py`)\n266: \n267: ```python\n268: def read_token_from_file(file_path: str) -> str: ...\n269: ```\n270: \n271: Returns file contents stripped, or `\"\"` on `FileNotFoundError`.\n272: \n273: ## `get_logger` (`agentcube/utils/log.py`)\n274: \n275: ```python\n276: def get_logger(name: str, level: Union[int, str] = logging.INFO) -> logging.Logger: ...\n277: ```\n278: \n279: ## Exception hierarchy (`agentcube/exceptions.py`)\n280: \n281: ```python\n282: class AgentCubeError(Exception):\n283:     \"\"\"Base exception for AgentCube SDK\"\"\"\n284:     pass\n285: \n286: class CommandExecutionError(AgentCubeError):\n287:     def __init__(self, exit_code, stderr, command=None):\n288:         self.exit_code = exit_code\n289:         self.stderr = stderr\n290:         self.command = command\n291:         super().__init__(f\"Command failed (exit {exit_code}): {stderr}\")\n292: \n293: class SessionError(AgentCubeError):\n294:     \"\"\"Raised when session creation or management fails\"\"\"\n295:     pass\n296: \n297: class DataPlaneError(AgentCubeError):\n298:     \"\"\"Raised when Data Plane operations fail\"\"\"\n299:     pass\n300: ```\n301: \n302: ## Dependencies (`sdk-python/pyproject.toml`)\n303: \n304: ```toml\n305: dependencies = [\n306:     \"requests\",\n307:     \"PyJWT>=2.0.0\",\n308:     \"cryptography\",\n309: ]\n310: ```\n311: \n312: - `requires-python = \">=3.10\"`\n313: - Build: `setuptools>=61.0`, `wheel`; backend `setuptools.build_meta`\n314: - Packages: `where = [\".\"]`, `include = [\"agentcube*\"]`, `namespaces = false`\n\n(End of file - total 314 lines)\n</content>","metadata":{"preview":"# AgentCube Python SDK — Design\n\nSource root: `/tmp/agentcube-ref/sdk-python/`.\n\n## Package layout\n\n| Path | Role |\n|------|------|\n| `pyproject.toml` | Package `agentcube-sdk`, dependencies |\n| `agentcube/__init__.py` | Public exports |\n| `agentcube/code_interpreter.py` | `CodeInterpreterClient` |\n| `agentcube/agent_runtime.py` | `AgentRuntimeClient` |\n| `agentcube/exceptions.py` | Exception classes |\n| `agentcube/clients/__init__.py` | Re-exports client classes |\n| `agentcube/clients/control_plane.py` | `ControlPlaneClient` |\n| `agentcube/clients/code_interpreter_data_plane.py` | `CodeInterpreterDataPlaneClient` |\n| `agentcube/clients/agent_runtime_data_plane.py` | `AgentRuntimeDataPlaneClient` |\n| `agentcube/utils/http.py` | `create_session` |\n| `agentcube/utils/utils.py` | `read_token_from_file` |\n| `agentcube/utils/log.py` | `get_logger` |","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/design.md","time":{"start":1775892679607,"end":1775892679621}}}}
{"type":"tool_use","timestamp":1775892680960,"sessionID":"ses_2848c743dffeBSEEKFJu9e5mea","part":{"id":"prt_d7b73cc36001jGaYqxfOYhCr3w","messageID":"msg_d7b73b541001eQA01Zdy7IGYzp","sessionID":"ses_2848c743dffeBSEEKFJu9e5mea","type":"tool","tool":"read","callID":"call_a7e49bc31d9840f6bb4098e6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/spec.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/spec.md</path>\n<type>file</type>\n<content>\n1: # AgentCube Python SDK Specification\n2: \n3: ## Purpose\n4: \n5: Python client library (`agentcube-sdk`) for creating Code Interpreter sessions via the Workload Manager (control plane) and executing code/files via the Router (data plane), plus invoking AgentRuntime workloads through the Router.\n6: \n7: ## Requirements\n8: \n9: ### Requirement: `CodeInterpreterClient` lifecycle\n10: The system SHALL construct a client that either reuses `session_id` or creates a session via `ControlPlaneClient.create_session`, then initializes `CodeInterpreterDataPlaneClient` with header `x-agentcube-session-id`.\n11: \n12: #### Scenario: Context manager cleanup\n13: - **GIVEN** `CodeInterpreterClient` is used as a context manager\n14: - **WHEN** the block exits (with or without exception)\n15: - **THEN** `__exit__` SHALL call `stop()`, which closes the data-plane session, deletes the control-plane session if `session_id` was set, and closes the control plane HTTP session\n16: \n17: #### Scenario: Data plane init failure after session create\n18: - **GIVEN** `session_id` was not provided and `create_session` succeeded\n19: - **WHEN** `_init_data_plane()` raises\n20: - **THEN** the client SHALL log a warning, call `delete_session(session_id)`, set `session_id` to `None`, and re-raise\n21: \n22: #### Scenario: Router URL required\n23: - **GIVEN** neither `router_url` nor environment variable `ROUTER_URL` is set\n24: - **WHEN** `CodeInterpreterClient.__init__` runs\n25: - **THEN** it SHALL raise `ValueError` explaining that Router URL must be provided via argument or `ROUTER_URL`\n26: \n27: ### Requirement: Code Interpreter — execute, files, stop\n28: The system SHALL expose `execute_command`, `run_code`, `write_file`, `upload_file`, `download_file`, `list_files`, and `stop` delegating to the data plane client where applicable.\n29: \n30: #### Scenario: Command non-zero exit\n31: - **GIVEN** `execute_command` receives a response with `exit_code != 0`\n32: - **WHEN** the response JSON is parsed\n33: - **THEN** the system SHALL raise `CommandExecutionError` with `exit_code`, `stderr`, and `command`\n34: \n35: #### Scenario: Python code execution path\n36: - **GIVEN** `language` is `python`, `py`, or `python3`\n37: - **WHEN** `run_code` runs\n38: - **THEN** the system SHALL write a timestamped `.py` file via `write_file` and execute `python3 <file>` through `execute_command`\n39: \n40: ### Requirement: `AgentRuntimeClient` lifecycle\n41: The system SHALL bootstrap or reuse `session_id` from the Agent Runtime invocation endpoint via `GET` on the base invocation URL, then `POST` JSON payloads with session header.\n42: \n43: #### Scenario: Context manager\n44: - **GIVEN** `AgentRuntimeClient` is used as a context manager\n45: - **WHEN** the block exits\n46: - **THEN** `close()` SHALL close the underlying `requests.Session`\n47: \n48: #### Scenario: Bootstrap session id\n49: - **GIVEN** `session_id` is not provided\n50: - **WHEN** the client initializes\n51: - **THEN** it SHALL `GET` `{router}/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/` and read header `x-agentcube-session-id`; if missing, raise `ValueError` with message `Missing required response header: x-agentcube-session-id`\n52: \n53: #### Scenario: Invoke without session\n54: - **GIVEN** `session_id` is falsy\n55: - **WHEN** `invoke` is called\n56: - **THEN** it SHALL raise `ValueError(\"AgentRuntime session_id is not initialized\")`\n57: \n58: ### Requirement: HTTP client contracts — control plane\n59: The system SHALL use `requests.Session` with connection pooling (`HTTPAdapter`) for Workload Manager calls.\n60: \n61: #### Scenario: Create session\n62: - **GIVEN** `ControlPlaneClient.create_session(name, namespace, metadata=None, ttl=3600)`\n63: - **WHEN** the request succeeds\n64: - **THEN** the client SHALL `POST {base_url}/v1/code-interpreter` with JSON body `{\"name\",\"namespace\",\"ttl\",\"metadata\"}` and return `data[\"sessionId\"]` or raise `ValueError` if absent\n65: \n66: #### Scenario: Delete session\n67: - **GIVEN** `delete_session(session_id)`\n68: - **WHEN** the server returns 404\n69: - **THEN** the method SHALL return `True`; on other failures it SHALL log and return `False`\n70: \n71: #### Scenario: Workload Manager URL and auth\n72: - **GIVEN** `workload_manager_url` and `auth_token` may be omitted\n73: - **WHEN** the client initializes\n74: - **THEN** `base_url` SHALL resolve from `workload_manager_url` or `WORKLOAD_MANAGER_URL`; token SHALL resolve from `auth_token` or `/var/run/secrets/kubernetes.io/serviceaccount/token` via `read_token_from_file`, and if present set `Authorization: Bearer {token}`\n75: \n76: ### Requirement: HTTP client contracts — data plane (Code Interpreter)\n77: The system SHALL target Router-relative paths under `{base_url}` derived from `urljoin(router_url, \"/v1/namespaces/{ns}/code-interpreters/{cr_name}/invocations/\")` unless `base_url` is passed explicitly.\n78: \n79: #### Scenario: Execute command\n80: - **WHEN** `execute_command` posts to `api/execute`\n81: - **THEN** the body SHALL be JSON `{\"command\": [...], \"timeout\": \"<n>s\"}` and read timeout SHALL be `timeout_value + 2.0` seconds when numeric (to avoid `ReadTimeout` before PicoD returns exit 124)\n82: \n83: #### Scenario: Files API\n84: - **WHEN** `write_file` runs\n85: - **THEN** it SHALL `POST api/files` with base64 `content`, `path`, `mode` `\"0644\"`\n86: - **WHEN** `upload_file` runs\n87: - **THEN** it SHALL `POST` multipart to `api/files` with headers including `x-agentcube-session-id`\n88: \n89: ### Requirement: HTTP client contracts — data plane (Agent Runtime)\n90: The system SHALL `POST` JSON to the invocation base URL with headers `x-agentcube-session-id` and `Content-Type: application/json`.\n91: \n92: #### Scenario: Invoke timeout tuple\n93: - **GIVEN** `invoke(..., timeout=None)`\n94: - **WHEN** the request is sent\n95: - **THEN** `timeout` SHALL be `(connect_timeout, self.timeout)` where `self.timeout` defaults to `120`\n96: \n97: ### Requirement: Session header management\n98: The system SHALL use lowercase header name `x-agentcube-session-id` for SDK Router requests (`CodeInterpreterDataPlaneClient` default session header; `AgentRuntimeDataPlaneClient` uses class constant `SESSION_HEADER = \"x-agentcube-session-id\"`).\n99: \n100: #### Scenario: Code Interpreter session header\n101: - **GIVEN** `CodeInterpreterDataPlaneClient` is constructed\n102: - **WHEN** any `_request` or upload runs\n103: - **THEN** the session SHALL include `x-agentcube-session-id: {session_id}` (upload sets it explicitly on the multipart POST)\n104: \n105: ### Requirement: Exception hierarchy\n106: The system SHALL define `AgentCubeError`, `CommandExecutionError`, `SessionError`, and `DataPlaneError` in `agentcube.exceptions`.\n107: \n108: #### Scenario: Command failure\n109: - **GIVEN** remote command returns non-zero exit code in JSON\n110: - **WHEN** `execute_command` processes the response\n111: - **THEN** it SHALL raise `CommandExecutionError` (subclass of `AgentCubeError`)\n112: \n113: #### Scenario: SessionError / DataPlaneError usage\n114: - **GIVEN** the current package sources under `agentcube/`\n115: - **WHEN** searching for `raise SessionError` / `raise DataPlaneError`\n116: - **THEN** these classes are defined for extension but not raised by the core client modules in the extracted tree (callers MAY rely on `ValueError`, `requests` exceptions, or `CommandExecutionError`)\n117: \n118: ### Requirement: Timeout behavior\n119: The system SHALL default control-plane and data-plane read timeouts to `120` seconds and connect timeout to `5.0` seconds unless overridden per call.\n120: \n121: #### Scenario: Per-call override for code execution\n122: - **GIVEN** `execute_command(command, timeout=None)`\n123: - **WHEN** `timeout` is `None`\n124: - **THEN** the effective timeout value SHALL default to `self.timeout` (`120`) for constructing the PicoD timeout string and read-timeout buffer logic\n125: \n126: #### Scenario: AgentRuntimeClient constructor timeouts\n127: - **GIVEN** `AgentRuntimeClient(..., timeout=120, connect_timeout=5.0)`\n128: - **WHEN** `invoke` is called without `timeout`\n129: - **THEN** read timeout SHALL be `120` (instance default)\n130: \n131: ---\n132: \n133: **Public package surface:** `agentcube/__init__.py` exports only `CodeInterpreterClient` and `AgentRuntimeClient` in `__all__`.\n\n(End of file - total 133 lines)\n</content>","metadata":{"preview":"# AgentCube Python SDK Specification\n\n## Purpose\n\nPython client library (`agentcube-sdk`) for creating Code Interpreter sessions via the Workload Manager (control plane) and executing code/files via the Router (data plane), plus invoking AgentRuntime workloads through the Router.\n\n## Requirements\n\n### Requirement: `CodeInterpreterClient` lifecycle\nThe system SHALL construct a client that either reuses `session_id` or creates a session via `ControlPlaneClient.create_session`, then initializes `CodeInterpreterDataPlaneClient` with header `x-agentcube-session-id`.\n\n#### Scenario: Context manager cleanup\n- **GIVEN** `CodeInterpreterClient` is used as a context manager\n- **WHEN** the block exits (with or without exception)\n- **THEN** `__exit__` SHALL call `stop()`, which closes the data-plane session, deletes the control-plane session if `session_id` was set, and closes the control plane HTTP session\n\n#### Scenario: Data plane init failure after session create\n- **GIVEN** `session_id` was not provided and `create_session` succeeded\n- **WHEN** `_init_data_plane()` raises\n- **THEN** the client SHALL log a warning, call `delete_session(session_id)`, set `session_id` to `None`, and re-raise","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/spec.md","time":{"start":1775892680947,"end":1775892680958}}}}
{"type":"tool_use","timestamp":1775892682129,"sessionID":"ses_2848c743dffeBSEEKFJu9e5mea","part":{"id":"prt_d7b73d170001IMuvprTLvb7Amc","messageID":"msg_d7b73b541001eQA01Zdy7IGYzp","sessionID":"ses_2848c743dffeBSEEKFJu9e5mea","type":"tool","tool":"read","callID":"call_de69a58af2884765a7041c60","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterClient.\"\"\"\n2: \n3: import os\n4: from unittest.mock import MagicMock, patch\n5: \n6: import pytest\n7: \n8: from agentcube.code_interpreter import CodeInterpreterClient\n9: from agentcube.exceptions import CommandExecutionError\n10: \n11: \n12: # ---------------------------------------------------------------------------\n13: # T-1: CodeInterpreterClient — Initialization\n14: # ---------------------------------------------------------------------------\n15: \n16: \n17: class TestCodeInterpreterClientInit:\n18:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n19:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n20:     def test_creates_session_when_no_session_id_provided(\n21:         self, mock_dp_cls, mock_cp_cls\n22:     ):\n23:         mock_cp_instance = MagicMock()\n24:         mock_cp_instance.create_session.return_value = \"new-session-id\"\n25:         mock_cp_cls.return_value = mock_cp_instance\n26: \n27:         mock_dp_instance = MagicMock()\n28:         mock_dp_cls.return_value = mock_dp_instance\n29: \n30:         client = CodeInterpreterClient(\n31:             name=\"my-interpreter\",\n32:             namespace=\"default\",\n33:             router_url=\"http://router:8080\",\n34:         )\n35: \n36:         mock_cp_instance.create_session.assert_called_once_with(\n37:             name=\"my-interpreter\",\n38:             namespace=\"default\",\n39:             ttl=3600,\n40:         )\n41:         assert client.session_id == \"new-session-id\"\n42:         mock_dp_cls.assert_called_once()\n43:         client.stop()\n44: \n45:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n46:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n47:     def test_reuses_session_id_when_provided(self, mock_dp_cls, mock_cp_cls):\n48:         mock_cp_instance = MagicMock()\n49:         mock_cp_cls.return_value = mock_cp_instance\n50: \n51:         mock_dp_instance = MagicMock()\n52:         mock_dp_cls.return_value = mock_dp_instance\n53: \n54:         client = CodeInterpreterClient(\n55:             session_id=\"existing-session\",\n56:             router_url=\"http://router:8080\",\n57:         )\n58: \n59:         mock_cp_instance.create_session.assert_not_called()\n60:         assert client.session_id == \"existing-session\"\n61:         client.stop()\n62: \n63:     def test_router_url_required_raises_value_error(self):\n64:         with patch.dict(os.environ, {}, clear=True):\n65:             os.environ.pop(\"ROUTER_URL\", None)\n66:             with pytest.raises(ValueError) as exc_info:\n67:                 CodeInterpreterClient(session_id=\"sess-1\")\n68:         assert \"router_url must be provided\" in str(exc_info.value)\n69: \n70:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n71:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n72:     def test_router_url_from_environment(self, mock_dp_cls, mock_cp_cls):\n73:         mock_cp_instance = MagicMock()\n74:         mock_cp_cls.return_value = mock_cp_instance\n75: \n76:         mock_dp_instance = MagicMock()\n77:         mock_dp_cls.return_value = mock_dp_instance\n78: \n79:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://env-router:8080\"}):\n80:             client = CodeInterpreterClient(session_id=\"sess-1\")\n81:             assert client.router_url == \"http://env-router:8080\"\n82:             client.stop()\n83: \n84:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n85:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n86:     def test_verbose_true_creates_debug_logger(self, mock_dp_cls, mock_cp_cls):\n87:         mock_cp_instance = MagicMock()\n88:         mock_cp_cls.return_value = mock_cp_instance\n89: \n90:         mock_dp_instance = MagicMock()\n91:         mock_dp_cls.return_value = mock_dp_instance\n92: \n93:         client = CodeInterpreterClient(\n94:             session_id=\"sess-1\",\n95:             router_url=\"http://router:8080\",\n96:             verbose=True,\n97:         )\n98: \n99:         assert client.logger.level == 10  # logging.DEBUG\n100:         client.stop()\n101: \n102:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n103:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n104:     def test_verbose_false_creates_info_logger(self, mock_dp_cls, mock_cp_cls):\n105:         mock_cp_instance = MagicMock()\n106:         mock_cp_cls.return_value = mock_cp_instance\n107: \n108:         mock_dp_instance = MagicMock()\n109:         mock_dp_cls.return_value = mock_dp_instance\n110: \n111:         client = CodeInterpreterClient(\n112:             session_id=\"sess-1\",\n113:             router_url=\"http://router:8080\",\n114:             verbose=False,\n115:         )\n116: \n117:         assert client.logger.level == 20  # logging.INFO\n118:         client.stop()\n119: \n120:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n121:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n122:     def test_control_plane_client_constructed_with_params(\n123:         self, mock_dp_cls, mock_cp_cls\n124:     ):\n125:         mock_cp_instance = MagicMock()\n126:         mock_cp_instance.create_session.return_value = \"sess-1\"\n127:         mock_cp_cls.return_value = mock_cp_instance\n128: \n129:         mock_dp_instance = MagicMock()\n130:         mock_dp_cls.return_value = mock_dp_instance\n131: \n132:         client = CodeInterpreterClient(\n133:             name=\"custom-name\",\n134:             namespace=\"custom-ns\",\n135:             ttl=7200,\n136:             workload_manager_url=\"http://wm:8080\",\n137:             router_url=\"http://router:8080\",\n138:             auth_token=\"my-token\",\n139:         )\n140: \n141:         mock_cp_cls.assert_called_once_with(\n142:             workload_manager_url=\"http://wm:8080\",\n143:             auth_token=\"my-token\",\n144:             timeout=120,\n145:             connect_timeout=5.0,\n146:         )\n147:         client.stop()\n148: \n149: \n150: # ---------------------------------------------------------------------------\n151: # T-2: CodeInterpreterClient — Data plane init failure cleanup\n152: # ---------------------------------------------------------------------------\n153: \n154: \n155: class TestDataPlaneInitFailure:\n156:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n157:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n158:     def test_data_plane_init_failure_deletes_session_and_reraises(\n159:         self, mock_dp_cls, mock_cp_cls\n160:     ):\n161:         mock_cp_instance = MagicMock()\n162:         mock_cp_instance.create_session.return_value = \"new-session\"\n163:         mock_cp_cls.return_value = mock_cp_instance\n164: \n165:         mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n166: \n167:         with pytest.raises(RuntimeError):\n168:             CodeInterpreterClient(\n169:                 name=\"my-interpreter\",\n170:                 router_url=\"http://router:8080\",\n171:             )\n172: \n173:         mock_cp_instance.delete_session.assert_called_once_with(\"new-session\")\n174: \n175:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n176:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n177:     def test_data_plane_init_failure_sets_session_id_to_none(\n178:         self, mock_dp_cls, mock_cp_cls\n179:     ):\n180:         mock_cp_instance = MagicMock()\n181:         mock_cp_instance.create_session.return_value = \"new-session\"\n182:         mock_cp_cls.return_value = mock_cp_instance\n183: \n184:         mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n185: \n186:         try:\n187:             CodeInterpreterClient(\n188:                 name=\"my-interpreter\",\n189:                 router_url=\"http://router:8080\",\n190:             )\n191:         except RuntimeError:\n192:             pass\n193: \n194:         mock_cp_instance.create_session.return_value = None\n195:         assert mock_cp_instance.delete_session.called\n196: \n197: \n198: # ---------------------------------------------------------------------------\n199: # T-3: CodeInterpreterClient — Context manager\n200: # ---------------------------------------------------------------------------\n201: \n202: \n203: class TestContextManager:\n204:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n205:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n206:     def test_enter_returns_self(self, mock_dp_cls, mock_cp_cls):\n207:         mock_cp_instance = MagicMock()\n208:         mock_cp_cls.return_value = mock_cp_instance\n209: \n210:         mock_dp_instance = MagicMock()\n211:         mock_dp_cls.return_value = mock_dp_instance\n212: \n213:         client = CodeInterpreterClient(\n214:             session_id=\"sess-1\",\n215:             router_url=\"http://router:8080\",\n216:         )\n217: \n218:         assert client.__enter__() is client\n219:         client.stop()\n220: \n221:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n222:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n223:     def test_exit_calls_stop(self, mock_dp_cls, mock_cp_cls):\n224:         mock_cp_instance = MagicMock()\n225:         mock_cp_cls.return_value = mock_cp_instance\n226: \n227:         mock_dp_instance = MagicMock()\n228:         mock_dp_cls.return_value = mock_dp_instance\n229: \n230:         client = CodeInterpreterClient(\n231:             session_id=\"sess-1\",\n232:             router_url=\"http://router:8080\",\n233:         )\n234:         client.stop = MagicMock()\n235: \n236:         client.__exit__(None, None, None)\n237: \n238:         client.stop.assert_called_once()\n239: \n240:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n241:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n242:     def test_context_manager_with_statement(self, mock_dp_cls, mock_cp_cls):\n243:         mock_cp_instance = MagicMock()\n244:         mock_cp_instance.create_session.return_value = \"sess-ctx\"\n245:         mock_cp_cls.return_value = mock_cp_instance\n246: \n247:         mock_dp_instance = MagicMock()\n248:         mock_dp_cls.return_value = mock_dp_instance\n249: \n250:         with CodeInterpreterClient(\n251:             session_id=\"sess-ctx\",\n252:             router_url=\"http://router:8080\",\n253:         ) as client:\n254:             assert client.session_id == \"sess-ctx\"\n255: \n256:         mock_dp_instance.close.assert_called_once()\n257:         mock_cp_instance.delete_session.assert_called_once_with(\"sess-ctx\")\n258:         mock_cp_instance.close.assert_called_once()\n259: \n260:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n261:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n262:     def test_context_manager_exception_flow(self, mock_dp_cls, mock_cp_cls):\n263:         mock_cp_instance = MagicMock()\n264:         mock_cp_cls.return_value = mock_cp_instance\n265: \n266:         mock_dp_instance = MagicMock()\n267:         mock_dp_cls.return_value = mock_dp_instance\n268: \n269:         with pytest.raises(RuntimeError):\n270:             with CodeInterpreterClient(\n271:                 session_id=\"sess-ctx\",\n272:                 router_url=\"http://router:8080\",\n273:             ):\n274:                 raise RuntimeError(\"boom\")\n275: \n276:         mock_dp_instance.close.assert_called_once()\n277:         mock_cp_instance.delete_session.assert_called_once()\n278: \n279: \n280: # ---------------------------------------------------------------------------\n281: # T-4: CodeInterpreterClient — stop\n282: # ---------------------------------------------------------------------------\n283: \n284: \n285: class TestStop:\n286:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n287:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n288:     def stop_closes_dp_client(self, mock_dp_cls, mock_cp_cls):\n289:         mock_cp_instance = MagicMock()\n290:         mock_cp_cls.return_value = mock_cp_instance\n291: \n292:         mock_dp_instance = MagicMock()\n293:         mock_dp_cls.return_value = mock_dp_instance\n294: \n295:         client = CodeInterpreterClient(\n296:             session_id=\"sess-1\",\n297:             router_url=\"http://router:8080\",\n298:         )\n299:         client.stop()\n300: \n301:         mock_dp_instance.close.assert_called_once()\n302: \n303:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n304:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n305:     def stop_deletes_session(self, mock_dp_cls, mock_cp_cls):\n306:         mock_cp_instance = MagicMock()\n307:         mock_cp_cls.return_value = mock_cp_instance\n308: \n309:         mock_dp_instance = MagicMock()\n310:         mock_dp_cls.return_value = mock_dp_instance\n311: \n312:         client = CodeInterpreterClient(\n313:             session_id=\"sess-1\",\n314:             router_url=\"http://router:8080\",\n315:         )\n316:         client.stop()\n317: \n318:         mock_cp_instance.delete_session.assert_called_once_with(\"sess-1\")\n319: \n320:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n321:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n322:     def stop_closes_cp_client(self, mock_dp_cls, mock_cp_cls):\n323:         mock_cp_instance = MagicMock()\n324:         mock_cp_cls.return_value = mock_cp_instance\n325: \n326:         mock_dp_instance = MagicMock()\n327:         mock_dp_cls.return_value = mock_dp_instance\n328: \n329:         client = CodeInterpreterClient(\n330:             session_id=\"sess-1\",\n331:             router_url=\"http://router:8080\",\n332:         )\n333:         client.stop()\n334: \n335:         mock_cp_instance.close.assert_called_once()\n336: \n337:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n338:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n339:     def test_stop_is_idempotent(self, mock_dp_cls, mock_cp_cls):\n340:         mock_cp_instance = MagicMock()\n341:         mock_cp_cls.return_value = mock_cp_instance\n342: \n343:         mock_dp_instance = MagicMock()\n344:         mock_dp_cls.return_value = mock_dp_instance\n345: \n346:         client = CodeInterpreterClient(\n347:             session_id=\"sess-1\",\n348:             router_url=\"http://router:8080\",\n349:         )\n350:         client.stop()\n351:         client.stop()\n352:         client.stop()\n353: \n354:         assert mock_dp_instance.close.call_count == 1\n355:         assert mock_cp_instance.delete_session.call_count == 1\n356:         assert mock_cp_instance.close.call_count == 1\n357: \n358: \n359: # ---------------------------------------------------------------------------\n360: # T-5: CodeInterpreterClient — execute_command\n361: # ---------------------------------------------------------------------------\n362: \n363: \n364: class TestExecuteCommand:\n365:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n366:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n367:     def test_execute_command_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n368:         mock_cp_instance = MagicMock()\n369:         mock_cp_cls.return_value = mock_cp_instance\n370: \n371:         mock_dp_instance = MagicMock()\n372:         mock_dp_instance.execute_command.return_value = \"output\"\n373:         mock_dp_cls.return_value = mock_dp_instance\n374: \n375:         client = CodeInterpreterClient(\n376:             session_id=\"sess-1\",\n377:             router_url=\"http://router:8080\",\n378:         )\n379:         result = client.execute_command(\"echo hello\")\n380: \n381:         assert result == \"output\"\n382:         mock_dp_instance.execute_command.assert_called_once()\n383:         client.stop()\n384: \n385:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n386:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n387:     def test_execute_command_string_converted_to_list(self, mock_dp_cls, mock_cp_cls):\n388:         mock_cp_instance = MagicMock()\n389:         mock_cp_cls.return_value = mock_cp_instance\n390: \n391:         mock_dp_instance = MagicMock()\n392:         mock_dp_instance.execute_command.return_value = \"output\"\n393:         mock_dp_cls.return_value = mock_dp_instance\n394: \n395:         client = CodeInterpreterClient(\n396:             session_id=\"sess-1\",\n397:             router_url=\"http://router:8080\",\n398:         )\n399:         client.execute_command(\"echo hello\")\n400: \n401:         call_args = mock_dp_instance.execute_command.call_args\n402:         assert call_args[0][0] == [\"echo hello\"]\n403:         client.stop()\n404: \n405:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n406:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n407:     def test_execute_command_with_custom_timeout(self, mock_dp_cls, mock_cp_cls):\n408:         mock_cp_instance = MagicMock()\n409:         mock_cp_cls.return_value = mock_cp_instance\n410: \n411:         mock_dp_instance = MagicMock()\n412:         mock_dp_instance.execute_command.return_value = \"output\"\n413:         mock_dp_cls.return_value = mock_dp_instance\n414: \n415:         client = CodeInterpreterClient(\n416:             session_id=\"sess-1\",\n417:             router_url=\"http://router:8080\",\n418:         )\n419:         client.execute_command(\"sleep 10\", timeout=10.0)\n420: \n421:         call_args = mock_dp_instance.execute_command.call_args\n422:         assert call_args[1][\"timeout\"] == 12.0\n423:         client.stop()\n424: \n425:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n426:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n427:     def test_execute_command_raises_on_nonzero_exit(self, mock_dp_cls, mock_cp_cls):\n428:         mock_cp_instance = MagicMock()\n429:         mock_cp_cls.return_value = mock_cp_instance\n430: \n431:         mock_dp_instance = MagicMock()\n432:         mock_dp_instance.execute_command.side_effect = CommandExecutionError(\n433:             exit_code=1, stderr=\"error\", command=[\"ls\"]\n434:         )\n435:         mock_dp_cls.return_value = mock_dp_instance\n436: \n437:         client = CodeInterpreterClient(\n438:             session_id=\"sess-1\",\n439:             router_url=\"http://router:8080\",\n440:         )\n441: \n442:         with pytest.raises(CommandExecutionError) as exc_info:\n443:             client.execute_command(\"ls\")\n444: \n445:         assert exc_info.value.exit_code == 1\n446:         client.stop()\n447: \n448: \n449: # ---------------------------------------------------------------------------\n450: # T-6: CodeInterpreterClient — run_code\n451: # ---------------------------------------------------------------------------\n452: \n453: \n454: class TestRunCode:\n455:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n456:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n457:     def test_run_code_python_writes_file_and_executes(self, mock_dp_cls, mock_cp_cls):\n458:         mock_cp_instance = MagicMock()\n459:         mock_cp_cls.return_value = mock_cp_instance\n460: \n461:         mock_dp_instance = MagicMock()\n462:         mock_dp_instance.execute_command.return_value = \"hello\\n\"\n463:         mock_dp_cls.return_value = mock_dp_instance\n464: \n465:         client = CodeInterpreterClient(\n466:             session_id=\"sess-1\",\n467:             router_url=\"http://router:8080\",\n468:         )\n469:         result = client.run_code(\"python\", \"print('hello')\")\n470: \n471:         assert result == \"hello\\n\"\n472:         mock_dp_instance.write_file.assert_called_once()\n473:         mock_dp_instance.execute_command.assert_called_once()\n474:         client.stop()\n475: \n476:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n477:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n478:     def test_run_code_unsupported_language_raises(self, mock_dp_cls, mock_cp_cls):\n479:         mock_cp_instance = MagicMock()\n480:         mock_cp_cls.return_value = mock_cp_instance\n481: \n482:         mock_dp_instance = MagicMock()\n483:         mock_dp_cls.return_value = mock_dp_instance\n484: \n485:         client = CodeInterpreterClient(\n486:             session_id=\"sess-1\",\n487:             router_url=\"http://router:8080\",\n488:         )\n489: \n490:         with pytest.raises(ValueError) as exc_info:\n491:             client.run_code(\"ruby\", \"puts 'hi'\")\n492:         assert \"Unsupported language\" in str(exc_info.value)\n493:         client.stop()\n494: \n495: \n496: # ---------------------------------------------------------------------------\n497: # T-7: CodeInterpreterClient — File operations\n498: # ---------------------------------------------------------------------------\n499: \n500: \n501: class TestFileOperations:\n502:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n503:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n504:     def test_write_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n505:         mock_cp_instance = MagicMock()\n506:         mock_cp_cls.return_value = mock_cp_instance\n507: \n508:         mock_dp_instance = MagicMock()\n509:         mock_dp_cls.return_value = mock_dp_instance\n510: \n511:         client = CodeInterpreterClient(\n512:             session_id=\"sess-1\",\n513:             router_url=\"http://router:8080\",\n514:         )\n515:         client.write_file(\"content\", \"/tmp/test.txt\")\n516: \n517:         mock_dp_instance.write_file.assert_called_once_with(\"content\", \"/tmp/test.txt\")\n518:         client.stop()\n519: \n520:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n521:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n522:     def test_upload_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n523:         mock_cp_instance = MagicMock()\n524:         mock_cp_cls.return_value = mock_cp_instance\n525: \n526:         mock_dp_instance = MagicMock()\n527:         mock_dp_cls.return_value = mock_dp_instance\n528: \n529:         client = CodeInterpreterClient(\n530:             session_id=\"sess-1\",\n531:             router_url=\"http://router:8080\",\n532:         )\n533:         client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n534: \n535:         mock_dp_instance.upload_file.assert_called_once_with(\n536:             \"/local/file.txt\", \"/remote/file.txt\"\n537:         )\n538:         client.stop()\n539: \n540:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n541:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n542:     def test_download_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n543:         mock_cp_instance = MagicMock()\n544:         mock_cp_cls.return_value = mock_cp_instance\n545: \n546:         mock_dp_instance = MagicMock()\n547:         mock_dp_cls.return_value = mock_dp_instance\n548: \n549:         client = CodeInterpreterClient(\n550:             session_id=\"sess-1\",\n551:             router_url=\"http://router:8080\",\n552:         )\n553:         client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n554: \n555:         mock_dp_instance.download_file.assert_called_once_with(\n556:             \"/remote/file.txt\", \"/local/file.txt\"\n557:         )\n558:         client.stop()\n559: \n560:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n561:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n562:     def test_list_files_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n563:         mock_cp_instance = MagicMock()\n564:         mock_cp_cls.return_value = mock_cp_instance\n565: \n566:         mock_dp_instance = MagicMock()\n567:         mock_dp_instance.list_files.return_value = {\"files\": [\"a.txt\"]}\n568:         mock_dp_cls.return_value = mock_dp_instance\n569: \n570:         client = CodeInterpreterClient(\n571:             session_id=\"sess-1\",\n572:             router_url=\"http://router:8080\",\n573:         )\n574:         result = client.list_files(\"/tmp\")\n575: \n576:         assert result == {\"files\": [\"a.txt\"]}\n577:         mock_dp_instance.list_files.assert_called_once_with(\"/tmp\")\n578:         client.stop()\n579: \n580: \n581: # ---------------------------------------------------------------------------\n582: # T-8: CodeInterpreterClient — Integration tests\n583: # ---------------------------------------------------------------------------\n584: \n585: \n586: class TestCodeInterpreterIntegration:\n587:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n588:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n589:     def test_full_lifecycle_with_context_manager(self, mock_dp_cls, mock_cp_cls