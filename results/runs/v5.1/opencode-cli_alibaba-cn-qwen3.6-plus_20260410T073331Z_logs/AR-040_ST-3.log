 assert adapter._pool_maxsize == 10\n40: \n41:     def test_session_can_be_closed(self):\n42:         session = create_session()\n43:         session.close()\n44: \n45: \n46: class TestReadTokenFromFile:\n47:     def test_returns_token_content_when_file_exists(self):\n48:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".token\") as f:\n49:             f.write(\"my-secret-token\\n\")\n50:             f.flush()\n51:             token_path = f.name\n52:         try:\n53:             result = read_token_from_file(token_path)\n54:             assert result == \"my-secret-token\"\n55:         finally:\n56:             os.unlink(token_path)\n57: \n58:     def test_strips_whitespace(self):\n59:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".token\") as f:\n60:             f.write(\"  token-with-spaces  \\n\")\n61:             f.flush()\n62:             token_path = f.name\n63:         try:\n64:             result = read_token_from_file(token_path)\n65:             assert result == \"token-with-spaces\"\n66:         finally:\n67:             os.unlink(token_path)\n68: \n69:     def test_returns_empty_string_when_file_not_found(self):\n70:         result = read_token_from_file(\"/nonexistent/path/token\")\n71:         assert result == \"\"\n72: \n73: \n74: class TestGetLogger:\n75:     def test_returns_logger_instance(self):\n76:         logger = get_logger(\"test_logger\")\n77:         assert isinstance(logger, logging.Logger)\n78: \n79:     def test_default_level_is_info(self):\n80:         logger = get_logger(\"test_logger_info\")\n81:         assert logger.level == logging.INFO\n82: \n83:     def test_verbose_sets_debug_level(self):\n84:         logger = get_logger(\"test_logger_debug\", level=logging.DEBUG)\n85:         assert logger.level == logging.DEBUG\n86: \n87:     def test_can_set_level_by_string(self):\n88:         logger = get_logger(\"test_logger_str\", level=\"DEBUG\")\n89:         assert logger.level == logging.DEBUG\n90: \n91:     def test_can_set_level_by_int(self):\n92:         logger = get_logger(\"test_logger_int\", level=logging.WARNING)\n93:         assert logger.level == logging.WARNING\n\n(End of file - total 93 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for utility helpers.\"\"\"\n\nimport logging\nimport os\nimport tempfile\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.log import get_logger\nfrom agentcube.utils.utils import read_token_from_file\n\n\nclass TestCreateSession:\n    def test_returns_requests_session(self):\n        import requests\n\n        session = create_session()\n        assert isinstance(session, requests.Session)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_utils.py","time":{"start":1775892719067,"end":1775892719080}}}}
