\n39:         )\n40:         self.session.headers[\"Content-Type\"] = \"application/json\"\n41:         if token:\n42:             self.session.headers[\"Authorization\"] = f\"Bearer {token}\"\n43: \n44:         self.timeout = timeout\n45:         self.connect_timeout = connect_timeout\n46: \n47:     def create_session(\n48:         self,\n49:         name: str = \"my-interpreter\",\n50:         namespace: str = \"default\",\n51:         metadata: Optional[Dict[str, Any]] = None,\n52:         ttl: int = 3600,\n53:     ) -> str:\n54:         \"\"\"Create a code interpreter session.\n55: \n56:         POST {base_url}/v1/code-interpreter\n57:         \"\"\"\n58:         body = {\n59:             \"name\": name,\n60:             \"namespace\": namespace,\n61:             \"ttl\": ttl,\n62:             \"metadata\": metadata,\n63:         }\n64:         url = f\"{self.base_url}/v1/code-interpreter\"\n65:         resp = self.session.post(\n66:             url, json=body, timeout=(self.connect_timeout, self.timeout)\n67:         )\n68:         resp.raise_for_status()\n69:         data = resp.json()\n70:         session_id = data.get(\"sessionId\")\n71:         if session_id is None:\n72:             raise ValueError(\"Response missing 'sessionId' field\")\n73:         return session_id\n74: \n75:     def delete_session(self, session_id: str) -> bool:\n76:         \"\"\"Delete a code interpreter session.\n77: \n78:         DELETE {base_url}/v1/code-interpreter/sessions/{session_id}\n79:         404 is treated as success.\n80:         \"\"\"\n81:         url = f\"{self.base_url}/v1/code-interpreter/sessions/{session_id}\"\n82:         try:\n83:             resp = self.session.delete(\n84:                 url, timeout=(self.connect_timeout, self.timeout)\n85:             )\n86:             if resp.status_code == 404:\n87:                 return True\n88:             resp.raise_for_status()\n89:             return True\n90:         except requests.RequestException as e:\n91:  