e CodeInterpreterSpec struct {\n45: \tPorts              []TargetPort                    `json:\"ports,omitempty\"`\n46: \tTemplate           *CodeInterpreterSandboxTemplate `json:\"template\"`\n47: \tSessionTimeout     *metav1.Duration                `json:\"sessionTimeout,omitempty\"`\n48: \tMaxSessionDuration *metav1.Duration                `json:\"maxSessionDuration,omitempty\"`\n49: \tWarmPoolSize       *int32                          `json:\"warmPoolSize,omitempty\"`\n50: \tAuthMode           AuthModeType                    `json:\"authMode,omitempty\"`\n51: }\n52: \n53: type CodeInterpreterStatus struct {\n54: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n55: \tReady      bool               `json:\"ready,omitempty\"`\n56: }\n57: \n58: type CodeInterpreterSandboxTemplate struct {\n59: \tLabels           map[string]string             `json:\"labels,omitempty\"`\n60: \tAnnotations      map[string]string             `json:\"annotations,omitempty\"`\n61: \tRuntimeClassName *string                       `json:\"runtimeClassName,omitempty\"`\n62: \tImage            string                        `json:\"image,omitempty\"`\n63: \tImagePullPolicy  corev1.PullPolicy             `json:\"imagePullPolicy,omitempty\"`\n64: \tImagePullSecrets []corev1.LocalObjectReference `json:\"imagePullSecrets,omitempty\"`\n65: \tEnvironment      []corev1.EnvVar               `json:\"environment,omitempty\"`\n66: \tCommand          []string                      `json:\"command,omitempty\"`\n67: \tArgs             []string                      `json:\"args,omitempty\"`\n68: \tResources        corev1.ResourceRequirements   `json:\"resources,omitempty\"`\n69: }\n70: \n71: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n72: // +kubebuilder:object:root=true\n73: \n74: type CodeInterpreterList struct {\n75: \tmetav1.TypeMeta `json:\",inline\"`\n76: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n77: \tItems           []CodeInterpreter `json:\"items\"`\n78: }\n79: \n80: func init() {\n81: \tSchemeBuilder.Register(&CodeInterpreter{}, &CodeInterpreterList{})\n82: }\n\n(End of file - total 82 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\ntype ProtocolType string\n\nconst (\n\tProtocolTypeHTTP  ProtocolType = \"HTTP\"\n\tProtocolTypeHTTPS ProtocolType = \"HTTPS\"\n)\n\ntype AuthModeType string\n\nconst (\n\tAuthModePicoD AuthModeType = \"picod\"\n\tAuthModeNone  AuthModeType = \"none\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types.go","time":{"start":1775811103958,"end":1775811103972}}}}
