ield or method Name)"}]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go\n@@ -1,10 +1,13 @@\n package v1alpha1\n \n import (\n \t\"testing\"\n+\t\"time\"\n \n \t\"github.com/stretchr/testify/assert\"\n+\tcorev1 \"k8s.io/api/core/v1\"\n+\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n )\n \n func TestProtocolTypeConstants(t *testing.T) {\n \tassert.Equal(t, ProtocolType(\"HTTP\"), ProtocolTypeHTTP)\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go","before":"package v1alpha1\n\nimport (\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestProtocolTypeConstants(t *testing.T) {\n\tassert.Equal(t, ProtocolType(\"HTTP\"), ProtocolTypeHTTP)\n\tassert.Equal(t, ProtocolType(\"HTTPS\"), ProtocolTypeHTTPS)\n}\n\nfunc TestAuthModeTypeConstants(t *testing.T) {\n\tassert.Equal(t, AuthModeType(\"picod\"), AuthModePicoD)\n\tassert.Equal(t, AuthModeType(\"none\"), AuthModeNone)\n}\n\nfunc TestTargetPortDefaults(t *testing.T) {\n\ttp := TargetPort{\n\t\tPort: 8080,\n\t}\n\n\tassert.Equal(t, uint32(8080), tp.Port)\n\tassert.Empty(t, tp.PathPrefix)\n\tassert.Empty(t, tp.Name)\n\tassert.Equal(t, ProtocolType(\"\"), tp.Protocol)\n}\n\nfunc TestTargetPortWithAllFields(t *testing.T) {\n\ttp := TargetPort{\n\t\tPathPrefix: \"/api\",\n\t\tName:       \"api\",\n\t\tPort:       3000,\n\t\tProtocol:   ProtocolTypeHTTPS,\n\t}\n\n\tassert.Equal(t, \"/api\", tp.PathPrefix)\n\tassert.Equal(t, \"api\", tp.Name)\n\tassert.Equal(t, uint32(3000), tp.Port)\n\tassert.Equal(t, ProtocolTypeHTTPS, tp.Protocol)\n}\n\nfunc TestTargetPortDeepCopy(t *testing.T) {\n\toriginal := &TargetPort{\n\t\tPathPrefix: \"/api\",\n\t\tName:       \"api\",\n\t\tPort:       3000,\n\t\tProtocol:   ProtocolTypeHTTPS,\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Port, cp.Port)\n\tassert.Equal(t, original.Protocol, cp.Protocol)\n\n\tcp.Port = 9090\n\tassert.Equal(t, uint32(3000), original.Port)\n}\n\nfunc TestCodeInterpreterSpecDefaults(t *testing.T) {\n\tci := &CodeInterpreterSpec{\n\t\tTemplate: &CodeInterpreterSandboxTemplate{},\n\t}\n\n\tassert.Empty(t, ci.Ports)\n\tassert.Nil(t, ci.SessionTimeout)\n\tassert.Nil(t, ci.MaxSessionDuration)\n\tassert.Nil(t, ci.WarmPoolSize)\n\tassert.Equal(t, AuthModeType(\"\"), ci.AuthMode)\n}\n\nfunc TestCodeInterpreterSandboxTemplateDeepCopy(t *testing.T) {\n\truntimeClass := \"kuasar-vmm\"\n\toriginal := &CodeInterpreterSandboxTemplate{\n\t\tLabels:           map[string]string{\"app\": \"test\"},\n\t\tAnnotations:      map[string]string{\"key\": \"value\"},\n\t\tRuntimeClassName: &runtimeClass,\n\t\tImage:            \"python:3.11\",\n\t\tImagePullPolicy:  corev1.PullIfNotPresent,\n\t\tCommand:          []string{\"python\", \"-m\", \"http.server\"},\n\t\tArgs:             []string{\"8080\"},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Image, cp.Image)\n\tassert.Equal(t, original.Labels[\"app\"], cp.Labels[\"app\"])\n\tassert.Equal(t, *original.RuntimeClassName, *cp.RuntimeClassName)\n\n\tcp.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Labels[\"app\"])\n\n\tcp.Image = \"modified:latest\"\n\tassert.Equal(t, \"python:3.11\", original.Image)\n}\n\nfunc TestCodeInterpreterDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n\t\tSpec: CodeInterpreterSpec{\n\t\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\t\tImage:  \"python:3.11\",\n\t\t\t},\n\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\tWarmPoolSize:       ptrInt32(3),\n\t\t\tAuthMode:           AuthModePicoD,\n\t\t},\n\t\tStatus: CodeInterpreterStatus{\n\t\t\tReady: true,\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Name, cp.Name)\n\tassert.Equal(t, original.Spec.WarmPoolSize, cp.Spec.WarmPoolSize)\n\tassert.Equal(t, original.Spec.AuthMode, cp.Spec.AuthMode)\n\tassert.Equal(t, original.Status.Ready, cp.Status.Ready)\n\n\tcp.Spec.WarmPoolSize = ptrInt32(5)\n\tassert.Equal(t, int32(3), *original.Spec.WarmPoolSize)\n}\n\nfunc TestCodeInterpreterListDeepCopy(t *testing.T) {\n\toriginal := &CodeInterpreterList{\n\t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\t\tImage: \"python:3.11\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n\tassert.Equal(t, len(original.Items), len(cp.Items))\n\tassert.Equal(t, original.Items[0].Name, cp.Items[0].Name)\n\n\tcp.Items[0].Name = \"modified\"\n\tassert.Equal(t, \"ci1\", original.Items[0].Name)\n}\n\nfunc ptrInt32(i int32) *int32 {\n\treturn &i\n}\n","after":"package v1alpha1\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestProtocolTypeConstants(t *testing.T) {\n\tassert.Equal(t, ProtocolType(\"HTTP\"), ProtocolTypeHTTP)\n\ta