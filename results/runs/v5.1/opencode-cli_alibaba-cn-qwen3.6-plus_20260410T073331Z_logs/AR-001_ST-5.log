notations[\"agentcube.io/runtime\"])\n\tassert.Equal(t, 15*time.Minute, ar.Spec.SessionTimeout.Duration)\n\tassert.Equal(t, 8*time.Hour, ar.Spec.MaxSessionDuration.Duration)\n}\n","additions":4,"deletions":13},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/agent_type_test.go","time":{"start":1775808258772,"end":1775808258958}}}}
