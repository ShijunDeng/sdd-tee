t_type_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/agent_type_test.go\n@@ -241,8 +241,4 @@\n \tassert.Equal(t, \"python-3.11\", ar.Spec.Template.Annotations[\"agentcube.io/runtime\"])\n \tassert.Equal(t, 15*time.Minute, ar.Spec.SessionTimeout.Duration)\n \tassert.Equal(t, 8*time.Hour, ar.Spec.MaxSessionDuration.Duration)\n }\n-\n-func parseQuantity(s string) metav1.Time {\n-\treturn metav1.Time{}\n-}\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/agent_type_test.go","before":"package v1alpha1\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestAgentRuntimeDefaultValues(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{{Name: \"test\", Image: \"test:latest\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Nil(t, ar.Spec.SessionTimeout)\n\tassert.Nil(t, ar.Spec.MaxSessionDuration)\n\tassert.Empty(t, ar.Spec.Ports)\n\tassert.NotNil(t, ar.Spec.Template)\n}\n\nfunc TestAgentRuntimeDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntime{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test\", Namespace: \"default\"},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t\tSessionTimeout:     &metav1.Duration{Duration: 30 * time.Minute},\n\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 4 * time.Hour},\n\t\t},\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tConditions: []metav1.Condition{{\n\t\t\t\tType:   \"Ready\",\n\t\t\t\tStatus: metav1.ConditionTrue,\n\t\t\t\tReason: \"SandboxRunning\",\n\t\t\t}},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Name, cp.Name)\n\tassert.Equal(t, original.Spec.Ports[0].Port, cp.Spec.Ports[0].Port)\n\n\tcp.Spec.Ports[0].Port = 9090\n\tassert.Equal(t, uint32(8080), original.Spec.Ports[0].Port)\n\n\tcp.Spec.Template.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Spec.Template.Labels[\"app\"])\n\n\tcp.Spec.Template.Annotations = map[string]string{\"new\": \"value\"}\n\tassert.Nil(t, original.Spec.Template.Annotations)\n\n\tcp.Status.Conditions[0].Reason = \"Modified\"\n\tassert.Equal(t, \"SandboxRunning\", original.Status.Conditions[0].Reason)\n}\n\nfunc TestAgentRuntimeListDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeList{\n\t\tListMeta: metav1.ListMeta{ResourceVersion: \"1234\"},\n\t\tItems: []AgentRuntime{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ar1\", Namespace: \"default\"},\n\t\t\t\tSpec: AgentRuntimeSpec{\n\t\t\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n\tassert.Equal(t, len(original.Items), len(cp.Items))\n\tassert.Equal(t, original.Items[0].Name, cp.Items[0].Name)\n\n\tcp.Items[0].Name = \"modified\"\n\tassert.Equal(t, \"ar1\", original.Items[0].Name)\n}\n\nfunc TestSandboxTemplateDeepCopy(t *testing.T) {\n\toriginal := &SandboxTemplate{\n\t\tLabels:      map[string]string{\"app\": \"test\"},\n\t\tAnnotations: map[string]string{\"key\": \"value\"},\n\t\tSpec: corev1.PodSpec{\n\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Labels[\"app\"], cp.Labels[\"app\"])\n\tassert.Equal(t, original.Annotations[\"key\"], cp.Annotations[\"key\"])\n\n\tcp.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Labels[\"app\"])\n}\n\nfunc TestAgentRuntimeSpecDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeSpec{\n\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n\t\tTemplate: &SandboxTemplate{\n\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\tSpec: corev1.PodSpec{\n\t\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n\t\t\t},\n\t\t},\n\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Ports[0].Port, cp.Ports[0].Port)\n\tassert.Equal(t, original.SessionTimeout.Duration, cp.SessionTimeout.Duration)\n\n\tcp.Ports[0].Port = 9090\n\tassert.Equal(t, uint32(8080), original.Ports[0].Port)\n}\n\nfunc TestAgentRuntimeStatusDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeStatus{\n\t\tConditions: []metav1.Condition{{\n\t\t\tType:               \"Ready\",\n\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\tReason:             \"SandboxRunning\",\n\t\t\tLastTransitionTime: metav1.Now(),\n\t\t}},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Conditions[0].Type, cp.Conditions[0].Type)\n\tassert.Equal(t, original.Conditions[0].Reason, cp.Conditions[0].Reason)\n\n\tcp.Conditions[0].Reason = \"Modified\"\n\tassert.Equal(t, \"SandboxRunning\", original.Conditions[0].Reason)\n}\n\nfunc TestAgentRuntimeWithNilTemplate(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tTemplate: nil,\n\t\t},\n\t}\n\n\tassert.Nil(t, ar.Spec.Template)\n\tassert.Nil(t, ar.Spec.SessionTimeout)\n\tassert.Nil(t, ar.Spec.MaxSessionDuration)\n}\n\nfunc TestAgentRuntimeWithEmptyPorts(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{{Name: \"test\", Image: \"test:latest\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Empty(t, ar.Spec.Ports)\n\tassert.Nil(t, ar.Spec.SessionTimeout)\n\tassert.Nil(t, ar.Spec.MaxSessionDuration)\n}\n\nfunc TestAgentRuntimeWithAllFields(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"python-sandbox\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels:    map[string]string{\"app\": \"python-agent\"},\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{\n\t\t\t\t\tName:       \"web\",\n\t\t\t\t\tPort:       8080,\n\t\t\t\t\tProtocol:   ProtocolTypeHTTP,\n\t\t\t\t\tPathPrefix: \"/\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\tLabels:      map[string]string{\"app\": \"python-agent\"},\n\t\t\t\tAnnotations: map[string]string{\"agentcube.io/runtime\": \"python-3.11\"},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"sandbox\",\n\t\t\t\t\t\t\tImage: \"python:3.11-slim\",\n\t\t\t\t\t\t\tPorts: []corev1.ContainerPort{{ContainerPort: 8080}},\n\t\t\t\t\t\t\tResources: corev1.ResourceRequirements{\n\t\t\t\t\t\t\t\tRequests: corev1.ResourceList{\n\t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"100m\"),\n\t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"128Mi\"),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\tLimits: corev1.ResourceList{\n\t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n\t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"512Mi\"),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t},\n\t}\n\n\tassert.Equal(t, \"runtime.agentcube.volcano.sh/v1alpha1\", ar.APIVersion)\n\tassert.Equal(t, \"AgentRuntime\", ar.Kind)\n\tassert.Equal(t, \"python-sandbox\", ar.Name)\n\tassert.Equal(t, \"default\", ar.Namespace)\n\tassert.Len(t, ar.Spec.Ports, 1)\n\tassert.Equal(t, uint32(8080), ar.Spec.Ports[0].Port)\n\tassert.Equal(t, ProtocolTypeHTTP, ar.Spec.Ports[0].Protocol)\n\tassert.Equal(t, \"/\", ar.Spec.Ports[0].PathPrefix)\n\tassert.NotNil(t, ar.Spec.Template)\n\tassert.Equal(t, \"python-3.11\", ar.Spec.Template.Annotations[\"agentcube.io/runtime\"])\n\tassert.Equal(t, 15*time.Minute, ar.Spec.SessionTimeout.Duration)\n\tassert.Equal(t, 8*time.Hour, ar.Spec.MaxSessionDuration.Duration)\n}\n\nfunc parseQuantity(s string) metav1.Time {\n\treturn metav1.Time{}\n}\n","after":"package v1alpha1\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestAgentRuntimeDefaultValues(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{{Name: \"test\", Image: \"test:latest\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Nil(t, ar.Spec.SessionTimeout)\n\tassert.Nil(t, ar.Spec.MaxSessionDuration)\n\tassert.Empty(t, ar.Spec.Ports)\n\tassert.NotNil(t, ar.Spec.Template)\n}\n\nfunc TestAgentRuntimeDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntime{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test\", Namespace: \"default\"},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t\tSessionTimeout:     &metav1.Duration{Duration: 30 * time.Minute},\n\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 4 * time.Hour},\n\t\t},\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tConditions: []metav1.Condition{{\n\t\t\t\tType:   \"Ready\",\n\t\t\t\tStatus: metav1.ConditionTrue,\n\t\t\t\tReason: \"SandboxRunning\",\n\t\t\t}},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Name, cp.Name)\n\tassert.Equal(t, original.Spec.Ports[0].Port, cp.Spec.Ports[0].Port)\n\n\tcp.Spec.Ports[0].Port = 9090\n\tassert.Equal(t, uint32(8080), original.Spec.Ports[0].Port)\n\n\tcp.Spec.Template.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Spec.Template.Labels[\"app\"])\n\n\tcp.Spec.Template.Annotations = map[string]string{\"new\": \"value\"}\n\tassert.Nil(t, original.Spec.Template.Annotations)\n\n\tcp.Status.Conditions[0].Reason = \"Modified\"\n\tassert.Equal(t, \"SandboxRunning\", original.Status.Conditions[0].Reason)\n}\n\nfunc TestAgentRuntimeListDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeList{\n\t\tListMeta: metav1.ListMeta{ResourceVersion: \"1234\"},\n\t\tItems: []AgentRuntime{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ar1\", Namespace: \"default\"},\n\t\t\t\tSpec: AgentRuntimeSpec{\n\t\t\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n\tassert.Equal(t, len(original.Items), len(cp.Items))\n\tassert.Equal(t, original.Items[0].Name, cp.Items[0].Name)\n\n\tcp.Items[0].Name = \"modified\"\n\tassert.Equal(t, \"ar1\", original.Items[0].Name)\n}\n\nfunc TestSandboxTemplateDeepCopy(t *testing.T) {\n\toriginal := &SandboxTemplate{\n\t\tLabels:      map[string]string{\"app\": \"test\"},\n\t\tAnnotations: map[string]string{\"key\": \"value\"},\n\t\tSpec: corev1.PodSpec{\n\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n\t\t},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Labels[\"app\"], cp.Labels[\"app\"])\n\tassert.Equal(t, original.Annotations[\"key\"], cp.Annotations[\"key\"])\n\n\tcp.Labels[\"app\"] = \"modified\"\n\tassert.Equal(t, \"test\", original.Labels[\"app\"])\n}\n\nfunc TestAgentRuntimeSpecDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeSpec{\n\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n\t\tTemplate: &SandboxTemplate{\n\t\t\tLabels: map[string]string{\"app\": \"test\"},\n\t\t\tSpec: corev1.PodSpec{\n\t\t\t\tContainers: []corev1.Container{{Name: \"c\", Image: \"test:latest\"}},\n\t\t\t},\n\t\t},\n\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Ports[0].Port, cp.Ports[0].Port)\n\tassert.Equal(t, original.SessionTimeout.Duration, cp.SessionTimeout.Duration)\n\n\tcp.Ports[0].Port = 9090\n\tassert.Equal(t, uint32(8080), original.Ports[0].Port)\n}\n\nfunc TestAgentRuntimeStatusDeepCopy(t *testing.T) {\n\toriginal := &AgentRuntimeStatus{\n\t\tConditions: []metav1.Condition{{\n\t\t\tType:               \"Ready\",\n\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\tReason:             \"SandboxRunning\",\n\t\t\tLastTransitionTime: metav1.Now(),\n\t\t}},\n\t}\n\n\tcp := original.DeepCopy()\n\n\tassert.Equal(t, original.Conditions[0].Type, cp.Conditions[0].Type)\n\tassert.Equal(t, original.Conditions[0].Reason, cp.Conditions[0].Reason)\n\n\tcp.Conditions[0].Reason = \"Modified\"\n\tassert.Equal(t, \"SandboxRunning\", original.Conditions[0].Reason)\n}\n\nfunc TestAgentRuntimeWithNilTemplate(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tTemplate: nil,\n\t\t},\n\t}\n\n\tassert.Nil(t, ar.Spec.Template)\n\tassert.Nil(t, ar.Spec.SessionTimeout)\n\tassert.Nil(t, ar.Spec.MaxSessionDuration)\n}\n\nfunc TestAgentRuntimeWithEmptyPorts(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{{Name: \"test\", Image: \"test:latest\"}},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tassert.Empty(t, ar.Spec.Ports)\n\tassert.Nil(t, ar.Spec.SessionTimeout)\n\tassert.Nil(t, ar.Spec.MaxSessionDuration)\n}\n\nfunc TestAgentRuntimeWithAllFields(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"python-sandbox\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels:    map[string]string{\"app\": \"python-agent\"},\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tPorts: []TargetPort{\n\t\t\t\t{\n\t\t\t\t\tName:       \"web\",\n\t\t\t\t\tPort:       8080,\n\t\t\t\t\tProtocol:   ProtocolTypeHTTP,\n\t\t\t\t\tPathPrefix: \"/\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\tLabels:      map[string]string{\"app\": \"python-agent\"},\n\t\t\t\tAnnotations: map[string]string{\"agentcube.io/runtime\": \"python-3.11\"},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"sandbox\",\n\t\t\t\t\t\t\tImage: \"python:3.11-slim\",\n\t\t\t\t\t\t\tPorts: []corev1.ContainerPort{{ContainerPort: 8080}},\n\t\t\t\t\t\t\tResources: corev1.ResourceRequirements{\n\t\t\t\t\t\t\t\tRequests: corev1.ResourceList{\n\t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"100m\"),\n\t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"128Mi\"),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\tLimits: corev1.ResourceList{\n\t\t\t\t\t\t\t\t\tcorev1.ResourceCPU:    parseQuantity(\"1\"),\n\t\t\t\t\t\t\t\t\tcorev1.ResourceMemory: parseQuantity(\"512Mi\"),\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t},\n\t}\n\n\tassert.Equal(t, \"runtime.agentcube.volcano.sh/v1alpha1\", ar.APIVersion)\n\tassert.Equal(t, \"AgentRuntime\", ar.Kind)\n\tassert.Equal(t, \"python-sandbox\", ar.Name)\n\tassert.Equal(t, \"default\", ar.Namespace)\n\tassert.Len(t, ar.Spec.Ports, 1)\n\tassert.Equal(t, uint32(8080), ar.Spec.Ports[0].Port)\n\tassert.Equal(t, ProtocolTypeHTTP, ar.Spec.Ports[0].Protocol)\n\tassert.Equal(t, \"/\", ar.Spec.Ports[0].PathPrefix)\n\tassert.NotNil(t, ar.Spec.Template)\n\tassert.Equal(t, \"python-3.11\", ar.Spec.Template.Annotations[\"agentcube.io/runtime\"])\n\tassert.Equal(t, 15*time.Minute, ar.Spec.SessionTimeout.Duration)\n\tassert.Equal(t, 8*time.Hour, ar.Spec.MaxSessionDuration.Duration)\n}\n","additions":0,"deletions":4},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/agent_type_test.go","time":{"start":1775808242973,"end":1775808243147}}}}
