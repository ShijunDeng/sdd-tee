None:\n47:     \"\"\"AgentCube CLI - A developer tool for AI agent lifecycle management.\"\"\"\n48:     if verbose:\n49:         logging.basicConfig(level=logging.DEBUG)\n50: \n51: \n52: def _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n53:     \"\"\"Handle errors by printing a message and optionally a traceback.\"\"\"\n54:     console.print(f\"[red]Error {command_name}: {e}[/red]\")\n55:     if verbose:\n56:         console.print_exception()\n57:     raise typer.Exit(1)\n58: \n59: \n60: @app.command()\n61: def pack(\n62:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory.\", show_default=True),\n63:     agent_name: Optional[str] = typer.Option(None, \"--agent-name\", help=\"Override the agent name.\"),\n64:     language: Optional[str] = typer.Option(None, \"--language\", help=\"Programming language (python, java).\"),\n65:     entrypoint: Optional[str] = typer.Option(None, \"--entrypoint\", help=\"Override the entrypoint command.\"),\n66:     port: Optional[int] = typer.Option(None, \"--port\", help=\"Port to expose in the Dockerfile.\"),\n67:     build_mode: Optional[str] = typer.Option(None, \"--build-mode\", help=\"Build strategy: local or cloud.\"),\n68:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description.\"),\n69:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for packaged workspace.\"),\n70:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging.\"),\n71: ) -> None:\n72:     \"\"\"Package an agent workspace for the AgentCube lifecycle.\"\"\"\n73:     with Progress(\n74:         SpinnerColumn(),\n75:         TextColumn(\"[progress.description]{task.description}\"),\n76:         transient=True,\n77:     ) as progress:\n78:         task = progress.add_task(\"Packaging agent...\", total=None)\n79:         try:\n80:             runtime = PackRuntime(verbose=verbose)\n81:             from pathlib import Path\n82:             workspace_path = Path(workspace).resolve()\n83:             result = runtime.pack(\n84:                 workspace_path,\n85:                 agent_name=agent_name,\n86:                 language=language,\n87:                 entrypoint=entrypoint,\n88:                 port=port,\n89:                 build_mode=build_mode,\n90:                 description=description,\n91:                 output=output,\n92:             )\n93:             progress.update(task, description=\"Done\")\n94:             console.print(f\"[green]✓[/green] Agent '[bold]{result['agent_name']}[/bold]' packaged successfully!\")\n95:             console.print(f\"  [dim]Workspace:[/dim] {result['workspace_path']}\")\n96:             console.print(f\"  [dim]Metadata: [/dim] {result['metadata_path']}\")\n97:         except Exception as e:\n98:             _handle_error(e, \"packaging agent\", verbose)\n99: \n100: \n101: @app.command()\n102: def build(\n103:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory.\", show_default=True),\n104:     proxy: Optional[str] = typer.Option(None, \"-p\", \"--proxy\", help=\"Custom proxy URL for dependency resolution.\"),\n105:     cloud_provider: Optional[str] = typer.Option(None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei).\"),\n106:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for build artifacts.\"),\n107:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging.\"),\n108: ) -> None:\n109:     \"\"\"Build a container image from a packaged agent workspace.\"\"\"\n110:     workspace_path = Path(workspace).resolve()\n111:     try:\n112:         with Progress(\n113:             SpinnerColumn(),\n114:             TextColumn(\"[progress.description]{task.description}\"),\n115:             transient=True,\n116:         ) as progress:\n117:             progress.add_task(\"Building agent...\", total=None)\n118:             runtime = BuildRuntime(verbose=verbose)\n119:             result = runtime.build(\n120:                 workspace_path,\n121:                 proxy=proxy,\n122:                 cloud_provider=cloud_provider,\n123:                 output=output,\n124:             )\n125: \n126:         metadata = runtime.metadata_service.load_metadata(workspace_path)\n127:         agent_name = metadata.agent_name if metadata else \"unknown\"\n128:         tag = metadata.version if metadata and metadata.version else \"latest\"\n129:         image_name = result.get(\"image_name\", agent_name)\n130:         image_size = result.get(\"image_size\", \"N/A\")\n131:         build_time = result.get(\"build_time\", \"N/A\")\n132: \n133:         console.print(f\"[green]✓[/green] Agent '[bold]{agent_name}[/bold]' built successfully!\")\n134:         console.print(f\"  [dim]Image:  [/dim] {image_name}:{tag}\")\n135:         console.print(f\"  [dim]Size:   [/dim] {image_size}\")\n136:         console.print(f\"  [dim]Time:   [/dim] {build_time}\")\n137:     except Exception as e:\n138:         _handle_error(e, \"building agent\", verbose)\n\n(End of file - total 138 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube CLI entry point.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom typing import Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\n\nfrom pathlib import Path\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtime.build_runtime import BuildRuntime\n\napp = typer.Typer(\n    name=\"agentcube\",\n    help=\"AgentCube CLI - A developer tool for AI agent lifecycle management.\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/cli/main.py","time":{"start":1775854355165,"end":1775854355173}}}}
