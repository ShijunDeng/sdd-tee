ip\", entrypoint=\"python main.py\", port=9090)\n90:         service.save_metadata(empty_workspace, meta)\n91:         loaded = service.load_metadata(empty_workspace)\n92:         assert loaded is not None\n93:         assert loaded.agent_name == \"roundtrip\"\n94:         assert loaded.port == 9090\n95: \n96: \n97: class TestSaveMetadataExcludeNone:\n98:     def test_no_null_values(self, empty_workspace: Path, service: MetadataService) -> None:\n99:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\")\n100:         service.save_metadata(empty_workspace, meta)\n101:         content = (empty_workspace / \"agent_metadata.yaml\").read_text()\n102:         data = yaml.safe_load(content)\n103:         assert \"null\" not in content.lower() or None not in data.values()\n104:         assert \"region\" not in data\n105:         assert \"version\" not in data\n106: \n107: \n108: class TestSaveMetadataFormat:\n109:     def test_yaml_format(self, empty_workspace: Path, service: MetadataService) -> None:\n110:         meta = AgentMetadata(agent_name=\"format-test\", entrypoint=\"python main.py\")\n111:         service.save_metadata(empty_workspace, meta)\n112:         content = (empty_workspace / \"agent_metadata.yaml\").read_text()\n113:         assert \"  \" in content\n114:         lines = content.splitlines()\n115:         for line in lines:\n116:             if line and not line.startswith(\"#\"):\n117:                 assert line == line.rstrip()\n118: \n119: \n120: class TestUpdateMetadataMerge:\n121:     def test_partial_update(self, workspace_with_primary: Path, service: MetadataService) -> None:\n122:         updated = service.update_metadata(workspace_with_primary, {\"port\": 9999})\n123:         assert updated.agent_name == \"primary-agent\"\n124:         assert updated.port == 9999\n125:         assert updated.language == \"python\"\n126: \n127: \n128: class TestUpdateMetadataCreateNew:\n129:     def test_creates_new_when_no_file(self, e