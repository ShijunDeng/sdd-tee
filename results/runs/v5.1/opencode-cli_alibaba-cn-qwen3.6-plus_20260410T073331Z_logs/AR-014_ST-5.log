g.T) {\n45: \tstore := &valkeyStore{\n46: \t\tsessionPrefix:        \"session:\",\n47: \t\texpiryIndexKey:       \"session:expiry\",\n48: \t\tlastActivityIndexKey: \"session:last_activity\",\n49: \t}\n50: \tctx := context.Background()\n51: \n52: \terr := store.UpdateSandbox(ctx, \"sess-001\", nil)\n53: \trequire.Error(t, err)\n54: \tassert.Contains(t, err.Error(), \"sandbox is nil\")\n55: }\n56: \n57: func TestValkeyStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n58: \tstore := &valkeyStore{\n59: \t\tsessionPrefix:        \"session:\",\n60: \t\texpiryIndexKey:       \"session:expiry\",\n61: \t\tlastActivityIndexKey: \"session:last_activity\",\n62: \t}\n63: \tctx := context.Background()\n64: \n65: \terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n66: \trequire.Error(t, err)\n67: \tassert.Contains(t, err.Error(), \"sessionID is empty\")\n68: }\n69: \n70: func TestValkeyStore_ListExpiredSandboxes_LimitZero(t *testing.T) {\n71: \tstore := &valkeyStore{\n72: \t\tsessionPrefix:        \"session:\",\n73: \t\texpiryIndexKey:       \"session:expiry\",\n74: \t\tlastActivityIndexKey: \"session:last_activity\",\n75: \t}\n76: \tctx := context.Background()\n77: \n78: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n79: \trequire.NoError(t, err)\n80: \tassert.Nil(t, result)\n81: }\n82: \n83: func TestValkeyStore_ListExpiredSandboxes_LimitNegative(t *testing.T) {\n84: \tstore := &valkeyStore{\n85: \t\tsessionPrefix:        \"session:\",\n86: \t\texpiryIndexKey:       \"session:expiry\",\n87: \t\tlastActivityIndexKey: \"session:last_activity\",\n88: \t}\n89: \tctx := context.Background()\n90: \n91: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), -5)\n92: \trequire.NoError(t, err)\n93: \tassert.Nil(t, result)\n94: }\n95: \n96: func TestValkeyStore_ListInactiveSandboxes_LimitZero(t *testing.T) {\n97: \tstore := &valkeyStore{\n98: \t\tsessionPrefix:        \"session:\",\n99: \t\texpiryIndexKey:       \"session:expiry\",\n100: \t\tlastActivityIndexKey: \"session:last_activity\",\n101: \t}\n102: \tctx := context.Background()\n103: \n104: \tresult, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n105: \trequire.NoError(t, err)\n106: \tassert.Nil(t, result)\n107: }\n108: \n109: func TestValkeyStore_ListInactiveSandboxes_LimitNegative(t *testing.T) {\n110: \tstore := &valkeyStore{\n111: \t\tsessionPrefix:        \"session:\",\n112: \t\texpiryIndexKey:       \"session:expiry\",\n113: \t\tlastActivityIndexKey: \"session:last_activity\",\n114: \t}\n115: \tctx := context.Background()\n116: \n117: \tresult, err := store.ListInactiveSandboxes(ctx, time.Now(), -1)\n118: \trequire.NoError(t, err)\n119: \tassert.Nil(t, result)\n120: }\n121: \n122: func TestNewValkeyStore_MissingAddr(t *testing.T) {\n123: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n124: \toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n125: \toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n126: \tdefer func() {\n127: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n128: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n129: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n130: \t}()\n131: \n132: \tos.Unsetenv(\"VALKEY_ADDR\")\n133: \tos.Unsetenv(\"VALKEY_PASSWORD\")\n134: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n135: \n136: \t_, err := newValkeyStore()\n137: \trequire.Error(t, err)\n138: \tassert.Contains(t, err.Error(), \"VALKEY_ADDR is required\")\n139: }\n140: \n141: func TestNewValkeyStore_MissingPassword(t *testing.T) {\n142: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n143: \toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n144: \toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n145: \tdefer func() {\n146: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n147: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n148: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n149: \t}()\n150: \n151: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n152: \tos.Unsetenv(\"VALKEY_PASSWORD\")\n153: \tos.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n154: \n155: \t_, err := newValkeyStore()\n156: \trequire.Error(t, err)\n157: \tassert.Contains(t, err.Error(), \"VALKEY_PASSWORD is required\")\n158: }\n159: \n160: func TestNewValkeyStore_PasswordNotRequired(t *testing.T) {\n161: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n162: \toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n163: \toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n164: \tdefer func() {\n165: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n166: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n167: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n168: \t}()\n169: \n170: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n171: \tos.Unsetenv(\"VALKEY_PASSWORD\")\n172: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n173: \n174: \tstore, err := newValkeyStore()\n175: \trequire.NoError(t, err)\n176: \trequire.NotNil(t, store)\n177: }\n178: \n179: func TestNewValkeyStore_PasswordRequiredTrue(t *testing.T) {\n180: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n181: \toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n182: \toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n183: \tdefer func() {\n184: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n185: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n186: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n187: \t}()\n188: \n189: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n190: \tos.Unsetenv(\"VALKEY_PASSWORD\")\n191: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"true\")\n192: \n193: \t_, err := newValkeyStore()\n194: \trequire.Error(t, err)\n195: \tassert.Contains(t, err.Error(), \"VALKEY_PASSWORD is required\")\n196: }\n197: \n198: func TestValkeyStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n199: \tat := time.Time{}\n200: \tassert.True(t, at.IsZero())\n201: \n202: \tif at.IsZero() {\n203: \t\tat = time.Now()\n204: \t}\n205: \tassert.False(t, at.IsZero())\n206: \tassert.True(t, at.After(time.Now().Add(-time.Second)))\n207: }\n208: \n209: func TestValkeyStore_ListExpiredSandboxes_ScoreCalculation(t *testing.T) {\n210: \tbase := time.Unix(1000000, 0)\n211: \tbefore := base.Add(-time.Hour)\n212: \texpectedMaxScore := before.Unix()\n213: \n214: \tassert.Equal(t, int64(996400), expectedMaxScore)\n215: }\n216: \n217: func TestValkeyStore_ListInactiveSandboxes_ScoreCalculation(t *testing.T) {\n218: \tbase := time.Unix(1000000, 0)\n219: \tbefore := base.Add(-2 * time.Hour)\n220: \texpectedMaxScore := before.Unix()\n221: \n222: \tassert.Equal(t, int64(992800), expectedMaxScore)\n223: }\n224: \n225: func TestValkeyStore_StructFields(t *testing.T) {\n226: \tstore := &valkeyStore{\n227: \t\tsessionPrefix:        \"session:\",\n228: \t\texpiryIndexKey:       \"session:expiry\",\n229: \t\tlastActivityIndexKey: \"session:last_activity\",\n230: \t}\n231: \n232: \tassert.Equal(t, \"session:\", store.sessionPrefix)\n233: \tassert.Equal(t, \"session:expiry\", store.expiryIndexKey)\n234: \tassert.Equal(t, \"session:last_activity\", store.lastActivityIndexKey)\n235: }\n236: \n237: func TestValkeyStore_InterfaceCompliance(t *testing.T) {\n238: \tvar _ Store = (*valkeyStore)(nil)\n239: }\n\n(End of file - total 239 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestValkeyStore_StoreSandbox_NilInfo(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey_test.go","time":{"start":1775837270198,"end":1775837270205}}}}
