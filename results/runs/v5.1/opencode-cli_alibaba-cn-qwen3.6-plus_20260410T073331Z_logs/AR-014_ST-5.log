/sandbox_delete_test.go":[{"range":{"start":{"line":225,"character":11},"end":{"line":225,"character":11}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field SandboxID"},{"range":{"start":{"line":226,"character":14},"end":{"line":226,"character":14}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field WorkloadName"},{"range":{"start":{"line":227,"character":11},"end":{"line":227,"character":11}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field Namespace"},{"range":{"start":{"line":228,"character":6},"end":{"line":228,"character":6}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field Kind"},{"range":{"start":{"line":229,"character":7},"end":{"line":229,"character":7}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field PodIP"},{"range":{"start":{"line":230,"character":27},"end":{"line":230,"character":27}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field EntryPoints"},{"range":{"start":{"line":233,"character":11},"end":{"line":233,"character":11}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field CreatedAt"}]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey_test.go\n@@ -402,9 +402,10 @@\n store, mr := newTestValkeyStore(t)\n ctx := context.Background()\n now := time.Now().UTC()\n \n-require.NoError(t, mr.ZAdd(\"session:expiry\", \"ghost\", float64(now.Add(-time.Hour).Unix())))\n+_, err := mr.ZAdd(\"session:expiry\", float64(now.Add(-time.Hour).Unix()), \"ghost\")\n+require.NoError(t, err)\n \n result, err := store.ListExpiredSandboxes(ctx, now, 10)\n require.NoError(t, err)\n assert.Empty(t, result)\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey_test.go","before":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tvalkey \"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc newTestValkeyStore(t *testing.T) (*valkeyStore, *miniredis.Miniredis) {\n\tt.Helper()\n\tmr, err := miniredis.Run()\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { mr.Close() })\n\n\tcli, err := valkey.NewClient(valkey.ClientOption{\n\t\tInitAddress: []string{mr.Addr()},\n\t})\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { cli.Close() })\n\n\treturn &valkeyStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}, mr\n}\n\nfunc testValkeySandboxInfo(sessionID string) *types.SandboxInfo {\n\tnow := time.Now().UTC()\n\treturn &types.SandboxInfo{\n\t\tSessionID:      sessionID,\n\t\tSandboxName:    \"test-sandbox\",\n\t\tSandboxID:      \"sb-123\",\n\t\tWorkloadName:   \"agent-runtime\",\n\t\tNamespace:      \"default\",\n\t\tKind:           \"AgentRuntime\",\n\t\tPodIP:          \"10.0.0.1\",\n\t\tEntryPoints:    []types.EntryPoint{{Path: \"/api\", Protocol: \"http\", Endpoint: \"http://10.0.0.1:8080\"}},\n\t\tCreatedAt:      now,\n\t\tExpiresAt:      now.Add(24 * time.Hour),\n\t\tStatus:         \"running\",\n\t\tLastActivityAt: now.Add(5 * time.Minute),\n\t}\n}\n\nfunc TestValkeyStore_Ping(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\terr := store.Ping(ctx)\n\trequire.NoError(t, err)\n}\n\nfunc TestValkeyStore_GetSandbox_NotFound(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\tresult, err := store.GetSandbox(ctx, \"nonexistent\")\n\tassert.ErrorIs(t, err, ErrNotFound)\n\tassert.Nil(t, result)\n}\n\nfunc TestValkeyStore_GetSandbox_Found(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-get\")\n\n\tdata, err := encodeSandboxInfo(info)\n\trequire.NoError(t, err)\n\terr = store.cli.Do(ctx, store.cli.B().Set().Key(\"session:sess-get\").Value(string(data)).Build()).Error()\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandbox(ctx, \"sess-get\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, info.SessionID, result.SessionID)\n\tassert.Equal(t, info.SandboxID, result.SandboxID)\n}\n\nfunc TestValkeyStore_StoreSandbox_NilInfo(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\n\terr := store.StoreSandbox(ctx, \"sess-001\", nil)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"sandbox is nil\")\n}\n\nfunc TestValkeyStore_StoreSandbox_ZeroExpiry(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\tinfo := &types.SandboxInfo{\n\t\tSessionID: \"sess-zero\",\n\t\tExpiresAt: time.Time{},\n\t}\n\n\terr := store.StoreSandbox(ctx, \"sess-zero\", info)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"ExpiresAt is zero\")\n}\n\nfunc TestValkeyStore_StoreSandbox_Success(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-store\")\n\n\terr := store.StoreSandbox(ctx, \"sess-store\", info)\n\trequire.NoError(t, err)\n\n\tval, err := mr.Get(\"session:sess-store\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, val, \"sess-store\")\n\n\tmembers, err := mr.ZMembers(\"session:expiry\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, members, \"sess-store\")\n\n\tmembers, err = mr.ZMembers(\"session:last_activity\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, members, \"sess-store\")\n}\n\nfunc TestValkeyStore_StoreSandbox_RoundTrip(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-roundtrip\")\n\n\terr := store.StoreSandbox(ctx, \"sess-roundtrip\", info)\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandbox(ctx, \"sess-roundtrip\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, info.SessionID, result.SessionID)\n\tassert.Equal(t, info.SandboxID, result.SandboxID)\n\tassert.Equal(t, info.Namespace, result.Namespace)\n\tassert.Equal(t, info.Status, result.Status)\n}\n\nfunc TestValkeyStore_StoreSandbox_Duplicate(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-dup\")\n\n\terr := store.StoreSandbox(ctx, \"sess-dup\", info)\n\trequire.NoError(t, err)\n\n\tinfo2 := testValkeySandboxInfo(\"sess-dup\")\n\tinfo2.SandboxID = \"sb-456\"\n\terr = store.StoreSandbox(ctx, \"sess-dup\", info2)\n\trequire.NoError(t, err)\n\n\tval, err := mr.Get(\"session:sess-dup\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, val, \"sb-123\")\n}\n\nfunc TestValkeyStore_UpdateSandbox_NilInfo(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\n\terr := store.UpdateSandbox(ctx, \"sess-001\", nil)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"sandbox is nil\")\n}\n\nfunc TestValkeyStore_UpdateSandbox_KeyNotExists(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-missing\")\n\n\terr := store.UpdateSandbox(ctx, \"sess-missing\", info)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"key not exists\")\n}\n\nfunc TestValkeyStore_UpdateSandbox_Success(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-update\")\n\n\terr := store.StoreSandbox(ctx, \"sess-update\", info)\n\trequire.NoError(t, err)\n\n\tinfo.SandboxID = \"sb-updated\"\n\tinfo.Status = \"stopped\"\n\terr = store.UpdateSandbox(ctx, \"sess-update\", info)\n\trequire.NoError(t, err)\n\n\tval, err := mr.Get(\"session:sess-update\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, val, \"sb-updated\")\n\tassert.Contains(t, val, \"stopped\")\n}\n\nfunc TestValkeyStore_DeleteSandboxBySessionID(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-del\")\n\n\terr := store.StoreSandbox(ctx, \"sess-del\", info)\n\trequire.NoError(t, err)\n\n\terr = store.DeleteSandboxBySessionID(ctx, \"sess-del\")\n\trequire.NoError(t, err)\n\n\texists := mr.Exists(\"session:sess-del\")\n\tassert.False(t, exists)\n\n\tmembers, err := mr.ZMembers(\"session:expiry\")\n\trequire.NoError(t, err)\n\tassert.NotContains(t, members, \"sess-del\")\n\n\tmembers, err = mr.ZMembers(\"session:last_activity\")\n\trequire.NoError(t, err)\n\tassert.NotContains(t, members, \"sess-del\")\n}\n\nfunc TestValkeyStore_DeleteSandboxBySessionID_NonExistent(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\terr := store.DeleteSandboxBySessionID(ctx, \"ghost\")\n\trequire.NoError(t, err)\n}\n\nfunc TestValkeyStore_ListSandboxes(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\tinfo1 := testValkeySandboxInfo(\"sess-a\")\n\tinfo2 := testValkeySandboxInfo(\"sess-b\")\n\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-a\", info1))\n\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-b\", info2))\n\n\tresult, err := store.ListSandboxes(ctx)\n\trequire.NoError(t, err)\n\tassert.Len(t, result, 2)\n\tassert.Contains(t, result, \"sess-a\")\n\tassert.Contains(t, result, \"sess-b\")\n}\n\nfunc TestValkeyStore_ListSandboxes_Empty(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\tresult, err := store.ListSandboxes(ctx)\n\trequire.NoError(t, err)\n\tassert.Empty(t, result)\n}\n\nfunc TestValkeyStore_ListSandboxes_OrphanZSETMember(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\tinfo := testValkeySandboxInfo(\"sess-orphan\")\n\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-orphan\", info))\n\n\t_, err := mr.ZAdd(\"session:expiry\", 1000, \"ghost\")\n\trequire.NoError(t, err)\n\n\tresult, err := store.ListSandboxes(ctx)\n\trequire.NoError(t, err)\n\tassert.Len(t, result, 1)\n\tassert.Contains(t, result, \"sess-orphan\")\n\tassert.NotContains(t, result, \"ghost\")\n}\n\nfunc TestValkeyStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\n\terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"sessionID is empty\")\n}\n\nfunc TestValkeyStore_UpdateSessionLastActivity_NotFound(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\terr := store.UpdateSessionLastActivity(ctx, \"nonexistent\", time.Now())\n\tassert.ErrorIs(t, err, ErrNotFound)\n}\n\nfunc TestValkeyStore_UpdateSessionLastActivity_Success(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-activity\")\n\n\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-activity\", info))\n\n\tactivityTime := time.Now().Add(-2 * time.Hour)\n\terr := store.UpdateSessionLastActivity(ctx, \"sess-activity\", activityTime)\n\trequire.NoError(t, err)\n\n\tscore, err := mr.ZScore(\"session:last_activity\", \"sess-activity\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, float64(activityTime.Unix()), score)\n}\n\nfunc TestValkeyStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-zerotime\")\n\n\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-zerotime\", info))\n\n\tbefore := time.Now()\n\terr := store.UpdateSessionLastActivity(ctx, \"sess-zerotime\", time.Time{})\n\trequire.NoError(t, err)\n\n\tscore, err := mr.ZScore(\"session:last_activity\", \"sess-zerotime\")\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, score, float64(before.Unix()))\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes_LimitZero(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\n\tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n\trequire.NoError(t, err)\n\tassert.Nil(t, result)\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes_LimitNegative(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\n\tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), -5)\n\trequire.NoError(t, err)\n\tassert.Nil(t, result)\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\tnow := time.Now().UTC()\n\n\texpired := testValkeySandboxInfo(\"sess-expired\")\n\texpired.ExpiresAt = now.Add(-2 * time.Hour)\n\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-expired\", expired))\n\n\tactive := testValkeySandboxInfo(\"sess-active\")\n\tactive.ExpiresAt = now.Add(24 * time.Hour)\n\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-active\", active))\n\n\tresult, err := store.ListExpiredSandboxes(ctx, now, 10)\n\trequire.NoError(t, err)\n\trequire.Len(t, result, 1)\n\tassert.Equal(t, \"sess-expired\", result[0].SessionID)\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes_Limit(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\tnow := time.Now().UTC()\n\n\tfor i := 0; i < 5; i++ {\n\t\tinfo := testValkeySandboxInfo(\"sess-exp-\" + string(rune('a'+i)))\n\t\tinfo.ExpiresAt = now.Add(-time.Hour)\n\t\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-exp-\"+string(rune('a'+i)), info))\n\t}\n\n\tresult, err := store.ListExpiredSandboxes(ctx, now, 2)\n\trequire.NoError(t, err)\n\tassert.LessOrEqual(t, len(result), 2)\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes_OrphanMember(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tnow := time.Now().UTC()\n\n\trequire.NoError(t, mr.ZAdd(\"session:expiry\", \"ghost\", float64(now.Add(-time.Hour).Unix())))\n\n\tresult, err := store.ListExpiredSandboxes(ctx, now, 10)\n\trequire.NoError(t, err)\n\tassert.Empty(t, result)\n}\n\nfunc TestValkeyStore_ListInactiveSandboxes_LimitZero(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\n\tresult, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n\trequire.NoError(t, err)\n\tassert.Nil(t, result)\n}\n\nfunc TestValkeyStore_ListInactiveSandboxes_LimitNegative(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\n\tresult, err := store.ListInactiveSandboxes(ctx, time.Now(), -1)\n\trequire.NoError(t, err)\n\tassert.Nil(t, result)\n}\n\nfunc TestValkeyStore_ListInactiveSandboxes(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\tnow := time.Now().UTC()\n\n\tinactive := testValkeySandboxInfo(\"sess-inactive\")\n\tinactive.LastActivityAt = now.Add(-3 * time.Hour)\n\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-inactive\", inactive))\n\n\terr := store.UpdateSessionLastActivity(ctx, \"sess-inactive\", now.Add(-3*time.Hour))\n\trequire.NoError(t, err)\n\n\tactive := testValkeySandboxInfo(\"sess-active2\")\n\trequire.NoError(t, store.StoreSandbox(ctx, \"sess-active2\", active))\n\n\tcutoff := now.Add(-1 * time.Hour)\n\tresult, err := store.ListInactiveSandboxes(ctx, cutoff, 10)\n\trequire.NoError(t, err)\n\trequire.Len(t, result, 1)\n\tassert.Equal(t, \"sess-inactive\", result[0].SessionID)\n}\n\nfunc TestValkeyStore_ListInactiveSandboxes_OrphanMember(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tnow := time.Now().UTC()\n\n\trequire.NoError(t, mr.ZAdd(\"session:last_activity\", \"ghost\", float64(now.Add(-time.Hour).Unix())))\n\n\tresult, err := store.ListInactiveSandboxes(ctx, now, 10)\n\trequire.NoError(t, err)\n\tassert.Empty(t, result)\n}\n\nfunc TestValkeyStore_Close(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\n\terr := store.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestValkeyStore_SessionKey(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\n\tassert.Equal(t, \"session:abc\", store.sessionKey(\"abc\"))\n\tassert.Equal(t, \"session:test-123\", store.sessionKey(\"test-123\"))\n}\n\nfunc TestValkeyStore_MultipleSandboxes(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\tfor i := 0; i < 10; i++ {\n\t\tid := \"sess-multi-\" + string(rune('a'+i))\n\t\tinfo := testValkeySandboxInfo(id)\n\t\trequire.NoError(t, store.StoreSandbox(ctx, id, info))\n\t}\n\n\tresult, err := store.ListSandboxes(ctx)\n\trequire.NoError(t, err)\n\tassert.Len(t, result, 10)\n}\n\nfunc TestValkeyStore_ErrNotFound_Is(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\t_, err := store.GetSandbox(ctx, \"missing\")\n\tassert.ErrorIs(t, err, ErrNotFound)\n}\n\nfunc TestNewValkeyStore_MissingAddr(t *testing.T) {\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n\t}()\n\n\tos.Unsetenv(\"VALKEY_ADDR\")\n\tos.Unsetenv(\"VALKEY_PASSWORD\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\n\t_, err := newValkeyStore()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"VALKEY_ADDR is required\")\n}\n\nfunc TestNewValkeyStore_MissingPassword(t *testing.T) {\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n\t}()\n\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Unsetenv(\"VALKEY_PASSWORD\")\n\tos.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n\n\t_, err := newValkeyStore()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"VALKEY_PASSWORD is required\")\n}\n\nfunc TestNewValkeyStore_PasswordNotRequired(t *testing.T) {\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n\t}()\n\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Unsetenv(\"VALKEY_PASSWORD\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\n\tstore, err := newValkeyStore()\n\trequire.NoError(t, err)\n\trequire.NotNil(t, store)\n}\n\nfunc TestNewValkeyStore_PasswordRequiredTrue(t *testing.T) {\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n\t}()\n\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Unsetenv(\"VALKEY_PASSWORD\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"true\")\n\n\t_, err := newValkeyStore()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"VALKEY_PASSWORD is required\")\n}\n\nfunc TestValkeyStore_UpdateSessionLastActivity_ZeroTime_Logic(t *testing.T) {\n\tat := time.Time{}\n\tassert.True(t, at.IsZero())\n\n\tif at.IsZero() {\n\t\tat = time.Now()\n\t}\n\tassert.False(t, at.IsZero())\n\tassert.True(t, at.After(time.Now().Add(-time.Second)))\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes_ScoreCalculation(t *testing.T) {\n\tbase := time.Unix(1000000, 0)\n\tbefore := base.Add(-time.Hour)\n\texpectedMaxScore := before.Unix()\n\n\tassert.Equal(t, int64(996400), expectedMaxScore)\n}\n\nfunc TestValkeyStore_ListInactiveSandboxes_ScoreCalculation(t *testing.T) {\n\tbase := time.Unix(1000000, 0)\n\tbefore := base.Add(-2 * time.Hour)\n\texpectedMaxScore := before.Unix()\n\n\tassert.Equal(t, int64(992800), expectedMaxScore)\n}\n\nfunc TestValkeyStore_StructFields(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\n\tassert.Equal(t, \"session:\", store.sessionPrefix)\n\tassert.Equal(t, \"session:expiry\", store.expiryIndexKey)\n\tassert.Equal(t, \"session:last_activity\", store.lastActivityIndexKey)\n}\n\nfunc TestValkeyStore_InterfaceCompliance(t *testing.T) {\n\tvar _ Store = (*valkeyStore)(nil)\n}\n","after":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tvalkey \"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc newTestValkeyStore(t *testing.T) (*valkeyStore, *miniredis.Miniredis) {\n\tt.Helper()\n\tmr, err := miniredis.Run()\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { mr.Close() })\n\n\tcli, err := valkey.NewClient(valkey.ClientOption{\n\t\tInitAddress: []string{mr.Addr()},\n\t})\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { cli.Close() })\n\n\treturn &valkeyStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}, mr\n}\n\nfunc testValkeySandboxInfo(sessionID string) *types.SandboxInfo {\n\tnow := time.Now().UTC()\n\treturn &types.SandboxInfo{\n\t\tSessionID:      sessionID,\n\t\tSandboxName:    \"test-sandbox\",\n\t\tSandboxID:      \"sb-123\",\n\t\tWorkloadName:   \"agent-runtime\",\n\t\tNamespace:      \"default\",\n\t\tKind:           \"AgentRuntime\",\n\t\tPodIP:          \"10.0.0.1\",\n\t\tEntryPoints:    []types.EntryPoint{{Path: \"/api\", Protocol: \"http\", Endpoint: \"http://10.0.0.1:8080\"}},\n\t\tCreatedAt:      now,\n\t\tExpiresAt:      now.Add(24 * time.Hour),\n\t\tStatus:         \"running\",\n\t\tLastActivityAt: now.Add(5 * time.Minute),\n\t}\n}\n\nfunc TestValkeyStore_Ping(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\terr := store.Ping(ctx)\n\trequire.NoError(t, err)\n}\n\nfunc TestValkeyStore_GetSandbox_NotFound(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\n\tresult, err := store.GetSandbox(ctx, \"nonexistent\")\n\tassert.ErrorIs(t, err, ErrNotFound)\n\tassert.Nil(t, result)\n}\n\nfunc TestValkeyStore_GetSandbox_Found(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-get\")\n\n\tdata, err := encodeSandboxInfo(info)\n\trequire.NoError(t, err)\n\terr = store.cli.Do(ctx, store.cli.B().Set().Key(\"session:sess-get\").Value(string(data)).Build()).Error()\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandbox(ctx, \"sess-get\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, info.SessionID, result.SessionID)\n\tassert.Equal(t, info.SandboxID, result.SandboxID)\n}\n\nfunc TestValkeyStore_StoreSandbox_NilInfo(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\n\terr := store.StoreSandbox(ctx, \"sess-001\", nil)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"sandbox is nil\")\n}\n\nfunc TestValkeyStore_StoreSandbox_ZeroExpiry(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\tinfo := &types.SandboxInfo{\n\t\tSessionID: \"sess-zero\",\n\t\tExpiresAt: time.Time{},\n\t}\n\n\terr := store.StoreSandbox(ctx, \"sess-zero\", info)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"ExpiresAt is zero\")\n}\n\nfunc TestValkeyStore_StoreSandbox_Success(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-store\")\n\n\terr := store.StoreSandbox(ctx, \"sess-store\", info)\n\trequire.NoError(t, err)\n\n\tval, err := mr.Get(\"session:sess-store\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, val, \"sess-store\")\n\n\tmembers, err := mr.ZMembers(\"session:expiry\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, members, \"sess-store\")\n\n\tmembers, err = mr.ZMembers(\"session:last_activity\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, members, \"sess-store\")\n}\n\nfunc TestValkeyStore_StoreSandbox_RoundTrip(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-roundtrip\")\n\n\terr := store.StoreSandbox(ctx, \"sess-roundtrip\", info)\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandbox(ctx, \"sess-roundtrip\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, info.SessionID, result.SessionID)\n\tassert.Equal(t, info.SandboxID, result.SandboxID)\n\tassert.Equal(t, info.Namespace, result.Namespace)\n\tassert.Equal(t, info.Status, result.Status)\n}\n\nfunc TestValkeyStore_StoreSandbox_Duplicate(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-dup\")\n\n\terr := store.StoreSandbox(ctx, \"sess-dup\", info)\n\trequire.NoError(t, err)\n\n\tinfo2 := testValkeySandboxInfo(\"sess-dup\")\n\tinfo2.SandboxID = \"sb-456\"\n\terr = store.StoreSandbox(ctx, \"sess-dup\", info2)\n\trequire.NoError(t, err)\n\n\tval, err := mr.Get(\"session:sess-dup\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, val, \"sb-123\")\n}\n\nfunc TestValkeyStore_UpdateSandbox_NilInfo(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n\n\terr := store.UpdateSandbox(ctx, \"sess-001\", nil)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"sandbox is nil\")\n}\n\nfunc TestValkeyStore_UpdateSandbox_KeyNotExists(t *testing.T) {\n\tstore, _ := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-missing\")\n\n\terr := store.UpdateSandbox(ctx, \"sess-missing\", info)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"key not exists\")\n}\n\nfunc TestValkeyStore_UpdateSandbox_Success(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-update\")\n\n\terr := store.StoreSandbox(ctx, \"sess-update\", info)\n\trequire.NoError(t, err)\n\n\tinfo.SandboxID = \"sb-updated\"\n\tinfo.Status = \"stopped\"\n\terr = store.UpdateSandbox(ctx, \"sess-update\", info)\n\trequire.NoError(t, err)\n\n\tval, err := mr.Get(\"session:sess-update\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, val, \"sb-updated\")\n\tassert.Contains(t, val, \"stopped\")\n}\n\nfunc TestValkeyStore_DeleteSandboxBySessionID(t *testing.T) {\n\tstore, mr := newTestValkeyStore(t)\n\tctx := context.Background()\n\tinfo := testValkeySandboxInfo(\"sess-del\")\n\n\terr := store.StoreSandbox(ctx, \"sess-del\", info)\n\trequire.NoError(t, err)\n\n\terr = store.DeleteSandboxBySessionID(ctx, \"sess-del\")\n\trequire.NoError(t, err)\n\n\texists := mr.Exists(\"session:sess-del\")\n\tassert.False(t, exists)\n\n\tmembers, err := mr.ZMembe