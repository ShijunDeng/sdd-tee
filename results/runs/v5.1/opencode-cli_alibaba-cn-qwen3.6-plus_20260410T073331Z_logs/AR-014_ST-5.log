Y_ADDR\")\n\toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n\t}()\n\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Unsetenv(\"VALKEY_PASSWORD\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\n\tstore, err := newValkeyStore()\n\trequire.NoError(t, err)\n\trequire.NotNil(t, store)\n}\n\nfunc TestNewValkeyStore_PasswordRequiredTrue(t *testing.T) {\n\toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n\toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n\toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n\tdefer func() {\n\t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n\t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n\t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n\t}()\n\n\tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tos.Unsetenv(\"VALKEY_PASSWORD\")\n\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"true\")\n\n\t_, err := newValkeyStore()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"VALKEY_PASSWORD is required\")\n}\n\nfunc TestValkeyStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n\tat := time.Time{}\n\tassert.True(t, at.IsZero())\n\n\tif at.IsZero() {\n\t\tat = time.Now()\n\t}\n\tassert.False(t, at.IsZero())\n\tassert.True(t, at.After(time.Now().Add(-time.Second)))\n}\n\nfunc TestValkeyStore_ListExpiredSandboxes_ScoreCalculation(t *testing.T) {\n\tbase := time.Unix(1000000, 0)\n\tbefore := base.Add(-time.Hour)\n\texpectedMaxScore := before.Unix()\n\n\tassert.Equal(t, int64(996400), expectedMaxScore)\n}\n\nfunc TestValkeyStore_ListInactiveSandboxes_ScoreCalculation(t *testing.T) {\n\tbase := time.Unix(1000000, 0)\n\tbefore := base.Add(-2 * time.Hour)\n\texpectedMaxScore := before.Unix()\n\n\tassert.Equal(t, int64(992800), expectedMaxScore)\n}\n\nfunc TestValkeyStore_StructFields(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\n\tassert.Equal(t, \"session:\", store.sessionPrefix)\n\tassert.Equal(t, \"session:expiry\", store.expiryIndexKey)\n\tassert.Equal(t, \"session:last_activity\", store.lastActivityIndexKey)\n}\n\nfunc TestValkeyStore_InterfaceCompliance(t *testing.T) {\n\tvar _ Store = (*valkeyStore)(nil)\n}\n","additions":3,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey_test.go","time":{"start":1775837224396,"end":1775837224593}}}}
