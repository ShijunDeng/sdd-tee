{"type":"tool_use","timestamp":1775837173156,"sessionID":"ses_287ddf2ddffeKgyYIqXjT8EJwx","part":{"id":"prt_d7824d1c3001H7wLYjwSx6rS4n","messageID":"msg_d7824c7d1001DEahssrfvpA2Uq","sessionID":"ses_287ddf2ddffeKgyYIqXjT8EJwx","type":"tool","tool":"read","callID":"call_cd10222ecea44637a416d897","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"errors\"\n6: \t\"fmt\"\n7: \t\"os\"\n8: \t\"strconv\"\n9: \t\"strings\"\n10: \t\"time\"\n11: \n12: \tvalkey \"github.com/valkey-io/valkey-go\"\n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: )\n15: \n16: type valkeyStore struct {\n17: \tcli                  valkey.Client\n18: \tsessionPrefix        string\n19: \texpiryIndexKey       string\n20: \tlastActivityIndexKey string\n21: }\n22: \n23: func newValkeyStore() (Store, error) {\n24: \taddr := os.Getenv(\"VALKEY_ADDR\")\n25: \tif addr == \"\" {\n26: \t\treturn nil, errors.New(\"VALKEY_ADDR is required\")\n27: \t}\n28: \n29: \taddresses := strings.Split(addr, \",\")\n30: \tfor i := range addresses {\n31: \t\taddresses[i] = strings.TrimSpace(addresses[i])\n32: \t}\n33: \n34: \tpassword := os.Getenv(\"VALKEY_PASSWORD\")\n35: \tpasswordRequired := strings.ToLower(os.Getenv(\"VALKEY_PASSWORD_REQUIRED\"))\n36: \tif password == \"\" && passwordRequired != \"false\" {\n37: \t\treturn nil, errors.New(\"VALKEY_PASSWORD is required (set VALKEY_PASSWORD_REQUIRED=false to disable)\")\n38: \t}\n39: \n40: \tdisableCache := strings.ToLower(os.Getenv(\"VALKEY_DISABLE_CACHE\")) == \"true\"\n41: \tforceSingle := strings.ToLower(os.Getenv(\"VALKEY_FORCE_SINGLE\")) == \"true\"\n42: \n43: \tclient, err := valkey.NewClient(valkey.ClientOption{\n44: \t\tInitAddress:       addresses,\n45: \t\tPassword:          password,\n46: \t\tDisableCache:      disableCache,\n47: \t\tForceSingleClient: forceSingle,\n48: \t})\n49: \tif err != nil {\n50: \t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n51: \t}\n52: \n53: \treturn &valkeyStore{\n54: \t\tcli:                  client,\n55: \t\tsessionPrefix:        \"session:\",\n56: \t\texpiryIndexKey:       \"session:expiry\",\n57: \t\tlastActivityIndexKey: \"session:last_activity\",\n58: \t}, nil\n59: }\n60: \n61: func (v *valkeyStore) Ping(ctx context.Context) error {\n62: \tresp, err := v.cli.Do(ctx, v.cli.B().Ping().Build()).ToString()\n63: \tif err != nil {\n64: \t\treturn err\n65: \t}\n66: \tif resp != \"PONG\" {\n67: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", resp)\n68: \t}\n69: \treturn nil\n70: }\n71: \n72: func (v *valkeyStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n73: \tkey := v.sessionKey(sessionID)\n74: \tdata, err := v.cli.Do(ctx, v.cli.B().Get().Key(key).Build()).ToString()\n75: \tif valkey.IsValkeyNil(err) {\n76: \t\treturn nil, ErrNotFound\n77: \t}\n78: \tif err != nil {\n79: \t\treturn nil, err\n80: \t}\n81: \treturn decodeSandboxInfo([]byte(data))\n82: }\n83: \n84: func (v *valkeyStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n85: \tif info == nil {\n86: \t\treturn errors.New(\"sandbox is nil\")\n87: \t}\n88: \tif info.ExpiresAt.IsZero() {\n89: \t\treturn errors.New(\"sandbox ExpiresAt is zero\")\n90: \t}\n91: \n92: \tdata, err := encodeSandboxInfo(info)\n93: \tif err != nil {\n94: \t\treturn fmt.Errorf(\"marshal sandbox: %w\", err)\n95: \t}\n96: \n97: \tkey := v.sessionKey(sessionID)\n98: \tnow := float64(time.Now().Unix())\n99: \texpiryScore := float64(info.ExpiresAt.Unix())\n100: \n101: \tresults := v.cli.DoMulti(ctx,\n102: \t\tv.cli.B().Setnx().Key(key).Value(string(data)).Build(),\n103: \t\tv.cli.B().Zadd().Key(v.expiryIndexKey).ScoreMember().ScoreMember(expiryScore, sessionID).Build(),\n104: \t\tv.cli.B().Zadd().Key(v.lastActivityIndexKey).ScoreMember().ScoreMember(now, sessionID).Build(),\n105: \t)\n106: \n107: \tfor _, result := range results {\n108: \t\tif err := result.Error(); err != nil {\n109: \t\t\treturn err\n110: \t\t}\n111: \t}\n112: \treturn nil\n113: }\n114: \n115: func (v *valkeyStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n116: \tif info == nil {\n117: \t\treturn errors.New(\"sandbox is nil\")\n118: \t}\n119: \n120: \tdata, err := encodeSandboxInfo(info)\n121: \tif err != nil {\n122: \t\treturn fmt.Errorf(\"marshal sandbox: %w\", err)\n123: \t}\n124: \n125: \tkey := v.sessionKey(sessionID)\n126: \tresp, err := v.cli.Do(ctx, v.cli.B().Set().Key(key).Value(string(data)).Xx().Build()).ToString()\n127: \tif err != nil {\n128: \t\treturn err\n129: \t}\n130: \tif resp != \"OK\" {\n131: \t\treturn fmt.Errorf(\"key not exists: %s\", key)\n132: \t}\n133: \treturn nil\n134: }\n135: \n136: func (v *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n137: \tresults := v.cli.DoMulti(ctx,\n138: \t\tv.cli.B().Del().Key(v.sessionPrefix+sessionID).Build(),\n139: \t\tv.cli.B().Zrem().Key(v.expiryIndexKey).Member(sessionID).Build(),\n140: \t\tv.cli.B().Zrem().Key(v.lastActivityIndexKey).Member(sessionID).Build(),\n141: \t)\n142: \n143: \tfor _, result := range results {\n144: \t\tif err := result.Error(); err != nil {\n145: \t\t\treturn err\n146: \t\t}\n147: \t}\n148: \treturn nil\n149: }\n150: \n151: func (v *valkeyStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n152: \tsessionIDs, err := v.cli.Do(ctx, v.cli.B().Zrange().Key(v.expiryIndexKey).Min(\"0\").Max(\"-1\").Build()).AsStrSlice()\n153: \tif err != nil {\n154: \t\treturn nil, err\n155: \t}\n156: \n157: \tresult := make(map[string]*types.SandboxInfo)\n158: \tfor _, id := range sessionIDs {\n159: \t\tinfo, err := v.GetSandbox(ctx, id)\n160: \t\tif err != nil {\n161: \t\t\tif err == ErrNotFound {\n162: \t\t\t\tcontinue\n163: \t\t\t}\n164: \t\t\treturn nil, err\n165: \t\t}\n166: \t\tresult[id] = info\n167: \t}\n168: \n169: \treturn result, nil\n170: }\n171: \n172: func (v *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n173: \tif sessionID == \"\" {\n174: \t\treturn errors.New(\"sessionID is empty\")\n175: \t}\n176: \n177: \tif at.IsZero() {\n178: \t\tat = time.Now()\n179: \t}\n180: \n181: \tkey := v.sessionKey(sessionID)\n182: \texists, err := v.cli.Do(ctx, v.cli.B().Exists().Key(key).Build()).AsInt64()\n183: \tif err != nil {\n184: \t\treturn err\n185: \t}\n186: \tif exists == 0 {\n187: \t\treturn ErrNotFound\n188: \t}\n189: \n190: \tscore := float64(at.Unix())\n191: \treturn v.cli.Do(ctx, v.cli.B().Zadd().Key(v.lastActivityIndexKey).ScoreMember().ScoreMember(score, sessionID).Build()).Error()\n192: }\n193: \n194: func (v *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n195: \tif limit <= 0 {\n196: \t\treturn nil, nil\n197: \t}\n198: \n199: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n200: \tsessionIDs, err := v.cli.Do(ctx, v.cli.B().Zrangebyscore().Key(v.expiryIndexKey).Min(\"-inf\").Max(maxScore).Limit(0, int64(limit)).Build()).AsStrSlice()\n201: \tif err != nil {\n202: \t\treturn nil, err\n203: \t}\n204: \n205: \tvar result []*types.SandboxInfo\n206: \tfor _, id := range sessionIDs {\n207: \t\tinfo, err := v.GetSandbox(ctx, id)\n208: \t\tif err != nil {\n209: \t\t\tif err == ErrNotFound {\n210: \t\t\t\tcontinue\n211: \t\t\t}\n212: \t\t\treturn nil, err\n213: \t\t}\n214: \t\tresult = append(result, info)\n215: \t}\n216: \n217: \treturn result, nil\n218: }\n219: \n220: func (v *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n221: \tif limit <= 0 {\n222: \t\treturn nil, nil\n223: \t}\n224: \n225: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n226: \tsessionIDs, err := v.cli.Do(ctx, v.cli.B().Zrangebyscore().Key(v.lastActivityIndexKey).Min(\"-inf\").Max(maxScore).Limit(0, int64(limit)).Build()).AsStrSlice()\n227: \tif err != nil {\n228: \t\treturn nil, err\n229: \t}\n230: \n231: \tvar result []*types.SandboxInfo\n232: \tfor _, id := range sessionIDs {\n233: \t\tinfo, err := v.GetSandbox(ctx, id)\n234: \t\tif err != nil {\n235: \t\t\tif err == ErrNotFound {\n236: \t\t\t\tcontinue\n237: \t\t\t}\n238: \t\t\treturn nil, err\n239: \t\t}\n240: \t\tresult = append(result, info)\n241: \t}\n242: \n243: \treturn result, nil\n244: }\n245: \n246: func (v *valkeyStore) sessionKey(sessionID string) string {\n247: \treturn v.sessionPrefix + sessionID\n248: }\n249: \n250: func (v *valkeyStore) Close() error {\n251: \tv.cli.Close()\n252: \treturn nil\n253: }\n\n(End of file - total 253 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tvalkey \"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey.go","time":{"start":1775837173146,"end":1775837173154}}}}
