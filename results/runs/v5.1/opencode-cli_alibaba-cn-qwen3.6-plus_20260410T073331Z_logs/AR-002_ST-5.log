data":{"preview":"package v1alpha1\n\nimport (\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n)\n\nfunc TestSchemeRegistration(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\terr := AddToScheme(scheme)\n\tassert.NoError(t, err)\n\n\tgvk := SchemeGroupVersion.WithKind(\"AgentRuntime\")\n\tobj, err := scheme.New(gvk)\n\tassert.NoError(t, err)\n\tassert.IsType(t, &AgentRuntime{}, obj)\n\n\tgvkList := SchemeGroupVersion.WithKind(\"AgentRuntimeList\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/groupversion_info_test.go","time":{"start":1775810188315,"end":1775810188329}}}}
