ing.T) {\n34: \tassert.Equal(t, GroupVersion, SchemeGroupVersion)\n35: }\n36: \n37: func TestResourceHelper(t *testing.T) {\n38: \tgvr := Resource(\"agentruntimes\")\n39: \tassert.Equal(t, \"runtime.agentcube.volcano.sh\", gvr.Group)\n40: \tassert.Equal(t, \"v1alpha1\", gvr.Version)\n41: \tassert.Equal(t, \"agentruntimes\", gvr.Resource)\n42: \n43: \tgvrCI := Resource(\"codeinterpreters\")\n44: \tassert.Equal(t, \"runtime.agentcube.volcano.sh\", gvrCI.Group)\n45: \tassert.Equal(t, \"v1alpha1\", gvrCI.Version)\n46: \tassert.Equal(t, \"codeinterpreters\", gvrCI.Resource)\n47: }\n\n(End of file - total 47 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n)\n\nfunc TestGroupVersionConstants(t *testing.T) {\n\tassert.Equal(t, \"runtime.agentcube.volcano.sh\", GroupVersion.Group)\n\tassert.Equal(t, \"v1alpha1\", GroupVersion.Version)\n\tassert.Equal(t, \"AgentRuntime\", AgentRuntimeKind)\n\tassert.Equal(t, \"AgentRuntimeList\", AgentRuntimeListKind)\n\n\tgvr := Resource(\"agentruntimes\")\n\tassert.Equal(t, schema.GroupVersionResource{\n\t\tGroup: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\", Resource: \"agentruntimes\",\n\t}, gvr)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/register_test.go","time":{"start":1775810188885,"end":1775810188892}}}}
