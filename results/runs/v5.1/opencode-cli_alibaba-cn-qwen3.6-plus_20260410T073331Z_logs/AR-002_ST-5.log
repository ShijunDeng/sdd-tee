\n258: \tif in.RuntimeClassName != nil {\n259: \t\tin, out := &in.RuntimeClassName, &out.RuntimeClassName\n260: \t\t*out = new(string)\n261: \t\t**out = **in\n262: \t}\n263: \tif in.ImagePullSecrets != nil {\n264: \t\tin, out := &in.ImagePullSecrets, &out.ImagePullSecrets\n265: \t\t*out = make([]corev1.LocalObjectReference, len(*in))\n266: \t\tcopy(*out, *in)\n267: \t}\n268: \tif in.Environment != nil {\n269: \t\tin, out := &in.Environment, &out.Environment\n270: \t\t*out = make([]corev1.EnvVar, len(*in))\n271: \t\tfor i := range *in {\n272: \t\t\t(*in)[i].DeepCopyInto(&(*out)[i])\n273: \t\t}\n274: \t}\n275: \tif in.Command != nil {\n276: \t\tin, out := &in.Command, &out.Command\n277: \t\t*out = make([]string, len(*in))\n278: \t\tcopy(*out, *in)\n279: \t}\n280: \tif in.Args != nil {\n281: \t\tin, out := &in.Args, &out.Args\n282: \t\t*out = make([]string, len(*in))\n283: \t\tcopy(*out, *in)\n284: \t}\n285: \tin.Resources.DeepCopyInto(&out.Resources)\n286: }\n287: \n288: func (in *CodeInterpreterSandboxTemplate) DeepCopy() *CodeInterpreterSandboxTemplate {\n289: \tif in == nil {\n290: \t\treturn nil\n291: \t}\n292: \tout := new(CodeInterpreterSandboxTemplate)\n293: \tin.DeepCopyInto(out)\n294: \treturn out\n295: }\n296: \n297: func (in *CodeInterpreterList) DeepCopyInto(out *CodeInterpreterList) {\n298: \t*out = *in\n299: \tout.TypeMeta = in.TypeMeta\n300: \tin.ListMeta.DeepCopyInto(&out.ListMeta)\n301: \tif in.Items != nil {\n302: \t\tin, out := &in.Items, &out.Items\n303: \t\t*out = make([]CodeInterpreter, len(*in))\n304: \t\tfor i := range *in {\n305: \t\t\t(*in)[i].DeepCopyInto(&(*out)[i])\n306: \t\t}\n307: \t}\n308: }\n309: \n310: func (in *CodeInterpreterList) DeepCopy() *CodeInterpreterList {\n311: \tif in == nil {\n312: \t\treturn nil\n313: \t}\n314: \tout := new(CodeInterpreterList)\n315: \tin.DeepCopyInto(out)\n316: \treturn out\n317: }\n318: \n319: func (in *CodeInterpreterList) DeepCopyObject() runtime.Object {\n320: \tif c := in.DeepCopy(); c != nil {\n32