int = self._infer_entrypoint(workspace_path, metadata.language)\n33: \n34:         self._validate_language_compatibility(workspace_path, metadata)\n35:         self._process_dependencies(workspace_path, metadata)\n36:         dockerfile_path = self._generate_dockerfile(workspace_path, metadata)\n37:         self._update_pack_metadata(workspace_path, metadata, dockerfile_path)\n38:         final_workspace = self._prepare_output_path(workspace_path, options.get(\"output\"))\n39: \n40:         return {\n41:             \"agent_name\": metadata.agent_name,\n42:             \"workspace_path\": str(workspace_path),\n43:             \"metadata_path\": str(workspace_path / \"agent_metadata.yaml\"),\n44:             \"dockerfile_path\": str(dockerfile_path) if dockerfile_path else None,\n45:             \"output_path\": str(final_workspace),\n46:         }\n47: \n48:     def _validate_workspace_structure(self, workspace_path: Path) -> None:\n49:         \"\"\"Validate that the workspace path exists and is a directory.\"\"\"\n50:         if not workspace_path.exists():\n51:             raise ValueError(f\"Workspace path does not exist: {workspace_path}\")\n52:         if not workspace_path.is_dir():\n53:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n54: \n55:     def _load_or_create_metadata(self, workspace_path: Path, options: Dict[str, Any]) -> AgentMetadata:\n56:         \"\"\"Load existing metadata or create new from options.\"\"\"\n57:         metadata = self.metadata_service.load_metadata(workspace_path)\n58:         if metadata is not None:\n59:             return metadata\n60: \n61:         agent_name = options.get(\"agent_name\") or workspace_path.name\n62:         return AgentMetadata(\n63:             agent_name=agent_name,\n64:             language=options.get(\"language\") or \"python\",\n65:             entrypoint=options.get(\"entrypoint\") or \"\",\n66:             port=options.get(\"port\") or 8080,\n67:             build_mode=options.get(\"build_mode\") or \"local\",\n68:             description=options.get(\"description\"),\n69:             requirements_file=options.get(\"requirements_file\"),\n70:         )\n71: \n72:     def _apply_option_overrides(self, metadata: AgentMetadata, options: Dict[str, Any]) -> AgentMetadata:\n73:         \"\"\"Apply CLI option overrides to existing metadata.\"\"\"\n74:         updates: Dict[str, Any] = {}\n75:         override_keys = [\n76:             \"agent_name\", \"language\", \"entrypoint\", \"port\", \"build_mode\",\n77:             \"description\", \"region\", \"workload_manager_url\", \"router_url\",\n78:             \"readiness_probe_path\", \"readiness_probe_port\",\n79:             \"registry_url\", \"registry_username\", \"registry_password\", \"agent_endpoint\",\n80:         ]\n81:         for key in override_keys:\n82:             value = options.get(key)\n83:             if value is not None and value != \"\":\n84:                 updates[key] = value\n85: \n86:         if updates:\n87:             metadata = metadata.model_copy(update=updates)\n88: \n89:         return metadata\n90: \n91:     def _validate_language_compatibility(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n92:         \"\"\"Dispatch to language-specific validation.\"\"\"\n93:         if metadata.language == \"python\":\n94:             self._validate_python_compatibility(workspace_path)\n95:         elif metadata.language == \"java\":\n96:             self._validate_java_compatibility(workspace_path)\n97:         else:\n98:             raise ValueError(f\"Unsupported language: {metadata.language}\")\n99: \n100:     def _validate_python_compatibility(self, workspace_path: Path) -> None:\n101:         \"\"\"Validate Python workspace has at least one .py file.\"\"\"\n102:         py_files = list(workspace_path.glob(\"*.py\"))\n103:         if not py_files:\n104:             raise ValueError(\"No Python files found in workspace\")\n105: \n106:     def _validate_java_compatibility(self, workspace_path: Path) -> None:\n107:         \"\"\"Validate Java workspace has a valid pom.xml.\"\"\"\n108:         pom = workspace_path / \"pom.xml\"\n109:         if not pom.exists():\n110:             raise ValueError(\"pom.xml is required for Java projects\")\n111:         try:\n112:             ET.parse(str(pom))\n113:         except ET.ParseError:\n114:             raise ValueError(\"Invalid pom.xml: not valid XML\")\n115: \n116:     def _process_dependencies(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n117:         \"\"\"Dispatch to language-specific dependency processing.\"\"\"\n118:         if metadata.language == \"python\":\n119:             self._process_python_dependencies(workspace_path, metadata)\n120:         elif metadata.language == \"java\":\n121:             self._process_java_dependencies(workspace_path)\n122: \n123:     def _process_python_dependencies(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n124:         \"\"\"Validate Python requirements file.\"\"\"\n125:         req_file = metadata.requirements_file or \"requirements.txt\"\n126:         req_path = workspace_path / req_file\n127:         if req_path.exists():\n128:             content = req_path.read_text()\n129:             for line in content.splitlines():\n130:                 line = line.strip()\n131:                 if line and not line.startswith(\"#\") and not line.startswith(\"-\"):\n132:                     pass\n133: \n134:     def _process_java_dependencies(self, workspace_path: Path) -> None:\n135:         \"\"\"Validate Java pom.xml has dependencies section.\"\"\"\n136:         pom = workspace_path / \"pom.xml\"\n137:         try:\n138:             tree = ET.parse(str(pom))\n139:             root = tree.getroot()\n140:             ns = \"\"\n141:             if root.tag.startswith(\"{\"):\n142:                 ns = root.tag.split(\"}\")[0] + \"}\"\n143:             deps = root.find(f\"{ns}dependencies\")\n144:             if deps is None:\n145:                 pass\n146:         except ET.ParseError:\n147:             pass\n148: \n149:     def _generate_dockerfile(self, workspace_path: Path, metadata: AgentMetadata) -> Optional[Path]:\n150:         \"\"\"Generate a Dockerfile if one doesn't already exist.\"\"\"\n151:         dockerfile = workspace_path / \"Dockerfile\"\n152:         if dockerfile.exists():\n153:             return dockerfile\n154: \n155:         if metadata.language == \"python\":\n156:             content = self._generate_python_dockerfile(metadata)\n157:         elif metadata.language == \"java\":\n158:             content = self._generate_java_dockerfile(metadata)\n159:         else:\n160:             return None\n161: \n162:         dockerfile.write_text(content)\n163:         return dockerfile\n164: \n165:     def _generate_python_dockerfile(self, metadata: AgentMetadata) -> str:\n166:         \"\"\"Generate a Python Dockerfile.\"\"\"\n167:         req_file = metadata.requirements_file or \"requirements.txt\"\n168:         entrypoint_parts = metadata.entrypoint.split()\n169:         cmd_json = json_array(entrypoint_parts)\n170:         return (\n171:             f\"FROM python:3.10-slim\\n\"\n172:             f\"WORKDIR /app\\n\"\n173:             f\"COPY {req_file} .\\n\"\n174:             f\"RUN pip install --no-cache-dir -r {req_file}\\n\"\n175:             f\"COPY . .\\n\"\n176:             f\"EXPOSE {metadata.port}\\n\"\n177:             f\"CMD {cmd_json}\\n\"\n178:         )\n179: \n180:     def _generate_java_dockerfile(self, metadata: AgentMetadata) -> str:\n181:         \"\"\"Generate a Java multi-stage Dockerfile.\"\"\"\n182:         entrypoint_parts = metadata.entrypoint.split()\n183:         cmd_json = json_array(entrypoint_parts)\n184:         return (\n185:             \"FROM maven:3.9-eclipse-temurin-17 AS build\\n\"\n186:             \"WORKDIR /app\\n\"\n187:             \"COPY pom.xml .\\n\"\n188:             \"RUN mvn package -DskipTests\\n\"\n189:             \"\\n\"\n190:             \"FROM eclipse-temurin:17-jre\\n\"\n191:             \"WORKDIR /app\\n\"\n192:             \"COPY --from=build /app/target/*.jar app.jar\\n\"\n193:             f\"EXPOSE {metadata.port}\\n\"\n194:             f\"CMD {cmd_json}\\n\"\n195:         )\n196: \n197:     def _update_pack_metadata(self, workspace_path: Path, metadata: AgentMetadata, dockerfile_path: Optional[Path]) -> None:\n198:         \"\"\"Save final metadata to agent_metadata.yaml.\"\"\"\n199:         if dockerfile_path is not None:\n200:             metadata = metadata.model_copy(update={\n201:                 \"image\": {\"dockerfile\": str(dockerfile_path)},\n202:             })\n203:         self.metadata_service.save_metadata(workspace_path, metadata)\n204: \n205:     def _prepare_output_path(self, workspace_path: Path, output_path: Optional[str]) -> Path:\n206:         \"\"\"Resolve the output path, creating directories if needed.\"\"\"\n207:         if output_path:\n208:             out = Path(output_path).resolve()\n209:             out.mkdir(parents=True, exist_ok=True)\n210:             return out\n211:         return workspace_path\n212: \n213:     def _infer_entrypoint(self, workspace_path: Path, language: str) -> str:\n214:         \"\"\"Infer the entrypoint command from workspace contents.\"\"\"\n215:         if language == \"python\":\n216:             py_files = sorted(workspace_path.glob(\"*.py\"))\n217:             if py_files:\n218:                 return f\"python {py_files[0].name}\"\n219:             raise ValueError(\"No Python files found in workspace. Provide --entrypoint explicitly.\")\n220:         elif language == \"java\":\n221:             return \"java -jar target/*.jar\"\n222:         raise ValueError(f\"Cannot infer entrypoint for language: {language}\")\n223: \n224: \n225: def json_array(parts: list[str]) -> str:\n226:     \"\"\"Format a list of strings as a JSON array string.\"\"\"\n227:     quoted = [f'\"{p}\"' for p in parts]\n228:     return \"[\" + \", \".join(quoted) + \"]\"\n\n(End of file - total 228 lines)\n</content>","metadata":{"preview":"\"\"\"PackRuntime - orchestrates the agent workspace packaging lifecycle.\"\"\"\n\nfrom __future__ import annotations\n\nimport xml.etree.ElementTree as ET\nfrom dataclasses import asdict\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.models.pack_models import MetadataOptions\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass PackRuntime:\n    \"\"\"Orchestrates validation, metadata merging, and Dockerfile generation for an agent workspace.\"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose\n        self.metadata_service = MetadataService(verbose=verbose)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/pack_runtime.py","time":{"start":1775851600520,"end":1775851600528}}}}
{"type":"tool_use","timestamp":1775851601715,"sessionID":"ses_28703d465ffex2hAFyWeo9SQ1g","part":{"id":"prt_d7900faf9001BHPd5AWSa8Z0W6","messageID":"msg_d7900d686001LEJVZ251nnuLM3","sessionID":"ses_28703d465ffex2hAFyWeo9SQ1g","type":"tool","tool":"read","callID":"call_3b6d64cc684d40f4b9a061d4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Metadata service for loading, saving, and updating agent metadata.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from pathlib import Path\n6: from typing import Any, Dict, List, Optional\n7: \n8: import yaml\n9: from pydantic import BaseModel, Field, field_validator\n10: \n11: \n12: class AgentMetadata(BaseModel):\n13:     \"\"\"Pydantic model representing agent metadata.\"\"\"\n14: \n15:     agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n16:     description: Optional[str] = Field(None, description=\"Human-readable summary\")\n17:     language: str = Field(\"python\", description=\"Programming language used\")\n18:     entrypoint: str = Field(..., description=\"Command to launch the agent\")\n19:     port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n20:     build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n21:     region: Optional[str] = Field(None, description=\"Deployment region\")\n22:     version: Optional[str] = Field(None, description=\"Semantic version string for publishing\")\n23:     image: Optional[Dict[str, Any]] = Field(None, description=\"Container image information\")\n24:     auth: Optional[Dict[str, Any]] = Field(None, description=\"Authentication configuration\")\n25:     requirements_file: Optional[str] = Field(\"requirements.txt\", description=\"Python dependency file\")\n26:     registry_url: Optional[str] = Field(\"\", description=\"Registry URL for image publishing\")\n27:     registry_username: Optional[str] = Field(\"\", description=\"Registry username\")\n28:     registry_password: Optional[str] = Field(\"\", description=\"Registry password\")\n29:     agent_endpoint: Optional[str] = Field(None, description=\"Agent endpoint URL\")\n30:     workload_manager_url: Optional[str] = Field(None, description=\"URL for the Workload Manager\")\n31:     router_url: Optional[str] = Field(None, description=\"URL for the Router\")\n32:     readiness_probe_path: Optional[str] = Field(None, description=\"Path for the readiness probe\")\n33:     readiness_probe_port: Optional[int] = Field(None, description=\"Port for the readiness probe\")\n34:     agent_id: Optional[str] = Field(None, description=\"Agent ID assigned by AgentCube\")\n35:     session_id: Optional[str] = Field(None, description=\"The session ID for the agent\")\n36:     k8s_deployment: Optional[Dict[str, Any]] = Field(None, description=\"Kubernetes deployment information\")\n37: \n38:     @field_validator(\"language\", mode=\"before\")\n39:     @classmethod\n40:     def validate_language(cls, v: Optional[str]) -> str:\n41:         if v is None:\n42:             return \"python\"\n43:         lowered = v.lower()\n44:         if lowered not in (\"python\", \"java\"):\n45:             raise ValueError(f\"Unsupported language: {v}. Must be 'python' or 'java'.\")\n46:         return lowered\n47: \n48:     @field_validator(\"build_mode\", mode=\"before\")\n49:     @classmethod\n50:     def validate_build_mode(cls, v: Optional[str]) -> str:\n51:         if v is None:\n52:             return \"local\"\n53:         lowered = v.lower()\n54:         if lowered not in (\"local\", \"cloud\"):\n55:             raise ValueError(f\"Unsupported build_mode: {v}. Must be 'local' or 'cloud'.\")\n56:         return lowered\n57: \n58:     @field_validator(\"port\")\n59:     @classmethod\n60:     def validate_port(cls, v: int) -> int:\n61:         if v < 1 or v > 65535:\n62:             raise ValueError(f\"Port must be between 1 and 65535, got {v}\")\n63:         return v\n64: \n65: \n66: class MetadataService:\n67:     \"\"\"Service for loading, saving, and updating agent metadata files.\"\"\"\n68: \n69:     METADATA_FILES: List[str] = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n70: \n71:     def __init__(self, verbose: bool = False) -> None:\n72:         self.verbose = verbose\n73: \n74:     def load_metadata(self, workspace_path: Path) -> Optional[AgentMetadata]:\n75:         \"\"\"Load agent metadata from the workspace directory.\n76: \n77:         Tries files in order: agent_metadata.yaml -> agent.yaml -> metadata.yaml.\n78:         Returns None if no metadata file exists.\n79:         \"\"\"\n80:         for filename in self.METADATA_FILES:\n81:             filepath = workspace_path / filename\n82:             if filepath.exists():\n83:                 with open(filepath, \"r\") as f:\n84:                     data = yaml.safe_load(f)\n85:                 if data is None:\n86:                     data = {}\n87:                 return AgentMetadata(**data)\n88:         return None\n89: \n90:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n91:         \"\"\"Save agent metadata to agent_metadata.yaml in the workspace directory.\"\"\"\n92:         filepath = workspace_path / \"agent_metadata.yaml\"\n93:         data = metadata.model_dump(exclude_none=True)\n94:         with open(filepath, \"w\") as f:\n95:             yaml.dump(data, f, default_flow_style=False, indent=2, sort_keys=False)\n96: \n97:     def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n98:         \"\"\"Load existing metadata (or create default), apply updates, save, and return.\"\"\"\n99:         existing = self.load_metadata(workspace_path)\n100:         if existing is None:\n101:             existing = AgentMetadata(\n102:                 agent_name=updates.get(\"agent_name\", workspace_path.name),\n103:                 entrypoint=updates.get(\"entrypoint\", \"\"),\n104:                 language=updates.get(\"language\", \"python\"),\n105:                 port=updates.get(\"port\", 8080),\n106:                 build_mode=updates.get(\"build_mode\", \"local\"),\n107:             )\n108:         merged = existing.model_copy(update=updates)\n109:         self.save_metadata(workspace_path, merged)\n110:         return merged\n111: \n112:     def validate_workspace(self, workspace_path: Path) -> bool:\n113:         \"\"\"Check if the workspace has valid metadata.\"\"\"\n114:         return self.load_metadata(workspace_path) is not None\n115: \n116:     def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n117:         \"\"\"Validate a Python workspace has required files.\"\"\"\n118:         py_files = list(workspace_path.glob(\"*.py\"))\n119:         if not py_files:\n120:             raise ValueError(\"No Python files found in workspace\")\n121:         req_file = metadata.requirements_file or \"requirements.txt\"\n122:         req_path = workspace_path / req_file\n123:         if not req_path.exists():\n124:             raise ValueError(f\"Dependency file not found: {req_file}\")\n125: \n126:     def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n127:         \"\"\"Validate a Java workspace has required files.\"\"\"\n128:         pom = workspace_path / \"pom.xml\"\n129:         if not pom.exists():\n130:             raise ValueError(\"pom.xml is required for Java projects\")\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"\"\"\"Metadata service for loading, saving, and updating agent metadata.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Pydantic model representing agent metadata.\"\"\"\n\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: Optional[str] = Field(None, description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775851601706,"end":1775851601713}}}}
