:     if verbose:\n46:         logging.basicConfig(level=logging.DEBUG)\n47: \n48: \n49: def _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n50:     \"\"\"Handle errors by printing a message and optionally a traceback.\"\"\"\n51:     console.print(f\"[red]Error {command_name}: {e}[/red]\")\n52:     if verbose:\n53:         console.print_exception()\n54:     raise typer.Exit(1)\n55: \n56: \n57: @app.command()\n58: def pack(\n59:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory.\", show_default=True),\n60:     agent_name: Optional[str] = typer.Option(None, \"--agent-name\", help=\"Override the agent name.\"),\n61:     language: Optional[str] = typer.Option(None, \"--language\", help=\"Programming language (python, java).\"),\n62:     entrypoint: Optional[str] = typer.Option(None, \"--entrypoint\", help=\"Override the entrypoint command.\"),\n63:     port: Optional[int] = typer.Option(None, \"--port\", help=\"Port to expose in the Dockerfile.\"),\n64:     build_mode: Optional[str] = typer.Option(None, \"--build-mode\", help=\"Build strategy: local or cloud.\"),\n65:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description.\"),\n66:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for packaged workspace.\"),\n67:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging.\"),\n68: ) -> None:\n69:     \"\"\"Package an agent workspace for the AgentCube lifecycle.\"\"\"\n70:     with Progress(\n71:         SpinnerColumn(),\n72:         TextColumn(\"[progress.description]{task.description}\"),\n73:         transient=True,\n74:     ) as progress:\n75:         task = progress.add_task(\"Packaging agent...\", total=None)\n76:         try:\n77:             runtime = PackRuntime(verbose=verbose)\n78:             from pathlib import Path\n79:             workspace_path = Path(workspace).resolve()\n80:             result = runtime.pack(\n81:                 workspace_path,\n82:                 agent_name=agent_name,\n83:                 language=language,\n84:                 entrypoint=entrypoint,\n85:                 port=port,\n86:                 build_mode=build_mode,\n87:                 description=description,\n88:                 output=output,\n89:             )\n90:             progress.update(task, description=\"Done\")\n91:             console.print(f\"[green]✓[/green] Agent '[bold]{result['agent_name']}[/bold]' packaged successfully!\")\n92:             console.print(f\"  [dim]Workspace:[/dim] {result['workspace_path']}\")\n93:             console.print(f\"  [dim]Metadata: [/dim] {result['metadata_path']}\")\n94:         except Exception as e:\n95:             _handle_error(e, \"packaging agent\", verbose)\n\n(End of file - total 95 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube CLI entry point.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom typing import Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\n\napp = typer.Typer(\n    name=\"agentcube\",\n    help=\"AgentCube CLI - A developer tool for AI agent lifecycle management.\",\n    no_args_is_help=True,\n    rich_markup_mode=\"rich\",\n    add_completion=False,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/cli/main.py","time":{"start":1775851448678,"end":1775851448687}}}}
