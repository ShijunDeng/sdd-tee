r != nil {\n45: \t\tif _, ok := err.(*SessionNotFoundError); ok {\n46: \t\t\tc.JSON(http.StatusNotFound, gin.H{\"error\": err.Error()})\n47: \t\t\treturn\n48: \t\t}\n49: \t\tif _, ok := err.(*SandboxTemplateNotFoundError); ok {\n50: \t\t\tc.JSON(http.StatusNotFound, gin.H{\"error\": err.Error()})\n51: \t\t\treturn\n52: \t\t}\n53: \t\thandleGetSandboxError(c, err)\n54: \t\treturn\n55: \t}\n56: \n57: \tif sessionID == \"\" {\n58: \t\tsessionID = sandboxInfo.SessionID\n59: \t}\n60: \n61: \tif s.storeClient != nil {\n62: \t\tif err := s.storeClient.UpdateSessionLastActivity(ctx, sessionID, time.Time{}); err != nil {\n63: \t\t\tklog.Warningf(\"failed to update last activity for session %s: %v\", sessionID, err)\n64: \t\t}\n65: \t}\n66: \n67: \tif len(sandboxInfo.EntryPoints) == 0 {\n68: \t\tc.JSON(http.StatusNotFound, gin.H{\"error\": \"no entry point found for sandbox\"})\n69: \t\treturn\n70: \t}\n71: \n72: \tif err := s.forwardToSandbox(c, sandboxInfo, kind, sessionID); err != nil {\n73: \t\treturn\n74: \t}\n75: \n76: \tif s.storeClient != nil {\n77: \t\tif err := s.storeClient.UpdateSessionLastActivity(ctx, sessionID, time.Now()); err != nil {\n78: \t\t\tklog.Warningf(\"failed to update last activity for session %s: %v\", sessionID, err)\n79: \t\t}\n80: \t}\n81: }\n82: \n83: func (s *Server) handleAgentInvoke(c *gin.Context) {\n84: \ts.handleInvoke(c, types.AgentRuntimeKind)\n85: }\n86: \n87: func (s *Server) handleCodeInterpreterInvoke(c *gin.Context) {\n88: \ts.handleInvoke(c, types.CodeInterpreterKind)\n89: }\n90: \n91: func (s *Server) forwardToSandbox(c *gin.Context, sandboxInfo *types.SandboxInfo, kind string, sessionID string) error {\n92: \tinvocationPath := c.Param(\"path\")\n93: \tif !strings.HasPrefix(invocationPath, \"/\") {\n94: \t\tinvocationPath = \"/\" + invocationPath\n95: \t}\n96: \n97: \tvar selectedEP *types.EntryPoint\n98: \tfor i := range sandboxInfo.EntryPoints {\n99: \t\tep := &sandboxInfo.EntryPoints[i]\n100: \t\tif strings.HasPrefix(invocationPath, ep.Path) {\n101: \t\t\tselectedEP = ep\n102: \t\t\tbreak\n103: \t\t}\n104: \t}\n105: \tif selectedEP == nil && len(sandboxInfo.EntryPoints) > 0 {\n106: \t\tselectedEP = &sandboxInfo.EntryPoints[0]\n107: \t}\n108: \tif selectedEP == nil {\n109: \t\tc.JSON(http.StatusNotFound, gin.H{\"error\": \"no entry point found for sandbox\"})\n110: \t\treturn nil\n111: \t}\n112: \n113: \ttargetStr := selectedEP.Endpoint\n114: \tif selectedEP.Protocol != \"\" && !strings.Contains(targetStr, \"://\") {\n115: \t\ttargetStr = strings.ToLower(selectedEP.Protocol) + \"://\" + targetStr\n116: \t}\n117: \tif !strings.Contains(targetStr, \"://\") {\n118: \t\ttargetStr = \"http://\" + targetStr\n119: \t}\n120: \n121: \ttargetURL, err := url.Parse(targetStr)\n122: \tif err != nil {\n123: \t\tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"invalid target URL\"})\n124: \t\treturn err\n125: \t}\n126: \n127: \tproxy := httputil.NewSingleHostReverseProxy(targetURL)\n128: \tproxy.Transport = s.httpTransport\n129: \n130: \tproxy.Director = func(req *http.Request) {\n131: \t\treq.URL.Scheme = targetURL.Scheme\n132: \t\treq.URL.Host = targetURL.Host\n133: \t\treq.URL.Path = invocationPath\n134: \t\treq.URL.RawPath = \"\"\n135: \t\treq.Host = targetURL.Host\n136: \n137: \t\treq.Header.Set(\"X-Forwarded-Host\", c.Request.Host)\n138: \t\tif s.config.EnableTLS {\n139: \t\t\treq.Header.Set(\"X-Forwarded-Proto\", \"https\")\n140: \t\t} else {\n141: \t\t\treq.Header.Set(\"X-Forwarded-Proto\", \"http\")\n142: \t\t}\n143: \t\tif existing := req.Header.Get(\"X-Forwarded-For\"); existing != \"\" {\n144: \t\t\treq.Header.Set(\"X-Forwarded-For\", existing+\", \"+c.ClientIP())\n145: \t\t} else {\n146: \t\t\treq.Header.Set(\"X-Forwarded-For\", c.ClientIP())\n147: \t\t}\n148: \n149: \t\tif kind == types.SandboxKind || kind == types.SandboxClaimKind {\n150: \t\t\tif s.jwtManager != nil {\n151: \t\t\t\ttoken, err := s.jwtManager.GenerateToken(map[string]interface{}{\n152: \t\t\t\t\t\"session_id\": sessionID,\n153: \t\t\t\t})\n154: \t\t\t\tif err != nil {\n155: \t\t\t\t\tklog.Errorf(\"failed to generate JWT: %v\", err)\n156: \t\t\t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n157: \t\t\t\t\t\t\"code\":  \"JWT_SIGNING_FAILED\",\n158: \t\t\t\t\t\t\"error\": \"failed to sign request\",\n159: \t\t\t\t\t})\n160: \t\t\t\t\treturn\n161: \t\t\t\t}\n162: \t\t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n163: \t\t\t}\n164: \t\t}\n165: \t}\n166: \n167: \tproxy.ModifyResponse = func(resp *http.Response) error {\n168: \t\tresp.Header.Set(\"x-agentcube-session-id\", sessionID)\n169: \t\treturn nil\n170: \t}\n171: \n172: \tproxy.ErrorHandler = func(w http.ResponseWriter, r *http.Request, err error) {\n173: \t\terrMsg := err.Error()\n174: \t\tif strings.Contains(errMsg, \"connection refused\") {\n175: \t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n176: \t\t\tw.WriteHeader(http.StatusBadGateway)\n177: \t\t\tjson.NewEncoder(w).Encode(gin.H{\"error\": \"sandbox unreachable\"})\n178: \t\t\treturn\n179: \t\t}\n180: \t\tif strings.Contains(errMsg, \"timeout\") || strings.Contains(errMsg, \"context deadline exceeded\") {\n181: \t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n182: \t\t\tw.WriteHeader(http.StatusGatewayTimeout)\n183: \t\t\tjson.NewEncoder(w).Encode(gin.H{\"error\": \"sandbox timeout\"})\n184: \t\t\treturn\n185: \t\t}\n186: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n187: \t\tw.WriteHeader(http.StatusBadGateway)\n188: \t\tjson.NewEncoder(w).Encode(gin.H{\"error\": \"sandbox unreachable\"})\n189: \t}\n190: \n191: \tproxy.ServeHTTP(c.Writer, c.Request)\n192: \treturn nil\n193: }\n\n(End of file - total 193 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/klog/v2\"\n)\n\nfunc handleGetSandboxError(c *gin.Context, err error) {\n\tif statusErr, ok := err.(apierrors.APIStatus); ok {\n\t\tcode := statusErr.Status().Code\n\t\tif code == 0 {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/proxy.go","time":{"start":1775848166869,"end":1775848166875}}}}
{"type":"tool_use","timestamp":1775848168176,"sessionID":"ses_287348949ffemSMrps0exZh022","part":{"id":"prt_d78cc9667001jJRLpiDD651QB1","messageID":"msg_d78cc82ef001oPpIqnVxJ0Hkx4","sessionID":"ses_287348949ffemSMrps0exZh022","type":"tool","tool":"read","callID":"call_7d8b2d913f474612bea74407","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"log\"\n7: \t\"math/rand\"\n8: \t\"net/http\"\n9: \t\"reflect\"\n10: \t\"time\"\n11: \n12: \t\"github.com/gin-gonic/gin\"\n13: \t\"github.com/google/uuid\"\n14: \tcorev1 \"k8s.io/api/core/v1\"\n15: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n16: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n17: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n18: \t\"k8s.io/apimachinery/pkg/labels\"\n19: \t\"k8s.io/apimachinery/pkg/runtime\"\n20: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n21: \t\"k8s.io/client-go/dynamic\"\n22: \t\"k8s.io/client-go/kubernetes\"\n23: \n24: \t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n25: \t\"github.com/volcano-sh/agentcube/client-go/informers/externalversions\"\n26: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n27: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n28: )\n29: \n30: type Store interface {\n31: \tStoreSandbox(ctx context.Context, info *SandboxInfo) error\n32: \tUpdateSandbox(ctx context.Context, sessionID string, info *SandboxInfo) error\n33: \tGetSandbox(ctx context.Context, sessionID string) (*SandboxInfo, error)\n34: \tDeleteSandbox(ctx context.Context, sessionID string) error\n35: \tListSandboxes(ctx context.Context) ([]*SandboxInfo, error)\n36: }\n37: \n38: type SandboxReconcilerWatcher interface {\n39: \tWatchSandboxOnce(namespace, name string) (<-chan SandboxStatus, error)\n40: }\n41: \n42: type TokenCache interface {\n43: \tGetOrCreateUserK8sClient(namespace, saName, token string) (dynamic.Interface, error)\n44: }\n45: \n46: type SandboxCreateHandlerDeps struct {\n47: \tDynamicClient     dynamic.Interface\n48: \tClientset         clientset.Interface\n49: \tKubeClientset     kubernetes.Interface\n50: \tInformerFactory   externalversions.SharedInformerFactory\n51: \tStore             Store\n52: \tReconciler        SandboxReconcilerWatcher\n53: \tTokenCache        TokenCache\n54: \tUserClientFactory UserClientFactory\n55: \tEnableAuth        bool\n56: }\n57: \n58: type UserClientFactory interface {\n59: \tCreateUserClient(token string) (dynamic.Interface, error)\n60: }\n61: \n62: type SandboxCreateHandler struct {\n63: \tdynamicClient     dynamic.Interface\n64: \tclientset         clientset.Interface\n65: \tkubeClientset     kubernetes.Interface\n66: \tinformerFactory   externalversions.SharedInformerFactory\n67: \tstore             Store\n68: \treconciler        SandboxReconcilerWatcher\n69: \ttokenCache        TokenCache\n70: \tuserClientFactory UserClientFactory\n71: \tenableAuth        bool\n72: }\n73: \n74: func NewSandboxCreateHandler(deps *SandboxCreateHandlerDeps) *SandboxCreateHandler {\n75: \treturn &SandboxCreateHandler{\n76: \t\tdynamicClient:     deps.DynamicClient,\n77: \t\tclientset:         deps.Clientset,\n78: \t\tkubeClientset:     deps.KubeClientset,\n79: \t\tinformerFactory:   deps.InformerFactory,\n80: \t\tstore:             deps.Store,\n81: \t\treconciler:        deps.Reconciler,\n82: \t\ttokenCache:        deps.TokenCache,\n83: \t\tuserClientFactory: deps.UserClientFactory,\n84: \t\tenableAuth:        deps.EnableAuth,\n85: \t}\n86: }\n87: \n88: func (h *SandboxCreateHandler) getDynamicClient(c *gin.Context) (dynamic.Interface, error) {\n89: \tif !h.enableAuth {\n90: \t\treturn h.dynamicClient, nil\n91: \t}\n92: \n93: \ttoken := c.GetHeader(\"Authorization\")\n94: \tif token == \"\" {\n95: \t\treturn nil, fmt.Errorf(\"authorization token is required\")\n96: \t}\n97: \tif len(token) > 7 && token[:7] == \"Bearer \" {\n98: \t\ttoken = token[7:]\n99: \t}\n100: \n101: \tnamespace := c.GetString(\"namespace\")\n102: \tsaName := c.GetString(\"serviceAccountName\")\n103: \n104: \tif h.tokenCache != nil {\n105: \t\treturn h.tokenCache.GetOrCreateUserK8sClient(namespace, saName, token)\n106: \t}\n107: \n108: \tif h.userClientFactory != nil {\n109: \t\treturn h.userClientFactory.CreateUserClient(token)\n110: \t}\n111: \n112: \treturn nil, fmt.Errorf(\"no user client factory available\")\n113: }\n114: \n115: func (h *SandboxCreateHandler) CreateAgentRuntimeSandbox(c *gin.Context) {\n116: \tvar sandboxReq CreateSandboxRequest\n117: \tif err := c.ShouldBindJSON(&sandboxReq); err != nil {\n118: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n119: \t\treturn\n120: \t}\n121: \n122: \tsandboxReq.Kind = AgentRuntimeKind\n123: \n124: \tif err := sandboxReq.Validate(); err != nil {\n125: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n126: \t\treturn\n127: \t}\n128: \n129: \tarLister := h.informerFactory.Runtime().V1alpha1().AgentRuntimes().Lister()\n130: \ttemplate, err := arLister.AgentRuntimes(sandboxReq.Namespace).Get(sandboxReq.Name)\n131: \tif err != nil {\n132: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"AgentRuntime %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n133: \t\treturn\n134: \t}\n135: \n136: \tif template.Spec.Template == nil {\n137: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"podTemplate is required\")\n138: \t\treturn\n139: \t}\n140: \n141: \tsessionID := generateSessionID()\n142: \tsandboxName := generateSandboxName(sandboxReq.Name)\n143: \n144: \tsandboxCR, err := h.buildAgentRuntimeSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace)\n145: \tif err != nil {\n146: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n147: \t\treturn\n148: \t}\n149: \n150: \tsandboxInfo := &SandboxInfo{\n151: \t\tSessionID:    sessionID,\n152: \t\tSandboxName:  sandboxName,\n153: \t\tWorkloadName: sandboxReq.Name,\n154: \t\tNamespace:    sandboxReq.Namespace,\n155: \t\tKind:         AgentRuntimeKind,\n156: \t\tStatus:       \"pending\",\n157: \t\tCreatedAt:    time.Now(),\n158: \t}\n159: \n160: \tif err := h.store.StoreSandbox(c.Request.Context(), sandboxInfo); err != nil {\n161: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n162: \t\treturn\n163: \t}\n164: \n165: \twatcherCh, err := h.reconciler.WatchSandboxOnce(sandboxReq.Namespace, sandboxName)\n166: \tif err != nil {\n167: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n168: \t\treturn\n169: \t}\n170: \n171: \tdynClient, err := h.getDynamicClient(c)\n172: \tif err != nil {\n173: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n174: \t\treturn\n175: \t}\n176: \n177: \tcreatedCR, err := dynClient.Resource(SandboxGVR).Namespace(sandboxReq.Namespace).Create(c.Request.Context(), sandboxCR, metav1.CreateOptions{})\n178: \tif err != nil {\n179: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n180: \t\treturn\n181: \t}\n182: \n183: \tctx, cancel := context.WithTimeout(c.Request.Context(), 2*time.Minute)\n184: \tdefer cancel()\n185: \n186: \tselect {\n187: \tcase status := <-watcherCh:\n188: \t\tif status.Error != nil {\n189: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n190: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, status.Error.Error())\n191: \t\t\treturn\n192: \t\t}\n193: \t\tif status.Status != \"running\" {\n194: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n195: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n196: \t\t\treturn\n197: \t\t}\n198: \tcase <-ctx.Done():\n199: \t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n200: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n201: \t\treturn\n202: \t}\n203: \n204: \tpodIP, err := h.resolvePodIP(c.Request.Context(), sandboxName, sandboxReq.Namespace, sandboxCR, h.kubeClientset)\n205: \tif err != nil {\n206: \t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n207: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())\n208: \t\treturn\n209: \t}\n210: \n211: \tports := template.Spec.Ports\n212: \tentryPoints := h.buildEntryPoints(podIP, ports)\n213: \n214: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n215: \tsandboxInfo.PodIP = podIP\n216: \tsandboxInfo.EntryPoints = entryPoints\n217: \tsandboxInfo.Status = \"running\"\n218: \n219: \tif err := h.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n220: \t\tlog.Printf(\"failed to update sandbox in store: %v\", err)\n221: \t}\n222: \n223: \tresp := &CreateSandboxResponse{\n224: \t\tSessionID:   sessionID,\n225: \t\tSandboxID:   sandboxInfo.SandboxID,\n226: \t\tSandboxName: sandboxName,\n227: \t\tEntryPoints: entryPoints,\n228: \t}\n229: \n230: \tresponse.JSON(c, http.StatusOK, resp)\n231: }\n232: \n233: func (h *SandboxCreateHandler) CreateCodeInterpreterSandbox(c *gin.Context) {\n234: \tvar sandboxReq CreateSandboxRequest\n235: \tif err := c.ShouldBindJSON(&sandboxReq); err != nil {\n236: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n237: \t\treturn\n238: \t}\n239: \n240: \tsandboxReq.Kind = CodeInterpreterKind\n241: \n242: \tif err := sandboxReq.Validate(); err != nil {\n243: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n244: \t\treturn\n245: \t}\n246: \n247: \tciLister := h.informerFactory.Runtime().V1alpha1().CodeInterpreters().Lister()\n248: \ttemplate, err := ciLister.CodeInterpreters(sandboxReq.Namespace).Get(sandboxReq.Name)\n249: \tif err != nil {\n250: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"CodeInterpreter %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n251: \t\treturn\n252: \t}\n253: \n254: \tif template.Spec.Template == nil {\n255: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"template is required\")\n256: \t\treturn\n257: \t}\n258: \n259: \tsessionID := generateSessionID()\n260: \tsandboxName := generateSandboxName(sandboxReq.Name)\n261: \n262: \tports := getPortsOrDefaults(template.Spec.Ports)\n263: \n264: \tvar sandboxCR *unstructured.Unstructured\n265: \tvar entryKind string\n266: \n267: \tsandboxCR, entryKind, err = h.buildCodeInterpreterSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace, ports)\n268: \tif err != nil {\n269: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n270: \t\treturn\n271: \t}\n272: \n273: \tif template.Spec.AuthMode == runtimev1alpha1.AuthModePicoD {\n274: \t\tif err := h.injectPicodAuthEnv(sandboxCR, sandboxReq.Namespace, h.kubeClientset); err != nil {\n275: \t\t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n276: \t\t\treturn\n277: \t\t}\n278: \t}\n279: \n280: \tsandboxInfo := &SandboxInfo{\n281: \t\tSessionID:    sessionID,\n282: \t\tSandboxName:  sandboxName,\n283: \t\tWorkloadName: sandboxReq.Name,\n284: \t