{"type":"tool_use","timestamp":1775848131726,"sessionID":"ses_287348949ffemSMrps0exZh022","part":{"id":"prt_d78cc05c7001dU2TKEkKMvji94","messageID":"msg_d78cbf7dc001D9NZ7Y2l7DC4Jd","sessionID":"ses_287348949ffemSMrps0exZh022","type":"tool","tool":"read","callID":"call_655aabf0a8d449048fdf3fd6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"net/http\"\n6: \t\"os\"\n7: \t\"os/signal\"\n8: \t\"syscall\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n13: \t\"golang.org/x/net/http2\"\n14: \t\"golang.org/x/net/http2/h2c\"\n15: \t\"k8s.io/klog/v2\"\n16: )\n17: \n18: type Server struct {\n19: \tconfig         *Config\n20: \tengine         *gin.Engine\n21: \thttpServer     *http.Server\n22: \tsessionManager SessionManager\n23: \tstoreClient    store.Store\n24: \thttpTransport  *http.Transport\n25: \tjwtManager     *JWTManager\n26: }\n27: \n28: func NewServer(config *Config) (*Server, error) {\n29: \tif config.MaxConcurrentRequests <= 0 {\n30: \t\tconfig.MaxConcurrentRequests = 1000\n31: \t}\n32: \n33: \thttpTransport := &http.Transport{\n34: \t\tIdleConnTimeout:    0,\n35: \t\tDisableCompression: false,\n36: \t}\n37: \n38: \tif config.Debug {\n39: \t\tgin.SetMode(gin.DebugMode)\n40: \t} else {\n41: \t\tgin.SetMode(gin.ReleaseMode)\n42: \t}\n43: \n44: \tengine := gin.New()\n45: \n46: \tjwtConfig := &JWTConfig{\n47: \t\tExpiration: config.JWTExpiration,\n48: \t\tIssuer:     config.JWTIssuer,\n49: \t\tLeeway:     config.JWTLeeway,\n50: \t}\n51: \tjwtManager, err := NewJWTManager(jwtConfig)\n52: \tif err != nil {\n53: \t\treturn nil, err\n54: \t}\n55: \tif err := jwtManager.TryStoreOrLoadJWTKeySecret(context.Background()); err != nil {\n56: \t\treturn nil, err\n57: \t}\n58: \n59: \tstoreClient := store.Storage()\n60: \n61: \tsessionManager, err := NewSessionManager(storeClient)\n62: \tif err != nil {\n63: \t\treturn nil, err\n64: \t}\n65: \n66: \ts := &Server{\n67: \t\tconfig:         config,\n68: \t\tengine:         engine,\n69: \t\thttpTransport:  httpTransport,\n70: \t\tjwtManager:     jwtManager,\n71: \t\tstoreClient:    storeClient,\n72: \t\tsessionManager: sessionManager,\n73: \t}\n74: \n75: \ts.registerRoutes()\n76: \n77: \ts.httpServer = &http.Server{\n78: \t\tAddr:        \":\" + config.Port,\n79: \t\tHandler:     s.engine,\n80: \t\tReadTimeout: 30 * time.Second,\n81: \t\tIdleTimeout: 90 * time.Second,\n82: \t}\n83: \n84: \treturn s, nil\n85: }\n86: \n87: func (s *Server) registerRoutes() {\n88: \ts.engine.GET(\"/health/live\", handleHealthLive)\n89: \ts.engine.GET(\"/health/ready\", s.handleHealthReady)\n90: \n91: \tv1 := s.engine.Group(\"/v1\")\n92: \tv1.Use(gin.Logger())\n93: \tv1.Use(gin.Recovery())\n94: \tv1.Use(AuthMiddleware(s.jwtManager))\n95: \tv1.Use(ConcurrencyLimitMiddleware(s.config.MaxConcurrentRequests))\n96: \n97: \tv1.GET(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n98: \tv1.POST(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n99: \tv1.GET(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n100: \tv1.POST(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n101: }\n102: \n103: func (s *Server) Start() error {\n104: \tif s.config.EnableTLS {\n105: \t\tif s.config.TLSCert == \"\" || s.config.TLSKey == \"\" {\n106: \t\t\treturn nil\n107: \t\t}\n108: \t\tklog.Infof(\"Starting HTTPS server on %s\", s.httpServer.Addr)\n109: \t\treturn s.httpServer.ListenAndServeTLS(s.config.TLSCert, s.config.TLSKey)\n110: \t}\n111: \n112: \th2cHandler := h2c.NewHandler(s.engine, &http2.Server{})\n113: \ts.httpServer.Handler = h2cHandler\n114: \n115: \tklog.Infof(\"Starting HTTP server on %s\", s.httpServer.Addr)\n116: \treturn s.httpServer.ListenAndServe()\n117: }\n118: \n119: func (s *Server) Run() {\n120: \tstopCh := make(chan os.Signal, 1)\n121: \tsignal.Notify(stopCh, syscall.SIGINT, syscall.SIGTERM)\n122: \n123: \tgo func() {\n124: \t\tif err := s.Start(); err != nil && err != http.ErrServerClosed {\n125: \t\t\tklog.Fatalf(\"server failed: %v\", err)\n126: \t\t}\n127: \t}()\n128: \n129: \t<-stopCh\n130: \tklog.Info(\"shutting down server...\")\n131: \n132: \tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n133: \tdefer cancel()\n134: \n135: \tif err := s.Shutdown(ctx); err != nil {\n136: \t\tklog.Errorf(\"server shutdown failed: %v\", err)\n137: \t}\n138: }\n139: \n140: func (s *Server) Shutdown(ctx context.Context) error {\n141: \tif s.httpServer == nil {\n142: \t\treturn nil\n143: \t}\n144: \treturn s.httpServer.Shutdown(ctx)\n145: }\n\n(End of file - total 145 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"golang.org/x/net/http2\"\n\t\"golang.org/x/net/http2/h2c\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go","time":{"start":1775848131714,"end":1775848131725}}}}
{"type":"tool_use","timestamp":1775848132407,"sessionID":"ses_287348949ffemSMrps0exZh022","part":{"id":"prt_d78cc0cc1001xW9TCOHCVSlmTh","messageID":"msg_d78cbf7dc001D9NZ7Y2l7DC4Jd","sessionID":"ses_287348949ffemSMrps0exZh022","type":"tool","tool":"read","callID":"call_22fa999ea0254709b33b6c45","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"log/slog\"\n7: \t\"net/http\"\n8: \t\"strconv\"\n9: \t\"sync\"\n10: \t\"time\"\n11: \n12: \t\"github.com/gin-gonic/gin\"\n13: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n14: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n15: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n16: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n17: \t\"k8s.io/client-go/dynamic\"\n18: \n19: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n20: )\n21: \n22: type LifecycleManagerDeps struct {\n23: \tDynamicClient      dynamic.Interface\n24: \tStore              Store\n25: \tCheckInterval      time.Duration\n26: \tDefaultTTL         time.Duration\n27: \tDefaultIdleTimeout time.Duration\n28: \tMetricsRecorder    MetricsRecorder\n29: }\n30: \n31: type LifecycleManager struct {\n32: \tdynamicClient      dynamic.Interface\n33: \tstore              Store\n34: \tcheckInterval      time.Duration\n35: \tdefaultTTL         time.Duration\n36: \tdefaultIdleTimeout time.Duration\n37: \tmetricsRecorder    MetricsRecorder\n38: \tstopCh             chan struct{}\n39: \tmu                 sync.Mutex\n40: \trunning            bool\n41: }\n42: \n43: func NewLifecycleManager(deps *LifecycleManagerDeps) *LifecycleManager {\n44: \tcheckInterval := deps.CheckInterval\n45: \tif checkInterval == 0 {\n46: \t\tcheckInterval = 5 * time.Minute\n47: \t}\n48: \tdefaultTTL := deps.DefaultTTL\n49: \tif defaultTTL == 0 {\n50: \t\tdefaultTTL = 8 * time.Hour\n51: \t}\n52: \tdefaultIdleTimeout := deps.DefaultIdleTimeout\n53: \tif defaultIdleTimeout == 0 {\n54: \t\tdefaultIdleTimeout = DefaultIdleTimeout\n55: \t}\n56: \n57: \treturn &LifecycleManager{\n58: \t\tdynamicClient:      deps.DynamicClient,\n59: \t\tstore:              deps.Store,\n60: \t\tcheckInterval:      checkInterval,\n61: \t\tdefaultTTL:         defaultTTL,\n62: \t\tdefaultIdleTimeout: defaultIdleTimeout,\n63: \t\tmetricsRecorder:    deps.MetricsRecorder,\n64: \t\tstopCh:             make(chan struct{}),\n65: \t}\n66: }\n67: \n68: func (m *LifecycleManager) Start(ctx context.Context) {\n69: \tm.mu.Lock()\n70: \tif m.running {\n71: \t\tm.mu.Unlock()\n72: \t\treturn\n73: \t}\n74: \tm.running = true\n75: \tm.mu.Unlock()\n76: \n77: \tgo m.runCleanupLoop(ctx)\n78: }\n79: \n80: func (m *LifecycleManager) Stop() {\n81: \tm.mu.Lock()\n82: \tdefer m.mu.Unlock()\n83: \tif !m.running {\n84: \t\treturn\n85: \t}\n86: \tm.running = false\n87: \tclose(m.stopCh)\n88: \tm.stopCh = make(chan struct{})\n89: }\n90: \n91: func (m *LifecycleManager) runCleanupLoop(ctx context.Context) {\n92: \tticker := time.NewTicker(m.checkInterval)\n93: \tdefer ticker.Stop()\n94: \n95: \tfor {\n96: \t\tselect {\n97: \t\tcase <-ctx.Done():\n98: \t\t\treturn\n99: \t\tcase <-m.stopCh:\n100: \t\t\treturn\n101: \t\tcase <-ticker.C:\n102: \t\t\tm.runGCCycle(ctx)\n103: \t\t}\n104: \t}\n105: }\n106: \n107: func (m *LifecycleManager) runGCCycle(ctx context.Context) {\n108: \tcycleStart := time.Now()\n109: \n110: \tslog.Info(\"gc_cycle_start\",\n111: \t\t\"check_interval\", m.checkInterval.String(),\n112: \t\t\"default_ttl\", m.defaultTTL.String(),\n113: \t\t\"default_idle_timeout\", m.defaultIdleTimeout.String(),\n114: \t)\n115: \n116: \tvar ttlCleaned, idleCleaned, orphanCleaned, ghostCleaned, errors int\n117: \n118: \tttlCleaned, idleCleaned, err := m.cleanupExpiredSandboxes(ctx)\n119: \tif err != nil {\n120: \t\tslog.Error(\"gc_error\", \"sub_task\", \"ttl_idle_cleanup\", \"error\", err)\n121: \t\terrors++\n122: \t}\n123: \n124: \torphanCleaned, err = m.cleanupOrphanCRs(ctx)\n125: \tif err != nil {\n126: \t\tslog.Error(\"gc_error\", \"sub_task\", \"orphan_scan\", \"error\", err)\n127: \t\terrors++\n128: \t}\n129: \n130: \tghostCleaned, err = m.cleanupGhostEntries(ctx)\n131: \tif err != nil {\n132: \t\tslog.Error(\"gc_error\", \"sub_task\", \"ghost_scan\", \"error\", err)\n133: \t\terrors++\n134: \t}\n135: \n136: \tduration := time.Since(cycleStart)\n137: \n138: \tslog.Info(\"gc_cycle_complete\",\n139: \t\t\"duration_ms\", duration.Milliseconds(),\n140: \t\t\"ttl_cleaned\", ttlCleaned,\n141: \t\t\"idle_cleaned\", idleCleaned,\n142: \t\t\"orphan_cleaned\", orphanCleaned,\n143: \t\t\"ghost_cleaned\", ghostCleaned,\n144: \t\t\"errors\", errors,\n145: \t)\n146: \n147: \tif m.metricsRecorder != nil {\n148: \t\tm.metricsRecorder.ObserveGCCycleDuration(duration)\n149: \t}\n150: }\n151: \n152: func (m *LifecycleManager) cleanupExpiredSandboxes(ctx context.Context) (int, int, error) {\n153: \tsandboxes, err := m.store.ListSandboxes(ctx)\n154: \tif err != nil {\n155: \t\tslog.Error(\"failed to list sandboxes for cleanup\", \"error\", err)\n156: \t\treturn 0, 0, fmt.Errorf(\"failed to list sandboxes: %w\", err)\n157: \t}\n158: \n159: \tnow := time.Now()\n160: \tvar ttlCleaned, idleCleaned int\n161: \n162: \tfor _, sb := range sandboxes {\n163: \t\tif m.isExpired(sb, now) {\n164: \t\t\tif err := m.deleteSandbox(ctx, sb, GRCleanupReasonTTLExpired); err != nil {\n165: \t\t\t\tslog.Error(\"failed to delete expired sandbox\",\n166: \t\t\t\t\t\"sessionID\", sb.SessionID,\n167: \t\t\t\t\t\"sandboxName\", sb.SandboxName,\n168: \t\t\t\t\t\"namespace\", sb.Namespace,\n169: \t\t\t\t\t\"reason\", GRCleanupReasonTTLExpired,\n170: \t\t\t\t\t\"error\", err,\n171: \t\t\t\t)\n172: \t\t\t\tif m.metricsRecorder != nil {\n173: \t\t\t\t\tm.metricsRecorder.IncGCCleanupErrors(GRCleanupReasonTTLExpired)\n174: \t\t\t\t}\n175: \t\t\t} else {\n176: \t\t\t\tttlCleaned++\n177: \t\t\t}\n178: \t\t\tcontinue\n179: \t\t}\n180: \n181: \t\tif m.isIdleExpired(sb, m.defaultIdleTimeout, now) {\n182: \t\t\tif err := m.deleteSandbox(ctx, sb, GRCleanupReasonIdle); err != nil {\n183: \t\t\t\tslog.Error(\"failed to delete idle sandbox\",\n184: \t\t\t\t\t\"sessionID\", sb.SessionID,\n185: \t\t\t\t\t\"sandboxName\", sb.SandboxName,\n186: \t\t\t\t\t\"namespace\", sb.Namespace,\n187: \t\t\t\t\t\"reason\", GRCleanupReasonIdle,\n188: \t\t\t\t\t\"error\", err,\n189: \t\t\t\t)\n190: \t\t\t\tif m.metricsRecorder != nil {\n191: \t\t\t\t\tm.metricsRecorder.IncGCCleanupErrors(GRCleanupReasonIdle)\n192: \t\t\t\t}\n193: \t\t\t} else {\n194: \t\t\t\tidleCleaned++\n195: \t\t\t}\n196: \t\t}\n197: \t}\n198: \n199: \treturn ttlCleaned, idleCleaned, nil\n200: }\n201: \n202: func (m *LifecycleManager) isExpired(info *SandboxInfo, now time.Time) bool {\n203: \tif !info.ExpiresAt.IsZero() {\n204: \t\treturn !now.Before(info.ExpiresAt)\n205: \t}\n206: \n207: \tif !info.CreatedAt.IsZero() {\n208: \t\treturn !now.Before(info.CreatedAt.Add(m.defaultTTL))\n209: \t}\n210: \n211: \treturn false\n212: }\n213: \n214: func (m *LifecycleManager) isIdleExpired(info *SandboxInfo, idleTimeout time.Duration, now time.Time) bool {\n215: \tif info.LastActivityAt.IsZero() {\n216: \t\treturn false\n217: \t}\n218: \n219: \tif info.Status != \"running\" {\n220: \t\treturn false\n221: \t}\n222: \n223: \treturn now.After(info.LastActivityAt.Add(idleTimeout))\n224: }\n225: \n226: func (m *LifecycleManager) deleteSandbox(ctx context.Context, info *SandboxInfo, reason string) error {\n227: \tstart := time.Now()\n228: \n229: \tgvr, err := m.resolveGVR(info.Kind)\n230: \tif err != nil {\n231: \t\tif m.metricsRecorder != nil {\n232: \t\t\tm.metricsRecorder.IncGCCleanupErrors(reason)\n233: \t\t}\n234: \t\treturn fmt.Errorf(\"failed to resolve GVR for kind %s: %w\", info.Kind, err)\n235: \t}\n236: \n237: \tdeleteCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n238: \tdefer cancel()\n239: \n240: \terr = m.dynamicClient.Resource(gvr).Namespace(info.Namespace).Delete(deleteCtx, info.SandboxName, metav1.DeleteOptions{})\n241: \tcrDeleted := true\n242: \tif err != nil {\n243: \t\tif apierrors.IsNotFound(err) {\n244: \t\t\tcrDeleted = false\n245: \t\t\tslog.Info(\"sandbox CR already deleted from cluster\",\n246: \t\t\t\t\"sessionID\", info.SessionID,\n247: \t\t\t\t\"sandboxName\", info.SandboxName,\n248: \t\t\t\t\"namespace\", info.Namespace,\n249: \t\t\t\t\"reason\", reason,\n250: \t\t\t)\n251: \t\t} else {\n252: \t\t\tif m.metricsRecorder != nil {\n253: \t\t\t\tm.metricsRecorder.IncGCCleanupErrors(reason)\n254: \t\t\t}\n255: \t\t\treturn fmt.Errorf(\"failed to delete sandbox from cluster: %w\", err)\n256: \t\t}\n257: \t}\n258: \n259: \tif err := m.store.DeleteSandbox(ctx, info.SessionID); err != nil {\n260: \t\tif m.metricsRecorder != nil {\n261: \t\t\tm.metricsRecorder.IncGCCleanupErrors(reason)\n262: \t\t}\n263: \t\treturn fmt.Errorf(\"failed to delete sandbox from store: %w\", err)\n264: \t}\n265: \n266: \tactualReason := reason\n267: \tif !crDeleted {\n268: \t\tactualReason = GRCleanupReasonGhostEntry\n269: \t}\n270: \n271: \tif m.metricsRecorder != nil {\n272: \t\tm.metricsRecorder.IncGCCleanupTotal(actualReason)\n273: \t\tm.metricsRecorder.ObserveGCCleanupDuration(actualReason, time.Since(start))\n274: \t}\n275: \n276: \tslog.Info(\"sandbox_deleted\",\n277: \t\t\"sessionID\", info.SessionID,\n278: \t\t\"sandboxName\", info.SandboxName,\n279: \t\t\"namespace\", info.Namespace,\n280: \t\t\"kind\", info.Kind,\n281: \t\t\"reason\", actualReason,\n282: \t)\n283: \n284: \treturn nil\n285: }\n286: \n287: func (m *LifecycleManager) cleanupOrphanCRs(ctx context.Context) (int, error) {\n288: \tif m.dynamicClient == nil {\n289: \t\treturn 0, nil\n290: \t}\n291: \n292: \tgvrs := []schema.GroupVersionResource{AgentRuntimeGVR, CodeInterpreterGVR}\n293: \tvar cleaned int\n294: \n295: \tfor _, gvr := range gvrs {\n296: \t\tlistOpts := metav1.ListOptions{\n297: \t\t\tLabelSelector: fmt.Sprintf(\"%s=%s\", LabelSessionID, \"\"),\n298: \t\t}\n299: \n300: \t\tlist, err := m.dynamicClient.Resource(gvr).List(ctx, listOpts)\n301: \t\tif err != nil {\n302: \t\t\tslog.Error(\"failed to list CRs for orphan scan\",\n303: \t\t\t\t\"gvr\", gvr.String(),\n304: \t\t\t\t\"error\", err,\n305: \t\t\t)\n306: \t\t\treturn cleaned, fmt.Errorf(\"failed to list %s: %w\", gvr.Resource, err)\n307: \t\t}\n308: \n309: \t\tfor _, item := range list.Items {\n310: \t\t\tif cleaned >= MaxOrphanScanLimit {\n311: \t\t\t\treturn cleaned, nil\n312: \t\t\t}\n313: \n314: \t\t\tsessionID := item.GetLabels()[LabelSessionID]\n315: \t\t\tif sessionID == \"\" {\n316: \t\t\t\tcontinue\n317: \t\t\t}\n318: \n319: \t\t\t_, err := m.store.GetSandbox(ctx, sessionID)\n320: \t\t\tif err == nil {\n321: \t\t\t\tcontinue\n322: \t\t\t}\n323: \n324: \t\t\tdeleteCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n325: \t\t\terr = m.dynamicClient.Resource(gvr).Namespace(item.GetNamespace()).Delete(deleteCtx, item.GetName(), metav1.DeleteOptions{})\n326: \t\t\tcancel()\n327: \n328: \t\t\tif err != nil && !apierrors.IsNotFound(err) {\n329: \t\t\t\tslog.Error(\"failed to delete orphan CR\",\n330: \t\t\t\t\t\"sessionID\", sessionID,\n331: \t\t\t\t\t\"crName\", item.GetName(),\n332: \t\t\t\t\t\"namespace\", item.GetNamespace(),\n333: \t\t\t\t\t\"kind\", gvr.Resource,\n334: \t\t\t\t\t\"error\", err,\n335: \t\t\t\t)\n336: \t\t\t\tif m.metricsRecorder != nil {\n337: \t\t\t\t\tm.metricsRecorder.IncGCCleanupErrors(GRCleanupReasonOrphanCR)\n338: \t\t\t\t}\n339: \t\t\t\tcontinue\n340: \t\t\t}\n341: \n342: \t\t\tcleaned++\n343: \t\t\tslog.Info(\"orphan_cr_deleted\",\n344: \t\t\t\t\"sessionID\", sessionID,\n345: \t\t\t\t\"crName\", item.GetName(),\n346: \t\t\t\t\"namespace\", item.GetNamespace(),\n347: \t\t\t\t\"kind\", gvr.Resource,\n348: \t\t\t)\n349: \n350: \t\t\tif m.metricsRecorder != nil {\n351: \t\t\t\tm.metricsRecorder.IncGCCleanupTotal(GRCleanupReasonOrphanCR)\n352: \t\t\t}\n353: \t\t}\n354: \t}\n355: \n356: \treturn cleaned, nil\n357: }\n358: \n359: func (m *LifecycleManager) cleanupGhostEntries(ctx context.Context) (int, error) {\n360: \tsandboxes, err := m.store.ListSandboxes(ctx)\n361: \tif err != nil {\n362: \t\tslog.Error(\"failed to list sandboxes for ghost scan\", \"error\", err)\n363: \t\treturn 0, fmt.Errorf(\"failed to list sandboxes: %w\", err)\n364: \t}\n365: \n366: \tvar cleaned int\n367: \n368: \tfor _, sb := range sandboxes {\n369: \t\tgvr, err := m.resolveGVR(sb.Kind)\n370: \t\tif err != nil {\n371: \t\t\tslog.Error(\"failed to resolve GVR for ghost scan\",\n372: \t\t\t\t\"sessionID\", sb.SessionID,\n373: \t\t\t\t\"kind\", sb.Kind,\n374: \t\t\t\t\"error\", err,\n375: \t\t\t)\n376: \t\t\tcontinue\n377: \t\t}\n378: \n379: \t\t_, err = m.dynamicClient.Resource(gvr).Namespace(sb.Namespace).Get(ctx, sb.SandboxName, metav1.GetOptions{})\n380: \t\tif err == nil {\n381: \t\t\tcontinue\n382: \t\t}\n383: \n384: \t\tif !apierrors.IsNotFound(err) {\n385: \t\t\tslog.Error(\"failed to check CR existence for ghost scan\",\n386: \t\t\t\t\"sessionID\", sb.SessionID,\n387: \t\t\t\t\"sandboxName\", sb.SandboxName,\n388: \t\t\t\t\"namespace\", sb.Namespace,\n389: \t\t\t\t\"error\", err,\n390: \t\t\t)\n391: \t\t\tcontinue\n392: \t\t}\n393: \n394: \t\tif err := m.store.DeleteSandbox(ctx, sb.SessionID); err != nil {\n395: \t\t\tslog.Error(\"failed to delete ghost entry from store\",\n396: \t\t\t\t\"sessionID\", sb.SessionID,\n397: \t\t\t\t\"sandboxName\", sb.SandboxName,\n398: \t\t\t\t\"kind\", sb.Kind,\n399: \t\t\t\t\"error\", err,\n400: \t\t\t)\n401: \t\t\tif m.metricsRecorder != nil {\n402: \t\t\t\tm.metricsRecorder.IncGCCleanupErrors(GRCleanupReasonGhostEntry)\n403: \t\t\t}\n404: \t\t\tcontinue\n405: \t\t}\n406: \n407: \t\tcleaned++\n408: \t\tslog.Info(\"ghost_entry_cleaned\",\n409: \t\t\t\"sessionID\", sb.SessionID,\n410: \t\t\t\"sandboxName\", sb.SandboxName,\n411: \t\t\t\"kind\", sb.Kind,\n412: \t\t)\n413: \n414: \t\tif m.metricsRecorder != nil {\n415: \t\t\tm.metricsRecorder.IncGCCleanupTotal(GRCleanupReasonGhostEntry)\n416: \t\t}\n417: \t}\n418: \n419: \treturn cleaned, nil\n420: }\n421: \n422: func (m *LifecycleManager) resolveGVR(kind string) (schema.GroupVersionResource, error) {\n423: \tswitch kind {\n424: \tcase SandboxesKind:\n425: \t\treturn SandboxGVR, nil\n426: \tcase SandboxClaimsKind:\n427: \t\treturn SandboxClaimGVR, nil\n428: \tcase AgentRuntimeKind:\n429: \t\treturn AgentRuntimeGVR, nil\n430: \tcase CodeInterpreterKind:\n431: \t\treturn CodeInterpreterGVR, nil\n432: \tdefault:\n433: \t\treturn schema.GroupVersionResource{}, fmt.Errorf(\"unknown sandbox kind: %s\", kind)\n434: \t}\n435: }\n436: \n437: func (m *LifecycleManager) calculateTimeToIdle(info *SandboxInfo, now time.Time) *time.Duration {\n438: \tif info.LastActivityAt.IsZero() {\n439: \t\treturn nil\n440: \t}\n441: \n442: \tif info.Status != \"running\" {\n443: \t\treturn nil\n444: \t}\n445: \n446: \tdeadline := info.LastActivityAt.Add(m.defaultIdleTimeout)\n447: \tremaining := deadline.Sub(now)\n448: \treturn &remaining\n449: }\n450: \n451: func (m *LifecycleManager) GetSandboxStatus(c *gin.Context) {\n452: \tsessionID := c.Param(\"sessionID\")\n453: \tif sessionID == \"\" {\n454: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"sessionID is required\")\n455: \t\treturn\n456: \t}\n457: \n458: \tsandboxInfo, err := m.store.GetSandbox(c.Request.Context(), sessionID)\n459: \tif err != nil {\n460: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox session %s not found\", sessionID))\n461: \t\treturn\n462: \t}\n463: \n464: \tnow := time.Now()\n465: \tsandboxInfo.LastActivityAt = now\n466: \tif err := m.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n467: \t\tslog.Error(\"failed to update LastActivityAt on status check\",\n468: \t\t\t\"sessionID\", sessionID,\n469: \t\t\t\"error\", err,\n470: \t\t)\n471: \t}\n472: \n473: \tvar timeToExpiry *time.Duration\n474: \tif !sandboxInfo.ExpiresAt.IsZero() {\n475: \t\tremaining := sandboxInfo.ExpiresAt.Sub(now)\n476: \t\tif remaining > 0 {\n477: \t\t\ttimeToExpiry = &remaining\n478: \t\t}\n479: \t}\n480: \n481: \ttimeToIdle := m.calculateTimeToIdle(sandboxInfo, now)\n482: \tisIdle := m.isIdleExpired(sandboxInfo, m.defaultIdleTimeout, now)\n483: \n484: \tresp := &SandboxStatusResponse{\n485: \t\tSessionID:      sandboxInfo.SessionID,\n486: \t\tSandboxName:    sandboxInfo.SandboxName,\n487: \t\tSandboxID:      sandboxInfo.SandboxID,\n488: \t\tStatus:         sandboxInfo.Status,\n489: \t\tCreatedAt:      sandboxInfo.CreatedAt,\n490: \t\tExpiresAt:      sandboxInfo.ExpiresAt,\n491: \t\tLastActivityAt: sandboxInfo.LastActivityAt,\n492: \t\tTimeToExpiry:   timeToExpiry,\n493: \t\tTimeToIdle:     timeToIdle,\n494: \t\tIsExpired:      m.isExpired(sandboxInfo, now),\n495: \t\tIsIdle:         isIdle,\n496: \t\tEntryPoints:    sandboxInfo.EntryPoints,\n497: \t}\n498: \n499: \tresponse.JSON(c, http.StatusOK, resp)\n500: }\n501: \n502: type SandboxStatusResponse struct {\n503: \tSessionID      string         `json:\"sessionId\"`\n504: \tSandboxName    string         `json:\"sandboxName\"`\n505: \tSandboxID      string         `json:\"sandboxId\"`\n506: \tStatus         string         `json:\"status\"`\n507: \tCreatedAt      time.Time      `json:\"createdAt\"`\n508: \tExpiresAt      time.Time      `json:\"expiresAt\"`\n509: \tLastActivityAt time.Time      `json:\"lastActivityAt\"`\n510: \tTimeToExpiry   *time.Duration `json:\"timeToExpiry,omitempty\"`\n511: \tTimeToIdle     *time.Duration `json:\"timeToIdle,omitempty\"`\n512: \tIsExpired      bool           `json:\"isExpired\"`\n513: \tIsIdle         bool           `json:\"isIdle\"`\n514: \tEntryPoints    []EntryPoint   `json:\"entryPoints,omitempty\"`\n515: }\n516: \n517: func (m *LifecycleManager) ListSandboxes(c *gin.Context) {\n518: \tnamespace := c.Query(\"namespace\")\n519: \tstatusFilter := c.Query(\"status\")\n520: \n521: \tsandboxes, err := m.store.ListSandboxes(c.Request.Context())\n522: \tif err != nil {\n523: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"failed to list sandboxes\")\n524: \t\treturn\n525: \t}\n526: \n527: \tvar filtered []*SandboxInfo\n528: \tfor _, sb := range sandboxes {\n529: \t\tif namespace != \"\" && sb.Namespace != namespace {\n530: \t\t\tcontinue\n531: \t\t}\n532: \t\tif statusFilter != \"\" && sb.Status != statusFilter {\n533: \t\t\tcontinue\n534: \t\t}\n535: \t\tfiltered = append(filtered, sb)\n536: \t}\n537: \n538: \tnow := time.Now()\n539: \titems := make([]SandboxListItem, 0, len(filtered))\n540: \tfor _, sb := range filtered {\n541: \t\tvar timeToExpiry *time.Duration\n542: \t\tif !sb.ExpiresAt.IsZero() {\n543: \t\t\tremaining := sb.ExpiresAt.Sub(now)\n544: \t\t\tif remaining > 0 {\n545: \t\t\t\ttimeToExpiry = &remaining\n546: \t\t\t}\n547: \t\t}\n548: \n549: \t\ttimeToIdle := m.calculateTimeToIdle(sb, now)\n550: \t\tisIdle := m.isIdleExpired(sb, m.defaultIdleTimeout, now)\n551: \n552: \t\titems = append(items, SandboxListItem{\n553: \t\t\tSessionID:      sb.SessionID,\n554: \t\t\tSandboxName:    sb.SandboxName,\n555: \t\t\tWorkloadName:   sb.WorkloadName,\n556: \t\t\tNamespace:      sb.Namespace,\n557: \t\t\tKind:           sb.Kind,\n558: \t\t\tStatus:         sb.Status,\n559: \t\t\tCreatedAt:      sb.CreatedAt,\n560: \t\t\tExpiresAt:      sb.ExpiresAt,\n561: \t\t\tLastActivityAt: sb.LastActivityAt,\n562: \t\t\tTimeToExpiry:   timeToExpiry,\n563: \t\t\tTimeToIdle:     timeToIdle,\n564: \t\t\tIsExpired:      m.isExpired(sb, now),\n565: \t\t\tIsIdle:         isIdle,\n566: \t\t})\n567: \t}\n568: \n569: \tresponse.JSON(c, http.StatusOK, &ListSandboxesResponse{\n570: \t\tTotal: len(items),\n571: \t\tItems: items,\n572: \t})\n573: }\n574: \n575: type SandboxListItem struct {\n576: \tSessionID      string         `json:\"sessionId\"`\n577: \tSandboxName    string         `json:\"sandboxName\"`\n578: \tWorkloadName   string         `json:\"workloadName\"`\n579: \tNamespace      string         `json:\"namespace\"`\n580: \tKind           string         `json:\"kind\"`\n581: \tStatus         string         `json:\"status\"`\n582: \tCreatedAt      time.Time      `json:\"createdAt\"`\n583: \tExpiresAt      time.Time      `json:\"expiresAt\"`\n584: \tLastActivityAt time.Time      `json:\"lastActivityAt\"`\n585: \tTimeToExpiry   *time.Duration `json:\"timeToExpiry,omitempty\"`\n586: \tTimeToIdle     *time.Duration `json:\"timeToIdle,omitempty\"`\n587: \tIsExpired      bool           `json:\"isExpired\"`\n588: \tIsIdle         bool           `json:\"isIdle\"`\n589: }\n590: \n591: type ListSandboxesResponse struct {\n592: \tTotal int               `json:\"total\"`\n593: \tItems []SandboxListItem `json:\"items\"`\n594: }\n595: \n596: func (m *LifecycleManager) ExtendSandboxTTL(c *gin.Context) {\n597: \tsessionID := c.Param(\"sessionID\")\n598: \tif sessionID == \"\" {\n599: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"sessionID is required\")\n600: \t\treturn\n601: \t}\n602: \n603: \tvar req ExtendTTLRequest\n604: \tif err := c.ShouldBindJSON(&req); err != nil {\n605: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n606: \t\treturn\n607: \t}\n608: \n609: \tif err := req.Validate(); err != nil {\n610: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n611: \t\treturn\n612: \t}\n613: \n614: \tsandboxInfo, err := m.store.GetSandbox(c.Request.Context(), sessionID)\n615: \tif err != nil {\n616: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox session %s not found\", sessionID))\n617: \t\treturn\n618: \t}\n619: \n620: \tnow := time.Now()\n621: \tif m.isExpired(sandboxInfo, now) {\n622: \t\tresponse.Error(c, http.StatusGone, http.StatusGone, \"sandbox has already expired and cannot be extended\")\n623: \t\treturn\n624: \t}\n625: \n626: \tsandboxInfo.ExpiresAt = now.Add(req.ExtensionDuration)\n627: \tsandboxInfo.LastActivityAt = now\n628: \tif err := m.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n629: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"failed to update sandbox TTL\")\n630: \t\treturn\n631: \t}\n632: \n633: \tresponse.JSON(c, http.StatusOK, &ExtendTTLResponse{\n634: \t\tSessionID: sessionID,\n635: \t\tNewExpiry: sandboxInfo.ExpiresAt,\n636: \t})\n637: }\n638: \n639: type ExtendTTLRequest struct {\n640: \tExtensionDuration time.Duration `json:\"extensionDuration\"`\n641: }\n642: \n643: func (r *ExtendTTLRequest) Validate() error {\n644: \tif r.ExtensionDuration <= 0 {\n645: \t\treturn fmt.Errorf(\"extensionDuration must be positive\")\n646: \t}\n647: \tif r.ExtensionDuration > 24*time.Hour {\n648: \t\treturn fmt.Errorf(\"extensionDuration cannot exceed 24 hours\")\n649: \t}\n650: \treturn nil\n651: }\n652: \n653: type ExtendTTLResponse struct {\n654: \tSessionID string    `json:\"sessionId\"`\n655: \tNewExpiry time.Time `json:\"newExpiry\"`\n656: }\n657: \n658: func parseIdleTimeoutFromAnnotations(annotations map[string]string, defaultTimeout time.Duration) time.Duration {\n659: \tif annotations == nil {\n660: \t\treturn defaultTimeout\n661: \t}\n662: \n663: \tval, ok := annotations[AnnotationIdleTimeout]\n664: \tif !ok {\n665: \t\treturn defaultTimeout\n666: \t}\n667: \n668: \tminutes, err := strconv.Atoi(val)\n669: \tif err != nil {\n670: \t\treturn defaultTimeout\n671: \t}\n672: \n673: \treturn time.Duration(minutes) * time.Minute\n674: }\n675: \n676: func extractIdleTimeoutFromCR(cr *unstructured.Unstructured, defaultTimeout time.Duration) time.Duration {\n677: \tannotations := cr.GetAnnotations()\n678: \treturn parseIdleTimeoutFromAnnotations(annotations, defaultTimeout)\n679: }\n\n(End of file - total 679 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log/slog\"\n\t\"net/http\"\n\t\"strconv\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_lifecycle.go","time":{"start":1775848132399,"end":1775848132405}}}}
