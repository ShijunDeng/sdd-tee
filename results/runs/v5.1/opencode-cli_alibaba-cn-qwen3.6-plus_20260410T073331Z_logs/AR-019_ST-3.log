backend}\n62: \tselected, err := r.lb.Select(backends)\n63: \tif err != nil {\n64: \t\thttp.Error(w, err.Error(), http.StatusBadGateway)\n65: \t\treturn\n66: \t}\n67: \n68: \tif !selected.Healthy {\n69: \t\thttp.Error(w, \"backend unhealthy\", http.StatusServiceUnavailable)\n70: \t\treturn\n71: \t}\n72: \n73: \tproxy := http.NewServeMux()\n74: \tproxy.HandleFunc(\"/\", func(w http.ResponseWriter, r *http.Request) {\n75: \t\tr.URL.Host = selected.URL.Host\n76: \t\tr.URL.Scheme = selected.URL.Scheme\n77: \t\thttp.DefaultTransport.RoundTrip(r)\n78: \t})\n79: }\n\n(End of file - total 79 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"sync\"\n)\n\ntype Router interface {\n\tAddRoute(pattern string, backend Backend) error\n\tRemoveRoute(pattern string) error\n\tServeHTTP(w http.ResponseWriter, r *http.Request)\n}\n\ntype routerImpl struct {\n\tmu     sync.RWMutex\n\troutes map[string]Backend\n\tlb     LoadBalancer\n}\n\nfunc NewRouter(lb LoadBalancer) Router {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/router.go","time":{"start":1775848165648,"end":1775848165653}}}}
