rometheus.CounterOpts{\n34: \t\t\tName: \"reconcile_errors_total\",\n35: \t\t\tHelp: \"Total number of reconciliation errors\",\n36: \t\t}, []string{\"resource_type\", \"error_type\"}),\n37: \t\tworkqueueDepth: prometheus.NewGauge(prometheus.GaugeOpts{\n38: \t\t\tName: \"workqueue_depth\",\n39: \t\t\tHelp: \"Current workqueue depth\",\n40: \t\t}),\n41: \t\tworkqueueAdds: prometheus.NewCounterVec(prometheus.CounterOpts{\n42: \t\t\tName: \"workqueue_adds_total\",\n43: \t\t\tHelp: \"Total number of workqueue adds\",\n44: \t\t}, []string{\"resource_type\"}),\n45: \t\tgcCleanupTotal: prometheus.NewCounterVec(prometheus.CounterOpts{\n46: \t\t\tName: \"gc_cleanup_total\",\n47: \t\t\tHelp: \"Total number of GC cleanup operations\",\n48: \t\t}, []string{\"reason\"}),\n49: \t\tgcCleanupDuration: prometheus.NewHistogramVec(prometheus.HistogramOpts{\n50: \t\t\tName:    \"gc_cleanup_duration_seconds\",\n51: \t\t\tHelp:    \"GC cleanup duration distribution\",\n52: \t\t\tBuckets: []float64{0.01, 0.05, 0.1, 0.5, 1, 5, 10, 30},\n53: \t\t}, []string{\"reason\"}),\n54: \t\tgcCleanupErrors: prometheus.NewCounterVec(prometheus.CounterOpts{\n55: \t\t\tName: \"gc_cleanup_errors_total\",\n56: \t\t\tHelp: \"Total number of GC cleanup errors\",\n57: \t\t}, []string{\"reason\"}),\n58: \t\tgcCycleDuration: prometheus.NewHistogramVec(prometheus.HistogramOpts{\n59: \t\t\tName:    \"gc_cycle_duration_seconds\",\n60: \t\t\tHelp:    \"GC cycle duration distribution\",\n61: \t\t\tBuckets: []float64{1, 5, 10, 30, 60, 120, 300},\n62: \t\t}, nil),\n63: \t}\n64: \n65: \tif reg != nil {\n66: \t\treg.MustRegister(r.reconcileTotal)\n67: \t\treg.MustRegister(r.reconcileDuration)\n68: \t\treg.MustRegister(r.reconcileErrors)\n69: \t\treg.MustRegister(r.workqueueDepth)\n70: \t\treg.MustRegister(r.workqueueAdds)\n71: \t\treg.MustRegister(r.gcCleanupTotal)\n72: \t\treg.MustRegister(r.gcCleanupDuration)\n73: \t\treg.MustRegister(r.gcCleanupErrors)\n74: \t\treg.MustRegister(r.gcCycleDuration)\n75: \t}\n76: \n77: \treturn r\n78: }\n79: \n80: func (r *PrometheusMetricsRecorder) IncReconcileTotal(resourceType string, result string) {\n81: \tif r == nil {\n82: \t\treturn\n83: \t}\n84: \tr.reconcileTotal.WithLabelValues(resourceType, result).Inc()\n85: }\n86: \n87: func (r *PrometheusMetricsRecorder) ObserveReconcileDuration(resourceType string, duration time.Duration) {\n88: \tif r == nil {\n89: \t\treturn\n90: \t}\n91: \tr.reconcileDuration.WithLabelValues(resourceType).Observe(duration.Seconds())\n92: }\n93: \n94: func (r *PrometheusMetricsRecorder) IncReconcileErrors(resourceType string, errorType string) {\n95: \tif r == nil {\n96: \t\treturn\n97: \t}\n98: \tr.reconcileErrors.WithLabelValues(resourceType, errorType).Inc()\n99: }\n100: \n101: func (r *PrometheusMetricsRecorder) SetWorkqueueDepth(depth int) {\n102: \tif r == nil {\n103: \t\treturn\n104: \t}\n105: \tr.workqueueDepth.Set(float64(depth))\n106: }\n107: \n108: func (r *PrometheusMetricsRecorder) IncWorkqueueAdds(resourceType string) {\n109: \tif r == nil {\n110: \t\treturn\n111: \t}\n112: \tr.workqueueAdds.WithLabelValues(resourceType).Inc()\n113: }\n114: \n115: func (r *PrometheusMetricsRecorder) IncGCCleanupTotal(reason string) {\n116: \tif r == nil {\n117: \t\treturn\n118: \t}\n119: \tr.gcCleanupTotal.WithLabelValues(reason).Inc()\n120: }\n121: \n122: func (r *PrometheusMetricsRecorder) ObserveGCCleanupDuration(reason string, duration time.Duration) {\n123: \tif r == nil {\n124: \t\treturn\n125: \t}\n126: \tr.gcCleanupDuration.WithLabelValues(reason).Observe(duration.Seconds())\n127: }\n128: \n129: func (r *PrometheusMetricsRecorder) IncGCCleanupErrors(reason string) {\n130: \tif r == nil {\n131: \t\treturn\n132: \t}\n133: \tr.gcCleanupErrors.WithLabelValues(reason).Inc()\n134: }\n135: \n136: func (r *PrometheusMetricsRecorder) ObserveGCCycleDuration(duration time.Duration) {\n137: \tif r == nil {\n138: \t\treturn\n139: \t}\n140: \tr.gcCycleDuration.WithLabelValues().Observe(duration.Seconds())\n141: }\n\n(End 