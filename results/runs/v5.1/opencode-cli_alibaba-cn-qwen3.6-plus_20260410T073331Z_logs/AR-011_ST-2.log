{"type":"tool_use","timestamp":1775830732037,"sessionID":"ses_2884073faffeGkgZBLhfZx1tsf","part":{"id":"prt_d77c289020013watS2GDklPQlV","messageID":"msg_d77c27d79001uXW25862qYZKOt","sessionID":"ses_2884073faffeGkgZBLhfZx1tsf","type":"tool","tool":"read","callID":"call_8a56620bfcc04c219b0e6577","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/pem\"\n9: \t\"os\"\n10: \t\"time\"\n11: \n12: \t\"github.com/golang-jwt/jwt/v5\"\n13: \t\"k8s.io/apimachinery/pkg/api/errors\"\n14: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n15: \t\"k8s.io/client-go/kubernetes\"\n16: \t\"k8s.io/client-go/rest\"\n17: \t\"k8s.io/klog/v2\"\n18: )\n19: \n20: const (\n21: \trsaKeySize         = 2048\n22: \tjwtExpiration      = 5 * time.Minute\n23: \tIdentitySecretName = \"picod-router-identity\"\n24: \tPrivateKeyDataKey  = \"private.pem\"\n25: \tPublicKeyDataKey   = \"public.pem\"\n26: )\n27: \n28: var IdentityNamespace = \"default\"\n29: \n30: func init() {\n31: \tif ns := os.Getenv(\"AGENTCUBE_NAMESPACE\"); ns != \"\" {\n32: \t\tIdentityNamespace = ns\n33: \t}\n34: }\n35: \n36: type JWTManager struct {\n37: \tprivateKey *rsa.PrivateKey\n38: \tpublicKey  *rsa.PublicKey\n39: \tclientset  kubernetes.Interface\n40: }\n41: \n42: func NewJWTManager() (*JWTManager, error) {\n43: \tprivateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n44: \tif err != nil {\n45: \t\treturn nil, err\n46: \t}\n47: \treturn &JWTManager{\n48: \t\tprivateKey: privateKey,\n49: \t\tpublicKey:  &privateKey.PublicKey,\n50: \t}, nil\n51: }\n52: \n53: func (m *JWTManager) GenerateToken(claims map[string]interface{}) (string, error) {\n54: \tnow := time.Now()\n55: \ttokenClaims := jwt.MapClaims{\n56: \t\t\"exp\": now.Add(jwtExpiration).Unix(),\n57: \t\t\"iat\": now.Unix(),\n58: \t\t\"iss\": \"agentcube-router\",\n59: \t}\n60: \tfor k, v := range claims {\n61: \t\ttokenClaims[k] = v\n62: \t}\n63: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n64: \treturn token.SignedString(m.privateKey)\n65: }\n66: \n67: func (m *JWTManager) TryStoreOrLoadJWTKeySecret(ctx context.Context) error {\n68: \tif m.clientset == nil {\n69: \t\tconfig, err := rest.InClusterConfig()\n70: \t\tif err != nil {\n71: \t\t\tklog.Warningf(\"not running in-cluster, using ephemeral keys: %v\", err)\n72: \t\t\treturn nil\n73: \t\t}\n74: \t\tm.clientset, err = kubernetes.NewForConfig(config)\n75: \t\tif err != nil {\n76: \t\t\tklog.Warningf(\"failed to create in-cluster clientset, using ephemeral keys: %v\", err)\n77: \t\t\treturn nil\n78: \t\t}\n79: \t}\n80: \n81: \tsecret := &metav1.Secret{\n82: \t\tObjectMeta: metav1.ObjectMeta{\n83: \t\t\tName:      IdentitySecretName,\n84: \t\t\tNamespace: IdentityNamespace,\n85: \t\t\tLabels: map[string]string{\n86: \t\t\t\t\"app\":       \"agentcube\",\n87: \t\t\t\t\"component\": \"router\",\n88: \t\t\t},\n89: \t\t},\n90: \t\tType: \"Opaque\",\n91: \t\tData: map[string][]byte{\n92: \t\t\tPrivateKeyDataKey: pem.EncodeToMemory(&pem.Block{\n93: \t\t\t\tType:  \"RSA PRIVATE KEY\",\n94: \t\t\t\tBytes: x509.MarshalPKCS1PrivateKey(m.privateKey),\n95: \t\t\t}),\n96: \t\t\tPublicKeyDataKey: pem.EncodeToMemory(&pem.Block{\n97: \t\t\t\tType:  \"PUBLIC KEY\",\n98: \t\t\t\tBytes: x509.MarshalPKCS1PublicKey(m.publicKey),\n99: \t\t\t}),\n100: \t\t},\n101: \t}\n102: \n103: \t_, err := m.clientset.CoreV1().Secrets(IdentityNamespace).Create(ctx, secret, metav1.CreateOptions{})\n104: \tif err != nil {\n105: \t\tif errors.IsAlreadyExists(err) {\n106: \t\t\texisting, getErr := m.clientset.CoreV1().Secrets(IdentityNamespace).Get(ctx, IdentitySecretName, metav1.GetOptions{})\n107: \t\t\tif getErr != nil {\n108: \t\t\t\treturn getErr\n109: \t\t\t}\n110: \t\t\treturn m.loadPrivateKeyPEM(existing.Data[PrivateKeyDataKey])\n111: \t\t}\n112: \t\treturn err\n113: \t}\n114: \treturn nil\n115: }\n116: \n117: func (m *JWTManager) loadPrivateKeyPEM(data []byte) error {\n118: \tblock, _ := pem.Decode(data)\n119: \tif block == nil {\n120: \t\treturn nil\n121: \t}\n122: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n123: \tif err != nil {\n124: \t\treturn err\n125: \t}\n126: \tm.privateKey = privateKey\n127: \tm.publicKey = &privateKey.PublicKey\n128: \treturn nil\n129: }\n\n(End of file - total 129 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go","time":{"start":1775830732029,"end":1775830732036}}}}
{"type":"tool_use","timestamp":1775830733261,"sessionID":"ses_2884073faffeGkgZBLhfZx1tsf","part":{"id":"prt_d77c28d890015qnSgkkfHIGZAC","messageID":"msg_d77c27d79001uXW25862qYZKOt","sessionID":"ses_2884073faffeGkgZBLhfZx1tsf","type":"tool","tool":"read","callID":"call_808353174643434d9a34beda","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"net/http\"\n6: \t\"os\"\n7: \t\"os/signal\"\n8: \t\"syscall\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n13: \t\"golang.org/x/net/http2\"\n14: \t\"golang.org/x/net/http2/h2c\"\n15: \t\"k8s.io/klog/v2\"\n16: )\n17: \n18: type Server struct {\n19: \tconfig         *Config\n20: \tengine         *gin.Engine\n21: \thttpServer     *http.Server\n22: \tsessionManager SessionManager\n23: \tstoreClient    store.Store\n24: \thttpTransport  *http.Transport\n25: \tjwtManager     *JWTManager\n26: }\n27: \n28: func NewServer(config *Config) (*Server, error) {\n29: \tif config.MaxConcurrentRequests <= 0 {\n30: \t\tconfig.MaxConcurrentRequests = 1000\n31: \t}\n32: \n33: \thttpTransport := &http.Transport{\n34: \t\tIdleConnTimeout:    0,\n35: \t\tDisableCompression: false,\n36: \t}\n37: \n38: \tif config.Debug {\n39: \t\tgin.SetMode(gin.DebugMode)\n40: \t} else {\n41: \t\tgin.SetMode(gin.ReleaseMode)\n42: \t}\n43: \n44: \tengine := gin.New()\n45: \n46: \tjwtManager, err := NewJWTManager()\n47: \tif err != nil {\n48: \t\treturn nil, err\n49: \t}\n50: \tif err := jwtManager.TryStoreOrLoadJWTKeySecret(context.Background()); err != nil {\n51: \t\treturn nil, err\n52: \t}\n53: \n54: \tstoreClient := store.Storage()\n55: \n56: \tsessionManager, err := NewSessionManager(storeClient)\n57: \tif err != nil {\n58: \t\treturn nil, err\n59: \t}\n60: \n61: \ts := &Server{\n62: \t\tconfig:         config,\n63: \t\tengine:         engine,\n64: \t\thttpTransport:  httpTransport,\n65: \t\tjwtManager:     jwtManager,\n66: \t\tstoreClient:    storeClient,\n67: \t\tsessionManager: sessionManager,\n68: \t}\n69: \n70: \ts.registerRoutes()\n71: \n72: \ts.httpServer = &http.Server{\n73: \t\tAddr:        \":\" + config.Port,\n74: \t\tHandler:     s.engine,\n75: \t\tReadTimeout: 30 * time.Second,\n76: \t\tIdleTimeout: 90 * time.Second,\n77: \t}\n78: \n79: \treturn s, nil\n80: }\n81: \n82: func (s *Server) registerRoutes() {\n83: \ts.engine.GET(\"/health/live\", handleHealthLive)\n84: \ts.engine.GET(\"/health/ready\", s.handleHealthReady)\n85: \n86: \tv1 := s.engine.Group(\"/v1\")\n87: \tv1.Use(gin.Logger())\n88: \tv1.Use(gin.Recovery())\n89: \tv1.Use(ConcurrencyLimitMiddleware(s.config.MaxConcurrentRequests))\n90: \n91: \tv1.GET(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n92: \tv1.POST(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n93: \tv1.GET(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n94: \tv1.POST(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n95: }\n96: \n97: func (s *Server) Start() error {\n98: \tif s.config.EnableTLS {\n99: \t\tif s.config.TLSCert == \"\" || s.config.TLSKey == \"\" {\n100: \t\t\treturn nil\n101: \t\t}\n102: \t\tklog.Infof(\"Starting HTTPS server on %s\", s.httpServer.Addr)\n103: \t\treturn s.httpServer.ListenAndServeTLS(s.config.TLSCert, s.config.TLSKey)\n104: \t}\n105: \n106: \th2cHandler := h2c.NewHandler(s.engine, &http2.Server{})\n107: \ts.httpServer.Handler = h2cHandler\n108: \n109: \tklog.Infof(\"Starting HTTP server on %s\", s.httpServer.Addr)\n110: \treturn s.httpServer.ListenAndServe()\n111: }\n112: \n113: func (s *Server) Run() {\n114: \tstopCh := make(chan os.Signal, 1)\n115: \tsignal.Notify(stopCh, syscall.SIGINT, syscall.SIGTERM)\n116: \n117: \tgo func() {\n118: \t\tif err := s.Start(); err != nil && err != http.ErrServerClosed {\n119: \t\t\tklog.Fatalf(\"server failed: %v\", err)\n120: \t\t}\n121: \t}()\n122: \n123: \t<-stopCh\n124: \tklog.Info(\"shutting down server...\")\n125: \n126: \tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n127: \tdefer cancel()\n128: \n129: \tif err := s.Shutdown(ctx); err != nil {\n130: \t\tklog.Errorf(\"server shutdown failed: %v\", err)\n131: \t}\n132: }\n133: \n134: func (s *Server) Shutdown(ctx context.Context) error {\n135: \tif s.httpServer == nil {\n136: \t\treturn nil\n137: \t}\n138: \treturn s.httpServer.Shutdown(ctx)\n139: }\n\n(End of file - total 139 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"golang.org/x/net/http2\"\n\t\"golang.org/x/net/http2/h2c\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go","time":{"start":1775830733252,"end":1775830733260}}}}
{"type":"tool_use","timestamp":1775830734489,"sessionID":"ses_2884073faffeGkgZBLhfZx1tsf","part":{"id":"prt_d77c29251001HjjNfMMVPtjTmK","messageID":"msg_d77c27d79001uXW25862qYZKOt","sessionID":"ses_2884073faffeGkgZBLhfZx1tsf","type":"tool","tool":"read","callID":"call_6792c382719f429c83e70667","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/middleware.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/middleware.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"log/slog\"\n6: \t\"time\"\n7: \n8: \t\"github.com/gin-gonic/gin\"\n9: \t\"github.com/google/uuid\"\n10: )\n11: \n12: func ConcurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n13: \tsem := make(chan struct{}, maxConcurrent)\n14: \treturn func(c *gin.Context) {\n15: \t\tselect {\n16: \t\tcase sem <- struct{}{}:\n17: \t\t\tdefer func() { <-sem }()\n18: \t\t\tc.Next()\n19: \t\tdefault:\n20: \t\t\tc.JSON(429, gin.H{\n21: \t\t\t\t\"error\": \"server overloaded, please try again later\",\n22: \t\t\t\t\"code\":  \"SERVER_OVERLOADED\",\n23: \t\t\t})\n24: \t\t\tc.Abort()\n25: \t\t}\n26: \t}\n27: }\n28: \n29: func RequestLoggerMiddleware() gin.HandlerFunc {\n30: \treturn func(c *gin.Context) {\n31: \t\tstart := time.Now()\n32: \t\tc.Next()\n33: \t\tduration := time.Since(start).Milliseconds()\n34: \t\tslog.Info(\"request\",\n35: \t\t\t\"method\", c.Request.Method,\n36: \t\t\t\"path\", c.Request.URL.Path,\n37: \t\t\t\"status\", c.Writer.Status(),\n38: \t\t\t\"duration_ms\", duration,\n39: \t\t\t\"trace_id\", c.GetHeader(\"X-Trace-Id\"),\n40: \t\t)\n41: \t}\n42: }\n43: \n44: func TraceIDMiddleware() gin.HandlerFunc {\n45: \treturn func(c *gin.Context) {\n46: \t\ttraceID := uuid.New().String()\n47: \t\tc.Request.Header.Set(\"X-Trace-Id\", traceID)\n48: \t\tc.Writer.Header().Set(\"X-Trace-Id\", traceID)\n49: \t\tc.Next()\n50: \t}\n51: }\n52: \n53: func FormatDuration(ms int64) string {\n54: \treturn fmt.Sprintf(\"%dms\", ms)\n55: }\n\n(End of file - total 55 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"log/slog\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n)\n\nfunc ConcurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n\tsem := make(chan struct{}, maxConcurrent)\n\treturn func(c *gin.Context) {\n\t\tselect {\n\t\tcase sem <- struct{}{}:\n\t\t\tdefer func() { <-sem }()\n\t\t\tc.Next()\n\t\tdefault:\n\t\t\tc.JSON(429, gin.H{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/middleware.go","time":{"start":1775830734480,"end":1775830734487}}}}
