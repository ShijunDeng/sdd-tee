untime.py\n│   ├── services/\n│   │   ├── __init__.py\n│   │   ├── docker_service.py\n│   │   └── metadata_service.py\n│   ├── models/\n│   │   ├── __init__.py\n│   │   └── pack_models.py\n│   └── operations/\n│       └── __init__.py\n├── tests/\n│   ├── __init__.py\n│   ├── cli/\n│   │   └── test_build_command.py\n│   ├── runtime/\n│   │   ├── test_build_runtime.py\n│   │   ├── test_build_runtime_version.py\n│   │   ├── test_build_runtime_prerequisites.py\n│   │   ├── test_build_runtime_local.py\n│   │   ├── test_build_runtime_cloud.py\n│   │   ├── test_build_runtime_metadata.py\n│   │   ├── test_pack_runtime_validation.py\n│   │   ├── test_pack_runtime_entrypoint.py\n│   │   ├── test_pack_runtime_overrides.py\n│   │   ├── test_pack_runtime_metadata_load.py\n│   │   └── test_pack_runtime_workspace.py\n│   ├── services/\n│   │   ├── test_docker_service.py\n│   │   └── test_metadata_service.py\n│   ├── models/\n│   │   └── test_pack_models.py\n│   └── integration/\n│       ├── __init__.py\n│       └── test_build_e2e.py\n└── examples/\n    ├── hello-agent/main.py\n    └── math-agent/main.py\n```\n\n**Note:** The following files referenced in the design doc are NOT yet implemented (out of scope for AR-021):\n- `agentcube/runtime/publish_runtime.py`\n- `agentcube/runtime/invoke_runtime.py`\n- `agentcube/runtime/status_runtime.py`\n- `agentcube/services/k8s_provider.py`\n- `agentcube/services/agentcube_provider.py`\n\n---\n\n### 3. AR-021 SPEC/DESIGN DOCUMENTS\n\n**Location:** `/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/changes/AR-021/`\n\n| File | Path |\n|------|------|\n| Proposal | `/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/changes/AR-021/proposal.md` (388 lines) |\n| Delta Spec | `/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/changes/AR-021/delta-spec.md` (245 lines) |\n| Design | `/home/dsj/benchmark/workspaces/v5.1/opencode-cli