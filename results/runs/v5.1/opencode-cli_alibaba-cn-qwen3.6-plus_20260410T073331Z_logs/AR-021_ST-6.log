vider\"] == \"huawei\"\n91:         assert result[\"job_id\"].startswith(\"build-test-agent-\")\n92: \n93: \n94: class TestBuildRuntimeBuildFailureVersionRollback:\n95:     def test_version_rolled_back_on_build_failure(self, packed_workspace: Path) -> None:\n96:         mock_client = MagicMock()\n97:         mock_client.ping.return_value = True\n98:         mock_client.images.build.side_effect = Exception(\"Docker daemon error\")\n99: \n100:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n101:             runtime = BuildRuntime()\n102:             with pytest.raises(Exception, match=\"Docker daemon error\"):\n103:                 runtime.build(packed_workspace)\n104: \n105:         from agentcube.services.metadata_service import MetadataService\n106:         service = MetadataService()\n107:         metadata = service.load_metadata(packed_workspace)\n108:         assert metadata is not None\n109:         assert metadata.version == \"1.0.0\"\n110: \n111: \n112: class TestBuildRuntimeBuildFailureMetadataSaved:\n113:     def test_metadata_saved_with_rolled_back_version(self, packed_workspace: Path) -> None:\n114:         with patch(\"agentcube.services.docker_service.docker.from_env\") as mock_from_env:\n115:             mock_from_env.side_effect = Exception(\"Build failed\")\n116:             runtime = BuildRuntime()\n117:             with pytest.raises(Exception):\n118:                 runtime.build(packed_workspace)\n119: \n120:         content = (packed_workspace / \"agent_metadata.yaml\").read_text()\n121:         assert \"version: 1.0.0\" in content\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for BuildRuntime main build() orchestration.\"\"\"\n\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\n@pytest.fixture\