 lines)\n</content>","metadata":{"preview":"package router\n\nimport \"time\"\n\nconst LastActivityAnnotationKey = \"agentcube.volcano.sh/last-activity\"\n\ntype JWTConfig struct {\n\tExpiration time.Duration\n\tIssuer     string\n\tLeeway     time.Duration\n}\n\ntype Config struct {\n\tPort                  string\n\tDebug                 bool\n\tEnableTLS             bool\n\tTLSCert               string\n\tTLSKey                string\n\tMaxConcurrentRequests int\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/config.go","time":{"start":1775846454410,"end":1775846454415}}}}
