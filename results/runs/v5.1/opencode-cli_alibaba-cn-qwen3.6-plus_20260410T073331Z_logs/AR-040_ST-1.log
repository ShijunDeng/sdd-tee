{"type":"tool_use","timestamp":1775892272440,"sessionID":"ses_284933119ffe5HMvafcOzuBksc","part":{"id":"prt_d7b6d90a3001MS0gSaHG3vay8J","messageID":"msg_d7b6d800e001IgiwPpxZBRG3ZM","sessionID":"ses_284933119ffe5HMvafcOzuBksc","type":"tool","tool":"read","callID":"call_7aa9d51392a44f3f8d711802","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_agent_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_agent_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for AgentRuntimeDataPlaneClient and AgentRuntimeClient.\"\"\"\n2: \n3: import os\n4: from unittest.mock import MagicMock, patch, PropertyMock\n5: \n6: import pytest\n7: import requests\n8: from requests.adapters import HTTPAdapter\n9: \n10: from agentcube.agent_runtime import AgentRuntimeClient\n11: from agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n12: \n13: \n14: # ---------------------------------------------------------------------------\n15: # T-1: AgentRuntimeDataPlaneClient — Base URL and HTTP session\n16: # ---------------------------------------------------------------------------\n17: \n18: \n19: class TestDataPlaneClientBaseUrl:\n20:     def test_base_url_is_correctly_constructed(self):\n21:         client = AgentRuntimeDataPlaneClient(\n22:             router_url=\"https://router.example.com\",\n23:             namespace=\"my-ns\",\n24:             agent_name=\"my-agent\",\n25:         )\n26:         assert client.base_url == (\n27:             \"https://router.example.com/v1/namespaces/my-ns/\"\n28:             \"agent-runtimes/my-agent/invocations/\"\n29:         )\n30: \n31:     def test_base_url_with_trailing_slash_on_router(self):\n32:         client = AgentRuntimeDataPlaneClient(\n33:             router_url=\"https://router.example.com/\",\n34:             namespace=\"ns\",\n35:             agent_name=\"agent\",\n36:         )\n37:         assert client.base_url == (\n38:             \"https://router.example.com/v1/namespaces/ns/\"\n39:             \"agent-runtimes/agent/invocations/\"\n40:         )\n41: \n42:     def test_session_header_constant(self):\n43:         assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n44: \n45:     def test_session_has_http_adapter_with_correct_pool_settings(self):\n46:         client = AgentRuntimeDataPlaneClient(\n47:             router_url=\"https://router.example.com\",\n48:             namespace=\"ns\",\n49:             agent_name=\"agent\",\n50:         )\n51:         http_adapter = client.session.adapters[\"http://\"]\n52:         https_adapter = client.session.adapters[\"https://\"]\n53:         assert isinstance(http_adapter, HTTPAdapter)\n54:         assert isinstance(https_adapter, HTTPAdapter)\n55:         assert http_adapter._pool_connections == 10\n56:         assert http_adapter._pool_maxsize == 10\n57: \n58:     def test_custom_pool_settings(self):\n59:         client = AgentRuntimeDataPlaneClient(\n60:             router_url=\"https://router.example.com\",\n61:             namespace=\"ns\",\n62:             agent_name=\"agent\",\n63:             pool_connections=20,\n64:             pool_maxsize=30,\n65:         )\n66:         adapter = client.session.adapters[\"http://\"]\n67:         assert adapter._pool_connections == 20\n68:         assert adapter._pool_maxsize == 30\n69: \n70:     def test_constructor_stores_all_fields_with_explicit_arguments(self):\n71:         client = AgentRuntimeDataPlaneClient(\n72:             router_url=\"https://router.example.com\",\n73:             namespace=\"custom-ns\",\n74:             agent_name=\"custom-agent\",\n75:             timeout=60,\n76:             connect_timeout=3.0,\n77:         )\n78:         assert client.router_url == \"https://router.example.com\"\n79:         assert client.namespace == \"custom-ns\"\n80:         assert client.agent_name == \"custom-agent\"\n81:         assert client.timeout == 60\n82:         assert client.connect_timeout == 3.0\n83: \n84:     def test_constructor_uses_default_timeout_values(self):\n85:         client = AgentRuntimeDataPlaneClient(\n86:             router_url=\"https://router.example.com\",\n87:             namespace=\"ns\",\n88:             agent_name=\"agent\",\n89:         )\n90:         assert client.timeout == 120\n91:         assert client.connect_timeout == 5.0\n92: \n93: \n94: # ---------------------------------------------------------------------------\n95: # T-2: AgentRuntimeDataPlaneClient — bootstrap_session_id\n96: # ---------------------------------------------------------------------------\n97: \n98: \n99: class TestBootstrapSessionId:\n100:     def test_bootstrap_returns_session_id_when_header_present(self):\n101:         client = AgentRuntimeDataPlaneClient(\n102:             router_url=\"https://router.example.com\",\n103:             namespace=\"ns\",\n104:             agent_name=\"agent\",\n105:         )\n106:         mock_resp = MagicMock(spec=requests.Response)\n107:         mock_resp.headers = {\"x-agentcube-session-id\": \"abc-123\"}\n108:         mock_resp.raise_for_status = MagicMock()\n109:         client.session.get = MagicMock(return_value=mock_resp)\n110: \n111:         result = client.bootstrap_session_id()\n112: \n113:         client.session.get.assert_called_once_with(\n114:             client.base_url,\n115:             timeout=(5.0, 120),\n116:         )\n117:         assert result == \"abc-123\"\n118: \n119:     def test_bootstrap_raises_value_error_when_header_missing(self):\n120:         client = AgentRuntimeDataPlaneClient(\n121:             router_url=\"https://router.example.com\",\n122:             namespace=\"ns\",\n123:             agent_name=\"agent\",\n124:         )\n125:         mock_resp = MagicMock(spec=requests.Response)\n126:         mock_resp.headers = {}\n127:         mock_resp.raise_for_status = MagicMock()\n128:         client.session.get = MagicMock(return_value=mock_resp)\n129: \n130:         with pytest.raises(ValueError) as exc_info:\n131:             client.bootstrap_session_id()\n132: \n133:         assert \"Missing required response header: x-agentcube-session-id\" in str(\n134:             exc_info.value\n135:         )\n136: \n137:     def test_bootstrap_raises_http_error_on_non_2xx(self):\n138:         client = AgentRuntimeDataPlaneClient(\n139:             router_url=\"https://router.example.com\",\n140:             namespace=\"ns\",\n141:             agent_name=\"agent\",\n142:         )\n143:         mock_resp = MagicMock(spec=requests.Response)\n144:         mock_resp.raise_for_status = MagicMock(\n145:             side_effect=requests.HTTPError(\"500 Server Error\")\n146:         )\n147:         client.session.get = MagicMock(return_value=mock_resp)\n148: \n149:         with pytest.raises(requests.HTTPError):\n150:             client.bootstrap_session_id()\n151: \n152:     def test_bootstrap_calls_raise_for_status(self):\n153:         client = AgentRuntimeDataPlaneClient(\n154:             router_url=\"https://router.example.com\",\n155:             namespace=\"ns\",\n156:             agent_name=\"agent\",\n157:         )\n158:         mock_resp = MagicMock(spec=requests.Response)\n159:         mock_resp.headers = {\"x-agentcube-session-id\": \"session-1\"}\n160:         mock_resp.raise_for_status = MagicMock()\n161:         client.session.get = MagicMock(return_value=mock_resp)\n162: \n163:         client.bootstrap_session_id()\n164: \n165:         mock_resp.raise_for_status.assert_called_once()\n166: \n167: \n168: # ---------------------------------------------------------------------------\n169: # T-3: AgentRuntimeDataPlaneClient — invoke\n170: # ---------------------------------------------------------------------------\n171: \n172: \n173: class TestDataPlaneInvoke:\n174:     def test_invoke_posts_correct_url_with_session_header_and_json_body(self):\n175:         client = AgentRuntimeDataPlaneClient(\n176:             router_url=\"https://router.example.com\",\n177:             namespace=\"ns\",\n178:             agent_name=\"agent\",\n179:         )\n180:         mock_resp = MagicMock(spec=requests.Response)\n181:         mock_resp.raise_for_status = MagicMock()\n182:         client.session.post = MagicMock(return_value=mock_resp)\n183: \n184:         payload = {\"action\": \"run\", \"input\": \"hello\"}\n185:         result = client.invoke(session_id=\"sess-1\", payload=payload)\n186: \n187:         client.session.post.assert_called_once_with(\n188:             client.base_url,\n189:             json=payload,\n190:             headers={\n191:                 \"x-agentcube-session-id\": \"sess-1\",\n192:                 \"Content-Type\": \"application/json\",\n193:             },\n194:             timeout=(5.0, 120),\n195:         )\n196:         assert result is mock_resp\n197: \n198:     def test_invoke_with_timeout_none_uses_default_read_timeout(self):\n199:         client = AgentRuntimeDataPlaneClient(\n200:             router_url=\"https://router.example.com\",\n201:             namespace=\"ns\",\n202:             agent_name=\"agent\",\n203:             timeout=120,\n204:             connect_timeout=5.0,\n205:         )\n206:         mock_resp = MagicMock(spec=requests.Response)\n207:         mock_resp.raise_for_status = MagicMock()\n208:         client.session.post = MagicMock(return_value=mock_resp)\n209: \n210:         client.invoke(session_id=\"sess-1\", payload={\"key\": \"val\"}, timeout=None)\n211: \n212:         _, kwargs = client.session.post.call_args\n213:         assert kwargs[\"timeout\"] == (5.0, 120)\n214: \n215:     def test_invoke_with_explicit_timeout_uses_provided_value(self):\n216:         client = AgentRuntimeDataPlaneClient(\n217:             router_url=\"https://router.example.com\",\n218:             namespace=\"ns\",\n219:             agent_name=\"agent\",\n220:             timeout=120,\n221:             connect_timeout=5.0,\n222:         )\n223:         mock_resp = MagicMock(spec=requests.Response)\n224:         mock_resp.raise_for_status = MagicMock()\n225:         client.session.post = MagicMock(return_value=mock_resp)\n226: \n227:         client.invoke(session_id=\"sess-1\", payload={\"key\": \"val\"}, timeout=60.0)\n228: \n229:         _, kwargs = client.session.post.call_args\n230:         assert kwargs[\"timeout\"] == (5.0, 60.0)\n231: \n232:     def test_invoke_returns_raw_response(self):\n233:         client = AgentRuntimeDataPlaneClient(\n234:             router_url=\"https://router.example.com\",\n235:             namespace=\"ns\",\n236:             agent_name=\"agent\",\n237:         )\n238:         mock_resp = MagicMock(spec=requests.Response)\n239:         mock_resp.raise_for_status = MagicMock()\n240:         client.session.post = MagicMock(return_value=mock_resp)\n241: \n242:         result = client.invoke(session_id=\"sess-1\", payload={})\n243: \n244:         assert result is mock_resp\n245: \n246:     def test_invoke_calls_raise_for_status(self):\n247:         client = AgentRuntimeDataPlaneClient(\n248:             router_url=\"https://router.example.com\",\n249:             namespace=\"ns\",\n250:             agent_name=\"agent\",\n251:         )\n252:         mock_resp = MagicMock(spec=requests.Response)\n253:         mock_resp.raise_for_status = MagicMock()\n254:         client.session.post = MagicMock(return_value=mock_resp)\n255: \n256:         client.invoke(session_id=\"sess-1\", payload={})\n257: \n258:         mock_resp.raise_for_status.assert_called_once()\n259: \n260: \n261: # ---------------------------------------------------------------------------\n262: # T-4: AgentRuntimeDataPlaneClient — close\n263: # ---------------------------------------------------------------------------\n264: \n265: \n266: class TestDataPlaneClose:\n267:     def test_close_closes_underlying_http_session(self):\n268:         client = AgentRuntimeDataPlaneClient(\n269:             router_url=\"https://router.example.com\",\n270:             namespace=\"ns\",\n271:             agent_name=\"agent\",\n272:         )\n273:         client.session.close = MagicMock()\n274: \n275:         client.close()\n276: \n277:         client.session.close.assert_called_once()\n278: \n279:     def test_close_is_idempotent(self):\n280:         client = AgentRuntimeDataPlaneClient(\n281:             router_url=\"https://router.example.com\",\n282:             namespace=\"ns\",\n283:             agent_name=\"agent\",\n284:         )\n285:         client.session.close = MagicMock()\n286: \n287:         client.close()\n288:         client.close()\n289:         client.close()\n290: \n291:         assert client.session.close.call_count == 3\n292: \n293: \n294: # ---------------------------------------------------------------------------\n295: # T-5: AgentRuntimeClient — Initialization with defaults\n296: # ---------------------------------------------------------------------------\n297: \n298: \n299: class TestClientInitDefaults:\n300:     @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n301:     def test_constructor_with_only_agent_name_uses_all_defaults(self, mock_bootstrap):\n302:         with patch.dict(os.environ, {\"ROUTER_URL\": \"https://router.example.com\"}):\n303:             client = AgentRuntimeClient(agent_name=\"my-agent\")\n304: \n305:         assert client.agent_name == \"my-agent\"\n306:         assert client.namespace == \"default\"\n307:         assert client.timeout == 120\n308:         assert client.connect_timeout == 5.0\n309:         assert client.session_id == \"bootstrapped-session\"\n310:         assert client.router_url == \"https://router.example.com\"\n311: \n312:     @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n313:     def test_constructor_with_explicit_args_stores_all_fields(self, mock_bootstrap):\n314:         client = AgentRuntimeClient(\n315:             agent_name=\"explicit-agent\",\n316:             namespace=\"explicit-ns\",\n317:             router_url=\"https://explicit-router.com\",\n318:             verbose=True,\n319:             session_id=\"pre-existing-session\",\n320:             timeout=60,\n321:             connect_timeout=3.0,\n322:         )\n323: \n324:         assert client.agent_name == \"explicit-agent\"\n325:         assert client.namespace == \"explicit-ns\"\n326:         assert client.timeout == 60\n327:         assert client.connect_timeout == 3.0\n328:         assert client.router_url == \"https://explicit-router.com\"\n329:         assert client.session_id == \"pre-existing-session\"\n330:         mock_bootstrap.assert_not_called()\n331: \n332:     @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n333:     def test_constructor_resolves_router_url_from_env(self, mock_bootstrap):\n334:         with patch.dict(os.environ, {\"ROUTER_URL\": \"https://env-router.com\"}):\n335:             client = AgentRuntimeClient(agent_name=\"my-agent\")\n336: \n337:         assert client.router_url == \"https://env-router.com\"\n338: \n339:     def test_constructor_raises_value_error_when_no_router_url(self):\n340:         with patch.dict(os.environ, {}, clear=True):\n341:             # Ensure ROUTER_URL is not set\n342:             os.environ.pop(\"ROUTER_URL\", None)\n343:             with pytest.raises(ValueError) as exc_info:\n344:                 AgentRuntimeClient(agent_name=\"my-agent\")\n345: \n346:         assert \"router_url must be provided or ROUTER_URL env var must be set\" in str(\n347:             exc_info.value\n348:         )\n349: \n350:     @patch.object(AgentRuntimeDataPlaneClient, \"bootstrap_session_id\", return_value=\"bootstrapped-session\")\n351:     def test_dp_client_is_constructed_with_resolved_params(self, mock_bootstrap):\n352:         with patch(\n353:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n354:         ) as mock_dp_cls:\n355:             mock_dp_instance = MagicMock()\n356:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n357:             mock_dp_cls.return_value = mock_dp_instance\n358: \n359:             client = AgentRuntimeClient(\n360:                 agent_name=\"my-agent\",\n361:                 namespace=\"my-ns\",\n362:                 router_url=\"https://router.example.com\",\n363:                 timeout=90,\n364:                 connect_timeout=4.0,\n365:             )\n366: \n367:             mock_dp_cls.assert_called_once_with(\n368:                 router_url=\"https://router.example.com\",\n369:                 namespace=\"my-ns\",\n370:                 agent_name=\"my-agent\",\n371:                 timeout=90,\n372:                 connect_timeout=4.0,\n373:             )\n374:             assert client.dp_client is mock_dp_instance\n375: \n376: \n377: # ---------------------------------------------------------------------------\n378: # T-6: AgentRuntimeClient — Session bootstrapping and reuse\n379: # ---------------------------------------------------------------------------\n380: \n381: \n382: class TestClientSession:\n383:     def test_session_id_none_triggers_bootstrap(self):\n384:         with patch(\n385:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n386:         ) as mock_dp_cls:\n387:             mock_dp_instance = MagicMock()\n388:             mock_dp_instance.bootstrap_session_id.return_value = \"bootstrapped-123\"\n389:             mock_dp_cls.return_value = mock_dp_instance\n390: \n391:             client = AgentRuntimeClient(\n392:                 agent_name=\"my-agent\",\n393:                 router_url=\"https://router.example.com\",\n394:                 session_id=None,\n395:             )\n396: \n397:             mock_dp_instance.bootstrap_session_id.assert_called_once()\n398:             assert client.session_id == \"bootstrapped-123\"\n399: \n400:     def test_session_id_provided_skips_bootstrap(self):\n401:         with patch(\n402:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n403:         ) as mock_dp_cls:\n404:             mock_dp_instance = MagicMock()\n405:             mock_dp_cls.return_value = mock_dp_instance\n406: \n407:             client = AgentRuntimeClient(\n408:                 agent_name=\"my-agent\",\n409:                 router_url=\"https://router.example.com\",\n410:                 session_id=\"existing-session-id\",\n411:             )\n412: \n413:             mock_dp_instance.bootstrap_session_id.assert_not_called()\n414:             assert client.session_id == \"existing-session-id\"\n415: \n416:     def test_verbose_true_creates_logger_with_debug_level(self):\n417:         with patch(\n418:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n419:         ) as mock_dp_cls:\n420:             mock_dp_instance = MagicMock()\n421:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n422:             mock_dp_cls.return_value = mock_dp_instance\n423: \n424:             client = AgentRuntimeClient(\n425:                 agent_name=\"my-agent\",\n426:                 router_url=\"https://router.example.com\",\n427:                 verbose=True,\n428:             )\n429: \n430:             assert client.logger.level == 10  # logging.DEBUG\n431: \n432:     def test_verbose_false_creates_logger_with_info_level(self):\n433:         with patch(\n434:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n435:         ) as mock_dp_cls:\n436:             mock_dp_instance = MagicMock()\n437:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n438:             mock_dp_cls.return_value = mock_dp_instance\n439: \n440:             client = AgentRuntimeClient(\n441:                 agent_name=\"my-agent\",\n442:                 router_url=\"https://router.example.com\",\n443:                 verbose=False,\n444:             )\n445: \n446:             assert client.logger.level == 20  # logging.INFO\n447: \n448: \n449: # ---------------------------------------------------------------------------\n450: # T-7: AgentRuntimeClient — Context manager\n451: # ---------------------------------------------------------------------------\n452: \n453: \n454: class TestContextManager:\n455:     def test_enter_returns_self(self):\n456:         with patch(\n457:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n458:         ) as mock_dp_cls:\n459:             mock_dp_instance = MagicMock()\n460:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n461:             mock_dp_cls.return_value = mock_dp_instance\n462: \n463:             client = AgentRuntimeClient(\n464:                 agent_name=\"my-agent\",\n465:                 router_url=\"https://router.example.com\",\n466:             )\n467: \n468:             assert client.__enter__() is client\n469: \n470:     def test_exit_with_no_exception_calls_close(self):\n471:         with patch(\n472:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n473:         ) as mock_dp_cls:\n474:             mock_dp_instance = MagicMock()\n475:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n476:             mock_dp_cls.return_value = mock_dp_instance\n477: \n478:             client = AgentRuntimeClient(\n479:                 agent_name=\"my-agent\",\n480:                 router_url=\"https://router.example.com\",\n481:             )\n482:             client.close = MagicMock()\n483: \n484:             client.__exit__(None, None, None)\n485: \n486:             client.close.assert_called_once()\n487: \n488:     def test_exit_with_exception_calls_close_and_re_raises(self):\n489:         with patch(\n490:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n491:         ) as mock_dp_cls:\n492:             mock_dp_instance = MagicMock()\n493:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n494:             mock_dp_cls.return_value = mock_dp_instance\n495: \n496:             client = AgentRuntimeClient(\n497:                 agent_name=\"my-agent\",\n498:                 router_url=\"https://router.example.com\",\n499:             )\n500:             client.close = MagicMock()\n501: \n502:             exc_type = ValueError\n503:             exc_val = ValueError(\"test error\")\n504:             exc_tb = None\n505: \n506:             result = client.__exit__(exc_type, exc_val, exc_tb)\n507: \n508:             client.close.assert_called_once()\n509:             assert result is None  # does not suppress exception\n510: \n511:     def test_context_manager_with_statement_normal_flow(self):\n512:         with patch(\n513:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n514:         ) as mock_dp_cls:\n515:             mock_dp_instance = MagicMock()\n516:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n517:             mock_dp_cls.return_value = mock_dp_instance\n518: \n519:             with AgentRuntimeClient(\n520:                 agent_name=\"my-agent\",\n521:                 router_url=\"https://router.example.com\",\n522:             ) as client:\n523:                 assert client.session_id == \"session-1\"\n524: \n525:             mock_dp_instance.close.assert_called_once()\n526: \n527:     def test_context_manager_with_statement_exception_flow(self):\n528:         with patch(\n529:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n530:         ) as mock_dp_cls:\n531:             mock_dp_instance = MagicMock()\n532:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n533:             mock_dp_cls.return_value = mock_dp_instance\n534: \n535:             with pytest.raises(RuntimeError):\n536:                 with AgentRuntimeClient(\n537:                     agent_name=\"my-agent\",\n538:                     router_url=\"https://router.example.com\",\n539:                 ) as client:\n540:                     raise RuntimeError(\"boom\")\n541: \n542:             mock_dp_instance.close.assert_called_once()\n543: \n544: \n545: # ---------------------------------------------------------------------------\n546: # T-8: AgentRuntimeClient — invoke\n547: # ---------------------------------------------------------------------------\n548: \n549: \n550: class TestClientInvoke:\n551:     def test_invoke_with_valid_session_calls_dp_invoke_and_returns_parsed_json(self):\n552:         with patch(\n553:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n554:         ) as mock_dp_cls:\n555:             mock_dp_instance = MagicMock()\n556:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n557:             mock_dp_cls.return_value = mock_dp_instance\n558: \n559:             mock_response = MagicMock(spec=requests.Response)\n560:             mock_response.json.return_value = {\"result\": \"ok\", \"status\": 200}\n561:             mock_dp_instance.invoke.return_value = mock_response\n562: \n563:             client = AgentRuntimeClient(\n564:                 agent_name=\"my-agent\",\n565:                 router_url=\"https://router.example.com\",\n566:             )\n567: \n568:             result = client.invoke({\"action\": \"run\"})\n569: \n570:             mock_dp_instance.invoke.assert_called_once_with(\n571:                 session_id=\"session-1\",\n572:                 payload={\"action\": \"run\"},\n573:                 timeout=None,\n574:             )\n575:             assert result == {\"result\": \"ok\", \"status\": 200}\n576: \n577:     def test_invoke_with_session_id_none_raises_value_error(self):\n578:         with patch(\n579:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n580:         ) as mock_dp_cls:\n581:             mock_dp_instance = MagicMock()\n582:             mock_dp_instance.bootstrap_session_id.return_value = None\n583:             mock_dp_cls.return_value = mock_dp_instance\n584: \n585:             client = AgentRuntimeClient(\n586:                 agent_name=\"my-agent\",\n587:                 router_url=\"https://router.example.com\",\n588:             )\n589: \n590:             with pytest.raises(ValueError) as exc_info:\n591:                 client.invoke({\"action\": \"run\"})\n592: \n593:             assert \"AgentRuntime session_id is not initialized\" in str(exc_info.value)\n594: \n595:     def test_invoke_with_custom_timeout_passes_timeout_to_data_plane(self):\n596:         with patch(\n597:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n598:         ) as mock_dp_cls:\n599:             mock_dp_instance = MagicMock()\n600:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n601:             mock_dp_cls.return_value = mock_dp_instance\n602: \n603:             mock_response = MagicMock(spec=requests.Response)\n604:             mock_response.json.return_value = {\"result\": \"ok\"}\n605:             mock_dp_instance.invoke.return_value = mock_response\n606: \n607:             client = AgentRuntimeClient(\n608:                 agent_name=\"my-agent\",\n609:                 router_url=\"https://router.example.com\",\n610:             )\n611: \n612:             client.invoke({\"action\": \"run\"}, timeout=30.0)\n613: \n614:             mock_dp_instance.invoke.assert_called_once_with(\n615:                 session_id=\"session-1\",\n616:                 payload={\"action\": \"run\"},\n617:                 timeout=30.0,\n618:             )\n619: \n620:     def test_invoke_with_timeout_none_passes_none_to_data_plane(self):\n621:         with patch(\n622:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n623:         ) as mock_dp_cls:\n624:             mock_dp_instance = MagicMock()\n625:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n626:             mock_dp_cls.return_value = mock_dp_instance\n627: \n628:             mock_response = MagicMock(spec=requests.Response)\n629:             mock_response.json.return_value = {\"result\": \"ok\"}\n630:             mock_dp_instance.invoke.return_value = mock_response\n631: \n632:             client = AgentRuntimeClient(\n633:                 agent_name=\"my-agent\",\n634:                 router_url=\"https://router.example.com\",\n635:             )\n636: \n637:             client.invoke({\"action\": \"run\"}, timeout=None)\n638: \n639:             mock_dp_instance.invoke.assert_called_once_with(\n640:                 session_id=\"session-1\",\n641:                 payload={\"action\": \"run\"},\n642:                 timeout=None,\n643:             )\n644: \n645:     def test_invoke_with_empty_session_id_raises_value_error(self):\n646:         with patch(\n647:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n648:         ) as mock_dp_cls:\n649:             mock_dp_instance = MagicMock()\n650:             mock_dp_instance.bootstrap_session_id.return_value = \"\"\n651:             mock_dp_cls.return_value = mock_dp_instance\n652: \n653:             client = AgentRuntimeClient(\n654:                 agent_name=\"my-agent\",\n655:                 router_url=\"https://router.example.com\",\n656:             )\n657: \n658:             with pytest.raises(ValueError) as exc_info:\n659:                 client.invoke({\"action\": \"run\"})\n660: \n661:             assert \"AgentRuntime session_id is not initialized\" in str(exc_info.value)\n662: \n663: \n664: # ---------------------------------------------------------------------------\n665: # T-9: AgentRuntimeClient — close\n666: # ---------------------------------------------------------------------------\n667: \n668: \n669: class TestClientClose:\n670:     def test_close_delegates_to_dp_client_close(self):\n671:         with patch(\n672:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n673:         ) as mock_dp_cls:\n674:             mock_dp_instance = MagicMock()\n675:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n676:             mock_dp_cls.return_value = mock_dp_instance\n677: \n678:             client = AgentRuntimeClient(\n679:                 agent_name=\"my-agent\",\n680:                 router_url=\"https://router.example.com\",\n681:             )\n682: \n683:             client.close()\n684: \n685:             mock_dp_instance.close.assert_called_once()\n686: \n687:     def test_close_is_idempotent(self):\n688:         with patch(\n689:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n690:         ) as mock_dp_cls:\n691:             mock_dp_instance = MagicMock()\n692:             mock_dp_instance.bootstrap_session_id.return_value = \"session-1\"\n693:             mock_dp_cls.return_value = mock_dp_instance\n694: \n695:             client = AgentRuntimeClient(\n696:                 agent_name=\"my-agent\",\n697:                 router_url=\"https://router.example.com\",\n698:             )\n699: \n700:             client.close()\n701:             client.close()\n702:             client.close()\n703: \n704:             assert mock_dp_instance.close.call_count == 3\n705: \n706: \n707: # ---------------------------------------------------------------------------\n708: # T-10: Integration tests\n709: # ---------------------------------------------------------------------------\n710: \n711: \n712: class TestAgentRuntimeIntegration:\n713:     def test_full_lifecycle_with_context_manager(self):\n714:         \"\"\"Full lifecycle: init -> bootstrap -> invoke -> cleanup.\"\"\"\n715:         with patch(\n716:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n717:         ) as mock_dp_cls:\n718:             mock_dp_instance = MagicMock()\n719:             mock_dp_instance.bootstrap_session_id.return_value = \"session-lifecycle\"\n720:             mock_dp_cls.return_value = mock_dp_instance\n721: \n722:             mock_response = MagicMock(spec=requests.Response)\n723:             mock_response.json.return_value = {\"output\": \"hello world\"}\n724:             mock_dp_instance.invoke.return_value = mock_response\n725: \n726:             with AgentRuntimeClient(\n727:                 agent_name=\"test-agent\",\n728:                 namespace=\"test-ns\",\n729:                 router_url=\"https://router.test.com\",\n730:             ) as client:\n731:                 assert client.session_id == \"session-lifecycle\"\n732:                 result = client.invoke({\"message\": \"hello\"})\n733:                 assert result == {\"output\": \"hello world\"}\n734: \n735:             mock_dp_instance.bootstrap_session_id.assert_called_once()\n736:             mock_dp_instance.invoke.assert_called_once()\n737:             mock_dp_instance.close.assert_called_once()\n738: \n739:     def test_pre_provisioned_session_skips_bootstrap(self):\n740:         with patch(\n741:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n742:         ) as mock_dp_cls:\n743:             mock_dp_instance = MagicMock()\n744:             mock_dp_cls.return_value = mock_dp_instance\n745: \n746:             mock_response = MagicMock(spec=requests.Response)\n747:             mock_response.json.return_value = {\"output\": \"result\"}\n748:             mock_dp_instance.invoke.return_value = mock_response\n749: \n750:             with AgentRuntimeClient(\n751:                 agent_name=\"test-agent\",\n752:                 router_url=\"https://router.test.com\",\n753:                 session_id=\"pre-provisioned\",\n754:             ) as client:\n755:                 assert client.session_id == \"pre-provisioned\"\n756:                 result = client.invoke({\"query\": \"test\"})\n757:                 assert result == {\"output\": \"result\"}\n758: \n759:             mock_dp_instance.bootstrap_session_id.assert_not_called()\n760:             mock_dp_instance.invoke.assert_called_once()\n761:             mock_dp_instance.close.assert_called_once()\n762: \n763:     def test_invoke_with_custom_timeout(self):\n764:         with patch(\n765:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n766:         ) as mock_dp_cls:\n767:             mock_dp_instance = MagicMock()\n768:             mock_dp_instance.bootstrap_session_id.return_value = \"session-timeout\"\n769:             mock_dp_cls.return_value = mock_dp_instance\n770: \n771:             mock_response = MagicMock(spec=requests.Response)\n772:             mock_response.json.return_value = {\"status\": \"done\"}\n773:             mock_dp_instance.invoke.return_value = mock_response\n774: \n775:             with AgentRuntimeClient(\n776:                 agent_name=\"test-agent\",\n777:                 router_url=\"https://router.test.com\",\n778:                 timeout=60,\n779:                 connect_timeout=3.0,\n780:             ) as client:\n781:                 client.invoke({\"task\": \"long_running\"}, timeout=30.0)\n782: \n783:             mock_dp_instance.invoke.assert_called_once_with(\n784:                 session_id=\"session-timeout\",\n785:                 payload={\"task\": \"long_running\"},\n786:                 timeout=30.0,\n787:             )\n788: \n789:     def test_context_manager_exit_with_exception_still_closes_session(self):\n790:         with patch(\n791:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n792:         ) as mock_dp_cls:\n793:             mock_dp_instance = MagicMock()\n794:             mock_dp_instance.bootstrap_session_id.return_value = \"session-exception\"\n795:             mock_dp_cls.return_value = mock_dp_instance\n796: \n797:             with pytest.raises(ValueError):\n798:                 with AgentRuntimeClient(\n799:                     agent_name=\"test-agent\",\n800:                     router_url=\"https://router.test.com\",\n801:                 ) as client:\n802:                     assert client.session_id == \"session-exception\"\n803:                     raise ValueError(\"something went wrong\")\n804: \n805:             mock_dp_instance.close.assert_called_once()\n806: \n807:     def test_missing_router_url_raises_value_error(self):\n808:         with patch.dict(os.environ, {}, clear=True):\n809:             os.environ.pop(\"ROUTER_URL\", None)\n810:             with pytest.raises(ValueError) as exc_info:\n811:                 AgentRuntimeClient(\n812:                     agent_name=\"test-agent\",\n813:                 )\n814: \n815:             assert \"router_url must be provided or ROUTER_URL env var must be set\" in str(\n816:                 exc_info.value\n817:             )\n818: \n819:     def test_bootstrap_session_id_missing_header_raises_value_error(self):\n820:         with patch(\n821:             \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n822:         ) as mock_dp_cls:\n823:             mock_dp_instance = MagicMock()\n824:             mock_dp_instance.bootstrap_session_id.side_effect = ValueError(\n825:                 \"Missing required response header: x-agentcube-session-id\"\n826:             )\n827:             mock_dp_cls.return_value = mock_dp_instance\n828: \n829:             with pytest.raises(ValueError) as exc_info:\n830:                 AgentRuntimeClient(\n831:                     agent_name=\"test-agent\",\n832:                     router_url=\"https://router.test.com\",\n833:                 )\n834: \n835:             assert \"Missing required response header: x-agentcube-session-id\" in str(\n836:                 exc_info.value\n837:             )\n\n(End of file - total 837 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentRuntimeDataPlaneClient and AgentRuntimeClient.\"\"\"\n\nimport os\nfrom un