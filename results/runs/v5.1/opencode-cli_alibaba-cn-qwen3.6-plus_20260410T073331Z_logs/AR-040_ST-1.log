{"type":"tool_use","timestamp":1775892263028,"sessionID":"ses_284933119ffe5HMvafcOzuBksc","part":{"id":"prt_d7b6d6c35001JuPnXa68xtqXQK","messageID":"msg_d7b6d5fe50018fzdJZLX55QagA","sessionID":"ses_284933119ffe5HMvafcOzuBksc","type":"tool","tool":"read","callID":"call_606ebbc5e5d14f74b21e611f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/conftest.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/conftest.py</path>\n<type>file</type>\n<content>\n1: import pytest\n2: \n3: \n4: @pytest.fixture\n5: def mock_requests_session(mocker):\n6:     \"\"\"Mock requests.Session to avoid real HTTP calls.\"\"\"\n7:     mock_session = mocker.patch(\"requests.Session\")\n8:     return mock_session\n9: \n10: \n11: @pytest.fixture\n12: def mock_create_session(mocker):\n13:     \"\"\"Mock the create_session utility.\"\"\"\n14:     return mocker.patch(\"agentcube.utils.http.create_session\")\n\n(End of file - total 14 lines)\n</content>","metadata":{"preview":"import pytest\n\n\n@pytest.fixture\ndef mock_requests_session(mocker):\n    \"\"\"Mock requests.Session to avoid real HTTP calls.\"\"\"\n    mock_session = mocker.patch(\"requests.Session\")\n    return mock_session\n\n\n@pytest.fixture\ndef mock_create_session(mocker):\n    \"\"\"Mock the create_session utility.\"\"\"\n    return mocker.patch(\"agentcube.utils.http.create_session\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/conftest.py","time":{"start":1775892263020,"end":1775892263027}}}}
{"type":"tool_use","timestamp":1775892264326,"sessionID":"ses_284933119ffe5HMvafcOzuBksc","part":{"id":"prt_d7b6d7145001bd7Nd0F57dVidS","messageID":"msg_d7b6d5fe50018fzdJZLX55QagA","sessionID":"ses_284933119ffe5HMvafcOzuBksc","type":"tool","tool":"read","callID":"call_cbc92769ae1a4c52ac7d7e78","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterClient.\"\"\"\n2: \n3: import os\n4: from unittest.mock import MagicMock, patch\n5: \n6: import pytest\n7: \n8: from agentcube.code_interpreter import CodeInterpreterClient\n9: from agentcube.exceptions import CommandExecutionError\n10: \n11: \n12: # ---------------------------------------------------------------------------\n13: # T-1: CodeInterpreterClient — Initialization\n14: # ---------------------------------------------------------------------------\n15: \n16: \n17: class TestCodeInterpreterClientInit:\n18:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n19:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n20:     def test_creates_session_when_no_session_id_provided(\n21:         self, mock_dp_cls, mock_cp_cls\n22:     ):\n23:         mock_cp_instance = MagicMock()\n24:         mock_cp_instance.create_session.return_value = \"new-session-id\"\n25:         mock_cp_cls.return_value = mock_cp_instance\n26: \n27:         mock_dp_instance = MagicMock()\n28:         mock_dp_cls.return_value = mock_dp_instance\n29: \n30:         client = CodeInterpreterClient(\n31:             name=\"my-interpreter\",\n32:             namespace=\"default\",\n33:             router_url=\"http://router:8080\",\n34:         )\n35: \n36:         mock_cp_instance.create_session.assert_called_once_with(\n37:             name=\"my-interpreter\",\n38:             namespace=\"default\",\n39:             ttl=3600,\n40:         )\n41:         assert client.session_id == \"new-session-id\"\n42:         mock_dp_cls.assert_called_once()\n43:         client.stop()\n44: \n45:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n46:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n47:     def test_reuses_session_id_when_provided(self, mock_dp_cls, mock_cp_cls):\n48:         mock_cp_instance = MagicMock()\n49:         mock_cp_cls.return_value = mock_cp_instance\n50: \n51:         mock_dp_instance = MagicMock()\n52:         mock_dp_cls.return_value = mock_dp_instance\n53: \n54:         client = CodeInterpreterClient(\n55:             session_id=\"existing-session\",\n56:             router_url=\"http://router:8080\",\n57:         )\n58: \n59:         mock_cp_instance.create_session.assert_not_called()\n60:         assert client.session_id == \"existing-session\"\n61:         client.stop()\n62: \n63:     def test_router_url_required_raises_value_error(self):\n64:         with patch.dict(os.environ, {}, clear=True):\n65:             os.environ.pop(\"ROUTER_URL\", None)\n66:             with pytest.raises(ValueError) as exc_info:\n67:                 CodeInterpreterClient(session_id=\"sess-1\")\n68:         assert \"router_url must be provided\" in str(exc_info.value)\n69: \n70:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n71:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n72:     def test_router_url_from_environment(self, mock_dp_cls, mock_cp_cls):\n73:         mock_cp_instance = MagicMock()\n74:         mock_cp_cls.return_value = mock_cp_instance\n75: \n76:         mock_dp_instance = MagicMock()\n77:         mock_dp_cls.return_value = mock_dp_instance\n78: \n79:         with patch.dict(os.environ, {\"ROUTER_URL\": \"http://env-router:8080\"}):\n80:             client = CodeInterpreterClient(session_id=\"sess-1\")\n81:             assert client.router_url == \"http://env-router:8080\"\n82:             client.stop()\n83: \n84:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n85:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n86:     def test_verbose_true_creates_debug_logger(self, mock_dp_cls, mock_cp_cls):\n87:         mock_cp_instance = MagicMock()\n88:         mock_cp_cls.return_value = mock_cp_instance\n89: \n90:         mock_dp_instance = MagicMock()\n91:         mock_dp_cls.return_value = mock_dp_instance\n92: \n93:         client = CodeInterpreterClient(\n94:             session_id=\"sess-1\",\n95:             router_url=\"http://router:8080\",\n96:             verbose=True,\n97:         )\n98: \n99:         assert client.logger.level == 10  # logging.DEBUG\n100:         client.stop()\n101: \n102:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n103:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n104:     def test_verbose_false_creates_info_logger(self, mock_dp_cls, mock_cp_cls):\n105:         mock_cp_instance = MagicMock()\n106:         mock_cp_cls.return_value = mock_cp_instance\n107: \n108:         mock_dp_instance = MagicMock()\n109:         mock_dp_cls.return_value = mock_dp_instance\n110: \n111:         client = CodeInterpreterClient(\n112:             session_id=\"sess-1\",\n113:             router_url=\"http://router:8080\",\n114:             verbose=False,\n115:         )\n116: \n117:         assert client.logger.level == 20  # logging.INFO\n118:         client.stop()\n119: \n120:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n121:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n122:     def test_control_plane_client_constructed_with_params(\n123:         self, mock_dp_cls, mock_cp_cls\n124:     ):\n125:         mock_cp_instance = MagicMock()\n126:         mock_cp_instance.create_session.return_value = \"sess-1\"\n127:         mock_cp_cls.return_value = mock_cp_instance\n128: \n129:         mock_dp_instance = MagicMock()\n130:         mock_dp_cls.return_value = mock_dp_instance\n131: \n132:         client = CodeInterpreterClient(\n133:             name=\"custom-name\",\n134:             namespace=\"custom-ns\",\n135:             ttl=7200,\n136:             workload_manager_url=\"http://wm:8080\",\n137:             router_url=\"http://router:8080\",\n138:             auth_token=\"my-token\",\n139:         )\n140: \n141:         mock_cp_cls.assert_called_once_with(\n142:             workload_manager_url=\"http://wm:8080\",\n143:             auth_token=\"my-token\",\n144:             timeout=120,\n145:             connect_timeout=5.0,\n146:         )\n147:         client.stop()\n148: \n149: \n150: # ---------------------------------------------------------------------------\n151: # T-2: CodeInterpreterClient — Data plane init failure cleanup\n152: # ---------------------------------------------------------------------------\n153: \n154: \n155: class TestDataPlaneInitFailure:\n156:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n157:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n158:     def test_data_plane_init_failure_deletes_session_and_reraises(\n159:         self, mock_dp_cls, mock_cp_cls\n160:     ):\n161:         mock_cp_instance = MagicMock()\n162:         mock_cp_instance.create_session.return_value = \"new-session\"\n163:         mock_cp_cls.return_value = mock_cp_instance\n164: \n165:         mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n166: \n167:         with pytest.raises(RuntimeError):\n168:             CodeInterpreterClient(\n169:                 name=\"my-interpreter\",\n170:                 router_url=\"http://router:8080\",\n171:             )\n172: \n173:         mock_cp_instance.delete_session.assert_called_once_with(\"new-session\")\n174: \n175:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n176:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n177:     def test_data_plane_init_failure_sets_session_id_to_none(\n178:         self, mock_dp_cls, mock_cp_cls\n179:     ):\n180:         mock_cp_instance = MagicMock()\n181:         mock_cp_instance.create_session.return_value = \"new-session\"\n182:         mock_cp_cls.return_value = mock_cp_instance\n183: \n184:         mock_dp_cls.side_effect = RuntimeError(\"data plane failed\")\n185: \n186:         try:\n187:             CodeInterpreterClient(\n188:                 name=\"my-interpreter\",\n189:                 router_url=\"http://router:8080\",\n190:             )\n191:         except RuntimeError:\n192:             pass\n193: \n194:         mock_cp_instance.create_session.return_value = None\n195:         assert mock_cp_instance.delete_session.called\n196: \n197: \n198: # ---------------------------------------------------------------------------\n199: # T-3: CodeInterpreterClient — Context manager\n200: # ---------------------------------------------------------------------------\n201: \n202: \n203: class TestContextManager:\n204:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n205:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n206:     def test_enter_returns_self(self, mock_dp_cls, mock_cp_cls):\n207:         mock_cp_instance = MagicMock()\n208:         mock_cp_cls.return_value = mock_cp_instance\n209: \n210:         mock_dp_instance = MagicMock()\n211:         mock_dp_cls.return_value = mock_dp_instance\n212: \n213:         client = CodeInterpreterClient(\n214:             session_id=\"sess-1\",\n215:             router_url=\"http://router:8080\",\n216:         )\n217: \n218:         assert client.__enter__() is client\n219:         client.stop()\n220: \n221:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n222:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n223:     def test_exit_calls_stop(self, mock_dp_cls, mock_cp_cls):\n224:         mock_cp_instance = MagicMock()\n225:         mock_cp_cls.return_value = mock_cp_instance\n226: \n227:         mock_dp_instance = MagicMock()\n228:         mock_dp_cls.return_value = mock_dp_instance\n229: \n230:         client = CodeInterpreterClient(\n231:             session_id=\"sess-1\",\n232:             router_url=\"http://router:8080\",\n233:         )\n234:         client.stop = MagicMock()\n235: \n236:         client.__exit__(None, None, None)\n237: \n238:         client.stop.assert_called_once()\n239: \n240:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n241:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n242:     def test_context_manager_with_statement(self, mock_dp_cls, mock_cp_cls):\n243:         mock_cp_instance = MagicMock()\n244:         mock_cp_instance.create_session.return_value = \"sess-ctx\"\n245:         mock_cp_cls.return_value = mock_cp_instance\n246: \n247:         mock_dp_instance = MagicMock()\n248:         mock_dp_cls.return_value = mock_dp_instance\n249: \n250:         with CodeInterpreterClient(\n251:             session_id=\"sess-ctx\",\n252:             router_url=\"http://router:8080\",\n253:         ) as client:\n254:             assert client.session_id == \"sess-ctx\"\n255: \n256:         mock_dp_instance.close.assert_called_once()\n257:         mock_cp_instance.delete_session.assert_called_once_with(\"sess-ctx\")\n258:         mock_cp_instance.close.assert_called_once()\n259: \n260:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n261:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n262:     def test_context_manager_exception_flow(self, mock_dp_cls, mock_cp_cls):\n263:         mock_cp_instance = MagicMock()\n264:         mock_cp_cls.return_value = mock_cp_instance\n265: \n266:         mock_dp_instance = MagicMock()\n267:         mock_dp_cls.return_value = mock_dp_instance\n268: \n269:         with pytest.raises(RuntimeError):\n270:             with CodeInterpreterClient(\n271:                 session_id=\"sess-ctx\",\n272:                 router_url=\"http://router:8080\",\n273:             ):\n274:                 raise RuntimeError(\"boom\")\n275: \n276:         mock_dp_instance.close.assert_called_once()\n277:         mock_cp_instance.delete_session.assert_called_once()\n278: \n279: \n280: # ---------------------------------------------------------------------------\n281: # T-4: CodeInterpreterClient — stop\n282: # ---------------------------------------------------------------------------\n283: \n284: \n285: class TestStop:\n286:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n287:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n288:     def stop_closes_dp_client(self, mock_dp_cls, mock_cp_cls):\n289:         mock_cp_instance = MagicMock()\n290:         mock_cp_cls.return_value = mock_cp_instance\n291: \n292:         mock_dp_instance = MagicMock()\n293:         mock_dp_cls.return_value = mock_dp_instance\n294: \n295:         client = CodeInterpreterClient(\n296:             session_id=\"sess-1\",\n297:             router_url=\"http://router:8080\",\n298:         )\n299:         client.stop()\n300: \n301:         mock_dp_instance.close.assert_called_once()\n302: \n303:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n304:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n305:     def stop_deletes_session(self, mock_dp_cls, mock_cp_cls):\n306:         mock_cp_instance = MagicMock()\n307:         mock_cp_cls.return_value = mock_cp_instance\n308: \n309:         mock_dp_instance = MagicMock()\n310:         mock_dp_cls.return_value = mock_dp_instance\n311: \n312:         client = CodeInterpreterClient(\n313:             session_id=\"sess-1\",\n314:             router_url=\"http://router:8080\",\n315:         )\n316:         client.stop()\n317: \n318:         mock_cp_instance.delete_session.assert_called_once_with(\"sess-1\")\n319: \n320:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n321:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n322:     def stop_closes_cp_client(self, mock_dp_cls, mock_cp_cls):\n323:         mock_cp_instance = MagicMock()\n324:         mock_cp_cls.return_value = mock_cp_instance\n325: \n326:         mock_dp_instance = MagicMock()\n327:         mock_dp_cls.return_value = mock_dp_instance\n328: \n329:         client = CodeInterpreterClient(\n330:             session_id=\"sess-1\",\n331:             router_url=\"http://router:8080\",\n332:         )\n333:         client.stop()\n334: \n335:         mock_cp_instance.close.assert_called_once()\n336: \n337:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n338:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n339:     def test_stop_is_idempotent(self, mock_dp_cls, mock_cp_cls):\n340:         mock_cp_instance = MagicMock()\n341:         mock_cp_cls.return_value = mock_cp_instance\n342: \n343:         mock_dp_instance = MagicMock()\n344:         mock_dp_cls.return_value = mock_dp_instance\n345: \n346:         client = CodeInterpreterClient(\n347:             session_id=\"sess-1\",\n348:             router_url=\"http://router:8080\",\n349:         )\n350:         client.stop()\n351:         client.stop()\n352:         client.stop()\n353: \n354:         assert mock_dp_instance.close.call_count == 1\n355:         assert mock_cp_instance.delete_session.call_count == 1\n356:         assert mock_cp_instance.close.call_count == 1\n357: \n358: \n359: # ---------------------------------------------------------------------------\n360: # T-5: CodeInterpreterClient — execute_command\n361: # ---------------------------------------------------------------------------\n362: \n363: \n364: class TestExecuteCommand:\n365:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n366:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n367:     def test_execute_command_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n368:         mock_cp_instance = MagicMock()\n369:         mock_cp_cls.return_value = mock_cp_instance\n370: \n371:         mock_dp_instance = MagicMock()\n372:         mock_dp_instance.execute_command.return_value = \"output\"\n373:         mock_dp_cls.return_value = mock_dp_instance\n374: \n375:         client = CodeInterpreterClient(\n376:             session_id=\"sess-1\",\n377:             router_url=\"http://router:8080\",\n378:         )\n379:         result = client.execute_command(\"echo hello\")\n380: \n381:         assert result == \"output\"\n382:         mock_dp_instance.execute_command.assert_called_once()\n383:         client.stop()\n384: \n385:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n386:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n387:     def test_execute_command_string_converted_to_list(self, mock_dp_cls, mock_cp_cls):\n388:         mock_cp_instance = MagicMock()\n389:         mock_cp_cls.return_value = mock_cp_instance\n390: \n391:         mock_dp_instance = MagicMock()\n392:         mock_dp_instance.execute_command.return_value = \"output\"\n393:         mock_dp_cls.return_value = mock_dp_instance\n394: \n395:         client = CodeInterpreterClient(\n396:             session_id=\"sess-1\",\n397:             router_url=\"http://router:8080\",\n398:         )\n399:         client.execute_command(\"echo hello\")\n400: \n401:         call_args = mock_dp_instance.execute_command.call_args\n402:         assert call_args[0][0] == [\"echo hello\"]\n403:         client.stop()\n404: \n405:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n406:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n407:     def test_execute_command_with_custom_timeout(self, mock_dp_cls, mock_cp_cls):\n408:         mock_cp_instance = MagicMock()\n409:         mock_cp_cls.return_value = mock_cp_instance\n410: \n411:         mock_dp_instance = MagicMock()\n412:         mock_dp_instance.execute_command.return_value = \"output\"\n413:         mock_dp_cls.return_value = mock_dp_instance\n414: \n415:         client = CodeInterpreterClient(\n416:             session_id=\"sess-1\",\n417:             router_url=\"http://router:8080\",\n418:         )\n419:         client.execute_command(\"sleep 10\", timeout=10.0)\n420: \n421:         call_args = mock_dp_instance.execute_command.call_args\n422:         assert call_args[1][\"timeout\"] == 12.0\n423:         client.stop()\n424: \n425:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n426:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n427:     def test_execute_command_raises_on_nonzero_exit(self, mock_dp_cls, mock_cp_cls):\n428:         mock_cp_instance = MagicMock()\n429:         mock_cp_cls.return_value = mock_cp_instance\n430: \n431:         mock_dp_instance = MagicMock()\n432:         mock_dp_instance.execute_command.side_effect = CommandExecutionError(\n433:             exit_code=1, stderr=\"error\", command=[\"ls\"]\n434:         )\n435:         mock_dp_cls.return_value = mock_dp_instance\n436: \n437:         client = CodeInterpreterClient(\n438:             session_id=\"sess-1\",\n439:             router_url=\"http://router:8080\",\n440:         )\n441: \n442:         with pytest.raises(CommandExecutionError) as exc_info:\n443:             client.execute_command(\"ls\")\n444: \n445:         assert exc_info.value.exit_code == 1\n446:         client.stop()\n447: \n448: \n449: # ---------------------------------------------------------------------------\n450: # T-6: CodeInterpreterClient — run_code\n451: # ---------------------------------------------------------------------------\n452: \n453: \n454: class TestRunCode:\n455:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n456:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n457:     def test_run_code_python_writes_file_and_executes(self, mock_dp_cls, mock_cp_cls):\n458:         mock_cp_instance = MagicMock()\n459:         mock_cp_cls.return_value = mock_cp_instance\n460: \n461:         mock_dp_instance = MagicMock()\n462:         mock_dp_instance.execute_command.return_value = \"hello\\n\"\n463:         mock_dp_cls.return_value = mock_dp_instance\n464: \n465:         client = CodeInterpreterClient(\n466:             session_id=\"sess-1\",\n467:             router_url=\"http://router:8080\",\n468:         )\n469:         result = client.run_code(\"python\", \"print('hello')\")\n470: \n471:         assert result == \"hello\\n\"\n472:         mock_dp_instance.write_file.assert_called_once()\n473:         mock_dp_instance.execute_command.assert_called_once()\n474:         client.stop()\n475: \n476:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n477:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n478:     def test_run_code_unsupported_language_raises(self, mock_dp_cls, mock_cp_cls):\n479:         mock_cp_instance = MagicMock()\n480:         mock_cp_cls.return_value = mock_cp_instance\n481: \n482:         mock_dp_instance = MagicMock()\n483:         mock_dp_cls.return_value = mock_dp_instance\n484: \n485:         client = CodeInterpreterClient(\n486:             session_id=\"sess-1\",\n487:             router_url=\"http://router:8080\",\n488:         )\n489: \n490:         with pytest.raises(ValueError) as exc_info:\n491:             client.run_code(\"ruby\", \"puts 'hi'\")\n492:         assert \"Unsupported language\" in str(exc_info.value)\n493:         client.stop()\n494: \n495: \n496: # ---------------------------------------------------------------------------\n497: # T-7: CodeInterpreterClient — File operations\n498: # ---------------------------------------------------------------------------\n499: \n500: \n501: class TestFileOperations:\n502:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n503:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n504:     def test_write_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n505:         mock_cp_instance = MagicMock()\n506:         mock_cp_cls.return_value = mock_cp_instance\n507: \n508:         mock_dp_instance = MagicMock()\n509:         mock_dp_cls.return_value = mock_dp_instance\n510: \n511:         client = CodeInterpreterClient(\n512:             session_id=\"sess-1\",\n513:             router_url=\"http://router:8080\",\n514:         )\n515:         client.write_file(\"content\", \"/tmp/test.txt\")\n516: \n517:         mock_dp_instance.write_file.assert_called_once_with(\"content\", \"/tmp/test.txt\")\n518:         client.stop()\n519: \n520:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n521:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n522:     def test_upload_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n523:         mock_cp_instance = MagicMock()\n524:         mock_cp_cls.return_value = mock_cp_instance\n525: \n526:         mock_dp_instance = MagicMock()\n527:         mock_dp_cls.return_value = mock_dp_instance\n528: \n529:         client = CodeInterpreterClient(\n530:             session_id=\"sess-1\",\n531:             router_url=\"http://router:8080\",\n532:         )\n533:         client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n534: \n535:         mock_dp_instance.upload_file.assert_called_once_with(\n536:             \"/local/file.txt\", \"/remote/file.txt\"\n537:         )\n538:         client.stop()\n539: \n540:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n541:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n542:     def test_download_file_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n543:         mock_cp_instance = MagicMock()\n544:         mock_cp_cls.return_value = mock_cp_instance\n545: \n546:         mock_dp_instance = MagicMock()\n547:         mock_dp_cls.return_value = mock_dp_instance\n548: \n549:         client = CodeInterpreterClient(\n550:             session_id=\"sess-1\",\n551:             router_url=\"http://router:8080\",\n552:         )\n553:         client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n554: \n555:         mock_dp_instance.download_file.assert_called_once_with(\n556:             \"/remote/file.txt\", \"/local/file.txt\"\n557:         )\n558:         client.stop()\n559: \n560:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n561:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n562:     def test_list_files_delegates_to_dp(self, mock_dp_cls, mock_cp_cls):\n563:         mock_cp_instance = MagicMock()\n564:         mock_cp_cls.return_value = mock_cp_instance\n565: \n566:         mock_dp_instance = MagicMock()\n567:         mock_dp_instance.list_files.return_value = {\"files\": [\"a.txt\"]}\n568:         mock_dp_cls.return_value = mock_dp_instance\n569: \n570:         client = CodeInterpreterClient(\n571:             session_id=\"sess-1\",\n572:             router_url=\"http://router:8080\",\n573:         )\n574:         result = client.list_files(\"/tmp\")\n575: \n576:         assert result == {\"files\": [\"a.txt\"]}\n577:         mock_dp_instance.list_files.assert_called_once_with(\"/tmp\")\n578:         client.stop()\n579: \n580: \n581: # ---------------------------------------------------------------------------\n582: # T-8: CodeInterpreterClient — Integration tests\n583: # ---------------------------------------------------------------------------\n584: \n585: \n586: class TestCodeInterpreterIntegration:\n587:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n588:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n589:     def test_full_lifecycle_with_context_manager(self, mock_dp_cls, mock_cp_cls):\n590:         mock_cp_instance = MagicMock()\n591:         mock_cp_instance.create_session.return_value = \"lifecycle-session\"\n592:         mock_cp_cls.return_value = mock_cp_instance\n593: \n594:         mock_dp_instance = MagicMock()\n595:         mock_dp_instance.execute_command.return_value = \"hello\"\n596:         mock_dp_cls.return_value = mock_dp_instance\n597: \n598:         with CodeInterpreterClient(\n599:             name=\"test-interpreter\",\n600:             namespace=\"test-ns\",\n601:             router_url=\"http://router.test.com\",\n602:         ) as client:\n603:             assert client.session_id == \"lifecycle-session\"\n604:             result = client.execute_command(\"echo hello\")\n605:             assert result == \"hello\"\n606: \n607:         mock_cp_instance.create_session.assert_called_once()\n608:         mock_dp_instance.execute_command.assert_called_once()\n609:         mock_dp_instance.close.assert_called_once()\n610:         mock_cp_instance.delete_session.assert_called_once_with(\"lifecycle-session\")\n611:         mock_cp_instance.close.assert_called_once()\n612: \n613:     @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n614:     @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n615:     def test_pre_provisioned_session_skips_control_plane(\n616:         self, mock_dp_cls, mock_cp_cls\n617:     ):\n618:         mock_cp_instance = MagicMock()\n619:         mock_cp_cls.return_value = mock_cp_instance\n620: \n621:         mock_dp_instance = MagicMock()\n622:         mock_dp_instance.execute_command.return_value = \"result\"\n623:         mock_dp_cls.return_value = mock_dp_instance\n624: \n625:         with CodeInterpreterClient(\n626:             session_id=\"pre-provisioned\",\n627:             router_url=\"http://router.test.com\",\n628:         ) as client:\n629:             assert client.session_id == \"pre-provisioned\"\n630:             result = client.execute_command(\"ls\")\n631:             assert result == \"result\"\n632: \n633:         mock_cp_instance.create_session.assert_not_called()\n634:         mock_dp_instance.execute_command.assert_called_once()\n635:         mock_dp_instance.close.assert_called_once()\n\n(End of file - total 635 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterClient.\"\"\"\n\nimport os\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\n# ---------------------------------------------------------------------------\n# T-1: CodeInterpreterClient — Initialization\n# ---------------------------------------------------------------------------\n\n\nclass TestCodeInterpreterClientInit:\n    @patch(\"agentcube.code_interpreter.ControlPlaneClient\")\n    @patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\")\n    def test_creates_session_when_no_session_id_provided(","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_code_interpreter.py","time":{"start":1775892264317,"end":1775892264324}}}}
{"type":"tool_use","timestamp":1775892265624,"sessionID":"ses_284933119ffe5HMvafcOzuBksc","part":{"id":"prt_d7b6d76560014RoEeM17xr7dsY","messageID":"msg_d7b6d5fe50018fzdJZLX55QagA","sessionID":"ses_284933119ffe5HMvafcOzuBksc","type":"tool","tool":"read","callID":"call_6bb20428415e43a1a180cccf","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_control_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_control_plane.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for ControlPlaneClient.\"\"\"\n2: \n3: import os\n4: import tempfile\n5: from unittest.mock import MagicMock, patch\n6: \n7: import pytest\n8: import requests\n9: \n10: from agentcube.clients.control_plane import ControlPlaneClient\n11: \n12: \n13: # ---------------------------------------------------------------------------\n14: # T-1: ControlPlaneClient — Constructor and URL resolution\n15: # ---------------------------------------------------------------------------\n16: \n17: \n18: class TestControlPlaneClientInit:\n19:     def test_base_url_from_argument(self):\n20:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n21:         assert client.base_url == \"http://wm:8080\"\n22:         client.close()\n23: \n24:     def test_base_url_from_environment(self):\n25:         with patch.dict(os.environ, {\"WORKLOAD_MANAGER_URL\": \"http://wm-env:9090\"}):\n26:             client = ControlPlaneClient()\n27:             assert client.base_url == \"http://wm-env:9090\"\n28:             client.close()\n29: \n30:     def test_raises_when_no_url_provided(self):\n31:         with patch.dict(os.environ, {}, clear=True):\n32:             os.environ.pop(\"WORKLOAD_MANAGER_URL\", None)\n33:             with pytest.raises(ValueError) as exc_info:\n34:                 ControlPlaneClient()\n35:         assert \"workload_manager_url must be provided\" in str(exc_info.value)\n36: \n37:     def test_auth_token_from_argument(self):\n38:         client = ControlPlaneClient(\n39:             workload_manager_url=\"http://wm:8080\",\n40:             auth_token=\"my-token\",\n41:         )\n42:         assert client.session.headers[\"Authorization\"] == \"Bearer my-token\"\n43:         client.close()\n44: \n45:     def test_auth_token_from_sa_file(self):\n46:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".token\") as f:\n47:             f.write(\"sa-token\\n\")\n48:             f.flush()\n49:             token_path = f.name\n50:         try:\n51:             with patch(\n52:                 \"agentcube.clients.control_plane.SA_TOKEN_PATH\", token_path\n53:             ):\n54:                 client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n55:                 assert client.session.headers[\"Authorization\"] == \"Bearer sa-token\"\n56:                 client.close()\n57:         finally:\n58:             os.unlink(token_path)\n59: \n60:     def test_auth_token_file_not_found_skips_header(self):\n61:         with patch(\"agentcube.clients.control_plane.read_token_from_file\", return_value=\"\"):\n62:             client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n63:             assert \"Authorization\" not in client.session.headers\n64:             client.close()\n65: \n66:     def test_empty_token_skips_authorization_header(self):\n67:         with patch(\"agentcube.clients.control_plane.read_token_from_file\", return_value=\"\"):\n68:             client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n69:             assert \"Authorization\" not in client.session.headers\n70:             client.close()\n71: \n72:     def test_default_content_type_header(self):\n73:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n74:         assert client.session.headers[\"Content-Type\"] == \"application/json\"\n75:         client.close()\n76: \n77:     def test_default_timeout_parameters(self):\n78:         client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n79:         assert client.timeout == 120\n80:         assert client.connect_timeout == 5.0\n81:         client.close()\n82: \n83:     def test_custom_timeout_parameters(self):\n84:         client = ControlPlaneClient(\n85:             workload_manager_url=\"http://wm:8080\",\n86:             timeout=60,\n87:             connect_timeout=3.0,\n88:         )\n89:         assert client.timeout == 60\n90:         assert client.connect_timeout == 3.0\n91:         client.close()\n92: \n93:     def test_custom_pool_settings(self):\n94:         from requests.adapters import HTTPAdapter\n95: \n96:         client = ControlPlaneClient(\n97:             workload_manager_url=\"http://wm:8080\",\n98:             pool_connections=20,\n99:             pool_maxsize=30,\n100:         )\n101:         adapter = client.session.adapters[\"http://\"]\n102:         assert isinstance(adapter, HTTPAdapter)\n103:         assert adapter._pool_connections == 20\n104:         assert adapter._pool_maxsize == 30\n105:         client.close()\n106: \n107: \n108: # ---------------------------------------------------------------------------\n109: # T-2: ControlPlaneClient — create_session\n110: # ---------------------------------------------------------------------------\n111: \n112: \n113: class TestCreateSession:\n114:     def test_successful_session_creation(self):\n115:         client = ControlPlaneClient(\n116:             workload_manager_url=\"http://wm:8080\",\n117:             auth_token=\"test-token\",\n118:         )\n119:         mock_resp = MagicMock(spec=requests.Response)\n120:         mock_resp.json.return_value = {\"data\": {\"sessionId\": \"abc-123\"}}\n121:         mock_resp.raise_for_status = MagicMock()\n122:         client.session.post = MagicMock(return_value=mock_resp)\n123: \n124:         result = client.create_session(\n125:             name=\"test\",\n126:             namespace=\"ns\",\n127:             ttl=7200,\n128:             metadata={\"key\": \"val\"},\n129:         )\n130: \n131:         client.session.post.assert_called_once()\n132:         call_args = client.session.post.call_args\n133:         assert call_args[0][0] == \"http://wm:8080/v1/code-interpreter\"\n134:         assert call_args[1][\"json\"] == {\n135:             \"name\": \"test\",\n136:             \"namespace\": \"ns\",\n137:             \"ttl\": 7200,\n138:             \"metadata\": {\"key\": \"val\"},\n139:         }\n140:         assert call_args[1][\"timeout\"] == (5.0, 120)\n141:         assert result == \"abc-123\"\n142:         client.close()\n143: \n144:     def test_response_contains_session_id(self):\n145:         client = ControlPlaneClient(\n146:             workload_manager_url=\"http://wm:8080\",\n147:             auth_token=\"test-token\",\n148:         )\n149:         mock_resp = MagicMock(spec=requests.Response)\n150:         mock_resp.json.return_value = {\"data\": {\"sessionId\": \"abc-123\"}}\n151:         mock_resp.raise_for_status = MagicMock()\n152:         client.session.post = MagicMock(return_value=mock_resp)\n153: \n154:         result = client.create_session()\n155:         assert result == \"abc-123\"\n156:         client.close()\n157: \n158:     def test_response_missing_session_id_raises_value_error(self):\n159:         client = ControlPlaneClient(\n160:             workload_manager_url=\"http://wm:8080\",\n161:             auth_token=\"test-token\",\n162:         )\n163:         mock_resp = MagicMock(spec=requests.Response)\n164:         mock_resp.json.return_value = {\"data\": {}}\n165:         mock_resp.raise_for_status = MagicMock()\n166:         client.session.post = MagicMock(return_value=mock_resp)\n167: \n168:         with pytest.raises(ValueError) as exc_info:\n169:             client.create_session()\n170:         assert \"sessionId\" in str(exc_info.value)\n171:         client.close()\n172: \n173:     def test_request_timeout_tuple(self):\n174:         client = ControlPlaneClient(\n175:             workload_manager_url=\"http://wm:8080\",\n176:             auth_token=\"test-token\",\n177:             timeout=120,\n178:             connect_timeout=5.0,\n179:         )\n180:         mock_resp = MagicMock(spec=requests.Response)\n181:         mock_resp.json.return_value = {\"data\": {\"sessionId\": \"sess-1\"}}\n182:         mock_resp.raise_for_status = MagicMock()\n183:         client.session.post = MagicMock(return_value=mock_resp)\n184: \n185:         client.create_session()\n186: \n187:         _, kwargs = client.session.post.call_args\n188:         assert kwargs[\"timeout\"] == (5.0, 120)\n189:         client.close()\n190: \n191:     def test_create_session_with_default_params(self):\n192:         client = ControlPlaneClient(\n193:             workload_manager_url=\"http://wm:8080\",\n194:             auth_token=\"test-token\",\n195:         )\n196:         mock_resp = MagicMock(spec=requests.Response)\n197:         mock_resp.json.return_value = {\"data\": {\"sessionId\": \"sess-1\"}}\n198:         mock_resp.raise_for_status = MagicMock()\n199:         client.session.post = MagicMock(return_value=mock_resp)\n200: \n201:         client.create_session()\n202: \n203:         call_args = client.session.post.call_args\n204:         assert call_args[1][\"json\"] == {\n205:             \"name\": \"my-interpreter\",\n206:             \"namespace\": \"default\",\n207:             \"ttl\": 3600,\n208:             \"metadata\": None,\n209:         }\n210:         client.close()\n211: \n212:     def test_create_session_raises_http_error_on_failure(self):\n213:         client = ControlPlaneClient(\n214:             workload_manager_url=\"http://wm:8080\",\n215:             auth_token=\"test-token\",\n216:         )\n217:         mock_resp = MagicMock(spec=requests.Response)\n218:         mock_resp.raise_for_status = MagicMock(\n219:             side_effect=requests.HTTPError(\"500 Server Error\")\n220:         )\n221:         client.session.post = MagicMock(return_value=mock_resp)\n222: \n223:         with pytest.raises(requests.HTTPError):\n224:             client.create_session()\n225:         client.close()\n226: \n227: \n228: # ---------------------------------------------------------------------------\n229: # T-3: ControlPlaneClient — delete_session\n230: # ---------------------------------------------------------------------------\n231: \n232: \n233: class TestDeleteSession:\n234:     def test_successful_deletion_returns_true(self):\n235:         client = ControlPlaneClient(\n236:             workload_manager_url=\"http://wm:8080\",\n237:             auth_token=\"test-token\",\n238:         )\n239:         mock_resp = MagicMock(spec=requests.Response)\n240:         mock_resp.status_code = 200\n241:         mock_resp.raise_for_status = MagicMock()\n242:         client.session.delete = MagicMock(return_value=mock_resp)\n243: \n244:         result = client.delete_session(\"sess-1\")\n245: \n246:         assert result is True\n247:         client.session.delete.assert_called_once_with(\n248:             \"http://wm:8080/v1/code-interpreter/sessions/sess-1\",\n249:             timeout=(5.0, 120),\n250:         )\n251:         client.close()\n252: \n253:     def test_404_treated_as_success(self):\n254:         client = ControlPlaneClient(\n255:             workload_manager_url=\"http://wm:8080\",\n256:             auth_token=\"test-token\",\n257:         )\n258:         mock_resp = MagicMock(spec=requests.Response)\n259:         mock_resp.status_code = 404\n260:         client.session.delete = MagicMock(return_value=mock_resp)\n261: \n262:         result = client.delete_session(\"nonexistent\")\n263: \n264:         assert result is True\n265:         client.close()\n266: \n267:     def test_other_error_returns_false(self):\n268:         client = ControlPlaneClient(\n269:             workload_manager_url=\"http://wm:8080\",\n270:             auth_token=\"test-token\",\n271:         )\n272:         client.session.delete = MagicMock(\n273:             side_effect=requests.HTTPError(\"500 Server Error\")\n274:         )\n275: \n276:         result = client.delete_session(\"sess-1\")\n277: \n278:         assert result is False\n279:         client.close()\n280: \n281:     def test_connection_error_returns_false(self):\n282:         client = ControlPlaneClient(\n283:             workload_manager_url=\"http://wm:8080\",\n284:             auth_token=\"test-token\",\n285:         )\n286:         client.session.delete = MagicMock(\n287:             side_effect=requests.ConnectionError(\"Connection refused\")\n288:         )\n289: \n290:         result = client.delete_session(\"sess-1\")\n291: \n292:         assert result is False\n293:         client.close()\n294: \n295:     def test_timeout_error_returns_false(self):\n296:         client = ControlPlaneClient(\n297:             workload_manager_url=\"http://wm:8080\",\n298:             auth_token=\"test-token\",\n299:         )\n300:         client.session.delete = MagicMock(\n301:             side_effect=requests.Timeout(\"Request timed out\")\n302:         )\n303: \n304:         result = client.delete_session(\"sess-1\")\n305: \n306:         assert result is False\n307:         client.close()\n308: \n309: \n310: # ---------------------------------------------------------------------------\n311: # T-4: ControlPlaneClient — close\n312: # ---------------------------------------------------------------------------\n313: \n314: \n315: class TestControlPlaneClose:\n316:     def test_close_releases_session(self):\n317:         client = ControlPlaneClient(\n318:             workload_manager_url=\"http://wm:8080\",\n319:             auth_token=\"test-token\",\n320:         )\n321:         client.session.close = MagicMock()\n322: \n323:         client.close()\n324: \n325:         client.session.close.assert_called_once()\n326: \n327:     def test_close_is_idempotent(self):\n328:         client = ControlPlaneClient(\n329:             workload_manager_url=\"http://wm:8080\",\n330:             auth_token=\"test-token\",\n331:         )\n332:         client.session.close = MagicMock()\n333: \n334:         client.close()\n335:         client.close()\n336:         client.close()\n337: \n338:         assert client.session.close.call_count == 3\n339: \n340: \n341: # ---------------------------------------------------------------------------\n342: # T-5: ControlPlaneClient — Session reuse\n343: # ---------------------------------------------------------------------------\n344: \n345: \n346: class TestSessionReuse:\n347:     def test_same_session_for_multiple_requests(self):\n348:         client = ControlPlaneClient(\n349:             workload_manager_url=\"http://wm:8080\",\n350:             auth_token=\"test-token\",\n351:         )\n352:         session_id = id(client.session)\n353: \n354:         mock_resp = MagicMock(spec=requests.Response)\n355:         mock_resp.json.return_value = {\"data\": {\"sessionId\": \"abc-123\"}}\n356:         mock_resp.raise_for_status = MagicMock()\n357:         client.session.post = MagicMock(return_value=mock_resp)\n358: \n359:         client.create_session()\n360:         assert id(client.session) == session_id\n361: \n362:         mock_resp_delete = MagicMock(spec=requests.Response)\n363:         mock_resp_delete.status_code = 200\n364:         mock_resp_delete.raise_for_status = MagicMock()\n365:         client.session.delete = MagicMock(return_value=mock_resp_delete)\n366: \n367:         client.delete_session(\"abc-123\")\n368:         assert id(client.session) == session_id\n369: \n370:         client.close()\n\n(End of file - total 370 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for ControlPlaneClient.\"\"\"\n\nimport os\nimport tempfile\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\nimport requests\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\n\n\n# ---------------------------------------------------------------------------\n# T-1: ControlPlaneClient — Constructor and URL resolution\n# ---------------------------------------------------------------------------\n\n\nclass TestControlPlaneClientInit:\n    def test_base_url_from_argument(self):\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_control_plane.py","time":{"start":1775892265615,"end":1775892265622}}}}
{"type":"tool_use","timestamp":1775892266924,"sessionID":"ses_284933119ffe5HMvafcOzuBksc","part":{"id":"prt_d7b6d7b1c0012Dc366smIttZkp","messageID":"msg_d7b6d5fe50018fzdJZLX55QagA","sessionID":"ses_284933119ffe5HMvafcOzuBksc","type":"tool","tool":"read","callID":"call_071e8999dd364d71947e97b7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_data_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_data_plane.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n2: \n3: import base64\n4: import json\n5: import os\n6: import tempfile\n7: from unittest.mock import MagicMock, mock_open, patch\n8: \n9: import pytest\n10: import requests\n11: from requests.adapters import HTTPAdapter\n12: \n13: from agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n14: from agentcube.exceptions import CommandExecutionError\n15: \n16: \n17: # ---------------------------------------------------------------------------\n18: # T-1: CodeInterpreterDataPlaneClient — Constructor and base URL\n19: # ---------------------------------------------------------------------------\n20: \n21: \n22: class TestDataPlaneClientInit:\n23:     def test_base_url_from_router_url(self):\n24:         client = CodeInterpreterDataPlaneClient(\n25:             session_id=\"sess-1\",\n26:             router_url=\"http://router:8080\",\n27:             namespace=\"ns\",\n28:             cr_name=\"my-interpreter\",\n29:         )\n30:         assert client.base_url == (\n31:             \"http://router:8080/v1/namespaces/ns/\"\n32:             \"code-interpreters/my-interpreter/invocations/\"\n33:         )\n34:         client.close()\n35: \n36:     def test_base_url_explicit_override(self):\n37:         client = CodeInterpreterDataPlaneClient(\n38:             session_id=\"sess-1\",\n39:             base_url=\"http://custom/url/\",\n40:         )\n41:         assert client.base_url == \"http://custom/url/\"\n42:         client.close()\n43: \n44:     def test_explicit_base_url_ignores_router_params(self):\n45:         client = CodeInterpreterDataPlaneClient(\n46:             session_id=\"sess-1\",\n47:             router_url=\"http://router:8080\",\n48:             namespace=\"ns\",\n49:             cr_name=\"my-interpreter\",\n50:             base_url=\"http://custom/url/\",\n51:         )\n52:         assert client.base_url == \"http://custom/url/\"\n53:         client.close()\n54: \n55:     def test_session_header_set(self):\n56:         client = CodeInterpreterDataPlaneClient(\n57:             session_id=\"sess-1\",\n58:             router_url=\"http://router:8080\",\n59:             namespace=\"ns\",\n60:             cr_name=\"my-interpreter\",\n61:         )\n62:         assert client.session.headers[\"x-agentcube-session-id\"] == \"sess-1\"\n63:         client.close()\n64: \n65:     def test_default_timeouts(self):\n66:         client = CodeInterpreterDataPlaneClient(\n67:             session_id=\"sess-1\",\n68:             router_url=\"http://router:8080\",\n69:             namespace=\"ns\",\n70:             cr_name=\"my-interpreter\",\n71:         )\n72:         assert client.timeout == 120\n73:         assert client.connect_timeout == 5.0\n74:         client.close()\n75: \n76:     def test_custom_timeouts(self):\n77:         client = CodeInterpreterDataPlaneClient(\n78:             session_id=\"sess-1\",\n79:             router_url=\"http://router:8080\",\n80:             namespace=\"ns\",\n81:             cr_name=\"my-interpreter\",\n82:             timeout=60,\n83:             connect_timeout=3.0,\n84:         )\n85:         assert client.timeout == 60\n86:         assert client.connect_timeout == 3.0\n87:         client.close()\n88: \n89:     def test_custom_pool_settings(self):\n90:         client = CodeInterpreterDataPlaneClient(\n91:             session_id=\"sess-1\",\n92:             router_url=\"http://router:8080\",\n93:             namespace=\"ns\",\n94:             cr_name=\"my-interpreter\",\n95:             pool_connections=20,\n96:             pool_maxsize=30,\n97:         )\n98:         adapter = client.session.adapters[\"http://\"]\n99:         assert adapter._pool_connections == 20\n100:         assert adapter._pool_maxsize == 30\n101:         client.close()\n102: \n103:     def test_independent_sessions_across_clients(self):\n104:         client1 = CodeInterpreterDataPlaneClient(\n105:             session_id=\"sess-1\",\n106:             router_url=\"http://router:8080\",\n107:             namespace=\"ns\",\n108:             cr_name=\"my-interpreter\",\n109:         )\n110:         client2 = CodeInterpreterDataPlaneClient(\n111:             session_id=\"sess-2\",\n112:             router_url=\"http://router:8080\",\n113:             namespace=\"ns\",\n114:             cr_name=\"my-interpreter\",\n115:         )\n116:         assert client1.session is not client2.session\n117:         client1.close()\n118:         client2.close()\n119: \n120: \n121: # ---------------------------------------------------------------------------\n122: # T-2: CodeInterpreterDataPlaneClient — _request\n123: # ---------------------------------------------------------------------------\n124: \n125: \n126: class TestRequest:\n127:     def test_json_body_request_sets_content_type(self):\n128:         client = CodeInterpreterDataPlaneClient(\n129:             session_id=\"sess-1\",\n130:             base_url=\"http://base/\",\n131:         )\n132:         mock_resp = MagicMock(spec=requests.Response)\n133:         mock_resp.raise_for_status = MagicMock()\n134:         client.session.request = MagicMock(return_value=mock_resp)\n135: \n136:         client._request(\"POST\", \"api/execute\", body=b'{\"cmd\": \"ls\"}')\n137: \n138:         client.session.request.assert_called_once()\n139:         _, kwargs = client.session.request.call_args\n140:         assert kwargs[\"headers\"][\"Content-Type\"] == \"application/json\"\n141:         assert kwargs[\"data\"] == b'{\"cmd\": \"ls\"}'\n142:         client.close()\n143: \n144:     def test_request_without_body_no_content_type_override(self):\n145:         client = CodeInterpreterDataPlaneClient(\n146:             session_id=\"sess-1\",\n147:             base_url=\"http://base/\",\n148:         )\n149:         mock_resp = MagicMock(spec=requests.Response)\n150:         mock_resp.raise_for_status = MagicMock()\n151:         client.session.request = MagicMock(return_value=mock_resp)\n152: \n153:         client._request(\"GET\", \"api/files\")\n154: \n155:         _, kwargs = client.session.request.call_args\n156:         assert \"Content-Type\" not in kwargs.get(\"headers\", {})\n157:         client.close()\n158: \n159:     def test_request_url_construction(self):\n160:         client = CodeInterpreterDataPlaneClient(\n161:             session_id=\"sess-1\",\n162:             base_url=\"http://base/\",\n163:         )\n164:         mock_resp = MagicMock(spec=requests.Response)\n165:         mock_resp.raise_for_status = MagicMock()\n166:         client.session.request = MagicMock(return_value=mock_resp)\n167: \n168:         client._request(\"GET\", \"api/files\")\n169: \n170:         _, kwargs = client.session.request.call_args\n171:         assert kwargs[\"url\"] == \"http://base/api/files\"\n172:         client.close()\n173: \n174:     def test_request_with_query_params(self):\n175:         client = CodeInterpreterDataPlaneClient(\n176:             session_id=\"sess-1\",\n177:             base_url=\"http://base/\",\n178:         )\n179:         mock_resp = MagicMock(spec=requests.Response)\n180:         mock_resp.raise_for_status = MagicMock()\n181:         client.session.request = MagicMock(return_value=mock_resp)\n182: \n183:         client._request(\"GET\", \"api/files\", params={\"path\": \"/tmp\"})\n184: \n185:         _, kwargs = client.session.request.call_args\n186:         assert kwargs[\"params\"] == {\"path\": \"/tmp\"}\n187:         client.close()\n188: \n189:     def test_request_raises_on_http_error(self):\n190:         client = CodeInterpreterDataPlaneClient(\n191:             session_id=\"sess-1\",\n192:             base_url=\"http://base/\",\n193:         )\n194:         mock_resp = MagicMock(spec=requests.Response)\n195:         mock_resp.raise_for_status = MagicMock(\n196:             side_effect=requests.HTTPError(\"500 Error\")\n197:         )\n198:         client.session.request = MagicMock(return_value=mock_resp)\n199: \n200:         with pytest.raises(requests.HTTPError):\n201:             client._request(\"GET\", \"api/files\")\n202:         client.close()\n203: \n204: \n205: # ---------------------------------------------------------------------------\n206: # T-3: CodeInterpreterDataPlaneClient — execute_command\n207: # ---------------------------------------------------------------------------\n208: \n209: \n210: class TestExecuteCommand:\n211:     def test_command_with_explicit_timeout(self):\n212:         client = CodeInterpreterDataPlaneClient(\n213:             session_id=\"sess-1\",\n214:             base_url=\"http://base/\",\n215:         )\n216:         mock_resp = MagicMock(spec=requests.Response)\n217:         mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"done\", \"stderr\": \"\"}\n218:         mock_resp.raise_for_status = MagicMock()\n219:         client.session.request = MagicMock(return_value=mock_resp)\n220: \n221:         result = client.execute_command(\"sleep 10\", timeout=10.0)\n222: \n223:         assert result == \"done\"\n224:         _, kwargs = client.session.request.call_args\n225:         assert kwargs[\"timeout\"] == (5.0, 12.0)\n226:         body = json.loads(kwargs[\"data\"])\n227:         assert body[\"command\"] == [\"sleep\", \"10\"]\n228:         assert body[\"timeout\"] == \"10s\"\n229:         client.close()\n230: \n231:     def test_command_with_default_timeout(self):\n232:         client = CodeInterpreterDataPlaneClient(\n233:             session_id=\"sess-1\",\n234:             base_url=\"http://base/\",\n235:             timeout=120,\n236:         )\n237:         mock_resp = MagicMock(spec=requests.Response)\n238:         mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"ok\", \"stderr\": \"\"}\n239:         mock_resp.raise_for_status = MagicMock()\n240:         client.session.request = MagicMock(return_value=mock_resp)\n241: \n242:         result = client.execute_command(\"ls\", timeout=None)\n243: \n244:         assert result == \"ok\"\n245:         _, kwargs = client.session.request.call_args\n246:         body = json.loads(kwargs[\"data\"])\n247:         assert body[\"timeout\"] == \"120s\"\n248:         assert kwargs[\"timeout\"] == (5.0, 122.0)\n249:         client.close()\n250: \n251:     def test_command_string_split_by_whitespace(self):\n252:         client = CodeInterpreterDataPlaneClient(\n253:             session_id=\"sess-1\",\n254:             base_url=\"http://base/\",\n255:         )\n256:         mock_resp = MagicMock(spec=requests.Response)\n257:         mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"\", \"stderr\": \"\"}\n258:         mock_resp.raise_for_status = MagicMock()\n259:         client.session.request = MagicMock(return_value=mock_resp)\n260: \n261:         client.execute_command(\"ls -la\")\n262: \n263:         _, kwargs = client.session.request.call_args\n264:         body = json.loads(kwargs[\"data\"])\n265:         assert body[\"command\"] == [\"ls\", \"-la\"]\n266:         client.close()\n267: \n268:     def test_command_list_passed_as_is(self):\n269:         client = CodeInterpreterDataPlaneClient(\n270:             session_id=\"sess-1\",\n271:             base_url=\"http://base/\",\n272:         )\n273:         mock_resp = MagicMock(spec=requests.Response)\n274:         mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"\", \"stderr\": \"\"}\n275:         mock_resp.raise_for_status = MagicMock()\n276:         client.session.request = MagicMock(return_value=mock_resp)\n277: \n278:         client.execute_command([\"ls\", \"-la\", \"/tmp\"])\n279: \n280:         _, kwargs = client.session.request.call_args\n281:         body = json.loads(kwargs[\"data\"])\n282:         assert body[\"command\"] == [\"ls\", \"-la\", \"/tmp\"]\n283:         client.close()\n284: \n285:     def test_nonzero_exit_code_raises_error(self):\n286:         client = CodeInterpreterDataPlaneClient(\n287:             session_id=\"sess-1\",\n288:             base_url=\"http://base/\",\n289:         )\n290:         mock_resp = MagicMock(spec=requests.Response)\n291:         mock_resp.json.return_value = {\n292:             \"exit_code\": 1,\n293:             \"stderr\": \"error occurred\",\n294:             \"stdout\": \"\",\n295:         }\n296:         mock_resp.raise_for_status = MagicMock()\n297:         client.session.request = MagicMock(return_value=mock_resp)\n298: \n299:         with pytest.raises(CommandExecutionError) as exc_info:\n300:             client.execute_command(\"ls\")\n301: \n302:         assert exc_info.value.exit_code == 1\n303:         assert exc_info.value.stderr == \"error occurred\"\n304:         assert exc_info.value.command == [\"ls\"]\n305:         client.close()\n306: \n307:     def test_timeout_buffer_logic(self):\n308:         client = CodeInterpreterDataPlaneClient(\n309:             session_id=\"sess-1\",\n310:             base_url=\"http://base/\",\n311:             timeout=60,\n312:             connect_timeout=3.0,\n313:         )\n314:         mock_resp = MagicMock(spec=requests.Response)\n315:         mock_resp.json.return_value = {\"exit_code\": 0, \"stdout\": \"\", \"stderr\": \"\"}\n316:         mock_resp.raise_for_status = MagicMock()\n317:         client.session.request = MagicMock(return_value=mock_resp)\n318: \n319:         client.execute_command(\"sleep 30\", timeout=30.0)\n320: \n321:         _, kwargs = client.session.request.call_args\n322:         assert kwargs[\"timeout\"] == (3.0, 32.0)\n323:         client.close()\n324: \n325: \n326: # ---------------------------------------------------------------------------\n327: # T-4: CodeInterpreterDataPlaneClient — run_code\n328: # ---------------------------------------------------------------------------\n329: \n330: \n331: class TestRunCode:\n332:     def test_python_code_execution(self):\n333:         client = CodeInterpreterDataPlaneClient(\n334:             session_id=\"sess-1\",\n335:             base_url=\"http://base/\",\n336:         )\n337:         client.write_file = MagicMock()\n338:         client.execute_command = MagicMock(return_value=\"hello\\n\")\n339: \n340:         result = client.run_code(\"python\", \"print('hi')\")\n341: \n342:         assert result == \"hello\\n\"\n343:         client.write_file.assert_called_once()\n344:         write_call = client.write_file.call_args\n345:         assert write_call[0][0] == \"print('hi')\"\n346:         assert write_call[0][1].endswith(\".py\")\n347:         client.execute_command.assert_called_once()\n348:         exec_call = client.execute_command.call_args\n349:         assert exec_call[0][0].startswith(\"python3 /tmp/code_\")\n350:         client.close()\n351: \n352:     def test_language_alias_py(self):\n353:         client = CodeInterpreterDataPlaneClient(\n354:             session_id=\"sess-1\",\n355:             base_url=\"http://base/\",\n356:         )\n357:         client.write_file = MagicMock()\n358:         client.execute_command = MagicMock(return_value=\"ok\")\n359: \n360:         client.run_code(\"py\", \"print(1)\")\n361: \n362:         client.write_file.assert_called_once()\n363:         client.close()\n364: \n365:     def test_language_alias_python3(self):\n366:         client = CodeInterpreterDataPlaneClient(\n367:             session_id=\"sess-1\",\n368:             base_url=\"http://base/\",\n369:         )\n370:         client.write_file = MagicMock()\n371:         client.execute_command = MagicMock(return_value=\"ok\")\n372: \n373:         client.run_code(\"python3\", \"print(1)\")\n374: \n375:         client.write_file.assert_called_once()\n376:         client.close()\n377: \n378:     def test_unsupported_language_raises_value_error(self):\n379:         client = CodeInterpreterDataPlaneClient(\n380:             session_id=\"sess-1\",\n381:             base_url=\"http://base/\",\n382:         )\n383: \n384:         with pytest.raises(ValueError) as exc_info:\n385:             client.run_code(\"ruby\", \"puts 'hi'\")\n386:         assert \"Unsupported language\" in str(exc_info.value)\n387:         client.close()\n388: \n389:     def test_run_code_passes_timeout(self):\n390:         client = CodeInterpreterDataPlaneClient(\n391:             session_id=\"sess-1\",\n392:             base_url=\"http://base/\",\n393:         )\n394:         client.write_file = MagicMock()\n395:         client.execute_command = MagicMock(return_value=\"ok\")\n396: \n397:         client.run_code(\"python\", \"print(1)\", timeout=30.0)\n398: \n399:         client.execute_command.assert_called_once()\n400:         _, kwargs = client.execute_command.call_args\n401:         assert kwargs[\"timeout\"] == 30.0\n402:         client.close()\n403: \n404: \n405: # ---------------------------------------------------------------------------\n406: # T-5: CodeInterpreterDataPlaneClient — write_file\n407: # ---------------------------------------------------------------------------\n408: \n409: \n410: class TestWriteFile:\n411:     def test_write_file_base64_encoding(self):\n412:         client = CodeInterpreterDataPlaneClient(\n413:             session_id=\"sess-1\",\n414:             base_url=\"http://base/\",\n415:         )\n416:         mock_resp = MagicMock(spec=requests.Response)\n417:         mock_resp.raise_for_status = MagicMock()\n418:         client.session.request = MagicMock(return_value=mock_resp)\n419: \n420:         client.write_file(\"hello\", \"/tmp/test.txt\")\n421: \n422:         _, kwargs = client.session.request.call_args\n423:         body = json.loads(kwargs[\"data\"])\n424:         assert body[\"path\"] == \"/tmp/test.txt\"\n425:         assert body[\"mode\"] == \"0644\"\n426:         assert body[\"content\"] == base64.b64encode(b\"hello\").decode(\"utf-8\")\n427:         client.close()\n428: \n429:     def test_write_file_empty_content(self):\n430:         client = CodeInterpreterDataPlaneClient(\n431:             session_id=\"sess-1\",\n432:             base_url=\"http://base/\",\n433:         )\n434:         mock_resp = MagicMock(spec=requests.Response)\n435:         mock_resp.raise_for_status = MagicMock()\n436:         client.session.request = MagicMock(return_value=mock_resp)\n437: \n438:         client.write_file(\"\", \"/tmp/empty.txt\")\n439: \n440:         _, kwargs = client.session.request.call_args\n441:         body = json.loads(kwargs[\"data\"])\n442:         assert body[\"content\"] == \"\"\n443:         client.close()\n444: \n445: \n446: # ---------------------------------------------------------------------------\n447: # T-6: CodeInterpreterDataPlaneClient — upload_file\n448: # ---------------------------------------------------------------------------\n449: \n450: \n451: class TestUploadFile:\n452:     def test_multipart_upload_with_session_header(self):\n453:         client = CodeInterpreterDataPlaneClient(\n454:             session_id=\"sess-1\",\n455:             base_url=\"http://base/\",\n456:         )\n457:         mock_resp = MagicMock(spec=requests.Response)\n458:         mock_resp.raise_for_status = MagicMock()\n459:         client.session.post = MagicMock(return_value=mock_resp)\n460: \n461:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".txt\") as f:\n462:             f.write(\"test content\")\n463:             f.flush()\n464:             local_path = f.name\n465: \n466:         try:\n467:             client.upload_file(local_path, \"/remote/path.txt\")\n468: \n469:             client.session.post.assert_called_once()\n470:             _, kwargs = client.session.post.call_args\n471:             assert kwargs[\"data\"][\"path\"] == \"/remote/path.txt\"\n472:             assert kwargs[\"data\"][\"mode\"] == \"0644\"\n473:             assert kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"sess-1\"\n474:         finally:\n475:             os.unlink(local_path)\n476:         client.close()\n477: \n478:     def test_upload_file_url_construction(self):\n479:         client = CodeInterpreterDataPlaneClient(\n480:             session_id=\"sess-1\",\n481:             base_url=\"http://base/\",\n482:         )\n483:         mock_resp = MagicMock(spec=requests.Response)\n484:         mock_resp.raise_for_status = MagicMock()\n485:         client.session.post = MagicMock(return_value=mock_resp)\n486: \n487:         with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".txt\") as f:\n488:             f.write(\"content\")\n489:             f.flush()\n490:             local_path = f.name\n491: \n492:         try:\n493:             client.upload_file(local_path, \"/remote/file.txt\")\n494: \n495:             call_args = client.session.post.call_args\n496:             assert call_args[0][0] == \"http://base/api/files\"\n497:         finally:\n498:             os.unlink(local_path)\n499:         client.close()\n500: \n501: \n502: # ---------------------------------------------------------------------------\n503: # T-7: CodeInterpreterDataPlaneClient — download_file\n504: # ---------------------------------------------------------------------------\n505: \n506: \n507: class TestDownloadFile:\n508:     def test_streaming_download(self):\n509:         client = CodeInterpreterDataPlaneClient(\n510:             session_id=\"sess-1\",\n511:             base_url=\"http://base/\",\n512:         )\n513:         mock_resp = MagicMock(spec=requests.Response)\n514:         mock_resp.raise_for_status = MagicMock()\n515:         mock_resp.iter_content.return_value = [b\"chunk1\", b\"chunk2\"]\n516:         client.session.get = MagicMock(return_value=mock_resp)\n517: \n518:         with tempfile.NamedTemporaryFile(delete=False, suffix=\".txt\") as f:\n519:             local_path = f.name\n520: \n521:         try:\n522:             client.download_file(\"/remote/path.txt\", local_path)\n523: \n524:             client.session.get.assert_called_once_with(\n525:                 \"http://base/api/files/remote/path.txt\",\n526:                 stream=True,\n527:                 timeout=(5.0, 120),\n528:             )\n529:             with open(local_path, \"rb\") as f:\n530:                 assert f.read() == b\"chunk1chunk2\"\n531:         finally:\n532:             os.unlink(local_path)\n533:         client.close()\n534: \n535:     def test_clean_path_strips_leading_slash(self):\n536:         client = CodeInterpreterDataPlaneClient(\n537:             session_id=\"sess-1\",\n538:             base_url=\"http://base/\",\n539:         )\n540:         mock_resp = MagicMock(spec=requests.Response)\n541:         mock_resp.raise_for_status = MagicMock()\n542:         mock_resp.iter_content.return_value = [b\"data\"]\n543:         client.session.get = MagicMock(return_value=mock_resp)\n544: \n545:         with tempfile.NamedTemporaryFile(delete=False) as f:\n546:             local_path = f.name\n547: \n548:         try:\n549:             client.download_file(\"/absolute/path.txt\", local_path)\n550: \n551:             call_args = client.session.get.call_args\n552:             assert call_args[0][0] == \"http://base/api/files/absolute/path.txt\"\n553:         finally:\n554:             os.unlink(local_path)\n555:         client.close()\n556: \n557:     def test_download_raises_on_http_error(self):\n558:         client = CodeInterpreterDataPlaneClient(\n559:             session_id=\"sess-1\",\n560:             base_url=\"http://base/\",\n561:         )\n562:         mock_resp = MagicMock(spec=requests.Response)\n563:         mock_resp.raise_for_status = MagicMock(\n564:             side_effect=requests.HTTPError(\"404 Not Found\")\n565:         )\n566:         client.session.get = MagicMock(return_value=mock_resp)\n567: \n568:         with pytest.raises(requests.HTTPError):\n569:             client.download_file(\"/nonexistent.txt\", \"/tmp/out.txt\")\n570:         client.close()\n571: \n572: \n573: # ---------------------------------------------------------------------------\n574: # T-8: CodeInterpreterDataPlaneClient — list_files\n575: # ---------------------------------------------------------------------------\n576: \n577: \n578: class TestListFiles:\n579:     def test_list_files_with_path(self):\n580:         client = CodeInterpreterDataPlaneClient(\n581:             session_id=\"sess-1\",\n582:             base_url=\"http://base/\",\n583:         )\n584:         mock_resp = MagicMock(spec=requests.Response)\n585:         mock_resp.json.return_value = {\"files\": [\"a.txt\", \"b.txt\"]}\n586:         mock_resp.raise_for_status = MagicMock()\n587:         client.session.request = MagicMock(return_value=mock_resp)\n588: \n589:         result = client.list_files(\"/some/path\")\n590: \n591:         assert result == {\"files\": [\"a.txt\", \"b.txt\"]}\n592:         _, kwargs = client.session.request.call_args\n593:         assert kwargs[\"params\"] == {\"path\": \"/some/path\"}\n594:         client.close()\n595: \n596:     def test_list_files_default_path(self):\n597:         client = CodeInterpreterDataPlaneClient(\n598:             session_id=\"sess-1\",\n599:             base_url=\"http://base/\",\n600:         )\n601:         mock_resp = MagicMock(spec=requests.Response)\n602:         mock_resp.json.return_value = {\"files\": [\"file1\"]}\n603:         mock_resp.raise_for_status = MagicMock()\n604:         client.session.request = MagicMock(return_value=mock_resp)\n605: \n606:         client.list_files()\n607: \n608:         _, kwargs = client.session.request.call_args\n609:         assert kwargs[\"params\"] == {\"path\": \".\"}\n610:         client.close()\n611: \n612: \n613: # ---------------------------------------------------------------------------\n614: # T-9: CodeInterpreterDataPlaneClient — close\n615: # ---------------------------------------------------------------------------\n616: \n617: \n618: class TestDataPlaneClose:\n619:     def test_close_releases_session(self):\n620:         client = CodeInterpreterDataPlaneClient(\n621:             session_id=\"sess-1\",\n622:             base_url=\"http://base/\",\n623:         )\n624:         client.session.close = MagicMock()\n625: \n626:         client.close()\n627: \n628:         client.session.close.assert_called_once()\n629: \n630:     def test_close_is_idempotent(self):\n631:         client = CodeInterpreterDataPlaneClient(\n632:             session_id=\"sess-1\",\n633:             base_url=\"http://base/\",\n634:         )\n635:         client.session.close = MagicMock()\n636: \n637:         client.close()\n638:         client.close()\n639:         client.close()\n640: \n641:         assert client.session.close.call_count == 3\n\n(End of file - total 641 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nimport base64\nimport json\nimport os\nimport tempfile\nfrom unittest.mock import MagicMock, mock_open, patch\n\nimport pytest\nimport requests\nfrom requests.adapters import HTTPAdapter\n\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\n# ---------------------------------------------------------------------------\n# T-1: CodeInterpreterDataPlaneClient — Constructor and base URL\n# ---------------------------------------------------------------------------\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_data_plane.py","time":{"start":1775892266910,"end":1775892266922}}}}
