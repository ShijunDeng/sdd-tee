= logging.DEBUG\n90: \n91:     def test_can_set_level_by_int(self):\n92:         logger = get_logger(\"test_logger_int\", level=logging.WARNING)\n93:         assert logger.level == logging.WARNING\n\n(End of file - total 93 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for utility helpers.\"\"\"\n\nimport logging\nimport os\nimport tempfile\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.log import get_logger\nfrom agentcube.utils.utils import read_token_from_file\n\n\nclass TestCreateSession:\n    def test_returns_requests_session(self):\n        import requests\n\n        session = create_session()\n        assert isinstance(session, requests.Session)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/python-sdk/tests/test_utils.py","time":{"start":1775892276234,"end":1775892276241}}}}
