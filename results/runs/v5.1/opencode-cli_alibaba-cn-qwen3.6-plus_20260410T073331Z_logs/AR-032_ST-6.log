e/go-build \\\n    CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \\\n    go build -ldflags=\"-s -w\" -o /agentcube-router ./cmd/router","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/docker/Dockerfile.router","time":{"start":1775876337946,"end":1775876337952}}}}
