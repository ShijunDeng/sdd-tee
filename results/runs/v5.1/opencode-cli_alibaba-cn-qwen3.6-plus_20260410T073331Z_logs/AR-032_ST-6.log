{"type":"tool_use","timestamp":1775876346992,"sessionID":"ses_28587bf52ffeiNWO6CVse3Bq5j","part":{"id":"prt_d7a7a90c9001LUcTZHVsQQn5kL","messageID":"msg_d7a7a7b3e0019WvcweV6LS3IbI","sessionID":"ses_28587bf52ffeiNWO6CVse3Bq5j","type":"tool","tool":"read","callID":"call_c405988b5bc84b249a3696fd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/services/test_docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/services/test_docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for DockerService.\"\"\"\n2: \n3: from pathlib import Path\n4: from unittest.mock import MagicMock, patch\n5: \n6: import pytest\n7: \n8: from agentcube.services.docker_service import DockerService\n9: \n10: \n11: class TestDockerServiceCheckDockerAvailableRunning:\n12:     def test_docker_running_returns_true(self) -> None:\n13:         mock_client = MagicMock()\n14:         mock_client.ping.return_value = True\n15:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n16:             service = DockerService()\n17:             assert service.check_docker_available() is True\n18: \n19: \n20: class TestDockerServiceCheckDockerAvailableNotRunning:\n21:     def test_docker_not_running_returns_false(self) -> None:\n22:         with patch(\"agentcube.services.docker_service.docker.from_env\", side_effect=Exception(\"Cannot connect\")):\n23:             service = DockerService()\n24:             assert service.check_docker_available() is False\n25: \n26:     def test_docker_ping_raises_returns_false(self) -> None:\n27:         mock_client = MagicMock()\n28:         mock_client.ping.side_effect = Exception(\"Daemon not running\")\n29:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n30:             service = DockerService()\n31:             assert service.check_docker_available() is False\n32: \n33: \n34: class TestDockerServiceBuildImageSuccess:\n35:     def test_build_image_returns_correct_dict(self) -> None:\n36:         mock_image = MagicMock()\n37:         mock_image.id = \"sha256:abc123def456\"\n38:         mock_image.short_id = \"sha256:abc123\"\n39: \n40:         mock_image_info = MagicMock()\n41:         mock_image_info.attrs = {\"Size\": 52428800}\n42: \n43:         mock_client = MagicMock()\n44:         mock_client.images.build.return_value = (mock_image, [])\n45:         mock_client.images.get.return_value = mock_image_info\n46: \n47:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n48:             service = DockerService()\n49:             result = service.build_image(\n50:                 dockerfile_path=Path(\"/tmp/Dockerfile\"),\n51:                 context_path=Path(\"/tmp\"),\n52:                 image_name=\"test-agent\",\n53:                 tag=\"1.0.0\",\n54:             )\n55: \n56:         assert result[\"image_name\"] == \"test-agent\"\n57:         assert result[\"image_id\"] == \"sha256:abc123\"\n58:         assert result[\"image_size\"] == \"50.0 MB\"\n59:         assert result[\"build_time\"].endswith(\"s\")\n60: \n61: \n62: class TestDockerServiceBuildImageWithProxy:\n63:     def test_build_image_passes_proxy_buildargs(self) -> None:\n64:         mock_image = MagicMock()\n65:         mock_image.id = \"sha256:abc123\"\n66:         mock_image.short_id = \"sha256:abc\"\n67: \n68:         mock_image_info = MagicMock()\n69:         mock_image_info.attrs = {\"Size\": 0}\n70: \n71:         mock_client = MagicMock()\n72:         mock_client.images.build.return_value = (mock_image, [])\n73:         mock_client.images.get.return_value = mock_image_info\n74: \n75:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n76:             service = DockerService()\n77:             build_args = {\"HTTP_PROXY\": \"http://proxy:8080\", \"HTTPS_PROXY\": \"http://proxy:8080\"}\n78:             service.build_image(\n79:                 dockerfile_path=Path(\"/tmp/Dockerfile\"),\n80:                 context_path=Path(\"/tmp\"),\n81:                 image_name=\"test-agent\",\n82:                 tag=\"1.0.0\",\n83:                 build_args=build_args,\n84:             )\n85: \n86:         mock_client.images.build.assert_called_once()\n87:         call_kwargs = mock_client.images.build.call_args[1]\n88:         assert call_kwargs[\"buildargs\"] == build_args\n89: \n90: \n91: class TestDockerServiceBuildImageFailure:\n92:     def test_build_error_propagates(self) -> None:\n93:         import docker.errors\n94: \n95:         with patch(\"agentcube.services.docker_service.docker.from_env\") as mock_from_env:\n96:             mock_from_env.side_effect = docker.errors.BuildError(\"Build failed\", [])  # type: ignore[arg-type]\n97:             service = DockerService()\n98:             with pytest.raises(docker.errors.BuildError):\n99:                 service.build_image(\n100:                     dockerfile_path=Path(\"/tmp/Dockerfile\"),\n101:                     context_path=Path(\"/tmp\"),\n102:                     image_name=\"test-agent\",\n103:                     tag=\"1.0.0\",\n104:                 )\n105: \n106: \n107: class TestDockerServiceFormatSizeBytes:\n108:     def test_zero_bytes(self) -> None:\n109:         service = DockerService()\n110:         assert service._format_size(0) == \"0 B\"\n111: \n112:     def test_bytes_under_1kb(self) -> None:\n113:         service = DockerService()\n114:         assert service._format_size(512) == \"512 B\"\n115: \n116: \n117: class TestDockerServiceFormatSizeKB:\n118:     def test_one_kb(self) -> None:\n119:         service = DockerService()\n120:         assert service._format_size(1024) == \"1.0 KB\"\n121: \n122:     def test_half_kb(self) -> None:\n123:         service = DockerService()\n124:         assert service._format_size(1536) == \"1.5 KB\"\n125: \n126: \n127: class TestDockerServiceFormatSizeMB:\n128:     def test_one_mb(self) -> None:\n129:         service = DockerService()\n130:         assert service._format_size(1048576) == \"1.0 MB\"\n131: \n132: \n133: class TestDockerServiceFormatSizeGB:\n134:     def test_one_gb(self) -> None:\n135:         service = DockerService()\n136:         assert service._format_size(1073741824) == \"1.0 GB\"\n137: \n138: \n139: class TestDockerServiceGetImageInfo:\n140:     def test_get_image_info_returns_dict_with_all_keys(self) -> None:\n141:         mock_image = MagicMock()\n142:         mock_image.id = \"sha256:abc123def456\"\n143:         mock_image.short_id = \"sha256:abc123\"\n144:         mock_image.tags = [\"test-agent:latest\", \"test-agent:1.0.0\"]\n145:         mock_image.attrs = {\"Size\": 104857600, \"Created\": \"2024-01-01T00:00:00Z\"}\n146: \n147:         mock_client = MagicMock()\n148:         mock_client.images.get.return_value = mock_image\n149: \n150:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n151:             service = DockerService()\n152:             result = service.get_image_info(\"test-agent:latest\")\n153: \n154:         assert result[\"image_id\"] == \"sha256:abc123def456\"\n155:         assert result[\"short_id\"] == \"sha256:abc123\"\n156:         assert result[\"size\"] == \"100.0 MB\"\n157:         assert result[\"tags\"] == \"test-agent:latest, test-agent:1.0.0\"\n158:         assert result[\"created\"] == \"2024-01-01T00:00:00Z\"\n159: \n160:     def test_get_image_info_no_tags(self) -> None:\n161:         mock_image = MagicMock()\n162:         mock_image.id = \"sha256:abc123\"\n163:         mock_image.short_id = \"sha256:abc\"\n164:         mock_image.tags = []\n165:         mock_image.attrs = {\"Size\": 0, \"Created\": \"2024-01-01T00:00:00Z\"}\n166: \n167:         mock_client = MagicMock()\n168:         mock_client.images.get.return_value = mock_image\n169: \n170:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n171:             service = DockerService()\n172:             result = service.get_image_info(\"untagged-image\")\n173: \n174:         assert result[\"tags\"] == \"<none>\"\n175: \n176:     def test_get_image_info_not_found_raises_value_error(self) -> None:\n177:         import docker.errors\n178: \n179:         mock_client = MagicMock()\n180:         mock_client.images.get.side_effect = docker.errors.ImageNotFound(\"Image not found\")\n181: \n182:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n183:             service = DockerService()\n184:             with pytest.raises(ValueError, match=\"Image not found locally\"):\n185:                 service.get_image_info(\"nonexistent:latest\")\n186: \n187:     def test_get_image_info_internal_helper(self) -> None:\n188:         mock_image = MagicMock()\n189:         mock_image.id = \"sha256:xyz789\"\n190:         mock_image.short_id = \"sha256:xyz\"\n191:         mock_image.tags = [\"my-agent:v2\"]\n192:         mock_image.attrs = {\"Size\": 52428800, \"Created\": \"2024-06-15T12:00:00Z\"}\n193: \n194:         mock_client = MagicMock()\n195:         mock_client.images.get.return_value = mock_image\n196: \n197:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n198:             service = DockerService()\n199:             result = service._get_image_info(\"my-agent:v2\")\n200: \n201:         assert result[\"image_id\"] == \"sha256:xyz789\"\n202:         assert result[\"short_id\"] == \"sha256:xyz\"\n203:         assert result[\"size\"] == \"50.0 MB\"\n204:         assert result[\"tags\"] == \"my-agent:v2\"\n205:         assert result[\"created\"] == \"2024-06-15T12:00:00Z\"\n206: \n207:     def test_get_image_info_internal_helper_propagates_image_not_found(self) -> None:\n208:         import docker.errors\n209: \n210:         mock_client = MagicMock()\n211:         mock_client.images.get.side_effect = docker.errors.ImageNotFound(\"not found\")\n212: \n213:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n214:             service = DockerService()\n215:             with pytest.raises(docker.errors.ImageNotFound):\n216:                 service._get_image_info(\"missing:latest\")\n217: \n218: \n219: class TestDockerServiceRemoveImage:\n220:     def test_remove_image_success_returns_true(self) -> None:\n221:         mock_client = MagicMock()\n222:         mock_client.images.remove.return_value = None\n223: \n224:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n225:             service = DockerService()\n226:             result = service.remove_image(\"old-image:latest\")\n227: \n228:         assert result is True\n229:         mock_client.images.remove.assert_called_once_with(\"old-image:latest\")\n230: \n231:     def test_remove_image_not_found_returns_false(self) -> None:\n232:         import docker.errors\n233: \n234:         mock_client = MagicMock()\n235:         mock_client.images.remove.side_effect = docker.errors.ImageNotFound(\"Image not found\")\n236: \n237:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n238:             service = DockerService()\n239:             result = service.remove_image(\"nonexistent:latest\")\n240: \n241:         assert result is False\n242: \n243:     def test_remove_image_api_error_returns_false(self) -> None:\n244:         import docker.errors\n245: \n246:         mock_client = MagicMock()\n247:         mock_client.images.remove.side_effect = docker.errors.APIError(\"Image in use\")\n248: \n249:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n250:             service = DockerService()\n251:             result = service.remove_image(\"in-use-image:latest\")\n252: \n253:         assert result is False\n254: \n255: \n256: class TestDockerService_PushImage_Success:\n257:     def test_push_image_returns_correct_result(self) -> None:\n258:         mock_client = MagicMock()\n259:         mock_client.images.push.return_value = None\n260:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n261:             service = DockerService()\n262:             result = service.push_image(\n263:                 image_name=\"registry.example.com/my-agent:v1.0.0\",\n264:             )\n265:         assert result[\"pushed_image\"] == \"registry.example.com/my-agent:v1.0.0\"\n266:         assert \"push_time\" in result\n267:         assert result[\"push_time\"].endswith(\"s\")\n268:         mock_client.images.push.assert_called_once_with(\n269:             \"registry.example.com/my-agent\", tag=\"v1.0.0\", auth_config=None\n270:         )\n271: \n272: \n273: class TestDockerService_PushImage_WithCredentials:\n274:     def test_push_image_passes_auth_config(self) -> None:\n275:         mock_client = MagicMock()\n276:         mock_client.images.push.return_value = None\n277:         mock_client.login.return_value = {\"Status\": \"Login Succeeded\"}\n278:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n279:             service = DockerService()\n280:             service.push_image(\n281:                 image_name=\"my-agent:v1.0.0\",\n282:                 registry_url=\"registry.example.com\",\n283:                 username=\"user\",\n284:                 password=\"pass\",\n285:             )\n286:         mock_client.login.assert_called_once_with(\n287:             username=\"user\", password=\"pass\", registry=\"registry.example.com\"\n288:         )\n289:         mock_client.images.push.assert_called_once()\n290:         call_kwargs = mock_client.images.push.call_args[1]\n291:         assert call_kwargs[\"auth_config\"] == {\"username\": \"user\", \"password\": \"pass\"}\n292: \n293: \n294: class TestDockerService_PushImage_Failure:\n295:     def test_push_image_raises_api_error(self) -> None:\n296:         import docker.errors\n297: \n298:         mock_client = MagicMock()\n299:         mock_client.images.push.side_effect = docker.errors.APIError(\"push failed\")\n300:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n301:             service = DockerService()\n302:             with pytest.raises(docker.errors.APIError):\n303:                 service.push_image(\n304:                     image_name=\"registry.example.com/my-agent:v1.0.0\",\n305:                 )\n306: \n307: \n308: class TestDockerServicePushImageSpec:\n309:     def test_push_without_registry_url_pushes_directly(self) -> None:\n310:         mock_client = MagicMock()\n311:         mock_client.images.push.return_value = None\n312:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n313:             service = DockerService()\n314:             result = service.push_image(\"my-agent:v1.0.0\")\n315: \n316:         assert result[\"pushed_image\"] == \"my-agent:v1.0.0\"\n317:         assert \"push_time\" in result\n318:         mock_client.images.push.assert_called_once_with(\"my-agent\", tag=\"v1.0.0\", auth_config=None)\n319: \n320:     def test_push_with_registry_url_and_credentials(self) -> None:\n321:         mock_image = MagicMock()\n322:         mock_image.tag.return_value = True\n323:         mock_client = MagicMock()\n324:         mock_client.images.get.return_value = mock_image\n325:         mock_client.images.push.return_value = None\n326:         mock_client.login.return_value = {\"Status\": \"Login Succeeded\"}\n327: \n328:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n329:             service = DockerService()\n330:             result = service.push_image(\n331:                 image_name=\"my-agent:v1.0.0\",\n332:                 registry_url=\"registry.example.com\",\n333:                 username=\"user\",\n334:                 password=\"pass\",\n335:             )\n336: \n337:         assert result[\"pushed_image\"] == \"registry.example.com/my-agent:v1.0.0\"\n338:         assert \"push_time\" in result\n339:         mock_client.login.assert_called_once_with(\n340:             username=\"user\", password=\"pass\", registry=\"registry.example.com\"\n341:         )\n342:         mock_image.tag.assert_called_once_with(\"registry.example.com/my-agent\", tag=\"v1.0.0\")\n343:         mock_client.images.push.assert_called_once_with(\n344:             \"registry.example.com/my-agent\", tag=\"v1.0.0\", auth_config={\"username\": \"user\", \"password\": \"pass\"}\n345:         )\n346: \n347:     def test_push_with_registry_url_no_credentials(self) -> None:\n348:         mock_image = MagicMock()\n349:         mock_image.tag.return_value = True\n350:         mock_client = MagicMock()\n351:         mock_client.images.get.return_value = mock_image\n352:         mock_client.images.push.return_value = None\n353: \n354:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n355:             service = DockerService()\n356:             result = service.push_image(\n357:                 image_name=\"my-agent:v1.0.0\",\n358:                 registry_url=\"registry.example.com\",\n359:             )\n360: \n361:         assert result[\"pushed_image\"] == \"registry.example.com/my-agent:v1.0.0\"\n362:         mock_client.login.assert_not_called()\n363:         mock_client.images.push.assert_called_once_with(\n364:             \"registry.example.com/my-agent\", tag=\"v1.0.0\", auth_config=None\n365:         )\n366: \n367:     def test_push_failure_raises_api_error(self) -> None:\n368:         import docker.errors\n369: \n370:         mock_client = MagicMock()\n371:         mock_client.images.push.side_effect = docker.errors.APIError(\"push failed\")\n372:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n373:             service = DockerService()\n374:             with pytest.raises(docker.errors.APIError):\n375:                 service.push_image(\"my-agent:v1.0.0\")\n376: \n377: \n378: class TestDockerService_DockerLoginSdk_Success:\n379:     def test_login_returns_none(self) -> None:\n380:         mock_client = MagicMock()\n381:         mock_client.login.return_value = {\"Status\": \"Login Succeeded\"}\n382:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n383:             service = DockerService()\n384:             result = service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n385:         assert result is None\n386:         mock_client.login.assert_called_once_with(\n387:             username=\"user\", password=\"pass\", registry=\"registry.example.com\"\n388:         )\n389: \n390: \n391: class TestDockerService_DockerLoginSdk_Failure:\n392:     def test_login_raises_on_failure(self) -> None:\n393:         import docker.errors\n394: \n395:         mock_client = MagicMock()\n396:         mock_client.login.side_effect = docker.errors.APIError(\"login failed\")\n397:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n398:             service = DockerService()\n399:             with pytest.raises(docker.errors.APIError):\n400:                 service._docker_login_sdk(\"registry.example.com\", \"user\", \"wrong-pass\")\n401: \n402: \n403: class TestDockerService_TagImageSdk_Success:\n404:     def test_tag_image_returns_none(self) -> None:\n405:         mock_image = MagicMock()\n406:         mock_image.tag.return_value = True\n407:         mock_client = MagicMock()\n408:         mock_client.images.get.return_value = mock_image\n409:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n410:             service = DockerService()\n411:             result = service._tag_image_sdk(\"my-agent:latest\", \"registry.example.com/my-agent:v1.0.0\")\n412:         assert result is None\n413:         mock_client.images.get.assert_called_once_with(\"my-agent:latest\")\n414:         mock_image.tag.assert_called_once_with(\"registry.example.com/my-agent\", tag=\"v1.0.0\")\n415: \n416:     def test_tag_image_failure_raises_image_not_found(self) -> None:\n417:         import docker.errors\n418: \n419:         mock_client = MagicMock()\n420:         mock_client.images.get.side_effect = docker.errors.ImageNotFound(\"not found\")\n421:         with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n422:             service = DockerService()\n423:             with pytest.raises(docker.errors.ImageNotFound):\n424:                 service._tag_image_sdk(\"missing:latest\", \"registry.example.com/missing:v1\")\n\n(End of file - total 424 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for DockerService.\"\"\"\n\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.services.docker_service import DockerService\n\n\nclass TestDockerServiceCheckDockerAvailableRunning:\n    def test_docker_running_returns_true(self) -> None:\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        with patch(\"agentcube.services.docker_service.docker.from_env\", return_value=mock_client):\n            service = DockerService()\n            assert service.check_docker_available() is True\n\n\nclass TestDockerServiceCheckDockerAvailableNotRunning:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/services/test_docker_service.py","time":{"start":17758763469