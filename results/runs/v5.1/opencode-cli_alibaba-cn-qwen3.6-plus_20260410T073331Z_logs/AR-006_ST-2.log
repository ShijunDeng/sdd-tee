{"type":"tool_use","timestamp":1775818122690,"sessionID":"ses_288ffc1e7ffeibQkrb4gwKYkT4","part":{"id":"prt_d77021e86001DxleoowJEN1R0b","messageID":"msg_d77020580001zTdgfPBzRPu2Pg","sessionID":"ses_288ffc1e7ffeibQkrb4gwKYkT4","type":"tool","tool":"read","callID":"call_436b32654ba8486a9a5c2f5f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"log\"\n7: \t\"math/rand\"\n8: \t\"net/http\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"github.com/google/uuid\"\n13: \tcorev1 \"k8s.io/api/core/v1\"\n14: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n15: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n16: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n17: \t\"k8s.io/apimachinery/pkg/labels\"\n18: \t\"k8s.io/apimachinery/pkg/runtime\"\n19: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n20: \t\"k8s.io/client-go/dynamic\"\n21: \t\"k8s.io/client-go/informers\"\n22: \t\"k8s.io/client-go/kubernetes\"\n23: \n24: \t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n25: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n26: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n27: )\n28: \n29: type Store interface {\n30: \tStoreSandbox(ctx context.Context, info *SandboxInfo) error\n31: \tUpdateSandbox(ctx context.Context, sessionID string, info *SandboxInfo) error\n32: }\n33: \n34: type SandboxReconcilerWatcher interface {\n35: \tWatchSandboxOnce(namespace, name string) (<-chan SandboxStatus, error)\n36: }\n37: \n38: type TokenCache interface {\n39: \tGetOrCreateUserK8sClient(namespace, saName, token string) (dynamic.Interface, error)\n40: }\n41: \n42: type SandboxCreateHandlerDeps struct {\n43: \tDynamicClient     dynamic.Interface\n44: \tClientset         clientset.Interface\n45: \tInformerFactory   informers.SharedInformerFactory\n46: \tStore             Store\n47: \tReconciler        SandboxReconcilerWatcher\n48: \tTokenCache        TokenCache\n49: \tUserClientFactory UserClientFactory\n50: \tEnableAuth        bool\n51: }\n52: \n53: type UserClientFactory interface {\n54: \tCreateUserClient(token string) (dynamic.Interface, error)\n55: }\n56: \n57: type SandboxCreateHandler struct {\n58: \tdynamicClient     dynamic.Interface\n59: \tclientset         clientset.Interface\n60: \tinformerFactory   informers.SharedInformerFactory\n61: \tstore             Store\n62: \treconciler        SandboxReconcilerWatcher\n63: \ttokenCache        TokenCache\n64: \tuserClientFactory UserClientFactory\n65: \tenableAuth        bool\n66: }\n67: \n68: func NewSandboxCreateHandler(deps *SandboxCreateHandlerDeps) *SandboxCreateHandler {\n69: \treturn &SandboxCreateHandler{\n70: \t\tdynamicClient:     deps.DynamicClient,\n71: \t\tclientset:         deps.Clientset,\n72: \t\tinformerFactory:   deps.InformerFactory,\n73: \t\tstore:             deps.Store,\n74: \t\treconciler:        deps.Reconciler,\n75: \t\ttokenCache:        deps.TokenCache,\n76: \t\tuserClientFactory: deps.UserClientFactory,\n77: \t\tenableAuth:        deps.EnableAuth,\n78: \t}\n79: }\n80: \n81: func (h *SandboxCreateHandler) getDynamicClient(c *gin.Context) (dynamic.Interface, error) {\n82: \tif !h.enableAuth {\n83: \t\treturn h.dynamicClient, nil\n84: \t}\n85: \n86: \ttoken := c.GetHeader(\"Authorization\")\n87: \tif token == \"\" {\n88: \t\treturn nil, fmt.Errorf(\"authorization token is required\")\n89: \t}\n90: \tif len(token) > 7 && token[:7] == \"Bearer \" {\n91: \t\ttoken = token[7:]\n92: \t}\n93: \n94: \tnamespace := c.GetString(\"namespace\")\n95: \tsaName := c.GetString(\"serviceAccountName\")\n96: \n97: \tif h.tokenCache != nil {\n98: \t\treturn h.tokenCache.GetOrCreateUserK8sClient(namespace, saName, token)\n99: \t}\n100: \n101: \tif h.userClientFactory != nil {\n102: \t\treturn h.userClientFactory.CreateUserClient(token)\n103: \t}\n104: \n105: \treturn nil, fmt.Errorf(\"no user client factory available\")\n106: }\n107: \n108: func (h *SandboxCreateHandler) CreateAgentRuntimeSandbox(c *gin.Context) {\n109: \tvar sandboxReq CreateSandboxRequest\n110: \tif err := c.ShouldBindJSON(&sandboxReq); err != nil {\n111: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n112: \t\treturn\n113: \t}\n114: \n115: \tsandboxReq.Kind = AgentRuntimeKind\n116: \n117: \tif err := sandboxReq.Validate(); err != nil {\n118: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n119: \t\treturn\n120: \t}\n121: \n122: \tarLister := h.informerFactory.Runtime().V1alpha1().AgentRuntimes().Lister()\n123: \ttemplate, err := arLister.AgentRuntimes(sandboxReq.Namespace).Get(sandboxReq.Name)\n124: \tif err != nil {\n125: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"AgentRuntime %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n126: \t\treturn\n127: \t}\n128: \n129: \tif template.Spec.Template == nil {\n130: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"podTemplate is required\")\n131: \t\treturn\n132: \t}\n133: \n134: \tsessionID := generateSessionID()\n135: \tsandboxName := generateSandboxName(sandboxReq.Name)\n136: \n137: \tsandboxCR, err := h.buildAgentRuntimeSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace)\n138: \tif err != nil {\n139: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n140: \t\treturn\n141: \t}\n142: \n143: \tsandboxInfo := &SandboxInfo{\n144: \t\tSessionID:    sessionID,\n145: \t\tSandboxName:  sandboxName,\n146: \t\tWorkloadName: sandboxReq.Name,\n147: \t\tNamespace:    sandboxReq.Namespace,\n148: \t\tKind:         AgentRuntimeKind,\n149: \t\tStatus:       \"pending\",\n150: \t\tCreatedAt:    time.Now(),\n151: \t}\n152: \n153: \tif err := h.store.StoreSandbox(c.Request.Context(), sandboxInfo); err != nil {\n154: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n155: \t\treturn\n156: \t}\n157: \n158: \twatcherCh, err := h.reconciler.WatchSandboxOnce(sandboxReq.Namespace, sandboxName)\n159: \tif err != nil {\n160: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n161: \t\treturn\n162: \t}\n163: \n164: \tdynClient, err := h.getDynamicClient(c)\n165: \tif err != nil {\n166: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n167: \t\treturn\n168: \t}\n169: \n170: \tcreatedCR, err := dynClient.Resource(SandboxGVR).Namespace(sandboxReq.Namespace).Create(c.Request.Context(), sandboxCR, metav1.CreateOptions{})\n171: \tif err != nil {\n172: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n173: \t\treturn\n174: \t}\n175: \n176: \tctx, cancel := context.WithTimeout(c.Request.Context(), 2*time.Minute)\n177: \tdefer cancel()\n178: \n179: \tselect {\n180: \tcase status := <-watcherCh:\n181: \t\tif status.Error != nil {\n182: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n183: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, status.Error.Error())\n184: \t\t\treturn\n185: \t\t}\n186: \t\tif status.Status != \"running\" {\n187: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n188: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n189: \t\t\treturn\n190: \t\t}\n191: \tcase <-ctx.Done():\n19