ory.Runtime().V1alpha1().CodeInterpreters().Lister()\n241: \ttemplate, err := ciLister.CodeInterpreters(sandboxReq.Namespace).Get(sandboxReq.Name)\n242: \tif err != nil {\n243: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"CodeInterpreter %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n244: \t\treturn\n245: \t}\n246: \n247: \tif template.Spec.Template == nil {\n248: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"template is required\")\n249: \t\treturn\n250: \t}\n251: \n252: \tsessionID := generateSessionID()\n253: \tsandboxName := generateSandboxName(sandboxReq.Name)\n254: \n255: \tports := getPortsOrDefaults(template.Spec.Ports)\n256: \n257: \tvar sandboxCR *unstructured.Unstructured\n258: \tvar entryKind string\n259: \tvar err error\n260: \n261: \tsandboxCR, entryKind, err = h.buildCodeInterpreterSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace, ports)\n262: \tif err != nil {\n263: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n264: \t\treturn\n265: \t}\n266: \n267: \tif template.Spec.AuthMode == runtimev1alpha1.AuthModePicoD {\n268: \t\tif err := h.injectPicodAuthEnv(sandboxCR, sandboxReq.Namespace, h.clientset.CoreV1().(*kubernetes.Clientset)); err != nil {\n269: \t\t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n270: \t\t\treturn\n271: \t\t}\n272: \t}\n273: \n274: \tsandboxInfo := &SandboxInfo{\n275: \t\tSessionID:    sessionID,\n276: \t\tSandboxName:  sandboxName,\n277: \t\tWorkloadName: sandboxReq.Name,\n278: \t\tNamespace:    sandboxReq.Namespace,\n279: \t\tKind:         entryKind,\n280: \t\tStatus:       \"pending\",\n281: \t\tCreatedAt:    time.Now(),\n282: \t}\n283: \n284: \tif err := h.store.StoreSandbox(c.Request.Context(), sandboxInfo); err != nil {\n285: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n286: \t\treturn\n287: \t}\n288: \n289: \twatcherCh, err := h.reconciler.WatchSandboxOnce(sandboxReq.Namespace, sandboxName)\n290: \tif err != nil {\n291: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n292: \t\treturn\n293: \t}\n294: \n295: \tdynClient, err := h.getDynamicClient(c)\n296: \tif err != nil {\n297: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n298: \t\treturn\n299: \t}\n300: \n301: \tvar gvr schema.GroupVersionResource\n302: \tif entryKind == SandboxClaimsKind {\n303: \t\tgvr = SandboxClaimGVR\n304: \t} else {\n305: \t\tgvr = SandboxGVR\n306: \t}\n307: \n308: \tcreatedCR, err := dynClient.Resource(gvr).Namespace(sandboxReq.Namespace).Create(c.Request.Context(), sandboxCR, metav1.CreateOptions{})\n309: \tif err != nil {\n310: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n311: \t\treturn\n312: \t}\n313: \n314: \tctx, cancel := context.WithTimeout(c.Request.Context(), 2*time.Minute)\n315: \tdefer cancel()\n316: \n317: \tselect {\n318: \tcase status := <-watcherCh:\n319: \t\tif status.Error != nil {\n320: \t\t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n321: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, status.Error.Error())\n322: \t\t\treturn\n323: \t\t}\n324: \t\tif status.Status != \"running\" {\n325: \t\t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n326: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n327: \t\t\treturn\n328: \t\t}\n329: \tcase <-ctx.Done():\n330: \t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n331: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n332: \t\treturn\n333: \t}\n334: \n335: \tpodIP, err := h.resolvePodIP(c.Request.Context(), sandboxName, sandboxReq.Namespace, sandboxCR, h.clientset.CoreV1().(*kubernetes.Clientset))\n336: \tif err != nil {\n337: \t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n338: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())\n339: \t\treturn\n340: \t}\n341: \n342: \tentryPoints := h.buildEntryPoints(podIP, ports)\n343: \n344: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n345: \tsandboxInfo.PodIP = podIP\n346: \tsandboxInfo.EntryPoints = entryPoints\n347: \tsandboxInfo.Status = \"running\"\n348: \n349: \tif err := h.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n350: \t\tlog.Printf(\"failed to update sandbox in store: %v\", err)\n351: \t}\n352: \n353: \tresp := &CreateSandboxResponse{\n354: \t\tSessionID:   sessionID,\n355: \t\tSandboxID:   sandboxInfo.SandboxID,\n356: \t\tSandboxName: sandboxName,\n357: \t\tEntryPoints: entryPoints,\n358: \t}\n359: \n360: \tresponse.JSON(c, http.StatusOK, resp)\n361: }\n362: \n363: func (h *SandboxCreateHandler) rollbackCR(ctx context.Context, gvr schema.GroupVersionResource, namespace, name string, dynClient dynamic.Interface) error {\n364: \trollbackCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n365: \tdefer cancel()\n366: \n367: \terr := dynClient.Resource(gvr).Namespace(namespace).Delete(rollbackCtx, name, metav1.DeleteOptions{})\n368: \tif err != nil && apierrors.IsNotFound(err) {\n369: \t\treturn nil\n370: \t}\n371: \treturn err\n372: }\n373: \n374: func (h *SandboxCreateHandler) buildAgentRuntimeSandboxCR(template *runtimev1alpha1.AgentRuntime, sessionID, sandboxName, workloadName, namespace string) (*unstructured.Unstructured, error) {\n375: \tcr := &unstructured.Unstructured{}\n376: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n377: \tcr.SetKind(\"Sandbox\")\n378: \tcr.SetName(sandboxName)\n379: \tcr.SetNamespace(namespace)\n380: \n381: \tcr.SetLabels(map[string]string{\n382: \t\tLabelManagedBy:    LabelManagedByValue,\n383: \t\tLabelSessionID:    sessionID,\n384: \t\tLabelWorkloadName: workloadName,\n385: \t\tLabelSandboxName:  sandboxName,\n386: \t})\n387: \n388: \tidleTimeout := DefaultSandboxIdleTimeout\n389: \tif template.Spec.SessionTimeout != nil {\n390: \t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n391: \t}\n392: \tcr.SetAnnotations(map[string]string{\n393: \t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n394: \t})\n395: \n396: \tttl := DefaultSandboxTTL\n397: \tif template.Spec.MaxSessionDuration != nil {\n398: \t\tttl = template.Spec.MaxSessionDuration.Duration.Hours()\n399: \t}\n400: \tshutdownTime := time.Now().Add(time.Duration(ttl) * time.Hour)\n401: \n402: \tspec := map[string]interface{}{\n403: \t\t\"replicas\": int64(1),\n404: \t\t\"lifecycle\": map[string]interface{}{\n405: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n406: \t\t},\n407: \t}\n408: \n409: \tvar ports []interface{}\n410: \tfor _, p := range template.Spec.Ports {\n411: \t\tports = append(ports, map[string]interface{}{\n412: \t\t\t\"name\":     p.Name,\n413: \t\t\t\"port\":     int64(p.Port),\n414: \t\t\t\"protocol\": string(p.Protocol),\n415: \t\t})\n416: \t}\n417: \tif len(ports) > 0 {\n418: \t\tspec[\"ports\"] = ports\n419: \t}\n420: \n421: \tpodSpec := template.Spec.Template.Spec\n422: \tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n423: \tif err != nil {\n424: \t\treturn nil, fmt.Errorf(\"failed to convert pod spec: %w\", err)\n425: \t}\n426: \tspec[\"podTemplate\"] = podSpecMap\n427: \n428: \tcr.Object[\"spec\"] = spec\n429: \n430: \treturn cr, nil\n431: }\n432: \n433: func (h *SandboxCreateHandler) buildCodeInterpreterSandboxCR(template *runtimev1alpha1.CodeInterpreter, sessionID, sandboxName, workloadName, namespace string, ports []runtimev1alpha1.TargetPort) (*unstructured.Unstructured, string, error) {\n434: \twarmPoolSize := int32(0)\n435: \tif template.Spec.WarmPoolSize != nil {\n436: \t\twarmPoolSize = *template.Spec.WarmPoolSize\n437: \t}\n438: \n439: \tif warmPoolSize > 0 {\n440: \t\tcr := &unstructured.Unstructured{}\n441: \t\tcr.SetAPIVersion(\"extensions.agents.x-k8s.io/v1alpha1\")\n442: \t\tcr.SetKind(\"SandboxClaim\")\n443: \t\tcr.SetName(sandboxName)\n444: \t\tcr.SetNamespace(namespace)\n445: \n446: \t\tcr.SetLabels(map[string]string{\n447: \t\t\tLabelManagedBy:    LabelManagedByValue,\n448: \t\t\tLabelSessionID:    sessionID,\n449: \t\t\tLabelWorkloadName: workloadName,\n450: \t\t\tLabelSandboxName:  sandboxName,\n451: \t\t})\n452: \n453: \t\tidleTimeout := DefaultSandboxIdleTimeout\n454: \t\tif template.Spec.SessionTimeout != nil {\n455: \t\t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n456: \t\t}\n457: \t\tcr.SetAnnotations(map[string]string{\n458: \t\t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n459: \t\t})\n460: \n461: \t\treturn cr, SandboxClaimsKind, nil\n462: \t}\n463: \n464: \tcr := &unstructured.Unstructured{}\n465: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n466: \tcr.SetKind(\"Sandbox\")\n467: \tcr.SetName(sandboxName)\n468: \tcr.SetNamespace(namespace)\n469: \n470: \tcr.SetLabels(map[string]string{\n471: \t\tLabelManagedBy:    LabelManagedByValue,\n472: \t\tLabelSessionID:    sessionID,\n473: \t\tLabelWorkloadName: workloadName,\n474: \t\tLabelSandboxName:  sandboxName,\n475: \t})\n476: \n477: \tidleTimeout := DefaultSandboxIdleTimeout\n478: \tif template.Spec.SessionTimeout != nil {\n479: \t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n480: \t}\n481: \tcr.SetAnnotations(map[string]string{\n482: \t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n483: \t})\n484: \n485: \tttl := DefaultSandboxTTL\n486: \tif template.Spec.MaxSessionDuration != nil {\n487: \t\tttl = template.Spec.MaxSessionDuration.Duration.Hours()\n488: \t}\n489: \tshutdownTime := time.Now().Add(time.Duration(ttl) * time.Hour)\n490: \n491: \tspec := map[string]interface{}{\n492: \t\t\"replicas\": int64(1),\n493: \t\t\"lifecycle\": map[string]interface{}{\n494: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n495: \t\t},\n496: \t}\n497: \n498: \tvar portsList []interface{}\n499: \tfor _, p := range ports {\n500: \t\tportsList = append(portsList, map[string]interface{}{\n501: \t\t\t\"name\":     p.Name,\n502: \t\t\t\"port\":     int64(p.Port),\n503: \t\t\t\"protocol\": string(p.Protocol),\n504: \t\t})\n505: \t}\n506: \tif len(portsList) > 0 {\n507: \t\tspec[\"ports\"] = portsList\n508: \t}\n509: \n510: \ttmpl := template.Spec.Template\n511: \tcontainer := corev1.Container{\n512: \t\tName:  \"code-interpreter\",\n513: \t\tImage: tmpl.Image,\n514: \t}\n515: \tif tmpl.ImagePullPolicy != \"\" {\n516: \t\tcontainer.ImagePullPolicy = tmpl.ImagePullPolicy\n517: \t}\n518: \tif len(tmpl.Environment) > 0 {\n519: \t\tcontainer.Env = tmpl.Environment\n520: \t}\n521: \tif len(tmpl.Command) > 0 {\n522: \t\tcontainer.Command = tmpl.Command\n523: \t}\n524: \tif len(tmpl.Args) > 0 {\n525: \t\tcontainer.Args = tmpl.Args\n526: \t}\n527: \tif !reflect.DeepEqual(tmpl.Resources, corev1.ResourceRequirements{}) {\n528: \t\tcontainer.Resources = tmpl.Resources\n529: \t}\n530: \n531: \tpodSpec := corev1.PodSpec{\n532: \t\tContainers: []corev1.Container{container},\n533: \t}\n534: \tif tmpl.RuntimeClassName != nil {\n535: \t\tpodSpec.RuntimeClassName = tmpl.RuntimeClassName\n536: \t}\n537: \tif len(tmpl.ImagePullSecrets) > 0 {\n538: \t\tpodSpec.ImagePullSecrets = tmpl.ImagePullSecrets\n539: \t}\n540: \n541: \tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n542: \tif err != nil {\n543: \t\treturn nil, \"\", fmt.Errorf(\"failed to convert pod spec: %w\", err)\n544: \t}\n545: \tspec[\"podTemplate\"] = podSpecMap\n546: \n547: \tcr.Object[\"spec\"] = spec\n548: \n549: \treturn cr, SandboxesKind, nil\n550: }\n551: \n552: func getPortsOrDefaults(ports []runtimev1alpha1.TargetPort) []runtimev1alpha1.TargetPort {\n553: \tif len(ports) == 0 {\n554: \t\treturn []runtimev1alpha1.TargetPort{\n555: \t\t\t{Port: 8080, Protocol: runtimev1alpha1.ProtocolTypeHTTP, PathPrefix: \"/\"},\n556: \t\t}\n557: \t}\n558: \treturn ports\n559: }\n560: \n561: func (h *SandboxCreateHandler) injectPicodAuthEnv(cr *unstructured.Unstructured, namespace string, clientset kubernetes.Interface) error {\n562: \tsecret, err := clientset.CoreV1().Secrets(namespace).Get(context.Background(), IdentitySecretName, metav1.GetOptions{})\n563: \tif err != nil {\n564: \t\tif apierrors.IsNotFound(err) {\n565: \t\t\treturn fmt.Errorf(\"public key not yet loaded from Router Secret\")\n566: \t\t}\n567: \t\treturn fmt.Errorf(\"failed to get secret: %w\", err)\n568: \t}\n569: \n570: \tpublicKey, ok := secret.Data[PublicKeyDataKey]\n571: \tif !ok || len(publicKey) == 0 {\n572: \t\treturn fmt.Errorf(\"public key not yet loaded from Router Secret\")\n573: \t}\n574: \n575: \tspec, ok := cr.Object[\"spec\"].(map[string]interface{})\n576: \tif !ok {\n577: \t\treturn fmt.Errorf(\"spec not found in CR\")\n578: \t}\n579: \n580: \tpodTemplate, ok := spec[\"podTemplate\"].(map[string]interface{})\n581: \tif !ok {\n582: \t\treturn fmt.Errorf(\"podTemplate not found in spec\")\n583: \t}\n584: \n585: \tcontainers, ok := podTemplate[\"containers\"].([]interface{})\n586: \tif !ok || len(containers) == 0 {\n587: \t\treturn fmt.Errorf(\"containers not found in podTemplate\")\n588: \t}\n589: \n590: \tfirstContainer, ok := containers[0].(map[string]interface{})\n591: \tif !ok {\n592: \t\treturn fmt.Errorf(\"invalid container format\")\n593: \t}\n594: \n595: \tenvVars, ok := firstContainer[\"env\"].([]interface{})\n596: \tif !ok {\n597: \t\tenvVars = []interface{}{}\n598: \t}\n599: \n600: \tnewEnv := map[string]interface{}{\n601: \t\t\"name\":  \"PICOD_AUTH_PUBLIC_KEY\",\n602: \t\t\"value\": string(publicKey),\n603: \t}\n604: \n605: \tfirstContainer[\"env\"] = append(envVars, newEnv)\n606: \tcontainers[0] = firstContainer\n607: \tpodTemplate[\"containers\"] = containers\n608: \tspec[\"podTemplate\"] = podTemplate\n609: \tcr.Object[\"spec\"] = spec\n610: \n611: \treturn nil\n612: }\n613: \n614: func (h *SandboxCreateHandler) resolvePodIP(ctx context.Context, sandboxName, namespace string, sandboxCR *unstructured.Unstructured, clientset kubernetes.Interface) (string, error) {\n615: \tpodLister := h.informerFactory.Core().V1().Pods().Lister()\n616: \n617: \tpod, err := podLister.Pods(namespace).Get(sandboxName)\n618: \tif err == nil && pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n619: \t\treturn pod.Status.PodIP, nil\n620: \t}\n621: \n622: \tannotations := sandboxCR.GetAnnotations()\n623: \tif podName, ok := annotations[AnnotationSandboxPodName]; ok && podName != \"\" {\n624: \t\tpod, err := podLister.Pods(namespace).Get(podName)\n625: \t\tif err == nil {\n626: \t\t\tif pod.Status.Phase != corev1.PodRunning {\n627: \t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n628: \t\t\t}\n629: \t\t\tif pod.Status.PodIP == \"\" {\n630: \t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n631: \t\t\t}\n632: \t\t\treturn pod.Status.PodIP, nil\n633: \t\t}\n634: \t}\n635: \n636: \tpods, err := podLister.Pods(namespace).List(labels.SelectorFromSet(labels.Set{\n637: \t\tLabelSandboxName: sandboxName,\n638: \t}))\n639: \tif err != nil {\n640: \t\treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n641: \t}\n642: \n643: \tfor _, p := range pods {\n644: \t\tfor _, ownerRef := range p.OwnerReferences {\n645: \t\t\tif ownerRef.Kind == \"Sandbox\" && ownerRef.Name == sandboxName {\n646: \t\t\t\tif p.Status.Phase != corev1.PodRunning {\n647: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n648: \t\t\t\t}\n649: \t\t\t\tif p.Status.PodIP == \"\" {\n650: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n651: \t\t\t\t}\n652: \t\t\t\treturn p.Status.PodIP, nil\n653: \t\t\t}\n654: \t\t}\n655: \t}\n656: \n657: \treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n658: }\n659: \n660: func (h *SandboxCreateHandler) buildEntryPoints(podIP string, ports []runtimev1alpha1.TargetPort) []EntryPoint {\n661: \tvar entryPoints []EntryPoint\n662: \tfor _, p := range ports {\n663: \t\tentryPoints = append(entryPoints, EntryPoint{\n664: \t\t\tPath:     p.PathPrefix,\n665: \t\t\tProtocol: string(p.Protocol),\n666: \t\t\tEndpoint: fmt.Sprintf(\"%s:%d\", podIP, p.Port),\n667: \t\t})\n668: \t}\n669: \treturn entryPoints\n670: }\n671: \n672: func generateSessionID() string {\n673: \treturn uuid.New().String()\n674: }\n675: \n676: func generateSandboxName(workloadName string) string {\n677: \treturn fmt.Sprintf(\"%s-%s\", workloadName, RandString(8))\n678: }\n679: \n680: func RandString(n int) string {\n681: \tconst charset = \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\"\n682: \tb := make([]byte, n)\n683: \tfor i := range b {\n684: \t\tb[i] = charset[rand.Intn(len(charset))]\n685: \t}\n686: \treturn string(b)\n687: }\n\n(End of file - total 687 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_create.go","time":{"start":1775818122677,"end":1775818122688}}}}
{"type":"tool_use","timestamp":1775818125407,"sessionID":"ses_288ffc1e7ffeibQkrb4gwKYkT4","part":{"id":"prt_d7702294d00145YuCNhkkYMrda","messageID":"msg_d77020580001zTdgfPBzRPu2Pg","sessionID":"ses_288ffc1e7ffeibQkrb4gwKYkT4","type":"tool","tool":"read","callID":"call_41adbc1031724a89bb3f2d53","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/delta-spec.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/delta-spec.md</path>\n<type>file</type>\n<content>\n1: # delta-spec: AR-004 — WorkloadManager HTTP 服务框架\n2: \n3: ## Context\n4: \n5: **Module:** `pkg/workloadmanager`  \n6: **Language:** Go  \n7: **Size:** M  \n8: \n9: WorkloadManager 提供 HTTP 服务框架，用于管理 AgentRuntime 和 CodeInterpreter 工作负载的生命周期。基于 `client-go` 生成的 Kubernetes typed client 与 informer 机制，对外暴露 RESTful API。\n10: \n11: ---\n12: \n13: ## Requirement: HTTP Server 初始化与生命周期\n14: \n15: **ID:** REQ-001  \n16: **Priority:** P0  \n17: \n18: 系统 MUST 提供一个可配置的 HTTP 服务器，支持 graceful shutdown。\n19: \n20: ### Scenario: 服务器正常启动\n21: \n22: **GIVEN** 有效的监听地址和端口配置  \n23: **WHEN** 调用 `WorkloadManager.Start(ctx)`  \n24: **THEN** HTTP 服务器在指定地址开始监听  \n25: **AND** 就绪探针端点返回 200\n26: \n27: ### Scenario: 服务器 graceful shutdown\n28: \n29: **GIVEN** 服务器正在运行  \n30: **WHEN** 上下文被取消或收到终止信号  \n31: **THEN** 服务器停止接受新请求  \n32: **AND** 正在处理的请求完成后再退出  \n33: **AND** 返回码为 0\n34: \n35: ### Scenario: 端口冲突\n36: \n37: **GIVEN** 目标端口已被其他进程占用  \n38: **WHEN** 调用 `WorkloadManager.Start(ctx)`  \n39: **THEN** 返回端口占用错误  \n40: **AND** 服务器不启动\n41: \n42: ---\n43: \n44: ## Requirement: AgentRuntime CRUD API\n45: \n46: **ID:** REQ-002  \n47: **Priority:** P0  \n48: \n49: 系统 MUST 提供 AgentRuntime 资源的 CRUD HTTP 端点。\n50: \n51: ### Scenario: 创建 AgentRuntime\n52: \n53: **GIVEN** 有效的 AgentRuntime 创建请求体（JSON）  \n54: **WHEN** 发送 `POST /api/v1/agentruntimes`  \n55: **THEN** 返回 201 Created  \n56: **AND** 响应体包含创建的 AgentRuntime 对象（含 metadata.uid 和 creationTimestamp）\n57: \n58: ### Scenario: 获取 AgentRuntime 列表\n59: \n60: **GIVEN** 命名空间中存在多个 AgentRuntime 资源  \n61: **WHEN** 发送 `GET /api/v1/agentruntimes?namespace=<ns>`  \n62: **THEN** 返回 200 OK  \n63: **AND** 响应体为 AgentRuntimeList，包含匹配的 items\n64: \n65: ### Scenario: 获取单个 AgentRuntime\n66: \n67: **GIVEN** 命名空间中存在名为 `my-runtime` 的 AgentRuntime  \n68: **WHEN** 发送 `GET /api/v1/agentruntimes/my-runtime?namespace=<ns>`  \n69: **THEN** 返回 200 OK  \n70: **AND** 响应体为该 AgentRuntime 对象\n71: \n72: ### Scenario: 获取不存在的 AgentRuntime\n73: \n74: **GIVEN** 命名空间中不存在指定的 AgentRuntime  \n75: **WHEN** 发送 `GET /api/v1/agentruntimes/nonexistent?namespace=<ns>`  \n76: **THEN** 返回 404 Not Found\n77: \n78: ### Scenario: 更新 AgentRuntime\n79: \n80: **GIVEN** 已存在的 AgentRuntime 和有效的更新请求体  \n81: **WHEN** 发送 `PUT /api/v1/agentruntimes/<name>?namespace=<ns>`  \n82: **THEN** 返回 200 OK  \n83: **AND** 响应体包含更新后的对象（resourceVersion 已变更）\n84: \n85: ### Scenario: 删除 AgentRuntime\n86: \n87: **GIVEN** 已存在的 AgentRuntime  \n88: **WHEN** 发送 `DELETE /api/v1/agentruntimes/<name>?namespace=<ns>`  \n89: **THEN** 返回 200 OK  \n90: **AND** 资源被标记删除\n91: \n92: ---\n93: \n94: ## Requirement: CodeInterpreter CRUD API\n95: \n96: **ID:** REQ-003  \n97: **Priority:** P0  \n98: \n99: 系统 MUST 提供 CodeInterpreter 资源的 CRUD HTTP 端点。\n100: \n101: ### Scenario: 创建 CodeInterpreter\n102: \n103: **GIVEN** 有效的 CodeInterpreter 创建请求体（JSON）  \n104: **WHEN** 发送 `POST /api/v1/codeinterpreters`  \n105: **THEN** 返回 201 Created  \n106: **AND** 响应体包含创建的 CodeInterpreter 对象\n107: \n108: ### Scenario: 获取 CodeInterpreter 列表\n109: \n110: **GIVEN** 命名空间中存在多个 CodeInterpreter 资源  \n111: **WHEN** 发送 `GET /api/v1/codeinterpreters?namespace=<ns>`  \n112: **THEN** 返回 200 OK  \n113: **AND** 响应体为 CodeInterpreterList\n114: \n115: ### Scenario: 获取单个 CodeInterpreter\n116: \n117: **GIVEN** 命名空间中存在名为 `my-interpreter` 的 CodeInterpreter  \n118: **WHEN** 发送 `GET /api/v1/codeinterpreters/my-interpreter?namespace=<ns>`  \n119: **THEN** 返回 200 OK\n120: \n121: ### Scenario: 更新 CodeInterpreter\n122: \n123: **GIVEN** 已存在的 CodeInterpreter 和有效的更新请求体  \n124: **WHEN** 发送 `PUT /api/v1/codeinterpreters/<name>?namespace=<ns>`  \n125: **THEN** 返回 200 OK  \n126: **AND** 响应体包含更新后的对象\n127: \n128: ### Scenario: 删除 CodeInterpreter\n129: \n130: **GIVEN** 已存在的 CodeInterpreter  \n131: **WHEN** 发送 `DELETE /api/v1/codeinterpreters/<name>?namespace=<ns>`  \n132: **THEN** 返回 200 OK\n133: \n134: ---\n135: \n136: ## Requirement: 请求验证与错误处理\n137: \n138: **ID:** REQ-004  \n139: **Priority:** P0  \n140: \n141: 系统 MUST 验证请求参数并返回结构化错误响应。\n142: \n143: ### Scenario: 缺少必填字段\n144: \n145: **GIVEN** 缺少 `metadata.name` 的创建请求  \n146: **WHEN** 发送 `POST /api/v1/agentruntimes`  \n147: **THEN** 返回 400 Bad Request  \n148: **AND** 响应体包含错误码和错误消息\n149: \n150: ### Scenario: 缺少 namespace 参数\n151: \n152: **GIVEN** 未提供 namespace 查询参数的列表请求  \n153: **WHEN** 发送 `GET /api/v1/agentruntimes`  \n154: **THEN** 返回 400 Bad Request  \n155: **AND** 错误消息指明缺少 namespace 参数\n156: \n157: ### Scenario: 无效的 JSON 请求体\n158: \n159: **GIVEN** 格式错误的 JSON 请求体  \n160: **WHEN** 发送 `POST /api/v1/agentruntimes`  \n161: **THEN** 返回 400 Bad Request  \n162: **AND** 错误消息说明 JSON 解析失败\n163: \n164: ### Scenario: 未注册的路由\n165: \n166: **GIVEN** 任意未注册的路径  \n167: **WHEN** 发送请求到该路径  \n168: **THEN** 返回 404 Not Found\n169: \n170: ---\n171: \n172: ## Requirement: 健康检查端点\n173: \n174: **ID:** REQ-005  \n175: **Priority:** P1  \n176: \n177: 系统 MUST 提供健康检查和就绪检查端点。\n178: \n179: ### Scenario: 存活探针\n180: \n181: **GIVEN** 服务器已启动  \n182: **WHEN** 发送 `GET /healthz`  \n183: **THEN** 返回 200 OK  \n184: **AND** 响应体包含 `{\"status\": \"ok\"}`\n185: \n186: ### Scenario: 就绪探针\n187: \n188: **GIVEN** 服务器已启动且 informer 缓存已同步  \n189: **WHEN** 发送 `GET /readyz`  \n190: **THEN** 返回 200 OK  \n191: **AND** 响应体包含 `{\"status\": \"ready\"}`\n192: \n193: ### Scenario: 未就绪状态\n194: \n195: **GIVEN** 服务器已启动但 informer 缓存未同步  \n196: **WHEN** 发送 `GET /readyz`  \n197: **THEN** 返回 503 Service Unavailable\n198: \n199: ---\n200: \n201: ## Requirement: Informer 缓存集成\n202: \n203: **ID:** REQ-006  \n204: **Priority:** P1  \n205: \n206: 系统 MUST 使用 SharedInformerFactory 缓存 AgentRuntime 和 CodeInterpreter 资源。\n207: \n208: ### Scenario: Informer 启动时缓存同步\n209: \n210: **GIVEN** 有效的 Kubernetes 集群连接  \n211: **WHEN** WorkloadManager 初始化  \n212: **THEN** SharedInformerFactory 启动  \n213: **AND** AgentRuntime 和 CodeInterpreter informers 开始同步缓存\n214: \n215: ### Scenario: 列表请求使用缓存\n216: \n217: **GIVEN** Informer 缓存已同步  \n218: **WHEN** 发送列表请求 `GET /api/v1/agentruntimes?namespace=<ns>`  \n219: **THEN** 响应数据来自 informer lister 缓存  \n220: **AND** 不直接调用 Kubernetes API\n221: \n222: ### Scenario: 创建/更新/删除请求直连 API\n223: \n224: **GIVEN** 写操作请求  \n225: **WHEN** 发送 POST/PUT/DELETE 请求  \n226: **THEN** 请求直接转发到 Kubernetes API server  \n227: **AND** 响应返回后 informer 缓存最终一致更新\n\n(End of file - total 227 lines)\n</content>","metadata":{"preview":"# delta-spec: AR-004 — WorkloadManager HTTP 服务框架\n\n## Context\n\n**Module:** `pkg/workloadmanager`  \n**Language:** Go  \n**Size:** M  \n\nWorkloadManager 提供 HTTP 服务框架，用于管理 AgentRuntime 和 CodeInterpreter 工作负载的生命周期。基于 `client-go` 生成的 Kubernetes typed client 与 informer 机制，对外暴露 RESTful API。\n\n---\n\n## Requirement: HTTP Server 初始化与生命周期\n\n**ID:** REQ-001  \n**Priority:** P0  \n\n系统 MUST 提供一个可配置的 HTTP 服务器，支持 graceful shutdown。\n\n### Scenario: 服务器正常启动","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/delta-spec.md","time":{"start":1775818125391,"end":1775818125406}}}}
