*Backend, error) {\n56: \tlb.mu.Lock()\n57: \tdefer lb.mu.Unlock()\n58: \n59: \tvar selected *Backend\n60: \tminConns := int64(-1)\n61: \n62: \tfor i := range backends {\n63: \t\tb := &backends[i]\n64: \t\tif !b.Healthy {\n65: \t\t\tcontinue\n66: \t\t}\n67: \t\tkey := b.URL.String()\n68: \t\tif _, ok := lb.connections[key]; !ok {\n69: \t\t\tlb.connections[key] = &atomic.Int64{}\n70: \t\t}\n71: \t\tconns := lb.connections[key].Load()\n72: \t\tif minConns == -1 || conns < minConns {\n73: \t\t\tminConns = conns\n74: \t\t\tselected = b\n75: \t\t}\n76: \t}\n77: \n78: \tif selected == nil {\n79: \t\treturn nil, ErrNoHealthyBackend\n80: \t}\n81: \n82: \treturn selected, nil\n83: }\n84: \n85: func (lb *LeastConnectionsBalancer) Inc(url string) {\n86: \tlb.mu.Lock()\n87: \tdefer lb.mu.Unlock()\n88: \tif _, ok := lb.connections[url]; !ok {\n89: \t\tlb.connections[url] = &atomic.Int64{}\n90: \t}\n91: \tlb.connections[url].Add(1)\n92: }\n93: \n94: func (lb *LeastConnectionsBalancer) Dec(url string) {\n95: \tlb.mu.Lock()\n96: \tdefer lb.mu.Unlock()\n97: \tif c, ok := lb.connections[url]; ok {\n98: \t\tc.Add(-1)\n99: \t}\n100: }\n\n(End of file - total 100 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"errors\"\n\t\"sync\"\n\t\"sync/atomic\"\n)\n\nvar ErrNoHealthyBackend = errors.New(\"no healthy backend available\")\n\ntype LoadBalancer interface {\n\tSelect(backends []Backend) (*Backend, error)\n}\n\ntype RoundRobinBalancer struct {\n\tmu      sync.Mutex\n\tcurrent int\n}\n\nfunc NewRoundRobinBalancer() *RoundRobinBalancer {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/loadbalancer.go","time":{"start":1775891104535,"end":1775891104542}}}}
