 \"runtime.agentcube.io/sandbox-name\"\n41: )\n42: \n43: const (\n44: \tAnnotationIdleTimeout    = \"runtime.agentcube.io/idle-timeout\"\n45: \tAnnotationSandboxPodName = \"agents.x-k8s.io/sandbox-pod-name\"\n46: )\n47: \n48: const (\n49: \tIdentitySecretName        = \"picod-router-identity\"\n50: \tPublicKeyDataKey          = \"public.pem\"\n51: \tDefaultSandboxTTL         = 8\n52: \tDefaultSandboxIdleTimeout = 15\n53: )\n\n(End of file - total 53 lines)\n</content>","metadata":{"preview":"package handler\n\nimport \"k8s.io/apimachinery/pkg/runtime/schema\"\n\nvar (\n\tAgentRuntimeGVR = schema.GroupVersionResource{\n\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n\t\tVersion:  \"v1alpha1\",\n\t\tResource: \"agentruntimes\",\n\t}\n\tCodeInterpreterGVR = schema.GroupVersionResource{\n\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n\t\tVersion:  \"v1alpha1\",\n\t\tResource: \"codeinterpreters\",\n\t}\n\tSandboxGVR = schema.GroupVersionResource{\n\t\tGroup:    \"agents.x-k8s.io\",\n\t\tVersion:  \"v1alpha1\",\n\t\tResource: \"sandboxes\",\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/constants.go","time":{"start":1775820183976,"end":1775820183983}}}}
