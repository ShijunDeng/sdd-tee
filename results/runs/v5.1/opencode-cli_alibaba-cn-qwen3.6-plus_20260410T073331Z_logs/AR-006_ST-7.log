{"type":"tool_use","timestamp":1775820181324,"sessionID":"ses_288deaa31ffeVP0mYhQq5K3nsM","part":{"id":"prt_d77218b4b00151Jul6vlNL85Sq","messageID":"msg_d772182de001tqrR2q3F2jwbFJ","sessionID":"ses_288deaa31ffeVP0mYhQq5K3nsM","type":"tool","tool":"read","callID":"call_e48d0d7b89d14c92a26dc95c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"time\"\n8: \n9: \t\"github.com/gin-gonic/gin\"\n10: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n11: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n12: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n13: \t\"k8s.io/client-go/dynamic\"\n14: \t\"k8s.io/client-go/informers\"\n15: \n16: \t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n17: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n18: )\n19: \n20: type SandboxDeleteHandlerDeps struct {\n21: \tDynamicClient   dynamic.Interface\n22: \tClientset       clientset.Interface\n23: \tInformerFactory informers.SharedInformerFactory\n24: \tStore           Store\n25: \tEnableAuth      bool\n26: \tTokenCache      TokenCache\n27: }\n28: \n29: type SandboxDeleteHandler struct {\n30: \tdynamicClient   dynamic.Interface\n31: \tclientset       clientset.Interface\n32: \tinformerFactory informers.SharedInformerFactory\n33: \tstore           Store\n34: \tenableAuth      bool\n35: \ttokenCache      TokenCache\n36: }\n37: \n38: func NewSandboxDeleteHandler(deps *SandboxDeleteHandlerDeps) *SandboxDeleteHandler {\n39: \treturn &SandboxDeleteHandler{\n40: \t\tdynamicClient:   deps.DynamicClient,\n41: \t\tclientset:       deps.Clientset,\n42: \t\tinformerFactory: deps.InformerFactory,\n43: \t\tstore:           deps.Store,\n44: \t\tenableAuth:      deps.EnableAuth,\n45: \t\ttokenCache:      deps.TokenCache,\n46: \t}\n47: }\n48: \n49: func (h *SandboxDeleteHandler) getDynamicClient(c *gin.Context) (dynamic.Interface, error) {\n50: \tif !h.enableAuth {\n51: \t\treturn h.dynamicClient, nil\n52: \t}\n53: \n54: \ttoken := c.GetHeader(\"Authorization\")\n55: \tif token == \"\" {\n56: \t\treturn nil, fmt.Errorf(\"authorization token is required\")\n57: \t}\n58: \tif len(token) > 7 && token[:7] == \"Bearer \" {\n59: \t\ttoken = token[7:]\n60: \t}\n61: \n62: \tnamespace := c.GetString(\"namespace\")\n63: \tsaName := c.GetString(\"serviceAccountName\")\n64: \n65: \tif h.tokenCache != nil {\n66: \t\treturn h.tokenCache.GetOrCreateUserK8sClient(namespace, saName, token)\n67: \t}\n68: \n69: \treturn nil, fmt.Errorf(\"no token cache available\")\n70: }\n71: \n72: type DeleteSandboxRequest struct {\n73: \tSessionID string `json:\"sessionId\"`\n74: \tNamespace string `json:\"namespace\"`\n75: }\n76: \n77: func (r *DeleteSandboxRequest) Validate() error {\n78: \tif r.SessionID == \"\" {\n79: \t\treturn fmt.Errorf(\"sessionId is required\")\n80: \t}\n81: \tif r.Namespace == \"\" {\n82: \t\treturn fmt.Errorf(\"namespace is required\")\n83: \t}\n84: \treturn nil\n85: }\n86: \n87: type DeleteSandboxResponse struct {\n88: \tSessionID   string `json:\"sessionId\"`\n89: \tSandboxName string `json:\"sandboxName\"`\n90: \tDeleted     bool   `json:\"deleted\"`\n91: \tMessage     string `json:\"message,omitempty\"`\n92: }\n93: \n94: func (h *SandboxDeleteHandler) DeleteSandbox(c *gin.Context) {\n95: \tvar req DeleteSandboxRequest\n96: \tif err := c.ShouldBindJSON(&req); err != nil {\n97: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n98: \t\treturn\n99: \t}\n100: \n101: \tif err := req.Validate(); err != nil {\n102: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n103: \t\treturn\n104: \t}\n105: \n106: \tsandboxInfo, err := h.store.GetSandbox(c.Request.Context(), req.SessionID)\n107: \tif err != nil {\n108: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox session %s not found\", req.SessionID))\n109: \t\treturn\n110: \t}\n111: \n112: \tgvr, err := h.resolveGVR(sandboxInfo.Kind)\n113: \tif err != nil {\n114: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n115: \t\treturn\n116: \t}\n117: \n118: \tdynClient, err := h.getDynamicClient(c)\n119: \tif err != nil {\n120: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n121: \t\treturn\n122: \t}\n123: \n124: \tdeleteCtx, cancel := context.WithTimeout(c.Request.Context(), 30*time.Second)\n125: \tdefer cancel()\n126: \n127: \terr = dynClient.Resource(gvr).Namespace(sandboxInfo.Namespace).Delete(deleteCtx, sandboxInfo.SandboxName, metav1.DeleteOptions{})\n128: \tif err != nil {\n129: \t\tif apierrors.IsNotFound(err) {\n130: \t\t\tif err := h.store.DeleteSandbox(c.Request.Context(), req.SessionID); err != nil {\n131: \t\t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"failed to cleanup sandbox from store\")\n132: \t\t\t\treturn\n133: \t\t\t}\n134: \t\t\tresponse.JSON(c, http.StatusOK, &DeleteSandboxResponse{\n135: \t\t\t\tSessionID:   req.SessionID,\n136: \t\t\t\tSandboxName: sandboxInfo.SandboxName,\n137: \t\t\t\tDeleted:     true,\n138: \t\t\t\tMessage:     \"sandbox already deleted, cleaned up from store\",\n139: \t\t\t})\n140: \t\t\treturn\n141: \t\t}\n142: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, fmt.Sprintf(\"failed to delete sandbox: %v\", err))\n143: \t\treturn\n144: \t}\n145: \n146: \tif err := h.store.DeleteSandbox(c.Request.Context(), req.SessionID); err != nil {\n147: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, fmt.Sprintf(\"sandbox deleted but failed to cleanup store: %v\", err))\n148: \t\treturn\n149: \t}\n150: \n151: \tresponse.JSON(c, http.StatusOK, &DeleteSandboxResponse{\n152: \t\tSessionID:   req.SessionID,\n153: \t\tSandboxName: sandboxInfo.SandboxName,\n154: \t\tDeleted:     true,\n155: \t})\n156: }\n157: \n158: func (h *SandboxDeleteHandler) DeleteSandboxByName(c *gin.Context) {\n159: \tname := c.Param(\"name\")\n160: \tif name == \"\" {\n161: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"sandbox name is required\")\n162: \t\treturn\n163: \t}\n164: \n165: \tnamespace := c.Query(\"namespace\")\n166: \tif namespace == \"\" {\n167: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"namespace query parameter is required\")\n168: \t\treturn\n169: \t}\n170: \n171: \tkind := c.Query(\"kind\")\n172: \tif kind == \"\" {\n173: \t\tkind = SandboxesKind\n174: \t}\n175: \n176: \tgvr, err := h.resolveGVR(kind)\n177: \tif err != nil {\n178: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n179: \t\treturn\n180: \t}\n181: \n182: \tdynClient, err := h.getDynamicClient(c)\n183: \tif err != nil {\n184: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n185: \t\treturn\n186: \t}\n187: \n188: \tdeleteCtx, cancel := context.WithTimeout(c.Request.Context(), 30*time.Second)\n189: \tdefer cancel()\n190: \n191: \terr = dynClient.Resource(gvr).Namespace(namespace).Delete(deleteCtx, name, metav1.DeleteOptions{})\n192: \tif err != nil {\n193: \t\tif apierrors.IsNotFound(err) {\n194: \t\t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"sandbox %s/%s not found\", namespace, name))\n195: \t\t\treturn\n196: \t\t}\n197: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, fmt.Sprintf(\"failed to delete sandbox: %v\", err))\n198: \t\treturn\n199: \t}\n200: \n201: \tresponse.JSON(c, http.StatusOK, &DeleteSandboxResponse{\n202: \t\tSandboxName: name,\n203: \t\tDeleted:     true,\n204: \t})\n205: }\n206: \n207: func (h *SandboxDeleteHandler) resolveGVR(kind string) (schema.GroupVersionResource, error) {\n208: \tswitch kind {\n209: \tcase SandboxesKind:\n210: \t\treturn SandboxGVR, nil\n211: \tcase SandboxClaimsKind:\n212: \t\treturn SandboxClaimGVR, nil\n213: \tdefault:\n214: \t\treturn schema.GroupVersionResource{}, fmt.Errorf(\"unknown sandbox kind: %s\", kind)\n215: \t}\n216: }\n\n(End of file - total 216 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/informers\"\n\n\t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/response\"\n)\n\ntype SandboxDeleteHandlerDeps struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete.go","time":{"start":1775820181315,"end":1775820181323}}}}
{"type":"tool_use","timestamp":1775820182668,"sessionID":"ses_288deaa31ffeVP0mYhQq5K3nsM","part":{"id":"prt_d77218fc6001Ux4tvNUqxR4Yp3","messageID":"msg_d772182de001tqrR2q3F2jwbFJ","sessionID":"ses_288deaa31ffeVP0mYhQq5K3nsM","type":"tool","tool":"read","callID":"call_4d1d25d4323c494fb6fc309d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"encoding/json\"\n7: \t\"errors\"\n8: \t\"net/http\"\n9: \t\"net/http/httptest\"\n10: \t\"testing\"\n11: \t\"time\"\n12: \n13: \t\"github.com/gin-gonic/gin\"\n14: \t\"github.com/stretchr/testify/assert\"\n15: \t\"github.com/stretchr/testify/require\"\n16: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n17: )\n18: \n19: type mockStore struct {\n20: \tsandboxes map[string]*SandboxInfo\n21: }\n22: \n23: func newMockStore() *mockStore {\n24: \treturn &mockStore{\n25: \t\tsandboxes: make(map[string]*SandboxInfo),\n26: \t}\n27: }\n28: \n29: func (m *mockStore) StoreSandbox(ctx context.Context, info *SandboxInfo) error {\n30: \tm.sandboxes[info.SessionID] = info\n31: \treturn nil\n32: }\n33: \n34: func (m *mockStore) UpdateSandbox(ctx context.Context, sessionID string, info *SandboxInfo) error {\n35: \tif _, exists := m.sandboxes[sessionID]; !exists {\n36: \t\treturn errors.New(\"sandbox not found\")\n37: \t}\n38: \tm.sandboxes[sessionID] = info\n39: \treturn nil\n40: }\n41: \n42: func (m *mockStore) GetSandbox(ctx context.Context, sessionID string) (*SandboxInfo, error) {\n43: \tinfo, exists := m.sandboxes[sessionID]\n44: \tif !exists {\n45: \t\treturn nil, errors.New(\"sandbox not found\")\n46: \t}\n47: \treturn info, nil\n48: }\n49: \n50: func (m *mockStore) DeleteSandbox(ctx context.Context, sessionID string) error {\n51: \tif _, exists := m.sandboxes[sessionID]; !exists {\n52: \t\treturn errors.New(\"sandbox not found\")\n53: \t}\n54: \tdelete(m.sandboxes, sessionID)\n55: \treturn nil\n56: }\n57: \n58: func (m *mockStore) ListSandboxes(ctx context.Context) ([]*SandboxInfo, error) {\n59: \tresult := make([]*SandboxInfo, 0, len(m.sandboxes))\n60: \tfor _, info := range m.sandboxes {\n61: \t\tresult = append(result, info)\n62: \t}\n63: \treturn result, nil\n64: }\n65: \n66: func TestDeleteSandboxRequest_Validate_SessionIDRequired(t *testing.T) {\n67: \treq := &DeleteSandboxRequest{\n68: \t\tNamespace: \"default\",\n69: \t}\n70: \terr := req.Validate()\n71: \tassert.Error(t, err)\n72: \tassert.Contains(t, err.Error(), \"sessionId is required\")\n73: }\n74: \n75: func TestDeleteSandboxRequest_Validate_NamespaceRequired(t *testing.T) {\n76: \treq := &DeleteSandboxRequest{\n77: \t\tSessionID: \"test-session\",\n78: \t}\n79: \terr := req.Validate()\n80: \tassert.Error(t, err)\n81: \tassert.Contains(t, err.Error(), \"namespace is required\")\n82: }\n83: \n84: func TestDeleteSandboxRequest_Validate_Valid(t *testing.T) {\n85: \treq := &DeleteSandboxRequest{\n86: \t\tSessionID: \"test-session\",\n87: \t\tNamespace: \"default\",\n88: \t}\n89: \terr := req.Validate()\n90: \tassert.NoError(t, err)\n91: }\n92: \n93: func TestSandboxDeleteHandler_ResolveGVR_Sandboxes(t *testing.T) {\n94: \thandler := &SandboxDeleteHandler{}\n95: \tgvr, err := handler.resolveGVR(SandboxesKind)\n96: \trequire.NoError(t, err)\n97: \tassert.Equal(t, SandboxGVR, gvr)\n98: }\n99: \n100: func TestSandboxDeleteHandler_ResolveGVR_SandboxClaims(t *testing.T) {\n101: \thandler := &SandboxDeleteHandler{}\n102: \tgvr, err := handler.resolveGVR(SandboxClaimsKind)\n103: \trequire.NoError(t, err)\n104: \tassert.Equal(t, SandboxClaimGVR, gvr)\n105: }\n106: \n107: func TestSandboxDeleteHandler_ResolveGVR_UnknownKind(t *testing.T) {\n108: \thandler := &SandboxDeleteHandler{}\n109: \t_, err := handler.resolveGVR(\"UnknownKind\")\n110: \tassert.Error(t, err)\n111: \tassert.Contains(t, err.Error(), \"unknown sandbox kind\")\n112: }\n113: \n114: func TestDeleteSandbox_InvalidRequestBody(t *testing.T) {\n115: \tgin.SetMode(gin.ReleaseMode)\n116: \tw := httptest.NewRecorder()\n117: \tc, _ := gin.CreateTestContext(w)\n118: \tc.Request = httptest.NewRequest(http.MethodPost, \"/delete\", nil)\n119: \n120: \tstore := newMockStore()\n121: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{\n122: \t\tStore: store,\n123: \t})\n124: \n125: \thandler.DeleteSandbox(c)\n126: \n127: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n128: \n129: \tvar resp map[string]interface{}\n130: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n131: \trequire.NoError(t, err)\n132: \tassert.Equal(t, \"Invalid request body\", resp[\"error\"])\n133: }\n134: \n135: func TestDeleteSandbox_MissingSessionID(t *testing.T) {\n136: \tgin.SetMode(gin.ReleaseMode)\n137: \tw := httptest.NewRecorder()\n138: \tc, _ := gin.CreateTestContext(w)\n139: \tc.Request = httptest.NewRequest(http.MethodPost, \"/delete\", bytes.NewBufferString(`{\"namespace\": \"default\"}`))\n140: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n141: \n142: \tstore := newMockStore()\n143: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{\n144: \t\tStore: store,\n145: \t})\n146: \n147: \thandler.DeleteSandbox(c)\n148: \n149: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n150: }\n151: \n152: func TestDeleteSandbox_SessionNotFound(t *testing.T) {\n153: \tgin.SetMode(gin.ReleaseMode)\n154: \tw := httptest.NewRecorder()\n155: \tc, _ := gin.CreateTestContext(w)\n156: \tc.Request = httptest.NewRequest(http.MethodPost, \"/delete\", bytes.NewBufferString(`{\"sessionId\": \"nonexistent\", \"namespace\": \"default\"}`))\n157: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n158: \n159: \tstore := newMockStore()\n160: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{\n161: \t\tStore: store,\n162: \t})\n163: \n164: \thandler.DeleteSandbox(c)\n165: \n166: \tassert.Equal(t, http.StatusNotFound, w.Code)\n167: }\n168: \n169: func TestDeleteSandboxByName_MissingName(t *testing.T) {\n170: \tgin.SetMode(gin.ReleaseMode)\n171: \tw := httptest.NewRecorder()\n172: \tc, _ := gin.CreateTestContext(w)\n173: \tc.Request = httptest.NewRequest(http.MethodDelete, \"/sandboxes/\", nil)\n174: \tc.Params = gin.Params{{Key: \"name\", Value: \"\"}}\n175: \n176: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{})\n177: \n178: \thandler.DeleteSandboxByName(c)\n179: \n180: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n181: }\n182: \n183: func TestDeleteSandboxByName_MissingNamespace(t *testing.T) {\n184: \tgin.SetMode(gin.ReleaseMode)\n185: \tw := httptest.NewRecorder()\n186: \tc, _ := gin.CreateTestContext(w)\n187: \tc.Request = httptest.NewRequest(http.MethodDelete, \"/sandboxes/test-sandbox\", nil)\n188: \tc.Params = gin.Params{{Key: \"name\", Value: \"test-sandbox\"}}\n189: \tc.Request.URL.RawQuery = \"\"\n190: \n191: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{})\n192: \n193: \thandler.DeleteSandboxByName(c)\n194: \n195: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n196: }\n197: \n198: func TestDeleteSandboxResponse_JSONSerialization(t *testing.T) {\n199: \tresp := &DeleteSandboxResponse{\n200: \t\tSessionID:   \"test-session\",\n201: \t\tSandboxName: \"test-sandbox\",\n202: \t\tDeleted:     true,\n203: \t\tMessage:     \"sandbox deleted successfully\",\n204: \t}\n205: \n206: \tdata, err := json.Marshal(resp)\n207: \trequire.NoError(t, err)\n208: \n209: \tvar decoded DeleteSandboxResponse\n210: \terr = json.Unmarshal(data, &decoded)\n211: \trequire.NoError(t, err)\n212: \n213: \tassert.Equal(t, resp.SessionID, decoded.SessionID)\n214: \tassert.Equal(t, resp.SandboxName, decoded.SandboxName)\n215: \tassert.Equal(t, resp.Deleted, decoded.Deleted)\n216: \tassert.Equal(t, resp.Message, decoded.Message)\n217: }\n218: \n219: func TestSandboxInfo_WithAllFields(t *testing.T) {\n220: \tnow := time.Now()\n221: \texpiresAt := now.Add(8 * time.Hour)\n222: \n223: \tinfo := &SandboxInfo{\n224: \t\tSessionID:    \"session-123\",\n225: \t\tSandboxName:  \"sandbox-abc\",\n226: \t\tSandboxID:    \"uid-456\",\n227: \t\tWorkloadName: \"my-runtime\",\n228: \t\tNamespace:    \"default\",\n229: \t\tKind:         SandboxesKind,\n230: \t\tPodIP:        \"10.0.0.1\",\n231: \t\tEntryPoints: []EntryPoint{\n232: \t\t\t{Path: \"/\", Protocol: \"HTTP\", Endpoint: \"10.0.0.1:8080\"},\n233: \t\t},\n234: \t\tCreatedAt: now,\n235: \t\tExpiresAt: expiresAt,\n236: \t\tStatus:    \"running\",\n237: \t}\n238: \n239: \tassert.Equal(t, \"session-123\", info.SessionID)\n240: \tassert.Equal(t, \"sandbox-abc\", info.SandboxName)\n241: \tassert.Equal(t, \"running\", info.Status)\n242: \tassert.False(t, info.ExpiresAt.IsZero())\n243: }\n244: \n245: func TestDeleteSandboxRequest_AllFieldsSet(t *testing.T) {\n246: \treq := &DeleteSandboxRequest{\n247: \t\tSessionID: \"session-123\",\n248: \t\tNamespace: \"test-namespace\",\n249: \t}\n250: \n251: \tassert.NoError(t, req.Validate())\n252: \tassert.Equal(t, \"session-123\", req.SessionID)\n253: \tassert.Equal(t, \"test-namespace\", req.Namespace)\n254: }\n255: \n256: func TestMockStore_StoreAndGet(t *testing.T) {\n257: \tstore := newMockStore()\n258: \tctx := context.Background()\n259: \n260: \tinfo := &SandboxInfo{\n261: \t\tSessionID:   \"test-session\",\n262: \t\tSandboxName: \"test-sandbox\",\n263: \t\tNamespace:   \"default\",\n264: \t\tKind:        SandboxesKind,\n265: \t\tCreatedAt:   time.Now(),\n266: \t\tStatus:      \"running\",\n267: \t}\n268: \n269: \terr := store.StoreSandbox(ctx, info)\n270: \trequire.NoError(t, err)\n271: \n272: \tretrieved, err := store.GetSandbox(ctx, \"test-session\")\n273: \trequire.NoError(t, err)\n274: \tassert.Equal(t, info.SessionID, retrieved.SessionID)\n275: \tassert.Equal(t, info.SandboxName, retrieved.SandboxName)\n276: }\n277: \n278: func TestMockStore_Update(t *testing.T) {\n279: \tstore := newMockStore()\n280: \tctx := context.Background()\n281: \n282: \tinfo := &SandboxInfo{\n283: \t\tSessionID:   \"test-session\",\n284: \t\tSandboxName: \"test-sandbox\",\n285: \t\tNamespace:   \"default\",\n286: \t\tKind:        SandboxesKind,\n287: \t\tCreatedAt:   time.Now(),\n288: \t\tStatus:      \"pending\",\n289: \t}\n290: \n291: \terr := store.StoreSandbox(ctx, info)\n292: \trequire.NoError(t, err)\n293: \n294: \tinfo.Status = \"running\"\n295: \terr = store.UpdateSandbox(ctx, \"test-session\", info)\n296: \trequire.NoError(t, err)\n297: \n298: \tretrieved, err := store.GetSandbox(ctx, \"test-session\")\n299: \trequire.NoError(t, err)\n300: \tassert.Equal(t, \"running\", retrieved.Status)\n301: }\n302: \n303: func TestMockStore_UpdateNonExistent(t *testing.T) {\n304: \tstore := newMockStore()\n305: \tctx := context.Background()\n306: \n307: \tinfo := &SandboxInfo{\n308: \t\tSessionID:   \"test-session\",\n309: \t\tSandboxName: \"test-sandbox\",\n310: \t}\n311: \n312: \terr := store.UpdateSandbox(ctx, \"nonexistent\", info)\n313: \tassert.Error(t, err)\n314: }\n315: \n316: func TestMockStore_Delete(t *testing.T) {\n317: \tstore := newMockStore()\n318: \tctx := context.Background()\n319: \n320: \tinfo := &SandboxInfo{\n321: \t\tSessionID:   \"test-session\",\n322: \t\tSandboxName: \"test-sandbox\",\n323: \t}\n324: \n325: \terr := store.StoreSandbox(ctx, info)\n326: \trequire.NoError(t, err)\n327: \n328: \terr = store.DeleteSandbox(ctx, \"test-session\")\n329: \trequire.NoError(t, err)\n330: \n331: \t_, err = store.GetSandbox(ctx, \"test-session\")\n332: \tassert.Error(t, err)\n333: }\n334: \n335: func TestMockStore_DeleteNonExistent(t *testing.T) {\n336: \tstore := newMockStore()\n337: \tctx := context.Background()\n338: \n339: \terr := store.DeleteSandbox(ctx, \"nonexistent\")\n340: \tassert.Error(t, err)\n341: }\n342: \n343: func TestMockStore_List(t *testing.T) {\n344: \tstore := newMockStore()\n345: \tctx := context.Background()\n346: \n347: \tstore.StoreSandbox(ctx, &SandboxInfo{SessionID: \"session-1\", SandboxName: \"sandbox-1\", Namespace: \"default\"})\n348: \tstore.StoreSandbox(ctx, &SandboxInfo{SessionID: \"session-2\", SandboxName: \"sandbox-2\", Namespace: \"test\"})\n349: \n350: \tlist, err := store.ListSandboxes(ctx)\n351: \trequire.NoError(t, err)\n352: \tassert.Len(t, list, 2)\n353: }\n354: \n355: func TestMockStore_ListEmpty(t *testing.T) {\n356: \tstore := newMockStore()\n357: \tctx := context.Background()\n358: \n359: \tlist, err := store.ListSandboxes(ctx)\n360: \trequire.NoError(t, err)\n361: \tassert.Empty(t, list)\n362: }\n363: \n364: func TestResolveGVR_AllKnownKinds(t *testing.T) {\n365: \thandler := &SandboxDeleteHandler{}\n366: \n367: \ttestCases := []struct {\n368: \t\tkind        string\n369: \t\texpectedGVR schema.GroupVersionResource\n370: \t\texpectError bool\n371: \t}{\n372: \t\t{SandboxesKind, SandboxGVR, false},\n373: \t\t{SandboxClaimsKind, SandboxClaimGVR, false},\n374: \t\t{\"Unknown\", schema.GroupVersionResource{}, true},\n375: \t\t{\"\", schema.GroupVersionResource{}, true},\n376: \t}\n377: \n378: \tfor _, tc := range testCases {\n379: \t\tgvr, err := handler.resolveGVR(tc.kind)\n380: \t\tif tc.expectError {\n381: \t\t\tassert.Error(t, err, \"kind: %s\", tc.kind)\n382: \t\t} else {\n383: \t\t\tassert.NoError(t, err, \"kind: %s\", tc.kind)\n384: \t\t\tassert.Equal(t, tc.expectedGVR, gvr, \"kind: %s\", tc.kind)\n385: \t\t}\n386: \t}\n387: }\n\n(End of file - total 387 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n)\n\ntype mockStore struct {\n\tsandboxes map[string]*SandboxInfo","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go","time":{"start":1775820182654,"end":1775820182666}}}}
