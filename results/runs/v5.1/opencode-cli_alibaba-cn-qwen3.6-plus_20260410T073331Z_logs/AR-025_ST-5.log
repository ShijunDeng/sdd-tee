fo.value).lower()\n+\n+\n class TestAgentMetadataValidateLanguage:\n     def test_python_lowercase(self) -> None:\n         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", language=\"python\")\n         assert meta.language == \"python\"\n@@ -118,4 +130,22 @@\n         assert \"build_mode\" in dumped\n         assert \"region\" not in dumped\n         assert \"version\" not in dumped\n         assert \"description\" not in dumped\n+\n+\n+class TestAgentMetadataOptionalDefaults:\n+    def test_optional_fields_default_to_none(self) -> None:\n+        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\")\n+        assert meta.description is None\n+        assert meta.region is None\n+        assert meta.version is None\n+        assert meta.image is None\n+        assert meta.auth is None\n+        assert meta.agent_endpoint is None\n+        assert meta.workload_manager_url is None\n+        assert meta.router_url is None\n+        assert meta.readiness_probe_path is None\n+        assert meta.readiness_probe_port is None\n+        assert meta.agent_id is None\n+        assert meta.session_id is None\n+        assert meta.k8s_deployment is None\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/services/test_metadata_model.py","before":"\"\"\"Tests for AgentMetadata Pydantic model.\"\"\"\n\nimport pytest\nfrom pydantic import ValidationError\n\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestAgentMetadataValidCreation:\n    def test_minimal_valid(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\")\n        assert meta.agent_name == \"test\"\n        assert meta.language == \"python\"\n        assert meta.entrypoint == \"python main.py\"\n        assert meta.port == 8080\n        assert meta.build_mode == \"local\"\n\n    def test_full_valid(self) -> None:\n        meta = AgentMetadata(\n            agent_name=\"full-agent\",\n            description=\"A full agent\",\n            language=\"java\",\n            entrypoint=\"java -jar app.jar\",\n            port=9090,\n            build_mode=\"cloud\",\n            region=\"us-east-1\",\n            version=\"1.0.0\",\n        )\n        assert meta.agent_name == \"full-agent\"\n        assert meta.description == \"A full agent\"\n        assert meta.language == \"java\"\n        assert meta.entrypoint == \"java -jar app.jar\"\n        assert meta.port == 9090\n        assert meta.build_mode == \"cloud\"\n        assert meta.region == \"us-east-1\"\n        assert meta.version == \"1.0.0\"\n\n\nclass TestAgentMetadataValidateLanguage:\n    def test_python_lowercase(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", language=\"python\")\n        assert meta.language == \"python\"\n\n    def test_python_uppercase_normalized(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", language=\"Python\")\n        assert meta.language == \"python\"\n\n    def test_java_lowercase(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"java -jar app.jar\", language=\"java\")\n        assert meta.language == \"java\"\n\n    def test_java_uppercase_normalized(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"java -jar app.jar\", language=\"Java\")\n        assert meta.language == \"java\"\n\n    def test_nodejs_rejected(self) -> None:\n        with pytest.raises(ValidationError) as exc_info:\n            AgentMetadata(agent_name=\"test\", entrypoint=\"node app.js\", language=\"nodejs\")\n        assert \"Unsupported language\" in str(exc_info.value)\n\n    def test_ruby_rejected(self) -> None:\n        with pytest.raises(ValidationError) as exc_info:\n            AgentMetadata(agent_name=\"test\", entrypoint=\"ruby app.rb\", language=\"ruby\")\n        assert \"Unsupported language\" in str(exc_info.value)\n\n\nclass TestAgentMetadataValidateBuildMode:\n    def test_local_accepted(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"local\")\n        assert meta.build_mode == \"local\"\n\n    def test_cloud_accepted(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"cloud\")\n        assert meta.build_mode == \"cloud\"\n\n    def test_local_uppercase_normalized(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"LOCAL\")\n        assert meta.build_mode == \"local\"\n\n    def test_hybrid_rejected(self) -> None:\n        with pytest.raises(ValidationError) as exc_info:\n            AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"hybrid\")\n        assert \"Unsupported build_mode\" in str(exc_info.value)\n\n\nclass TestAgentMetadataValidatePort:\n    def test_valid_port(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=8080)\n        assert meta.port == 8080\n\n    def test_port_one(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=1)\n        assert meta.port == 1\n\n    def test_port_max(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=65535)\n        assert meta.port == 65535\n\n    def test_port_zero_rejected(self) -> None:\n        with pytest.raises(ValidationError) as exc_info:\n            AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=0)\n        assert \"Port must be between 1 and 65535\" in str(exc_info.value)\n\n    def test_port_overflow_rejected(self) -> None:\n        with pytest.raises(ValidationError) as exc_info:\n            AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=70000)\n        assert \"Port must be between 1 and 65535\" in str(exc_info.value)\n\n\nclass TestAgentMetadataModelDump:\n    def test_exclude_none(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\")\n        dumped = meta.model_dump(exclude_none=True)\n        assert \"agent_name\" in dumped\n        assert \"entrypoint\" in dumped\n        assert \"language\" in dumped\n        assert \"port\" in dumped\n        assert \"build_mode\" in dumped\n        assert \"region\" not in dumped\n        assert \"version\" not in dumped\n        assert \"description\" not in dumped\n","after":"\"\"\"Tests for AgentMetadata Pydantic model.\"\"\"\n\nimport pytest\nfrom pydantic import ValidationError\n\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestAgentMetadataValidCreation:\n    def test_minimal_valid(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\")\n        assert meta.agent_name == \"test\"\n        assert meta.language == \"python\"\n        assert meta.entrypoint == \"python main.py\"\n        assert meta.port == 8080\n        assert meta.build_mode == \"local\"\n\n    def test_full_valid(self) -> None:\n        meta = AgentMetadata(\n            agent_name=\"full-agent\",\n            description=\"A full agent\",\n            language=\"java\",\n            entrypoint=\"java -jar app.jar\",\n            port=9090,\n            build_mode=\"cloud\",\n            region=\"us-east-1\",\n            version=\"1.0.0\",\n        )\n        assert meta.agent_name == \"full-agent\"\n        assert meta.description == \"A full agent\"\n        assert meta.language == \"java\"\n        assert meta.entrypoint == \"java -jar app.jar\"\n        assert meta.port == 9090\n        assert meta.build_mode == \"cloud\"\n        assert meta.region == \"us-east-1\"\n        assert meta.version == \"1.0.0\"\n\n\nclass TestAgentMetadataRequiredFields:\n    def test_missing_agent_name_raises(self) -> None