etadataService:\n    return MetadataService()\n\n\n@pytest.fixture\ndef workspace_with_primary(tmp_path: Path) -> Path:\n    ws = tmp_path / \"ws-primary\"\n    ws.mkdir()\n    (ws / \"agent_metadata.yaml\").write_text(\n        \"agent_name: primary-agent\\nlanguage: python\\nentrypoint: python main.py\\nport: 8080\\nbuild_mode: local\\n\"\n    )\n    (ws / \"main.py\").write_text(\"print('hello')\\n\")\n    return ws\n\n\n@pytest.fixture\ndef workspace_with_fallback1(tmp_path: Path) -> Path:\n    ws = tmp_path / \"ws-fb1\"\n    ws.mkdir()\n    (ws / \"agent.yaml\").write_text(\n        \"agent_name: fallback1-agent\\nlanguage: java\\nentrypoint: java -jar app.jar\\nport: 9090\\nbuild_mode: cloud\\n\"\n    )\n    (ws / \"pom.xml\").write_text(\"<project></project>\\n\")\n    return ws\n\n\n@pytest.fixture\ndef workspace_with_fallback2(tmp_path: Path) -> Path:\n    ws = tmp_path / \"ws-fb2\"\n    ws.mkdir()\n    (ws / \"metadata.yaml\").write_text(\n        \"agent_name: fallback2-agent\\nlanguage: python\\nentrypoint: python app.py\\nport: 3000\\nbuild_mode: local\\n\"\n    )\n    (ws / \"app.py\").write_text(\"print('hi')\\n\")\n    return ws\n\n\n@pytest.fixture\ndef empty_workspace(tmp_path: Path) -> Path:\n    ws = tmp_path / \"ws-empty\"\n    ws.mkdir()\n    return ws\n\n\nclass TestLoadMetadataPrimaryExists:\n    def test_loads_primary(self, workspace_with_primary: Path, service: MetadataService) -> None:\n        meta = service.load_metadata(workspace_with_primary)\n        assert meta is not None\n        assert meta.agent_name == \"primary-agent\"\n        assert meta.language == \"python\"\n        assert meta.entrypoint == \"python main.py\"\n\n\nclass TestLoadMetadataFirstFallback:\n    def test_loads_fallback1(self, workspace_with_fallback1: Path, service: MetadataService) -> None:\n        meta = service.load_metadata(workspace_with_fallback1)\n        assert meta is not None\n        assert meta.agent_name == \"fallback1-agent\"\n        assert meta.language == \"java\"\n\n\nclass TestLoadMetadataSecondFallback:\n    def test_loads_fallback2(self, workspace_with_fallback2: Path, service: MetadataService) -> None:\n        meta = service.load_metadata(workspace_with_fallback2)\n        assert meta is not None\n        assert meta.agent_name == \"fallback2-agent\"\n        assert meta.language == \"python\"\n\n\nclass TestLoadMetadataNoneExist:\n    def test_returns_none(self, empty_workspace: Path, service: MetadataService) -> None:\n        meta = service.load_metadata(empty_workspace)\n        assert meta is None\n\n\nclass TestLoadMetadataInvalidYaml:\n    def test_malformed_yaml_raises(self, tmp_path: Path, service: MetadataService) -> None:\n        ws = tmp_path / \"ws-invalid\"\n        ws.mkdir()\n        (ws / \"agent_metadata.yaml\").write_text(\"agent_name: [invalid yaml\\n  broken: {\")\n        with pytest.raises(yaml.YAMLError):\n            service.load_metadata(ws)\n\n\nclass TestLoadMetadataValidationFailure:\n    def test_unsupported_language_raises(self, tmp_path: Path, service: MetadataService) -> None:\n        from pydantic import ValidationError\n        ws = tmp_path / \"ws-bad-lang\"\n        ws.mkdir()\n        (ws / \"agent_metadata.yaml\").write_text(\n            \"agent_name: bad-lang-agent\\nlanguage: rust\\nentrypoint: cargo run\\n\"\n        )\n        with pytest.raises(ValidationError) as exc_info:\n            service.load_metadata(ws)\n        assert \"Unsupported language\" in str(exc_info.value)\n\n\nclass TestLoadMetadataVerbose:\n    def test_verbose_logs_on_load(self, tmp_path: Path, caplog: pytest.LogCaptureFixture) -> None:\n        import logging\n        ws = tmp_path / \"ws-verbose\"\n        ws.mkdir()\n        (ws / \"agent_metadata.yaml\").write_text(\n            \"agent_name: verbose-agent\\nentrypoint: python main.py\\n\"\n        )\n        service = MetadataService(verbose=True)\n        with caplog.at_level(logging.INFO, logger=\"agentcube.services.metadata_service\"):\n            service.load_metadata(ws)\n        assert \"Loaded metadata from\" in caplog.text\n\n\nclass TestSaveMetadataRoundTrip:\n    def test_save_and_load(self, empty_workspace: Path, service: MetadataService) -> None:\n        meta = AgentMetadata(agent_name=\"roundtrip\", entrypoint=\"python main.py\", port=9090)\n        service.save_metadata(empty_workspace, meta)\n        loaded = service.load_metadata(empty_workspace)\n        assert loaded is not None\n        assert loaded.agent_name == \"roundtrip\"\n        assert loaded.port == 9090\n\n\nclass TestSaveMetadataExcludeNone:\n    def test_no_null_values(self, empty_workspace: Path, service: MetadataService) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\")\n        service.save_metadata(empty_workspace, meta)\n        content = (empty_workspace / \"agent_metadata.yaml\").read_text()\n        data = yaml.safe_load(content)\n        assert \"null\" not in content.lower() or None not in data.values()\n        assert \"region\" not in data\n        assert \"version\" not in data\n\n\nclass TestSaveMetadataFormat:\n    def test_yaml_format(self, empty_workspace: Path, service: MetadataService) -> None:\n        meta = AgentMetadata(\n            agent_name=\"format-test\",\n            entrypoint=\"python main.py\",\n            image={\"name\": \"test\", \"tag\": \"latest\"},\n        )\n        service.save_metadata(empty_workspace, meta)\n        content = (empty_workspace / \"agent_metadata.yaml\").read_text()\n        assert \"  \" in content\n        lines = content.splitlines()\n        for line in lines:\n            if line and not line.startswith(\"#\"):\n                assert line == line.rstrip()\n\n\nclass TestSaveMetadataVerbose:\n    def test_verbose_logs_on_save(self, empty_workspace: Path, caplog: pytest.LogCaptureFixture) -> None:\n        import logging\n        meta = AgentMetadata(agent_name=\"verbose-save\", entrypoint=\"python main.py\")\n        service = MetadataService(verbose=True)\n        with caplog.at_level(logging.INFO, logger=\"agentcube.services.metadata_service\"):\n            service.save_metadata(empty_workspace, meta)\n        assert \"Saved metadata to\" in caplog.text\n\n\nclass TestUpdateMetadataMerge:\n    def test_partial_update(self, workspace_with_primary: Path, service: MetadataService) -> None:\n        updated = service.update_metadata(workspace_with_primary, {\"port\": 9999})\n        assert updated.agent_name == \"primary-agent\"\n        assert updated.port == 9999\n        assert updated.language == \"python\"\n\n\nclass TestUpdateMetadataCreateNew:\n    def test_creates_new_when_no_file(self, empty_workspace: Path, service: MetadataService) -> None:\n        updated = service.update_metadata(\n            empty_workspace,\n            {\"agent_name\": \"new-agent\", \"entrypoint\": \"python main.py\", \"language\": \"python\", \"port\": 8080, \"build_mode\": \"local\"},\n        )\n        assert updated.agent_name == \"new-agent\"\n        assert (empty_workspace / \"agent_metadata.yaml\").exists()\n\n\nclass TestUpdateMetadataInvalidValues:\n    def test_invalid_port_raises(self, workspace_with_primary: Path, service: MetadataService) -> None:\n        from pydantic import ValidationError\n        with pytest.raises(ValidationError) as exc_info:\n            service.update_metadata(workspace_with_primary, {\"port\": 99999})\n        assert \"Port must be between 1 and 65535\" in str(exc_info.value)\n\n\nclass TestUpdateMetadataVerbose:\n    def test_verbose_logs_on_update(self, workspace_with_primary: Path, caplog: pytest.LogCaptureFixture) -> None:\n        import logging\n        service = MetadataService(verbose=True)\n        with caplog.at_level(logging.INFO, logger=\"agentcube.services.metadata_service\"):\n            service.update_metadata(workspace_with_primary, {\"port\": 7070})\n        assert \"Updated metadata fields\" in caplog.text\n\n\nclass 