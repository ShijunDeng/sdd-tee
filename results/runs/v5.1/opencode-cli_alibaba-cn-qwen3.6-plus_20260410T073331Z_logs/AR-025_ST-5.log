aml\").write_text(\n43:         \"agent_name: fallback2-agent\\nlanguage: python\\nentrypoint: python app.py\\nport: 3000\\nbuild_mode: local\\n\"\n44:     )\n45:     (ws / \"app.py\").write_text(\"print('hi')\\n\")\n46:     return ws\n47: \n48: \n49: @pytest.fixture\n50: def empty_workspace(tmp_path: Path) -> Path:\n51:     ws = tmp_path / \"ws-empty\"\n52:     ws.mkdir()\n53:     return ws\n54: \n55: \n56: class TestLoadMetadataPrimaryExists:\n57:     def test_loads_primary(self, workspace_with_primary: Path, service: MetadataService) -> None:\n58:         meta = service.load_metadata(workspace_with_primary)\n59:         assert meta is not None\n60:         assert meta.agent_name == \"primary-agent\"\n61:         assert meta.language == \"python\"\n62:         assert meta.entrypoint == \"python main.py\"\n63: \n64: \n65: class TestLoadMetadataFirstFallback:\n66:     def test_loads_fallback1(self, workspace_with_fallback1: Path, service: MetadataService) -> None:\n67:         meta = service.load_metadata(workspace_with_fallback1)\n68:         assert meta is not None\n69:         assert meta.agent_name == \"fallback1-agent\"\n70:         assert meta.language == \"java\"\n71: \n72: \n73: class TestLoadMetadataSecondFallback:\n74:     def test_loads_fallback2(self, workspace_with_fallback2: Path, service: MetadataService) -> None:\n75:         meta = service.load_metadata(workspace_with_fallback2)\n76:         assert meta is not None\n77:         assert meta.agent_name == \"fallback2-agent\"\n78:         assert meta.language == \"python\"\n79: \n80: \n81: class TestLoadMetadataNoneExist:\n82:     def test_returns_none(self, empty_workspace: Path, service: MetadataService) -> None:\n83:         meta = service.load_metadata(empty_workspace)\n84:         assert meta is None\n85: \n86: \n87: class TestSaveMetadataRoundTrip:\n88:     def test_save_and_load(self, empty_workspace: Path, service: MetadataService) -> None:\n89:         meta = AgentMetadata(agent_name=\"roundtrip\", entrypoint=\"python main.py\", port=9090)\n90:         service.save_metadata(empty_workspace, meta)\n91:         loaded = service.load_metadata(empty_workspace)\n92:         assert loaded is not None\n93:         assert loaded.agent_name == \"roundtrip\"\n94:         assert loaded.port == 9090\n95: \n96: \n97: class TestSaveMetadataExcludeNone:\n98:     def test_no_null_values(self, empty_workspace: Path, service: MetadataService) -> None:\n99:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\")\n100:         service.save_metadata(empty_workspace, meta)\n101:         content = (empty_workspace / \"agent_metadata.yaml\").read_text()\n102:         data = yaml.safe_load(content)\n103:         assert \"null\" not in content.lower() or None not in data.values()\n104:         assert \"region\" not in data\n105:         assert \"version\" not in data\n106: \n107: \n108: class TestSaveMetadataFormat:\n109:     def test_yaml_format(self, empty_workspace: Path, service: MetadataService) -> None:\n110:         meta = AgentMetadata(agent_name=\"format-test\", entrypoint=\"python main.py\")\n111:         service.save_metadata(empty_workspace, meta)\n112:         content = (empty_workspace / \"agent_metadata.yaml\").read_text()\n113:         assert \"  \" in content\n114:         lines = content.splitlines()\n115:         for line in lines:\n116:             if line and not line.startswith(\"#\"):\n117:                 assert line == line.rstrip()\n118: \n119: \n120: class TestUpdateMetadataMerge:\n121:     def test_partial_update(self, workspace_with_primary: Path, service: MetadataService) -> None:\n122:         updated = service.update_metadata(workspace_with_primary, {\"port\": 9999})\n123:         assert updated.agent_name == \"primary-agent\"\n124:         assert updated.port == 9999\n125:         assert updated.language == \"python\"\n126: \n127: \n128: class TestUpdateMetadataCreateNew:\n129:     def test_creates_new_when_no_file(self, empty_workspace: Path, service: MetadataService) -> None:\n130:         updated = service.update_metadata(\n131:             empty_workspace,\n132:             {\"agent_name\": \"new-agent\", \"entrypoint\": \"python main.py\", \"language\": \"python\", \"port\": 8080, \"build_mode\": \"local\"},\n133:         )\n134:         assert updated.agent_name == \"new-agent\"\n135:         assert (empty_workspace / \"agent_metadata.yaml\").exists()\n\n(End of file - total 135 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for MetadataService.\"\"\"\n\nfrom pathlib import Path\n\nimport pytest\nimport yaml\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\n@pytest.fixture\ndef service() -> MetadataService:\n    return MetadataService()\n\n\n@pytest.fixture\ndef workspace_with_primary(tmp_path: Path) -> Path:\n    ws = tmp_path / \"ws-primary\"\n    ws.mkdir()\n    (ws / \"agent_metadata.yaml\").write_text(","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/services/test_metadata_service.py","time":{"start":1775859943476,"end":1775859943484}}}}
