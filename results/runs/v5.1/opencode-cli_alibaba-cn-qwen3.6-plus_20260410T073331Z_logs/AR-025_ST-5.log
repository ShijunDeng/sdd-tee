:\n76:         options = {\n77:             \"agent_name\": \"test\",\n78:             \"unknown_field\": \"should_be_ignored\",\n79:             \"another_unknown\": 42,\n80:         }\n81:         opts = MetadataOptions.from_options(options)\n82:         assert opts.agent_name == \"test\"\n83:         assert not hasattr(opts, \"unknown_field\")\n84: \n85:     def test_empty_options(self) -> None:\n86:         opts = MetadataOptions.from_options({})\n87:         assert opts.agent_name is None\n88:         assert opts.language == \"python\"\n89:         assert opts.port == 8080\n\n(End of file - total 89 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for MetadataOptions dataclass.\"\"\"\n\nfrom dataclasses import asdict\n\nimport pytest\n\nfrom agentcube.models.pack_models import MetadataOptions\n\n\nclass TestMetadataOptionsDefaults:\n    def test_default_values(self) -> None:\n        opts = MetadataOptions()\n        assert opts.agent_name is None\n        assert opts.language == \"python\"\n        assert opts.entrypoint is None\n        assert opts.port == 8080\n        assert opts.build_mode == \"local\"\n        assert opts.requirements_file is None\n        assert opts.description is None\n        assert opts.workload_manager_url == \"\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/models/test_pack_models.py","time":{"start":1775859946070,"end":1775859946088}}}}
