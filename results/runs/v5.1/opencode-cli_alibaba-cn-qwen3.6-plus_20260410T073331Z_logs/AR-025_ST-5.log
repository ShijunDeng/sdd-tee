osoft/pyright/blob/main/docs/configuration.md#reportCallIssue"}},{"range":{"start":{"line":105,"character":12},"end":{"line":105,"character":85}},"message":"Arguments missing for parameters \"description\", \"language\", \"build_mode\", \"region\", \"version\", \"image\", \"auth\", \"requirements_file\", \"registry_url\", \"registry_username\", \"registry_password\", \"agent_endpoint\", \"workload_manager_url\", \"router_url\", \"readiness_probe_path\", \"readiness_probe_port\", \"agent_id\", \"session_id\", \"k8s_deployment\"","severity":1,"code":"reportCallIssue","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportCallIssue"}},{"range":{"start":{"line":111,"character":15},"end":{"line":111,"character":76}},"message":"Arguments missing for parameters \"description\", \"language\", \"port\", \"build_mode\", \"region\", \"version\", \"image\", \"auth\", \"requirements_file\", \"registry_url\", \"registry_username\", \"registry_password\", \"agent_endpoint\", \"workload_manager_url\", \"router_url\", \"readiness_probe_path\", \"readiness_probe_port\", \"agent_id\", \"session_id\", \"k8s_deployment\"","severity":1,"code":"reportCallIssue","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportCallIssue"}}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/models/test_pack_models.py":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py\n@@ -115,8 +115,10 @@\n             build_mode=updates.get(\"build_mode\", \"local\"),\n         )\n     merged = existing.model_copy(update=updates)\n     self.save_metadata(workspace_path, merged)\n+    if self.verbose:\n+        logger.info(f\"Updated metadata fields: {list(updates.keys())}\")\n     return merged\n \n def validate_workspace(self, workspace_path: Path) -> bool:\n     \"\"\"Check if the workspace has valid metadata.\"\"\"\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py","before":"\"\"\"Metadata service for loading, saving, and updating agent metadata.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\nlogger = logging.getLogger(__name__)\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Pydantic model representing agent metadata.\"\"\"\n\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: Optional[str] = Field(None, description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n    region: Optional[str] = Field(None, description=\"Deployment region\")\n    version: Optional[str] = Field(None, description=\"Semantic version string for publishing\")\n    image: Optional[Dict[str, Any]] = Field(None, description=\"Container image information\")\n    auth: Optional[Dict[str, Any]] = Field(None, description=\"Authentication configuration\")\n    requirements_file: Optional[str] = Field(\"requirements.txt\", description=\"Python dependency file\")\n    registry_url: Optional[str] = Field(\"\", description=\"Registry URL for image publishing\")\n    registry_username: Optional[str] = Field(\"\", description=\"Registry username\")\n    registry_password: Optional[str] = Field(\"\", description=\"Registry password\")\n    agent_endpoint: Optional[str] = Field(None, description=\"Agent endpoint URL\")\n    workload_manager_url: Optional[str] = Field(None, description=\"URL for the Workload Manager\")\n    router_url: Optional[str] = Field(None, description=\"URL for the Router\")\n    readiness_probe_path: Optional[str] = Field(None, description=\"Path for the readiness probe\")\n    readiness_probe_port: Optional[int] = Field(None, description=\"Port for the readiness probe\")\n    agent_id: Optional[str] = Field(None, description=\"Agent ID assigned by AgentCube\")\n    session_id: Optional[str] = Field(None, description=\"The session ID for the agent\")\n    k8s_deployment: Optional[Dict[str, Any]] = Field(None, description=\"Kubernetes deployment information\")\n\n    @field_validator(\"language\", mode=\"before\")\n    @classmethod\n    def validate_language(cls, v: Optional[str]) -> str:\n        if v is None:\n            return \"python\"\n        lowered = v.lower()\n        if lowered not in (\"python\", \"java\"):\n            raise ValueError(f\"Unsupported language: {v}. Must be 'python' or 'java'.\")\n        return lowered\n\n    @field_validator(\"build_mode\", mode=\"before\")\n    @classmethod\n    def validate_build_mode(cls, v: Optional[str]) -> str:\n        if v is None:\n            return \"local\"\n        lowered = v.lower()\n        if lowered not in (\"local\", \"cloud\"):\n            raise ValueError(f\"Unsupported build_mode: {v}. Must be 'local' or 'cloud'.\")\n        return lowered\n\n    @field_validator(\"port\")\n    @classmethod\n    def validate_port(cls, v: int) -> int:\n        if v < 1 or v > 65535:\n            raise ValueError(f\"Port must be between 1 and 65535, got {v}\")\n        return v\n\n\nclass MetadataService:\n    \"\"\"Service for loading, saving, and updating agent metadata files.\"\"\"\n\n    METADATA_FILES: List[str] = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose\n\n    def load_metadata(self, workspace_path: Path) -> Optional[AgentMetadata]:\n        \"\"\"Load agent metadata from the workspace directory.\n\n        Tries files in order: agent_metadata.yaml -> agent.yaml -> metadata.yaml.\n        Returns None if no metadata file exists.\n        \"\"\"\n        for filename in self.METADATA_FILES:\n            filepath = workspace_path / filename\n            if filepath.exists():\n                with open(filepath, \"r\") as f:\n                    data = yaml.safe_load(f)\n                if data is None:\n                    data = {}\n                if self.verbose:\n                    logger.info(f\"Loaded metadata from {filepath}\")\n                return AgentMetadata(**data)\n        if self.verbose:\n            logger.info(\"No metadata file found, using defaults\")\n        return None\n\n    def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Save agent metadata to agent_metadata.yaml in the workspace directory.\"\"\"\n        filepath = workspace_path / \"agent_metadata.yaml\"\n        data = metadata.model_dump(exclude_none=True)\n        with open(filepath, \"w\") as f:\n            yaml.dump(data, f, default_flow_style=False, indent=2, sort_keys=False)\n        if self.verbose:\n            logger.info(f\"Saved metadata to {filepath}\")\n\n    def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n        \"\"\"Load existing metadata (or create default), apply updates, save, and return.\"\"\"\n        existing = self.load_metadata(workspace_path)\n        if existing is None:\n            existing = AgentMetadata(\n                agent_name=updates.get(\"agent_name\", workspace_path.name),\n                entrypoint=updates.get(\"entrypoint\", \"\"),\n                language=updates.get(\"language\", \"python\"),\n                port=updates.get(\"port\", 8080),\n                build_mode=updates.get(\"build_mode\", \"local\"),\n            )\n        merged = existing.model_copy(update=updates)\n        self.save_metadata(workspace_path, merged)\n        return merged\n\n    def validate_workspace(self, workspace_path: Path) -> bool:\n        \"\"\"Check if the workspace has valid metadata.\"\"\"\n        return self.load_metadata(workspace_path) is not None\n\n    def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Validate a Python workspace has required files.\"\"\"\n        py_files = list(workspace_path.glob(\"*.py\"))\n        if not py_files:\n            raise ValueError(\"No Python files found in workspace\")\n        req_file = metadata.requirements_file or \"requirements.txt\"\n        req_path = workspace_path / req_file\n        if not req_path.exists():\n            raise ValueError(f\"Dependency file not found: {req_file}\")\n\n    def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Validate a Java workspace has required files.\"\"\"\n        pom = workspace_path / \"pom.xml\"\n        if not pom.exists():\n            raise ValueError(\"pom.xml is required for Java projects\")\n","after":"\"\"\"Metadata service for loading, saving, and updating agent metadata.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\nlogger = logging.getLogger(__name__)\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Pydantic model representing agent metadata.\"\"\"\n\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: Optional[str] = Field(None, description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n    region: Optional[str] = Field(None, description=\"Deployment region\")\n    version: Optional[str] = Field(None, description=\"Semantic version string for publishing\")\n    image: Optional[Dict[str, Any]] = Field(None, description=\"Container image information\")\n    auth: Optional[Dict[str, Any]] = Field(None, description=\"Authentication configuration\")\n    requirements_file: Optional[str] = Field(\"requirements.txt\", description=\"Python dependency file\")\n    registry_url: Optional[str] = Field(\"\", description=\"Registry URL for image publishing\")\n    registry_username: Optional[str] = Field(\"\", description=\"Registry username\")\n    registry_password: Optional[str] = Field(\"\", description=\"Registry password\")\n    agent_endpoint: Optional[str] = Field(None, description=\"Agent endpoint URL\")\n    workload_manager_url: Optional[str] = Field(None, description=\"URL for the Workload Manager\")\n    router_url: Optional[str] = Field(None, description=\"URL for the Router\")\n    readiness_probe_path: Optional[str] = Field(None, description=\"Path for the readiness probe\")\n    readiness_probe_port: Optional[int] = Field(None, description=\"Port for the readiness probe\")\n    agent_id: Optional[str] = Field(None, description=\"Agent ID assigned by AgentCube\")\n    session_id: Optional[str] = Field(None, description=\"The session ID for the agent\")\n    k8s_deployment: Optional[Dict[str, Any]] = Field(None, description=\"Kubernetes deployment information\")\n\n    @field_validator(\"language\", mode=\"before\")\n    @classmethod\n    def validate_language(cls, v: Optional[str]) -> str:\n        if v is None:\n            return \"python\"\n        lowered = v.lower()\n        if lowered not in (\"python\", \"java\"):\n            raise ValueError(f\"Unsupported language: {v}. Must be 'python' or 'java'.\")\n        return lowered\n\n    @field_validator(\"build_mode\", mode=\"before\")\n    @classmethod\n    def validate_build_mode(cls, v: Optional[str]) -> str:\n        if v is None:\n            return \"local\"\n        lowered = v.lower()\n        if lowered not in (\"local\", \"cloud\"):\n            raise ValueError(f\"Unsupported build_mode: {v}. Must be 'local' or 'cloud'.\")\n        return lowered\n\n    @field_validator(\"port\")\n    @classmethod\n    def validate_port(cls, v: int) -> int:\n        if v < 1 or v > 65535:\n            raise ValueError(f\"Port must be between 1 and 65535, got {v}\")\n        return v\n\n\nclass MetadataService:\n    \"\"\"Service for loading, saving, and updating agent metadata files.\"\"\"\n\n    METADATA_FILES: List[str] = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose\n\n    def load_metadata(self, workspace_path: Path) -> Optional[AgentMetadata]:\n        \"\"\"Load agent metadata from the workspace directory.\n\n        Tries files in order: agent_metadata.yaml -> agent.yaml -> metadata.yaml.\n        Returns None if no metadata file exists.\n        \"\"\"\n        for filename in self.METADATA_FILES:\n            filepath = workspace_path / filename\n            if filepath.exists():\n                with open(filepath, \"r\") as f:\n                    data = yaml.safe_load(f)\n                if data is None:\n                    data = {}\n                if self.verbose:\n                    logger.info(f\"Loaded metadata from {filepath}\")\n                return AgentMetadata(**data)\n        if self.verbose:\n            logger.info(\"No metadata file found, using defaults\")\n        return None\n\n    def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Save agent metadata to agent_metadata.yaml in the workspace directory.\"\"\"\n        filepath = workspace_path / \"agent_metadata.yaml\"\n        data = metadata.model_dump(exclude_none=True)\n        with open(filepath, \"w\") as f:\n            yaml.dump(data, f, default_flow_style=False, indent=2, sort_keys=False)\n        if self.verbose:\n            logger.info(f\"Saved metadata to {filepath}\")\n\n    def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n        \"\"\"Load existing metadata (or create default), apply updates, save, and return.\"\"\"\n        existing = self.load_metadata(workspace_path)\n        if existing is None:\n            existing = AgentMetadata(\n                agent_name=updates.get(\"agent_name\", workspace_path.name),\n                entrypoint=updates.get(\"entrypoint\", \"\"),\n                language=updates.get(\"language\", \"python\"),\n                port=updates.get(\"port\", 8080),\n                build_mode=updates.get(\"build_mode\", \"local\"),\n            )\n        merged = existing.model_copy(update=updates)\n        self.save_metadata(workspace_path, merged)\n        if self.verbose:\n            logger.info(f\"Updated metadata fields: {list(updates.keys())}\")\n        return merged\n\n    def validate_workspace(self, workspace_path: Path) -> bool:\n        \"\"\"Check if the workspace has valid metadata.\"\"\"\n        return self.load_metadata(workspace_path) is not None\n\n    def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Validate a Python workspace has required files.\"\"\"\n        py_files = list(workspace_path.glob(\"*.py\"))\n        if not py_files:\n            raise ValueError(\"No Python files found in workspace\")\n        req_file = metadata.requirements_file or \"requirements.txt\"\n        req_path = workspace_path / req_file\n        if not req_path.exists():\n            raise ValueError(f\"Dependency file not found: {req_file}\")\n\n    def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n        \"\"\"Validate a Java workspace has required files.\"\"\"\n        pom = workspace_path / \"pom.xml\"\n        if not pom.exists():\n            raise ValueError(\"pom.xml is required for Java projects\")\n","additions":2,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775860020334,"end":1775860021196}}}}
