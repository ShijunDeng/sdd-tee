ot set\")\n39: \t}\n40: \n41: \ttransport := &http.Transport{\n42: \t\tMaxIdleConnsPerHost: 100,\n43: \t\tDisableCompression:  false,\n44: \t}\n45: \tif err := http2.ConfigureTransport(transport); err == nil {\n46: \t\ttransport2 := transport.TLSClientConfig\n47: \t\t_ = transport2\n48: \t}\n49: \n50: \thttpClient := &http.Client{\n51: \t\tTimeout:   2 * time.Minute,\n52: \t\tTransport: transport,\n53: \t}\n54: \n55: \treturn &manager{\n56: \t\tstoreClient:     storeClient,\n57: \t\tworkloadMgrAddr: addr,\n58: \t\thttpClient:      httpClient,\n59: \t}, nil\n60: }\n61: \n62: func (m *manager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n63: \tif sessionID != \"\" {\n64: \t\tinfo, err := m.storeClient.GetSandbox(ctx, sessionID)\n65: \t\tif err != nil {\n66: \t\t\tif err == store.ErrNotFound {\n67: \t\t\t\treturn nil, NewSessionNotFoundError(sessionID)\n68: \t\t\t}\n69: \t\t\treturn nil, err\n70: \t\t}\n71: \t\treturn info, nil\n72: \t}\n73: \n74: \tnewInfo, err := m.createSandbox(ctx, namespace, name, kind)\n75: \tif err != nil {\n76: \t\treturn nil, err\n77: \t}\n78: \n79: \tif err := m.CreateSession(ctx, newInfo); err != nil {\n80: \t\treturn nil, err\n81: \t}\n82: \n83: \treturn newInfo, nil\n84: }\n85: \n86: func (m *manager) CreateSession(ctx context.Context, info *types.SandboxInfo) error {\n87: \treturn m.storeClient.StoreSandbox(ctx, info.SessionID, info)\n88: }\n89: \n90: func (m *manager) UpdateSession(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n91: \treturn m.storeClient.UpdateSandbox(ctx, sessionID, info)\n92: }\n93: \n94: func (m *manager) DeleteSession(ctx context.Context, sessionID string) error {\n95: \treturn m.storeClient.DeleteSandboxBySessionID(ctx, sessionID)\n96: }\n97: \n98: func (m *manager) UpdateLastActivity(ctx context.Context, sessionID string) error {\n99: \treturn m.storeClient.UpdateSessionLastActivity(ctx, sessionID, time.Now())\n100: }\n101: \n102: func (m *manager) ListSessions(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n103: \treturn m.storeClient.ListSandboxes(ctx)\n104: }\n105: \n106: func (m *manager) createSandbox(ctx context.Context, namespace, name, kind string) (*types.SandboxInfo, error) {\n107: \tvar endpoint string\n108: \tswitch kind {\n109: \tcase types.AgentRuntimeKind:\n110: \t\tendpoint = fmt.Sprintf(\"%s/v1/agent-runtime\", m.workloadMgrAddr)\n111: \tcase types.CodeInterpreterKind:\n112: \t\tendpoint = fmt.Sprintf(\"%s/v1/code-interpreter\", m.workloadMgrAddr)\n113: \tdefault:\n114: \t\tendpoint = fmt.Sprintf(\"%s/v1/agent-runtime\", m.workloadMgrAddr)\n115: \t}\n116: \n117: \treqBody := handler.CreateSandboxRequest{\n118: \t\tKind:      kind,\n119: \t\tName:      name,\n120: \t\tNamespace: namespace,\n121: \t}\n122: \tbodyBytes, err := json.Marshal(reqBody)\n123: \tif err != nil {\n124: \t\treturn nil, err\n125: \t}\n126: \n127: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(bodyBytes))\n128: \tif err != nil {\n129: \t\treturn nil, err\n130: \t}\n131: \treq.Header.Set(\"Content-Type\", \"application/json\")\n132: \n133: \ttokenPath := \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n134: \tif tokenData, err := os.ReadFile(tokenPath); err == nil {\n135: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+string(tokenData))\n136: \t}\n137: \n138: \tresp, err := m.httpClient.Do(req)\n139: \tif err != nil {\n140: \t\treturn nil, err\n141: \t}\n142: \tdefer resp.Body.Close()\n143: \n144: \tif resp.StatusCode != http.StatusOK {\n145: \t\treturn nil, NewSandboxTemplateNotFoundError(namespace, name, kind)\n146: \t}\n147: \n148: \tvar createResp handler.CreateSandboxResponse\n149: \tif err := json.NewDecoder(resp.Body).Decode(&createResp); err != nil {\n150: \t\treturn nil, fmt.Errorf(\"failed to decode response: %w\", err)\n151: \t}\n152: \n153: \tif createResp.SessionID == \"\" {\n154: \t\treturn nil, fmt.Errorf(\"empty session ID in response\")\n155: \t}\n156: \n157: \tinfo := &types.SandboxInfo{\n158: \t\tSessionID:   createResp.SessionID,\n159: \t\tSandboxID:   createResp.SandboxID,\n160: \t\tSandboxName: createResp.SandboxName,\n161: \t\tEntryPoints: make([]types.EntryPoint, len(createResp.EntryPoints)),\n162: \t\tKind:        kind,\n163: \t\tNamespace:   namespace,\n164: \t}\n165: \tfor i, ep := range createResp.EntryPoints {\n166: \t\tinfo.EntryPoints[i] = types.EntryPoint{\n167: \t\t\tPath:     ep.Path,\n168: \t\t\tProtocol: ep.Protocol,\n169: \t\t\tEndpoint: ep.Endpoint,\n170: \t\t}\n171: \t}\n172: \n173: \treturn info, nil\n174: }\n175: \n176: var _ io.Reader = (*bytes.Reader)(nil)\n\n(End of file - total 176 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\t\"golang.org/x/net/http2\"\n)\n\ntype SessionManager interface {\n\tGetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/session_manager.go","time":{"start":1775895685385,"end":1775895685391}}}}
