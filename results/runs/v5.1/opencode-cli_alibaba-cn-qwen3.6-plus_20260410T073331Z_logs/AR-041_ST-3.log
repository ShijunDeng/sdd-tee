nPath, ep.Path) {\n101: \t\t\tselectedEP = ep\n102: \t\t\tbreak\n103: \t\t}\n104: \t}\n105: \tif selectedEP == nil && len(sandboxInfo.EntryPoints) > 0 {\n106: \t\tselectedEP = &sandboxInfo.EntryPoints[0]\n107: \t}\n108: \tif selectedEP == nil {\n109: \t\tc.JSON(http.StatusNotFound, gin.H{\"error\": \"no entry point found for sandbox\"})\n110: \t\treturn nil\n111: \t}\n112: \n113: \ttargetStr := selectedEP.Endpoint\n114: \tif selectedEP.Protocol != \"\" && !strings.Contains(targetStr, \"://\") {\n115: \t\ttargetStr = strings.ToLower(selectedEP.Protocol) + \"://\" + targetStr\n116: \t}\n117: \tif !strings.Contains(targetStr, \"://\") {\n118: \t\ttargetStr = \"http://\" + targetStr\n119: \t}\n120: \n121: \ttargetURL, err := url.Parse(targetStr)\n122: \tif err != nil {\n123: \t\tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"invalid target URL\"})\n124: \t\treturn err\n125: \t}\n126: \n127: \tproxy := httputil.NewSingleHostReverseProxy(targetURL)\n128: \tproxy.Transport = s.httpTransport\n129: \n130: \tproxy.Director = func(req *http.Request) {\n131: \t\treq.URL.Scheme = targetURL.Scheme\n132: \t\treq.URL.Host = targetURL.Host\n133: \t\treq.URL.Path = invocationPath\n134: \t\treq.URL.RawPath = \"\"\n135: \t\treq.Host = targetURL.Host\n136: \n137: \t\treq.Header.Set(\"X-Forwarded-Host\", c.Request.Host)\n138: \t\tif s.config.EnableTLS {\n139: \t\t\treq.Header.Set(\"X-Forwarded-Proto\", \"https\")\n140: \t\t} else {\n141: \t\t\treq.Header.Set(\"X-Forwarded-Proto\", \"http\")\n142: \t\t}\n143: \t\tif existing := req.Header.Get(\"X-Forwarded-For\"); existing != \"\" {\n144: \t\t\treq.Header.Set(\"X-Forwarded-For\", existing+\", \"+c.ClientIP())\n145: \t\t} else {\n146: \t\t\treq.Header.Set(\"X-Forwarded-For\", c.ClientIP())\n147: \t\t}\n148: \n149: \t\tif kind == types.SandboxKind || kind == types.SandboxClaimKind {\n150: \t\t\tif s.jwtManager != nil {\n151: \t\t\t\ttoken, err := s.jwtManager.GenerateToken(map[string]interface{}{\n152: \t\t\t\t\t\"session_id\": sessionID,\n153: \t\t\t\t})\n154: \t\t\t\tif err != nil {\n155: \t\t\t\t\tklog.Errorf(\"failed to generate JWT: %v\", err)\n156: \t\t\t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n157: \t\t\t\t\t\t\"code\":  \"JWT_SIGNING_FAILED\",\n158: \t\t\t\t\t\t\"error\": \"failed to sign request\",\n159: \t\t\t\t\t})\n160: \t\t\t\t\treturn\n161: \t\t\t\t}\n162: \t\t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n163: \t\t\t}\n164: \t\t}\n165: \t}\n166: \n167: \tproxy.ModifyResponse = func(resp *http.Response) error {\n168: \t\tresp.Header.Set(\"x-agentcube-session-id\", sessionID)\n169: \t\treturn nil\n170: \t}\n171: \n172: \tproxy.ErrorHandler = func(w http.ResponseWriter, r *http.Request, err error) {\n173: \t\terrMsg := err.Error()\n174: \t\tif strings.Contains(errMsg, \"connection refused\") {\n175: \t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n176: \t\t\tw.WriteHeader(http.StatusBadGateway)\n177: \t\t\tjson.NewEncoder(w).Encode(gin.H{\"error\": \"sandbox unreachable\"})\n178: \t\t\treturn\n179: \t\t}\n180: \t\tif strings.Contains(errMsg, \"timeout\") || strings.Contains(errMsg, \"context deadline exceeded\") {\n181: \t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n182: \t\t\tw.WriteHeader(http.StatusGatewayTimeout)\n183: \t\t\tjson.NewEncoder(w).Encode(gin.H{\"error\": \"sandbox timeout\"})\n184: \t\t\treturn\n185: \t\t}\n186: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n187: \t\tw.WriteHeader(http.StatusBadGateway)\n188: \t\tjson.NewEncoder(w).Encode(gin.H{\"error\": \"sandbox unreachable\"})\n189: \t}\n190: \n191: \tproxy.ServeHTTP(c.Writer, c.Request)\n192: \treturn nil\n193: }\n\n(End of file - total 193 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/erro