IN_DIR)\n90: \t$(Q)echo \"  CLEAN   build artifacts removed\"\n91: \n92: # ==============================================================================\n93: # Docker Build Targets\n94: # ==============================================================================\n95: \n96: docker: $(addprefix docker/,$(DOCKER_IMAGES))\n97: \n98: docker/agentcube:\n99: \t$(Q)echo \"  DOCKER  $(REGISTRY)/agentcube:$(TAG)\"\n100: \t$(V)docker build -t $(REGISTRY)/agentcube:$(TAG) -f $(DOCKER_AGENTCUBE_DOCKERFILE) .\n101: \n102: docker/router:\n103: \t$(Q)echo \"  DOCKER  $(REGISTRY)/router:$(TAG)\"\n104: \t$(V)docker build -t $(REGISTRY)/router:$(TAG) -f $(DOCKER_ROUTER_DOCKERFILE) .\n105: \n106: docker/picod:\n107: \t$(Q)echo \"  DOCKER  $(REGISTRY)/picod:$(TAG)\"\n108: \t$(V)docker build -t $(REGISTRY)/picod:$(TAG) -f $(DOCKER_PICOD_DOCKERFILE) .\n109: \n110: # ==============================================================================\n111: # Test Targets\n112: # ==============================================================================\n113: \n114: test:\n115: \t$(Q)echo \"  TEST    go test ./...\"\n116: \t$(V)go test ./...\n117: \n118: test-coverage:\n119: \t$(Q)echo \"  COVER   go test -coverprofile=coverage.out ./...\"\n120: \t$(V)go test -coverprofile=coverage.out ./...\n121: \n122: test-chart:\n123: \t$(Q)echo \"  TEST    helm chart render\"\n124: \t$(V)bash test/chart/test_render.sh\n125: \n126: # ==============================================================================\n127: # Code Quality Targets\n128: # ==============================================================================\n129: \n130: lint:\n131: \t$(Q)if ! command -v golangci-lint >/dev/null 2>&1; then \\\n132: \t\techo \"ERROR: golangci-lint is required but not installed.\"; \\\n133: \t\texit 1; \\\n134: \tfi\n135: \t$(Q)echo \"  LINT    golangci-lint run\"\n136: \t$(V)golangci-lint run\n137: \n138: fmt:\n139: \t$(Q)echo \"  FMT     go fmt ./...\"\n140: \t$(V)go fmt ./...\n141: \n142: vet:\n143: \t$(Q)echo \"  VET     go vet ./...\"\n144: \t$(V)go vet ./...\n145: \n146: # ==============================================================================\n147: # Helm Targets\n148: # ==============================================================================\n149: \n150: helm-lint:\n151: \t$(Q)if ! command -v helm >/dev/null 2>&1; then \\\n152: \t\techo \"ERROR: helm is required but not installed.\"; \\\n153: \t\texit 1; \\\n154: \tfi\n155: \t$(Q)echo \"  HELM    lint $(HELM_CHART_DIR)\"\n156: \t$(V)helm lint $(HELM_CHART_DIR)\n157: \n158: helm-template:\n159: \t$(Q)if ! command -v helm >/dev/null 2>&1; then \\\n160: \t\techo \"ERROR: helm is required but not installed.\"; \\\n161: \t\texit 1; \\\n162: \tfi\n163: \t$(Q)echo \"  HELM    template $(HELM_CHART_DIR)\"\n164: \t$(V)helm template release $(HELM_CHART_DIR)\n165: \n166: # ==============================================================================\n167: # Python Targets\n168: # ==============================================================================\n169: \n170: python-lint:\n171: \t$(Q)if command -v ruff >/dev/null 2>&1; then \\\n172: \t\techo \"  PYLINT  ruff check $(PYTHON_SDK_DIR) $(PYTHON_CLI_DIR)\"; \\\n173: \t\truff check $(PYTHON_SDK_DIR) $(PYTHON_CLI_DIR); \\\n174: \telif command -v flake8 >/dev/null 2>&1; then \\\n175: \t\techo \"  PYLINT  flake8 $(PYTHON_SDK_DIR) $(PYTHON_CLI_DIR)\"; \\\n176: \t\tflake8 $(PYTHON_SDK_DIR) $(PYTHON_CLI_DIR); \\\n177: \telse \\\n178: \t\techo \"WARNING: No Python lint tool found (ruff or flake8). Install one to enable linting.\"; \\\n179: \tfi\n180: \n181: python-test:\n182: \t$(Q)if command -v pytest >/dev/null 2>&1; then \\\n183: \t\techo \"  PYTEST  pytest $(PYTHON_SDK_DIR)/tests $(PYTHON_CLI_DIR)/tests\"; \\\n184: \t\tpytest $(PYTHON_SDK_DIR)/tests $(PYTHON_CLI_DIR)/tests; \\\n185: \telse \\\n186: \t\techo \"WARNING: pytest is not installed. Install it to run Python tests.\"; \\\n187: \tfi\n188: \n189: # ==============================================================================\n190: # Code Generation\n191: # ==============================================================================\n192: \n193: gen-client:\n194: \t$(Q)echo \"  GEN     client-go (k8s.io/code-generator)\"\n195: \t$(V)bash hack/update-codegen.sh\n\n(End of file - total 195 lines)\n</content>","metadata":{"preview":"# AgentCube — Makefile 构建目标体系\n# AR-033: Unified build, test, docker, lint, helm, and python targets\n\n# ==============================================================================\n# Variables and Configuration\n# ==============================================================================\n\nTAG        ?= latest\nREGISTRY   ?= agentcube\nGOOS       ?= $(shell go env GOOS)\nGOARCH     ?= $(shell go env GOARCH)\nBIN_DIR    ?= bin\nLDFLAGS    ?= -s -w\nVERBOSE    ?=\n\n# Go binaries\nGO_BINARIES := router workloadmanager agentd picod\n\n# Docker images (name -> Dockerfile mapping)\nDOCKER_AGENTCUBE_DOCKERFILE := docker/Dockerfile","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/Makefile","time":{"start":1775895651237,"end":1775895651244}}}}
{"type":"tool_use","timestamp":1775895652538,"sessionID":"ses_28462a26bffeq8oXJ4B2HFgoq1","part":{"id":"prt_d7ba12434001fPVUiqyyxDssjK","messageID":"msg_d7ba10ebc001dHoSed91mwtz09","sessionID":"ses_28462a26bffeq8oXJ4B2HFgoq1","type":"tool","tool":"read","callID":"call_2286738ffc324737b62c7811","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/testing/agentcube_tdd_manifest.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/testing/agentcube_tdd_manifest.md</path>\n<type>file</type>\n<content>\n1: # AgentCube 核心模块测试契约 (TDD Manifest)\n2: \n3: 本规范定义了系统各核心组件必须实现的最小测试集。未通过以下测试用例的实现将被判定为“跑偏”。\n4: \n5: ## 1. Workload Manager (Go) - 核心准入测试\n6: - **Func: `CreateSandbox`**\n7:     - **Test-WM-1**: 必须 Mock Kubernetes Client，验证 `sandbox` 资源被正确创建。\n8:     - **Test-WM-2**: 验证 Session 冲突处理（同名 Sandbox 冲突时返回 409 或恢复现有会话）。\n9:     - **Test-WM-3**: 验证 Pod 状态同步逻辑。模拟 Pod 变为 `Running` 状态，验证 API 返回正确的 `Endpoint`。\n10: - **Func: `DeleteSession`**\n11:     - **Test-WM-4**: 验证物理资源的清理。确保调用了 K8s Delete API 且 Redis 记录同步删除。\n12: \n13: ## 2. Router (Go) - 高并发与安全测试\n14: - **Middleware: `AuthMiddleware`**\n15:     - **Test-RT-1**: 构造非法 JWT，验证返回 `401 Unauthorized`。\n16:     - **Test-RT-2**: 构造过期 JWT，验证返回 `Token Expired`。\n17: - **Proxy Logic: `HandleProxy`**\n18:     - **Test-RT-3**: 模拟后端超时，验证 Proxy 正确处理 `Gateway Timeout` 且不崩溃。\n19:     - **Test-RT-4**: 验证 Header 透传（Host, X-Forwarded-For 等）。\n20: \n21: ## 3. Session Store (Go) - 强一致性测试\n22: - **Store Interface: `RedisStore` / `ValkeyStore`**\n23:     - **Test-ST-1**: 验证对象序列化与反序列化（SessionInfo -> JSON -> SessionInfo）。\n24:     - **Test-ST-2**: 并发写测试。模拟 100 个并发请求写入同一 Session，验证无 Data Race。\n25: \n26: ## 4. PicoD (Go) - 执行引擎隔离测试\n27: - **Executor: `RunCode`**\n28:     - **Test-PD-1**: 验证资源限制（如 OOM）。模拟大内存分配，验证进程被正确杀掉并返回错误。\n29:     - **Test-PD-2**: 验证 Stdout 分块读取。处理超过 1MB 的输出，验证无缓冲区溢出。\n30: \n31: ## 5. Python SDK & CLI - 兼容性与易用性测试\n32: - **Class: `CodeInterpreterClient`**\n33:     - **Test-SDK-1**: 验证所有 HTTP 状态码映射。404 -> `NotFoundError`, 429 -> `RateLimitError`。\n34:     - **Test-SDK-2**: 验证文件上传协议。构造二进制流，验证 Multipart 封装符合 Router 规范。\n35: - **CLI: `kubectl-agentcube`**\n36:     - **Test-CLI-1**: 验证 `run` 命令的参数解析。测试 `--image`, `--env` 等参数的正确合并。\n37: \n38: ## 物理指标要求\n39: 1.  **测试/代码行数比 (T/C Ratio)**: 必须 > 0.4 (即每 100 行代码至少 40 行测试)。\n40: 2.  **用例完整性**: 每个源文件（`*.go`, `*.py`）必须存在对应的 `*_test.go` 或 `test_*.py`。\n\n(End of file - total 40 lines)\n</content>","metadata":{"preview":"# AgentCube 核心模块测试契约 (TDD Manifest)\n\n本规范定义了系统各核心组件必须实现的最小测试集。未通过以下测试用例的实现将被判定为“跑偏”。\n\n## 1. Workload Manager (Go) - 核心准入测试\n- **Func: `CreateSandbox`**\n    - **Test-WM-1**: 必须 Mock Kubernetes Client，验证 `sandbox` 资源被正确创建。\n    - **Test-WM-2**: 验证 Session 冲突处理（同名 Sandbox 冲突时返回 409 或恢复现有会话）。\n    - **Test-WM-3**: 验证 Pod 状态同步逻辑。模拟 Pod 变为 `Running` 状态，验证 API 返回正确的 `Endpoint`。\n- **Func: `DeleteSession`**\n    - **Test-WM-4**: 验证物理资源的清理。确保调用了 K8s Delete API 且 Redis 记录同步删除。\n\n## 2. Router (Go) - 高并发与安全测试\n- **Middleware: `AuthMiddleware`**\n    - **Test-RT-1**: 构造非法 JWT，验证返回 `401 Unauthorized`。\n    - **Test-RT-2**: 构造过期 JWT，验证返回 `Token Expired`。\n- **Proxy Logic: `HandleProxy`**\n    - **Test-RT-3**: 模拟后端超时，验证 Proxy 正确处理 `Gateway Timeout` 且不崩溃。\n    - **Test-RT-4**: 验证 Header 透传（Host, X-Forwarded-For 等）。\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/testing/agentcube_tdd_manifest.md","time":{"start":1775895652531,"end":1775895652536}}}}
