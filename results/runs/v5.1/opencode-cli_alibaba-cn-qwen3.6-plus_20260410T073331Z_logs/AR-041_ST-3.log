OwnerReferences {\n651: \t\t\tif ownerRef.Kind == \"Sandbox\" && ownerRef.Name == sandboxName {\n652: \t\t\t\tif p.Status.Phase != corev1.PodRunning {\n653: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n654: \t\t\t\t}\n655: \t\t\t\tif p.Status.PodIP == \"\" {\n656: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n657: \t\t\t\t}\n658: \t\t\t\treturn p.Status.PodIP, nil\n659: \t\t\t}\n660: \t\t}\n661: \t}\n662: \n663: \treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n664: }\n665: \n666: func (h *SandboxCreateHandler) buildEntryPoints(podIP string, ports []runtimev1alpha1.TargetPort) []EntryPoint {\n667: \tvar entryPoints []EntryPoint\n668: \tfor _, p := range ports {\n669: \t\tentryPoints = append(entryPoints, EntryPoint{\n670: \t\t\tPath:     p.PathPrefix,\n671: \t\t\tProtocol: string(p.Protocol),\n672: \t\t\tEndpoint: fmt.Sprintf(\"%s:%d\", podIP, p.Port),\n673: \t\t})\n674: \t}\n675: \treturn entryPoints\n676: }\n677: \n678: func generateSessionID() string {\n679: \treturn uuid.New().String()\n680: }\n681: \n682: func generateSandboxName(workloadName string) string {\n683: \treturn fmt.Sprintf(\"%s-%s\", workloadName, RandString(8))\n684: }\n685: \n686: func RandString(n int) string {\n687: \tconst charset = \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\"\n688: \tb := make([]byte, n)\n689: \tfor i := range b {\n690: \t\tb[i] = charset[rand.Intn(len(charset))]\n691: \t}\n692: \treturn string(b)\n693: }\n\n(End of file - total 693 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"reflect\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime\"