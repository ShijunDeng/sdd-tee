.Context) ([]*SandboxInfo, error)\n36: }\n37: \n38: type SandboxReconcilerWatcher interface {\n39: \tWatchSandboxOnce(namespace, name string) (<-chan SandboxStatus, error)\n40: }\n41: \n42: type TokenCache interface {\n43: \tGetOrCreateUserK8sClient(namespace, saName, token string) (dynamic.Interface, error)\n44: }\n45: \n46: type SandboxCreateHandlerDeps struct {\n47: \tDynamicClient     dynamic.Interface\n48: \tClientset         clientset.Interface\n49: \tKubeClientset     kubernetes.Interface\n50: \tInformerFactory   externalversions.SharedInformerFactory\n51: \tStore             Store\n52: \tReconciler        SandboxReconcilerWatcher\n53: \tTokenCache        TokenCache\n54: \tUserClientFactory UserClientFactory\n55: \tEnableAuth        bool\n56: }\n57: \n58: type UserClientFactory interface {\n59: \tCreateUserClient(token string) (dynamic.Interface, error)\n60: }\n61: \n62: type SandboxCreateHandler struct {\n63: \tdynamicClient     dynamic.Interface\n64: \tclientset         clientset.Interface\n65: \tkubeClientset     kubernetes.Interface\n66: \tinformerFactory   externalversions.SharedInformerFactory\n67: \tstore             Store\n68: \treconciler        SandboxReconcilerWatcher\n69: \ttokenCache        TokenCache\n70: \tuserClientFactory UserClientFactory\n71: \tenableAuth        bool\n72: }\n73: \n74: func NewSandboxCreateHandler(deps *SandboxCreateHandlerDeps) *SandboxCreateHandler {\n75: \treturn &SandboxCreateHandler{\n76: \t\tdynamicClient:     deps.DynamicClient,\n77: \t\tclientset:         deps.Clientset,\n78: \t\tkubeClientset:     deps.KubeClientset,\n79: \t\tinformerFactory:   deps.InformerFactory,\n80: \t\tstore:             deps.Store,\n81: \t\treconciler:        deps.Reconciler,\n82: \t\ttokenCache:        deps.TokenCache,\n83: \t\tuserClientFactory: deps.UserClientFactory,\n84: \t\tenableAuth:        deps.EnableAuth,\n85: \t}\n86: }\n87: \n88: func (h *SandboxCreateHandler) getDynamicClient(c *gin.Context) (dynamic.Interface, error) {\n89: \tif !h.enableAuth {\n90: \t\treturn h.dynamicClient, nil\n91: \t}\n92: \n93: \ttoken := c.GetHeader(\"Authorization\")\n94: \tif token == \"\" {\n95: \t\treturn nil, fmt.Errorf(\"authorization token is required\")\n96: \t}\n97: \tif len(token) > 7 && token[:7] == \"Bearer \" {\n98: \t\ttoken = token[7:]\n99: \t}\n100: \n101: \tnamespace := c.GetString(\"namespace\")\n102: \tsaName := c.GetString(\"serviceAccountName\")\n103: \n104: \tif h.tokenCache != nil {\n105: \t\treturn h.tokenCache.GetOrCreateUserK8sClient(namespace, saName, token)\n106: \t}\n107: \n108: \tif h.userClientFactory != nil {\n109: \t\treturn h.userClientFactory.CreateUserClient(token)\n110: \t}\n111: \n112: \treturn nil, fmt.Errorf(\"no user client factory available\")\n113: }\n114: \n115: func (h *SandboxCreateHandler) CreateAgentRuntimeSandbox(c *gin.Context) {\n116: \tvar sandboxReq CreateSandboxRequest\n117: \tif err := c.ShouldBindJSON(&sandboxReq); err != nil {\n118: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n119: \t\treturn\n120: \t}\n121: \n122: \tsandboxReq.Kind = AgentRuntimeKind\n123: \n124: \tif err := sandboxReq.Validate(); err != nil {\n125: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n126: \t\treturn\n127: \t}\n128: \n129: \tarLister := h.informerFactory.Runtime().V1alpha1().AgentRuntimes().Lister()\n130: \ttemplate, err := arLister.AgentRuntimes(sandboxReq.Namespace).Get(sandboxReq.Name)\n131: \tif err != nil {\n132: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"AgentRuntime %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n133: \t\treturn\n134: \t}\n135: \n136: \tif template.Spec.Template == nil {\n137: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"podTemplate is required\")\n138: \t\treturn\n139: \t}\n140: \n141: \tsessionID := generateSessionID()\n142: \tsandboxName := generateSandboxName(sandboxReq.Name)\n143: \n144: \tsandboxCR, err := h.buildAgentRuntimeSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace)\n145: \tif err != nil {\n146: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n147: \t\treturn\n148: \t}\n149: \n150: \tsandboxInfo := &SandboxInfo{\n151: \t\tSessionID:    sessionID,\n152: \t\tSandboxName:  sandboxName,\n153: \t\tWorkloadName: sandboxReq.Name,\n154: \t\tNamespace:    sandboxReq.Namespace,\n155: \t\tKind:         AgentRuntimeKind,\n156: \t\tStatus:       \"pending\",\n157: \t\tCreatedAt:    time.Now(),\n158: \t}\n159: \n160: \tif err := h.store.StoreSandbox(c.Request.Context(), sandboxInfo); err != nil {\n161: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n162: \t\treturn\n163: \t}\n164: \n165: \twatcherCh, err := h.reconciler.WatchSandboxOnce(sandboxReq.Namespace, sandboxName)\n166: \tif err != nil {\n167: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n168: \t\treturn\n169: \t}\n170: \n171: \tdynClient, err := h.getDynamicClient(c)\n172: \tif err != nil {\n173: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n174: \t\treturn\n175: \t}\n176: \n177: \tcreatedCR, err := dynClient.Resource(SandboxGVR).Namespace(sandboxReq.Namespace).Create(c.Request.Context(), sandboxCR, metav1.CreateOptions{})\n178: \tif err != nil {\n179: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n180: \t\treturn\n181: \t}\n182: \n183: \tctx, cancel := context.WithTimeout(c.Request.Context(), 2*time.Minute)\n184: \tdefer cancel()\n185: \n186: \tselect {\n187: \tcase status := <-watcherCh:\n188: \t\tif status.Error != nil {\n189: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n190: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, status.Error.Error())\n191: \t\t\treturn\n192: \t\t}\n193: \t\tif status.Status != \"running\" {\n194: \t\t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n195: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n196: \t\t\treturn\n197: \t\t}\n198: \tcase <-ctx.Done():\n199: \t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n200: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n201: \t\treturn\n202: \t}\n203: \n204: \tpodIP, err := h.resolvePodIP(c.Request.Context(), sandboxName, sandboxReq.Namespace, sandboxCR, h.kubeClientset)\n205: \tif err != nil {\n206: \t\th.rollbackCR(c.Request.Context(), SandboxGVR, sandboxReq.Namespace, sandboxName, dynClient)\n207: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())\n208: \t\treturn\n209: \t}\n210: \n211: \tports := template.Spec.Ports\n212: \tentryPoints := h.buildEntryPoints(podIP, ports)\n213: \n214: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n215: \tsandboxInfo.PodIP = podIP\n216: \tsandboxInfo.EntryPoints = entryPoints\n217: \tsandboxInfo.Status = \"running\"\n218: \n219: \tif err := h.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n220: \t\tlog.Printf(\"failed to update sandbox in store: %v\", err)\n221: \t}\n222: \n223: \tresp := &CreateSandboxResponse{\n224: \t\tSessionID:   sessionID,\n225: \t\tSandboxID:   sandboxInfo.SandboxID,\n226: \t\tSandboxName: sandboxName,\n227: \t\tEntryPoints: entryPoints,\n228: \t}\n229: \n230: \tresponse.JSON(c, http.StatusOK, resp)\n231: }\n232: \n233: func (h *SandboxCreateHandler) CreateCodeInterpreterSandbox(c *gin.Context) {\n234: \tvar sandboxReq CreateSandboxRequest\n235: \tif err := c.ShouldBindJSON(&sandboxReq); err != nil {\n236: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n237: \t\treturn\n238: \t}\n239: \n240: \tsandboxReq.Kind = CodeInterpreterKind\n241: \n242: \tif err := sandboxReq.Validate(); err != nil {\n243: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n244: \t\treturn\n245: \t}\n246: \n247: \tciLister := h.informerFactory.Runtime().V1alpha1().CodeInterpreters().Lister()\n248: \ttemplate, err := ciLister.CodeInterpreters(sandboxReq.Namespace).Get(sandboxReq.Name)\n249: \tif err != nil {\n250: \t\tresponse.Error(c, http.StatusNotFound, http.StatusNotFound, fmt.Sprintf(\"CodeInterpreter %s/%s not found\", sandboxReq.Namespace, sandboxReq.Name))\n251: \t\treturn\n252: \t}\n253: \n254: \tif template.Spec.Template == nil {\n255: \t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"template is required\")\n256: \t\treturn\n257: \t}\n258: \n259: \tsessionID := generateSessionID()\n260: \tsandboxName := generateSandboxName(sandboxReq.Name)\n261: \n262: \tports := getPortsOrDefaults(template.Spec.Ports)\n263: \n264: \tvar sandboxCR *unstructured.Unstructured\n265: \tvar entryKind string\n266: \n267: \tsandboxCR, entryKind, err = h.buildCodeInterpreterSandboxCR(template, sessionID, sandboxName, sandboxReq.Name, sandboxReq.Namespace, ports)\n268: \tif err != nil {\n269: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n270: \t\treturn\n271: \t}\n272: \n273: \tif template.Spec.AuthMode == runtimev1alpha1.AuthModePicoD {\n274: \t\tif err := h.injectPicodAuthEnv(sandboxCR, sandboxReq.Namespace, h.kubeClientset); err != nil {\n275: \t\t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n276: \t\t\treturn\n277: \t\t}\n278: \t}\n279: \n280: \tsandboxInfo := &SandboxInfo{\n281: \t\tSessionID:    sessionID,\n282: \t\tSandboxName:  sandboxName,\n283: \t\tWorkloadName: sandboxReq.Name,\n284: \t\tNamespace:    sandboxReq.Namespace,\n285: \t\tKind:         entryKind,\n286: \t\tStatus:       \"pending\",\n287: \t\tCreatedAt:    time.Now(),\n288: \t}\n289: \n290: \tif err := h.store.StoreSandbox(c.Request.Context(), sandboxInfo); err != nil {\n291: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n292: \t\treturn\n293: \t}\n294: \n295: \twatcherCh, err := h.reconciler.WatchSandboxOnce(sandboxReq.Namespace, sandboxName)\n296: \tif err != nil {\n297: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n298: \t\treturn\n299: \t}\n300: \n301: \tdynClient, err := h.getDynamicClient(c)\n302: \tif err != nil {\n303: \t\tresponse.Error(c, http.StatusUnauthorized, http.StatusUnauthorized, err.Error())\n304: \t\treturn\n305: \t}\n306: \n307: \tvar gvr schema.GroupVersionResource\n308: \tif entryKind == SandboxClaimsKind {\n309: \t\tgvr = SandboxClaimGVR\n310: \t} else {\n311: \t\tgvr = SandboxGVR\n312: \t}\n313: \n314: \tcreatedCR, err := dynClient.Resource(gvr).Namespace(sandboxReq.Namespace).Create(c.Request.Context(), sandboxCR, metav1.CreateOptions{})\n315: \tif err != nil {\n316: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"internal server error\")\n317: \t\treturn\n318: \t}\n319: \n320: \tctx, cancel := context.WithTimeout(c.Request.Context(), 2*time.Minute)\n321: \tdefer cancel()\n322: \n323: \tselect {\n324: \tcase status := <-watcherCh:\n325: \t\tif status.Error != nil {\n326: \t\t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n327: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, status.Error.Error())\n328: \t\t\treturn\n329: \t\t}\n330: \t\tif status.Status != \"running\" {\n331: \t\t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n332: \t\t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n333: \t\t\treturn\n334: \t\t}\n335: \tcase <-ctx.Done():\n336: \t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n337: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, \"sandbox creation timed out\")\n338: \t\treturn\n339: \t}\n340: \n341: \tpodIP, err := h.resolvePodIP(c.Request.Context(), sandboxName, sandboxReq.Namespace, sandboxCR, h.kubeClientset)\n342: \tif err != nil {\n343: \t\th.rollbackCR(c.Request.Context(), gvr, sandboxReq.Namespace, sandboxName, dynClient)\n344: \t\tresponse.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())\n345: \t\treturn\n346: \t}\n347: \n348: \tentryPoints := h.buildEntryPoints(podIP, ports)\n349: \n350: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n351: \tsandboxInfo.PodIP = podIP\n352: \tsandboxInfo.EntryPoints = entryPoints\n353: \tsandboxInfo.Status = \"running\"\n354: \n355: \tif err := h.store.UpdateSandbox(c.Request.Context(), sessionID, sandboxInfo); err != nil {\n356: \t\tlog.Printf(\"failed to update sandbox in store: %v\", err)\n357: \t}\n358: \n359: \tresp := &CreateSandboxResponse{\n360: \t\tSessionID:   sessionID,\n361: \t\tSandboxID:   sandboxInfo.SandboxID,\n362: \t\tSandboxName: sandboxName,\n363: \t\tEntryPoints: entryPoints,\n364: \t}\n365: \n366: \tresponse.JSON(c, http.StatusOK, resp)\n367: }\n368: \n369: func (h *SandboxCreateHandler) rollbackCR(ctx context.Context, gvr schema.GroupVersionResource, namespace, name string, dynClient dynamic.Interface) error {\n370: \trollbackCtx, cancel := context.WithTimeout(ctx, 30*time.Second)\n371: \tdefer cancel()\n372: \n373: \terr := dynClient.Resource(gvr).Namespace(namespace).Delete(rollbackCtx, name, metav1.DeleteOptions{})\n374: \tif err != nil && apierrors.IsNotFound(err) {\n375: \t\treturn nil\n376: \t}\n377: \treturn err\n378: }\n379: \n380: func (h *SandboxCreateHandler) buildAgentRuntimeSandboxCR(template *runtimev1alpha1.AgentRuntime, sessionID, sandboxName, workloadName, namespace string) (*unstructured.Unstructured, error) {\n381: \tcr := &unstructured.Unstructured{}\n382: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n383: \tcr.SetKind(\"Sandbox\")\n384: \tcr.SetName(sandboxName)\n385: \tcr.SetNamespace(namespace)\n386: \n387: \tcr.SetLabels(map[string]string{\n388: \t\tLabelManagedBy:    LabelManagedByValue,\n389: \t\tLabelSessionID:    sessionID,\n390: \t\tLabelWorkloadName: workloadName,\n391: \t\tLabelSandboxName:  sandboxName,\n392: \t})\n393: \n394: \tidleTimeout := DefaultSandboxIdleTimeout\n395: \tif template.Spec.SessionTimeout != nil {\n396: \t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n397: \t}\n398: \tcr.SetAnnotations(map[string]string{\n399: \t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n400: \t})\n401: \n402: \tttl := DefaultSandboxTTL\n403: \tif template.Spec.MaxSessionDuration != nil {\n404: \t\tttl = int(template.Spec.MaxSessionDuration.Duration.Hours())\n405: \t}\n406: \tshutdownTime := time.Now().Add(time.Duration(ttl) * time.Hour)\n407: \n408: \tspec := map[string]interface{}{\n409: \t\t\"replicas\": int64(1),\n410: \t\t\"lifecycle\": map[string]interface{}{\n411: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n412: \t\t},\n413: \t}\n414: \n415: \tvar ports []interface{}\n416: \tfor _, p := range template.Spec.Ports {\n417: \t\tports = append(ports, map[string]interface{}{\n418: \t\t\t\"name\":     p.Name,\n419: \t\t\t\"port\":     int64(p.Port),\n420: \t\t\t\"protocol\": string(p.Protocol),\n421: \t\t})\n422: \t}\n423: \tif len(ports) > 0 {\n424: \t\tspec[\"ports\"] = ports\n425: \t}\n426: \n427: \tpodSpec := template.Spec.Template.Spec\n428: \tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n429: \tif err != nil {\n430: \t\treturn nil, fmt.Errorf(\"failed to convert pod spec: %w\", err)\n431: \t}\n432: \tspec[\"podTemplate\"] = podSpecMap\n433: \n434: \tcr.Object[\"spec\"] = spec\n435: \n436: \treturn cr, nil\n437: }\n438: \n439: func (h *SandboxCreateHandler) buildCodeInterpreterSandboxCR(template *runtimev1alpha1.CodeInterpreter, sessionID, sandboxName, workloadName, namespace string, ports []runtimev1alpha1.TargetPort) (*unstructured.Unstructured, string, error) {\n440: \twarmPoolSize := int32(0)\n441: \tif template.Spec.WarmPoolSize != nil {\n442: \t\twarmPoolSize = *template.Spec.WarmPoolSize\n443: \t}\n444: \n445: \tif warmPoolSize > 0 {\n446: \t\tcr := &unstructured.Unstructured{}\n447: \t\tcr.SetAPIVersion(\"extensions.agents.x-k8s.io/v1alpha1\")\n448: \t\tcr.SetKind(\"SandboxClaim\")\n449: \t\tcr.SetName(sandboxName)\n450: \t\tcr.SetNamespace(namespace)\n451: \n452: \t\tcr.SetLabels(map[string]string{\n453: \t\t\tLabelManagedBy:    LabelManagedByValue,\n454: \t\t\tLabelSessionID:    sessionID,\n455: \t\t\tLabelWorkloadName: workloadName,\n456: \t\t\tLabelSandboxName:  sandboxName,\n457: \t\t})\n458: \n459: \t\tidleTimeout := DefaultSandboxIdleTimeout\n460: \t\tif template.Spec.SessionTimeout != nil {\n461: \t\t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n462: \t\t}\n463: \t\tcr.SetAnnotations(map[string]string{\n464: \t\t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n465: \t\t})\n466: \n467: \t\treturn cr, SandboxClaimsKind, nil\n468: \t}\n469: \n470: \tcr := &unstructured.Unstructured{}\n471: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n472: \tcr.SetKind(\"Sandbox\")\n473: \tcr.SetName(sandboxName)\n474: \tcr.SetNamespace(namespace)\n475: \n476: \tcr.SetLabels(map[string]string{\n477: \t\tLabelManagedBy:    LabelManagedByValue,\n478: \t\tLabelSessionID:    sessionID,\n479: \t\tLabelWorkloadName: workloadName,\n480: \t\tLabelSandboxName:  sandboxName,\n481: \t})\n482: \n483: \tidleTimeout := DefaultSandboxIdleTimeout\n484: \tif template.Spec.SessionTimeout != nil {\n485: \t\tidleTimeout = int(template.Spec.SessionTimeout.Duration.Minutes())\n486: \t}\n487: \tcr.SetAnnotations(map[string]string{\n488: \t\tAnnotationIdleTimeout: fmt.Sprintf(\"%dm\", idleTimeout),\n489: \t})\n490: \n491: \tttl := DefaultSandboxTTL\n492: \tif template.Spec.MaxSessionDuration != nil {\n493: \t\tttl = int(template.Spec.MaxSessionDuration.Duration.Hours())\n494: \t}\n495: \tshutdownTime := time.Now().Add(time.Duration(ttl) * time.Hour)\n496: \n497: \tspec := map[string]interface{}{\n498: \t\t\"replicas\": int64(1),\n499: \t\t\"lifecycle\": map[string]interface{}{\n500: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n501: \t\t},\n502: \t}\n503: \n504: \tvar portsList []interface{}\n505: \tfor _, p := range ports {\n506: \t\tportsList = append(portsList, map[string]interface{}{\n507: \t\t\t\"name\":     p.Name,\n508: \t\t\t\"port\":     int64(p.Port),\n509: \t\t\t\"protocol\": string(p.Protocol),\n510: \t\t})\n511: \t}\n512: \tif len(portsList) > 0 {\n513: \t\tspec[\"ports\"] = portsList\n514: \t}\n515: \n516: \ttmpl := template.Spec.Template\n517: \tcontainer := corev1.Container{\n518: \t\tName:  \"code-interpreter\",\n519: \t\tImage: tmpl.Image,\n520: \t}\n521: \tif tmpl.ImagePullPolicy != \"\" {\n522: \t\tcontainer.ImagePullPolicy = tmpl.ImagePullPolicy\n523: \t}\n524: \tif len(tmpl.Environment) > 0 {\n525: \t\tcontainer.Env = tmpl.Environment\n526: \t}\n527: \tif len(tmpl.Command) > 0 {\n528: \t\tcontainer.Command = tmpl.Command\n529: \t}\n530: \tif len(tmpl.Args) > 0 {\n531: \t\tcontainer.Args = tmpl.Args\n532: \t}\n533: \tif !reflect.DeepEqual(tmpl.Resources, corev1.ResourceRequirements{}) {\n534: \t\tcontainer.Resources = tmpl.Resources\n535: \t}\n536: \n537: \tpodSpec := corev1.PodSpec{\n538: \t\tContainers: []corev1.Container{container},\n539: \t}\n540: \tif tmpl.RuntimeClassName != nil {\n541: \t\tpodSpec.RuntimeClassName = tmpl.RuntimeClassName\n542: \t}\n543: \tif len(tmpl.ImagePullSecrets) > 0 {\n544: \t\tpodSpec.ImagePullSecrets = tmpl.ImagePullSecrets\n545: \t}\n546: \n547: \tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n548: \tif err != nil {\n549: \t\treturn nil, \"\", fmt.Errorf(\"failed to convert pod spec: %w\", err)\n550: \t}\n551: \tspec[\"podTemplate\"] = podSpecMap\n552: \n553: \tcr.Object[\"spec\"] = spec\n554: \n555: \treturn cr, SandboxesKind, nil\n556: }\n557: \n558: func getPortsOrDefaults(ports []runtimev1alpha1.TargetPort) []runtimev1alpha1.TargetPort {\n559: \tif len(ports) == 0 {\n560: \t\treturn []runtimev1alpha1.TargetPort{\n561: \t\t\t{Port: 8080, Protocol: runtimev1alpha1.ProtocolTypeHTTP, PathPrefix: \"/\"},\n562: \t\t}\n563: \t}\n564: \treturn ports\n565: }\n566: \n567: func (h *SandboxCreateHandler) injectPicodAuthEnv(cr *unstructured.Unstructured, namespace string, clientset kubernetes.Interface) error {\n568: \tsecret, err := clientset.CoreV1().Secrets(namespace).Get(context.Background(), IdentitySecretName, metav1.GetOptions{})\n569: \tif err != nil {\n570: \t\tif apierrors.IsNotFound(err) {\n571: \t\t\treturn fmt.Errorf(\"public key not yet loaded from Router Secret\")\n572: \t\t}\n573: \t\treturn fmt.Errorf(\"failed to get secret: %w\", err)\n574: \t}\n575: \n576: \tpublicKey, ok := secret.Data[PublicKeyDataKey]\n577: \tif !ok || len(publicKey) == 0 {\n578: \t\treturn fmt.Errorf(\"public key not yet loaded from Router Secret\")\n579: \t}\n580: \n581: \tspec, ok := cr.Object[\"spec\"].(map[string]interface{})\n582: \tif !ok {\n583: \t\treturn fmt.Errorf(\"spec not found in CR\")\n584: \t}\n585: \n586: \tpodTemplate, ok := spec[\"podTemplate\"].(map[string]interface{})\n587: \tif !ok {\n588: \t\treturn fmt.Errorf(\"podTemplate not found in spec\")\n589: \t}\n590: \n591: \tcontainers, ok := podTemplate[\"containers\"].([]interface{})\n592: \tif !ok || len(containers) == 0 {\n593: \t\treturn fmt.Errorf(\"containers not found in podTemplate\")\n594: \t}\n595: \n596: \tfirstContainer, ok := containers[0].(map[string]interface{})\n597: \tif !ok {\n598: \t\treturn fmt.Errorf(\"invalid 