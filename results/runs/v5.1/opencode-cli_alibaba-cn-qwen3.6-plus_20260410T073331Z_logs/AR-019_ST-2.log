{"type":"tool_use","timestamp":1775848017122,"sessionID":"ses_28737182bfferMscz6UMoo0a4N","part":{"id":"prt_d78ca4126001UVfcpq0QKcYdhN","messageID":"msg_d78ca3764001fkzrhh5r7JpH1G","sessionID":"ses_28737182bfferMscz6UMoo0a4N","type":"tool","tool":"read","callID":"call_bdeb529a24a048d1904527b7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/reconciler.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/reconciler.go</path>\n<type>file</type>\n<content>\n1: package reconciler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"log\"\n7: \t\"sync\"\n8: \t\"time\"\n9: \n10: \t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n11: \t\"github.com/volcano-sh/agentcube/client-go/informers/externalversions\"\n12: \tlisters \"github.com/volcano-sh/agentcube/client-go/listers/runtime/v1alpha1\"\n13: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n14: \t\"k8s.io/apimachinery/pkg/util/runtime\"\n15: \tcoreinformers \"k8s.io/client-go/informers/core/v1\"\n16: \t\"k8s.io/client-go/tools/cache\"\n17: \t\"k8s.io/client-go/util/workqueue\"\n18: )\n19: \n20: type SandboxReconciler struct {\n21: \tclientset       clientset.Interface\n22: \tinformerFactory externalversions.SharedInformerFactory\n23: \tarLister        listers.AgentRuntimeLister\n24: \tciLister        listers.CodeInterpreterLister\n25: \tpodInformer     coreinformers.PodInformer\n26: \tstore           Store\n27: \tworkqueue       workqueue.RateLimitingInterface\n28: \tworkers         int\n29: \tmetricsRecorder handler.MetricsRecorder\n30: \tmu              sync.Mutex\n31: \trunning         bool\n32: \tstopCh          chan struct{}\n33: }\n34: \n35: func NewSandboxReconciler(deps ReconcilerDeps) *SandboxReconciler {\n36: \tif deps.Store == nil {\n37: \t\tpanic(\"Store is required\")\n38: \t}\n39: \tif deps.Clientset == nil {\n40: \t\tpanic(\"Clientset is required\")\n41: \t}\n42: \tif deps.InformerFactory == nil {\n43: \t\tpanic(\"InformerFactory is required\")\n44: \t}\n45: \n46: \tworkers := deps.Workers\n47: \tif workers == 0 {\n48: \t\tworkers = defaultWorkers\n49: \t}\n50: \n51: \twq := workqueue.NewNamedRateLimitingQueue(\n52: \t\tworkqueue.NewItemExponentialFailureRateLimiter(5*time.Second, 5*time.Minute),\n53: \t\t\"sandbox-reconciler\",\n54: \t)\n55: \n56: \tr := &SandboxReconciler{\n57: \t\tclientset:       deps.Clientset,\n58: \t\tinformerFactory: deps.InformerFactory,\n59: \t\tarLister:        deps.ARLister,\n60: \t\tciLister:        deps.CILister,\n61: \t\tpodInformer:     deps.PodInformer,\n62: \t\tstore:           deps.Store,\n63: \t\tworkqueue:       wq,\n64: \t\tworkers:         workers,\n65: \t\tmetricsRecorder: deps.MetricsRecorder,\n66: \t\tstopCh:          make(chan struct{}),\n67: \t}\n68: \n69: \tr.registerEventHandlers()\n70: \n71: \treturn r\n72: }\n73: \n74: func (r *SandboxReconciler) registerEventHandlers() {\n75: \tarInformer := r.informerFactory.Runtime().V1alpha1().AgentRuntimes().Informer()\n76: \tarInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n77: \t\tAddFunc: func(obj interface{}) {\n78: \t\t\truntime.HandleCrash(func() {\n79: \t\t\t\tr.onAgentRuntimeAdd(obj)\n80: \t\t\t})\n81: \t\t},\n82: \t\tUpdateFunc: func(oldObj, newObj interface{}) {\n83: \t\t\truntime.HandleCrash(func() {\n84: \t\t\t\tr.onAgentRuntimeUpdate(oldObj, newObj)\n85: \t\t\t})\n86: \t\t},\n87: \t\tDeleteFunc: func(obj interface{}) {\n88: \t\t\truntime.HandleCrash(func() {\n89: \t\t\t\tr.onAgentRuntimeDelete(obj)\n90: \t\t\t})\n91: \t\t},\n92: \t})\n93: \n94: \tciInformer := r.informerFactory.Runtime().V1alpha1().CodeInterpreters().Informer()\n95: \tciInformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n96: \t\tAddFunc: func(obj interface{}) {\n97: \t\t\truntime.HandleCrash(func() {\n98: \t\t\t\tr.onCodeInterpreterAdd(obj)\n99: \t\t\t})\n100: \t\t},\n101: \t\tUpdateFunc: func(oldObj, newObj interface{}) {\n102: \t\t\truntime.HandleCrash(func() {\n103: \t\t\t\tr.onCodeInterpreterUpdate(oldObj, newObj)\n104: \t\t\t})\n105: \t\t},\n106: \t\tDeleteFunc: func(obj interface{}) {\n107: \t\t\truntime.HandleCrash(func() {\n108: \t\t\t\tr.onCodeInterpreterDelete(obj)\n109: \t\t\t})\n110: \t\t},\n111: \t})\n112: \n113: \tif r.podInformer != nil {\n114: \t\tr.podInformer.Informer().AddEventHandler(cache.ResourceEventHandlerFuncs{\n115: \t\t\tAddFunc: func(obj interface{}) {\n116: \t\t\t\truntime.HandleCrash(func() {\n117: \t\t\t\t\tr.onPodAdd(obj)\n118: \t\t\t\t})\n119: \t\t\t},\n120: \t\t\tUpdateFunc: func(oldObj, newObj interface{}) {\n121: \t\t\t\truntime.HandleCrash(func() {\n122: \t\t\t\t\tr.onPodUpdate(oldObj, newObj)\n123: \t\t\t\t})\n124: \t\t\t},\n125: \t\t\tDeleteFunc: func(obj interface{}) {\n126: \t\t\t\truntime.HandleCrash(func() {\n127: \t\t\t\t\tr.onPodDelete(obj)\n128: \t\t\t\t})\n129: \t\t\t},\n130: \t\t})\n131: \t}\n132: }\n133: \n134: func (r *SandboxReconciler) Enqueue(namespace, name string) {\n135: \tkey := name\n136: \tif namespace != \"\" {\n137: \t\tkey = fmt.Sprintf(\"%s/%s\", namespace, name)\n138: \t}\n139: \tr.workqueue.Add(key)\n140: \tif r.metricsRecorder != nil {\n141: \t\tr.metricsRecorder.IncWorkqueueAdds(resourceTypeAgentRuntime)\n142: \t}\n143: }\n144: \n145: func (r *SandboxReconciler) Run(stopCh <-chan struct{}) {\n146: \tr.mu.Lock()\n147: \tif r.running {\n148: \t\tr.mu.Unlock()\n149: \t\tlog.Println(\"[reconciler] already running, ignoring duplicate Run call\")\n150: \t\treturn\n151: \t}\n152: \tr.running = true\n153: \tr.stopCh = stopCh\n154: \tr.mu.Unlock()\n155: \n156: \tlog.Println(\"[reconciler] starting informer factory\")\n157: \tr.informerFactory.Start(stopCh)\n158: \n159: \tlog.Println(\"[reconciler] waiting for cache sync\")\n160: \tctx, cancel := context.WithTimeout(context.Background(), cacheSyncTimeout)\n161: \tdefer cancel()\n162: \n163: \tsynced := r.informerFactory.WaitForCacheSync(ctx.Done())\n164: \tfor informerType, ok := range synced {\n165: \t\tif !ok {\n166: \t\t\tlog.Printf(\"[reconciler] cache sync failed for informer: %s\", informerType)\n167: \t\t\tr.mu.Lock()\n168: \t\t\tr.running = false\n169: \t\t\tr.mu.Unlock()\n170: \t\t\treturn\n171: \t\t}\n172: \t}\n173: \n174: \tlog.Printf(\"[reconciler] starting %d workers\", r.workers)\n175: \tfor i := 0; i < r.workers; i++ {\n176: \t\tgo r.runWorker()\n177: \t}\n178: \n179: \t<-stopCh\n180: \tlog.Println(\"[reconciler] shutdown signal received\")\n181: \n182: \tr.informerFactory.Shutdown()\n183: \n184: \tdone := make(chan struct{})\n185: \tgo func() {\n186: \t\tr.workqueue.ShutDownWithDrain()\n187: \t\tclose(done)\n188: \t}()\n189: \n190: \tselect {\n191: \tcase <-done:\n192: \t\tlog.Println(\"[reconciler] workqueue drained\")\n193: \tcase <-time.After(shutdownTimeout):\n194: \t\tlog.Println(\"[reconciler] shutdown timeout, forcing exit\")\n195: \t}\n196: \n197: \tr.mu.Lock()\n198: \tr.running = false\n199: \tr.mu.Unlock()\n200: \tlog.Println(\"[reconciler] stopped\")\n201: }\n\n(End of file - total 201 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n\t\"github.com/volcano-sh/agentcube/client-go/informers/externalversions\"\n\tlisters \"github.com/volcano-sh/agentcube/client-go/listers/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\t\"k8s.io/apimachinery/pkg/util/runtime\"\n\tcoreinformers \"k8s.io/client-go/informers/core/v1\"\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/client-go/util/workqueue\"\n)\n\ntype SandboxReconciler struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/reconciler.go","time":{"start":1775848017114,"end":1775848017121}}}}
