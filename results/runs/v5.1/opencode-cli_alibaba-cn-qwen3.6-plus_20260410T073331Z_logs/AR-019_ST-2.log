toreOrLoadJWTKeySecret(context.Background()); err != nil {\n56: \t\treturn nil, err\n57: \t}\n58: \n59: \tstoreClient := store.Storage()\n60: \n61: \tsessionManager, err := NewSessionManager(storeClient)\n62: \tif err != nil {\n63: \t\treturn nil, err\n64: \t}\n65: \n66: \ts := &Server{\n67: \t\tconfig:         config,\n68: \t\tengine:         engine,\n69: \t\thttpTransport:  httpTransport,\n70: \t\tjwtManager:     jwtManager,\n71: \t\tstoreClient:    storeClient,\n72: \t\tsessionManager: sessionManager,\n73: \t}\n74: \n75: \ts.registerRoutes()\n76: \n77: \ts.httpServer = &http.Server{\n78: \t\tAddr:        \":\" + config.Port,\n79: \t\tHandler:     s.engine,\n80: \t\tReadTimeout: 30 * time.Second,\n81: \t\tIdleTimeout: 90 * time.Second,\n82: \t}\n83: \n84: \treturn s, nil\n85: }\n86: \n87: func (s *Server) registerRoutes() {\n88: \ts.engine.GET(\"/health/live\", handleHealthLive)\n89: \ts.engine.GET(\"/health/ready\", s.handleHealthReady)\n90: \n91: \tv1 := s.engine.Group(\"/v1\")\n92: \tv1.Use(gin.Logger())\n93: \tv1.Use(gin.Recovery())\n94: \tv1.Use(AuthMiddleware(s.jwtManager))\n95: \tv1.Use(ConcurrencyLimitMiddleware(s.config.MaxConcurrentRequests))\n96: \n97: \tv1.GET(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n98: \tv1.POST(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n99: \tv1.GET(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n100: \tv1.POST(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n101: }\n102: \n103: func (s *Server) Start() error {\n104: \tif s.config.EnableTLS {\n105: \t\tif s.config.TLSCert == \"\" || s.config.TLSKey == \"\" {\n106: \t\t\treturn nil\n107: \t\t}\n108: \t\tklog.Infof(\"Starting HTTPS server on %s\", s.httpServer.Addr)\n109: \t\treturn s.httpServer.ListenAndServeTLS(s.config.TLSCert, s.config.TLSKey)\n110: \t}\n111: \n112: \th2cHandler := h2c.NewHandler(s.engine, &http2.Server{})\n113: \ts.httpServer.Handler = h2cHandler\n114: \n115: \tklog.Infof(\"Starting HTTP server on %s\", s.httpServer.Addr)\n116: \treturn s.httpServer.ListenAndServe()\n117: }\n118: \n119: func (s *Server) Run() {\n120: \tstopCh := make(chan os.Signal, 1)\n121: \tsignal.Notify(stopCh, syscall.SIGINT, syscall.SIGTERM)\n122: \n123: \tgo func() {\n124: \t\tif err := s.Start(); err != nil && err != http.ErrServerClosed {\n125: \t\t\tklog.Fatalf(\"server failed: %v\", err)\n126: \t\t}\n127: \t}()\n128: \n129: \t<-stopCh\n130: \tklog.Info(\"shutting down server...\")\n131: \n132: \tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n133: \tdefer cancel()\n134: \n135: \tif err := s.Shutdown(ctx); err != nil {\n136: \t\tklog.Errorf(\"server shutdown failed: %v\", err)\n137: \t}\n138: }\n139: \n140: func (s *Server) Shutdown(ctx context.Context) error {\n141: \tif s.httpServer == nil {\n142: \t\treturn nil\n143: \t}\n144: \treturn s.httpServer.Shutdown(ctx)\n145: }\n\n(End of file - total 145 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"golang.org/x/net/http2\"\n\t\"golang.org/x/net/http2/h2c\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go","time":{"start":1775848017805,"end":1775848017811}}}}
