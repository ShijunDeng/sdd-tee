anitized = sanitized.strip(\"-\")\n37:         if len(sanitized) > 63:\n38:             sanitized = sanitized[:63].rstrip(\"-\")\n39:         return sanitized\n40: \n41:     def deploy_agent_runtime(\n42:         self,\n43:         agent_name: str,\n44:         image_url: str,\n45:         port: int,\n46:         entrypoint: str,\n47:         env_vars: Dict[str, str],\n48:         workload_manager_url: str,\n49:         router_url: str,\n50:         readiness_probe_path: str,\n51:         readiness_probe_port: int,\n52:     ) -> Dict[str, Any]:\n53:         \"\"\"Deploy an AgentRuntime Custom Resource to Kubernetes.\n54: \n55:         Args:\n56:             agent_name: Name of the agent.\n57:             image_url: Container image URL.\n58:             port: Port the agent listens on.\n59:             entrypoint: Command to start the agent.\n60:             env_vars: Environment variables for the container.\n61:             workload_manager_url: URL for the Workload Manager.\n62:             router_url: URL for the Router.\n63:             readiness_probe_path: Path for readiness probe.\n64:             readiness_probe_port: Port for readiness probe.\n65: \n66:         Returns:\n67:             Dict with 'name' and 'endpoint' keys.\n68:         \"\"\"\n69:         sanitized_name = self._sanitize_name(agent_name)\n70: \n71:         resolved_env = []\n72:         for key, value in env_vars.items():\n73:             resolved_env.append({\"name\": key, \"value\": value})\n74: \n75:         for key in [\"WORKLOAD_MANAGER_URL\", \"ROUTER_URL\"]:\n76:             env_value = os.environ.get(key)\n77:             if env_value and not any(e[\"name\"] == key for e in resolved_env):\n78:                 resolved_env.append({\"name\": key, \"value\": env_value})\n79: \n80:         cr_spec = {\n81:             \"apiVersion\": f\"{self.CRD_GROUP}/{self.CRD_VERSION}\",\n82:             \"kind\": \"AgentRuntime\",\n83:             \"metadata\": {\n84:                 \"name\": sanitized_name,\n85:                 \"namespace\": self.namespace,\n86:             },\n87:             \"spec\": {\n88:                 \"image\": image_url,\n89:                 \"port\": port,\n90:                 \"entrypoint\": entrypoint,\n91:                 \"env\": resolved_env,\n92:                 \"workloadManagerUrl\": workload_manager_url,\n93:                 \"routerUrl\": router_url,\n94:                 \"readinessProbe\": {\n95:                     \"path\": readiness_probe_path,\n96:                     \"port\": readiness_probe_port,\n97:                 },\n98:                 \"sessionTimeout\": \"15m\",\n99:                 \"maxSessionDuration\": \"8h\",\n100:                 \"imagePullSecrets\": [{\"name\": \"default-secret\"}],\n101:             },\n102:         }\n103: \n104:         self._custom_api.create_namespaced_custom_object(\n105:             group=self.CRD_GROUP,\n106:             version=self.CRD_VERSION,\n107:             namespace=self.namespace,\n108:             plural=self.CRD_PLURAL,\n109:             body=cr_spec,\n110:         )\n111: \n112:         endpoint = f\"{router_url}/v1/agents/{sanitized_name}\"\n113:         return {\"name\": sanitized_name, \"endpoint\": endpoint}\n114: \n115:     def get_agent_runtime(self, name: str) -> Optional[Dict[str, Any]]:\n116:         \"\"\"Retrieve an existing AgentRuntime CR by name.\n117: \n118:         Args:\n119:             name: The CR name.\n120: \n121:         Returns:\n122:             The CR dict if found, None otherwise.\n123:         \"\"\"\n124:         try:\n125:             return self._custom_api.get_namespaced_custom_object(\n126:                 group=self.CRD_GROUP,\n127:                 version=self.CRD_VERSION,\n128:                 namespace=self.namespace,\n129:                 plural=self.CRD_PLURAL,\n130:                 name=name,\n131:             )\n132:         except ApiException as e:\n133:             if e.status == 404:\n134:                 return None