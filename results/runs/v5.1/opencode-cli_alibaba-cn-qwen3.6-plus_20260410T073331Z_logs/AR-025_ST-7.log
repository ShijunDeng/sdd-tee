{"type":"tool_use","timestamp":1775861054066,"sessionID":"ses_2866ef6d6ffesXIQtY8ta7H3uE","part":{"id":"prt_d799135e8001gPsiPMWBb1VTQ6","messageID":"msg_d79912d81001X6wyWg7xl71DhV","sessionID":"ses_2866ef6d6ffesXIQtY8ta7H3uE","type":"tool","tool":"read","callID":"call_6bd70a5ef40a421a950f28cf","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Metadata service for loading, saving, and updating agent metadata.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import logging\n6: from pathlib import Path\n7: from typing import Any, Dict, List, Optional\n8: \n9: import yaml\n10: from pydantic import BaseModel, Field, field_validator\n11: \n12: logger = logging.getLogger(__name__)\n13: \n14: \n15: class AgentMetadata(BaseModel):\n16:     \"\"\"Pydantic model representing agent metadata.\"\"\"\n17: \n18:     agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n19:     description: Optional[str] = Field(None, description=\"Human-readable summary\")\n20:     language: str = Field(\"python\", description=\"Programming language used\")\n21:     entrypoint: str = Field(..., description=\"Command to launch the agent\")\n22:     port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n23:     build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n24:     region: Optional[str] = Field(None, description=\"Deployment region\")\n25:     version: Optional[str] = Field(None, description=\"Semantic version string for publishing\")\n26:     image: Optional[Dict[str, Any]] = Field(None, description=\"Container image information\")\n27:     auth: Optional[Dict[str, Any]] = Field(None, description=\"Authentication configuration\")\n28:     requirements_file: Optional[str] = Field(\"requirements.txt\", description=\"Python dependency file\")\n29:     registry_url: Optional[str] = Field(\"\", description=\"Registry URL for image publishing\")\n30:     registry_username: Optional[str] = Field(\"\", description=\"Registry username\")\n31:     registry_password: Optional[str] = Field(\"\", description=\"Registry password\")\n32:     agent_endpoint: Optional[str] = Field(None, description=\"Agent endpoint URL\")\n33:     workload_manager_url: Optional[str] = Field(None, description=\"URL for the Workload Manager\")\n34:     router_url: Optional[str] = Field(None, description=\"URL for the Router\")\n35:     readiness_probe_path: Optional[str] = Field(None, description=\"Path for the readiness probe\")\n36:     readiness_probe_port: Optional[int] = Field(None, description=\"Port for the readiness probe\")\n37:     agent_id: Optional[str] = Field(None, description=\"Agent ID assigned by AgentCube\")\n38:     session_id: Optional[str] = Field(None, description=\"The session ID for the agent\")\n39:     k8s_deployment: Optional[Dict[str, Any]] = Field(None, description=\"Kubernetes deployment information\")\n40: \n41:     @field_validator(\"language\", mode=\"before\")\n42:     @classmethod\n43:     def validate_language(cls, v: Optional[str]) -> str:\n44:         if v is None:\n45:             return \"python\"\n46:         lowered = v.lower()\n47:         if lowered not in (\"python\", \"java\"):\n48:             raise ValueError(f\"Unsupported language: {v}. Must be 'python' or 'java'.\")\n49:         return lowered\n50: \n51:     @field_validator(\"build_mode\", mode=\"before\")\n52:     @classmethod\n53:     def validate_build_mode(cls, v: Optional[str]) -> str:\n54:         if v is None:\n55:             return \"local\"\n56:         lowered = v.lower()\n57:         if lowered not in (\"local\", \"cloud\"):\n58:             raise ValueError(f\"Unsupported build_mode: {v}. Must be 'local' or 'cloud'.\")\n59:         return lowered\n60: \n61:     @field_validator(\"port\")\n62:     @classmethod\n63:     def validate_port(cls, v: int) -> int:\n64:         if v < 1 or v > 65535:\n65:             raise ValueError(f\"Port must be between 1 and 65535, got {v}\")\n66:         return v\n67: \n68: \n69: class MetadataService:\n70:     \"\"\"Service for loading, saving, and updating agent metadata files.\"\"\"\n71: \n72:     METADATA_FILES: List[str] = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n73: \n74:     def __init__(self, verbose: bool = False) -> None:\n75:         self.verbose = verbose\n76: \n77:     def load_metadata(self, workspace_path: Path) -> Optional[AgentMetadata]:\n78:         \"\"\"Load agent metadata from the workspace directory.\n79: \n80:         Tries files in order: agent_metadata.yaml -> agent.yaml -> metadata.yaml.\n81:         Returns None if no metadata file exists.\n82:         \"\"\"\n83:         for filename in self.METADATA_FILES:\n84:             filepath = workspace_path / filename\n85:             if filepath.exists():\n86:                 with open(filepath, \"r\") as f:\n87:                     data = yaml.safe_load(f)\n88:                 if data is None:\n89:                     data = {}\n90:                 if self.verbose:\n91:                     logger.info(f\"Loaded metadata from {filepath}\")\n92:                 return AgentMetadata(**data)\n93:         if self.verbose:\n94:             logger.info(\"No metadata file found, using defaults\")\n95:         return None\n96: \n97:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n98:         \"\"\"Save agent metadata to agent_metadata.yaml in the workspace directory.\"\"\"\n99:         filepath = workspace_path / \"agent_metadata.yaml\"\n100:         data = metadata.model_dump(exclude_none=True)\n101:         with open(filepath, \"w\") as f:\n102:             yaml.dump(data, f, default_flow_style=False, indent=2, sort_keys=False)\n103:         if self.verbose:\n104:             logger.info(f\"Saved metadata to {filepath}\")\n105: \n106:     def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n107:         \"\"\"Load existing metadata (or create default), apply updates, save, and return.\"\"\"\n108:         existing = self.load_metadata(workspace_path)\n109:         if existing is None:\n110:             existing = AgentMetadata(\n111:                 agent_name=updates.get(\"agent_name\", workspace_path.name),\n112:                 entrypoint=updates.get(\"entrypoint\", \"\"),\n113:                 language=updates.get(\"language\", \"python\"),\n114:                 port=updates.get(\"port\", 8080),\n115:                 build_mode=updates.get(\"build_mode\", \"local\"),\n116:             )\n117:         data = existing.model_dump()\n118:         for key, value in updates.items():\n119:             if value is not None and value != \"\":\n120:                 data[key] = value\n121:         merged = AgentMetadata(**data)\n122:         self.save_metadata(workspace_path, merged)\n123:         if self.verbose:\n124:             logger.info(f\"Updated metadata fields: {list(updates.keys())}\")\n125:         return merged\n126: \n127:     def validate_workspace(self, workspace_path: Path) -> bool:\n128:         \"\"\"Check if the workspace path exists and is a directory with valid metadata.\"\"\"\n129:         if not workspace_path.exists() or not workspace_path.is_dir():\n130:             return False\n131:         return self.load_metadata(workspace_path) is not None\n132: \n133:     def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n134:         \"\"\"Validate a Python workspace has required files.\"\"\"\n135:         py_files = list(workspace_path.glob(\"*.py\"))\n136:         if not py_files:\n137:             raise ValueError(\"No Python files found in workspace\")\n138:         req_file = metadata.requirements_file or \"requirements.txt\"\n139:         req_path = workspace_path / req_file\n140:         if not req_path.exists():\n141:             raise ValueError(f\"Dependency file not found: {req_file}\")\n142: \n143:     def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n144:         \"\"\"Validate a Java workspace has required files.\"\"\"\n145:         pom = workspace_path / \"pom.xml\"\n146:         if not pom.exists():\n147:             raise ValueError(\"pom.xml is required for Java projects\")\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"\"\"\"Metadata service for loading, saving, and updating agent metadata.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\nlogger = logging.getLogger(__name__)\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Pydantic model representing agent metadata.\"\"\"\n\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: Optional[str] = Field(None, description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775861054057,"end":1775861054065}}}}
