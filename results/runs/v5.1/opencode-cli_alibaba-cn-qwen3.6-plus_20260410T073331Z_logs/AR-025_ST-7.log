ata(agent_name=\"test\", entrypoint=\"ruby app.rb\", language=\"ruby\")\n76:         assert \"Unsupported language\" in str(exc_info.value)\n77: \n78: \n79: class TestAgentMetadataValidateBuildMode:\n80:     def test_local_accepted(self) -> None:\n81:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"local\")\n82:         assert meta.build_mode == \"local\"\n83: \n84:     def test_cloud_accepted(self) -> None:\n85:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"cloud\")\n86:         assert meta.build_mode == \"cloud\"\n87: \n88:     def test_local_uppercase_normalized(self) -> None:\n89:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"LOCAL\")\n90:         assert meta.build_mode == \"local\"\n91: \n92:     def test_hybrid_rejected(self) -> None:\n93:         with pytest.raises(ValidationError) as exc_info:\n94:             AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"hybrid\")\n95:         assert \"Unsupported build_mode\" in str(exc_info.value)\n96: \n97: \n98: class TestAgentMetadataValidatePort:\n99:     def test_valid_port(self) -> None:\n100:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=8080)\n101:         assert meta.port == 8080\n102: \n103:     def test_port_one(self) -> None:\n104:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=1)\n105:         assert meta.port == 1\n106: \n107:     def test_port_max(self) -> None:\n108:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=65535)\n109:         assert meta.port == 65535\n110: \n111:     def test_port_zero_rejected(self) -> None:\n112:         with pytest.raises(ValidationError) as exc_info:\n113:             AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=0)\n114:         assert \"Port must be between 1 and