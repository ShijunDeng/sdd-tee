):\n40:         err = CommandExecutionError(exit_code=42, stderr=\"not found\")\n41:         assert \"42\" in str(err)\n42:         assert \"not found\" in str(err)\n43: \n44:     def test_message_format(self):\n45:         err = CommandExecutionError(exit_code=1, stderr=\"fail\")\n46:         assert str(err) == \"Command failed (exit 1): fail\"\n47: \n48:     def test_is_subclass_of_agent_cube_error(self):\n49:         assert issubclass(CommandExecutionError, AgentCubeError)\n50: \n51:     def test_catchable_as_agent_cube_error(self):\n52:         with pytest.raises(AgentCubeError):\n53:             raise CommandExecutionError(exit_code=1, stderr=\"err\")\n54: \n55: \n56: class TestSessionError:\n57:     def test_is_subclass_of_agent_cube_error(self):\n58:         assert issubclass(SessionError, AgentCubeError)\n59: \n60:     def test_has_correct_docstring(self):\n61:         assert SessionError.__doc__ == \"Raised when session creation or management fails\"\n62: \n63:     def test_catchable_as_agent_cube_error(self):\n64:         with pytest.raises(AgentCubeError):\n65:             raise SessionError(\"session failed\")\n66: \n67: \n68: class TestDataPlaneError:\n69:     def test_is_subclass_of_agent_cube_error(self):\n70:         assert issubclass(DataPlaneError, AgentCubeError)\n71: \n72:     def test_has_correct_docstring(self):\n73:         assert DataPlaneError.__doc__ == \"Raised when Data Plane operations fail\"\n74: \n75:     def test_catchable_as_agent_cube_error(self):\n76:         with pytest.raises(AgentCubeError):\n77:             raise DataPlaneError(\"data plane failed\")\n\n(End of file - total 77 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for exception hierarchy.\"\"\"\n\nimport pytest\n\nfrom agentcube.exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    DataPlaneError,\n    SessionError,\n)\n\n\nclass TestAgentCubeError:\n    def test_is_exception(self):\n        assert issubclass(AgentCubeError, Exception)\n\n  