dboxError(c, err)\n\t\treturn\n\t}\n\n\tif sessionID == \"\" {\n\t\tsessionID = sandboxInfo.SessionID\n\t}\n\n\tif s.storeClient != nil {\n\t\tif err := s.storeClient.UpdateSessionLastActivity(ctx, sessionID, time.Time{}); err != nil {\n\t\t\tklog.Warningf(\"failed to update last activity for session %s: %v\", sessionID, err)\n\t\t}\n\t}\n\n\tif len(sandboxInfo.EntryPoints) == 0 {\n\t\tc.JSON(http.StatusNotFound, gin.H{\"error\": \"no entry point found for sandbox\"})\n\t\treturn\n\t}\n\n\tif err := s.forwardToSandbox(c, sandboxInfo, kind, sessionID); err != nil {\n\t\treturn\n\t}\n\n\tif s.storeClient != nil {\n\t\tif err := s.storeClient.UpdateSessionLastActivity(ctx, sessionID, nil); err != nil {\n\t\t\tklog.Warningf(\"failed to update last activity for session %s: %v\", sessionID, err)\n\t\t}\n\t}\n}\n\nfunc (s *Server) handleAgentInvoke(c *gin.Context) {\n\ts.handleInvoke(c, types.AgentRuntimeKind)\n}\n\nfunc (s *Server) handleCodeInterpreterInvoke(c *gin.Context) {\n\ts.handleInvoke(c, types.CodeInterpreterKind)\n}\n\nfunc (s *Server) forwardToSandbox(c *gin.Context, sandboxInfo *types.SandboxInfo, kind string, sessionID string) error {\n\tinvocationPath := c.Param(\"path\")\n\tif !strings.HasPrefix(invocationPath, \"/\") {\n\t\tinvocationPath = \"/\" + invocationPath\n\t}\n\n\tvar selectedEP *types.EntryPoint\n\tfor i := range sandboxInfo.EntryPoints {\n\t\tep := &sandboxInfo.EntryPoints[i]\n\t\tif strings.HasPrefix(invocationPath, ep.Path) {\n\t\t\tselectedEP = ep\n\t\t\tbreak\n\t\t}\n\t}\n\tif selectedEP == nil && len(sandboxInfo.EntryPoints) > 0 {\n\t\tselectedEP = &sandboxInfo.EntryPoints[0]\n\t}\n\tif selectedEP == nil {\n\t\tc.JSON(http.StatusNotFound, gin.H{\"error\": \"no entry point found for sandbox\"})\n\t\treturn nil\n\t}\n\n\ttargetStr := selectedEP.Endpoint\n\tif selectedEP.Protocol != \"\" && !strings.Contains(targetStr, \"://\") {\n\t\ttargetStr = strings.ToLower(selectedEP.Protocol) + \"://\" + targetStr\n\t}\n\tif !strings.Contains(targetStr