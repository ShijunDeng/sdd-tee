terface interface {\n\tDiscovery() discovery.DiscoveryInterface\n\tRuntimeV1alpha1() runtimev1alpha1.RuntimeV1alpha1Interface\n}\n```\n\n### `Clientset` struct\n\nEmbeds `*discovery.DiscoveryClient` and holds `runtimeV1alpha1 *runtimev1alpha1.RuntimeV1alpha1Client`.\n\n**Constructors**","truncated":false,"loaded":[]},"title":"specs/deployment/client-go.md","time":{"start":1775831963151,"end":1775831963159}}}}
{"type":"tool_use","timestamp":1775831964319,"sessionID":"ses_2882b03e5ffe0qgNxH0zdvDDhW","part":{"id":"prt_d77d556d1001FWC1m9HoUi333y","messageID":"msg_d77d54899001y0z7rXlHd6Vr1x","sessionID":"ses_2882b03e5ffe0qgNxH0zdvDDhW","type":"tool","tool":"read","callID":"call_1626bf094a724550989f32cb","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/pem\"\n9: \t\"errors\"\n10: \t\"os\"\n11: \t\"time\"\n12: \n13: \t\"github.com/golang-jwt/jwt/v5\"\n14: \tcorev1 \"k8s.io/api/core/v1\"\n15: \tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n16: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n17: \t\"k8s.io/client-go/kubernetes\"\n18: \t\"k8s.io/client-go/rest\"\n19: \t\"k8s.io/klog/v2\"\n20: )\n21: \n22: const (\n23: \trsaKeySize         = 2048\n24: \tjwtExpiration      = 5 * time.Minute\n25: \tIdentitySecretName = \"picod-router-identity\"\n26: \tPrivateKeyDataKey  = \"private.pem\"\n27: \tPublicKeyDataKey   = \"public.pem\"\n28: )\n29: \n30: var IdentityNamespace = \"default\"\n31: \n32: func init() {\n33: \tif ns := os.Getenv(\"AGENTCUBE_NAMESPACE\"); ns != \"\" {\n34: \t\tIdentityNamespace = ns\n35: \t}\n36: }\n37: \n38: type JWTManager struct {\n39: \tprivateKey *rsa.PrivateKey\n40: \tpublicKey  *rsa.PublicKey\n41: \tclientset  kubernetes.Interface\n42: \tconfig     *JWTConfig\n43: }\n44: \n45: func NewJWTManager(config *JWTConfig) (*JWTManager, error) {\n46: \tprivateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n47: \tif err != nil {\n48: \t\treturn nil, err\n49: \t}\n50: \n51: \tif config == nil {\n52: \t\tconfig = &JWTConfig{\n53: \t\t\tExpiration: 5 * time.Minute,\n54: \t\t\tIssuer:     \"agentcube-router\",\n55: \t\t\tLeeway:     1 * time.Minute,\n56: \t\t}\n57: \t}\n58: \n59: \treturn &JWTManager{\n60: \t\tprivateKey: privateKey,\n61: \t\tpublicKey:  &privateKey.PublicKey,\n62: \t\tconfig:     config,\n63: \t}, nil\n64: }\n65: \n66: func (m *JWTManager) PublicKey() *rsa.PublicKey {\n67: \treturn m.publicKey\n68: }\n69: \n70: func (m *JWTManager) GenerateToken(claims map[string]interface{}) (string, error) {\n71: \tnow := time.Now()\n72: \ttokenClaims := jwt.MapClaims{\n73: \t\t\"exp\": now.Add(m.config.Expiration).Unix(),\n74: \t\t\"iat\": now.Unix(),\n75: \t\t\"iss\": m.config.Issuer,\n76: \t}\n77: \tfor k, v := range claims {\n78: \t\ttokenClaims[k] = v\n79: \t}\n80: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n81: \treturn token.SignedString(m.privateKey)\n82: }\n83: \n84: func (m *JWTManager) ParseAndValidateToken(tokenString string) (jwt.MapClaims, error) {\n85: \tif tokenString == \"\" {\n86: \t\treturn nil, errors.New(\"invalid token: empty string\")\n87: \t}\n88: \n89: \ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n90: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n91: \t\t\treturn nil, jwt.ErrTokenSignatureInvalid\n92: \t\t}\n93: \t\treturn m.publicKey, nil\n94: \t}, jwt.WithLeeway(m.config.Leeway))\n95: \n96: \tif err != nil {\n97: \t\tif errors.Is(err, jwt.ErrTokenExpired) {\n98: \t\t\treturn nil, errors.New(\"token is expired\")\n99: \t\t}\n100: \t\tif errors.Is(err, jwt.ErrTokenSignatureInvalid) {\n101: \t\t\treturn nil, errors.New(\"invalid signature\")\n102: \t\t}\n103: \t\tif errors.Is(err, jwt.ErrTokenMalformed) {\n104: \t\t\treturn nil, errors.New(\"invalid token\")\n105: \t\t}\n106: \t\treturn nil, err\n107: \t}\n108: \n109: \tif claims, ok := token.Claims.(jwt.MapClaims); ok && token.Valid {\n110: \t\tiss, err := claims.GetIssuer()\n111: \t\tif err != nil || iss != m.config.Issuer {\n112: \t\t\treturn nil, errors.New(\"invalid issuer\")\n113: \t\t}\n114: \t\treturn claims, nil\n115: \t}\n116: \n117: \treturn nil, errors.New(\"invalid token\")\n118: }\n119: \n120: func (m *JWTManager) TryStoreOrLoadJWTKeySecret(ctx context.Context) error {\n121: \tif m.clientset == nil {\n122: \t\tconfig, err := rest.InClusterConfig()\n123: \t\tif err != nil {\n124: \t\t\tklog.Warningf(\"not running in-cluster, using ephemeral keys: %v\", err)\n125: \t\t\treturn nil\n126: \t\t}\n127: \t\tm.clientset, err = kubernetes.NewForConfig(config)\n128: \t\tif err != nil {\n129: \t\t\tklog.Warningf(\"failed to create in-cluster clientset, using ephemeral keys: %v\", err)\n130: \t\t\treturn nil\n131: \t\t}\n132: \t}\n133: \n134: \tsecret := &corev1.Secret{\n135: \t\tObjectMeta: metav1.ObjectMeta{\n136: \t\t\tName:      IdentitySecretName,\n137: \t\t\tNamespace: IdentityNamespace,\n138: \t\t\tLabels: map[string]string{\n139: \t\t\t\t\"app\":       \"agentcube\",\n140: \t\t\t\t\"component\": \"router\",\n141: \t\t\t},\n142: \t\t},\n143: \t\tType: \"Opaque\",\n144: \t\tData: map[string][]byte{\n145: \t\t\tPrivateKeyDataKey: pem.EncodeToMemory(&pem.Block{\n146: \t\t\t\tType:  \"RSA PRIVATE KEY\",\n147: \t\t\t\tBytes: x509.MarshalPKCS1PrivateKey(m.privateKey),\n148: \t\t\t}),\n149: \t\t\tPublicKeyDataKey: pem.EncodeToMemory(&pem.Block{\n150: \t\t\t\tType:  \"PUBLIC KEY\",\n151: \t\t\t\tBytes: x509.MarshalPKCS1PublicKey(m.publicKey),\n152: \t\t\t}),\n153: \t\t},\n154: \t}\n155: \n156: \t_, err := m.clientset.CoreV1().Secrets(IdentityNamespace).Create(ctx, secret, metav1.CreateOptions{})\n157: \tif err != nil {\n158: \t\tif k8serrors.IsAlreadyExists(err) {\n159: \t\t\texisting, getErr := m.clientset.CoreV1().Secrets(IdentityNamespace).Get(ctx, IdentitySecretName, metav1.GetOptions{})\n160: \t\t\tif getErr != nil {\n161: \t\t\t\treturn getErr\n162: \t\t\t}\n163: \t\t\treturn m.loadPrivateKeyPEM(existing.Data[PrivateKeyDataKey])\n164: \t\t}\n165: \t\treturn err\n166: \t}\n167: \treturn nil\n168: }\n169: \n170: func (m *JWTManager) loadPrivateKeyPEM(data []byte) error {\n171: \tblock, _ := pem.Decode(data)\n172: \tif block == nil {\n173: \t\treturn nil\n174: \t}\n175: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n176: \tif err != nil {\n177: \t\treturn err\n178: \t}\n179: \tm.privateKey = privateKey\n180: \tm.publicKey = &privateKey.PublicKey\n181: \treturn nil\n182: }\n\n(End of file - total 182 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go","time":{"start":1775831964304,"end":1775831964318}}}}
{"type":"tool_use","timestamp":1775831965744,"sessionID":"ses_2882b03e5ffe0qgNxH0zdvDDhW","part":{"id":"prt_d77d55b0e001EmOKmGJah0of7W","messageID":"msg_d77d54899001y0z7rXlHd6Vr1x","sessionID":"ses_2882b03e5ffe0qgNxH0zdvDDhW","type":"tool","tool":"read","callID":"call_cf9ade44e6384fa4ad4020dd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"crypto/rand\"\n5: \t\"crypto/rsa\"\n6: \t\"testing\"\n7: \t\"time\"\n8: \n9: \t\"github.com/golang-jwt/jwt/v5\"\n10: \t\"github.com/stretchr/testify/assert\"\n11: \t\"github.com/stretchr/testify/require\"\n12: )\n13: \n14: func TestNewJWTManager_NilConfig(t *testing.T) {\n15: \tmgr, err := NewJWTManager(nil)\n16: \trequire.NoError(t, err)\n17: \trequire.NotNil(t, mgr)\n18: \tassert.Equal(t, 5*time.Minute, mgr.config.Expiration)\n19: \tassert.Equal(t, \"agentcube-router\", mgr.config.Issuer)\n20: \tassert.Equal(t, 1*time.Minute, mgr.config.Leeway)\n21: }\n22: \n23: func TestNewJWTManager_CustomConfig(t *testing.T) {\n24: \tcfg := &JWTConfig{\n25: \t\tExpiration: 10 * time.Minute,\n26: \t\tIssuer:     \"custom-issuer\",\n27: \t\tLeeway:     2 * time.Minute,\n28: \t}\n29: \tmgr, err := NewJWTManager(cfg)\n30: \trequire.NoError(t, err)\n31: \trequire.NotNil(t, mgr)\n32: \tassert.Equal(t, 10*time.Minute, mgr.config.Expiration)\n33: \tassert.Equal(t, \"custom-issuer\", mgr.config.Issuer)\n34: \tassert.Equal(t, 2*time.Minute, mgr.config.Leeway)\n35: }\n36: \n37: func TestJWTManager_PublicKey(t *testing.T) {\n38: \tmgr, err := NewJWTManager(nil)\n39: \trequire.NoError(t, err)\n40: \n41: \tpubKey := mgr.PublicKey()\n42: \trequire.NotNil(t, pubKey)\n43: \n44: \tpubKey2 := mgr.PublicKey()\n45: \tassert.Same(t, pubKey, pubKey2)\n46: }\n47: \n48: func TestJWTManager_GenerateToken(t *testing.T) {\n49: \tmgr, err := NewJWTManager(nil)\n50: \trequire.NoError(t, err)\n51: \n52: \tclaims := map[string]interface{}{\n53: \t\t\"session_id\": \"sess-001\",\n54: \t}\n55: \ttoken, err := mgr.GenerateToken(claims)\n56: \trequire.NoError(t, err)\n57: \tassert.NotEmpty(t, token)\n58: \n59: \tparsedClaims, err := mgr.ParseAndValidateToken(token)\n60: \trequire.NoError(t, err)\n61: \tassert.Equal(t, \"agentcube-router\", parsedClaims[\"iss\"])\n62: \tassert.Equal(t, \"sess-001\", parsedClaims[\"session_id\"])\n63: \tassert.Contains(t, parsedClaims, \"exp\")\n64: \tassert.Contains(t, parsedClaims, \"iat\")\n65: }\n66: \n67: func TestJWTManager_GenerateToken_CustomConfig(t *testing.T) {\n68: \tcfg := &JWTConfig{\n69: \t\tExpiration: 10 * time.Minute,\n70: \t\tIssuer:     \"custom-issuer\",\n71: \t\tLeeway:     2 * time.Minute,\n72: \t}\n73: \tmgr, err := NewJWTManager(cfg)\n74: \trequire.NoError(t, err)\n75: \n76: \ttoken, err := mgr.GenerateToken(nil)\n77: \trequire.NoError(t, err)\n78: \n79: \tparsedClaims, err := mgr.ParseAndValidateToken(token)\n80: \trequire.NoError(t, err)\n81: \tassert.Equal(t, \"custom-issuer\", parsedClaims[\"iss\"])\n82: \n83: \texp, err := parsedClaims.GetExpirationTime()\n84: \trequire.NoError(t, err)\n85: \tassert.WithinDuration(t, time.Now().Add(10*time.Minute), exp.Time, 5*time.Second)\n86: }\n87: \n88: func TestJWTManager_ParseAndValidateToken_ValidToken(t *testing.T) {\n89: \tmgr, err := NewJWTManager(nil)\n90: \trequire.NoError(t, err)\n91: \n92: \ttoken, err := mgr.GenerateToken(map[string]interface{}{\n93: \t\t\"user_id\": \"user-123\",\n94: \t})\n95: \trequire.NoError(t, err)\n96: \n97: \tclaims, err := mgr.ParseAndValidateToken(token)\n98: \trequire.NoError(t, err)\n99: \tassert.Equal(t, \"agentcube-router\", claims[\"iss\"])\n100: \tassert.Equal(t, \"user-123\", claims[\"user_id\"])\n101: }\n102: \n103: func TestJWTManager_ParseAndValidateToken_ExpiredToken(t *testing.T) {\n104: \tmgr, err := NewJWTManager(nil)\n105: \trequire.NoError(t, err)\n106: \n107: \tnow := time.Now()\n108: \ttokenClaims := jwt.MapClaims{\n109: \t\t\"exp\": jwt.NewNumericDate(now.Add(-2 * time.Minute)),\n110: \t\t\"iat\": jwt.NewNumericDate(now.Add(-7 * time.Minute)),\n111: \t\t\"iss\": \"agentcube-router\",\n112: \t}\n113: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n114: \ttokenString, err := token.SignedString(mgr.privateKey)\n115: \trequire.NoError(t, err)\n116: \n117: \t_, err = mgr.ParseAndValidateToken(tokenString)\n118: \trequire.Error(t, err)\n119: \tassert.Contains(t, err.Error(), \"token is expired\")\n120: }\n121: \n122: func TestJWTManager_ParseAndValidateToken_ForgedSignature(t *testing.T) {\n123: \tmgr, err := NewJWTManager(nil)\n124: \trequire.NoError(t, err)\n125: \n126: \tforgedKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n127: \trequire.NoError(t, err)\n128: \n129: \tnow := time.Now()\n130: \ttokenClaims := jwt.MapClaims{\n131: \t\t\"exp\": jwt.NewNumericDate(now.Add(5 * time.Minute)),\n132: \t\t\"iat\": jwt.NewNumericDate(now),\n133: \t\t\"iss\": \"agentcube-router\",\n134: \t}\n135: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n136: \ttokenString, err := token.SignedString(forgedKey)\n137: \trequire.NoError(t, err)\n138: \n139: \t_, err = mgr.ParseAndValidateToken(tokenString)\n140: \trequire.Error(t, err)\n141: \tassert.Contains(t, err.Error(), \"invalid signature\")\n142: }\n143: \n144: func TestJWTManager_ParseAndValidateToken_NonRS256Algorithm(t *testing.T) {\n145: \tmgr, err := NewJWTManager(nil)\n146: \trequire.NoError(t, err)\n147: \n148: \tnow := time.Now()\n149: \ttokenClaims := jwt.MapClaims{\n150: \t\t\"exp\": jwt.NewNumericDate(now.Add(5 * time.Minute)),\n151: \t\t\"iat\": jwt.NewNumericDate(now),\n152: \t\t\"iss\": \"agentcube-router\",\n153: \t}\n154: \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, tokenClaims)\n155: \ttokenString, err := token.SignedString([]byte(\"secret\"))\n156: \trequire.NoError(t, err)\n157: \n158: \t_, err = mgr.ParseAndValidateToken(tokenString)\n159: \trequire.Error(t, err)\n160: \tassert.Contains(t, err.Error(), \"invalid signature\")\n161: }\n162: \n163: func TestJWTManager_ParseAndValidateToken_InvalidIssuer(t *testing.T) {\n164: \tmgr, err := NewJWTManager(nil)\n165: \trequire.NoError(t, err)\n166: \n167: \tnow := time.Now()\n168: \ttokenClaims := jwt.MapClaims{\n169: \t\t\"exp\": jwt.NewNumericDate(now.Add(5 * time.Minute)),\n170: \t\t\"iat\": jwt.NewNumericDate(now),\n171: \t\t\"iss\": \"other-service\",\n172: \t}\n173: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n174: \ttokenString, err := token.SignedString(mgr.privateKey)\n175: \trequire.NoError(t, err)\n176: \n177: \t_, err = mgr.ParseAndValidateToken(tokenString)\n178: \trequire.Error(t, err)\n179: \tassert.Contains(t, err.Error(), \"invalid issuer\")\n180: }\n181: \n182: func TestJWTManager_ParseAndValidateToken_MalformedToken(t *testing.T) {\n183: \tmgr, err := NewJWTManager(nil)\n184: \trequire.NoError(t, err)\n185: \n186: \t_, err = mgr.ParseAndValidateToken(\"not-a-jwt-token\")\n187: \trequire.Error(t, err)\n188: \tassert.Contains(t, err.Error(), \"invalid token\")\n189: }\n190: \n191: func TestJWTManager_ParseAndValidateToken_EmptyString(t *testing.T) {\n192: \tmgr, err := NewJWTManager(nil)\n193: \trequire.NoError(t, err)\n194: \n195: \t_, err = mgr.ParseAndValidateToken(\"\")\n196: \trequire.Error(t, err)\n197: }\n198: \n199: func TestJWTManager_ParseAndValidateToken_Leeway(t *testing.T) {\n200: \tcfg := &JWTConfig{\n201: \t\tExpiration: 5 * time.Minute,\n202: \t\tIssuer:     \"agentcube-router\",\n203: \t\tLeeway:     1 * time.Minute,\n204: \t}\n205: \tmgr, err := NewJWTManager(cfg)\n206: \trequire.NoError(t, err)\n207: \n208: \tnow := time.Now()\n209: \ttokenClaims := jwt.MapClaims{\n210: \t\t\"exp\": jwt.NewNumericDate(now.Add(-30 * time.Second)),\n211: \t\t\"iat\": jwt.NewNumericDate(now.Add(-5 * time.Minute)),\n212: \t\t\"iss\": \"agentcube-router\",\n213: \t}\n214: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n215: \ttokenString, err := token.SignedString(mgr.privateKey)\n216: \trequire.NoError(t, err)\n217: \n218: \tclaims, err := mgr.ParseAndValidateToken(tokenString)\n219: \trequire.NoError(t, err)\n220: \tassert.Equal(t, \"agentcube-router\", claims[\"iss\"])\n221: }\n222: \n223: func TestJWTManager_ParseAndValidateToken_LeewayExceeded(t *testing.T) {\n224: \tcfg := &JWTConfig{\n225: \t\tExpiration: 5 * time.Minute,\n226: \t\tIssuer:     \"agentcube-router\",\n227: \t\tLeeway:     1 * time.Minute,\n228: \t}\n229: \tmgr, err := NewJWTManager(cfg)\n230: \trequire.NoError(t, err)\n231: \n232: \tnow := time.Now()\n233: \ttokenClaims := jwt.MapClaims{\n234: \t\t\"exp\": jwt.NewNumericDate(now.Add(-2 * time.Minute)),\n235: \t\t\"iat\": jwt.NewNumericDate(now.Add(-7 * time.Minute)),\n236: \t\t\"iss\": \"agentcube-router\",\n237: \t}\n238: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n239: \ttokenString, err := token.SignedString(mgr.privateKey)\n240: \trequire.NoError(t, err)\n241: \n242: \t_, err = mgr.ParseAndValidateToken(tokenString)\n243: \trequire.Error(t, err)\n244: \tassert.Contains(t, err.Error(), \"token is expired\")\n245: }\n246: \n247: func TestJWTManager_ConcurrentAccess(t *testing.T) {\n248: \tmgr, err := NewJWTManager(nil)\n249: \trequire.NoError(t, err)\n250: \n251: \tdone := make(chan bool, 10)\n252: \tfor i := 0; i < 10; i++ {\n253: \t\tgo func() {\n254: \t\t\ttoken, err := mgr.GenerateToken(map[string]interface{}{\n255: \t\t\t\t\"session_id\": \"sess-concurrent\",\n256: \t\t\t})\n257: \t\t\tif err != nil {\n258: \t\t\t\tt.Errorf(\"GenerateToken failed: %v\", err)\n259: \t\t\t\tdone <- false\n260: \t\t\t\treturn\n261: \t\t\t}\n262: \t\t\t_, err = mgr.ParseAndValidateToken(token)\n263: \t\t\tif err != nil {\n264: \t\t\t\tt.Errorf(\"ParseAndValidateToken failed: %v\", err)\n265: \t\t\t\tdone <- false\n266: \t\t\t\treturn\n267: \t\t\t}\n268: \t\t\tdone <- true\n269: \t\t}()\n270: \t}\n271: \n272: \tfor i := 0; i < 10; i++ {\n273: \t\tassert.True(t, <-done)\n274: \t}\n275: }\n\n(End of file - total 275 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestNewJWTManager_NilConfig(t *testing.T) {\n\tmgr, err := NewJWTManager(nil)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, mgr)\n\tassert.Equal(t, 5*time.Minute, mgr.config.Expiration)\n\tassert.Equal(t, \"agentcube-router\", mgr.config.Issuer)\n\tassert.Equal(t, 1*time.Minute, mgr.config.Leeway)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt_test.go","time":{"start":1775831965732,"end":1775831965742}}}}
