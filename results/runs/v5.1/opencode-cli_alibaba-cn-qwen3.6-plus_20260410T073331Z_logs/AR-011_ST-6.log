SON(200, gin.H{\"status\": \"ok\"})\n53: \t})\n54: \n55: \treq := httptest.NewRequest(http.MethodGet, \"/v1/test\", nil)\n56: \tw := httptest.NewRecorder()\n57: \n58: \tengine.ServeHTTP(w, req)\n59: \n60: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n61: }\n62: \n63: func TestServer_Routes_V1AcceptsValidAuth(t *testing.T) {\n64: \tgin.SetMode(gin.TestMode)\n65: \n66: \tmgr, err := NewJWTManager(nil)\n67: \trequire.NoError(t, err)\n68: \n69: \ttoken, err := mgr.GenerateToken(nil)\n70: \trequire.NoError(t, err)\n71: \n72: \tengine := gin.New()\n73: \tengine.GET(\"/health/live\", handleHealthLive)\n74: \n75: \tv1 := engine.Group(\"/v1\")\n76: \tv1.Use(AuthMiddleware(mgr))\n77: \n78: \tv1.GET(\"/test\", func(c *gin.Context) {\n79: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n80: \t})\n81: \n82: \treq := httptest.NewRequest(http.MethodGet, \"/v1/test\", nil)\n83: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n84: \tw := httptest.NewRecorder()\n85: \n86: \tengine.ServeHTTP(w, req)\n87: \n88: \tassert.Equal(t, http.StatusOK, w.Code)\n89: }\n90: \n91: func TestServer_MiddlewareOrder(t *testing.T) {\n92: \tgin.SetMode(gin.TestMode)\n93: \n94: \tmgr, err := NewJWTManager(nil)\n95: \trequire.NoError(t, err)\n96: \n97: \tengine := gin.New()\n98: \n99: \tvar middlewareOrder []string\n100: \n101: \tengine.Use(func(c *gin.Context) {\n102: \t\tmiddlewareOrder = append(middlewareOrder, \"before-group\")\n103: \t\tc.Next()\n104: \t})\n105: \n106: \tv1 := engine.Group(\"/v1\")\n107: \tv1.Use(func(c *gin.Context) {\n108: \t\tmiddlewareOrder = append(middlewareOrder, \"logger\")\n109: \t\tc.Next()\n110: \t})\n111: \tv1.Use(func(c *gin.Context) {\n112: \t\tmiddlewareOrder = append(middlewareOrder, \"recovery\")\n113: \t\tc.Next()\n114: \t})\n115: \tv1.Use(AuthMiddleware(mgr))\n116: \tv1.Use(func(c *gin.Context) {\n117: \t\tmiddlewareOrder = append(middlewareOrder, \"concurrency-limit\")\n118: \t\tc.Next()\n119: \t})\n120: \n121: \tv1.GET(\"/test\", func(c *gin.Context) {\n122: \t\tmiddlewareOrder = append(middlewareOrder, \"handler\")\n123: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n124: \t})\n125: \n126: \ttoken, err := mgr.GenerateToken(nil)\n127: \trequire.NoError(t, err)\n128: \n129: \treq := httptest.NewRequest(http.MethodGet, \"/v1/test\", nil)\n130: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n131: \tw := httptest.NewRecorder()\n132: \n133: \tengine.ServeHTTP(w, req)\n134: \n135: \tassert.Equal(t, http.StatusOK, w.Code)\n136: \tassert.Equal(t, []string{\n137: \t\t\"before-group\",\n138: \t\t\"logger\",\n139: \t\t\"recovery\",\n140: \t\t\"concurrency-limit\",\n141: \t\t\"handler\",\n142: \t}, middlewareOrder)\n143: }\n144: \n145: func TestServer_UnauthRequestBeforeConcurrencyLimit(t *testing.T) {\n146: \tgin.SetMode(gin.TestMode)\n147: \n148: \tmgr, err := NewJWTManager(nil)\n149: \trequire.NoError(t, err)\n150: \n151: \tengine := gin.New()\n152: \n153: \tconcurrencyReached := false\n154: \n155: \tv1 := engine.Group(\"/v1\")\n156: \tv1.Use(gin.Recovery())\n157: \tv1.Use(AuthMiddleware(mgr))\n158: \tv1.Use(func(c *gin.Context) {\n159: \t\tconcurrencyReached = true\n160: \t\tc.Next()\n161: \t})\n162: \n163: \tv1.GET(\"/test\", func(c *gin.Context) {\n164: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n165: \t})\n166: \n167: \treq := httptest.NewRequest(http.MethodGet, \"/v1/test\", nil)\n168: \tw := httptest.NewRecorder()\n169: \n170: \tengine.ServeHTTP(w, req)\n171: \n172: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n173: \tassert.False(t, concurrencyReached, \"concurrency limit middleware should not be reached for unauthenticated requests\")\n174: }\n\n(End of file - total 174 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestServer_Routes_HealthEndpointsPublic(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tmgr, err := NewJWTManager(nil)\n\trequire.NoError(t, err)\n\n\tengine := gin.New()\n\tengine.GET(\"/health/live\", handleHealthLive)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server_test.go","time":{"start":1775832175076,"end":1775832175084}}}}
{"type":"tool_use","timestamp":1775832176368,"sessionID":"ses_2882b03e5ffe0qgNxH0zdvDDhW","part":{"id":"prt_d77d892b1001xbtCQZS0WHYX7S","messageID":"msg_d77d88511001cZhpziBfKDVF35","sessionID":"ses_2882b03e5ffe0qgNxH0zdvDDhW","type":"tool","tool":"read","callID":"call_bdf55c5f2d924f6cbd8463a7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/middleware_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/middleware_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"net/http\"\n6: \t\"net/http/httptest\"\n7: \t\"testing\"\n8: \t\"time\"\n9: \n10: \t\"github.com/gin-gonic/gin\"\n11: \t\"github.com/golang-jwt/jwt/v5\"\n12: \t\"github.com/stretchr/testify/assert\"\n13: \t\"github.com/stretchr/testify/require\"\n14: )\n15: \n16: func setupTestRouter(jwtManager *JWTManager) *gin.Engine {\n17: \tgin.SetMode(gin.TestMode)\n18: \tengine := gin.New()\n19: \tengine.Use(AuthMiddleware(jwtManager))\n20: \tengine.GET(\"/protected\", func(c *gin.Context) {\n21: \t\tclaims, exists := c.Get(\"claims\")\n22: \t\tc.JSON(200, gin.H{\n23: \t\t\t\"authenticated\": true,\n24: \t\t\t\"claims\":        claims,\n25: \t\t\t\"has_claims\":    exists,\n26: \t\t})\n27: \t})\n28: \treturn engine\n29: }\n30: \n31: func TestAuthMiddleware_ValidToken(t *testing.T) {\n32: \tmgr, err := NewJWTManager(nil)\n33: \trequire.NoError(t, err)\n34: \n35: \ttoken, err := mgr.GenerateToken(map[string]interface{}{\n36: \t\t\"session_id\": \"sess-001\",\n37: \t})\n38: \trequire.NoError(t, err)\n39: \n40: \trouter := setupTestRouter(mgr)\n41: \n42: \treq := httptest.NewRequest(http.MethodGet, \"/protected\", nil)\n43: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n44: \tw := httptest.NewRecorder()\n45: \n46: \trouter.ServeHTTP(w, req)\n47: \n48: \tassert.Equal(t, http.StatusOK, w.Code)\n49: \n50: \tvar resp map[string]interface{}\n51: \terr = json.Unmarshal(w.Body.Bytes(), &resp)\n52: \trequire.NoError(t, err)\n53: \tassert.Equal(t, true, resp[\"authenticated\"])\n54: \tassert.Equal(t, true, resp[\"has_claims\"])\n55: }\n56: \n57: func TestAuthMiddleware_MissingAuthorizationHeader(t *testing.T) {\n58: \tmgr, err := NewJWTManager(nil)\n59: \trequire.NoError(t, err)\n60: \n61: \trouter := setupTestRouter(mgr)\n62: \n63: \treq := httptest.NewRequest(http.MethodGet, \"/protected\", nil)\n64: \tw := httptest.NewRecorder()\n65: \n66: \trouter.ServeHTTP(w, req)\n67: \n68: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n69: \n70: \tvar resp map[string]string\n71: \terr = json.Unmarshal(w.Body.Bytes(), &resp)\n72: \trequire.NoError(t, err)\n73: \tassert.Equal(t, \"missing authorization header\", resp[\"error\"])\n74: \tassert.Equal(t, \"UNAUTHORIZED\", resp[\"code\"])\n75: }\n76: \n77: func TestAuthMiddleware_InvalidAuthorizationFormat_Basic(t *testing.T) {\n78: \tmgr, err := NewJWTManager(nil)\n79: \trequire.NoError(t, err)\n80: \n81: \trouter := setupTestRouter(mgr)\n82: \n83: \treq := httptest.NewRequest(http.MethodGet, \"/protected\", nil)\n84: \treq.Header.Set(\"Authorization\", \"Basic dXNlcjpwYXNz\")\n85: \tw := httptest.NewRecorder()\n86: \n87: \trouter.ServeHTTP(w, req)\n88: \n89: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n90: \n91: \tvar resp map[string]string\n92: \terr = json.Unmarshal(w.Body.Bytes(), &resp)\n93: \trequire.NoError(t, err)\n94: \tassert.Equal(t, \"invalid authorization format\", resp[\"error\"])\n95: \tassert.Equal(t, \"UNAUTHORIZED\", resp[\"code\"])\n96: }\n97: \n98: func TestAuthMiddleware_InvalidAuthorizationFormat_EmptyToken(t *testing.T) {\n99: \tmgr, err := NewJWTManager(nil)\n100: \trequire.NoError(t, err)\n101: \n102: \trouter := setupTestRouter(mgr)\n103: \n104: \treq := httptest.NewRequest(http.MethodGet, \"/protected\", nil)\n105: \treq.Header.Set(\"Authorization\", \"Bearer \")\n106: \tw := httptest.NewRecorder()\n107: \n108: \trouter.ServeHTTP(w, req)\n109: \n110: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n111: \n112: \tvar resp map[string]string\n113: \terr = json.Unmarshal(w.Body.Bytes(), &resp)\n114: \trequire.NoError(t, err)\n115: \tassert.Equal(t, \"invalid authorization format\", resp[\"error\"])\n116: \tassert.Equal(t, \"UNAUTHORIZED\", resp[\"code\"])\n117: }\n118: \n119: func TestAuthMiddleware_ExpiredToken(t *testing.T) {\n120: \tmgr, err := NewJWTManager(nil)\n121: \trequire.NoError(t, err)\n122: \n123: \tnow := time.Now()\n124: \ttokenClaims := jwt.MapClaims{\n125: \t\t\"exp\": jwt.NewNumericDate(now.Add(-2 * time.Minute)),\n126: \t\t\"iat\": jwt.NewNumericDate(now.Add(-7 * time.Minute)),\n127: \t\t\"iss\": \"agentcube-router\",\n128: \t}\n129: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n130: \ttokenString, err := token.SignedString(mgr.privateKey)\n131: \trequire.NoError(t, err)\n132: \n133: \trouter := setupTestRouter(mgr)\n134: \n135: \treq := httptest.NewRequest(http.MethodGet, \"/protected\", nil)\n136: \treq.Header.Set(\"Authorization\", \"Bearer \"+tokenString)\n137: \tw := httptest.NewRecorder()\n138: \n139: \trouter.ServeHTTP(w, req)\n140: \n141: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n142: \n143: \tvar resp map[string]string\n144: \terr = json.Unmarshal(w.Body.Bytes(), &resp)\n145: \trequire.NoError(t, err)\n146: \tassert.Equal(t, \"token is expired\", resp[\"error\"])\n147: \tassert.Equal(t, \"TOKEN_EXPIRED\", resp[\"code\"])\n148: }\n149: \n150: func TestAuthMiddleware_ForgedToken(t *testing.T) {\n151: \tmgr, err := NewJWTManager(nil)\n152: \trequire.NoError(t, err)\n153: \n154: \tforgedMgr, err := NewJWTManager(nil)\n155: \trequire.NoError(t, err)\n156: \n157: \ttoken, err := forgedMgr.GenerateToken(nil)\n158: \trequire.NoError(t, err)\n159: \n160: \trouter := setupTestRouter(mgr)\n161: \n162: \treq := httptest.NewRequest(http.MethodGet, \"/protected\", nil)\n163: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n164: \tw := httptest.NewRecorder()\n165: \n166: \trouter.ServeHTTP(w, req)\n167: \n168: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n169: \n170: \tvar resp map[string]string\n171: \terr = json.Unmarshal(w.Body.Bytes(), &resp)\n172: \trequire.NoError(t, err)\n173: \tassert.Equal(t, \"invalid token\", resp[\"error\"])\n174: \tassert.Equal(t, \"UNAUTHORIZED\", resp[\"code\"])\n175: }\n176: \n177: func TestAuthMiddleware_CustomClaimsPassedToDownstream(t *testing.T) {\n178: \tmgr, err := NewJWTManager(nil)\n179: \trequire.NoError(t, err)\n180: \n181: \ttoken, err := mgr.GenerateToken(map[string]interface{}{\n182: \t\t\"session_id\": \"sess-001\",\n183: \t\t\"user_id\":    \"user-123\",\n184: \t})\n185: \trequire.NoError(t, err)\n186: \n187: \trouter := setupTestRouter(mgr)\n188: \n189: \treq := httptest.NewRequest(http.MethodGet, \"/protected\", nil)\n190: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n191: \tw := httptest.NewRecorder()\n192: \n193: \trouter.ServeHTTP(w, req)\n194: \n195: \tassert.Equal(t, http.StatusOK, w.Code)\n196: \n197: \tvar resp map[string]interface{}\n198: \terr = json.Unmarshal(w.Body.Bytes(), &resp)\n199: \trequire.NoError(t, err)\n200: \n201: \tclaims, ok := resp[\"claims\"].(map[string]interface{})\n202: \trequire.True(t, ok)\n203: \tassert.Equal(t, \"sess-001\", claims[\"session_id\"])\n204: \tassert.Equal(t, \"user-123\", claims[\"user_id\"])\n205: }\n206: \n207: func TestAuthMiddleware_MalformedToken(t *testing.T) {\n208: \tmgr, err := NewJWTManager(nil)\n209: \trequire.NoError(t, err)\n210: \n211: \trouter := setupTestRouter(mgr)\n212: \n213: \treq := httptest.NewRequest(http.MethodGet, \"/protected\", nil)\n214: \treq.Header.Set(\"Authorization\", \"Bearer not-a-jwt-token\")\n215: \tw := httptest.NewRecorder()\n216: \n217: \trouter.ServeHTTP(w, req)\n218: \n219: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n220: \n221: \tvar resp map[string]string\n222: \terr = json.Unmarsha