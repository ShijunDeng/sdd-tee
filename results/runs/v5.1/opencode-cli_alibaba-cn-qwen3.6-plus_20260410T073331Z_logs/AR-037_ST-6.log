103:             \"example.pcap_analyzer.pcap_analyzer.build_react_agent\"\n104:         ) as mock_build:\n105:             mock_agent = MagicMock()\n106:             mock_build.return_value = mock_agent\n107: \n108:             agent = build_reporter_agent(mock_llm)\n109: \n110:             mock_build.assert_called_once()\n111:             call_args = mock_build.call_args\n112:             assert call_args[0][0] is mock_llm\n113:             assert \"reporter\" in call_args[0][1].lower() or \"report\" in call_args[0][1].lower()\n114:             assert agent is mock_agent\n115: \n116: \n117: class TestPlanScript:\n118:     def test_plan_script_generates_script(self):\n119:         mock_agent = MagicMock()\n120:         with patch(\n121:             \"example.pcap_analyzer.pcap_analyzer.invoke_react_agent\"\n122:         ) as mock_invoke:\n123:             mock_invoke.return_value = \"import scapy\\nprint('analysis')\"\n124: \n125:             result = _plan_script(mock_agent, \"/tmp/test.pcap\")\n126: \n127:             assert result == \"import scapy\\nprint('analysis')\"\n128:             mock_invoke.assert_called_once()\n129:             call_args = mock_invoke.call_args\n130:             assert call_args[0][0] is mock_agent\n131:             assert \"/tmp/test.pcap\" in call_args[0][1]\n132: \n133: \n134: class TestRepairScript:\n135:     def test_repair_script_generates_fixed_script(self):\n136:         mock_agent = MagicMock()\n137:         prev_script = \"import scapy\\nprint('broken')\"\n138:         results = [{\"success\": False, \"error\": \"ImportError\"}]\n139: \n140:         with patch(\n141:             \"example.pcap_analyzer.pcap_analyzer.invoke_react_agent\"\n142:         ) as mock_invoke:\n143:             mock_invoke.return_value = \"import scapy.all\\nprint('fixed')\"\n144: \n145:             result = _repair_script(mock_agent, prev_script, results)\n146: \n147:             assert result == \"import scapy.all\\nprint('fixed')\"\n148:           