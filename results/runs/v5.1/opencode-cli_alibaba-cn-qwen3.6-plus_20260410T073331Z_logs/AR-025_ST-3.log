mode=\"cloud\")\n74:         assert meta.build_mode == \"cloud\"\n75: \n76:     def test_local_uppercase_normalized(self) -> None:\n77:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"LOCAL\")\n78:         assert meta.build_mode == \"local\"\n79: \n80:     def test_hybrid_rejected(self) -> None:\n81:         with pytest.raises(ValidationError) as exc_info:\n82:             AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", build_mode=\"hybrid\")\n83:         assert \"Unsupported build_mode\" in str(exc_info.value)\n84: \n85: \n86: class TestAgentMetadataValidatePort:\n87:     def test_valid_port(self) -> None:\n88:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=8080)\n89:         assert meta.port == 8080\n90: \n91:     def test_port_one(self) -> None:\n92:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=1)\n93:         assert meta.port == 1\n94: \n95:     def test_port_max(self) -> None:\n96:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=65535)\n97:         assert meta.port == 65535\n98: \n99:     def test_port_zero_rejected(self) -> None:\n100:         with pytest.raises(ValidationError) as exc_info:\n101:             AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=0)\n102:         assert \"Port must be between 1 and 65535\" in str(exc_info.value)\n103: \n104:     def test_port_overflow_rejected(self) -> None:\n105:         with pytest.raises(ValidationError) as exc_info:\n106:             AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\", port=70000)\n107:         assert \"Port must be between 1 and 65535\" in str(exc_info.value)\n108: \n109: \n110: class TestAgentMetadataModelDump:\n111:     def test_exclude_none(self) -> None:\n112:         meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\")\n113:         dumped = meta.model_dump(exclude_none=True)\n114:         assert \"agent_name\" in dumped\n115:         assert \"entrypoint\" in dumped\n116:         assert \"language\" in dumped\n117:         assert \"port\" in dumped\n118:         assert \"build_mode\" in dumped\n119:         assert \"region\" not in dumped\n120:         assert \"version\" not in dumped\n121:         assert \"description\" not in dumped\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentMetadata Pydantic model.\"\"\"\n\nimport pytest\nfrom pydantic import ValidationError\n\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestAgentMetadataValidCreation:\n    def test_minimal_valid(self) -> None:\n        meta = AgentMetadata(agent_name=\"test\", entrypoint=\"python main.py\")\n        assert meta.agent_name == \"test\"\n        assert meta.language == \"python\"\n        assert meta.entrypoint == \"python main.py\"\n        assert meta.port == 8080\n        assert meta.build_mode == \"local\"\n\n    def test_full_valid(self) -> None:\n        meta = AgentMetadata(\n            agent_name=\"full-agent\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/services/test_metadata_model.py","time":{"start":1775859523539,"end":1775859523553}}}}
{"type":"tool_use","timestamp":1775859524450,"sessionID":"ses_28686b59affeAylUCxRXkYiV1W","part":{"id":"prt_d7979e03e0014qXes0g8IpsnNr","messageID":"msg_d7979c366001kSs0PWBFKzUaxf","sessionID":"ses_28686b59affeAylUCxRXkYiV1W","type":"tool","tool":"read","callID":"call_201a24c978bb4a47af8bcbcb","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/models/test_pack_models.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/models/test_pack_models.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for MetadataOptions dataclass.\"\"\"\n2: \n3: from dataclasses import asdict\n4: \n5: import pytest\n6: \n7: from agentcube.models.pack_models import MetadataOptions\n8: \n9: \n10: class TestMetadataOptionsDefaults:\n11:     def test_default_values(self) -> None:\n12:         opts = MetadataOptions()\n13:         assert opts.agent_name is None\n14:         assert opts.language == \"python\"\n15:         assert opts.entrypoint is None\n16:         assert opts.port == 8080\n17:         assert opts.build_mode == \"local\"\n18:         assert opts.requirements_file is None\n19:         assert opts.description is None\n20:         assert opts.workload_manager_url == \"\"\n21:         assert opts.router_url == \"\"\n22:         assert opts.readiness_probe_path == \"\"\n23:         assert opts.readiness_probe_port == 8080\n24:         assert opts.registry_url == \"\"\n25:         assert opts.registry_username == \"\"\n26:         assert opts.registry_password == \"\"\n27:         assert opts.agent_endpoint == \"\"\n28: \n29: \n30: class TestMetadataOptionsFromOptions:\n31:     def test_full_options(self) -> None:\n32:         options = {\n33:             \"agent_name\": \"test-agent\",\n34:             \"language\": \"java\",\n35:             \"entrypoint\": \"java -jar app.jar\",\n36:             \"port\": 9090,\n37:             \"build_mode\": \"cloud\",\n38:             \"requirements_file\": \"deps.txt\",\n39:             \"description\": \"A test agent\",\n40:             \"workload_manager_url\": \"http://wm:8080\",\n41:             \"router_url\": \"http://router:8080\",\n42:             \"readiness_probe_path\": \"/health\",\n43:             \"readiness_probe_port\": 9090,\n44:             \"registry_url\": \"http://registry\",\n45:             \"registry_username\": \"user\",\n46:             \"registry_password\": \"pass\",\n47:             \"agent_endpoint\": \"http://agent:8080\",\n48:         }\n49:         opts = MetadataOptions.from_options(options)\n50:         assert opts.agent_name == \"test-agent\"\n51:         assert opts.language == \"java\"\n52:         assert opts.entrypoint == \"java -jar app.jar\"\n53:         assert opts.port == 9090\n54:         assert opts.build_mode == \"cloud\"\n55:         assert opts.requirements_file == \"deps.txt\"\n56:         assert opts.description == \"A test agent\"\n57:         assert opts.workload_manager_url == \"http://wm:8080\"\n58:         assert opts.router_url == \"http://router:8080\"\n59:         assert opts.readiness_probe_path == \"/health\"\n60:         assert opts.readiness_probe_port == 9090\n61:         assert opts.registry_url == \"http://registry\"\n62:         assert opts.registry_username == \"user\"\n63:         assert opts.registry_password == \"pass\"\n64:         assert opts.agent_endpoint == \"http://agent:8080\"\n65: \n66:     def test_partial_options(self) -> None:\n67:         options = {\"agent_name\": \"partial-agent\", \"port\": 3000}\n68:         opts = MetadataOptions.from_options(options)\n69:         assert opts.agent_name == \"partial-agent\"\n70:         assert opts.language == \"python\"\n71:         assert opts.entrypoint is None\n72:         assert opts.port == 3000\n73:         assert opts.build_mode == \"local\"\n74: \n75:     def test_unknown_fields_ignored(self) -> None:\n76:         options = {\n77:             \"agent_name\": \"test\",\n78:             \"unknown_field\": \"should_be_ignored\",\n79:             \"another_unknown\": 42,\n80:         }\n81:         opts = MetadataOptions.from_options(options)\n82:         assert opts.agent_name == \"test\"\n83:         assert not hasattr(opts, \"unknown_field\")\n84: \n85:     def test_empty_options(self) -> None:\n86:         opts = MetadataOptions.from_options({})\n87:         assert opts.agent_name is None\n88:         assert opts.language == \"python\"\n89:         assert opts.port == 8080\n\n(End of file - total 89 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for MetadataOptions dataclass.\"\"\"\n\nfrom dataclasses import asdict\n\nimport pytest\n\nfrom agentcube.models.pack_models import MetadataOptions\n\n\nclass TestMetadataOptionsDefaults:\n    def test_default_values(self) -> None:\n        opts = MetadataOptions()\n        assert opts.agent_name is None\n        assert opts.language == \"python\"\n        assert opts.entrypoint is None\n        assert opts.port == 8080\n        assert opts.build_mode == \"local\"\n        assert opts.requirements_file is None\n        assert opts.description is None\n        assert opts.workload_manager_url == \"\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/models/test_pack_models.py","time":{"start":1775859524433,"end":1775859524448}}}}
