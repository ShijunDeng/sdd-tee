ge_name: str,\n        tag: str = \"latest\",\n        build_args: Optional[Dict[str, str]] = None,\n    ) -> Dict[str, str]:\n        \"\"\"Build a Docker image and return metadata about the result.\"\"\"\n        if self.verbose:\n            logger.debug(\n                \"Building image %s:%s from Dockerfile=%s context=%s build_args=%s\",\n                image_name,\n                tag,\n                dockerfile_path,\n                context_path,\n                build_args,\n            )\n\n        client = docker.from_env()\n        start_time = time.time()\n\n        image, logs = client.images.build(\n            path=str(context_path),\n            dockerfile=str(dockerfile_path),\n            tag=f\"{image_name}:{tag}\",\n            buildargs=build_args,\n        )\n\n        build_time = time.time() - start_time\n        image_info = client.images.get(image.id)\n\n        return {\n            \"image_name\": image_name,\n            \"image_id\": image.short_id,\n            \"image_size\": self._format_size(int(image_info.attrs.get(\"Size\", 0) or 0)),\n            \"build_time\": f\"{build_time:.2f}s\",\n        }\n\n    def get_image_info(self, image_name: str) -> Dict[str, str]:\n        \"\"\"Get metadata about a local Docker image.\n\n        Args:\n            image_name: Image reference (e.g., my-agent:latest).\n\n        Returns:\n            Dict with image_id, short_id, size, tags, created.\n\n        Raises:\n            ValueError: If the image is not found locally.\n        \"\"\"\n        try:\n            return self._get_image_info(image_name)\n        except docker.errors.ImageNotFound:  # type: ignore[attr-defined]\n            raise ValueError(f\"Image not found locally: {image_name}\")\n\n    def _get_image_info(self, image_name: str) -> Dict[str, str]:\n        \"\"\"Internal helper to retrieve image metadata from Docker daemon.\n\n        Args:\n            image_name: Image reference (e.g., my-agent:latest).\n\n        Returns:\n            Dict with image_id, short_id, size, tags, created.\n        \"\"\"\n        client = docker.from_env()\n        image = client.images.get(image_name)  # type: ignore[arg-type]\n        attrs = image.attrs\n        size_bytes = attrs.get(\"Size\", 0)\n        if size_bytes is None:\n            size_bytes = 0\n        created = attrs.get(\"Created\", \"unknown\")\n        if created is None:\n            created = \"unknown\"\n        return {\n            \"image_id\": image.id,\n            \"short_id\": image.short_id,\n            \"size\": self._format_size(int(size_bytes)),\n            \"tags\": \", \".join(image.tags) if image.tags else \"<none>\",\n            \"created\": created,\n        }\n\n    def _format_size(self, size_bytes: int) -> str:\n        \"\"\"Format byte count into a human-readable string.\"\"\"\n        if size_bytes < 1024:\n            return f\"{size_bytes} B\"\n        elif size_bytes < 1024 * 1024:\n            return f\"{size_bytes / 1024:.1f} KB\"\n        elif size_bytes < 1024 * 1024 * 1024:\n            return f\"{size_bytes / (1024 * 1024):.1f} MB\"\n        else:\n            return f\"{size_bytes / (1024 * 1024 * 1024):.1f} GB\"\n\n    def push_image(\n        self,\n        image_name: str,\n        registry_url: Optional[str] = None,\n        username: Optional[str] = None,\n        password: Optional[str] = None,\n    ) -> Dict[str, str]:\n        \"\"\"Push a Docker image to a registry.\n\n        Args:\n            image_name: Image reference (e.g., my-agent:v1.0.0 or registry.example.com/my-agent:v1.0.0).\n            registry_url: Optional registry URL to retag and push to.\n            username: Optional registry username.\n            password: Optional registry password.\n\n        Returns:\n            Dict with 'pushed_image' and 'push_time' keys.\n        \"\"\"\n        if self.verbose:\n            logger.debug(\n                \"Pushing image %s to registry_url=%s username=%s\",\n                image_name,\n                registry_url,\n                username,\n            )\n\n        client = docker.from_env()\n        start_time = time.time()\n\n        if registry_url:\n            parts = image_name.rsplit(\":\", 1)\n            repo = parts[0]\n            tag = parts[1] if len(parts) > 1 else \"latest\"\n            target = f\"{registry_url}/{repo}:{tag}\"\n            self._tag_image_sdk(image_name, target)\n            push_repo = f\"{registry_url}/{repo}\"\n            push_tag = tag\n            pushed_image = target\n        else:\n            parts = image_name.rsplit(\":\", 1)\n            push_repo = parts[0]\n            push_tag = parts[1] if len(parts) > 1 else \"latest\"\n            pushed_image = image_name\n\n        auth_config: Optional[Dict[str, str]] = None\n        if username and password:\n            if registry_url:\n                self._docker_login_sdk(registry_url, username, password)\n            auth_config = {\"username\": username, \"password\": password}\n\n        client.images.push(push_repo, tag=push_tag, auth_config=auth_config)\n\n        push_time = time.time() - start_time\n        return {\"pushed_image\": pushed_image, \"push_time\": f\"{push_time:.2f}s\"}\n\n    def _docker_login_sdk(self, registry_url: str, username: str, password: str) -> None:\n        \"\"\"Log in to a Docker registry using the SDK.\n\n        Args:\n            registry_url: The registry URL.\n            username: Registry username.\n            password: Registry password.\n\n        Raises:\n            docker.errors.APIError: If login fails.\n        \"\"\"\n        client = docker.from_env()\n        client.login(username=username, password=password, registry=registry_url)\n\n    def _tag_image_sdk(self, source_image: str, target_image: str) -> None:\n        \"\"\"Tag a local Docker image with a new name.\n\n        Args:\n            source_image: Source image reference (e.g., my-agent:latest).\n            target_image: Target image reference (e.g., registry.example.com/my-agent:v1.0.0).\n        \"\"\"\n        client = docker.from_env()\n        image = client.images.get(source_image)\n        target_parts = target_image.rsplit(\":\", 1)\n        repository = target_parts[0]\n        tag = target_parts[1] if len(target_parts) > 1 else \"latest\"\n        image.tag(repository, tag=tag)\n\n    def remove_image(self, image_name: str) -> bool:\n        \"\"\"Remove a local Docker image.\n\n        Args:\n            image_name: Image reference to remove.\n\n        Returns:\n            True on success, False on failure (with warning logged).\n        \"\"\"\n        try:\n            client = docker.from_env()\n            client.images.remove(image_name)\n            return True\n        except (docker.errors.ImageNotFound, docker.errors.APIError) as e:  # type: ignore[attr-defined]\n            logger.warning(\"Failed to remove image %s: %s\", image_name, e)\n            return False\n","after":"\"\"\"Docker service for checking daemon availability and building images.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport docker\n\nlogger = logging.getLogger(__name__)\n\n\nclass DockerService:\n    \"\"\"Service for interacting with the local Docker daemon.\"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose\n\n    def check_docker_available(self) -> bool:\n        \"\"\"Check if the Docker daemon is running and reachable.\"\"\"\n        try:\n            client = docker.from_env()\n            client.ping()\n            return True\n        except Exception:\n            return False\n\n    def build_image(\n        self,\n        dockerfile_path: Path,\n        context_path: Path,\n        image_name: str,\n        tag: str = \"latest\",\n        build_args: Optional[Dict[str, str]] = None,\n    ) -> Dict[str, str]:\n        \"\"\"Build