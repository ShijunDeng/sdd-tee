e on success, False on failure (with warning logged).\n        \"\"\"\n        try:\n            client = docker.from_env()\n            client.images.remove(image_name)\n            return True\n        except (docker.errors.ImageNotFound, docker.errors.APIError) as e:  # type: ignore[attr-defined]\n            logger.warning(\"Failed to remove image %s: %s\", image_name, e)\n            return False\n","additions":14,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/docker_service.py","time":{"start":1775858321360,"end":1775858321839}}}}
