{"type":"tool_use","timestamp":1775858223363,"sessionID":"ses_2869a5355ffeUQlTjgego4sLL0","part":{"id":"prt_d796605f1001JadIXAP5V1lWmc","messageID":"msg_d7965f2a3001ofJjB9QXr74adl","sessionID":"ses_2869a5355ffeUQlTjgego4sLL0","type":"tool","tool":"read","callID":"call_f50d1b51d8f045b9bfbf0229","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Publish runtime for deploying agents to Kubernetes.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from pathlib import Path\n6: from typing import Any, Dict\n7: \n8: from agentcube.services.agentcube_provider import AgentCubeProvider\n9: from agentcube.services.docker_service import DockerService\n10: from agentcube.services.k8s_provider import KubernetesProvider\n11: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n12: \n13: \n14: class PublishRuntime:\n15:     \"\"\"Runtime for publishing agents to Kubernetes clusters.\"\"\"\n16: \n17:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n18:         self.verbose = verbose\n19:         self.provider = provider\n20: \n21:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n22:         \"\"\"Publish an agent to a Kubernetes cluster.\n23: \n24:         Args:\n25:             workspace_path: Path to the packaged agent workspace.\n26:             **options: CLI options (version, image_url, provider, etc.).\n27: \n28:         Returns:\n29:             Dict with deployment information.\n30: \n31:         Raises:\n32:             ValueError: If workspace is invalid or required options are missing.\n33:             RuntimeError: If Docker is unavailable or deployment times out.\n34:         \"\"\"\n35:         if not workspace_path.exists():\n36:             raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n37:         if not workspace_path.is_dir():\n38:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n39: \n40:         service = MetadataService(verbose=self.verbose)\n41:         metadata = service.load_metadata(workspace_path)\n42:         if metadata is None:\n43:             raise ValueError(\"Workspace has not been packaged. Run 'pack' first.\")\n44: \n45:         for key in [\"version\", \"description\", \"region\"]:\n46:             value = options.get(key)\n47:             if value is not None:\n48:                 setattr(metadata, key, value)\n49: \n50:         node_port = options.get(\"node_port\")\n51:         if node_port is not None and not (30000 <= node_port <= 32767):\n52:             raise ValueError(\"NodePort must be between 30000 and 32767\")\n53: \n54:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n55:         options[\"image_url\"] = image_url\n56: \n57:         if self.provider == \"agentcube\":\n58:             result = self._publish_cr_to_k8s(workspace_path, metadata, **options)\n59:         elif self.provider == \"k8s\":\n60:             result = self._publish_k8s(workspace_path, metadata, **options)\n61:         else:\n62:             raise ValueError(f\"Unsupported provider: {self.provider}\")\n63: \n64:         self._update_publish_metadata(workspace_path, result)\n65: \n66:         return result\n67: \n68:     def _prepare_image_for_publishing(\n69:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n70:     ) -> str:\n71:         \"\"\"Prepare the container image for publishing based on build mode.\"\"\"\n72:         if metadata.build_mode == \"local\":\n73:             return self._prepare_local_image(workspace_path, metadata, options)\n74:         elif metadata.build_mode == \"cloud\":\n75:             return self._prepare_cloud_image(workspace_path, metadata, options)\n76:         else:\n77:             raise ValueError(f\"Unsupported build mode: {metadata.build_mode}\")\n78: \n79:     def _prepare_local_image(\n80:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n81:     ) -> str:\n82:         \"\"\"Prepare a local Docker image for publishing by pushing to a registry.\"\"\"\n83:         docker_service = DockerService(verbose=self.verbose)\n84: \n85:         if not docker_service.check_docker_available():\n86:             raise RuntimeError(\"Docker is not available or not running\")\n87: \n88:         image_url = options.get(\"image_url\")\n89:         if not image_url:\n90:             if metadata.image and metadata.image.get(\"url\"):\n91:                 image_url = metadata.image[\"url\"]\n92:             else:\n93:                 raise ValueError(\"Image URL is required for local build mode\")\n94: \n95:         version = metadata.version or \"latest\"\n96:         image_tag = f\"{image_url}:{version}\"\n97: \n98:         username = options.get(\"image_username\") or metadata.registry_username\n99:         password = options.get(\"image_password\") or metadata.registry_password\n100:         registry_url = options.get(\"registry_url\") or metadata.registry_url\n101: \n102:         if username and password:\n103:             docker_service._docker_login_sdk(registry_url or \"\", username, password)\n104: \n105:         result = docker_service.push_image(image_tag, registry_url or \"\", username, password)\n106:         return result.get(\"pushed_image\", image_tag)\n107: \n108:     def _prepare_cloud_image(\n109:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n110:     ) -> str:\n111:         \"\"\"Resolve the image URL for cloud build mode.\"\"\"\n112:         image_url = options.get(\"image_url\")\n113:         if image_url:\n114:             return image_url\n115: \n116:         if metadata.image and metadata.image.get(\"url\"):\n117:             return metadata.image[\"url\"]\n118: \n119:         raise ValueError(\"Image URL is required for cloud build mode\")\n120: \n121:     def _publish_cr_to_k8s(\n122:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n123:     ) -> Dict[str, Any]:\n124:         \"\"\"Publish an agent as an AgentRuntime Custom Resource.\"\"\"\n125:         if not metadata.router_url:\n126:             raise ValueError(\n127:                 \"router_url and workload_manager_url are required in agent_metadata.yaml for AgentCube provider\"\n128:             )\n129:         if not metadata.workload_manager_url:\n130:             raise ValueError(\n131:                 \"router_url and workload_manager_url are required in agent_metadata.yaml for AgentCube provider\"\n132:             )\n133:         if not metadata.readiness_probe_path:\n134:             raise ValueError(\"readiness_probe_path is required in agent_metadata.yaml for AgentCube provider\")\n135:         if not metadata.readiness_probe_port:\n136:             raise ValueError(\"readiness_probe_port is required in agent_metadata.yaml for AgentCube provider\")\n137: \n138:         namespace = options.get(\"namespace\") or \"default\"\n139:         provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n140: \n141:         result = provider.deploy_agent_runtime(\n142:             agent_name=metadata.agent_name,\n143:             image_url=options.get(\"image_url\", \"\"),\n144:             port=metadata.port,\n145:             entrypoint=metadata.entrypoint,\n146:             env_vars={},\n147:             workload_manager_url=metadata.workload_manager_url,\n148:             router_url=metadata.router_url,\n149:             readiness_probe_path=metadata.readiness_probe_path,\n150:             readiness_probe_port=metadata.readiness_probe_port,\n151:         )\n152: \n153:         return {\n154:             \"agent_id\": result.get(\"name\"),\n155:             \"agent_endpoint\": result.get(\"endpoint\"),\n156:             \"namespace\": namespace,\n157:             \"k8s_deployment\": {\n158:                 \"type\": \"AgentRuntime\",\n159:                 \"namespace\": namespace,\n160:                 \"cr_name\": result.get(\"name\"),\n161:             },\n162:         }\n163: \n164:     def _publish_k8s(\n165:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n166:     ) -> Dict[str, Any]:\n167:         \"\"\"Publish an agent as a standard Kubernetes Deployment + Service.\"\"\"\n168:         namespace = options.get(\"namespace\") or \"default\"\n169:         replicas = options.get(\"replicas\") or 1\n170:         node_port = options.get(\"node_port\")\n171: \n172:         provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n173: \n174:         result = provider.deploy_agent(\n175:             agent_name=metadata.agent_name,\n176:             image_url=options.get(\"image_url\", \"\"),\n177:             port=metadata.port,\n178:             entrypoint=metadata.entrypoint,\n179:             replicas=replicas,\n180:             node_port=node_port,\n181:             env_vars={},\n182:         )\n183: \n184:         try:\n185:             provider.wait_for_deployment_ready(result[\"deployment_name\"], timeout=120)\n186:         except TimeoutError:\n187:             raise RuntimeError(\n188:                 f\"Deployment {result['deployment_name']} did not become ready within 120s\"\n189:             )\n190: \n191:         return {\n192:             \"deployment_name\": result[\"deployment_name\"],\n193:             \"service_name\": result[\"service_name\"],\n194:             \"service_url\": result[\"service_url\"],\n195:             \"namespace\": namespace,\n196:             \"replicas\": replicas,\n197:             \"node_port\": result.get(\"node_port\"),\n198:             \"k8s_deployment\": {\n199:                 \"type\": \"Deployment\",\n200:                 \"namespace\": namespace,\n201:                 \"deployment_name\": result[\"deployment_name\"],\n202:                 \"service_url\": result[\"service_url\"],\n203:             },\n204:         }\n205: \n206:     def _update_publish_metadata(\n207:         self, workspace_path: Path, agent_info: Dict[str, Any]\n208:     ) -> None:\n209:         \"\"\"Update workspace metadata with publish results.\"\"\"\n210:         service = MetadataService(verbose=self.verbose)\n211:         updates: Dict[str, Any] = {\n212:             \"agent_id\": agent_info.get(\"agent_id\"),\n213:             \"agent_endpoint\": agent_info.get(\"agent_endpoint\") or agent_info.get(\"service_url\"),\n214:             \"k8s_deployment\": agent_info.get(\"k8s_deployment\"),\n215:         }\n216:         service.update_metadata(workspace_path, updates)\n\n(End of file - total 216 lines)\n</content>","metadata":{"preview":"\"\"\"Publish runtime for deploying agents to Kubernetes.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass PublishRuntime:\n    \"\"\"Runtime for publishing agents to Kubernetes clusters.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/publish_runtime.py","time":{"start":1775858223346,"end":1775858223361}}}}
