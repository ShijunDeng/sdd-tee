th.exists():\n            raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n        if not workspace_path.is_dir():\n            raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n\n        service = MetadataService(verbose=self.verbose)\n        metadata = service.load_metadata(workspace_path)\n        if metadata is None:\n            raise ValueError(\"Workspace has not been packaged. Run 'pack' first.\")\n\n        for key in [\"version\", \"description\", \"region\"]:\n            value = options.get(key)\n            if value is not None:\n                setattr(metadata, key, value)\n\n        node_port = options.get(\"node_port\")\n        if node_port is not None and not (30000 <= node_port <= 32767):\n            raise ValueError(\"NodePort must be between 30000 and 32767\")\n\n        image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n        options[\"image_url\"] = image_url\n\n        if self.provider == \"agentcube\":\n            result = self._publish_cr_to_k8s(workspace_path, metadata, **options)\n        elif self.provider == \"k8s\":\n            result = self._publish_k8s(workspace_path, metadata, **options)\n        else:\n            raise ValueError(f\"Unsupported provider: {self.provider}\")\n\n        self._update_publish_metadata(workspace_path, result)\n\n        return result\n\n    def _prepare_image_for_publishing(\n        self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n    ) -> str:\n        \"\"\"Prepare the container image for publishing based on build mode.\"\"\"\n        if metadata.build_mode == \"local\":\n            return self._prepare_local_image(workspace_path, metadata, options)\n        elif metadata.build_mode == \"cloud\":\n            return self._prepare_cloud_image(workspace_path, metadata, options)\n        else:\n            raise ValueError(f\"Unsupported build mode: {metadata.build_mode}\")\n\n    def _prepare_local_image(\n        self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n    ) -> str:\n        \"\"\"Prepare a local Docker image for publishing by pushing to a registry.\"\"\"\n        docker_service = DockerService(verbose=self.verbose)\n\n        if not docker_service.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n        image_url = options.get(\"image_url\")\n        if not image_url:\n            if metadata.image and metadata.image.get(\"url\"):\n                image_url = metadata.image[\"url\"]\n            else:\n                raise ValueError(\"Image URL is required for local build mode\")\n\n        version = metadata.version or \"latest\"\n        image_tag = f\"{image_url}:{version}\"\n\n        username = options.get(\"image_username\") or metadata.registry_username\n        password = options.get(\"image_password\") or metadata.registry_password\n        registry_url = options.get(\"registry_url\") or metadata.registry_url\n\n        if username and password:\n            docker_service._docker_login_sdk(registry_url or \"\", username, password)\n\n        result = docker_service.push_image(image_tag, registry_url or \"\", username, password)\n        return result.get(\"pushed_image\", image_tag)\n\n    def _prepare_cloud_image(\n        self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n    ) -> str:\n        \"\"\"Resolve the image URL for cloud build mode.\"\"\"\n        image_url = options.get(\"image_url\")\n        if image_url:\n            return image_url\n\n        if metadata.image and metadata.image.get(\"url\"):\n            return metadata.image[\"url\"]\n\n        raise ValueError(\"Image URL is required for cloud build mode\")\n\n    def _publish_cr_to_k8s(\n        self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n    ) -> Dict[str, Any]:\n        \"\"\"Publish an agent as an AgentRuntime Custom Resource.\"\"\"\n        if not metadata.router_url:\n            raise ValueError(\n                \"router_url and workload_manager_url are required in agent_metadata.yaml for AgentCube provider\"\n            )\n        if not metadata.workload_manager_url:\n            raise ValueError(\n                \"router_url and workload_manager_url are required in agent_metadata.yaml for AgentCube provider\"\n            )\n        if not metadata.readiness_probe_path:\n            raise ValueError(\"readiness_probe_path is required in agent_metadata.yaml for AgentCube provider\")\n        if not metadata.readiness_probe_port:\n            raise ValueError(\"readiness_probe_port is required in agent_metadata.yaml for AgentCube provider\")\n\n        namespace = options.get(\"namespace\") or \"default\"\n        provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n\n        result = provider.deploy_agent_runtime(\n            agent_name=metadata.agent_name,\n            image_url=options.get(\"image_url\", \"\"),\n            port=metadata.port,\n            entrypoint=metadata.entrypoint,\n            env_vars={},\n            workload_manager_url=metadata.workload_manager_url,\n            router_url=metadata.router_url,\n            readiness_probe_path=metadata.readiness_probe_path,\n            readiness_probe_port=metadata.readiness_probe_port,\n        )\n\n        return {\n            \"agent_id\": result.get(\"name\"),\n            \"agent_endpoint\": result.get(\"endpoint\"),\n            \"namespace\": namespace,\n            \"k8s_deployment\": {\n                \"type\": \"AgentRuntime\",\n                \"namespace\": namespace,\n                \"cr_name\": result.get(\"name\"),\n            },\n        }\n\n    def _publish_k8s(\n        self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n    ) -> Dict[str, Any]:\n        \"\"\"Publish an agent as a standard Kubernetes Deployment + Service.\"\"\"\n        namespace = options.get(\"namespace\") or \"default\"\n        replicas = options.get(\"replicas\") or 1\n        node_port = options.get(\"node_port\")\n\n        provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n\n        result = provider.deploy_agent(\n            agent_name=metadata.agent_name,\n            image_url=options.get(\"image_url\", \"\"),\n            port=metadata.port,\n            entrypoint=metadata.entrypoint,\n            replicas=replicas,\n            node_port=node_port,\n            env_vars={},\n        )\n\n        try:\n            provider.wait_for_deployment_ready(result[\"deployment_name\"], timeout=120)\n        except TimeoutError:\n            raise RuntimeError(\n                f\"Deployment {result['deployment_name']} did not become ready within 120s\"\n            )\n\n        return {\n            \"deployment_name\": result[\"deployment_name\"],\n            \"service_name\": result[\"service_name\"],\n            \"service_url\": result[\"service_url\"],\n            \"namespace\": namespace,\n            \"replicas\": replicas,\n            \"node_port\": result.get(\"node_port\"),\n            \"k8s_deployment\": {\n                \"type\": \"Deployment\",\n                \"namespace\": namespace,\n                \"deployment_name\": result[\"deployment_name\"],\n                \"service_url\": result[\"service_url\"],\n            },\n        }\n\n    def _update_publish_metadata(\n        self, workspace_path: Path, agent_info: Dict[str, Any]\n    ) -> None:\n        \"\"\"Update workspace metadata with publish results.\"\"\"\n        service = MetadataService(verbose=self.verbose)\n        updates: Dict[str, Any] = {\n            \"agent_id\": agent_info.get(\"agent_id\"),\n            \"agent_endpoint\": agent_info.get(\"agent_endpoint\") or agent_info.get(\"service_url\"),\n            \"k8s_deployment\": agent_info.get(\"k8s_deployment\"),\n        }\n        service.update_metadata(workspace_path, updates)\n","after":"\"\"\"Publish runtime for deploying agents to Kubernetes.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass PublishRuntime:\n    \"\"\"Runtime for publishing agents to Kubernetes clusters.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider\n\n    def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n        \"\"\"Publish an agent to a Kubernetes cluster.\n\n        Args:\n            workspace_path: Path to the packaged agent workspace.\n            **options: CLI options (version, image_url, provider, etc.).\n\n        Returns:\n            Dict with deployment information.\n\n        Raises:\n            ValueError: If workspace is invalid or required options are missing.\n            RuntimeError: If Docker is unavailable or deployment times out.\n        \"\"\"\n        if not workspace_path.exists():\n            raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n        if not workspace_path.is_dir():\n            raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n\n        service = MetadataService(verbose=self.verbose)\n        metadata = service.load_metadata(workspace_path)\n        if metadata is None:\n            raise ValueError(\"Workspace has not been packaged. Run 'pack' first.\")\n\n        for key in [\"version\", \"description\", \"region\"]:\n            value = options.get(key)\n            if value is not None:\n                setattr(metadata, key, value)\n\n        node_port = options.get(\"node_port\")\n        if node_port is not None and not (30000 <= node_port <= 32767):\n            raise ValueError(\"NodePort must be between 30000 and 32767\")\n\n        image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n        options[\"image_url\"] = image_url\n\n        if self.provider == \"agentcube\":\n            result = self._publish_cr_to_k8s(workspace_path, metadata, **options)\n        elif self.provider == \"k8s\":\n            result = self._publish_k8s(workspace_path, metadata, **options)\n        else:\n            raise ValueError(f\"Unsupported provider: {self.provider}\")\n\n        self._update_publish_metadata(workspace_path, result)\n\n        return result\n\n    def _prepare_image_for_publishing(\n        self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n    ) -> str:\n        \"\"\"Prepare the container image for publishing based on build mode.\"\"\"\n        if metadata.build_mode == \"local\":\n            return self._prepare_local_image(workspace_path, metadata, options)\n        elif metadata.build_mode == \"cloud\":\n            return self._prepare_cloud_image(workspace_path, metadata, options)\n        else:\n            raise ValueError(f\"Unsupported build mode: {metadata.build_mode}\")\n\n    def _prepare_local_image(\n        self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n    ) -> str:\n        \"\"\"Prepare a local Docker image for publishing by pushing to a registry.\"\"\"\n        docker_service = DockerService(verbose=self.verbose)\n\n        if not docker_service.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n        image_url = options.get(\"image_url\")\n        if not image_url:\n            if metadata.image and metadata.image.get(\"url\"):\n                image_url = metadata.image[\"url\"]\n            else:\n                raise ValueError(\"Image URL is required for local