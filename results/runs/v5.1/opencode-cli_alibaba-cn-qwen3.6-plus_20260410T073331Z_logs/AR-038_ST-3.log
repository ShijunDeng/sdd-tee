{"type":"tool_use","timestamp":1775887334166,"sessionID":"ses_284e24014ffe4WImNheu6RKOHU","part":{"id":"prt_d7b223668001q3V3RTQM1TyH99","messageID":"msg_d7b2216ea001zvMrhocxjKS3gu","sessionID":"ses_284e24014ffe4WImNheu6RKOHU","type":"tool","tool":"read","callID":"call_93b3cbff06ad4a268d15d1a7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/response/response_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/response/response_test.go</path>\n<type>file</type>\n<content>\n1: package response\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"net/http\"\n6: \t\"net/http/httptest\"\n7: \t\"testing\"\n8: \n9: \t\"github.com/gin-gonic/gin\"\n10: \t\"github.com/stretchr/testify/assert\"\n11: )\n12: \n13: func TestJSON_Success(t *testing.T) {\n14: \tgin.SetMode(gin.ReleaseMode)\n15: \tw := httptest.NewRecorder()\n16: \tc, _ := gin.CreateTestContext(w)\n17: \n18: \tdata := map[string]string{\"key\": \"value\"}\n19: \tJSON(c, http.StatusOK, data)\n20: \n21: \tassert.Equal(t, http.StatusOK, w.Code)\n22: \tassert.Equal(t, \"application/json\", w.Header().Get(\"Content-Type\"))\n23: \n24: \tvar resp SuccessResponse\n25: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n26: \tassert.NoError(t, err)\n27: \tresult := resp.Data.(map[string]interface{})\n28: \tassert.Equal(t, \"value\", result[\"key\"])\n29: }\n30: \n31: func TestCreated_Success(t *testing.T) {\n32: \tgin.SetMode(gin.ReleaseMode)\n33: \tw := httptest.NewRecorder()\n34: \tc, _ := gin.CreateTestContext(w)\n35: \n36: \tdata := map[string]string{\"name\": \"test\"}\n37: \tCreated(c, data)\n38: \n39: \tassert.Equal(t, http.StatusCreated, w.Code)\n40: \n41: \tvar resp SuccessResponse\n42: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n43: \tassert.NoError(t, err)\n44: \tresult := resp.Data.(map[string]interface{})\n45: \tassert.Equal(t, \"test\", result[\"name\"])\n46: }\n47: \n48: func TestError_BadRequest(t *testing.T) {\n49: \tgin.SetMode(gin.ReleaseMode)\n50: \tw := httptest.NewRecorder()\n51: \tc, _ := gin.CreateTestContext(w)\n52: \n53: \tError(c, http.StatusBadRequest, 40001, \"missing parameter\")\n54: \n55: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n56: \n57: \tvar resp ErrorResponse\n58: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n59: \tassert.NoError(t, err)\n60: \tassert.Equal(t, \"missing parameter\", resp.Error)\n61: \tassert.Equal(t, 40001, resp.Code)\n62: \tassert.Empty(t, resp.RequestID)\n63: }\n64: \n65: func TestError_NotFound(t *testing.T) {\n66: \tgin.SetMode(gin.ReleaseMode)\n67: \tw := httptest.NewRecorder()\n68: \tc, _ := gin.CreateTestContext(w)\n69: \n70: \tError(c, http.StatusNotFound, 40401, \"not found\")\n71: \n72: \tassert.Equal(t, http.StatusNotFound, w.Code)\n73: \n74: \tvar resp ErrorResponse\n75: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n76: \tassert.NoError(t, err)\n77: \tassert.Equal(t, 40401, resp.Code)\n78: }\n79: \n80: func TestError_Internal(t *testing.T) {\n81: \tgin.SetMode(gin.ReleaseMode)\n82: \tw := httptest.NewRecorder()\n83: \tc, _ := gin.CreateTestContext(w)\n84: \n85: \tError(c, http.StatusInternalServerError, 50001, \"internal error\")\n86: \n87: \tassert.Equal(t, http.StatusInternalServerError, w.Code)\n88: \n89: \tvar resp ErrorResponse\n90: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n91: \tassert.NoError(t, err)\n92: \tassert.Equal(t, 50001, resp.Code)\n93: }\n94: \n95: func TestError_WithRequestID(t *testing.T) {\n96: \tgin.SetMode(gin.ReleaseMode)\n97: \tw := httptest.NewRecorder()\n98: \tc, _ := gin.CreateTestContext(w)\n99: \n100: \tErrorWithID(c, http.StatusBadRequest, 40001, \"bad request\", \"test-request-id\")\n101: \n102: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n103: \n104: \tvar resp ErrorResponse\n105: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n106: \tassert.NoError(t, err)\n107: \tassert.Equal(t, \"bad request\", resp.Error)\n108: \tassert.Equal(t, 40001, resp.Code)\n109: \tassert.Equal(t, \"test-request-id\", resp.RequestID)\n110: }\n\n(End of file - total 110 lines)\n</content>","metadata":{"preview":"package response\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestJSON_Success(t *testing.T) {\n\tgin.SetMode(gin.ReleaseMode)\n\tw := httptest.NewRecorder()\n\tc, _ := gin.CreateTestContext(w)\n\n\tdata := map[string]string{\"key\": \"value\"}\n\tJSON(c, http.StatusOK, data)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/response/response_test.go","time":{"start":1775887334156,"end":1775887334164}}}}
