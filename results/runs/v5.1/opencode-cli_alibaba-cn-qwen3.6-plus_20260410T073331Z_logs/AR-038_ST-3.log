eUpdateFailed)\n84: \t\t\t}\n85: \t\t\treturn fmt.Errorf(\"failed to update sandbox for session %s: %w\", sessionID, err)\n86: \t\t}\n87: \n88: \t\tif status == StatusTerminated {\n89: \t\t\tlog.Printf(\"[reconciler] CodeInterpreter %s/%s terminated, cleaning up session %s\", namespace, name, sessionID)\n90: \t\t\tif err := r.store.DeleteSandboxBySessionID(ctx, sessionID); err != nil {\n91: \t\t\t\tif r.metricsRecorder != nil {\n92: \t\t\t\t\tr.metricsRecorder.IncReconcileErrors(resourceTypeCodeInterpreter, errorTypeStoreUnreachable)\n93: \t\t\t\t}\n94: \t\t\t\treturn fmt.Errorf(\"failed to delete sandbox by session %s after termination: %w\", sessionID, err)\n95: \t\t\t}\n96: \t\t}\n97: \t}\n98: \n99: \tif ci.Spec.WarmPoolSize != nil && *ci.Spec.WarmPoolSize > 0 {\n100: \t\tlog.Printf(\"[reconciler] CodeInterpreter %s/%s warm pool activated with size %d\", namespace, name, *ci.Spec.WarmPoolSize)\n101: \t}\n102: \n103: \treturn nil\n104: }\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/client-go/tools/cache\"\n)\n\nfunc (r *SandboxReconciler) reconcileCodeInterpreter(key string) error {\n\tnamespace, name, err := cache.SplitMetaNamespaceKey(key)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"invalid key %q: %w\", key, err)\n\t}\n\n\tci, err := r.ciLister.CodeInterpreters(namespace).Get(name)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/codeinterpreter.go","time":{"start":1775887319498,"end":1775887319508}}}}
