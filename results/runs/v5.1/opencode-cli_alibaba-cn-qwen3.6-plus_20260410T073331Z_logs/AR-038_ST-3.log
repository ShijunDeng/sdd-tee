essionId\"`\n42: \tSandboxID   string       `json:\"sandboxId\"`\n43: \tSandboxName string       `json:\"sandboxName\"`\n44: \tEntryPoints []EntryPoint `json:\"entryPoints\"`\n45: }\n46: \n47: type EntryPoint struct {\n48: \tPath     string `json:\"path\"`\n49: \tProtocol string `json:\"protocol\"`\n50: \tEndpoint string `json:\"endpoint\"`\n51: }\n52: \n53: type SandboxInfo struct {\n54: \tSessionID      string       `json:\"sessionId\"`\n55: \tSandboxName    string       `json:\"sandboxName\"`\n56: \tSandboxID      string       `json:\"sandboxId\"`\n57: \tWorkloadName   string       `json:\"workloadName\"`\n58: \tNamespace      string       `json:\"namespace\"`\n59: \tKind           string       `json:\"kind\"`\n60: \tPodIP          string       `json:\"podIp,omitempty\"`\n61: \tEntryPoints    []EntryPoint `json:\"entryPoints,omitempty\"`\n62: \tCreatedAt      time.Time    `json:\"createdAt\"`\n63: \tExpiresAt      time.Time    `json:\"expiresAt\"`\n64: \tStatus         string       `json:\"status\"`\n65: \tLastActivityAt time.Time    `json:\"lastActivityAt\"`\n66: }\n67: \n68: type SandboxStatus struct {\n69: \tStatus string\n70: \tError  error\n71: }\n\n(End of file - total 71 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"fmt\"\n\t\"time\"\n)\n\ntype MetricsRecorder interface {\n\tIncReconcileTotal(resourceType string, result string)\n\tObserveReconcileDuration(resourceType string, duration time.Duration)\n\tIncReconcileErrors(resourceType string, errorType string)\n\tSetWorkqueueDepth(depth int)\n\tIncWorkqueueAdds(resourceType string)\n\n\tIncGCCleanupTotal(reason string)\n\tObserveGCCleanupDuration(reason string, duration time.Duration)\n\tIncGCCleanupErrors(reason string)\n\tObserveGCCycleDuration(duration time.Duration)\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/models.go","time":{"start":1775887324752,"end":1775887324758}}}}
