{"type":"tool_use","timestamp":1775887330169,"sessionID":"ses_284e24014ffe4WImNheu6RKOHU","part":{"id":"prt_d7b2226ba001bt6gespYCZbRhj","messageID":"msg_d7b2216ea001zvMrhocxjKS3gu","sessionID":"ses_284e24014ffe4WImNheu6RKOHU","type":"tool","tool":"read","callID":"call_d39c21f53bc4426291dc0484","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"encoding/json\"\n7: \t\"errors\"\n8: \t\"net/http\"\n9: \t\"net/http/httptest\"\n10: \t\"testing\"\n11: \t\"time\"\n12: \n13: \t\"github.com/gin-gonic/gin\"\n14: \t\"github.com/stretchr/testify/assert\"\n15: \t\"github.com/stretchr/testify/require\"\n16: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n17: )\n18: \n19: type mockStore struct {\n20: \tsandboxes map[string]*SandboxInfo\n21: }\n22: \n23: func newMockStore() *mockStore {\n24: \treturn &mockStore{\n25: \t\tsandboxes: make(map[string]*SandboxInfo),\n26: \t}\n27: }\n28: \n29: func (m *mockStore) StoreSandbox(ctx context.Context, info *SandboxInfo) error {\n30: \tm.sandboxes[info.SessionID] = info\n31: \treturn nil\n32: }\n33: \n34: func (m *mockStore) UpdateSandbox(ctx context.Context, sessionID string, info *SandboxInfo) error {\n35: \tif _, exists := m.sandboxes[sessionID]; !exists {\n36: \t\treturn errors.New(\"sandbox not found\")\n37: \t}\n38: \tm.sandboxes[sessionID] = info\n39: \treturn nil\n40: }\n41: \n42: func (m *mockStore) GetSandbox(ctx context.Context, sessionID string) (*SandboxInfo, error) {\n43: \tinfo, exists := m.sandboxes[sessionID]\n44: \tif !exists {\n45: \t\treturn nil, errors.New(\"sandbox not found\")\n46: \t}\n47: \treturn info, nil\n48: }\n49: \n50: func (m *mockStore) DeleteSandbox(ctx context.Context, sessionID string) error {\n51: \tif _, exists := m.sandboxes[sessionID]; !exists {\n52: \t\treturn errors.New(\"sandbox not found\")\n53: \t}\n54: \tdelete(m.sandboxes, sessionID)\n55: \treturn nil\n56: }\n57: \n58: func (m *mockStore) ListSandboxes(ctx context.Context) ([]*SandboxInfo, error) {\n59: \tresult := make([]*SandboxInfo, 0, len(m.sandboxes))\n60: \tfor _, info := range m.sandboxes {\n61: \t\tresult = append(result, info)\n62: \t}\n63: \treturn result, nil\n64: }\n65: \n66: func TestDeleteSandboxRequest_Validate_SessionIDRequired(t *testing.T) {\n67: \treq := &DeleteSandboxRequest{\n68: \t\tNamespace: \"default\",\n69: \t}\n70: \terr := req.Validate()\n71: \tassert.Error(t, err)\n72: \tassert.Contains(t, err.Error(), \"sessionId is required\")\n73: }\n74: \n75: func TestDeleteSandboxRequest_Validate_NamespaceRequired(t *testing.T) {\n76: \treq := &DeleteSandboxRequest{\n77: \t\tSessionID: \"test-session\",\n78: \t}\n79: \terr := req.Validate()\n80: \tassert.Error(t, err)\n81: \tassert.Contains(t, err.Error(), \"namespace is required\")\n82: }\n83: \n84: func TestDeleteSandboxRequest_Validate_Valid(t *testing.T) {\n85: \treq := &DeleteSandboxRequest{\n86: \t\tSessionID: \"test-session\",\n87: \t\tNamespace: \"default\",\n88: \t}\n89: \terr := req.Validate()\n90: \tassert.NoError(t, err)\n91: }\n92: \n93: func TestSandboxDeleteHandler_ResolveGVR_Sandboxes(t *testing.T) {\n94: \thandler := &SandboxDeleteHandler{}\n95: \tgvr, err := handler.resolveGVR(SandboxesKind)\n96: \trequire.NoError(t, err)\n97: \tassert.Equal(t, SandboxGVR, gvr)\n98: }\n99: \n100: func TestSandboxDeleteHandler_ResolveGVR_SandboxClaims(t *testing.T) {\n101: \thandler := &SandboxDeleteHandler{}\n102: \tgvr, err := handler.resolveGVR(SandboxClaimsKind)\n103: \trequire.NoError(t, err)\n104: \tassert.Equal(t, SandboxClaimGVR, gvr)\n105: }\n106: \n107: func TestSandboxDeleteHandler_ResolveGVR_UnknownKind(t *testing.T) {\n108: \thandler := &SandboxDeleteHandler{}\n109: \t_, err := handler.resolveGVR(\"UnknownKind\")\n110: \tassert.Error(t, err)\n111: \tassert.Contains(t, err.Error(), \"unknown sandbox kind\")\n112: }\n113: \n114: func TestDeleteSandbox_InvalidRequestBody(t *testing.T) {\n115: \tgin.SetMode(gin.ReleaseMode)\n116: \tw := httptest.NewRecorder()\n117: \tc, _ := gin.CreateTestContext(w)\n118: \tc.Request = httptest.NewRequest(http.MethodPost, \"/delete\", nil)\n119: \n120: \tstore := newMockStore()\n121: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{\n122: \t\tStore: store,\n123: \t})\n124: \n125: \thandler.DeleteSandbox(c)\n126: \n127: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n128: \n129: \tvar resp map[string]interface{}\n130: \terr := json.Unmarshal(w.Body.Bytes(), &resp)\n131: \trequire.NoError(t, err)\n132: \tassert.Equal(t, \"Invalid request body\", resp[\"error\"])\n133: }\n134: \n135: func TestDeleteSandbox_MissingSessionID(t *testing.T) {\n136: \tgin.SetMode(gin.ReleaseMode)\n137: \tw := httptest.NewRecorder()\n138: \tc, _ := gin.CreateTestContext(w)\n139: \tc.Request = httptest.NewRequest(http.MethodPost, \"/delete\", bytes.NewBufferString(`{\"namespace\": \"default\"}`))\n140: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n141: \n142: \tstore := newMockStore()\n143: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{\n144: \t\tStore: store,\n145: \t})\n146: \n147: \thandler.DeleteSandbox(c)\n148: \n149: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n150: }\n151: \n152: func TestDeleteSandbox_SessionNotFound(t *testing.T) {\n153: \tgin.SetMode(gin.ReleaseMode)\n154: \tw := httptest.NewRecorder()\n155: \tc, _ := gin.CreateTestContext(w)\n156: \tc.Request = httptest.NewRequest(http.MethodPost, \"/delete\", bytes.NewBufferString(`{\"sessionId\": \"nonexistent\", \"namespace\": \"default\"}`))\n157: \tc.Request.Header.Set(\"Content-Type\", \"application/json\")\n158: \n159: \tstore := newMockStore()\n160: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{\n161: \t\tStore: store,\n162: \t})\n163: \n164: \thandler.DeleteSandbox(c)\n165: \n166: \tassert.Equal(t, http.StatusNotFound, w.Code)\n167: }\n168: \n169: func TestDeleteSandboxByName_MissingName(t *testing.T) {\n170: \tgin.SetMode(gin.ReleaseMode)\n171: \tw := httptest.NewRecorder()\n172: \tc, _ := gin.CreateTestContext(w)\n173: \tc.Request = httptest.NewRequest(http.MethodDelete, \"/sandboxes/\", nil)\n174: \tc.Params = gin.Params{{Key: \"name\", Value: \"\"}}\n175: \n176: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{})\n177: \n178: \thandler.DeleteSandboxByName(c)\n179: \n180: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n181: }\n182: \n183: func TestDeleteSandboxByName_MissingNamespace(t *testing.T) {\n184: \tgin.SetMode(gin.ReleaseMode)\n185: \tw := httptest.NewRecorder()\n186: \tc, _ := gin.CreateTestContext(w)\n187: \tc.Request = httptest.NewRequest(http.MethodDelete, \"/sandboxes/test-sandbox\", nil)\n188: \tc.Params = gin.Params{{Key: \"name\", Value: \"test-sandbox\"}}\n189: \tc.Request.URL.RawQuery = \"\"\n190: \n191: \thandler := NewSandboxDeleteHandler(&SandboxDeleteHandlerDeps{})\n192: \n193: \thandler.DeleteSandboxByName(c)\n194: \n195: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n196: }\n197: \n198: func TestDeleteSandboxResponse_JSONSerialization(t *testing.T) {\n199: \tresp := &DeleteSandboxResponse{\n200: \t\tSessionID:   \"test-session\",\n201: \t\tSandboxName: \"test-sandbox\",\n202: \t\tDeleted:     true,\n203: \t\tMessage:     \"sandbox deleted successfully\",\n204: \t}\n205: \n206: \tdata, err := json.Marshal(resp)\n207: \trequire.NoError(t, err)\n208: \n209: \tvar decoded DeleteSandboxResponse\n210: \terr = json.Unmarshal(data, &decoded)\n211: \trequire.NoError(t, err)\n212: \n213: \tassert.Equal(t, resp.SessionID, decoded.SessionID)\n214: \tassert.Equal(t, resp.SandboxName, decoded.SandboxName)\n215: \tassert.Equal(t, resp.Deleted, decoded.Deleted)\n216: \tassert.Equal(t, resp.Message, decoded.Message)\n217: }\n218: \n219: func TestSandboxInfo_WithAllFields(t *testing.T) {\n220: \tnow := time.Now()\n221: \texpiresAt := now.Add(8 * time.Hour)\n222: \n223: \tinfo := &SandboxInfo{\n224: \t\tSessionID:    \"session-123\",\n225: \t\tSandboxName:  \"sandbox-abc\",\n226: \t\tSandboxID:    \"uid-456\",\n227: \t\tWorkloadName: \"my-runtime\",\n228: \t\tNamespace:    \"default\",\n229: \t\tKind:         SandboxesKind,\n230: \t\tPodIP:        \"10.0.0.1\",\n231: \t\tEntryPoints: []EntryPoint{\n232: \t\t\t{Path: \"/\", Protocol: \"HTTP\", Endpoint: \"10.0.0.1:8080\"},\n233: \t\t},\n234: \t\tCreatedAt: now,\n235: \t\tExpiresAt: expiresAt,\n236: \t\tStatus:    \"running\",\n237: \t}\n238: \n239: \tassert.Equal(t, \"session-123\", info.SessionID)\n240: \tassert.Equal(t, \"sandbox-abc\", info.SandboxName)\n241: \tassert.Equal(t, \"running\", info.Status)\n242: \tassert.False(t, info.ExpiresAt.IsZero())\n243: }\n244: \n245: func TestDeleteSandboxRequest_AllFieldsSet(t *testing.T) {\n246: \treq := &DeleteSandboxRequest{\n247: \t\tSessionID: \"session-123\",\n248: \t\tNamespace: \"test-namespace\",\n249: \t}\n250: \n251: \tassert.NoError(t, req.Validate())\n252: \tassert.Equal(t, \"session-123\", req.SessionID)\n253: \tassert.Equal(t, \"test-namespace\", req.Namespace)\n254: }\n255: \n256: func TestMockStore_StoreAndGet(t *testing.T) {\n257: \tstore := newMockStore()\n258: \tctx := context.Background()\n259: \n260: \tinfo := &SandboxInfo{\n261: \t\tSessionID:   \"test-session\",\n262: \t\tSandboxName: \"test-sandbox\",\n263: \t\tNamespace:   \"default\",\n264: \t\tKind:        SandboxesKind,\n265: \t\tCreatedAt:   time.Now(),\n266: \t\tStatus:      \"running\",\n267: \t}\n268: \n269: \terr := store.StoreSandbox(ctx, info)\n270: \trequire.NoError(t, err)\n271: \n272: \tretrieved, err := store.GetSandbox(ctx, \"test-session\")\n273: \trequire.NoError(t, err)\n274: \tassert.Equal(t, info.SessionID, retrieved.SessionID)\n275: \tassert.Equal(t, info.SandboxName, retrieved.SandboxName)\n276: }\n277: \n278: func TestMockStore_Update(t *testing.T) {\n279: \tstore := newMockStore()\n280: \tctx := context.Background()\n281: \n282: \tinfo := &SandboxInfo{\n283: \t\tSessionID:   \"test-session\",\n284: \t\tSandboxName: \"test-sandbox\",\n285: \t\tNamespace:   \"default\",\n286: \t\tKind:        SandboxesKind,\n287: \t\tCreatedAt:   time.Now(),\n288: \t\tStatus:      \"pending\",\n289: \t}\n290: \n291: \terr := store.StoreSandbox(ctx, info)\n292: \trequire.NoError(t, err)\n293: \n294: \tinfo.Status = \"running\"\n295: \terr = store.UpdateSandbox(ctx, \"test-session\", info)\n296: \trequire.NoError(t, err)\n297: \n298: \tretrieved, err := store.GetSandbox(ctx, \"test-session\")\n299: \trequire.NoError(t, err)\n300: \tassert.Equal(t, \"running\", retrieved.Status)\n301: }\n302: \n303: func TestMockStore_UpdateNonExistent(t *testing.T) {\n304: \tstore := newMockStore()\n305: \tctx := context.Background()\n306: \n307: \tinfo := &SandboxInfo{\n308: \t\tSessionID:   \"test-session\",\n309: \t\tSandboxName: \"test-sandbox\",\n310: \t}\n311: \n312: \terr := store.UpdateSandbox(ctx, \"nonexistent\", info)\n313: \tassert.Error(t, err)\n314: }\n315: \n316: func TestMockStore_Delete(t *testing.T) {\n317: \tstore := newMockStore()\n318: \tctx := context.Background()\n319: \n320: \tinfo := &SandboxInfo{\n321: \t\tSessionID:   \"test-session\",\n322: \t\tSandboxName: \"test-sandbox\",\n323: \t}\n324: \n325: \terr := store.StoreSandbox(ctx, info)\n326: \trequire.NoError(t, err)\n327: \n328: \terr = store.DeleteSandbox(ctx, \"test-session\")\n329: \trequire.NoError(t, err)\n330: \n331: \t_, err = store.GetSandbox(ctx, \"test-session\")\n332: \tassert.Error(t, err)\n333: }\n334: \n335: func TestMockStore_DeleteNonExistent(t *testing.T) {\n336: \tstore := newMockStore()\n337: \tctx := context.Background()\n338: \n339: \terr := store.DeleteSandbox(ctx, \"nonexistent\")\n340: \tassert.Error(t, err)\n341: }\n342: \n343: func TestMockStore_List(t *testing.T) {\n344: \tstore := newMockStore()\n345: \tctx := context.Background()\n346: \n347: \tstore.StoreSandbox(ctx, &SandboxInfo{SessionID: \"session-1\", SandboxName: \"sandbox-1\", Namespace: \"default\"})\n348: \tstore.StoreSandbox(ctx, &SandboxInfo{SessionID: \"session-2\", SandboxName: \"sandbox-2\", Namespace: \"test\"})\n349: \n350: \tlist, err := store.ListSandboxes(ctx)\n351: \trequire.NoError(t, err)\n352: \tassert.Len(t, list, 2)\n353: }\n354: \n355: func TestMockStore_ListEmpty(t *testing.T) {\n356: \tstore := newMockStore()\n357: \tctx := context.Background()\n358: \n359: \tlist, err := store.ListSandboxes(ctx)\n360: \trequire.NoError(t, err)\n361: \tassert.Empty(t, list)\n362: }\n363: \n364: func TestResolveGVR_AllKnownKinds(t *testing.T) {\n365: \thandler := &SandboxDeleteHandler{}\n366: \n367: \ttestCases := []struct {\n368: \t\tkind        string\n369: \t\texpectedGVR schema.GroupVersionResource\n370: \t\texpectError bool\n371: \t}{\n372: \t\t{SandboxesKind, SandboxGVR, false},\n373: \t\t{SandboxClaimsKind, SandboxClaimGVR, false},\n374: \t\t{\"Unknown\", schema.GroupVersionResource{}, true},\n375: \t\t{\"\", schema.GroupVersionResource{}, true},\n376: \t}\n377: \n378: \tfor _, tc := range testCases {\n379: \t\tgvr, err := handler.resolveGVR(tc.kind)\n380: \t\tif tc.expectError {\n381: \t\t\tassert.Error(t, err, \"kind: %s\", tc.kind)\n382: \t\t} else {\n383: \t\t\tassert.NoError(t, err, \"kind: %s\", tc.kind)\n384: \t\t\tassert.Equal(t, tc.expectedGVR, gvr, \"kind: %s\", tc.kind)\n385: \t\t}\n386: \t}\n387: }\n\n(End of file - total 387 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n)\n\ntype mockStore struct {\n\tsandboxes map[string]*SandboxInfo","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/sandbox_delete_test.go","time":{"start":1775887330161,"end":1775887330167}}}}
