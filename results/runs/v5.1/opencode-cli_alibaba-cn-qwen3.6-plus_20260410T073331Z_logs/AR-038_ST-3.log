True(t, metricNames[\"gc_cleanup_errors_total\"])\n82: \tassert.True(t, metricNames[\"gc_cycle_duration_seconds\"])\n83: }\n\n(End of file - total 83 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/prometheus/client_golang/prometheus\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc newTestMetricsRecorder(t *testing.T) *PrometheusMetricsRecorder {\n\tt.Helper()\n\treg := prometheus.NewRegistry()\n\treturn NewPrometheusMetricsRecorder(reg)\n}\n\nfunc TestPrometheusMetricsRecorder_IncGCCleanupTotal(t *testing.T) {\n\tr := newTestMetricsRecorder(t)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/metrics_test.go","time":{"start":1775887332827,"end":1775887332835}}}}
