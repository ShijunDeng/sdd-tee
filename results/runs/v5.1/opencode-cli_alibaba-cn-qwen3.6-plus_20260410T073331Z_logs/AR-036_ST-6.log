{"type":"tool_use","timestamp":1775883913776,"sessionID":"ses_28513a79cffeGKOj7slrX3J3hz","part":{"id":"prt_d7aee05a5001v4RM9STdsgEw7j","messageID":"msg_d7aedf481001iZMbU12pYwj8pz","sessionID":"ses_28513a79cffeGKOj7slrX3J3hz","type":"tool","tool":"read","callID":"call_eec0b26b95a3451db8aa268a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/integrations/dify-plugin/tests/test_tool.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/integrations/dify-plugin/tests/test_tool.py</path>\n<type>file</type>\n<content>\n1: import sys\n2: import types\n3: from unittest.mock import MagicMock, patch\n4: \n5: import pytest\n6: \n7: dify_plugin_module = types.ModuleType(\"dify_plugin\")\n8: \n9: \n10: class FakeTool:\n11:     def create_json_message(self, data):\n12:         return {\"type\": \"json\", \"data\": data}\n13: \n14: \n15: dify_plugin_module.Tool = FakeTool\n16: \n17: entities_module = types.ModuleType(\"dify_plugin.entities\")\n18: tool_entities_module = types.ModuleType(\"dify_plugin.entities.tool\")\n19: \n20: \n21: class FakeToolInvokeMessage:\n22:     pass\n23: \n24: \n25: tool_entities_module.ToolInvokeMessage = FakeToolInvokeMessage\n26: entities_module.tool = tool_entities_module\n27: dify_plugin_module.entities = entities_module\n28: \n29: sys.modules[\"dify_plugin\"] = dify_plugin_module\n30: sys.modules[\"dify_plugin.entities\"] = entities_module\n31: sys.modules[\"dify_plugin.entities.tool\"] = tool_entities_module\n32: \n33: mock_code_interpreter_client = MagicMock()\n34: agentcube_module = types.ModuleType(\"agentcube\")\n35: agentcube_module.CodeInterpreterClient = mock_code_interpreter_client\n36: sys.modules[\"agentcube\"] = agentcube_module\n37: \n38: from integrations.dify_plugin.tools.agentcube_code_interpreter import (\n39:     AgentcubeCodeInterpreterTool,\n40: )\n41: \n42: \n43: class TestAgentcubeCodeInterpreterTool:\n44:     def test_invoke_yields_json_message_with_code(self):\n45:         tool = AgentcubeCodeInterpreterTool()\n46:         params = {\n47:             \"router_url\": \"http://router.example.com\",\n48:             \"workload_manager_url\": \"http://wm.example.com\",\n49:             \"code\": \"print('hello')\",\n50:         }\n51: \n52:         mock_client = MagicMock()\n53:         mock_client.run_code.return_value = \"hello\"\n54:         mock_client.session_id = \"test-session\"\n55:         mock_client.list_files.return_value = [\"file1.py\"]\n56: \n57:         with patch.object(\n58:             agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n59:         ):\n60:             messages = list(tool._invoke(params))\n61: \n62:         assert len(messages) == 1\n63:         assert messages[0][\"type\"] == \"json\"\n64:         assert messages[0][\"data\"][\"success\"] is True\n65:         assert messages[0][\"data\"][\"output\"] == \"hello\"\n66:         mock_client.stop.assert_called_once()\n67: \n68:     def test_invoke_yields_json_message_with_command(self):\n69:         tool = AgentcubeCodeInterpreterTool()\n70:         params = {\n71:             \"router_url\": \"http://router.example.com\",\n72:             \"workload_manager_url\": \"http://wm.example.com\",\n73:             \"command\": \"ls -la\",\n74:         }\n75: \n76:         mock_client = MagicMock()\n77:         mock_client.execute_command.return_value = \"file1.py\\nfile2.py\"\n78:         mock_client.session_id = \"test-session\"\n79:         mock_client.list_files.return_value = [\"file1.py\", \"file2.py\"]\n80: \n81:         with patch.object(\n82:             agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n83:         ):\n84:             messages = list(tool._invoke(params))\n85: \n86:         assert len(messages) == 1\n87:         assert messages[0][\"type\"] == \"json\"\n88:         assert messages[0][\"data\"][\"success\"] is True\n89:         assert messages[0][\"data\"][\"output\"] == \"file1.py\\nfile2.py\"\n90:         mock_client.stop.assert_called_once()\n91: \n92:     def test_invoke_returns_error_when_no_code_or_command(self):\n93:         tool = AgentcubeCodeInterpreterTool()\n94:         params = {\n95:             \"router_url\": \"http://router.example.com\",\n96:             \"workload_manager_url\": \"http://wm.example.com\",\n97:         }\n98: \n99:         mock_client = MagicMock()\n100:         mock_client.session_id = \"test-session\"\n101:         mock_client.list_files.return_value = []\n102: \n103:         with patch.object(\n104:             agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n105:         ):\n106:             messages = list(tool._invoke(params))\n107: \n108:         assert len(messages) == 1\n109:         assert messages[0][\"data\"][\"success\"] is False\n110:         assert \"No code or command provided\" in messages[0][\"data\"][\"error\"]\n111: \n112:     def test_invoke_returns_error_on_exception(self):\n113:         tool = AgentcubeCodeInterpreterTool()\n114:         params = {\n115:             \"router_url\": \"http://router.example.com\",\n116:             \"workload_manager_url\": \"http://wm.example.com\",\n117:             \"code\": \"print('hello')\",\n118:         }\n119: \n120:         mock_client = MagicMock()\n121:         mock_client.run_code.side_effect = RuntimeError(\"Sandbox error\")\n122:         mock_client.session_id = \"test-session\"\n123: \n124:         with patch.object(\n125:             agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n126:         ):\n127:             messages = list(tool._invoke(params))\n128: \n129:         assert len(messages) == 1\n130:         assert messages[0][\"data\"][\"success\"] is False\n131:         assert \"Sandbox error\" in messages[0][\"data\"][\"error\"]\n132:         mock_client.stop.assert_called_once()\n133: \n134:     def test_execute_delegates_to_code_interpreter_client(self):\n135:         tool = AgentcubeCodeInterpreterTool()\n136: \n137:         mock_client = MagicMock()\n138:         mock_client.run_code.return_value = \"output\"\n139:         mock_client.session_id = \"session-123\"\n140:         mock_client.list_files.return_value = [\"test.py\"]\n141: \n142:         with patch.object(\n143:             agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n144:         ):\n145:             result = tool.execute(\n146:                 router_url=\"http://router.example.com\",\n147:                 workload_manager_url=\"http://wm.example.com\",\n148:                 code=\"print('test')\",\n149:             )\n150: \n151:         assert result[\"success\"] is True\n152:         assert result[\"output\"] == \"output\"\n153:         assert result[\"session_id\"] == \"session-123\"\n154:         mock_client.run_code.assert_called_once()\n155:         mock_client.stop.assert_called_once()\n156: \n157:     def test_execute_uses_session_id_when_session_reuse_is_true(self):\n158:         tool = AgentcubeCodeInterpreterTool()\n159: \n160:         mock_client = MagicMock()\n161:         mock_client.execute_command.return_value = \"ok\"\n162:         mock_client.session_id = \"existing-session\"\n163:         mock_client.list_files.return_value = []\n164: \n165:         with patch.object(\n166:             agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n167:         ) as mock_ctor:\n168:             tool.execute(\n169:                 router_url=\"http://router.example.com\",\n170:                 workload_manager_url=\"http://wm.example.com\",\n171:                 command=\"echo hello\",\n172:                 session_id=\"existing-session\",\n173:                 session_reuse=True,\n174:             )\n175: \n176:         mock_ctor.assert_called_once()\n177:         call_kwargs = mock_ctor.call_args[1]\n178:         assert call_kwargs[\"session_id\"] == \"existing-session\"\n179: \n180:     def test_execute_default_language_is_python(self):\n181:         tool = AgentcubeCodeInterpreterTool()\n182: \n183:         mock_client = MagicMock()\n184:         mock_client.run_code.return_value = \"output\"\n185:         mock_client.session_id = \"session-1\"\n186:         mock_client.list_files.return_value = []\n187: \n188:         with patch.object(\n189:             agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n190:         ) as mock_ctor:\n191:             tool.execute(\n192:                 router_url=\"http://router.example.com\",\n193:                 workload_manager_url=\"http://wm.example.com\",\n194:                 code=\"print('test')\",\n195:             )\n196: \n197:         call_kwargs = mock_ctor.call_args[1]\n198:         assert call_kwargs[\"name\"] == \"my-interpreter\"\n\n(End of file - total 198 lines)\n</content>","metadata":{"preview":"import sys\nimport types\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\ndify_plugin_module = types.ModuleType(\"dify_plugin\")\n\n\nclass FakeTool:\n    def create_json_message(self, data):\n        return {\"type\": \"json\", \"data\": data}\n\n\ndify_plugin_module.Tool = FakeTool\n\nentities_module = types.ModuleType(\"dify_plugin.entities\")\ntool_entities_module = types.ModuleType(\"dify_plugin.entities.tool\")\n\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/integrations/dify-plugin/tests/test_tool.py","time":{"start":1775883913769,"end":1775883913775}}}}
