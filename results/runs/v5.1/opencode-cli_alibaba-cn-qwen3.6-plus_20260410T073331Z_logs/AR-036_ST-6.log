s(credentials)\n        assert \"router_url is required\" in str(exc_info.value)\n\n    def test_validate_credentials_raises_when_workload_manager_url_missing(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        credentials = {\n            \"router_url\": \"http://router.example.com\",\n        }\n        with pytest.raises(FakeToolProviderCredentialValidationError) as exc_info:\n            provider._validate_credentials(credentials)\n        assert \"workload_manager_url is required\" in str(exc_info.value)\n\n    def test_validate_credentials_raises_on_generic_exception(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        credentials = {\"router_url\": None, \"workload_manager_url\": None}\n        with pytest.raises(FakeToolProviderCredentialValidationError):\n            provider._validate_credentials(credentials)\n\n    def test_validate_credentials_passes_with_empty_dict(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        with pytest.raises(FakeToolProviderCredentialValidationError):\n            provider._validate_credentials({})\n\n    def test_validate_credentials_passes_with_all_fields_present(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        credentials = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n            \"extra_field\": \"value\",\n        }\n        result = provider._validate_credentials(credentials)\n        assert result is None\n","after":"import sys\nimport types\nimport os\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\n# Add parent directory to path since 'dify-plugin' is not a valid Python module name\nsys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n\ndify_plugin_module = types.ModuleType(\"dify_plugin\")\ndify_plugin_module.ToolProvider = MagicMock\n\nerrors_module = types.ModuleType(\"dify_plugin.errors\")\nerrors_tool_module = types.ModuleType(\"dify_plugin.errors.tool\")\n\n\nclass FakeToolProviderCredentialValidationError(Exception):\n    pass\n\n\nerrors_tool_module.ToolProviderCredentialValidationError = (\n    FakeToolProviderCredentialValidationError\n)\nerrors_module.tool = errors_tool_module\ndify_plugin_module.errors = errors_module\n\nsys.modules[\"dify_plugin\"] = dify_plugin_module\nsys.modules[\"dify_plugin.errors\"] = errors_module\nsys.modules[\"dify_plugin.errors.tool\"] = errors_tool_module\n\nfrom provider.agentcube import (\n    AgentcubeCodeInterpreterProvider,\n)\n\n\nclass TestAgentcubeCodeInterpreterProvider:\n    def test_validate_credentials_passes_with_valid_credentials(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        credentials = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n        }\n        result = provider._validate_credentials(credentials)\n        assert result is None\n\n    def test_validate_credentials_raises_when_router_url_missing(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        credentials = {\n            \"workload_manager_url\": \"http://wm.example.com\",\n        }\n        with pytest.raises(FakeToolProviderCredentialValidationError) as exc_info:\n            provider._validate_credentials(credentials)\n        assert \"router_url is required\" in str(exc_info.value)\n\n    def test_validate_credentials_raises_when_workload_manager_url_missing(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        credentials = {\n            \"router_url\": \"http://router.example.com\",\n        }\n        with pytest.raises(FakeToolProviderCredentialValidationError) as exc_info:\n            provider._validate_credentials(credentials)\n        assert \"workload_manager_url is required\" in str(exc_info.value)\n\n    def test_validate_credentials_raises_on_generic_exception(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        credentials = {\"router_url\": None, \"workload_manager_url\": None}\n        with pytest.raises(FakeToolProviderCredentialValidationError):\n            provider._validate_credentials(credentials)\n\n    def test_validate_credentials_passes_with_empty_dict(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        with pytest.raises(FakeToolProviderCredentialValidationError):\n            provider._validate_credentials({})\n\n    def test_validate_credentials_passes_with_all_fields_present(self):\n        provider = AgentcubeCodeInterpreterProvider()\n        credentials = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n            \"extra_field\": \"value\",\n        }\n        result = provider._validate_credentials(credentials)\n        assert result is None\n","additions":5,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/integrations/dify-plugin/tests/test_provider.py","time":{"start":1775883969124,"end":1775883969617}}}}
