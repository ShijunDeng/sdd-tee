{"type":"tool_use","timestamp":1775883911112,"sessionID":"ses_28513a79cffeGKOj7slrX3J3hz","part":{"id":"prt_d7aedfb44001E3AHO947ahzoCj","messageID":"msg_d7aedf481001iZMbU12pYwj8pz","sessionID":"ses_28513a79cffeGKOj7slrX3J3hz","type":"tool","tool":"read","callID":"call_947651cf6eb84e3daa43f761","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/integrations/dify-plugin/tests/test_manifest.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/integrations/dify-plugin/tests/test_manifest.py</path>\n<type>file</type>\n<content>\n1: import os\n2: import yaml\n3: import pytest\n4: \n5: BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))\n6: \n7: \n8: class TestManifestYaml:\n9:     def setup_method(self):\n10:         manifest_path = os.path.join(BASE_DIR, \"manifest.yaml\")\n11:         with open(manifest_path) as f:\n12:             self.manifest = yaml.safe_load(f)\n13: \n14:     def test_version(self):\n15:         assert self.manifest[\"version\"] == \"0.0.2\"\n16: \n17:     def test_type(self):\n18:         assert self.manifest[\"type\"] == \"plugin\"\n19: \n20:     def test_author(self):\n21:         assert self.manifest[\"author\"] == \"volcano-sh\"\n22: \n23:     def test_name(self):\n24:         assert self.manifest[\"name\"] == \"agentcube\"\n25: \n26:     def test_label_multilingual(self):\n27:         label = self.manifest[\"label\"]\n28:         assert label[\"en_US\"] == \"Agentcube\"\n29:         assert label[\"ja_JP\"] == \"Agentcube\"\n30:         assert label[\"zh_Hans\"] == \"Agentcube\"\n31:         assert label[\"pt_BR\"] == \"Agentcube\"\n32: \n33:     def test_description_multilingual(self):\n34:         desc = self.manifest[\"description\"]\n35:         assert \"en_US\" in desc\n36:         assert \"ja_JP\" in desc\n37:         assert \"zh_Hans\" in desc\n38:         assert \"pt_BR\" in desc\n39: \n40:     def test_icon(self):\n41:         assert self.manifest[\"icon\"] == \"icon.png\"\n42:         assert self.manifest[\"icon_dark\"] == \"icon-dark.png\"\n43: \n44:     def test_resource_has_memory_and_permission(self):\n45:         resource = self.manifest[\"resource\"]\n46:         assert \"memory\" in resource\n47:         assert \"permission\" in resource\n48:         permission = resource[\"permission\"]\n49:         assert \"tool\" in permission\n50:         assert \"model\" in permission\n51:         assert \"endpoint\" in permission\n52:         assert \"app\" in permission\n53:         assert \"storage\" in permission\n54: \n55:     def test_plugins_tools(self):\n56:         assert self.manifest[\"plugins\"][\"tools\"] == [\"provider/agentcube.yaml\"]\n57: \n58:     def test_meta_version(self):\n59:         assert \"version\" in self.manifest[\"meta\"]\n60: \n61:     def test_meta_arch(self):\n62:         arch = self.manifest[\"meta\"][\"arch\"]\n63:         assert \"amd64\" in arch\n64:         assert \"arm64\" in arch\n65: \n66:     def test_meta_runner(self):\n67:         runner = self.manifest[\"meta\"][\"runner\"]\n68:         assert runner[\"language\"] == \"python\"\n69:         assert runner[\"version\"] == \"3.12\"\n70:         assert runner[\"entrypoint\"] == \"main\"\n71: \n72:     def test_meta_minimum_dify_version(self):\n73:         assert self.manifest[\"meta\"][\"minimum_dify_version\"] is None\n74: \n75:     def test_additional_fields(self):\n76:         assert \"created_at\" in self.manifest\n77:         assert \"privacy\" in self.manifest\n78:         assert \"repo\" in self.manifest\n79:         assert \"verified\" in self.manifest\n80: \n81: \n82: class TestProviderDescriptor:\n83:     def setup_method(self):\n84:         provider_path = os.path.join(BASE_DIR, \"provider\", \"agentcube.yaml\")\n85:         with open(provider_path) as f:\n86:             self.provider = yaml.safe_load(f)\n87: \n88:     def test_identity_author(self):\n89:         assert \"author\" in self.provider[\"identity\"]\n90: \n91:     def test_identity_name(self):\n92:         assert \"name\" in self.provider[\"identity\"]\n93: \n94:     def test_identity_label_multilingual(self):\n95:         label = self.provider[\"identity\"][\"label\"]\n96:         assert \"en_US\" in label\n97:         assert \"zh_Hans\" in label\n98: \n99:     def test_identity_description_multilingual(self):\n100:         desc = self.provider[\"identity\"][\"description\"]\n101:         assert \"en_US\" in desc\n102:         assert \"zh_Hans\" in desc\n103: \n104:     def test_identity_icon(self):\n105:         assert \"icon\" in self.provider[\"identity\"]\n106: \n107:     def test_tools_list(self):\n108:         assert self.provider[\"tools\"] == [\"tools/agentcube-code-interpreter.yaml\"]\n109: \n110:     def test_extra_python_source(self):\n111:         assert self.provider[\"extra\"][\"python\"][\"source\"] == \"provider/agentcube.py\"\n112: \n113:     def test_oauth_schema_is_commented(self):\n114:         provider_path = os.path.join(BASE_DIR, \"provider\", \"agentcube.yaml\")\n115:         with open(provider_path) as f:\n116:             content = f.read()\n117:         assert \"oauth_schema\" not in self.provider\n118:         assert \"# oauth_schema\" in content or \"#oauth_schema\" in content\n119: \n120: \n121: class TestToolSchema:\n122:     def setup_method(self):\n123:         tool_path = os.path.join(\n124:             BASE_DIR, \"tools\", \"agentcube-code-interpreter.yaml\"\n125:         )\n126:         with open(tool_path) as f:\n127:             self.tool = yaml.safe_load(f)\n128: \n129:     def test_identity_name(self):\n130:         assert self.tool[\"identity\"][\"name\"] == \"agentcube-code-interpreter\"\n131: \n132:     def test_identity_author(self):\n133:         assert self.tool[\"identity\"][\"author\"] == \"agentcube\"\n134: \n135:     def test_identity_label(self):\n136:         label = self.tool[\"identity\"][\"label\"]\n137:         assert \"en_US\" in label\n138:         assert \"zh_Hans\" in label\n139: \n140:     def test_identity_description_human_and_llm(self):\n141:         desc = self.tool[\"identity\"][\"description\"]\n142:         assert \"human\" in desc\n143:         assert \"llm\" in desc\n144: \n145:     def test_required_parameters(self):\n146:         params = {p[\"name\"]: p for p in self.tool[\"parameters\"]}\n147:         assert params[\"router_url\"][\"required\"] is True\n148:         assert params[\"workload_manager_url\"][\"required\"] is True\n149: \n150:     def test_language_select_parameter(self):\n151:         params = {p[\"name\"]: p for p in self.tool[\"parameters\"]}\n152:         lang = params[\"language\"]\n153:         assert lang[\"type\"] == \"select\"\n154:         assert lang[\"required\"] is False\n155:         assert lang[\"form\"] == \"llm\"\n156:         assert set(lang[\"options\"]) == {\"python\", \"javascript\", \"typescript\"}\n157: \n158:     def test_optional_parameters(self):\n159:         params = {p[\"name\"]: p for p in self.tool[\"parameters\"]}\n160:         assert params[\"code\"][\"required\"] is False\n161:         assert params[\"command\"][\"required\"] is False\n162:         assert params[\"session_id\"][\"required\"] is False\n163:         assert params[\"session_reuse\"][\"required\"] is False\n164:         assert params[\"code_interpreter_id\"][\"required\"] is False\n165: \n166:     def test_session_reuse_is_boolean(self):\n167:         params = {p[\"name\"]: p for p in self.tool[\"parameters\"]}\n168:         assert params[\"session_reuse\"][\"type\"] == \"boolean\"\n169: \n170:     def test_parameter_documentation(self):\n171:         for param in self.tool[\"parameters\"]:\n172:             assert \"name\" in param\n173:             assert \"type\" in param\n174:             assert \"required\" in param\n175:             assert \"label\" in param\n176:             assert \"human_description\" in param\n177:             assert \"llm_description\" in param\n178:             assert \"form\" in param\n179: \n180:     def test_extra_python_source(self):\n181:         assert (\n182:             self.tool[\"extra\"][\"python\"][\"source\"]\n183:             == \"tools/agentcube-code-interpreter.py\"\n184:         )\n\n(End of file - total 184 lines)\n</content>","metadata":{"preview":"import os\nimport yaml\nimport pytest\n\nBASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))\n\n\nclass TestManifestYaml:\n    def setup_method(self):\n        manifest_path = os.path.join(BASE_DIR, \"manifest.yaml\")\n        with open(manifest_path) as f:\n            self.manifest = yaml.safe_load(f)\n\n    def test_version(self):\n        assert self.manifest[\"version\"] == \"0.0.2\"\n\n    def test_type(self):\n        assert self.manifest[\"type\"] == \"plugin\"\n\n    def test_author(self):","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/integrations/dify-plugin/tests/test_manifest.py","time":{"start":1775883911104,"end":1775883911110}}}}
