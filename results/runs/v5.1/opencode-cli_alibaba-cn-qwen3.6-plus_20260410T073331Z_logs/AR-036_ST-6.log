331Z/integrations/dify-plugin/tests/test_tool.py","before":"import sys\nimport types\nimport os\nimport importlib.util\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\n# Add parent directory to path since 'dify-plugin' is not a valid Python module name\nsys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n\ndify_plugin_module = types.ModuleType(\"dify_plugin\")\n\n\nclass FakeTool:\n    def create_json_message(self, data):\n        return {\"type\": \"json\", \"data\": data}\n\n\ndify_plugin_module.Tool = FakeTool\n\nentities_module = types.ModuleType(\"dify_plugin.entities\")\ntool_entities_module = types.ModuleType(\"dify_plugin.entities.tool\")\n\n\nclass FakeToolInvokeMessage:\n    pass\n\n\ntool_entities_module.ToolInvokeMessage = FakeToolInvokeMessage\nentities_module.tool = tool_entities_module\ndify_plugin_module.entities = entities_module\n\nsys.modules[\"dify_plugin\"] = dify_plugin_module\nsys.modules[\"dify_plugin.entities\"] = entities_module\nsys.modules[\"dify_plugin.entities.tool\"] = tool_entities_module\n\nmock_code_interpreter_client = MagicMock()\nagentcube_module = types.ModuleType(\"agentcube\")\nagentcube_module.CodeInterpreterClient = mock_code_interpreter_client\nsys.modules[\"agentcube\"] = agentcube_module\n\n# Load module with hyphenated filename using importlib\n_tool_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))),\n                          \"tools\", \"agentcube-code-interpreter.py\")\n_spec = importlib.util.spec_from_file_location(\"agentcube_code_interpreter\", _tool_path)\n_agentcube_code_interpreter = importlib.util.module_from_spec(_spec)\nsys.modules[\"agentcube_code_interpreter\"] = _agentcube_code_interpreter\n_spec.loader.exec_module(_agentcube_code_interpreter)\nAgentcubeCodeInterpreterTool = _agentcube_code_interpreter.AgentcubeCodeInterpreterTool\n\n\nclass TestAgentcubeCodeInterpreterTool:\n    def test_invoke_yields_json_message_with_code(self):\n        tool = AgentcubeCodeInterpreterTool()\n        params = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n            \"code\": \"print('hello')\",\n        }\n\n        mock_client = MagicMock()\n        mock_client.run_code.return_value = \"hello\"\n        mock_client.session_id = \"test-session\"\n        mock_client.list_files.return_value = [\"file1.py\"]\n\n        with patch.object(\n            _agentcube_code_interpreter, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            messages = list(tool._invoke(params))\n\n        assert len(messages) == 1\n        assert messages[0][\"type\"] == \"json\"\n        assert messages[0][\"data\"][\"success\"] is True\n        assert messages[0][\"data\"][\"output\"] == \"hello\"\n        mock_client.stop.assert_called_once()\n\n    def test_invoke_yields_json_message_with_command(self):\n        tool = AgentcubeCodeInterpreterTool()\n        params = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n            \"command\": \"ls -la\",\n        }\n\n        mock_client = MagicMock()\n        mock_client.execute_command.return_value = \"file1.py\\nfile2.py\"\n        mock_client.session_id = \"test-session\"\n        mock_client.list_files.return_value = [\"file1.py\", \"file2.py\"]\n\n        with patch.object(\n            _agentcube_code_interpreter, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            messages = list(tool._invoke(params))\n\n        assert len(messages) == 1\n        assert messages[0][\"type\"] == \"json\"\n        assert messages[0][\"data\"][\"success\"] is True\n        assert messages[0][\"data\"][\"output\"] == \"file1.py\\nfile2.py\"\n        mock_client.stop.assert_called_once()\n\n    def test_invoke_returns_error_when_no_code_or_command(self):\n        tool = AgentcubeCodeInterpreterTool()\n        params = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n        }\n\n        mock_client = MagicMock()\n        mock_client.session_id = \"test-session\"\n        mock_client.list_files.return_value = []\n\n        with patch.object(\n            agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            messages = list(tool._invoke(params))\n\n        assert len(messages) == 1\n        assert messages[0][\"data\"][\"success\"] is False\n        assert \"No code or command provided\" in messages[0][\"data\"][\"error\"]\n\n    def test_invoke_returns_error_on_exception(self):\n        tool = AgentcubeCodeInterpreterTool()\n        params = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n            \"code\": \"print('hello')\",\n        }\n\n        mock_client = MagicMock()\n        mock_client.run_code.side_effect = RuntimeError(\"Sandbox error\")\n        mock_client.session_id = \"test-session\"\n\n        with patch.object(\n            agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            messages = list(tool._invoke(params))\n\n        assert len(messages) == 1\n        assert messages[0][\"data\"][\"success\"] is False\n        assert \"Sandbox error\" in messages[0][\"data\"][\"error\"]\n        mock_client.stop.assert_called_once()\n\n    def test_execute_delegates_to_code_interpreter_client(self):\n        tool = AgentcubeCodeInterpreterTool()\n\n        mock_client = MagicMock()\n        mock_client.run_code.return_value = \"output\"\n        mock_client.session_id = \"session-123\"\n        mock_client.list_files.return_value = [\"test.py\"]\n\n        with patch.object(\n            agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            result = tool.execute(\n                router_url=\"http://router.example.com\",\n                workload_manager_url=\"http://wm.example.com\",\n                code=\"print('test')\",\n            )\n\n        assert result[\"success\"] is True\n        assert result[\"output\"] == \"output\"\n        assert result[\"session_id\"] == \"session-123\"\n        mock_client.run_code.assert_called_once()\n        mock_client.stop.assert_called_once()\n\n    def test_execute_uses_session_id_when_session_reuse_is_true(self):\n        tool = AgentcubeCodeInterpreterTool()\n\n        mock_client = MagicMock()\n        mock_client.execute_command.return_value = \"ok\"\n        mock_client.session_id = \"existing-session\"\n        mock_client.list_files.return_value = []\n\n        with patch.object(\n            agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n        ) as mock_ctor:\n            tool.execute(\n                router_url=\"http://router.example.com\",\n                workload_manager_url=\"http://wm.example.com\",\n                command=\"echo hello\",\n                session_id=\"existing-session\",\n                session_reuse=True,\n            )\n\n        mock_ctor.assert_called_once()\n        call_kwargs = mock_ctor.call_args[1]\n        assert call_kwargs[\"session_id\"] == \"existing-session\"\n\n    def test_execute_default_language_is_python(self):\n        tool = AgentcubeCodeInterpreterTool()\n\n        mock_client = MagicMock()\n        mock_client.run_code.return_value = \"output\"\n        mock_client.session_id = \"session-1\"\n        mock_client.list_files.return_value = []\n\n        with patch.object(\n            agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n        ) as mock_ctor:\n            tool.execute(\n                router_url=\"http://router.example.com\",\n                workload_manager_url=\"http://wm.example.com\",\n                code=\"print('test')\",\n            )\n\n        call_kwargs = mock_ctor.call_args[1]\n        assert call_kwargs[\"name\"] == \"my-interpreter\"\n","after":"import sys\nimport types\nimport os\nimport importlib.util\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\n# Add parent directory to path since 'dify-plugin' is not a valid Python module name\nsys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n\ndify_plugin_module = types.ModuleType(\"dify_plugin\")\n\n\nclass FakeTool:\n    def create_json_message(self, data):\n        return {\"type\": \"json\", \"data\": data}\n\n\ndify_plugin_module.Tool = FakeTool\n\nentities_module = types.ModuleType(\"dify_plugin.entities\")\ntool_entities_module = types.ModuleType(\"dify_plugin.entities.tool\")\n\n\nclass FakeToolInvokeMessage:\n    pass\n\n\ntool_entities_module.ToolInvokeMessage = FakeToolInvokeMessage\nentities_module.tool = tool_entities_module\ndify_plugin_module.entities = entities_module\n\nsys.modules[\"dify_plugin\"] = dify_plugin_module\nsys.modules[\"dify_plugin.entities\"] = entities_module\nsys.modules[\"dify_plugin.entities.tool\"] = tool_entities_module\n\nmock_code_interpreter_client = MagicMock()\nagentcube_module = types.ModuleType(\"agentcube\")\nagentcube_module.CodeInterpreterClient = mock_code_interpreter_client\nsys.modules[\"agentcube\"] = agentcube_module\n\n# Load module with hyphenated filename using importlib\n_tool_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))),\n                          \"tools\", \"agentcube-code-interpreter.py\")\n_spec = importlib.util.spec_from_file_location(\"agentcube_code_interpreter\", _tool_path)\n_agentcube_code_interpreter = importlib.util.module_from_spec(_spec)\nsys.modules[\"agentcube_code_interpreter\"] = _agentcube_code_interpreter\n_spec.loader.exec_module(_agentcube_code_interpreter)\nAgentcubeCodeInterpreterTool = _agentcube_code_interpreter.AgentcubeCodeInterpreterTool\n\n\nclass TestAgentcubeCodeInterpreterTool:\n    def test_invoke_yields_json_message_with_code(self):\n        tool = AgentcubeCodeInterpreterTool()\n        params = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n            \"code\": \"print('hello')\",\n        }\n\n        mock_client = MagicMock()\n        mock_client.run_code.return_value = \"hello\"\n        mock_client.session_id = \"test-session\"\n        mock_client.list_files.return_value = [\"file1.py\"]\n\n        with patch.object(\n            _agentcube_code_interpreter, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            messages = list(tool._invoke(params))\n\n        assert len(messages) == 1\n        assert messages[0][\"type\"] == \"json\"\n        assert messages[0][\"data\"][\"success\"] is True\n        assert messages[0][\"data\"][\"output\"] == \"hello\"\n        mock_client.stop.assert_called_once()\n\n    def test_invoke_yields_json_message_with_command(self):\n        tool = AgentcubeCodeInterpreterTool()\n        params = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n            \"command\": \"ls -la\",\n        }\n\n        mock_client = MagicMock()\n        mock_client.execute_command.return_value = \"file1.py\\nfile2.py\"\n        mock_client.session_id = \"test-session\"\n        mock_client.list_files.return_value = [\"file1.py\", \"file2.py\"]\n\n        with patch.object(\n            _agentcube_code_interpreter, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            messages = list(tool._invoke(params))\n\n        assert len(messages) == 1\n        assert messages[0][\"type\"] == \"json\"\n        assert messages[0][\"data\"][\"success\"] is True\n        assert messages[0][\"data\"][\"output\"] == \"file1.py\\nfile2.py\"\n        mock_client.stop.assert_called_once()\n\n    def test_invoke_returns_error_when_no_code_or_command(self):\n        tool = AgentcubeCodeInterpreterTool()\n        params = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n        }\n\n        mock_client = MagicMock()\n        mock_client.session_id = \"test-session\"\n        mock_client.list_files.return_value = []\n\n        with patch.object(\n            _agentcube_code_interpreter, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            messages = list(tool._invoke(params))\n\n        assert len(messages) == 1\n        assert messages[0][\"data\"][\"success\"] is False\n        assert \"No code or command provided\" in messages[0][\"data\"][\"error\"]\n\n    def test_invoke_returns_error_on_exception(self):\n        tool = AgentcubeCodeInterpreterTool()\n        params = {\n            \"router_url\": \"http://router.example.com\",\n            \"workload_manager_url\": \"http://wm.example.com\",\n            \"code\": \"print('hello')\",\n        }\n\n        mock_client = MagicMock()\n        mock_client.run_code.side_effect = RuntimeError(\"Sandbox error\")\n        mock_client.session_id = \"test-session\"\n\n        with patch.object(\n            agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            messages = list(tool._invoke(params))\n\n        assert len(messages) == 1\n        assert messages[0][\"data\"][\"success\"] is False\n        assert \"Sandbox error\" in messages[0][\"data\"][\"error\"]\n        mock_client.stop.assert_called_once()\n\n    def test_execute_delegates_to_code_interpreter_client(self):\n        tool = AgentcubeCodeInterpreterTool()\n\n        mock_client = MagicMock()\n        mock_client.run_code.return_value = \"output\"\n        mock_client.session_id = \"session-123\"\n        mock_client.list_files.return_value = [\"test.py\"]\n\n        with patch.object(\n            agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n        ):\n            result = tool.execute(\n                router_url=\"http://router.example.com\",\n                workload_manager_url=\"http://wm.example.com\",\n                code=\"print('test')\",\n            )\n\n        assert result[\"success\"] is True\n        assert result[\"output\"] == \"output\"\n        assert result[\"session_id\"] == \"session-123\"\n        mock_client.run_code.assert_called_once()\n        mock_client.stop.assert_called_once()\n\n    def test_execute_uses_session_id_when_session_reuse_is_true(self):\n        tool = AgentcubeCodeInterpreterTool()\n\n        mock_client = MagicMock()\n        mock_client.execute_command.return_value = \"ok\"\n        mock_client.session_id = \"existing-session\"\n        mock_client.list_files.return_value = []\n\n        with patch.object(\n            agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n        ) as mock_ctor:\n            tool.execute(\n                router_url=\"http://router.example.com\",\n                workload_manager_url=\"http://wm.example.com\",\n                command=\"echo hello\",\n                session_id=\"existing-session\",\n                session_reuse=True,\n            )\n\n        mock_ctor.assert_called_once()\n        call_kwargs = mock_ctor.call_args[1]\n        assert call_kwargs[\"session_id\"] == \"existing-session\"\n\n    def test_execute_default_language_is_python(self):\n        tool = AgentcubeCodeInterpreterTool()\n\n        mock_client = MagicMock()\n        mock_client.run_code.return_value = \"output\"\n        mock_client.session_id = \"session-1\"\n        mock_client.list_files.return_value = []\n\n        with patch.object(\n            agentcube_module, \"CodeInterpreterClient\", return_value=mock_client\n        ) as mock_ctor:\n            tool.execute(\n                router_url=\"http://router.example.com\",\n                workload_manager_url=\"http://wm.example.com\",\n                code=\"print('test')\",\n            )\n\n        call_kwargs = mock_ctor.call_args[1]\n        assert call_kwargs[\"name\"] == \"my-interpreter\"\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/integrations/dify-plugin/tests/test_tool.py","time":{"start":1775884052800,"end":1775884053307}}}}
