{"type":"tool_use","timestamp":1775809259045,"sessionID":"ses_289858378ffe8pgoe8n4OXP7zD","part":{"id":"prt_d767ae24c001Lz3Hrou9c8HduN","messageID":"msg_d767ad6c5001izoMT2OmiT6u1O","sessionID":"ses_289858378ffe8pgoe8n4OXP7zD","type":"tool","tool":"read","callID":"call_d5f1ecd1d1b64bb1b7c12bbf","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go</path>\n<type>file</type>\n<content>\n1: package v1alpha1\n2: \n3: import (\n4: \t\"testing\"\n5: \t\"time\"\n6: \n7: \t\"github.com/stretchr/testify/assert\"\n8: \tcorev1 \"k8s.io/api/core/v1\"\n9: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n10: )\n11: \n12: func TestProtocolTypeConstants(t *testing.T) {\n13: \tassert.Equal(t, ProtocolType(\"HTTP\"), ProtocolTypeHTTP)\n14: \tassert.Equal(t, ProtocolType(\"HTTPS\"), ProtocolTypeHTTPS)\n15: }\n16: \n17: func TestAuthModeTypeConstants(t *testing.T) {\n18: \tassert.Equal(t, AuthModeType(\"picod\"), AuthModePicoD)\n19: \tassert.Equal(t, AuthModeType(\"none\"), AuthModeNone)\n20: }\n21: \n22: func TestTargetPortDefaults(t *testing.T) {\n23: \ttp := TargetPort{\n24: \t\tPort: 8080,\n25: \t}\n26: \n27: \tassert.Equal(t, uint32(8080), tp.Port)\n28: \tassert.Empty(t, tp.PathPrefix)\n29: \tassert.Empty(t, tp.Name)\n30: \tassert.Equal(t, ProtocolType(\"\"), tp.Protocol)\n31: }\n32: \n33: func TestTargetPortWithAllFields(t *testing.T) {\n34: \ttp := TargetPort{\n35: \t\tPathPrefix: \"/api\",\n36: \t\tName:       \"api\",\n37: \t\tPort:       3000,\n38: \t\tProtocol:   ProtocolTypeHTTPS,\n39: \t}\n40: \n41: \tassert.Equal(t, \"/api\", tp.PathPrefix)\n42: \tassert.Equal(t, \"api\", tp.Name)\n43: \tassert.Equal(t, uint32(3000), tp.Port)\n44: \tassert.Equal(t, ProtocolTypeHTTPS, tp.Protocol)\n45: }\n46: \n47: func TestTargetPortDeepCopy(t *testing.T) {\n48: \toriginal := &TargetPort{\n49: \t\tPathPrefix: \"/api\",\n50: \t\tName:       \"api\",\n51: \t\tPort:       3000,\n52: \t\tProtocol:   ProtocolTypeHTTPS,\n53: \t}\n54: \n55: \tcp := original.DeepCopy()\n56: \n57: \tassert.Equal(t, original.Port, cp.Port)\n58: \tassert.Equal(t, original.Protocol, cp.Protocol)\n59: \n60: \tcp.Port = 9090\n61: \tassert.Equal(t, uint32(3000), original.Port)\n62: }\n63: \n64: func TestCodeInterpreterSpecDefaults(t *testing.T) {\n65: \tci := &CodeInterpreterSpec{\n66: \t\tTemplate: &CodeInterpreterSandboxTemplate{},\n67: \t}\n68: \n69: \tassert.Empty(t, ci.Ports)\n70: \tassert.Nil(t, ci.SessionTimeout)\n71: \tassert.Nil(t, ci.MaxSessionDuration)\n72: \tassert.Nil(t, ci.WarmPoolSize)\n73: \tassert.Equal(t, AuthModeType(\"\"), ci.AuthMode)\n74: }\n75: \n76: func TestCodeInterpreterSandboxTemplateDeepCopy(t *testing.T) {\n77: \truntimeClass := \"kuasar-vmm\"\n78: \toriginal := &CodeInterpreterSandboxTemplate{\n79: \t\tLabels:           map[string]string{\"app\": \"test\"},\n80: \t\tAnnotations:      map[string]string{\"key\": \"value\"},\n81: \t\tRuntimeClassName: &runtimeClass,\n82: \t\tImage:            \"python:3.11\",\n83: \t\tImagePullPolicy:  corev1.PullIfNotPresent,\n84: \t\tCommand:          []string{\"python\", \"-m\", \"http.server\"},\n85: \t\tArgs:             []string{\"8080\"},\n86: \t}\n87: \n88: \tcp := original.DeepCopy()\n89: \n90: \tassert.Equal(t, original.Image, cp.Image)\n91: \tassert.Equal(t, original.Labels[\"app\"], cp.Labels[\"app\"])\n92: \tassert.Equal(t, *original.RuntimeClassName, *cp.RuntimeClassName)\n93: \n94: \tcp.Labels[\"app\"] = \"modified\"\n95: \tassert.Equal(t, \"test\", original.Labels[\"app\"])\n96: \n97: \tcp.Image = \"modified:latest\"\n98: \tassert.Equal(t, \"python:3.11\", original.Image)\n99: }\n100: \n101: func TestCodeInterpreterDeepCopy(t *testing.T) {\n102: \toriginal := &CodeInterpreter{\n103: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test-ci\", Namespace: \"default\"},\n104: \t\tSpec: CodeInterpreterSpec{\n105: \t\t\tPorts: []TargetPort{{Name: \"web\", Port: 8080, Protocol: ProtocolTypeHTTP}},\n106: \t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n107: \t\t\t\tLabels: map[string]string{\"app\": \"test\"},\n108: \t\t\t\tImage:  \"python:3.11\",\n109: \t\t\t},\n110: \t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n111: \t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n112: \t\t\tWarmPoolSize:       ptrInt32(3),\n113: \t\t\tAuthMode:           AuthModePicoD,\n114: \t\t},\n115: \t\tStatus: CodeInterpreterStatus{\n116: \t\t\tReady: true,\n117: \t\t},\n118: \t}\n119: \n120: \tcp := original.DeepCopy()\n121: \n122: \tassert.Equal(t, original.Name, cp.Name)\n123: \tassert.Equal(t, original.Spec.WarmPoolSize, cp.Spec.WarmPoolSize)\n124: \tassert.Equal(t, original.Spec.AuthMode, cp.Spec.AuthMode)\n125: \tassert.Equal(t, original.Status.Ready, cp.Status.Ready)\n126: \n127: \tcp.Spec.WarmPoolSize = ptrInt32(5)\n128: \tassert.Equal(t, int32(3), *original.Spec.WarmPoolSize)\n129: }\n130: \n131: func TestCodeInterpreterListDeepCopy(t *testing.T) {\n132: \toriginal := &CodeInterpreterList{\n133: \t\tListMeta: metav1.ListMeta{ResourceVersion: \"5678\"},\n134: \t\tItems: []CodeInterpreter{\n135: \t\t\t{\n136: \t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"ci1\", Namespace: \"default\"},\n137: \t\t\t\tSpec: CodeInterpreterSpec{\n138: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n139: \t\t\t\t\t\tImage: \"python:3.11\",\n140: \t\t\t\t\t},\n141: \t\t\t\t},\n142: \t\t\t},\n143: \t\t},\n144: \t}\n145: \n146: \tcp := original.DeepCopy()\n147: \n148: \tassert.Equal(t, original.ListMeta.ResourceVersion, cp.ListMeta.ResourceVersion)\n149: \tassert.Equal(t, len(original.Items), len(cp.Items))\n150: \tassert.Equal(t, original.Items[0].Name, cp.Items[0].Name)\n151: \n152: \tcp.Items[0].Name = \"modified\"\n153: \tassert.Equal(t, \"ci1\", original.Items[0].Name)\n154: }\n155: \n156: func ptrInt32(i int32) *int32 {\n157: \treturn &i\n158: }\n\n(End of file - total 158 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc TestProtocolTypeConstants(t *testing.T) {\n\tassert.Equal(t, ProtocolType(\"HTTP\"), ProtocolTypeHTTP)\n\tassert.Equal(t, ProtocolType(\"HTTPS\"), ProtocolTypeHTTPS)\n}\n\nfunc TestAuthModeTypeConstants(t *testing.T) {\n\tassert.Equal(t, AuthModeType(\"picod\"), AuthModePicoD)\n\tassert.Equal(t, AuthModeType(\"none\"), AuthModeNone)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types_test.go","time":{"start":1775809259037,"end":1775809259043}}}}
