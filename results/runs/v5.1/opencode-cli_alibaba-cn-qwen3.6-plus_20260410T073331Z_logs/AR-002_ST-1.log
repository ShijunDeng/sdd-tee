imeGroupVersionKind = GroupVersion.WithKind(\"AgentRuntime\")\n)\n\nvar SchemeGroupVersion = GroupVersion\n\nfunc Resource(resource string) schema.GroupVersionResource {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/apis/runtime/v1alpha1/register.go","time":{"start":1775809252325,"end":1775809252331}}}}
