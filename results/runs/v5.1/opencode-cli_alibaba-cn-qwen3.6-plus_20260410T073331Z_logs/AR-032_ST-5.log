46: \t}\n47: \n48: \tacClientset, err := clientset.NewForConfig(restConfig)\n49: \tif err != nil {\n50: \t\tklog.Fatalf(\"failed to create agentcube clientset: %v\", err)\n51: \t}\n52: \n53: \tinformerFactory := externalversions.NewSharedInformerFactory(acClientset, 30*time.Second)\n54: \n55: \tarLister := informerFactory.Runtime().V1alpha1().AgentRuntimes().Lister()\n56: \tciLister := informerFactory.Runtime().V1alpha1().CodeInterpreters().Lister()\n57: \n58: \treconcilerDeps := reconciler.ReconcilerDeps{\n59: \t\tClientset:       acClientset,\n60: \t\tInformerFactory: informerFactory,\n61: \t\tARLister:        arLister,\n62: \t\tCILister:        ciLister,\n63: \t\tWorkers:         cfg.Workers,\n64: \t}\n65: \tsandboxReconciler := reconciler.NewSandboxReconciler(reconcilerDeps)\n66: \n67: \tlifecycleDeps := &handler.LifecycleManagerDeps{\n68: \t\tDynamicClient:      dynamicClient,\n69: \t\tCheckInterval:      cfg.SessionCheckInterval,\n70: \t\tDefaultTTL:         cfg.SessionMaxDuration,\n71: \t\tDefaultIdleTimeout: cfg.SessionIdleTimeout,\n72: \t}\n73: \tlifecycleManager := handler.NewLifecycleManager(lifecycleDeps)\n74: \n75: \tcreateHandlerDeps := &handler.SandboxCreateHandlerDeps{\n76: \t\tDynamicClient:   dynamicClient,\n77: \t\tClientset:       acClientset,\n78: \t\tKubeClientset:   kubeClientset,\n79: \t\tInformerFactory: informerFactory,\n80: \t\tReconciler:      sandboxReconciler,\n81: \t\tEnableAuth:      cfg.EnableAuth,\n82: \t}\n83: \tcreateHandler := handler.NewSandboxCreateHandler(createHandlerDeps)\n84: \n85: \tdeleteHandlerDeps := &handler.SandboxDeleteHandlerDeps{\n86: \t\tDynamicClient: dynamicClient,\n87: \t\tEnableAuth:    cfg.EnableAuth,\n88: \t}\n89: \tdeleteHandler := handler.NewSandboxDeleteHandler(deleteHandlerDeps)\n90: \n91: \tstopCh := make(chan struct{})\n92: \tgo sandboxReconciler.Run(stopCh)\n93: \n94: \tctx := signalHandlerContext()\n95: \tgo lifecycleManager.Start(ctx)\n96: \n97: \tif cfg.Debug {\n98: \t\tgin.SetMode(gin.DebugMode)\n99: \t} else {\n100: \t\tgin.SetMode(gin.ReleaseMode)\n101: \t}\n102: \tengine := gin.New()\n103: \tengine.Use(gin.Recovery())\n104: \n105: \tengine.GET(\"/health/live\", handleLive)\n106: \tengine.GET(\"/health/ready\", func(c *gin.Context) {\n107: \t\tresponse.JSON(c, http.StatusOK, gin.H{\"status\": \"ok\"})\n108: \t})\n109: \n110: \tv1 := engine.Group(\"/api/v1\")\n111: \tv1.POST(\"/sandboxes\", func(c *gin.Context) {\n112: \t\tvar req handler.CreateSandboxRequest\n113: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n114: \t\t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n115: \t\t\treturn\n116: \t\t}\n117: \t\tswitch req.Kind {\n118: \t\tcase handler.AgentRuntimeKind:\n119: \t\t\tcreateHandler.CreateAgentRuntimeSandbox(c)\n120: \t\tcase handler.CodeInterpreterKind:\n121: \t\t\tcreateHandler.CreateCodeInterpreterSandbox(c)\n122: \t\tdefault:\n123: \t\t\tresponse.Error(c, http.StatusBadRequest, http.StatusBadRequest,\n124: \t\t\t\tfmt.Sprintf(\"invalid kind %q\", req.Kind))\n125: \t\t}\n126: \t})\n127: \tv1.DELETE(\"/sandboxes/:sessionID\", deleteHandler.DeleteSandbox)\n128: \tv1.GET(\"/sandboxes/:sessionID\", lifecycleManager.GetSandboxStatus)\n129: \tv1.GET(\"/sandboxes\", lifecycleManager.ListSandboxes)\n130: \tv1.POST(\"/sandboxes/:sessionID/extend\", lifecycleManager.ExtendSandboxTTL)\n131: \n132: \tserver := &http.Server{\n133: \t\tAddr:    \":\" + cfg.Port,\n134: \t\tHandler: engine,\n135: \t}\n136: \n137: \tgo func() {\n138: \t\tklog.Infof(\"workloadmanager listening on %s\", cfg.Port)\n139: \t\tif err := server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n140: \t\t\tklog.Fatalf(\"server failed: %v\", err)\n141: \t\t}\n142: \t}()\n143: \n144: \t<-ctx.Done()\n145: \tklog.Info(\"shutting down workloadmanager...\")\n146: \tclose(stopCh)\n147: \tlifecycleManager.Stop()\n148: \tserver.Shutdown(ctx)\n149: }\n150: \n151: func handleLive(c *gin.Context) {\n152: \tresponse.JSON(c, http.StatusOK, gin.H{\"status\": \"ok\"})\n153: }\n154: \n155: func signalHandlerContext() context.Context {\n156: \tctx, cancel := context.WithCancel(context.Background())\n157: \tsigCh := make(chan os.Signal, 1)\n158: \tsignal.Notify(sigCh, syscall.SIGINT, syscall.SIGTERM)\n159: \tgo func() {\n160: \t\t<-sigCh\n161: \t\tcancel()\n162: \t}()\n163: \treturn ctx\n164: }\n\n(End of file - total 164 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/client-go/clientset\"\n\t\"github.com/volcano-sh/agentcube/client-go/informers/externalversions\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/reconciler\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/workloadmanager/main.go","time":{"start":1775875966891,"end":1775875966898}}}}
