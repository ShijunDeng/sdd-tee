:"unused write to field Template"},{"range":{"start":{"line":506,"character":10},"end":{"line":506,"character":10}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field Template"},{"range":{"start":{"line":516,"character":10},"end":{"line":516,"character":10}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field Template"},{"range":{"start":{"line":522,"character":10},"end":{"line":522,"character":10}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field Template"},{"range":{"start":{"line":531,"character":10},"end":{"line":531,"character":10}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field Template"},{"range":{"start":{"line":541,"character":10},"end":{"line":541,"character":10}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field Template"},{"range":{"start":{"line":551,"character":7},"end":{"line":551,"character":7}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field Image"},{"range":{"start":{"line":568,"character":7},"end":{"line":568,"character":7}},"severity":3,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/unusedwrite"},"source":"unusedwrite","message":"unused write to field Image"},{"range":{"start":{"line":575,"character":7