", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service).\"),\n255:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging.\"),\n256: ) -> None:\n257:     \"\"\"Check the status of a deployed agent.\"\"\"\n258:     from rich.table import Table\n259: \n260:     try:\n261:         from agentcube.runtime.status_runtime import StatusRuntime\n262: \n263:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n264:         result = runtime.get_status(Path(workspace), provider)\n265: \n266:         if result.get(\"status\") == \"not_published\":\n267:             console.print(\"[yellow]Agent has not been published yet.[/yellow]\")\n268:             console.print(\"Run [bold]kubectl-agentcube publish[/bold] first to deploy the agent.\")\n269:             raise typer.Exit(1)\n270: \n271:         if result.get(\"status\") == \"error\":\n272:             console.print(f\"[red]Error: {result.get('message', 'Unknown error')}[/red]\")\n273:             raise typer.Exit(1)\n274: \n275:         table = Table(show_header=True, header_style=\"bold cyan\")\n276:         table.add_column(\"Field\", style=\"dim\")\n277:         table.add_column(\"Value\")\n278: \n279:         for key, value in result.items():\n280:             table.add_row(str(key), str(value))\n281: \n282:         console.print(table)\n283:     except typer.Exit:\n284:         raise\n285:     except Exception as e:\n286:         _handle_error(e, \"getting status\", verbose)\n\n(End of file - total 286 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube CLI entry point.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom typing import Dict, List, Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\n\nfrom pathlib import Path\n\nfrom agentcube import __version__\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtim