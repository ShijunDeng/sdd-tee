{"type":"tool_use","timestamp":1775863521785,"sessionID":"ses_28649817fffe9AkP3UViOSPpKA","part":{"id":"prt_d79b6dda5001fH1iVawx1Q50nx","messageID":"msg_d79b6d189001mKxO24FB2t0fT6","sessionID":"ses_28649817fffe9AkP3UViOSPpKA","type":"tool","tool":"read","callID":"call_2e8b8d4c13474ec2b3939407","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/k8s_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/k8s_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Kubernetes provider for deploying standard Deployment + NodePort Service.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import time\n6: from typing import Any, Dict, Optional\n7: \n8: try:\n9:     from kubernetes import client, config\n10:     from kubernetes.client.rest import ApiException\n11:     from kubernetes.client import (\n12:         V1Container,\n13:         V1ContainerPort,\n14:         V1Deployment,\n15:         V1DeploymentSpec,\n16:         V1DeploymentStatus,\n17:         V1EnvVar,\n18:         V1ObjectMeta,\n19:         V1PodSpec,\n20:         V1PodTemplateSpec,\n21:         V1Service,\n22:         V1ServicePort,\n23:         V1ServiceSpec,\n24:         V1ServiceStatus,\n25:     )\n26: except ImportError:\n27:     client = None  # type: ignore[misc]\n28:     config = None  # type: ignore[misc]\n29:     ApiException = Exception  # type: ignore[misc, assignment]\n30:     V1Container = object  # type: ignore[misc, assignment]\n31:     V1ContainerPort = object  # type: ignore[misc, assignment]\n32:     V1Deployment = object  # type: ignore[misc, assignment]\n33:     V1DeploymentSpec = object  # type: ignore[misc, assignment]\n34:     V1DeploymentStatus = object  # type: ignore[misc, assignment]\n35:     V1EnvVar = object  # type: ignore[misc, assignment]\n36:     V1ObjectMeta = object  # type: ignore[misc, assignment]\n37:     V1PodSpec = object  # type: ignore[misc, assignment]\n38:     V1PodTemplateSpec = object  # type: ignore[misc, assignment]\n39:     V1Service = object  # type: ignore[misc, assignment]\n40:     V1ServicePort = object  # type: ignore[misc, assignment]\n41:     V1ServiceSpec = object  # type: ignore[misc, assignment]\n42:     V1ServiceStatus = object  # type: ignore[misc, assignment]\n43: \n44: \n45: class KubernetesProvider:\n46:     \"\"\"Provider for deploying agents as standard Kubernetes Deployment + Service.\"\"\"\n47: \n48:     def __init__(self, namespace: str = \"default\", verbose: bool = False) -> None:\n49:         self.namespace = namespace\n50:         self.verbose = verbose\n51:         self._apps_api = client.AppsV1Api()\n52:         self._core_api = client.CoreV1Api()\n53: \n54:     def deploy_agent(\n55:         self,\n56:         agent_name: str,\n57:         image_url: str,\n58:         port: int,\n59:         entrypoint: str,\n60:         replicas: int = 1,\n61:         node_port: Optional[int] = None,\n62:         env_vars: Optional[Dict[str, str]] = None,\n63:     ) -> Dict[str, Any]:\n64:         \"\"\"Deploy a Kubernetes Deployment and NodePort Service.\n65: \n66:         Args:\n67:             agent_name: Name of the agent.\n68:             image_url: Container image URL.\n69:             port: Port the agent listens on.\n70:             entrypoint: Command to start the agent (shell string).\n71:             replicas: Number of replicas (default: 1).\n72:             node_port: Specific NodePort (30000-32767), or None for auto-assign.\n73:             env_vars: Environment variables for the container.\n74: \n75:         Returns:\n76:             Dict with deployment_name, service_name, service_url, node_port.\n77:         \"\"\"\n78:         sanitized_name = agent_name.lower().replace(\"_\", \"-\").replace(\".\", \"-\")\n79: \n80:         env_list = []\n81:         if env_vars:\n82:             for key, value in env_vars.items():\n83:                 env_list.append(V1EnvVar(name=key, value=value))\n84: \n85:         entrypoint_cmd = entrypoint.split() if entrypoint else []\n86: \n87:         container = V1Container(\n88:             name=sanitized_name,\n89:             image=image_url,\n90:             ports=[V1ContainerPort(container_port=port)],\n91:             command=entrypoint_cmd[:1] if entrypoint_cmd else None,\n92:             args=entrypoint_cmd[1:] if len(entrypoint_cmd) > 1 else None,\n93:             env=env_list if env_list else None,\n94:         )\n95: \n96:         pod_spec = V1PodSpec(containers=[container])\n97:         pod_template = V1PodTemplateSpec(\n98:             metadata=V1ObjectMeta(labels={\"app\": sanitized_name}),\n99:             spec=pod_spec,\n100:         )\n101:         deployment_spec = V1DeploymentSpec(\n102:             replicas=replicas,\n103:             selector={\"matchLabels\": {\"app\": sanitized_name}},\n104:             template=pod_template,\n105:         )\n106:         deployment = V1Deployment(\n107:             api_version=\"apps/v1\",\n108:             kind=\"Deployment\",\n109:             metadata=V1ObjectMeta(name=sanitized_name, namespace=self.namespace),\n110:             spec=deployment_spec,\n111:         )\n112: \n113:         self._apps_api.create_namespaced_deployment(\n114:             namespace=self.namespace,\n115:             body=deployment,\n116:         )\n117: \n118:         service_ports = [V1ServicePort(port=port, target_port=port)]\n119:         if node_port is not None:\n120:             service_ports[0].node_port = node_port\n121: \n122:         service_spec = V1ServiceSpec(\n123:             selector={\"app\": sanitized_name},\n124:             ports=service_ports,\n125:             type=\"NodePort\",\n126:         )\n127:         service = V1Service(\n128:             api_version=\"v1\",\n129:             kind=\"Service\",\n130:             metadata=V1ObjectMeta(name=sanitized_name, namespace=self.namespace),\n131:             spec=service_spec,\n132:         )\n133: \n134:         created_service = self._core_api.create_namespaced_service(\n135:             namespace=self.namespace,\n136:             body=service,\n137:         )\n138: \n139:         actual_node_port = node_port\n140:         if actual_node_port is None and created_service.spec.ports:\n141:             actual_node_port = created_service.spec.ports[0].node_port\n142: \n143:         service_url = f\"http://localhost:{actual_node_port}\"\n144: \n145:         return {\n146:             \"deployment_name\": sanitized_name,\n147:             \"service_name\": sanitized_name,\n148:             \"service_url\": service_url,\n149:             \"node_port\": actual_node_port,\n150:         }\n151: \n152:     def wait_for_deployment_ready(self, deployment_name: str, timeout: int = 120) -> None:\n153:         \"\"\"Wait for a deployment to become ready.\n154: \n155:         Args:\n156:             deployment_name: Name of the deployment.\n157:             timeout: Maximum seconds to wait (default: 120).\n158: \n159:         Raises:\n160:             TimeoutError: If the deployment does not become ready within timeout.\n161:         \"\"\"\n162:         start_time = time.time()\n163:         while time.time() - start_time < timeout:\n164:             deployment = self._apps_api.read_namespaced_deployment_status(\n165:                 name=deployment_name,\n166:                 namespace=self.namespace,\n167:             )\n168:             status = deployment.status\n169:             if (\n170:                 status.ready_replicas is not None\n171:                 and status.replicas is not None\n172:                 and status.ready_replicas == status.replicas\n173:             ):\n174:                 return\n175:             time.sleep(2)\n176: \n177:         raise TimeoutError(\n178:             f\"Deployment {deployment_name} did not become ready within {timeout}s\"\n179:         )\n180: \n181:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n182:         \"\"\"Get the status of a deployed agent.\n183: \n184:         Args:\n185:             agent_name: Name of the deployment.\n186: \n187:         Returns:\n188:             Dict with status, replicas, ready_replicas, available_replicas, etc.\n189:         \"\"\"\n190:         try:\n191:             deployment = self._apps_api.read_namespaced_deployment_status(\n192:                 name=agent_name,\n193:                 namespace=self.namespace,\n194:             )\n195:             status = deployment.status\n196:             return {\n197:                 \"status\": \"running\" if (status.ready_replicas and status.ready_replicas > 0) else \"pending\",\n198:                 \"deployment_name\": agent_name,\n199:                 \"namespace\": self.namespace,\n200:                 \"replicas\": status.replicas,\n201:                 \"ready_replicas\": status.ready_replicas,\n202:                 \"available_replicas\": status.available_replicas,\n203:                 \"updated_replicas\": status.updated_replicas,\n204:             }\n205:         except ApiException as e:\n206:             if e.status == 404:\n207:                 return {\n208:                     \"status\": \"not_found\",\n209:                     \"deployment_name\": agent_name,\n210:                     \"namespace\": self.namespace,\n211:                 }\n212:             raise\n213: \n214:     def update_agent(\n215:         self,\n216:         agent_name: str,\n217:         image_url: Optional[str] = None,\n218:         port: Optional[int] = None,\n219:         entrypoint: Optional[str] = None,\n220:         replicas: Optional[int] = None,\n221:         env_vars: Optional[Dict[str, str]] = None,\n222:     ) -> Dict[str, Any]:\n223:         \"\"\"Patch an existing Deployment and Service.\n224: \n225:         If the Deployment does not exist (404), falls back to deploy_agent.\n226: \n227:         Args:\n228:             agent_name: Name of the agent.\n229:             image_url: New container image URL.\n230:             port: New port the agent listens on.\n231:             entrypoint: New command to start the agent.\n232:             replicas: New number of replicas.\n233:             env_vars: New environment variables for the container.\n234: \n235:         Returns:\n236:             Dict with deployment_name, service_name, service_url, node_port.\n237:         \"\"\"\n238:         sanitized_name = agent_name.lower().replace(\"_\", \"-\").replace(\".\", \"-\")\n239: \n240:         deployment_patch: Dict[str, Any] = {\"spec\": {}}\n241:         if replicas is not None:\n242:             deployment_patch[\"spec\"][\"replicas\"] = replicas\n243: \n244:         if image_url or entrypoint or env_vars is not None:\n245:             containers_patch: Dict[str, Any] = {}\n246:             if image_url:\n247:                 containers_patch[\"image\"] = image_url\n248:             if entrypoint:\n249:                 entrypoint_cmd = entrypoint.split()\n250:                 containers_patch[\"command\"] = entrypoint_cmd[:1] if entrypoint_cmd else None\n251:                 containers_patch[\"args\"] = entrypoint_cmd[1:] if len(entrypoint_cmd) > 1 else None\n252:             if env_vars is not None:\n253:                 env_list = []\n254:                 for key, value in env_vars.items():\n255:                     env_list.append({\"name\": key, \"value\": value})\n256:                 containers_patch[\"env\"] = env_list\n257:             if containers_patch:\n258:                 deployment_patch[\"spec\"][\"template\"] = {\n259:                     \"spec\": {\"containers\": [containers_patch]}\n260:                 }\n261: \n262:         try:\n263:             self._apps_api.patch_namespaced_deployment(\n264:                 name=sanitized_name,\n265:                 namespace=self.namespace,\n266:                 body=deployment_patch,\n267:             )\n268:         except ApiException as e:\n269:             if e.status == 404:\n270:                 return self.deploy_agent(\n271:                     agent_name=agent_name,\n272:                     image_url=image_url or \"\",\n273:                     port=port or 8080,\n274:                     entrypoint=entrypoint or \"\",\n275:                     replicas=replicas or 1,\n276:                     env_vars=env_vars,\n277:                 )\n278:             raise\n279: \n280:         service_patch: Dict[str, Any] = {}\n281:         if port is not None:\n282:             service_patch[\"spec\"] = {\n283:                 \"ports\": [{\"port\": port, \"target_port\": port}]\n284:             }\n285: \n286:         if service_patch:\n287:             try:\n288:                 self._core_api.patch_namespaced_service(\n289:                     name=sanitized_name,\n290:                     namespace=self.namespace,\n291:                     body=service_patch,\n292:                 )\n293:             except ApiException as e:\n294:                 if e.status != 404:\n295:                     raise\n296: \n297:         existing_service = self._core_api.read_namespaced_service(\n298:             name=sanitized_name,\n299:             namespace=self.namespace,\n300:         )\n301:         actual_node_port = None\n302:         if existing_service.spec.ports:\n303:             actual_node_port = existing_service.spec.ports[0].node_port\n304: \n305:         service_url = f\"http://localhost:{actual_node_port}\"\n306: \n307:         return {\n308:             \"deployment_name\": sanitized_name,\n309:             \"service_name\": sanitized_name,\n310:             \"service_url\": service_url,\n311:             \"node_port\": actual_node_port,\n312:         }\n313: \n314:     def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n315:         \"\"\"Delete a Deployment and Service by name.\n316: \n317:         Ignores 404 errors if resources do not exist.\n318: \n319:         Args:\n320:             agent_name: Name of the agent resources to delete.\n321: \n322:         Returns:\n323:             Dict with status, deployment_name, namespace.\n324:         \"\"\"\n325:         try:\n326:             self._apps_api.delete_namespaced_deployment(\n327:                 name=agent_name,\n328:                 namespace=self.namespace,\n329:             )\n330:         except ApiException as e:\n331:             if e.status != 404:\n332:                 raise\n333: \n334:         try:\n335:             self._core_api.delete_namespaced_service(\n336:                 name=agent_name,\n337:                 namespace=self.namespace,\n338:             )\n339:         except ApiException as e:\n340:             if e.status != 404:\n341:                 raise\n342: \n343:         return {\n344:             \"status\": \"deleted\",\n345:             \"deployment_name\": agent_name,\n346:             \"namespace\": self.namespace,\n347:         }\n\n(End of file - total 347 lines)\n</content>","metadata":{"preview":"\"\"\"Kubernetes provider for deploying standard Deployment + NodePort Service.\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom typing import Any, Dict, Optional\n\ntry:\n    from kubernetes import client, config\n    from kubernetes.client.rest import ApiException\n    from kubernetes.client import (\n        V1Container,\n        V1ContainerPort,\n        V1Deployment,\n        V1DeploymentSpec,\n        V1DeploymentStatus,\n        V1EnvVar,\n        V1ObjectMeta,\n        V1PodSpec,\n        V1PodTemplateSpec,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/services/k8s_provider.py","time":{"start":1775863521777,"end":1775863521783}}}}
{"type":"tool_use","timestamp":1775863523081,"sessionID":"ses_28649817fffe9AkP3UViOSPpKA","part":{"id":"prt_d79b6e2810013e43W4iA44pjTx","messageID":"msg_d79b6d189001mKxO24FB2t0fT6","sessionID":"ses_28649817fffe9AkP3UViOSPpKA","type":"tool","tool":"read","callID":"call_eb24dc02f2f645f4a108f2c0","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Publish runtime for deploying agents to Kubernetes.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from pathlib import Path\n6: from typing import Any, Dict\n7: \n8: from agentcube.services.agentcube_provider import AgentCubeProvider\n9: from agentcube.services.docker_service import DockerService\n10: from agentcube.services.k8s_provider import KubernetesProvider\n11: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n12: \n13: \n14: class PublishRuntime:\n15:     \"\"\"Runtime for publishing agents to Kubernetes clusters.\"\"\"\n16: \n17:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n18:         self.verbose = verbose\n19:         self.provider = provider\n20: \n21:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n22:         \"\"\"Publish an agent to a Kubernetes cluster.\n23: \n24:         Args:\n25:             workspace_path: Path to the packaged agent workspace.\n26:             **options: CLI options (version, image_url, provider, etc.).\n27: \n28:         Returns:\n29:             Dict with deployment information.\n30: \n31:         Raises:\n32:             ValueError: If workspace is invalid or required options are missing.\n33:             RuntimeError: If Docker is unavailable or deployment times out.\n34:         \"\"\"\n35:         if not workspace_path.exists():\n36:             raise ValueError(f\"Workspace directory does not exist: {workspace_path}\")\n37:         if not workspace_path.is_dir():\n38:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n39: \n40:         service = MetadataService(verbose=self.verbose)\n41:         metadata = service.load_metadata(workspace_path)\n42:         if metadata is None:\n43:             raise ValueError(\"Workspace has not been packaged. Run 'pack' first.\")\n44: \n45:         for key in [\"version\", \"description\", \"region\"]:\n46:             value = options.get(key)\n47:             if value is not None:\n48:                 setattr(metadata, key, value)\n49: \n50:         node_port = options.get(\"node_port\")\n51:         if node_port is not None and not (30000 <= node_port <= 32767):\n52:             raise ValueError(\"NodePort must be between 30000 and 32767\")\n53: \n54:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n55:         options[\"image_url\"] = image_url\n56: \n57:         if self.provider == \"agentcube\":\n58:             result = self._publish_cr_to_k8s(workspace_path, metadata, **options)\n59:         elif self.provider == \"k8s\":\n60:             result = self._publish_k8s(workspace_path, metadata, **options)\n61:         else:\n62:             raise ValueError(f\"Unsupported provider: {self.provider}\")\n63: \n64:         self._update_publish_metadata(workspace_path, result)\n65: \n66:         return result\n67: \n68:     def _prepare_image_for_publishing(\n69:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n70:     ) -> str:\n71:         \"\"\"Prepare the container image for publishing based on build mode.\"\"\"\n72:         if metadata.build_mode == \"local\":\n73:             return self._prepare_local_image(workspace_path, metadata, options)\n74:         elif metadata.build_mode == \"cloud\":\n75:             return self._prepare_cloud_image(workspace_path, metadata, options)\n76:         else:\n77:             raise ValueError(f\"Unsupported build mode: {metadata.build_mode}\")\n78: \n79:     def _prepare_local_image(\n80:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n81:     ) -> str:\n82:         \"\"\"Prepare a local Docker image for publishing by pushing to a registry.\"\"\"\n83:         docker_service = DockerService(verbose=self.verbose)\n84: \n85:         if not docker_service.check_docker_available():\n86:             raise RuntimeError(\"Docker is not available or not running\")\n87: \n88:         image_url = options.get(\"image_url\")\n89:         if not image_url:\n90:             if metadata.image and metadata.image.get(\"url\"):\n91:                 image_url = metadata.image[\"url\"]\n92:             else:\n93:                 raise ValueError(\"Image URL is required for local build mode\")\n94: \n95:         version = metadata.version or \"latest\"\n96:         image_tag = f\"{image_url}:{version}\"\n97: \n98:         username = options.get(\"image_username\") or metadata.registry_username\n99:         password = options.get(\"image_password\") or metadata.registry_password\n100:         registry_url = options.get(\"registry_url\") or metadata.registry_url\n101: \n102:         if username and password:\n103:             docker_service._docker_login_sdk(registry_url or \"\", username, password)\n104: \n105:         result = docker_service.push_image(image_tag, registry_url, username, password)\n106:         return result.get(\"pushed_image\", image_tag)\n107: \n108:     def _prepare_cloud_image(\n109:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n110:     ) -> str:\n111:         \"\"\"Resolve the image URL for cloud build mode.\"\"\"\n112:         image_url = options.get(\"image_url\")\n113:         if image_url:\n114:             return image_url\n115: \n116:         if metadata.image and metadata.image.get(\"url\"):\n117:             return metadata.image[\"url\"]\n118: \n119:         raise ValueError(\"Image URL is required for cloud build mode\")\n120: \n121:     def _publish_cr_to_k8s(\n122:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n123:     ) -> Dict[str, Any]:\n124:         \"\"\"Publish an agent as an AgentRuntime Custom Resource.\"\"\"\n125:         if not metadata.router_url:\n126:             raise ValueError(\n127:                 \"router_url and workload_manager_url are required in agent_metadata.yaml for AgentCube provider\"\n128:             )\n129:         if not metadata.workload_manager_url:\n130:             raise ValueError(\n131:                 \"router_url and workload_manager_url are required in agent_metadata.yaml for AgentCube provider\"\n132:             )\n133:         if not metadata.readiness_probe_path:\n134:             raise ValueError(\"readiness_probe_path is required in agent_metadata.yaml for AgentCube provider\")\n135:         if not metadata.readiness_probe_port:\n136:             raise ValueError(\"readiness_probe_port is required in agent_metadata.yaml for AgentCube provider\")\n137: \n138:         namespace = options.get(\"namespace\") or \"default\"\n139:         provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n140: \n141:         env_vars = options.get(\"env_vars\", {})\n142:         if not env_vars and metadata.image and metadata.image.get(\"env\"):\n143:             env_vars = metadata.image[\"env\"]\n144: \n145:         result = provider.deploy_agent_runtime(\n146:             agent_name=metadata.agent_name,\n147:             image_url=options.get(\"image_url\", \"\"),\n148:             port=metadata.port,\n149:             entrypoint=metadata.entrypoint,\n150:             env_vars=env_vars,\n151:             workload_manager_url=metadata.workload_manager_url,\n152:             router_url=metadata.router_url,\n153:             readiness_probe_path=metadata.readiness_probe_path,\n154:             readiness_probe_port=metadata.readiness_probe_port,\n155:         )\n156: \n157:         return {\n158:             \"agent_id\": result.get(\"name\"),\n159:             \"agent_endpoint\": result.get(\"endpoint\"),\n160:             \"namespace\": namespace,\n161:             \"k8s_deployment\": {\n162:                 \"type\": \"AgentRuntime\",\n163:                 \"namespace\": namespace,\n164:                 \"cr_name\": result.get(\"name\"),\n165:             },\n166:         }\n167: \n168:     def _publish_k8s(\n169:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n170:     ) -> Dict[str, Any]:\n171:         \"\"\"Publish an agent as a standard Kubernetes Deployment + Service.\"\"\"\n172:         namespace = options.get(\"namespace\") or \"default\"\n173:         replicas = options.get(\"replicas\") or 1\n174:         node_port = options.get(\"node_port\")\n175: \n176:         provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n177: \n178:         env_vars = options.get(\"env_vars\", {})\n179:         if not env_vars and metadata.image and metadata.image.get(\"env\"):\n180:             env_vars = metadata.image[\"env\"]\n181: \n182:         result = provider.deploy_agent(\n183:             agent_name=metadata.agent_name,\n184:             image_url=options.get(\"image_url\", \"\"),\n185:             port=metadata.port,\n186:             entrypoint=metadata.entrypoint,\n187:             replicas=replicas,\n188:             node_port=node_port,\n189:             env_vars=env_vars,\n190:         )\n191: \n192:         try:\n193:             provider.wait_for_deployment_ready(result[\"deployment_name\"], timeout=120)\n194:         except TimeoutError:\n195:             raise RuntimeError(\n196:                 f\"Deployment {result['deployment_name']} did not become ready within 120s\"\n197:             )\n198: \n199:         return {\n200:             \"deployment_name\": result[\"deployment_name\"],\n201:             \"service_name\": result[\"service_name\"],\n202:             \"service_url\": result[\"service_url\"],\n203:             \"namespace\": namespace,\n204:             \"replicas\": replicas,\n205:             \"node_port\": result.get(\"node_port\"),\n206:             \"k8s_deployment\": {\n207:                 \"type\": \"Deployment\",\n208:                 \"namespace\": namespace,\n209:                 \"deployment_name\": result[\"deployment_name\"],\n210:                 \"service_url\": result[\"service_url\"],\n211:             },\n212:         }\n213: \n214:     def _update_publish_metadata(\n215:         self, workspace_path: Path, agent_info: Dict[str, Any]\n216:     ) -> None:\n217:         \"\"\"Update workspace metadata with publish results.\"\"\"\n218:         service = MetadataService(verbose=self.verbose)\n219:         updates: Dict[str, Any] = {\n220:             \"agent_id\": agent_info.get(\"agent_id\"),\n221:             \"agent_endpoint\": agent_info.get(\"agent_endpoint\") or agent_info.get(\"service_url\"),\n222:             \"k8s_deployment\": agent_info.get(\"k8s_deployment\"),\n223:         }\n224:         service.update_metadata(workspace_path, updates)\n\n(End of file - total 224 lines)\n</content>","metadata":{"preview":"\"\"\"Publish runtime for deploying agents to Kubernetes.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Any, Dict\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass PublishRuntime:\n    \"\"\"Runtime for publishing agents to Kubernetes clusters.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/publish_runtime.py","time":{"start":1775863523072,"end":1775863523079}}}}
