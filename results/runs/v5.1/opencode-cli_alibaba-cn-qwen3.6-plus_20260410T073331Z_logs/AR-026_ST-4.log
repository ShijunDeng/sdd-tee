_url\": \"http://localhost:30080\",\n115:                 \"node_port\": 30080,\n116:                 \"k8s_deployment\": {\"type\": \"Deployment\"},\n117:             }):\n118:                 with patch.object(PublishRuntime, \"_update_publish_metadata\"):\n119:                     runtime = PublishRuntime(provider=\"k8s\")\n120:                     runtime.publish(workspace_with_metadata, description=\"New description\")\n121: \n122:         from agentcube.services.metadata_service import MetadataService\n123:         metadata = MetadataService().load_metadata(workspace_with_metadata)\n124:         assert metadata is not None\n125:         assert metadata.description == \"New description\"\n126: \n127: \n128: class TestPublishRuntime_RegionOverride:\n129:     def test_region_is_updated_in_metadata(self, workspace_with_metadata: Path) -> None:\n130:         with patch.object(PublishRuntime, \"_prepare_image_for_publishing\", return_value=\"test:v1\"):\n131:             with patch.object(PublishRuntime, \"_publish_k8s\", return_value={\n132:                 \"deployment_name\": \"test-agent\",\n133:                 \"service_name\": \"test-agent\",\n134:                 \"service_url\": \"http://localhost:30080\",\n135:                 \"node_port\": 30080,\n136:                 \"k8s_deployment\": {\"type\": \"Deployment\"},\n137:             }):\n138:                 with patch.object(PublishRuntime, \"_update_publish_metadata\"):\n139:                     runtime = PublishRuntime(provider=\"k8s\")\n140:                     runtime.publish(workspace_with_metadata, region=\"cn-north-4\")\n141: \n142:         from agentcube.services.metadata_service import MetadataService\n143:         metadata = MetadataService().load_metadata(workspace_with_metadata)\n144:         assert metadata is not None\n145:         assert metadata.region == \"cn-north-4\"\n146: \n147: \n148: class TestPublishRuntime_ValidAgentCubePublish:\n149:     def test_publishes_cr_successfully(self, 