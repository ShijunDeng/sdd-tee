fixture\n46: def workspace_without_agent_id(tmp_path: Path) -> Path:\n47:     ws = tmp_path / \"my-agent\"\n48:     ws.mkdir()\n49:     (ws / \"main.py\").write_text(\"print('hello')\\n\")\n50:     (ws / \"agent_metadata.yaml\").write_text(\n51:         \"agent_name: test-agent\\n\"\n52:         \"language: python\\n\"\n53:         \"entrypoint: python main.py\\n\"\n54:         \"port: 8080\\n\"\n55:         \"build_mode: local\\n\"\n56:     )\n57:     return ws\n58: \n59: \n60: @pytest.fixture\n61: def workspace_no_metadata(tmp_path: Path) -> Path:\n62:     ws = tmp_path / \"my-agent\"\n63:     ws.mkdir()\n64:     (ws / \"main.py\").write_text(\"print('hello')\\n\")\n65:     return ws\n66: \n67: \n68: class TestStatusRuntime_Constructor:\n69:     def test_default_values(self) -> None:\n70:         runtime = StatusRuntime()\n71:         assert runtime.verbose is False\n72:         assert runtime.provider == \"agentcube\"\n73: \n74:     def test_custom_values(self) -> None:\n75:         runtime = StatusRuntime(verbose=True, provider=\"k8s\")\n76:         assert runtime.verbose is True\n77:         assert runtime.provider == \"k8s\"\n78: \n79: \n80: class TestStatusRuntime_NotPublished:\n81:     def test_returns_not_published_when_no_agent_id(\n82:         self, workspace_without_agent_id: Path, runtime: StatusRuntime,\n83:     ) -> None:\n84:         result = runtime.get_status(workspace_without_agent_id)\n85:         assert result[\"status\"] == \"not_published\"\n86: \n87:     def test_returns_not_published_when_no_metadata(\n88:         self, workspace_no_metadata: Path, runtime: StatusRuntime,\n89:     ) -> None:\n90:         result = runtime.get_status(workspace_no_metadata)\n91:         assert result[\"status\"] == \"not_published\"\n92: \n93: \n94: class TestStatusRuntime_CRAgentCubeExists:\n95:     def test_returns_cr_status_when_exists(\n96:         self, workspace_with_published_metadata: Path, mocker,\n97:     ) -> None:\n98:         mock_cr = {\n99:             \"metadata\": {\"name\": \"test-agent\"},\n100:             \"status\": {\n101:                 \"status\": \"running\",\n102:                 \"agentEndpoint\": \"http://router.example.com/v1/agents/test-agent\",\n103:             },\n104:         }\n105:         mock_provider = MagicMock()\n106:         mock_provider.get_agent_runtime.return_value = mock_cr\n107:         mocker.patch(\n108:             \"agentcube.runtime.status_runtime.AgentCubeProvider\",\n109:             return_value=mock_provider,\n110:         )\n111: \n112:         runtime = StatusRuntime(provider=\"agentcube\")\n113:         result = runtime.get_status(workspace_with_published_metadata)\n114: \n115:         assert result[\"status\"] == \"running\"\n116:         assert result[\"agent_name\"] == \"test-agent\"\n117:         assert result[\"endpoint\"] == \"http://router.example.com/v1/agents/test-agent\"\n118:         assert result[\"cr_name\"] == \"test-agent\"\n119:         assert result[\"namespace\"] == \"default\"\n120:         assert result[\"version\"] == \"1.0.0\"\n121: \n122: \n123: class TestStatusRuntime_CRAgentCubeNoStatus:\n124:     def test_returns_created_no_status(\n125:         self, workspace_with_published_metadata: Path, mocker,\n126:     ) -> None:\n127:         mock_cr = {\n128:             \"metadata\": {\"name\": \"test-agent\"},\n129:         }\n130:         mock_provider = MagicMock()\n131:         mock_provider.get_agent_runtime.return_value = mock_cr\n132:         mocker.patch(\n133:             \"agentcube.runtime.status_runtime.AgentCubeProvider\",\n134:             return_value=mock_provider,\n135:         )\n136: \n137:         runtime = StatusRuntime(provider=\"agentcube\")\n138:         result = runtime.get_status(workspace_with_published_metadata)\n139: \n140:         assert result[\"status\"] == \"created_no_status\"\n141:         assert result[\"agent_name\"] == \"test-agent\"\n142:         assert result[\"cr_name\"] == \"test-agent\"\n143:         assert result[\"namespace\"] == \"default\"\n144: \n145: \n146: class TestStatusRuntime_CRNotFound:\n147:     def test_returns_not_found_in_k8s(\n148:         self, workspace_with_published_metadata: Path, mocker,\n149:     ) -> None:\n150:         mock_provider = MagicMock()\n151:         mock_provider.get_agent_runtime.return_value = None\n152:         mocker.patch(\n153:             \"agentcube.runtime.status_runtime.AgentCubeProvider\",\n154:             return_value=mock_provider,\n155:         )\n156: \n157:         runtime = StatusRuntime(provider=\"agentcube\")\n158:         result = runtime.get_status(workspace_with_published_metadata)\n159: \n160:         assert result[\"status\"] == \"not_found_in_k8s\"\n161:         assert result[\"agent_name\"] == \"test-agent\"\n162:         assert result[\"cr_name\"] == \"test-agent\"\n163:         assert result[\"namespace\"] == \"default\"\n164: \n165: \n166: class TestStatusRuntime_K8sDeploymentRunning:\n167:     def test_returns_running_status(\n168:         self, workspace_with_published_metadata: Path, mocker,\n169:     ) -> None:\n170:         k8s_status = {\n171:             \"status\": \"running\",\n172:             \"deployment_name\": \"test-agent\",\n173:             \"namespace\": \"default\",\n174:             \"replicas\": 1,\n175:             \"ready_replicas\": 1,\n176:         }\n177:         mock_provider = MagicMock()\n178:         mock_provider.get_agent_status.return_value = k8s_status\n179:         mocker.patch(\n180:             \"agentcube.runtime.status_runtime.KubernetesProvider\",\n181:             return_value=mock_provider,\n182:         )\n183: \n184:         runtime = StatusRuntime(provider=\"k8s\")\n185:         result = runtime.get_status(workspace_with_published_metadata)\n186: \n187:         assert result[\"status\"] == \"running\"\n188:         assert result[\"deployment_name\"] == \"test-agent\"\n189:         mock_provider.get_agent_status.assert_called_once()\n190: \n191: \n192: class TestStatusRuntime_K8sDeploymentPending:\n193:     def test_returns_pending_status(\n194:         self, workspace_with_published_metadata: Path, mocker,\n195:     ) -> None:\n196:         k8s_status = {\n197:             \"status\": \"pending\",\n198:             \"deployment_name\": \"test-agent\",\n199:             \"namespace\": \"default\",\n200:             \"replicas\": 1,\n201:             \"ready_replicas\": 0,\n202:         }\n203:         mock_provider = MagicMock()\n204:         mock_provider.get_agent_status.return_value = k8s_status\n205:         mocker.patch(\n206:             \"agentcube.runtime.status_runtime.KubernetesProvider\",\n207:             return_value=mock_provider,\n208:         )\n209: \n210:         runtime = StatusRuntime(provider=\"k8s\")\n211:         result = runtime.get_status(workspace_with_published_metadata)\n212: \n213:         assert result[\"status\"] == \"pending\"\n214: \n215: \n216: class TestStatusRuntime_K8sDeploymentNotFound:\n217:     def test_returns_not_found_status(\n218:         self, workspace_with_published_metadata: Path, mocker,\n219:     ) -> None:\n220:         k8s_status = {\n221:             \"status\": \"not_found\",\n222:             \"deployment_name\": \"test-agent\",\n223:             \"namespace\": \"default\",\n224:         }\n225:         mock_provider = MagicMock()\n226:         mock_provider.get_agent_status.return_value = k8s_status\n227:         mocker.patch(\n228:             \"agentcube.runtime.status_runtime.KubernetesProvider\",\n229:             return_value=mock_provider,\n230:         )\n231: \n232:         runtime = StatusRuntime(provider=\"k8s\")\n233:         result = runtime.get_status(workspace_with_published_metadata)\n234: \n235:         assert result[\"status\"] == \"not_found\"\n236: \n237: \n238: class TestStatusRuntime_ProviderSelection:\n239:     def test_agentcube_provider_routes_to_cr_status(\n240:         self, workspace_with_published_metadata: Path, mocker,\n241:     ) -> None:\n242:         mock_provider = MagicMock()\n243:         mock_provider.get_agent_runtime.return_value = None\n244:         mocker.patch(\n245:             \"agentcube.runtime.status_runtime.AgentCubeProvider\",\n246:             return_value=mock_provider,\n247:         )\n248: \n249:         runtime = StatusRuntime(provider=\"agentcube\")\n250:         runtime.get_status(workspace_with_published_metadata)\n251: \n252:         mock_provider.get_agent_runtime.assert_called_once()\n253: \n254:     def test_k8s_provider_routes_to_k8s_status(\n255:         self, workspace_with_published_metadata: Path, mocker,\n256:     ) -> None:\n257:         mock_provider = MagicMock()\n258:         mock_provider.get_agent_status.return_value = {\"status\": \"running\"}\n259:         mocker.patch(\n260:             \"agentcube.runtime.status_runtime.KubernetesProvider\",\n261:             return_value=mock_provider,\n262:         )\n263: \n264:         runtime = StatusRuntime(provider=\"k8s\")\n265:         runtime.get_status(workspace_with_published_metadata)\n266: \n267:         mock_provider.get_agent_status.assert_called_once()\n268: \n269:     def test_provider_parameter_overrides_constructor(\n270:         self, workspace_with_published_metadata: Path, mocker,\n271:     ) -> None:\n272:         mock_provider = MagicMock()\n273:         mock_provider.get_agent_status.return_value = {\"status\": \"running\"}\n274:         mocker.patch(\n275:             \"agentcube.runtime.status_runtime.KubernetesProvider\",\n276:             return_value=mock_provider,\n277:         )\n278: \n279:         runtime = StatusRuntime(provider=\"agentcube\")\n280:         runtime.get_status(workspace_with_published_metadata, provider=\"k8s\")\n281: \n282:         mock_provider.get_agent_status.assert_called_once()\n\n(End of file - total 282 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for StatusRuntime.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.runtime.status_runtime import StatusRuntime\n\n\n@pytest.fixture\ndef runtime() -> StatusRuntime:\n    return StatusRuntime()\n\n\n@pytest.fixture\ndef runtime_k8s() -> StatusRuntime:\n    return StatusRuntime(provider=\"k8s\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/runtime/test_status_runtime.py","time":{"start":1775862109573,"end":1775862109581}}}}
