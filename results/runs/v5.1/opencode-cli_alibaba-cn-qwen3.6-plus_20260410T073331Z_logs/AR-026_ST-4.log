{"type":"tool_use","timestamp":1775862115182,"sessionID":"ses_28661e1e4ffevPoFHX5USfhuNI","part":{"id":"prt_d79a167d8001UO1vl0oUEJM75i","messageID":"msg_d79a15a01001mneXJVPL1Wwszu","sessionID":"ses_28661e1e4ffevPoFHX5USfhuNI","type":"tool","tool":"read","callID":"call_c5e73712d7da44ac932433d9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/invoke_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/invoke_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"InvokeRuntime for invoking deployed agents via HTTP.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import asyncio\n6: import json\n7: from pathlib import Path\n8: from typing import Any, Dict, Optional, Tuple\n9: \n10: import httpx\n11: \n12: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n13: \n14: \n15: class InvokeRuntime:\n16:     \"\"\"Runtime for invoking deployed agents with provider-aware logic.\"\"\"\n17: \n18:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n19:         self.verbose = verbose\n20:         self.provider = provider\n21: \n22:     def invoke(\n23:         self,\n24:         workspace_path: Path,\n25:         payload: Dict[str, Any],\n26:         headers: Optional[Dict[str, str]] = None,\n27:     ) -> Any:\n28:         \"\"\"Invoke a deployed agent with the given payload.\n29: \n30:         Args:\n31:             workspace_path: Path to the agent workspace.\n32:             payload: JSON payload to send to the agent.\n33:             headers: Optional HTTP headers to include.\n34: \n35:         Returns:\n36:             The response from the agent endpoint.\n37:         \"\"\"\n38:         metadata, agent_id, endpoint = self._validate_invoke_prerequisites(workspace_path)\n39: \n40:         if self.provider == \"agentcube\":\n41:             return asyncio.run(\n42:                 self._invoke_agent_via_agentcube(\n43:                     agent_id, payload, headers, endpoint, workspace_path,\n44:                 )\n45:             )\n46:         else:\n47:             return asyncio.run(\n48:                 self._direct_http_invocation(\n49:                     endpoint, payload, headers, workspace_path,\n50:                 )\n51:             )\n52: \n53:     def _validate_invoke_prerequisites(\n54:         self, workspace_path: Path,\n55:     ) -> Tuple[AgentMetadata, str, str]:\n56:         \"\"\"Validate that the workspace has published metadata.\n57: \n58:         Args:\n59:             workspace_path: Path to the agent workspace.\n60: \n61:         Returns:\n62:             Tuple of (metadata, agent_id, endpoint).\n63: \n64:         Raises:\n65:             ValueError: If the agent has not been published or endpoint is missing.\n66:         \"\"\"\n67:         service = MetadataService(verbose=self.verbose)\n68:         metadata = service.load_metadata(workspace_path)\n69: \n70:         if metadata is None:\n71:             raise ValueError(\n72:                 \"Agent has not been published. Run 'kubectl-agentcube publish' first.\"\n73:             )\n74: \n75:         if not metadata.agent_id:\n76:             raise ValueError(\n77:                 \"Agent has not been published. Run 'kubectl-agentcube publish' first.\"\n78:             )\n79:         if not metadata.agent_endpoint:\n80:             raise ValueError(\n81:                 \"Agent endpoint is not set in metadata. Run 'kubectl-agentcube publish' first.\"\n82:             )\n83: \n84:         return metadata, metadata.agent_id, metadata.agent_endpoint\n85: \n86:     async def _invoke_agent_via_agentcube(\n87:         self,\n88:         agent_id: str,\n89:         payload: Dict[str, Any],\n90:         headers: Optional[Dict[str, str]],\n91:         endpoint: str,\n92:         workspace_path: Path,\n93:     ) -> Any:\n94:         \"\"\"Invoke via AgentCube AgentRuntime CR endpoint.\n95: \n96:         Rewrites the endpoint URL if k8s_deployment.type == \"AgentRuntime\".\n97:         Adds X-Agentcube-Session-Id header if session_id exists in metadata.\n98: \n99:         Args:\n100:             agent_id: The agent ID.\n101:             payload: JSON payload to send.\n102:             headers: Optional HTTP headers.\n103:             endpoint: The base endpoint URL.\n104:             workspace_path: Path to the workspace (for loading metadata).\n105: \n106:         Returns:\n107:             Parsed JSON response.\n108:         \"\"\"\n109:         metadata = MetadataService(verbose=self.verbose).load_metadata(workspace_path)\n110: \n111:         if metadata.k8s_deployment and metadata.k8s_deployment.get(\"type\") == \"AgentRuntime\":\n112:             namespace = metadata.k8s_deployment.get(\"namespace\", \"default\")\n113:             agent_name = metadata.k8s_deployment.get(\"cr_name\", metadata.agent_name)\n114:             base = endpoint.rstrip(\"/\").rsplit(\"/v1/\", 1)[0] if \"/v1/\" in endpoint else endpoint.rstrip(\"/\")\n115:             endpoint = f\"{base}/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n116: \n117:         request_headers = headers.copy() if headers else {}\n118:         if metadata and metadata.session_id:\n119:             request_headers[\"X-Agentcube-Session-Id\"] = metadata.session_id\n120: \n121:         async with httpx.AsyncClient() as client:\n122:             response = await client.post(endpoint, json=payload, headers=request_headers)\n123:             response.raise_for_status()\n124:             return response.json()\n125: \n126:     async def _direct_http_invocation(\n127:         self,\n128:         endpoint: str,\n129:         payload: Dict[str, Any],\n130:         headers: Optional[Dict[str, str]],\n131:         workspace_path: Path,\n132:     ) -> Dict[str, Any]:\n133:         \"\"\"Direct HTTP POST to the agent endpoint.\n134: \n135:         Args:\n136:             endpoint: The agent endpoint URL.\n137:             payload: JSON payload to send.\n138:             headers: Optional HTTP headers.\n139:             workspace_path: Path to the workspace (for loading metadata).\n140: \n141:         Returns:\n142:             Parsed JSON response.\n143:         \"\"\"\n144:         metadata = MetadataService(verbose=self.verbose).load_metadata(workspace_path)\n145: \n146:         request_headers = headers.copy() if headers else {}\n147:         if metadata and metadata.session_id:\n148:             request_headers[\"X-Agentcube-Session-Id\"] = metadata.session_id\n149: \n150:         async with httpx.AsyncClient() as client:\n151:             response = await client.post(endpoint, json=payload, headers=request_headers)\n152:             response.raise_for_status()\n153:             return response.json()\n\n(End of file - total 153 lines)\n</content>","metadata":{"preview":"\"\"\"InvokeRuntime for invoking deployed agents via HTTP.\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport json\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional, Tuple\n\nimport httpx\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass InvokeRuntime:\n    \"\"\"Runtime for invoking deployed agents with provider-aware logic.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/agentcube/runtime/invoke_runtime.py","time":{"start":1775862115173,"end":1775862115181}}}}
