= runner.invoke(\n96:             app, [\"status\", \"-f\", str(published_workspace), \"--provider\", \"k8s\"],\n97:         )\n98:         assert result.exit_code == 0\n99:         assert \"running\" in result.output\n100: \n101: \n102: class TestStatusCommand_NotPublished:\n103:     def test_shows_guidance_when_not_published(\n104:         self, unpublished_workspace: Path,\n105:     ) -> None:\n106:         result = runner.invoke(\n107:             app, [\"status\", \"-f\", str(unpublished_workspace)],\n108:         )\n109:         assert result.exit_code == 1\n110:         assert \"not been published\" in result.output\n111:         assert \"publish\" in result.output.lower()\n112: \n113: \n114: class TestStatusCommand_ErrorStatus:\n115:     def test_shows_error_when_status_is_error(\n116:         self, published_workspace: Path, mocker,\n117:     ) -> None:\n118:         mocker.patch(\n119:             \"agentcube.runtime.status_runtime.StatusRuntime.get_status\",\n120:             return_value={\"status\": \"error\", \"message\": \"K8s connection failed\"},\n121:         )\n122: \n123:         result = runner.invoke(\n124:             app, [\"status\", \"-f\", str(published_workspace)],\n125:         )\n126:         assert result.exit_code == 1\n127:         assert \"Error\" in result.output\n128: \n129: \n130: class TestStatusCommand_VerboseError:\n131:     def test_shows_traceback_with_verbose(\n132:         self, published_workspace: Path, mocker,\n133:     ) -> None:\n134:         mocker.patch(\n135:             \"agentcube.runtime.status_runtime.StatusRuntime.get_status\",\n136:             side_effect=RuntimeError(\"K8s connection failed\"),\n137:         )\n138: \n139:         result = runner.invoke(\n140:             app, [\n141:                 \"status\", \"-f\", str(published_workspace),\n142:                 \"--verbose\",\n143:             ],\n144:         )\n145:         assert result.exit_code == 1\n146:         assert \"Error getting status\" in result.output\n147:         assert \"Traceback\" in result.output\n148: \n149: \n150: class TestStatusCommand_QuietError:\n151:     def test_no_traceback_without_verbose(\n152:         self, published_workspace: Path, mocker,\n153:     ) -> None:\n154:         mocker.patch(\n155:             \"agentcube.runtime.status_runtime.StatusRuntime.get_status\",\n156:             side_effect=RuntimeError(\"K8s connection failed\"),\n157:         )\n158: \n159:         result = runner.invoke(\n160:             app, [\"status\", \"-f\", str(published_workspace)],\n161:         )\n162:         assert result.exit_code == 1\n163:         assert \"Error getting status\" in result.output\n164:         assert \"Traceback\" not in result.output\n165: \n166: \n167: class TestStatusCommand_HelpOutput:\n168:     def test_shows_help(self) -> None:\n169:         result = runner.invoke(app, [\"status\", \"--help\"])\n170:         assert result.exit_code == 0\n171:         assert \"--workspace\" in result.output or \"-f\" in result.output\n172:         assert \"--provider\" in result.output\n173:         assert \"--verbose\" in result.output\n\n(End of file - total 173 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for the CLI status command.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\nfrom typer.testing import CliRunner\n\nfrom agentcube.cli.main import app\n\nrunner = CliRunner()\n\n\n@pytest.fixture\ndef published_workspace(tmp_path: Path) -> Path:\n    ws = tmp_path / \"my-agent\"\n    ws.mkdir()\n    (ws / \"main.py\").write_text(\"print('hello')\\n\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/cmd/cli/tests/cli/test_status_command.py","time":{"start":1775862124695,"end":1775862124702}}}}
