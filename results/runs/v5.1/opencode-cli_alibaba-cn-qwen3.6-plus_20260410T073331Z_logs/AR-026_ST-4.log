t:v1\"):\n254:             with patch(\"agentcube.runtime.publish_runtime.AgentCubeProvider\") as mock_provider_cls:\n255:                 mock_provider = MagicMock()\n256:                 mock_provider.deploy_agent_runtime.return_value = {\n257:                     \"name\": \"test-agent\",\n258:                     \"endpoint\": \"http://router.example.com/v1/agents/test-agent\",\n259:                 }\n260:                 mock_provider_cls.return_value = mock_provider\n261: \n262:                 runtime = PublishRuntime(provider=\"agentcube\")\n263:                 runtime.publish(workspace_with_metadata, namespace=\"production\")\n264: \n265:                 mock_provider_cls.assert_called_once_with(namespace=\"production\", verbose=False)\n266: \n267: \n268: class TestPublishRuntime_DeploymentTimeout:\n269:     def test_raises_runtime_error_on_timeout(self, workspace_with_metadata: Path) -> None:\n270:         with patch.object(PublishRuntime, \"_prepare_image_for_publishing\", return_value=\"test:v1\"):\n271:             with patch(\"agentcube.runtime.publish_runtime.KubernetesProvider\") as mock_provider_cls:\n272:                 mock_provider = MagicMock()\n273:                 mock_provider.deploy_agent.return_value = {\n274:                     \"deployment_name\": \"test-agent\",\n275:                     \"service_name\": \"test-agent\",\n276:                     \"service_url\": \"http://localhost:30080\",\n277:                     \"node_port\": 30080,\n278:                 }\n279:                 mock_provider.wait_for_deployment_ready.side_effect = TimeoutError(\"timeout\")\n280:                 mock_provider_cls.return_value = mock_provider\n281: \n282:                 runtime = PublishRuntime(provider=\"k8s\")\n283:                 with pytest.raises(RuntimeError, match=\"did not become ready within 120s\"):\n284:                     runtime.publish(workspace_with_metadata)\n285: \n286: \n287: class TestPublishRuntime_K8sWithReplicas:\n288:     def test_passes_replicas_to_provider(self, workspace_with_metadata: Path) -> None:\n289:         with patch.object(PublishRuntime, \"_prepare_image_for_publishing\", return_value=\"test:v1\"):\n290:             with patch(\"agentcube.runtime.publish_runtime.KubernetesProvider\") as mock_provider_cls:\n291:                 mock_provider = MagicMock()\n292:                 mock_provider.deploy_agent.return_value = {\n293:                     \"deployment_name\": \"test-agent\",\n294:                     \"service_name\": \"test-agent\",\n295:                     \"service_url\": \"http://localhost:30080\",\n296:                     \"node_port\": 30080,\n297:                 }\n298:                 mock_provider.wait_for_deployment_ready.return_value = None\n299:                 mock_provider_cls.return_value = mock_provider\n300: \n301:                 runtime = PublishRuntime(provider=\"k8s\")\n302:                 runtime.publish(workspace_with_metadata, replicas=3)\n303: \n304:                 call_kwargs = mock_provider.deploy_agent.call_args[1]\n305:                 assert call_kwargs[\"replicas\"] == 3\n306: \n307: \n308: class TestPublishRuntime_K8sWithNodePort:\n309:     def test_passes_node_port_to_provider(self, workspace_with_metadata: Path) -> None:\n310:         with patch.object(PublishRuntime, \"_prepare_image_for_publishing\", return_value=\"test:v1\"):\n311:             with patch(\"agentcube.runtime.publish_runtime.KubernetesProvider\") as mock_provider_cls:\n312:                 mock_provider = MagicMock()\n313:                 mock_provider.deploy_agent.return_value = {\n314:                     \"deployment_name\": \"test-agent\",\n315:                     \"service_name\": \"test-agent\",\n316:                     \"service_url\": \"http://localhost:30080\",\n317:                     \"node_port\": 30080,\n318:                 }\n319:                 mock_provider.wait_for_deployment_ready.return_value = None\n320:                 mock_provider_cls.return_value = mock_provider\n321: \n322:                 runtime = PublishRuntime(provider=\"k8s\")\n323:                 runtime.publish(workspace_with_metadata, node_port=30080)\n324: \n325:                 call_kwargs = mock_provider.deploy_agent.call_args[1]\n326:                 assert call_kwargs[\"node_port\"] == 30080\n327: \n328: \n329: class TestPublishRuntime_K8sWithNamespace:\n330:     def test_uses_specified_namespace_for_k8s(self, workspace_with_metadata: Path) -> None:\n331:         with patch.object(PublishRuntime, \"_prepare_image_for_publishing\", return_value=\"test:v1\"):\n332:             with patch(\"agentcube.runtime.publish_runtime.KubernetesProvider\") as mock_provider_cls:\n333:                 mock_provider = MagicMock()\n334:                 mock_provider.deploy_agent.return_value = {\n335:                     \"deployment_name\": \"test-agent\",\n336:                     \"service_name\": \"test-agent\",\n337:                     \"service_url\": \"http://localhost:30080\",\n338:                     \"node_port\": 30080,\n339:                 }\n340:                 mock_provider.wait_for_deployment_ready.return_value = None\n341:                 mock_provider_cls.return_value = mock_provider\n342: \n343:                 runtime = PublishRuntime(provider=\"k8s\")\n344:                 runtime.publish(workspace_with_metadata, namespace=\"staging\")\n345: \n346:                 mock_provider_cls.assert_called_once_with(namespace=\"staging\", verbose=False)\n\n(End of file - total 346 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for PublishRuntime main publish() orchestration.\"\"\"\n\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.runtime.publish_runtime import PublishRuntime\n\n\n@pytest.fixture\ndef runtime() -> PublishRuntime:\n    return PublishRuntime()\n\n\n@pytest.fixture\ndef workspace_with_metadata(tmp_path: Path) -> Path:\n    ws = tmp_path / \"my-agent\"\n 