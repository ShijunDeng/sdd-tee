 None\n42: \n43:     mock_client = MagicMock()\n44:     mock_client.__aenter__ = AsyncMock(return_value=mock_client)\n45:     mock_client.__aexit__ = AsyncMock(return_value=None)\n46:     mock_client.post.return_value = mock_response\n47: \n48:     mocker.patch(\"httpx.AsyncClient\", return_value=mock_client)\n49:     return mock_client\n50: \n51: \n52: class TestInvokeCommand_SuccessAgentCube:\n53:     def test_invoke_agentcube_provider(\n54:         self, published_workspace: Path, mock_httpx_for_invoke,\n55:     ) -> None:\n56:         result = runner.invoke(\n57:             app, [\"invoke\", \"-f\", str(published_workspace), \"--provider\", \"agentcube\"],\n58:         )\n59:         assert result.exit_code == 0\n60:         assert \"hello world\" in result.output\n61: \n62: \n63: class TestInvokeCommand_SuccessK8s:\n64:     def test_invoke_k8s_provider(\n65:         self, published_workspace: Path, mock_httpx_for_invoke,\n66:     ) -> None:\n67:         result = runner.invoke(\n68:             app, [\"invoke\", \"-f\", str(published_workspace), \"--provider\", \"k8s\"],\n69:         )\n70:         assert result.exit_code == 0\n71:         assert \"hello world\" in result.output\n72: \n73: \n74: class TestInvokeCommand_DefaultPayload:\n75:     def test_uses_empty_json_by_default(\n76:         self, published_workspace: Path, mock_httpx_for_invoke,\n77:     ) -> None:\n78:         result = runner.invoke(\n79:             app, [\"invoke\", \"-f\", str(published_workspace)],\n80:         )\n81:         assert result.exit_code == 0\n82: \n83: \n84: class TestInvokeCommand_CustomPayload:\n85:     def test_parses_custom_payload(\n86:         self, published_workspace: Path, mock_httpx_for_invoke,\n87:     ) -> None:\n88:         result = runner.invoke(\n89:             app, [\n90:                 \"invoke\", \"-f\", str(published_workspace),\n91:                 \"--payload\", '{\"key\": \"value\"}',\n92:             ],\n93:         )\n94:         assert result.exit_code == 0\n95: \n96: \n97: class TestInvokeCommand_InvalidPayload:\n98:     def test_rejects_invalid_json(self, published_workspace: Path) -> None:\n99:         result = runner.invoke(\n100:             app, [\n101:                 \"invoke\", \"-f\", str(published_workspace),\n102:                 \"--payload\", \"{bad}\",\n103:             ],\n104:         )\n105:         assert result.exit_code == 1\n106:         assert \"Invalid JSON payload\" in result.output\n107: \n108: \n109: class TestInvokeCommand_SingleHeader:\n110:     def test_parses_single_header(\n111:         self, published_workspace: Path, mock_httpx_for_invoke,\n112:     ) -> None:\n113:         result = runner.invoke(\n114:             app, [\n115:                 \"invoke\", \"-f\", str(published_workspace),\n116:                 \"--header\", \"Authorization: Bearer token\",\n117:             ],\n118:         )\n119:         assert result.exit_code == 0\n120: \n121: \n122: class TestInvokeCommand_MultipleHeaders:\n123:     def test_parses_multiple_headers(\n124:         self, published_workspace: Path, mock_httpx_for_invoke,\n125:     ) -> None:\n126:         result = runner.invoke(\n127:             app, [\n128:                 \"invoke\", \"-f\", str(published_workspace),\n129:                 \"--header\", \"Authorization: Bearer token\",\n130:                 \"--header\", \"X-Custom: value\",\n131:             ],\n132:         )\n133:         assert result.exit_code == 0\n134: \n135: \n136: class TestInvokeCommand_InvalidHeader:\n137:     def test_rejects_invalid_header_format(self, published_workspace: Path) -> None:\n138:         result = runner.invoke(\n139:             app, [\n140:                 \"invoke\", \"-f\", str(published_workspace),\n141:                 \"--header\", \"BadHeader\",\n142:             ],\n143:         )\n144:         assert result.exit_code == 1\n145:         assert \"Invalid header format\" in result.output\n146: \n147: \n148: class TestInvokeCommand_VerboseError:\n149:     def test_shows_traceback_with_verbose(\n150:         self, published_workspace: Path, mocker,\n151:     ) -> None:\n152:         mocker.patch(\n153:             \"agentcube.runtime.invoke_runtime.InvokeRuntime.invoke\",\n154:             side_effect=RuntimeError(\"Connection failed\"),\n155:         )\n156:         result = runner.invoke(\n157:             app, [\n158:                 \"invoke\", \"-f\", str(published_workspace),\n159:                 \"--verbose\",\n160:             ],\n161:         )\n162:         assert result.exit_code == 1\n163:         assert \"Error invoking agent\" in result.output\n164:         assert \"Traceback\" in result.output\n165: \n166: \n167: class TestInvokeCommand_QuietError:\n168:     def test_no_traceback_without_verbose(\n169:         self, published_workspace: Path, mocker,\n170:     ) -> None:\n171:         mocker.patch(\n172:             \"agentcube.runtime.invoke_runtime.InvokeRuntime.invoke\",\n173:             side_effect=RuntimeError(\"Connection failed\"),\n174:         )\n175:         result = runner.invoke(\n176:             app, [\"invoke\", \"-f\", str(published_workspace)],\n177:         )\n178:         assert result.exit_code == 1\n179:         assert \"Error invoking agent\" in result.output\n180:         assert \"Traceback\" not in result.output\n181: \n182: \n183: class TestInvokeCommand_HelpOutput:\n184:     def test_shows_help(self) -> None:\n185:         result = runner.invoke(app, [\"invoke\", \"--help\"])\n186:         assert result.exit_code == 0\n187:         assert \"--workspace\" in result.output or \"-f\" in result.output\n188:         assert \"--payload\" in result.output\n189:         assert \"--header\" in result.output\n190:         assert \"--provider\" in result.output\n191:         assert \"--verbose\" in result.output\n\n(End of file - total 191 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for the CLI invoke command.\"\"\"\n\nfrom __future__ import annotations\n\nfro