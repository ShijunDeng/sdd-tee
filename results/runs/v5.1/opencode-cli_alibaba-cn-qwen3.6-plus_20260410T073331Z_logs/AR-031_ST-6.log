 \\\n38:   \"python3 -c \\\"import yaml; yaml.safe_load(open('${CHART_DIR}/values.yaml'))\\\"\"\n39: assert \"All top-level keys present\" \\\n40:   \"python3 -c \\\"import yaml; d=yaml.safe_load(open('${CHART_DIR}/values.yaml')); assert all(k in d for k in ['imagePullSecrets','nameOverride','fullnameOverride','redis','router','workloadmanager','volcano'])\\\"\"\n41: assert \"redis.addr defaults to empty string\" \\\n42:   \"python3 -c \\\"import yaml; d=yaml.safe_load(open('${CHART_DIR}/values.yaml')); assert d['redis']['addr']==''\\\"\"\n43: assert \"redis.password defaults to empty string\" \\\n44:   \"python3 -c \\\"import yaml; d=yaml.safe_load(open('${CHART_DIR}/values.yaml')); assert d['redis']['password']==''\\\"\"\n45: assert \"router.replicas defaults to 1\" \\\n46:   \"python3 -c \\\"import yaml; d=yaml.safe_load(open('${CHART_DIR}/values.yaml')); assert d['router']['replicas']==1\\\"\"\n47: assert \"router.rbac.create defaults to false\" \\\n48:   \"python3 -c \\\"import yaml; d=yaml.safe_load(open('${CHART_DIR}/values.yaml')); assert d['router']['rbac']['create']==False\\\"\"\n49: assert \"volcano.scheduler.enabled defaults to false\" \\\n50:   \"python3 -c \\\"import yaml; d=yaml.safe_load(open('${CHART_DIR}/values.yaml')); assert d['volcano']['scheduler']['enabled']==False\\\"\"\n51: assert \"workloadmanager.replicas defaults to 1\" \\\n52:   \"python3 -c \\\"import yaml; d=yaml.safe_load(open('${CHART_DIR}/values.yaml')); assert d['workloadmanager']['replicas']==1\\\"\"\n53: echo \"\"\n54: \n55: # T-011: Helm lint and default rendering\n56: echo \"--- T-011: Helm lint and default rendering ---\"\n57: assert \"helm lint passes\" \\\n58:   \"helm lint ${CHART_DIR} > /dev/null 2>&1\"\n59: assert \"Default renders 2 Deployments\" \\\n60:   \"[ \\$(helm template test ${CHART_DIR} | grep -cE '^kind: Deployment\\$') -eq 2 ]\"\n61: assert \"Default renders 2 Services\" \\\n62:   \"[ \\$(helm template test ${CHART_DIR} | grep -cE '^kind: Service\\$') -eq 2 ]\"\n63: assert \"Default renders 1 ClusterRole\" \\\n64:   \"[ \\$(helm template test ${CHART_DIR} | grep -cE '^kind: ClusterRole\\$') -eq 1 ]\"\n65: assert \"Default renders 1 ServiceAccount\" \\\n66:   \"[ \\$(helm template test ${CHART_DIR} | grep -cE '^kind: ServiceAccount\\$') -eq 1 ]\"\n67: assert \"No Router RBAC by default\" \\\n68:   \"! helm template test ${CHART_DIR} | grep -qE '^kind: Role$'\"\n69: assert \"No Volcano resources by default\" \\\n70:   \"! helm template test ${CHART_DIR} | grep -q 'volcano-agent-scheduler'\"\n71: echo \"\"\n72: \n73: # T-005: Workload Manager template\n74: echo \"--- T-005: Workload Manager template ---\"\n75: WM_RENDER=$(helm template test ${CHART_DIR} --namespace agentcube -s templates/workloadmanager.yaml)\n76: assert \"WM Deployment name is workloadmanager\" \\\n77:   \"echo '$WM_RENDER' | grep -q 'name: workloadmanager'\"\n78: assert \"WM namespace is agentcube\" \\\n79:   \"echo '$WM_RENDER' | grep -q 'namespace: agentcube'\"\n80: assert \"WM replicas is 1\" \\\n81:   \"echo '$WM_RENDER' | grep -q 'replicas: 1'\"\n82: assert \"WM image is correct\" \\\n83:   \"echo '$WM_RENDER' | grep -q 'ghcr.io/volcano-sh/workloadmanager:latest'\"\n84: assert \"WM imagePullPolicy is IfNotPresent\" \\\n85:   \"echo '$WM_RENDER' | grep -q 'imagePullPolicy: IfNotPresent'\"\n86: assert \"WM has liveness probe /health\" \\\n87:   \"echo '$WM_RENDER' | grep -A2 'livenessProbe' | grep -q '/health'\"\n88: assert \"WM liveness initialDelaySeconds is 10\" \\\n89:   \"echo '$WM_RENDER' | grep -A4 'livenessProbe' | grep -q 'initialDelaySeconds: 10'\"\n90: assert \"WM readiness initialDelaySeconds is 5\" \\\n91:   \"echo '$WM_RENDER' | grep -A4 'readinessProbe' | grep -q 'initialDelaySeconds: 5'\"\n92: assert \"WM has AGENTCUBE_NAMESPACE fieldRef\" \\\n93:   \"echo '$WM_RENDER' | grep -A3 'AGENTCUBE_NAMESPACE' | grep -q 'metadata.namespace'\"\n94: assert \"WM serviceAccountName is workloadmanager\" \\\n95:   \"echo '$WM_RENDER' | grep -q 'serviceAccountName: workloadmanager'\"\n96: assert \"WM Service has selector app: workloadmanager\" \\\n97:   \"echo '$WM_RENDER' | grep -A1 'selector' | grep -q 'app: workloadmanager'\"\n98: echo \"\"\n99: \n100: # T-006: Router template\n101: echo \"--- T-006: Router template ---\"\n102: ROUTER_RENDER=$(helm template test ${CHART_DIR} --namespace agentcube -s templates/agentcube-router.yaml)\n103: assert \"Router Deployment name is agentcube-router\" \\\n104:   \"echo '$ROUTER_RENDER' | grep -q 'name: agentcube-router'\"\n105: assert \"Router replicas is 1\" \\\n106:   \"echo '$ROUTER_RENDER' | grep -q 'replicas: 1'\"\n107: assert \"Router image is correct\" \\\n108:   \"echo '$ROUTER_RENDER' | grep -q 'ghcr.io/volcano-sh/agentcube-router:latest'\"\n109: assert \"Router WORKLOAD_MANAGER_URL is set\" \\\n110:   \"echo '$ROUTER_RENDER' | grep -q 'WORKLOAD_MANAGER_URL'\"\n111: assert \"Router WORKLOAD_MANAGER_URL contains correct namespace\" \\\n112:   \"echo '$ROUTER_RENDER' | grep -A1 'WORKLOAD_MANAGER_URL' | grep -q 'workloadmanager.agentcube.svc.cluster.local:8080'\"\n113: assert \"Router has liveness /health/live\" \\\n114:   \"echo '$ROUTER_RENDER' | grep -A2 'livenessProbe' | grep -q '/health/live'\"\n115: assert \"Router liveness initialDelaySeconds is 1\" \\\n116:   \"echo '$ROUTER_RENDER' | grep -A4 'livenessProbe' | grep -q 'initialDelaySeconds: 1'\"\n117: assert \"Router readiness /health/ready\" \\\n118:   \"echo '$ROUTER_RENDER' | grep -A2 'readinessProbe' | grep -q '/health/ready'\"\n119: assert \"Router args include --debug\" \\\n120:   \"echo '$ROUTER_RENDER' | grep -q '\\-\\-debug'\"\n121: assert \"Router no serviceAccountName by default\" \\\n122:   \"! echo '$ROUTER_RENDER' | grep -q 'serviceAccountName:'\"\n123: assert \"Router Service selector app: agentcube-router\" \\\n124:   \"echo '$ROUTER_RENDER' | grep -A1 'selector' | grep -q 'app: agentcube-router'\"\n125: echo \"\"\n126: \n127: # T-007: WM RBAC\n128: echo \"--- T-007: WM RBAC ---\"\n129: RBAC_RENDER=$(helm template test ${CHART_DIR} --namespace agentcube -s templates/rbac/workloadmanager.yaml)\n130: assert \"WM RBAC has ServiceAccount\" \\\n131:   \"echo '$RBAC_RENDER' | grep -qE '^kind: ServiceAccount$'\"\n132: assert \"WM RBAC has ClusterRole\" \\\n133:   \"echo '$RBAC_RENDER' | grep -qE '^kind: ClusterRole$'\"\n134: assert \"WM RBAC has ClusterRoleBinding\" \\\n135:   \"echo '$RBAC_RENDER' | grep -qE '^kind: ClusterRoleBinding$'\"\n136: assert \"WM ClusterRole has agents.x-k8s.io/sandboxes\" \\\n137:   \"echo '$RBAC_RENDER' | grep -A3 'agents.x-k8s.io' | grep -q 'sandboxes'\"\n138: assert \"WM ClusterRole has runtime.agentcube.volcano.sh/codeinterpreters\" \\\n139:   \"echo '$RBAC_RENDER' | grep -A3 'runtime.agentcube.volcano.sh' | grep -q 'codeinterpreters'\"\n140: assert \"WM ClusterRole has secrets\" \\\n141:   \"echo '$RBAC_RENDER' | grep -q 'secrets'\"\n142: assert \"WM ClusterRole has tokenreviews\" \\\n143:   \"echo '$RBAC_RENDER' | grep -q 'tokenreviews'\"\n144: echo \"\"\n145: \n146: # T-008: Router RBAC conditional\n147: echo \"--- T-008: Router RBAC conditional ---\"\n148: assert \"Router RBAC off by default\" \\\n149:   \"! helm template test ${CHART_DIR} | grep -q 'kind: Role$'\"\n150: ROUTER_RBAC=$(helm template test ${CHART_DIR} --set router.rbac.create=true)\n151: assert \"Router RBAC enabled creates Role\" \\\n152:   \"echo '$ROUTER_RBAC' | grep -qE '^kind: Role$'\"\n153: assert \"Router RBAC enabled creates RoleBinding\" \\\n154:   \"echo '$ROUTER_RBAC' | grep -qE '^kind: RoleBinding$'\"\n155: assert \"Router RBAC enabled creates ServiceAccount\" \\\n156:   \"echo '$ROUTER_RBAC' | grep -q 'name: agentcube-router'\"\n157: ROUTER_RBAC_CUSTOM=$(helm template test ${CHART_DIR} --set router.rbac.create=true --set router.serviceAccountName=my-router-sa)\n158: assert \"Router RBAC custom SA name\" \\\n159:   \"echo '$ROUTER_RBAC_CUSTOM' | grep -q 'name: my-router-sa'\"\n160: echo \"\"\n161: \n162: # T-009: Volcano conditional\n163: echo \"--- T-009: Volcano conditional ---\"\n164: assert \"Volcano disabled by default\" \\\n165:   \"! helm template test ${CHART_DIR} | grep -q 'volcano-agent-scheduler'\"\n166: VOLCANO_RENDER=$(helm template test ${CHART_DIR} --set volcano.scheduler.enabled=true)\n167: assert \"Volcano enabled creates ServiceAccount\" \\\n168:   \"echo '$VOLCANO_RENDER' | grep -q 'name: volcano-agent-scheduler'\"\n169: assert \"Volcano enabled creates ConfigMap\" \\\n170:   \"echo '$VOLCANO_RENDER' | grep -qE '^kind: ConfigMap$'\"\n171: assert \"Volcano enabled creates ClusterRole\" \\\n172:   \"echo '$VOLCANO_RENDER' | grep -q 'name: volcano-agent-scheduler'\"\n173: assert \"Volcano enabled creates Service\" \\\n174:   \"echo '$VOLCANO_RENDER' | grep -q 'volcano-agent-scheduler-service'\"\n175: assert \"Volcano enabled creates Deployment\" \\\n176:   \"echo '$VOLCANO_RENDER' | grep -q 'name: volcano-agent-scheduler'\"\n177: assert \"Volcano ConfigMap has agent-scheduler.conf\" \\\n178:   \"echo '$VOLCANO_RENDER' | grep -q 'agent-scheduler.conf'\"\n179: assert \"Volcano ConfigMap has allocate action\" \\\n180:   \"echo '$VOLCANO_RENDER' | grep -q 'actions: \\\"allocate\\\"'\"\n181: assert \"Volcano Deployment has --scheduler-name=agent-scheduler\" \\\n182:   \"echo '$VOLCANO_RENDER' | grep -q '\\-\\-scheduler-name=agent-scheduler'\"\n183: assert \"Volcano Service has prometheus annotations\" \\\n184:   \"echo '$VOLCANO_RENDER' | grep -q 'prometheus.io/scrape'\"\n185: echo \"\"\n186: \n187: # T-012: Scenario tests\n188: echo \"--- T-012: Scenario tests ---\"\n189: assert \"Custom WM replicas\" \\\n190:   \"helm template test ${CHART_DIR} --set workloadmanager.replicas=3 | grep -q 'replicas: 3'\"\n191: assert \"Custom WM image\" \\\n192:   \"helm template test ${CHART_DIR} --set workloadmanager.image.repository=myregistry/wm --set workloadmanager.image.tag=v1.2.3 | grep -q 'myregistry/wm:v1.2.3'\"\n193: assert \"WM extraEnv injection\" \\\n194:   \"helm template test ${CHART_DIR} --set-json 'workloadmanager.extraEnv=[{\\\"name\\\":\\\"CUSTOM\\\",\\\"value\\\":\\\"val\\\"}]' | grep -q 'CUSTOM'\"\n195: assert \"imagePullSecrets applied\" \\\n196:   \"helm template test ${CHART_DIR} --set-json 'imagePullSecrets=[{\\\"name\\\":\\\"my-secret\\\"}]' | grep -q 'my-secret'\"\n197: assert \"Namespace scoping\" \\\n198:   \"helm template test ${CHART_DIR} --namespace production | grep -q 'namespace: production'\"\n199: assert \"Router serviceAccountName set\" \\\n200:   \"helm template test ${CHART_DIR} --set router.serviceAccountName=agentcube-router | grep -q 'serviceAccountName: agentcube-router'\"\n201: assert \"Router extraEnv injection\" \\\n202:   \"helm template test ${CHART_DIR} --set-json 'router.extraEnv=[{\\\"name\\\":\\\"LOG_LEVEL\\\",\\\"value\\\":\\\"debug\\\"}]' | grep -q 'LOG_LEVEL'\"\n203: assert \"WM Service type override\" \\\n204:   \"helm template test ${CHART_DIR} --set workloadmanager.service.type=NodePort | grep -q 'type: NodePort'\"\n205: echo \"\"\n206: \n207: # T-013: CRD verification\n208: echo \"--- T-013: CRD verification ---\"\n209: CRD_RENDER=$(helm template test ${CHART_DIR} --include-crds)\n210: assert \"AgentRuntime CRD present\" \\\n211:   \"echo '$CRD_RENDER' | grep -q 'agentruntimes.runtime.agentcube.volcano.sh'\"\n212: assert \"CodeInterpreter CRD present\" \\\n213:   \"echo '$CRD_RENDER' | grep -q 'codeinterpreters.runtime.agentcube.volcano.sh'\"\n214: assert \"CRD count is 2\" \\\n215:   \"[ \\$(echo '$CRD_RENDER' | grep -cE '^kind: CustomResourceDefinition$') -eq 2 ]\"\n216: assert \"AgentRuntime CRD group is correct\" \\\n217:   \"python3 -c \\\"\n218: import yaml\n219: docs = list(yaml.safe_load_all(open('${CHART_DIR}/crds/runtime.agentcube.volcano.sh_agentruntimes.yaml')))\n220: crd = docs[0]\n221: assert crd['spec']['group'] == 'runtime.agentcube.volcano.sh'\n222: assert crd['spec']['scope'] == 'Namespaced'\n223: assert crd['spec']['versions'][0]['name'] == 'v1alpha1'\n224: \\\"\"\n225: assert \"CodeInterpreter CRD group is correct\" \\\n226:   \"python3 -c \\\"\n227: import yaml\n228: docs = list(yaml.safe_load_all(open('${CHART_DIR}/crds/runtime.agentcube.volcano.sh_codeinterpreters.yaml')))\n229: crd = docs[0]\n230: assert crd['spec']['group'] == 'runtime.agentcube.volcano.sh'\n231: assert crd['spec']['scope'] == 'Namespaced'\n232: assert crd['spec']['versions'][0]['name'] == 'v1alpha1'\n233: \\\"\"\n234: assert \"AgentRuntime required fields\" \\\n235:   \"python3 -c \\\"\n236: import yaml\n237: docs = list(yaml.safe_load_all(open('${CHART_DIR}/crds/runtime.agentcube.volcano.sh_agentruntimes.yaml')))\n238: crd = docs[0]\n239: required = crd['spec']['versions'][0]['schema']['openAPIV3Schema']['properties']['spec']['required']\n240: assert 'maxSessionDuration' in required\n241: assert 'podTemplate' in required\n242: assert 'sessionTimeout' in required\n243: assert 'targetPort' in required\n244: \\\"\"\n245: assert \"CodeInterpreter required fields\" \\\n246:   \"python3 -c \\\"\n247: import yaml\n248: docs = list(yaml.safe_load_all(open('${CHART_DIR}/crds/runtime.agentcube.volcano.sh_codeinterpreters.yaml')))\n249: crd = docs[0]\n250: required = crd['spec']['versions'][0]['schema']['openAPIV3Schema']['properties']['spec']['required']\n251: assert 'template' in required\n252: auth_mode = crd['spec']['versions'][0]['schema']['openAPIV3Schema']['properties']['spec']['properties']['authMode']\n253: assert auth_mode['default'] == 'picod'\n254: \\\"\"\n255: echo \"\"\n256: \n257: # T-015: Naming override\n258: echo \"--- T-015: Naming override ---\"\n259: assert \"fullnameOverride works\" \\\n260:   \"helm template test ${CHART_DIR} --set fullnameOverride=agentcube-prod | grep -q 'agentcube-prod'\"\n261: echo \"\"\n262: \n263: # Summary\n264: echo \"=== Test Summary ===\"\n265: echo \"PASSED: $PASS\"\n266: echo \"FAILED: $FAIL\"\n267: echo \"TOTAL:  $((PASS + FAIL))\"\n268: \n269: if [ \"$FAIL\" -gt 0 ]; then\n270:   exit 1\n271: fi\n\n(End of file - total 271 lines)\n</content