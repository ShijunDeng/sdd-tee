{"type":"tool_use","timestamp":1775830993820,"sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","part":{"id":"prt_d77c68802001m645Pw4zpTc5LJ","messageID":"msg_d77c673b4001kN91xnl8AbuiNx","sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","type":"tool","tool":"read","callID":"call_f52676bdb16649d182e185d8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/pem\"\n9: \t\"os\"\n10: \t\"time\"\n11: \n12: \t\"github.com/golang-jwt/jwt/v5\"\n13: \t\"k8s.io/apimachinery/pkg/api/errors\"\n14: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n15: \t\"k8s.io/client-go/kubernetes\"\n16: \t\"k8s.io/client-go/rest\"\n17: \t\"k8s.io/klog/v2\"\n18: )\n19: \n20: const (\n21: \trsaKeySize         = 2048\n22: \tjwtExpiration      = 5 * time.Minute\n23: \tIdentitySecretName = \"picod-router-identity\"\n24: \tPrivateKeyDataKey  = \"private.pem\"\n25: \tPublicKeyDataKey   = \"public.pem\"\n26: )\n27: \n28: var IdentityNamespace = \"default\"\n29: \n30: func init() {\n31: \tif ns := os.Getenv(\"AGENTCUBE_NAMESPACE\"); ns != \"\" {\n32: \t\tIdentityNamespace = ns\n33: \t}\n34: }\n35: \n36: type JWTManager struct {\n37: \tprivateKey *rsa.PrivateKey\n38: \tpublicKey  *rsa.PublicKey\n39: \tclientset  kubernetes.Interface\n40: }\n41: \n42: func NewJWTManager() (*JWTManager, error) {\n43: \tprivateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n44: \tif err != nil {\n45: \t\treturn nil, err\n46: \t}\n47: \treturn &JWTManager{\n48: \t\tprivateKey: privateKey,\n49: \t\tpublicKey:  &privateKey.PublicKey,\n50: \t}, nil\n51: }\n52: \n53: func (m *JWTManager) GenerateToken(claims map[string]interface{}) (string, error) {\n54: \tnow := time.Now()\n55: \ttokenClaims := jwt.MapClaims{\n56: \t\t\"exp\": now.Add(jwtExpiration).Unix(),\n57: \t\t\"iat\": now.Unix(),\n58: \t\t\"iss\": \"agentcube-router\",\n59: \t}\n60: \tfor k, v := range claims {\n61: \t\ttokenClaims[k] = v\n62: \t}\n63: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n64: \treturn token.SignedString(m.privateKey)\n65: }\n66: \n67: func (m *JWTManager) TryStoreOrLoadJWTKeySecret(ctx context.Context) error {\n68: \tif m.clientset == nil {\n69: \t\tconfig, err := rest.InClusterConfig()\n70: \t\tif err != nil {\n71: \t\t\tklog.Warningf(\"not running in-cluster, using ephemeral keys: %v\", err)\n72: \t\t\treturn nil\n73: \t\t}\n74: \t\tm.clientset, err = kubernetes.NewForConfig(config)\n75: \t\tif err != nil {\n76: \t\t\tklog.Warningf(\"failed to create in-cluster clientset, using ephemeral keys: %v\", err)\n77: \t\t\treturn nil\n78: \t\t}\n79: \t}\n80: \n81: \tsecret := &metav1.Secret{\n82: \t\tObjectMeta: metav1.ObjectMeta{\n83: \t\t\tName:      IdentitySecretName,\n84: \t\t\tNamespace: IdentityNamespace,\n85: \t\t\tLabels: map[string]string{\n86: \t\t\t\t\"app\":       \"agentcube\",\n87: \t\t\t\t\"component\": \"router\",\n88: \t\t\t},\n89: \t\t},\n90: \t\tType: \"Opaque\",\n91: \t\tData: map[string][]byte{\n92: \t\t\tPrivateKeyDataKey: pem.EncodeToMemory(&pem.Block{\n93: \t\t\t\tType:  \"RSA PRIVATE KEY\",\n94: \t\t\t\tBytes: x509.MarshalPKCS1PrivateKey(m.privateKey),\n95: \t\t\t}),\n96: \t\t\tPublicKeyDataKey: pem.EncodeToMemory(&pem.Block{\n97: \t\t\t\tType:  \"PUBLIC KEY\",\n98: \t\t\t\tBytes: x509.MarshalPKCS1PublicKey(m.publicKey),\n99: \t\t\t}),\n100: \t\t},\n101: \t}\n102: \n103: \t_, err := m.clientset.CoreV1().Secrets(IdentityNamespace).Create(ctx, secret, metav1.CreateOptions{})\n104: \tif err != nil {\n105: \t\tif errors.IsAlreadyExists(err) {\n106: \t\t\texisting, getErr := m.clientset.CoreV1().Secrets(IdentityNamespace).Get(ctx, IdentitySecretName, metav1.GetOptions{})\n107: \t\t\tif getErr != nil {\n108: \t\t\t\treturn getErr\n109: \t\t\t}\n110: \t\t\treturn m.loadPrivateKeyPEM(existing.Data[PrivateKeyDataKey])\n111: \t\t}\n112: \t\treturn err\n113: \t}\n114: \treturn nil\n115: }\n116: \n117: func (m *JWTManager) loadPrivateKeyPEM(data []byte) error {\n118: \tblock, _ := pem.Decode(data)\n119: \tif block == nil {\n120: \t\treturn nil\n121: \t}\n122: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n123: \tif err != nil {\n124: \t\treturn err\n125: \t}\n126: \tm.privateKey = privateKey\n127: \tm.publicKey = &privateKey.PublicKey\n128: \treturn nil\n129: }\n\n(End of file - total 129 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go","time":{"start":1775830993812,"end":1775830993819}}}}
{"type":"tool_use","timestamp":1775830994846,"sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","part":{"id":"prt_d77c68c0f001oB1hl6FH4MwqBt","messageID":"msg_d77c673b4001kN91xnl8AbuiNx","sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","type":"tool","tool":"read","callID":"call_6d0a54aa8ce54511aec2b16c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"net/http\"\n6: \t\"os\"\n7: \t\"os/signal\"\n8: \t\"syscall\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n13: \t\"golang.org/x/net/http2\"\n14: \t\"golang.org/x/net/http2/h2c\"\n15: \t\"k8s.io/klog/v2\"\n16: )\n17: \n18: type Server struct {\n19: \tconfig         *Config\n20: \tengine         *gin.Engine\n21: \thttpServer     *http.Server\n22: \tsessionManager SessionManager\n23: \tstoreClient    store.Store\n24: \thttpTransport  *http.Transport\n25: \tjwtManager     *JWTManager\n26: }\n27: \n28: func NewServer(config *Config) (*Server, error) {\n29: \tif config.MaxConcurrentRequests <= 0 {\n30: \t\tconfig.MaxConcurrentRequests = 1000\n31: \t}\n32: \n33: \thttpTransport := &http.Transport{\n34: \t\tIdleConnTimeout:    0,\n35: \t\tDisableCompression: false,\n36: \t}\n37: \n38: \tif config.Debug {\n39: \t\tgin.SetMode(gin.DebugMode)\n40: \t} else {\n41: \t\tgin.SetMode(gin.ReleaseMode)\n42: \t}\n43: \n44: \tengine := gin.New()\n45: \n46: \tjwtManager, err := NewJWTManager()\n47: \tif err != nil {\n48: \t\treturn nil, err\n49: \t}\n50: \tif err := jwtManager.TryStoreOrLoadJWTKeySecret(context.Background()); err != nil {\n51: \t\treturn nil, err\n52: \t}\n53: \n54: \tstoreClient := store.Storage()\n55: \n56: \tsessionManager, err := NewSessionManager(storeClient)\n57: \tif err != nil {\n58: \t\treturn nil, err\n59: \t}\n60: \n61: \ts := &Server{\n62: \t\tconfig:         config,\n63: \t\tengine:         engine,\n64: \t\thttpTransport:  httpTransport,\n65: \t\tjwtManager:     jwtManager,\n66: \t\tstoreClient:    storeClient,\n67: \t\tsessionManager: sessionManager,\n68: \t}\n69: \n70: \ts.registerRoutes()\n71: \n72: \ts.httpServer = &http.Server{\n73: \t\tAddr:        \":\" + config.Port,\n74: \t\tHandler:     s.engine,\n75: \t\tReadTimeout: 30 * time.Second,\n76: \t\tIdleTimeout: 90 * time.Second,\n77: \t}\n78: \n79: \treturn s, nil\n80: }\n81: \n82: func (s *Server) registerRoutes() {\n83: \ts.engine.GET(\"/health/live\", handleHealthLive)\n84: \ts.engine.GET(\"/health/ready\", s.handleHealthReady)\n85: \n86: \tv1 := s.engine.Group(\"/v1\")\n87: \tv1.Use(gin.Logger())\n88: \tv1.Use(gin.Recovery())\n89: \tv1.Use(ConcurrencyLimitMiddleware(s.config.MaxConcurrentRequests))\n90: \n91: \tv1.GET(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n92: \tv1.POST(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n93: \tv1.GET(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n94: \tv1.POST(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n95: }\n96: \n97: func (s *Server) Start() error {\n98: \tif s.config.EnableTLS {\n99: \t\tif s.config.TLSCert == \"\" || s.config.TLSKey == \"\" {\n100: \t\t\treturn nil\n101: \t\t}\n102: \t\tklog.Infof(\"Starting HTTPS server on %s\", s.httpServer.Addr)\n103: \t\treturn s.httpServer.ListenAndServeTLS(s.config.TLSCert, s.config.TLSKey)\n104: \t}\n105: \n106: \th2cHandler := h2c.NewHandler(s.engine, &http2.Server{})\n107: \ts.httpServer.Handler = h2cHandler\n108: \n109: \tklog.Infof(\"Starting HTTP server on %s\", s.httpServer.Addr)\n110: \treturn s.httpServer.ListenAndServe()\n111: }\n112: \n113: func (s *Server) Run() {\n114: \tstopCh := make(chan os.Signal, 1)\n115: \tsignal.Notify(stopCh, syscall.SIGINT, syscall.SIGTERM)\n116: \n117: \tgo func() {\n118: \t\tif err := s.Start(); err != nil && err != http.ErrServerClosed {\n119: \t\t\tklog.Fatalf(\"server failed: %v\", err)\n120: \t\t}\n121: \t}()\n122: \n123: \t<-stopCh\n124: \tklog.Info(\"shutting down server...\")\n125: \n126: \tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n127: \tdefer cancel()\n128: \n129: \tif err := s.Shutdown(ctx); err != nil {\n130: \t\tklog.Errorf(\"server shutdown failed: %v\", err)\n131: \t}\n132: }\n133: \n134: func (s *Server) Shutdown(ctx context.Context) error {\n135: \tif s.httpServer == nil {\n136: \t\treturn nil\n137: \t}\n138: \treturn s.httpServer.Shutdown(ctx)\n139: }\n\n(End of file - total 139 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"golang.org/x/net/http2\"\n\t\"golang.org/x/net/http2/h2c\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/server.go","time":{"start":1775830994839,"end":1775830994845}}}}
{"type":"tool_use","timestamp":1775830996023,"sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","part":{"id":"prt_d77c69010001LPmWRVliwiF2tB","messageID":"msg_d77c673b4001kN91xnl8AbuiNx","sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","type":"tool","tool":"read","callID":"call_a64cd8768a6044a49aa10596","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/config.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/config.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import \"time\"\n4: \n5: const LastActivityAnnotationKey = \"agentcube.volcano.sh/last-activity\"\n6: \n7: type Config struct {\n8: \tPort                  string\n9: \tDebug                 bool\n10: \tEnableTLS             bool\n11: \tTLSCert               string\n12: \tTLSKey                string\n13: \tMaxConcurrentRequests int\n14: \n15: \tSessionCheckInterval time.Duration\n16: \tSessionIdleTimeout   time.Duration\n17: \tSessionMaxDuration   time.Duration\n18: \tStoreType            string\n19: }\n20: \n21: func NewDefaultConfig() *Config {\n22: \treturn &Config{\n23: \t\tPort:                  \"8080\",\n24: \t\tDebug:                 false,\n25: \t\tEnableTLS:             false,\n26: \t\tMaxConcurrentRequests: 1000,\n27: \t\tSessionCheckInterval:  5 * time.Minute,\n28: \t\tSessionIdleTimeout:    30 * time.Minute,\n29: \t\tSessionMaxDuration:    24 * time.Hour,\n30: \t\tStoreType:             \"\",\n31: \t}\n32: }\n\n(End of file - total 32 lines)\n</content>","metadata":{"preview":"package router\n\nimport \"time\"\n\nconst LastActivityAnnotationKey = \"agentcube.volcano.sh/last-activity\"\n\ntype Config struct {\n\tPort                  string\n\tDebug                 bool\n\tEnableTLS             bool\n\tTLSCert               string\n\tTLSKey                string\n\tMaxConcurrentRequests int\n\n\tSessionCheckInterval time.Duration\n\tSessionIdleTimeout   time.Duration\n\tSessionMaxDuration   time.Duration\n\tStoreType            string\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/config.go","time":{"start":1775830996016,"end":1775830996022}}}}
{"type":"tool_use","timestamp":1775830997247,"sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","part":{"id":"prt_d77c694c1001gEbt8x4KIRpzZQ","messageID":"msg_d77c673b4001kN91xnl8AbuiNx","sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","type":"tool","tool":"read","callID":"call_90966aec5db04631b952d5c3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/middleware.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/middleware.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"log/slog\"\n6: \t\"time\"\n7: \n8: \t\"github.com/gin-gonic/gin\"\n9: \t\"github.com/google/uuid\"\n10: )\n11: \n12: func ConcurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n13: \tsem := make(chan struct{}, maxConcurrent)\n14: \treturn func(c *gin.Context) {\n15: \t\tselect {\n16: \t\tcase sem <- struct{}{}:\n17: \t\t\tdefer func() { <-sem }()\n18: \t\t\tc.Next()\n19: \t\tdefault:\n20: \t\t\tc.JSON(429, gin.H{\n21: \t\t\t\t\"error\": \"server overloaded, please try again later\",\n22: \t\t\t\t\"code\":  \"SERVER_OVERLOADED\",\n23: \t\t\t})\n24: \t\t\tc.Abort()\n25: \t\t}\n26: \t}\n27: }\n28: \n29: func RequestLoggerMiddleware() gin.HandlerFunc {\n30: \treturn func(c *gin.Context) {\n31: \t\tstart := time.Now()\n32: \t\tc.Next()\n33: \t\tduration := time.Since(start).Milliseconds()\n34: \t\tslog.Info(\"request\",\n35: \t\t\t\"method\", c.Request.Method,\n36: \t\t\t\"path\", c.Request.URL.Path,\n37: \t\t\t\"status\", c.Writer.Status(),\n38: \t\t\t\"duration_ms\", duration,\n39: \t\t\t\"trace_id\", c.GetHeader(\"X-Trace-Id\"),\n40: \t\t)\n41: \t}\n42: }\n43: \n44: func TraceIDMiddleware() gin.HandlerFunc {\n45: \treturn func(c *gin.Context) {\n46: \t\ttraceID := uuid.New().String()\n47: \t\tc.Request.Header.Set(\"X-Trace-Id\", traceID)\n48: \t\tc.Writer.Header().Set(\"X-Trace-Id\", traceID)\n49: \t\tc.Next()\n50: \t}\n51: }\n52: \n53: func FormatDuration(ms int64) string {\n54: \treturn fmt.Sprintf(\"%dms\", ms)\n55: }\n\n(End of file - total 55 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"log/slog\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n)\n\nfunc ConcurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n\tsem := make(chan struct{}, maxConcurrent)\n\treturn func(c *gin.Context) {\n\t\tselect {\n\t\tcase sem <- struct{}{}:\n\t\t\tdefer func() { <-sem }()\n\t\t\tc.Next()\n\t\tdefault:\n\t\t\tc.JSON(429, gin.H{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/middleware.go","time":{"start":1775830997241,"end":1775830997246}}}}
{"type":"tool_use","timestamp":1775830998461,"sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","part":{"id":"prt_d77c69989001FnEgImNceepPCG","messageID":"msg_d77c673b4001kN91xnl8AbuiNx","sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","type":"tool","tool":"read","callID":"call_a941a978381c4bb39e4a3829","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/design.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/design.md</path>\n<type>file</type>\n<content>\n1: # AR-009: Router HTTP 反向代理核心 — 设计说明\n2: \n3: ## 1. 架构\n4: \n5: ### 1.1 定位\n6: \n7: `pkg/router` 是 AgentCube 系统的流量入口，负责将外部 HTTP 请求反向代理到 AgentRuntime 和 CodeInterpreter 的 sandbox pod。核心职责：\n8: \n9: 1. **Session 解析与 Sandbox 创建**：通过 session ID 从 store 查找 sandbox，或在 session ID 为空时通过 WorkloadManager 创建新 sandbox\n10: 2. **HTTP 反向代理**：将请求代理到 sandbox 的 entry point，注入 RS256 JWT 签名\n11: 3. **动态服务发现**：通过 client-go Informer 监听 AgentRuntime/CodeInterpreter CRD 变更\n12: 4. **流量治理**：负载均衡、健康检查、并发限制\n13: \n14: ### 1.2 包结构\n15: \n16: ```\n17: pkg/router/\n18: ├── config.go              # Config 结构体与默认值\n19: ├── server.go              # Server 结构体、构造函数、启动/关闭\n20: ├── session_manager.go     # SessionManager 接口与实现\n21: ├── jwt.go                 # JWTManager、密钥管理、token 生成\n22: ├── proxy.go               # ReverseProxy 封装、Director、ErrorHandler\n23: ├── backend.go             # Backend 管理、健康检查\n24: ├── loadbalancer.go        # Round-Robin、Least-Connections 负载均衡\n25: ├── middleware.go          # 并发限制、日志、Trace ID 中间件\n26: ├── informer.go            # CRD Informer 集成、事件处理\n27: ├── router.go              # Router 接口、路由表管理\n28: ├── errors.go              # 自定义错误类型\n29: └── *_test.go              # 单元测试\n30: \n31: cmd/router/\n32: └── main.go                # CLI 入口、标志解析\n33: ```\n34: \n35: ### 1.3 依赖关系\n36: \n37: ```\n38: pkg/router\n39: ├── github.com/gin-gonic/gin              # HTTP 路由引擎\n40: ├── github.com/golang-jwt/jwt/v5          # RS256 JWT 签名\n41: ├── golang.org/x/net/http2                # HTTP/2 支持\n42: ├── k8s.io/api                            # K8s API 类型\n43: ├── k8s.io/apimachinery                   # errors, schema, runtime\n44: ├── k8s.io/client-go                      # rest, kubernetes.Interface\n45: ├── k8s.io/klog/v2                        # 结构化日志\n46: ├── github.com/volcano-sh/agentcube/client-go        # 生成的 typed client\n47: ├── github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1  # CRD 类型\n48: ├── github.com/volcano-sh/agentcube/pkg/common/types           # 共享类型（Kind, SandboxInfo）\n49: ├── github.com/volcano-sh/agentcube/pkg/store                  # Session store 接口\n50: └── net/http/httputil                     # Go 标准库反向代理\n51: ```\n52: \n53: ---\n54: \n55: ## 2. 数据结构\n56: \n57: ### 2.1 Config\n58: \n59: ```go\n60: type Config struct {\n61:     Port                  string // 监听端口，默认 \"8080\"\n62:     Debug                 bool   // Gin debug 模式\n63:     EnableTLS             bool   // 是否启用 TLS\n64:     TLSCert               string // TLS 证书路径\n65:     TLSKey                string // TLS 私钥路径\n66:     MaxConcurrentRequests int    // 最大并发请求数，默认 1000\n67: }\n68: ```\n69: \n70: ### 2.2 Server\n71: \n72: ```go\n73: type Server struct {\n74:     config         *Config\n75:     engine         *gin.Engine\n76:     httpServer     *http.Server\n77:     sessionManager SessionManager\n78:     storeClient    store.Store\n79:     httpTransport  *http.Transport\n80:     jwtManager     *JWTManager\n81: }\n82: ```\n83: \n84: - `httpTransport`: `IdleConnTimeout: 0`（不回收空闲连接），`DisableCompression: false`\n85: - `httpServer`: `ReadTimeout: 30s`, `IdleTimeout: 90s`, 支持 h2c 明文升级\n86: \n87: ### 2.3 SessionManager\n88: \n89: ```go\n90: type SessionManager interface {\n91:     GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)\n92: }\n93: \n94: type manager struct {\n95:     storeClient     store.Store\n96:     workloadMgrAddr string\n97:     httpClient      *http.Client\n98: }\n99: ```\n100: \n101: - `httpClient.Timeout`: 2 分钟\n102: - Transport: `MaxIdleConnsPerHost: 100`, `DisableCompression: false`, HTTP/2 `ReadIdleTimeout: 30s`, `PingTimeout: 15s`\n103: \n104: ### 2.4 JWTManager\n105: \n106: ```go\n107: const (\n108:     rsaKeySize         = 2048\n109:     jwtExpiration      = 5 * time.Minute\n110:     IdentitySecretName = \"picod-router-identity\"\n111:     PrivateKeyDataKey  = \"private.pem\"\n112:     PublicKeyDataKey   = \"public.pem\"\n113: )\n114: \n115: var IdentityNamespace = \"default\" // init(): AGENTCUBE_NAMESPACE 覆盖\n116: \n117: type JWTManager struct {\n118:     privateKey *rsa.PrivateKey\n119:     publicKey  *rsa.PublicKey\n120:     clientset  kubernetes.Interface\n121: }\n122: ```\n123: \n124: - `NewJWTManager()`: 生成 RSA 2048-bit 密钥对\n125: - `GenerateToken(claims)`: RS256 签名，基础 claims `exp`, `iat`, `iss=\"agentcube-router\"`\n126: - `TryStoreOrLoadJWTKeySecret(ctx)`: 创建或加载 K8s Secret 中的密钥对\n127: \n128: ### 2.5 Router 与 Backend\n129: \n130: ```go\n131: type Router interface {\n132:     AddRoute(pattern string, backend Backend) error\n133:     RemoveRoute(pattern string) error\n134:     ServeHTTP(w http.ResponseWriter, r *http.Request)\n135: }\n136: \n137: type Backend struct {\n138:     URL      *url.URL\n139:     Weight   int\n140:     Healthy  bool\n141: }\n142: \n143: type routerImpl struct {\n144:     mu       sync.RWMutex\n145:     routes   map[string]Backend\n146:     lb       LoadBalancer\n147: }\n148: ```\n149: \n150: ### 2.6 LoadBalancer\n151: \n152: ```go\n153: type LoadBalancer interface {\n154:     Select(backends []Backend) (*Backend, error)\n155: }\n156: \n157: type RoundRobinBalancer struct {\n158:     mu      sync.Mutex\n159:     current int\n160: }\n161: \n162: type LeastConnectionsBalancer struct {\n163:     connections map[string]*atomic.Int64\n164: }\n165: ```\n166: \n167: ### 2.7 BackendHealthChecker\n168: \n169: ```go\n170: type BackendHealthChecker struct {\n171:     interval          time.Duration // 默认 30s\n172:     consecutiveFail   int           // 标记不健康阈值，默认 3\n173:     consecutiveSuccess int          // 标记健康阈值，默认 2\n174:     checker           func(*url.URL) (bool, error)\n175: }\n176: ```\n177: \n178: ### 2.8 自定义错误类型\n179: \n180: ```go\n181: type SessionNotFoundError struct {\n182:     SessionID string\n183: }\n184: \n185: type SandboxTemplateNotFoundError struct {\n186:     Namespace string\n187:     Name      string\n188:     Kind      string\n189: }\n190: \n191: func (e *SessionNotFoundError) Error() string\n192: func (e *SandboxTemplateNotFoundError) Error() string\n193: ```\n194: \n195: ---\n196: \n197: ## 3. API 契约\n198: \n199: ### 3.1 路由注册\n200: \n201: | Method | Path | Middleware | Handler |\n202: |--------|------|------------|---------|\n203: | GET | `/health/live` | none | `handleHealthLive` |\n204: | GET | `/health/ready` | none | `handleHealthReady` |\n205: | GET, POST | `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` | `gin.Logger`, `gin.Recovery`, `concurrencyLimitMiddleware` | `handleAgentInvoke` |\n206: | GET, POST | `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path` | 同上 | `handleCodeInterpreterInvoke` |\n207: \n208: ### 3.2 Health 端点响应\n209: \n210: **Liveness:**\n211: ```json\n212: GET /health/live → 200 {\"status\":\"alive\"}\n213: ```\n214: \n215: **Readiness:**\n216: ```json\n217: GET /health/ready → 200 {\"status\":\"ready\"}\n218: GET /health/ready → 503 {\"status\":\"not ready\",\"error\":\"session manager not available\"}\n219: ```\n220: \n221: ### 3.3 反向代理行为\n222: \n223: **Upstream URL 确定：**\n224: 1. 从 `SandboxInfo.EntryPoints` 查找第一个 `path` 前缀匹配 invocation path 的 entry point\n225: 2. 无匹配时使用第一个 entry point\n226: 3. EntryPoints 为空时返回 404 `{\"error\":\"no entry point found for sandbox\"}`\n227: \n228: **Director 设置：**\n229: - `req.URL.Path`: 规范化路径（Gin `*path` 无前导 `/` 时自动添加）\n230: - `req.URL.RawPath`: 清空\n231: - `req.Host`: `targetURL.Host`\n232: - `X-Forwarded-Host`: 原始请求 `Host`\n233: - `X-Forwarded-Proto`: `\"https\"`（TLS 存在）或 `\"http\"`\n234: - `X-Forwarded-For`: 追加客户端 IP\n235: - `Authorization`: `Bearer <JWT>`（仅 `Sandbox`/`SandboxClaim` kind）\n236: \n237: **ModifyResponse:**\n238: - 设置响应 header `x-agentcube-session-id` 为 resolved session ID\n239: \n240: ### 3.4 JWT 注入\n241: \n242: 对 `Sandbox` 和 `SandboxClaim` kind 的 sandbox：\n243: - 代理前生成 JWT token\n244: - 设置 `Authorization: Bearer <token>` 到代理请求\n245: - JWT 签名失败时返回 500 `{\"code\":\"JWT_SIGNING_FAILED\",\"error\":\"failed to sign request\"}`\n246: \n247: ### 3.5 代理错误映射\n248: \n249: | 错误信息 | HTTP 状态码 | 响应体 |\n250: |----------|-------------|--------|\n251: | 包含 `\"connection refused\"` | 502 | `{\"error\":\"sandbox unreachable\"}` |\n252: | 包含 `\"timeout\"` | 504 | `{\"error\":\"sandbox timeout\"}` |\n253: | 其他错误 | 502 | `{\"error\":\"sandbox unreachable\"}` |\n254: \n255: ### 3.6 并发限制中间件\n256: \n257: - 基于 buffered channel 的信号量，容量 `MaxConcurrentRequests`\n258: - 槽位耗尽时返回 429 `{\"error\":\"server overloaded, please try again later\",\"code\":\"SERVER_OVERLOADED\"}`\n259: - 仅应用于 `/v1` 路由组，health 端点不受限制\n260: \n261: ### 3.7 Last-activity 更新\n262: \n263: - sandbox 解析成功后调用 `UpdateSessionLastActivity(ctx, sessionID, time.Now())`\n264: - `forwardToSandbox` 返回后再次调用\n265: - 失败仅记录 warning 日志，不阻断代理流程\n266: \n267: ---\n268: \n269: ## 4. 错误处理\n270: \n271: ### 4.1 错误分类\n272: \n273: | 错误类型 | 来源 | 处理方式 |\n274: |----------|------|----------|\n275: | `SessionNotFoundError` | Store 中不存在 session | 404 JSON |\n276: | `SandboxTemplateNotFoundError` | WorkloadManager 返回非 200 | 404 JSON |\n277: | JWT 签名失败 | `GenerateToken` 返回错误 | 500 JSON `JWT_SIGNING_FAILED` |\n278: | 连接拒绝 | 反向代理 ErrorHandler | 502 `sandbox unreachable` |\n279: | 超时 | 反向代理 ErrorHandler | 504 `sandbox timeout` |\n280: | 并发超限 | `concurrencyLimitMiddleware` | 429 `SERVER_OVERLOADED` |\n281: | K8s API 错误 | `apierrors.APIStatus` | 使用 status code，500 时替换消息为 `internal server error` |\n282: \n283: ### 4.2 错误辅助函数\n284: \n285: ```go\n286: func handleGetSandboxError(c *gin.Context, err error) {\n287:     if statusErr, ok := err.(apierrors.APIStatus); ok {\n288:         code := statusErr.Status().Code\n289:         if code == 0 {\n290:             code = http.StatusInternalServerError\n291:         }\n292:         message := statusErr.Status().Message\n293:         if message == \"\" {\n294:             message = err.Error()\n295:         }\n296:         if code == http.StatusInternalServerError {\n297:             message = \"internal server error\"\n298:         }\n299:         c.JSON(int(code), gin.H{\"error\": message})\n300:         return\n301:     }\n302:     c.JSON(http.StatusInternalServerError, gin.H{\"error\": \"internal server error\"})\n303: }\n304: ```\n305: \n306: ### 4.3 日志策略\n307: \n308: - 使用 `slog` 或 `klog`，禁止 `log.Printf`\n309: - 结构化日志字段：`method`, `path`, `status`, `duration_ms`, `trace_id`\n310: - 警告级别：store 更新失败、service account token 读取失败（非 NotExist）、非 in-cluster JWT 密钥初始化\n311: \n312: ---\n313: \n314: ## 5. 测试策略\n315: \n316: ### 5.1 单元测试覆盖\n317: \n318: | 文件 | 测试内容 |\n319: |------|----------|\n320: | `config_test.go` | 默认值、CLI 标志解析、`MaxConcurrentRequests <= 0` 时 NewServer 设为 1000 |\n321: | `server_test.go` | Debug/Release 模式、JWT 初始化失败、`WORKLOAD_MANAGER_URL` 未设置、TLS 配置验证 |\n322: | `session_manager_test.go` | session 查找、session 创建、Store NotFound、WorkloadManager 非 200、token 附加 |\n323: | `jwt_test.go` | token 生成、claims 验证、RS256 算法、Secret 创建/加载、ephemeral keys 路径 |\n324: | `proxy_test.go` | Director 设置、ModifyResponse、upstream URL 确定、协议拼接、path 规范化 |\n325: | `backend_test.go` | 健康检查成功/失败、连续失败阈值、单次失败不立即标记 |\n326: | `loadbalancer_test.go` | Round-Robin 循环、跳过不健康、Least-Connections 选择、全不健康错误 |\n327: | `middleware_test.go` | 并发限制通过/拒绝、槽位释放、health 端点不受限、Trace ID 注入 |\n328: | `router_test.go` | 路由添加/删除/重复/幂等、并发安全、ServeHTTP 匹配/404 |\n329: | `informer_test.go` | CRD 事件处理、路由表更新、Lister 缓存查询 |\n330: \n331: ### 5.2 并发测试\n332: \n333: ```bash\n334: go test -race ./pkg/router/...\n335: ```\n336: \n337: 覆盖场景：\n338: - 并发 `AddRoute`/`RemoveRoute`\n339: - 并发负载均衡选择\n340: - 并发健康检查状态更新\n341: - 并发中间件槽位获取/释放\n342: \n343: ### 5.3 门禁要求\n344: \n345: 1. `go build ./pkg/router/...` 编译通过\n346: 2. `go build ./cmd/router/...` 编译通过\n347: 3. `go test ./pkg/router/... -v` 全部通过\n348: 4. `go test -race ./pkg/router/...` 无 data race 告警\n349: 5. 无 `log.Printf` 残留（`grep -rn 'log\\.Printf' pkg/router/` 无匹配）\n350: \n351: ### 5.4 Mock 策略\n352: \n353: - `store.Store`: 使用接口 mock 实现 NotFound/成功场景\n354: - `kubernetes.Interface`: 使用 `client-go` fake clientset\n355: - WorkloadManager HTTP: 使用 `httptest.NewServer`\n356: - Informer: 使用 fake clientset + 手动触发事件\n357: \n358: ---\n359: \n360: ## 6. 实现步骤\n361: \n362: ### Phase 1: 基础结构（Day 1-2）\n363: \n364: 1. 创建 `pkg/router/config.go` — Config 结构体与默认值\n365: 2. 创建 `pkg/router/errors.go` — 自定义错误类型\n366: 3. 创建 `pkg/router/jwt.go` — JWTManager、密钥管理\n367: 4. 创建 `pkg/router/session_manager.go` — SessionManager 接口与实现\n368: 5. 编写对应单元测试\n369: \n370: ### Phase 2: 反向代理核心（Day 3-4）\n371: \n372: 1. 创建 `pkg/router/proxy.go` — ReverseProxy 封装、Director、ErrorHandler\n373: 2. 创建 `pkg/router/backend.go` — Backend 管理、健康检查\n374: 3. 创建 `pkg/router/loadbalancer.go` — Round-Robin、Least-Connections\n375: 4. 创建 `pkg/router/middleware.go` — 并发限制、日志、Trace ID\n376: 5. 编写对应单元测试\n377: \n378: ### Phase 3: 路由与服务器（Day 5-6）\n379: \n380: 1. 创建 `pkg/router/router.go` — Router 接口、路由表管理\n381: 2. 创建 `pkg/router/informer.go` — CRD Informer 集成、事件处理\n382: 3. 创建 `pkg/router/server.go` — Server 结构体、构造函数、路由注册、Start/Stop\n383: 4. 创建 `cmd/router/main.go` — CLI 入口、标志解析\n384: 5. 编写集成测试\n385: \n386: ### Phase 4: 集成与门禁（Day 7）\n387: \n388: 1. 运行 `go build ./pkg/router/... ./cmd/router/...`\n389: 2. 运行 `go test ./pkg/router/... -v`\n390: 3. 运行 `go test -race ./pkg/router/...`\n391: 4. 检查 `log.Printf` 残留\n392: 5. 修复所有问题，确保门禁通过\n393: \n394: ---\n395: \n396: ## 7. 后续变更\n397: \n398: | 变更 | 描述 | 优先级 |\n399: |------|------|--------|\n400: | AR-010 | 高级流量治理（灰度发布、A/B 测试） | P1 |\n401: | AR-011 | WebSocket/gRPC 代理支持 | P2 |\n402: | AR-012 | 基于 Prometheus 的动态负载均衡 | P2 |\n403: | AR-013 | 分布式追踪集成（OpenTelemetry） | P3 |\n404: | AR-014 | TLS 证书自动轮转 | P3 |\n405: \n406: ### 已知限制\n407: \n408: - 当前不支持 per-backend 超时配置（使用全局 `http.Transport`）\n409: - 健康检查路径固定为 `/health`，后续可配置化\n410: - 负载均衡策略仅支持 Round-Robin 和 Least-Connections，后续可扩展 Weighted Round-Robin\n411: - JWT 密钥固定 RS256，后续可支持 ES256 等其他算法\n\n(End of file - total 411 lines)\n</content>","metadata":{"preview":"# AR-009: Router HTTP 反向代理核心 — 设计说明\n\n## 1. 架构\n\n### 1.1 定位\n\n`pkg/router` 是 AgentCube 系统的流量入口，负责将外部 HTTP 请求反向代理到 AgentRuntime 和 CodeInterpreter 的 sandbox pod。核心职责：\n\n1. **Session 解析与 Sandbox 创建**：通过 session ID 从 store 查找 sandbox，或在 session ID 为空时通过 WorkloadManager 创建新 sandbox\n2. **HTTP 反向代理**：将请求代理到 sandbox 的 entry point，注入 RS256 JWT 签名\n3. **动态服务发现**：通过 client-go Informer 监听 AgentRuntime/CodeInterpreter CRD 变更\n4. **流量治理**：负载均衡、健康检查、并发限制\n\n### 1.2 包结构\n\n```\npkg/router/\n├── config.go              # Config 结构体与默认值\n├── server.go              # Server 结构体、构造函数、启动/关闭\n├── session_manager.go     # SessionManager 接口与实现","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/design.md","time":{"start":1775830998453,"end":1775830998459}}}}
{"type":"step_finish","timestamp":1775830998474,"sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","part":{"id":"prt_d77c69dbc001uKhiFol2LDfvUN","reason":"tool-calls","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","messageID":"msg_d77c673b4001kN91xnl8AbuiNx","sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","type":"step-finish","tokens":{"total":23304,"input":22771,"output":344,"reasoning":189,"cache":{"write":0,"read":0}},"cost":0.007164779}}
{"type":"step_start","timestamp":1775831001560,"sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","part":{"id":"prt_d77c6a9d5001MTSiNiIKmbOncH","messageID":"msg_d77c69de5001Uir8HkL3PR01gf","sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","type":"step-start"}}
{"type":"tool_use","timestamp":1775831117371,"sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","part":{"id":"prt_d77c6bc42001MsuKA87dEffq92","messageID":"msg_d77c69de5001Uir8HkL3PR01gf","sessionID":"ses_2883bc6c3ffeGLRvqmCBoCzzsE","type":"tool","tool":"write","callID":"call_944e38293d3042e9b7b4c34b","state":{"status":"completed","input":{"content":"# AR-011: Router JWT 认证与签发 — 设计说明\n\n## 1. 架构\n\n### 1.1 定位\n\nAR-011 在现有 JWT 签发能力（router → sandbox）基础上，新增 **客户端 → Router 的 JWT 认证**能力，形成完整的双向认证链路。核心职责：\n\n1. **入站 JWT 验证**：验证客户端请求携带的 JWT token，提取用户身份与权限信息\n2. **出站 JWT 签发**：保留现有 router → sandbox 的 JWT 签发能力，注入 session 上下文\n3. **密钥统一管理**：RS256 密钥对的生成、持久化（K8s Secret）、加载与轮转\n4. **认证中间件**：可配置的 JWT 验证中间件，支持 per-route 启用/跳过\n\n### 1.2 认证流程\n\n```\nClient Request (Authorization: Bearer <client-JWT>)\n  -> JWT Auth Middleware (验证 client-JWT, 提取 user_id, roles)\n  -> Router (port 8080)\n     -> Extracts x-agentcube-session-id header\n     -> Looks up sandbox in Redis/Valkey store\n     -> If no session: calls WorkloadManager to create sandbox\n     -> Forwards request to sandbox pod via reverse proxy\n        -> Generates JWT (RS256, 5min expiry, session_id + user_id claims)\n        -> Sets Authorization: Bearer <router-JWT> on proxied request\n     -> Sandbox (PicoD) verifies router-JWT using public key from env var\n```\n\n### 1.3 包结构\n\n```\npkg/router/\n├── jwt.go                 # JWTManager（现有：密钥管理 + 签发；新增：验证）\n├── middleware.go           # 现有中间件 + 新增 JWTAuthMiddleware\n├── config.go               # 新增 JWT 相关配置项\n├── server.go               # 路由注册更新（JWT 中间件挂载）\n└── *_test.go               # 单元测试\n```\n\n### 1.4 依赖关系\n\n```\npkg/router (JWT 相关)\n├── github.com/golang-jwt/jwt/v5          # RS256 签名与验证\n├── k8s.io/api                            # Secret 类型\n├── k8s.io/apimachinery                   # errors, metav1\n├── k8s.io/client-go                      # kubernetes.Interface, rest\n└── k8s.io/klog/v2                        # 结构化日志\n```\n\n---\n\n## 2. 数据结构\n\n### 2.1 JWTConfig\n\n```go\ntype JWTConfig struct {\n    // 入站认证（客户端 → Router）\n    EnableAuth       bool          // 是否启用客户端 JWT 认证，默认 false\n    AllowedIssuers   []string      // 允许的签发者列表，默认 [\"agentcube-gateway\"]\n    AllowedAudiences []string      // 允许的受众列表，默认 [\"agentcube-router\"]\n    Leeway           time.Duration // 时间容差（处理时钟偏移），默认 30s\n\n    // 出站签发（Router → Sandbox）\n    TokenExpiration  time.Duration // token 有效期，默认 5min\n    Issuer           string        // 签发者标识，默认 \"agentcube-router\"\n}\n```\n\n### 2.2 Config 扩展\n\n```go\ntype Config struct {\n    // ... 现有字段 ...\n    JWT JWTConfig // JWT 认证与签发配置\n}\n```\n\n### 2.3 JWTManager 扩展\n\n```go\ntype JWTManager struct {\n    privateKey *rsa.PrivateKey\n    publicKey  *rsa.PublicKey\n    clientset  kubernetes.Interface\n    config     *JWTConfig\n}\n```\n\n新增方法：\n\n```go\n// ValidateToken 验证客户端 JWT，返回解析后的 claims\nfunc (m *JWTManager) ValidateToken(tokenString string) (jwt.MapClaims, error)\n\n// GetPublicKeyPEM 返回公钥 PEM 编码（用于分发到 sandbox）\nfunc (m *JWTManager) GetPublicKeyPEM() ([]byte, error)\n```\n\n### 2.4 JWT Claims 定义\n\n**入站 Claims（客户端 → Router）：**\n\n| Claim | 类型 | 必填 | 描述 |\n|-------|------|------|------|\n| `sub` | string | 是 | 用户标识 |\n| `iss` | string | 是 | 签发者（需在 AllowedIssuers 中） |\n| `aud` | string | 是 | 受众（需在 AllowedAudiences 中） |\n| `exp` | int64  | 是 | 过期时间 |\n| `iat` | int64  | 是 | 签发时间 |\n| `roles` | []string | 否 | 用户角色列表 |\n| `tenant_id` | string | 否 | 租户标识 |\n\n**出站 Claims（Router → Sandbox）：**\n\n| Claim | 类型 | 必填 | 描述 |\n|-------|------|------|------|\n| `session_id` | string | 是 | 会话标识 |\n| `user_id` | string | 否 | 透传客户端 sub（如已认证） |\n| `iss` | string | 是 | 固定 \"agentcube-router\" |\n| `exp` | int64  | 是 | 过期时间 |\n| `iat` | int64  | 是 | 签发时间 |\n\n### 2.5 认证上下文\n\n```go\ntype AuthContext struct {\n    UserID   string\n    TenantID string\n    Roles    []string\n    RawToken string\n}\n\n// 存储在 gin.Context 中的 key\nconst AuthContextKey = \"_agentcube_auth_context\"\n```\n\n---\n\n## 3. API 契约\n\n### 3.1 路由与中间件挂载\n\n| Method | Path | Middleware | 说明 |\n|--------|------|------------|------|\n| GET | `/health/live` | none | 健康检查，跳过认证 |\n| GET | `/health/ready` | none | 健康检查，跳过认证 |\n| GET, POST | `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` | `JWTAuthMiddleware`（条件启用）, `Logger`, `Recovery`, `ConcurrencyLimit` | Agent 调用 |\n| GET, POST | `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path` | `JWTAuthMiddleware`（条件启用）, `Logger`, `Recovery`, `ConcurrencyLimit` | CodeInterpreter 调用 |\n\n### 3.2 JWTAuthMiddleware 行为\n\n**启用条件：** `JWTConfig.EnableAuth == true`\n\n**处理流程：**\n\n1. 从 `Authorization` header 提取 token（格式：`Bearer <token>`）\n2. 缺失 token → 401 `{\"code\":\"UNAUTHORIZED\",\"error\":\"missing authorization token\"}`\n3. 调用 `JWTManager.ValidateToken(token)` 验证\n4. 验证失败 → 401 `{\"code\":\"INVALID_TOKEN\",\"error\":\"<具体错误>\"}`\n5. 验证成功 → 解析 claims，构建 `AuthContext` 存入 `gin.Context`\n6. 调用 `c.Next()` 继续处理\n\n**中间件顺序：**\n\n```\nJWTAuthMiddleware → Logger → Recovery → ConcurrencyLimit → Handler\n```\n\n### 3.3 出站 JWT 签发增强\n\n**现有行为保留：** 代理到 sandbox 前生成 JWT，设置 `Authorization: Bearer <token>`\n\n**增强内容：**\n\n- 如果入站请求已认证（`AuthContext` 存在），将 `user_id` 透传到出站 JWT claims\n- 出站 JWT claims 结构：\n\n```go\nclaims := map[string]interface{}{\n    \"session_id\": sessionID,\n}\nif authCtx, exists := c.Get(AuthContextKey); exists {\n    claims[\"user_id\"] = authCtx.(*AuthContext).UserID\n}\ntoken, err := jwtManager.GenerateToken(claims)\n```\n\n### 3.4 错误响应\n\n| 场景 | HTTP 状态码 | 响应体 |\n|------|-------------|--------|\n| 缺失 Authorization header | 401 | `{\"code\":\"UNAUTHORIZED\",\"error\":\"missing authorization token\"}` |\n| Token 格式错误（非 Bearer） | 401 | `{\"code\":\"INVALID_TOKEN_FORMAT\",\"error\":\"invalid authorization header format\"}` |\n| Token 签名验证失败 | 401 | `{\"code\":\"INVALID_TOKEN\",\"error\":\"token signature verification failed\"}` |\n| Token 过期 | 401 | `{\"code\":\"TOKEN_EXPIRED\",\"error\":\"token has expired\"}` |\n| Issuer 不匹配 | 401 | `{\"code\":\"INVALID_ISSUER\",\"error\":\"token issuer not allowed\"}` |\n| Audience 不匹配 | 401 | `{\"code\":\"INVALID_AUDIENCE\",\"error\":\"token audience mismatch\"}` |\n| JWT 签发失败（出站） | 500 | `{\"code\":\"JWT_SIGNING_FAILED\",\"error\":\"failed to sign request\"}` |\n\n---\n\n## 4. 核心实现\n\n### 4.1 JWTManager.ValidateToken\n\n```go\nfunc (m *JWTManager) ValidateToken(tokenString string) (jwt.MapClaims, error) {\n    token, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n        if _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n            return nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n        }\n        return m.publicKey, nil\n    },\n        jwt.WithExpirationRequired(),\n        jwt.WithIssuer(m.config.AllowedIssuers...),\n        jwt.WithAudience(m.config.AllowedAudiences...),\n        jwt.WithLeeway(m.config.Leeway),\n    )\n    if err != nil {\n        return nil, err\n    }\n\n    claims, ok := token.Claims.(jwt.MapClaims)\n    if !ok || !token.Valid {\n        return nil, fmt.Errorf(\"invalid token claims\")\n    }\n\n    return claims, nil\n}\n```\n\n### 4.2 JWTAuthMiddleware\n\n```go\nfunc JWTAuthMiddleware(jwtManager *JWTManager) gin.HandlerFunc {\n    return func(c *gin.Context) {\n        authHeader := c.GetHeader(\"Authorization\")\n        if authHeader == \"\" {\n            c.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{\n                \"code\":  \"UNAUTHORIZED\",\n                \"error\": \"missing authorization token\",\n            })\n            return\n        }\n\n        const bearerPrefix = \"Bearer \"\n        if !strings.HasPrefix(authHeader, bearerPrefix) {\n            c.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{\n                \"code\":  \"INVALID_TOKEN_FORMAT\",\n                \"error\": \"invalid authorization header format\",\n            })\n            return\n        }\n\n        tokenString := strings.TrimPrefix(authHeader, bearerPrefix)\n        claims, err := jwtManager.ValidateToken(tokenString)\n        if err != nil {\n            c.AbortWithStatusJSON(http.StatusUnauthorized, gin.H{\n                \"code\":  \"INVALID_TOKEN\",\n                \"error\": err.Error(),\n            })\n            return\n        }\n\n        authCtx := &AuthContext{\n            RawToken: tokenString,\n        }\n        if sub, ok := claims[\"sub\"].(string); ok {\n            authCtx.UserID = sub\n        }\n        if tenantID, ok := claims[\"tenant_id\"].(string); ok {\n            authCtx.TenantID = tenantID\n        }\n        if roles, ok := claims[\"roles\"].([]interface{}); ok {\n            for _, r := range roles {\n                if role, ok := r.(string); ok {\n                    authCtx.Roles = append(authCtx.Roles, role)\n                }\n            }\n        }\n\n        c.Set(AuthContextKey, authCtx)\n        c.Next()\n    }\n}\n```\n\n### 4.3 JWTManager 构造函数更新\n\n```go\nfunc NewJWTManager(config *JWTConfig) (*JWTManager, error) {\n    if config == nil {\n        config = DefaultJWTConfig()\n    }\n\n    privateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n    if err != nil {\n        return nil, err\n    }\n\n    return &JWTManager{\n        privateKey: privateKey,\n        publicKey:  &privateKey.PublicKey,\n        config:     config,\n    }, nil\n}\n\nfunc DefaultJWTConfig() *JWTConfig {\n    return &JWTConfig{\n        EnableAuth:       false,\n        AllowedIssuers:   []string{\"agentcube-gateway\"},\n        AllowedAudiences: []string{\"agentcube-router\"},\n        Leeway:           30 * time.Second,\n        TokenExpiration:  5 * time.Minute,\n        Issuer:           \"agentcube-router\",\n    }\n}\n```\n\n### 4.4 GenerateToken 更新（使用配置）\n\n```go\nfunc (m *JWTManager) GenerateToken(claims map[string]interface{}) (string, error) {\n    now := time.Now()\n    tokenClaims := jwt.MapClaims{\n        \"exp\": now.Add(m.config.TokenExpiration).Unix(),\n        \"iat\": now.Unix(),\n        \"iss\": m.config.Issuer,\n    }\n    for k, v := range claims {\n        tokenClaims[k] = v\n    }\n    token := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n    return token.SignedString(m.privateKey)\n}\n```\n\n### 4.5 Server 路由注册更新\n\n```go\nfunc (s *Server) registerRoutes() {\n    s.engine.GET(\"/health/live\", handleHealthLive)\n    s.engine.GET(\"/health/ready\", s.handleHealthReady)\n\n    v1 := s.engine.Group(\"/v1\")\n\n    // 条件启用 JWT 认证中间件\n    if s.config.JWT.EnableAuth {\n        v1.Use(JWTAuthMiddleware(s.jwtManager))\n    }\n\n    v1.Use(gin.Logger())\n    v1.Use(gin.Recovery())\n    v1.Use(ConcurrencyLimitMiddleware(s.config.MaxConcurrentRequests))\n\n    v1.GET(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n    v1.POST(\"/namespaces/:namespace/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n    v1.GET(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n    v1.POST(\"/namespaces/:namespace/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n}\n```\n\n### 4.6 proxy.go 出站 JWT 注入增强\n\n```go\n// 在 forwardToSandbox 或 proxy director 中\nfunc (s *Server) buildProxyClaims(c *gin.Context, sessionID string) map[string]interface{} {\n    claims := map[string]interface{}{\n        \"session_id\": sessionID,\n    }\n\n    // 透传用户身份\n    if authCtx, exists := c.Get(AuthContextKey); exists {\n        if ctx, ok := authCtx.(*AuthContext); ok && ctx.UserID != \"\" {\n            claims[\"user_id\"] = ctx.UserID\n        }\n    }\n\n    return claims\n}\n```\n\n### 4.7 密钥轮转支持\n\n**现状：** 启动时生成密钥对，尝试存储到 K8s Secret，若已存在则加载\n\n**增强：** 支持定时检查 Secret 变更（可选）\n\n```go\nfunc (m *JWTManager) StartKeyRotation(ctx context.Context, interval time.Duration) {\n    ticker := time.NewTicker(interval)\n    go func() {\n        for {\n            select {\n            case <-ctx.Done():\n                return\n            case <-ticker.C:\n                if err := m.ReloadKeyFromSecret(ctx); err != nil {\n                    klog.Warningf(\"key rotation failed: %v\", err)\n                }\n            }\n        }\n    }()\n}\n\nfunc (m *JWTManager) ReloadKeyFromSecret(ctx context.Context) error {\n    if m.clientset == nil {\n        return nil\n    }\n    secret, err := m.clientset.CoreV1().Secrets(IdentityNamespace).Get(\n        ctx, IdentitySecretName, metav1.GetOptions{})\n    if err != nil {\n        return err\n    }\n    return m.loadPrivateKeyPEM(secret.Data[PrivateKeyDataKey])\n}\n```\n\n---\n\n## 5. 错误处理\n\n### 5.1 错误分类\n\n| 错误类型 | 来源 | 处理方式 |\n|----------|------|----------|\n| 缺失 token | 客户端请求无 Authorization | 401 UNAUTHORIZED |\n| 格式错误 | Authorization 非 Bearer 格式 | 401 INVALID_TOKEN_FORMAT |\n| 签名验证失败 | 公钥不匹配或 token 被篡改 | 401 INVALID_TOKEN |\n| Token 过期 | exp < now（含 leeway） | 401 TOKEN_EXPIRED |\n| Issuer 不匹配 | iss 不在 AllowedIssuers 中 | 401 INVALID_ISSUER |\n| Audience 不匹配 | aud 不在 AllowedAudiences 中 | 401 INVALID_AUDIENCE |\n| 密钥加载失败 | K8s Secret 读取失败 | 启动失败（fatal）或降级为临时密钥（warning） |\n| 出站签发失败 | RSA 签名异常 | 500 JWT_SIGNING_FAILED |\n\n### 5.2 错误辅助函数\n\n```go\nfunc mapJWTError(err error) (code string, message string) {\n    switch {\n    case errors.Is(err, jwt.ErrTokenExpired):\n        return \"TOKEN_EXPIRED\", \"token has expired\"\n    case errors.Is(err, jwt.ErrTokenInvalidIssuer):\n        return \"INVALID_ISSUER\", \"token issuer not allowed\"\n    case errors.Is(err, jwt.ErrTokenInvalidAudience):\n        return \"INVALID_AUDIENCE\", \"token audience mismatch\"\n    case errors.Is(err, jwt.ErrTokenSignatureInvalid):\n        return \"INVALID_TOKEN\", \"token signature verification failed\"\n    case errors.Is(err, jwt.ErrTokenMalformed):\n        return \"INVALID_TOKEN\", \"malformed token\"\n    default:\n        return \"INVALID_TOKEN\", err.Error()\n    }\n}\n```\n\n### 5.3 日志策略\n\n- **认证成功：** DEBUG 级别，记录 `user_id`, `roles`（不记录 token）\n- **认证失败：** WARNING 级别，记录失败原因和客户端 IP\n- **密钥操作：** INFO 级别，记录密钥加载/轮转事件\n- **禁止：** 日志中不得出现 token 原文或私钥内容\n\n---\n\n## 6. 测试策略\n\n### 6.1 单元测试覆盖\n\n| 文件 | 测试内容 |\n|------|----------|\n| `jwt_test.go` | token 生成、claims 验证、RS256 算法、Secret 创建/加载、ephemeral keys 路径、token 验证（有效/过期/错误签名/错误 issuer/错误 audience）、leeway 容差 |\n| `middleware_test.go` | JWT 认证中间件：通过/拒绝场景、token 缺失、格式错误、claims 解析、AuthContext 注入 gin.Context |\n| `config_test.go` | JWTConfig 默认值、CLI 标志解析、EnableAuth 开关行为 |\n| `server_test.go` | 路由注册：EnableAuth=true 时挂载中间件、EnableAuth=false 时跳过、health 端点不受认证影响 |\n| `proxy_test.go` | 出站 JWT 注入：含 AuthContext 时透传 user_id、无 AuthContext 时仅 session_id |\n\n### 6.2 测试用例详情\n\n**JWTManager.ValidateToken：**\n\n| 用例 | 输入 | 期望 |\n|------|------|------|\n| 有效 token | 正确签名、未过期、issuer/audience 匹配 | 返回 claims，无错误 |\n| 过期 token | exp < now | 返回 jwt.ErrTokenExpired |\n| 未来 token | iat > now + leeway | 返回 jwt.ErrTokenUsedBeforeIssued |\n| 错误签名 | 用其他密钥签名的 token | 返回 jwt.ErrTokenSignatureInvalid |\n| 错误 issuer | iss=\"unknown-issuer\" | 返回 jwt.ErrTokenInvalidIssuer |\n| 错误 audience | aud=\"other-service\" | 返回 jwt.ErrTokenInvalidAudience |\n| 畸形 token | \"not-a-jwt\" | 返回 jwt.ErrTokenMalformed |\n| Leeway 容差 | exp = now - 15s, leeway=30s | 验证通过 |\n\n**JWTAuthMiddleware：**\n\n| 用例 | 输入 | 期望 |\n|------|------|------|\n| 无 Authorization | 空 header | 401 UNAUTHORIZED |\n| 非 Bearer 格式 | \"Basic xyz\" | 401 INVALID_TOKEN_FORMAT |\n| 有效 token | 正确 Bearer token | 200，AuthContext 注入 |\n| 无效 token | 过期/签名错误 | 401 INVALID_TOKEN + 具体错误码 |\n| claims 解析 | token 含 sub/roles/tenant_id | AuthContext 正确填充 |\n\n### 6.3 并发测试\n\n```bash\ngo test -race ./pkg/router/...\n```\n\n覆盖场景：\n- 并发 token 验证（公钥只读安全）\n- 并发 token 签发（私钥只读安全）\n- 密钥轮转期间的验证/签发（读写锁保护）\n\n### 6.4 门禁要求\n\n1. `go build ./pkg/router/...` 编译通过\n2. `go build ./cmd/router/...` 编译通过\n3. `go test ./pkg/router/... -v` 全部通过\n4. `go test -race ./pkg/router/...` 无 data race 告警\n5. 无 `log.Printf` 残留\n6. 无敏感信息泄露（token/密钥不出现在日志中）\n\n### 6.5 Mock 策略\n\n- `kubernetes.Interface`: 使用 `client-go` fake clientset 模拟 Secret 操作\n- JWT token: 使用测试密钥生成有效/无效 token\n- gin.Context: 使用 `gin.CreateTestContext()` 构建测试上下文\n\n---\n\n## 7. 环境变量与配置\n\n### 7.1 环境变量\n\n| 变量 | 描述 | 默认值 |\n|------|------|--------|\n| `AGENTCUBE_NAMESPACE` | K8s namespace（用于 Identity Secret） | `default` |\n| `ENABLE_JWT_AUTH` | 是否启用客户端 JWT 认证 | `false` |\n| `JWT_ALLOWED_ISSUERS` | 允许的签发者列表（逗号分隔） | `agentcube-gateway` |\n| `JWT_ALLOWED_AUDIENCES` | 允许的受众列表（逗号分隔） | `agentcube-router` |\n| `JWT_LEEWAY` | 时间容差 | `30s` |\n| `JWT_TOKEN_EXPIRATION` | 出站 token 有效期 | `5m` |\n| `JWT_KEY_ROTATION_INTERVAL` | 密钥轮转检查间隔（0 表示禁用） | `0` |\n\n### 7.2 CLI 标志\n\n```\n--enable-jwt-auth          启用客户端 JWT 认证\n--jwt-issuers string       允许的签发者（逗号分隔）\n--jwt-audiences string     允许的受众（逗号分隔）\n--jwt-leeway duration      时间容差 (default 30s)\n--jwt-token-expiration duration  出站 token 有效期 (default 5m)\n--jwt-key-rotation-interval duration  密钥轮转检查间隔 (default 0)\n```\n\n---\n\n## 8. 安全考量\n\n### 8.1 密钥安全\n\n- RSA 私钥仅存储在内存和 K8s Secret 中，不写入本地文件系统\n- Secret 使用 Opaque 类型，依赖 K8s RBAC 控制访问\n- 日志中禁止输出私钥或完整 token\n\n### 8.2 Token 安全\n\n- 出站 token 有效期短（5min），降低泄露风险\n- 入站 token 验证包含 issuer、audience、expiration 三重校验\n- Leeway 仅用于处理时钟偏移，不宜设置过大\n\n### 8.3 降级策略\n\n- 非 in-cluster 运行时使用临时密钥（ephemeral keys），仅记录 warning\n- 认证禁用时（`EnableAuth=false`），中间件不挂载，不影响现有行为\n- 密钥加载失败不阻塞服务启动（降级为临时密钥）\n\n---\n\n## 9. 实现步骤\n\n### Phase 1: JWT 验证核心（Day 1-2）\n\n1. 扩展 `JWTConfig` 结构体与默认值\n2. 实现 `JWTManager.ValidateToken()` 方法\n3. 实现 `mapJWTError()` 错误映射函数\n4. 编写 `jwt_test.go` 验证相关测试\n\n### Phase 2: 认证中间件（Day 3）\n\n1. 实现 `JWTAuthMiddleware` 中间件\n2. 定义 `AuthContext` 结构与 `AuthContextKey`\n3. 更新 `Config` 集成 `JWTConfig`\n4. 编写 `middleware_test.go` 中间件测试\n\n### Phase 3: 集成与路由更新（Day 4）\n\n1. 更新 `NewJWTManager` 接受 `JWTConfig`\n2. 更新 `GenerateToken` 使用配置项\n3. 更新 `server.go` 路由注册（条件挂载中间件）\n4. 更新 `proxy.go` 出站 JWT 注入（透传 user_id）\n5. 编写 `server_test.go` 和 `proxy_test.go` 集成测试\n\n### Phase 4: 密钥轮转与配置（Day 5）\n\n1. 实现 `StartKeyRotation()` 和 `ReloadKeyFromSecret()`\n2. 添加环境变量与 CLI 标志解析\n3. 编写密钥轮转测试\n4. 运行门禁检查\n\n### Phase 5: 门禁与验收（Day 6）\n\n1. `go build ./pkg/router/... ./cmd/router/...`\n2. `go test ./pkg/router/... -v`\n3. `go test -race ./pkg/router/...`\n4. 检查日志无敏感信息泄露\n5. 修复所有问题\n\n---\n\n## 10. 后续变更\n\n| 变更 | 描述 | 优先级 |\n|------|------|--------|\n| AR-0XX | JWT 黑名单/吊销列表（Redis 存储） | P1 |\n| AR-0XX | 支持 ES256（ECDSA）签名算法 | P2 |\n| AR-0XX | 基于角色的访问控制（RBAC 中间件） | P2 |\n| AR-0XX | 自动证书管理（cert-manager 集成） | P3 |\n| AR-0XX | mTLS 双向认证支持 | P3 |\n\n### 已知限制\n\n- 当前仅支持 RS256 算法，不支持 HS256/ES256\n- 入站 token 验证使用单一公钥（router 自身密钥对），不支持 JWKS 多密钥源\n- 无 token 刷新机制，客户端需自行处理过期重认证\n- 密钥轮转为被动拉取模式，不支持 K8s Secret watch 主动推送\n","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/design.md"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/jwt.go\">\nERROR [12:2] could not import github.com/golang-jwt/jwt/v5 (no required module provides package \"github.com/golang-jwt/jwt/v5\")\nERROR [55:17] undefined: jwt\nERROR [63:11] undefined: jwt\nERROR [63:29] undefined: jwt\nERROR [81:20] undefined: metav1.Secret\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/codeinterpreter.go\">\nERROR [11:2] \"k8s.io/apimachinery/pkg/apis/meta/v1\" imported as metav1 and not used\nERROR [32:25] undefined: LabelSessionID\nERROR [58:29] undefined: LabelSandboxName\nERROR [59:29] undefined: LabelWorkloadName\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/reconciler/pod.go\">\nERROR [31:28] undefined: LabelSandboxName\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/ds