├── router/                 # Session routing, reverse proxy, JWT\n│   ├── store/                  # Redis/Valkey session store\n│   ├── agentd/                 # Idle cleanup controller\n│   └── picod/                  # Code execution daemon\n├── client-go/                  # Generated Kubernetes client\n├── sdk-python/                 # Python SDK (agentcube package)\n├── manifests/charts/base/      # Helm chart\n│   ├── crds/                   # Generated CRD YAMLs\n│   └── templates/\n├── docker/\n│   ├── Dockerfile              # Workload manager\n│   ├── Dockerfile.router\n│   └── Dockerfile.picod\n├── hack/\n│   ├── update-codegen.sh\n│   ├── update-copyright.sh\n│   ├── boilerplate.go.txt\n│   └── boilerplate.py.txt\n├── test/e2e/\n├── integrations/dify-plugin/\n├── example/pcap-analyzer/\n├── go.mod\n├── go.sum\n└── Makefile\n```\n\n---\n\n### 2. Existing CRD Definitions in pkg/apis/\n\n**API Group:** `runtime.agentcube.volcano.sh`\n**Version:** `v1alpha1`\n\n**File: `pkg/apis/runtime/v1alpha1/groupversion_info.go`**\n```go\n// +groupName=runtime.agentcube.volcano.sh\npackage v1alpha1\n\nvar (\n    GroupVersion = schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"}\n    SchemeBuilder = &scheme.Builder{GroupVersion: GroupVersion}\n    AddToScheme = SchemeBuilder.AddToScheme\n)\n```\n\n**File: `pkg/apis/runtime/v1alpha1/register.go`**\n```go\nvar (\n    CodeInterpreterKind             = \"CodeInterpreter\"\n    CodeInterpreterGroupKind        = GroupVersion.WithKind(\"CodeInterpreter\")\n    CodeInterpreterListKind         = \"CodeInterpreterList\"\n    CodeInterpreterGroupVersionKind = GroupVersion.WithKind(\"CodeInterpreter\")\n    AgentRuntimeKind             = \"AgentRuntime\"\n    AgentRuntimeListKind         = \"AgentRuntimeList\"\n    AgentRuntimeGroupVersionKind = GroupVersion.WithKind(\"AgentRuntime\")\n)\nvar SchemeGroupVersion = GroupVersion\nfunc Resource(resource string) schema.GroupVersionResource { return GroupVersion.WithResource(resource) }\n```\n\n**File: `pkg/apis/runtime/v1alpha1/agent_type.go`** -- AgentRuntime CRD:\n```go\n// +genclient\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\n// +kubebuilder:subresource:status\n// +kubebuilder:resource:scope=Namespaced\n// +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\ntype AgentRuntime struct {\n    metav1.TypeMeta   `json:\",inline\"`\n    metav1.ObjectMeta `json:\"metadata,omitempty\"`\n    Spec   AgentRuntimeSpec   `json:\"spec\"`\n    Status AgentRuntimeStatus `json:\"status,omitempty\"`\n}\n\ntype AgentRuntimeSpec struct {\n    Ports []TargetPort `json:\"targetPort\"`\n    // +kubebuilder:validation:Required\n    Template *SandboxTemplate `json:\"podTemplate\" protobuf:\"bytes,1,opt,name=podTemplate\"`\n    // +kubebuilder:validation:Required\n    // +kubebuilder:default=\"15m\"\n    SessionTimeout *metav1.Duration `json:\"sessionTimeout,omitempty\"`\n    // +kubebuilder:validation:Required\n    // +kubebuilder:default=\"8h\"\n    MaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\"`\n}\n\ntype AgentRuntimeStatus struct {\n    Conditions []metav1.Condition `json:\"conditions,omitempty\"`\n}\n\ntype SandboxTemplate struct {\n    Labels      map[string]string `json:\"labels,omitempty\"`\n    Annotations map[string]string `json:\"annotations,omitempty\"`\n    // +kubebuilder:validation:Required\n    Spec corev1.PodSpec `json:\"spec\"`\n}\n\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\ntype AgentRuntimeList struct {\n    metav1.TypeMeta `json:\",inline\"`\n    metav1.ListMeta `json:\"metadata,omitempty\"`\n    Items           []AgentRuntime `json:\"items\"`\n}\n```\n\n**File: `pkg/apis/runtime/v1alpha1/codeinterpreter_types.go`** -- CodeInterpreter CRD + shared types:\n```go\n// +genclient\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\n// +kubebuilder:subresource:status\n// +kubebuilder:resource:scope=Namespaced\n// +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\ntype CodeInterpreter struct { ... }\n\ntype CodeInterpreterSpec struct {\n    Ports            []TargetPort                   `json:\"ports,omitempty\"`\n    Template         *CodeInterpreterSandboxTemplate `json:\"template\"`\n    SessionTimeout   *metav1.Duration               `json:\"sessionTimeout,omitempty\"`   // default \"15m\"\n    MaxSessionDuration *metav1.Duration             `json:\"maxSessionDuration,omitempty\"` // default \"8h\"\n    WarmPoolSize     *int32                         `json:\"warmPoolSize,omitempty\"`\n    AuthMode         AuthModeType                   `json:\"authMode,omitempty\"`  // default \"picod\", enum: picod|none\n}\n\ntype CodeInterpreterStatus struct {\n    Conditions []metav1.Condition `json:\"conditions,omitempty\"`\n    Ready      bool               `json:\"ready,omitempty\"`\n}\n\ntype CodeInterpreterSandboxTemplate struct {\n    Labels           map[string]string             `json:\"labels,omitempty\"`\n    Annotations      map[string]string             `json:\"annotations,omitempty\"`\n    RuntimeClassName *string                       `json:\"runtimeClassName,omitempty\"`\n    Image            string                        `json:\"image,omitempty\"`\n    ImagePullPolicy  corev1.PullPolicy             `json:\"imagePullPolicy,omitempty\"`\n    ImagePullSecrets []corev1.LocalObjectReference `json:\"imagePullSecrets,omitempty\"`\n    Environment      []corev1.EnvVar               `json:\"environment,omitempty\"`\n    Command          []string                      `json:\"command,omitempty\"`\n    Args             []string                      `json:\"args,omitempty\"`\n    Resources        corev1.ResourceRequirements   `json:\"resources,omitempty\"`\n}\n\ntype TargetPort struct {\n    PathPrefix string       `json:\"pathPrefix,omitempty\"`\n    Name       string       `json:\"name,omitempty\"`\n    Port       uint32       `json:\"port\"`\n    Protocol   ProtocolType `json:\"protocol\"`  // default HTTP, enum: HTTP|HTTPS\n}\n\ntype ProtocolType string\nconst ( ProtocolTypeHTTP ProtocolType = \"HTTP\"; ProtocolTypeHTTPS ProtocolType = \"HTTPS\" )\n\ntype AuthModeType string\nconst ( AuthModePicoD AuthModeType = \"picod\"; AuthModeNone AuthModeType = \"none\" )\n\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\ntype CodeInterpreterList struct { ... }\n```\n\n**File: `pkg/common/types/types.go`** -- Shared types:\n```go\nconst ( AgentRuntimeKind = \"AgentRuntime\"; CodeInterpreterKind = \"CodeInterpreter\"\n      SandboxKind = \"Sandbox\"; SandboxClaimsKind = \"SandboxClaim\" )\n\ntype SandboxInfo struct {\n    Kind, SandboxID, SandboxNamespace, Name, SessionID, Status string\n    EntryPoints      []SandboxEntryPoint\n    CreatedAt, ExpiresAt time.Time\n}\ntype SandboxEntryPoint struct { Path, Protocol, Endpoint string }\ntype CreateSandboxRequest struct { Kind, Name, Namespace string }\ntype CreateSandboxResponse struct { SessionID, SandboxID, SandboxName string; EntryPoints []SandboxEntryPoint }\n```\n\n---\n\n### 3. Design Document Patterns\n\nThe project uses a **dual-document pattern** for each module:\n\n| File | Purpose |\n|------|---------|\n| `design.md` | Technical implementation details: exact Go structs, function signatures, constants, HTTP routes, CLI flags, environment variables, dependency lists |\n| `spec.md` | Normative requirements in Given/When/Then format with SHALL/SHOULD/MAY language |\n\n**Change Request pattern** (`changes/AR-XXX/`):\n| File | Purpose |\n|------|---------|\n| `proposal.md` | Overview, scope (in/out), type definition summary, impact analysis, alternatives, acceptance criteria |\n| `design.md` | Detailed technical design (currently placeholder for AR-001) |\n| `tasks.md` | Checklist of implementation tasks |\n\n**TDD Manifest** (`testing/agentcube_tdd_manifest.md`): Defines required test cases per module with pass/fail criteria.\n\n---\n\n### 4. Go Module Structure\n\n**Module path:** `github.com/volcano-sh/agentcube`\n**Go version:** `1.24.4` (toolchain: `go1.24.9`)\n\n**Key direct dependencies (from go.mod):**\n| Dependency | Version |\n|-----------|---------|\n| `k8s.io/api` | `v0.34.1` |\n| `k8s.io/apimachinery` | `v0.34.1` |\n| `k8s.io/client-go` | `v0.34.1` |\n| `sigs.k8s.io/controller-runtime` | `v0.22.2` |\n| `sigs.k8s.io/agent-sandbox` | `v0.1.1` |\n| `github.com/gin-gonic/gin` | `v1.10.0` |\n| `github.com/redis/go-redis/v9` | `v9.17.1` |\n| `github.com/valkey-io/valkey-go` | `v1.0.69` |\n| `github.com/golang-jwt/jwt/v5` | `v5.2.2` |\n| `github.com/google/uuid` | `v1.6.0` |\n| `k8s.io/klog/v2` | `v2.130.1` |\n| `github.com/stretchr/testify` | `v1.11.1` |\n| `github.com/alicebob/miniredis/v2` | `v2.35.0` |\n| `github.com/agiledragon/gomonkey/v2` | `v2.13.0` |\n\n**Sub-module:** `github.com/volcano-sh/agentcube/client-go` (generated Kubernetes client)\n\n---\n\n### 5. Makefile Targets Related to Code Generation\n\nFrom `deployment/design.md` (the project Makefile, not the benchmark Makefile):\n\n**Code generation targets:**\n\n| Target | Description |\n|--------|-------------|\n| `gen-crd` | Runs `controller-gen crd paths=./pkg/apis/runtime/v1alpha1/...` to output CRD YAMLs to `manifests/charts/base/crds` |\n| `generate` | Runs `controller-gen object` (DeepCopy), then `gen-crd`, then `go mod tidy` |\n| `gen-client` | Runs `bash hack/update-codegen.sh` then `go mod tidy` |\n| `gen-all` | Runs `generate` + `gen-client` |\n| `gen-check` | Runs `gen-all` then `git diff --exit-code` (CI gate) |\n| `gen-copyright` | Runs `hack/update-copyright.sh` to add Apache/Volcano boilerplate headers |\n\n**Code generation toolchain:**\n- **controller-gen** version: `v0.17.2` (downloaded to `$(LOCALBIN)/controller-gen`)\n- **k8s.io/code-generator** version: `v0.34.1`\n- `hack/update-codegen.sh` sources `kube_codegen.sh`, calls `kube::codegen::gen_client --with-watch --output-dir client-go --output-pkg github.com/volcano-sh/agentcube/client-go --boilerplate hack/boilerplate.go.txt --one-input-api runtime/v1alpha1`\n- Post-processing: `sed` appends `.GroupResource()` to lister files for agentruntime/codeinterpreter resources\n\n**Build targets:**\n| Target | Description |\n|--------|-------------|\n| `build` | `generate` + `go build -o bin/workloadmanager ./cmd/workload-manager` |\n| `build-agentd` | `generate` + `go build -o bin/agentd ./cmd/agentd` |\n| `build-router` | `generate` + `go build -o bin/agentcube-router ./cmd/router` |\n| `build-all` | `build` + `build-agentd` + `build-router` |\n\n**Key Makefile variables:**\n```\nCONTROLLER_GEN = $(LOCALBIN)/controller-gen\nCONTROLLER_TOOLS_VERSION = v0.17.2\nLOCALBIN = $(shell pwd)/bin\n```\n\n---\n\n### Summary of Key File Paths (absolute, as referenced in design docs)\n\n| Category | Path (relative to repo root) |\n|----------|------------------------------|\n| CRD types | `pkg/apis/runtime/v1alpha1/agent_type.go` |\n| CRD types | `pkg/apis/runtime/v1alpha1/codeinterpreter_types.go` |\n| Group version | `pkg/apis/runtime/v1alpha1/groupversion_info.go` |\n| Register | `pkg/apis/runtime/v1alpha1/register.go` |\n| DeepCopy (generated) | `pkg/apis/runtime/v1alpha1/zz_generated.deepcopy.go` |\n| Shared types | `pkg/common/types/types.go` |\n| API errors | `pkg/api/errors.go` |\n| Codegen script | `hack/update-codegen.sh` |\n| Boilerplate | `hack/boilerplate.go.txt` |\n| CRD YAMLs | `manifests/charts/base/crds/runtime.agentcube.volcano.sh_agentruntimes.yaml` |\n| CRD YAMLs | `manifests/charts/base/crds/runtime.agentcube.volcano.sh_codeinterpreters.yaml` |\n| Generated client | `client-go/` (entire tree) |\n</task_result>","metadata":{"sessionId":"ses_289a35190ffeInBTk1CP3JQtnK","model":{"modelID":"qwen3.6-plus","providerID":"alibaba-cn"},"truncated":false},"title":"Explore agentcube project structure","time":{"start":1775807278699,"end":1775807450280}}}}
