dboxTemplateNotFoundError struct {\n\tNamespace string\n\tName      string\n\tKind      string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/errors.go","time":{"start":1775828882937,"end":1775828882942}}}}
