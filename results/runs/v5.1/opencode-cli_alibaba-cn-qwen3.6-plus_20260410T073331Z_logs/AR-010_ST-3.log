{"type":"tool_use","timestamp":1775828881722,"sessionID":"ses_2885cc624ffe0LB44CoY3k3GVD","part":{"id":"prt_d77a64cfc0016WemWDsPr2HY13","messageID":"msg_d77a642aa001DlyAHI25jkjME3","sessionID":"ses_2885cc624ffe0LB44CoY3k3GVD","type":"tool","tool":"read","callID":"call_25297821c0a44ba3bad672ec","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/proxy.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/proxy.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"net/http\"\n6: \t\"net/http/httputil\"\n7: \t\"net/url\"\n8: \t\"strings\"\n9: \n10: \t\"github.com/gin-gonic/gin\"\n11: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n12: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n13: \t\"k8s.io/klog/v2\"\n14: )\n15: \n16: func handleGetSandboxError(c *gin.Context, err error) {\n17: \tif statusErr, ok := err.(apierrors.APIStatus); ok {\n18: \t\tcode := statusErr.Status().Code\n19: \t\tif code == 0 {\n20: \t\t\tcode = http.StatusInternalServerError\n21: \t\t}\n22: \t\tmessage := statusErr.Status().Message\n23: \t\tif message == \"\" {\n24: \t\t\tmessage = err.Error()\n25: \t\t}\n26: \t\tif code == http.StatusInternalServerError {\n27: \t\t\tmessage = \"internal server error\"\n28: \t\t}\n29: \t\tc.JSON(int(code), gin.H{\"error\": message})\n30: \t\treturn\n31: \t}\n32: \tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"internal server error\"})\n33: }\n34: \n35: func (s *Server) handleInvoke(c *gin.Context, kind string) {\n36: \tnamespace := c.Param(\"namespace\")\n37: \tname := c.Param(\"name\")\n38: \tsessionID := c.GetHeader(\"x-agentcube-session-id\")\n39: \n40: \tctx := c.Request.Context()\n41: \n42: \tsandboxInfo, err := s.sessionManager.GetSandboxBySession(ctx, sessionID, namespace, name, kind)\n43: \tif err != nil {\n44: \t\tif _, ok := err.(*SessionNotFoundError); ok {\n45: \t\t\tc.JSON(http.StatusNotFound, gin.H{\"error\": err.Error()})\n46: \t\t\treturn\n47: \t\t}\n48: \t\tif _, ok := err.(*SandboxTemplateNotFoundError); ok {\n49: \t\t\tc.JSON(http.StatusNotFound, gin.H{\"error\": err.Error()})\n50: \t\t\treturn\n51: \t\t}\n52: \t\thandleGetSandboxError(c, err)\n53: \t\treturn\n54: \t}\n55: \n56: \tif sessionID == \"\" {\n57: \t\tsessionID = sandboxInfo.SessionID\n58: \t}\n59: \n60: \tif s.storeClient != nil {\n61: \t\tif err := s.storeClient.UpdateSessionLastActivity(ctx, sessionID, nil); err != nil {\n62: \t\t\tklog.Warningf(\"failed to update last activity for session %s: %v\", sessionID, err)\n63: \t\t}\n64: \t}\n65: \n66: \tif len(sandboxInfo.EntryPoints) == 0 {\n67: \t\tc.JSON(http.StatusNotFound, gin.H{\"error\": \"no entry point found for sandbox\"})\n68: \t\treturn\n69: \t}\n70: \n71: \tif err := s.forwardToSandbox(c, sandboxInfo, kind, sessionID); err != nil {\n72: \t\treturn\n73: \t}\n74: \n75: \tif s.storeClient != nil {\n76: \t\tif err := s.storeClient.UpdateSessionLastActivity(ctx, sessionID, nil); err != nil {\n77: \t\t\tklog.Warningf(\"failed to update last activity for session %s: %v\", sessionID, err)\n78: \t\t}\n79: \t}\n80: }\n81: \n82: func (s *Server) handleAgentInvoke(c *gin.Context) {\n83: \ts.handleInvoke(c, types.AgentRuntimeKind)\n84: }\n85: \n86: func (s *Server) handleCodeInterpreterInvoke(c *gin.Context) {\n87: \ts.handleInvoke(c, types.CodeInterpreterKind)\n88: }\n89: \n90: func (s *Server) forwardToSandbox(c *gin.Context, sandboxInfo *types.SandboxInfo, kind string, sessionID string) error {\n91: \tinvocationPath := c.Param(\"path\")\n92: \tif !strings.HasPrefix(invocationPath, \"/\") {\n93: \t\tinvocationPath = \"/\" + invocationPath\n94: \t}\n95: \n96: \tvar selectedEP *types.EntryPoint\n97: \tfor i := range sandboxInfo.EntryPoints {\n98: \t\tep := &sandboxInfo.EntryPoints[i]\n99: \t\tif strings.HasPrefix(invocationPath, ep.Path) {\n100: \t\t\tselectedEP = ep\n101: \t\t\tbreak\n102: \t\t}\n103: \t}\n104: \tif selectedEP == nil && len(sandboxInfo.EntryPoints) > 0 {\n105: \t\tselectedEP = &sandboxInfo.EntryPoints[0]\n106: \t}\n107: \tif selectedEP == nil {\n108: \t\tc.JSON(http.StatusNotFound, gin.H{\"error\": \"no entry point found for sandbox\"})\n109: \t\treturn nil\n110: \t}\n111: \n112: \ttargetStr := selectedEP.Endpoint\n113: \tif selectedEP.Protocol != \"\" && !strings.Contains(targetStr, \"://\") {\n114: \t\ttargetStr = strings.ToLower(selectedEP.Protocol) + \"://\" + targetStr\n115: \t}\n116: \tif !strings.Contains(targetStr, \"://\") {\n117: \t\ttargetStr = \"http://\" + targetStr\n118: \t}\n119: \n120: \ttargetURL, err := url.Parse(targetStr)\n121: \tif err != nil {\n122: \t\tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"invalid target URL\"})\n123: \t\treturn err\n124: \t}\n125: \n126: \tproxy := httputil.NewSingleHostReverseProxy(targetURL)\n127: \tproxy.Transport = s.httpTransport\n128: \n129: \tproxy.Director = func(req *http.Request) {\n130: \t\treq.URL.Scheme = targetURL.Scheme\n131: \t\treq.URL.Host = targetURL.Host\n132: \t\treq.URL.Path = invocationPath\n133: \t\treq.URL.RawPath = \"\"\n134: \t\treq.Host = targetURL.Host\n135: \n136: \t\treq.Header.Set(\"X-Forwarded-Host\", c.Request.Host)\n137: \t\tif s.config.EnableTLS {\n138: \t\t\treq.Header.Set(\"X-Forwarded-Proto\", \"https\")\n139: \t\t} else {\n140: \t\t\treq.Header.Set(\"X-Forwarded-Proto\", \"http\")\n141: \t\t}\n142: \t\tif existing := req.Header.Get(\"X-Forwarded-For\"); existing != \"\" {\n143: \t\t\treq.Header.Set(\"X-Forwarded-For\", existing+\", \"+c.ClientIP())\n144: \t\t} else {\n145: \t\t\treq.Header.Set(\"X-Forwarded-For\", c.ClientIP())\n146: \t\t}\n147: \n148: \t\tif kind == types.SandboxKind || kind == types.SandboxClaimKind {\n149: \t\t\tif s.jwtManager != nil {\n150: \t\t\t\ttoken, err := s.jwtManager.GenerateToken(map[string]interface{}{\n151: \t\t\t\t\t\"session_id\": sessionID,\n152: \t\t\t\t})\n153: \t\t\t\tif err != nil {\n154: \t\t\t\t\tklog.Errorf(\"failed to generate JWT: %v\", err)\n155: \t\t\t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n156: \t\t\t\t\t\t\"code\":  \"JWT_SIGNING_FAILED\",\n157: \t\t\t\t\t\t\"error\": \"failed to sign request\",\n158: \t\t\t\t\t})\n159: \t\t\t\t\treturn\n160: \t\t\t\t}\n161: \t\t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n162: \t\t\t}\n163: \t\t}\n164: \t}\n165: \n166: \tproxy.ModifyResponse = func(resp *http.Response) error {\n167: \t\tresp.Header.Set(\"x-agentcube-session-id\", sessionID)\n168: \t\treturn nil\n169: \t}\n170: \n171: \tproxy.ErrorHandler = func(w http.ResponseWriter, r *http.Request, err error) {\n172: \t\terrMsg := err.Error()\n173: \t\tif strings.Contains(errMsg, \"connection refused\") {\n174: \t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n175: \t\t\tw.WriteHeader(http.StatusBadGateway)\n176: \t\t\tjson.NewEncoder(w).Encode(gin.H{\"error\": \"sandbox unreachable\"})\n177: \t\t\treturn\n178: \t\t}\n179: \t\tif strings.Contains(errMsg, \"timeout\") || strings.Contains(errMsg, \"context deadline exceeded\") {\n180: \t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n181: \t\t\tw.WriteHeader(http.StatusGatewayTimeout)\n182: \t\t\tjson.NewEncoder(w).Encode(gin.H{\"error\": \"sandbox timeout\"})\n183: \t\t\treturn\n184: \t\t}\n185: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n186: \t\tw.WriteHeader(http.StatusBadGateway)\n187: \t\tjson.NewEncoder(w).Encode(gin.H{\"error\": \"sandbox unreachable\"})\n188: \t}\n189: \n190: \tproxy.ServeHTTP(c.Writer, c.Request)\n191: \treturn nil\n192: }\n\n(End of file - total 192 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/klog/v2\"\n)\n\nfunc handleGetSandboxError(c *gin.Context, err error) {\n\tif statusErr, ok := err.(apierrors.APIStatus); ok {\n\t\tcode := statusErr.Status().Code\n\t\tif code == 0 {\n\t\t\tcode = http.StatusInternalServerError","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/router/proxy.go","time":{"start":1775828881715,"end":1775828881720}}}}
