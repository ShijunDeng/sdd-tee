\tif in.SessionTimeout != nil {\n50: \t\tin, out := &in.SessionTimeout, &out.SessionTimeout\n51: \t\t*out = new(metav1.Duration)\n52: \t\t**out = **in\n53: \t}\n54: \tif in.MaxSessionDuration != nil {\n55: \t\tin, out := &in.MaxSessionDuration, &out.MaxSessionDuration\n56: \t\t*out = new(metav1.Duration)\n57: \t\t**out = **in\n58: \t}\n59: }\n60: \n61: func (in *AgentRuntimeSpec) DeepCopy() *AgentRuntimeSpec {\n62: \tif in == nil {\n63: \t\treturn nil\n64: \t}\n65: \tout := new(AgentRuntimeSpec)\n66: \tin.DeepCopyInto(out)\n67: \treturn out\n68: }\n69: \n70: func (in *SandboxTemplate) DeepCopyInto(out *SandboxTemplate) {\n71: \t*out = *in\n72: \tif in.Labels != nil {\n73: \t\tin, out := &in.Labels, &out.Labels\n74: \t\t*out = make(map[string]string, len(*in))\n75: \t\tfor key, val := range *in {\n76: \t\t\t(*out)[key] = val\n77: \t\t}\n78: \t}\n79: \tif in.Annotations != nil {\n80: \t\tin, out := &in.Annotations, &out.Annotations\n81: \t\t*out = make(map[string]string, len(*in))\n82: \t\tfor key, val := range *in {\n83: \t\t\t(*out)[key] = val\n84: \t\t}\n85: \t}\n86: \tin.Spec.DeepCopyInto(&out.Spec)\n87: }\n88: \n89: func (in *SandboxTemplate) DeepCopy() *SandboxTemplate {\n90: \tif in == nil {\n91: \t\treturn nil\n92: \t}\n93: \tout := new(SandboxTemplate)\n94: \tin.DeepCopyInto(out)\n95: \treturn out\n96: }\n97: \n98: func (in *AgentRuntimeStatus) DeepCopyInto(out *AgentRuntimeStatus) {\n99: \t*out = *in\n100: \tif in.Conditions != nil {\n101: \t\tin, out := &in.Conditions, &out.Conditions\n102: \t\t*out = make([]metav1.Condition, len(*in))\n103: \t\tfor i := range *in {\n104: \t\t\t(*in)[i].DeepCopyInto(&(*out)[i])\n105: \t\t}\n106: \t}\n107: }\n108: \n109: func (in *AgentRuntimeStatus) DeepCopy() *AgentRuntimeStatus {\n110: \tif in == nil {\n111: \t\treturn nil\n112: \t}\n113: \tout := new(AgentRuntimeStatus)\n114: \tin.DeepCopyInto(out)\n115: \treturn out\n116: }\n117: \n118: func (in *AgentRuntimeList) DeepCopyInto(out *AgentRuntimeList) {\n119: \t*out = *in\n120: \tout.TypeMeta = in.TypeMeta\n121: \tin.ListMeta.DeepCopyInto(&out.ListMeta)\n122: \tif in.Items != nil {\n123: \t\tin, out := &in.Items, &out.Items\n124: \t\t*out = make([]AgentRuntime, len(*in))\n125: \t\tfor i := range *in {\n126: \t\t\t(*in)[i].DeepCopyInto(&(*out)[i])\n127: \t\t}\n128: \t}\n129: }\n130: \n131: func (in *AgentRuntimeList) DeepCopy() *AgentRuntimeList {\n132: \tif in == nil {\n133: \t\treturn nil\n134: \t}\n135: \tout := new(AgentRuntimeList)\n136: \tin.DeepCopyInto(out)\n137: \treturn out\n138: }\n139: \n140: func (in *AgentRuntimeList) DeepCopyObject() runtime.Object {\n141: \tif c := in.DeepCopy(); c != nil {\n142: \t\treturn c\n143: \t}\n144: \treturn nil\n145: }\n146: \n147: func (in *TargetPort) DeepCopyInto(out *TargetPort) {\n148: \t*out = *in\n149: }\n150: \n151: func (in *TargetPort) DeepCopy() *TargetPort {\n152: \tif in == nil {\n153: \t\treturn nil\n154: \t}\n155: \tout := new(TargetPort)\n156: \tin.DeepCopyInto(out)\n157: \treturn out\n158: }\n159: \n160: func (in *CodeInterpreter) DeepCopyInto(out *CodeInterpreter) {\n161: \t*out = *in\n162: \tout.TypeMeta = in.TypeMeta\n163: \tin.ObjectMeta.DeepCopyInto(&out.ObjectMeta)\n164: \tin.Spec.DeepCopyInto(&out.Spec)\n165: \tin.Status.DeepCopyInto(&out.Status)\n166: }\n167: \n168: func (in *CodeInterpreter) DeepCopy() *CodeInterpreter {\n169: \tif in == nil {\n170: \t\treturn nil\n171: \t}\n172: \tout := new(CodeInterpreter)\n173: \tin.DeepCopyInto(out)\n174: \treturn out\n175: }\n176: \n177: func (in *CodeInterpreter) DeepCopyObject() runtime.Object {\n178: \tif c := in.DeepCopy(); c != nil {\n179: \t\treturn c\n180: \t}\n181: \treturn nil\n182: }\n183: \n184: func (in *CodeInterpreterSpec) DeepCopyInto(out *CodeInterpreterSpec) {\n185: \t*out = *in\n186: \tif in.Ports != nil {\n187: \t\tin, out := &in.Ports, &out.Ports\n188: \t\t*out = make([]TargetPort, len(*in))\n189: \t\tcopy(*out, *in)\n190: \t}\n191: \tif in.Template != nil {\n192: \t\tin, out := &in.Template, &out.Template\