{\n50: \tpong, err := r.cli.Ping(ctx).Result()\n51: \tif err != nil {\n52: \t\treturn err\n53: \t}\n54: \tif pong != \"PONG\" {\n55: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n56: \t}\n57: \treturn nil\n58: }\n59: \n60: func (r *redisStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n61: \tkey := r.sessionPrefix + sessionID\n62: \tdata, err := r.cli.Get(ctx, key).Bytes()\n63: \tif err == redis.Nil {\n64: \t\treturn nil, ErrNotFound\n65: \t}\n66: \tif err != nil {\n67: \t\treturn nil, err\n68: \t}\n69: \treturn decodeSandboxInfo(data)\n70: }\n71: \n72: func (r *redisStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n73: \tif info == nil {\n74: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n75: \t}\n76: \n77: \tdata, err := encodeSandboxInfo(info)\n78: \tif err != nil {\n79: \t\treturn err\n80: \t}\n81: \n82: \tkey := r.sessionPrefix + sessionID\n83: \texpiryScore := float64(info.ExpiresAt.Unix())\n84: \tlastActivityScore := float64(info.LastActivityAt.Unix())\n85: \n86: \tpipe := r.cli.Pipeline()\n87: \tpipe.SetNX(ctx, key, data, 0)\n88: \tpipe.ZAdd(ctx, r.expiryIndexKey, redis.Z{Score: expiryScore, Member: sessionID})\n89: \tpipe.ZAdd(ctx, r.lastActivityIndexKey, redis.Z{Score: lastActivityScore, Member: sessionID})\n90: \n91: \t_, err = pipe.Exec(ctx)\n92: \treturn err\n93: }\n94: \n95: func (r *redisStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n96: \tif info == nil {\n97: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n98: \t}\n99: \n100: \tdata, err := encodeSandboxInfo(info)\n101: \tif err != nil {\n102: \t\treturn err\n103: \t}\n104: \n105: \tkey := r.sessionPrefix + sessionID\n106: \tresult, err := r.cli.SetXX(ctx, key, data, 0).Result()\n107: \tif err != nil {\n108: \t\treturn err\n109: \t}\n110: \tif !result {\n111: \t\treturn fmt.Errorf(\"key %s does not exist\", key)\n112: \t}\n113: \treturn nil\n114: }\n115: \n116: func (r *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n117: \tkey := r.sessionPrefix + sessionID\n118: \n119: \tpipe := r.cli.Pipeline()\n120: \tpipe.Del(ctx, key)\n121: \tpipe.ZRem(ctx, r.expiryIndexKey, sessionID)\n122: \tpipe.ZRem(ctx, r.lastActivityIndexKey, sessionID)\n123: \n124: \t_, err := pipe.Exec(ctx)\n125: \treturn err\n126: }\n127: \n128: func (r *redisStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n129: \tsessionIDs, err := r.cli.ZRange(ctx, r.expiryIndexKey, 0, -1).Result()\n130: \tif err != nil {\n131: \t\treturn nil, err\n132: \t}\n133: \n134: \tresult := make(map[string]*types.SandboxInfo)\n135: \tfor _, id := range sessionIDs {\n136: \t\tinfo, err := r.GetSandbox(ctx, id)\n137: \t\tif err != nil {\n138: \t\t\tif err == ErrNotFound {\n139: \t\t\t\tcontinue\n140: \t\t\t}\n141: \t\t\treturn nil, err\n142: \t\t}\n143: \t\tresult[id] = info\n144: \t}\n145: \n146: \treturn result, nil\n147: }\n148: \n149: func (r *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n150: \tif sessionID == \"\" {\n151: \t\treturn fmt.Errorf(\"sessionID cannot be empty\")\n152: \t}\n153: \n154: \tif at.IsZero() {\n155: \t\tat = time.Now()\n156: \t}\n157: \n158: \tkey := r.sessionPrefix + sessionID\n159: \texists, err := r.cli.Exists(ctx, key).Result()\n160: \tif err != nil {\n161: \t\treturn err\n162: \t}\n163: \tif exists == 0 {\n164: \t\treturn ErrNotFound\n165: \t}\n166: \n167: \tscore := float64(at.Unix())\n168: \treturn r.cli.ZAdd(ctx, r.lastActivityIndexKey, redis.Z{Score: score, Member: sessionID}).Err()\n169: }\n170: \n171: func (r *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n172: \tif limit <= 0 {\n173: \t\treturn nil, nil\n174: \t}\n175: \n176: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n177: \tsessionIDs, err := r.cli.ZRangeByScore(ctx, r.expiryIndexKey, &redis.ZRangeBy{\n178: \t\tMin:    \"-inf\",\n179: \t\tMax:    maxScore,\n180: \t\tOffset: 0,\n181: \t\tCount:  int64(limit),\n182: \t}).Result()\n183: \tif err != nil {\n184: \t\treturn nil, err\n185: \t}\n186: \n187: \tvar result []*types.SandboxInfo\n188: \tfor _, id := range sessionIDs {\n189: \t\tinfo, err := r.GetSandbox(ctx, id)\n190: \t\tif err != nil {\n191: \t\t\tif err == ErrNotFound {\n192: \t\t\t\tcontinue\n193: \t\t\t}\n194: \t\t\treturn nil, err\n195: \t\t}\n196: \t\tresult = append(result, info)\n197: \t}\n198: \n199: \treturn result, nil\n200: }\n201: \n202: func (r *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n203: \tif limit <= 0 {\n204: \t\treturn nil, nil\n205: \t}\n206: \n207: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n208: \tsessionIDs, err := r.cli.ZRangeByScore(ctx, r.lastActivityIndexKey, &redis.ZRangeBy{\n209: \t\tMin:    \"-inf\",\n210: \t\tMax:    maxScore,\n211: \t\tOffset: 0,\n212: \t\tCount:  int64(limit),\n213: \t}).Result()\n214: \tif err != nil {\n215: \t\treturn nil, err\n216: \t}\n217: \n218: \tvar result []*types.SandboxInfo\n219: \tfor _, id := range sessionIDs {\n220: \t\tinfo, err := r.GetSandbox(ctx, id)\n221: \t\tif err != nil {\n222: \t\t\tif err == ErrNotFound {\n223: \t\t\t\tcontinue\n224: \t\t\t}\n225: \t\t\treturn nil, err\n226: \t\t}\n227: \t\tresult = append(result, info)\n228: \t}\n229: \n230: \treturn result, nil\n231: }\n232: \n233: func (r *redisStore) Close() error {\n234: \treturn r.cli.Close()\n235: }\n\n(End of file - total 235 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  redis.UniversalClient\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go","time":{"start":1775834004771,"end":1775834004779}}}}
