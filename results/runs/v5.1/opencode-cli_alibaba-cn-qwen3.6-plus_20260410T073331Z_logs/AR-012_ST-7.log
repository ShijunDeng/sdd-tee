sword:          password,\n46: \t\tDisableCache:      disableCache,\n47: \t\tForceSingleClient: forceSingle,\n48: \t})\n49: \tif err != nil {\n50: \t\tklog.Fatalf(\"failed to create valkey client: %v\", err)\n51: \t}\n52: \n53: \treturn &valkeyStore{\n54: \t\tcli:                  client,\n55: \t\tsessionPrefix:        \"session:\",\n56: \t\texpiryIndexKey:       \"session:expiry\",\n57: \t\tlastActivityIndexKey: \"session:last_activity\",\n58: \t}\n59: }\n60: \n61: func (v *valkeyStore) Ping(ctx context.Context) error {\n62: \tresp, err := v.cli.Do(ctx, v.cli.B().Ping().Build()).ToString()\n63: \tif err != nil {\n64: \t\treturn err\n65: \t}\n66: \tif resp != \"PONG\" {\n67: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", resp)\n68: \t}\n69: \treturn nil\n70: }\n71: \n72: func (v *valkeyStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n73: \tkey := v.sessionPrefix + sessionID\n74: \tdata, err := v.cli.Do(ctx, v.cli.B().Get().Key(key).Build()).ToString()\n75: \tif valkey.IsValkeyNil(err) {\n76: \t\treturn nil, ErrNotFound\n77: \t}\n78: \tif err != nil {\n79: \t\treturn nil, err\n80: \t}\n81: \treturn decodeSandboxInfo([]byte(data))\n82: }\n83: \n84: func (v *valkeyStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n85: \tif info == nil {\n86: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n87: \t}\n88: \n89: \tdata, err := encodeSandboxInfo(info)\n90: \tif err != nil {\n91: \t\treturn err\n92: \t}\n93: \n94: \tkey := v.sessionPrefix + sessionID\n95: \texpiryScore := float64(info.ExpiresAt.Unix())\n96: \tlastActivityScore := float64(info.LastActivityAt.Unix())\n97: \n98: \tresults := v.cli.DoMulti(ctx,\n99: \t\tv.cli.B().Setnx().Key(key).Value(string(data)).Build(),\n100: \t\tv.cli.B().Zadd().Key(v.expiryIndexKey).ScoreMember().ScoreMember(expiryScore, sessionID).Build(),\n101: \t\tv.cli.B().Zadd().Key(v.lastActivityIndexKey).ScoreMember().ScoreMember(lastActivityScore, sessionID).Build(),\n102: \t)\n103: \n104: \tfor _, result := range results {\n105: \t\tif err := result.Error(); err != nil {\n106: \t\t\treturn err\n107: \t\t}\n108: \t}\n109: \treturn nil\n110: }\n111: \n112: func (v *valkeyStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n113: \tif info == nil {\n114: \t\treturn fmt.Errorf(\"sandbox info cannot be nil\")\n115: \t}\n116: \n117: \tdata, err := encodeSandboxInfo(info)\n118: \tif err != nil {\n119: \t\treturn err\n120: \t}\n121: \n122: \tkey := v.sessionPrefix + sessionID\n123: \tresp, err := v.cli.Do(ctx, v.cli.B().Set().Key(key).Value(string(data)).Xx().Build()).ToString()\n124: \tif err != nil {\n125: \t\treturn err\n126: \t}\n127: \tif resp != \"OK\" {\n128: \t\treturn fmt.Errorf(\"key %s does not exist\", key)\n129: \t}\n130: \treturn nil\n131: }\n132: \n133: func (v *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n134: \tresults := v.cli.DoMulti(ctx,\n135: \t\tv.cli.B().Del().Key(v.sessionPrefix+sessionID).Build(),\n136: \t\tv.cli.B().Zrem().Key(v.expiryIndexKey).Member(sessionID).Build(),\n137: \t\tv.cli.B().Zrem().Key(v.lastActivityIndexKey).Member(sessionID).Build(),\n138: \t)\n139: \n140: \tfor _, result := range results {\n141: \t\tif err := result.Error(); err != nil {\n142: \t\t\treturn err\n143: \t\t}\n144: \t}\n145: \treturn nil\n146: }\n147: \n148: func (v *valkeyStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n149: \tsessionIDs, err := v.cli.Do(ctx, v.cli.B().Zrange().Key(v.expiryIndexKey).Min(\"0\").Max(\"-1\").Build()).AsStrSlice()\n150: \tif err != nil {\n151: \t\treturn nil, err\n152: \t}\n153: \n154: \tresult := make(map[string]*types.SandboxInfo)\n155: \tfor _, id := range sessionIDs {\n156: \t\tinfo, err := v.GetSandbox(ctx, id)\n157: \t\tif err != nil {\n158: \t\t\tif err == ErrNotFound {\n159: \t\t\t\tcontinue\n160: \t\t\t}\n161: \t\t\treturn nil, err\n162: \t\t}\n163: \t\tresult[id] = info\n164: \t}\n165: \n166: \treturn result, nil\n167: }\n168: \n169: func (v *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n170: \tif sessionID == \"\" {\n171: \t\treturn fmt.Errorf(\"sessionID cannot be empty\")\n172: \t}\n173: \n174: \tif at.IsZero() {\n175: \t\tat = time.Now()\n176: \t}\n177: \n178: \tkey := v.sessionPrefix + sessionID\n179: \texists, err := v.cli.Do(ctx, v.cli.B().Exists().Key(key).Build()).AsInt64()\n180: \tif err != nil {\n181: \t\treturn err\n182: \t}\n183: \tif exists == 0 {\n184: \t\treturn ErrNotFound\n185: \t}\n186: \n187: \tscore := float64(at.Unix())\n188: \treturn v.cli.Do(ctx, v.cli.B().Zadd().Key(v.lastActivityIndexKey).ScoreMember().ScoreMember(score, sessionID).Build()).Error()\n189: }\n190: \n191: func (v *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n192: \tif limit <= 0 {\n193: \t\treturn nil, nil\n194: \t}\n195: \n196: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n197: \tsessionIDs, err := v.cli.Do(ctx, v.cli.B().Zrangebyscore().Key(v.expiryIndexKey).Min(\"-inf\").Max(maxScore).Limit(0, int64(limit)).Build()).AsStrSlice()\n198: \tif err != nil {\n199: \t\treturn nil, err\n200: \t}\n201: \n202: \tvar result []*types.SandboxInfo\n203: \tfor _, id := range sessionIDs {\n204: \t\tinfo, err := v.GetSandbox(ctx, id)\n205: \t\tif err != nil {\n206: \t\t\tif err == ErrNotFound {\n207: \t\t\t\tcontinue\n208: \t\t\t}\n209: \t\t\treturn nil, err\n210: \t\t}\n211: \t\tresult = append(result, info)\n212: \t}\n213: \n214: \treturn result, nil\n215: }\n216: \n217: func (v *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n218: \tif limit <= 0 {\n219: \t\treturn nil, nil\n220: \t}\n221: \n222: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n223: \tsessionIDs, err := v.cli.Do(ctx, v.cli.B().Zrangebyscore().Key(v.lastActivityIndexKey).Min(\"-inf\").Max(maxScore).Limit(0, int64(limit)).Build()).AsStrSlice()\n224: \tif err != nil {\n225: \t\treturn nil, err\n226: \t}\n227: \n228: \tvar result []*types.SandboxInfo\n229: \tfor _, id := range sessionIDs {\n230: \t\tinfo, err := v.GetSandbox(ctx, id)\n231: \t\tif err != nil {\n232: \t\t\tif err == ErrNotFound {\n233: \t\t\t\tcontinue\n234: \t\t\t}\n235: \t\t\treturn nil, err\n236: \t\t}\n237: \t\tresult = append(result, info)\n238: \t}\n239: \n240: \treturn result, nil\n241: }\n242: \n243: func (v *valkeyStore) Close() error {\n244: \tv.cli.Close()\n245: \treturn nil\n246: }\n\n(End of file - total 246 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\tvalkey \"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_valkey.go","time":{"start":1775834006064,"end":1775834006074}}}}
