result, err := store.ListInactiveSandboxes(ctx, now, 10)\n380: \trequire.NoError(t, err)\n381: \trequire.Len(t, result, 1)\n382: \tassert.Equal(t, \"sess-inactive\", result[0].SessionID)\n383: }\n384: \n385: func TestRedisStore_ListInactiveSandboxes_OrphanMember(t *testing.T) {\n386: \tstore, mr := newTestRedisStore(t)\n387: \tctx := context.Background()\n388: \tnow := time.Now().UTC()\n389: \n390: \tinfo := testSandboxInfo(\"sess-orphan-inactive\")\n391: \tinfo.LastActivityAt = now.Add(-time.Hour)\n392: \terr := store.StoreSandbox(ctx, \"sess-orphan-inactive\", info)\n393: \trequire.NoError(t, err)\n394: \n395: \tmr.Del(\"session:sess-orphan-inactive\")\n396: \n397: \tresult, err := store.ListInactiveSandboxes(ctx, now.Add(time.Hour), 10)\n398: \trequire.NoError(t, err)\n399: \tassert.Len(t, result, 0)\n400: }\n401: \n402: func TestRedisStore_Close(t *testing.T) {\n403: \tstore, mr := newTestRedisStore(t)\n404: \n405: \terr := store.Close()\n406: \trequire.NoError(t, err)\n407: \n408: \tmr.Close()\n409: }\n410: \n411: func TestRedisStore_ErrNotFound_Is(t *testing.T) {\n412: \tstore, _ := newTestRedisStore(t)\n413: \tctx := context.Background()\n414: \n415: \t_, err := store.GetSandbox(ctx, \"nonexistent\")\n416: \tassert.ErrorIs(t, err, ErrNotFound)\n417: }\n418: \n419: func TestRedisStore_MultipleSandboxes(t *testing.T) {\n420: \tstore, _ := newTestRedisStore(t)\n421: \tctx := context.Background()\n422: \n423: \tsessions := []string{\"multi-01\", \"multi-02\", \"multi-03\"}\n424: \tfor _, sid := range sessions {\n425: \t\tinfo := testSandboxInfo(sid)\n426: \t\terr := store.StoreSandbox(ctx, sid, info)\n427: \t\trequire.NoError(t, err)\n428: \t}\n429: \n430: \tresult, err := store.ListSandboxes(ctx)\n431: \trequire.NoError(t, err)\n432: \tassert.Len(t, result, 3)\n433: \n434: \tfor _, sid := range sessions {\n435: \t\tsandbox, err := store.GetSandbox(ctx, sid)\n436: \t\trequire.NoError(t, err)\n437: \t\tassert.Equal(t, sid, sandbox.SessionID)\n438: \t}\n439: }\n\n(