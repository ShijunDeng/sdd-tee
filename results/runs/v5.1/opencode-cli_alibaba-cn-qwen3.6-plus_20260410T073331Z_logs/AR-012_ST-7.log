e.NoError(t, err)\n214: \n215: \tmr.Del(\"session:sess-020\")\n216: \n217: \tresult, err := store.ListSandboxes(ctx)\n218: \trequire.NoError(t, err)\n219: \tassert.Len(t, result, 0)\n220: }\n221: \n222: func TestRedisStore_ListSandboxes_Empty(t *testing.T) {\n223: \tstore, _ := newTestRedisStore(t)\n224: \tctx := context.Background()\n225: \n226: \tresult, err := store.ListSandboxes(ctx)\n227: \trequire.NoError(t, err)\n228: \tassert.Empty(t, result)\n229: }\n230: \n231: func TestRedisStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n232: \tstore, _ := newTestRedisStore(t)\n233: \tctx := context.Background()\n234: \n235: \terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n236: \trequire.Error(t, err)\n237: \tassert.Contains(t, err.Error(), \"sessionID cannot be empty\")\n238: }\n239: \n240: func TestRedisStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n241: \tstore, mr := newTestRedisStore(t)\n242: \tctx := context.Background()\n243: \tinfo := testSandboxInfo(\"sess-030\")\n244: \n245: \terr := store.StoreSandbox(ctx, \"sess-030\", info)\n246: \trequire.NoError(t, err)\n247: \n248: \tbefore := time.Now()\n249: \terr = store.UpdateSessionLastActivity(ctx, \"sess-030\", time.Time{})\n250: \trequire.NoError(t, err)\n251: \n252: \tscore, err := mr.ZScore(\"session:last_activity\", \"sess-030\")\n253: \trequire.NoError(t, err)\n254: \tassert.GreaterOrEqual(t, score, float64(before.Unix()))\n255: }\n256: \n257: func TestRedisStore_UpdateSessionLastActivity_NotFound(t *testing.T) {\n258: \tstore, _ := newTestRedisStore(t)\n259: \tctx := context.Background()\n260: \n261: \terr := store.UpdateSessionLastActivity(ctx, \"nonexistent\", time.Now())\n262: \tassert.ErrorIs(t, err, ErrNotFound)\n263: }\n264: \n265: func TestRedisStore_UpdateSessionLastActivity_Success(t *testing.T) {\n266: \tstore, mr := newTestRedisStore(t)\n267: \tctx := context.Background()\n268: \tinfo := testSandboxInfo(\"sess-031\")\n269: \n270: \terr := store.StoreSandbox(ctx, \"sess-031\", info)\n271: \trequire.NoError(t, err)\n272: \n273: \tnewTime := time.Now().Add(10 * time.Minute)\n274: \terr = store.UpdateSessionLastActivity(ctx, \"sess-031\", newTime)\n275: \trequire.NoError(t, err)\n276: \n277: \tscore, err := mr.ZScore(\"session:last_activity\", \"sess-031\")\n278: \trequire.NoError(t, err)\n279: \tassert.Equal(t, float64(newTime.Unix()), score)\n280: }\n281: \n282: func TestRedisStore_ListExpiredSandboxes_LimitZero(t *testing.T) {\n283: \tstore, _ := newTestRedisStore(t)\n284: \tctx := context.Background()\n285: \n286: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n287: \trequire.NoError(t, err)\n288: \tassert.Nil(t, result)\n289: }\n290: \n291: func TestRedisStore_ListExpiredSandboxes_LimitNegative(t *testing.T) {\n292: \tstore, _ := newTestRedisStore(t)\n293: \tctx := context.Background()\n294: \n295: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n296: \trequire.NoError(t, err)\n297: \tassert.Nil(t, result)\n298: }\n299: \n300: func TestRedisStore_ListExpiredSandboxes(t *testing.T) {\n301: \tstore, _ := newTestRedisStore(t)\n302: \tctx := context.Background()\n303: \tnow := time.Now().UTC()\n304: \n305: \texpired := testSandboxInfo(\"sess-expired\")\n306: \texpired.ExpiresAt = now.Add(-2 * time.Hour)\n307: \terr := store.StoreSandbox(ctx, \"sess-expired\", expired)\n308: \trequire.NoError(t, err)\n309: \n310: \tactive := testSandboxInfo(\"sess-active\")\n311: \tactive.ExpiresAt = now.Add(2 * time.Hour)\n312: \terr = store.StoreSandbox(ctx, \"sess-active\", active)\n313: \trequire.NoError(t, err)\n314: \n315: \tresult, err := store.ListExpiredSandboxes(ctx, now, 10)\n316: \trequire.NoError(t, err)\n317: \trequire.Len(t, result, 1)\n318: \tassert.Equal(t, \"sess-expired\", result[0].SessionID)\n319: }\n320: \n321: func TestRedisStore_ListExpiredSandboxes_Limit(t *testing.T) {\n322: \tstore, _ := newTestRedisStore(t)\n323: \tctx := context.Background()\n324: \tnow := time.Now().UTC()\n32