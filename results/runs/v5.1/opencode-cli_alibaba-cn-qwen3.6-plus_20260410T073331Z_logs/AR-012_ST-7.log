ypes.EntryPoint{{Path: \"/api\", Protocol: \"http\", Endpoint: \"http://10.0.0.1:8080\"}},\n45: \t\tCreatedAt:      now,\n46: \t\tExpiresAt:      now.Add(24 * time.Hour),\n47: \t\tStatus:         \"running\",\n48: \t\tLastActivityAt: now.Add(5 * time.Minute),\n49: \t}\n50: }\n51: \n52: func TestRedisStore_Ping(t *testing.T) {\n53: \tstore, _ := newTestRedisStore(t)\n54: \tctx := context.Background()\n55: \n56: \terr := store.Ping(ctx)\n57: \trequire.NoError(t, err)\n58: }\n59: \n60: func TestRedisStore_GetSandbox_NotFound(t *testing.T) {\n61: \tstore, _ := newTestRedisStore(t)\n62: \tctx := context.Background()\n63: \n64: \tresult, err := store.GetSandbox(ctx, \"nonexistent\")\n65: \tassert.ErrorIs(t, err, ErrNotFound)\n66: \tassert.Nil(t, result)\n67: }\n68: \n69: func TestRedisStore_StoreSandbox_NilInfo(t *testing.T) {\n70: \tstore, _ := newTestRedisStore(t)\n71: \tctx := context.Background()\n72: \n73: \terr := store.StoreSandbox(ctx, \"sess-001\", nil)\n74: \trequire.Error(t, err)\n75: \tassert.Contains(t, err.Error(), \"sandbox info cannot be nil\")\n76: }\n77: \n78: func TestRedisStore_StoreSandbox_Success(t *testing.T) {\n79: \tstore, mr := newTestRedisStore(t)\n80: \tctx := context.Background()\n81: \tinfo := testSandboxInfo(\"sess-001\")\n82: \n83: \terr := store.StoreSandbox(ctx, \"sess-001\", info)\n84: \trequire.NoError(t, err)\n85: \n86: \tdata, err := mr.Get(\"session:sess-001\")\n87: \trequire.NoError(t, err)\n88: \trequire.NotEmpty(t, data)\n89: \n90: \texpiryMembers, err := mr.ZMembers(\"session:expiry\")\n91: \trequire.NoError(t, err)\n92: \tassert.Contains(t, expiryMembers, \"sess-001\")\n93: \n94: \tactivityMembers, err := mr.ZMembers(\"session:last_activity\")\n95: \trequire.NoError(t, err)\n96: \tassert.Contains(t, activityMembers, \"sess-001\")\n97: }\n98: \n99: func TestRedisStore_StoreSandbox_RoundTrip(t *testing.T) {\n100: \tstore, _ := newTestRedisStore(t)\n101: \tctx := context.Background()\n102: \tinfo := testSandboxInfo(\"sess-002\")\n103: \n104: \terr := store.StoreSandbox(ctx, \"sess-002\", info)\n105: \trequire.NoError(t, err)\n106: \n107: \tresult, err := store.GetSandbox(ctx, \"sess-002\")\n108: \trequire.NoError(t, err)\n109: \trequire.NotNil(t, result)\n110: \n111: \tassert.Equal(t, info.SessionID, result.SessionID)\n112: \tassert.Equal(t, info.SandboxName, result.SandboxName)\n113: \tassert.Equal(t, info.SandboxID, result.SandboxID)\n114: \tassert.Equal(t, info.Namespace, result.Namespace)\n115: \tassert.Equal(t, info.Kind, result.Kind)\n116: \tassert.Equal(t, info.Status, result.Status)\n117: \tassert.Equal(t, info.PodIP, result.PodIP)\n118: \tassert.Len(t, result.EntryPoints, len(info.EntryPoints))\n119: }\n120: \n121: func TestRedisStore_UpdateSandbox_NilInfo(t *testing.T) {\n122: \tstore, _ := newTestRedisStore(t)\n123: \tctx := context.Background()\n124: \n125: \terr := store.UpdateSandbox(ctx, \"sess-001\", nil)\n126: \trequire.Error(t, err)\n127: \tassert.Contains(t, err.Error(), \"sandbox info cannot be nil\")\n128: }\n129: \n130: func TestRedisStore_UpdateSandbox_KeyNotExists(t *testing.T) {\n131: \tstore, _ := newTestRedisStore(t)\n132: \tctx := context.Background()\n133: \tinfo := testSandboxInfo(\"sess-003\")\n134: \n135: \terr := store.UpdateSandbox(ctx, \"sess-003\", info)\n136: \trequire.Error(t, err)\n137: \tassert.Contains(t, err.Error(), \"does not exist\")\n138: }\n139: \n140: func TestRedisStore_UpdateSandbox_Success(t *testing.T) {\n141: \tstore, _ := newTestRedisStore(t)\n142: \tctx := context.Background()\n143: \tinfo := testSandboxInfo(\"sess-004\")\n144: \n145: \terr := store.StoreSandbox(ctx, \"sess-004\", info)\n146: \trequire.NoError(t, err)\n147: \n148: \tupdated := *info\n149: \tupdated.Status = \"updated\"\n150: \tupdated.PodIP = \"10.0.0.2\"\n151: \n152: \terr = store.UpdateSandbox(ctx, \"sess-004\", &updated)\n153: \trequire.NoError(t, err)\n154: \n155: \tresult, err := store.GetSandbox(ctx, \"sess-004\")\n156: \trequire.NoError(t, err)\n157: \tassert.Equal