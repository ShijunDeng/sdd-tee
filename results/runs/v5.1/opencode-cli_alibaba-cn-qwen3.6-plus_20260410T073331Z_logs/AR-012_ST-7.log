3: \t\tlastActivityIndexKey: \"session:last_activity\",\n44: \t}\n45: \tctx := context.Background()\n46: \n47: \terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n48: \trequire.Error(t, err)\n49: \tassert.Contains(t, err.Error(), \"sessionID cannot be empty\")\n50: }\n51: \n52: func TestValkeyStore_ListExpiredSandboxes_LimitZero(t *testing.T) {\n53: \tstore := &valkeyStore{\n54: \t\tsessionPrefix:        \"session:\",\n55: \t\texpiryIndexKey:       \"session:expiry\",\n56: \t\tlastActivityIndexKey: \"session:last_activity\",\n57: \t}\n58: \tctx := context.Background()\n59: \n60: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n61: \trequire.NoError(t, err)\n62: \tassert.Nil(t, result)\n63: }\n64: \n65: func TestValkeyStore_ListExpiredSandboxes_LimitNegative(t *testing.T) {\n66: \tstore := &valkeyStore{\n67: \t\tsessionPrefix:        \"session:\",\n68: \t\texpiryIndexKey:       \"session:expiry\",\n69: \t\tlastActivityIndexKey: \"session:last_activity\",\n70: \t}\n71: \tctx := context.Background()\n72: \n73: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), -5)\n74: \trequire.NoError(t, err)\n75: \tassert.Nil(t, result)\n76: }\n77: \n78: func TestValkeyStore_ListInactiveSandboxes_LimitZero(t *testing.T) {\n79: \tstore := &valkeyStore{\n80: \t\tsessionPrefix:        \"session:\",\n81: \t\texpiryIndexKey:       \"session:expiry\",\n82: \t\tlastActivityIndexKey: \"session:last_activity\",\n83: \t}\n84: \tctx := context.Background()\n85: \n86: \tresult, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n87: \trequire.NoError(t, err)\n88: \tassert.Nil(t, result)\n89: }\n90: \n91: func TestValkeyStore_ListInactiveSandboxes_LimitNegative(t *testing.T) {\n92: \tstore := &valkeyStore{\n93: \t\tsessionPrefix:        \"session:\",\n94: \t\texpiryIndexKey:       \"session:expiry\",\n95: \t\tlastActivityIndexKey: \"session:last_activity\",\n96: \t}\n97: \tctx := context.Background()\n98: \n99: \tresult, err := store.ListInactiveSandboxes(ctx, time.Now(), -1)\n100: \trequire.NoError(t, err)\n101: \tassert.Nil(t, result)\n102: }\n103: \n104: func TestNewValkeyStore_MissingAddr(t *testing.T) {\n105: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n106: \toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n107: \toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n108: \tdefer func() {\n109: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n110: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n111: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n112: \t}()\n113: \n114: \tos.Unsetenv(\"VALKEY_ADDR\")\n115: \tos.Unsetenv(\"VALKEY_PASSWORD\")\n116: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n117: \n118: \tdefer func() {\n119: \t\tr := recover()\n120: \t\trequire.NotNil(t, r, \"expected panic from klog.Fatal when VALKEY_ADDR is missing\")\n121: \t}()\n122: \n123: \t_ = newValkeyStore()\n124: \tt.Fatal(\"expected panic but did not get one\")\n125: }\n126: \n127: func TestNewValkeyStore_MissingPassword(t *testing.T) {\n128: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n129: \toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n130: \toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n131: \tdefer func() {\n132: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n133: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n134: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n135: \t}()\n136: \n137: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n138: \tos.Unsetenv(\"VALKEY_PASSWORD\")\n139: \tos.Unsetenv(\"VALKEY_PASSWORD_REQUIRED\")\n140: \n141: \tdefer func() {\n142: \t\tr := recover()\n143: \t\trequire.NotNil(t, r, \"expected panic from klog.Fatal when password is required but missing\")\n144: \t}()\n145: \n146: \t_ = newValkeyStore()\n147: \tt.Fatal(\"expected panic but did not get one\")\n148: }\n149: \n150: func TestNewValkeyStore_PasswordNotRequired(t *testing.T) {\n151: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n152: \toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n153: \toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n154: \tdefer func() {\n155: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n156: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n157: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n158: \t}()\n159: \n160: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n161: \tos.Unsetenv(\"VALKEY_PASSWORD\")\n162: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n163: \n164: \tdefer func() {\n165: \t\tr := recover()\n166: \t\trequire.NotNil(t, r, \"expected panic from klog.Fatalf due to connection failure (no real server)\")\n167: \t}()\n168: \n169: \t_ = newValkeyStore()\n170: \tt.Fatal(\"expected panic but did not get one\")\n171: }\n172: \n173: func TestNewValkeyStore_DisableCache(t *testing.T) {\n174: \toriginalAddr := os.Getenv(\"VALKEY_ADDR\")\n175: \toriginalPwd := os.Getenv(\"VALKEY_PASSWORD\")\n176: \toriginalPwdReq := os.Getenv(\"VALKEY_PASSWORD_REQUIRED\")\n177: \toriginalDisableCache := os.Getenv(\"VALKEY_DISABLE_CACHE\")\n178: \toriginalForceSingle := os.Getenv(\"VALKEY_FORCE_SINGLE\")\n179: \tdefer func() {\n180: \t\tos.Setenv(\"VALKEY_ADDR\", originalAddr)\n181: \t\tos.Setenv(\"VALKEY_PASSWORD\", originalPwd)\n182: \t\tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", originalPwdReq)\n183: \t\tos.Setenv(\"VALKEY_DISABLE_CACHE\", originalDisableCache)\n184: \t\tos.Setenv(\"VALKEY_FORCE_SINGLE\", originalForceSingle)\n185: \t}()\n186: \n187: \tos.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n188: \tos.Unsetenv(\"VALKEY_PASSWORD\")\n189: \tos.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n190: \tos.Setenv(\"VALKEY_DISABLE_CACHE\", \"true\")\n191: \tos.Setenv(\"VALKEY_FORCE_SINGLE\", \"true\")\n192: \n193: \tdefer func() {\n194: \t\tr := recover()\n195: \t\trequire.NotNil(t, r, \"expected panic from klog.Fatalf due to connection failure (no real server)\")\n196: \t}()\n197: \n198: \t_ = newValkeyStore()\n199: \tt.Fatal(\"expected panic but did not get one\")\n200: }\n201: \n202: func TestValkeyStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n203: \tat := time.Time{}\n204: \tassert.True(t, at.IsZero())\n205: \n206: \tif at.IsZero() {\n207: \t\tat = time.Now()\n208: \t}\n209: \tassert.False(t, at.IsZero())\n210: \tassert.True(t, at.After(time.Now().Add(-time.Second)))\n211: }\n212: \n213: func TestValkeyStore_ListExpiredSandboxes_ScoreCalculation(t *testing.T) {\n214: \tbefore := time.Now().Add(-time.Hour)\n215: \texpectedMaxScore := before.Unix()\n216: \n217: \tassert.Equal(t, int64(-3600), expectedMaxScore)\n218: }\n219: \n220: func TestValkeyStore_ListInactiveSandboxes_ScoreCalculation(t *testing.T) {\n221: \tbefore := time.Now().Add(-2 * time.Hour)\n222: \texpectedMaxScore := before.Unix()\n223: \n224: \tassert.Equal(t, int64(-7200), expectedMaxScore)\n225: }\n226: \n227: func TestValkeyStore_StructFields(t *testing.T) {\n228: \tstore := &valkeyStore{\n229: \t\tsessionPrefix:        \"session:\",\n230: \t\texpiryIndexKey:       \"session:expiry\",\n231: \t\tlastActivityIndexKey: \"session:last_activity\",\n232: \t}\n233: \n234: \tassert.Equal(t, \"session:\", store.sessionPrefix)\n235: \tassert.Equal(t, \"session:expiry\", store.expiryIndexKey)\n236: \tassert.Equal(t, \"session:last_activity\", store.lastActivityIndexKey)\n237: }\n238: \n239: func TestValkeyStore_InterfaceCompliance(t *testing.T) {\n240: \tvar _ Store = (*valkeyStore)(nil)\n241: }\n\n(End of file - total 241 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestValkeyStore_StoreSandbox_NilInfo(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}\n\tctx := context.Background()\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pk