{"type":"tool_use","timestamp":1775835773332,"sessionID":"ses_287f3c6b0ffeDZ0hfYvo2PU9oI","part":{"id":"prt_d780f752b001wjkVQ4uWRcYgkr","messageID":"msg_d780f6b2c0014y3ZERibiIUeNX","sessionID":"ses_287f3c6b0ffeDZ0hfYvo2PU9oI","type":"tool","tool":"read","callID":"call_c11dfaf48a8d44388c7e9ae5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis_test.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"os\"\n6: \t\"testing\"\n7: \t\"time\"\n8: \n9: \t\"github.com/alicebob/miniredis/v2\"\n10: \t\"github.com/redis/go-redis/v9\"\n11: \t\"github.com/stretchr/testify/assert\"\n12: \t\"github.com/stretchr/testify/require\"\n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: )\n15: \n16: func newTestRedisStore(t *testing.T) (*redisStore, *miniredis.Miniredis) {\n17: \tt.Helper()\n18: \tmr, err := miniredis.Run()\n19: \trequire.NoError(t, err)\n20: \tt.Cleanup(func() { mr.Close() })\n21: \n22: \tcli := redis.NewClient(&redis.Options{\n23: \t\tAddr: mr.Addr(),\n24: \t})\n25: \tt.Cleanup(func() { cli.Close() })\n26: \n27: \treturn &redisStore{\n28: \t\tcli:                  cli,\n29: \t\tsessionPrefix:        \"session:\",\n30: \t\texpiryIndexKey:       \"session:expiry\",\n31: \t\tlastActivityIndexKey: \"session:last_activity\",\n32: \t}, mr\n33: }\n34: \n35: func testSandboxInfo(sessionID string) *types.SandboxInfo {\n36: \tnow := time.Now().UTC()\n37: \treturn &types.SandboxInfo{\n38: \t\tSessionID:      sessionID,\n39: \t\tSandboxName:    \"test-sandbox\",\n40: \t\tSandboxID:      \"sb-123\",\n41: \t\tWorkloadName:   \"agent-runtime\",\n42: \t\tNamespace:      \"default\",\n43: \t\tKind:           \"AgentRuntime\",\n44: \t\tPodIP:          \"10.0.0.1\",\n45: \t\tEntryPoints:    []types.EntryPoint{{Path: \"/api\", Protocol: \"http\", Endpoint: \"http://10.0.0.1:8080\"}},\n46: \t\tCreatedAt:      now,\n47: \t\tExpiresAt:      now.Add(24 * time.Hour),\n48: \t\tStatus:         \"running\",\n49: \t\tLastActivityAt: now.Add(5 * time.Minute),\n50: \t}\n51: }\n52: \n53: func TestRedisStore_Ping(t *testing.T) {\n54: \tstore, _ := newTestRedisStore(t)\n55: \tctx := context.Background()\n56: \n57: \terr := store.Ping(ctx)\n58: \trequire.NoError(t, err)\n59: }\n60: \n61: func TestRedisStore_GetSandbox_NotFound(t *testing.T) {\n62: \tstore, _ := newTestRedisStore(t)\n63: \tctx := context.Background()\n64: \n65: \tresult, err := store.GetSandbox(ctx, \"nonexistent\")\n66: \tassert.ErrorIs(t, err, ErrNotFound)\n67: \tassert.Nil(t, result)\n68: }\n69: \n70: func TestRedisStore_StoreSandbox_NilInfo(t *testing.T) {\n71: \tstore, _ := newTestRedisStore(t)\n72: \tctx := context.Background()\n73: \n74: \terr := store.StoreSandbox(ctx, \"sess-001\", nil)\n75: \trequire.Error(t, err)\n76: \tassert.Contains(t, err.Error(), \"sandbox is nil\")\n77: }\n78: \n79: func TestRedisStore_StoreSandbox_Success(t *testing.T) {\n80: \tstore, mr := newTestRedisStore(t)\n81: \tctx := context.Background()\n82: \tinfo := testSandboxInfo(\"sess-001\")\n83: \n84: \terr := store.StoreSandbox(ctx, \"sess-001\", info)\n85: \trequire.NoError(t, err)\n86: \n87: \tdata, err := mr.Get(\"session:sess-001\")\n88: \trequire.NoError(t, err)\n89: \trequire.NotEmpty(t, data)\n90: \n91: \texpiryMembers, err := mr.ZMembers(\"session:expiry\")\n92: \trequire.NoError(t, err)\n93: \tassert.Contains(t, expiryMembers, \"sess-001\")\n94: \n95: \tactivityMembers, err := mr.ZMembers(\"session:last_activity\")\n96: \trequire.NoError(t, err)\n97: \tassert.Contains(t, activityMembers, \"sess-001\")\n98: }\n99: \n100: func TestRedisStore_StoreSandbox_RoundTrip(t *testing.T) {\n101: \tstore, _ := newTestRedisStore(t)\n102: \tctx := context.Background()\n103: \tinfo := testSandboxInfo(\"sess-002\")\n104: \n105: \terr := store.StoreSandbox(ctx, \"sess-002\", info)\n106: \trequire.NoError(t, err)\n107: \n108: \tresult, err := store.GetSandbox(ctx, \"sess-002\")\n109: \trequire.NoError(t, err)\n110: \trequire.NotNil(t, result)\n111: \n112: \tassert.Equal(t, info.SessionID, result.SessionID)\n113: \tassert.Equal(t, info.SandboxName, result.SandboxName)\n114: \tassert.Equal(t, info.SandboxID, result.SandboxID)\n115: \tassert.Equal(t, info.Namespace, result.Namespace)\n116: \tassert.Equal(t, info.Kind, result.Kind)\n117: \tassert.Equal(t, info.Status, result.Status)\n118: \tassert.Equal(t, info.PodIP, result.PodIP)\n119: \tassert.Len(t, result.EntryPoints, len(info.EntryPoints))\n120: }\n121: \n122: func TestRedisStore_UpdateSandbox_NilInfo(t *testing.T) {\n123: \tstore, _ := newTestRedisStore(t)\n124: \tctx := context.Background()\n125: \n126: \terr := store.UpdateSandbox(ctx, \"sess-001\", nil)\n127: \trequire.Error(t, err)\n128: \tassert.Contains(t, err.Error(), \"sandbox is nil\")\n129: }\n130: \n131: func TestRedisStore_UpdateSandbox_KeyNotExists(t *testing.T) {\n132: \tstore, _ := newTestRedisStore(t)\n133: \tctx := context.Background()\n134: \tinfo := testSandboxInfo(\"sess-003\")\n135: \n136: \terr := store.UpdateSandbox(ctx, \"sess-003\", info)\n137: \trequire.Error(t, err)\n138: \tassert.Contains(t, err.Error(), \"key not exists\")\n139: }\n140: \n141: func TestRedisStore_UpdateSandbox_Success(t *testing.T) {\n142: \tstore, _ := newTestRedisStore(t)\n143: \tctx := context.Background()\n144: \tinfo := testSandboxInfo(\"sess-004\")\n145: \n146: \terr := store.StoreSandbox(ctx, \"sess-004\", info)\n147: \trequire.NoError(t, err)\n148: \n149: \tupdated := *info\n150: \tupdated.Status = \"updated\"\n151: \tupdated.PodIP = \"10.0.0.2\"\n152: \n153: \terr = store.UpdateSandbox(ctx, \"sess-004\", &updated)\n154: \trequire.NoError(t, err)\n155: \n156: \tresult, err := store.GetSandbox(ctx, \"sess-004\")\n157: \trequire.NoError(t, err)\n158: \tassert.Equal(t, \"updated\", result.Status)\n159: \tassert.Equal(t, \"10.0.0.2\", result.PodIP)\n160: }\n161: \n162: func TestRedisStore_DeleteSandboxBySessionID(t *testing.T) {\n163: \tstore, mr := newTestRedisStore(t)\n164: \tctx := context.Background()\n165: \tinfo := testSandboxInfo(\"sess-005\")\n166: \n167: \terr := store.StoreSandbox(ctx, \"sess-005\", info)\n168: \trequire.NoError(t, err)\n169: \n170: \terr = store.DeleteSandboxBySessionID(ctx, \"sess-005\")\n171: \trequire.NoError(t, err)\n172: \n173: \tresult, err := store.GetSandbox(ctx, \"sess-005\")\n174: \tassert.ErrorIs(t, err, ErrNotFound)\n175: \tassert.Nil(t, result)\n176: \n177: \texists := mr.Exists(\"session:sess-005\")\n178: \tassert.False(t, exists)\n179: \n180: \texpiryMembers, err := mr.ZMembers(\"session:expiry\")\n181: \trequire.NoError(t, err)\n182: \tassert.NotContains(t, expiryMembers, \"sess-005\")\n183: \n184: \tactivityMembers, err := mr.ZMembers(\"session:last_activity\")\n185: \trequire.NoError(t, err)\n186: \tassert.NotContains(t, activityMembers, \"sess-005\")\n187: }\n188: \n189: func TestRedisStore_ListSandboxes(t *testing.T) {\n190: \tstore, _ := newTestRedisStore(t)\n191: \tctx := context.Background()\n192: \n193: \tinfo1 := testSandboxInfo(\"sess-010\")\n194: \tinfo2 := testSandboxInfo(\"sess-011\")\n195: \n196: \terr := store.StoreSandbox(ctx, \"sess-010\", info1)\n197: \trequire.NoError(t, err)\n198: \terr = store.StoreSandbox(ctx, \"sess-011\", info2)\n199: \trequire.NoError(t, err)\n200: \n201: \tresult, err := store.ListSandboxes(ctx)\n202: \trequire.NoError(t, err)\n203: \tassert.Len(t, result, 2)\n204: \tassert.Contains(t, result, \"sess-010\")\n205: \tassert.Contains(t, result, \"sess-011\")\n206: }\n207: \n208: func TestRedisStore_ListSandboxes_OrphanZSETMember(t *testing.T) {\n209: \tstore, mr := newTestRedisStore(t)\n210: \tctx := context.Background()\n211: \n212: \tinfo := testSandboxInfo(\"sess-020\")\n213: \terr := store.StoreSandbox(ctx, \"sess-020\", info)\n214: \trequire.NoError(t, err)\n215: \n216: \tmr.Del(\"session:sess-020\")\n217: \n218: \tresult, err := store.ListSandboxes(ctx)\n219: \trequire.NoError(t, err)\n220: \tassert.Len(t, result, 0)\n221: }\n222: \n223: func TestRedisStore_ListSandboxes_Empty(t *testing.T) {\n224: \tstore, _ := newTestRedisStore(t)\n225: \tctx := context.Background()\n226: \n227: \tresult, err := store.ListSandboxes(ctx)\n228: \trequire.NoError(t, err)\n229: \tassert.Empty(t, result)\n230: }\n231: \n232: func TestRedisStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n233: \tstore, _ := newTestRedisStore(t)\n234: \tctx := context.Background()\n235: \n236: \terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n237: \trequire.Error(t, err)\n238: \tassert.Contains(t, err.Error(), \"sessionID cannot be empty\")\n239: }\n240: \n241: func TestRedisStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n242: \tstore, mr := newTestRedisStore(t)\n243: \tctx := context.Background()\n244: \tinfo := testSandboxInfo(\"sess-030\")\n245: \n246: \terr := store.StoreSandbox(ctx, \"sess-030\", info)\n247: \trequire.NoError(t, err)\n248: \n249: \tbefore := time.Now()\n250: \terr = store.UpdateSessionLastActivity(ctx, \"sess-030\", time.Time{})\n251: \trequire.NoError(t, err)\n252: \n253: \tscore, err := mr.ZScore(\"session:last_activity\", \"sess-030\")\n254: \trequire.NoError(t, err)\n255: \tassert.GreaterOrEqual(t, score, float64(before.Unix()))\n256: }\n257: \n258: func TestRedisStore_UpdateSessionLastActivity_NotFound(t *testing.T) {\n259: \tstore, _ := newTestRedisStore(t)\n260: \tctx := context.Background()\n261: \n262: \terr := store.UpdateSessionLastActivity(ctx, \"nonexistent\", time.Now())\n263: \tassert.ErrorIs(t, err, ErrNotFound)\n264: }\n265: \n266: func TestRedisStore_UpdateSessionLastActivity_Success(t *testing.T) {\n267: \tstore, mr := newTestRedisStore(t)\n268: \tctx := context.Background()\n269: \tinfo := testSandboxInfo(\"sess-031\")\n270: \n271: \terr := store.StoreSandbox(ctx, \"sess-031\", info)\n272: \trequire.NoError(t, err)\n273: \n274: \tnewTime := time.Now().Add(10 * time.Minute)\n275: \terr = store.UpdateSessionLastActivity(ctx, \"sess-031\", newTime)\n276: \trequire.NoError(t, err)\n277: \n278: \tscore, err := mr.ZScore(\"session:last_activity\", \"sess-031\")\n279: \trequire.NoError(t, err)\n280: \tassert.Equal(t, float64(newTime.Unix()), score)\n281: }\n282: \n283: func TestRedisStore_ListExpiredSandboxes_LimitZero(t *testing.T) {\n284: \tstore, _ := newTestRedisStore(t)\n285: \tctx := context.Background()\n286: \n287: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n288: \trequire.NoError(t, err)\n289: \tassert.Nil(t, result)\n290: }\n291: \n292: func TestRedisStore_ListExpiredSandboxes_LimitNegative(t *testing.T) {\n293: \tstore, _ := newTestRedisStore(t)\n294: \tctx := context.Background()\n295: \n296: \tresult, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n297: \trequire.NoError(t, err)\n298: \tassert.Nil(t, result)\n299: }\n300: \n301: func TestRedisStore_ListExpiredSandboxes(t *testing.T) {\n302: \tstore, _ := newTestRedisStore(t)\n303: \tctx := context.Background()\n304: \tnow := time.Now().UTC()\n305: \n306: \texpired := testSandboxInfo(\"sess-expired\")\n307: \texpired.ExpiresAt = now.Add(-2 * time.Hour)\n308: \terr := store.StoreSandbox(ctx, \"sess-expired\", expired)\n309: \trequire.NoError(t, err)\n310: \n311: \tactive := testSandboxInfo(\"sess-active\")\n312: \tactive.ExpiresAt = now.Add(2 * time.Hour)\n313: \terr = store.StoreSandbox(ctx, \"sess-active\", active)\n314: \trequire.NoError(t, err)\n315: \n316: \tresult, err := store.ListExpiredSandboxes(ctx, now, 10)\n317: \trequire.NoError(t, err)\n318: \trequire.Len(t, result, 1)\n319: \tassert.Equal(t, \"sess-expired\", result[0].SessionID)\n320: }\n321: \n322: func TestRedisStore_ListExpiredSandboxes_Limit(t *testing.T) {\n323: \tstore, _ := newTestRedisStore(t)\n324: \tctx := context.Background()\n325: \tnow := time.Now().UTC()\n326: \n327: \tfor i := 0; i < 5; i++ {\n328: \t\tinfo := testSandboxInfo(\"sess-exp-\" + string(rune('0'+i)))\n329: \t\tinfo.ExpiresAt = now.Add(-time.Duration(i+1) * time.Hour)\n330: \t\terr := store.StoreSandbox(ctx, \"sess-exp-\"+string(rune('0'+i)), info)\n331: \t\trequire.NoError(t, err)\n332: \t}\n333: \n334: \tresult, err := store.ListExpiredSandboxes(ctx, now, 3)\n335: \trequire.NoError(t, err)\n336: \tassert.LessOrEqual(t, len(result), 3)\n337: }\n338: \n339: func TestRedisStore_ListExpiredSandboxes_OrphanMember(t *testing.T) {\n340: \tstore, mr := newTestRedisStore(t)\n341: \tctx := context.Background()\n342: \tnow := time.Now().UTC()\n343: \n344: \tinfo := testSandboxInfo(\"sess-orphan-exp\")\n345: \tinfo.ExpiresAt = now.Add(-time.Hour)\n346: \terr := store.StoreSandbox(ctx, \"sess-orphan-exp\", info)\n347: \trequire.NoError(t, err)\n348: \n349: \tmr.Del(\"session:sess-orphan-exp\")\n350: \n351: \tresult, err := store.ListExpiredSandboxes(ctx, now.Add(time.Hour), 10)\n352: \trequire.NoError(t, err)\n353: \tassert.Len(t, result, 0)\n354: }\n355: \n356: func TestRedisStore_ListInactiveSandboxes_LimitZero(t *testing.T) {\n357: \tstore, _ := newTestRedisStore(t)\n358: \tctx := context.Background()\n359: \n360: \tresult, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n361: \trequire.NoError(t, err)\n362: \tassert.Nil(t, result)\n363: }\n364: \n365: func TestRedisStore_ListInactiveSandboxes(t *testing.T) {\n366: \tstore, _ := newTestRedisStore(t)\n367: \tctx := context.Background()\n368: \tnow := time.Now().UTC()\n369: \n370: \tinactive := testSandboxInfo(\"sess-inactive\")\n371: \tinactive.LastActivityAt = now.Add(-2 * time.Hour)\n372: \terr := store.StoreSandbox(ctx, \"sess-inactive\", inactive)\n373: \trequire.NoError(t, err)\n374: \n375: \tactive := testSandboxInfo(\"sess-active-2\")\n376: \tactive.LastActivityAt = now.Add(-5 * time.Minute)\n377: \terr = store.StoreSandbox(ctx, \"sess-active-2\", active)\n378: \trequire.NoError(t, err)\n379: \n380: \tresult, err := store.ListInactiveSandboxes(ctx, now, 10)\n381: \trequire.NoError(t, err)\n382: \trequire.Len(t, result, 1)\n383: \tassert.Equal(t, \"sess-inactive\", result[0].SessionID)\n384: }\n385: \n386: func TestRedisStore_ListInactiveSandboxes_OrphanMember(t *testing.T) {\n387: \tstore, mr := newTestRedisStore(t)\n388: \tctx := context.Background()\n389: \tnow := time.Now().UTC()\n390: \n391: \tinfo := testSandboxInfo(\"sess-orphan-inactive\")\n392: \tinfo.LastActivityAt = now.Add(-time.Hour)\n393: \terr := store.StoreSandbox(ctx, \"sess-orphan-inactive\", info)\n394: \trequire.NoError(t, err)\n395: \n396: \tmr.Del(\"session:sess-orphan-inactive\")\n397: \n398: \tresult, err := store.ListInactiveSandboxes(ctx, now.Add(time.Hour), 10)\n399: \trequire.NoError(t, err)\n400: \tassert.Len(t, result, 0)\n401: }\n402: \n403: func TestRedisStore_Close(t *testing.T) {\n404: \tstore, mr := newTestRedisStore(t)\n405: \n406: \terr := store.Close()\n407: \trequire.NoError(t, err)\n408: \n409: \tmr.Close()\n410: }\n411: \n412: func TestRedisStore_ErrNotFound_Is(t *testing.T) {\n413: \tstore, _ := newTestRedisStore(t)\n414: \tctx := context.Background()\n415: \n416: \t_, err := store.GetSandbox(ctx, \"nonexistent\")\n417: \tassert.ErrorIs(t, err, ErrNotFound)\n418: }\n419: \n420: func TestRedisStore_MultipleSandboxes(t *testing.T) {\n421: \tstore, _ := newTestRedisStore(t)\n422: \tctx := context.Background()\n423: \n424: \tsessions := []string{\"multi-01\", \"multi-02\", \"multi-03\"}\n425: \tfor _, sid := range sessions {\n426: \t\tinfo := testSandboxInfo(sid)\n427: \t\terr := store.StoreSandbox(ctx, sid, info)\n428: \t\trequire.NoError(t, err)\n429: \t}\n430: \n431: \tresult, err := store.ListSandboxes(ctx)\n432: \trequire.NoError(t, err)\n433: \tassert.Len(t, result, 3)\n434: \n435: \tfor _, sid := range sessions {\n436: \t\tsandbox, err := store.GetSandbox(ctx, sid)\n437: \t\trequire.NoError(t, err)\n438: \t\tassert.Equal(t, sid, sandbox.SessionID)\n439: \t}\n440: }\n441: \n442: func TestRedisStore_StoreSandbox_ZeroExpiry(t *testing.T) {\n443: \tstore, _ := newTestRedisStore(t)\n444: \tctx := context.Background()\n445: \tinfo := testSandboxInfo(\"sess-zero-expiry\")\n446: \tinfo.ExpiresAt = time.Time{}\n447: \n448: \terr := store.StoreSandbox(ctx, \"sess-zero-expiry\", info)\n449: \trequire.Error(t, err)\n450: \tassert.Contains(t, err.Error(), \"ExpiresAt is zero\")\n451: }\n452: \n453: func TestRedisStore_GetSandbox_Found(t *testing.T) {\n454: \tstore, _ := newTestRedisStore(t)\n455: \tctx := context.Background()\n456: \tinfo := testSandboxInfo(\"sess-found\")\n457: \n458: \terr := store.StoreSandbox(ctx, \"sess-found\", info)\n459: \trequire.NoError(t, err)\n460: \n461: \tresult, err := store.GetSandbox(ctx, \"sess-found\")\n462: \trequire.NoError(t, err)\n463: \trequire.NotNil(t, result)\n464: \tassert.Equal(t, \"sess-found\", result.SessionID)\n465: }\n466: \n467: func TestRedisStore_DeleteSandboxBySessionID_NonExistent(t *testing.T) {\n468: \tstore, _ := newTestRedisStore(t)\n469: \tctx := context.Background()\n470: \n471: \terr := store.DeleteSandboxBySessionID(ctx, \"ghost\")\n472: \trequire.NoError(t, err)\n473: }\n474: \n475: func TestRedisStore_SessionKey(t *testing.T) {\n476: \tstore, _ := newTestRedisStore(t)\n477: \tkey := store.sessionKey(\"abc\")\n478: \tassert.Equal(t, \"session:abc\", key)\n479: }\n480: \n481: func TestRedisStore_ListExpiredSandboxes_OrphanZSETMember(t *testing.T) {\n482: \tstore, mr := newTestRedisStore(t)\n483: \tctx := context.Background()\n484: \tnow := time.Now().UTC()\n485: \n486: \tmr.ZAdd(\"session:expiry\", float64(now.Add(-1*time.Hour).Unix()), \"orphan-session\")\n487: \n488: \tresult, err := store.ListExpiredSandboxes(ctx, now, 10)\n489: \trequire.NoError(t, err)\n490: \tassert.Empty(t, result)\n491: }\n492: \n493: func TestRedisStore_ListInactiveSandboxes_OrphanZSETMember(t *testing.T) {\n494: \tstore, mr := newTestRedisStore(t)\n495: \tctx := context.Background()\n496: \tnow := time.Now().UTC()\n497: \n498: \tmr.ZAdd(\"session:last_activity\", float64(now.Add(-1*time.Hour).Unix()), \"orphan-inactive\")\n499: \n500: \tresult, err := store.ListInactiveSandboxes(ctx, now, 10)\n501: \trequire.NoError(t, err)\n502: \tassert.Empty(t, result)\n503: }\n504: \n505: func TestNewRedisStore_MissingAddr(t *testing.T) {\n506: \toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n507: \toriginalPwd := os.Getenv(\"REDIS_PASSWORD\")\n508: \toriginalPwdReq := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n509: \tdefer func() {\n510: \t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n511: \t\tos.Setenv(\"REDIS_PASSWORD\", originalPwd)\n512: \t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalPwdReq)\n513: \t}()\n514: \n515: \tos.Unsetenv(\"REDIS_ADDR\")\n516: \tos.Unsetenv(\"REDIS_PASSWORD\")\n517: \tos.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n518: \n519: \t_, err := newRedisStore()\n520: \trequire.Error(t, err)\n521: \tassert.Contains(t, err.Error(), \"REDIS_ADDR is required\")\n522: }\n523: \n524: func TestNewRedisStore_MissingPassword(t *testing.T) {\n525: \toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n526: \toriginalPwd := os.Getenv(\"REDIS_PASSWORD\")\n527: \toriginalPwdReq := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n528: \tdefer func() {\n529: \t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n530: \t\tos.Setenv(\"REDIS_PASSWORD\", originalPwd)\n531: \t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalPwdReq)\n532: \t}()\n533: \n534: \tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n535: \tos.Unsetenv(\"REDIS_PASSWORD\")\n536: \tos.Unsetenv(\"REDIS_PASSWORD_REQUIRED\")\n537: \n538: \t_, err := newRedisStore()\n539: \trequire.Error(t, err)\n540: \tassert.Contains(t, err.Error(), \"REDIS_PASSWORD is required\")\n541: }\n542: \n543: func TestNewRedisStore_PasswordNotRequired(t *testing.T) {\n544: \toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n545: \toriginalPwd := os.Getenv(\"REDIS_PASSWORD\")\n546: \toriginalPwdReq := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n547: \tdefer func() {\n548: \t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n549: \t\tos.Setenv(\"REDIS_PASSWORD\", originalPwd)\n550: \t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalPwdReq)\n551: \t}()\n552: \n553: \tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n554: \tos.Unsetenv(\"REDIS_PASSWORD\")\n555: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n556: \n557: \tstore, err := newRedisStore()\n558: \trequire.NoError(t, err)\n559: \trequire.NotNil(t, store)\n560: }\n561: \n562: func TestNewRedisStore_PasswordRequiredTrue(t *testing.T) {\n563: \toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n564: \toriginalPwd := os.Getenv(\"REDIS_PASSWORD\")\n565: \toriginalPwdReq := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n566: \tdefer func() {\n567: \t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n568: \t\tos.Setenv(\"REDIS_PASSWORD\", originalPwd)\n569: \t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalPwdReq)\n570: \t}()\n571: \n572: \tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n573: \tos.Unsetenv(\"REDIS_PASSWORD\")\n574: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"true\")\n575: \n576: \t_, err := newRedisStore()\n577: \trequire.Error(t, err)\n578: \tassert.Contains(t, err.Error(), \"REDIS_PASSWORD is required\")\n579: }\n580: \n581: func TestRedisStore_InterfaceCompliance(t *testing.T) {\n582: \tvar _ Store = (*redisStore)(nil)\n583: }\n\n(End of file - total 583 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc newTestRedisStore(t *testing.T) (*redisStore, *miniredis.Miniredis) {\n\tt.Helper()\n\tmr, err := miniredis.Run()\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { mr.Close() })","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis_test.go","