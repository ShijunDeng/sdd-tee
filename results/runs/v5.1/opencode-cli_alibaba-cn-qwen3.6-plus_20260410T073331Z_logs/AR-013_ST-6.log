{"type":"tool_use","timestamp":1775835765812,"sessionID":"ses_287f3c6b0ffeDZ0hfYvo2PU9oI","part":{"id":"prt_d780f57f3001ehM5jMSuL1pQHf","messageID":"msg_d780f4ca3001Pnc0VHukmf3JNO","sessionID":"ses_287f3c6b0ffeDZ0hfYvo2PU9oI","type":"tool","tool":"read","callID":"call_b7459845f218414c96b55870","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"errors\"\n6: \t\"fmt\"\n7: \t\"os\"\n8: \t\"strconv\"\n9: \t\"strings\"\n10: \t\"time\"\n11: \n12: \t\"github.com/redis/go-redis/v9\"\n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: )\n15: \n16: type redisStore struct {\n17: \tcli                  redis.UniversalClient\n18: \tsessionPrefix        string\n19: \texpiryIndexKey       string\n20: \tlastActivityIndexKey string\n21: }\n22: \n23: func newRedisStore() (Store, error) {\n24: \taddr := os.Getenv(\"REDIS_ADDR\")\n25: \tif addr == \"\" {\n26: \t\treturn nil, errors.New(\"REDIS_ADDR is required\")\n27: \t}\n28: \n29: \tpassword := os.Getenv(\"REDIS_PASSWORD\")\n30: \tpasswordRequired := strings.ToLower(os.Getenv(\"REDIS_PASSWORD_REQUIRED\"))\n31: \tif password == \"\" && passwordRequired != \"false\" {\n32: \t\treturn nil, errors.New(\"REDIS_PASSWORD is required (set REDIS_PASSWORD_REQUIRED=false to disable)\")\n33: \t}\n34: \n35: \topts := &redis.Options{\n36: \t\tAddr:     addr,\n37: \t\tPassword: password,\n38: \t}\n39: \n40: \tcli := redis.NewClient(opts)\n41: \n42: \treturn &redisStore{\n43: \t\tcli:                  cli,\n44: \t\tsessionPrefix:        \"session:\",\n45: \t\texpiryIndexKey:       \"session:expiry\",\n46: \t\tlastActivityIndexKey: \"session:last_activity\",\n47: \t}, nil\n48: }\n49: \n50: func (r *redisStore) Ping(ctx context.Context) error {\n51: \tpong, err := r.cli.Ping(ctx).Result()\n52: \tif err != nil {\n53: \t\treturn err\n54: \t}\n55: \tif pong != \"PONG\" {\n56: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", pong)\n57: \t}\n58: \treturn nil\n59: }\n60: \n61: func (r *redisStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n62: \tkey := r.sessionKey(sessionID)\n63: \tdata, err := r.cli.Get(ctx, key).Bytes()\n64: \tif err == redis.Nil {\n65: \t\treturn nil, ErrNotFound\n66: \t}\n67: \tif err != nil {\n68: \t\treturn nil, err\n69: \t}\n70: \treturn decodeSandboxInfo(data)\n71: }\n72: \n73: func (r *redisStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n74: \tif info == nil {\n75: \t\treturn errors.New(\"sandbox is nil\")\n76: \t}\n77: \tif info.ExpiresAt.IsZero() {\n78: \t\treturn errors.New(\"sandbox ExpiresAt is zero\")\n79: \t}\n80: \n81: \tdata, err := encodeSandboxInfo(info)\n82: \tif err != nil {\n83: \t\treturn fmt.Errorf(\"marshal sandbox: %w\", err)\n84: \t}\n85: \n86: \tkey := r.sessionKey(sessionID)\n87: \tnow := float64(time.Now().Unix())\n88: \texpiryScore := float64(info.ExpiresAt.Unix())\n89: \n90: \tpipe := r.cli.Pipeline()\n91: \tpipe.SetNX(ctx, key, data, 0)\n92: \tpipe.ZAdd(ctx, r.expiryIndexKey, redis.Z{Score: expiryScore, Member: sessionID})\n93: \tpipe.ZAdd(ctx, r.lastActivityIndexKey, redis.Z{Score: now, Member: sessionID})\n94: \n95: \t_, err = pipe.Exec(ctx)\n96: \treturn err\n97: }\n98: \n99: func (r *redisStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n100: \tif info == nil {\n101: \t\treturn errors.New(\"sandbox is nil\")\n102: \t}\n103: \n104: \tdata, err := encodeSandboxInfo(info)\n105: \tif err != nil {\n106: \t\treturn fmt.Errorf(\"marshal sandbox: %w\", err)\n107: \t}\n108: \n109: \tkey := r.sessionKey(sessionID)\n110: \tok, err := r.cli.SetXX(ctx, key, data, 0).Result()\n111: \tif err != nil {\n112: \t\treturn err\n113: \t}\n114: \tif !ok {\n115: \t\treturn fmt.Errorf(\"key not exists: %s\", key)\n116: \t}\n117: \treturn nil\n118: }\n119: \n120: func (r *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n121: \tkey := r.sessionKey(sessionID)\n122: \n123: \tpipe := r.cli.Pipeline()\n124: \tpipe.Del(ctx, key)\n125: \tpipe.ZRem(ctx, r.expiryIndexKey, sessionID)\n126: \tpipe.ZRem(ctx, r.lastActivityIndexKey, sessionID)\n127: \n128: \t_, err := pipe.Exec(ctx)\n129: \treturn err\n130: }\n131: \n132: func (r *redisStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n133: \tsessionIDs, err := r.cli.ZRange(ctx, r.expiryIndexKey, 0, -1).Result()\n134: \tif err != nil {\n135: \t\treturn nil, err\n136: \t}\n137: \n138: \treturn r.loadSandboxesBySessionIDsAsMap(ctx, sessionIDs)\n139: }\n140: \n141: func (r *redisStore) loadSandboxesBySessionIDsAsMap(ctx context.Context, sessionIDs []string) (map[string]*types.SandboxInfo, error) {\n142: \tif len(sessionIDs) == 0 {\n143: \t\treturn make(map[string]*types.SandboxInfo), nil\n144: \t}\n145: \n146: \tkeys := make([]string, len(sessionIDs))\n147: \tfor i, id := range sessionIDs {\n148: \t\tkeys[i] = r.sessionKey(id)\n149: \t}\n150: \n151: \tresults, err := r.cli.MGet(ctx, keys...).Result()\n152: \tif err != nil {\n153: \t\treturn nil, err\n154: \t}\n155: \n156: \tresult := make(map[string]*types.SandboxInfo)\n157: \tfor i, raw := range results {\n158: \t\tif raw == nil {\n159: \t\t\tcontinue\n160: \t\t}\n161: \t\tdata, ok := raw.(string)\n162: \t\tif !ok || data == \"\" {\n163: \t\t\tcontinue\n164: \t\t}\n165: \t\tinfo, err := decodeSandboxInfo([]byte(data))\n166: \t\tif err != nil {\n167: \t\t\treturn nil, fmt.Errorf(\"unmarshal sandbox: %w\", err)\n168: \t\t}\n169: \t\tresult[sessionIDs[i]] = info\n170: \t}\n171: \treturn result, nil\n172: }\n173: \n174: func (r *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n175: \tif sessionID == \"\" {\n176: \t\treturn errors.New(\"sessionID is empty\")\n177: \t}\n178: \tif at.IsZero() {\n179: \t\tat = time.Now()\n180: \t}\n181: \n182: \tkey := r.sessionKey(sessionID)\n183: \texists, err := r.cli.Exists(ctx, key).Result()\n184: \tif err != nil {\n185: \t\treturn err\n186: \t}\n187: \tif exists == 0 {\n188: \t\treturn ErrNotFound\n189: \t}\n190: \n191: \treturn r.cli.ZAdd(ctx, r.lastActivityIndexKey, redis.Z{\n192: \t\tScore:  float64(at.Unix()),\n193: \t\tMember: sessionID,\n194: \t}).Err()\n195: }\n196: \n197: func (r *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n198: \tif limit <= 0 {\n199: \t\treturn nil, nil\n200: \t}\n201: \n202: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n203: \tsessionIDs, err := r.cli.ZRangeByScore(ctx, r.expiryIndexKey, &redis.ZRangeBy{\n204: \t\tMin:    \"-inf\",\n205: \t\tMax:    maxScore,\n206: \t\tOffset: 0,\n207: \t\tCount:  int64(limit),\n208: \t}).Result()\n209: \tif err != nil {\n210: \t\treturn nil, err\n211: \t}\n212: \n213: \treturn r.loadSandboxesBySessionIDs(ctx, sessionIDs)\n214: }\n215: \n216: func (r *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n217: \tif limit <= 0 {\n218: \t\treturn nil, nil\n219: \t}\n220: \n221: \tmaxScore := strconv.FormatInt(before.Unix(), 10)\n222: \tsessionIDs, err := r.cli.ZRangeByScore(ctx, r.lastActivityIndexKey, &redis.ZRangeBy{\n223: \t\tMin:    \"-inf\",\n224: \t\tMax:    maxScore,\n225: \t\tOffset: 0,\n226: \t\tCount:  int64(limit),\n227: \t}).Result()\n228: \tif err != nil {\n229: \t\treturn nil, err\n230: \t}\n231: \n232: \treturn r.loadSandboxesBySessionIDs(ctx, sessionIDs)\n233: }\n234: \n235: func (r *redisStore) loadSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n236: \tif len(sessionIDs) == 0 {\n237: \t\treturn nil, nil\n238: \t}\n239: \n240: \tkeys := make([]string, len(sessionIDs))\n241: \tfor i, id := range sessionIDs {\n242: \t\tkeys[i] = r.sessionKey(id)\n243: \t}\n244: \n245: \tresults, err := r.cli.MGet(ctx, keys...).Result()\n246: \tif err != nil {\n247: \t\treturn nil, err\n248: \t}\n249: \n250: \tvar sandboxes []*types.SandboxInfo\n251: \tfor _, raw := range results {\n252: \t\tif raw == nil {\n253: \t\t\tcontinue\n254: \t\t}\n255: \t\tdata, ok := raw.(string)\n256: \t\tif !ok || data == \"\" {\n257: \t\t\tcontinue\n258: \t\t}\n259: \t\tinfo, err := decodeSandboxInfo([]byte(data))\n260: \t\tif err != nil {\n261: \t\t\treturn nil, fmt.Errorf(\"unmarshal sandbox: %w\", err)\n262: \t\t}\n263: \t\tsandboxes = append(sandboxes, info)\n264: \t}\n265: \treturn sandboxes, nil\n266: }\n267: \n268: func (r *redisStore) sessionKey(sessionID string) string {\n269: \treturn r.sessionPrefix + sessionID\n270: }\n271: \n272: func (r *redisStore) Close() error {\n273: \treturn r.cli.Close()\n274: }\n\n(End of file - total 274 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype redisStore struct {\n\tcli                  redis.UniversalClient\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/store_redis.go","time":{"start":1775835765804,"end":1775835765811}}}}
