tRuntime, 0, len(items)),\n163: \t}\n164: \tfor _, obj := range items {\n165: \t\tif ar, ok := obj.(*v1alpha1.AgentRuntime); ok {\n166: \t\t\tresult.Items = append(result.Items, *ar.DeepCopy())\n167: \t\t}\n168: \t}\n169: \treturn result, nil\n170: }\n171: \n172: func (c *AgentRuntimeClient) Watch(ctx context.Context, opts metav1.ListOptions) (watch.Interface, error) {\n173: \treturn watch.NewFake(), nil\n174: }\n175: \n176: func (c *AgentRuntimeClient) Patch(ctx context.Context, name string, pt types.PatchType, data []byte, opts metav1.PatchOptions, subresources ...string) (*v1alpha1.AgentRuntime, error) {\n177: \tobj, ok := c.store.Get(c.ns, name)\n178: \tif !ok {\n179: \t\treturn nil, apierrors.NewNotFound(v1alpha1.SchemeGroupVersion.WithResource(\"agentruntimes\").GroupResource(), name)\n180: \t}\n181: \treturn obj.(*v1alpha1.AgentRuntime).DeepCopy(), nil\n182: }\n183: \n184: type CodeInterpreterClient struct {\n185: \tstore *ObjectStore\n186: \tns    string\n187: }\n188: \n189: func NewCodeInterpreterClient(store *ObjectStore, namespace string) *CodeInterpreterClient {\n190: \treturn &CodeInterpreterClient{store: store, ns: namespace}\n191: }\n192: \n193: func (c *CodeInterpreterClient) Create(ctx context.Context, ci *v1alpha1.CodeInterpreter, opts metav1.CreateOptions) (*v1alpha1.CodeInterpreter, error) {\n194: \tobj := ci.DeepCopy()\n195: \tif err := c.store.Create(obj); err != nil {\n196: \t\treturn nil, err\n197: \t}\n198: \treturn obj, nil\n199: }\n200: \n201: func (c *CodeInterpreterClient) Update(ctx context.Context, ci *v1alpha1.CodeInterpreter, opts metav1.UpdateOptions) (*v1alpha1.CodeInterpreter, error) {\n202: \tobj := ci.DeepCopy()\n203: \tif err := c.store.Update(obj); err != nil {\n204: \t\treturn nil, err\n205: \t}\n206: \treturn obj, nil\n207: }\n208: \n209: func (c *CodeInterpreterClient) UpdateStatus(ctx context.Context, ci *v1alpha1.CodeInterpreter, opts metav1.UpdateOptions) (*v1alpha1.CodeInterpreter, error) {\n210: \treturn c.Update(ctx, 