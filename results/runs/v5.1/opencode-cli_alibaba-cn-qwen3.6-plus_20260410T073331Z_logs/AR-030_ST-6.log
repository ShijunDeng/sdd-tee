  tag: latest\n45:   service:\n46:     type: ClusterIP\n47:     port: 8080\n48:   resources:\n49:     limits:\n50:       cpu: 500m\n51:       memory: 512Mi\n52:     requests:\n53:       cpu: 100m\n54:       memory: 128Mi\n55:   extraEnv: []\n56: \n57: # Volcano scheduler configuration (optional)\n58: volcano:\n59:   scheduler:\n60:     enabled: false\n61:     replicas: 1\n62:     image:\n63:       repository: ghcr.io/volcano-sh/vc-agent-scheduler\n64:       pullPolicy: IfNotPresent\n65:       tag: latest\n\n(End of file - total 65 lines)\n</content>","metadata":{"preview":"# imagePullSecrets -- Private registry credentials for pulling images\nimagePullSecrets: []\n# nameOverride -- Override the chart name used for resource naming\nnameOverride: \"\"\n# fullnameOverride -- Fully override the resource name prefix\nfullnameOverride: \"\"\n\n# Redis/Valkey connection configuration\n# NOTE: redis.addr and redis.password MUST be provided via --set during installation\nredis:\n  addr: \"\"       # Redis address, e.g. redis.agentcube.svc.cluster.local:6379\n  password: \"\"   # Redis password (can be empty for instances without auth)\n\n# Router component configuration\nrouter:\n  replicas: 1\n  image:\n    repository: ghcr.io/volcano-sh/agentcube-router\n    pullPolicy: IfNotPresent\n    tag: latest","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/manifests/charts/base/values.yaml","time":{"start":1775871919667,"end":1775871919673}}}}
