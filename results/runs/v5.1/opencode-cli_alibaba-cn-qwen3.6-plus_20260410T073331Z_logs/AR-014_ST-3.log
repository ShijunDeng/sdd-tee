{"type":"tool_use","timestamp":1775836697307,"sessionID":"ses_287e323f0ffeRSHYr3i6L0TFAl","part":{"id":"prt_d781d8f1500178Nd7LKCELfMZ6","messageID":"msg_d781d593d001eoQ9yW8p9Zh1yc","sessionID":"ses_287e323f0ffeRSHYr3i6L0TFAl","type":"tool","tool":"read","callID":"call_49ec307840794fa7b31bc4aa","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/singleton_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/store/singleton_test.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"os\"\n5: \t\"sync\"\n6: \t\"testing\"\n7: \n8: \t\"github.com/stretchr/testify/assert\"\n9: \t\"github.com/stretchr/testify/require\"\n10: )\n11: \n12: func TestInitStore_UnsupportedType(t *testing.T) {\n13: \toriginal := os.Getenv(\"STORE_TYPE\")\n14: \tdefer os.Setenv(\"STORE_TYPE\", original)\n15: \n16: \tos.Setenv(\"STORE_TYPE\", \"memcached\")\n17: \n18: \terr := initStore()\n19: \trequire.Error(t, err)\n20: \tassert.Contains(t, err.Error(), \"unsupported store type: memcached\")\n21: }\n22: \n23: func TestInitStore_CaseInsensitive(t *testing.T) {\n24: \toriginal := os.Getenv(\"STORE_TYPE\")\n25: \toriginalAddr := os.Getenv(\"REDIS_ADDR\")\n26: \toriginalPwd := os.Getenv(\"REDIS_PASSWORD\")\n27: \toriginalPwdReq := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n28: \tdefer func() {\n29: \t\tos.Setenv(\"STORE_TYPE\", original)\n30: \t\tos.Setenv(\"REDIS_ADDR\", originalAddr)\n31: \t\tos.Setenv(\"REDIS_PASSWORD\", originalPwd)\n32: \t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalPwdReq)\n33: \t}()\n34: \n35: \tos.Setenv(\"STORE_TYPE\", \"REDIS\")\n36: \tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n37: \tos.Setenv(\"REDIS_PASSWORD\", \"\")\n38: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n39: \n40: \terr := initStore()\n41: \trequire.NoError(t, err)\n42: \tassert.NotNil(t, storeInstance)\n43: }\n44: \n45: func TestStorage_ConcurrentCalls(t *testing.T) {\n46: \toriginalStoreType := os.Getenv(\"STORE_TYPE\")\n47: \toriginalRedisAddr := os.Getenv(\"REDIS_ADDR\")\n48: \toriginalRedisPwd := os.Getenv(\"REDIS_PASSWORD\")\n49: \toriginalRedisPwdReq := os.Getenv(\"REDIS_PASSWORD_REQUIRED\")\n50: \tdefer func() {\n51: \t\tos.Setenv(\"STORE_TYPE\", originalStoreType)\n52: \t\tos.Setenv(\"REDIS_ADDR\", originalRedisAddr)\n53: \t\tos.Setenv(\"REDIS_PASSWORD\", originalRedisPwd)\n54: \t\tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", originalRedisPwdReq)\n55: \t}()\n56: \n57: \tos.Setenv(\"STORE_TYPE\", \"redis\")\n58: \tos.Setenv(\"REDIS_ADDR\", \"localhost:6379\")\n59: \tos.Setenv(\"REDIS_PASSWORD\", \"\")\n60: \tos.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n61: \n62: \tvar wg sync.WaitGroup\n63: \tresults := make(chan Store, 10)\n64: \tfor i := 0; i < 10; i++ {\n65: \t\twg.Add(1)\n66: \t\tgo func() {\n67: \t\t\tdefer wg.Done()\n68: \t\t\tresults <- Storage()\n69: \t\t}()\n70: \t}\n71: \twg.Wait()\n72: \tclose(results)\n73: \n74: \tvar first Store\n75: \tcount := 0\n76: \tfor s := range results {\n77: \t\tcount++\n78: \t\tif first == nil {\n79: \t\t\tfirst = s\n80: \t\t}\n81: \t\tassert.Same(t, first, s, \"all goroutines should get the same instance\")\n82: \t}\n83: \tassert.Equal(t, 10, count)\n84: \tassert.NotNil(t, first)\n85: }\n\n(End of file - total 85 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"os\"\n\t\"sync\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestInitStore_UnsupportedType(t *testing.T) {\n\toriginal := os.Getenv(\"STORE_TYPE\")\n\tdefer os.Setenv(\"STORE_TYPE\", original)\n\n\tos.Setenv(\"STORE_TYPE\", \"memcached\")\n\n\terr := initStore()\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"unsupported store type: memcached\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pk