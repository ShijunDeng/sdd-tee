{"type":"tool_use","timestamp":1775848467186,"sessionID":"ses_2873001a1ffe1HZzyFzQGSya52","part":{"id":"prt_d78d1254c0010NMJ5eRE86MmkR","messageID":"msg_d78d11b5a0017hNifJxqn3kzGe","sessionID":"ses_2873001a1ffe1HZzyFzQGSya52","type":"tool","tool":"read","callID":"toolu_tool-3acae0310f874c7182a58a6e5ac1fdc3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/scheduler.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/scheduler.go</path>\n<type>file</type>\n<content>\n1: package gc\n2: \n3: import (\n4: \t\"context\"\n5: \t\"time\"\n6: \n7: \t\"k8s.io/client-go/dynamic\"\n8: \n9: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n10: )\n11: \n12: type GCScheduler struct {\n13: \tdynamicClient dynamic.Interface\n14: \tstoreClient   store.Store\n15: \tconfig        *GCConfig\n16: \tpolicy        *GCPolicy\n17: \tmetrics       *GCMetrics\n18: \tlogger        Logger\n19: \n20: \tinterval time.Duration\n21: \tstopCh   chan struct{}\n22: }\n23: \n24: func NewGCScheduler(\n25: \tdynamicClient dynamic.Interface,\n26: \tstoreClient store.Store,\n27: \tconfig *GCConfig,\n28: \tmetrics *GCMetrics,\n29: ) (*GCScheduler, error) {\n30: \tif config == nil {\n31: \t\tconfig = DefaultGCConfig()\n32: \t}\n33: \n34: \tpolicy, err := NewGCPolicy(config)\n35: \tif err != nil {\n36: \t\treturn nil, err\n37: \t}\n38: \n39: \treturn &GCScheduler{\n40: \t\tdynamicClient: dynamicClient,\n41: \t\tstoreClient:   storeClient,\n42: \t\tconfig:        config,\n43: \t\tpolicy:        policy,\n44: \t\tmetrics:       metrics,\n45: \t\tlogger:        &DefaultLogger{},\n46: \t\tinterval:      config.Interval,\n47: \t\tstopCh:        make(chan struct{}),\n48: \t}, nil\n49: }\n50: \n51: func (s *GCScheduler) Start(ctx context.Context) error {\n52: \ts.logger.Info(\"Starting GC scheduler\", \"interval\", s.interval)\n53: \n54: \tticker := time.NewTicker(s.interval)\n55: \tdefer ticker.Stop()\n56: \n57: \tfor {\n58: \t\tselect {\n59: \t\tcase <-ctx.Done():\n60: \t\t\ts.logger.Info(\"GC scheduler context canceled, stopping\")\n61: \t\t\treturn ctx.Err()\n62: \t\tcase <-s.stopCh:\n63: \t\t\ts.logger.Info(\"GC scheduler stop signal received, stopping\")\n64: \t\t\treturn nil\n65: \t\tcase <-ticker.C:\n66: \t\t\ts.runOnce(ctx)\n67: \t\t}\n68: \t}\n69: }\n70: \n71: func (s *GCScheduler) Stop() {\n72: \ts.logger.Info(\"Stopping GC scheduler\")\n73: \tclose(s.stopCh)\n74: }\n75: \n76: func (s *GCScheduler) RunOnce(ctx context.Context) (*GCResult, error) {\n77: \treturn s.runOnce(ctx)\n78: }\n79: \n80: func (s *GCScheduler) runOnce(ctx context.Context) (*GCResult, error) {\n81: \ts.metrics.RecordRun()\n82: \n83: \tcollector := NewGCCollector(\n84: \t\ts.dynamicClient,\n85: \t\ts.storeClient,\n86: \t\ts.config,\n87: \t\ts.policy,\n88: \t\ts.metrics,\n89: \t)\n90: \n91: \tresult, err := collector.Collect(ctx)\n92: \tif err != nil {\n93: \t\ts.logger.Error(\"GC run failed\", \"error\", err)\n94: \t\ts.metrics.RecordError(\"collect\")\n95: \t\treturn result, err\n96: \t}\n97: \n98: \treturn result, nil\n99: }\n100: \n101: func (s *GCScheduler) UpdateConfig(config *GCConfig) error {\n102: \tpolicy, err := NewGCPolicy(config)\n103: \tif err != nil {\n104: \t\treturn err\n105: \t}\n106: \n107: \ts.config = config\n108: \ts.policy = policy\n109: \ts.interval = config.Interval\n110: \n111: \ts.logger.Info(\"GC scheduler config updated\", \"interval\", s.interval)\n112: \n113: \treturn nil\n114: }\n\n(End of file - total 114 lines)\n</content>","metadata":{"preview":"package gc\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\t\"k8s.io/client-go/dynamic\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\ntype GCScheduler struct {\n\tdynamicClient dynamic.Interface\n\tstoreClient   store.Store\n\tconfig        *GCConfig\n\tpolicy        *GCPolicy\n\tmetrics       *GCMetrics\n\tlogger        Logger\n\n\tinterval time.Duration","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/scheduler.go","time":{"start":1775848467168,"end":1775848467185}}}}
{"type":"tool_use","timestamp":1775848467188,"sessionID":"ses_2873001a1ffe1HZzyFzQGSya52","part":{"id":"prt_d78d12807001j8MZ2xnd0Tz0mX","messageID":"msg_d78d11b5a0017hNifJxqn3kzGe","sessionID":"ses_2873001a1ffe1HZzyFzQGSya52","type":"tool","tool":"read","callID":"toolu_tool-c21c4800350f4451b7a6c055047127a5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/collector.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/collector.go</path>\n<type>file</type>\n<content>\n1: package gc\n2: \n3: import (\n4: \t\"context\"\n5: \t\"time\"\n6: \n7: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n8: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n9: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n10: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n11: \t\"k8s.io/client-go/dynamic\"\n12: \t\"k8s.io/klog/v2\"\n13: \n14: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n15: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n16: \twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n17: )\n18: \n19: type GCCollector struct {\n20: \tdynamicClient dynamic.Interface\n21: \tstoreClient   store.Store\n22: \tconfig        *GCConfig\n23: \tpolicy        *GCPolicy\n24: \tmetrics       *GCMetrics\n25: \tlogger        Logger\n26: }\n27: \n28: type Logger interface {\n29: \tInfo(msg string, keysAndValues ...interface{})\n30: \tError(msg string, keysAndValues ...interface{})\n31: \tWarning(msg string, keysAndValues ...interface{})\n32: }\n33: \n34: type DefaultLogger struct{}\n35: \n36: func (l *DefaultLogger) Info(msg string, keysAndValues ...interface{}) {\n37: \tklog.InfoS(msg, keysAndValues...)\n38: }\n39: \n40: func (l *DefaultLogger) Error(msg string, keysAndValues ...interface{}) {\n41: \tklog.ErrorS(nil, msg, keysAndValues...)\n42: }\n43: \n44: func (l *DefaultLogger) Warning(msg string, keysAndValues ...interface{}) {\n45: \tklog.V(2).InfoS(msg, keysAndValues...)\n46: }\n47: \n48: func NewGCCollector(\n49: \tdynamicClient dynamic.Interface,\n50: \tstoreClient store.Store,\n51: \tconfig *GCConfig,\n52: \tpolicy *GCPolicy,\n53: \tmetrics *GCMetrics,\n54: ) *GCCollector {\n55: \treturn &GCCollector{\n56: \t\tdynamicClient: dynamicClient,\n57: \t\tstoreClient:   storeClient,\n58: \t\tconfig:        config,\n59: \t\tpolicy:        policy,\n60: \t\tmetrics:       metrics,\n61: \t\tlogger:        &DefaultLogger{},\n62: \t}\n63: }\n64: \n65: func (c *GCCollector) Collect(ctx context.Context) (*GCResult, error) {\n66: \tstartTime := time.Now()\n67: \tresult := &GCResult{}\n68: \n69: \tfinder := NewSandboxFinder(c.dynamicClient, &storeAdapter{c.storeClient}, c.policy)\n70: \n71: \tcandidates, err := finder.FindCandidates(ctx)\n72: \tif err != nil {\n73: \t\tc.logger.Error(\"Failed to find candidates\", \"error\", err)\n74: \t\tc.metrics.RecordError(\"find_candidates\")\n75: \t\tresult.Errors++\n76: \t\treturn result, err\n77: \t}\n78: \n79: \tresult.Scanned = len(candidates)\n80: \tc.metrics.RecordScanned(result.Scanned)\n81: \n82: \tvar toDelete []*unstructured.Unstructured\n83: \tfor _, candidate := range candidates {\n84: \t\tsessionID := GetSessionIDFromSandbox(candidate)\n85: \t\tsessionInfo, err := c.getSessionInfo(ctx, sessionID)\n86: \t\tif err != nil {\n87: \t\t\tc.logger.Warning(\"Failed to get session info\", \"sessionID\", sessionID, \"error\", err)\n88: \t\t\tc.metrics.RecordError(\"get_session_info\")\n89: \t\t\tresult.Errors++\n90: \t\t\tcontinue\n91: \t\t}\n92: \n93: \t\tif c.policy.ShouldGC(candidate, sessionInfo) {\n94: \t\t\ttoDelete = append(toDelete, candidate)\n95: \t\t}\n96: \t}\n97: \n98: \tresult.Candidates = len(toDelete)\n99: \tc.metrics.SetCandidates(result.Candidates)\n100: \n101: \tif result.Candidates > 0 {\n102: \t\tc.logger.Info(\"Found candidates for GC\", \"count\", result.Candidates)\n103: \t}\n104: \n105: \tfor _, sandbox := range toDelete {\n106: \t\tsessionID := GetSessionIDFromSandbox(sandbox)\n107: \t\tsessionInfo, err := c.getSessionInfo(ctx, sessionID)\n108: \t\tif err != nil {\n109: \t\t\tc.logger.Warning(\"Failed to get session info for deletion\", \"sessionID\", sessionID, \"error\", err)\n110: \t\t\tc.metrics.RecordError(\"get_session_info_delete\")\n111: \t\t\tresult.Errors++\n112: \t\t\tcontinue\n113: \t\t}\n114: \n115: \t\treason := BuildCleanupReasonFromPolicy(c.policy, sandbox, sessionInfo)\n116: \t\terr = c.Delete(ctx, sandbox, reason)\n117: \t\tif err != nil {\n118: \t\t\tresult.Errors++\n119: \t\t\tc.metrics.RecordError(\"delete\")\n120: \t\t} else {\n121: \t\t\tresult.Deleted++\n122: \t\t\tc.metrics.RecordDeleted(string(reason), sandbox.GetKind())\n123: \t\t}\n124: \t}\n125: \n126: \tresult.Duration = time.Since(startTime)\n127: \tc.metrics.RecordDuration(result.Duration.Seconds())\n128: \tc.metrics.ResetCandidates()\n129: \n130: \tc.logger.Info(\"GC collection completed\",\n131: \t\t\"scanned\", result.Scanned,\n132: \t\t\"candidates\", result.Candidates,\n133: \t\t\"deleted\", result.Deleted,\n134: \t\t\"errors\", result.Errors,\n135: \t\t\"duration\", result.Duration,\n136: \t)\n137: \n138: \treturn result, nil\n139: }\n140: \n141: func (c *GCCollector) Delete(ctx context.Context, sandbox *unstructured.Unstructured, reason wmTypes.SandboxCleanupReason) error {\n142: \tif c.config.DryRun {\n143: \t\tc.logger.Info(\"Dry run: would delete sandbox\",\n144: \t\t\t\"name\", sandbox.GetName(),\n145: \t\t\t\"namespace\", sandbox.GetNamespace(),\n146: \t\t\t\"reason\", reason,\n147: \t\t)\n148: \t\treturn nil\n149: \t}\n150: \n151: \tgvr := c.getGVRForKind(sandbox.GetKind())\n152: \n153: \tdeleteCtx, cancel := context.WithTimeout(ctx, workloadmanager.DeleteTimeout)\n154: \tdefer cancel()\n155: \n156: \terr := c.dynamicClient.Resource(gvr).\n157: \t\tNamespace(sandbox.GetNamespace()).\n158: \t\tDelete(deleteCtx, sandbox.GetName(), metav1.DeleteOptions{})\n159: \n160: \tif err != nil && !apierrors.IsNotFound(err) {\n161: \t\tc.logger.Error(\"Failed to delete sandbox\",\n162: \t\t\t\"name\", sandbox.GetName(),\n163: \t\t\t\"namespace\", sandbox.GetNamespace(),\n164: \t\t\t\"error\", err,\n165: \t\t)\n166: \t\treturn err\n167: \t}\n168: \n169: \tsessionID := GetSessionIDFromSandbox(sandbox)\n170: \tif sessionID != \"\" {\n171: \t\tif err := c.storeClient.DeleteSandboxBySessionID(ctx, sessionID); err != nil {\n172: \t\t\tc.logger.Warning(\"Failed to delete sandbox from store\",\n173: \t\t\t\t\"sessionID\", sessionID,\n174: \t\t\t\t\"error\", err,\n175: \t\t\t)\n176: \t\t}\n177: \t}\n178: \n179: \tc.logger.Info(\"Deleted sandbox\",\n180: \t\t\"name\", sandbox.GetName(),\n181: \t\t\"namespace\", sandbox.GetNamespace(),\n182: \t\t\"reason\", reason,\n183: \t)\n184: \n185: \treturn nil\n186: }\n187: \n188: func (c *GCCollector) getGVRForKind(kind string) schema.GroupVersionResource {\n189: \tif kind == \"SandboxClaim\" {\n190: \t\treturn SandboxClaimGVR\n191: \t}\n192: \treturn SandboxGVR\n193: }\n194: \n195: func (c *GCCollector) getSessionInfo(ctx context.Context, sessionID string) (*SessionInfo, error) {\n196: \tif sessionID == \"\" {\n197: \t\treturn nil, nil\n198: \t}\n199: \n200: \tsandboxInfo, err := c.storeClient.GetSandbox(ctx, sessionID)\n201: \tif err != nil {\n202: \t\tif err == store.ErrNotFound {\n203: \t\t\treturn nil, nil\n204: \t\t}\n205: \t\treturn nil, err\n206: \t}\n207: \n208: \treturn &SessionInfo{\n209: \t\tSessionID:        sandboxInfo.SessionID,\n210: \t\tLastActivityAt:   sandboxInfo.LastActivityAt,\n211: \t\tExpiresAt:        sandboxInfo.ExpiresAt,\n212: \t\tHasActiveSession: true,\n213: \t}, nil\n214: }\n215: \n216: type storeAdapter struct {\n217: \tstore store.Store\n218: }\n219: \n220: func (a *storeAdapter) GetSandbox(ctx context.Context, sessionID string) (*SessionInfo, error) {\n221: \tsandboxInfo, err := a.store.GetSandbox(ctx, sessionID)\n222: \tif err != nil {\n223: \t\treturn nil, err\n224: \t}\n225: \n226: \treturn &SessionInfo{\n227: \t\tSessionID:        sandboxInfo.SessionID,\n228: \t\tLastActivityAt:   sandboxInfo.LastActivityAt,\n229: \t\tExpiresAt:        sandboxInfo.ExpiresAt,\n230: \t\tHasActiveSession: true,\n231: \t}, nil\n232: }\n\n(End of file - total 232 lines)\n</content>","metadata":{"preview":"package gc\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\ntype GCCollector struct {\n\tdynamicClient dynamic.Interface","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/collector.go","time":{"start":1775848467171,"end":1775848467186}}}}
{"type":"tool_use","timestamp":1775848467190,"sessionID":"ses_2873001a1ffe1HZzyFzQGSya52","part":{"id":"prt_d78d12abe0016Zxiongc0vZkZj","messageID":"msg_d78d11b5a0017hNifJxqn3kzGe","sessionID":"ses_2873001a1ffe1HZzyFzQGSya52","type":"tool","tool":"read","callID":"toolu_tool-f61156acf2ee444a834caaa4839cf067","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/policy.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/policy.go</path>\n<type>file</type>\n<content>\n1: package gc\n2: \n3: import (\n4: \t\"context\"\n5: \t\"time\"\n6: \n7: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n8: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n9: \t\"k8s.io/apimachinery/pkg/labels\"\n10: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n11: \t\"k8s.io/client-go/dynamic\"\n12: \t\"k8s.io/klog/v2\"\n13: \n14: \twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n15: )\n16: \n17: var (\n18: \tSandboxGVR = schema.GroupVersionResource{\n19: \t\tGroup:    \"agents.x-k8s.io\",\n20: \t\tVersion:  \"v1alpha1\",\n21: \t\tResource: \"sandboxes\",\n22: \t}\n23: \n24: \tSandboxClaimGVR = schema.GroupVersionResource{\n25: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n26: \t\tVersion:  \"v1alpha1\",\n27: \t\tResource: \"sandboxclaims\",\n28: \t}\n29: \n30: \tSessionIDLabelKey         = \"runtime.agentcube.io/session-id\"\n31: \tLastActivityAnnotationKey = \"last-activity-time\"\n32: )\n33: \n34: type OrphanPolicy string\n35: \n36: const (\n37: \tOrphanPolicyDelete    OrphanPolicy = \"delete\"\n38: \tOrphanPolicyKeep      OrphanPolicy = \"keep\"\n39: \tOrphanPolicyReconcile OrphanPolicy = \"reconcile\"\n40: )\n41: \n42: type SessionInfo struct {\n43: \tSessionID        string\n44: \tLastActivityAt   time.Time\n45: \tExpiresAt        time.Time\n46: \tHasActiveSession bool\n47: }\n48: \n49: type GCPolicy struct {\n50: \tMaxAgeThreshold time.Duration\n51: \tIdleThreshold   time.Duration\n52: \tOrphanPolicy    OrphanPolicy\n53: \tLabelSelector   labels.Selector\n54: \tNamespaces      []string\n55: }\n56: \n57: type GCConfig struct {\n58: \tInterval      time.Duration\n59: \tMaxAge        time.Duration\n60: \tIdleTimeout   time.Duration\n61: \tDryRun        bool\n62: \tNamespaces    []string\n63: \tLabelSelector string\n64: }\n65: \n66: type GCResult struct {\n67: \tScanned    int\n68: \tCandidates int\n69: \tDeleted    int\n70: \tErrors     int\n71: \tDuration   time.Duration\n72: }\n73: \n74: func DefaultGCConfig() *GCConfig {\n75: \treturn &GCConfig{\n76: \t\tInterval:      15 * time.Second,\n77: \t\tMaxAge:        8 * time.Hour,\n78: \t\tIdleTimeout:   15 * time.Minute,\n79: \t\tDryRun:        false,\n80: \t\tNamespaces:    []string{},\n81: \t\tLabelSelector: \"\",\n82: \t}\n83: }\n84: \n85: func NewGCPolicy(config *GCConfig) (*GCPolicy, error) {\n86: \tvar selector labels.Selector\n87: \tvar err error\n88: \n89: \tif config.LabelSelector != \"\" {\n90: \t\tselector, err = labels.Parse(config.LabelSelector)\n91: \t\tif err != nil {\n92: \t\t\treturn nil, err\n93: \t\t}\n94: \t} else {\n95: \t\tselector = labels.Everything()\n96: \t}\n97: \n98: \treturn &GCPolicy{\n99: \t\tMaxAgeThreshold: config.MaxAge,\n100: \t\tIdleThreshold:   config.IdleTimeout,\n101: \t\tOrphanPolicy:    OrphanPolicyDelete,\n102: \t\tLabelSelector:   selector,\n103: \t\tNamespaces:      config.Namespaces,\n104: \t}, nil\n105: }\n106: \n107: func (p *GCPolicy) ShouldGC(sandbox *unstructured.Unstructured, sessionInfo *SessionInfo) bool {\n108: \tif p.IsExpired(sandbox) {\n109: \t\treturn true\n110: \t}\n111: \n112: \tif sessionInfo != nil && p.IsIdle(sandbox, sessionInfo) {\n113: \t\treturn true\n114: \t}\n115: \n116: \treturn p.IsOrphaned(sandbox, sessionInfo)\n117: }\n118: \n119: func (p *GCPolicy) IsExpired(sandbox *unstructured.Unstructured) bool {\n120: \tcreationTimestamp, _, err := unstructured.NestedFieldNoCopy(sandbox.Object, \"metadata\", \"creationTimestamp\")\n121: \tif err != nil {\n122: \t\treturn false\n123: \t}\n124: \n125: \tcreationTime, ok := creationTimestamp.(string)\n126: \tif !ok {\n127: \t\treturn false\n128: \t}\n129: \n130: \tcreatedAt, err := time.Parse(time.RFC3339, creationTime)\n131: \tif err != nil {\n132: \t\treturn false\n133: \t}\n134: \n135: \treturn time.Since(createdAt) > p.MaxAgeThreshold\n136: }\n137: \n138: func (p *GCPolicy) IsIdle(sandbox *unstructured.Unstructured, sessionInfo *SessionInfo) bool {\n139: \tif sessionInfo == nil || sessionInfo.LastActivityAt.IsZero() {\n140: \t\treturn false\n141: \t}\n142: \n143: \treturn time.Since(sessionInfo.LastActivityAt) > p.IdleThreshold\n144: }\n145: \n146: func (p *GCPolicy) IsOrphaned(sandbox *unstructured.Unstructured, sessionInfo *SessionInfo) bool {\n147: \tif p.OrphanPolicy != OrphanPolicyDelete {\n148: \t\treturn false\n149: \t}\n150: \n151: \treturn sessionInfo == nil || !sessionInfo.HasActiveSession\n152: }\n153: \n154: func (p *GCPolicy) MatchesLabelSelector(sandbox *unstructured.Unstructured) bool {\n155: \tobjLabels, _, err := unstructured.NestedFieldNoCopy(sandbox.Object, \"metadata\", \"labels\")\n156: \tif err != nil {\n157: \t\treturn false\n158: \t}\n159: \n160: \tsandboxLabels, ok := objLabels.(map[string]interface{})\n161: \tif !ok {\n162: \t\treturn false\n163: \t}\n164: \n165: \tlabelsMap := make(map[string]string)\n166: \tfor k, v := range sandboxLabels {\n167: \t\tif strValue, ok := v.(string); ok {\n168: \t\t\tlabelsMap[k] = strValue\n169: \t\t}\n170: \t}\n171: \n172: \treturn p.LabelSelector.Matches(labels.Set(labelsMap))\n173: }\n174: \n175: func (p *GCPolicy) ShouldProcessNamespace(namespace string) bool {\n176: \tif len(p.Namespaces) == 0 {\n177: \t\treturn true\n178: \t}\n179: \n180: \tfor _, ns := range p.Namespaces {\n181: \t\tif ns == namespace {\n182: \t\t\treturn true\n183: \t\t}\n184: \t}\n185: \n186: \treturn false\n187: }\n188: \n189: type SandboxFinder struct {\n190: \tdynamicClient dynamic.Interface\n191: \tstoreClient   StoreClient\n192: \tpolicy        *GCPolicy\n193: }\n194: \n195: type StoreClient interface {\n196: \tGetSandbox(ctx context.Context, sessionID string) (*SessionInfo, error)\n197: }\n198: \n199: func NewSandboxFinder(dynamicClient dynamic.Interface, storeClient StoreClient, policy *GCPolicy) *SandboxFinder {\n200: \treturn &SandboxFinder{\n201: \t\tdynamicClient: dynamicClient,\n202: \t\tstoreClient:   storeClient,\n203: \t\tpolicy:        policy,\n204: \t}\n205: }\n206: \n207: func (f *SandboxFinder) FindCandidates(ctx context.Context) ([]*unstructured.Unstructured, error) {\n208: \tsandboxes, err := f.listSandboxes(ctx)\n209: \tif err != nil {\n210: \t\treturn nil, err\n211: \t}\n212: \n213: \tvar candidates []*unstructured.Unstructured\n214: \tfor _, sandbox := range sandboxes {\n215: \t\tif f.policy.ShouldProcessNamespace(sandbox.GetNamespace()) && f.policy.MatchesLabelSelector(sandbox) {\n216: \t\t\tcandidates = append(candidates, sandbox)\n217: \t\t}\n218: \t}\n219: \n220: \treturn candidates, nil\n221: }\n222: \n223: func (f *SandboxFinder) listSandboxes(ctx context.Context) ([]*unstructured.Unstructured, error) {\n224: \tvar allSandboxes []*unstructured.Unstructured\n225: \n226: \tsandboxList, err := f.dynamicClient.Resource(SandboxGVR).List(ctx, metav1.ListOptions{})\n227: \tif err == nil {\n228: \t\tfor i := range sandboxList.Items {\n229: \t\t\tallSandboxes = append(allSandboxes, &sandboxList.Items[i])\n230: \t\t}\n231: \t}\n232: \n233: \tsandboxClaimList, err := f.dynamicClient.Resource(SandboxClaimGVR).List(ctx, metav1.ListOptions{})\n234: \tif err == nil {\n235: \t\tfor i := range sandboxClaimList.Items {\n236: \t\t\tallSandboxes = append(allSandboxes, &sandboxClaimList.Items[i])\n237: \t\t}\n238: \t}\n239: \n240: \treturn allSandboxes, nil\n241: }\n242: \n243: func GetSessionIDFromSandbox(sandbox *unstructured.Unstructured) string {\n244: \tlabels := sandbox.GetLabels()\n245: \tif labels == nil {\n246: \t\treturn \"\"\n247: \t}\n248: \n249: \treturn labels[SessionIDLabelKey]\n250: }\n251: \n252: func GetLastActivityFromSandbox(sandbox *unstructured.Unstructured) time.Time {\n253: \tannotations := sandbox.GetAnnotations()\n254: \tif annotations == nil {\n255: \t\treturn time.Time{}\n256: \t}\n257: \n258: \tlastActivityStr, ok := annotations[LastActivityAnnotationKey]\n259: \tif !ok {\n260: \t\treturn time.Time{}\n261: \t}\n262: \n263: \tlastActivity, err := time.Parse(time.RFC3339, lastActivityStr)\n264: \tif err != nil {\n265: \t\tklog.Warningf(\"Failed to parse last activity time: %v\", err)\n266: \t\treturn time.Time{}\n267: \t}\n268: \n269: \treturn lastActivity\n270: }\n271: \n272: func BuildCleanupReasonFromPolicy(policy *GCPolicy, sandbox *unstructured.Unstructured, sessionInfo *SessionInfo) wmTypes.SandboxCleanupReason {\n273: \tif policy.IsExpired(sandbox) {\n274: \t\treturn wmTypes.CleanupReasonExpired\n275: \t}\n276: \n277: \tif sessionInfo != nil && policy.IsIdle(sandbox, sessionInfo) {\n278: \t\treturn wmTypes.CleanupReasonIdleTimeout\n279: \t}\n280: \n281: \tif policy.IsOrphaned(sandbox, sessionInfo) {\n282: \t\treturn wmTypes.CleanupReasonManual\n283: \t}\n284: \n285: \treturn wmTypes.CleanupReasonManual\n286: }\n\n(End of file - total 286 lines)\n</content>","metadata":{"preview":"package gc\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/klog/v2\"\n\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\nvar (\n\tSandboxGVR = schema.GroupVersionResource{\n\t\tGroup:    \"agents.x-k8s.io\",\n\t\tVersion:  \"v1alpha1\",","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163