led(ctx, sessionID, info)\n42: \treturn args.Error(0)\n43: }\n44: \n45: func (m *mockStoreForGC) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n46: \targs := m.Called(ctx, sessionID)\n47: \treturn args.Error(0)\n48: }\n49: \n50: func (m *mockStoreForGC) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n51: \targs := m.Called(ctx)\n52: \treturn args.Get(0).(map[string]*types.SandboxInfo), args.Error(1)\n53: }\n54: \n55: func (m *mockStoreForGC) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n56: \targs := m.Called(ctx, sessionID, at)\n57: \treturn args.Error(0)\n58: }\n59: \n60: func (m *mockStoreForGC) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n61: \targs := m.Called(ctx, before, limit)\n62: \tif args.Get(0) == nil {\n63: \t\treturn nil, args.Error(1)\n64: \t}\n65: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n66: }\n67: \n68: func (m *mockStoreForGC) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n69: \targs := m.Called(ctx, before, limit)\n70: \tif args.Get(0) == nil {\n71: \t\treturn nil, args.Error(1)\n72: \t}\n73: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n74: }\n75: \n76: func (m *mockStoreForGC) Close() error {\n77: \targs := m.Called()\n78: \treturn args.Error(0)\n79: }\n80: \n81: func buildUnstructuredSandboxForGC(name, namespace string) *unstructured.Unstructured {\n82: \treturn &unstructured.Unstructured{\n83: \t\tObject: map[string]interface{}{\n84: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n85: \t\t\t\"kind\":       \"Sandbox\",\n86: \t\t\t\"metadata\": map[string]interface{}{\n87: \t\t\t\t\"name\":      name,\n88: \t\t\t\t\"namespace\": namespace,\n89: \t\t\t\t\"labels\": map[string]interface{}{\n90: \t\t\t\t\t\"runtime.agentcube.io/session-id\": \"test-session\",\n91: \t\t\t\t},\n92: \t\t\t},\n93: \t\t},\n94: \t}\n95: }\n96: \n97: func TestGarbageCollector_Tick_IdleSandboxes(t *testing.T) {\n98: \tmockStore := &mockStoreForGC{}\n99: \tidleSandboxes := []*types.SandboxInfo{\n100: \t\t{\n101: \t\t\tSessionID:        \"idle-session-1\",\n102: \t\t\tSandboxID:        \"idle-sandbox-1\",\n103: \t\t\tSandboxNamespace: \"default\",\n104: \t\t\tKind:             \"Sandbox\",\n105: \t\t},\n106: \t}\n107: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return(idleSandboxes, nil)\n108: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\").Return(nil)\n109: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n110: \n111: \tscheme := runtime.NewScheme()\n112: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n113: \n114: \tsandboxObj := buildUnstructuredSandboxForGC(\"idle-sandbox-1\", \"default\")\n115: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n116: \n117: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n118: \n119: \tgc.tick()\n120: \n121: \tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n122: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\")\n123: }\n124: \n125: func TestGarbageCollector_Tick_ExpiredSandboxes(t *testing.T) {\n126: \tmockStore := &mockStoreForGC{}\n127: \texpiredSandboxes := []*types.SandboxInfo{\n128: \t\t{\n129: \t\t\tSessionID:        \"expired-session-1\",\n130: \t\t\tSandboxID:        \"expired-sandbox-1\",\n131: \t\t\tSandboxNamespace: \"default\",\n132: \t\t\tKind:             \"Sandbox\",\n133: \t\t},\n134: \t}\n135: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return(expiredSandboxes, nil)\n136: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\").Return(nil)\n137: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n138: \n139: \tscheme := runtime.NewScheme()\n140: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n141: \n142: \tsandboxObj := buildUnstructuredSandboxForGC(\"expired-sandbox-1\", \"default\")\n143: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n144: \n145: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n146: \n147: \tgc.tick()\n148: \n149: \tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n150: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\")\n151: }\n152: \n153: func TestGarbageCollector_Tick_KubernetesNotFound(t *testing.T) {\n154: \tmockStore := &mockStoreForGC{}\n155: \tsandboxInfo := &types.SandboxInfo{\n156: \t\tSessionID:        \"missing-session\",\n157: \t\tSandboxID:        \"missing-sandbox\",\n158: \t\tSandboxNamespace: \"default\",\n159: \t\tKind:             \"Sandbox\",\n160: \t}\n161: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{sandboxInfo}, nil)\n162: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\").Return(nil)\n163: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n164: \n165: \tscheme := runtime.NewScheme()\n166: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n167: \n168: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n169: \n170: \tgc.tick()\n171: \n172: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\")\n173: }\n174: \n175: func TestGarbageCollector_StartStop(t *testing.T) {\n176: \tmockStore := &mockStoreForGC{}\n177: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n178: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n179: \n180: \tscheme := runtime.NewScheme()\n181: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n182: \n183: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, 100*time.Millisecond)\n184: \n185: \tgc.Start()\n186: \n187: \ttime.Sleep(250 * time.Millisecond)\n188: \n189: \tgc.Stop()\n190: \n191: \ttime.Sleep(50 * time.Millisecond)\n192: \tassert.True(t, true, \"GC stopped without panic\")\n193: }\n194: \n195: func TestGarbageCollector_Tick_ListInactiveError(t *testing.T) {\n196: \tmockStore := &mockStoreForGC{}\n197: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n198: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n199: \n200: \tscheme := runtime.NewScheme()\n201: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n202: \n203: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n204: \n205: \tgc.tick()\n206: \n207: \tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n208: \tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n209: }\n210: \n211: func TestGarbageCollector_Tick_ListExpiredError(t *testing.T) {\n212: \tmockStore := &mockStoreForGC{}\n213: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n214: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n215: \n216: \tscheme := runtime.NewScheme()\n217: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n218: \n219: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n220: \n221: \tgc.tick()\n222: \n223: \tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n224: \tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n225: }\n226: \n227: func TestGarbageCollector_Tick_BothLists(t *testing.T) {\n228: \tmockStore := &mockStoreForGC{}\n229: \tidleSandboxes := []*types.SandboxInfo{\n230: \t\t{\n231: \t\t\tSessionID:        \"idle-session-1\",\n232: \t\t\tSandboxID:        \"idle-sandbox-1\",\n233: \t\t\tSandboxNamespace: \"default\",\n234: \t\t\tKind:             \"Sandbox\",\n235: \t\t},\n236: \t}\n237: \texpiredSandboxes := []*types.SandboxInfo{\n238: \t\t{\n239: \t\t\tSessionID:        \"expired-session-1\",\n240: \t\t\tSandboxID:        \"expired-sandbox-1\",\n241: \t\t\tSandboxNamespace: \"default\",\n242: \t\t\tKind:             \"Sandbox\",\n243: \t\t},\n244: \t}\n245: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return(idleSandboxes, nil)\n246: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\").Return(nil)\n247: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return(expiredSandboxes, nil)\n248: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\").Return(nil)\n249: \n250: \tscheme := runtime.NewScheme()\n251: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n252: \n253: \tidleObj := buildUnstructuredSandboxForGC(\"idle-sandbox-1\", \"default\")\n254: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), idleObj, metav1.CreateOptions{})\n255: \n256: \texpiredObj := buildUnstructuredSandboxForGC(\"expired-sandbox-1\", \"default\")\n257: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), expiredObj, metav1.CreateOptions{})\n258: \n259: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n260: \n261: \tgc.tick()\n262: \n263: \tmockStore.AssertNumberOfCalls(t, \"DeleteSandboxBySessionID\", 2)\n264: }\n\n(End of file - total 264 lines)\n</content>","metadata"