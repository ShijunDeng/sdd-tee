ace {\n36: \tDiscovery() discovery.DiscoveryInterface\n37: \tRuntimeV1alpha1() runtimev1alpha1.RuntimeV1alpha1Interface\n38: }\n39: \n40: type Clientset struct {\n41: \t*discovery.DiscoveryClient\n42: \truntimeV1alpha1 *runtimev1alpha1.RuntimeV1alpha1Client\n43: }\n44: \n45: func New(c *rest.Config) (*Clientset, error) {\n46: \tconfigShallowCopy := *c\n47: \tif configShallowCopy.UserAgent == \"\" {\n48: \t\tconfigShallowCopy.UserAgent = rest.DefaultKubernetesUserAgent()\n49: \t}\n50: \n51: \tdiscoveryClient, err := discovery.NewDiscoveryClientForConfig(&configShallowCopy)\n52: \tif err != nil {\n53: \t\treturn nil, err\n54: \t}\n55: \n56: \tvar cs Clientset\n57: \tcs.runtimeV1alpha1, err = runtimev1alpha1.NewForConfig(&configShallowCopy)\n58: \tif err != nil {\n59: \t\treturn nil, err\n60: \t}\n61: \n62: \tcs.DiscoveryClient = discoveryClient\n63: \treturn &cs, nil\n64: }\n65: \n66: func NewForConfig(c *rest.Config) (*Clientset, error) {\n67: \tconfigShallowCopy := *c\n68: \tif configShallowCopy.RateLimiter == nil && configShallowCopy.QPS > 0 {\n69: \t\tif configShallowCopy.Burst <= 0 {\n70: \t\t\treturn nil, fmt.Errorf(\"burst is required to be greater than 0 when RateLimiter is not set and QPS is set to greater than 0\")\n71: \t\t}\n72: \t\tconfigShallowCopy.RateLimiter = createDefaultRateLimiter(configShallowCopy.QPS, configShallowCopy.Burst)\n73: \t}\n74: \n75: \tvar cs Clientset\n76: \tvar err error\n77: \tcs.runtimeV1alpha1, err = runtimev1alpha1.NewForConfig(&configShallowCopy)\n78: \tif err != nil {\n79: \t\treturn nil, err\n80: \t}\n81: \tcs.DiscoveryClient, err = discovery.NewDiscoveryClientForConfig(&configShallowCopy)\n82: \tif err != nil {\n83: \t\treturn nil, err\n84: \t}\n85: \treturn &cs, nil\n86: }\n87: \n88: func NewForConfigAndClient(c *rest.Config, httpClient *rest.HttpClient) (*Clientset, error) {\n89: \tconfigShallowCopy := *c\n90: \tif configShallowCopy.RateLimiter == nil && configShallowCopy.QPS > 0 {\n91: \t\tif configShallowCopy.Burst <= 0 {\n92: \t\t\treturn nil, fmt.Errorf(\"burst is required to be greater than 0 when RateLimiter is not set and QPS is set to greater than 0\")\n93: \t\t}\n94: \t\tconfigShallowCopy.RateLimiter = createDefaultRateLimiter(configShallowCopy.QPS, configShallowCopy.Burst)\n95: \t}\n96: \n97: \tvar cs Clientset\n98: \tvar err error\n99: \tcs.runtimeV1alpha1, err = runtimev1alpha1.NewForConfigAndClient(&configShallowCopy, httpClient)\n100: \tif err != nil {\n101: \t\treturn nil, err\n102: \t}\n103: \tcs.DiscoveryClient, err = discovery.NewDiscoveryClientForConfigAndClient(&configShallowCopy, httpClient)\n104: \tif err != nil {\n105: \t\treturn nil, err\n106: \t}\n107: \treturn &cs, nil\n108: }\n109: \n110: func NewForConfigOrDie(c *rest.Config) *Clientset {\n111: \tvar cs Clientset\n112: \tcs.runtimeV1alpha1 = runtimev1alpha1.NewForConfigOrDie(c)\n113: \tcs.DiscoveryClient = discovery.NewDiscoveryClientForConfigOrDie(c)\n114: \treturn &cs\n115: }\n116: \n117: func (c *Clientset) RuntimeV1alpha1() runtimev1alpha1.RuntimeV1alpha1Interface {\n118: \treturn c.runtimeV1alpha1\n119: }\n120: \n121: func NewConfig(hostname string, httpClient *rest.HttpClient) *rest.Config {\n122: \tif httpClient == nil {\n123: \t\thttpClient = rest.DefaultClient\n124: \t}\n125: \treturn &rest.Config{\n126: \t\tHost: hostname,\n127: \t\tTLSClientConfig: rest.TLSClientConfig{\n128: \t\t\tInsecure: true,\n129: \t\t},\n130: \t\tAPIPath: \"/apis\",\n131: \t\tContentConfig: rest.ContentConfig{\n132: \t\t\tContentType:          \"application/json\",\n133: \t\t\tGroupVersion:         &schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"},\n134: \t\t\tNegotiatedSerializer: createNegotiatedSerializer(),\n135: \t\t},\n136: \t\tRateLimiter:      createDefaultRateLimiter(5, 10),\n137: \t\tTimeout:          30,\n138: \t\tDial:             httpClient.Dial,\n139: \t\tTransport:        httpClient.Transport,\n140: \t\tWrappedTransport: httpClient.WrappedTransport,\n141: \t\tUserAgent:        rest.DefaultKubernetesUserAgent(),\n142: \t}\n143: }\n144: \n145: func createDefaultRateLimiter(qps float32, burst int) rest.RateLimiter {\n146: \treturn rest.NewTokenBucketRateLimiter(qps, burst)\n147: }\n148: \n149: func createNegotiatedSerializer() runtime.NegotiatedSerializer {\n150: \treturn serializer.NewCodecFactory(scheme.Scheme).WithoutConversion()\n151: }\n152: \n153: func DefaultConfig() *rest.Config {\n154: \tconfig := rest.DefaultClientConfig(rest.DefaultClientConfigOverrides{})\n155: \trestConfig, err := config.ClientConfig()\n156: \tif err != nil {\n157: \t\tpanic(err)\n158: \t}\n159: \treturn restConfig\n160: }\n161: \n162: func DefaultClientConfig() (*rest.Config, error) {\n163: \treturn config.ClientConfig()\n164: }\n165: \n166: func (c *Clientset) Discovery() discovery.DiscoveryInterface {\n167: \tif c == nil {\n168: \t\treturn nil\n169: \t}\n170: \treturn c.DiscoveryClient\n171: }\n172: \n173: func (c *Clientset) DiscoveryCache() discovery.CachedDiscoveryInterface {\n174: \tif c == nil {\n175: \t\treturn nil\n176: \t}\n177: \treturn memory.NewMemCacheClient(c.DiscoveryClient)\n178: }\n179: \n180: func (c *Clientset) RESTClient() rest.Interface {\n181: \tif c == nil {\n182: \t\treturn nil\n183: \t}\n184: \treturn c.runtimeV1alpha1.RESTClient()\n185: }\n186: \n187: func (c *Clientset) RuntimeAPI() (*RESTClient, error) {\n188: \treturn c.runtimeV1alpha1.RESTClient(), nil\n189: }\n190: \n191: func NewRESTClient(baseURL string) (*RESTClient, error) {\n192: \tconfig := NewConfig(baseURL, rest.DefaultClient)\n193: \tconfig.GroupVersion = &schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"}\n194: \tconfig.APIPath = \"/apis/runtime.agentcube.volcano.sh/v1alpha1\"\n195: \n196: \trestClient, err := rest.RESTClientFor(config)\n197: \tif err != nil {\n198: \t\treturn nil, err\n199: \t}\n200: \n201: \treturn &RESTClient{\n202: \t\tRESTClient: restClient,\n203: \t}, nil\n204: }\n205: \n206: type RESTClient struct {\n207: \trest.Interface\n208: }\n209: \n210: func (c *Clientset) DynamicClient() (dynamic.Interface, error) {\n211: \tif c == nil {\n212: \t\treturn nil, fmt.Errorf(\"clientset is nil\")\n213: \t}\n214: \n215: \tdynamicConfig := rest.CopyConfig(c.runtimeV1alpha1.RESTClient().(*rest.RESTClient).Config)\n216: \tdynamicConfig.GroupVersion = nil\n217: \tdynamicConfig.NegotiatedSerializer = createNegotiatedSerializer()\n218: \n219: \tdynamicClient, err := dynamic.NewForConfig(dynamicConfig)\n220: \tif err != nil {\n221: \t\treturn nil, err\n222: \t}\n223: \n224: \treturn dynamicClient, nil\n225: }\n226: \n227: func (c *Clientset) RESTMapper() (restmapper.ResettableRESTMapper, error) {\n228: \tif c == nil {\n229: \t\treturn nil, fmt.Errorf(\"clientset is nil\")\n230: \t}\n231: \n232: \tdiscoveryClient := c.Discovery()\n233: \tif discoveryClient == nil {\n234: \t\treturn nil, fmt.Errorf(\"discovery client is nil\")\n235: \t}\n236: \n237: \tgroupResources, err := restmapper.GetAPIGroupResources(discoveryClient)\n238: \tif err != nil {\n239: \t\treturn nil, err\n240: \t}\n241: \n242: \treturn restmapper.NewDiscoveryRESTMapper(groupResources), nil\n243: }\n244: \n245: func init() {\n246: \tutilruntime.Must(scheme.AddToScheme(scheme.Scheme))\n247: }\n\n(End of file - total 247 lines)\n</content>","metadata":{"preview":"/*\nCopyright 2024 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage versioned\n\nimport (\n\t\"fmt\"","truncated":false,"loaded":[]},"title":"workspac