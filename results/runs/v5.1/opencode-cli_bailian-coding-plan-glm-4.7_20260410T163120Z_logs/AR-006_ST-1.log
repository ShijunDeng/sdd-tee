6 Apr 11 02:10 changes\ndrwxr-xr-x  2 root root  4096 Mar 21 15:58 ci-cd\ndrwxr-xr-x  2 root root  4096 Mar 21 15:55 cli-toolkit\ndrwxr-xr-x  2 root root  4096 Mar 21 15:55 code-execution\ndrwxr-xr-x  4 root root  4096 Apr 11 00:47 config\n-rw-r--r--  1 root root  4745 Apr 11 01:09 delta-spec.md\ndrwxr-xr-x  2 root root  4096 Apr 11 00:59 deployment\ndrwxr-xr-x  2 root root  4096 Apr 11 01:03 examples\n-rw-r--r--  1 root root  4027 Apr 11 01:58 go.mod\n-rw-r--r--  1 root root 18989 Apr 11 01:39 go.sum\ndrwxr-xr-x  2 root root  4096 Mar 21 15:56 idle-cleanup\ndrwxr-xr-x  2 root root  4096 Mar 21 15:58 integrations\ndrwxr-xr-x  6 root root  4096 Apr 11 01:34 pkg\n-rw-r--r--  1 root root  1674 Mar 21 15:53 project.md\n-rw-r--r--  1 root root 41511 Apr 11 01:24 proposal.md\ndrwxr-xr-x  2 root root  4096 Mar 21 15:56 python-sdk\ndrwxr-xr-x  3 root root  4096 Apr 10 18:18 sandbox-orchestration\n-rw-r--r--  1 root root 10003 Apr 11 02:10 .sdd_prompt.md\ndrwxr-xr-x  2 root root  4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root  4096 Mar 21 15:56 session-store\ndrwxr-xr-x  2 root root  4096 Mar 25 09:51 testing\n-rw-r--r--  1 root root  1983 Mar 25 09:36 test_spec.md\n","exit":0,"description":"List directory contents","truncated":false},"title":"List directory contents","time":{"start":1775844665478,"end":1775844665576}}}}
{"type":"tool_use","timestamp":1775844665591,"sessionID":"ses_28769335cffe6KTVXupCu969qv","part":{"id":"prt_d7897246e0012tczeLy24QLIwY","messageID":"msg_d789717bb001GO7EkEoOsKi4GY","sessionID":"ses_28769335cffe6KTVXupCu969qv","type":"tool","tool":"read","callID":"toolu_tool-e7cc8bc7b0c9433b81c41346458c45dd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"errors\"\n6: \t\"fmt\"\n7: \t\"time\"\n8: \n9: \t\"github.com/redis/go-redis/v9\"\n10: \t\"k8s.io/klog/v2\"\n11: \n12: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n13: )\n14: \n15: var ErrNotFound = errors.New(\"sandbox not found\")\n16: \n17: type Store interface {\n18: \tPing(ctx context.Context) error\n19: \tGetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n20: \tStoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error\n21: \tUpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error\n22: \tDeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n23: \tListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error)\n24: \tUpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n25: \tListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)\n26: \tListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)\n27: \tClose() error\n28: }\n29: \n30: type redisStore struct {\n31: \tclient *redis.Client\n32: }\n33: \n34: func newValkeyStore(addr string, password string, db int) (Store, error) {\n35: \tclient := redis.NewClient(&redis.Options{\n36: \t\tAddr:     addr,\n37: \t\tPassword: password,\n38: \t\tDB:       db,\n39: \t})\n40: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n41: \tdefer cancel()\n42: \n43: \tif err := client.Ping(ctx).Err(); err != nil {\n44: \t\treturn nil, fmt.Errorf(\"failed to connect to redis: %w\", err)\n45: \t}\n46: \n47: \treturn &redisStore{client: client}, nil\n48: }\n49: \n50: func (s *redisStore) Ping(ctx context.Context) error {\n51: \treturn s.client.Ping(ctx).Err()\n52: }\n53: \n54: func (s *redisStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n55: \tkey := s.sessionKey(sessionID)\n56: \tdata, err := s.client.Get(ctx, key).Result()\n57: \tif err != nil {\n58: \t\tif err == redis.Nil {\n59: \t\t\treturn nil, ErrNotFound\n60: \t\t}\n61: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n62: \t}\n63: \n64: \tinfo := &types.SandboxInfo{}\n65: \tif err := unmarshalSandboxInfo(data, info); err != nil {\n66: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n67: \t}\n68: \n69: \treturn info, nil\n70: }\n71: \n72: func (s *redisStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n73: \tkey := s.sessionKey(sessionID)\n74: \tdata, err := marshalSandboxInfo(info)\n75: \tif err != nil {\n76: \t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n77: \t}\n78: \n79: \tttl := info.ExpiresAt.Sub(time.Now())\n80: \tif ttl <= 0 {\n81: \t\tttl = 8 * time.Hour\n82: \t}\n83: \n84: \tif err := s.client.Set(ctx, key, data, ttl).Err(); err != nil {\n85: \t\treturn fmt.Errorf(\"failed to store sandbox: %w\", err)\n86: \t}\n87: \n88: \treturn nil\n89: }\n90: \n91: func (s *redisStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n92: \treturn s.StoreSandbox(ctx, sessionID, info)\n93: }\n94: \n95: func (s *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n96: \tkey := s.sessionKey(sessionID)\n97: \tif err := s.client.Del(ctx, key).Err(); err != nil {\n98: \t\treturn fmt.Errorf(\"failed to delete sandbox: %w\", err)\n99: \t}\n100: \treturn nil\n101: }\n102: \n103: func (s *redisStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n104: \tpattern := \"session:*\"\n105: \tkeys, err := s.client.Keys(ctx, pattern).Result()\n106: \tif err != nil {\n107: \t\treturn nil, fmt.Errorf(\"failed to list sessions: %w\", err)\n108: \t}\n109: \n110: \tresult := make(map[string]*types.SandboxInfo)\n111: \tfor _, key := range keys {\n112: \t\tdata, err := s.client.Get(ctx, key).Result()\n113: \t\tif err != nil {\n114: \t\t\tif err == redis.Nil {\n115: \t\t\t\tcontinue\n116: \t\t\t}\n117: \t\t\tklog.Warningf(\"Failed to get session %s: %v\", key, err)\n118: \t\t\tcontinue\n119: \t\t}\n120: \n121: \t\tinfo := &types.SandboxInfo{}\n122: \t\tif err := unmarshalSandboxInfo(data, info); err != nil {\n123: \t\t\tklog.Warningf(\"Failed to unmarshal session %s: %v\", key, err)\n124: \t\t\tcontinue\n125: \t\t}\n126: \n127: \t\tresult[key] = info\n128: \t}\n129: \n130: \treturn result, nil\n131: }\n132: \n133: func (s *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n134: \tinfo, err := s.GetSandbox(ctx, sessionID)\n135: \tif err != nil {\n136: \t\treturn fmt.Errorf(\"failed to get sandbox: %w\", err)\n137: \t}\n138: \n139: \tinfo.LastActivityAt = at\n140: \treturn s.UpdateSandbox(ctx, sessionID, info)\n141: }\n142: \n143: func (s *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n144: \tsandboxes, err := s.ListSandboxes(ctx)\n145: \tif err != nil {\n146: \t\treturn nil, err\n147: \t}\n148: \n149: \tvar result []*types.SandboxInfo\n150: \tcount := 0\n151: \tfor _, info := range sandboxes {\n152: \t\tif count >= limit {\n153: \t\t\tbreak\n154: \t\t}\n155: \n156: \t\tif info.ExpiresAt.Before(before) {\n157: \t\t\tresult = append(result, info)\n158: \t\t\tcount++\n159: \t\t}\n160: \t}\n161: \n162: \treturn result, nil\n163: }\n164: \n165: func (s *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n166: \tsandboxes, err := s.ListSandboxes(ctx)\n167: \tif err != nil {\n168: \t\treturn nil, err\n169: \t}\n170: \n171: \tvar result []*types.SandboxInfo\n172: \tcount := 0\n173: \tfor _, info := range sandboxes {\n174: \t\tif count >= limit {\n175: \t\t\tbreak\n176: \t\t}\n177: \n178: \t\tif info.LastActivityAt.Before(before) {\n179: \t\t\tresult = append(result, info)\n180: \t\t\tcount++\n181: \t\t}\n182: \t}\n183: \n184: \treturn result, nil\n185: }\n186: \n187: func (s *redisStore) Close() error {\n188: \treturn s.client.Close()\n189: }\n190: \n191: func (s *redisStore) sessionKey(sessionID string) string {\n192: \treturn fmt.Sprintf(\"session:%s\", sessionID)\n193: }\n\n(End of file - total 193 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nvar ErrNotFound = errors.New(\"sandbox not found\")\n\ntype Store interface {\n\tPing(ctx context.Context) error\n\tGetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n\tStoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store.go","time":{"start":1775844665466,"end":1775844665588}}}}
