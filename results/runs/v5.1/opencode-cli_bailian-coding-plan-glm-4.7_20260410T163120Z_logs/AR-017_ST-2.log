 = \"application/octet-stream\"\n48: \tMIMEMultipart   = \"multipart/form-data\"\n49: )\n50: \n51: const (\n52: \tErrMsgMissingAuthHeader = \"Missing Authorization header\"\n53: \tErrMsgInvalidAuthFormat = \"Use Bearer <token> format\"\n54: \tErrMsgInvalidToken      = \"Invalid token\"\n55: \tErrMsgEmptyCommand      = \"command cannot be empty\"\n56: \tErrMsgMissingPathParam  = \"Missing 'path' query parameter\"\n57: \tErrMsgDirectoryNotFound = \"Directory not found\"\n58: \tErrMsgFileNotFound      = \"File not found\"\n59: \tErrMsgPathIsDirectory   = \"Path is a directory, not a file\"\n60: \tErrMsgAccessDenied      = \"Access denied: path escapes workspace\"\n61: \tErrMsgInvalidWorkingDir = \"Invalid working directory: \"\n62: \tErrMsgWorkspaceNotInit  = \"workspace directory not initialized\"\n63: \tErrMsgInvalidBase64     = \"invalid base64 encoding\"\n64: \tErrMsgPathTooLong       = \"path exceeds maximum length\"\n65: )\n\n(End of file - total 65 lines)\n</content>","metadata":{"preview":"package picod\n\nimport \"time\"\n\nconst (\n\tPublicKeyEnvVar           = \"PICOD_AUTH_PUBLIC_KEY\"\n\tK8sInClusterEnvVar        = \"PICOD_K8S_IN_CLUSTER\"\n\tK8sKubeconfigEnvVar       = \"PICOD_K8S_KUBECONFIG\"\n\tK8sNamespaceEnvVar        = \"PICOD_K8S_NAMESPACE\"\n\tK8sAgentRuntimeNameEnvVar = \"PICOD_K8S_AGENT_RUNTIME_NAME\"\n)\n\nconst (\n\tTimeoutExitCode = 124\n)\n\nconst (\n\tMaxBodySize     = 32 << 20\n\tMaxPathLength   = 4096\n\tFileLockTimeout = 30 * time.Second","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/constants.go","time":{"start":1775860619206,"end":1775860619228}}}}
