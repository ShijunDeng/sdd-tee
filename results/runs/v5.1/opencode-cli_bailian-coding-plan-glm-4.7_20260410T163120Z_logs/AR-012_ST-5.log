{"type":"tool_use","timestamp":1775853356178,"sessionID":"ses_286e94b72ffeWiya1gSc36VaAY","part":{"id":"prt_d791bc310001MNAaWU0txdzWyX","messageID":"msg_d791b3b22001O0gOcxNafc2o6J","sessionID":"ses_286e94b72ffeWiya1gSc36VaAY","type":"tool","tool":"write","callID":"toolu_tool-3d44e22de09d476e8b277dd183c44887","state":{"status":"completed","input":{"content":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc newValkeyStore(addr string, password string, db int) (Store, error) {\n\tdialer := net.Dialer{\n\t\tTimeout:   5 * time.Second,\n\t\tKeepAlive: 30 * time.Second,\n\t}\n\n\toptions := valkey.ClientOption{\n\t\tInitAddress:       []string{addr},\n\t\tPassword:          password,\n\t\tSelectDB:          db,\n\t\tDisableCache:      os.Getenv(\"VALKEY_DISABLE_CACHE\") == \"true\",\n\t\tForceSingleClient: os.Getenv(\"VALKEY_FORCE_SINGLE\") == \"true\",\n\t\tDialer:            dialer,\n\t}\n\n\tcli, err := valkey.NewClient(options)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n\t}\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\n\tresult, err := cli.Do(ctx, cli.B().Ping().Build()).ToString()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to ping valkey: %w\", err)\n\t}\n\tif result != \"PONG\" {\n\t\treturn nil, fmt.Errorf(\"unexpected ping response: %s\", result)\n\t}\n\n\treturn &valkeyStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}, nil\n}\n\nfunc (s *valkeyStore) Ping(ctx context.Context) error {\n\tresult, err := s.cli.Do(ctx, s.cli.B().Ping().Build()).ToString()\n\tif err != nil {\n\t\treturn err\n\t}\n\tif result != \"PONG\" {\n\t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n\t}\n\treturn nil\n}\n\nfunc (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\tkey := s.sessionPrefix + sessionID\n\tdata := s.cli.Do(ctx, s.cli.B().Get().Key(key).Build())\n\n\tif valkey.IsValkeyNil(data.Error()) {\n\t\treturn nil, ErrNotFound\n\t}\n\n\tif data.Error() != nil {\n\t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", data.Error())\n\t}\n\n\tbytes, err := data.AsBytes()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n\t}\n\n\tinfo := &types.SandboxInfo{}\n\tif err := unmarshalSandboxInfo(string(bytes), info); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n\t}\n\n\treturn info, nil\n}\n\nfunc (s *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn fmt.Errorf(\"session ID cannot be empty\")\n\t}\n\tif sandboxStore.ExpiresAt.IsZero() {\n\t\treturn fmt.Errorf(\"expires at cannot be zero\")\n\t}\n\n\tkey := s.sessionPrefix + sandboxStore.SessionID\n\tdata, err := marshalSandboxInfo(sandboxStore)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n\t}\n\n\tcommands := []valkey.Completed{\n\t\ts.cli.B().Set().Key(key).Value(data).Nx().Build(),\n\t\ts.cli.B().Zadd().Key(s.expiryIndexKey).Member().Member(sandboxStore.SessionID).Score(float64(sandboxStore.ExpiresAt.Unix())).Build(),\n\t\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).Member().Member(sandboxStore.SessionID).Score(float64(time.Now().Unix())).Build(),\n\t}\n\n\tfor _, cmd := range commands {\n\t\tif err := s.cli.Do(ctx, cmd).Error(); err != nil {\n\t\t\treturn fmt.Errorf(\"failed to store sandbox: %w\", err)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (s *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn fmt.Errorf(\"session ID cannot be empty\")\n\t}\n\n\tkey := s.sessionPrefix + sandboxStore.SessionID\n\tdata, err := marshalSandboxInfo(sandboxStore)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n\t}\n\n\tresult, err := s.cli.Do(ctx, s.cli.B().Set().Key(key).Value(data).Xx().Build()).ToString()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to update sandbox: %w\", err)\n\t}\n\tif result != \"OK\" {\n\t\treturn ErrNotFound\n\t}\n\n\treturn nil\n}\n\nfunc (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\tkey := s.sessionPrefix + sessionID\n\n\tcommands := []valkey.Completed{\n\t\ts.cli.B().Del().Key(key).Build(),\n\t\ts.cli.B().Zrem().Key(s.expiryIndexKey).Member(sessionID).Build(),\n\t\ts.cli.B().Zrem().Key(s.lastActivityIndexKey).Member(sessionID).Build(),\n\t}\n\n\tfor _, cmd := range commands {\n\t\tif err := s.cli.Do(ctx, cmd).Error(); err != nil {\n\t\t\treturn fmt.Errorf(\"failed to delete sandbox: %w\", err)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tsessionIDs, err := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.expiryIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()).ToArray()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to list expired sandboxes: %w\", err)\n\t}\n\n\treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n}\n\nfunc (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tsessionIDs, err := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.lastActivityIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()).ToArray()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to list inactive sandboxes: %w\", err)\n\t}\n\n\treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n}\n\nfunc (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n\tkey := s.sessionPrefix + sessionID\n\n\texists, err := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build()).ToInt64()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to check session existence: %w\", err)\n\t}\n\tif exists != 1 {\n\t\treturn ErrNotFound\n\t}\n\n\tif err := s.cli.Do(ctx, s.cli.B().Zadd().Key(s.lastActivityIndexKey).Member().Member(sessionID).Score(float64(at.Unix())).Build()).Error(); err != nil {\n\t\treturn fmt.Errorf(\"failed to update last activity: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *valkeyStore) Close() error {\n\ts.cli.Close()\n\treturn nil\n}\n\nfunc (s *valkeyStore) getSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n\tif len(sessionIDs) == 0 {\n\t\treturn []*types.SandboxInfo{}, nil\n\t}\n\n\tkeys := make([]string, len(sessionIDs))\n\tfor i, sessionID := range sessionIDs {\n\t\tkeys[i] = s.sessionPrefix + sessionID\n\t}\n\n\tvalues, err := s.cli.Do(ctx, s.cli.B().Mget().Key(keys...).Build()).ToArray()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to get sandbox data: %w\", err)\n\t}\n\n\tresult := make([]*types.SandboxInfo, 0, len(sessionIDs))\n\tfor _, value := range values {\n\t\tif valkey.IsValkeyNil(value.Error()) {\n\t\t\tcontinue\n\t\t}\n\n\t\tif value.Error() != nil {\n\t\t\tklog.Warningf(\"Failed to get value: %v\", value.Error())\n\t\t\tcontinue\n\t\t}\n\n\t\tbytes, err := value.AsBytes()\n\t\tif err != nil {\n\t\t\tklog.Warningf(\"Failed to convert value to bytes: %v\", err)\n\t\t\tcontinue\n\t\t}\n\n\t\tinfo := &types.SandboxInfo{}\n\t\tif err := unmarshalSandboxInfo(