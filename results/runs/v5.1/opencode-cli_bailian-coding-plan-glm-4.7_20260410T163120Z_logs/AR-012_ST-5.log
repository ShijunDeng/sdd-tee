onPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc newRedisStore(addr string, password string, db int) (Store, error) {\n\tcli := redis.NewClient(&redis.Options{\n\t\tAddr:     addr,\n\t\tPassword: password,\n\t\tDB:       db,\n\t})\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\n\tif err := cli.Ping(ctx).Err(); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to connect to redis: %w\", err)\n\t}\n\n\treturn &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}, nil\n}\n\nfunc (s *redisStore) Ping(ctx context.Context) error {\n\tresult := s.cli.Ping(ctx)\n\tif result.Err() != nil {\n\t\treturn result.Err()\n\t}\n\tif result.Val() != \"PONG\" {\n\t\treturn fmt.Errorf(\"unexpected ping response: %s\", result.Val())\n\t}\n\treturn nil\n}\n\nfunc (s *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\tkey := s.sessionPrefix + sessionID\n\tdata, err := s.cli.Get(ctx, key).Result()\n\tif err != nil {\n\t\tif err == redis.Nil {\n\t\t\treturn nil, ErrNotFound\n\t\t}\n\t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n\t}\n\n\tinfo := &types.SandboxInfo{}\n\tif err := unmarshalSandboxInfo(data, info); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n\t}\n\n\treturn info, nil\n}\n\nfunc (s *redisStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn fmt.Errorf(\"session ID cannot be empty\")\n\t}\n\tif sandboxStore.ExpiresAt.IsZero() {\n\t\treturn fmt.Errorf(\"expires at cannot be zero\")\n\t}\n\n\tkey := s.sessionPrefix + sandboxStore.SessionID\n\tdata, err := marshalSandboxInfo(sandboxStore)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n\t}\n\n\tpipe := s.cli.Pipeline()\n\n\tpipe.SetNX(ctx, key, data, 0)\n\n\tpipe.ZAdd(ctx, s.expiryIndexKey, redis.Z{\n\t\tScore:  float64(sandboxStore.ExpiresAt.Unix()),\n\t\tMember: sandboxStore.SessionID,\n\t})\n\n\tpipe.ZAdd(ctx, s.lastActivityIndexKey, redis.Z{\n\t\tScore:  float64(time.Now().Unix()),\n\t\tMember: sandboxStore.SessionID,\n\t})\n\n\tif _, err := pipe.Exec(ctx); err != nil {\n\t\treturn fmt.Errorf(\"failed to store sandbox: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn fmt.Errorf(\"session ID cannot be empty\")\n\t}\n\n\tkey := s.sessionPrefix + sandboxStore.SessionID\n\tdata, err := marshalSandboxInfo(sandboxStore)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n\t}\n\n\tresult := s.cli.Set(ctx, key, data, 0).XX()\n\tif result.Err() != nil {\n\t\treturn fmt.Errorf(\"failed to update sandbox: %w\", result.Err())\n\t}\n\tif result.Val() != \"OK\" {\n\t\treturn ErrNotFound\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\tkey := s.sessionPrefix + sessionID\n\n\tpipe := s.cli.Pipeline()\n\n\tpipe.Del(ctx, key)\n\n\tpipe.ZRem(ctx, s.expiryIndexKey, sessionID)\n\n\tpipe.ZRem(ctx, s.lastActivityIndexKey, sessionID)\n\n\tif _, err := pipe.Exec(ctx); err != nil {\n\t\treturn fmt.Errorf(\"failed to delete sandbox: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.expiryIndexKey, &redis.ZRangeBy{\n\t\tMin:    \"-inf\",\n\t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n\t\tOffset: 0,\n\t\tCount:  limit,\n\t}).Result()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to list expired sandboxes: %w\", err)\n\t}\n\n\treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n}\n\nfunc (s *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.lastActivityIndexKey, &redis.ZRangeBy{\n\t\tMin:    \"-inf\",\n\t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n\t\tOffset: 0,\n\t\tCount:  limit,\n\t}).Result()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to list inactive sandboxes: %w\", err)\n\t}\n\n\treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n}\n\nfunc (s *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n\tkey := s.sessionPrefix + sessionID\n\n\texists, err := s.cli.Exists(ctx, key).Result()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to check session existence: %w\", err)\n\t}\n\tif exists == 0 {\n\t\treturn ErrNotFound\n\t}\n\n\tif err := s.cli.ZAdd(ctx, s.lastActivityIndexKey, redis.Z{\n\t\tScore:  float64(at.Unix()),\n\t\tMember: sessionID,\n\t}).Err(); err != nil {\n\t\treturn fmt.Errorf(\"failed to update last activity: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) Close() error {\n\treturn s.cli.Close()\n}\n\nfunc (s *redisStore) getSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n\tif len(sessionIDs) == 0 {\n\t\treturn []*types.SandboxInfo{}, nil\n\t}\n\n\tkeys := make([]string, len(sessionIDs))\n\tfor i, sessionID := range sessionIDs {\n\t\tkeys[i] = s.sessionPrefix + sessionID\n\t}\n\n\tvalues, err := s.cli.MGet(ctx, keys...).Result()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to get sandbox data: %w\", err)\n\t}\n\n\tresult := make([]*types.SandboxInfo, 0, len(sessionIDs))\n\tfor _, value := range values {\n\t\tif value == nil {\n\t\t\tcontinue\n\t\t}\n\t\tdata, ok := value.(string)\n\t\tif !ok {\n\t\t\tcontinue\n\t\t}\n\n\t\tinfo := &types.SandboxInfo{}\n\t\tif err := unmarshalSandboxInfo(data, info); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n\t\t}\n\n\t\tresult = append(result, info)\n\t}\n\n\treturn result, nil\n}\n","after":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype redisStore struct {\n\tcli                  *redis.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc newRedisStore(addr string, password string, db int) (Store, error) {\n\tcli := redis.NewClient(&redis.Options{\n\t\tAddr:     addr,\n\t\tPassword: password,\n\t\tDB:       db,\n\t})\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\n\tif err := cli.Ping(ctx).Err(); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to connect to redis: %w\", err)\n\t}\n\n\treturn &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}, nil\n}\n\nfunc (s *redisStore) Ping(ctx context.Context) error {\n\tresult := s.cli.Ping(ctx)\n\tif result.Err() != nil {\n\t\treturn result.Err()\n\t}\n\tif result.Val() != \"PONG\" {\n\t\treturn fmt.Errorf(\"unexpected ping response: %s\", result.Val())\n\t}\n\treturn nil\n}\n\nfunc (s *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\tkey := s.sessionPrefix + sessionID\n\tdata, err := s.cli.Get(ctx, key).Result()\n\tif err != nil {\n\t\tif err == redis.Nil {\n\t\t\treturn nil, ErrNotFound\n\t\t}\n\t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n\t}\n\n\tinfo := &types.SandboxInfo{}\n\tif err := unmarshalSandboxInfo(data, info); err != nil {\n\t\treturn nil, fmt.Errorf(\"