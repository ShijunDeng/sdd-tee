, err := store.GetSandbox(ctx, sessionID)\n49: \t\trequire.NoError(t, err)\n50: \t\tassert.Equal(t, sessionID, retrieved.SessionID)\n51: \t\tassert.Equal(t, \"test-sandbox\", retrieved.SandboxName)\n52: \t\tassert.Equal(t, \"AgentRuntime\", retrieved.Kind)\n53: \t})\n54: \n55: \tt.Run(\"Get Non-Existent Sandbox\", func(t *testing.T) {\n56: \t\t_, err := store.GetSandbox(ctx, \"non-existent\")\n57: \t\tassert.Error(t, err)\n58: \t\tassert.Equal(t, ErrNotFound, err)\n59: \t})\n60: \n61: \tt.Run(\"Update Sandbox\", func(t *testing.T) {\n62: \t\tsessionID := \"test-session-2\"\n63: \t\tinfo := &types.SandboxInfo{\n64: \t\t\tSessionID:    sessionID,\n65: \t\t\tSandboxName:  \"test-sandbox-2\",\n66: \t\t\tWorkloadName: \"test-workload\",\n67: \t\t\tNamespace:    \"default\",\n68: \t\t\tKind:         \"CodeInterpreter\",\n69: \t\t\tStatus:       \"pending\",\n70: \t\t\tCreatedAt:    time.Now(),\n71: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n72: \t\t}\n73: \n74: \t\terr := store.StoreSandbox(ctx, sessionID, info)\n75: \t\trequire.NoError(t, err)\n76: \n77: \t\tinfo.Status = \"running\"\n78: \t\tinfo.PodIP = \"10.0.0.2\"\n79: \n80: \t\terr = store.UpdateSandbox(ctx, sessionID, info)\n81: \t\trequire.NoError(t, err)\n82: \n83: \t\tretrieved, err := store.GetSandbox(ctx, sessionID)\n84: \t\trequire.NoError(t, err)\n85: \t\tassert.Equal(t, \"running\", retrieved.Status)\n86: \t\tassert.Equal(t, \"10.0.0.2\", retrieved.PodIP)\n87: \t})\n88: \n89: \tt.Run(\"Delete Sandbox\", func(t *testing.T) {\n90: \t\tsessionID := \"test-session-3\"\n91: \t\tinfo := &types.SandboxInfo{\n92: \t\t\tSessionID:    sessionID,\n93: \t\t\tSandboxName:  \"test-sandbox-3\",\n94: \t\t\tWorkloadName: \"test-workload\",\n95: \t\t\tNamespace:    \"default\",\n96: \t\t\tKind:         \"AgentRuntime\",\n97: \t\t\tStatus:       \"running\",\n98: \t\t\tCreatedAt:    time.Now(),\n99: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n100: \t\t}\n101: \n102: \t\terr := store.StoreSandbox(ctx, sessionID, info)\n103: \t\trequire.NoError(t, err)\n104: \n105: \t\terr = store.DeleteSandboxBySessionID(ctx, sessionID)\n106: \t\trequire.NoError(t, err)\n107: \n108: \t\t_, err = store.GetSandbox(ctx, sessionID)\n109: \t\tassert.Error(t, err)\n110: \t\tassert.Equal(t, ErrNotFound, err)\n111: \t})\n112: \n113: \tt.Run(\"Update Session Last Activity\", func(t *testing.T) {\n114: \t\tsessionID := \"test-session-4\"\n115: \t\tinfo := &types.SandboxInfo{\n116: \t\t\tSessionID:    sessionID,\n117: \t\t\tSandboxName:  \"test-sandbox-4\",\n118: \t\t\tWorkloadName: \"test-workload\",\n119: \t\t\tNamespace:    \"default\",\n120: \t\t\tKind:         \"AgentRuntime\",\n121: \t\t\tStatus:       \"running\",\n122: \t\t\tCreatedAt:    time.Now().Add(-1 * time.Hour),\n123: \t\t\tExpiresAt:    time.Now().Add(7 * time.Hour),\n124: \t\t}\n125: \n126: \t\terr := store.StoreSandbox(ctx, sessionID, info)\n127: \t\trequire.NoError(t, err)\n128: \n129: \t\tnewActivityTime := time.Now()\n130: \t\terr = store.UpdateSessionLastActivity(ctx, sessionID, newActivityTime)\n131: \t\trequire.NoError(t, err)\n132: \n133: \t\tretrieved, err := store.GetSandbox(ctx, sessionID)\n134: \t\trequire.NoError(t, err)\n135: \t\tassert.WithinDuration(t, newActivityTime, retrieved.LastActivityAt, time.Second)\n136: \t})\n137: \n138: \tt.Run(\"List Expired Sandboxes\", func(t *testing.T) {\n139: \t\tsessionID1 := \"expired-session-1\"\n140: \t\tsessionID2 := \"expired-session-2\"\n141: \t\tsessionID3 := \"active-session\"\n142: \n143: \t\tnow := time.Now()\n144: \n145: \t\texpiredInfo1 := &types.SandboxInfo{\n146: \t\t\tSessionID:    sessionID1,\n147: \t\t\tSandboxName:  \"expired-1\",\n148: \t\t\tWorkloadName: \"test\",\n149: \t\t\tNamespace:    \"default\",\n150: \t\t\tKind:         \"AgentRuntime\",\n151: \t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n152: \t\t\tExpiresAt:    now.Add(-1 * time.Hour),\n153: \t\t}\n154: \n155: \t\texpiredInfo2 := &types.SandboxInfo{\n156: \t\t\tSessionID:    sessionID2,\n157: \t\t\tSandboxName:  \"expired-2\",\n158: \t\t\tWorkloadName: \"test\",\n159: \t\t\tNamespace:    \"default\",\n160: \t\t\tKind:         \"AgentRuntime\",\n161: \t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n162: \t\t\tExpiresAt:    now.Add(-30 * time.Minute),\n163: \t\t}\n164: \n165: \t\tactiveInfo := &types.SandboxInfo{\n166: \t\t\tSessionID:    sessionID3,\n167: \t\t\tSandboxName:  \"active\",\n168: \t\t\tWorkloadName: \"test\",\n169: \t\t\tNamespace:    \"default\",\n170: \t\t\tKind:         \"AgentRuntime\",\n171: \t\t\tCreatedAt:    now,\n172: \t\t\tExpiresAt:    now.Add(8 * time.Hour),\n173: \t\t}\n174: \n175: \t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID1, expiredInfo1))\n176: \t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID2, expiredInfo2))\n177: \t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID3, activeInfo))\n178: \n179: \t\texpired, err := store.ListExpiredSandboxes(ctx, now, 10)\n180: \t\trequire.NoError(t, err)\n181: \t\tassert.Len(t, expired, 2)\n182: \n183: \t\tsessionIDs := make([]string, 0, len(expired))\n184: \t\tfor _, sb := range expired {\n185: \t\t\tsessionIDs = append(sessionIDs, sb.SessionID)\n186: \t\t}\n187: \t\tassert.Contains(t, sessionIDs, sessionID1)\n188: \t\tassert.Contains(t, sessionIDs, sessionID2)\n189: \t\tassert.NotContains(t, sessionIDs, sessionID3)\n190: \t})\n191: \n192: \tt.Run(\"List Inactive Sandboxes\", func(t *testing.T) {\n193: \t\tsessionID1 := \"inactive-session-test-1\"\n194: \t\tsessionID2 := \"inactive-session-test-2\"\n195: \t\tsessionID3 := \"recent-session-test\"\n196: \n197: \t\tnow := time.Now()\n198: \t\tinactiveThreshold := now.Add(-15 * time.Minute)\n199: \n200: \t\tinactiveInfo1 := &types.SandboxInfo{\n201: \t\t\tSessionID:      sessionID1,\n202: \t\t\tSandboxName:    \"inactive-1\",\n203: \t\t\tWorkloadName:   \"test\",\n204: \t\t\tNamespace:      \"default\",\n205: \t\t\tKind:           \"AgentRuntime\",\n206: \t\t\tCreatedAt:      now.Add(-1 * time.Hour),\n207: \t\t\tExpiresAt:      now.Add(7 * time.Hour),\n208: \t\t\tLastActivityAt: now.Add(-20 * time.Minute),\n209: \t\t}\n210: \n211: \t\tinactiveInfo2 := &types.SandboxInfo{\n212: \t\t\tSessionID:      sessionID2,\n213: \t\t\tSandboxName:    \"inactive-2\",\n214: \t\t\tWorkloadName:   \"test\",\n215: \t\t\tNamespace:      \"default\",\n216: \t\t\tKind:           \"AgentRuntime\",\n217: \t\t\tCreatedAt:      now.Add(-1 * time.Hour),\n218: \t\t\tExpiresAt:      now.Add(7 * time.Hour),\n219: \t\t\tLastActivityAt: now.Add(-30 * time.Minute),\n220: \t\t}\n221: \n222: \t\trecentInfo := &types.SandboxInfo{\n223: \t\t\tSessionID:      sessionID3,\n224: \t\t\tSandboxName:    \"recent\",\n225: \t\t\tWorkloadName:   \"test\",\n226: \t\t\tNamespace:      \"default\",\n227: \t\t\tKind:           \"AgentRuntime\",\n228: \t\t\tCreatedAt:      now,\n229: \t\t\tExpiresAt:      now.Add(8 * time.Hour),\n230: \t\t\tLastActivityAt: now,\n231: \t\t}\n232: \n233: \t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID1, inactiveInfo1))\n234: \t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID2, inactiveInfo2))\n235: \t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID3, recentInfo))\n236: \n237: \t\tinactive, err := store.ListInactiveSandboxes(ctx, inactiveThreshold, 10)\n238: \t\trequire.NoError(t, err)\n239: \n240: \t\tinactiveSessionIDs := make([]string, 0)\n241: \t\tfor _, sb := range inactive {\n242: \t\t\tif sb.SessionID == sessionID1 || sb.SessionID == sessionID2 {\n243: \t\t\t\tinactiveSessionIDs = append(inactiveSessionIDs, sb.SessionID)\n244: \t\t\t}\n245: \t\t}\n246: \n247: \t\tassert.Contains(t, inactiveSessionIDs, sessionID1)\n248: \t\tassert.Contains(t, inactiveSessionIDs, sessionID2)\n249: \t})\n250: }\n\n(End of file - total 250 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\n\t\"github.com/volcano-sh/a