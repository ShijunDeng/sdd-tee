lly\")\n47: \n48: \treturn &AuthManager{\n49: \t\tpublicKey: rsaPublicKey,\n50: \t}, nil\n51: }\n52: \n53: func (am *AuthManager) ValidateToken(tokenString string) (*AuthClaims, error) {\n54: \tam.mutex.RLock()\n55: \tdefer am.mutex.RUnlock()\n56: \n57: \ttoken, err := jwt.ParseWithClaims(tokenString, &AuthClaims{}, func(token *jwt.Token) (interface{}, error) {\n58: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n59: \t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n60: \t\t}\n61: \t\treturn am.publicKey, nil\n62: \t}, jwt.WithLeeway(1*time.Minute))\n63: \n64: \tif err != nil {\n65: \t\tif validationErr, ok := err.(*jwt.ValidationError); ok {\n66: \t\t\tswitch {\n67: \t\t\tcase validationErr.Errors&jwt.ValidationErrorExpired != 0:\n68: \t\t\t\treturn nil, NewError(ErrTokenExpired, \"token expired\", \"\", err)\n69: \t\t\tcase validationErr.Errors&jwt.ValidationErrorSignatureInvalid != 0:\n70: \t\t\t\treturn nil, NewError(ErrInvalidSignature, \"invalid signature\", \"\", err)\n71: \t\t\tdefault:\n72: \t\t\t\treturn nil, NewError(ErrInvalidToken, \"token validation failed\", \"\", err)\n73: \t\t\t}\n74: \t\t}\n75: \t\treturn nil, NewError(ErrInvalidToken, \"invalid token\", \"\", err)\n76: \t}\n77: \n78: \tif claims, ok := token.Claims.(*AuthClaims); ok && token.Valid {\n79: \t\treturn claims, nil\n80: \t}\n81: \n82: \treturn nil, NewError(ErrInvalidToken, \"invalid token claims\", \"\", nil)\n83: }\n\n(End of file - total 83 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"os\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype AuthClaims struct {\n\tjwt.RegisteredClaims\n}\n\ntype AuthManager struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/auth.go","time":{"start":1775858495256,"end":1775858495263