      \"\",\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/auth_test.go","before":"package picod\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc generateTestKeyPair(t *testing.T) (*rsa.PrivateKey, *rsa.PublicKey) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\treturn privateKey, &privateKey.PublicKey\n}\n\nfunc publicKeyToPEM(t *testing.T, publicKey *rsa.PublicKey) string {\n\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: publicKeyBytes,\n\t})\n\n\treturn string(publicKeyPEM)\n}\n\nfunc createTestToken(t *testing.T, privateKey *rsa.PrivateKey) string {\n\tclaims := AuthClaims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now()),\n\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),\n\t\t},\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, err := token.SignedString(privateKey)\n\trequire.NoError(t, err)\n\n\treturn tokenString\n}\n\nfunc TestNewAuthManager(t *testing.T) {\n\t_, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n\n\ttests := []struct {\n\t\tname     string\n\t\tsetupEnv func()\n\t\twantErr  bool\n\t\terrMsg   string\n\t\tcleanup  func()\n\t}{\n\t\t{\n\t\t\tname: \"success with valid public key\",\n\t\t\tsetupEnv: func() {\n\t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\t\t\t},\n\t\t\twantErr: false,\n\t\t\tcleanup: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"error when public key not set\",\n\t\t\tsetupEnv: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t\twantErr: true,\n\t\t\terrMsg:  \"public key not found\",\n\t\t\tcleanup: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"error with invalid PEM format\",\n\t\t\tsetupEnv: func() {\n\t\t\t\tos.Setenv(PublicKeyEnvVar, \"invalid pem\")\n\t\t\t},\n\t\t\twantErr: true,\n\t\t\terrMsg:  \"invalid PEM format\",\n\t\t\tcleanup: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\ttt.setupEnv()\n\t\t\tdefer tt.cleanup()\n\n\t\t\tam, err := NewAuthManager()\n\n\t\t\tif tt.wantErr {\n\t\t\t\tassert.Error(t, err)\n\t\t\t\tassert.Nil(t, am)\n\t\t\t\tif tt.errMsg != \"\" {\n\t\t\t\t\tassert.Contains(t, err.Error(), tt.errMsg)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tassert.NoError(t, err)\n\t\t\t\tassert.NotNil(t, am)\n\t\t\t\tassert.NotNil(t, am.publicKey)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestValidateToken(t *testing.T) {\n\tprivateKey, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tam, err := NewAuthManager()\n\trequire.NoError(t, err)\n\n\tvalidToken := createTestToken(t, privateKey)\n\n\texpiredClaims := AuthClaims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now().Add(-2 * time.Hour)),\n\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(-1 * time.Hour)),\n\t\t},\n\t}\n\texpiredToken := jwt.NewWithClaims(jwt.SigningMethodRS256, expiredClaims)\n\texpiredTokenString, _ := expiredToken.SignedString(privateKey)\n\n\ttests := []struct {\n\t\tname        string\n\t\ttoken       string\n\t\twantErr     bool\n\t\terrContains string\n\t}{\n\t\t{\n\t\t\tname:    \"valid token\",\n\t\t\ttoken:   validToken,\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"invalid token format\",\n\t\t\ttoken:       \"invalid.token.string\",\n\t\t\twantErr:     true,\n\t\t\terrContains: \"invalid token\",\n\t\t},\n\t\t{\n\t\t\tname:        \"expired token\",\n\t\t\ttoken:       expiredTokenString,\n\t\t\twantErr:     true,\n\t\t\terrContains: \"token expired\",\n\t\t},\n\t\t{\n\t\t\tname:        \"empty token\",\n\t\t\ttoken:       \"\",\n\t\t\twantErr:     true,\n\t\t\terrContains: \"invalid token\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tclaims, err := am.ValidateToken(tt.token)\n\n\t\t\tif tt.wantErr {\n\t\t\t\tassert.Error(t, err)\n\t\t\t\tassert.Nil(t, claims)\n\t\t\t\tif tt.errContains != \"\" {\n\t\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tassert.NoError(t, err)\n\t\t\t\tassert.NotNil(t, claims)\n\t\t\t}\n\t\t})\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc generateTestKeyPair(t *testing.T) (*rsa.PrivateKey, *rsa.PublicKey) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\treturn privateKey, &privateKey.PublicKey\n}\n\nfunc publicKeyToPEM(t *testing.T, publicKey *rsa.PublicKey) string {\n\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: publicKeyBytes,\n\t})\n\n\treturn string(publicKeyPEM)\n}\n\nfunc createTestToken(t *testing.T, privateKey *rsa.PrivateKey) string {\n\tclaims := AuthClaims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now()),\n\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),\n\t\t},\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, err := token.SignedString(privateKey)\n\trequire.NoError