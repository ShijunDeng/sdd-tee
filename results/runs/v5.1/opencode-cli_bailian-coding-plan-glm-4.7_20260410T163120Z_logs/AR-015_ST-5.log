","before":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"os\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype AuthClaims struct {\n\tjwt.RegisteredClaims\n}\n\ntype AuthManager struct {\n\tpublicKey *rsa.PublicKey\n\tmutex     sync.RWMutex\n}\n\nfunc NewAuthManager() (*AuthManager, error) {\n\tpublicKeyPEM := os.Getenv(PublicKeyEnvVar)\n\tif publicKeyPEM == \"\" {\n\t\treturn nil, NewError(ErrInvalidPublicKey, \"public key not found\", \"PICOD_AUTH_PUBLIC_KEY environment variable is not set\", nil)\n\t}\n\n\tblock, _ := pem.Decode([]byte(publicKeyPEM))\n\tif block == nil {\n\t\treturn nil, NewError(ErrInvalidPublicKey, \"invalid PEM format\", \"failed to decode PEM block\", nil)\n\t}\n\n\tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n\tif err != nil {\n\t\treturn nil, NewError(ErrInvalidPublicKey, \"failed to parse public key\", err.Error(), err)\n\t}\n\n\trsaPublicKey, ok := pubKey.(*rsa.PublicKey)\n\tif !ok {\n\t\treturn nil, NewError(ErrInvalidPublicKey, \"not an RSA public key\", \"expected RSA public key\", nil)\n\t}\n\n\tklog.Info(\"Auth manager initialized successfully\")\n\n\treturn &AuthManager{\n\t\tpublicKey: rsaPublicKey,\n\t}, nil\n}\n\nfunc (am *AuthManager) ValidateToken(tokenString string) (*AuthClaims, error) {\n\tam.mutex.RLock()\n\tdefer am.mutex.RUnlock()\n\n\ttoken, err := jwt.ParseWithClaims(tokenString, &AuthClaims{}, func(token *jwt.Token) (interface{}, error) {\n\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n\t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n\t\t}\n\t\treturn am.publicKey, nil\n\t}, jwt.WithLeeway(1*time.Minute))\n\n\tif err != nil {\n\t\tif validationErr, ok := err.(*jwt.ValidationError); ok {\n\t\t\tswitch {\n\t\t\tcase validationErr.Errors&jwt.ValidationErrorExpired != 0:\n\t\t\t\treturn nil, NewError(ErrTokenExpired, \"token expired\", \"\", err)\n\t\t\tcase validationErr.Errors&jwt.ValidationErrorSignatureInvalid != 0:\n\t\t\t\treturn nil, NewError(ErrInvalidSignature, \"invalid signature\", \"\", err)\n\t\t\tdefault:\n\t\t\t\treturn nil, NewError(ErrInvalidToken, \"token validation failed\", \"\", err)\n\t\t\t}\n\t\t}\n\t\treturn nil, NewError(ErrInvalidToken, \"invalid token\", \"\", err)\n\t}\n\n\tif claims, ok := token.Claims.(*AuthClaims); ok && token.Valid {\n\t\treturn claims, nil\n\t}\n\n\treturn nil, NewError(ErrInvalidToken, \"invalid token claims\", \"\", nil)\n}\n","after":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"os\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype AuthClaims struct {\n\tjwt.RegisteredClaims\n}\n\ntype AuthManager struct {\n\tpublicKey *rsa.PublicKey\n\tmutex     sync.RWMutex\n}\n\nfunc NewAuthManager() (*AuthManager, error) {\n\tpublicKeyPEM := os.Getenv(PublicKeyEnvVar)\n\tif publicKeyPEM == \"\" {\n\t\treturn nil, NewError(ErrInvalidPublicKey, \"public key not found\", \"PICOD_AUTH_PUBLIC_KEY environment variable is not set\", nil)\n\t}\n\n\tblock, _ := pem.Decode([]byte(publicKeyPEM))\n\tif block == nil {\n\t\treturn nil, NewError(ErrInvalidPublicKey, \"invalid PEM format\", \"failed to decode PEM block\", nil)\n\t}\n\n\tpubKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n\tif err != nil {\n\t\treturn nil, NewError(ErrInvalidPublicKey, \"failed to parse public key\", err.Error(), err)\n\t}\n\n\trsaPublicKey, ok := pubKey.(*rsa.PublicKey)\n\tif !ok {\n\t\treturn nil, NewError(ErrInvalidPublicKey, \"not an RSA public key\", \"expected RSA public key\", nil)\n\t}\n\n\tklog.Info(\"Auth manager initialized successfully\")\n\n\treturn &AuthManager{\n\t\tpublicKey: rsaPublicKey,\n\t}, nil\n}\n\nfunc (am *AuthManager) ValidateToken(tokenString string) (*AuthClaims, error) {\n\tam.mutex.RLock()\n\tdefer am.mutex.RUnlock()\n\n\ttoken, err := jwt.ParseWithClaims(tokenString, &AuthClaims{}, func(token *jwt.Token) (interface{}, error) {\n\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n\t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n\t\t}\n\t\treturn am.publicKey, nil\n\t}, jwt.WithLeeway(1*time.Minute))\n\n\tif err != nil {\n\t\treturn nil, NewError(ErrInvalidToken, \"invalid token\", \"\", err)\n\t}\n\n\tif claims, ok := token.Claims.(*AuthClaims); ok && token.Valid {\n\t\treturn claims, nil\n\t}\n\n\treturn nil, NewError(ErrInvalidToken, \"invalid token claims\", \"\", nil)\n}\n","additions":0,"deletions":10},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/auth.go","time":{"start":1775858513366,"end":1775858513545}}}}
