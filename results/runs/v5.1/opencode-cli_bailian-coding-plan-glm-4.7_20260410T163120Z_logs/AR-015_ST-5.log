tions"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/errors.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/config.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/execute.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/files.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/auth.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/middleware.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/handlers.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/picod/flags.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/picod/main.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/auth_test.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go\n@@ -3,9 +3,8 @@\n import (\n \t\"net/http\"\n \t\"net/http/httptest\"\n \t\"os\"\n-\t\"strings\"\n \t\"testing\"\n \t\"time\"\n \n \t\"github.com/gin-gonic/gin\"\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go","before":"package picod\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc setupTestServer(t *testing.T) *Server {\n\tworkspace := t.TempDir()\n\n\t_, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tconfig := Config{\n\t\tPort:      0,\n\t\tWorkspace: workspace,\n\t}\n\n\tserver, err := NewServer(config)\n\trequire.NoError(t, err)\n\n\tgin.SetMode(gin.TestMode)\n\n\treturn server\n}\n\nfunc cleanupTestServer(t *testing.T, server *Server) {\n\tos.Unsetenv(PublicKeyEnvVar)\n}\n\nfunc TestSanitizePath(t *testing.T) {\n\tserver := setupTestServer(t)\n\tdefer cleanupTestServer(t, server)\n\n\ttests := []struct {\n\t\tname        string\n\t\tpath        string\n\t\twantErr     bool\n\t\terrContains string\n\t}{\n\t\t{\n\t\t\tname:    \"valid relative path\",\n\t\t\tpath:    \"test/file.txt\",\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname:    \"valid absolute path\",\n\t\t\tpath:    \"/test/file.txt\",\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"path traversal attempt\",\n\t\t\tpath:        \"../../etc/passwd\",\n\t\t\twantErr:     true,\n\t\t\terrContains: \"Access denied\",\n\t\t},\n\t\t{\n\t\t\tname:    \"empty path\",\n\t\t\tpath:    \"\",\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname:    \"single dot\",\n\t\t\tpath:    \".\",\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"double dot at root\",\n\t\t\tpath:        \"..\",\n\t\t\twantErr:     true,\n\t\t\terrContains: \"Access denied\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tresult, err := server.sanitizePath(tt.path)\n\n\t\t\tif tt.wantErr {\n\t\t\t\tassert.Error(t, err)\n\t\t\t\tif tt.errContains != \"\" {\n\t\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tassert.NoError(t, err)\n\t\t\t\tassert.NotEmpty(t, result)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestParseFileMode(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tmodeStr  string\n\t\texpected int\n\t}{\n\t\t{\n\t\t\tname:     \"default mode\",\n\t\t\tmodeStr:  \"\",\n\t\t\texpected: 0644,\n\t\t},\n\t\t{\n\t\t\tname:     \"valid octal mode\",\n\t\t\tmodeStr:  \"0644\",\n\t\t\texpected: 0644,\n\t\t},\n\t\t{\n\t\t\tname:     \"valid octal mode 0755\",\n\t\t\tmodeStr:  \"0755\",\n\t\t\texpected: 0755,\n\t\t},\n\t\t{\n\t\t\tname:     \"invalid format\",\n\t\t\tmodeStr:  \"invalid\",\n\t\t\texpected: 0644,\n\t\t},\n\t\t{\n\t\t\tname:     \"exceeds max\",\n\t\t\tmodeStr:  \"10000\",\n\t\t\texpected: 0644,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tresult := parseFileMode(tt.modeStr)\n\t\t\tassert.Equal(t, int(result), tt.expected)\n\t\t})\n\t}\n}\n\nfunc TestAuthMiddleware(t *testing.T) {\n\tserver := setupTestServer(t)\n\tdefer cleanupTestServer(t, server)\n\n\tprivateKey, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tserver, err := NewServer(Config{\n\t\tPort:      0,\n\t\tWorkspace: t.TempDir(),\n\t})\n\trequire.NoError(t, err)\n\n\tvalidToken := createTestToken(t, privateKey)\n\n\ttests := []struct {\n\t\tname           string\n\t\tsetupRequest   func(*http.Request)\n\t\twantStatusCode int\n\t\twantError      string\n\t}{\n\t\t{\n\t\t\tname: \"valid token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+validToken)\n\t\t\t},\n\t\t\twantStatusCode: http.StatusOK,\n\t\t},\n\t\t{\n\t\t\tname: \"missing authorization header\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t},\n\t\t\twantStatusCode: http.StatusUnauthorized,\n\t\t\twantError:      ErrMsgMissingAuthHeader,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"InvalidFormat token\")\n\t\t\t},\n\t\t\twantStatusCode: http.StatusUnauthorized,\n\t\t\twantError:      ErrMsgInvalidAuthFormat,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer invalid.token.here\")\n\t\t\t},\n\t\t\twantStatusCode: http.StatusUnauthorized,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\trouter := gin.New()\n\t\t\trouter.Use(AuthMiddleware(server.authManager))\n\t\t\trouter.GET(\"/test\", func(c *gin.Context) {\n\t\t\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n\t\t\t})\n\n\t\t\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\t\t\ttt.setupRequest(req)\n\t\t\tw := httptest.NewRecorder()\n\n\t\t\trouter.ServeHTTP(w, req)\n\n\t\t\tassert.Equal(t, tt.wantStatusCode, w.Code)\n\t\t\tif tt.wantError != \"\" {\n\t\t\t\tassert.Contains(t, w.Body.String(), tt.wantError)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestHealthCheckHandler(t *testing.T) {\n\tserver := setupTestServer(t)\n\tdefer cleanupTestServer(t, server)\n\n\treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n\tw := httptest.NewRecorder()\n\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), `\"status\":\"ok\"`)\n\tassert.Contains(t, w.Body.String(), `\"service\":\"PicoD\"`)\n\tassert.Contains(t, w.Body.String(), `\"version\":\"0.0.1\"`)\n\tassert.Contains(t, w.Body.String(), `\"uptime\"`)\n}\n\nfunc TestNewServer(t *testing.T) {\n\t_, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n\n\ttests := []struct {\n\t\tname     string\n\t\tconfig   Config\n\t\tsetupEnv func()\n\t\tcleanup  func()\n\t\twantErr  bool\n\t\terrMsg   string\n\t}{\n\t\t{\n\t\t\tname: \"success with default workspace\",\n\t\t\tconfig: Config{\n\t\t\t\tPort: DefaultPort,\n\t\t\t},\n\t\t\tsetupEnv: func() {\n\t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\t\t\t},\n\t\t\tcleanup: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname: \"success with custom workspace\",\n\t\t\tconfig: Config{\n\t\t\t\tPort:      9090,\n\t\t\t\tWorkspace: t.TempDir(),\n\t\t\t},\n\t\t\tsetupEnv: func() {\n\t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\t\t\t},\n\t\t\tcleanup: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname: \"error without public key\",\n\t\t\tconfig: Config{\n\t\t\t\tPort: DefaultPort,\n\t\t\t},\n\t\t\tsetupEnv: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t\tcleanup: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t\twantErr: true,\n\t\t\terrMsg:  \"public key not found\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\ttt.setupEnv()\n\t\t\tdefer tt.cleanup()\n\n\t\t\tserver, err := NewServer(tt.config)\n\n\t\t\tif tt.wantErr {\n\t\t\t\tassert.Error(t, err)\n\t\t\t\tassert.Nil(t, server)\n\t\t\t\tif tt.errMsg != \"\" {\n\t\t\t\t\tassert.Contains(t, err.Error(), tt.errMsg)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tassert.NoError(t, err)\n\t\t\t\tassert.NotNil(t, server)\n\t\t\t\tassert.Equal(t, tt.config.Port, server.config.Port)\n\t\t\t\tassert.NotEmpty(t, server.workspaceDir)\n\t\t\t\tassert.NotNil(t, server.authManager)\n\t\t\t\tassert.True(t, time.Since(server.startTime) < time.Second)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestDefaultConfig(t *testing.T) {\n\tconfig := DefaultConfig()\n\n\tassert.Equal(t, DefaultPort, config.Port)\n\tassert.Empty(t, config.Workspace)\n}\n\nfunc TestPicoDError(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\terr     *PicoDError\n\t\twantMsg string\n\t}{\n\t\t{\n\t\t\tname: \"error without underlying error\",\n\t\t\terr: &PicoDError{\n\t\t\t\tCode:    \"TestCode\",\n\t\t\t\tMessage: \"Test message\",\n\t\t\t\tDetail:  \"Test detail\",\n\t\t\t},\n\t\t\twantMsg: \"TestCode: Test message\",\n\t\t},\n\t\t{\n\t\t\tname: \"error with underlying error\",\n\t\t\terr: &PicoDError{\n\t\t\t\tCode:    \"TestCode\",\n\t\t\t\tMessage: \"Test message\",\n\t\t\t\tDetail:  \"Test detail\",\n\t\t\t\tErr:     assert.AnError,\n\t\t\t},\n\t\t\twantMsg: \"TestCode: Test message (caused by: \",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\terrMsg := tt.err.Error()\n\t\t\tassert.Contains(t, errMsg, tt.wantMsg)\n\n\t\t\tif tt.err.Err != nil {\n\t\t\t\tassert.Equal(t, tt.err.Err, tt.err.Unwrap())\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestNewError(t *testing.T) {\n\terr := NewError(\"TestCode\", \"Test message\", \"Test detail\", nil)\n\n\tassert.Equal(t, \"TestCode\", err.Code)\n\tassert.Equal(t, \"Test message\", err.Message)\n\tassert.Equal(t, \"Test detail\", err.Detail)\n\tassert.Nil(t, err.Err)\n}\n\nfunc TestStatusCodeMap(t *testing.T) {\n\ttests := []struct {\n\t\tname           string\n\t\tcode           string\n\t\texpectedStatus int\n\t}{\n\t\t{\n\t\t\tname:           \"bad request\",\n\t\t\tcode:           ErrInvalidCommand,\n\t\t\texpectedStatus: http.StatusBadRequest,\n\t\t},\n\t\t{\n\t\t\tname:           \"unauthorized\",\n\t\t\tcode:           ErrMissingAuthHeader,\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t},\n\t\t{\n\t\t\tname:           \"not found\",\n\t\t\tcode:           ErrFileNotFound,\n\t\t\texpectedStatus: http.StatusNotFound,\n\t\t},\n\t\t{\n\t\t\tname:           \"internal error\",\n\t\t\tcode:           ErrServerInternal,\n\t\t\texpectedStatus: http.StatusInternalServerError,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstatus, exists := statusCodeMap[tt.code]\n\t\t\tassert.True(t, exists)\n\t\t\tassert.Equal(t, tt.expectedStatus, status)\n\t\t})\n\t}\n}\n\nfunc TestHandleError(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\ttests := []struct {\n\t\tname           string\n\t\terr            error\n\t\texpectedStatus int\n\t\tcontains       string\n\t}{\n\t\t{\n\t\t\tname:           \"picoD error\",\n\t\t\terr:            NewError(ErrInvalidCommand, \"Test message\", \"\", nil),\n\t\t\texpectedStatus: http.StatusBadRequest,\n\t\t\tcontains:       \"Test message\",\n\t\t},\n\t\t{\n\t\t\tname:           \"generic error\",\n\t\t\terr:            assert.AnError,\n\t\t\texpectedStatus: http.StatusInternalServerError,\n\t\t\tcontains:       \"Error\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tw := httptest.NewRecorder()\n\t\t\tc, _ := gin.CreateTestContext(w)\n\n\t\t\tHandleError(c, tt.err)\n\n\t\t\tassert.Equal(t, tt.expectedStatus, w.Code)\n\t\t\tassert.Contains(t, w.Body.String(), tt.contains)\n\t\t})\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc setupTestServer(t *testing.T) *Server {\n\tworkspace := t.TempDir()\n\n\t_, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tconfig := Config{\n\t\tPort:      0,\n\t\tWorkspace: workspace,\n\t}\n\n\tserver, err := NewServer(config)\n\trequire.NoError(t, err)\n\n\tgin.SetMode(gin.TestMode)\n\n\treturn server\n}\n\nfunc cleanupTestServer(t *testing.T, server *Server) {\n\tos.Unsetenv(PublicKeyEnvVar)\n}\n\nfunc TestSanitizePath(t *testing.T) {\n\tserver := setupTestServer(t)\n\tdefer cleanupTestServer(t, server)\n\n\ttests := []struct {\n\t\tname        string\n\t\tpath        string\n\t\twantErr     bool\n\t\terrContains string\n\t}{\n\t\t{\n\t\t\tname:    \"valid relative path\",\n\t\t\tpath:    \"test/file.txt\",\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname:    \"valid absolute path\",\n\t\t\tpath:    \"/test/file.txt\",\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"path traversal attempt\",\n\t\t\tpath:        \"../../etc/passwd\",\n\t\t\twantErr:     true,\n\t\t\terrContains: \"Access denied\",\n\t\t},\n\t\t{\n\t\t\tname:    \"empty path\",\n\t\t\tpath:    \"\",\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname:    \"single dot\",\n\t\t\tpath:    \".\",\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"double dot at root\",\n\t\t\tpath:        \"..\",\n\t\t\twantErr:     true,\n\t\t\terrContains: \"Access denied\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tresult, err := server.sanitizePath(tt.path)\n\n\t\t\tif tt.wantErr {\n\t\t\t\tassert.Error(t, err)\n\t\t\t\tif tt.errContains != \"\" {\n\t\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tassert.NoError(t, err)\n\t\t\t\tassert.NotEmpty(t, result)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestParseFileMode(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tmodeStr  string\n\t\texpected int\n\t}{\n\t\t{\n\t\t\tname:     \"default mode\",\n\t\t\tmodeStr:  \"\",\n\t\t\texpected: 0644,\n\t\t},\n\t\t{\n\t\t\tname:     \"valid octal mode\",\n\t\t\tmodeStr:  \"0644\",\n\t\t\texpected: 0644,\n\t\t},\n\t\t{\n\t\t\tname:     \"valid octal mode 0755\",\n\t\t\tmodeStr:  \"0755\",\n\t\t\texpected: 0755,\n\t\t},\n\t\t{\n\t\t\tname:     \"invalid format\",\n\t\t\tmodeStr:  \"invalid\",\n\t\t\texpected: 0644,\n\t\t},\n\t\t{\n\t\t\tname:     \"exceeds max\",\n\t\t\tmodeStr:  \"10000\",\n\t\t\texpected: 0644,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tresult := parseFileMode(tt.modeStr)\n\t\t\tassert.Equal(t, int(result), tt.expected)\n\t\t})\n\t}\n}\n\nfunc TestAuthMiddleware(t *testing.T) {\n\tserver := setupTestServer(t)\n\tdefer cleanupTestServer(t, server)\n\n\tprivateKey, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tserver, err := NewServer(Config{\n\t\tPort:      0,\n\t\tWorkspace: t.TempDir(),\n\t})\n\trequire.NoError(t, err)\n\n\tvalidToken := createTestToken(t, privateKey)\n\n\ttests := []struct {\n\t\tname           string\n\t\tsetupRequest   func(*http.Request)\n\t\twantStatusCode int\n\t\twantError      string\n\t}{\n\t\t{\n\t\t\tname: \"valid token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+validToken)\n\t\t\t},\n\t\t\twantStatusCode: http.StatusOK,\n\t\t},\n\t\t{\n\t\t\tname: \"missing authorization header\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t},\n\t\t\twantStatusCode: http.StatusUnauthorized,\n\t\t\twantError:      ErrMsgMissingAuthHeader,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"InvalidFormat token\")\n\t\t\t},\n\t\t\twantStatusCode: http.StatusUnauthorized,\n\t\t\twantError:      ErrMsgInvalidAuthFormat,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer invalid.token.here\")\n\t\t\t},\n\t\t\twantStatusCode: http.StatusUnauthorized,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\trouter := gin.New()\n\t\t\trouter.Use(AuthMiddleware(server.authManager))\n\t\t\trouter.GET(\"/test\", func(c *gin.Context) {\n\t\t\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n\t\t\t})\n\n\t\t\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\t\t\ttt.setupRequest(req)\n\t\t\tw := httptest.NewRecorder()\n\n\t\t\trouter.ServeHTTP(w, req)\n\n\t\t\tassert.Equal(t, tt.wantStatusCode, w.Code)\n\t\t\tif tt.wantError != \"\" {\n\t\t\t\tassert.Contains(t, w.Body.String(), tt.wantError)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestHealthCheckHandler(t *testing.T) {\n\tserver := setupTestServer(t)\n\tdefer cleanupTestServer(t, server)\n\n\treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n\tw := httptest.NewRecorder()\n\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), `\"status\":\"ok\"`)\n\tassert.Contains(t, w.Body.String(), `\"service\":\"PicoD\"`)\n\tassert.Contains(t, w.Body.String(), `\"version\":\"0.0.1\"`)\n\tassert.Contains(t, w.Body.String(), `\"uptime\"`)\n}\n\nfunc TestNewServer(t *testing.T) {\n\t_, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n\n\ttests := []struct {\n\t\tname     string\n\t\tconfig   Config\n\t\tsetupEnv func()\n\t\tcleanup  func()\n\t\twantErr  bool\n\t\terrMsg   string\n\t}{\n\t\t{\n\t\t\tname: \"success with default workspace\",\n\t\t\tconfig: Config{\n\t\t\t\tPort: DefaultPort,\n\t\t\t},\n\t\t\tsetupEnv: func() {\n\t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\t\t\t},\n\t\t\tcleanup: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname: \"success with custom workspace\",\n\t\t\tconfig: Config{\n\t\t\t\tPort:      9090,\n\t\t\t\tWorkspace: t.TempDir(),\n\t\t\t},\n\t\t\tsetupEnv: func() {\n\t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\t\t\t},\n\t\t\tcleanup: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname: \"error without public key\",\n\t\t\tconfig: Config{\n\t\t\t\tPort: DefaultPort,\n\t\t\t},\n\t\t\tsetupEnv: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t\tcleanup: func() {\n\t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t\t},\n\t\t\twantErr: true,\n\t\t\terrMsg:  \"public key not found\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\ttt.setupEnv()\n\t\t\tdefer tt.cleanup()\n\n\t\t\tserver, err := NewServer(tt.config)\n\n\t\t\tif tt.wantErr {\n\t\t\t\tassert.Error(t, err)\n\t\t\t\tassert.Nil(t, server)\n\t\t\t\tif tt.errMsg != \"\" {\n\t\t\t\t\tassert.Contains(t, err.Error(), tt.errMsg)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tassert.NoError(t, err)\n\t\t\t\tassert.NotNil(t, server)\n\t\t\t\tassert.Equal(t, tt.config.Port, server.config.Port)\n\t\t\t\tassert.NotEmpty(t, server.workspaceDir)\n\t\t\t\tassert.NotNil(t, server.authManager)\n\t\t\t\tassert.True(t, time.Since(server.startTime) < time.Second)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestDefaultConfig(t *testing.T) {\n\tconfig := DefaultConfig()\n\n\tassert.Equal(t, DefaultPort, config.Port)\n\tassert.Empty(t, config.Workspace)\n}\n\nfunc TestPicoDError(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\terr     *PicoDError\n\t\twantMsg string\n\t}{\n\t\t{\n\t\t\tname: \"error without underlying error\",\n\t\t\terr: &PicoDError{\n\t\t\t\tCode:    \"TestCode\",\n\t\t\t\tMessage: \"Test message\",\n\t\t\t\tDetail:  \"Test detail\",\n\t\t\t},\n\t\t\twantMsg: \"TestCode: Test message\",\n\t\t},\n\t\t{\n\t\t\tname: \"error with underlying error\",\n\t\t\terr: &PicoDError{\n\t\t\t\tCode:    \"TestCode\",\n\t\t\t\tMessage: \"Test message\",\n\t\t\t\tDetail:  \"Test detail\",\n\t\t\t\tErr:     assert.AnError,\n\t\t\t},\n\t\t\twantMsg: \"TestCode: Test message (caused by: \",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\terrMsg := tt.err.Error()\n\t\t\tassert.Contains(t, errMsg, tt.wantMsg)\n\n\t\t\tif tt.err.Err != nil {\n\t\t\t\tassert.Equal(t, tt.err.Err, tt.err.Unwrap())\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestNewError(t *testing.T) {\n\terr := NewError(\"TestCode\", \"Test message\", \"Test detail\", nil)\n\n\tassert.Equal(t, \"TestCode\", err.Code)\n\tassert.Equal(t, \"Test message\", err.Message)\n\tassert.Equal(t, \"Test detail\", err.Detail)\n\tassert.Nil(t, err.Err)\n}\n\nfunc TestStatusCodeMap(t *testing.T) {\n\ttests := []struct {\n\t\tname           string\n\t\tcode           string\n\t\texpectedStatus int\n\t}{\n\t\t{\n\t\t\tname:           \"bad request\",\n\t\t\tcode:           ErrInvalidCommand,\n\t\t\texpectedStatus: http.StatusBadRequest,\n\t\t},\n\t\t{\n\t\t\tname:           \"unauthorized\",\n\t\t\tcode:           ErrMissingAuthHeader,\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t},\n\t\t{\n\t\t\tname:           \"not found\",\n\t\t\tcode:           ErrFileNotFound,\n\t\t\texpectedStatus: http.StatusNotFound,\n\t\t},\n\t\t{\n\t\t\tname:           \"internal error\",\n\t\t\tcode:           ErrServerInternal,\n\t\t\texpectedStatus: http.StatusInternalServerError,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tstatus, exists := statusCodeMap[tt.code]\n\t\t\tassert.True(t, exists)\n\t\t\tassert.Equal(t, tt.expectedStatus, status)\n\t\t})\n\t}\n}\n\nfunc TestHandleError(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\ttests := []struct {\n\t\tname           string\n\t\terr            error\n\t\texpectedStatus int\n\t\tcontains       string\n\t}{\n\t\t{\n\t\t\tname:           \"picoD error\",\n\t\t\terr:            NewError(ErrInvalidCommand, \"Test message\", \"\", nil),\n\t\t\texpectedStatus: http.StatusBadRequest,\n\t\t\tcontains:       \"Test message\",\n\t\t},\n\t\t{\n\t\t\tname:           \"generic error\",\n\t\t\terr:            assert.AnError,\n\t\t\texpectedStatus: http.StatusInternalServerError,\n\t\t\tcontains:       \"Error\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tw := httptest.NewRecorder()\n\t\t\tc, _ := gin.CreateTestContext(w)\n\n\t\t\tHandleError(c, tt.err)\n\n\t\t\tassert.Equal(t, tt.expectedStatus, w.Code)\n\t\t\tassert.Contains(t, w.Body.String(), tt.contains)\n\t\t})\n\t}\n}\n","additions":0,"deletions":1},"truncated":false},"title":