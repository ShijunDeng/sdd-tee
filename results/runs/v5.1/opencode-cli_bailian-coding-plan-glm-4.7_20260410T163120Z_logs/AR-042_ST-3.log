®зұ»еһӢ\n\n#### DocusaurusConfig\n\n```typescript\nimport type { Config } from '@docusaurus/types';\nimport type * as Preset from '@docusaurus/preset-classic';\n\ninterface DocusaurusConfig extends Config {\n  title: string;\n  tagline: string;\n  url: string;\n  baseUrl: string;\n  favicon: string;\n  organizationName: string;\n  projectName: string;\n  i18n: {\n    defaultLocale: string;\n    locales: string[];\n  };\n  presets: Preset.Entry[];\n  plugins: PluginEntry[];\n  themes: ThemeEntry[];\n  themeConfig: Preset.ThemeConfig;\n}\n```\n\n#### ThemeConfig\n\n```typescript\ninterface CustomThemeConfig extends Preset.ThemeConfig {\n  navbar: NavbarConfig;\n  footer: FooterConfig;\n  colorMode: {\n    defaultMode: 'light' | 'dark';\n    disableSwitch: boolean;\n    respectPrefersColorScheme: boolean;\n  };\n  metadata: Array<{\n    name: string;\n    content: string;\n  }>;\n}\n\ninterface NavbarConfig {\n  title: string;\n  logo: LogoConfig;\n  items: NavbarItem[];\n}\n\ninterface NavbarItem {\n  type: 'doc' | 'dropdown' | 'link' | 'localeDropdown' | 'docsVersionDropdown';\n  to?: string;\n  href?: string;\n  label?: string;\n  position?: 'left' | 'right';\n  items?: NavbarItem[];\n}\n\ninterface FooterConfig {\n  style: 'dark' | 'light';\n  links: FooterLinkGroup[];\n  copyright: string;\n}\n\ninterface FooterLinkGroup {\n  title: string;\n  items: FooterLink[];\n}\n\ninterface FooterLink {\n  label: string;\n  to?: string;\n  href?: string;\n}\n```\n\n#### дҫ§иҫ№ж Ҹй…ҚзҪ®зұ»еһӢ\n\n```typescript\nimport type { SidebarsConfig } from '@docusaurus/plugin-content-docs';\n\ninterface CustomSidebarsConfig extends SidebarsConfig {\n  docs?: SidebarItem[];\n}\n\ntype SidebarItem =\n  | DocSidebarItem\n  | CategorySidebarItem\n  | LinkSidebarItem\n  | HtmlSidebarItem;\n\ninterface DocSidebarItem {\n  type: 'doc';\n  id: string;\n  label?: string;\n  className?: string;\n  customProps?: Record<string, unknown>;\n}\n\ninterface CategorySidebarItem {\n  type: 'category';\n  label: string;\n  link?: CategoryLinkConfig;\n  items: SidebarItem[];\n  className?: string;\n  customProps?: Record<string, unknown>;\n  collapsed?: boolean;\n  collapsible?: boolean;\n}\n\ninterface CategoryLinkConfig {\n  type: 'doc' | 'generated-index';\n  id?: string;\n  title?: string;\n  description?: string;\n  slug?: string;\n  symbol?: string;\n}\n\ninterface LinkSidebarItem {\n  type: 'link';\n  label: string;\n  href: string;\n  className?: string;\n  customProps?: Record<string, unknown>;\n}\n\ninterface HtmlSidebarItem {\n  type: 'html';\n  value: string;\n  defaultStyle?: boolean;\n  className?: string;\n  customProps?: Record<string, unknown>;\n}\n```\n\n#### еүҚиЁҖе…ғж•°жҚ®зұ»еһӢ\n\n```typescript\ninterface DocFrontMatter {\n  title?: string;\n  description?: string;\n  slug?: string;\n  tags?: string[];\n  id?: string;\n  sidebar_label?: string;\n  sidebar_position?: number;\n  sidebar_custom_props?: Record<string, unknown>;\n  hide_title?: boolean;\n  hide_table_of_contents?: boolean;\n  pagination_next?: string;\n  pagination_prev?: string;\n  custom_edit_url?: string;\n  keywords?: string[];\n  image?: string;\n  draft?: boolean;\n  unlisted?: boolean;\n  hide_sidebar?: boolean;\n}\n```\n\n#### жҸ’д»¶й…ҚзҪ®зұ»еһӢ\n\n```typescript\ninterface PluginConfig {\n  [key: string]: unknown;\n}\n\ninterface ContentDocPluginConfig extends PluginConfig {\n  path: string;\n  routeBasePath: string;\n  include: string[];\n  exclude?: string[];\n  sidebarPath?: string;\n  editUrl?: string | false;\n  editLocalizedFiles?: boolean;\n  versions?: {\n    current: {\n      label: string;\n      path: string;\n      banner?: string;\n    }[];\n  };\n  lastVersion?: string;\n  showLastUpdateAuthor: boolean;\n  showLastUpdateTime: boolean;\n}\n```\n\n## API еҘ‘зәҰ\n\n### жһ„е»әе’ҢејҖеҸ‘и„ҡжң¬\n\n#### npm scripts\n\n```json\n{\n  \"scripts\": {\n    \"docusaurus\": \"docusaurus\",\n    \"start\": \"docusaurus start\",\n    \"build\": \"docusaurus build\",\n    \"swizzle\": \"docusaurus swizzle\",\n    \"deploy\": \"docusaurus deploy\",\n    \"clear\": \"docusaurus clear\",\n    \"serve\": \"docusaurus serve\",\n    \"write-translations\": \"docusaurus write-translations\",\n    \"write-heading-ids\": \"docusaurus write-heading-ids\",\n    \"typecheck\": \"tsc\"\n  }\n}\n```\n\n### React з»„д»¶жҺҘеҸЈ\n\n#### иҮӘе®ҡд№үж–ҮжЎЈеҚЎзүҮз»„д»¶\n\n```typescript\ninterface FeatureCardProps {\n  title: string;\n  description: string;\n  icon: React.ReactNode;\n  link?: string;\n}\n\nexport function FeatureCard({ title, description, icon, link }: FeatureCardProps): JSX.Element;\n```\n\n#### иҮӘе®ҡд№үд»Јз Ғеқ—з»„д»¶\n\n```typescript\ninterface CustomCodeBlockProps {\n  children: string;\n  language?: string;\n  title?: string;\n  showLineNumbers?: boolean;\n  highlightLines?: number[];\n}\n\nexport function CustomCodeBlock({\n  children,\n  language,\n  title,\n  showLineNumbers = true,\n  highlightLines = [],\n}: CustomCodeBlockProps): JSX.Element;\n```\n\n#### иҮӘе®ҡд№ү API зӯҫеҗҚз»„д»¶\n\n```typescript\ninterface ApiSignatureProps {\n  name: string;\n  parameters: Array<{\n    name: string;\n    type: string;\n    description?: string;\n    optional?: boolean;\n  }>;\n  returnType: string;\n  description?: string;\n}\n\nexport function ApiSignature({\n  name,\n  parameters,\n  returnType,\n  description,\n}: ApiSignatureProps): JSX.Element;\n```\n\n### MDX з»„д»¶жҺҘеҸЈ\n\n#### иҮӘе®ҡд№үж Үзӯҫз»„д»¶\n\n```typescript\ninterface TagProps {\n  label: string;\n  color?: 'primary' | 'secondary' | 'success' | 'warning' | 'danger';\n  icon?: React.ReactNode;\n}\n\nexport function Tag({ label, color = 'primary', icon }: TagProps): JSX.Element;\n```\n\n#### иҮӘе®ҡд№үжҸҗзӨәжЎҶз»„д»¶\n\n```typescript\ninterface AdmonitionProps {\n  type: 'note' | 'tip' | 'info' | 'caution' | 'danger';\n  title?: string;\n  children: React.ReactNode;\n}\n\nexport function Admonition({ type, title, children }: AdmonitionProps): JSX.Element;\n```\n\n#### иҮӘе®ҡд№үеҫҪз« з»„д»¶\n\n```typescript\ninterface BadgeProps {\n  text: string;\n  variant?: 'default' | 'outline' | 'ghost';\n  size?: 'sm' | 'md' | 'lg';\n}\n\nexport function Badge({ text, variant = 'default', size = 'md' }: BadgeProps): JSX.Element;\n```\n\n### е·Ҙе…·еҮҪж•°жҺҘеҸЈ\n\n#### зүҲжң¬з®ЎзҗҶе·Ҙе…·\n\n```typescript\ninterface VersionInfo {\n  version: string;\n  path: string;\n  label: string;\n  isLast?: boolean;\n}\n\nexport function getAllVersions(): VersionInfo[];\nexport function getCurrentVersion(): string;\nexport function getVersionDocs(version: string): DocMetadata[];\nexport function getLatestStableVersion(): string;\n```\n\n#### еӣҪйҷ…еҢ–е·Ҙе…·\n\n```typescript\ninterface I18nConfig {\n  defaultLocale: string;\n  locales: string[];\n}\n\nexport function getAvailableLocales(): string[];\nexport function getCurrentLocale(): string;\nexport function getLocalizedUrl(url: string, locale: string): string;\nexport function translate(key: string, locale?: string): string;\n```\n\n#### жҗңзҙўе·Ҙе…·\n\n```typescript\ninterface SearchResult {\n  id: string;\n  title: string;\n  url: string;\n  excerpt: string;\n  section?: string;\n}\n\nexport interface SearchService {\n  search(query: string): Promise<SearchResult[]>;\n  initialize(index: string): Promise<void>;\n  dispose(): void;\n}\n```\n\n### жҸ’д»¶жү©еұ•жҺҘеҸЈ\n\n#### иҮӘе®ҡд№үжҸ’д»¶жҺҘеҸЈ\n\n```typescript\nimport type { Plugin, LoadContext } from '@docusaurus/types';\n\ninterface CustomPluginOptions {\n  option1: string;\n  option2?: number;\n}\n\ndeclare const customPlugin: Plugin<CustomPluginOptions>;\n\nexport default function (context: LoadContext, options: CustomPluginOptions): Plugin<CustomPluginOptions>;\n```\n\n#### иҮӘе®ҡд№үдё»йўҳжҺҘеҸЈ\n\n```typescript\nimport type { Theme, LoadContext } from '@docusaurus/types';\n\ninterface CustomThemeOptions {\n  customColor?: string;\n  customFont?: string;\n}\n\ndeclare const customTheme: Theme<CustomThemeOptions>;\n\nexport default function (context: LoadContext, options: CustomThemeOptions): Theme<CustomThemeOptions>;\n```\n\n## й”ҷиҜҜеӨ„зҗҶ\n\n### й”ҷиҜҜеұӮж¬Ўз»“жһ„\n\n```\nError\nв”ңв”Җв”Җ BuildError\nв”Ӯ   в”ңв”Җв”Җ MarkdownParseError\nв”Ӯ   в”ңв”Җв”Җ ComponentError\nв”Ӯ   в”ңв”Җв”Җ ConfigError\nв”Ӯ   в””в”Җв”Җ PluginError\nв”ңв”Җв”Җ DeploymentError\nв”Ӯ   в”ңв”Җв”Җ GitHubPagesError\nв”Ӯ   в”ңв”Җв”Җ CIError\nв”Ӯ   в””в”Җв”Җ PublishError\nв”ңв”Җв”Җ ValidationError\nв”Ӯ   в”ңв”Җв”Җ FrontMatterValidationError\nв”Ӯ   в”ңв”Җв”Җ LinkValidationError\nв”Ӯ   в””в”Җв”Җ AssetValidationError\nв””в”Җв”Җ RuntimeError\n    в”ңв”Җв”Җ SearchIndexError\n    в”ңв”Җв”Җ VersioningError\n    в””в”Җв”Җ I18nError\n```\n\n### й”ҷиҜҜеӨ„зҗҶзӯ–з•Ҙ\n\n#### жһ„е»әж—¶й”ҷиҜҜеӨ„зҗҶ\n\n1. **й…ҚзҪ®й”ҷиҜҜ**: еңЁжһ„е»әеүҚйӘҢиҜҒй…ҚзҪ®ж–Үд»¶\n2. **Markdown и§Јжһҗй”ҷиҜҜ**: жҸҗдҫӣиҜҰз»Ҷзҡ„й”ҷиҜҜдҝЎжҒҜе’ҢдҪҚзҪ®\n3. **й“ҫжҺҘйӘҢиҜҒ**: жЈҖжҹҘжүҖжңүж–ҮжЎЈй“ҫжҺҘзҡ„жңүж•ҲжҖ§\n4. **иө„жәҗйӘҢиҜҒ**: йӘҢиҜҒеӣҫзүҮе’Ңе…¶д»–йқҷжҖҒиө„жәҗ\n\n```typescript\ninterface BuildError extends Error {\n  type: 'config' | 'markdown' | 'component' | 'plugin';\n  filePath?: string;\n  line?: number;\n  column?: number;\n}\n\nfunction validateConfig(config: DocusaurusConfig): BuildError | null {\n  if (!config.title || !config.url) {\n    return new BuildError('Missing required config fields');\n  }\n  return null;\n}\n```\n\n#### иҝҗиЎҢж—¶й”ҷиҜҜеӨ„зҗҶ\n\n1. **з»„д»¶жёІжҹ“й”ҷиҜҜ**: дҪҝз”Ё Error Boundary жҚ•иҺ·\n2. **жҗңзҙўй”ҷиҜҜ**: жҸҗдҫӣйҷҚзә§ж–№жЎҲ\n3. **еӣҪйҷ…еҢ–й”ҷиҜҜ**: еӣһйҖҖеҲ°й»ҳи®ӨиҜӯиЁҖ\n\n```typescript\ninterface ErrorBoundaryState {\n  hasError: boolean;\n  error?: Error;\n}\n\nexport class DocErrorBoundary extends React.Component<\n  { children: React.ReactNode },\n  ErrorBoundaryState\n> {\n  constructor(props: { children: React.ReactNode }) {\n    super(props);\n    this.state = { hasError: false };\n  }\n\n  static getDerivedStateFromError(error: Error): ErrorBoundaryState {\n    return { hasError: true, error };\n  }\n\n  componentDidCatch(error: Error, errorInfo: React.ErrorInfo): void {\n    console.error('Doc rendering error:', error, errorInfo);\n  }\n\n  render(): React.ReactNode {\n    if (this.state.hasError) {\n      return <ErrorFallback error={this.state.error} />;\n    }\n    return this.props.children;\n  }\n}\n```\n\n### й”ҷиҜҜз Ғе®ҡд№ү\n\n```typescript\nenum ErrorCode {\n  // й…ҚзҪ®й”ҷиҜҜ\n  CONFIG_MISSING = 'CONFIG_MISSING',\n  CONFIG_INVALID = 'CONFIG_INVALID',\n\n  // ж–ҮжЎЈй”ҷиҜҜ\n  DOC_NOT_FOUND = 'DOC_NOT_FOUND',\n  DOC_INVALID_FRONTMATTER = 'DOC_INVALID_FRONTMATTER',\n  DOC_BROKEN_LINK = 'DOC_BROKEN_LINK',\n\n  // жһ„е»әй”ҷиҜҜ\n  BUILD_FAILED = 'BUILD_FAILED',\n  BUILD_TIMEOUT = 'BUILD_TIMEOUT',\n\n  // йғЁзҪІй”ҷиҜҜ\n  DEPLOY_FAILED = 'DEPLOY_FAILED',\n  DEPLOY_PERMISSION_DENIED = 'DEPLOY_PERMISSION_DENIED',\n\n  // жҸ’д»¶й”ҷиҜҜ\n  PLUGIN_LOAD_FAILED = 'PLUGIN_LOAD_FAILED',\n  PLUGIN_CONFIG_INVALID = 'PLUGIN_CONFIG_INVALID',\n\n  // еӣҪйҷ…еҢ–й”ҷиҜҜ\n  I18N_MISSING_TRANSLATION = 'I18N_MISSING_TRANSLATION',\n  I18N_INVALID_LOCALE = 'I18N_INVALID_LOCALE',\n}\n```\n\n### й”ҷиҜҜжҒўеӨҚзӯ–з•Ҙ\n\n#### жһ„е»әеӨұиҙҘжҒўеӨҚ\n\n1. **еўһйҮҸжһ„е»ә**: д»…йҮҚж–°жһ„е»әеҸҳжӣҙзҡ„ж–Үд»¶\n2. **зј“еӯҳжңәеҲ¶**: зј“еӯҳжһ„е»әз»“жһң\n3. **е№¶иЎҢжһ„е»ә**: е№¶иЎҢеӨ„зҗҶж–ҮжЎЈ\n\n```typescript\ninterface BuildOptions {\n  incremental?: boolean;\n  cache?: boolean;\n  parallel?: boolean;\n  maxWorkers?: number;\n}\n\nasync function buildSite(options: BuildOptions = {}): Promise<void> {\n  try {\n    await docusaurus.build(options);\n  } catch (error) {\n    if (options.incremental) {\n      console.warn('Incremental build failed, falling back to full build');\n      await docusaurus.build({ ...options, incremental: false });\n    } else {\n      throw error;\n    }\n  }\n}\n```\n\n#### жҗңзҙўйҷҚзә§\n\n```typescript\nclass FallbackSearchService implements SearchService {\n  private mainSearch?: SearchService;\n\n  constructor(private fallbackService: SearchService) {}\n\n  async search(query: string): Promise<SearchResult[]> {\n    try {\n      if (this.mainSearch) {\n        return await this.mainSearch.search(query);\n      }\n    } catch (error) {\n      console.error('Main search failed, using fallback:', error);\n    }\n    return await this.fallbackService.search(query);\n  }\n\n  async initialize(index: string): Promise<void> {\n    try {\n      this.mainSearch = await createMainSearchService();\n      await this.mainSearch.initialize(index);\n    } catch (error) {\n      console.warn('Main search initialization failed:', error);\n      await this.fallbackService.initialize(index);\n    }\n  }\n\n  dispose(): void {\n    this.mainSearch?.dispose();\n    this.fallbackService.dispose();\n  }\n}\n```\n\n## жөӢиҜ•зӯ–з•Ҙ\n\n### жөӢиҜ•з»„з»Үз»“жһ„\n\n```\ntests/\nв”ңв”Җв”Җ unit/\nв”Ӯ   в”ңв”Җв”Җ components/\nв”Ӯ   в”Ӯ   в”ңв”Җв”Җ FeatureCard.test.tsx\nв”Ӯ   в”Ӯ   в”ңв”Җв”Җ ApiSignature.test.tsx\nв”Ӯ   в”Ӯ   в””в”Җв”Җ Admonition.test.tsx\nв”Ӯ   в”ңв”Җв”Җ utils/\nв”Ӯ   в”Ӯ   в”ңв”Җв”Җ version.test.ts\nв”Ӯ   в”Ӯ   в”ңв”Җв”Җ i18n.test.ts\nв”Ӯ   в”Ӯ   в””в”Җв”Җ search.test.ts\nв”Ӯ   в””в”Җв”Җ plugins/\nв”Ӯ       в””в”Җв”Җ customPlugin.test.ts\nв”ңв”Җв”Җ integration/\nв”Ӯ   в”ңв”Җв”Җ build.test.ts\nв”Ӯ   в”ңв”Җв”Җ deploy.test.ts\nв”Ӯ   в””в”Җв”Җ i18n.test.ts\nв”ңв”Җв”Җ e2e/\nв”Ӯ   в”ңв”Җв”Җ navigation.spec.ts\nв”Ӯ   в”ңв”Җв”Җ search.spec.ts\nв”Ӯ   в””в”Җв”Җ versioning.spec.ts\nв””в”Җв”Җ fixtures/\n    в”ңв”Җв”Җ docs/\n    в””в”Җв”Җ content/\n```\n\n### жөӢиҜ•жЎҶжһ¶е’Ңе·Ҙе…·\n\n#### дё»иҰҒжөӢиҜ•жЎҶжһ¶\n\n- **Jest**: еҚ•е…ғжөӢиҜ•е’ҢйӣҶжҲҗжөӢиҜ•жЎҶжһ¶\n- **React Testing Library**: React з»„д»¶жөӢиҜ•\n- **Playwright**: E2E жөӢиҜ•\n- **Testing Library**: DOM жөӢиҜ•е·Ҙе…·\n\n#### жөӢиҜ•иҫ…еҠ©е·Ҙе…·\n\n- **@testing-library/react**: React з»„д»¶жөӢиҜ•\n- **@testing-library/jest-dom**: Jest DOM ж–ӯиЁҖ\n- **@testing-library/user-event**: з”ЁжҲ·дәӨдә’жЁЎжӢҹ\n- **msw (Mock Service Worker)**: API жЁЎжӢҹ\n\n#### д»Јз ҒиҰҶзӣ–зҺҮе·Ҙе…·\n\n- **Istanbul/NYC**: д»Јз ҒиҰҶзӣ–зҺҮз»ҹи®Ў\n- **Coverage Reports**: HTML е’Ң JSON иҰҶзӣ–зҺҮжҠҘе‘Ҡ\n\n### жөӢиҜ•иҰҶзӣ–зҺҮзӣ®ж Ү\n\n| жЁЎеқ— | зӣ®ж ҮиҰҶзӣ–зҺҮ | дјҳе…Ҳзә§ |\n|------|-----------|--------|\n| иҮӘе®ҡд№үз»„д»¶ | вүҘ85% | й«ҳ |\n| е·Ҙе…·еҮҪж•° | вүҘ90% | й«ҳ |\n| жҸ’д»¶ | вүҘ75% | дёӯ |\n| жһ„е»әжөҒзЁӢ | вүҘ70% | дёӯ |\n| E2E еңәжҷҜ | е…ій”®и·Ҝеҫ„иҰҶзӣ– | й«ҳ |\n\n### жөӢиҜ•еҲҶзұ»\n\n#### еҚ•е…ғжөӢиҜ•\n\n**зӣ®ж Ү**: жөӢиҜ•еҚ•дёӘеҮҪж•°гҖҒз»„д»¶жҲ–жЁЎеқ—зҡ„иЎҢдёә\n\n**зү№зӮ№**:\n- еҝ«йҖҹжү§иЎҢпјҲжҜ«з§’зә§пјү\n- ж— еӨ–йғЁдҫқиө–\n- еҸҜйҮҚеӨҚиҝҗиЎҢ\n- иҰҶзӣ–жүҖжңүд»Јз Ғи·Ҝеҫ„\n\n**зӨәдҫӢ**:\n\n```typescript\ndescribe('VersionUtils', () => {\n  describe('getCurrentVersion', () => {\n    it('should return current version from config', () => {\n      const result = getCurrentVersion();\n      expect(result).toBe('1.0.0');\n    });\n\n    it('should handle missing config gracefully', () => {\n      const result = getCurrentVersion();\n      expect(result).toBe('current');\n    });\n  });\n\n  describe('getAllVersions', () => {\n    it('should return all available versions', () => {\n      const versions = getAllVersions();\n      expect(versions).toHaveLength(3);\n      expect(versions[0].version).toBe('1.0.0');\n    });\n\n    it('should include version metadata', () => {\n      const versions = getAllVersions();\n      const v1 = versions.find((v) => v.version === '1.0.0');\n      expect(v1).toHaveProperty('path');\n      expect(v1).toHaveProperty('label');\n    });\n  });\n});\n```\n\n#### з»„д»¶жөӢиҜ•\n\n**зӣ®ж Ү**: жөӢиҜ• React з»„д»¶зҡ„жёІжҹ“е’ҢдәӨдә’\n\n**зү№зӮ№**:\n- жөӢиҜ•з»„д»¶иҫ“еҮә\n- жЁЎжӢҹз”ЁжҲ·дәӨдә’\n- жөӢиҜ•з»„д»¶зҠ¶жҖҒ\n- йӘҢиҜҒеҸҜи®ҝй—®жҖ§\n\n**зӨәдҫӢ**:\n\n```typescript\ndescribe('FeatureCard', () => {\n  it('should render correctly with all props', () => {\n    const { getByText, getByTestId } = render(\n      <FeatureCard\n        title=\"Test Feature\"\n        description=\"Test description\"\n        icon={<span data-testid=\"icon\">Icon</span>}\n        link=\"/test\"\n      />\n    );\n\n    expect(getByText('Test Feature')).toBeInTheDocument();\n    expect(getByText('Test description')).toBeInTheDocument();\n    expect(getByTestId('icon')).toBeInTheDocument();\n    expect(getByText('Test Feature').closest('a')).toHaveAttribute('href', '/test');\n  });\n\n  it('should render without link', () => {\n    const { container } = render(\n      <FeatureCard\n        title=\"Test Feature\"\n        description=\"Test description\"\n        icon={<span>Icon</span>}\n      />\n    );\n\n    expect(container.querySelector('a')).not.toBeInTheDocument();\n  });\n\n  it('should handle click events', async () => {\n    const user = userEvent.setup();\n    const handleClick = jest.fn();\n\n    render(\n      <FeatureCard\n        title=\"Test Feature\"\n        description=\"Test description\"\n        icon={<span>Icon</span>}\n        onClick={handleClick}\n      />\n    );\n\n    const card = screen.getByRole('article');\n    await user.click(card);\n\n    expect(handleClick).toHaveBeenCalledTimes(1);\n  });\n});\n```\n\n#### йӣҶжҲҗжөӢиҜ•\n\n**зӣ®ж Ү**: жөӢиҜ•еӨҡдёӘз»„д»¶жҲ–жЁЎеқ—д№Ӣй—ҙзҡ„дәӨдә’\n\n**зү№зӮ№**:\n- жөӢиҜ•ж•°жҚ®жөҒ\n- йӘҢиҜҒжҺҘеҸЈеҘ‘зәҰ\n- жөӢиҜ•зңҹе®һдҫқиө–\n- дёӯзӯүжү§иЎҢйҖҹеәҰ\n\n**зӨәдҫӢ**:\n\n```typescript\ndescribe('Documentation Integration', () => {\n  it('should build all docs without errors', async () => {\n    const result = await docusaurus.build({\n      config: './docusaurus.config.ts',\n    });\n\n    expect(result.success).toBe(true);\n    expect(result.buildErrors).toHaveLength(0);\n  });\n\n  it('should generate correct sitemap', async () => {\n    await docusaurus.build();\n    const sitemap = fs.readFileSync('build/sitemap.xml', 'utf-8');\n\n    expect(sitemap).toContain('https://docs.agentcube.dev/docs/intro');\n    expect(sitemap).toContain('https://docs.agentcube.dev/docs/api/overview');\n  });\n\n  it('should include all locales in build output', async () => {\n    await docusaurus.build();\n\n    const zhCnDocs = glob.sync('build/zh-CN/**/*');\n    const enDocs = glob.sync('build/en/**/*');\n\n    expect(zhCnDocs.length).toBeGreaterThan(0);\n    expect(enDocs.length).toBeGreaterThan(0);\n  });\n});\n```\n\n#### E2E жөӢиҜ•\n\n**зӣ®ж Ү**: жөӢиҜ•е®Ңж•ҙзҡ„з”ЁжҲ·жөҒзЁӢ\n\n**зү№зӮ№**:\n- зңҹе®һжөҸи§ҲеҷЁзҺҜеўғ\n- жөӢиҜ•з”ЁжҲ·дҪ“йӘҢ\n- йӘҢиҜҒдёҡеҠЎжөҒзЁӢ\n- иҫғж…ўжү§иЎҢйҖҹеәҰ\n\n**зӨәдҫӢ**:\n\n```typescript\nimport { test, expect } from '@playwright/test';\n\ntest.describe('Documentation Navigation', () => {\n  test('should navigate to doc pages', async ({ page }) => {\n    await page.goto('http://localhost:3000');\n\n    await page.click('text=Getting Started');\n    await expect(page).toHaveURL(/.*\\/docs\\/getting-started/);\n    await expect(page.locator('h1')).toContainText('Getting Started');\n  });\n\n  test('should search for content', async ({ page }) => {\n    await page.goto('http://localhost:3000');\n\n    await page.click('[aria-label=\"Search\"]');\n    await page.fill('input[placeholder=\"Search\"]', 'API');\n\n    await expect(page.locator('.DocSearch-Hit')).toHaveCount(\n      expect.any(Number)\n    );\n  });\n\n  test('should switch versions', async ({ page }) => {\n    await page.goto('http://localhost:3000');\n\n    await page.click('.navbar__item.dropdown');\n    await page.click('text=v1.0.0');\n\n    await expect(page).toHaveURL(/.*\\/docs\\/next\\/.*/);\n  });\n\n  test('should switch languages', async ({ page }) => {\n    await page.goto('http://localhost:3000');\n\n    await page.click('.navbar__item.dropdown .locale-dropdown');\n    await page.click('text=English');\n\n    await expect(page.locator('html')).toHaveAttribute('lang', 'en');\n  });\n});\n```\n\n### Mock зӯ–з•Ҙ\n\n#### з»„д»¶ Mock\n\n```typescript\njest.mock('@docusaurus/useGlobalData', () => ({\n  useGlobalData: jest.fn(() => ({\n    'docusaurus-plugin-content-docs': {\n      versions: [\n        {\n          versionName: 'current',\n          label: 'Next',\n          path: '/docs/next',\n        },\n        {\n          versionName: '1.0.0',\n          label: '1.0.0',\n          path: '/docs/1.0.0',\n        },\n      ],\n    },\n  })),\n}));\n```\n\n#### API Mock\n\n```typescript\nimport { rest } from 'msw';\n\nexport const handlers = [\n  rest.get('https://api.example.com/search', (req, res, ctx) => {\n    const query = req.url.searchParams.get('q');\n    return res(\n      ctx.json({\n        results: [\n          {\n            id: '1',\n            title: `Result for ${query}`,\n            url: '/docs/result',\n          },\n        ],\n      })\n    );\n  }),\n\n  rest.get('https://api.example.com/versions', (req, res, ctx) => {\n    return res(\n      ctx.json({\n        versions: [\n          { version: '1.0.0', path: '/docs/1.0.0' },\n          { version: '2.0.0', path: '/docs/2.0.0' },\n        ],\n      })\n    );\n  }),\n];\n```\n\n### жөӢиҜ•иҫ…еҠ©еҮҪж•°\n\n#### з»„д»¶жёІжҹ“иҫ…еҠ©\n\n```typescript\nimport { render } from '@testing-library/react';\nimport { DocusaurusContextProvider } from '@docusaurus/theme-common';\n\nexport function renderWithDocusaurus(ui: React.ReactNode) {\n  return render(\n    <DocusaurusContextProvider\n      siteConfig={{\n        title: 'Test',\n        url: 'https://test.com',\n        baseUrl: '/',\n      }}\n    >\n      {ui}\n    </DocusaurusContextProvider>\n  );\n}\n```\n\n#### ж–ҮжЎЈеҶ…е®№иҫ…еҠ©\n\n```typescript\nexport function createTestDoc(frontMatter: Partial<DocFrontMatter> = {}) {\n  return {\n    id: 'test-doc',\n    title: 'Test Doc',\n    description: 'Test description',\n    ...frontMatter,\n    content: '# Test Content\\n\\nTest paragraph.',\n  };\n}\n\nexport function createTestVersion(version: string) {\n  return {\n    version,\n    label: version,\n    path: `/docs/${version}`,\n    isLast: version === '1.0.0',\n  };\n}\n```\n\n### жөӢиҜ•еңәжҷҜ\n\n#### жһ„е»әжөӢиҜ•еңәжҷҜ\n\n1. вң“ й…ҚзҪ®ж–Үд»¶йӘҢиҜҒ\n2. вң“ Markdown и§Јжһҗ\n3. вң“ з»„д»¶жёІжҹ“\n4. вң“ йқҷжҖҒиө„жәҗеӨ„зҗҶ\n5. вң“ еӨҡиҜӯиЁҖжһ„е»ә\n6. вң“ зүҲжң¬з”ҹжҲҗ\n7. вң“ Sitemap з”ҹжҲҗ\n8. вң“ жһ„е»әжҖ§иғҪ\n\n#### з»„д»¶жөӢиҜ•еңәжҷҜ\n\n1. вң“ FeatureCard жёІжҹ“е’ҢдәӨдә’\n2. вң“ ApiSignature жҳҫзӨә\n3. вң“ Admonition зұ»еһӢ\n4. вң“ Tag жҳҫзӨә\n5. вң“ Badge ж ·ејҸ\n6. вң“ CodeBlock иҜӯжі•й«ҳдә®\n7. вң“ жҗңзҙўз»„д»¶\n8. вң“ зүҲжң¬йҖүжӢ©еҷЁ\n9. вң“ иҜӯиЁҖйҖүжӢ©еҷЁ\n\n#### E2E жөӢиҜ•еңәжҷҜ\n\n1. вң“ йҰ–йЎөеҜјиҲӘ\n2. вң“ ж–ҮжЎЈжөҸи§Ҳ\n3. вң“ жҗңзҙўеҠҹиғҪ\n4. вң“ зүҲжң¬еҲҮжҚў\n5. вң“ иҜӯиЁҖеҲҮжҚў\n6. вң“ й“ҫжҺҘжңүж•ҲжҖ§\n7. вң“ з§»еҠЁз«ҜйҖӮй…Қ\n8. вң“ й”®зӣҳеҜјиҲӘ\n9. вң“ еұҸе№•йҳ…иҜ»еҷЁж”ҜжҢҒ\n\n### жөӢиҜ•жү§иЎҢ\n\n#### жң¬ең°жөӢиҜ•иҝҗиЎҢ\n\n```bash\n# иҝҗиЎҢжүҖжңүжөӢиҜ•\nnpm test\n\n# иҝҗиЎҢзү№е®ҡжөӢиҜ•ж–Үд»¶\nnpm test FeatureCard.test.tsx\n\n# иҝҗиЎҢеёҰиҰҶзӣ–зҺҮзҡ„жөӢиҜ•\nnpm test -- --coverage\n\n# иҝҗиЎҢ E2E жөӢиҜ•\nnpx playwright test\n\n# иҝҗиЎҢжөӢиҜ•е№¶зӣ‘еҗ¬ж–Үд»¶еҸҳеҢ–\nnpm test -- --watch\n\n# иҝҗиЎҢйӣҶжҲҗжөӢиҜ•\nnpm test -- tests/integration\n```\n\n#### CI/CD йӣҶжҲҗ\n\n```yaml\n# .github/workflows/test.yml\nname: Tests\n\non: [push, pull_request]\n\njobs:\n  test:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - uses: actions/setup-node@v4\n        with:\n          node-version: 18\n          cache: 'npm'\n          cache-dependency-path: 'docs/package-lock.json'\n\n      - name: Install dependencies\n        working-directory: docs\n        run: npm ci\n\n      - name: Run unit tests\n        working-directory: docs\n        run: npm test -- --coverage\n\n      - name: Upload coverage\n        uses: codecov/codecov-action@v3\n        with:\n          files: ./docs/coverage/coverage-final.json\n\n      - name: Run E2E tests\n        working-directory: docs\n        run: npx playwright test\n```\n\n### жөӢиҜ•жңҖдҪіе®һи·ө\n\n1. **жөӢиҜ•е‘ҪеҗҚ**: дҪҝз”ЁжҸҸиҝ°жҖ§зҡ„жөӢиҜ•еҗҚз§°\n2. **AAA жЁЎејҸ**: Arrange-Act-Assert жЁЎејҸз»„з»ҮжөӢиҜ•\n3. **йҡ”зҰ»жҖ§**: жҜҸдёӘжөӢиҜ•еә”иҜҘжҳҜзӢ¬з«Ӣзҡ„\n4. **еҸҜиҜ»жҖ§**: жөӢиҜ•еә”иҜҘжҳ“дәҺзҗҶи§Ј\n5. **еҝ«йҖҹеҸҚйҰҲ**: дјҳе…Ҳжү§иЎҢеҝ«йҖҹжөӢиҜ•\n6. **иҰҶзӣ–е…ій”®и·Ҝеҫ„**: йҮҚзӮ№е…іжіЁе…ій”®дёҡеҠЎжөҒзЁӢ\n7. **з»ҙжҠӨжҖ§**: дҝқжҢҒжөӢиҜ•д»Јз Ғж•ҙжҙҒ\n8. **зңҹе®һеңәжҷҜ**: жөӢиҜ•зңҹе®һз”ЁжҲ·еңәжҷҜ\n9. **иҫ№з•ҢжқЎд»¶**: жөӢиҜ•иҫ№з•Ңе’Ңзү№ж®Ҡжғ…еҶө\n10. **жҖ§иғҪиҖғиҷ‘**: дјҳеҢ–ж…ўйҖҹжөӢиҜ•\n\n## жҖ§иғҪиҖғиҷ‘\n\n### жһ„е»әжҖ§иғҪдјҳеҢ–\n\n1. **еўһйҮҸжһ„е»ә**: д»…йҮҚж–°жһ„е»әеҸҳжӣҙзҡ„ж–Үд»¶\n2. **е№¶иЎҢеӨ„зҗҶ**: е№¶иЎҢеӨ„зҗҶж–ҮжЎЈе’Ңиө„жәҗ\n3. **зј“еӯҳжңәеҲ¶**: зј“еӯҳжһ„е»әз»“жһң\n4. **иө„жәҗдјҳеҢ–**: еҺӢзј©е’ҢдјҳеҢ–йқҷжҖҒиө„жәҗ\n\n```typescript\ninterface BuildPerformanceConfig {\n  incremental?: boolean;\n  cache?: boolean;\n  parallel?: boolean;\n  maxWorkers?: number;\n  optimizeImages?: boolean;\n  minify?: boolean;\n}\n\nconst performanceConfig: BuildPerformanceConfig = {\n  incremental: true,\n  cache: true,\n  parallel: true,\n  maxWorkers: 4,\n  optimizeImages: true,\n  minify: true,\n};\n```\n\n### иҝҗиЎҢж—¶жҖ§иғҪдјҳеҢ–\n\n1. **д»Јз ҒеҲҶеүІ**: еҠЁжҖҒеҜје…Ҙз»„д»¶\n2. **жҮ’еҠ иҪҪ**: жҢүйңҖеҠ иҪҪеҶ…е®№\n3. **йў„еҠ иҪҪ**: йў„еҠ иҪҪе…ій”®иө„жәҗ\n4. **CDN**: дҪҝз”Ё CDN еҲҶеҸ‘йқҷжҖҒиө„жәҗ\n\n```typescript\n// еҠЁжҖҒеҜје…Ҙз»„д»¶\nconst HeavyComponent = React.lazy(() => import('./HeavyComponent'));\n\n// еӣҫзүҮдјҳеҢ–\n<img\n  src=\"/img/logo.png\"\n  loading=\"lazy\"\n  width=\"200\"\n  height=\"100\"\n  decoding=\"async\"\n/>\n```\n\n### жҖ§иғҪзӣ‘жҺ§\n\n1. **Core Web Vitals**: зӣ‘жҺ§ж ёеҝғ Web жҢҮж Ү\n2. **Lighthouse**: е®ҡжңҹиҝҗиЎҢжҖ§иғҪе®Ўи®Ў\n3. **Web Vitals**: дҪҝз”Ё web-vitals еә“\n4. **Analytics**: йӣҶжҲҗ Google Analytics\n\n```typescript\nimport { onCLS, onFID, onLCP } from 'web-vitals';\n\nonCLS((metric) => console.log('CLS:', metric));\nonFID((metric) => console.log('FID:', metric));\nonLCP((metric) => console.log('LCP:', metric));\n```\n\n## йғЁзҪІзӯ–з•Ҙ\n\n### йғЁзҪІжөҒзЁӢ\n\n```\nејҖеҸ‘ вҶ’ жҺЁйҖҒд»Јз Ғ вҶ’ и§ҰеҸ‘ CI вҶ’ жһ„е»әж–ҮжЎЈ вҶ’ иҝҗиЎҢжөӢиҜ• вҶ’ йғЁзҪІеҲ° GitHub Pages вҶ’ йҖҡзҹҘ\n```\n\n### йғЁзҪІй…ҚзҪ®\n\n```yaml\n# .github/workflows/deploy.yml\nname: Deploy to GitHub Pages\n\non:\n  push:\n    branches:\n      - main\n    paths:\n      - 'docs/**'\n      - '.github/workflows/deploy.yml'\n\npermissions:\n  contents: read\n  pages: write\n  id-token: write\n\nconcurrency:\n  group: \"pages\"\n  cancel-in-progress: false\n\njobs:\n  build:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - uses: actions/setup-node@v4\n        with:\n          node-version: 18\n          cache: 'npm'\n          cache-dependency-path: 'docs/package-lock.json'\n\n      - name: Install dependencies\n        working-directory: docs\n        run: npm ci\n\n      - name: Build website\n        working-directory: docs\n        run: npm run build\n\n      - name: Run tests\n        working-directory: docs\n        run: npm test\n\n      - name: Upload artifact\n        uses: actions/upload-pages-artifact@v3\n        with:\n          path: 'docs/build'\n\n  deploy:\n    environment:\n      name: github-pages\n      url: ${{ steps.deployment.outputs.page_url }}\n    runs-on: ubuntu-latest\n    needs: build\n    steps:\n      - name: Deploy to GitHub Pages\n        id: deployment\n        uses: actions/deploy-pages@v4\n```\n\n## дҫқиө–е…ізі»\n\n### ж ёеҝғдҫқиө–\n\n```json\n{\n  \"dependencies\": {\n    \"@docusaurus/core\": \"^3.0.0\",\n    \"@docusaurus/preset-classic\": \"^3.0.0\",\n    \"@docusaurus/theme-classic\": \"^3.0.0\",\n    \"@mdx-js/react\": \"^3.0.0\",\n    \"react\": \"^18.0.0\",\n    \"react-dom\": \"^18.0.0\"\n  },\n  \"devDependencies\": {\n    \"@docusaurus/types\": \"^3.0.0\",\n    \"@docusaurus/module-type-aliases\": \"^3.0.0\",\n    \"@tsconfig/docusaurus\": \"^2.0.0\",\n    \"@types/react\": \"^18.0.0\",\n    \"@types/react-dom\": \"^18.0.0\",\n    \"typescript\": \"^5.0.0\"\n  }\n}\n```\n\n### еҸҜйҖүдҫқиө–\n\n```json\n{\n  \"dependencies\": {\n    \"@easyops-cn/docusaurus-search-local\": \"^0.40.0\",\n    \"@docusaurus/plugin-ideal-image\": \"^3.0.0\",\n    \"@docusaurus/plugin-pwa\": \"^3.0.0\",\n    \"@docusaurus/theme-live-codeblock\": \"^3.0.0\"\n  }\n}\n```\n\n### жөӢиҜ•дҫқиө–\n\n```json\n{\n  \"devDependencies\": {\n    \"@testing-library/react\": \"^14.0.0\",\n    \"@testing-library/jest-dom\": \"^6.0.0\",\n    \"@testing-library/user-event\": \"^14.0.0\",\n    \"@playwright/test\": \"^1.40.0\",\n    \"jest\": \"^29.0.0\",\n    \"jest-environment-jsdom\": \"^29.0.0\",\n    \"msw\": \"^2.0.0\",\n    \"@types/jest\": \"^29.0.0\"\n  }\n}\n```\n\n## з»ҙжҠӨе’Ңжӣҙж–°\n\n### з»ҙжҠӨжҢҮеҚ—\n\n1. **е®ҡжңҹжӣҙж–°дҫқиө–**: жҜҸжңҲжӣҙж–°дёҖж¬Ўдҫқиө–еҢ…\n2. **зӣ‘жҺ§е®үе…ЁжјҸжҙһ**: дҪҝз”Ё npm audit жЈҖжҹҘжјҸжҙһ\n3. **жҖ§иғҪзӣ‘жҺ§**: е®ҡжңҹиҝҗиЎҢ Lighthouse е®Ўи®Ў\n4. **еҶ…е®№е®ЎжҹҘ**: е®ҡжңҹе®ЎжҹҘе’Ңжӣҙж–°ж–ҮжЎЈеҶ…е®№\n5. **з”ЁжҲ·еҸҚйҰҲ**: ж”¶йӣҶе’ҢеӨ„зҗҶз”ЁжҲ·еҸҚйҰҲ\n\n### жӣҙж–°жөҒзЁӢ\n\n1. еҲӣе»әжӣҙж–°еҲҶж”Ҝ\n2. жӣҙж–°дҫқиө–зүҲжң¬\n3. иҝҗиЎҢжөӢиҜ•зЎ®дҝқе…је®№жҖ§\n4. жӣҙж–° CHANGELOG\n5. жҸҗдәӨ PR е®ЎжҹҘ\n6. еҗҲе№¶еҲ°дё»еҲҶж”Ҝ\n7. йғЁзҪІж–°зүҲжң¬\n\n## жҖ»з»“\n\nжң¬и®ҫи®Ўж–ҮжЎЈдёә AR-042 Docusaurus ж–ҮжЎЈз«ҷжЎҶжһ¶жҸҗдҫӣдәҶе…Ёйқўзҡ„жҠҖжңҜе®һж–ҪжҢҮеҚ—гҖӮйҖҡиҝҮйҒөеҫӘжң¬ж–ҮжЎЈдёӯжҸҸиҝ°зҡ„жһ¶жһ„гҖҒж•°жҚ®з»“жһ„гҖҒAPI еҘ‘зәҰгҖҒй”ҷиҜҜеӨ„зҗҶе’ҢжөӢиҜ•зӯ–з•ҘпјҢеҸҜд»Ҙдёә AgentCube йЎ№зӣ®жһ„е»әй«ҳиҙЁйҮҸгҖҒеҸҜз»ҙжҠӨзҡ„ж–ҮжЎЈзҪ‘з«ҷгҖӮ\n\nе®һж–ҪжӯӨи®ҫи®Ўе°ҶеёҰжқҘд»ҘдёӢеҘҪеӨ„пјҡ\n- жҸҗдҫӣз»ҹдёҖзҡ„ж–ҮжЎЈи®ҝй—®е№іеҸ°\n- ж”№е–„з”ЁжҲ·дҪ“йӘҢе’ҢеҸҜи®ҝй—®жҖ§\n- з®ҖеҢ–ж–ҮжЎЈз»ҙжҠӨе’Ңжӣҙж–°жөҒзЁӢ\n- ж”ҜжҢҒеӨҡиҜӯиЁҖе’ҢзүҲжң¬з®ЎзҗҶ\n- жҸҗдҫӣејәеӨ§зҡ„жҗңзҙўеҠҹиғҪ\n- е®һзҺ°иҮӘеҠЁеҢ–йғЁзҪІ\n\nйҖҡиҝҮйҳ¶ж®өеҢ–зҡ„е®һж–Ҫи®ЎеҲ’е’ҢжҳҺзЎ®зҡ„йӘҢж”¶ж ҮеҮҶпјҢеҸҜд»ҘзЎ®дҝқж–ҮжЎЈз«ҷе·ҘдҪңзҡ„жңүеәҸиҝӣиЎҢе’ҢжҲҗеҠҹдәӨд»ҳгҖӮ","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-042/design.md"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-042/design.md","exists":false,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-042/desi