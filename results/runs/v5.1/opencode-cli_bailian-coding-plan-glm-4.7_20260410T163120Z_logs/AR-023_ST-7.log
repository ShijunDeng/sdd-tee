ime = InvokeRuntime(provider=\"k8s\")\n40:         assert runtime.verbose is False\n41:         assert runtime.provider == \"k8s\"\n42:     \n43:     def test_init_with_all_params(self) -> None:\n44:         \"\"\"Test initialization with all parameters.\"\"\"\n45:         runtime = InvokeRuntime(verbose=True, provider=\"k8s\")\n46:         assert runtime.verbose is True\n47:         assert runtime.provider == \"k8s\"\n48: \n49: \n50: class TestValidateInvokePrerequisites:\n51:     \"\"\"Tests for InvokeRuntime._validate_invoke_prerequisites.\"\"\"\n52:     \n53:     def test_validate_success_with_agent_id(self, tmp_path: Path) -> None:\n54:         \"\"\"Test validation with agent_id present.\"\"\"\n55:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n56:         metadata_file.write_text(\"\"\"\n57: agent_name: test-agent\n58: entrypoint: python main.py\n59: agent_id: abc123\n60: agent_endpoint: http://localhost:8080\n61: \"\"\")\n62:         \n63:         runtime = InvokeRuntime()\n64:         metadata, endpoint, namespace = runtime._validate_invoke_prerequisites(tmp_path)\n65:         \n66:         assert metadata.agent_id == \"abc123\"\n67:         assert endpoint == \"http://localhost:8080\"\n68:         assert namespace == \"default\"\n69:     \n70:     def test_validate_success_with_endpoint(self, tmp_path: Path) -> None:\n71:         \"\"\"Test validation with agent_endpoint present.\"\"\"\n72:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n73:         metadata_file.write_text(\"\"\"\n74: agent_name: test-agent\n75: entrypoint: python main.py\n76: agent_endpoint: http://localhost:8080\n77: \"\"\")\n78:         \n79:         runtime = InvokeRuntime()\n80:         metadata, endpoint, namespace = runtime._validate_invoke_prerequisites(tmp_path)\n81:         \n82:         assert metadata.agent_endpoint == \"http://localhost:8080\"\n83:         assert endpoint == \"http://localhost:8080\"\n84:         assert namespace == \"default\"\n85:     \n86:     def test_validate_with_k8s_deployment(self, tmp_path: Path) -> None:\n87:         \"\"\"Test validation with k8s_deployment.\"\"\"\n88:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n89:         metadata_file.write_text(\"\"\"\n90: agent_name: test-agent\n91: entrypoint: python main.py\n92: agent_id: abc123\n93: k8s_deployment:\n94:   type: AgentRuntime\n95:   namespace: test-ns\n96:   service_url: http://localhost:8080\n97: \"\"\")\n98:         \n99:         runtime = InvokeRuntime()\n100:         metadata, endpoint, namespace = runtime._validate_invoke_prerequisites(tmp_path)\n101:         \n102:         assert metadata.agent_id == \"abc123\"\n103:         assert endpoint == \"http://localhost:8080\"\n104:         assert namespace == \"test-ns\"\n105:     \n106:     def test_validate_not_published(self, tmp_path: Path) -> None:\n107:         \"\"\"Test validation raises ValueError when agent not published.\"\"\"\n108:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n109:         metadata_file.write_text(\"\"\"\n110: agent_name: test-agent\n111: entrypoint: python main.py\n112: \"\"\")\n113:         \n114:         runtime = InvokeRuntime()\n115:         with pytest.raises(ValueError, match=\"Agent has not been published\"):\n116:             runtime._validate_invoke_prerequisites(tmp_path)\n117:     \n118:     def test_validate_no_endpoint(self, tmp_path: Path) -> None:\n119:         \"\"\"Test validation raises ValueError when no endpoint found.\"\"\"\n120:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n121:         metadata_file.write_text(\"\"\"\n122: agent_name: test-agent\n123: entrypoint: python main.py\n124: agent_id: abc123\n125: \"\"\")\n126:         \n127:         runtime = InvokeRuntime()\n128:         with pytest.raises(ValueError, match=\"No endpoint found\"):\n129:             runtime._validate_invoke_prerequisites(tmp_path)\n130:     \n131:     def test_validate_no_metadata(self, tmp_path: Path) -> No