{"type":"tool_use","timestamp":1775870572188,"sessionID":"ses_285de6bdaffeSCYlWS06GqDtjM","part":{"id":"prt_d7a227670001miVfKjnO6DZ93o","messageID":"msg_d7a226a63001kcEXXNqKFrRzK2","sessionID":"ses_285de6bdaffeSCYlWS06GqDtjM","type":"tool","tool":"read","callID":"toolu_tool-985e703e7e694311a6685a1d1f3182e9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/status_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/status_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Runtime for the status command.\"\"\"\n2: \n3: import logging\n4: from pathlib import Path\n5: from typing import Any, Dict, Optional\n6: \n7: from agentcube.services.agentcube_provider import AgentCubeProvider\n8: from agentcube.services.k8s_provider import KubernetesProvider\n9: from agentcube.services.metadata_service import MetadataService\n10: \n11: logger = logging.getLogger(__name__)\n12: \n13: \n14: class StatusRuntime:\n15:     \"\"\"Runtime for checking agent status.\"\"\"\n16: \n17:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n18:         \"\"\"Initialize the status runtime.\"\"\"\n19:         self.verbose = verbose\n20:         self.provider = provider\n21:         if verbose:\n22:             logging.basicConfig(level=logging.DEBUG)\n23: \n24:     def get_status(self, workspace_path: Path, provider: Optional[str] = None) -> Dict[str, Any]:\n25:         \"\"\"Get the status of a published agent.\"\"\"\n26:         logger.info(f\"Getting status for: {workspace_path}\")\n27: \n28:         provider = provider or self.provider\n29:         metadata_service = MetadataService(verbose=self.verbose)\n30:         metadata = metadata_service.load_metadata(workspace_path)\n31: \n32:         if not metadata.agent_id and not metadata.k8s_deployment:\n33:             return {\n34:                 \"status\": \"not_published\",\n35:                 \"message\": \"Agent has not been published\",\n36:             }\n37: \n38:         try:\n39:             if provider == \"agentcube\":\n40:                 return self._get_cr_k8s_status(metadata)\n41:             elif provider == \"k8s\":\n42:                 return self._get_k8s_status(metadata)\n43:             else:\n44:                 raise ValueError(f\"Unsupported provider: {provider}\")\n45:         except Exception as e:\n46:             logger.error(f\"Error getting status: {e}\")\n47:             return {\n48:                 \"status\": \"error\",\n49:                 \"message\": str(e),\n50:             }\n51: \n52:     def _get_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n53:         \"\"\"Get status for standard Kubernetes deployment.\"\"\"\n54:         if not metadata.k8s_deployment:\n55:             return {\n56:                 \"status\": \"not_published\",\n57:                 \"message\": \"No Kubernetes deployment found\",\n58:             }\n59: \n60:         namespace = metadata.k8s_deployment.get(\"namespace\", \"default\")\n61:         deployment_name = metadata.k8s_deployment.get(\"deployment_name\", metadata.agent_name)\n62: \n63:         provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n64: \n65:         try:\n66:             status = provider.get_agent_status(deployment_name)\n67: \n68:             result = {\n69:                 \"status\": status.get(\"status\", \"unknown\"),\n70:                 \"provider\": \"k8s\",\n71:                 \"namespace\": namespace,\n72:                 \"deployment_name\": deployment_name,\n73:                 \"replicas\": status.get(\"replicas\", 0),\n74:                 \"ready_replicas\": status.get(\"ready_replicas\", 0),\n75:             }\n76: \n77:             if status.get(\"status\") == \"not_found\":\n78:                 result[\"message\"] = \"Deployment not found in Kubernetes\"\n79:             elif status.get(\"ready_replicas\", 0) < status.get(\"replicas\", 0):\n80:                 result[\"message\"] = \"Deployment is not fully ready\"\n81: \n82:             return result\n83: \n84:         except Exception as e:\n85:             logger.error(f\"Error getting k8s status: {e}\")\n86:             return {\n87:                 \"status\": \"error\",\n88:                 \"message\": str(e),\n89:                 \"provider\": \"k8s\",\n90:             }\n91: \n92:     def _get_cr_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n93:         \"\"\"Get status for AgentCube AgentRuntime CR.\"\"\"\n94:         if not metadata.agent_id:\n95:             return {\n96:                 \"status\": \"not_published\",\n97:                 \"message\": \"Agent has not been published\",\n98:             }\n99: \n100:         namespace = (\n101:             metadata.k8s_deployment.get(\"namespace\") if metadata.k8s_deployment else \"default\"\n102:         )\n103: \n104:         provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n105: \n106:         try:\n107:             cr_object = provider.get_agent_runtime(metadata.agent_name, namespace)\n108: \n109:             if cr_object is None:\n110:                 return {\n111:                     \"status\": \"not_found_in_k8s\",\n112:                     \"message\": \"AgentRuntime not found in Kubernetes\",\n113:                     \"provider\": \"agentcube\",\n114:                     \"namespace\": namespace,\n115:                 }\n116: \n117:             if \"status\" in cr_object:\n118:                 status_info = cr_object[\"status\"]\n119:                 return {\n120:                     \"status\": status_info.get(\"status\", \"created_no_status\"),\n121:                     \"provider\": \"agentcube\",\n122:                     \"namespace\": namespace,\n123:                     \"agent_name\": metadata.agent_name,\n124:                     \"agent_endpoint\": status_info.get(\"agentEndpoint\"),\n125:                     \"message\": status_info.get(\"message\", \"\"),\n126:                 }\n127:             else:\n128:                 return {\n129:                     \"status\": \"created_no_status\",\n130:                     \"message\": \"AgentRuntime created but no status available yet\",\n131:                     \"provider\": \"agentcube\",\n132:                     \"namespace\": namespace,\n133:                 }\n134: \n135:         except Exception as e:\n136:             logger.error(f\"Error getting CR status: {e}\")\n137:             return {\n138:                 \"status\": \"error\",\n139:                 \"message\": str(e),\n140:                 \"provider\": \"agentcube\",\n141:             }\n\n(End of file - total 141 lines)\n</content>","metadata":{"preview":"\"\"\"Runtime for the status command.\"\"\"\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.metadata_service import MetadataService\n\nlogger = logging.getLogger(__name__)\n\n\nclass StatusRuntime:\n    \"\"\"Runtime for checking agent status.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        \"\"\"Initialize the status runtime.\"\"\"\n        self.verbose = verbose\n        self.provider = provider","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/status_runtime.py","time":{"start":1775870572176,"end":1775870572186}}}}
