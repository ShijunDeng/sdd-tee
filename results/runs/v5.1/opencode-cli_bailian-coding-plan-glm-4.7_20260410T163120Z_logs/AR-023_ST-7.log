59:                 payload=payload,\n260:                 headers=headers,\n261:                 workspace_path=Path(\"/tmp\"),\n262:             )\n263:             \n264:             assert result == {\"result\": \"success\"}\n265:     \n266:     @pytest.mark.asyncio\n267:     async def test_direct_http_invocation_timeout(self) -> None:\n268:         \"\"\"Test direct HTTP invocation handles timeout.\"\"\"\n269:         runtime = InvokeRuntime()\n270:         endpoint = \"http://localhost:8080/invoke\"\n271:         payload = {\"message\": \"hello\"}\n272:         headers = {}\n273:         \n274:         with patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\") as mock_client_class:\n275:             async def mock_post(url, json=None, headers=None):\n276:                 raise httpx.TimeoutException(\"Request timed out\")\n277:             \n278:             mock_client = AsyncMock()\n279:             mock_client.post = mock_post\n280:             mock_client.__aenter__ = AsyncMock(return_value=mock_client)\n281:             mock_client.__aexit__ = AsyncMock(return_value=None)\n282:             mock_client_class.return_value = mock_client\n283:             \n284:             with pytest.raises(httpx.TimeoutException):\n285:                 await runtime._direct_http_invocation(\n286:                     endpoint=endpoint,\n287:                     payload=payload,\n288:                     headers=headers,\n289:                     workspace_path=Path(\"/tmp\"),\n290:                 )\n291:     \n292:     @pytest.mark.asyncio\n293:     async def test_direct_http_invocation_connection_error(self) -> None:\n294:         \"\"\"Test direct HTTP invocation handles connection errors.\"\"\"\n295:         runtime = InvokeRuntime()\n296:         endpoint = \"http://localhost:8080/invoke\"\n297:         payload = {\"message\": \"hello\"}\n298:         headers = {}\n299:         \n300:         with patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\") as mock_client_class:\n301:             async def mock_post(url, json=None, headers=None):\n302:                 raise httpx.ConnectError(\"Connection failed\")\n303:             \n304:             mock_client = AsyncMock()\n305:             mock_client.post = mock_post\n306:             mock_client.__aenter__ = AsyncMock(return_value=mock_client)\n307:             mock_client.__aexit__ = AsyncMock(return_value=None)\n308:             mock_client_class.return_value = mock_client\n309:             \n310:             with pytest.raises(httpx.ConnectError):\n311:                 await runtime._direct_http_invocation(\n312:                     endpoint=endpoint,\n313:                     payload=payload,\n314:                     headers=headers,\n315:                     workspace_path=Path(\"/tmp\"),\n316:                 )\n317: \n318: \n319: class TestInvoke:\n320:     \"\"\"Tests for InvokeRuntime.invoke.\"\"\"\n321:     \n322:     def test_invoke_success_agentcube_provider(self, tmp_path: Path) -> None:\n323:         \"\"\"Test successful invoke with agentcube provider.\"\"\"\n324:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n325:         metadata_file.write_text(\"\"\"\n326: agent_name: test-agent\n327: entrypoint: python main.py\n328: agent_id: abc123\n329: agent_endpoint: http://localhost:8080\n330: k8s_deployment:\n331:   type: AgentRuntime\n332:   namespace: default\n333: \"\"\")\n334:         \n335:         runtime = InvokeRuntime(provider=\"agentcube\")\n336:         payload = {\"message\": \"hello\"}\n337:         headers = {\"X-Custom-Header\": \"value\"}\n338:         \n339:         with patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\") as mock_client_class:\n340:             mock_response = MagicMock()\n341:             mock_response.status_code = 200\n342:             mock_response.json.return_value = {\"result\": \"success\"}\n343:             mock_response.raise_for_status = MagicMock()\n344:             \n345:             async def mock_post(url, json=None, headers=None):\n346:                 return mock_response\n347:             \n348:             mock_client = AsyncMock()\n349:             mock_client.post = mock_post\n350:             mock_client.__aenter__ = AsyncMock(return_value=mock_client)\n351:             mock_client.__aexit__ = AsyncMock(return_value=None)\n352:             mock_client_class.return_value = mock_client\n353:             \n354:             result = runtime.invoke(tmp_path, payload, headers)\n355:             \n356:             assert result == {\"result\": \"success\"}\n357:     \n358:     def test_invoke_with_session_id(self, tmp_path: Path) -> None:\n359:         \"\"\"Test invoke includes session_id header.\"\"\"\n360:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n361:         metadata_file.write_text(\"\"\"\n362: agent_name: test-agent\n363: entrypoint: python main.py\n364: agent_id: abc123\n365: agent_endpoint: http://localhost:8080\n366: session_id: session123\n367: k8s_deployment:\n368:   type: AgentRuntime\n369:   namespace: default\n370: \"\"\")\n371:         \n372:         runtime = InvokeRuntime(provider=\"agentcube\")\n373:         payload = {\"message\": \"hello\"}\n374:         headers = {}\n375:         \n376:         session_id_sent = []\n377:         \n378:         with patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\") as mock_client_class:\n379:             mock_response = MagicMock()\n380:             mock_response.status_code = 200\n381:             mock_response.json.return_value = {\"result\": \"success\"}\n382:             mock_response.raise_for_status = MagicMock()\n383:             \n384:             async def mock_post(url, json=None, headers=None):\n385:                 session_id_sent.append(headers.get(\"X-Agentcube-Session-Id\"))\n386:                 return mock_response\n387:             \n388:             mock_client = AsyncMock()\n389:             mock_client.post = mock_post\n390:             mock_client.__aenter__ = AsyncMock(return_value=mock_client)\n391:             mock_client.__aexit__ = AsyncMock(return_value=None)\n392:             mock_client_class.return_value = mock_client\n393:             \n394:             result = runtime.invoke(tmp_path, payload, headers)\n395:             \n396:             assert result == {\"result\": \"success\"}\n397:             assert session_id_sent[0] == \"session123\"\n398:     \n399:     def test_invoke_k8s_provider(self, tmp_path: Path) -> None:\n400:         \"\"\"Test invoke with k8s provider.\"\"\"\n401:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n402:         metadata_file.write_text(\"\"\"\n403: agent_name: test-agent\n404: entrypoint: python main.py\n405: agent_endpoint: http://localhost:8080\n406: k8s_deployment:\n407:   type: Deployment\n408:   namespace: default\n409:   service_url: http://localhost:8080\n410: \"\"\")\n411:         \n412:         runtime = InvokeRuntime(provider=\"k8s\")\n413:         payload = {\"message\": \"hello\"}\n414:         headers = {}\n415:         \n416:         with patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\") as mock_client_class:\n417:             mock_response = MagicMock()\n418:             mock_response.status_code = 200\n419:             mock_response.json.return_value = {\"result\": \"success\"}\n420:             mock_response.raise_for_status = MagicMock()\n421:             \n422:             async def mock_post(url, json=None, headers=None):\n423:                 return mock_response\n424:             \n425:             mock_client = AsyncMock()\n426:             mock_client.post = mock_post\n427:             mock_client.__aenter__ = AsyncMock(return_value=mock_client)\n428:             mock_client.__aexit__ = AsyncMock(return_value=None)\n429:             mock_client_class.return_value = mock_client\n430:             \n431:             result = runtime.invoke(tmp_path, payload, headers)\n432:             \n433:             assert result == {\"result\": \"success\"}\n434:     \n435:     def test_invoke_not_published(self, tmp_path: Path) -> None:\n436:         \"\"\"Test invoke raises ValueError when agent not published.\"\"\"\n437:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n438:         metadata_file.write_text(\"\"\"\n439: agent_name: test-agent\n440: entrypoint: python main.py\n441: \"\"\")\n442:         \n443:         runtime = InvokeRuntime()\n444:         payload = {\"message\": \"hello\"}\n445:         \n446:         with pytest.raises(ValueError, match=\"Agent has not been published\"):\n447:             runtime.invoke(tmp_path, payload)\n448:     \n449:     def test_invoke_no_endpoint(self, tmp_path: Path) -> None:\n450:         \"\"\"Test invoke raises ValueError when no endpoint found.\"\"\"\n451:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n452:         metadata_file.write_text(\"\"\"\n453: agent_name: test-agent\n454: entrypoint: python main.py\n455: agent_id: abc123\n456: \"\"\")\n457:         \n458:         runtime = InvokeRuntime()\n459:         payload = {\"message\": \"hello\"}\n460:         \n461:         with pytest.raises(ValueError, match=\"No endpoint found\"):\n462:             runtime.invoke(tmp_path, payload)\n463:     \n464:     def test_invoke_invalid_endpoint_format(self, tmp_path: Path) -> None:\n465:         \"\"\"Test invoke handles invalid endpoint format.\"\"\"\n466:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n467:         metadata_file.write_text(\"\"\"\n468: agent_name: test-agent\n469: entrypoint: python main.py\n470: agent_endpoint: invalid-endpoint\n471: k8s_deployment:\n472:   type: Deployment\n473:   namespace: default\n474: \"\"\")\n475:         \n476:         runtime = InvokeRuntime(provider=\"k8s\")\n477:         payload = {\"message\": \"hello\"}\n478:         \n479:         result = runtime.invoke(tmp_path, payload)\n480:         \n481:         assert \"error\" in result\n482:     \n483:     def test_invoke_verbose_logging(self, tmp_path: Path) -> None:\n484:         \"\"\"Test invoke with verbose logging enabled.\"\"\"\n485:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n486:         metadata_file.write_text(\"\"\"\n487: agent_name: test-agent\n488: entrypoint: python main.py\n489: agent_endpoint: http://localhost:8080\n490: k8s_deployment:\n491:   type: Deployment\n492:   namespace: default\n493: \"\"\")\n494:         \n495:         runtime = InvokeRuntime(verbose=True)\n496:         payload = {\"message\": \"hello\"}\n497:         \n498:         with patch(\"agentcube.runtime.invoke_runtime.httpx.AsyncClient\") as mock_client_class:\n499:             mock_response = MagicMock()\n500:             mock_response.status_code = 200\n501:             mock_response.json.return_value = {\"result\": \"success\"}\n502:             mock_response.raise_for_status = MagicMock()\n503:             \n504:             async def mock_post(url, json=None, headers=None):\n505:                 return mock_response\n506:             \n507:             mock_client = AsyncMock()\n508:             mock_client.post = mock_post\n509:             mock_client.__aenter__ = AsyncMock(return_value=mock_client)\n510:             mock_client.__aexit__ = AsyncMock(return_value=None)\n511:             mock_client_class.return_value = mock_client\n512:             \n513:             result = runtime.invoke(tmp_path, payload)\n514:             \n515:             assert result == {\"result\": \"success\"}\n\n(End of file - total 515 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for InvokeRuntime.\"\"\"\n\nimport asyncio\nimport json\nimport pytest\nfrom pathlib import Path\nfrom typing import Any, Dict\nfrom unittest.mock import MagicMock, AsyncMock, patch\n\nimport httpx\n\nfrom agentcube.runtime.invoke_runtime import InvokeRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\n@pytest.fixture\ndef tmp_path(tmp_path: Path) -> Path:\n    \"\"\"Create a temp