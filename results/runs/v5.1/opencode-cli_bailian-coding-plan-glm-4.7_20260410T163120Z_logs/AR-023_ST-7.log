replicas\": 2,\n42:     }\n43:     return provider\n44: \n45: \n46: class TestStatusRuntimeInit:\n47:     \"\"\"Tests for StatusRuntime.__init__.\"\"\"\n48:     \n49:     def test_init_default(self) -> None:\n50:         \"\"\"Test initialization with default parameters.\"\"\"\n51:         runtime = StatusRuntime()\n52:         assert runtime.verbose is False\n53:         assert runtime.provider == \"agentcube\"\n54:     \n55:     def test_init_with_verbose(self) -> None:\n56:         \"\"\"Test initialization with verbose flag.\"\"\"\n57:         runtime = StatusRuntime(verbose=True)\n58:         assert runtime.verbose is True\n59:         assert runtime.provider == \"agentcube\"\n60:     \n61:     def test_init_with_provider(self) -> None:\n62:         \"\"\"Test initialization with custom provider.\"\"\"\n63:         runtime = StatusRuntime(provider=\"k8s\")\n64:         assert runtime.verbose is False\n65:         assert runtime.provider == \"k8s\"\n66:     \n67:     def test_init_with_all_params(self) -> None:\n68:         \"\"\"Test initialization with all parameters.\"\"\"\n69:         runtime = StatusRuntime(verbose=True, provider=\"k8s\")\n70:         assert runtime.verbose is True\n71:         assert runtime.provider == \"k8s\"\n72: \n73: \n74: class TestGetStatus:\n75:     \"\"\"Tests for StatusRuntime.get_status.\"\"\"\n76:     \n77:     def test_get_status_not_published(self, tmp_path: Path) -> None:\n78:         \"\"\"Test get_status returns not_published when agent not published.\"\"\"\n79:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n80:         metadata_file.write_text(\"\"\"\n81: agent_name: test-agent\n82: entrypoint: python main.py\n83: \"\"\")\n84:         \n85:         runtime = StatusRuntime()\n86:         status = runtime.get_status(tmp_path)\n87:         \n88:         assert status[\"status\"] == \"not_published\"\n89:         assert \"not been published\" in status[\"message\"].lower()\n90:     \n91:     def test_get_status_agentcube_provider(self, tmp_path: Path) -> None:\n92:         \"\"\"Test get_status with agentcube provider.\"\"\"\n93:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n94:         metadata_file.write_text(\"\"\"\n95: agent_name: test-agent\n96: entrypoint: python main.py\n97: agent_id: abc123\n98: k8s_deployment:\n99:   type: AgentRuntime\n100:   namespace: default\n101: \"\"\")\n102:         \n103:         runtime = StatusRuntime(provider=\"agentcube\")\n104:         \n105:         with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n106:             mock_provider = MagicMock()\n107:             mock_provider.get_agent_runtime.return_value = {\n108:                 \"metadata\": {\"name\": \"test-agent\"},\n109:                 \"status\": {\n110:                     \"status\": \"Running\",\n111:                     \"agentEndpoint\": \"http://localhost:8080\",\n112:                 }\n113:             }\n114:             mock_provider_class.return_value = mock_provider\n115:             \n116:             status = runtime.get_status(tmp_path)\n117:             \n118:             assert status[\"status\"] == \"Running\"\n119:             assert status[\"provider\"] == \"agentcube\"\n120:             assert status[\"agent_endpoint\"] == \"http://localhost:8080\"\n121:     \n122:     def test_get_status_k8s_provider(self, tmp_path: Path) -> None:\n123:         \"\"\"Test get_status with k8s provider.\"\"\"\n124:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n125:         metadata_file.write_text(\"\"\"\n126: agent_name: test-agent\n127: entrypoint: python main.py\n128: k8s_deployment:\n129:   type: Deployment\n130:   namespace: default\n131:   deployment_name: test-agent\n132:   service_url: http://localhost:8080\n133: \"\"\")\n134:         \n135:         runtime = StatusRuntime(provider=\"k8s\")\n136:         \n137:         with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n138:             mock_provider = MagicMock()\n139:             mock_provider.get_agent_status.return_value = {\n140:                 \"status\": \"running\",\n141:                 \"replicas\": 2,\n142:                 \"ready_replicas\": 2,\n143:                 \"available_replicas\": 2,\n144:             }\n145:             mock_provider_class.return_value = mock_provider\n146:             \n147:             status = runtime.get_status(tmp_path)\n148:             \n149:             assert status[\"status\"] == \"running\"\n150:             assert status[\"provider\"] == \"k8s\"\n151:             assert status[\"replicas\"] == 2\n152:             assert status[\"ready_replicas\"] == 2\n153:     \n154:     def test_get_status_provider_override(self, tmp_path: Path) -> None:\n155:         \"\"\"Test get_status with provider parameter override.\"\"\"\n156:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n157:         metadata_file.write_text(\"\"\"\n158: agent_name: test-agent\n159: entrypoint: python main.py\n160: agent_id: abc123\n161: k8s_deployment:\n162:   type: AgentRuntime\n163:   namespace: default\n164: \"\"\")\n165:         \n166:         runtime = StatusRuntime(provider=\"agentcube\")\n167:         \n168:         with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n169:             mock_provider = MagicMock()\n170:             mock_provider.get_agent_status.return_value = {\n171:                 \"status\": \"running\",\n172:                 \"replicas\": 1,\n173:                 \"ready_replicas\": 1,\n174:                 \"available_replicas\": 1,\n175:             }\n176:             mock_provider_class.return_value = mock_provider\n177:             \n178:             status = runtime.get_status(tmp_path, provider=\"k8s\")\n179:             \n180:             assert status[\"provider\"] == \"k8s\"\n181:     \n182:     def test_get_status_unsupported_provider(self, tmp_path: Path) -> None:\n183:         \"\"\"Test get_status handles unsupported provider gracefully.\"\"\"\n184:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n185:         metadata_file.write_text(\"\"\"\n186: agent_name: test-agent\n187: entrypoint: python main.py\n188: agent_id: abc123\n189: k8s_deployment:\n190:   type: AgentRuntime\n191:   namespace: default\n192: \"\"\")\n193:         \n194:         runtime = StatusRuntime()\n195:         \n196:         status = runtime.get_status(tmp_path, provider=\"invalid\")\n197:         \n198:         assert status[\"status\"] == \"error\"\n199:         assert \"Unsupported provider\" in status[\"message\"]\n200:     \n201:     def test_get_status_provider_error(self, tmp_path: Path) -> None:\n202:         \"\"\"Test get_status handles provider errors gracefully.\"\"\"\n203:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n204:         metadata_file.write_text(\"\"\"\n205: agent_name: test-agent\n206: entrypoint: python main.py\n207: agent_id: abc123\n208: k8s_deployment:\n209:   type: AgentRuntime\n210:   namespace: default\n211: \"\"\")\n212:         \n213:         runtime = StatusRuntime()\n214:         \n215:         with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n216:             mock_provider = MagicMock()\n217:             mock_provider.get_agent_runtime.side_effect = Exception(\"Provider error\")\n218:             mock_provider_class.return_value = mock_provider\n219:             \n220:             status = runtime.get_status(tmp_path)\n221:             \n222:             assert status[\"status\"] == \"error\"\n223:             assert \"Provider error\" in status[\"message\"]\n224: \n225: \n226: class TestGetK8sStatus:\n227:     \"\"\"Tests for StatusRuntime._get_k8s_status.\"\"\"\n228:     \n229:     def test_get_k8s_status_success(self) -> None:\n230:         \"\"\"Test successful k8s status retrieval.\"\"\"\n231:         metadata = AgentMetadata(\n232:             agent_name=\"test-agent\",\n233:             entrypoint=\"python main.py\",\n234:             k8s_deployment={\n235:                 \"type\": \"Deployment\",\n236:                 \"namespace\": \"test-ns\",\n237:                 \"deployment_name\": \"test-agent\",\n238:             }\n239:         )\n240:         \n241:         runtime = StatusRuntime()\n242:         \n243:         with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n244:             mock_provider = MagicMock()\n245:             mock_provider.get_agent_status.return_value = {\n246:                 \"status\": \"running\",\n247:                 \"replicas\": 3,\n248:                 \"ready_replicas\": 3,\n249:                 \"available_replicas\": 3,\n250:             }\n251:             mock_provider_class.return_value = mock_provider\n252:             \n253:             status = runtime._get_k8s_status(metadata)\n254:             \n255:             assert status[\"status\"] == \"running\"\n256:             assert status[\"provider\"] == \"k8s\"\n257:             assert status[\"namespace\"] == \"test-ns\"\n258:             assert status[\"deployment_name\"] == \"test-agent\"\n259:             assert status[\"replicas\"] == 3\n260:             assert status[\"ready_replicas\"] == 3\n261:     \n262:     def test_get_k8s_status_no_deployment(self) -> None:\n263:         \"\"\"Test k8s status with no k8s_deployment.\"\"\"\n264:         metadata = AgentMetadata(\n265:             agent_name=\"test-agent\",\n266:             entrypoint=\"python main.py\",\n267:         )\n268:         \n269:         runtime = StatusRuntime()\n270:         status = runtime._get_k8s_status(metadata)\n271:         \n272:         assert status[\"status\"] == \"not_published\"\n273:         assert \"No Kubernetes deployment found\" in status[\"message\"]\n274:     \n275:     def test_get_k8s_status_not_found(self) -> None:\n276:         \"\"\"Test k8s status when deployment not found.\"\"\"\n277:         metadata = AgentMetadata(\n278:             agent_name=\"test-agent\",\n279:             entrypoint=\"python main.py\",\n280:             k8s_deployment={\n281:                 \"type\": \"Deployment\",\n282:                 \"namespace\": \"default\",\n283:                 \"deployment_name\": \"test-agent\",\n284:             }\n285:         )\n286:         \n287:         runtime = StatusRuntime()\n288:         \n289:         with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n290:             mock_provider = MagicMock()\n291:             mock_provider.get_agent_status.return_value = {\n292:                 \"status\": \"not_found\"\n293:             }\n294:             mock_provider_class.return_value = mock_provider\n295:             \n296:             status = runtime._get_k8s_status(metadata)\n297:             \n298:             assert status[\"status\"] == \"not_found\"\n299:             assert \"Deployment not found\" in status[\"message\"]\n300:     \n301:     def test_get_k8s_status_partial_ready(self) -> None:\n302:         \"\"\"Test k8s status when deployment is partially ready.\"\"\"\n303:         metadata = AgentMetadata(\n304:             agent_name=\"test-agent\",\n305:             entrypoint=\"python main.py\",\n306:             k8s_deployment={\n307:                 \"type\": \"Deployment\",\n308:                 \"namespace\": \"default\",\n309:                 \"deployment_name\": \"test-agent\",\n310:             }\n311:         )\n312:         \n313:         runtime = StatusRuntime()\n314:         \n315:         with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n316:             mock_provider = MagicMock()\n317:             mock_provider.get_agent_status.return_value = {\n318:                 \"status\": \"running\",\n319:                 \"replicas\": 3,\n320:                 \"ready_replicas\": 1,\n321:                 \"available_replicas\": 1,\n322:             }\n323:             mock_provider_class.return_value = mock_provider\n324:             \n325:             status = runtime._get_k8s_status(metadata)\n326:             \n327:             assert status[\"status\"] == \"running\"\n328:             assert status[\"replicas\"] == 3\n329:             assert status[\"ready_replicas\"] == 1\n330:             assert \"not fully ready\" in status[\"message\"]\n331:     \n332:     def test_get_k8s_status_default_namespace(self) -> None:\n333:         \"\"\"Test k8s status with default namespace.\"\"\"\n334:         metadata = AgentMetadata(\n335:             agent_name=\"test-agent\",\n336:             entrypoint=\"python main.py\",\n337:             k8s_deployment={\n338:                 \"type\": \"Deployment\",\n339:                 \"deployment_name\": \"test-agent\",\n340:             }\n341:         )\n342:         \n343:         runtime = StatusRuntime()\n344:         \n345:         with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n346:             mock_provider = MagicMock()\n347:             mock_provider.get_agent_status.return_value = {\n348:                 \"status\": \"running\",\n349:                 \"replicas\": 1,\n350:                 \"ready_replicas\": 1,\n351:                 \"available_replicas\": 1,\n352:             }\n353:             mock_provider_class.return_value = mock_provider\n354:             \n355:             status = runtime._get_k8s_status(metadata)\n356:             \n357:             assert status[\"namespace\"] == \"default\"\n358:             mock_provider_class.assert_called_once_with(namespace=\"default\", verbose=False)\n359:     \n360:     def test_get_k8s_status_deployment_name_fallback(self) -> None:\n361:         \"\"\"Test k8s status uses agent_name as deployment_name.\"\"\"\n362:         metadata = AgentMetadata(\n363:             agent_name=\"my-agent\",\n364:             entrypoint=\"python main.py\",\n365:             k8s_deployment={\n366:                 \"type\": \"Deployment\",\n367:                 \"namespace\": \"default\",\n368:             }\n369:         )\n370:         \n371:         runtime = StatusRuntime()\n372:         \n373:         with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n374:             mock_provider = MagicMock()\n375:             mock_provider.get_agent_status.return_value = {\n376:                 \"status\": \"running\",\n377:                 \"replicas\": 1,\n378:                 \"ready_replicas\": 1,\n379:                 \"available_replicas\": 1,\n380:             }\n381:             mock_provider_class.return_value = mock_provider\n382:             \n383:             status = runtime._get_k8s_status(metadata)\n384:             \n385:             assert status[\"deployment_name\"] == \"my-agent\"\n386:             mock_provider.get_agent_status.assert_called_once_with(\"my-agent\")\n387:     \n388:     def test_get_k8s_status_error(self) -> None:\n389:         \"\"\"Test k8s status handles provider errors.\"\"\"\n390:         metadata = AgentMetadata(\n391:             agent_name=\"test-agent\",\n392:             entrypoint=\"python main.py\",\n393:             k8s_deployment={\n394:                 \"type\": \"Deployment\",\n395:                 \"namespace\": \"default\",\n396:                 \"deployment_name\": \"test-agent\",\n397:             }\n398:         )\n399:         \n400:         runtime = StatusRuntime()\n401:         \n402:         with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n403:             mock_provider = MagicMock()\n404:             mock_provider.get_agent_status.side_effect = Exception(\"K8s API error\")\n405:             mock_provider_class.return_value = mock_provider\n406:             \n407:             status = runtime._get_k8s_status(metadata)\n408:             \n409:             assert status[\"status\"] == \"error\"\n410:             assert \"K8s API error\" in status[\"message\"]\n411: \n412: \n413: class TestGetCrK8sStatus:\n414:     \"\"\"Tests for StatusRuntime._get_cr_k8s_status.\"\"\"\n415:     \n416:     def test_get_cr_k8s_status_running(self) -> None:\n417:         \"\"\"Test CR status when agent is running.\"\"\"\n418:         metadata = AgentMetadata(\n419:             agent_name=\"test-agent\",\n420:             entrypoint=\"python main.py\",\n421:             agent_id=\"abc123\",\n422:             k8s_deployment={\n423:                 \"type\": \"AgentRuntime\",\n424:                 \"namespace\": \"test-ns\",\n425:             }\n426:         )\n427:         \n428:         runtime = StatusRuntime()\n429:         \n430:         with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n431:             mock_provider = MagicMock()\n432:             mock_provider.get_agent_runtime.return_value = {\n433:                 \"metadata\": {\"name\": \"test-agent\"},\n434:                 \"status\": {\n435:                     \"status\": \"Running\",\n436:                     \"agentEndpoint\": \"http://localhost:8080\",\n437:                     \"message\": \"Agent is running\",\n438:                 }\n439:             }\n440:             mock_provider_class.return_value = mock_provider\n441:             \n442:             status = runtime._get_cr_k8s_status(metadata)\n443:             \n444:             assert status[\"status\"] == \"Running\"\n445:             assert status[\"provider\"] == \"agentcube\"\n446:             assert status[\"namespace\"] == \"test-ns\"\n447:             assert status[\"agent_endpoint\"] == \"http://localhost:8080\"\n448:             assert status[\"message\"] == \"Agent is running\"\n449:     \n450:     def test_get_cr_k8s_status_not_published(self) -> None:\n451:         \"\"\"Test CR status when agent not published.\"\"\"\n452:         metadata = AgentMetadata(\n453:             agent_name=\"