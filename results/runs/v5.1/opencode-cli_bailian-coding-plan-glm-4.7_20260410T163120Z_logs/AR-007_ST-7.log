ult{Created: false}, nil\n239: \t}\n240: \n241: \tdesiredSpec := r.buildPodSpec(codeInterpreter)\n242: \tif podSpecsEqual(&existingPod.Spec, &desiredSpec) {\n243: \t\treturn &SandboxResult{Created: false}, nil\n244: \t}\n245: \n246: \texistingPod.Spec = desiredSpec\n247: \tif err := r.Update(ctx, existingPod); err != nil {\n248: \t\tlogger.Error(err, \"Failed to update sandbox pod\")\n249: \t\tRecordSandboxUpdate(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"error\", 0)\n250: \t\treturn nil, NewSandboxUpdateFailedError(fmt.Sprintf(\"Failed to update sandbox pod: %v\", err), err)\n251: \t}\n252: \n253: \tlogger.Info(\"Sandbox pod updated successfully\")\n254: \tRecordSandboxUpdate(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", 0)\n255: \treturn &SandboxResult{Updated: true}, nil\n256: }\n257: \n258: func (r *CodeInterpreterReconciler) buildPodSpec(codeInterpreter *runtimev1alpha1.CodeInterpreter) corev1.PodSpec {\n259: \timage := codeInterpreter.Spec.Image\n260: \tif image == \"\" {\n261: \t\timage = \"python:3.11-slim\"\n262: \t}\n263: \n264: \tcontainer := corev1.Container{\n265: \t\tName:                     \"code-interpreter\",\n266: \t\tImage:                    image,\n267: \t\tEnv:                      convertEnvVars(codeInterpreter.Spec.Env),\n268: \t\tTerminationMessagePath:   \"/dev/termination-log\",\n269: \t\tTerminationMessagePolicy: corev1.TerminationMessageReadFile,\n270: \t\tImagePullPolicy:          corev1.PullIfNotPresent,\n271: \t}\n272: \n273: \tif codeInterpreter.Spec.Resources != nil {\n274: \t\tcontainer.Resources = convertResources(codeInterpreter.Spec.Resources)\n275: \t}\n276: \n277: \treturn corev1.PodSpec{\n278: \t\tContainers: []corev1.Container{container},\n279: \t}\n280: }\n281: \n282: func (r *CodeInterpreterReconciler) validateSpec(codeInterpreter *runtimev1alpha1.CodeInterpreter) error {\n283: \tif codeInterpreter.Spec.Image == \"\" {\n284: \t\treturn fmt.Errorf(\"image i