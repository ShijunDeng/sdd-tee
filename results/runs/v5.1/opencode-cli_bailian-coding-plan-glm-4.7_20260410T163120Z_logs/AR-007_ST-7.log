\t\tlogger.Info(\"Sandbox pod deleted successfully\")\n153: \t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeNormal, ReasonSandboxDeleted,\n154: \t\t\tfmt.Sprintf(\"Sandbox %s deleted\", sandboxName))\n155: \t\tRecordSandboxDeletion(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", 0)\n156: \t} else if !apierrors.IsNotFound(err) {\n157: \t\tlogger.Error(err, \"Failed to get sandbox pod\")\n158: \t\treturn ctrl.Result{}, err\n159: \t}\n160: \n161: \tif HasFinalizer(codeInterpreter, FinalizerCodeInterpreter) {\n162: \t\tif err := RemoveFinalizer(ctx, r.Client, codeInterpreter, FinalizerCodeInterpreter); err != nil {\n163: \t\t\tlogger.Error(err, \"Failed to remove finalizer\")\n164: \t\t\treturn ctrl.Result{}, err\n165: \t\t}\n166: \t}\n167: \n168: \tlogger.Info(\"CodeInterpreter deleted successfully\")\n169: \treturn ctrl.Result{}, nil\n170: }\n171: \n172: func (r *CodeInterpreterReconciler) reconcileSandbox(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter) (*SandboxResult, error) {\n173: \tlogger := log.FromContext(ctx)\n174: \tsandboxName := GetSandboxName(codeInterpreter.Name)\n175: \n176: \texistingPod := &corev1.Pod{}\n177: \terr := r.Get(ctx, client.ObjectKey{\n178: \t\tNamespace: codeInterpreter.Namespace,\n179: \t\tName:      sandboxName,\n180: \t}, existingPod)\n181: \n182: \tif err != nil {\n183: \t\tif apierrors.IsNotFound(err) {\n184: \t\t\treturn r.createSandboxPod(ctx, codeInterpreter, sandboxName)\n185: \t\t}\n186: \t\treturn nil, fmt.Errorf(\"failed to get sandbox pod: %w\", err)\n187: \t}\n188: \n189: \treturn r.updateSandboxPod(ctx, codeInterpreter, existingPod, sandboxName)\n190: }\n191: \n192: func (r *CodeInterpreterReconciler) createSandboxPod(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter, sandboxName string) (*SandboxResult, error) {\n193: \tlogger := log.FromContext(ctx)\n194: \tlogger.Info(\"Creating sandbox pod\", \"name\", sandboxName)\n195: \n196: \tstartTim