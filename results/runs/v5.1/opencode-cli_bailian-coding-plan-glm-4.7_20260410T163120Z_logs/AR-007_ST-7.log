(conditions *[]metav1.Condition, conditionType string, status metav1.ConditionStatus, reason, message string) {\n37: \tnewCondition := metav1.Condition{\n38: \t\tType:               conditionType,\n39: \t\tStatus:             status,\n40: \t\tReason:             reason,\n41: \t\tMessage:            message,\n42: \t\tLastTransitionTime: metav1.Now(),\n43: \t}\n44: \n45: \tif conditions == nil {\n46: \t\tconditions = &[]metav1.Condition{}\n47: \t}\n48: \n49: \tfor i := range *conditions {\n50: \t\tif (*conditions)[i].Type == conditionType {\n51: \t\t\tif (*conditions)[i].Status != status {\n52: \t\t\t\t(*conditions)[i] = newCondition\n53: \t\t\t} else {\n54: \t\t\t\t(*conditions)[i].LastTransitionTime = newCondition.LastTransitionTime\n55: \t\t\t\t(*conditions)[i].Reason = reason\n56: \t\t\t\t(*conditions)[i].Message = message\n57: \t\t\t}\n58: \t\t\treturn\n59: \t\t}\n60: \t}\n61: \n62: \t*conditions = append(*conditions, newCondition)\n63: }\n64: \n65: func GetCondition(conditions []metav1.Condition, conditionType string) *metav1.Condition {\n66: \tfor i := range conditions {\n67: \t\tif conditions[i].Type == conditionType {\n68: \t\t\treturn &conditions[i]\n69: \t\t}\n70: \t}\n71: \treturn nil\n72: }\n73: \n74: func IsReady(conditions []metav1.Condition) bool {\n75: \tcondition := GetCondition(conditions, ConditionTypeReady)\n76: \treturn condition != nil && condition.Status == metav1.ConditionTrue\n77: }\n78: \n79: func IsAvailable(conditions []metav1.Condition) bool {\n80: \tcondition := GetCondition(conditions, ConditionTypeAvailable)\n81: \treturn condition != nil && condition.Status == metav1.ConditionTrue\n82: }\n83: \n84: func IsProgressing(conditions []metav1.Condition) bool {\n85: \tcondition := GetCondition(conditions, ConditionTypeProgressing)\n86: \treturn condition != nil && condition.Status == metav1.ConditionTrue\n87: }\n88: \n89: func HasError(conditions []metav1.Condition) bool {\n90: \tcondition := GetCondition(conditions, ConditionTypeError)\n91: \treturn condition != nil && condition.Status == metav1.ConditionTrue\n92: }\n93: \n94: func SetReadyCondition(conditions *[]metav1.Condition, ready bool, reason, message string) {\n95: \tstatus := metav1.ConditionFalse\n96: \tif ready {\n97: \t\tstatus = metav1.ConditionTrue\n98: \t}\n99: \tSetCondition(conditions, ConditionTypeReady, status, reason, message)\n100: }\n101: \n102: func SetErrorCondition(conditions *[]metav1.Condition, err error, reason string) {\n103: \tmessage := \"\"\n104: \tif err != nil {\n105: \t\tmessage = err.Error()\n106: \t}\n107: \tSetCondition(conditions, ConditionTypeError, metav1.ConditionTrue, reason, message)\n108: }\n109: \n110: func ClearErrorCondition(conditions *[]metav1.Condition) {\n111: \tfor i := len(*conditions) - 1; i >= 0; i-- {\n112: \t\tif (*conditions)[i].Type == ConditionTypeError {\n113: \t\t\t*conditions = append((*conditions)[:i], (*conditions)[i+1:]...)\n114: \t\t\tbreak\n115: \t\t}\n116: \t}\n117: }\n118: \n119: func SetProgressingCondition(conditions *[]metav1.Condition, progressing bool, reason, message string) {\n120: \tstatus := metav1.ConditionFalse\n121: \tif progressing {\n122: \t\tstatus = metav1.ConditionTrue\n123: \t}\n124: \tSetCondition(conditions, ConditionTypeProgressing, status, reason, message)\n125: }\n126: \n127: func SetAvailableCondition(conditions *[]metav1.Condition, available bool, reason, message string) {\n128: \tstatus := metav1.ConditionFalse\n129: \tif available {\n130: \t\tstatus = metav1.ConditionTrue\n131: \t}\n132: \tSetCondition(conditions, ConditionTypeAvailable, status, reason, message)\n133: }\n134: \n135: func SetSandboxCreatedCondition(conditions *[]metav1.Condition, created bool, reason, message string) {\n136: \tstatus := metav1.ConditionFalse\n137: \tif created {\n138: \t\tstatus = metav1.ConditionTrue\n139: \t}\n140: \tSetCondition(conditions, ConditionTypeSandboxCreated, status, reason, message)\n141: }\n142: \n143: func GetConditionMessage(conditions []metav1.Condition, conditionType string) string {\n144: \tcondition := GetCondition(conditions, conditionType)\n145: \tif condition != nil {\n146: \t\treturn condition.Message\n147: \t}\n148: \treturn \"\"\n149: }\n150: \n151: func GetConditionReason(conditions []metav1.Condition, conditionType string) string {\n152: \tcondition := GetCondition(conditions, conditionType)\n153: \tif condition != nil {\n154: \t\treturn condition.Reason\n155: \t}\n156: \treturn \"\"\n157: }\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nconst (\n\tConditionTypeReady          = \"Ready\"\n\tConditionTypeAvailable      = \"Available\"\n\tConditionTypeProgressing    = \"Progressing\"\n\tConditionTypeError          = \"Error\"\n\tConditionTypeSandboxCreated = \"SandboxCreated\"\n)\n\nconst (\n\tReasonReconciliationStarted  = \"ReconciliationStarted\"\n\tReasonReconciliationComplete = \"ReconciliationComplete\"\n\tReasonReconciliationFailed   = \"ReconciliationFailed\"\n\n\tReasonSandboxCreating     = \"SandboxCreating\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/status.go","time":{"start":1775847111424,"end":1775847111440}}}}
{"type":"tool_use","timestamp":1775847111443,"sessionID":"ses_28743f8f0ffeMF8CEy3M1Ky4Ux","part":{"id":"prt_d78bc76a2001PDAm7ERbSAzZ20","messageID":"msg_d78bc65ea001tyXjvobapHm86j","sessionID":"ses_28743f8f0ffeMF8CEy3M1Ky4Ux","type":"tool","tool":"read","callID":"toolu_tool-51ee536a37ac4bb39cb4a9ef5992f8dd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/metrics.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/metrics.go</path>\n<type>file</type>\n<content>\n1: package reconciler\n2: \n3: import (\n4: \t\"github.com/prometheus/client_golang/prometheus\"\n5: )\n6: \n7: const (\n8: \tmetricReconcileTotal    = \"workloadmanager_reconcile_total\"\n9: \tmetricReconcileErrors   = \"workloadmanager_reconcile_errors_total\"\n10: \tmetricReconcileDuration = \"workloadmanager_reconcile_duration_seconds\"\n11: \tmetricReconcileRequeues = \"workloadmanager_reconcile_requeues_total\"\n12: \n13: \tmetricResourcesReady   = \"workloadmanager_resources_ready\"\n14: \tmetricResourcesPending = \"workloadmanager_resources_pending\"\n15: \tmetricResourcesError   = \"workloadmanager_resources_error\"\n16: \n17: \tmetricSandboxCreations      = \"workloadmanager_sandbox_creations_total\"\n18: \tmetricSandboxDeletions      = \"workloadmanager_sandbox_deletions_total\"\n19: \tmetricSandboxUpdateDuration = \"workloadmanager_sandbox_update_duration_seconds\"\n20: )\n21: \n22: var (\n23: \treconcileTotal = prometheus.NewCounterVec(\n24: \t\tprometheus.CounterOpts{\n25: \t\t\tName: metricReconcileTotal,\n26: \t\t\tHelp: \"Total number of reconciliation operations\",\n27: \t\t},\n28: \t\t[]string{\"controller\", \"namespace\", \"name\"},\n29: \t)\n30: \n31: \treconcileErrors = prometheus.NewCounterVec(\n32: \t\tprometheus.CounterOpts{\n33: \t\t\tName: metricReconcileErrors,\n34: \t\t\tHelp: \"Total number of reconciliation errors\",\n35: \t\t},\n36: \t\t[]string{\"controller\", \"namespace\", \"name\", \"error_type\"},\n37: \t)\n38: \n39: \treconcileDuration = prometheus.NewHistogramVec(\n40: \t\tprometheus.HistogramOpts{\n41: \t\t\tName:    metricReconcileDuration,\n42: \t\t\tHelp:    \"Reconciliation duration in seconds\",\n43: \t\t\tBuckets: prometheus.DefBuckets,\n44: \t\t},\n45: \t\t[]string{\"controller\", \"result\"},\n46: \t)\n47: \n48: \treconcileRequeues = prometheus.NewCounterVec(\n49: \t\tprometheus.CounterOpts{\n50: \t\t\tName: metricReconcileRequeues,\n51: \t\t\tHelp: \"Total number of reconciliation requeues\",\n52: \t\t},\n53: \t\t[]string{\"controller\", \"namespace\", \"name\"},\n54: \t)\n55: \n56: \tresourcesReady = prometheus.NewGaugeVec(\n57: \t\tprometheus.GaugeOpts{\n58: \t\t\tName: metricResourcesReady,\n59: \t\t\tHelp: \"Number of ready resources\",\n60: \t\t},\n61: \t\t[]string{\"controller\", \"namespace\"},\n62: \t)\n63: \n64: \tresourcesPending = prometheus.NewGaugeVec(\n65: \t\tprometheus.GaugeOpts{\n66: \t\t\tName: metricResourcesPending,\n67: \t\t\tHelp: \"Number of pending resources\",\n68: \t\t},\n69: \t\t[]string{\"controller\", \"namespace\"},\n70: \t)\n71: \n72: \tresourcesError = prometheus.NewGaugeVec(\n73: \t\tprometheus.GaugeOpts{\n74: \t\t\tName: metricResourcesError,\n75: \t\t\tHelp: \"Number of resources in error state\",\n76: \t\t},\n77: \t\t[]string{\"controller\", \"namespace\"},\n78: \t)\n79: \n80: \tsandboxCreations = prometheus.NewCounterVec(\n81: \t\tprometheus.CounterOpts{\n82: \t\t\tName: metricSandboxCreations,\n83: \t\t\tHelp: \"Total number of sandbox creations\",\n84: \t\t},\n85: \t\t[]string{\"controller\", \"namespace\", \"name\", \"result\"},\n86: \t)\n87: \n88: \tsandboxDeletions = prometheus.NewCounterVec(\n89: \t\tprometheus.CounterOpts{\n90: \t\t\tName: metricSandboxDeletions,\n91: \t\t\tHelp: \"Total number of sandbox deletions\",\n92: \t\t},\n93: \t\t[]string{\"controller\", \"namespace\", \"name\", \"result\"},\n94: \t)\n95: \n96: \tsandboxUpdateDuration = prometheus.NewHistogramVec(\n97: \t\tprometheus.HistogramOpts{\n98: \t\t\tName:    metricSandboxUpdateDuration,\n99: \t\t\tHelp:    \"Sandbox update duration in seconds\",\n100: \t\t\tBuckets: prometheus.DefBuckets,\n101: \t\t},\n102: \t\t[]string{\"controller\", \"operation\"},\n103: \t)\n104: )\n105: \n106: func init() {\n107: \tprometheus.MustRegister(reconcileTotal)\n108: \tprometheus.MustRegister(reconcileErrors)\n109: \tprometheus.MustRegister(reconcileDuration)\n110: \tprometheus.MustRegister(reconcileRequeues)\n111: \tprometheus.MustRegister(resourcesReady)\n112: \tprometheus.MustRegister(resourcesPending)\n113: \tprometheus.MustRegister(resourcesError)\n114: \tprometheus.MustRegister(sandboxCreations)\n115: \tprometheus.MustRegister(sandboxDeletions)\n116: \tprometheus.MustRegister(sandboxUpdateDuration)\n117: }\n118: \n119: func RecordReconciliation(controller, namespace, name string, duration float64, result string) {\n120: \treconcileTotal.WithLabelValues(controller, namespace, name).Inc()\n121: \treconcileDuration.WithLabelValues(controller, result).Observe(duration)\n122: \n123: \tif result == \"error\" {\n124: \t\treconcileRequeues.WithLabelValues(controller, namespace, name).Inc()\n125: \t}\n126: }\n127: \n128: func RecordReconciliationError(controller, namespace, name, errorType string) {\n129: \treconcileErrors.WithLabelValues(controller, namespace, name, errorType).Inc()\n130: }\n131: \n132: func RecordRequeue(controller, namespace, name string) {\n133: \treconcileRequeues.WithLabelValues(controller, namespace, name).Inc()\n134: }\n135: \n136: func RecordResourceReady(controller, namespace string) {\n137: \tresourcesReady.WithLabelValues(controller, namespace).Inc()\n138: }\n139: \n140: func RecordResourcePending(controller, namespace string) {\n141: \tresourcesPending.WithLabelValues(controller, namespace).Inc()\n142: }\n143: \n144: func RecordResourceError(controller, namespace string) {\n145: \tresourcesError.WithLabelValues(controller, namespace).Inc()\n146: }\n147: \n148: func ClearResourceMetrics(controller, namespace string) {\n149: \tresourcesReady.WithLabelValues(controller, namespace).Set(0)\n150: \tresourcesPending.WithLabelValues(controller, namespace).Set(0)\n151: \tresourcesError.WithLabelValues(controller, namespace).Set(0)\n152: }\n153: \n154: func RecordSandboxCreation(controller, namespace, name, result string, duration float64) {\n155: \tsandboxCreations.WithLabelValues(controller, namespace, name, result).Inc()\n156: \tsandboxUpdateDuration.WithLabelValues(controller, \"create\").Observe(duration)\n157: }\n158: \n159: func RecordSandboxDeletion(controller, namespace, name, result string, duration float64) {\n160: \tsandboxDeletions.WithLabelValues(controller, namespace, name, result).Inc()\n161: \tsandboxUpdateDuration.WithLabelValues(controller, \"delete\").Observe(duration)\n162: }\n163: \n164: func RecordSandboxUpdate(controller, namespace, name, result string, duration float64) {\n165: \tsandboxUpdateDuration.WithLabelValues(controller, \"update\").Observe(duration)\n166: }\n167: \n168: func ResetMetrics() {\n169: \treconcileTotal.Reset()\n170: \treconcileErrors.Reset()\n171: \treconcileDuration.Reset()\n172: \treconcileRequeues.Reset()\n173: \tresourcesReady.Reset()\n174: \tresourcesPending.Reset()\n175: \tresourcesError.Reset()\n176: \tsandboxCreations.Reset()\n177: \tsandboxDeletions.Reset()\n178: \tsandboxUpdateDuration.Reset()\n179: }\n\n(End of file - total 179 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"github.com/prometheus/client_golang/prometheus\"\n)\n\nconst (\n\tmetricReconcileTotal    = \"workloadmanager_reconcile_total\"\n\tmetricReconcileErrors   = \"workloadmanager_reconcile_errors_total\"\n\tmetricReconcileDuration = \"workloadmanager_reconcile_duration_seconds\"\n\tmetricReconcileRequeues = \"workloadmanager_reconcile_requeues_total\"\n\n\tmetricResourcesReady   = \"workloadmanager_resources_ready\"\n\tmetricResourcesPending = \"workloadmanager_resources_pending\"\n\tmetricResourcesError   = \"workloadmanager_resources_error\"\n\n\tmetricSandboxCreations      = \"workloadmanager_sandbox_creations_total\"\n\tmetricSandboxDeletions      = \"workloadmanager_sandbox_deletions_total\"\n\tmetricSandboxUpdateDuration = \"workloadmanager_sandbox_update_duration_seconds\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/metrics.go","time":{"start":1775847111427,"end":1775847111442}}}}
