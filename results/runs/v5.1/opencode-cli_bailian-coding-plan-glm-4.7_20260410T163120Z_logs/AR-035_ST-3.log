}) {\n    f.lock.Lock()\n    defer f.lock.Unlock()\n\n    for informerType, informer := range f.informers {\n        if !f.startedInformers[informerType] {\n            go informer.Run(stopCh)\n            f.startedInformers[informerType] = true\n        }\n    }\n}\n\n// WaitForCacheSync waits for all started informers' cache were synced.\nfunc (f *sharedInformerFactory) WaitForCacheSync(stopCh <-chan struct{}) map[reflect.Type]bool {\n    informers := func() []cache.SharedIndexInformer {\n        f.lock.Lock()\n        defer f.lock.Unlock()\n\n        informers := make([]cache.SharedIndexInformer, 0, len(f.informers))\n        for _, informer := range f.informers {\n            if f.startedInformers[informer.Type()] {\n                informers = append(informers, informer)\n            }\n        }\n        return informers\n    }()\n\n    res := map[reflect.Type]bool{}\n    for _, informer := range informers {\n        res[informer.Type()] = cache.WaitForCacheSync(stopCh, informer.HasSynced)\n    }\n    return res\n}\n\n// Runtime provides access to runtime shared informers.\nfunc (f *sharedInformerFactory) Runtime() externalversionsruntime.Interface {\n    return externalversionsruntime.New(f, f.namespace, f.tweakListOptions)\n}\n```\n\n## API Contracts\n\n### ClientSet Contract\n\n**Interface Definition** (`clientset/versioned/clientset.go`):\n\n```go\ntype Interface interface {\n    Discovery() discovery.DiscoveryInterface\n    RuntimeV1alpha1() runtimev1alpha1.RuntimeV1alpha1Interface\n}\n```\n\n**Constructors**:\n\n| Constructor | Parameters | Returns | Behavior |\n|-------------|------------|---------|----------|\n| `NewForConfig` | `c *rest.Config` | `(*Clientset, error)` | Creates clientset from config |\n| `NewForConfigAndClient` | `c *rest.Config, httpClient *http.Client` | `(*Clientset, error)` | Creates clientset with custom HTTP client |\n| `NewForConfigOrDie` | `c *rest.Config` | `*Clientset` | Creates clientset or panics |\n| `New` | `c rest.Interface` | `*Clientset` | Creates clientset from REST client |\n\n### AgentRuntime Interface Contract\n\n**Interface Definition** (`clientset/versioned/typed/runtime/v1alpha1/agentruntime.go`):\n\n```go\ntype AgentRuntimeInterface interface {\n    Create(ctx context.Context, agentRuntime *v1alpha1.AgentRuntime, opts metav1.CreateOptions) (*v1alpha1.AgentRuntime, error)\n    Update(ctx context.Context, agentRuntime *v1alpha1.AgentRuntime, opts metav1.UpdateOptions) (*v1alpha1.AgentRuntime, error)\n    UpdateStatus(ctx context.Context, agentRuntime *v1alpha1.AgentRuntime, opts metav1.UpdateOptions) (*v1alpha1.AgentRuntime, error)\n    Delete(ctx context.Context, name string, opts metav1.DeleteOptions) error\n    DeleteCollection(ctx context.Context, opts metav1.DeleteOptions, listOpts metav1.ListOptions) error\n    Get(ctx context.Context, name string, opts metav1.GetOptions) (*v1alpha1.AgentRuntime, error)\n    List(ctx context.Context, opts metav1.ListOptions) (*v1alpha1.AgentRuntimeList, error)\n    Watch(ctx context.Context, opts metav1.ListOptions) (watch.Interface, error)\n    Patch(ctx context.Context, name string, pt types.PatchType, data []byte, opts metav1.PatchOptions, subresources ...string) (*v1alpha1.AgentRuntime, error)\n}\n```\n\n**REST Endpoints**:\n\n| Method | Endpoint | Description |\n|--------|----------|-------------|\n| GET | `/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/agentruntimes/{name}` | Get single AgentRuntime |\n| GET | `/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/agentruntimes` | List AgentRuntimes |\n| POST | `/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/agentruntimes` | Create AgentRuntime |\n| PUT | `/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/agentruntimes/{name}` | Update AgentRuntime |\n| PUT | `/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/agentruntimes/{name}/status` | Update AgentRuntime status |\n| DELETE | `/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/agentruntimes/{name}` | Delete AgentRuntime |\n| PATCH | `/apis/runtime.agentcube.volcano.sh/v1alpha1/namespaces/{namespace}/agentruntimes/{name}` | Patch AgentRuntime |\n\n### Informer Contract\n\n**SharedInformerFactory Interface** (`informers/externalversions/factory.go`):\n\n```go\ntype SharedInformerFactory interface {\n    Start(stopCh <-chan struct{})\n    Shutdown()\n    WaitForCacheSync(stopCh <-chan struct{}) map[reflect.Type]bool\n    ForResource(resource schema.GroupVersionResource) (GenericInformer, error)\n    InformerFor(obj runtime.Object, newFunc internalinterfaces.NewInformerFunc) cache.SharedIndexInformer\n    Runtime() externalversionsruntime.Interface\n}\n```\n\n**AgentRuntimeInformer Interface** (`informers/externalversions/runtime/v1alpha1/agentruntime.go`):\n\n```go\ntype AgentRuntimeInformer interface {\n    Informer() cache.SharedIndexInformer\n    Lister() v1alpha1.AgentRuntimeLister\n}\n```\n\n## Error Handling\n\n### Client Error Handling Pattern\n\n```go\n// Common error handling pattern for client operations\nimport (\n    \"k8s.io/apimachinery/pkg/api/errors\"\n)\n\nfunc handleAgentRuntime(ctx context.Context, client runtimev1alpha1.AgentRuntimeInterface, name string) error {\n    agentRuntime, err := client.Get(ctx, name, metav1.GetOptions{})\n    if err != nil {\n        if errors.IsNotFound(err) {\n            // Resource does not exist\n            return fmt.Errorf(\"agentRuntime %s not found: %w\", name, err)\n        } else if errors.IsAlreadyExists(err) {\n            // Resource already exists\n            return fmt.Errorf(\"agentRuntime %s already exists: %w\", name, err)\n        } else if errors.IsConflict(err) {\n            // Resource version conflict\n            return fmt.Errorf(\"agentRuntime %s conflict: %w\", name, err)\n        } else if errors.IsInvalid(err) {\n            // Invalid object\n            return fmt.Errorf(\"agentRuntime %s is invalid: %w\", name, err)\n        } else if errors.IsForbidden(err) {\n            // RBAC permission denied\n            return fmt.Errorf(\"access denied for agentRuntime %s: %w\", name, err)\n        } else if errors.IsUnauthorized(err) {\n            // Authentication failed\n            return fmt.Errorf(\"unauthorized access for agentRuntime %s: %w\", name, err)\n        }\n        // Other errors\n        return fmt.Errorf(\"failed to get agentRuntime %s: %w\", name, err)\n    }\n    // Process agentRuntime\n    return nil\n}\n```\n\n### Informer Error Handling\n\n```go\n// Informer event handler with error handling\ninformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n    AddFunc: func(obj interface{}) {\n        agentRuntime, ok := obj.(*v1alpha1.AgentRuntime)\n        if !ok {\n            klog.Errorf(\"unexpected type: %T\", obj)\n            return\n        }\n        klog.Infof(\"AgentRuntime %s added\", agentRuntime.Name)\n    },\n    UpdateFunc: func(oldObj, newObj interface{}) {\n        oldRuntime, ok := oldObj.(*v1alpha1.AgentRuntime)\n        if !ok {\n            klog.Errorf(\"unexpected old type: %T\", oldObj)\n            return\n        }\n        newRuntime, ok := newObj.(*v1alpha1.AgentRuntime)\n        if !ok {\n            klog.Errorf(\"unexpected new type: %T\", newObj)\n            return\n        }\n        if oldRuntime.ResourceVersion == newRuntime.ResourceVersion {\n            // Periodic resync with no change\n            return\n        }\n        klog.Infof(\"AgentRuntime %s updated\", newRuntime.Name)\n    },\n    DeleteFunc: func(obj interface{}) {\n        agentRuntime, ok := obj.(*v1alpha1.AgentRuntime)\n        if !ok {\n            tombstone, ok := obj.(cache.DeletedFinalStateUnknown)\n            if !ok {\n                klog.Errorf(\"couldn't get object from tombstone: %T\", obj)\n                return\n            }\n            agentRuntime, ok = tombstone.Obj.(*v1alpha1.AgentRuntime)\n            if !ok {\n                klog.Errorf(\"tombstone contained unexpected type: %T\", tombstone.Obj)\n                return\n            }\n        }\n        klog.Infof(\"AgentRuntime %s deleted\", agentRuntime.Name)\n    },\n})\n```\n\n## Testing Strategy\n\n### Unit Tests\n\n**File**: `clientset/versioned/typed/runtime/v1alpha1/agentruntime_test.go`\n\n```go\npackage v1alpha1_test\n\nimport (\n    \"context\"\n    \"testing\"\n\n    . \"github.com/onsi/ginkgo/v2\"\n    . \"github.com/onsi/gomega\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n    \"k8s.io/apimachinery/pkg/runtime\"\n    \"k8s.io/apimachinery/pkg/runtime/schema\"\n\n    runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n    \"github.com/volcano-sh/agentcube/client-go/clientset/versioned/fake\"\n)\n\nvar _ = Describe(\"AgentRuntime Client\", func() {\n    var (\n        client *fake.Clientset\n        ctx    context.Context\n    )\n\n    BeforeEach(func() {\n        ctx = context.Background()\n        client = fake.NewSimpleClientset()\n    })\n\n    Describe(\"Create\", func() {\n        It(\"should create AgentRuntime successfully\", func() {\n            agentRuntime := &runtimev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"test-agentruntime\",\n                    Namespace: \"default\",\n                },\n                Spec: runtimev1alpha1.AgentRuntimeSpec{\n                    MaxSessionDuration: \"8h\",\n                    SessionTimeout:     \"15m\",\n                    TargetPort: []runtimev1alpha1.TargetPort{\n                        {Port: 8080, Protocol: \"HTTP\"},\n                    },\n                },\n            }\n\n            result, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(ctx, agentRuntime, metav1.CreateOptions{})\n            Expect(err).NotTo(HaveOccurred())\n            Expect(result.Name).To(Equal(\"test-agentruntime\"))\n        })\n    })\n\n    Describe(\"Get\", func() {\n        It(\"should get AgentRuntime successfully\", func() {\n            agentRuntime := &runtimev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"test-agentruntime\",\n                    Namespace: \"default\",\n                },\n            }\n\n            _, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(ctx, agentRuntime, metav1.CreateOptions{})\n            Expect(err).NotTo(HaveOccurred())\n\n            result, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Get(ctx, \"test-agentruntime\", metav1.GetOptions{})\n            Expect(err).NotTo(HaveOccurred())\n            Expect(result.Name).To(Equal(\"test-agentruntime\"))\n        })\n    })\n\n    Describe(\"List\", func() {\n        It(\"should list AgentRuntimes successfully\", func() {\n            for i := 0; i < 3; i++ {\n                agentRuntime := &runtimev1alpha1.AgentRuntime{\n                    ObjectMeta: metav1.ObjectMeta{\n                        Name:      fmt.Sprintf(\"agentruntime-%d\", i),\n                        Namespace: \"default\",\n                    },\n                }\n                _, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(ctx, agentRuntime, metav1.CreateOptions{})\n                Expect(err).NotTo(HaveOccurred())\n            }\n\n            list, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").List(ctx, metav1.ListOptions{})\n            Expect(err).NotTo(HaveOccurred())\n            Expect(len(list.Items)).To(Equal(3))\n        })\n    })\n\n    Describe(\"Update\", func() {\n        It(\"should update AgentRuntime successfully\", func() {\n            agentRuntime := &runtimev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"test-agentruntime\",\n                    Namespace: \"default\",\n                },\n                Spec: runtimev1alpha1.AgentRuntimeSpec{\n                    MaxSessionDuration: \"8h\",\n                },\n            }\n\n            created, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(ctx, agentRuntime, metav1.CreateOptions{})\n            Expect(err).NotTo(HaveOccurred())\n\n            created.Spec.MaxSessionDuration = \"12h\"\n            updated, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Update(ctx, created, metav1.UpdateOptions{})\n            Expect(err).NotTo(HaveOccurred())\n            Expect(updated.Spec.MaxSessionDuration).To(Equal(\"12h\"))\n        })\n    })\n\n    Describe(\"Delete\", func() {\n        It(\"should delete AgentRuntime successfully\", func() {\n            agentRuntime := &runtimev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"test-agentruntime\",\n                    Namespace: \"default\",\n                },\n            }\n\n            _, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(ctx, agentRuntime, metav1.CreateOptions{})\n            Expect(err).NotTo(HaveOccurred())\n\n            err = client.RuntimeV1alpha1().AgentRuntimes(\"default\").Delete(ctx, \"test-agentruntime\", metav1.DeleteOptions{})\n            Expect(err).NotTo(HaveOccurred())\n\n            _, err = client.RuntimeV1alpha1().AgentRuntimes(\"default\").Get(ctx, \"test-agentruntime\", metav1.GetOptions{})\n            Expect(err).To(HaveOccurred())\n            Expect(errors.IsNotFound(err)).To(BeTrue())\n        })\n    })\n})\n```\n\n### Informer Tests\n\n**File**: `informers/externalversions/runtime/v1alpha1/agentruntime_test.go`\n\n```go\npackage v1alpha1_test\n\nimport (\n    \"context\"\n    \"testing\"\n    \"time\"\n\n    . \"github.com/onsi/ginkgo/v2\"\n    . \"github.com/onsi/gomega\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n    \"k8s.io/apimachinery/pkg/runtime\"\n    \"k8s.io/client-go/tools/cache\"\n\n    runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n    \"github.com/volcano-sh/agentcube/client-go/clientset/versioned/fake\"\n    \"github.com/volcano-sh/agentcube/client-go/informers/externalversions\"\n)\n\nvar _ = Describe(\"AgentRuntime Informer\", func() {\n    var (\n        client    *fake.Clientset\n        factory   externalversions.SharedInformerFactory\n        informer  cache.SharedIndexInformer\n        ctx       context.Context\n        stopCh    chan struct{}\n        addEvents chan *runtimev1alpha1.AgentRuntime\n    )\n\n    BeforeEach(func() {\n        ctx = context.Background()\n        stopCh = make(chan struct{})\n        addEvents = make(chan *runtimev1alpha1.AgentRuntime, 10)\n\n        client = fake.NewSimpleClientset()\n        factory = externalversions.NewSharedInformerFactory(client, time.Second)\n        informer = factory.Runtime().V1alpha1().AgentRuntimes().Informer()\n\n        informer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n            AddFunc: func(obj interface{}) {\n                agentRuntime, ok := obj.(*runtimev1alpha1.AgentRuntime)\n                if ok {\n                    addEvents <- agentRuntime\n                }\n            },\n        })\n\n        factory.Start(stopCh)\n    })\n\n    AfterEach(func() {\n        close(stopCh)\n    })\n\n    Describe(\"Add event\", func() {\n        It(\"should receive add events\", func() {\n            agentRuntime := &runtimev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"test-agentruntime\",\n                    Namespace: \"default\",\n                },\n            }\n\n            _, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(ctx, agentRuntime, metav1.CreateOptions{})\n            Expect(err).NotTo(HaveOccurred())\n\n            Eventually(func() bool {\n                sync := factory.WaitForCacheSync(stopCh)\n                return sync[informer.Type()]\n            }, 5*time.Second).Should(BeTrue())\n\n            Eventually(func() *runtimev1alpha1.AgentRuntime {\n                select {\n                case event := <-addEvents:\n                    return event\n                default:\n                    return nil\n                }\n            }, 5*time.Second).Should(Equal(agentRuntime))\n        })\n    })\n})\n```\n\n### Integration Tests\n\n**File**: `clientset/versioned/integration_test.go`\n\n```go\npackage versioned_test\n\nimport (\n    \"context\"\n    \"testing\"\n    \"time\"\n\n    . \"github.com/onsi/ginkgo/v2\"\n    . \"github.com/onsi/gomega\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n    \"k8s.io/client-go/kubernetes/scheme\"\n    \"sigs.k8s.io/controller-runtime/pkg/envtest\"\n\n    runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n    clientset \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n)\n\nvar (\n    envTest  *envtest.Environment\n    k8sClient clientset.Interface\n)\n\nvar _ = BeforeSuite(func() {\n    err := runtimev1alpha1.AddToScheme(scheme.Scheme)\n    Expect(err).NotTo(HaveOccurred())\n\n    envTest = &envtest.Environment{\n        CRDDirectoryPaths: []string{\"../../../manifests/charts/base/crds\"},\n    }\n\n    cfg, err := envTest.Start()\n    Expect(err).NotTo(HaveOccurred())\n\n    k8sClient, err = clientset.NewForConfig(cfg)\n    Expect(err).NotTo(HaveOccurred())\n})\n\nvar _ = AfterSuite(func() {\n    err := envTest.Stop()\n    Expect(err).NotTo(HaveOccurred())\n})\n\nvar _ = Describe(\"AgentRuntime Integration\", func() {\n    Context(\"CRUD operations\", func() {\n        It(\"should create, get, update, and delete AgentRuntime\", func(ctx SpecContext) {\n            namespace := \"default\"\n\n            // Create\n            agentRuntime := &runtimev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"integration-test\",\n                    Namespace: namespace,\n                },\n                Spec: runtimev1alpha1.AgentRuntimeSpec{\n                    MaxSessionDuration: \"8h\",\n                    SessionTimeout:     \"15m\",\n                    TargetPort: []runtimev1alpha1.TargetPort{\n                        {Port: 8080, Protocol: \"HTTP\"},\n                    },\n                },\n            }\n\n            created, err := k8sClient.RuntimeV1alpha1().AgentRuntimes(namespace).Create(ctx, agentRuntime, metav1.CreateOptions{})\n            Expect(err).NotTo(HaveOccurred())\n            Expect(created.Name).To(Equal(\"integration-test\"))\n\n            // Get\n            fetched, err := k8sClient.RuntimeV1alpha1().AgentRuntimes(namespace).Get(ctx, \"integration-test\", metav1.GetOptions{})\n            Expect(err).NotTo(HaveOccurred())\n            Expect(fetched.Spec.MaxSessionDuration).To(Equal(\"8h\"))\n\n            // Update\n            fetched.Spec.MaxSessionDuration = \"12h\"\n            updated, err := k8sClient.RuntimeV1alpha1().AgentRuntimes(namespace).Update(ctx, fetched, metav1.UpdateOptions{})\n            Expect(err).NotTo(HaveOccurred())\n            Expect(updated.Spec.MaxSessionDuration).To(Equal(\"12h\"))\n\n            // Delete\n            err = k8sClient.RuntimeV1alpha1().AgentRuntimes(namespace).Delete(ctx, \"integration-test\", metav1.DeleteOptions{})\n            Expect(err).NotTo(HaveOccurred())\n\n            // Verify deletion\n            _, err = k8sClient.RuntimeV1alpha1().AgentRuntimes(namespace).Get(ctx, \"integration-test\", metav1.GetOptions{})\n            Expect(err).To(HaveOccurred())\n        }, SpecTimeout(30*time.Second))\n    })\n\n    Context(\"Watch operations\", func() {\n        It(\"should watch AgentRuntime changes\", func(ctx SpecContext) {\n            namespace := \"default\"\n\n            watcher, err := k8sClient.RuntimeV1alpha1().AgentRuntimes(namespace).Watch(ctx, metav1.ListOptions{})\n            Expect(err).NotTo(HaveOccurred())\n            defer watcher.Stop()\n\n            agentRuntime := &runtimev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"watch-test\",\n                    Namespace: namespace,\n                },\n                Spec: runtimev1alpha1.AgentRuntimeSpec{\n                    MaxSessionDuration: \"8h\",\n                },\n            }\n\n            _, err = k8sClient.RuntimeV1alpha1().AgentRuntimes(namespace).Create(ctx, agentRuntime, metav1.CreateOptions{})\n            Expect(err).NotTo(HaveOccurred())\n\n            event := <-watcher.ResultChan()\n            Expect(event.Type).To(Equal(watch.Added))\n\n            fetched := event.Object.(*runtimev1alpha1.AgentRuntime)\n            Expect(fetched.Name).To(Equal(\"watch-test\"))\n        }, SpecTimeout(30*time.Second))\n    })\n})\n```\n\n## Code Generation\n\n### Code Generation Script\n\n**File**: `hack/update-codegen.sh`\n\n```bash\n#!/bin/bash\nset -o errexit\nset -o nounset\nset -o pipefail\n\nSCRIPT_ROOT=$(dirname \"${BASH_SOURCE[0]}\")/..\nCODEGEN_PKG=${CODEGEN_PKG:-$(cd \"${SCRIPT_ROOT}\"; go list -m -f '{{.Dir}}' k8s.io/code-generator)}\n\ngo run \"${CODEGEN_PKG}\"/cmd/client-gen/main.go \\\n  --input-base=\"github.com/volcano-sh/agentcube/pkg/apis\" \\\n  --input=\"runtime/v1alpha1\" \\\n  --clientset-path=\"github.com/volcano-sh/agentcube/client-go/clientset\" \\\n  --output-package=\"github.com/volcano-sh/agentcube/client-go/clientset\" \\\n  --output-base=\"${SCRIPT_ROOT}\"\n\ngo run \"${CODEGEN_PKG}\"/cmd/informer-gen/main.go \\\n  --input-dirs=\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\" \\\n  --versioned-clientset-package=\"github.com/volcano-sh/agentcube/client-go/clientset/versioned\" \\\n  --listers-package=\"github.com/volcano-sh/agentcube/client-go/listers\" \\\n  --output-package=\"github.com/volcano-sh/agentcube/client-go/informers\" \\\n  --output-base=\"${SCRIPT_ROOT}\" \\\n  --go-header-file=\"${SCRIPT_ROOT}/hack/boilerplate.go.txt\"\n\ngo run \"${CODEGEN_PKG}\"/cmd/lister-gen/main.go \\\n  --input-dirs=\"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\" \\\n  --output-package=\"github.com/volcano-sh/agentcube/client-go/listers\" \\\n  --output-base=\"${SCRIPT_ROOT}\" \\\n  --go-header-file=\"${SCRIPT_ROOT}/hack/boilerplate.go.txt\"\n```\n\n### Makefile Targets\n\n**File**: `Makefile`\n\n```makefile\n# Code generation\n.PHONY: gen-client\ngen-client:\n\t@echo \"Generating client-go code...\"\n\t@bash hack/update-codegen.sh\n\t@go mod tidy\n\n.PHONY: gen-client-verify\ngen-client-verify:\n\t@echo \"Verifying client-go code is up-to-date...\"\n\t@bash hack/verify-codegen.sh\n```\n\n### Generated Code Structure\n\n| Directory | Purpose | Generator |\n|-----------|---------|-----------|\n| `clientset/versioned/` | ClientSet and typed clients | client-gen |\n| `informers/externalversions/` | Informers for event watching | informer-gen |\n| `listers/runtime/v1alpha1/` | Listers for read-only access | lister-gen |\n\n## Integration Points\n\n### With Controller Manager\n\nThe Controller Manager uses the generated client-go to:\n1. Watch AgentRuntime and CodeInterpreter CRDs for changes\n2. Reconcile resources based on spec changes\n3. Update status subresource with observed state\n4. Handle finalizers and cleanup\n\n```go\n// Example usage in controller\nimport (\n    clientset \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n    runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\ntype AgentRuntimeReconciler struct {\n    client clientset.Interface\n    informer cache.SharedIndexInformer\n}\n\nfunc (r *AgentRuntimeReconciler) Reconcile(ctx context.Context, key string) error {\n    namespace, name, err := cache.SplitMetaNamespaceKey(key)\n    if err != nil {\n        return err\n    }\n\n    agentRuntime, err := r.client.RuntimeV1alpha1().AgentRuntimes(namespace).Get(ctx, name, metav1.GetOptions{})\n    if errors.IsNotFound(err) {\n        // Resource deleted\n        return nil\n    }\n    if err != nil {\n        return err\n    }\n\n    // Reconcile logic...\n\n    // Update status\n    agentRuntime.Status.ObservedGeneration = agentRuntime.Generation\n    _, err = r.client.RuntimeV1alpha1().AgentRuntimes(namespace).UpdateStatus(ctx, agentRuntime, metav1.UpdateOptions{})\n    return err\n}\n```\n\n### With Workload Manager\n\nThe Workload Manager uses the generated client-go to:\n1. Create and manage AgentRuntime resources\n2. Query AgentRuntime status and configuration\n3. Watch for AgentRuntime changes to trigger actions\n\n```go\n// Example usage in Workload Manager\nimport (\n    clientset \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n)\n\ntype WorkloadManager struct {\n    client clientset.Interface\n}\n\nfunc (w *WorkloadManager) CreateAgentRuntime(ctx context.Context, spec AgentRuntimeSpec) (*runtimev1alpha1.AgentRuntime, error) {\n    agentRuntime := &runtimev1alpha1.AgentRuntime{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      generateName(),\n            Namespace: w.namespace,\n        },\n        Spec: spec,\n    }\n    return w.client.RuntimeV1alpha1().AgentRuntimes(w.namespace).Create(ctx, agentRuntime, metav1.CreateOptions{})\n}\n```\n\n## Dependencies\n\n### Go Dependencies\n\n**File**: `go.mod`\n\n```go\nmodule github.com/volcano-sh/agentcube/client-go\n\ngo 1.21\n\nrequire (\n    k8s.io/api v0.28.0\n    k8s.io/apimachinery v0.28.0\n    k8s.io/client-go v0.28.0\n)\n```\n\n### Build Tools\n\n| Tool | Version | Purpose |\n|------|---------|---------|\n| `k8s.io/code-generator` | v0.28.0 | Generate client-go code |\n| `go` | 1.21+ | Build and test |\n\n## Documentation\n\n### Package Documentation\n\n**File**: `README.md`\n\n```markdown\n# AgentCube client-go\n\nType-safe Kubernetes client library for AgentCube custom resources.\n\n## Installation\n\n```bash\ngo get github.com/volcano-sh/agentcube/client-go\n```\n\n## Usage\n\n### Create ClientSet\n\n```go\nimport (\n    \"k8s.io/client-go/tools/clientcmd\"\n    clientset \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n)\n\nconfig, err := clientcmd.BuildConfigFromFlags(\"\", kubeconfig)\nif err != nil {\n    panic(err)\n}\n\nclient, err := clientset.NewForConfig(config)\nif err != nil {\n    panic(err)\n}\n```\n\n### Create AgentRuntime\n\n```go\nagentRuntime := &runtimev1alpha1.AgentRuntime{\n    ObjectMeta: metav1.ObjectMeta{\n        Name:      \"my-agent\",\n        Namespace: \"default\",\n    },\n    Spec: runtimev1alpha1.AgentRuntimeSpec{\n        MaxSessionDuration: \"8h\",\n        SessionTimeout:     \"15m\",\n        TargetPort: []runtimev1alpha1.TargetPort{\n            {Port: 8080, Protocol: \"HTTP\"},\n        },\n    },\n}\n\ncreated, err := client.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(ctx, agentRuntime, metav1.CreateOptions{})\nif err != nil {\n    panic(err)\n}\n```\n\n### Use Informers\n\n```go\nfactory := informers.NewSharedInformerFactory(client, time.Minute)\ninformer := factory.Runtime().V1alpha1().AgentRuntimes().Informer()\n\ninformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n    AddFunc: func(obj interface{}) {\n        agentRuntime := obj.(*runtimev1alpha1.AgentRuntime)\n        fmt.Printf(\"AgentRuntime %s added\\n\", agentRuntime.Name)\n    },\n    UpdateFunc: func(oldObj, newObj interface{}) {\n        oldRuntime := oldObj.(*runtimev1alpha1.AgentRuntime)\n        newRuntime := newObj.(*runtimev1alpha1.AgentRuntime)\n        if oldRuntime.ResourceVersion != newRuntime.ResourceVersion {\n            fmt.Printf(\"AgentRuntime %s updated\\n\", newRuntime.Name)\n        }\n    },\n    DeleteFunc: func(obj interface{}) {\n        agentRuntime := obj.(*runtimev1alpha1.AgentRuntime)\n        fmt.Printf(\"AgentRuntime %s deleted\\n\", agentRuntime.Name)\n    },\n})\n\nstopCh := make(chan struct{})\ndefer close(stopCh)\n\nfactory.Start(stopCh)\nfactory.WaitForCacheSync(stopCh)\n\n<-stopCh\n```\n\n## API Reference\n\nSee [pkg/apis](../pkg/apis) for type definitions.\n\n## License\n\nApache 2.0\n```\n\n## Version Migration Strategy\n\n### v1alpha1 → v1beta1 Migration\n\n1. Create new version package: `pkg/apis/runtime/v1beta1/`\n2. Implement conversion functions:\n   ```go\n   func (src *v1alpha1.AgentRuntime) ConvertTo(dstRaw conversion.Hub) error {\n       dst := dstRaw.(*v1beta1.AgentRuntime)\n       // Conversion logic\n       return nil\n   }\n   ```\n3. Update CRD to serve both versions\n4. Set v1beta1 as storage version\n5. Regenerate client-go for both versions\n6. Update clients to use v1beta1\n7. Deprecate v1alpha1\n\n## Security Considerations\n\n1. **Authentication**: Support kubeconfig, ServiceAccount tokens, TLS certificates\n2. **Authorization**: Follow Kubernetes RBAC model\n3. **Transport Security**: Use HTTPS with proper TLS verification\n4. **Secrets**: Never log sensitive data in status or spec\n5. **Input Validation**: Rely on CRD OpenAPIV3Schema validation\n\n## Performance Considerations\n\n1. **Caching**: Use Informers for local caching to reduce API load\n2. **Watch**: Use Watch instead of polling for real-time updates\n3. **Listers**: Use Listers for read-only access from cache\n4. **Resync**: Configure appropriate resync intervals (default 10 minutes)\n5. **Batches**: Use List operations instead of individual Get when possible\n6. **Rate Limiting**: Client-go includes built-in rate limiting\n\n## Success Criteria\n\n- All CRUD operations work correctly for AgentRuntime and CodeInterpreter\n- Informers properly emit events for all resource changes\n- Listers provide efficient read-only access\n- Unit tests achieve 80%+ coverage\n- Integration tests pass with real Kubernetes API server\n- Code generation is reproducible and automated\n- Documentation is complete and examples work","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-035/design.md"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-035/design.md","exists":false,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-035/design.md","time":{"start":1775887413104,"end":1775887413115}}}}
