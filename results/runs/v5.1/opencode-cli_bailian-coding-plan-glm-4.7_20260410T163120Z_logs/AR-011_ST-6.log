loadManagerGetSessionResponse struct {\n52: \tSessionID    string                    `json:\"sessionId\"`\n53: \tSandboxID    string                    `json:\"sandboxId\"`\n54: \tSandboxName  string                    `json:\"sandboxName\"`\n55: \tKind         string                    `json:\"kind\"`\n56: \tNamespace    string                    `json:\"namespace\"`\n57: \tName         string                    `json:\"name\"`\n58: \tEntryPoints  []types.SandboxEntryPoint `json:\"entryPoints\"`\n59: \tLastActivity string                    `json:\"lastActivity\"`\n60: \tCreatedAt    string                    `json:\"createdAt\"`\n61: \tExpiresAt    string                    `json:\"expiresAt\"`\n62: \tPodIP        string                    `json:\"podIp,omitempty\"`\n63: }\n64: \n65: func SandboxInfoFromWorkloadManager(resp *WorkloadManagerGetSessionResponse, sessionID string) *types.SandboxInfo {\n66: \tcreatedAt, _ := time.Parse(time.RFC3339, resp.CreatedAt)\n67: \texpiresAt, _ := time.Parse(time.RFC3339, resp.ExpiresAt)\n68: \tlastActivity, _ := time.Parse(time.RFC3339, resp.LastActivity)\n69: \n70: \treturn &types.SandboxInfo{\n71: \t\tKind:             resp.Kind,\n72: \t\tSandboxID:        resp.SandboxID,\n73: \t\tSandboxName:      resp.SandboxName,\n74: \t\tSandboxNamespace: resp.Namespace,\n75: \t\tName:             resp.Name,\n76: \t\tEntryPoints:      resp.EntryPoints,\n77: \t\tSessionID:        sessionID,\n78: \t\tCreatedAt:        createdAt,\n79: \t\tExpiresAt:        expiresAt,\n80: \t\tStatus:           \"Ready\",\n81: \t\tPodIP:            resp.PodIP,\n82: \t\tNamespace:        resp.Namespace,\n83: \t\tLastActivityAt:   lastActivity,\n84: \t}\n85: }\n86: \n87: type CreateSessionResponse struct {\n88: \tSessionID   string                    `json:\"sessionId\"`\n89: \tSandboxID   string                    `json:\"sandboxId\"`\n90: \tSandboxName string                    `json:\"sandboxName\"`\n91: \tToken       string                    `json:\"token\"`\n92: \tEntryPoints []types.SandboxEntryPoint `json:\"entryPoints\"`\n93: }\n94: \n95: func NewErrorResponse(errorMsg string, code string) *ErrorResponse {\n96: \treturn &ErrorResponse{\n97: \t\tError: errorMsg,\n98: \t\tCode:  code,\n99: \t}\n100: }\n\n(End of file - total 100 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype JWTClaims struct {\n\tSessionID string `json:\"session_id\"`\n\tjwt.RegisteredClaims\n}\n\ntype ErrorResponse struct {\n\tError string `json:\"error\"`\n\tCode  string `json:\"code,omitempty\"`\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/types.go","time":{"start":1775852432388,"end":1775852432424}}}}
{"type":"tool_use","timestamp":1775852432427,"sessionID":"ses_286f27b45ffeMq6hIQGqkgco09","part":{"id":"prt_d790da80b0017PEtHAmuT8AHzF","messageID":"msg_d790d9945001JX6J5XVFkGixuR","sessionID":"ses_286f27b45ffeMq6hIQGqkgco09","type":"tool","tool":"read","callID":"toolu_tool-f39a51a9a816417d80a329907b9618e0","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/x509\"\n6: \t\"encoding/json\"\n7: \t\"encoding/pem\"\n8: \t\"fmt\"\n9: \t\"strings\"\n10: \t\"testing\"\n11: \t\"time\"\n12: \n13: \t\"github.com/golang-jwt/jwt/v5\"\n14: \tcorev1 \"k8s.io/api/core/v1\"\n15: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n16: \t\"k8s.io/client-go/kubernetes\"\n17: \t\"k8s.io/client-go/kubernetes/fake\"\n18: )\n19: \n20: func TestNewJWTManager(t *testing.T) {\n21: \ttests := []struct {\n22: \t\tname        string\n23: \t\tclientset   kubernetes.Interface\n24: \t\tnamespace   string\n25: \t\texpectError bool\n26: \t}{\n27: \t\t{\n28: \t\t\tname:        \"nil clientset\",\n29: \t\t\tclientset:   nil,\n30: \t\t\tnamespace:   \"test\",\n31: \t\t\texpectError: true,\n32: \t\t},\n33: \t\t{\n34: \t\t\tname:        \"valid clientset with explicit namespace\",\n35: \t\t\tclientset:   fake.NewSimpleClientset(),\n36: \t\t\tnamespace:   \"test-namespace\",\n37: \t\t\texpectError: false,\n38: \t\t},\n39: \t\t{\n40: \t\t\tname:        \"valid clientset with default namespace\",\n41: \t\t\tclientset:   fake.NewSimpleClientset(),\n42: \t\t\tnamespace:   \"\",\n43: \t\t\texpectError: false,\n44: \t\t},\n45: \t}\n46: \n47: \tfor _, tt := range tests {\n48: \t\tt.Run(tt.name, func(t *testing.T) {\n49: \t\t\tmanager, err := NewJWTManager(tt.clientset, tt.namespace)\n50: \n51: \t\t\tif tt.expectError {\n52: \t\t\t\tif err == nil {\n53: \t\t\t\t\tt.Errorf(\"Expected error but got nil\")\n54: \t\t\t\t}\n55: \t\t\t\treturn\n56: \t\t\t}\n57: \n58: \t\t\tif err != nil {\n59: \t\t\t\tt.Errorf(\"Unexpected error: %v\", err)\n60: \t\t\t\treturn\n61: \t\t\t}\n62: \n63: \t\t\tif manager == nil {\n64: \t\t\t\tt.Errorf(\"Expected manager to be non-nil\")\n65: \t\t\t\treturn\n66: \t\t\t}\n67: \n68: \t\t\tif manager.privateKey == nil {\n69: \t\t\t\tt.Errorf(\"Expected private key to be initialized\")\n70: \t\t\t}\n71: \n72: \t\t\tif manager.publicKey == nil {\n73: \t\t\t\tt.Errorf(\"Expected public key to be initialized\")\n74: \t\t\t}\n75: \n76: \t\t\tif tt.namespace == \"\" && manager.namespace != defaultNamespace {\n77: \t\t\t\tt.Errorf(\"Expected default namespace %s, got %s\", defaultNamespace, manager.namespace)\n78: \t\t\t}\n79: \n80: \t\t\tif tt.namespace != \"\" && manager.namespace != tt.namespace {\n81: \t\t\t\tt.Errorf(\"Expected namespace %s, got %s\", tt.namespace, manager.namespace)\n82: \t\t\t}\n83: \t\t})\n84: \t}\n85: }\n86: \n87: func TestNewJWTManagerWithExistingSecret(t *testing.T) {\n88: \tprivateKey, publicKey, err := generateRSAKeyPair()\n89: \tif err != nil {\n90: \t\tt.Fatalf(\"Failed to generate RSA key pair: %v\", err)\n91: \t}\n92: \n93: \tprivateKeyPEM := pem.EncodeToMemory(&pem.Block{\n94: \t\tType:  privateKeyPEMType,\n95: \t\tBytes: x509.MarshalPKCS1PrivateKey(privateKey),\n96: \t})\n97: \n98: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n99: \tif err != nil {\n100: \t\tt.Fatalf(\"Failed to marshal public key: %v\", err)\n101: \t}\n102: \n103: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n104: \t\tType:  publicKeyPEMType,\n105: \t\tBytes: publicKeyBytes,\n106: \t})\n107: \n108: \tsecret := &corev1.Secret{\n109: \t\tObjectMeta: metav1.ObjectMeta{\n110: \t\t\tName:      jwtSecretName,\n111: \t\t\tNamespace: \"test-namespace\",\n112: \t\t},\n113: \t\tData: map[string][]byte{\n114: \t\t\t\"private.pem\": privateKeyPEM,\n115: \t\t\t\"public.pem\":  publicKeyPEM,\n116: \t\t},\n117: \t}\n118: \n119: \tclientset := fake.NewSimpleClientset(secret)\n120: \n121: \tmanager, err := NewJWTManager(clientset, \"test-namespace\")\n122: \tif err != nil {\n123: \t\tt.Fatalf(\"Unexpected error: %v\", err)\n124: \t}\n125: \n126: \tif manager == nil {\n127: \t\tt.Fatalf(\"Expected manager to be non-nil\")\n128: \t}\n129: \n130: \ttestSessionID := \"test-session-id\"\n131: \ttoken, err := manager.GenerateToken(testSessionID)\n132: \tif err != nil {\n133: \t\tt.Fatalf(\"Failed to generate token: %v\", err)\n134: \t}\n135: \n136: \tclaims, err := manager.ValidateToken(token)\n137: \tif err != nil {\n138: \t\tt.Fatalf(\"Failed to validate token: %v\", err)\n139: \t}\n140: \n141: \tif claims.SessionID != testSessionID {\n142: \t\tt.Errorf(\"Expected session ID %s, got %s\", testSessionID, claims.SessionID)\n143: \t}\n144: }\n145: \n146: func TestGenerateToken(t *testing.T) {\n147: \ttests := []struct {\n148: \t\tname        string\n149: \t\tsessionID   string\n150: \t\texpectError bool\n151: \t}{\n152: \t\t{\n153: \t\t\tname:        \"valid session ID\",\n154: \t\t\tsessionID:   \"test-session-123\",\n155: \t\t\texpectError: false,\n156: \t\t},\n157: \t\t{\n158: \t\t\tname:        \"empty session ID\",\n159: \t\t\tsessionID:   \"\",\n160: \t\t\texpectError: false,\n161: \t\t},\n162: \t\t{\n163: \t\t\tname:        \"long session ID\",\n164: \t\t\tsessionID:   \"very-long-session-id-with-lots-of-characters-1234567890\",\n165: \t\t\texpectError: false,\n166: \t\t},\n167: \t}\n168: \n169: \tfor _, tt := range tests {\n170: \t\tt.Run(tt.name, func(t *testing.T) {\n171: \t\t\tmanager, err := NewJWTManager(fake.NewSimpleClientset(), \"test\")\n172: \t\t\tif err != nil {\n173: \t\t\t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n174: \t\t\t}\n175: \n176: \t\t\ttoken, err := manager.GenerateToken(tt.sessionID)\n177: \n178: \t\t\tif tt.expectError {\n179: \t\t\t\tif err == nil {\n180: \t\t\t\t\tt.Errorf(\"Expected error but got nil\")\n181: \t\t\t\t}\n182: \t\t\t\treturn\n183: \t\t\t}\n184: \n185: \t\t\tif err != nil {\n186: \t\t\t\tt.Errorf(\"Unexpected error: %v\", err)\n187: \t\t\t\treturn\n188: \t\t\t}\n189: \n190: \t\t\tif token == \"\" {\n191: \t\t\t\tt.Errorf(\"Expected token to be non-empty\")\n192: \t\t\t\treturn\n193: \t\t\t}\n194: \t\t})\n195: \t}\n196: }\n197: \n198: func TestGenerateTokenWithoutPrivateKey(t *testing.T) {\n199: \tmanager := &JWTManager{}\n200: \n201: \t_, err := manager.GenerateToken(\"test-session\")\n202: \tif err == nil {\n203: \t\tt.Errorf(\"Expected error when private key is not initialized\")\n204: \t}\n205: }\n206: \n207: func TestValidateToken(t *testing.T) {\n208: \tmanager, err := NewJWTManager(fake.NewSimpleClientset(), \"test\")\n209: \tif err != nil {\n210: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n211: \t}\n212: \n213: \tsessionID := \"test-session-123\"\n214: \ttoken, err := manager.GenerateToken(sessionID)\n215: \tif err != nil {\n216: \t\tt.Fatalf(\"Failed to generate token: %v\", err)\n217: \t}\n218: \n219: \tclaims, err := manager.ValidateToken(token)\n220: \tif err != nil {\n221: \t\tt.Fatalf(\"Failed to validate token: %v\", err)\n222: \t}\n223: \n224: \tif claims == nil {\n225: \t\tt.Fatalf(\"Expected claims to be non-nil\")\n226: \t}\n227: \n228: \tif claims.SessionID != sessionID {\n229: \t\tt.Errorf(\"Expected session ID %s, got %s\", sessionID, claims.SessionID)\n230: \t}\n231: \n232: \tnow := time.Now()\n233: \tif claims.IssuedAt == nil {\n234: \t\tt.Errorf(\"Expected IssuedAt to be set\")\n235: \t} else if now.Sub(claims.IssuedAt.Time) > time.Minute {\n236: \t\tt.Errorf(\"Expected IssuedAt to be recent\")\n237: \t}\n238: \n239: \tif claims.ExpiresAt == nil {\n240: \t\tt.Errorf(\"Expected ExpiresAt to be set\")\n241: \t} else if claims.ExpiresAt.Time.Sub(claims.IssuedAt.Time) != jwtTokenExpiration {\n242: \t\tt.Errorf(\"Expected ExpiresAt to be %v after IssuedAt, got %v\", jwtTokenExpiration, claims.ExpiresAt.Time.Sub(claims.IssuedAt.Time))\n243: \t}\n244: \n245: \tif claims.NotBefore == nil {\n246: \t\tt.Errorf(\"Expected NotBefore to be set\")\n247: \t}\n248: }\n249: \n250: func TestValidateTokenWithoutPublicKey(t *testing.T) {\n251: \tmanager := &JWTManager{}\n252: \n253: \t_, err := manager.ValidateToken(\"some-token\")\n254: \tif err == nil {\n255: \t\tt.Errorf(\"Expected error when public key is not initialized\")\n256: \t}\n257: }\n258: \n259: func TestValidateExpiredToken(t *testing.T) {\n260: \tprivateKey, _, err := generateRSAKeyPair()\n261: \tif err != nil {\n262: \t\tt.Fatalf(\"Failed to generate RSA key pair: %v\", err)\n263: \t}\n264: \n265: \tmanager := &JWTManager{\n266: \t\tprivateKey: privateKey,\n267: \t\tpublicKey:  &privateKey.PublicKey,\n268: \t}\n269: \n270: \tsessionID := \"test-session-123\"\n271: \tnow := time.Now()\n272: \tclaims := &JWTClaims{\n273: \t\tSessionID: sessionID,\n274: \t\tRegisteredClaims: jwt.RegisteredClaims{\n275: \t\t\tIssuedAt:  jwt.NewNumericDate(now.Add(-10 * time.Minute)),\n276: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(-5 * time.Minute)),\n277: \t\t\tNotBefore: jwt.NewNumericDate(now.Add(-10 * time.Minute)),\n278: \t\t},\n279: \t}\n280: \n281: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n282: \ttokenString, err := token.SignedString(privateKey)\n283: \tif err != nil {\n284: \t\tt.Fatalf(\"Failed to sign token: %v\", err)\n285: \t}\n286: \n287: \t_, err = manager.ValidateToken(tokenString)\n288: \tif err == nil {\n289: \t\tt.Errorf(\"Expected error for expired token\")\n290: \t}\n291: \n292: \tif err != nil && !containsString(err.Error(), \"expired\") {\n293: \t\tt.Errorf(\"Expected error message to contain 'expired', got: %v\", err)\n294: \t}\n295: }\n296: \n297: func TestValidateInvalidSignature(t *testing.T) {\n298: \tprivateKey1, _, err := generateRSAKeyPair()\n299: \tif err != nil {\n300: \t\tt.Fatalf(\"Failed to generate RSA key pair: %v\", err)\n301: \t}\n302: \n303: \tprivateKey2, _, err := generateRSAKeyPair()\n304: \tif err != nil {\n305: \t\tt.Fatalf(\"Failed to generate second RSA key pair: %v\", err)\n306: \t}\n307: \n308: \tsessionID := \"test-session-123\"\n309: \tnow := time.Now()\n310: \tclaims := &JWTClaims{\n311: \t\tSessionID: sessionID,\n312: \t\tRegisteredClaims: jwt.RegisteredClaims{\n313: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n314: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(jwtTokenExpiration)),\n315: \t\t\tNotBefore: jwt.NewNumericDate(now),\n316: \t\t},\n317: \t}\n318: \n319: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n320: \ttokenString, err := token.SignedString(privateKey1)\n321: \tif err != nil {\n322: \t\tt.Fatalf(\"Failed to sign token: %v\", err)\n323: \t}\n324: \n325: \tmanager := &JWTManager{\n326: \t\tprivateKey: privateKey2,\n327: \t\tpublicKey:  &privateKey2.PublicKey,\n328: \t}\n329: \n330: \t_, err = manager.ValidateToken(tokenString)\n331: \tif err == nil {\n332: \t\tt.Errorf(\"Expected error for invalid signature\")\n333: \t}\n334: }\n335: \n336: func TestValidateMalformedToken(t *testing.T) {\n337: \tmanager, err := NewJWTManager(fake.NewSimpleClientset(), \"test\")\n338: \tif err != nil {\n339: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n340: \t}\n341: \n342: \tinvalidTokens := []string{\n343: \t\t\"\",\n344: \t\t\"invalid\",\n345: \t\t\"not.a.jwt.token\",\n346: \t\t\"invalid-header.payload\",\n347: \t}\n348: \n349: \tfor _, invalidToken := range invalidTokens {\n350: \t\t_, err := manager.ValidateToken(invalidToken)\n351: \t\tif err == nil {\n352: \t\t\tt.Errorf(\"Expected error for invalid token: %s\", invalidToken)\n353: \t\t}\n354: \t}\n355: }\n356: \n357: func TestValidateNotBeforeToken(t *testing.T) {\n358: \tprivateKey, _, err := generateRSAKeyPair()\n359: \tif err != nil {\n360: \t\tt.Fatalf(\"Failed to generate RSA key pair: %v\", err)\n361: \t}\n362: \n363: \tmanager := &JWTManager{\n364: \t\tprivateKey: privateKey,\n365: \t\tpublicKey:  &privateKey.PublicKey,\n366: \t}\n367: \n368: \tsessionID := \"test-session-123\"\n369: \tnow := time.Now()\n370: \tclaims := &JWTClaims{\n371: \t\tSessionID: sessionID,\n372: \t\tRegisteredClaims: jwt.RegisteredClaims{\n373: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n374: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(jwtTokenExpiration)),\n375: \t\t\tNotBefore: jwt.NewNumericDate(now.Add(5 * time.Minute)),\n376: \t\t},\n377: \t}\n378: \n379: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n380: \ttokenString, err := token.SignedString(privateKey)\n381: \tif err != nil {\n382: \t\tt.Fatalf(\"Failed to sign token: %v\", err)\n383: \t}\n384: \n385: \t_, err = manager.ValidateToken(tokenString)\n386: \tif err == nil {\n387: \t\tt.Errorf(\"Expected error for token not yet valid\")\n388: \t}\n389: }\n390: \n391: func TestGenerateRSAKeyPair(t *testing.T) {\n392: \tprivateKey, publicKey, err := generateRSAKeyPair()\n393: \tif err != nil {\n394: \t\tt.Fatalf(\"Failed to generate RSA key pair: %v\", err)\n395: \t}\n396: \n397: \tif privateKey == nil {\n398: \t\tt.Errorf(\"Expected private key to be non-nil\")\n399: \t}\n400: \n401: \tif publicKey == nil {\n402: \t\tt.Errorf(\"Expected public key to be non-nil\")\n403: \t}\n404: \n405: \tif privateKey.N.BitLen() != 2048 {\n406: \t\tt.Errorf(\"Expected RSA key size of 2048 bits, got %d\", privateKey.N.BitLen())\n407: \t}\n408: \n409: \tif publicKey.N.BitLen() != 2048 {\n410: \t\tt.Errorf(\"Expected RSA public key size of 2048 bits, got %d\", publicKey.N.BitLen())\n411: \t}\n412: }\n413: \n414: func TestParsePrivateKeyPEM(t *testing.T) {\n415: \tprivateKey, _, err := generateRSAKeyPair()\n416: \tif err != nil {\n417: \t\tt.Fatalf(\"Failed to generate RSA key pair: %v\", err)\n418: \t}\n419: \n420: \tprivateKeyPEM := pem.EncodeToMemory(&pem.Block{\n421: \t\tType:  privateKeyPEMType,\n422: \t\tBytes: x509.MarshalPKCS1PrivateKey(privateKey),\n423: \t})\n424: \n425: \tparsedKey, err := parsePrivateKeyPEM(privateKeyPEM)\n426: \tif err != nil {\n427: \t\tt.Fatalf(\"Failed to parse private key PEM: %v\", err)\n428: \t}\n429: \n430: \tif parsedKey == nil {\n431: \t\tt.Errorf(\"Expected parsed key to be non-nil\")\n432: \t}\n433: }\n434: \n435: func TestParseInvalidPrivateKeyPEM(t *testing.T) {\n436: \tinvalidPEMs := [][]byte{\n437: \t\t[]byte(\"invalid pem data\"),\n438: \t\t[]byte(\"-----BEGIN INVALID-----\\n-----END INVALID-----\"),\n439: \t\t[]byte(\"-----BEGIN PUBLIC KEY-----\\n-----END PUBLIC KEY-----\"),\n440: \t}\n441: \n442: \tfor _, invalidPEM := range invalidPEMs {\n443: \t\t_, err := parsePrivateKeyPEM(invalidPEM)\n444: \t\tif err == nil {\n445: \t\t\tt.Errorf(\"Expected error for invalid PEM: %s\", string(invalidPEM))\n446: \t\t}\n447: \t}\n448: }\n449: \n450: func TestParsePublicKeyPEM(t *testing.T) {\n451: \t_, publicKey, err := generateRSAKeyPair()\n452: \tif err != nil {\n453: \t\tt.Fatalf(\"Failed to generate RSA key pair: %v\", err)\n454: \t}\n455: \n456: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n457: \tif err != nil {\n458: \t\tt.Fatalf(\"Failed to marshal public key: %v\", err)\n459: \t}\n460: \n461: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n462: \t\tType:  publicKeyPEMType,\n463: \t\tBytes: publicKeyBytes,\n464: \t})\n465: \n466: \tparsedKey, err := parsePublicKeyPEM(publicKeyPEM)\n467: \tif err != nil {\n468: \t\tt.Fatalf(\"Failed to parse public key PEM: %v\", err)\n469: \t}\n470: \n471: \tif parsedKey == nil {\n472: \t\tt.Errorf(\"Expected parsed key to be non-nil\")\n473: \t}\n474: }\n475: \n476: func TestParseInvalidPublicKeyPEM(t *testing.T) {\n477: \tinvalidPEMs := [][]byte{\n478: \t\t[]byte(\"invalid pem data\"),\n479: \t\t[]byte(\"-----BEGIN INVALID-----\\n-----END INVALID-----\"),\n480: \t\t[]byte(\"-----BEGIN RSA PRIVATE KEY-----\\n-----END RSA PRIVATE KEY-----\"),\n481: \t}\n482: \n483: \tfor _, invalidPEM := range invalidPEMs {\n484: \t\t_, err := parsePublicKeyPEM(invalidPEM)\n485: \t\tif err == nil {\n486: \t\t\tt.Errorf(\"Expected error for invalid PEM: %s\", string(invalidPEM))\n487: \t\t}\n488: \t}\n489: }\n490: \n491: func TestLoadKeysFromSecret(t *testing.T) {\n492: \tprivateKey, publicKey, err := generateRSAKeyPair()\n493: \tif err != nil {\n494: \t\tt.Fatalf(\"Failed to generate RSA key pair: %v\", err)\n495: \t}\n496: \n497: \tprivateKeyPEM := pem.EncodeToMemory(&pem.Block{\n498: \t\tType:  privateKeyPEMType,\n499: \t\tBytes: x509.MarshalPKCS1PrivateKey(privateKey),\n500: \t})\n501: \n502: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n503: \tif err != nil {\n504: \t\tt.Fatalf(\"Failed to marshal public key: %v\", err)\n505: \t}\n506: \n507: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n508: \t\tType:  publicKeyPEMType,\n509: \t\tBytes: publicKeyBytes,\n510: \t})\n511: \n512: \tsecret := &corev1.Secret{\n513: \t\tData: map[string][]byte{\n514: \t\t\t\"private.pem\": privateKeyPEM,\n515: \t\t\t\"public.pem\":  publicKeyPEM,\n516: \t\t},\n517: \t}\n518: \n519: \tmanager := &JWTManager{}\n520: \terr = manager.loadKeysFromSecret(secret)\n521: \tif err != nil {\n522: \t\tt.Fatalf(\"Failed to load keys from secret: %v\", err)\n523: \t}\n524: \n525: \tif manager.privateKey == nil {\n526: \t\tt.Errorf(\"Expected private key to be loaded\")\n527: \t}\n528: \n529: \tif manager.publicKey == nil {\n530: \t\tt.Errorf(\"Expected public key to be loaded\")\n531: \t}\n532: }\n533: \n534: func TestLoadKeysFromSecretMissingFields(t *testing.T) {\n535: \ttests := []struct {\n536: \t\tname           string\n537: \t\tsecret         *corev1.Secret\n538: \t\texpectError    bool\n539: \t\terrorSubstring string\n540: \t}{\n541: \t\t{\n542: \t\t\tname: \"missing private.pem\",\n543: \t\t\tsecret: &corev1.Secret{\n544: \t\t\t\tData: map[string][]byte{\n545: \t\t\t\t\t\"public.pem\": []byte(\"public key\"),\n546: \t\t\t\t},\n547: \t\t\t},\n548: \t\t\texpectError:    true,\n549: \t\t\terrorSubstring: \"private.pem\",\n550: \t\t},\n551: \t\t{\n552: \t\t\tname: \"missing public.pem\",\n553: \t\t\tsecret: &corev1.Secret{\n554: \t\t\t\tData: map[string][]byte{\n555: \t\t\t\t\t\"private.pem\": []byte(\"private key\"),\n556: \t\t\t\t},\n557: \t\t\t},\n558: \t\t\texpectError:    true,\n559: \t\t\terrorSubstring: \"public.pem\",\n560: \t\t},\n561: \t\t{\n562: \t\t\tname: \"missing both\",\n563: \t\t\tsecret: &corev1.Secret{\n564: \t\t\t\tData: map[string][]byte{},\n565: \t\t\t},\n566: \t\t\texpectError:    true,\n567: \t\t\terrorSubstring: \"private.pem\",\n568: \t\t},\n569: \t}\n570: \n571: \tfor _, tt := range tests {\n572: \t\tt.Run(tt.name, func(t *testing.T) {\n573: \t\t\tmanager := &JWTManager{}\n574: \t\t\terr := manager.loadKeysFromSecret(tt.secret)\n575: \n576: \t\t\tif !tt.expectError {\n577: \t\t\t\tif err != nil {\n578: \t\t\t\t\tt.Errorf(\"Unexpected error: %v\", err)\n579: \t\t\t\t}\n580: \t\t\t\treturn\n581: \t\t\t}\n582: \n583: \t\t\tif err == nil {\n584: \t\t\t\tt.Errorf(\"Expected error but got nil\")\n585: \t\t\t}\n586: \n587: \t\t\tif tt.errorSubstring != \"\" && !containsString(err.Error(), tt.errorSubstring) {\n588: \t\t\t\tt.Errorf(\"Expected error to contain '%s', got: %v\", tt.errorSubstring, err)\n589: \t\t\t}\n590: \t\t})\n591: \t}\n592: }\n593: \n594: func TestStoreJWTKeySecret(t *testing.T) {\n595: \tclientset := fake.NewSimpleClientset()\n596: \tnamespace := \"test-namespace\"\n597: \n598: \tmanager := &JWTManager{\n599: \t\tclientset: clientset,\n600: \t\tnamespace: namespace,\n601: \t}\n602: \n603: \terr := manager.storeJWTKeySecret()\n604: \tif err != nil {\n605: \t\tt.Fatalf(\"Failed to store JWT key secret: %v\", err)\n606: \t}\n607: \n608: \tsecret, err := clientset.CoreV1().Secrets(namespace).Get(context.Background(), jwtSecretName, metav1.GetOptions{})\n609: \tif err != nil {\n610: \t\tt.Fatalf(\"Failed to get secret: %v\", err)\n611: \t}\n612: \n613: \tif secret == nil {\n614: \t\tt.Fatalf(\"Expected secret to be created\")\n615: \t}\n616: \n617: \tif _, ok := secret.Data[\"private.pem\"]; !ok {\n618: \t\tt.Errorf(\"Expected secret to contain private.pem\")\n619: \t}\n620: \n621: \tif _, ok := secret.Data[\"public.pem\"]; !ok {\n622: \t\tt.Errorf(\"Expected secret to contain public.pem\")\n623: \t}\n624: \n625: \tif manager.privateKey == nil {\n626: \t\tt.Errorf(\"Expected private key to be initialized\")\n627: \t}\n628: \n629: \tif manager.publicKey == nil {\n630: \t\tt.Errorf(\"Expected public key to be initialized\")\n631: \t}\n632: }\n633: \n634: func TestTryStoreOrLoadJWTKeySecret(t *testing.T) {\n635: \ttests := []struct {\n636: \t\tname         string\n637: \t\texistingKeys bool\n638: \t}{\n639: \t\t{\n640: \t\t\tname:         \"create new secret\",\n641: \t\t\texistingKeys: false,\n642: \t\t},\n643: \t\t{\n644: \t\t\tname:         \"load existing secret\",\n645: \t\t\texistingKeys: true,\n646: \t\t},\n647: \t}\n648: \n649: \tfor _, tt := range tests {\n650: \t\tt.Run(tt.name, func(t *testing.T) {\n651: \t\t\tvar clientset kubernetes.Interface\n652: \t\t\tnamespace := \"test-namespace\"\n653: \n654: \t\t\tif tt.existingKeys {\n655: \t\t\t\tprivateKey, publicKey, err := generateRSAKeyPair()\n656: \t\t\t\tif err != nil {\n657: \t\t\t\t\tt.Fatalf(\"Failed to generate RSA key pair: %v\", err)\n658: \t\t\t\t}\n659: \n660: \t\t\t\tprivateKeyPEM := pem.EncodeToMemory(&pem.Block{\n661: \t\t\t\t\tType:  privateKeyPEMType,\n662: \t\t\t\t\tBytes: x509.MarshalPKCS1PrivateKey(privateKey),\n663: \t\t\t\t})\n664: \n665: \t\t\t\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n666: \t\t\t\tif err != nil {\n667: \t\t\t\t\tt.Fatalf(\"Failed to marshal public key: %v\", err)\n668: \t\t\t\t}\n669: \n670: \t\t\t\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n671: \t\t\t\t\tType:  publicKeyPEMType,\n672: \t\t\t\t\tBytes: publicKeyBytes,\n673: \t\t\t\t})\n674: \n675: \t\t\t\tsecret := &corev1.Secret{\n676: \t\t\t\t\tObjectMeta: metav1.ObjectMeta{\n677: \t\t\t\t\t\tName:      jwtSecretName,\n678: \t\t\t\t\t\tNamespace: namespace,\n679: \t\t\t\t\t},\n680: \t\t\t\t\tData: map[string][]byte{\n681: \t\t\t\t\t\t\"private.pem\": privateKeyPEM,\n682: \t\t\t\t\t\t\"public.pem\":  publicKeyPEM,\n683: \t\t\t\t\t},\n684: \t\t\t\t}\n685: \n686: \t\t\t\tclientset = fake.NewSimpleClientset(secret)\n687: \t\t\t} else {\n688: \t\t\t\tclientset = fake.NewSimpleClientset()\n689: \t\t\t}\n690: \n691: \t\t\tmanager := &JWTManager{\n692: \t\t\t\tclientset: clientset,\n693: \t\t\t\tnamespace: namespace,\n694: \t\t\t}\n695: \n696: \t\t\terr := manager.tryStoreOrLoadJWTKeySecret()\n697: \t\t\tif err != nil {\n698: \t\t\t\tt.Fatalf(\"Unexpected error: %v\", err)\n699: \t\t\t}\n700: \n701: \t\t\tif manager.privateKey == nil {\n702: \t\t\t\tt.Errorf(\"Expected private key to be initialized\")\n703: \t\t\t}\n704: \n705: \t\t\tif manager.publicKey == nil {\n706: \t\t\t\tt.Errorf(\"Expected public key to be initialized\")\n707: \t\t\t}\n708: \t\t})\n709: \t}\n710: }\n711: \n712: func TestConcurrentTokenGeneration(t *testing.T) {\n713: \tmanager, err := NewJWTManager(fake.NewSimpleClientset(), \"test\")\n714: \tif err != nil {\n715: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n716: \t}\n717: \n718: \tconcurrency := 100\n719: \tdone := make(chan string, concurrency)\n720: \terrors := make(chan error, concurrency)\n721: \n722: \tfor i := 0; i < concurrency; i++ {\n723: \t\tgo func(sessionID string) {\n724: \t\t\ttoken, err := manager.GenerateToken(sessionID)\n725: \t\t\tif err != nil {\n726: \t\t\t\terrors <- err\n727: \t\t\t\treturn\n728: \t\t\t}\n729: \t\t\tdone <- token\n730: \t\t}(string(rune('a' + i)))\n731: \t}\n732: \n733: \ttokenCount := 0\n734: \tfor i := 0; i < concurrency; i++ {\n735: \t\tselect {\n736: \t\tcase <-done:\n737: \t\t\ttokenCount++\n738: \t\tcase err := <-errors:\n739: \t\t\tt.Errorf(\"Unexpected error: %v\", err)\n740: \t\t}\n741: \t}\n742: \n743: \tif tokenCount != concurrency {\n744: \t\tt.Errorf(\"Expected %d tokens, got %d\", concurrency, tokenCount)\n745: \t}\n746: }\n747: \n748: func TestConcurrentTokenValidation(t *testing.T) {\n749: \tmanager, err := NewJWTManager(fake.NewSimpleClientset(), \"test\")\n750: \tif err != nil {\n751: \t\tt.Fatalf(\"Failed to create JWT manager: %v\", err)\n752: \t}\n753: \n754: \tsessionID := \"test-session-123\"\n755: \ttoken, err := manager.GenerateToken(sessionID)\n756: \tif err != nil {\n757: \t\tt.Fatalf(\"Failed to generate token: %v\", err)\n758: \t}\n759: \n760: \tconcurrency := 100\n761: \tdone := make(chan *JWTClaims, concurrency)\n762: \terrors := make(chan error, concurrency)\n763: \n764: \tfor i := 0; i < concurrency; i++ {\n765: \t\tgo func() {\n766: \t\t\tclaims, err := manager.ValidateToken(token)\n767: \t\t\tif err != nil {\n768: \t\t\t\terrors <- err\n769: \t\t\t\treturn\n770: \t\t\t}\n771: \t\t\tdone <- claims\n772: \t\t}()\n773: \t}\n774: \n775: \tclaimsCount := 0\n776: \tfor i := 0; i < concurrency; i++ {\n777: \t\tselect {\n778: \t\tcase claims := <-done:\n779: \t\t\tif claims.SessionID != sessionID {\n780: \t\t\t\tt.Errorf(\"Expected session ID %s, got %s\", sessionID, claims.SessionID)\n781: \t\t\t}\n782: \t\t\tclaimsCount++\n783: \t\tcase err := <-errors:\n784: \t\t\tt.Errorf(\"Unexpected error: %v\", err)\n785: \t\t}\n786: \t}\n787: \n788: \tif claimsCount != concurrency {\n789: \t\tt.Errorf(\"Expected %d claims, got %d\", concurrency, claimsCount)\n790: \t}\n791: }\n792: \n793: func TestIsNotFoundError(t *testing.T) {\n794: \ttests := []struct {\n795: \t\tname     string\n796: \t\terr      error\n797: \t\texpected bool\n798: \t}{\n799: \t\t{\n800: \t\t\tname:     \"nil error\",\n801: \t\t\terr:      nil,\n802: \t\t\texpected: false,\n803: \t\t},\n804: \t\t{\n805: \t\t\tname:     \"error with 'not found'\",\n806: \t\t\terr:      fmt.Errorf(\"error: not found\"),\n807: \t\t\texpected: true,\n808: \t\t},\n809: \t\t{\n810: \t\t\tname:     \"error with '404'\",\n811: \t\t\terr:      fmt.Errorf(\"error: 404 not found\"),\n812: \t\t\texpected: true,\n813: \t\t},\n814: \t\t{\n815: \t\t\tname:     \"other error\",\n816: \t\t\terr:      fmt.Errorf(\"some other error\"),\n817: \t\t\texpected: false,\n818: \t\t},\n819: \t}\n820: \n821: \tfor _, tt := range tests {\n822: \t\tt.Run(tt.name, func(t *testing.T) {\n823: \t\t\tresult := isNotFoundError(tt.err)\n824: \t\t\tif result != tt.expected {\n825: \t\t\t\tt.Errorf(\"Expected %v, got %v\", tt.expected, result)\n826: \t\t\t}\n827: \t\t})\n828: \t}\n829: }\n830: \n831: func TestJWTClaimsJSON(t *testing.T) {\n832: \tsessionID := \"test-session-123\"\n833: \tnow := time.Now()\n834: \tclaims := &JWTClaims{\n835: \t\tSessionID: sessionID,\n836: \t\tRegisteredClaims: jwt.RegisteredClaims{\n837: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n838: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(jwtTokenExpiration)),\n839: \t\t\tNotBefore: jwt.NewNumericDate(now),\n840: \t\t},\n841: \t}\n842: \n843: \tjsonData, err := json.Marshal(claims)\n844: \tif err != nil {\n845: \t\tt.Fatalf(\"Failed to marshal claims: %v\", err)\n846: \t}\n847: \n848: \tvar unmarshaledClaims JWTClaims\n849: \terr = json.Unmarshal(jsonData, &unmarshaledClaims)\n850: \tif err != nil {\n851: \t\tt.Fatalf(\"Failed to unmarshal claims: %v\", err)\n852: \t}\n853: \n854: \tif unmarshaledClaims.SessionID != sessionID {\n855: \t\tt.Errorf(\"Expected session ID %s, got %s\", sessionID, unmarshaledClaims.SessionID)\n856: \t}\n857: }\n858: \n859: func containsString(s, substr string) bool {\n860: \treturn strings.Contains(s, substr)\n861: }\n\n(End of file - total 861 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/x509\"\n\t\"encoding/json\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n)\n\nfunc TestNewJWTManager(t *testing.T) {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-pl