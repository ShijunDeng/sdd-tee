       ci.CreationTimestamp.Time,\n35: \t\tExpiresAt:        GetExpirationTime(ci),\n36: \t\tSessionID:        sessionID,\n37: \t}\n38: }\n39: \n40: func GetSandboxPodName(obj metav1.Object) string {\n41: \tif annotations := obj.GetAnnotations(); annotations != nil {\n42: \t\tif podName, exists := annotations[\"agentcube.volcano.sh/sandbox-pod\"]; exists {\n43: \t\t\treturn podName\n44: \t\t}\n45: \t}\n46: \n47: \treturn obj.GetName()\n48: }\n49: \n50: func GetExpirationTime(obj metav1.Object) time.Time {\n51: \tif annotations := obj.GetAnnotations(); annotations != nil {\n52: \t\tif expiresAt, exists := annotations[\"agentcube.volcano.sh/expiration-time\"]; exists {\n53: \t\t\tif t, err := time.Parse(time.RFC3339, expiresAt); err == nil {\n54: \t\t\t\treturn t\n55: \t\t\t}\n56: \t\t}\n57: \t}\n58: \n59: \tcreatedAt := obj.GetCreationTimestamp().Time\n60: \tif createdAt.IsZero() {\n61: \t\treturn time.Now().Add(8 * time.Hour)\n62: \t}\n63: \n64: \treturn createdAt.Add(8 * time.Hour)\n65: }\n66: \n67: func GetPodIPFromAgentRuntime(ar *agentcubev1alpha1.AgentRuntime) string {\n68: \tif ar == nil {\n69: \t\treturn \"\"\n70: \t}\n71: \n72: \tif annotations := ar.GetAnnotations(); annotations != nil {\n73: \t\tif podIP, exists := annotations[\"agentcube.volcano.sh/pod-ip\"]; exists {\n74: \t\t\treturn podIP\n75: \t\t}\n76: \t}\n77: \n78: \treturn \"\"\n79: }\n80: \n81: func GetPodIPFromCodeInterpreter(ci *agentcubev1alpha1.CodeInterpreter) string {\n82: \tif ci == nil {\n83: \t\treturn \"\"\n84: \t}\n85: \n86: \tif annotations := ci.GetAnnotations(); annotations != nil {\n87: \t\tif podIP, exists := annotations[\"agentcube.volcano.sh/pod-ip\"]; exists {\n88: \t\t\treturn podIP\n89: \t\t}\n90: \t}\n91: \n92: \treturn \"\"\n93: }\n94: \n95: func GetEntryPointsFromAgentRuntime(ar *agentcubev1alpha1.AgentRuntime) []types.SandboxEntryPoint {\n96: \tif ar == nil || ar.Spec.PodTemplate == nil {\n97: \t\treturn []types.SandboxEntryPoint{}\n98: \t}\n99: \n100: \tentryPoints := make([]types.SandboxEntryPoint, 0)\n101: \n102: \tfor _, container := range ar.Spec.PodTemplate.Spec.Containers {\n103: \t\tfor _, port := range container.Ports {\n104: \t\t\tentryPoint := types.SandboxEntryPoint{\n105: \t\t\t\tPath:     \"/\",\n106: \t\t\t\tProtocol: \"http\",\n107: \t\t\t\tEndpoint: \"\",\n108: \t\t\t}\n109: \n110: \t\t\tif port.ContainerPort > 0 {\n111: \t\t\t\tentryPoint.Endpoint = container.Name + \":\" + string(rune(port.ContainerPort))\n112: \t\t\t}\n113: \n114: \t\t\tentryPoints = append(entryPoints, entryPoint)\n115: \t\t}\n116: \t}\n117: \n118: \treturn entryPoints\n119: }\n120: \n121: func GetEntryPointsFromCodeInterpreter(ci *agentcubev1alpha1.CodeInterpreter) []types.SandboxEntryPoint {\n122: \tif ci == nil {\n123: \t\treturn []types.SandboxEntryPoint{}\n124: \t}\n125: \n126: \tentryPoints := make([]types.SandboxEntryPoint, 0)\n127: \n128: \tentryPoint := types.SandboxEntryPoint{\n129: \t\tPath:     \"/\",\n130: \t\tProtocol: \"http\",\n131: \t\tEndpoint: \"code-interpreter:8080\",\n132: \t}\n133: \n134: \tentryPoints = append(entryPoints, entryPoint)\n135: \n136: \treturn entryPoints\n137: }\n138: \n139: func GetMaxSessionDuration(ar *agentcubev1alpha1.AgentRuntime) time.Duration {\n140: \tif ar == nil || ar.Spec.MaxSessionDuration == nil {\n141: \t\treturn 8 * time.Hour\n142: \t}\n143: \n144: \treturn ar.Spec.MaxSessionDuration.Duration\n145: }\n146: \n147: func GetSessionTimeout(ar *agentcubev1alpha1.AgentRuntime) time.Duration {\n148: \tif ar == nil || ar.Spec.SessionTimeout == nil {\n149: \t\treturn 15 * time.Minute\n150: \t}\n151: \n152: \treturn ar.Spec.SessionTimeout.Duration\n153: }\n154: \n155: func GetCodeInterpreterTimeout(ci *agentcubev1alpha1.CodeInterpreter) time.Duration {\n156: \tif ci == nil || ci.Spec.Timeout == nil {\n157: \t\treturn 5 * time.Minute\n158: \t}\n159: \n160: \treturn ci.Spec.Timeout.Duration\n161: }\n162: \n163: func IsAgentRuntimeReady(ar *agentcubev1alpha1.AgentRuntime) bool {\n164: \tif ar == nil {\n165: \t\treturn false\n166: \t}\n167: \n168: \treturn isResourceReady(ar.Status.Conditions)\n169: }\n170: \n171: func IsCodeInterpreterReady(ci *agentcubev1alpha1.CodeInterpreter) bool {\n172: \tif ci == nil {\n173: \t\treturn false\n174: \t}\n175: \n176: \treturn ci.Status.Ready\n177: }\n178: \n179: func GetAgentRuntimeObservedGeneration(ar *agentcubev1alpha1.AgentRuntime) int64 {\n180: \tif ar == nil {\n181: \t\treturn 0\n182: \t}\n183: \n184: \treturn ar.Status.ObservedGeneration\n185: }\n186: \n187: func GetCodeInterpreterObservedGeneration(ci *agentcubev1alpha1.CodeInterpreter) int64 {\n188: \tif ci == nil {\n189: \t\treturn 0\n190: \t}\n191: \n192: \treturn ci.Status.ObservedGeneration\n193: }\n194: \n195: func GetAgentRuntimeConditions(ar *agentcubev1alpha1.AgentRuntime) []metav1.Condition {\n196: \tif ar == nil {\n197: \t\treturn []metav1.Condition{}\n198: \t}\n199: \n200: \treturn ar.Status.Conditions\n201: }\n202: \n203: func GetCodeInterpreterConditions(ci *agentcubev1alpha1.CodeInterpreter) []metav1.Condition {\n204: \tif ci == nil {\n205: \t\treturn []metav1.Condition{}\n206: \t}\n207: \n208: \treturn ci.Status.Conditions\n209: }\n\n(End of file - total 209 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc SandboxInfoFromAgentRuntime(ar *agentcubev1alpha1.AgentRuntime, sessionID string) *types.SandboxInfo {\n\treturn &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tName:             ar.Name,\n\t\tNamespace:        ar.Namespace,\n\t\tSandboxName:      GetSandboxPodName(ar),\n\t\tSandboxNamespace: ar.Namespace,\n\t\tStatus:           GetResourceStatus(ar.Status.Conditions),\n\t\tCreatedAt:        ar.CreationTimestamp.Time,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-co