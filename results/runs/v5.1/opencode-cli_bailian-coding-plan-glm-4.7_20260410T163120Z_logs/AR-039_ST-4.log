printf(\"session expired: %s\", e.SessionID)\n47: }\n48: \n49: func (e *SessionExpiredError) HTTPStatusCode() int {\n50: \treturn http.StatusNotFound\n51: }\n52: \n53: func (e *SessionExpiredError) ErrorCode() string {\n54: \treturn \"SESSION_EXPIRED\"\n55: }\n56: \n57: type WorkloadManagerError struct {\n58: \tMessage string\n59: \tCode    int\n60: }\n61: \n62: func (e *WorkloadManagerError) Error() string {\n63: \treturn fmt.Sprintf(\"workload manager error: %s (code: %d)\", e.Message, e.Code)\n64: }\n65: \n66: func (e *WorkloadManagerError) HTTPStatusCode() int {\n67: \treturn e.Code\n68: }\n69: \n70: func (e *WorkloadManagerError) ErrorCode() string {\n71: \treturn \"WORKLOAD_MANAGER_ERROR\"\n72: }\n73: \n74: type ValidationError struct {\n75: \tField   string\n76: \tMessage string\n77: }\n78: \n79: func (e *ValidationError) Error() string {\n80: \treturn fmt.Sprintf(\"validation error: %s - %s\", e.Field, e.Message)\n81: }\n82: \n83: func (e *ValidationError) HTTPStatusCode() int {\n84: \treturn http.StatusBadRequest\n85: }\n86: \n87: func (e *ValidationError) ErrorCode() string {\n88: \treturn \"VALIDATION_ERROR\"\n89: }\n90: \n91: type HTTPError interface {\n92: \tError() string\n93: \tHTTPStatusCode() int\n94: \tErrorCode() string\n95: }\n96: \n97: func GetHTTPStatusCode(err error) int {\n98: \tif httpErr, ok := err.(HTTPError); ok {\n99: \t\treturn httpErr.HTTPStatusCode()\n100: \t}\n101: \treturn http.StatusInternalServerError\n102: }\n103: \n104: func GetErrorCode(err error) string {\n105: \tif httpErr, ok := err.(HTTPError); ok {\n106: \t\treturn httpErr.ErrorCode()\n107: \t}\n108: \treturn \"\"\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n)\n\nvar (\n\tErrSandboxNotFound        = &SandboxNotFoundError{}\n\tErrSessionExpired         = &SessionExpiredError{}\n\tErrWorkloadManagerError   = &WorkloadManagerError{}\n\tErrValidationError        = &ValidationError{}\n\tErr