{"type":"tool_use","timestamp":1775893847629,"sessionID":"ses_2847add1cffeuUuNzOXxl3iH5B","part":{"id":"prt_d7b859bd80011fB0cNUUUraifw","messageID":"msg_d7b85804d001xUcWHC1iHC9m3w","sessionID":"ses_2847add1cffeuUuNzOXxl3iH5B","type":"tool","tool":"read","callID":"toolu_tool-844b35eed4cc40db9cdd57ce9aa333b6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/proxy.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/proxy.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"io\"\n7: \t\"net/http\"\n8: \t\"net/http/httputil\"\n9: \t\"net/url\"\n10: \t\"strings\"\n11: \t\"time\"\n12: \n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: \t\"k8s.io/klog/v2\"\n15: )\n16: \n17: type ReverseProxy struct {\n18: \thttpTransport *http.Transport\n19: \tjwtManager    *JWTManager\n20: }\n21: \n22: func NewReverseProxy(jwtManager *JWTManager) *ReverseProxy {\n23: \treturn &ReverseProxy{\n24: \t\thttpTransport: configureHTTPTransport(),\n25: \t\tjwtManager:    jwtManager,\n26: \t}\n27: }\n28: \n29: func configureHTTPTransport() *http.Transport {\n30: \treturn &http.Transport{\n31: \t\tMaxIdleConns:        100,\n32: \t\tIdleConnTimeout:     90 * time.Second,\n33: \t\tDisableCompression:  false,\n34: \t\tForceAttemptHTTP2:   true,\n35: \t\tTLSHandshakeTimeout: 10 * time.Second,\n36: \t}\n37: }\n38: \n39: func (p *ReverseProxy) ProxyRequest(ctx context.Context, sandboxInfo *types.SandboxInfo, originalReq *http.Request) (*http.Response, error) {\n40: \tentryPoint := findMatchingEntryPoint(originalReq.URL.Path, sandboxInfo.EntryPoints)\n41: \tif entryPoint == nil {\n42: \t\treturn nil, fmt.Errorf(\"no matching entry point for path: %s\", originalReq.URL.Path)\n43: \t}\n44: \n45: \tupstreamURL := constructUpstreamURL(entryPoint.Protocol, entryPoint.Endpoint)\n46: \tupstreamURLParsed, err := url.Parse(upstreamURL)\n47: \tif err != nil {\n48: \t\treturn nil, fmt.Errorf(\"failed to parse upstream URL: %w\", err)\n49: \t}\n50: \n51: \ttargetPath := originalReq.URL.Path\n52: \tif originalReq.URL.RawQuery != \"\" {\n53: \t\ttargetPath = targetPath + \"?\" + originalReq.URL.RawQuery\n54: \t}\n55: \n56: \tproxyReq, err := http.NewRequestWithContext(ctx, originalReq.Method, upstreamURLParsed.String()+targetPath, originalReq.Body)\n57: \tif err != nil {\n58: \t\treturn nil, fmt.Errorf(\"failed to create proxy request: %w\", err)\n59: \t}\n60: \n61: \tp.modifyRequestHeaders(proxyReq, originalReq, sandboxInfo)\n62: \n63: \ttoken, err := p.jwtManager.GenerateToken(sandboxInfo.SessionID)\n64: \tif err != nil {\n65: \t\treturn nil, fmt.Errorf(\"failed to sign request: %w\", err)\n66: \t}\n67: \tproxyReq.Header.Set(\"Authorization\", \"Bearer \"+token)\n68: \n69: \tclient := &http.Client{\n70: \t\tTransport: p.httpTransport,\n71: \t\tTimeout:   60 * time.Second,\n72: \t}\n73: \n74: \tresp, err := client.Do(proxyReq)\n75: \tif err != nil {\n76: \t\treturn nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusBadGateway}\n77: \t}\n78: \n79: \treturn resp, nil\n80: }\n81: \n82: func (p *ReverseProxy) modifyRequestHeaders(proxyReq, originalReq *http.Request, sandboxInfo *types.SandboxInfo) {\n83: \tfor name, values := range originalReq.Header {\n84: \t\tif isHopByHopHeader(name) {\n85: \t\t\tcontinue\n86: \t\t}\n87: \n88: \t\tif strings.EqualFold(name, \"Authorization\") {\n89: \t\t\tcontinue\n90: \t\t}\n91: \n92: \t\tfor _, value := range values {\n93: \t\t\tproxyReq.Header.Add(name, value)\n94: \t\t}\n95: \t}\n96: \n97: \tproxyReq.Header.Set(\"X-Forwarded-Host\", originalReq.Host)\n98: \n99: \tif originalReq.TLS != nil {\n100: \t\tproxyReq.Header.Set(\"X-Forwarded-Proto\", \"https\")\n101: \t} else {\n102: \t\tproxyReq.Header.Set(\"X-Forwarded-Proto\", \"http\")\n103: \t}\n104: \n105: \tclientIP := originalReq.RemoteAddr\n106: \tif xff := originalReq.Header.Get(\"X-Forwarded-For\"); xff != \"\" {\n107: \t\tclientIP = xff + \", \" + clientIP\n108: \t}\n109: \tproxyReq.Header.Set(\"X-Forwarded-For\", clientIP)\n110: \n111: \tproxyReq.Header.Set(\"X-Agentcube-Session-ID\", sandboxInfo.SessionID)\n112: }\n113: \n114: func (p *ReverseProxy) CopyResponse(resp *http.Response, w http.ResponseWriter, sessionID string) {\n115: \tfor name, values := range resp.Header {\n116: \t\tif isHopByHopHeader(name) {\n117: \t\t\tcontinue\n118: \t\t}\n119: \n120: \t\tfor _, value := range values {\n121: \t\t\tw.Header().Add(name, value)\n122: \t\t}\n123: \t}\n124: \n125: \tw.Header().Set(\"X-Agentcube-Session-ID\", sessionID)\n126: \n127: \tw.WriteHeader(resp.StatusCode)\n128: \n129: \tif resp.Body != nil {\n130: \t\tdefer resp.Body.Close()\n131: \t\tif _, err := io.Copy(w, resp.Body); err != nil {\n132: \t\t\tklog.Warningf(\"Failed to copy response body: %v\", err)\n133: \t\t}\n134: \t}\n135: }\n136: \n137: func (p *ReverseProxy) ServeHTTP(w http.ResponseWriter, r *http.Request, sandboxInfo *types.SandboxInfo) {\n138: \tentryPoint := findMatchingEntryPoint(r.URL.Path, sandboxInfo.EntryPoints)\n139: \tif entryPoint == nil {\n140: \t\thttp.Error(w, \"no matching entry point\", http.StatusNotFound)\n141: \t\treturn\n142: \t}\n143: \n144: \tupstreamURL := constructUpstreamURL(entryPoint.Protocol, entryPoint.Endpoint)\n145: \tupstreamURLParsed, err := url.Parse(upstreamURL)\n146: \tif err != nil {\n147: \t\thttp.Error(w, fmt.Sprintf(\"invalid upstream URL: %v\", err), http.StatusInternalServerError)\n148: \t\treturn\n149: \t}\n150: \n151: \tdirector := func(req *http.Request) {\n152: \t\treq.URL.Scheme = upstreamURLParsed.Scheme\n153: \t\treq.URL.Host = upstreamURLParsed.Host\n154: \t\treq.URL.Path = singleJoiningSlash(upstreamURLParsed.Path, req.URL.Path)\n155: \n156: \t\tp.modifyRequestHeaders(req, r, sandboxInfo)\n157: \n158: \t\ttoken, err := p.jwtManager.GenerateToken(sandboxInfo.SessionID)\n159: \t\tif err != nil {\n160: \t\t\tklog.Warningf(\"Failed to generate JWT token: %v\", err)\n161: \t\t} else {\n162: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n163: \t\t}\n164: \t}\n165: \n166: \tproxy := &httputil.ReverseProxy{\n167: \t\tDirector:       director,\n168: \t\tTransport:      p.httpTransport,\n169: \t\tErrorHandler:   p.errorHandler,\n170: \t\tModifyResponse: p.modifyResponse,\n171: \t}\n172: \n173: \tproxy.ServeHTTP(w, r)\n174: }\n175: \n176: func (p *ReverseProxy) errorHandler(w http.ResponseWriter, r *http.Request, err error) {\n177: \tklog.Warningf(\"Proxy error: %v\", err)\n178: \n179: \tif err == context.DeadlineExceeded {\n180: \t\thttp.Error(w, \"sandbox timeout\", http.StatusGatewayTimeout)\n181: \t\treturn\n182: \t}\n183: \n184: \thttp.Error(w, \"sandbox unreachable\", http.StatusBadGateway)\n185: }\n186: \n187: func (p *ReverseProxy) modifyResponse(resp *http.Response) error {\n188: \tfor name, values := range resp.Header {\n189: \t\tif isHopByHopHeader(name) {\n190: \t\t\tresp.Header.Del(name)\n191: \t\t} else {\n192: \t\t\tfor _, value := range values {\n193: \t\t\t\tresp.Header.Set(name, value)\n194: \t\t\t}\n195: \t\t}\n196: \t}\n197: \n198: \treturn nil\n199: }\n200: \n201: func singleJoiningSlash(a, b string) string {\n202: \taslash := strings.HasSuffix(a, \"/\")\n203: \tbslash := strings.HasPrefix(b, \"/\")\n204: \tswitch {\n205: \tcase aslash && bslash:\n206: \t\treturn a + b[1:]\n207: \tcase !aslash && !bslash:\n208: \t\treturn a + \"/\" + b\n209: \t}\n210: \treturn a + b\n211: }\n\n(End of file - total 211 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype ReverseProxy struct {\n\thttpTransport *http.Transport\n\tjwtManager    *JWTManager\n}","truncated":false,"loaded":[]},"title":"