50: \n51: \tif err := s.initializeSessionManager(); err != nil {\n52: \t\treturn nil, fmt.Errorf(\"failed to initialize session manager: %w\", err)\n53: \t}\n54: \n55: \tif err := s.initializeJWTManager(clientset); err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to initialize JWT manager: %w\", err)\n57: \t}\n58: \n59: \ts.handler = NewHandler(s.sessionManager, s.jwtManager, NewReverseProxy(s.jwtManager))\n60: \n61: \ts.engine = gin.New()\n62: \n63: \ts.applyMiddleware()\n64: \n65: \ts.setupRoutes()\n66: \n67: \ts.httpServer = &http.Server{\n68: \t\tAddr:         \":\" + s.config.Port,\n69: \t\tHandler:      s.engine,\n70: \t\tReadTimeout:  time.Duration(s.config.ReadTimeout) * time.Second,\n71: \t\tWriteTimeout: time.Duration(s.config.WriteTimeout) * time.Second,\n72: \t\tIdleTimeout:  time.Duration(s.config.IdleTimeout) * time.Second,\n73: \t}\n74: \n75: \treturn s, nil\n76: }\n77: \n78: func (s *Server) initializeSessionManager() error {\n79: \tsessionManager, err := NewSessionManager(s.storeClient, s.config.WorkloadManagerURL)\n80: \tif err != nil {\n81: \t\treturn err\n82: \t}\n83: \n84: \ts.sessionManager = sessionManager\n85: \treturn nil\n86: }\n87: \n88: func (s *Server) initializeJWTManager(clientset kubernetes.Interface) error {\n89: \tif clientset == nil {\n90: \t\tklog.Warning(\"Kubernetes clientset not provided, JWT manager will not be fully functional\")\n91: \t\ts.jwtManager = &JWTManager{}\n92: \t\treturn nil\n93: \t}\n94: \n95: \tjwtManager, err := NewJWTManager(clientset, s.config.AgentcubeNamespace)\n96: \tif err != nil {\n97: \t\treturn err\n98: \t}\n99: \n100: \ts.jwtManager = jwtManager\n101: \treturn nil\n102: }\n103: \n104: func (s *Server) applyMiddleware() {\n105: \ts.engine.Use(recoveryMiddleware())\n106: \ts.engine.Use(loggingMiddleware())\n107: \ts.engine.Use(correlationIDMiddleware())\n108: \ts.engine.Use(concurrencyLimitMiddleware(s.limiter))\n109: \ts.engine.Use(metricsMiddleware(s.metrics))\n110: }\n111: \n112: func (s *Server) setupRoutes() {\n113: \ts.engine.GET(\"/health/live\", s.handler.handleHealthLive)\n114: \ts.engine.GET(\"/health/ready\", s.handler.handleHealthReady)\n115: \n116: \tv1 := s.engine.Group(\"/v1\")\n117: \t{\n118: \t\tsessions := v1.Group(\"/sessions\")\n119: \t\t{\n120: \t\t\tsessions.POST(\"/namespaces/:namespace/:kind/:name\", s.handler.handleCreateSession)\n121: \t\t}\n122: \n123: \t\tprotected := v1.Group(\"\")\n124: \t\tprotected.Use(jwtAuthMiddleware(s.jwtManager))\n125: \t\t{\n126: \t\t\tprotected.GET(\"/sessions/:sessionID\", s.handler.handleGetSession)\n127: \t\t}\n128: \n129: \t\tnamespaces := v1.Group(\"/namespaces/:namespace\")\n130: \t\t{\n131: \t\t\tagentRuntimes := namespaces.Group(\"/agent-runtimes/:name\")\n132: \t\t\t{\n133: \t\t\t\tagentRuntimes.Any(\"/invocations/*path\", s.handler.handleAgentInvoke)\n134: \t\t\t}\n135: \n136: \t\t\tcodeInterpreters := namespaces.Group(\"/code-interpreters/:name\")\n137: \t\t\t{\n138: \t\t\t\tcodeInterpreters.Any(\"/invocations/*path\", s.handler.handleCodeInterpreterInvoke)\n139: \t\t\t}\n140: \t\t}\n141: \t}\n142: }\n143: \n144: func (s *Server) Start(ctx context.Context) error {\n145: \tlistener, err := net.Listen(\"tcp\", s.httpServer.Addr)\n146: \tif err != nil {\n147: \t\treturn fmt.Errorf(\"failed to listen on %s: %w\", s.httpServer.Addr, err)\n148: \t}\n149: \n150: \tklog.Infof(\"Starting HTTP server on %s\", s.httpServer.Addr)\n151: \tklog.Infof(\"TLS enabled: %v\", s.config.EnableTLS)\n152: \tklog.Infof(\"Max concurrent requests: %d\", s.config.MaxConcurrentRequests)\n153: \n154: \terrChan := make(chan error, 1)\n155: \n156: \tgo func() {\n157: \t\tif s.config.EnableTLS {\n158: \t\t\terrChan <- s.httpServer.ServeTLS(listener, s.config.TLSCert, s.config.TLSKey)\n159: \t\t} else {\n160: \t\t\terrChan <- s.httpServer.Serve(listener)\n161: \t\t}\n162: \t}()\n163: \n164: \tselect {\n165: \tcase err := <-errChan:\n166: \t\tif err != nil && err != http.ErrServerClosed {\n167: \t\t\treturn fmt.Errorf(\"server error: %w\", err)\n168: \t\t}\n169: \t\treturn err\n170: \tcase <-ctx.Done():\n171: \t\treturn s.Shutdown(ctx)\n172: \t}\n173: }\n174: \n175: func (s *Server) Shutdown(ctx context.Context) error {\n176: \tklog.Info(\"Shutting down HTTP server...\")\n177: \n178: \tshutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n179: \tdefer cancel()\n180: \n181: \tif err := s.httpServer.Shutdown(shutdownCtx); err != nil {\n182: \t\tklog.Warningf(\"Error during server shutdown: %v\", err)\n183: \t\treturn err\n184: \t}\n185: \n186: \tklog.Info(\"HTTP server stopped\")\n187: \n188: \treturn nil\n189: }\n190: \n191: func (s *Server) GetMetrics() *Metrics {\n192: \treturn s.metrics\n193: }\n194: \n195: func (s *Server) GetActiveConnections() int {\n196: \treturn s.limiter.semaphoreLen()\n197: }\n198: \n199: func (l *ConcurrencyLimiter) semaphoreLen() int {\n200: \treturn len(l.semaphore)\n201: }\n\n(End of file - total 201 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go","time":{"start":1775893866577,"end":1775893866590}}}}
