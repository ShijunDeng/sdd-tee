tcleanPath = \"/\" + cleanPath\n51: \t}\n52: \n53: \treturn cleanPath\n54: }\n55: \n56: func normalizeURL(rawURL string) (string, error) {\n57: \tparsed, err := url.Parse(rawURL)\n58: \tif err != nil {\n59: \t\treturn \"\", err\n60: \t}\n61: \n62: \tparsed.Path = sanitizePath(parsed.Path)\n63: \n64: \treturn parsed.String(), nil\n65: }\n66: \n67: func parseSessionID(sessionID string) error {\n68: \tif sessionID == \"\" {\n69: \t\treturn fmt.Errorf(\"session ID is required\")\n70: \t}\n71: \n72: \tif !sessionIDRegex.MatchString(sessionID) {\n73: \t\treturn fmt.Errorf(\"invalid session ID format\")\n74: \t}\n75: \n76: \treturn nil\n77: }\n78: \n79: func validateKind(kind string) error {\n80: \tif kind != types.AgentRuntimeKind && kind != types.CodeInterpreterKind {\n81: \t\treturn fmt.Errorf(\"invalid kind: %s, must be %s or %s\", kind, types.AgentRuntimeKind, types.CodeInterpreterKind)\n82: \t}\n83: \treturn nil\n84: }\n85: \n86: func generateCacheKey(sessionID, namespace, name, kind string) string {\n87: \treturn fmt.Sprintf(\"session:%s:%s:%s:%s\", namespace, kind, name, sessionID)\n88: }\n89: \n90: func isHopByHopHeader(header string) bool {\n91: \thopByHopHeaders := []string{\n92: \t\t\"Connection\",\n93: \t\t\"Keep-Alive\",\n94: \t\t\"Proxy-Authenticate\",\n95: \t\t\"Proxy-Authorization\",\n96: \t\t\"Te\",\n97: \t\t\"Trailers\",\n98: \t\t\"Transfer-Encoding\",\n99: \t\t\"Upgrade\",\n100: \t}\n101: \n102: \tfor _, h := range hopByHopHeaders {\n103: \t\tif strings.EqualFold(header, h) {\n104: \t\t\treturn true\n105: \t\t}\n106: \t}\n107: \treturn false\n108: }\n109: \n110: func constructUpstreamURL(protocol, endpoint string) string {\n111: \tif strings.Contains(endpoint, \"://\") {\n112: \t\treturn endpoint\n113: \t}\n114: \n115: \tif protocol == \"\" {\n116: \t\tprotocol = \"http\"\n117: \t}\n118: \n119: \tif !strings.HasPrefix(endpoint, \"http://\") && !strings.HasPrefix(endpoint, \"https://\") {\n120: \t\tendpoint = fmt.Sprintf(\"%s://%s\", protocol, endpoint)\n121: \t}\n122: \n123: \treturn endpoint\n124: }\n125: \n126: func findMatchingEntryPoint(requestPath string, entryPoints []types.SandboxEntryPoint) *types.SandboxEntryPoint {\n127: \tif len(entryPoints) == 0 {\n128: \t\treturn nil\n129: \t}\n130: \n131: \tfor _, ep := range entryPoints {\n132: \t\tif strings.HasPrefix(requestPath, ep.Path) {\n133: \t\t\treturn &ep\n134: \t\t}\n135: \t}\n136: \n137: \tfor _, ep := range entryPoints {\n138: \t\tif ep.Path == \"/\" || ep.Path == \"\" {\n139: \t\t\treturn &ep\n140: \t\t}\n141: \t}\n142: \n143: \treturn &entryPoints[0]\n144: }\n145: \n146: func getK8sValidation(field string) bool {\n147: \terrs := validation.IsDNS1123Label(field)\n148: \treturn len(errs) == 0\n149: }\n\n(End of file - total 149 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"regexp\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/apimachinery/pkg/util/validation\"\n)\n\nconst (\n\tsessionTTL = 5 * time.Minute\n)\n\nvar (\n\tnamespaceRegex    = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)\n\tresourceNameRegex = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/utils.go","time":{"start":1775893866580,"end":1775893866593}}}}
