{"type":"tool_use","timestamp":1775876027944,"sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","part":{"id":"prt_d7a75779a001xhqsV4j2y1iVlI","messageID":"msg_d7a7542b3001GHiCTxtALcB0P4","sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","type":"tool","tool":"write","callID":"toolu_tool-60bbe0583cc5471cb00640eaf3a93307","state":{"status":"completed","input":{"content":"\"\"\"Configuration validation for providers.\"\"\"\n\nimport os\nfrom typing import Any, List\n\n\nclass ConfigValidator:\n    \"\"\"Validator for provider configuration parameters.\"\"\"\n\n    @staticmethod\n    def validate_provider_config(\n        provider_type: str,\n        **kwargs: Any,\n    ) -> List[str]:\n        \"\"\"Validate configuration for a specific provider type.\n\n        Args:\n            provider_type: Provider type identifier\n            **kwargs: Configuration parameters\n\n        Returns:\n            List[str]: List of error messages (empty if valid)\n\n        Example:\n            errors = ConfigValidator.validate_provider_config(\n                \"k8s\", replicas=3, node_port=30080\n            )\n        \"\"\"\n        try:\n            from agentcube.providers.factory import ProviderFactory\n\n            provider = ProviderFactory.create(provider_type, verbose=False)\n            return provider.validate_config(**kwargs)\n        except Exception as e:\n            return [f\"Failed to validate config: {e}\"]\n\n    @staticmethod\n    def validate_k8s_config(\n        replicas: Any = None,\n        node_port: Any = None,\n    ) -> List[str]:\n        \"\"\"Validate Kubernetes-specific configuration.\n\n        Args:\n            replicas: Number of replicas\n            node_port: NodePort value\n\n        Returns:\n            List[str]: List of error messages (empty if valid)\n\n        Example:\n            errors = ConfigValidator.validate_k8s_config(\n                replicas=3, node_port=30080\n            )\n        \"\"\"\n        errors: List[str] = []\n\n        if replicas is not None:\n            if not isinstance(replicas, int) or replicas < 0:\n                errors.append(\"replicas must be a non-negative integer\")\n\n        if node_port is not None:\n            if not isinstance(node_port, int) or not (30000 <= node_port <= 32767):\n                errors.append(\"node_port must be between 30000 and 32767\")\n\n        return errors\n\n    @staticmethod\n    def validate_agentcube_config(\n        workload_manager_url: Any = None,\n        router_url: Any = None,\n    ) -> List[str]:\n        \"\"\"Validate AgentCube-specific configuration.\n\n        Args:\n            workload_manager_url: Workload manager URL\n            router_url: Router URL\n\n        Returns:\n            List[str]: List of error messages (empty if valid)\n\n        Example:\n            errors = ConfigValidator.validate_agentcube_config(\n                workload_manager_url=\"http://workload-manager:8080\",\n                router_url=\"http://router:8080\"\n            )\n        \"\"\"\n        errors: List[str] = []\n\n        workload_manager = workload_manager_url or os.getenv(\"WORKLOAD_MANAGER_URL\")\n        router = router_url or os.getenv(\"ROUTER_URL\")\n\n        if not workload_manager:\n            errors.append(\"workload_manager_url is required\")\n\n        if not router:\n            errors.append(\"router_url is required\")\n\n        return errors\n\n    @staticmethod\n    def validate_common_config(\n        namespace: Any = None,\n        kubeconfig: Any = None,\n        timeout: Any = None,\n    ) -> List[str]:\n        \"\"\"Validate common provider configuration.\n\n        Args:\n            namespace: Kubernetes namespace\n            kubeconfig: Path to kubeconfig file\n            timeout: Operation timeout in seconds\n\n        Returns:\n            List[str]: List of error messages (empty if valid)\n\n        Example:\n            errors = ConfigValidator.validate_common_config(\n                namespace=\"my-namespace\",\n                timeout=120\n            )\n        \"\"\"\n        errors: List[str] = []\n\n        if namespace is not None and not isinstance(namespace, str):\n            errors.append(\"namespace must be a string\")\n\n        if kubeconfig is not None and not isinstance(kubeconfig, str):\n            errors.append(\"kubeconfig must be a string\")\n\n        if timeout is not None:\n            if not isinstance(timeout, int) or timeout <= 0:\n                errors.append(\"timeout must be a positive integer\")\n\n        return errors\n\n    @staticmethod\n    def validate_all_configs(\n        provider_type: str,\n        **kwargs: Any,\n    ) -> List[str]:\n        \"\"\"Validate all configuration parameters.\n\n        Args:\n            provider_type: Provider type identifier\n            **kwargs: Configuration parameters\n\n        Returns:\n            List[str]: List of error messages (empty if valid)\n\n        Example:\n            errors = ConfigValidator.validate_all_configs(\n                \"k8s\",\n                namespace=\"my-namespace\",\n                replicas=3,\n                node_port=30080,\n                timeout=120\n            )\n        \"\"\"\n        errors: List[str] = []\n\n        common_errors = ConfigValidator.validate_common_config(\n            namespace=kwargs.get(\"namespace\"),\n            kubeconfig=kwargs.get(\"kubeconfig\"),\n            timeout=kwargs.get(\"timeout\"),\n        )\n        errors.extend(common_errors)\n\n        provider_errors = ConfigValidator.validate_provider_config(\n            provider_type,\n            **kwargs\n        )\n        errors.extend(provider_errors)\n\n        return errors","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/providers/config_validator.py"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v