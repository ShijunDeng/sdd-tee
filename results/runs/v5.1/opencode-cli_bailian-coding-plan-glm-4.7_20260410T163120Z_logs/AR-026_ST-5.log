{"type":"tool_use","timestamp":1775875867145,"sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","part":{"id":"prt_d7a733785001w1Lxp1XTfIpcTs","messageID":"msg_d7a72f744001JNL09xNKHyQjo4","sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","type":"tool","tool":"write","callID":"toolu_tool-0c47943e4c9f4d43b7dc702ab85ad187","state":{"status":"completed","input":{"content":"\"\"\"Retry mechanism decorator for provider operations.\"\"\"\n\nimport functools\nimport logging\nimport time\nfrom typing import Any, Callable, Tuple, Type\n\nfrom agentcube.providers.exceptions import ProviderTimeoutError\n\nlogger = logging.getLogger(__name__)\n\n\ndef retry_on_exception(\n    max_attempts: int = 3,\n    delay: float = 1.0,\n    backoff: float = 2.0,\n    exceptions: Tuple[Type[Exception], ...] = (Exception,),\n) -> Callable:\n    \"\"\"Decorator to retry function on specified exceptions.\n\n    Args:\n        max_attempts: Maximum number of retry attempts\n        delay: Initial delay in seconds between attempts\n        backoff: Multiplier for delay after each attempt\n        exceptions: Tuple of exception types to catch and retry on\n\n    Returns:\n        Callable: Decorated function with retry logic\n\n    Example:\n        @retry_on_exception(max_attempts=3, delay=2.0, exceptions=(ApiException,))\n        def deploy_agent(...):\n            ...\n    \"\"\"\n\n    def decorator(func: Callable) -> Callable:\n        @functools.wraps(func)\n        def wrapper(*args: Any, **kwargs: Any) -> Any:\n            last_exception = None\n            current_delay = delay\n\n            for attempt in range(max_attempts):\n                try:\n                    return func(*args, **kwargs)\n                except exceptions as e:\n                    last_exception = e\n                    if attempt < max_attempts - 1:\n                        logger.warning(\n                            f\"Attempt {attempt + 1}/{max_attempts} failed: {e}. \"\n                            f\"Retrying in {current_delay}s...\"\n                        )\n                        time.sleep(current_delay)\n                        current_delay *= backoff\n                    else:\n                        logger.error(f\"All {max_attempts} attempts failed\")\n\n            raise last_exception  # type: ignore\n\n        return wrapper\n\n    return decorator\n\n\nclass RetryableOperation:\n    \"\"\"Context manager for retryable operations with timeout.\"\"\"\n\n    def __init__(\n        self,\n        max_attempts: int = 3,\n        delay: float = 1.0,\n        backoff: float = 2.0,\n        timeout: float = 120.0,\n    ) -> None:\n        \"\"\"Initialize the retryable operation context manager.\n\n        Args:\n            max_attempts: Maximum number of retry attempts\n            delay: Initial delay in seconds\n            backoff: Multiplier for delay\n            timeout: Total timeout in seconds\n        \"\"\"\n        self.max_attempts = max_attempts\n        self.delay = delay\n        self.backoff = backoff\n        self.timeout = timeout\n        self.start_time: float = 0.0\n        self.attempt_count: int = 0\n\n    def __enter__(self) -> \"RetryableOperation\":\n        \"\"\"Enter the context and record start time.\"\"\"\n        self.start_time = time.time()\n        return self\n\n    def __exit__(self, exc_type: Any, exc_val: Any, exc_tb: Any) -> bool:\n        \"\"\"Exit the context and handle retries.\"\"\"\n        if exc_type is None:\n            return False\n\n        self.attempt_count += 1\n\n        if self.attempt_count < self.max_attempts:\n            elapsed = time.time() - self.start_time\n            if elapsed + self.delay > self.timeout:\n                logger.error(f\"Operation would exceed timeout of {self.timeout}s\")\n                raise ProviderTimeoutError(\n                    f\"Operation did not complete within {self.timeout} seconds\"\n                ) from exc_val\n\n            logger.warning(\n                f\"Attempt {self.attempt_count}/{self.max_attempts} failed: {exc_val}. \"\n                f\"Retrying in {self.delay}s...\"\n            )\n            time.sleep(self.delay)\n            self.delay *= self.backoff\n            return True\n\n        return False","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/providers/retry.py"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/k8s_provider.py\">\nERROR [46:32] \"CoreV1Api\" is not a known attribute of \"None\"\nERROR [47:32] \"AppsV1Api\" is not a known attribute of \"None\"\nERROR [56:23] \"ConfigException\" is not a known attribute of \"None\"\nERROR [53:24] \"load_kube_config\" is not a known attribute of \"None\"\nERROR [55:24] \"load_kube_config\" is not a known attribute of \"None\"\nERROR [59:27] \"ConfigException\" is not a known attribute of \"None\"\nERROR [58:24] \"load_incluster_config\" is not a known attribute of \"None\"\nERROR [70:18] Cannot access attribute \"status\" for class \"Exception\"\n  Attribute \"status\" is unknown\nERROR [71:36] \"V1Namespace\" is not a known attribute of \"None\"\nERROR [72:37] \"V1ObjectMeta\" is not a known attribute of \"None\"\nERROR [95:20] \"V1EnvVar\" is not a known attribute of \"None\"\nERROR [98:28] \"V1Container\" is not a known attribute of \"None\"\nERROR [101:27] \"V1ContainerPort\" is not a known attribute of \"None\"\nERROR [182:10] Variable not allowed in type expression\nERROR [137:20] \"V1EnvVar\" is not a known attribute of \"None\"\nERROR [140:28] \"V1Container\" is not a known attribute of \"None\"\nERROR [143:27] \"V1ContainerPort\" is not a known attribute of \"None\"\nERROR [147:27] \"V1PodTemplateSpec\" is not a known attribute of \"None\"\nERROR [148:29] \"V1ObjectMeta\" is not a known attribute of \"None\"\