{"type":"tool_use","timestamp":1775876148291,"sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","part":{"id":"prt_d7a7736bd001v3VH3u8ajlzgzy","messageID":"msg_d7a76a3240019CDcaCwjpVirvi","sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","type":"tool","tool":"write","callID":"toolu_tool-b384ebba9c1d43c7bf182a73b3869238","state":{"status":"completed","input":{"content":"\"\"\"Unit tests for retry mechanism.\"\"\"\n\nimport time\nimport pytest\n\nfrom agentcube.providers.retry import retry_on_exception, RetryableOperation\nfrom agentcube.providers.exceptions import ProviderTimeoutError\n\n\nclass TestRetryDecorator:\n    \"\"\"Tests for retry_on_exception decorator.\"\"\"\n\n    def test_retry_on_success(self):\n        \"\"\"Test that retry succeeds on first attempt.\"\"\"\n        call_count = 0\n\n        @retry_on_exception(max_attempts=3, delay=0.1)\n        def test_function():\n            nonlocal call_count\n            call_count += 1\n            return \"success\"\n\n        result = test_function()\n        assert result == \"success\"\n        assert call_count == 1\n\n    def test_retry_on_failure_then_success(self):\n        \"\"\"Test that retry succeeds after failures.\"\"\"\n        call_count = 0\n\n        @retry_on_exception(max_attempts=3, delay=0.1)\n        def test_function():\n            nonlocal call_count\n            call_count += 1\n            if call_count < 3:\n                raise ValueError(\"Temporary failure\")\n            return \"success\"\n\n        result = test_function()\n        assert result == \"success\"\n        assert call_count == 3\n\n    def test_retry_max_attempts_exceeded(self):\n        \"\"\"Test that retry raises after max attempts.\"\"\"\n        @retry_on_exception(max_attempts=3, delay=0.1)\n        def test_function():\n            raise ValueError(\"Persistent failure\")\n\n        with pytest.raises(ValueError, match=\"Persistent failure\"):\n            test_function()\n\n    def test_retry_with_specific_exception(self):\n        \"\"\"Test that retry only catches specified exceptions.\"\"\"\n        call_count = 0\n\n        @retry_on_exception(max_attempts=3, delay=0.1, exceptions=(ValueError,))\n        def test_function():\n            nonlocal call_count\n            call_count += 1\n            if call_count < 2:\n                raise ValueError(\"Retryable error\")\n            raise TypeError(\"Non-retryable error\")\n\n        with pytest.raises(TypeError, match=\"Non-retryable error\"):\n            test_function()\n\n        assert call_count == 2\n\n    def test_retry_with_backoff(self):\n        \"\"\"Test that retry implements exponential backoff.\"\"\"\n        call_times = []\n\n        @retry_on_exception(max_attempts=3, delay=0.1, backoff=2.0)\n        def test_function():\n            call_times.append(time.time())\n            if len(call_times) < 3:\n                raise ValueError(\"Retry me\")\n            return \"success\"\n\n        start_time = time.time()\n        test_function()\n        total_time = time.time() - start_time\n\n        assert len(call_times) == 3\n        assert total_time >= 0.3  # 0.1 + 0.2\n        assert total_time < 0.5\n\n\nclass TestRetryableOperation:\n    \"\"\"Tests for RetryableOperation context manager.\"\"\"\n\n    def test_retryable_operation_success(self):\n        \"\"\"Test RetryableOperation on success.\"\"\"\n        operation = RetryableOperation(max_attempts=3, delay=0.1)\n\n        with operation:\n            pass\n\n        assert operation.attempt_count == 0\n\n    def test_retryable_operation_retry(self):\n        \"\"\"Test RetryableOperation with retries.\"\"\"\n        call_count = 0\n\n        operation = RetryableOperation(max_attempts=3, delay=0.1)\n\n        def failing_operation():\n            nonlocal call_count\n            call_count += 1\n            if call_count < 3:\n                raise ValueError(\"Retry me\")\n\n        with operation:\n            failing_operation()\n\n        assert call_count == 3\n        assert operation.attempt_count == 3\n\n    def test_retryable_operation_max_attempts(self):\n        \"\"\"Test RetryableOperation max attempts.\"\"\"\n        operation = RetryableOperation(max_attempts=3, delay=0.1)\n\n        def always_failing_operation():\n            raise ValueError(\"Always fail\")\n\n        with pytest.raises(ValueError):\n            with operation:\n                always_failing_operation()\n\n        assert operation.attempt_count == 3\n\n    def test_retryable_operation_timeout(self):\n        \"\"\"Test RetryableOperation timeout.\"\"\"\n        operation = RetryableOperation(max_attempts=10, delay=0.1, timeout=0.3)\n\n        def slow_operation():\n            raise ValueError(\"Slow failure\")\n\n        with pytest.raises(ProviderTimeoutError):\n            with operation:\n                slow_operation()\n\n    def test_retryable_operation_backoff(self):\n        \"\"\"Test RetryableOperation backoff.\"\"\"\n        call_times = []\n\n        operation = RetryableOperation(max_attempts=3, delay=0.1, backoff=2.0)\n\n        def failing_operation():\n            call_times.append(time.time())\n            raise ValueError(\"Fail\")\n\n        start_time = time.time()\n        with pytest.raises(ValueError):\n            with operation:\n                failing_operation()\n        total_time = time.time() - start_time\n\n        assert len(call_times) == 3\n        assert total_time >= 0.3  # 0.1 + 0.2","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_providers_retry.py"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/k8s_provider.py\">\nERROR [46:32] \"CoreV1Api\" is not a known attribute of \"None\"\nERROR [47:32] \"AppsV1Api\" is not a known attribute of \"N