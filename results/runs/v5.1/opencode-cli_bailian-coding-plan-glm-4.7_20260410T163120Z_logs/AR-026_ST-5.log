{"type":"tool_use","timestamp":1775875976491,"sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","part":{"id":"prt_d7a74e6fc001P2TfQOVMwMX3Mk","messageID":"msg_d7a749fcf001nYYCbVKDAcTmRr","sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","type":"tool","tool":"write","callID":"toolu_tool-ec2b76ee8b1a4175897a6c5cd1fa5f73","state":{"status":"completed","input":{"content":"\"\"\"Provider factory for creating provider instances.\"\"\"\n\nimport logging\nfrom typing import Any, Dict, List, Type\n\nfrom agentcube.providers.base import BaseProvider\nfrom agentcube.providers.k8s_provider import KubernetesProvider\nfrom agentcube.providers.agentcube_provider import AgentCubeProvider\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass ProviderFactory:\n    \"\"\"Factory for creating provider instances.\"\"\"\n\n    _providers: Dict[str, Type[BaseProvider]] = {}\n\n    @classmethod\n    def register(cls, provider_type: str, provider_class: Type[BaseProvider]) -> None:\n        \"\"\"Register a provider class.\n\n        Args:\n            provider_type: Provider type identifier\n            provider_class: Provider class to register\n\n        Example:\n            ProviderFactory.register(\"my-provider\", MyProvider)\n        \"\"\"\n        cls._providers[provider_type] = provider_class\n        logger.info(f\"Registered provider: {provider_type}\")\n\n    @classmethod\n    def unregister(cls, provider_type: str) -> None:\n        \"\"\"Unregister a provider class.\n\n        Args:\n            provider_type: Provider type identifier\n\n        Raises:\n            ValueError: If provider type is not registered\n        \"\"\"\n        if provider_type not in cls._providers:\n            raise ValueError(f\"Provider type '{provider_type}' is not registered\")\n\n        del cls._providers[provider_type]\n        logger.info(f\"Unregistered provider: {provider_type}\")\n\n    @classmethod\n    def create(\n        cls,\n        provider_type: str,\n        **kwargs: Any,\n    ) -> BaseProvider:\n        \"\"\"Create a provider instance.\n\n        Args:\n            provider_type: Provider type identifier\n            **kwargs: Provider initialization parameters\n\n        Returns:\n            BaseProvider: Provider instance\n\n        Raises:\n            ValueError: If provider type is not registered\n\n        Example:\n            provider = ProviderFactory.create(\"k8s\", namespace=\"default\", verbose=True)\n        \"\"\"\n        if provider_type not in cls._providers:\n            available = list(cls._providers.keys())\n            raise ValueError(\n                f\"Unknown provider type: {provider_type}. \"\n                f\"Available providers: {available}\"\n            )\n\n        provider_class = cls._providers[provider_type]\n        return provider_class(**kwargs)\n\n    @classmethod\n    def list_providers(cls) -> List[str]:\n        \"\"\"List all registered provider types.\n\n        Returns:\n            List[str]: List of provider type identifiers\n\n        Example:\n            providers = ProviderFactory.list_providers()\n            print(f\"Available providers: {providers}\")\n        \"\"\"\n        return list(cls._providers.keys())\n\n    @classmethod\n    def is_registered(cls, provider_type: str) -> bool:\n        \"\"\"Check if a provider type is registered.\n\n        Args:\n            provider_type: Provider type identifier\n\n        Returns:\n            bool: True if registered, False otherwise\n\n        Example:\n            if ProviderFactory.is_registered(\"k8s\"):\n                provider = ProviderFactory.create(\"k8s\")\n        \"\"\"\n        return provider_type in cls._providers\n\n\n# Register default providers\nProviderFactory.register(\"k8s\", KubernetesProvider)\nProviderFactory.register(\"agentcube\", AgentCubeProvider)","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/providers/factory.py"},"output":"Wrote file 