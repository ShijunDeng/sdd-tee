{"type":"tool_use","timestamp":1775876148325,"sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","part":{"id":"prt_d7a775b2c001WkxN48OK59qITD","messageID":"msg_d7a76a3240019CDcaCwjpVirvi","sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","type":"tool","tool":"write","callID":"toolu_tool-d649503f7ad0400e922d1f6f2813a8fd","state":{"status":"completed","input":{"content":"\"\"\"Unit tests for provider factory.\"\"\"\n\nimport pytest\n\nfrom agentcube.providers.factory import ProviderFactory\nfrom agentcube.providers.base import BaseProvider\n\n\nclass MockProvider(BaseProvider):\n    \"\"\"Mock provider for testing.\"\"\"\n\n    def __init__(self, **kwargs):\n        self.kwargs = kwargs\n        super().__init__(\n            namespace=kwargs.get(\"namespace\", \"default\"),\n            verbose=kwargs.get(\"verbose\", False),\n            kubeconfig=kwargs.get(\"kubeconfig\"),\n            timeout=kwargs.get(\"timeout\", 120),\n        )\n\n    def deploy(self, agent_name: str, image_url: str, port: int, **kwargs):\n        pass\n\n    def get_status(self, agent_name: str):\n        pass\n\n    def delete(self, agent_name: str):\n        pass\n\n    def get_provider_type(self) -> str:\n        return \"mock\"\n\n\nclass TestProviderFactory:\n    \"\"\"Tests for ProviderFactory.\"\"\"\n\n    def setup_method(self):\n        \"\"\"Setup test method.\"\"\"\n        if ProviderFactory.is_registered(\"mock\"):\n            ProviderFactory.unregister(\"mock\")\n\n    def teardown_method(self):\n        \"\"\"Teardown test method.\"\"\"\n        if ProviderFactory.is_registered(\"mock\"):\n            ProviderFactory.unregister(\"mock\")\n\n    def test_register_provider(self):\n        \"\"\"Test registering a provider.\"\"\"\n        ProviderFactory.register(\"mock\", MockProvider)\n        assert ProviderFactory.is_registered(\"mock\")\n        assert \"mock\" in ProviderFactory.list_providers()\n\n    def test_unregister_provider(self):\n        \"\"\"Test unregistering a provider.\"\"\"\n        ProviderFactory.register(\"mock\", MockProvider)\n        ProviderFactory.unregister(\"mock\")\n        assert not ProviderFactory.is_registered(\"mock\")\n        assert \"mock\" not in ProviderFactory.list_providers()\n\n    def test_unregister_nonexistent_provider(self):\n        \"\"\"Test unregistering a non-existent provider.\"\"\"\n        with pytest.raises(ValueError, match=\"not registered\"):\n            ProviderFactory.unregister(\"nonexistent\")\n\n    def test_create_provider(self):\n        \"\"\"Test creating a provider instance.\"\"\"\n        ProviderFactory.register(\"mock\", MockProvider)\n        provider = ProviderFactory.create(\"mock\", namespace=\"test\", verbose=True)\n\n        assert isinstance(provider, MockProvider)\n        assert provider.namespace == \"test\"\n        assert provider.verbose is True\n\n    def test_create_provider_unknown_type(self):\n        \"\"\"Test creating a provider with unknown type.\"\"\"\n        with pytest.raises(ValueError, match=\"Unknown provider type\"):\n            ProviderFactory.create(\"unknown\")\n\n    def test_list_providers(self):\n        \"\"\"Test listing all providers.\"\"\"\n        ProviderFactory.register(\"mock\", MockProvider)\n        providers = ProviderFactory.list_providers()\n\n        assert isinstance(providers, list)\n        assert \"mock\" in providers\n\n    def test_is_registered(self):\n        \"\"\"Test checking if provider is registered.\"\"\"\n        ProviderFactory.register(\"mock\", MockProvider)\n\n        assert ProviderFactory.is_registered(\"mock\")\n        assert not ProviderFactory.is_registered(\"other\")\n\n    def test_default_providers_registered(self):\n        \"\"\"Test that default providers are registered.\"\"\"\n        providers = ProviderFactory.list_providers()\n        assert \"k8s\" in providers\n        assert \"agentcube\" in providers","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7