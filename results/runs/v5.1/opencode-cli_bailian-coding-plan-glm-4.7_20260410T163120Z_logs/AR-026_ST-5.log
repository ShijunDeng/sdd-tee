{"type":"tool_use","timestamp":1775875998339,"sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","part":{"id":"prt_d7a753ccb001jK41xKzMi6ccLy","messageID":"msg_d7a74ed60001FH3zdbspjlQYaW","sessionID":"ses_2858e4900ffeHni7jjmb7lEFcK","type":"tool","tool":"write","callID":"toolu_tool-1ad1b6ba078940888d12f7553bb176e9","state":{"status":"completed","input":{"content":"\"\"\"Status and event monitoring for providers.\"\"\"\n\nimport logging\nimport time\nfrom datetime import datetime\nfrom typing import Any, Callable, Dict, List, Optional\n\nfrom agentcube.providers.base import BaseProvider, AgentStatus, ProviderStatus\nfrom agentcube.providers.exceptions import ProviderError, ProviderTimeoutError\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass StatusMonitor:\n    \"\"\"Monitor agent status with polling capabilities.\"\"\"\n\n    def __init__(\n        self,\n        provider: BaseProvider,\n        agent_name: str,\n        poll_interval: int = 5,\n    ) -> None:\n        \"\"\"Initialize the status monitor.\n\n        Args:\n            provider: Provider instance\n            agent_name: Name of the agent to monitor\n            poll_interval: Polling interval in seconds\n        \"\"\"\n        self.provider = provider\n        self.agent_name = agent_name\n        self.poll_interval = poll_interval\n        self._monitoring = False\n\n    def monitor(\n        self,\n        duration: Optional[int] = None,\n        callback: Optional[Callable[[AgentStatus], None]] = None,\n    ) -> List[AgentStatus]:\n        \"\"\"Monitor agent status for a specified duration.\n\n        Args:\n            duration: Duration to monitor in seconds (None for infinite)\n            callback: Callback function called on each status update\n\n        Returns:\n            List[AgentStatus]: History of agent statuses\n\n        Example:\n            monitor = StatusMonitor(provider, \"my-agent\")\n            def on_status(status):\n                print(f\"Status: {status.status}\")\n            history = monitor.monitor(duration=60, callback=on_status)\n        \"\"\"\n        self._monitoring = True\n        status_history: List[AgentStatus] = []\n\n        start_time = datetime.now()\n\n        while self._monitoring:\n            try:\n                status = self.provider.get_status(self.agent_name)\n                status_history.append(status)\n\n                if callback:\n                    callback(status)\n\n                if status.status in [ProviderStatus.FAILED, ProviderStatus.ERROR]:\n                    logger.error(f\"Agent {self.agent_name} failed or errored\")\n                    break\n\n                if duration and (datetime.now() - start_time).total_seconds() >= duration:\n                    break\n\n            except Exception as e:\n                logger.error(f\"Error monitoring agent {self.agent_name}: {e}\")\n                status_history.append(\n                    AgentStatus(\n                        status=ProviderStatus.ERROR,\n                        agent_name=self.agent_name,\n                        namespace=self.provider.namespace,\n                        error=str(e),\n                    )\n                )\n\n            time.sleep(self.poll_interval)\n\n        self._monitoring = False\n        return status_history\n\n    def stop(self) -> None:\n        \"\"\"Stop monitoring.\"\"\"\n        self._monitoring = False\n        logger.info(f\"Stopped monitoring agent {self.agent_name}\")\n\n    def wait_for_status(\n        self,\n        target_status: ProviderStatus,\n        timeout: int = 120,\n    ) -> AgentStatus:\n        \"\"\"Wait for agent to reach target status.\n\n        Args:\n            target_status: Target status to wait for\n            timeout: Timeout in seconds\n\n        Returns:\n            AgentStatus: Final agent status\n\n        Raises:\n            ProviderTimeoutError: If timeout is reached\n            ProviderError: If agent reaches failed/error state\n\n        Example:\n            monitor = StatusMonitor(provider, \"my-agent\")\n            status = monitor.wait_for_status(ProviderStatus.RUNNING, timeout=60)\n        \"\"\"\n        start_time = datetime.now()\n\n        while (datetime.now() - start_time).total_seconds() < timeout:\n            status = self.provider.get_status(self.agent_name)\n\n            if status.status == target_status:\n                return status\n\n            if status.status in [ProviderStatus.FAILED, ProviderStatus.ERROR]:\n                raise ProviderError(\n                    f\"Agent {self.agent_name} failed or errored: {status.error}\"\n                )\n\n            time.sleep(self.poll_interval)\n\n        raise ProviderTimeoutError(\n            f\"Agent {self.agent_name} did not reach status {target_status} \"\n            f\"within {timeout} seconds\"\n        )\n\n\nclass EventMonitor:\n    \"\"\"Monitor Kubernetes events and pod logs.\"\"\"\n\n    def __init__(\n        self,\n        provider: BaseProvider,\n        agent_name: str,\n    ) -> None:\n        \"\"\"Initialize the event monitor.\n\n        Args:\n            provider: Provider instance (must be KubernetesProvider)\n            agent_name: Name of the agent to monitor\n        \"\"\"\n        self.provider = provider\n        self.agent_name = agent_name\n\n        if provider.get_provider_type() != \"k8s\":\n            logger.warning(\n                f\"EventMonitor requires KubernetesProvider, got {provider.get_provider_type()}\"\n            )\n\n    def get_events(\n        self,\n        since: Optional[datetime] = None,\n    ) -> List[Dict[str, Any]]:\n        \"\"\"Get Kubernetes events for the agent.\n\n        Args:\n            since: Only return events after this timestamp\n\n        Returns:\n            List[Dict[str, Any]]: List of events\n\n        Example:\n            monitor = EventMonitor(provider, \"my-agent\")\n            events = monitor.get_events(since=datetime.now() - timedelta(hours=1))\n        \"\"\"\n        if self.provider.get_provider_type() != \"k8s\":\n            return []\n\n        try:\n            from kubernetes import client\n            from kubernetes.client.rest import ApiException\n        except ImportError:\n            logger.error(\"Kubernetes client not available\")\n            return []\n\n        try:\n            sanitized_name = self.provider._sanitize_name(self.agent_name)\n            core_v1 = client.CoreV1Api()\n\n            events = core_v1.list_namespaced_event(\n                self.provider.namespace,\n                field_selector=f\"involvedObject.name={sanitized_name}\",\n            )\n\n            event_list: List[Dict[str, Any]] = []\n            for event in events.items:\n                if since and event.last_timestamp and event.last_timestamp < since:\n                    continue\n\n                event_list.append({\n                    \"type\": event.type,\n                    \"reason\": event.reason,\n                    \"message\": event.message,\n                    \"timestamp\": event.last_timestamp,\n                })\n\n            return event_list\n\n        except ApiException as e:\n            logger.error(f\"Failed to get events: {e}\")\n            return []\n\n    def get_pod_logs(\n        self,\n        container_name: Optional[str] = None,\n        tail_lines: int = 100,\n    ) -> List[str]:\n        \"\"\"Get logs from agent pods.\n\n        Args:\n            container_name: Name of container (None for all)\n            tail_lines: Number of lines to retrieve from end of logs\n\n        Returns:\n            List[str]: Log lines\n\n        Example:\n            monitor = EventMonitor(provider, \"my-agent\")\n            logs = monitor.get_pod_logs(tail_lines=50)\n        \"\"\"\n        if self.provider.get_provider_type() != \"k8s\":\n            return []\n\n        try:\n            from kubernetes import client\n            from kubernetes.client.rest import ApiException\n        except ImportError:\n            logger.error(\"Kubernetes client not available\")\n            return []\n\n        try:\n            sanitized_name = self.provider._sanitize_name(self.agent_name)\n            core_v1 = client.CoreV1Api()\n\n            pods = core_v1.list_namespaced_pod(\n                self.provider.namespace,\n                label_selector=f\"app={sanitized_name}\",\n            )\n\n            logs: List[str] = []\n            for pod in pods.items:\n                try:\n                    pod_logs = core_v1.read_namespaced_pod_log(\n                        pod.metadata.name,\n                        self.provider.namespace,\n                        container=container_name,\n                        tail_lines=tail_lines,\n                    )\n                    logs.append(f\"=== Pod: {pod.metadata.name} ===\")\n                    logs.extend(pod_logs.split(\"\\n\"))\n                except ApiException as e:\n                    logger.warning(f\"Failed to get logs for pod {pod.metadata.name}: {e}\")\n\n            return logs\n\n        except ApiException as e:\n            logger.error(f\"Failed to get pods: {e}\")\n            return []","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/providers/monitoring.py"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/k8s_provider.py\">\nERROR [46:32] \"CoreV1Api\" is not a known attribute of \"None\"\nERROR [47:32] \"AppsV1Api\" is not a known attribute of \"None\"\nERROR [56:23] \"ConfigException\" is not a known attribute of \"None\"\nERROR [53:24] \"load_kube_config\" is not a known attribute of \"None\"\nERROR [55:24] \"load_kube_config\" is not a known attribute of \"None\"\nERROR [59:27] \"ConfigException\" is not a known