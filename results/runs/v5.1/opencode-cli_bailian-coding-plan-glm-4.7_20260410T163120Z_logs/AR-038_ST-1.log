\t\t\t},\n141: \t\t},\n142: \t}\n143: }\n144: \n145: func TestSandboxController_CreateAgentRuntimeSandbox(t *testing.T) {\n146: \ts := miniredis.RunT(t)\n147: \n148: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n149: \trequire.NoError(t, err)\n150: \tdefer redisStore.Close()\n151: \n152: \tctx := context.Background()\n153: \n154: \tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n155: \t\tmockK8s := new(MockK8sClient)\n156: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n157: \n158: \t\treq := &api.CreateSandboxRequest{\n159: \t\t\tName:      \"test-runtime\",\n160: \t\t\tNamespace: \"default\",\n161: \t\t}\n162: \n163: \t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n164: \t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n165: \n166: \t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n167: \t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n168: \t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.5\", nil)\n169: \n170: \t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n171: \n172: \t\trequire.NoError(t, err)\n173: \t\trequire.NotNil(t, resp)\n174: \t\tassert.NotEmpty(t, resp.SessionID)\n175: \t\tassert.NotEmpty(t, resp.SandboxID)\n176: \t\tassert.NotEmpty(t, resp.SandboxName)\n177: \t\tassert.Contains(t, resp.SandboxName, \"test-runtime-\")\n178: \t\tassert.NotEmpty(t, resp.EntryPoints)\n179: \t\tassert.Len(t, resp.EntryPoints, 1)\n180: \t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n181: \t\tassert.Equal(t, \"10.244.1.5:8080\", resp.EntryPoints[0].Endpoint)\n182: \t\tassert.NotEmpty(t, resp.CreatedAt)\n183: \t\tassert.NotEmpty(t, resp.ExpiresAt)\n184: \n185: \t\tmockK8s.AssertExpectations(t)\n186: \n187: \t\tsandboxInfo, err := redisStore.GetSandbox(ctx, resp.SessionID)\n188: \t\trequire.NoError(t, err)\n189: \t\tassert.Equal(t, resp.SessionID, sandboxInfo.SessionID)\n190: \t\tassert.Equal(t, \"running\", sandboxInfo.Status)\n191: \t\tassert.Equal(t, \"10.244.1.5\", sandboxInfo.PodIP)\n192: \t})\n193: \n194: \tt.Run(\"agent runtime not found\", func(t *testing.T) {\n195: \t\tmockK8s := new(MockK8sClient)\n196: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n197: \n198: \t\treq := &api.CreateSandboxRequest{\n199: \t\t\tName:      \"nonexistent\",\n200: \t\t\tNamespace: \"default\",\n201: \t\t}\n202: \n203: \t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"agentruntimes\"), \"nonexistent\")\n204: \t\tmockK8s.On(\"GetAgentRuntime\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n205: \n206: \t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n207: \n208: \t\trequire.Error(t, err)\n209: \t\tassert.Nil(t, resp)\n210: \t\tassert.Contains(t, err.Error(), \"not found\")\n211: \n212: \t\tmockK8s.AssertExpectations(t)\n213: \t})\n214: \n215: \tt.Run(\"failed to create sandbox\", func(t *testing.T) {\n216: \t\tmockK8s := new(MockK8sClient)\n217: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n218: \n219: \t\treq := &api.CreateSandboxRequest{\n220: \t\t\tName:      \"test-runtime\",\n221: \t\t\tNamespace: \"default\",\n222: \t\t}\n223: \n224: \t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n225: \t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n226: \n227: \t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n228: \t\tmockK8s.On(\"CreateSandbox\", mock.Anything, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n229: \t\tmockK8s.On(\"GetPodIP\", mock.Anything, mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"\", assert.AnError).Once()\n230: \t\tmockK8s.On(\"DeleteSandbox\", mock.Anything, \"default\", mock.MatchedBy(func(s string) bool { return true })).Return(nil).Maybe()\n231: \n232: \t\tctx, cancel := context.WithTimeout(ctx, 100*time.Millisecond)\n233: \t\tdefer cancel()\n234: \n235: \t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n236: \n237: \t\trequire.Error(t, err)\n238: \t\tassert.Nil(t, resp)\n239: \t\tassert.Contains(t, err.Error(), \"timed out\")\n240: \n241: \t\tmockK8s.AssertExpectations(t)\n242: \t})\n243: }\n244: \n245: func TestSandboxController_CreateCodeInterpreterSandbox(t *testing.T) {\n246: \ts := miniredis.RunT(t)\n247: \n248: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n249: \trequire.NoError(t, err)\n250: \tdefer redisStore.Close()\n251: \n252: \tctx := context.Background()\n253: \n254: \tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n255: \t\tmockK8s := new(MockK8sClient)\n256: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n257: \n258: \t\treq := &api.CreateSandboxRequest{\n259: \t\t\tName:      \"test-interpreter\",\n260: \t\t\tNamespace: \"default\",\n261: \t\t}\n262: \n263: \t\tcodeInterpreter := createCodeInterpreter(\"test-interpreter\", \"default\")\n264: \t\tsandboxCR := createSandboxCR(\"test-interpreter-12345678\", \"default\", \"session-123\", \"test-interpreter\")\n265: \n266: \t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"test-interpreter\").Return(codeInterpreter, nil)\n267: \t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n268: \t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.6\", nil)\n269: \n270: \t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n271: \n272: \t\trequire.NoError(t, err)\n273: \t\trequire.NotNil(t, resp)\n274: \t\tassert.NotEmpty(t, resp.SessionID)\n275: \t\tassert.NotEmpty(t, resp.SandboxID)\n276: \t\tassert.NotEmpty(t, resp.SandboxName)\n277: \t\tassert.Contains(t, resp.SandboxName, \"test-interpreter-\")\n278: \t\tassert.NotEmpty(t, resp.EntryPoints)\n279: \t\tassert.Len(t, resp.EntryPoints, 1)\n280: \t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n281: \t\tassert.Equal(t, \"10.244.1.6:8080\", resp.EntryPoints[0].Endpoint)\n282: \n283: \t\tmockK8s.AssertExpectations(t)\n284: \n285: \t\tsandboxInfo, err := redisStore.GetSandbox(ctx, resp.SessionID)\n286: \t\trequire.NoError(t, err)\n287: \t\tassert.Equal(t, \"CodeInterpreter\", sandboxInfo.Kind)\n288: \t\tassert.Equal(t, \"running\", sandboxInfo.Status)\n289: \t})\n290: \n291: \tt.Run(\"code interpreter not found\", func(t *testing.T) {\n292: \t\tmockK8s := new(MockK8sClient)\n293: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n294: \n295: \t\treq := &api.CreateSandboxRequest{\n296: \t\t\tName:      \"nonexistent\",\n297: \t\t\tNamespace: \"default\",\n298: \t\t}\n299: \n300: \t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"codeinterpreters\"), \"nonexistent\")\n301: \t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n302: \n303: \t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n304: \n305: \t\trequire.Error(t, err)\n306: \t\tassert.Nil(t, resp)\n307: \t\tassert.Contains(t, err.Error(), \"not found\")\n308: \n309: \t\tmockK8s.AssertExpectations(t)\n310: \t})\n311: \n312: \tt.Run(\"code interpreter without ports uses default\", func(t *testing.T) {\n313: \t\tmockK8s := new(MockK8sClient)\n314: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n315: \n316: \t\treq := &api.CreateSandboxRequest{\n317: \t\t\tName:      \"test-interpreter-no-ports\",\n318: \t\t\tNamespace: \"default\",\n319: \t\t}\n320: \n321: \t\tcodeInterpreter := &unstructured.Unstructured{\n322: \t\t\tObject: map[string]interface{}{\n323: \t\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n324: \t\t\t\t\"kind\":       \"CodeInterpreter\",\n325: \t\t\t\t\"metadata\": map[string]interface{}{\n326: \t\t\t\t\t\"name\":      \"test-interpreter-no-ports\",\n327: \t\t\t\t\t\"namespace\": \"default\",\n328: \t\t\t\t},\n329: \t\t\t\t\"spec\": map[string]interface{}{\n330: \t\t\t\t\t\"template\": map[string]interface{}{\n331: \t\t\t\t\t\t\"image\": \"python:3.11-slim\",\n332: \t\t\t\t\t},\n333: \t\t\t\t},\n334: \t\t\t},\n335: \t\t}\n336: \n337: \t\tsandboxCR := createSandboxCR(\"test-interpreter-no-ports-12345678\", \"default\", \"session-123\", \"test-interpreter-no-ports\")\n338: \n339: \t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"test-interpreter-no-ports\").Return(codeInterpreter, nil)\n340: \t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n341: \t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.7\", nil)\n342: \n343: \t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n344: \n345: \t\trequire.NoError(t, err)\n346: \t\trequire.NotNil(t, resp)\n347: \t\tassert.Len(t, resp.EntryPoints, 1)\n348: \t\tassert.Equal(t, int32(8080), resp.EntryPoints[0].Port)\n349: \t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n350: \n351: \t\tmockK8s.AssertExpectations(t)\n352: \t})\n353: }\n354: \n355: func TestSandboxController_GetSession(t *testing.T) {\n356: \ts := miniredis.RunT(t)\n357: \n358: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n359: \trequire.NoError(t, err)\n360: \tdefer redisStore.Close()\n361: \n362: \tctx := context.Background()\n363: \tmockK8s := new(MockK8sClient)\n364: \tcontroller := NewSandboxController(mockK8s, redisStore)\n365: \n366: \tt.Run(\"successfully gets session\", func(t *testing.T) {\n367: \t\tsessionID := \"test-session-1\"\n368: \t\tsandboxInfo := &types.SandboxInfo{\n369: \t\t\tSessionID:    sessionID,\n370: \t\t\tSandboxID:    \"sandbox-123\",\n371: \t\t\tSandboxName:  \"test-sandbox\",\n372: \t\t\tWorkloadName: \"test-workload\",\n373: \t\t\tNamespace:    \"default\",\n374: \t\t\tKind:         \"AgentRuntime\",\n375: \t\t\tStatus:       \"running\",\n376: \t\t\tCreatedAt:    time.Now(),\n377: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n378: \t\t\tPodIP:        \"10.244.1.5\",\n379: \t\t\tEntryPoints: []types.SandboxEntryPoint{\n380: \t\t\t\t{\n381: \t\t\t\t\tProtocol: \"HTTP\",\n382: \t\t\t\t\tEndpoint: \"10.244.1.5:8080\",\n383: \t\t\t\t\tPath:     \"/\",\n384: \t\t\t\t},\n385: \t\t\t},\n386: \t\t\tLastActivityAt: time.Now(),\n387: \t\t}\n388: \n389: \t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n390: \t\trequire.NoError(t, err)\n391: \n392: \t\tresp, err := controller.GetSession(ctx, sessionID)\n393: \n394: \t\trequire.NoError(t, err)\n395: \t\trequire.NotNil(t, resp)\n396: \t\tassert.Equal(t, sessionID, resp.SessionID)\n397: \t\tassert.Equal(t, \"sandbox-123\", resp.SandboxID)\n398: \t\tassert.Equal(t, \"test-sandbox\", resp.SandboxName)\n399: \t\tassert.Equal(t, \"AgentRuntime\", resp.Kind)\n400: \t\tassert.Equal(t, \"default\", resp.Namespace)\n401: \t\tassert.Equal(t, \"test-workload\", resp.Name)\n402: \t\tassert.Len(t, resp.EntryPoints, 1)\n403: \t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n404: \t\tassert.Equal(t, \"10.244.1.5\", resp.PodIP)\n405: \t})\n406: \n407: \tt.Run(\"session not found\", func(t *testing.T) {\n408: \t\tresp, err := controller.GetSession(ctx, \"nonexistent-session\")\n409: \n410: \t\trequire.Error(t, err)\n411: \t\tassert.Nil(t, resp)\n412: \t\tassert.Contains(t, err.Error(), \"not found\")\n413: \t})\n414: }\n415: \n416: func TestSandboxController_DeleteSession(t *testing.T) {\n417: \ts := miniredis.RunT(t)\n418: \n419: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n420: \trequire.NoError(t, err)\n421: \tdefer redisStore.Close()\n422: \n423: \tctx := context.Background()\n424: \n425: \tt.Run(\"successfully deletes session\", func(t *testing.T) {\n426: \t\tmockK8s := new(MockK8sClient)\n427: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n428: \n429: \t\tsessionID := \"test-session-delete\"\n430: \t\tsandboxInfo := &types.SandboxInfo{\n431: \t\t\tSessionID:    sessionID,\n432: \t\t\tSandboxID:    \"sandbox-123\",\n433: \t\t\tSandboxName:  \"test-sandbox\",\n434: \t\t\tWorkloadName: \"test-workload\",\n435: \t\t\tNamespace:    \"default\",\n436: \t\t\tKind:         \"AgentRuntime\",\n437: \t\t\tStatus:       \"running\",\n438: \t\t\tCreatedAt:    time.Now(),\n439: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n440: \t\t}\n441: \n442: \t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n443: \t\trequire.NoError(t, err)\n444: \n445: \t\tmockK8s.On(\"DeleteSandbox\", ctx, \"default\", \"test-sandbox\").Return(nil)\n446: \n447: \t\tresp, err := controller.DeleteSession(ctx, sessionID)\n448: \n449: \t\trequire.NoError(t, err)\n450: \t\trequire.NotNil(t, resp)\n451: \t\tassert.Equal(t, sessionID, resp.SessionID)\n452: \t\tassert.NotEmpty(t, resp.DeletedAt)\n453: \n454: \t\tmockK8s.AssertExpectations(t)\n455: \n456: \t\t_, err = redisStore.GetSandbox(ctx, sessionID)\n457: \t\tassert.Error(t, err)\n458: \t\tassert.Equal(t, store.ErrNotFound, err)\n459: \t})\n460: \n461: \tt.Run(\"session not found\", func(t *testing.T) {\n462: \t\tmockK8s := new(MockK8sClient)\n463: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n464: \n465: \t\tresp, err := controller.DeleteSession(ctx, \"nonexistent-session\")\n466: \n467: \t\trequire.Error(t, err)\n468: \t\tassert.Nil(t, resp)\n469: \t\tassert.Contains(t, err.Error(), \"not found\")\n470: \t})\n471: \n472: \tt.Run(\"k8s delete fails but store cleanup succeeds\", func(t *testing.T) {\n473: \t\tmockK8s := new(MockK8sClient)\n474: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n475: \t\tsessionID := \"test-session-fail-k8s\"\n476: \t\tsandboxInfo := &types.SandboxInfo{\n477: \t\t\tSessionID:    sessionID,\n478: \t\t\tSandboxID:    \"sandbox-123\",\n479: \t\t\tSandboxName:  \"test-sandbox\",\n480: \t\t\tWorkloadName: \"test-workload\",\n481: \t\t\tNamespace:    \"default\",\n482: \t\t\tKind:         \"AgentRuntime\",\n483: \t\t\tStatus:       \"running\",\n484: \t\t\tCreatedAt:    time.Now(),\n485: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n486: \t\t}\n487: \n488: \t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n489: \t\trequire.NoError(t, err)\n490: \n491: \t\tmockK8s.On(\"DeleteSandbox\", ctx, \"default\", \"test-sandbox\").Return(assert.AnError)\n492: \n493: \t\tresp, err := controller.DeleteSession(ctx, sessionID)\n494: \n495: \t\trequire.Error(t, err)\n496: \t\tassert.Nil(t, resp)\n497: \t\tassert.Contains(t, err.Error(), \"failed to delete sandbox\")\n498: \n499: \t\tmockK8s.AssertExpectations(t)\n500: \t})\n501: }\n502: \n503: func extractSessionIDFromName(name string) string {\n504: \treturn \"session-\" + name\n505: }\n506: \n507: func TestBuildAgentRuntimeSandboxCR(t *testing.T) {\n508: \ts := miniredis.RunT(t)\n509: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n510: \trequire.NoError(t, err)\n511: \tdefer redisStore.Close()\n512: \n513: \tmockK8s := new(MockK8sClient)\n514: \tcontroller := NewSandboxController(mockK8s, redisStore)\n515: \n516: \tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n517: \n518: \tcr, err := controller.buildAgentRuntimeSandboxCR(agentRuntime, \"session-123\", \"test-runtime-abc\", \"test-runtime\", \"default\")\n519: \n520: \trequire.NoError(t, err)\n521: \trequire.NotNil(t, cr)\n522: \n523: \tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", cr.GetAPIVersion())\n524: \tassert.Equal(t, \"Sandbox\", cr.GetKind())\n525: \tassert.Equal(t, \"test-runtime-abc\", cr.GetName())\n526: \tassert.Equal(t, \"default\", cr.GetNamespace())\n527: \n528: \tlabels := cr.GetLabels()\n529: \tassert.NotNil(t, labels)\n530: \tassert.Equal(t, \"agentcube-workload-manager\", labels[\"managed-by\"])\n531: \tassert.Equal(t, \"session-123\", labels[\"runtime.agentcube.io/session-id\"])\n532: \tassert.Equal(t, \"test-runtime\", labels[\"runtime.agentcube.io/workload-name\"])\n533: \n534: \tannotations := cr.GetAnnotations()\n535: \tassert.NotNil(t, annotations)\n536: \tassert.Equal(t, \"15m\", annotations[\"runtime.agentcube.io/idle-timeout\"])\n537: }\n538: \n539: func TestBuildCodeInterpreterSandboxCR(t *testing.T) {\n540: \ts := miniredis.RunT(t)\n541: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n542: \trequire.NoError(t, err)\n543: \tdefer redisStore.Close()\n544: \n545: \tmockK8s := new(MockK8sClient)\n546: \tcontroller := NewSandboxController(mockK8s, redisStore)\n547: \n548: \tcodeInterpreter := createCodeInterpreter(\"test-interpreter\", \"default\")\n549: \n550: \tports := []interface{}{\n551: \t\tmap[string]interface{}{\n552: \t\t\t\"port\":     int64(8080),\n553: \t\t\t\"protocol\": \"HTTP\",\n554: \t\t},\n555: \t}\n556: \n557: \tcr, err := controller.buildCodeInterpreterSandboxCR(codeInterpreter, \"session-456\", \"test-interpreter-xyz\", \"test-interpreter\", \"default\", ports)\n558: \n559: \trequire.NoError(t, err)\n560: \trequire.NotNil(t, cr)\n561: \n562: \tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", cr.GetAPIVersion())\n563: \tassert.Equal(t, \"Sandbox\", cr.GetKind())\n564: \tassert.Equal(t, \"test-interpreter-xyz\", cr.GetName())\n565: \tassert.Equal(t, \"default\", cr.GetNamespace())\n566: \n567: \tlabels := cr.GetLabels()\n568: \tassert.NotNil(t, labels)\n569: \tassert.Equal(t, \"agentcube-workload-manager\", labels[\"managed-by\"])\n570: \tassert.Equal(t, \"session-456\", labels[\"runtime.agentcube.io/session-id\"])\n571: \n572: \tannotations := cr.GetAnnotations()\n573: \tassert.NotNil(t, annotations)\n574: \tassert.Equal(t, \"15m\", annotations[\"runtime.agentcube.io/idle-timeout\"])\n575: }\n576: \n577: func TestBuildEntryPoints(t *testing.T) {\n578: \ts := miniredis.RunT(t)\n579: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n580: \trequire.NoError(t, err)\n581: \tdefer redisStore.Close()\n582: \n583: \tmockK8s := new(MockK8sClient)\n584: \tcontroller := NewSandboxController(mockK8s, redisStore)\n585: \n586: \tt.Run(\"builds entry points from ports\", func(t *testing.T) {\n587: \t\tports := []interface{}{\n588: \t\t\tmap[string]interface{}{\n589: \t\t\t\t\"port\":       int64(8080),\n590: \t\t\t\t\"protocol\":   \"HTTP\",\n591: \t\t\t\t\"pathPrefix\": \"/api\",\n592: \t\t\t},\n593: \t\t\tmap[string]interface{}{\n594: \t\t\t\t\"port\":     int64(9090),\n595: \t\t\t\t\"protocol\": \"gRPC\",\n596: \t\t\t},\n597: \t\t}\n598: \n599: \t\tentryPoints := controller.buildEntryPoints(\"10.244.1.5\", ports)\n600: \n601: \t\trequire.Len(t, entryPoints, 2)\n602: \n603: \t\tassert.Equal(t, \"HTTP\", entryPoints[0].Protocol)\n604: \t\tassert.Equal(t, \"10.244.1.5:8080\", entryPoints[0].Endpoint)\n605: \t\tassert.Equal(t, \"/api\", entryPoints[0].Path)\n606: \t\tassert.Equal(t, int32(8080), entryPoints[0].Port)\n607: \n608: \t\tassert.Equal(t, \"gRPC\", entryPoints[1].Protocol)\n609: \t\tassert.Equal(t, \"10.244.1.5:9090\", entryPoints[1].Endpoint)\n610: \t\tassert.Equal(t, \"\", entryPoints[1].Path)\n611: \t\tassert.Equal(t, int32(9090), entryPoints[1].Port)\n612: \t})\n613: \n614: \tt.Run(\"handles malformed port entries\", func(t *testing.T) {\n615: \t\tports := []interface{}{\n616: \t\t\tmap[string]interface{}{\n617: \t\t\t\t\"port\":     int64(8080),\n618: \t\t\t\t\"protocol\": \"HTTP\",\n619: \t\t\t},\n620: \t\t\t\"invalid\",\n621: \t\t\tmap[string]interface{}{\n622: \t\t\t\t\"port\": int64(9090),\n623: \t\t\t},\n624: \t\t}\n625: \n626: \t\tentryPoints := controller.buildEntryPoints(\"10.244.1.5\", ports)\n627: \n628: \t\trequire.Len(t, entryPoints, 1)\n629: \t\tassert.Equal(t, \"HTTP\", entryPoints[0].Protocol)\n630: \t})\n631: }\n632: \n633: func TestGenerateSandboxName(t *testing.T) {\n634: \tname1 := generateSandboxName(\"test-runtime\")\n635: \tname2 := generateSandboxName(\"test-runtime\")\n636: \n637: \tassert.Contains(t, name1, \"test-runtime-\")\n638: \tassert.Contains(t, name2, \"test-runtime-\")\n639: \tassert.NotEqual(t, name1, name2)\n640: \tassert.Len(t, name1, len(\"test-runtime-\")+8)\n641: \tassert.Len(t, name2, len(\"test-runtime-\")+8)\n642: }\n643: \n644: func TestRandString(t *testing.T) {\n645: \tstr1 := RandString(8)\n646: \tstr2 := RandString(8)\n647: \n648: \tassert.Len(t, str1, 8)\n649: \tassert.Len(t, str2, 8)\n650: \tassert.NotEqual(t, str1, str2)\n651: \n652: \tfor _, ch := range str1 {\n653: \t\tassert.Contains(t, \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\", string(ch))\n654: \t}\n655: }\n656: \n657: func TestConvertEntryPoints(t *testing.T) {\n658: \tapiEntryPoints := []api.EntryPoint{\n659: \t\t{\n660: \t\t\tProtocol: \"HTTP\",\n661: \t\t\tEndpoint: \"10.244.1.5:8080\",\n662: \t\t\tPath:     \"/api\",\n663: \t\t\tPort:     8080,\n664: \t\t},\n665: \t}\n666: \n667: \tconverted := convertEntryPoints(apiEntryPoints)\n668: \n669: \trequire.Len(t, converted, 1)\n670: \tassert.Equal(t, \"HTTP\", converted[0].Protocol)\n671: \tassert.Equal(t, \"10.244.1.5:8080\", converted[0].Endpoint)\n672: \tassert.Equal(t, \"/api\", converted[0].Path)\n673: }\n674: \n675: func TestConvertToAPIEntryPoints(t *testing.T) {\n676: \tentryPoints := []types.SandboxEntryPoint{\n677: \t\t{\n678: \t\t\tProtocol: \"HTTP\",\n679: \t\t\tEndpoint: \"10.244.1.5:8080\",\n680: \t\t\tPath:     \"/api\",\n681: \t\t},\n682: \t}\n683: \n684: \tconverted := convertToAPIEntryPoints(entryPoints)\n685: \n686: \trequire.Len(t, converted, 1)\n687: \tassert.Equal(t, \"HTTP\", converted[0].Protocol)\n688: \tassert.Equal(t, \"10.244.1.5:8080\", converted[0].Endpoint)\n689: \tassert.Equal(t, \"/api\", converted[0].Path)\n690: }\n\n(End of file - total 690 lines)\n</content>","metadata":{"preview":"package controller\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/google/uuid\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/require\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/api\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox_test.go","time":{"start":1775891152201,"end":1775891152217}}}}
