tif apierrors.IsNotFound(err) {\n37: \t\t\tlogger.Info(\"CodeInterpreter resource not found. Ignoring since object must be deleted\")\n38: \t\t\treturn ctrl.Result{}, nil\n39: \t\t}\n40: \t\tlogger.Error(err, \"Failed to get CodeInterpreter\")\n41: \t\tRecordReconciliation(\"codeinterpreter\", req.Namespace, req.Name,\n42: \t\t\ttime.Since(startTime).Seconds(), \"error\")\n43: \t\treturn ctrl.Result{}, err\n44: \t}\n45: \n46: \tif !codeInterpreter.DeletionTimestamp.IsZero() {\n47: \t\treturn r.reconcileDelete(ctx, codeInterpreter)\n48: \t}\n49: \n50: \tif !HasFinalizer(codeInterpreter, FinalizerCodeInterpreter) {\n51: \t\tif err := AddFinalizer(ctx, r.Client, codeInterpreter, FinalizerCodeInterpreter); err != nil {\n52: \t\t\tlogger.Error(err, \"Failed to add finalizer\")\n53: \t\t\treturn ctrl.Result{Requeue: true}, err\n54: \t\t}\n55: \t\treturn ctrl.Result{}, nil\n56: \t}\n57: \n58: \tif err := r.validateSpec(codeInterpreter); err != nil {\n59: \t\tlogger.Error(err, \"Spec validation failed\")\n60: \t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeWarning, ReasonSpecInvalid, err.Error())\n61: \t\toriginalStatus := codeInterpreter.Status.DeepCopy()\n62: \t\tSetErrorCondition(&codeInterpreter.Status.Conditions, err, ReasonSpecInvalid)\n63: \t\tif !statusConditionsEqual(originalStatus.Conditions, codeInterpreter.Status.Conditions) {\n64: \t\t\tif statusErr := r.Status().Update(ctx, codeInterpreter); statusErr != nil {\n65: \t\t\t\tRecordReconciliationError(\"codeinterpreter\", req.Namespace, req.Name, ErrCodeStatusUpdateFailed)\n66: \t\t\t\treturn ctrl.Result{}, statusErr\n67: \t\t\t}\n68: \t\t}\n69: \t\tRecordReconciliationError(\"codeinterpreter\", req.Namespace, req.Name, ErrCodeValidationFailed)\n70: \t\treturn ctrl.Result{}, nil\n71: \t}\n72: \n73: \tsandboxResult, err := r.reconcileSandbox(ctx, codeInterpreter)\n74: \tif err != nil {\n75: \t\tlogger.Error(err, \"Failed to reconcile sandbox\")\n76: \t\tRecordReconciliation(\"codeinterpreter\", req.Namespace, req.Name,\n77: \t\t\ttime.Since(startTime).Seconds(), \"error\")\n78: \t\tRecordReconciliationError(\"codeinterpreter\", req.Namespace, req.Name, ErrCodeSandboxCreateFailed)\n79: \t\treturn r.handleReconcileError(ctx, codeInterpreter, err)\n80: \t}\n81: \n82: \toriginalStatus := codeInterpreter.Status.DeepCopy()\n83: \n84: \tif sandboxResult.Created {\n85: \t\tSetSandboxCreatedCondition(&codeInterpreter.Status.Conditions, true, ReasonSandboxCreated, \"Sandbox resource created successfully\")\n86: \t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeNormal, ReasonSandboxCreated,\n87: \t\t\tfmt.Sprintf(\"Sandbox %s created\", GetSandboxName(codeInterpreter.Name)))\n88: \t\tRecordSandboxCreation(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", time.Since(startTime).Seconds())\n89: \t} else if sandboxResult.Updated {\n90: \t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeNormal, ReasonSandboxUpdated,\n91: \t\t\tfmt.Sprintf(\"Sandbox %s updated\", GetSandboxName(codeInterpreter.Name)))\n92: \t\tRecordSandboxUpdate(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", time.Since(startTime).Seconds())\n93: \t}\n94: \n95: \tready := r.isReady(ctx, codeInterpreter)\n96: \tSetReadyCondition(&codeInterpreter.Status.Conditions, ready, ReasonReconciliationComplete, \"CodeInterpreter is ready\")\n97: \n98: \tif ready {\n99: \t\tClearErrorCondition(&codeInterpreter.Status.Conditions)\n100: \t\tRecordResourceReady(\"codeinterpreter\", codeInterpreter.Namespace)\n101: \t} else {\n102: \t\tSetProgressingCondition(&codeInterpreter.Status.Conditions, true, ReasonReconciliationStarted, \"CodeInterpreter is being reconciled\")\n103: \t\tRecordResourcePending(\"codeinterpreter\", codeInterpreter.Namespace)\n104: \t}\n105: \n106: \tif !statusConditionsEqual(originalStatus.Conditions, codeInterpreter.Status.Conditions) {\n107: \t\tcodeInterpreter.Status.ObservedGeneration = codeInterpreter.Generation\n108: \t\tif err := r.Status().Update(ctx, codeInterpreter); err != nil {\n109: \t\t\tlogger.Error(err, \"Failed to update status\")\n110: \t\t\tRecordReconciliationError(\"codeinterpreter\", req.Namespace, req.Name, ErrCodeStatusUpdateFailed)\n111: \t\t\treturn ctrl.Result{}, err\n112: \t\t}\n113: \t}\n114: \n115: \tduration := time.Since(startTime).Seconds()\n116: \tresult := \"success\"\n117: \tif !ready {\n118: \t\tresult = \"requeue\"\n119: \t\tRecordRequeue(\"codeinterpreter\", req.Namespace, req.Name)\n120: \t}\n121: \tRecordReconciliation(\"codeinterpreter\", req.Namespace, req.Name, duration, result)\n122: \n123: \tif !ready {\n124: \t\tlogger.Info(\"CodeInterpreter not ready, requeuing\")\n125: \t\treturn ctrl.Result{RequeueAfter: r.RequeueAfter}, nil\n126: \t}\n127: \n128: \tlogger.Info(\"Reconciliation completed successfully\")\n129: \treturn ctrl.Result{RequeueAfter: r.RequeueAfter}, nil\n130: }\n131: \n132: func (r *CodeInterpreterReconciler) reconcileDelete(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter) (ctrl.Result, error) {\n133: \tlogger := log.FromContext(ctx)\n134: \tlogger.Info(\"Deleting CodeInterpreter\", \"namespace\", codeInterpreter.Namespace, \"name\", codeInterpreter.Name)\n135: \n136: \tsandboxName := GetSandboxName(codeInterpreter.Name)\n137: \tsandbox := &corev1.Pod{}\n138: \n139: \terr := r.Get(ctx, client.ObjectKey{\n140: \t\tNamespace: codeInterpreter.Namespace,\n141: \t\tName:      sandboxName,\n142: \t}, sandbox)\n143: \n144: \tif err == nil {\n145: \t\tif err := r.Delete(ctx, sandbox); err != nil && !apierrors.IsNotFound(err) {\n146: \t\t\tlogger.Error(err, \"Failed to delete sandbox pod\")\n147: \t\t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeWarning, ReasonSandboxDeleteFailed,\n148: \t\t\t\tfmt.Sprintf(\"Failed to delete sandbox pod: %v\", err))\n149: \t\t\tRecordSandboxDeletion(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"error\", 0)\n150: \t\t\treturn ctrl.Result{}, err\n151: \t\t}\n152: \t\tlogger.Info(\"Sandbox pod deleted successfully\")\n153: \t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeNormal, ReasonSandboxDeleted,\n154: \t\t\tfmt.Sprintf(\"Sandbox %s deleted\", sandboxName))\n155: \t\tRecordSandboxDeletion(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", 0)\n156: \t} else if !apierrors.IsNotFound(err) {\n157: \t\tlogger.Error(err, \"Failed to get sandbox pod\")\n158: \t\treturn ctrl.Result{}, err\n159: \t}\n160: \n161: \tif HasFinalizer(codeInterpreter, FinalizerCodeInterpreter) {\n162: \t\tif err := RemoveFinalizer(ctx, r.Client, codeInterpreter, FinalizerCodeInterpreter); err != nil {\n163: \t\t\tlogger.Error(err, \"Failed to remove finalizer\")\n164: \t\t\treturn ctrl.Result{}, err\n165: \t\t}\n166: \t}\n167: \n168: \tlogger.Info(\"CodeInterpreter deleted successfully\")\n169: \treturn ctrl.Result{}, nil\n170: }\n171: \n172: func (r *CodeInterpreterReconciler) reconcileSandbox(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter) (*SandboxResult, error) {\n173: \tlogger := log.FromContext(ctx)\n174: \tsandboxName := GetSandboxName(codeInterpreter.Name)\n175: \n176: \texistingPod := &corev1.Pod{}\n177: \terr := r.Get(ctx, client.ObjectKey{\n178: \t\tNamespace: codeInterpreter.Namespace,\n179: \t\tName:      sandboxName,\n180: \t}, existingPod)\n181: \n182: \tif err != nil {\n183: \t\tif apierrors.IsNotFound(err) {\n184: \t\t\treturn r.createSandboxPod(ctx, codeInterpreter, sandboxName)\n185: \t\t}\n186: \t\treturn nil, fmt.Errorf(\"failed to get sandbox pod: %w\", err)\n187: \t}\n188: \n189: \treturn r.updateSandboxPod(ctx, codeInterpreter, existingPod, sandboxName)\n190: }\n191: \n192: func (r *CodeInterpreterReconciler) createSandboxPod(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter, sandboxName string) (*SandboxResult, error) {\n193: \tlogger := log.FromContext(ctx)\n194: \tlogger.Info(\"Creating sandbox pod\", \"name\", sandboxName)\n195: \n196: \tstartTime := time.Now()\n197: \n198: \tpod := &corev1.Pod{\n199: \t\tObjectMeta: metav1.ObjectMeta{\n200: \t\t\tName:      sandboxName,\n201: \t\t\tNamespace: codeInterpreter.Namespace,\n202: \t\t\tLabels: map[string]string{\n203: \t\t\t\tconstants.LabelManagedBy:    constants.LabelManagedByValue,\n204: \t\t\t\tconstants.LabelWorkloadName: codeInterpreter.Name,\n205: \t\t\t\tconstants.LabelSandboxName:  sandboxName,\n206: \t\t\t\tconstants.LabelSessionID:    codeInterpreter.Name,\n207: \t\t\t\tLabelKind:                   \"CodeInterpreter\",\n208: \t\t\t},\n209: \t\t\tOwnerReferences: []metav1.OwnerReference{\n210: \t\t\t\t{\n211: \t\t\t\t\tAPIVersion:         \"runtime.agentcube.volcano.sh/v1alpha1\",\n212: \t\t\t\t\tKind:               \"CodeInterpreter\",\n213: \t\t\t\t\tName:               codeInterpreter.Name,\n214: \t\t\t\t\tUID:                codeInterpreter.UID,\n215: \t\t\t\t\tController:         &[]bool{true}[0],\n216: \t\t\t\t\tBlockOwnerDeletion: &[]bool{true}[0],\n217: \t\t\t\t},\n218: \t\t\t},\n219: \t\t},\n220: \t\tSpec: r.buildPodSpec(codeInterpreter),\n221: \t}\n222: \n223: \tif err := r.Create(ctx, pod); err != nil {\n224: \t\tlogger.Error(err, \"Failed to create sandbox pod\")\n225: \t\tRecordSandboxCreation(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"error\", time.Since(startTime).Seconds())\n226: \t\treturn nil, NewSandboxCreateFailedError(fmt.Sprintf(\"Failed to create sandbox pod: %v\", err), err)\n227: \t}\n228: \n229: \tlogger.Info(\"Sandbox pod created successfully\")\n230: \treturn &SandboxResult{Created: true}, nil\n231: }\n232: \n233: func (r *CodeInterpreterReconciler) updateSandboxPod(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter, existingPod *corev1.Pod, sandboxName string) (*SandboxResult, error) {\n234: \tlogger := log.FromContext(ctx)\n235: \tlogger.Info(\"Checking sandbox pod\", \"name\", sandboxName)\n236: \n237: \tif existingPod.DeletionTimestamp != nil {\n238: \t\treturn &SandboxResult{Created: false}, nil\n239: \t}\n240: \n241: \tdesiredSpec := r.buildPodSpec(codeInterpreter)\n242: \tif podSpecsEqual(&existingPod.Spec, &desiredSpec) {\n243: \t\treturn &SandboxResult{Created: false}, nil\n244: \t}\n245: \n246: \texistingPod.Spec = desiredSpec\n247: \tif err := r.Update(ctx, existingPod); err != nil {\n248: \t\tlogger.Error(err, \"Failed to update sandbox pod\")\n249: \t\tRecordSandboxUpdate(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"error\", 0)\n250: \t\treturn nil, NewSandboxUpdateFailedError(fmt.Sprintf(\"Failed to update sandbox pod: %v\", err), err)\n251: \t}\n252: \n253: \tlogger.Info(\"Sandbox pod updated successfully\")\n254: \tRecordSandboxUpdate(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", 0)\n255: \treturn &SandboxResult{Updated: true}, nil\n256: }\n257: \n258: func (r *CodeInterpreterReconciler) buildPodSpec(codeInterpreter *runtimev1alpha1.CodeInterpreter) corev1.PodSpec {\n259: \timage := codeInterpreter.Spec.Image\n260: \tif image == \"\" {\n261: \t\timage = \"python:3.11-slim\"\n262: \t}\n263: \n264: \tcontainer := corev1.Container{\n265: \t\tName:                     \"code-interpreter\",\n266: \t\tImage:                    image,\n267: \t\tEnv:                      convertEnvVars(codeInterpreter.Spec.Env),\n268: \t\tTerminationMessagePath:   \"/dev/termination-log\",\n269: \t\tTerminationMessagePolicy: corev1.TerminationMessageReadFile,\n270: \t\tImagePullPolicy:          corev1.PullIfNotPresent,\n271: \t}\n272: \n273: \tif codeInterpreter.Spec.Resources != nil {\n274: \t\tcontainer.Resources = convertResources(codeInterpreter.Spec.Resources)\n275: \t}\n276: \n277: \treturn corev1.PodSpec{\n278: \t\tContainers: []corev1.Container{container},\n279: \t}\n280: }\n281: \n282: func (r *CodeInterpreterReconciler) validateSpec(codeInterpreter *runtimev1alpha1.CodeInterpreter) error {\n283: \tif codeInterpreter.Spec.Image == \"\" {\n284: \t\treturn fmt.Errorf(\"image is required\")\n285: \t}\n286: \n287: \treturn nil\n288: }\n289: \n290: func (r *CodeInterpreterReconciler) isReady(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter) bool {\n291: \tsandboxName := GetSandboxName(codeInterpreter.Name)\n292: \tpod := &corev1.Pod{}\n293: \n294: \terr := r.Get(ctx, client.ObjectKey{\n295: \t\tNamespace: codeInterpreter.Namespace,\n296: \t\tName:      sandboxName,\n297: \t}, pod)\n298: \n299: \tif err != nil {\n300: \t\treturn false\n301: \t}\n302: \n303: \tif pod.DeletionTimestamp != nil {\n304: \t\treturn false\n305: \t}\n306: \n307: \treturn IsPodReady(pod)\n308: }\n309: \n310: func (r *CodeInterpreterReconciler) handleReconcileError(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter, err error) (ctrl.Result, error) {\n311: \tlogger := log.FromContext(ctx)\n312: \n313: \tif apierrors.IsConflict(err) {\n314: \t\tlogger.Info(\"Conflict error, requeuing\")\n315: \t\treturn ctrl.Result{Requeue: true}, nil\n316: \t}\n317: \n318: \tif apierrors.IsNotFound(err) {\n319: \t\tlogger.Info(\"Resource not found, ignoring\")\n320: \t\treturn ctrl.Result{}, nil\n321: \t}\n322: \n323: \toriginalStatus := codeInterpreter.Status.DeepCopy()\n324: \tSetErrorCondition(&codeInterpreter.Status.Conditions, err, ReasonReconciliationFailed)\n325: \n326: \tif !statusConditionsEqual(originalStatus.Conditions, codeInterpreter.Status.Conditions) {\n327: \t\tcodeInterpreter.Status.ObservedGeneration = codeInterpreter.Generation\n328: \t\tif statusErr := r.Status().Update(ctx, codeInterpreter); statusErr != nil {\n329: \t\t\tlogger.Error(statusErr, \"Failed to update error status\")\n330: \t\t\treturn ctrl.Result{}, statusErr\n331: \t\t}\n332: \t}\n333: \n334: \tRecordResourceError(\"codeinterpreter\", codeInterpreter.Namespace)\n335: \treturn ctrl.Result{}, nil\n336: }\n337: \n338: func (r *CodeInterpreterReconciler) SetupWithManager(mgr ctrl.Manager) error {\n339: \treturn ctrl.NewControllerManagedBy(mgr).\n340: \t\tFor(&runti