tricReconcileErrors,\n34: \t\t\tHelp: \"Total number of reconciliation errors\",\n35: \t\t},\n36: \t\t[]string{\"controller\", \"namespace\", \"name\", \"error_type\"},\n37: \t)\n38: \n39: \treconcileDuration = prometheus.NewHistogramVec(\n40: \t\tprometheus.HistogramOpts{\n41: \t\t\tName:    metricReconcileDuration,\n42: \t\t\tHelp:    \"Reconciliation duration in seconds\",\n43: \t\t\tBuckets: prometheus.DefBuckets,\n44: \t\t},\n45: \t\t[]string{\"controller\", \"result\"},\n46: \t)\n47: \n48: \treconcileRequeues = prometheus.NewCounterVec(\n49: \t\tprometheus.CounterOpts{\n50: \t\t\tName: metricReconcileRequeues,\n51: \t\t\tHelp: \"Total number of reconciliation requeues\",\n52: \t\t},\n53: \t\t[]string{\"controller\", \"namespace\", \"name\"},\n54: \t)\n55: \n56: \tresourcesReady = prometheus.NewGaugeVec(\n57: \t\tprometheus.GaugeOpts{\n58: \t\t\tName: metricResourcesReady,\n59: \t\t\tHelp: \"Number of ready resources\",\n60: \t\t},\n61: \t\t[]string{\"controller\", \"namespace\"},\n62: \t)\n63: \n64: \tresourcesPending = prometheus.NewGaugeVec(\n65: \t\tprometheus.GaugeOpts{\n66: \t\t\tName: metricResourcesPending,\n67: \t\t\tHelp: \"Number of pending resources\",\n68: \t\t},\n69: \t\t[]string{\"controller\", \"namespace\"},\n70: \t)\n71: \n72: \tresourcesError = prometheus.NewGaugeVec(\n73: \t\tprometheus.GaugeOpts{\n74: \t\t\tName: metricResourcesError,\n75: \t\t\tHelp: \"Number of resources in error state\",\n76: \t\t},\n77: \t\t[]string{\"controller\", \"namespace\"},\n78: \t)\n79: \n80: \tsandboxCreations = prometheus.NewCounterVec(\n81: \t\tprometheus.CounterOpts{\n82: \t\t\tName: metricSandboxCreations,\n83: \t\t\tHelp: \"Total number of sandbox creations\",\n84: \t\t},\n85: \t\t[]string{\"controller\", \"namespace\", \"name\", \"result\"},\n86: \t)\n87: \n88: \tsandboxDeletions = prometheus.NewCounterVec(\n89: \t\tprometheus.CounterOpts{\n90: \t\t\tName: metricSandboxDeletions,\n91: \t\t\tHelp: \"Total number of sandbox deletions\",\n92: \t\t},\n93: \t\t[]string{\"controller\", \"namespace\", \"name\", \"result\"},\n94: \t)\n95: \n96: \tsandboxUpdateDuration = prometheus.NewHistogramVec(\n97: \t\tprometheus.HistogramOpts{\n98: \t\t\tName:    metricSandboxUpdateDuration,\n99: \t\t\tHelp:    \"Sandbox update duration in seconds\",\n100: \t\t\tBuckets: prometheus.DefBuckets,\n101: \t\t},\n102: \t\t[]string{\"controller\", \"operation\"},\n103: \t)\n104: )\n105: \n106: func init() {\n107: \tprometheus.MustRegister(reconcileTotal)\n108: \tprometheus.MustRegister(reconcileErrors)\n109: \tprometheus.MustRegister(reconcileDuration)\n110: \tprometheus.MustRegister(reconcileRequeues)\n111: \tprometheus.MustRegister(resourcesReady)\n112: \tprometheus.MustRegister(resourcesPending)\n113: \tprometheus.MustRegister(resourcesError)\n114: \tprometheus.MustRegister(sandboxCreations)\n115: \tprometheus.MustRegister(sandboxDeletions)\n116: \tprometheus.MustRegister(sandboxUpdateDuration)\n117: }\n118: \n119: func RecordReconciliation(controller, namespace, name string, duration float64, result string) {\n120: \treconcileTotal.WithLabelValues(controller, namespace, name).Inc()\n121: \treconcileDuration.WithLabelValues(controller, result).Observe(duration)\n122: \n123: \tif result == \"error\" {\n124: \t\treconcileRequeues.WithLabelValues(controller, namespace, name).Inc()\n125: \t}\n126: }\n127: \n128: func RecordReconciliationError(controller, namespace, name, errorType string) {\n129: \treconcileErrors.WithLabelValues(controller, namespace, name, errorType).Inc()\n130: }\n131: \n132: func RecordRequeue(controller, namespace, name string) {\n133: \treconcileRequeues.WithLabelValues(controller, namespace, name).Inc()\n134: }\n135: \n136: func RecordResourceReady(controller, namespace string) {\n137: \tresourcesReady.WithLabelValues(controller, namespace).Inc()\n138: }\n139: \n140: func RecordResourcePending(controller, namespace string) {\n141: \tresourcesPending.WithLabelValues(controller, namespace).Inc()\n142: }\n143: \n144: func RecordResourceError(controller, namespace string) {\n145: \tresourcesError.WithLabelValues(controller, namespace).Inc()\n146: }\n147: \n148: func ClearResourceMetrics(controller, namespace string) {\n149: \tresourcesReady.WithLabelValues(controller, namespace).Set(0)\n150: \tresourcesPending.WithLabelValues(controller, namespace).Set(0)\n151: \tresourcesError.WithLabelValues(controller, namespace).Set(0)\n152: }\n153: \n154: func RecordSandboxCreation(controller, namespace, name, result string, duration float64) {\n155: \tsandboxCreations.WithLabelValues(controller, namespace, name, result).Inc()\n156: \tsandboxUpdateDuration.WithLabelValues(controller, \"create\").Observe(duration)\n157: }\n158: \n159: func RecordSandboxDeletion(controller, namespace, name, result string, duration float64) {\n160: \tsandboxDeletions.WithLabelValues(controller, namespace, name, result).Inc()\n161: \tsandboxUpdateDuration.WithLabelValues(controller, \"delete\").Observe(duration)\n162: }\n163: \n164: func RecordSandboxUpdate(controller, namespace, name, result string, duration float64) {\n165: \tsandboxUpdateDuration.WithLabelValues(controller, \"update\").Observe(duration)\n166: }\n167: \n168: func ResetMetrics() {\n169: \treconcileTotal.Reset()\n170: \treconcileErrors.Reset()\n171: \treconcileDuration.Reset()\n172: \treconcileRequeues.Reset()\n173: \tresourcesReady.Reset()\n174: \tresourcesPending.Reset()\n175: \tresourcesError.Reset()\n176: \tsandboxCreations.Reset()\n177: \tsandboxDeletions.Reset()\n178: \tsandboxUpdateDuration.Reset()\n179: }\n\n(End of file - total 179 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"github.com/prometheus/client_golang/prometheus\"\n)\n\nconst (\n\tmetricReconcileTotal    = \"workloadmanager_reconcile_total\"\n\tmetricReconcileErrors   = \"workloadmanager_reconcile_errors_total\"\n\tmetricReconcileDuration = \"workloadmanager_reconcile_duration_seconds\"\n\tmetricReconcileRequeues = \"workloadmanager_reconcile_requeues_total\"\n\n\tmetricResourcesReady   = \"workloadmanager_resources_ready\"\n\tmetricResourcesPending = \"workloadmanager_resources_pending\"\n\tmetricResourcesError   = \"workloadmanager_resources_error\"\n\n\tmetricSandboxCreations      = \"workloadmanager_sandbox_creations_total\"\n\tmetricSandboxDeletions      = \"workloadmanager_sandbox_deletions_total\"\n\tmetricSandboxUpdateDuration = \"workloadmanager_sandbox_update_duration_seconds\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/metrics.go","time":{"start":1775891152199,"end":1775891152227}}}}
