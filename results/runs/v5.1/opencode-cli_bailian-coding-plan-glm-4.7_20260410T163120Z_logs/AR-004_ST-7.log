{"type":"tool_use","timestamp":1775843042571,"sessionID":"ses_28781ead6ffeH8TacWsajPyF7T","part":{"id":"prt_d787e608e001F2Tl74tLM3tKBU","messageID":"msg_d787e588a001Gr7MNA9iIHZ2r3","sessionID":"ses_28781ead6ffeH8TacWsajPyF7T","type":"tool","tool":"read","callID":"toolu_tool-a04aed5c791b4748b279ef4fb557a7e3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go</path>\n<type>file</type>\n<content>\n1: package server\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"sync\"\n8: \t\"time\"\n9: \n10: \t\"github.com/gin-gonic/gin\"\n11: \t\"k8s.io/client-go/rest\"\n12: \t\"k8s.io/klog/v2\"\n13: \n14: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n15: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/client\"\n16: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/config\"\n17: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/controller\"\n18: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n19: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/middleware\"\n20: )\n21: \n22: type Server struct {\n23: \tconfig     *config.Config\n24: \trouter     *gin.Engine\n25: \tserver     *http.Server\n26: \tk8sClient  *client.K8sClient\n27: \tstore      store.Store\n28: \tcontroller *controller.SandboxController\n29: \twg         sync.WaitGroup\n30: \tctx        context.Context\n31: \tcancel     context.CancelFunc\n32: }\n33: \n34: func NewServer(cfg *config.Config) (*Server, error) {\n35: \tk8sConfig, err := rest.InClusterConfig()\n36: \tif err != nil {\n37: \t\treturn nil, fmt.Errorf(\"failed to get in-cluster config: %w\", err)\n38: \t}\n39: \n40: \tk8sConfig.QPS = float32(cfg.K8s.QPS)\n41: \tk8sConfig.Burst = cfg.K8s.Burst\n42: \n43: \tk8sClient, err := client.NewK8sClient(k8sConfig)\n44: \tif err != nil {\n45: \t\treturn nil, fmt.Errorf(\"failed to create k8s client: %w\", err)\n46: \t}\n47: \n48: \tredisStore, err := store.NewValkeyStore(cfg.Redis.Addr, cfg.Redis.Password, cfg.Redis.DB)\n49: \tif err != nil {\n50: \t\treturn nil, fmt.Errorf(\"failed to create redis store: %w\", err)\n51: \t}\n52: \n53: \tsandboxController := controller.NewSandboxController(k8sClient, redisStore)\n54: \n55: \th := handler.NewHandler(sandboxController)\n56: \n57: \tgin.SetMode(gin.ReleaseMode)\n58: \trouter := gin.New()\n59: \n60: \trouter.Use(middleware.RecoveryMiddleware())\n61: \trouter.Use(middleware.LoggingMiddleware())\n62: \trouter.Use(middleware.CORSMiddleware())\n63: \n64: \tapiGroup := router.Group(\"/v1\")\n65: \t{\n66: \t\tapiGroup.POST(\"/agent-runtime\", h.CreateAgentRuntimeSandbox)\n67: \t\tapiGroup.POST(\"/code-interpreter\", h.CreateCodeInterpreterSandbox)\n68: \t\tapiGroup.GET(\"/sessions/:sessionId\", h.GetSession)\n69: \t\tapiGroup.DELETE(\"/sessions/:sessionId\", h.DeleteSession)\n70: \t}\n71: \n72: \trouter.GET(\"/health\", h.Health)\n73: \n74: \tctx, cancel := context.WithCancel(context.Background())\n75: \n76: \tsrv := &http.Server{\n77: \t\tAddr:         fmt.Sprintf(\"%s:%s\", cfg.Server.Host, cfg.Server.Port),\n78: \t\tHandler:      router,\n79: \t\tReadTimeout:  cfg.Server.ReadTimeout,\n80: \t\tWriteTimeout: cfg.Server.WriteTimeout,\n81: \t\tIdleTimeout:  cfg.Server.IdleTimeout,\n82: \t}\n83: \n84: \treturn &Server{\n85: \t\tconfig:     cfg,\n86: \t\trouter:     router,\n87: \t\tserver:     srv,\n88: \t\tk8sClient:  k8sClient,\n89: \t\tstore:      redisStore,\n90: \t\tcontroller: sandboxController,\n91: \t\tctx:        ctx,\n92: \t\tcancel:     cancel,\n93: \t}, nil\n94: }\n95: \n96: func (s *Server) Start() error {\n97: \ts.wg.Add(1)\n98: \tgo func() {\n99: \t\tdefer s.wg.Done()\n100: \t\tklog.Infof(\"Starting server on %s\", s.server.Addr)\n101: \t\tif err := s.server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n102: \t\t\tklog.Errorf(\"Server error: %v\", err)\n103: \t\t}\n104: \t}()\n105: \n106: \ts.wg.Add(1)\n107: \tgo func() {\n108: \t\tdefer s.wg.Done()\n109: \t\ts.runGarbageCollector()\n110: \t}()\n111: \n112: \treturn nil\n113: }\n114: \n115: func (s *Server) Stop() error {\n116: \tklog.Info(\"Shutting down server...\")\n117: \n118: \tctx, cancel := context.WithTimeout(context.Background(), s.config.Server.ShutdownTimeout)\n119: \tdefer cancel()\n120: \n121: \tif err := s.server.Shutdown(ctx); err != nil {\n122: \t\tklog.Errorf(\"Server shutdown error: %v\", err)\n123: \t}\n124: \n125: \ts.cancel()\n126: \ts.wg.Wait()\n127: \n128: \tif err := s.store.Close(); err != nil {\n129: \t\tklog.Errorf(\"Store close error: %v\", err)\n130: \t}\n131: \n132: \tklog.Info(\"Server stopped\")\n133: \treturn nil\n134: }\n135: \n136: func (s *Server) runGarbageCollector() {\n137: \tticker := time.NewTicker(s.config.Session.CleanupInterval)\n138: \tdefer ticker.Stop()\n139: \n140: \tfor {\n141: \t\tselect {\n142: \t\tcase <-s.ctx.Done():\n143: \t\t\treturn\n144: \t\tcase <-ticker.C:\n145: \t\t\ts.cleanupExpiredSessions()\n146: \t\t\ts.cleanupInactiveSessions()\n147: \t\t}\n148: \t}\n149: }\n150: \n151: func (s *Server) cleanupExpiredSessions() {\n152: \tctx, cancel := context.WithTimeout(s.ctx, 2*time.Minute)\n153: \tdefer cancel()\n154: \n155: \tsandboxes, err := s.store.ListExpiredSandboxes(ctx, time.Now(), 16)\n156: \tif err != nil {\n157: \t\tklog.Errorf(\"Failed to list expired sessions: %v\", err)\n158: \t\treturn\n159: \t}\n160: \n161: \tfor _, sb := range sandboxes {\n162: \t\tklog.Infof(\"Cleaning up expired session %s\", sb.SessionID)\n163: \t\ts.k8sClient.DeleteSandbox(ctx, sb.Namespace, sb.SandboxName)\n164: \t\ts.store.DeleteSandboxBySessionID(ctx, sb.SessionID)\n165: \t}\n166: }\n167: \n168: func (s *Server) cleanupInactiveSessions() {\n169: \tctx, cancel := context.WithTimeout(s.ctx, 2*time.Minute)\n170: \tdefer cancel()\n171: \n172: \tinactiveThreshold := time.Now().Add(-15 * time.Minute)\n173: \tsandboxes, err := s.store.ListInactiveSandboxes(ctx, inactiveThreshold, 16)\n174: \tif err != nil {\n175: \t\tklog.Errorf(\"Failed to list inactive sessions: %v\", err)\n176: \t\treturn\n177: \t}\n178: \n179: \tfor _, sb := range sandboxes {\n180: \t\tklog.Infof(\"Cleaning up inactive session %s\", sb.SessionID)\n181: \t\ts.k8sClient.DeleteSandbox(ctx, sb.Namespace, sb.SandboxName)\n182: \t\ts.store.DeleteSandboxBySessionID(ctx, sb.SessionID)\n183: \t}\n184: }\n185: \n186: func (s *Server) GetRouter() *gin.Engine {\n187: \treturn s.router\n188: }\n\n(End of file - total 188 lines)\n</content>","metadata":{"preview":"package server\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/client\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/config\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/controller\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/middleware\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go","time":{"start":1775843042547,"end":1775843042569}}}}
