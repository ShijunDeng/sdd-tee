 \tEntryPoints  []EntryPoint `json:\"entryPoints\"`\n37: \tLastActivity string       `json:\"lastActivity\"`\n38: \tCreatedAt    string       `json:\"createdAt\"`\n39: \tExpiresAt    string       `json:\"expiresAt\"`\n40: \tPodIP        string       `json:\"podIp,omitempty\"`\n41: }\n42: \n43: type DeleteSessionRequest struct {\n44: \tSessionID string `uri:\"sessionId\" binding:\"required\"`\n45: }\n46: \n47: type DeleteSessionResponse struct {\n48: \tSessionID string `json:\"sessionId\"`\n49: \tDeletedAt string `json:\"deletedAt\"`\n50: }\n\n(End of file - total 50 lines)\n</content>","metadata":{"preview":"package api\n\ntype CreateSandboxRequest struct {\n\tKind      string `json:\"kind\" binding:\"required\"`\n\tName      string `json:\"name\" binding:\"required\"`\n\tNamespace string `json:\"namespace\" binding:\"required\"`\n}\n\ntype CreateSandboxResponse struct {\n\tSessionID   string       `json:\"sessionId\"`\n\tSandboxID   string       `json:\"sandboxId\"`\n\tSandboxName string       `json:\"sandboxName\"`\n\tEntryPoints []EntryPoint `json:\"entryPoints\"`\n\tCreatedAt   string       `json:\"createdAt\"`\n\tExpiresAt   string       `json:\"expiresAt\"`\n}\n\ntype EntryPoint struct {\n\tProtocol string `json:\"protocol\"`\n\tEndpoint string `json:\"endpoint\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/api/types.go","time":{"start":1775843053908,"end":1775843053920}}}}
{"type":"tool_use","timestamp":1775843053924,"sessionID":"ses_28781ead6ffeH8TacWsajPyF7T","part":{"id":"prt_d787e91370014whmzP1SvyMdq1","messageID":"msg_d787e6544001gZCQnVkMDhgaH5","sessionID":"ses_28781ead6ffeH8TacWsajPyF7T","type":"tool","tool":"read","callID":"toolu_tool-0c796b5c6d044fb1916bd04f8d75f26c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox.go</path>\n<type>file</type>\n<content>\n1: package controller\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"math/rand\"\n7: \t\"time\"\n8: \n9: \t\"github.com/google/uuid\"\n10: \tcorev1 \"k8s.io/api/core/v1\"\n11: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n12: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n13: \t\"k8s.io/apimachinery/pkg/runtime\"\n14: \n15: \t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n16: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n17: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n18: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/api\"\n19: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/client\"\n20: )\n21: \n22: type SandboxController struct {\n23: \tk8sClient *client.K8sClient\n24: \tstore     store.Store\n25: }\n26: \n27: func NewSandboxController(k8sClient *client.K8sClient, store store.Store) *SandboxController {\n28: \treturn &SandboxController{\n29: \t\tk8sClient: k8sClient,\n30: \t\tstore:     store,\n31: \t}\n32: }\n33: \n34: func (sc *SandboxController) CreateAgentRuntimeSandbox(ctx context.Context, req *api.CreateSandboxRequest) (*api.CreateSandboxResponse, error) {\n35: \tagentRuntime, err := sc.k8sClient.GetAgentRuntime(ctx, req.Namespace, req.Name)\n36: \tif err != nil {\n37: \t\tif apierrors.IsNotFound(err) {\n38: \t\t\treturn nil, fmt.Errorf(\"AgentRuntime %s/%s not found\", req.Namespace, req.Name)\n39: \t\t}\n40: \t\treturn nil, fmt.Errorf(\"failed to get AgentRuntime: %w\", err)\n41: \t}\n42: \n43: \tspec, found, err := unstructured.NestedMap(agentRuntime.Object, \"spec\")\n44: \tif err != nil {\n45: \t\treturn nil, fmt.Errorf(\"failed to get spec: %w\", err)\n46: \t}\n47: \tif !found {\n48: \t\treturn nil, fmt.Errorf(\"spec not found\")\n49: \t}\n50: \n51: \tsessionID := uuid.New().String()\n52: \tsandboxName := generateSandboxName(req.Name)\n53: \n54: \tsandboxCR, err := sc.buildAgentRuntimeSandboxCR(agentRuntime, sessionID, sandboxName, req.Name, req.Namespace)\n55: \tif err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to build sandbox CR: %w\", err)\n57: \t}\n58: \n59: \tsandboxInfo := &types.SandboxInfo{\n60: \t\tSessionID:    sessionID,\n61: \t\tSandboxName:  sandboxName,\n62: \t\tWorkloadName: req.Name,\n63: \t\tNamespace:    req.Namespace,\n64: \t\tKind:         \"AgentRuntime\",\n65: \t\tStatus:       \"pending\",\n66: \t\tCreatedAt:    time.Now(),\n67: \t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n68: \t}\n69: \n70: \tif err := sc.store.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n71: \t\treturn nil, fmt.Errorf(\"failed to store sandbox: %w\", err)\n72: \t}\n73: \n74: \tcreatedCR, err := sc.k8sClient.CreateSandbox(ctx, req.Namespace, sandboxCR)\n75: \tif err != nil {\n76: \t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n77: \t\treturn nil, fmt.Errorf(\"failed to create sandbox: %w\", err)\n78: \t}\n79: \n80: \tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\n81: \tdefer cancel()\n82: \n83: \tvar podIP string\n84: \tfor i := 0; i < 60; i++ {\n85: \t\tpodIP, err = sc.k8sClient.GetPodIP(ctx, sandboxName, req.Namespace, createdCR)\n86: \t\tif err == nil {\n87: \t\t\tbreak\n88: \t\t}\n89: \t\tselect {\n90: \t\tcase <-ctx.Done():\n91: \t\t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n92: \t\t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n93: \t\t\treturn nil, fmt.Errorf(\"sandbox creation timed out\")\n94: \t\tcase <-time.After(2 * time.Second):\n95: \t\t\tcontinue\n96: \t\t}\n97: \t}\n98: \n99: \tports, _, err := unstructured.NestedSlice(spec, \"ports\")\n100: \tif err != nil {\n101: \t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n102: \t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n103: \t\treturn nil, fmt.Errorf(\"failed to get ports: %w\", err)\n104: \t}\n105: \n106: \tentryPoints := sc.buildEntryPoints(podIP, ports)\n107: \n108: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n109: \tsandboxInfo.PodIP = podIP\n110: \tsandboxInfo.EntryPoints = convertEntryPoints(entryPoints)\n111: \tsandboxInfo.Status = \"running\"\n112: \n113: \tif err := sc.store.UpdateSandbox(ctx, sessionID, sandboxInfo); err != nil {\n114: \t\treturn nil, fmt.Errorf(\"failed to update sandbox: %w\", err)\n115: \t}\n116: \n117: \treturn &api.CreateSandboxResponse{\n118: \t\tSessionID:   sessionID,\n119: \t\tSandboxID:   sandboxInfo.SandboxID,\n120: \t\tSandboxName: sandboxName,\n121: \t\tEntryPoints: entryPoints,\n122: \t\tCreatedAt:   sandboxInfo.CreatedAt.Format(time.RFC3339),\n123: \t\tExpiresAt:   sandboxInfo.ExpiresAt.Format(time.RFC3339),\n124: \t}, nil\n125: }\n126: \n127: func (sc *SandboxController) CreateCodeInterpreterSandbox(ctx context.Context, req *api.CreateSandboxRequest) (*api.CreateSandboxResponse, error) {\n128: \tcodeInterpreter, err := sc.k8sClient.GetCodeInterpreter(ctx, req.Namespace, req.Name)\n129: \tif err != nil {\n130: \t\tif apierrors.IsNotFound(err) {\n131: \t\t\treturn nil, fmt.Errorf(\"CodeInterpreter %s/%s not found\", req.Namespace, req.Name)\n132: \t\t}\n133: \t\treturn nil, fmt.Errorf(\"failed to get CodeInterpreter: %w\", err)\n134: \t}\n135: \n136: \tspec, found, err := unstructured.NestedMap(codeInterpreter.Object, \"spec\")\n137: \tif err != nil {\n138: \t\treturn nil, fmt.Errorf(\"failed to get spec: %w\", err)\n139: \t}\n140: \tif !found {\n141: \t\treturn nil, fmt.Errorf(\"spec not found\")\n142: \t}\n143: \n144: \tsessionID := uuid.New().String()\n145: \tsandboxName := generateSandboxName(req.Name)\n146: \n147: \tports, _, _ := unstructured.NestedSlice(spec, \"ports\")\n148: \tif len(ports) == 0 {\n149: \t\tports = []interface{}{\n150: \t\t\tmap[string]interface{}{\n151: \t\t\t\t\"port\":     int64(8080),\n152: \t\t\t\t\"protocol\": \"HTTP\",\n153: \t\t\t},\n154: \t\t}\n155: \t}\n156: \n157: \tsandboxCR, err := sc.buildCodeInterpreterSandboxCR(codeInterpreter, sessionID, sandboxName, req.Name, req.Namespace, ports)\n158: \tif err != nil {\n159: \t\treturn nil, fmt.Errorf(\"failed to build sandbox CR: %w\", err)\n160: \t}\n161: \n162: \tsandboxInfo := &types.SandboxInfo{\n163: \t\tSessionID:    sessionID,\n164: \t\tSandboxName:  sandboxName,\n165: \t\tWorkloadName: req.Name,\n166: \t\tNamespace:    req.Namespace,\n167: \t\tKind:         \"CodeInterpreter\",\n168: \t\tStatus:       \"pending\",\n169: \t\tCreatedAt:    time.Now(),\n170: \t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n171: \t}\n172: \n173: \tif err := sc.store.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n174: \t\treturn nil, fmt.Errorf(\"failed to store sandbox: %w\", err)\n175: \t}\n176: \n177: \tcreatedCR, err := sc.k8sClient.CreateSandbox(ctx, req.Namespace, sandboxCR)\n178: \tif err != nil {\n179: \t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n180: \t\treturn nil, fmt.Errorf(\"failed to create sandbox: %w\", err)\n181: \t}\n182: \n183: \tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\n184: \tdefer cancel()\n185: \n186: \tvar podIP string\n187: \tfor i := 0; i < 60; i++ {\n188: \t\tpodIP, err = sc.k8sClient.GetPodIP(ctx, sandboxName, req.Namespace, createdCR)\n189: \t\tif err == nil {\n190: \t\t\tbreak\n191: \t\t}\n192: \t\tselect {\n193: \t\tcase <-ctx.Done():\n194: \t\t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n195: \t\t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n196: \t\t\treturn nil, fmt.Errorf(\"sandbox creation timed out\")\n197: \t\tcase <-time.After(2 * time.Second):\n198: \t\t\tcontinue\n199: \t\t}\n200: \t}\n201: \n202: \tentryPoints := sc.buildEntryPoints(podIP, ports)\n203: \n204: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n205: \tsandboxInfo.PodIP = podIP\n206: \tsandboxInfo.EntryPoints = convertEntryPoints(entryPoints)\n207: \tsandboxInfo.Status = \"running\"\n208: \n209: \tif err := sc.store.UpdateSandbox(ctx, sessionID, sandboxInfo); err != nil {\n210: \t\treturn nil, fmt.Errorf(\"failed to update sandbox: %w\", err)\n211: \t}\n212: \n213: \treturn &api.CreateSandboxResponse{\n214: \t\tSessionID:   sessionID,\n215: \t\tSandboxID:   sandboxInfo.SandboxID,\n216: \t\tSandboxName: sandboxName,\n217: \t\tEntryPoints: entryPoints,\n218: \t\tCreatedAt:   sandboxInfo.CreatedAt.Format(time.RFC3339),\n219: \t\tExpiresAt:   sandboxInfo.ExpiresAt.Format(time.RFC3339),\n220: \t}, nil\n221: }\n222: \n223: func (sc *SandboxController) GetSession(ctx context.Context, sessionID string) (*api.GetSessionResponse, error) {\n224: \tsandboxInfo, err := sc.store.GetSandbox(ctx, sessionID)\n225: \tif err != nil {\n226: \t\tif err == store.ErrNotFound {\n227: \t\t\treturn nil, fmt.Errorf(\"session not found\")\n228: \t\t}\n229: \t\treturn nil, fmt.Errorf(\"failed to get session: %w\", err)\n230: \t}\n231: \n232: \treturn &api.GetSessionResponse{\n233: \t\tSessionID:    sandboxInfo.SessionID,\n234: \t\tSandboxID:    sandboxInfo.SandboxID,\n235: \t\tSandboxName:  sandboxInfo.SandboxName,\n236: \t\tKind:         sandboxInfo.Kind,\n237: \t\tNamespace:    sandboxInfo.Namespace,\n238: \t\tName:         sandboxInfo.WorkloadName,\n239: \t\tEntryPoints:  convertToAPIEntryPoints(sandboxInfo.EntryPoints),\n240: \t\tLastActivity: sandboxInfo.LastActivityAt.Format(time.RFC3339),\n241: \t\tCreatedAt:    sandboxInfo.CreatedAt.Format(time.RFC3339),\n242: \t\tExpiresAt:    sandboxInfo.ExpiresAt.Format(time.RFC3339),\n243: \t\tPodIP:        sandboxInfo.PodIP,\n244: \t}, nil\n245: }\n246: \n247: func (sc *SandboxController) DeleteSession(ctx context.Context, sessionID string) (*api.DeleteSessionResponse, error) {\n248: \tsandboxInfo, err := sc.store.GetSandbox(ctx, sessionID)\n249: \tif err != nil {\n250: \t\tif err == store.ErrNotFound {\n251: \t\t\treturn nil, fmt.Errorf(\"session not found\")\n252: \t\t}\n253: \t\treturn nil, fmt.Errorf(\"failed to get session: %w\", err)\n254: \t}\n255: \n256: \tif err := sc.k8sClient.DeleteSandbox(ctx, sandboxInfo.Namespace, sandboxInfo.SandboxName); err != nil && !apierrors.IsNotFound(err) {\n257: \t\treturn nil, fmt.Errorf(\"failed to delete sandbox: %w\", err)\n258: \t}\n259: \n260: \tif err := sc.store.DeleteSandboxBySessionID(ctx, sessionID); err != nil {\n261: \t\treturn nil, fmt.Errorf(\"failed to delete session: %w\", err)\n262: \t}\n263: \n264: \treturn &api.DeleteSessionResponse{\n265: \t\tSessionID: sessionID,\n266: \t\tDeletedAt: time.Now().Format(time.RFC3339),\n267: \t}, nil\n268: }\n269: \n270: func (sc *SandboxController) buildAgentRuntimeSandboxCR(agentRuntime *unstructured.Unstructured, sessionID, sandboxName, workloadName, namespace string) (*unstructured.Unstructured, error) {\n271: \tcr := &unstructured.Unstructured{}\n272: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n273: \tcr.SetKind(\"Sandbox\")\n274: \tcr.SetName(sandboxName)\n275: \tcr.SetNamespace(namespace)\n276: \n277: \tcr.SetLabels(map[string]string{\n278: \t\tconstants.LabelManagedBy:    constants.LabelManagedByValue,\n279: \t\tconstants.LabelSessionID:    sessionID,\n280: \t\tconstants.LabelWorkloadName: workloadName,\n281: \t\tconstants.LabelSandboxName:  sandboxName,\n282: \t})\n283: \n284: \tcr.SetAnnotations(map[string]string{\n285: \t\tconstants.AnnotationIdleTimeout: \"15m\",\n286: \t})\n287: \n288: \tshutdownTime := time.Now().Add(8 * time.Hour)\n289: \n290: \tspec := map[string]interface{}{\n291: \t\t\"replicas\": int64(1),\n292: \t\t\"lifecycle\": map[string]interface{}{\n2