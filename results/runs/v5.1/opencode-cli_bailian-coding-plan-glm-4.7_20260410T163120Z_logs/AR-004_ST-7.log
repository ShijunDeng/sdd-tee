\treturn &K8sClient{\n43: \t\tclientset: clientset,\n44: \t\tdynamic:   dynamicClient,\n45: \t\tconfig:    config,\n46: \t\tgvrSandbox: schema.GroupVersionResource{\n47: \t\t\tGroup:    \"agents.x-k8s.io\",\n48: \t\t\tVersion:  \"v1alpha1\",\n49: \t\t\tResource: \"sandboxes\",\n50: \t\t},\n51: \t\tgvrAgent: schema.GroupVersionResource{\n52: \t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n53: \t\t\tVersion:  \"v1alpha1\",\n54: \t\t\tResource: \"agentruntimes\",\n55: \t\t},\n56: \t\tgvrCode: schema.GroupVersionResource{\n57: \t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n58: \t\t\tVersion:  \"v1alpha1\",\n59: \t\t\tResource: \"codeinterpreters\",\n60: \t\t},\n61: \t}, nil\n62: }\n63: \n64: func (c *K8sClient) GetAgentRuntime(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n65: \treturn c.dynamic.Resource(c.gvrAgent).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n66: }\n67: \n68: func (c *K8sClient) GetCodeInterpreter(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n69: \treturn c.dynamic.Resource(c.gvrCode).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n70: }\n71: \n72: func (c *K8sClient) CreateSandbox(ctx context.Context, namespace string, sandbox *unstructured.Unstructured) (*unstructured.Unstructured, error) {\n73: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Create(ctx, sandbox, metav1.CreateOptions{})\n74: }\n75: \n76: func (c *K8sClient) GetSandbox(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n77: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n78: }\n79: \n80: func (c *K8sClient) DeleteSandbox(ctx context.Context, namespace, name string) error {\n81: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Delete(ctx, name, metav1.DeleteOptions{})\n82: }\n83: \n84: func (c *K8sClient) GetPodIP(ctx context.Context, sandboxName, namespace string, sandbox *unstructured.Unstructured) (string, error) {\n85: \tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n86: \tif err == nil && pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n87: \t\treturn pod.Status.PodIP, nil\n88: \t}\n89: \n90: \tannotations := sandbox.GetAnnotations()\n91: \tconst podNameAnnotation = \"agents.x-k8s.io/sandbox-pod-name\"\n92: \tif podName, ok := annotations[podNameAnnotation]; ok && podName != \"\" {\n93: \t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, podName, metav1.GetOptions{})\n94: \t\tif err == nil {\n95: \t\t\tif pod.Status.Phase != corev1.PodRunning {\n96: \t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n97: \t\t\t}\n98: \t\t\tif pod.Status.PodIP == \"\" {\n99: \t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n100: \t\t\t}\n101: \t\t\treturn pod.Status.PodIP, nil\n102: \t\t}\n103: \t}\n104: \n105: \tpods, err := c.clientset.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n106: \t\tLabelSelector: labels.SelectorFromSet(labels.Set{\n107: \t\t\tconstants.LabelSandboxName: sandboxName,\n108: \t\t}).String(),\n109: \t})\n110: \tif err != nil {\n111: \t\treturn \"\", fmt.Errorf(\"failed to list pods: %w\", err)\n112: \t}\n113: \n114: \tfor _, p := range pods.Items {\n115: \t\tfor _, ownerRef := range p.OwnerReferences {\n116: \t\t\tif ownerRef.Kind == \"Sandbox\" && ownerRef.Name == sandboxName {\n117: \t\t\t\tif p.Status.Phase != corev1.PodRunning {\n118: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n119: \t\t\t\t}\n120: \t\t\t\tif p.Status.PodIP == \"\" {\n121: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n122: \t\t\t\t}\n123: \t\t\t\treturn p.Status.PodIP, nil\n124: \t\t\t}\n125: \t\t}\n126: \t}\n127: \n128: \treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n129: }\n130: \n131: func (c *K8sClient) WatchPods(ctx context.Context, namespace string, sandboxName string) (<-chan string, error) {\n132: \tpodCh := make(chan string, 1)\n133: \n134: \tgo func() {\n135: \t\tdefer close(podCh)\n136: \n137: \t\tticker := time.NewTicker(2 * time.Second)\n138: \t\tdefer ticker.Stop()\n139: \n140: \t\tfor {\n141: \t\t\tselect {\n142: \t\t\tcase <-ctx.Done():\n143: \t\t\t\treturn\n144: \t\t\tcase <-ticker.C:\n145: \t\t\t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n146: \t\t\t\tif err != nil {\n147: \t\t\t\t\tif apierrors.IsNotFound(err) {\n148: \t\t\t\t\t\tcontinue\n149: \t\t\t\t\t}\n150: \t\t\t\t\tklog.Errorf(\"Failed to get pod: %v\", err)\n151: \t\t\t\t\tcontinue\n152: \t\t\t\t}\n153: \n154: \t\t\t\tif pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n155: \t\t\t\t\tselect {\n156: \t\t\t\t\tcase podCh <- pod.Status.PodIP:\n157: \t\t\t\t\tdefault:\n158: \t\t\t\t\t}\n159: \t\t\t\t\treturn\n160: \t\t\t\t}\n161: \t\t\t}\n162: \t\t}\n163: \t}()\n164: \n165: \treturn podCh, nil\n166: }\n167: \n168: func (c *K8sClient) GetSecret(ctx context.Context, namespace, name string) (*corev1.Secret, error) {\n169: \treturn c.clientset.CoreV1().Secrets(namespace).Get(ctx, name, metav1.GetOptions{})\n170: }\n\n(End of file - total 170 lines)\n</content>","metadata":{"preview":"package client\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go","time":{"start":1775843070167,"end":1775843070182}}}}
{"type":"tool_use","timestamp":1775843070185,"sessionID":"ses_28781ead6ffeH8TacWsajPyF7T","part":{"id":"prt_d787ece81001P7hPZB28e0LciQ","messageID":"msg_d787eacc7001kWT7xaWpjZ2umI","sessionID":"ses_28781ead6ffeH8TacWsajPyF7T","type":"tool","tool":"read","callID":"toolu_tool-931d188fd2794593814282747faa12d0","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/auth/k8s_auth.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/auth/k8s_auth.go</path>\n<type>file</type>\n<content>\n1: package auth\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"sync\"\n7: \t\"time\"\n8: \n9: \tauthenticationv1 \"k8s.io/api/authentication/v1\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: \t\"k8s.io/client-go/kubernetes\"\n12: )\n13: \n14: type K8sAuthenticator struct {\n15: \tclientset kubernetes.Interface\n16: \taudience  string\n17: }\n18: \n19: type AuthenticationInfo struct {\n20: \tUsername string\n21: \tUID      string\n22: \tGroups   []string\n23: }\n24: \n25: type TokenCache struct {\n26: \tcache map[string]*cacheEntry\n27: \tmu    sync.RWMutex\n28: \tttl   time.Duration\n29: }\n30: \n31: type cacheEntry struct {\n32: \tinfo      *AuthenticationInfo\n33: \texpiresAt time.Time\n34: }\n35: \n36: func NewK8sAuthenticator(clientset kubernetes.Interface, audience string) *K8sAuthenticator {\n37: \treturn &K8sAuthenticator{\n38: \t\tclientset: clientset,\n39: \t\taudience:  audience,\n40: \t}\n41: }\n42: \n43: func (a *K8sAuthenticator) Authenticate(ctx context.Context, token string) (*AuthenticationInfo, error) {\n44: \ttokenReview := &authenticationv1.TokenReview{\n45: \t\tSpec: authenticationv1.TokenReviewSpec{\n46: \t\t\tToken:     token,\n47: \t\t\tAudiences: []string{a.audience},\n48: \t\t},\n49: \t}\n50: \n51: \tresp, err := a.clientset.AuthenticationV1().TokenReviews().Create(ctx, tokenReview, metav1.CreateOptions{})\n52: \tif err != nil {\n53: \t\treturn nil, fmt.Errorf(\"token review failed: %w\", err)\n54: \t}\n55: \n56: \tif !resp.Status.Authenticated {\n57: \t\treturn nil, fmt.Errorf(\"token authentication failed\")\n58: \t}\n59: \n60: \treturn &AuthenticationInfo{\n61: \t\tUsername: resp.Status.User.Username,\n62: \t\tUID:      resp.Status.User.UID,\n63: \t\tGroups:   resp.Status.User.Groups,\n64: \t}, nil\n65: }\n66: \n67: func NewTokenCache(ttl time.Duration) *TokenCache {\n68: \treturn &TokenCache{\n69: \t\tcache: make(map[string]*cacheEntry),\n70: \t\tttl:   ttl,\n71: \t}\n72: }\n73: \n74: func (c *TokenCache) Get(token string) (*AuthenticationInfo, bool) {\n75: \tc.mu.RLock()\n76: \tdefer c.mu.RUnlock()\n77: \n78: \tentry, exists := c.cache[token]\n79: \tif !exists {\n80: \t\treturn nil, false\n81: \t}\n82: \n83: \tif time.Now().After(entry.expiresAt) {\n84: \t\treturn nil, false\n85: \t}\n86: \n87: \treturn entry.info, true\n88: }\n89: \n90: func (c *TokenCache) Put(token string, info *AuthenticationInfo) {\n91: \tc.mu.Lock()\n92: \tdefer c.mu.Unlock()\n93: \n94: \tc.cache[token] = &cacheEntry{\n95: \t\tinfo:      info,\n96: \t\texpiresAt: time.Now().Add(c.ttl),\n97: \t}\n98: }\n99: \n100: func (c *TokenCache) Delete(token string) {\n101: \tc.mu.Lock()\n102: \tdefer c.mu.Unlock()\n103: \n104: \tdelete(c.cache, token)\n105: }\n106: \n107: func (c *TokenCache) Cleanup() {\n108: \tc.mu.Lock()\n109: \tdefer c.mu.Unlock()\n110: \n111: \tnow := time.Now()\n112: \tfor token, entry := range c.cache {\n113: \t\tif now.After(entry.expiresAt) {\n114: \t\t\tdelete(c.cache, token)\n115: \t\t}\n116: \t}\n117: }\n\n(End of file - total 117 lines)\n</content>","metadata":{"preview":"package auth\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\tauthenticationv1 \"k8s.io/api/authentication/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n)\n\ntype K8sAuthenticator struct {\n\tclientset kubernetes.Interface\n\taudience  string\n}\n\ntype AuthenticationInfo struct {\n\tUsername string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/auth/k8s_auth.go","time":{"start":1775843070170,"end":1775843070184}}}}
