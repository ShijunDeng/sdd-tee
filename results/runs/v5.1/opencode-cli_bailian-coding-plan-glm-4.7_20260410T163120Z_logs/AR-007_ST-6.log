lStatus.Conditions, codeInterpreter.Status.Conditions) {\n","metadata":{"output":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/codeinterpreter.go:\t\tif !statusConditionsEqual(originalStatus.Conditions, codeInterpreter.Status.Conditions) {\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/codeinterpreter.go:\tif !statusConditionsEqual(originalStatus.Conditions, codeInterpreter.Status.Conditions) {\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/codeinterpreter.go:\tif podSpecsEqual(&existingPod.Spec, &desiredSpec) {\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/codeinterpreter.go:\t\tEnv:                      convertEnvVars(codeInterpreter.Spec.Env),\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/codeinterpreter.go:\t\tcontainer.Resources = convertResources(codeInterpreter.Spec.Resources)\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/codeinterpreter.go:\tif !statusConditionsEqual(originalStatus.Conditions, codeInterpreter.Status.Conditions) {\n","exit":0,"description":"Search for missing helper functions","truncated":false},"title":"Search for missing helper functions","time":{"start":1775846995175,"end":1775846995190}}}}
