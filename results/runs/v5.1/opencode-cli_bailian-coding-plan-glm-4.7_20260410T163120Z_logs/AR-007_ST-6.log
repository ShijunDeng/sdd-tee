 \treturn condition != nil && condition.Status == metav1.ConditionTrue\n92: }\n93: \n94: func SetReadyCondition(conditions *[]metav1.Condition, ready bool, reason, message string) {\n95: \tstatus := metav1.ConditionFalse\n96: \tif ready {\n97: \t\tstatus = metav1.ConditionTrue\n98: \t}\n99: \tSetCondition(conditions, ConditionTypeReady, status, reason, message)\n100: }\n101: \n102: func SetErrorCondition(conditions *[]metav1.Condition, err error, reason string) {\n103: \tmessage := \"\"\n104: \tif err != nil {\n105: \t\tmessage = err.Error()\n106: \t}\n107: \tSetCondition(conditions, ConditionTypeError, metav1.ConditionTrue, reason, message)\n108: }\n109: \n110: func ClearErrorCondition(conditions *[]metav1.Condition) {\n111: \tfor i := len(*conditions) - 1; i >= 0; i-- {\n112: \t\tif (*conditions)[i].Type == ConditionTypeError {\n113: \t\t\t*conditions = append((*conditions)[:i], (*conditions)[i+1:]...)\n114: \t\t\tbreak\n115: \t\t}\n116: \t}\n117: }\n118: \n119: func SetProgressingCondition(conditions *[]metav1.Condition, progressing bool, reason, message string) {\n120: \tstatus := metav1.ConditionFalse\n121: \tif progressing {\n122: \t\tstatus = metav1.ConditionTrue\n123: \t}\n124: \tSetCondition(conditions, ConditionTypeProgressing, status, reason, message)\n125: }\n126: \n127: func SetAvailableCondition(conditions *[]metav1.Condition, available bool, reason, message string) {\n128: \tstatus := metav1.ConditionFalse\n129: \tif available {\n130: \t\tstatus = metav1.ConditionTrue\n131: \t}\n132: \tSetCondition(conditions, ConditionTypeAvailable, status, reason, message)\n133: }\n134: \n135: func SetSandboxCreatedCondition(conditions *[]metav1.Condition, created bool, reason, message string) {\n136: \tstatus := metav1.ConditionFalse\n137: \tif created {\n138: \t\tstatus = metav1.ConditionTrue\n139: \t}\n140: \tSetCondition(conditions, ConditionTypeSandboxCreated, status, reason, message)\n141: }\n142: \n143: func GetConditionMessage(conditions []metav1.Condition, 