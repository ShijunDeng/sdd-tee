{"type":"tool_use","timestamp":1775846995188,"sessionID":"ses_28745fd73ffepLMcTLtooTm4f5","part":{"id":"prt_d78bab02700132Ws5u2e2qPZSf","messageID":"msg_d78baa091001A108EGbEAVDdXi","sessionID":"ses_28745fd73ffepLMcTLtooTm4f5","type":"tool","tool":"read","callID":"toolu_tool-47456cde3aee4c6bbe8a2c89032c6b6f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/predicates.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/predicates.go</path>\n<type>file</type>\n<content>\n1: package reconciler\n2: \n3: import (\n4: \tcorev1 \"k8s.io/api/core/v1\"\n5: \t\"k8s.io/apimachinery/pkg/types\"\n6: \t\"sigs.k8s.io/controller-runtime/pkg/client\"\n7: \t\"sigs.k8s.io/controller-runtime/pkg/controller/controllerutil\"\n8: \t\"sigs.k8s.io/controller-runtime/pkg/event\"\n9: \t\"sigs.k8s.io/controller-runtime/pkg/predicate\"\n10: )\n11: \n12: const (\n13: \tLabelKind         = \"runtime.agentcube.volcano.sh/kind\"\n14: \tLabelWorkloadName = \"runtime.agentcube.volcano.sh/workload-name\"\n15: )\n16: \n17: type ResourceGenerationChangedPredicate struct {\n18: \tpredicate.Funcs\n19: }\n20: \n21: func (p *ResourceGenerationChangedPredicate) Update(e event.UpdateEvent) bool {\n22: \tif e.ObjectOld == nil || e.ObjectNew == nil {\n23: \t\treturn false\n24: \t}\n25: \n26: \toldGen := e.ObjectOld.GetGeneration()\n27: \tnewGen := e.ObjectNew.GetGeneration()\n28: \n29: \tif oldGen == newGen {\n30: \t\treturn false\n31: \t}\n32: \n33: \treturn true\n34: }\n35: \n36: func (p *ResourceGenerationChangedPredicate) Create(e event.CreateEvent) bool {\n37: \treturn true\n38: }\n39: \n40: func (p *ResourceGenerationChangedPredicate) Delete(e event.DeleteEvent) bool {\n41: \treturn true\n42: }\n43: \n44: type LabelChangedPredicate struct {\n45: \tpredicate.Funcs\n46: }\n47: \n48: func (p *LabelChangedPredicate) Update(e event.UpdateEvent) bool {\n49: \tif e.ObjectOld == nil || e.ObjectNew == nil {\n50: \t\treturn false\n51: \t}\n52: \n53: \toldLabels := e.ObjectOld.GetLabels()\n54: \tnewLabels := e.ObjectNew.GetLabels()\n55: \n56: \tif len(oldLabels) != len(newLabels) {\n57: \t\treturn true\n58: \t}\n59: \n60: \tfor k, v := range oldLabels {\n61: \t\tif newLabels[k] != v {\n62: \t\t\treturn true\n63: \t\t}\n64: \t}\n65: \n66: \treturn false\n67: }\n68: \n69: type AnnotationChangedPredicate struct {\n70: \tpredicate.Funcs\n71: }\n72: \n73: func (p *AnnotationChangedPredicate) Update(e event.UpdateEvent) bool {\n74: \tif e.ObjectOld == nil || e.ObjectNew == nil {\n75: \t\treturn false\n76: \t}\n77: \n78: \toldAnnotations := e.ObjectOld.GetAnnotations()\n79: \tnewAnnotations := e.ObjectNew.GetAnnotations()\n80: \n81: \tif len(oldAnnotations) != len(newAnnotations) {\n82: \t\treturn true\n83: \t}\n84: \n85: \tfor k, v := range oldAnnotations {\n86: \t\tif newAnnotations[k] != v {\n87: \t\t\treturn true\n88: \t\t}\n89: \t}\n90: \n91: \treturn false\n92: }\n93: \n94: type PauseAnnotationPredicate struct {\n95: \tpredicate.Funcs\n96: }\n97: \n98: func (p *PauseAnnotationPredicate) Update(e event.UpdateEvent) bool {\n99: \tif e.ObjectNew == nil {\n100: \t\treturn false\n101: \t}\n102: \n103: \treturn !p.isPaused(e.ObjectNew.GetAnnotations())\n104: }\n105: \n106: func (p *PauseAnnotationPredicate) Create(e event.CreateEvent) bool {\n107: \tif e.Object == nil {\n108: \t\treturn false\n109: \t}\n110: \n111: \treturn !p.isPaused(e.Object.GetAnnotations())\n112: }\n113: \n114: func (p *PauseAnnotationPredicate) Delete(e event.DeleteEvent) bool {\n115: \treturn true\n116: }\n117: \n118: func (p *PauseAnnotationPredicate) isPaused(annotations map[string]string) bool {\n119: \tif annotations == nil {\n120: \t\treturn false\n121: \t}\n122: \n123: \tval, ok := annotations[\"agentcube.volcano.sh/paused\"]\n124: \treturn ok && val == \"true\"\n125: }\n126: \n127: func IsBeingDeleted(obj client.Object) bool {\n128: \treturn !obj.GetDeletionTimestamp().IsZero()\n129: }\n130: \n131: func HasOwnerReference(obj client.Object, owner types.UID) bool {\n132: \tfor _, ref := range obj.GetOwnerReferences() {\n133: \t\tif ref.UID == owner {\n134: \t\t\treturn true\n135: \t\t}\n136: \t}\n137: \treturn false\n138: }\n139: \n140: func AddOwnerReference(obj, owner client.Object) error {\n141: \treturn controllerutil.SetControllerReference(owner, obj, nil)\n142: }\n143: \n144: func AddLabels(obj client.Object, labels map[string]string) {\n145: \texisting := obj.GetLabels()\n146: \tif existing == nil {\n147: \t\texisting = make(map[string]string)\n148: \t}\n149: \n150: \tfor k, v := range labels {\n151: \t\texisting[k] = v\n152: \t}\n153: \n154: \tobj.SetLabels(existing)\n155: }\n156: \n157: func AddAnnotations(obj client.Object, annotations map[string]string) {\n158: \texisting := obj.GetAnnotations()\n159: \tif existing == nil {\n160: \t\texisting = make(map[string]string)\n161: \t}\n162: \n163: \tfor k, v := range annotations {\n164: \t\texisting[k] = v\n165: \t}\n166: \n167: \tobj.SetAnnotations(existing)\n168: }\n169: \n170: func IsPodReady(pod *corev1.Pod) bool {\n171: \tfor _, condition := range pod.Status.Conditions {\n172: \t\tif condition.Type == corev1.PodReady && condition.Status == corev1.ConditionTrue {\n173: \t\t\treturn true\n174: \t\t}\n175: \t}\n176: \treturn false\n177: }\n178: \n179: func GetPodCondition(pod *corev1.Pod, conditionType corev1.PodConditionType) *corev1.PodCondition {\n180: \tfor _, condition := range pod.Status.Conditions {\n181: \t\tif condition.Type == conditionType {\n182: \t\t\treturn &condition\n183: \t\t}\n184: \t}\n185: \treturn nil\n186: }\n\n(End of file - total 186 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/controller/controllerutil\"\n\t\"sigs.k8s.io/controller-runtime/pkg/event\"\n\t\"sigs.k8s.io/controller-runtime/pkg/predicate\"\n)\n\nconst (\n\tLabelKind         = \"runtime.agentcube.volcano.sh/kind\"\n\tLabelWorkloadName = \"runtime.agentcube.volcano.sh/workload-name\"\n)\n\ntype ResourceGenerationChangedPredicate struct {\n\tpredicate.Funcs\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/predicates.go","time":{"start":1775846995173,"end":1775846995186}}}}
