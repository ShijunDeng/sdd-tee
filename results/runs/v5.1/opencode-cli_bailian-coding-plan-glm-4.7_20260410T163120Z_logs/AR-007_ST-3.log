,\n\t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n\t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n\t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n\t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\t\t\t\t\tImage: \"python:3.11-slim\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\t\t\t\n\t\t\tExpect(fakeClient.Create(ctx, agentRuntime)).To(Succeed())\n\t\t\t\n\t\t\treq := reconcile.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t\tName:      \"test-runtime\",\n\t\t\t\t},\n\t\t\t}\n\t\t\t\n\t\t\t_, err := reconciler.Reconcile(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t\n\t\t\t// Verify finalizer was added\n\t\t\tupdated := &runtimev1alpha1.AgentRuntime{}\n\t\t\tExpect(fakeClient.Get(ctx, client.ObjectKey{\n\t\t\t\tNamespace: \"default\",\n\t\t\t\tName:      \"test-runtime\",\n\t\t\t}, updated)).To(Succeed())\n\t\t\tExpect(updated.Finalizers).To(ContainElement(reconciler.FinalizerAgentRuntime))\n\t\t})\n\t})\n\n\tContext(\"Reconcile deletion\", func() {\n\t\tIt(\"should delete sandbox resource when AgentRuntime is deleted\", func() {\n\t\t\t// Create AgentRuntime\n\t\t\tagentRuntime := &runtimev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"test-runtime\",\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t\tFinalizers: []string{reconciler.FinalizerAgentRuntime},\n\t\t\t\t},\n\t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n\t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n\t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n\t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\t\t\t\t\tImage: \"python:3.11-slim\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\t\t\t\n\t\t\tExpect(fakeClient.Create(ctx, agentRuntime)).To(Succeed())\n\t\t\t\n\t\t\t// Create sandbox\n\t\t\tsandbox := &unstructured.Unstructured{}\n\t\t\tsandbox.SetGroupVersionKind(schema.GroupVersionKind{\n\t\t\t\tGroup:   \"agents.x-k8s.io\",\n\t\t\t\tVersion: \"v1alpha1\",\n\t\t\t\tKind:    \"Sandbox\",\n\t\t\t})\n\t\t\tsandbox.SetName(\"test-runtime-sandbox\")\n\t\t\tsandbox.SetNamespace(\"default\")\n\t\t\tExpect(fakeClient.Create(ctx, sandbox)).To(Succeed())\n\t\t\t\n\t\t\t// Delete AgentRuntime\n\t\t\tExpect(fakeClient.Delete(ctx, agentRuntime)).To(Succeed())\n\t\t\t\n\t\t\treq := reconcile.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t\tName:      \"test-runtime\",\n\t\t\t\t},\n\t\t\t}\n\t\t\t\n\t\t\t_, err := reconciler.Reconcile(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t\n\t\t\t// Verify sandbox was deleted\n\t\t\terr = fakeClient.Get(ctx, client.ObjectKey{\n\t\t\t\tNamespace: \"default\",\n\t\t\t\tName:      \"test-runtime-sandbox\",\n\t\t\t}, sandbox)\n\t\t\tExpect(apierrors.IsNotFound(err)).To(BeTrue())\n\t\t})\n\t})\n\n\tContext(\"Error handling\", func() {\n\t\tIt(\"should handle invalid spec gracefully\", func() {\n\t\t\tagentRuntime := &runtimev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"test-runtime\",\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t},\n\t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n\t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n\t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n\t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\t\t\t\n\t\t\tExpect(fakeClient.Create(ctx, agentRuntime)).To(Succeed())\n\t\t\t\n\t\t\treq := reconcile.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t\tName:      \"test-runtime\",\n\t\t\t\t},\n\t\t\t}\n\t\t\t\n\t\t\t_, err := reconciler.Reconcile(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t\n\t\t\t// Verify error condition was set\n\t\t\tupdated := &runtimev1alpha1.AgentRuntime{}\n\t\t\tExpect(fakeClient.Get(ctx, client.ObjectKey{\n\t\t\t\tNamespace: \"default\",\n\t\t\t\tName:      \"test-runtime\",\n\t\t\t}, updated)).To(Succeed())\n\t\t\t\n\t\t\terrorCondition := reconciler.GetCondition(updated.Status.Conditions, reconciler.ConditionTypeError)\n\t\t\tExpect(errorCondition).NotTo(BeNil())\n\t\t\tExpect(errorCondition.Status).To(Equal(metav1.ConditionFalse))\n\t\t})\n\t})\n})\n```\n\n### Integration Tests\n\n**File**: `pkg/workloadmanager/controller/reconciler/integration_test.go`\n\n```go\npackage reconciler_test\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes/scheme\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/envtest\"\n\t\"sigs.k8s.io/controller-runtime/pkg/manager\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/controller/reconciler\"\n)\n\nvar (\n\tenvTest   *envtest.Environment\n\tk8sClient client.Client\n\tmgr       manager.Manager\n)\n\nvar _ = BeforeSuite(func() {\n\terr := runtimev1alpha1.AddToScheme(scheme.Scheme)\n\tExpect(err).NotTo(HaveOccurred())\n\t\n\tenvTest = &envtest.Environment{\n\t\tCRDDirectoryPaths: []string{\n\t\t\t\"../../../manifests/charts/base/crds\",\n\t\t},\n\t}\n\t\n\tcfg, err := envTest.Start()\n\tExpect(err).NotTo(HaveOccurred())\n\t\n\tk8sClient, err = client.New(cfg, client.Options{Scheme: scheme.Scheme})\n\tExpect(err).NotTo(HaveOccurred())\n\t\n\tmgr, err = manager.New(cfg, manager.Options{\n\t\tScheme: scheme.Scheme,\n\t})\n\tExpect(err).NotTo(HaveOccurred())\n\t\n\tcontrollerCfg := &reconciler.ControllerConfig{\n\t\tRequeueAfter:          10 * time.Second,\n\t\tMaxConcurrentReconciles: 2,\n\t}\n\t\n\terr = reconciler.SetupWithManager(mgr, nil, controllerCfg)\n\tExpect(err).NotTo(HaveOccurred())\n\t\n\tgo func() {\n\t\terr = mgr.Start(context.Background())\n\t\tExpect(err).NotTo(HaveOccurred())\n\t}()\n})\n\nvar _ = AfterSuite(func() {\n\terr := envTest.Stop()\n\tExpect(err).NotTo(HaveOccurred())\n})\n\nvar _ = Describe(\"AgentRuntime Reconciler Integration\", func() {\n\tContext(\"Full lifecycle\", func() {\n\t\tIt(\"should create, update, and delete AgentRuntime with sandbox\", func(ctx SpecContext) {\n\t\t\tnamespace := \"default\"\n\t\t\t\n\t\t\t// Create AgentRuntime\n\t\t\tagentRuntime := &runtimev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"integration-test-runtime\",\n\t\t\t\t\tNamespace: namespace,\n\t\t\t\t},\n\t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n\t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n\t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n\t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\t\t\t\t\tImage: \"python:3.11-slim\",\n\t\t\t\t\t\t\t\t\tPorts: []runtimev1alpha1.SandboxContainerPort{\n\t\t\t\t\t\t\t\t\t\t{ContainerPort: 8080, Protocol: \"TCP\"},\n\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\t\t\t\n\t\t\terr := k8sClient.Create(ctx, agentRuntime)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t\n\t\t\t// Wait for sandbox to be created\n\t\t\tEventually(func() bool {\n\t\t\t\tsandbox := &unstructured.Unstructured{}\n\t\t\t\tsandbox.SetGroupVersionKind(schema.GroupVersionKind{\n\t\t\t\t\tGroup:   \"agents.x-k8s.io\",\n\t\t\t\t\tVersion: \"v1alpha1\",\n\t\t\t\t\tKind:    \"Sandbox\",\n\t\t\t\t})\n\t\t\t\terr := k8sClient.Get(ctx, client.ObjectKey{\n\t\t\t\t\tNamespace: namespace,\n\t\t\t\t\tName:      \"integration-test-runtime-sandbox\",\n\t\t\t\t}, sandbox)\n\t\t\t\treturn err == nil\n\t\t\t}, 30*time.Second, 2*time.Second).Should(BeTrue())\n\t\t\t\n\t\t\t// Verify AgentRuntime status\n\t\t\tEventually(func() bool {\n\t\t\t\tupdated := &runtimev1alpha1.AgentRuntime{}\n\t\t\t\terr := k8sClient.Get(ctx, client.ObjectKey{\n\t\t\t\t\tNamespace: namespace,\n\t\t\t\t\tName:      \"integration-test-runtime\",\n\t\t\t\t}, updated)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\treturn reconciler.IsReady(updated.Status.Conditions)\n\t\t\t}, 30*time.Second, 2*time.Second).Should(BeTrue())\n\t\t\t\n\t\t\t// Update AgentRuntime\n\t\t\tEventually(func() error {\n\t\t\t\tupdated := &runtimev1alpha1.AgentRuntime{}\n\t\t\t\terr := k8sClient.Get(ctx, client.ObjectKey{\n\t\t\t\t\tNamespace: namespace,\n\t\t\t\t\tName:      \"integration-test-runtime\",\n\t\t\t\t}, updated)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t\tupdated.Spec.SessionTimeout = &metav1.Duration{Duration: 30 * time.Minute}\n\t\t\t\treturn k8sClient.Update(ctx, updated)\n\t\t\t}, 10*time.Second, 2*time.Second).Should(Succeed())\n\t\t\t\n\t\t\t// Delete AgentRuntime\n\t\t\tEventually(func() error {\n\t\t\t\tupdated := &runtimev1alpha1.AgentRuntime{}\n\t\t\t\terr := k8sClient.Get(ctx, client.ObjectKey{\n\t\t\t\t\tNamespace: namespace,\n\t\t\t\t\tName:      \"integration-test-runtime\",\n\t\t\t\t}, updated)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t\treturn k8sClient.Delete(ctx, updated)\n\t\t\t}, 10*time.Second, 2*time.Second).Should(Succeed())\n\t\t\t\n\t\t\t// Wait for sandbox to be deleted\n\t\t\tEventually(func() bool {\n\t\t\t\tsandbox := &unstructured.Unstructured{}\n\t\t\t\tsandbox.SetGroupVersionKind(schema.GroupVersionKind{\n\t\t\t\t\tGroup:   \"agents.x-k8s.io\",\n\t\t\t\t\tVersion: \"v1alpha1\",\n\t\t\t\t\tKind:    \"Sandbox\",\n\t\t\t\t})\n\t\t\t\terr := k8sClient.Get(ctx, client.ObjectKey{\n\t\t\t\t\tNamespace: namespace,\n\t\t\t\t\tName:      \"integration-test-runtime-sandbox\",\n\t\t\t\t}, sandbox)\n\t\t\t\treturn apierrors.IsNotFound(err)\n\t\t\t}, 30*time.Second, 2*time.Second).Should(BeTrue())\n\t\t}, SpecTimeout(2*time.Minute))\n\t})\n})\n```\n\n## Dependencies\n\n### Go Module Dependencies\n\n```go\nrequire (\n    sigs.k8s.io/controller-runtime v0.19.2\n    sigs.k8s.io/controller-runtime/pkg/log v0.19.2\n    sigs.k8s.io/controller-runtime/pkg/client v0.19.2\n    sigs.k8s.io/controller-runtime/pkg/reconcile v0.19.2\n    sigs.k8s.io/controller-runtime/pkg/controller v0.19.2\n    sigs.k8s.io/controller-runtime/pkg/event v0.19.2\n    sigs.k8s.io/controller-runtime/pkg/predicate v0.19.2\n    sigs.k8s.io/controller-runtime/pkg/manager v0.19.2\n    k8s.io/apimachinery v0.32.1\n    k8s.io/api v0.32.1\n    k8s.io/client-go v0.32.1\n    sigs.k8s.io/agent-sandbox v0.6.0\n    github.com/prometheus/client_golang v1.20.5\n    github.com/go-logr/logr v1.4.1\n    k8s.io/klog/v2 v2.130.1\n)\n```\n\n### Kubernetes RBAC Permissions\n\n```yaml\napiVersion: rbac.authorization.k8s.io/v1\nkind: ClusterRole\nmetadata:\n  name: agentcube-reconciler\nrules:\n  # AgentRuntime and CodeInterpreter CRDs\n  - apiGroups: [\"runtime.agentcube.volcano.sh\"]\n    resources: [\"agentruntimes\", \"agentruntimes/status\", \"agentruntimes/finalizers\"]\n    verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"]\n  \n  - apiGroups: [\"runtime.agentcube.volcano.sh\"]\n    resources: [\"codeinterpreters\", \"codeinterpreters/status\", \"codeinterpreters/finalizers\"]\n    verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"]\n  \n  # Sandbox resources\n  - apiGroups: [\"agent-sandbox.volcano.sh\"]\n    resources: [\"sandboxes\"]\n    verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"delete\"]\n  \n  # Events\n  - apiGroups: [\"\"]\n    resources: [\"events\"]\n    verbs: [\"create\", \"patch\"]\n  \n  # ConfigMaps (for configuration)\n  - apiGroups: [\"\"]\n    resources: [\"configmaps\"]\n    verbs: [\"get\", \"list\", \"watch\"]\n```\n\n## Integration Points\n\n### With Existing Controller\n\nThe new reconciler-based controllers will coexist with the existing HTTP-based controller:\n\n- The HTTP controller continues to handle on-demand sandbox creation for sessions\n- The reconciler controllers handle the lifecycle of AgentRuntime and CodeInterpreter CRDs\n- Both use the same client-go and store interfaces\n\n### With WorkloadManager\n\nThe reconciler controllers are integrated into the WorkloadManager:\n\n- The controller manager is started as part of the WorkloadManager main process\n- Shared configuration and dependencies are injected\n- Metrics are exposed through the WorkloadManager metrics endpoint\n\n### With Session Store\n\nThe reconciler controllers may use the session store for:\n\n- Storing metadata about sandbox resources\n- Tracking active sessions for a given AgentRuntime/CodeInterpreter\n- Implementing cleanup logic for orphaned sessions\n\n## Documentation\n\n### Configuration\n\nThe reconciler configuration should be documented in `docs/configuration.md`:\n\n```yaml\n# Controller configuration\ncontroller:\n  # Requeue interval for reconciliation\n  requeueAfter: 10s\n  \n  # Maximum number of concurrent reconciles per controller\n  maxConcurrentReconciles: 2\n  \n  # Full resync period (optional)\n  syncPeriod: 10m\n  \n  # Leader election\n  enableLeaderElection: true\n  leaderElectionID: \"agentcube-reconciler\"\n  leaderElectionNamespace: \"agentcube-system\"\n  \n  # Metrics\n  metricsAddr: \":8080\"\n  enableProfiling: true\n  \n  # Health probes\n  probeAddr: \":8081\"\n```\n\n### Usage Examples\n\n**Example AgentRuntime with reconciler-managed sandbox** (`examples/agentruntime-reconciler.yaml`):\n\n```yaml\napiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: AgentRuntime\nmetadata:\n  name: python-agent\n  namespace: agentcube\nspec:\n  sessionTimeout: \"15m\"\n  maxSessionDuration: \"8h\"\n  podTemplate:\n    metadata:\n      labels:\n        app: python-agent\n    spec:\n      containers:\n      - name: agent\n        image: ghcr.io/volcano-sh/python-agent:latest\n        ports:\n        - containerPort: 8080\n          protocol: TCP\n        resources:\n          limits:\n            cpu: \"500m\"\n            memory: \"512Mi\"\n          requests:\n            cpu: \"100m\"\n            memory: \"128Mi\"\n```\n\nThe reconciler will automatically create and manage the sandbox resource for this AgentRuntime.\n\n## Migration Path\n\n### Phase 1: Implement Reconcilers\n\n- Implement AgentRuntimeReconciler and CodeInterpreterReconciler\n- Add unit tests for both reconcilers\n- Add integration tests using envtest\n\n### Phase 2: Integrate with WorkloadManager\n\n- Add reconciler setup to WorkloadManager main process\n- Enable controller manager with reconcilers\n- Add configuration options for reconcilers\n\n### Phase 3: Deploy and Validate\n\n- Deploy reconciler-based controllers\n- Monitor metrics and logs\n- Validate that sandbox resources are created and managed correctly\n\n### Phase 4: Optional Migration\n\n- Evaluate whether to migrate HTTP-based sandbox creation to use reconciler\n- Consider deprecating direct sandbox creation in favor of CRD-based approach\n\n## Success Criteria\n\n- [ ] AgentRuntimeReconciler successfully creates and manages sandbox resources\n- [ ] CodeInterpreterReconciler successfully creates and manages sandbox resources\n- [ ] Status conditions are accurately updated during reconciliation\n- [ ] Finalizers are properly handled for resource deletion\n- [ ] Events are recorded for all significant operations\n- [ ] Metrics are exposed and can be scraped by Prometheus\n- [ ] Unit tests cover all major code paths\n- [ ] Integration tests validate end-to-end reconciliation\n- [ ] Error handling is robust and provides clear feedback\n- [ ] Reconciler can handle spec changes gracefully\n- [ ] Leader election works correctly in HA deployments","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-007/design.md"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/deepcopy.go":[{"range":{"start":{"line":22,"character":1},"end":{"line":22,"character":7}},"severity":2,"code":"default","codeDescription":{"href":"https://staticcheck.dev/docs/checks/#S1023"},"source":"S1023","message":"redundant return statement"},{"range":{"start":{"line":52,"character":1},"end":{"line":52,"character":7}},"severity":2,"code":"default","codeDescription":{"href":"https://staticcheck.dev/docs/checks/#S1023"},"source":"S1023","message":"redundant return statement"},{"range":{"start":{"line":88,"character":1},"end":{"line":88,"character":7}},"severity":2,"code":"default","codeDescription":{"href":"https://staticcheck.dev/docs/checks/#S1023"},"source":"S1023","message":"redundant return statement"},{"range":{"start":{"line":109,"character":1},"end":{"line":109,"character":7}},"severity":2,"code":"default","codeDescription":{"href":"https://staticcheck.dev/docs/checks/#S1023"},"source":"S1023","message":"redundant return statement"},{"range":{"start":{"line":129,"character":1},"end":{"line":129,"character":7}},"severity":2,"code":"default","codeDescription":{"href":"https://staticcheck.dev/docs/checks/#S1023"},"source":"S1023","message":"redundant return statement"},{"range":{"start":{"line":157,"character":1},"end":{"line":157,"character":7}},"severity":2,"code":"default","codeDescription":{"href":"https://staticcheck.dev/docs/checks/#S1023"},"source":"S1023","message":"redundant return statement"},{"range":{"start":{"line":209,"character":1},"end":{"line":209,"character":7}},"severity":2,"code":"default","codeD