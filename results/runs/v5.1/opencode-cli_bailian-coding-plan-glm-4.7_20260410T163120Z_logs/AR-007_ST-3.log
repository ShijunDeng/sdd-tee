NPath=\".metadata.creationTimestamp\"\n739: \n740: // CodeInterpreter defines a custom resource for managing code execution environments.\n741: // It represents a code interpreter sandbox that executes user code in a secure environment.\n742: type CodeInterpreter struct {\n743: \tmetav1.TypeMeta   `json:\",inline\"`\n744: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n745: \n746: \tSpec   CodeInterpreterSpec   `json:\"spec,omitempty\"`\n747: \tStatus CodeInterpreterStatus `json:\"status,omitempty\"`\n748: }\n749: \n750: // CodeInterpreterSpec defines the desired state of a CodeInterpreter.\n751: type CodeInterpreterSpec struct {\n752: \t// Image is the container image for the interpreter (e.g., \"python:3.11-slim\").\n753: \t// +required\n754: \tImage string `json:\"image\"`\n755: \n756: \t// Runtime specifies the execution environment type.\n757: \t// +kubebuilder:default=\"python\"\n758: \t// +kubebuilder:validation:Enum=python;javascript;typescript;go\n759: \t// +optional\n760: \tRuntime string `json:\"runtime,omitempty\"`\n761: \n762: \t// Timeout defines the maximum execution time for code snippets.\n763: \t// +kubebuilder:default=\"5m\"\n764: \t// +kubebuilder:validation:Type=string\n765: \t// +kubebuilder:validation:Format=duration\n766: \t// +optional\n767: \tTimeout *metav1.Duration `json:\"timeout,omitempty\"`\n768: \n769: \t// Resources defines compute resource requirements for the interpreter container.\n770: \t// +optional\n771: \tResources *SandboxContainerResources `json:\"resources,omitempty\"`\n772: \n773: \t// Env defines environment variables to inject into the interpreter container.\n774: \t// +optional\n775: \tEnv []SandboxEnvVar `json:\"env,omitempty\"`\n776: \n777: \t// EnabledPackages specifies allowed packages for the interpreter.\n778: \t// Only packages listed here can be imported/required. Empty list allows all.\n779: \t// +optional\n780: \tEnabledPackages []string `json:\"enabledPackages,omitempty\"`\n781: }\n782: \n783: // CodeInterpreterStatus defines the observed state of a CodeInterpreter.\n784: type CodeInterpreterStatus struct {\n785: \t// Ready indicates whether the interpreter is ready to execute code.\n786: \t// +optional\n787: \tReady bool `json:\"ready,omitempty\"`\n788: \n789: \t// Conditions represent the latest available observations of the CodeInterpreter's current state.\n790: \t// +optional\n791: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n792: \n793: \t// ObservedGeneration is the most recent generation observed by the controller.\n794: \t// +optional\n795: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n796: }\n797: \n798: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n799: \n800: // CodeInterpreterList contains a list of CodeInterpreter objects.\n801: type CodeInterpreterList struct {\n802: \tmetav1.TypeMeta `json:\",inline\"`\n803: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n804: \n805: \tItems []CodeInterpreter `json:\"items\"`\n806: }\n\n(End of file - total 806 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/util/intstr\"\n)\n\n// +genclient\n// +genclient:nonNamespaced\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +k8s:openapi-gen=true\n// +kubebuilder:resource:shortName=ar;agentruntime\n// +kubebuilder:subresource:status\n// +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n\n// AgentRuntime defines a custom resource for managing agent runtime configurations.\n// It represents a sandbox orchestration runtime that manages the lifecycle of agent pods.\ntype AgentRuntime struct {\n\tmetav1.TypeMeta   `json:\",inline\"`\n\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types.go","time":{"s