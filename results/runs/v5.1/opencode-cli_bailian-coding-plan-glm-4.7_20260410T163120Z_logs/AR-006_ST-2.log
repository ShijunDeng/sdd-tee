preterStatus defines the observed state of a CodeInterpreter.\n784: type CodeInterpreterStatus struct {\n785: \t// Ready indicates whether the interpreter is ready to execute code.\n786: \t// +optional\n787: \tReady bool `json:\"ready,omitempty\"`\n788: \n789: \t// Conditions represent the latest available observations of the CodeInterpreter's current state.\n790: \t// +optional\n791: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n792: \n793: \t// ObservedGeneration is the most recent generation observed by the controller.\n794: \t// +optional\n795: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n796: }\n797: \n798: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n799: \n800: // CodeInterpreterList contains a list of CodeInterpreter objects.\n801: type CodeInterpreterList struct {\n802: \tmetav1.TypeMeta `json:\",inline\"`\n803: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n804: \n805: \tItems []CodeInterpreter `json:\"items\"`\n806: }\n\n(End of file - total 806 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/util/intstr\"\n)\n\n// +genclient\n// +genclient:nonNamespaced\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +k8s:openapi-gen=true\n// +kubebuilder:resource:shortName=ar;agentruntime\n// +kubebuilder:subresource:status\n// +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n\n// AgentRuntime defines a custom resource for managing agent runtime configurations.\n// It represents a sandbox orchestration runtime that manages the lifecycle of agent pods.\ntype AgentRuntime struct {\n\tmetav1.TypeMeta   `json:\",inline\"`\n\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types.go","time":{"s