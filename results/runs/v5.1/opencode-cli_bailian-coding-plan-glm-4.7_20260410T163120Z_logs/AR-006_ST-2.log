{"type":"tool_use","timestamp":1775844863315,"sessionID":"ses_287669e8cffe9eejhbdIpiHeM8","part":{"id":"prt_d789a2a64001aJmW4Zl3XHDDgR","messageID":"msg_d789a192e0015IQqwJdhjjJtVG","sessionID":"ses_287669e8cffe9eejhbdIpiHeM8","type":"tool","tool":"read","callID":"toolu_tool-bb43dc6b20874bb495cd446eecf68a1c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/handler/sandbox_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/handler/sandbox_test.go</path>\n<type>file</type>\n<content>\n1: package handler\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"net/http\"\n7: \t\"net/http/httptest\"\n8: \t\"testing\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"github.com/stretchr/testify/assert\"\n13: \t\"github.com/stretchr/testify/mock\"\n14: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n15: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n16: \t\"k8s.io/apimachinery/pkg/runtime\"\n17: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n18: \t\"k8s.io/client-go/dynamic/fake\"\n19: \n20: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n21: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n22: \twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n23: )\n24: \n25: type mockStore struct {\n26: \tmock.Mock\n27: }\n28: \n29: func (m *mockStore) Ping(ctx context.Context) error {\n30: \targs := m.Called(ctx)\n31: \treturn args.Error(0)\n32: }\n33: \n34: func (m *mockStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n35: \targs := m.Called(ctx, sessionID)\n36: \tif args.Get(0) == nil {\n37: \t\treturn nil, args.Error(1)\n38: \t}\n39: \treturn args.Get(0).(*types.SandboxInfo), args.Error(1)\n40: }\n41: \n42: func (m *mockStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n43: \targs := m.Called(ctx, sessionID, info)\n44: \treturn args.Error(0)\n45: }\n46: \n47: func (m *mockStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n48: \targs := m.Called(ctx, sessionID, info)\n49: \treturn args.Error(0)\n50: }\n51: \n52: func (m *mockStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n53: \targs := m.Called(ctx, sessionID)\n54: \treturn args.Error(0)\n55: }\n56: \n57: func (m *mockStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n58: \targs := m.Called(ctx)\n59: \treturn args.Get(0).(map[string]*types.SandboxInfo), args.Error(1)\n60: }\n61: \n62: func (m *mockStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n63: \targs := m.Called(ctx, sessionID, at)\n64: \treturn args.Error(0)\n65: }\n66: \n67: func (m *mockStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n68: \targs := m.Called(ctx, before, limit)\n69: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n70: }\n71: \n72: func (m *mockStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n73: \targs := m.Called(ctx, before, limit)\n74: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n75: }\n76: \n77: func (m *mockStore) Close() error {\n78: \targs := m.Called()\n79: \treturn args.Error(0)\n80: }\n81: \n82: func buildUnstructuredSandbox(name, namespace string) *runtime.Unstructured {\n83: \treturn &runtime.Unstructured{\n84: \t\tObject: map[string]interface{}{\n85: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n86: \t\t\t\"kind\":       \"Sandbox\",\n87: \t\t\t\"metadata\": map[string]interface{}{\n88: \t\t\t\t\"name\":      name,\n89: \t\t\t\t\"namespace\": namespace,\n90: \t\t\t\t\"labels\": map[string]interface{}{\n91: \t\t\t\t\t\"runtime.agentcube.io/session-id\": \"test-session\",\n92: \t\t\t\t},\n93: \t\t\t},\n94: \t\t},\n95: \t}\n96: }\n97: \n98: func buildUnstructuredSandboxClaim(name, namespace string) *runtime.Unstructured {\n99: \treturn &runtime.Unstructured{\n100: \t\tObject: map[string]interface{}{\n101: \t\t\t\"apiVersion\": \"extensions.agents.x-k8s.io/v1alpha1\",\n102: \t\t\t\"kind\":       \"SandboxClaim\",\n103: \t\t\t\"metadata\": map[string]interface{}{\n104: \t\t\t\t\"name\":      name,\n105: \t\t\t\t\"namespace\": namespace,\n106: \t\t\t},\n107: \t\t},\n108: \t}\n109: }\n110: \n111: func TestHandleDeleteSandbox_Success(t *testing.T) {\n112: \tgin.SetMode(gin.TestMode)\n113: \n114: \tsessionID := \"test-session-123\"\n115: \tsandboxInfo := &types.SandboxInfo{\n116: \t\tSessionID:        sessionID,\n117: \t\tSandboxID:        \"test-sandbox-abc\",\n118: \t\tSandboxName:      \"test-sandbox\",\n119: \t\tSandboxNamespace: \"default\",\n120: \t\tKind:             \"Sandbox\",\n121: \t}\n122: \n123: \tmockStore := &mockStore{}\n124: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n125: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n126: \n127: \tscheme := runtime.NewScheme()\n128: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n129: \n130: \tsandboxObj := buildUnstructuredSandbox(sandboxInfo.SandboxID, sandboxInfo.SandboxNamespace)\n131: \tfakeDynamicClient.Resource(schema.GroupVersionResource{\n132: \t\tGroup:    \"agents.x-k8s.io\",\n133: \t\tVersion:  \"v1alpha1\",\n134: \t\tResource: \"sandboxes\",\n135: \t}).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n136: \n137: \thandler := NewSandboxHandler(fakeDynamicClient, mockStore)\n138: \n139: \tw := httptest.NewRecorder()\n140: \tc, _ := gin.CreateTestContext(w)\n141: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\"+sessionID, nil)\n142: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n143: \n144: \thandler.HandleDeleteSandbox(c)\n145: \n146: \tassert.Equal(t, http.StatusOK, w.Code)\n147: \tvar resp wmTypes.DeleteSandboxResponse\n148: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n149: \tassert.Equal(t, \"Sandbox deleted successfully\", resp.Message)\n150: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, sessionID)\n151: }\n152: \n153: func TestHandleDeleteSandbox_NotFound(t *testing.T) {\n154: \tgin.SetMode(gin.TestMode)\n155: \n156: \tsessionID := \"non-existent-session\"\n157: \tmockStore := &mockStore{}\n158: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(nil, store.ErrNotFound)\n159: \n160: \thandler := NewSandboxHandler(nil, mockStore)\n161: \n162: \tw := httptest.NewRecorder()\n163: \tc, _ := gin.CreateTestContext(w)\n164: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\"+sessionID, nil)\n165: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n166: \n167: \thandler.HandleDeleteSandbox(c)\n168: \n169: \tassert.Equal(t, http.StatusNotFound, w.Code)\n170: \tvar resp map[string]interface{}\n171: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n172: \tassert.Contains(t, resp[\"error\"], sessionID)\n173: \tassert.Contains(t, resp[\"error\"], \"not found\")\n174: }\n175: \n176: func TestHandleDeleteSandbox_EmptySessionID(t *testing.T) {\n177: \tgin.SetMode(gin.TestMode)\n178: \n179: \tmockStore := &mockStore{}\n180: \thandler := NewSandboxHandler(nil, mockStore)\n181: \n182: \tw := httptest.NewRecorder()\n183: \tc, _ := gin.CreateTestContext(w)\n184: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\", nil)\n185: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: \"\"}}\n186: \n187: \thandler.HandleDeleteSandbox(c)\n188: \n189: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n190: \tvar resp map[string]interface{}\n191: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n192: \tassert.Contains(t, resp[\"error\"], \"sessionId is required\")\n193: }\n194: \n195: func TestHandleDeleteSandbox_SandboxClaim(t *testing.T) {\n196: \tgin.SetMode(gin.TestMode)\n197: \n198: \tsessionID := \"test-session-claim\"\n199: \tsandboxInfo := &types.SandboxInfo{\n200: \t\tSessionID:        sessionID,\n201: \t\tSandboxID:        \"test-claim-abc\",\n202: \t\tSandboxName:      \"test-claim\",\n203: \t\tSandboxNamespace: \"default\",\n204: \t\tKind:             \"SandboxClaim\",\n205: \t}\n206: \n207: \tmockStore := &mockStore{}\n208: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n209: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n210: \n211: \tscheme := runtime.NewScheme()\n212: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n213: \n214: \tclaimObj := buildUnstructuredSandboxClaim(sandboxInfo.SandboxID, sandboxInfo.SandboxNamespace)\n215: \tfakeDynamicClient.Resource(schema.GroupVersionResource{\n216: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n217: \t\tVersion:  \"v1alpha1\",\n218: \t\tResource: \"sandboxclaims\",\n219: \t}).Namespace(\"default\").Create(context.Background(), claimObj, metav1.CreateOptions{})\n220: \n221: \thandler := NewSandboxHandler(fakeDynamicClient, mockStore)\n222: \n223: \tw := httptest.NewRecorder()\n224: \tc, _ := gin.CreateTestContext(w)\n225: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/code-interpreter/sessions/\"+sessionID, nil)\n226: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n227: \n228: \thandler.HandleDeleteSandbox(c)\n229: \n230: \tassert.Equal(t, http.StatusOK, w.Code)\n231: \t_, err := fakeDynamicClient.Resource(schema.GroupVersionResource{\n232: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n233: \t\tVersion:  \"v1alpha1\",\n234: \t\tResource: \"sandboxclaims\",\n235: \t}).Namespace(\"default\").Get(context.Background(), sandboxInfo.SandboxID, metav1.GetOptions{})\n236: \tassert.True(t, apierrors.IsNotFound(err))\n237: }\n238: \n239: func TestHandleDeleteSandbox_StoreError(t *testing.T) {\n240: \tgin.SetMode(gin.TestMode)\n241: \n242: \tsessionID := \"test-session\"\n243: \tmockStore := &mockStore{}\n244: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(nil, assert.AnError)\n245: \n246: \thandler := NewSandboxHandler(nil, mockStore)\n247: \n248: \tw := httptest.NewRecorder()\n249: \tc, _ := gin.CreateTestContext(w)\n250: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\"+sessionID, nil)\n251: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n252: \n253: \thandler.HandleDeleteSandbox(c)\n254: \n255: \tassert.Equal(t, http.StatusInternalServerError, w.Code)\n256: \tvar resp map[string]interface{}\n257: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n258: \tassert.Contains(t, resp[\"error\"], \"internal server error\")\n259: }\n\n(End of file - total 259 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/handler/sandbox_test.go","time":{"start":1775844863301,"end":1775844863314}}}}
