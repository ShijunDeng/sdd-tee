\t\t\tapi.Error(c, http.StatusNotFound, 40402, \"Session ID \"+sessionID+\" not found, maybe already deleted\")\n42: \t\t\treturn\n43: \t\t}\n44: \t\tklog.Errorf(\"Failed to get sandbox by session ID %s: %v\", sessionID, err)\n45: \t\tapi.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n46: \t\treturn\n47: \t}\n48: \n49: \tgvr := workloadmanager.SandboxGVR\n50: \tif sandboxInfo.Kind == \"SandboxClaim\" {\n51: \t\tgvr = workloadmanager.SandboxClaimGVR\n52: \t}\n53: \n54: \tdeleteCtx, cancel := context.WithTimeout(c.Request.Context(), workloadmanager.DeleteTimeout)\n55: \tdefer cancel()\n56: \n57: \terr = h.dynamicClient.Resource(gvr).\n58: \t\tNamespace(sandboxInfo.SandboxNamespace).\n59: \t\tDelete(deleteCtx, sandboxInfo.SandboxID, metav1.DeleteOptions{})\n60: \n61: \tif err != nil && !apierrors.IsNotFound(err) {\n62: \t\tklog.Errorf(\"Failed to delete sandbox %s/%s: %v\", sandboxInfo.SandboxNamespace, sandboxInfo.SandboxID, err)\n63: \t\tapi.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n64: \t\treturn\n65: \t}\n66: \n67: \tif err := h.storeClient.DeleteSandboxBySessionID(c.Request.Context(), sessionID); err != nil {\n68: \t\tklog.Warningf(\"Failed to delete sandbox %s from store: %v\", sessionID, err)\n69: \t}\n70: \n71: \tapi.JSON(c, http.StatusOK, wmTypes.DeleteSandboxResponse{\n72: \t\tMessage: \"Sandbox deleted successfully\",\n73: \t})\n74: }\n\n(End of file - total 74 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/api\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\n