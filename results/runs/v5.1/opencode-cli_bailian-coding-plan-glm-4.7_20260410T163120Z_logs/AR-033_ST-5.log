rpreter built successfully$(NC)\"\n\n.PHONY: build-agent-runtime\nbuild-agent-runtime: ## Build agent-runtime binary\n\t@echo \"$(BLUE)Building agent-runtime...$(NC)\"\n\t@mkdir -p $(BUILD_DIR)/$(PLATFORM)\n\t$(GO) build $(GOFLAGS) $(GO_BUILD_FLAGS) -o $(AGENT_RUNTIME_BIN) ./cmd/agent-runtime\n\t@echo \"$(GREEN)✓ agent-runtime built successfully$(NC)\"\n\n.PHONY: build-go-race\nbuild-go-race: ## Build all Go binaries with race detector\n\t@$(MAKE) BUILD_MODE=race build-go\n\n.PHONY: build-go-debug\nbuild-go-debug: ## Build all Go binaries with debug symbols\n\t@$(MAKE) GO_BUILD_FLAGS=\"-gcflags='all=-N -l'\" build-go\n\n.PHONY: build-go-release\nbuild-go-release: ## Build all Go binaries in release mode\n\t@$(MAKE) BUILD_MODE=release build-go\n\n.PHONY: build-go-fast\nbuild-go-fast: ## Build all Go binaries quickly (skip non-essential checks)\n\t@$(MAKE) GO_BUILD_FLAGS=\"\" build-go\n\n.PHONY: build-matrix-go\nbuild-matrix-go: ## Build Go binaries for all supported platforms\n\t@echo \"$(BLUE)Building Go binaries for all platforms...$(NC)\"\n\t@$(MAKE) GOOS=linux GOARCH=amd64 build-go\n\t@$(MAKE) GOOS=linux GOARCH=arm64 build-go\n\t@$(MAKE) GOOS=darwin GOARCH=amd64 build-go\n\t@$(MAKE) GOOS=darwin GOARCH=arm64 build-go\n\t@echo \"$(GREEN)✓ All platform builds completed$(NC)\"\n\n.PHONY: install-go\ninstall-go: build-go ## Install Go binaries to GOPATH/bin\n\t@echo \"$(BLUE)Installing Go binaries...$(NC)\"\n\t@cp $(BUILD_DIR)/$(PLATFORM)/agentd $$($(GO) env GOPATH)/bin/\n\t@cp $(BUILD_DIR)/$(PLATFORM)/picod $$($(GO) env GOPATH)/bin/\n\t@cp $(BUILD_DIR)/$(PLATFORM)/agentcube $$($(GO) env GOPATH)/bin/\n\t@cp $(BUILD_DIR)/$(PLATFORM)/agentcube-util $$($(GO) env GOPATH)/bin/\n\t@cp $(BUILD_DIR)/$(PLATFORM)/code-interpreter $$($(GO) env GOPATH)/bin/\n\t@cp $(BUILD_DIR)/$(PLATFORM)/agent-runtime $$($(GO) env GOPATH)/bin/\n\t@echo \"$(GREEN)✓ Go binaries installed$(NC)\"\n\n.PHONY: run-agentd\nrun-agentd: build-agentd ## Build and run agentd\n\t@echo \"$(BLUE)Running agentd