; \\\n\t\tblack agentcube/ cmd/cli/ tests/; \\\n\tfi\n\t@if command -v isort > /dev/null 2>&1; then \\\n\t\techo \"$(BLUE)Running isort...$(NC)\"; \\\n\t\tisort agentcube/ cmd/cli/ tests/; \\\n\tfi\n\t@echo \"$(GREEN)✓ Python code formatted$(NC)\"\n\n.PHONY: format-docker\nformat-docker: ## Format Dockerfiles\n\t@echo \"$(BLUE)Formatting Dockerfiles...$(NC)\"\n\t@if command -v dockerfile-format > /dev/null 2>&1; then \\\n\t\tdockerfile-format -i Dockerfile*; \\\n\tfi\n\t@echo \"$(GREEN)✓ Dockerfiles formatted$(NC)\"\n\n.PHONY: format-check-go\nformat-check-go: ## Check if Go code is formatted\n\t@echo \"$(BLUE)Checking Go code formatting...$(NC)\"\n\t@test -z $$($(GO) fmt ./...)\n\t@echo \"$(GREEN)✓ Go code is properly formatted$(NC)\"\n\n.PHONY: format-check-python\nformat-check-python: ## Check if Python code is formatted\n\t@echo \"$(BLUE)Checking Python code formatting...$(NC)\"\n\t@if command -v black > /dev/null 2>&1; then \\\n\t\tblack --check agentcube/ cmd/cli/ tests/; \\\n\tfi\n\t@if command -v isort > /dev/null 2>&1; then \\\n\t\tisort --check-only agentcube/ cmd/cli/ tests/; \\\n\tfi\n\t@echo \"$(GREEN)✓ Python code is properly formatted$(NC)\"\n\n.PHONY: format-check\nformat-check: format-check-go format-check-python ## Check if all code is formatted\n\n.PHONY: format-all\nformat-all: format-go format-python format-docker ## Format all code including Dockerfiles\n\n.PHONY: lint-all\nlint-all: lint-go lint-python lint-docker ## Run all linting checks including Docker\n\n.PHONY: security-scan\nsecurity-scan: ## Run security scanning\n\t@echo \"$(BLUE)Running security scans...$(NC)\"\n\t@if command -v gosec > /dev/null 2>&1; then \\\n\t\techo \"$(BLUE)Running gosec...$(NC)\"; \\\n\t\tgosec ./...; \\\n\telse \\\n\t\techo \"$(YELLOW)gosec not found, skipping...$(NC)\"; \\\n\tfi\n\t@if command -v bandit > /dev/null 2>&1; then \\\n\t\techo \"$(BLUE)Running bandit...$(NC)\"; \\\n\t\tbandit -r agentcube/; \\\n\telse \\\n\t\techo \"$(YELLOW)bandit not found, skipping...$(NC)\"; \\\n\tfi\n\t@if command -v trivy > /dev/null 2>&1; then \\\n\t\techo \"$(BLUE)Running trivy...$(NC)\"; \\\n\t\ttrivy fs .; \\\n\telse \\\n\t\techo \"$(YELLOW)trivy not found, skipping...$(NC)\"; \\\n\tfi\n\t@echo \"$(GREEN)✓ Security scans completed$(NC)\"\n\n.PHONY: go-vet\ngo-vet: ## Run go vet\n\t@echo \"$(BLUE)Running go vet...$(NC)\"\n\t@$(GO) vet ./...\n\t@echo \"$(GREEN)✓ go vet passed$(NC)\"\n\n.PHONY: go-fmt\ngo-fmt: ## Run go fmt\n\t@echo \"$(BLUE)Running go fmt...$(NC)\"\n\t@$(GO) fmt ./...\n\t@echo \"$(GREEN)✓ go fmt completed$(NC)\"\n\n.PHONY: goimports\ngoimports: ## Run goimports\n\t@echo \"$(BLUE)Running goimports...$(NC)\"\n\t@if command -v goimports > /dev/null 2>&1; then \\\n\t\tgoimports -w .; \\\n\t\techo \"$(GREEN)✓ goimports completed$(NC)\"; \\\n\telse \\\n\t\techo \"$(RED)goimports not found. Install with: go install golang.org/x/tools/cmd/goimports@latest$(NC)\"; \\\n\tfi\n\n.PHONY: ruff\nruff: ## Run ruff on Python code\n\t@echo \"$(BLUE)Running ruff...$(NC)\"\n\t@if command -v ruff > /dev/null 2>&1; then \\\n\t\truff check .; \\\n\t\techo \"$(GREEN)✓ ruff passed$(NC)\"; \\\n\telse \\\n\t\techo \"$(RED)ruff not found. Install with: pip install ruff$(NC)\"; \\\n\tfi\n\n.PHONY: black\nblack: ## Run black on Python code\n\t@echo \"$(BLUE)Running black...$(NC)\"\n\t@if command -v black > /dev/null 2>&1; then \\\n\t\tblack agentcube/ cmd/cli/ tests/; \\\n\t\techo \"$(GREEN)✓ black completed$(NC)\"; \\\n\telse \\\n\t\techo \"$(RED)black not found. Install with: pip install black$(NC)\"; \\\n\tfi\n\n.PHONY: mypy\nmypy: ## Run mypy on Python code\n\t@echo \"$(BLUE)Running mypy...$(NC)\"\n\t@if command -v mypy > /dev/null 2>&1; then \\\n\t\tmypy agentcube/ --ignore-missing-imports; \\\n\t\techo \"$(GREEN)✓ mypy completed$(NC)\"; \\\n\telse \\\n\t\techo \"$(RED)mypy not found. Install with: pip install mypy$(NC)\"; \\\n\tfi","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/.mak