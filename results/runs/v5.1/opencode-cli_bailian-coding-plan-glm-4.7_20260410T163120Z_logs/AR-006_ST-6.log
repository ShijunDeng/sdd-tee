\t\"podTemplate\": map[string]interface{}{\n87: \t\t\t\t\t\"spec\": map[string]interface{}{\n88: \t\t\t\t\t\t\"containers\": []interface{}{\n89: \t\t\t\t\t\t\tmap[string]interface{}{\n90: \t\t\t\t\t\t\t\t\"name\":  \"agent\",\n91: \t\t\t\t\t\t\t\t\"image\": \"python:3.11-slim\",\n92: \t\t\t\t\t\t\t},\n93: \t\t\t\t\t\t},\n94: \t\t\t\t\t},\n95: \t\t\t\t},\n96: \t\t\t\t\"ports\": []interface{}{\n97: \t\t\t\t\tmap[string]interface{}{\n98: \t\t\t\t\t\t\"port\":     int64(8080),\n99: \t\t\t\t\t\t\"protocol\": \"HTTP\",\n100: \t\t\t\t\t},\n101: \t\t\t\t},\n102: \t\t\t},\n103: \t\t},\n104: \t}\n105: }\n106: \n107: func createCodeInterpreter(name, namespace string) *unstructured.Unstructured {\n108: \treturn &unstructured.Unstructured{\n109: \t\tObject: map[string]interface{}{\n110: \t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n111: \t\t\t\"kind\":       \"CodeInterpreter\",\n112: \t\t\t\"metadata\": map[string]interface{}{\n113: \t\t\t\t\"name\":      name,\n114: \t\t\t\t\"namespace\": namespace,\n115: \t\t\t},\n116: \t\t\t\"spec\": map[string]interface{}{\n117: \t\t\t\t\"template\": map[string]interface{}{\n118: \t\t\t\t\t\"image\": \"python:3.11-slim\",\n119: \t\t\t\t},\n120: \t\t\t},\n121: \t\t},\n122: \t}\n123: }\n124: \n125: func createSandboxCR(name, namespace, sessionID, workloadName string) *unstructured.Unstructured {\n126: \treturn &unstructured.Unstructured{\n127: \t\tObject: map[string]interface{}{\n128: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n129: \t\t\t\"kind\":       \"Sandbox\",\n130: \t\t\t\"metadata\": map[string]interface{}{\n131: \t\t\t\t\"name\":      name,\n132: \t\t\t\t\"namespace\": namespace,\n133: \t\t\t\t\"uid\":       \"sandbox-uid-\" + uuid.New().String(),\n134: \t\t\t},\n135: \t\t\t\"spec\": map[string]interface{}{\n136: \t\t\t\t\"replicas\": int64(1),\n137: \t\t\t\t\"lifecycle\": map[string]interface{}{\n138: \t\t\t\t\t\"shutdownTime\": time.Now().Add(8 * time.Hour).Format(time.RFC3339),\n139: \t\t\t\t},\n140: \t\t\t},\n141: \t\t},\n142: \t}\n143: }\n144: \n145: func TestSandboxController_CreateAgentRuntimeSandbox(t *testing.T) {\n146: \ts := miniredis.RunT(t)\n147: \n148: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n149: \trequire.NoError(t, err)\n150: \tdefer redisStore.Close()\n151: \n152: \tctx := context.Background()\n153: \n154: \tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n155: \t\tmockK8s := new(MockK8sClient)\n156: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n157: \n158: \t\treq := &api.CreateSandboxRequest{\n159: \t\t\tName:      \"test-runtime\",\n160: \t\t\tNamespace: \"default\",\n161: \t\t}\n162: \n163: \t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n164: \t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n165: \n166: \t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n167: \t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n168: \t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.5\", nil)\n169: \n170: \t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n171: \n172: \t\trequire.NoError(t, err)\n173: \t\trequire.NotNil(t, resp)\n174: \t\tassert.NotEmpty(t, resp.SessionID)\n175: \t\tassert.NotEmpty(t, resp.SandboxID)\n176: \t\tassert.NotEmpty(t, resp.SandboxName)\n177: \t\tassert.Contains(t, resp.SandboxName, \"test-runtime-\")\n178: \t\tassert.NotEmpty(t, resp.EntryPoints)\n179: \t\tassert.Len(t, resp.EntryPoints, 1)\n180: \t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n181: \t\tassert.Equal(t, \"10.244.1.5:8080\", resp.EntryPoints[0].Endpoint)\n182: \t\tassert.NotEmpty(t, resp.CreatedAt)\n183: \t\tassert.NotEmpty(t, resp.ExpiresAt)\n184: \n185: \t\tmockK8s.AssertExpectations(t)\n186: \n187: \t\tsandboxInfo, err := redisStore.GetSandbox(ctx, resp.SessionID)\n188: \t\trequire.NoError(t, err)\n189: \t\tassert.Equal(t, resp.SessionID, sandboxInfo.SessionID)\n190: \t\tassert.Equal(t, \"running\", sandboxInfo.Status)\n191: \t\tassert.Equal(t, \"10.244.1.5\", sandboxInfo.PodIP)\n192: \t})\n193: \n194: \tt.Run(\"agent runtime not found\", func(t *testing.T) {\n195: \t\tmockK8s := new(MockK8sClient)\n196: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n197: \n198: \t\treq := &api.CreateSandboxRequest{\n199: \t\t\tName:      \"nonexistent\",\n200: \t\t\tNamespace: \"default\",\n201: \t\t}\n202: \n203: \t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"agentruntimes\"), \"nonexistent\")\n204: \t\tmockK8s.On(\"GetAgentRuntime\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n205: \n206: \t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n207: \n208: \t\trequire.Error(t, err)\n209: \t\tassert.Nil(t, resp)\n210: \t\tassert.Contains(t, err.Error(), \"not found\")\n211: \n212: \t\tmockK8s.AssertExpectations(t)\n213: \t})\n214: \n215: \tt.Run(\"failed to create sandbox\", func(t *testing.T) {\n216: \t\tmockK8s := new(MockK8sClient)\n217: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n218: \n219: \t\treq := &api.CreateSandboxRequest{\n220: \t\t\tName:      \"test-runtime\",\n221: \t\t\tNamespace: \"default\",\n222: \t\t}\n223: \n224: \t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n225: \t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n226: \n227: \t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n228: \t\tmockK8s.On(\"CreateSandbox\", mock.Anything, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n229: \t\tmockK8s.On(\"GetPodIP\", mock.Anything, mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"\", assert.AnError).Once()\n230: \t\tmockK8s.On(\"DeleteSandbox\", mock.Anything, \"default\", mock.MatchedBy(func(s string) bool { return true })).Return(nil).Maybe()\n231: \n232: \t\tctx, cancel := context.WithTimeout(ctx, 100*time.Millisecond)\n233: \t\tdefer cancel()\n234: \n235: \t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n236: \n237: \t\trequire.Error(t, err)\n238: \t\tassert.Nil(t, resp)\n239: \t\tassert.Contains(t, err.Error(), \"timed out\")\n240: \n241: \t\tmockK8s.AssertExpectations(t)\n242: \t})\n243: }\n244: \n245: func TestSandboxController_CreateCodeInterpreterSandbox(t *testing.T) {\n246: \ts := miniredis.RunT(t)\n247: \n248: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n249: \trequire.NoError(t, err)\n250: \tdefer redisStore.Close()\n251: \n252: \tctx := context.Background()\n253: \n254: \tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n255: \t\tmockK8s := new(MockK8sClient)\n256: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n257: \n258: \t\treq := &api.CreateSandboxRequest{\n259: \t\t\tName:      \"test-interpreter\",\n260: \t\t\tNamespace: \"default\",\n261: \t\t}\n262: \n263: \t\tcodeInterpreter := createCodeInterpreter(\"test-interpreter\", \"default\")\n264: \t\tsandboxCR := createSandboxCR(\"test-interpreter-12345678\", \"default\", \"session-123\", \"test-interpreter\")\n265: \n266: \t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"test-interpreter\").Return(codeInterpreter, nil)\n267: \t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n268: \t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.6\", nil)\n269: \n270: \t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n271: \n272: \t\trequire.NoError(t, err)\n273: \t\trequire.NotNil(t, resp)\n274: \t\tassert.NotEmpty(t, resp.SessionID)\n275: \t\tassert.NotEmpty(t, resp.SandboxID)\n276: \t\tassert.NotEmpty(t, resp.SandboxName)\n277: \t\tassert.Contains(t, resp.SandboxName, \"test-interpreter-\")\n278: \t\tassert.NotEmpty(t, resp.EntryPoints)\n279: \t\tassert.Len(t, resp.EntryPoints, 1)\n280: \t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n281: \t\tassert.Equal(t, \"10.244.1.6:8080\", resp.EntryPoints[0].Endpoint)\n282: \n283: \t\tmockK8s.AssertExpectations(t)\n284: \n285: \t\tsandboxInfo, err := redisStore.GetSandbox(ctx, resp.SessionID)\n286: \t\trequire.NoError(t, err)\n287: \t\tassert.Equal(t, \"CodeInterpreter\", sandboxInfo.Kind)\n288: \t\tassert.Equal(t, \"running\", sandboxInfo.Status)\n289: \t})\n290: \n291: \tt.Run(\"code interpreter not found\", func(t *testing.T) {\n292: \t\tmockK8s := new(MockK8sClient)\n293: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n294: \n295: \t\treq := &api.CreateSandboxRequest{\n296: \t\t\tName:      \"nonexistent\",\n297: \t\t\tNamespace: \"default\",\n298: \t\t}\n299: \n300: \t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"codeinterpreters\"), \"nonexistent\")\n301: \t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n302: \n303: \t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n304: \n305: \t\trequire.Error(t, err)\n306: \t\tassert.Nil(t, resp)\n307: \t\tassert.Contains(t, err.Error(), \"not found\")\n308: \n309: \t\tmockK8s.AssertExpectations(t)\n310: \t})\n311: \n312: \tt.Run(\"code interpreter without ports uses default\", func(t *testing.T) {\n313: \t\tmockK8s := new(MockK8sClient)\n314: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n315: \n316: \t\treq := &api.CreateSandboxRequest{\n317: \t\t\tName:      \"test-interpreter-no-ports\",\n318: \t\t\tNamespace: \"default\",\n319: \t\t}\n320: \n321: \t\tcodeInterpreter := &unstructured.Unstructured{\n322: \t\t\tObject: map[string]interface{}{\n323: \t\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n324: \t\t\t\t\"kind\":       \"CodeInterpreter\",\n325: \t\t\t\t\"metadata\": map[string]interface{}{\n326: \t\t\t\t\t\"name\":      \"test-interpreter-no-ports\",\n327: \t\t\t\t\t\"namespace\": \"default\",\n328: \t\t\t\t},\n329: \t\t\t\t\"spec\": map[string]interface{}{\n330: \t\t\t\t\t\"template\": map[string]interface{}{\n331: \t\t\t\t\t\t\"image\": \"python:3.11-slim\",\n332: \t\t\t\t\t},\n333: \t\t\t\t},\n334: \t\t\t},\n335: \t\t}\n336: \n337: \t\tsandboxCR := createSandboxCR(\"test-interpreter-no-ports-12345678\", \"default\", \"session-123\", \"test-interpreter-no-ports\")\n338: \n339: \t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"test-interpreter-no-ports\").Return(codeInterpreter, nil)\n340: \t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n341: \t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.7\", nil)\n342: \n343: \t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n344: \n345: \t\trequire.NoError(t, err)\n346: \t\trequire.NotNil(t, resp)\n347: \t\tassert.Len(t, resp.EntryPoints, 1)\n348: \t\tassert.Equal(t, int32(8080), resp.EntryPoints[0].Port)\n349: \t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n350: \n351: \t\tmockK8s.AssertExpectations(t)\n352: \t})\n353: }\n354: \n355: func TestSandboxController_GetSession(t *testing.T) {\n356: \ts := miniredis.RunT(t)\n357: \n358: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n359: \trequire.NoError(t, err)\n360: \tdefer redisStore.Close()\n361: \n362: \tctx := context.Background()\n363: \tmockK8s := new(MockK8sClient)\n364: \tcontroller := NewSandboxController(mockK8s, redisStore)\n365: \n366: \tt.Run(\"successfully gets session\", func(t *testing.T) {\n367: \t\tsessionID := \"test-session-1\"\n368: \t\tsandboxInfo := &types.SandboxInfo{\n369: \t\t\tSessionID:    sessionID,\n370: \t\t\tSandboxID:    \"sandbox-123\",\n371: \t\t\tSandboxName:  \"test-sandbox\",\n372: \t\t\tWorkloadName: \"test-workload\",\n373: \t\t\tNamespace:    \"default\",\n374: \t\t\tKind:         \"AgentRuntime\",\n375: \t\t\tStatus:       \"running\",\n376: \t\t\tCreatedAt:    time.Now(),\n377: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n378: \t\t\tPodIP:        \"10.244.1.5\",\n379: \t\t\tEntryPoints: []types.SandboxEntryPoint{\n380: \t\t\t\t{\n381: \t\t\t\t\tProtocol: \"HTTP\",\n382: \t\t\t\t\tEndpoint: \"10.244.1.5:8080\",\n383: \t\t\t\t\tPath:     \"/\",\n384: \t\t\t\t},\n385: \t\t\t},\n386: \t\t\tLastActivityAt: time.Now(),\n387: \t\t}\n388: \n389: \t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n390: \t\trequire.NoError(t, err)\n391: \n392: \t\tresp, err := controller.GetSession(ctx, sessionID)\n393: \n394: \t\trequire.NoError(t, err)\n395: \t\trequire.NotNil(t, resp)\n396: \t\tassert.Equal(t, sessionID, resp.SessionID)\n397: \t\tassert.Equal(t, \"sandbox-123\", resp.SandboxID)\n398: \t\tassert.Equal(t, \"test-sandbox\", resp.SandboxName)\n399: \t\tassert.Equal(t, \"AgentRuntime\", resp.Kind)\n400: \t\tassert.Equal(t, \"default\", resp.Namespace)\n401: \t\tassert.Equal(t, \"test-workload\", resp.Name)\n402: \t\tassert.Len(t, resp.EntryPoints, 1)\n403: \t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n404: \t\tassert.Equal(t, \"10.244.1.5\", resp.PodIP)\n405: \t})\n406: \n407: \tt.Run(\"session not found\", func(t *testing.T) {\n408: \t\tresp, err := controller.GetSession(ctx, \"nonexistent-session\")\n409: \n410: \t\trequire.Error(t, err)\n411: \t\tassert.Nil(t, resp)\n412: \t\tassert.Contains(t, err.Error(), \"not found\")\n413: \t})\n414: }\n415: \n416: func TestSandboxController_DeleteSession(t *testing.T) {\n417: \ts := miniredis.RunT(t)\n418: \n419: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n420: \trequire.NoError(t, err)\n421: \tdefer redisStore.Close()\n422: \n423: \tctx := context.Background()\n424: \n425: \tt.Run(\"successfully deletes session\", func(t *testing.T) {\n426: \t\tmockK8s := new(MockK8sClient)\n427: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n428: \n429: \t\tsessionID := \"test-session-delete\"\n430: \t\tsandboxInfo := &types.SandboxInfo{\n431: \t\t\tSessionID:    sessionID,\n432: \t\t\tSandboxID:    \"sandbox-123\",\n433: \t\t\tSandboxName:  \"test-sandbox\",\n434: \t\t\tWorkloadName: \"test-workload\",\n435: \t\t\tNamespace:    \"default\",\n436: \t\t\tKind:         \"AgentRuntime\",\n437: \t\t\tStatus:       \"running\",\n438: \t\t\tCreatedAt:    time.Now(),\n439: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n440: \t\t}\n441: \n442: \t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n443: \t\trequire.NoError(t, err)\n444: \n445: \t\tmockK8s.On(\"DeleteSandbox\", ctx, \"default\", \"test-sandbox\").Return(nil)\n446: \n447: \t\tresp, err := controller.DeleteSession(ctx, sessionID)\n448: \n449: \t\trequire.NoError(t, err)\n450: \t\trequire.NotNil(t, resp)\n451: \t\tassert.Equal(t, sessionID, resp.SessionID)\n452: \t\tassert.NotEmpty(t, resp.DeletedAt)\n453: \n454: \t\tmockK8s.AssertExpectations(t)\n455: \n456: \t\t_, err = redisStore.GetSandbox(ctx, sessionID)\n457: \t\tassert.Error(t, err)\n458: \t\tassert.Equal(t, store.ErrNotFound, err)\n459: \t})\n460: \n461: \tt.Run(\"session not found\", func(t *testing.T) {\n462: \t\tmockK8s := new(MockK8sClient)\n463: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n464: \n465: \t\tresp, err := controller.DeleteSession(ctx, \"nonexistent-session\")\n466: \n467: \t\trequire.Error(t, err)\n468: \t\tassert.Nil(t, resp)\n469: \t\tassert.Contains(t, err.Error(), \"not found\")\n470: \t})\n471: \n472: \tt.Run(\"k8s delete fails but store cleanup succeeds\", func(t *testing.T) {\n473: \t\tmockK8s := new(MockK8sClient)\n474: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n475: \t\tsessionID := \"test-session-fail-k8s\"\n476: \t\tsandboxInfo := &types.SandboxInfo{\n477: \t\t\tSessionID:    sessionID,\n478: \t\t\tSandboxID:    \"sandbox-123\",\n479: \t\t\tSandboxName:  \"test-sandbox\",\n480: \t\t\tWorkloadName: \"test-workload\",\n481: \t\t\tNamespace:    \"default\",\n482: \t\t\tKind:         \"AgentRuntime\",\n483: \t\t\tStatus:       \"running\",\n484: \t\t\tCreatedAt:    time.Now(),\n485: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n486: \t\t}\n487: \n488: \t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n489: \t\trequire.NoError(t, err)\n490: \n491: \t\tmockK8s.On(\"DeleteSandbox\", ctx, \"default\", \"test-sandbox\").Return(assert.AnError)\n492: \n493: \t\tresp, err := controller.DeleteSession(ctx, sessionID)\n494: \n495: \t\trequire.Error(t, err)\n496: \t\tassert.Nil(t, resp)\n497: \t\tassert.Contains(t, err.Error(), \"failed to delete sandbox\")\n498: \n499: \t\tmockK8s.AssertExpectations(t)\n500: \t})\n501: }\n502: \n503: func extractSessionIDFromName(name string) string {\n504: \treturn \"session-\" + name\n505: }\n506: \n507: func TestBuildAgentRuntimeSandboxCR(t *testing.T) {\n508: \ts := miniredis.RunT(t)\n509: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n510: \trequire.NoError(t, err)\n511: \tdefer redisStore.Close()\n512: \n513: \tmockK8s := new(MockK8sClient)\n514: \tcontroller := NewSandboxController(mockK8s, redisStore)\n515: \n516: \tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n517: \n518: \tcr, err := controller.buildAgentRuntimeSandboxCR(agentRuntime, \"session-123\", \"test-runtime-abc\", \"test-runtime\", \"default\")\n519: \n520: \trequire.NoError(t, err)\n521: \trequire.NotNil(t, cr)\n522: \n523: \tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", cr.GetAPIVersion())\n524: \tassert.Equal(t, \"Sandbox\", cr.GetKind())\n525: \tassert.Equal(t, \"test-runtime-abc\", cr.GetName())\n526: \tassert.Equal(t, \"default\", cr.GetNamespace())\n527: \n528: \tlabels := cr.GetLabels()\n529: \tassert.NotNil(t, labels)\n530: \tassert.Equal(t, \"agentcube-workload-manager\", labels[\"managed-by\"])\n531: \tassert.Equal(t, \"session-123\", labels[\"runtime.agentcube.io/session-id\"])\n532: \tassert.Equal(t, \"test-runtime\", labels[\"runtime.agentcube.io/workload-name\"])\n533: \n534: \tannotations := cr.GetAnnotations()\n535: \tassert.NotNil(t, annotations)\n536: \tassert.Equal(t, \"15m\", annotations[\"runtime.agentcube.io/idle-timeout\"])\n537: }\n538: \n539: func TestBuildCodeInterpreterSandboxCR(t *testing.T) {\n540: \ts := miniredis.RunT(t)\n541: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n542: \trequire.NoError(t, err)\n543: \tdefer redisStore.Close()\n544: \n545: \tmockK8s := new(MockK8sClient)\n546: \tcontroller := NewSandboxController(mockK8s, redisStore)\n547: \n548: \tcodeInterpreter := createCodeInterpreter(\"test-interpreter\", \"default\")\n549: \n550: \tports := []interface{}{\n551: \t\tmap[string]interface{}{\n552: \t\t\t\"port\":     int64(8080),\n553: \t\t\t\"protocol\": \"HTTP\",\n554: \t\t},\n555: \t}\n556: \n557: \tcr, err := controller.buildCodeInterpreterSandboxCR(codeInterpreter, \"session-456\", \"test-interpreter-xyz\", \"test-interpreter\", \"default\", ports)\n558: \n559: \trequire.NoError(t, err)\n560: \trequire.NotNil(t, cr)\n561: \n562: \tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", cr.GetAPIVersion())\n563: \tassert.Equal(t, \"Sandbox\", cr.GetKind())\n564: \tassert.Equal(t, \"test-interpreter-xyz\", cr.GetName())\n565: \tassert.Equal(t, \"default\", cr.GetNamespace())\n566: \n567: \tlabels := cr.GetLabels()\n568: \tassert.NotNil(t, labels)\n569: \tassert.Equal(t, \"agentcube-workload-manager\", labels[\"managed-by\"])\n570: \tassert.Equal(t, \"session-456\", labels[\"runtime.agentcube.io/session-id\"])\n571: \n572: \tannotations := cr.GetAnnotations()\n573: \tassert.NotNil(t, annotations)\n574: \tassert.Equal(t, \"15m\", annotations[\"runtime.agentcube.io/idle-timeout\"])\n575: }\n576: \n577: func TestBuildEntryPoints(t *testing.T) {\n578: \ts := miniredis.RunT(t)\n579: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n580: \trequire.NoError(t, err)\n581: \tdefer redisStore.Close()\n582: \n583: \tmockK8s := new(MockK8sClient)\n584: \tcontroller := NewSandboxController(mockK8s, redisStore)\n585: \n586: \tt.Run(\"builds entry points from ports\", func(t *testing.T) {\n587: \t\tports := []interface{}{\n588: \t\t\tmap[string]interface{}{\n589: \t\t\t\t\"port\":       int64(8080),\n590: \t\t\t\t\"protocol\":   \"HTTP\",\n591: \t\t\t\t\"pathPrefix\": \"/api\",\n592: \t\t\t},\n593: \t\t\tmap[string]interface{}{\n594: \t\t\t\t\"port\":     int64(9090),\n595: \t\t\t\t\"protocol\": \"gRPC\",\n596: \t\t\t},\n597: \t\t}\n598: \n599: \t\tentryPoints := controller.buildEntryPoints(\"10.244.1.5\", ports)\n600: \n601: \t\trequire.Len(t, entryPoints, 2)\n602: \n603: \t\tassert.Equal(t, \"HTTP\", entryPoints[0].Protocol)\n604: \t\tassert.Equal(t, \"10.244.1.5:8080\", entryPoints[0].Endpoint)\n605: \t\tassert.Equal(t, \"/api\", entryPoints[0].Path)\n606: \t\tassert.Equal(t, int32(8080), entryPoints[0].Port)\n607: \n608: \t\tassert.Equal(t, \"gRPC\", entryPoints[1].Protocol)\n609: \t\tassert.Equal(t, \"10.244.1.5:9090\", entryPoints[1].Endpoint)\n610: \t\tassert.Equal(t, \"\", entryPoints[1].Path)\n611: \t\tassert.Equal(t, int32(9090), entryPoints[1].Port)\n612: \t})\n613: \n614: \tt.Run(\"handles malformed port entries\", func(t *testing.T) {\n615: \t\tports := []interface{}{\n616: \t\t\tmap[string]interface{}{\n617: \t\t\t\t\"port\":     int64(8080),\n618: \t\t\t\t\"protocol\": \"HTTP\",\n619: \t\t\t},\n620: \t\t\t\"invalid\",\n621: \t\t\tmap[string]interface{}{\n622: \t\t\t\t\"port\": int64(9090),\n623: \t\t\t},\n624: \t\t}\n625: \n626: \t\tentryPoints := controller.buildEntryPoints(\"10.244.1.5\", ports)\n627: \n628: \t\trequire.Len(t, entryPoints, 1)\n629: \t\tassert.Equal(t, \"HTTP\", entryPoints[0].Protocol)\n630: \t})\n631: }\n632: \n633: func TestGenerateSandboxName(t *testing.T) {\n634: \tname1 := generateSandboxName(\"test-runtime\")\n635: \tname2 := generateSandboxName(\"test-runtime\")\n636: \n637: \tassert.Contains(t, name1, \"test-runtime-\")\n638: \tassert.Contains(t, name2, \"test-runtime-\")\n639: \tassert.NotEqual(t, name1, name2)\n640: \tassert.Len(t, name1, len(\"test-runtime-\")+8)\n641: \tassert.Len(t, name2, len(\"test-runtime-\")+8)\n642: }\n643: \n644: func TestRandString(t *testing.T) {\n645: \tstr1 := RandString(8)\n646: \tstr2 := RandString(8)\n647: \n648: \tassert.Len(t, str1, 8)\n649: \tassert.Len(t, str2, 8)\n650: \tassert.NotEqual(t, str1, str2)\n651: \n652: \tfor _, ch := range str1 {\n653: \t\tassert.Contains(t, \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\", string(ch))\n654: \t}\n655: }\n656: \n657: func TestConvertEntryPoints(t *testing.T) {\n658: \tapiEntryPoints := []api.EntryPoint{\n659: \t\t{\n660: \t\t\tProtocol: \"HTTP\",\n661: \t\t\tEndpoint: \"10.244.1.5:8080\",\n662: \t\t\tPath:     \"/api\",\n663: \t\t\tPort:     8080,\n664: \t\t},\n665: \t}\n666: \n667: \tconverted := convertEntryPoints(apiEntryPoints)\n668: \n669: \trequire.Len(t, converted, 1)\n670: \tassert.Equal(t, \"HTTP\", converted[0].Protocol)\n671: \tassert.Equal(t, \"10.244.1.5:8080\", converted[0].Endpoint)\n672: \tassert.Equal(t, \"/api\", converted[0].Path)\n673: }\n674: \n675: func TestConvertToAPIEntryPoints(t *testing.T) {\n676: \tentryPoints := []types.SandboxEntryPoint{\n677: \t\t{\n678: \t\t\tProtocol: \"HTTP\",\n679: \t\t\tEndpoint: \"10.244.1.5:8080\",\n680: \t\t\tPath:     \"/api\",\n681: \t\t},\n682: \t}\n683: \n684: \tconverted := convertToAPIEntryPoints(entryPoints)\n685: \n686: \trequire.Len(t, converted, 1)\n687: \tassert.Equal(t, \"HTTP\", converted[0].Protocol)\n688: \tassert.Equal(t, \"10.244.1.5:8080\", converted[0].Endpoint)\n689: \tassert.Equal(t, \"/api\", converted[0].Path)\n690: }\n\n(End of file - total 690 lines)\n</content>","metadata":{"preview":"package controller\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/google/uuid\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/require\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/api\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox_test.go","time":{"start":1775845488024,"end":1775845488036}}}}
{"type":"tool_use","timestamp":1775845488043,"sessionID":"ses_2875cb156ffeVlf4vEBwAaj7La","part":{"id":"prt_d78a3abb4001AdLRuchE1EPDXS","messageID":"msg_d78a38d88001svlAT21JOd50XO","sessionID":"ses_2875cb156ffeVlf4vEBwAaj7La","type":"tool","tool":"bash","callID":"toolu_tool-680f6146810c4b0fb41b2c8257c93a29","state":{"status":"completed","input":{"command":"find /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z -name \"client-go\" -type d 2>/dev/null | head -5","description":"Find client-go directories"},"output":"","metadata":{"output":"","exit":0,"description":"Find client-go directories","truncated":false},"title":"Find client-go directories","time":{"start":1775845488015,"end":1775845488042}}}}
{"type":"tool_use","timestamp":1775845488054,"sessionID":"ses_2875cb156ffeVlf4vEBwAaj7La","part":{"id":"prt_d78a3b215001PPAsZ25V53MVdm","messageID":"msg_d78a38d88001svlAT21JOd50XO","sessionID":"ses_2875cb156ffeVlf4vEBwAaj7La","type":"tool","tool":"read","callID":"toolu_tool-2f8d6843be4a4858ac2dc0d480e10f5a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types.go</path>\n<type>file</type>\n<content>\n1: package v1alpha1\n2: \n3: import (\n4: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n5: \t\"k8s.io/apimachinery/pkg/util/intstr\"\n6: )\n7: \n8: // +genclient\n9: // +genclient:nonNamespaced\n10: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n11: // +k8s:openapi-gen=true\n12: // +kubebuilder:resource:shortName=ar;agentruntime\n13: // +kubebuilder:subresource:status\n14: // +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n15: \n16: // AgentRuntime defines a custom resource for managing agent runtime configurations.\n17: // It represents a sandbox orchestration runtime that manages the lifecycle of agent pods.\n18: type AgentRuntime struct {\n19: \tmetav1.TypeMeta   `json:\",inline\"`\n20: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n21: \n22: \tSpec   AgentRuntimeSpec   `json:\"spec,omitempty\"`\n23: \tStatus AgentRuntimeStatus `json:\"status,omitempty\"`\n24: }\n25: \n26: // AgentRuntimeSpec defines the desired state of an AgentRuntime.\n27: type AgentRuntimeSpec struct {\n28: \t// PodTemplate defines the template for creating sandbox pods.\n29: \t// +required\n30: \tPodTemplate *SandboxTemplate `json:\"podTemplate\"`\n31: \n32: \t// SessionTimeout defines the timeout for idle sessions before cleanup.\n33: \t// +kubebuilder:default=\"15m\"\n34: \t// +kubebuilder:validation:Type=string\n35: \t// +kubebuilder:validation:Format=duration\n36: \t// +optional\n37: \tSessionTimeout *metav1.Duration `json:\"sessionTimeout,omitempty\"`\n38: \n39: \t// MaxSessionDuration defines the maximum allowed duration for a session.\n40: \t// +kubebuilder:default=\"8h\"\n41: \t// +kubebuilder:validation:Type=string\n42: \t// +kubebuilder:validation:Format=duration\n43: \t// +optional\n44: \tMaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\"`\n45: }\n46: \n47: // SandboxTemplate defines the template for creating sandbox pods.\n48: type SandboxTemplate struct {\n49: \t// Metadata defines labels and annotations for the pod.\n50: \t// +optional\n51: \tMetadata *SandboxMetadata `json:\"metadata,omitempty\"`\n52: \n53: \t// Spec defines the pod specification.\n54: \tSpec SandboxPodSpec `json:\"spec\"`\n55: }\n56: \n57: // SandboxMetadata defines metadata for sandbox pods.\n58: type SandboxMetadata struct {\n59: \t// Labels are key-value pairs attached to the pod.\n60: \t// +optional\n61: \tLabels map[string]string `json:\"labels,omitempty\"`\n62: \n63: \t// Annotations are unstructured key-value pairs stored with the pod.\n64: \t// +optional\n65: \tAnnotations map[string]string `json:\"annotations,omitempty\"`\n66: }\n67: \n68: // SandboxPodSpec defines the specification for sandbox pods.\n69: type SandboxPodSpec struct {\n70: \t// Containers represents the list of containers in the pod.\n71: \t// +kubebuilder:validation:MinItems=1\n72: \tContainers []SandboxContainer `json:\"containers\"`\n73: \n74: \t// NodeSelector specifies node selection constraints.\n75: \t// +optional\n76: \tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n77: \n78: \t// Affinity defines pod scheduling constraints.\n79: \t// +optional\n80: \tAffinity *SandboxAffinity `json:\"affinity,omitempty\"`\n81: \n82: \t// Tolerations defines pod tolerations.\n83: \t// +optional\n84: \tTolerations []SandboxToleration `json:\"tolerations,omitempty\"`\n85: \n86: \t// ResourceRequirements defines resource requirements for the pod.\n87: \t// +optional\n88: \tResourceRequirements *SandboxResources `json:\"resources,omitempty\"`\n89: \n90: \t// Volumes defines pod volumes.\n91: \t// +optional\n92: \tVolumes []SandboxVolume `json:\"volumes,omitempty\"`\n93: }\n94: \n95: // SandboxContainer defines a container in a sandbox pod.\n96: type SandboxContainer struct {\n97: \t// Name is the name of the container.\n98: \t// +required\n99: \t// +kubebuilder:validation:MinLength=1\n100: \tName string `json:\"name\"`\n101: \n102: \t// Image is the container image.\n103: \t// +required\n104: \tImage string `json:\"image\"`\n105: \n106: \t// Command specifies the entrypoint array for the container.\n107: \t// +optional\n108: \tCommand []string `json:\"command,omitempty\"`\n109: \n110: \t// Args specifies the arguments to the entrypoint.\n111: \t// +optional\n112: \tArgs []string `json:\"args,omitempty\"`\n113: \n114: \t// WorkingDir specifies the working directory.\n115: \t// +optional\n116: \tWorkingDir string `json:\"workingDir,omitempty\"`\n117: \n118: \t// Ports represents the network ports exposed by the container.\n119: \t// +optional\n120: \tPorts []SandboxContainerPort `json:\"ports,omitempty\"`\n121: \n122: \t// Env represents environment variables.\n123: \t// +optional\n124: \tEnv []SandboxEnvVar `json:\"env,omitempty\"`\n125: \n126: \t// Resources defines compute resource requirements.\n127: \t// +optional\n128: \tResources *SandboxContainerResources `json:\"resources,omitempty\"`\n129: \n130: \t// VolumeMounts specifies volume mounts.\n131: \t// +optional\n132: \tVolumeMounts []SandboxVolumeMount `json:\"volumeMounts,omitempty\"`\n133: \n134: \t// LivenessProbe defines the liveness probe.\n135: \t// +optional\n136: \tLivenessProbe *SandboxProbe `json:\"livenessProbe,omitempty\"`\n137: \n138: \t// ReadinessProbe defines the readiness probe.\n139: \t// +optional\n140: \tReadinessProbe *SandboxProbe `json:\"readinessProbe,omitempty\"`\n141: \n142: \t// SecurityContext defines security settings.\n143: \t// +optional\n144: \tSecurityContext *SandboxSecurityContext `json:\"securityContext,omitempty\"`\n145: }\n146: \n147: // SandboxContainerPort defines a network port in a container.\n148: type SandboxContainerPort struct {\n149: \t// Name is the name of the port.\n150: \t// +optional\n151: \tName string `json:\"name,omitempty\"`\n152: \n153: \t// ContainerPort is the port number on the container.\n154: \t// +required\n155: \t// +kubebuilder:validation:Minimum=1\n156: \t// +kubebuilder:validation:Maximum=65535\n157: \tContainerPort int32 `json:\"containerPort\"`\n158: \n159: \t// Protocol is the protocol for the port.\n160: \t// +optional\n161: \t// +kubebuilder:default=TCP\n162: \tProtocol string `json:\"protocol,omitempty\"`\n163: \n164: \t// HostPort is the port number on the host.\n165: \t// +optional\n166: \t// +kubebuilder:validation:Minimum=1\n167: \t// +kubebuilder:validation:Maximum=65535\n168: \tHostPort int32 `json:\"hostPort,omitempty\"`\n169: }\n170: \n171: // SandboxEnvVar defines an environment variable.\n172: type SandboxEnvVar struct {\n173: \t// Name is the name of the environment variable.\n174: \t// +required\n175: \tName string `json:\"name\"`\n176: \n177: \t// Value is the literal value of the environment variable.\n178: \t// +optional\n179: \tValue string `json:\"value,omitempty\"`\n180: \n181: \t// ValueFrom specifies a source for the value.\n182: \t// +optional\n183: \tValueFrom *SandboxEnvVarSource `json:\"valueFrom,omitempty\"`\n184: }\n185: \n186: // SandboxEnvVarSource defines a source for environment variable values.\n187: type SandboxEnvVarSource struct {\n188: \t// FieldRef selects a field from the pod.\n189: \t// +optional\n190: \tFieldRef *SandboxFieldRef `json:\"fieldRef,omitempty\"`\n191: \n192: \t// ConfigMapKeyRef selects a key from a ConfigMap.\n193: \t// +optional\n194: \tConfigMapKeyRef *SandboxConfigMapKeyRef `json:\"configMapKeyRef,omitempty\"`\n195: \n196: \t// SecretKeyRef selects a key from a Secret.\n197: \t// +optional\n198: \tSecretKeyRef *SandboxSecretKeyRef `json:\"secretKeyRef,omitempty\"`\n199: }\n200: \n201: // SandboxFieldRef selects a field from a pod.\n202: type SandboxFieldRef struct {\n203: \t// FieldPath is the path of the field.\n204: \t// +required\n205: \tFieldPath string `json:\"fieldPath\"`\n206: }\n207: \n208: // SandboxConfigMapKeyRef selects a key from a ConfigMap.\n209: type SandboxConfigMapKeyRef struct {\n210: \t// Name is the name of the ConfigMap.\n211: \t// +required\n212: \tName string `json:\"name\"`\n213: \n214: \t// Key is the key to select.\n215: \t// +required\n216: \tKey string `json:\"key\"`\n217: \n218: \t// Optional specifies whether the ConfigMap must exist.\n219: \t// +optional\n220: \tOptional *bool `json:\"optional,omitempty\"`\n221: }\n222: \n223: // SandboxSecretKeyRef selects a key from a Secret.\n224: type SandboxSecretKeyRef struct {\n225: \t// Name is the name of the Secret.\n226: \t// +required\n227: \tName string `json:\"name\"`\n228: \n229: \t// Key is the key to select.\n230: \t// +required\n231: \tKey string `json:\"key\"`\n232: \n233: \t// Optional specifies whether the Secret must exist.\n234: \t// +optional\n235: \tOptional *bool `json:\"optional,omitempty\"`\n236: }\n237: \n238: // SandboxContainerResources defines resource requirements for a container.\n239: type SandboxContainerResources struct {\n240: \t// Limits defines the resource limits.\n241: \t// +optional\n242: \tLimits SandboxResourceList `json:\"limits,omitempty\"`\n243: \n244: \t// Requests defines the resource requests.\n245: \t// +optional\n246: \tRequests SandboxResourceList `json:\"requests,omitempty\"`\n247: }\n248: \n249: // SandboxResourceList defines a list of resources.\n250: type SandboxResourceList struct {\n251: \t// CPU defines CPU resources.\n252: \t// +optional\n253: \tCPU string `json:\"cpu,omitempty\"`\n254: \n255: \t// Memory defines memory resources.\n256: \t// +optional\n257: \tMemory string `json:\"memory,omitempty\"`\n258: \n259: \t// EphemeralStorage defines ephemeral storage resources.\n260: \t// +optional\n261: \tEphemeralStorage string `json:\"ephemeralStorage,omitempty\"`\n262: }\n263: \n264: // SandboxResources defines resource requirements for the pod.\n265: type SandboxResources struct {\n266: \t// Limits defines the resource limits.\n267: \t// +optional\n268: \tLimits SandboxResourceList `json:\"limits,omitempty\"`\n269: \n270: \t// Requests defines the resource requests.\n271: \t// +optional\n272: \tRequests SandboxResourceList `json:\"requests,omitempty\"`\n273: }\n274: \n275: // SandboxVolumeMount defines a volume mount.\n276: type SandboxVolumeMount struct {\n277: \t// Name is the name of the volume.\n278: \t// +required\n279: \tName string `json:\"name\"`\n280: \n281: \t// MountPath is the path within the container.\n282: \t// +required\n283: \tMountPath string `json:\"mountPath\"`\n284: \n285: \t// SubPath is the sub-path within the volume.\n286: \t// +optional\n287: \tSubPath string `json:\"subPath,omitempty\"`\n288: \n289: \t// ReadOnly specifies whether the volume is read-only.\n290: \t// +optional\n291: \tReadOnly bool `json:\"readOnly,omitempty\"`\n292: }\n293: \n294: // SandboxVolume defines a volume.\n295: type SandboxVolume struct {\n296: \t// Name is the name of the volume.\n297: \t// +required\n298: \tName string `json:\"name\"`\n299: \n300: \t// EmptyDir defines an empty directory volume.\n301: \t// +optional\n302: \tEmptyDir *SandboxEmptyDirVolumeSource `json:\"emptyDir,omitempty\"`\n303: \n304: \t// ConfigMap defines a ConfigMap volume.\n305: \t// +optional\n306: \tConfigMap *SandboxConfigMapVolumeSource `json:\"configMap,omitempty\"`\n307: \n308: \t// Secret defines a Secret volume.\n309: \t// +optional\n310: \tSecret *SandboxSecretVolumeSource `json:\"secret,omitempty\"`\n311: \n312: \t// PersistentVolumeClaim defines a PVC volume.\n313: \t// +optional\n314: \tPersistentVolumeClaim *SandboxPersistentVolumeClaimVolumeSource `json:\"persistentVolumeClaim,omitempty\"`\n315: }\n316: \n317: // SandboxEmptyDirVolumeSource defines an empty directory volume.\n318: type SandboxEmptyDirVolumeSource struct {\n319: \t// SizeLimit is the limit on the size of the volume.\n320: \t// +optional\n321: \tSizeLimit string `json:\"sizeLimit,omitempty\"`\n322: }\n323: \n324: // SandboxConfigMapVolumeSource defines a ConfigMap volume.\n325: type SandboxConfigMapVolumeSource struct {\n326: \t// Name is the name of the ConfigMap.\n327: \t// +required\n328: \tName string `json:\"name\"`\n329: \n330: \t// Optional specifies whether the ConfigMap must exist.\n331: \t// +optional\n332: \tOptional *bool `json:\"optional,omitempty\"`\n333: \n334: \t// Items specifies keys to use and the path to mount them at.\n335: \t// +optional\n336: \tItems []SandboxKeyToPath `json:\"items,omitempty\"`\n337: }\n338: \n339: // SandboxSecretVolumeSource defines a Secret volume.\n340: type SandboxSecretVolumeSource struct {\n341: \t// SecretName is the name of the Secret.\n342: \t// +required\n343: \tSecretName string `json:\"secretName\"`\n344: \n345: \t// Optional specifies whether the Secret must exist.\n346: \t// +optional\n347: \tOptional *bool `json:\"optional,omitempty\"`\n348: \n349: \t// Items specifies keys to use and the path to mount them at.\n350: \t// +optional\n351: \tItems []SandboxKeyToPath `json:\"items,omitempty\"`\n352: }\n353: \n354: // SandboxPersistentVolumeClaimVolumeSource defines a PVC volume.\n355: type SandboxPersistentVolumeClaimVolumeSource struct {\n356: \t// ClaimName is the name of the PVC.\n357: \t// +required\n358: \tClaimName string `json:\"claimName\"`\n359: \n360: \t// ReadOnly specifies whether the volume is read-only.\n361: \t// +optional\n362: \tReadOnly bool `json:\"readOnly,omitempty\"`\n363: }\n364: \n365: // SandboxKeyToPath maps a key to a path.\n366: type SandboxKeyToPath struct {\n367: \t// Key is the key to reference.\n368: \t// +required\n369: \tKey string `json:\"key\"`\n370: \n371: \t// Path is the relative path within the mount point.\n372: \t// +required\n373: \tPath string `json:\"path\"`\n374: \n375: \t// Mode is the octal permission bits.\n376: \t// +optional\n377: \tMode *int32 `json:\"mode,omitempty\"`\n378: }\n379: \n380: // SandboxProbe defines a probe.\n381: type SandboxProbe struct {\n382: \t// ProbeHandler defines the probe handler.\n383: \tSandboxProbeHandler `json:\",inline\"`\n384: \n385: \t// InitialDelaySeconds is the delay before the first probe.\n386: \t// +optional\n387: \t// +kubebuilder:default=0\n388: \t// +kubebuilder:validation:Minimum=0\n389: \tInitialDelaySeconds int32 `json:\"initialDelaySeconds,omitempty\"`\n390: \n391: \t// TimeoutSeconds is the timeout for the probe.\n392: \t// +optional\n393: \t// +kubebuilder:default=1\n394: \t// +kubebuilder:validation:Minimum=1\n395: \tTimeoutSeconds int32 `json:\"timeoutSeconds,omitempty\"`\n396: \n397: \t// PeriodSeconds is the period between probes.\n398: \t// +optional\n399: \t// +kubebuilder:default=10\n400: \t// +kubebuilder:validation:Minimum=1\n401: \tPeriodSeconds int32 `json:\"periodSeconds,omitempty\"`\n402: \n403: \t// SuccessThreshold is the number of successes to consider successful.\n404: \t// +optional\n405: \t// +kubebuilder:default=1\n406: \t// +kubebuilder:validation:Minimum=1\n407: \tSuccessThreshold int32 `json:\"successThreshold,omitempty\"`\n408: \n409: \t// FailureThreshold is the number of failures to consider failed.\n410: \t// +optional\n411: \t// +kubebuilder:default=3\n412: \t// +kubebuilder:validation:Minimum=1\n413: \tFailureThreshold int32 `json:\"failureThreshold,omitempty\"`\n414: }\n415: \n416: // SandboxProbeHandler defines the probe handler.\n417: type SandboxProbeHandler struct {\n418: \t// ExecAction specifies an action to execute in the container.\n419: \t// +optional\n420: \tExec *SandboxExecAction `json:\"exec,omitempty\"`\n421: \n422: \t// TCPSocketAction specifies a TCP socket check.\n423: \t// +optional\n424: \tTCPSocket *SandboxTCPSocketAction `json:\"tcpSocket,omitempty\"`\n425: \n426: \t// HTTPGetAction specifies an HTTP GET check.\n427: \t// +optional\n428: \tHTTPGet *SandboxHTTPGetAction `json:\"httpGet,omitempty\"`\n429: }\n430: \n431: // SandboxExecAction defines an exec action.\n432: type SandboxExecAction struct {\n433: \t// Command is the command to execute.\n434: \t// +required\n435: \tCommand []string `json:\"command\"`\n436: }\n437: \n438: // SandboxTCPSocketAction defines a TCP socket check.\n439: type SandboxTCPSocketAction struct {\n440: \t// Port is the port number or name.\n441: \t// +required\n442: \tPort intstr.IntOrString `json:\"port\"`\n443: \n444: \t// Host is the host to connect to.\n445: \t// +optional\n446: \tHost string `json:\"host,omitempty\"`\n447: }\n448: \n449: // SandboxHTTPGetAction defines an HTTP GET check.\n450: type SandboxHTTPGetAction struct {\n451: \t// Port is the port number or name.\n452: \t// +required\n453: \tPort intstr.IntOrString `json:\"port\"`\n454: \n455: \t// Host is the host to connect to.\n456: \t// +optional\n457: \tHost string `json:\"host,omitempty\"`\n458: \n459: \t// Path is the path to request.\n460: \t// +optional\n461: \tPath string `json:\"path,omitempty\"`\n462: \n463: \t// Scheme is the URI scheme.\n464: \t// +optional\n465: \t// +kubebuilder:default=HTTP\n466: \tScheme string `json:\"scheme,omitempty\"`\n467: \n468: \t// HTTPHeaders specifies custom headers.\n469: \t// +optional\n470: \tHTTPHeaders []SandboxHTTPHeader `json:\"httpHeaders,omitempty\"`\n471: }\n472: \n473: // SandboxHTTPHeader defines an HTTP header.\n474: type SandboxHTTPHeader struct {\n475: \t// Name is the header name.\n476: \t// +required\n477: \tName string `json:\"name\"`\n478: \n479: \t// Value is the header value.\n480: \t// +required\n481: \tValue string `json:\"value\"`\n482: }\n483: \n484: // SandboxSecurityContext defines security settings.\n485: type SandboxSecurityContext struct {\n486: \t// RunAsUser is the UID to run the entrypoint of the container.\n487: \t// +optional\n488: \tRunAsUser *int64 `json:\"runAsUser,omitempty\"`\n489: \n490: \t// RunAsGroup is the GID to run the entrypoint of the container.\n491: \t// +optional\n492: \tRunAsGroup *int64 `json:\"runAsGroup,omitempty\"`\n493: \n494: \t// RunAsNonRoot specifies whether the container must run as non-root.\n495: \t// +optional\n496: \tRunAsNonRoot *bool `json:\"runAsNonRoot,omitempty\"`\n497: \n498: \t// ReadOnlyRootFilesystem specifies whether the root filesystem is read-only.\n499: \t// +optional\n500: \tReadOnlyRootFilesystem *bool `json:\"readOnlyRootFilesystem,omitempty\"`\n501: \n502: \t// AllowPrivilegeEscalation specifies whether a process can gain privileges.\n503: \t// +optional\n504: \tAllowPrivilegeEscalation *bool `json:\"allowPrivilegeEscalation,omitempty\"`\n505: \n506: \t// Capabilities defines Linux capabilities.\n507: \t// +optional\n508: \tCapabilities *SandboxCapabilities `json:\"capabilities,omitempty\"`\n509: \n510: \t// SeccompProfile defines the seccomp profile.\n511: \t// +optional\n512: \tSeccompProfile *SandboxSeccompProfile `json:\"seccompProfile,omitempty\"`\n513: \n514: \t// Privileged specifies whether to run in privileged mode.\n515: \t// +optional\n516: \tPrivileged *bool `json:\"privileged,omitempty\"`\n517: \n518: \t// ProcMount specifies the proc mount type.\n519: \t// +optional\n520: \tProcMount string `json:\"procMount,omitempty\"`\n521: }\n522: \n523: // SandboxCapabilities defines Linux capabilities.\n524: type SandboxCapabilities struct {\n525: \t// Add is the list of capabilities to add.\n526: \t// +optional\n527: \tAdd []string `json:\"add,omitempty\"`\n528: \n529: \t// Drop is the list of capabilities to drop.\n530: \t// +optional\n531: \tDrop []string `json:\"drop,omitempty\"`\n532: }\n533: \n534: // SandboxSeccompProfile defines the seccomp profile.\n535: type SandboxSeccompProfile struct {\n536: \t// Type is the type of seccomp profile.\n537: \t// +required\n538: \tType string `json:\"type\"`\n539: \n540: \t// LocalhostProfile references a local profile.\n541: \t// +optional\n542: \tLocalhostProfile string `json:\"localhostProfile,omitempty\"`\n543: }\n544: \n545: // SandboxAffinity defines pod scheduling constraints.\n546: type SandboxAffinity struct {\n547: \t// NodeAffinity defines node affinity.\n548: \t// +optional\n549: \tNodeAffinity *SandboxNodeAffinity `json:\"nodeAffinity,omitempty\"`\n550: \n551: \t// PodAffinity defines pod affinity.\n552: \t// +optional\n553: \tPodAffinity *SandboxPodAffinity `json:\"podAffinity,omitempty\"`\n554: \n555: \t// PodAntiAffinity defines pod anti-affinity.\n556: \t// +optional\n557: \tPodAntiAffinity *SandboxPodAffinity `json:\"podAntiAffinity,omitempty\"`\n558: }\n559: \n560: // SandboxNodeAffinity defines node affinity.\n561: type SandboxNodeAffinity struct {\n562: \t// RequiredDuringSchedulingIgnoredDuringExecution defines required node selectors.\n563: \t// +optional\n564: \tRequiredDuringSchedulingIgnoredDuringExecution *SandboxNodeSelector `json:\"requiredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n565: \n566: \t// PreferredDuringSchedulingIgnoredDuringExecution defines preferred node selectors.\n567: \t// +optional\n568: \tPreferredDuringSchedulingIgnoredDuringExecution []SandboxPreferredSchedulingTerm `json:\"preferredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n569: }\n570: \n571: // SandboxNodeSelector defines a node selector.\n572: type SandboxNodeSelector struct {\n573: \t// NodeSelectorTerms is the list of node selector terms.\n574: \t// +required\n575: \t// +kubebuilder:validation:MinItems=1\n576: \tNodeSelectorTerms []SandboxNodeSelectorTerm `json:\"nodeSelectorTerms\"`\n577: }\n578: \n579: // SandboxNodeSelectorTerm defines a node selector term.\n580: type SandboxNodeSelectorTerm struct {\n581: \t// MatchExpressions is a list of node selector requirements.\n582: \t// +optional\n583: \tMatchExpressions []SandboxNodeSelectorRequirement `json:\"matchExpressions,omitempty\"`\n584: \n585: \t// MatchFields is a list of node selector field requirements.\n586: \t// +optional\n587: \tMatchFields []SandboxNodeSelectorRequirement `json:\"matchFields,omitempty\"`\n588: }\n589: \n590: // SandboxNodeSelectorRequirement defines a node selector requirement.\n591: type SandboxNodeSelectorRequirement struct {\n592: \t// Key is the label key.\n593: \t// +required\n594: \tKey string `json:\"key\"`\n595: \n596: \t// Operator is the operator.\n597: \t// +required\n598: \tOperator string `json:\"operator\"`\n599: \n600: \t// Values is the values.\n601: \t// +optional\n602: \tValues []string `json:\"values,omitempty\"`\n603: }\n604: \n605: // SandboxPreferredSchedulingTerm defines a preferred scheduling term.\n606: type SandboxPreferredSchedulingTerm struct {\n607: \t// Weight is the weight.\n608: \t// +required\n609: \t// +kubebuilder:validation:Minimum=1\n610: \t// +kubebuilder:validation:Maximum=100\n611: \tWeight int32 `json:\"weight\"`\n612: \n613: \t// Preference is the preference.\n614: \t// +required\n615: \tPreference SandboxNodeSelectorTerm `json:\"preference\"`\n616: }\n617: \n618: // SandboxPodAffinity defines pod affinity.\n619: type SandboxPodAffinity struct {\n620: \t// RequiredDuringSchedulingIgnoredDuringExecution defines required pod selectors.\n621: \t// +optional\n622: \tRequiredDuringSchedulingIgnoredDuringExecution []SandboxPodAffinityTerm `json:\"requiredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n623: \n624: \t// PreferredDuringSchedulingIgnoredDuringExecution defines preferred pod selectors.\n625: \t// +optional\n626: \tPreferredDuringSchedulingIgnoredDuringExecution []SandboxWeightedPodAffinityTerm `json:\"preferredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n627: }\n628: \n629: // SandboxPodAffinityTerm defines a pod affinity term.\n630: type SandboxPodAffinityTerm struct {\n631: \t// LabelSelector defines the label selector.\n632: \t// +optional\n633: 