{"type":"tool_use","timestamp":1775895132791,"sessionID":"ses_284670632ffefvjDMSqLX2EfCV","part":{"id":"prt_d7b992ebe001YDG5wiSUNOIqz7","messageID":"msg_d7b992014001CUT4w9oFCemGYi","sessionID":"ses_284670632ffefvjDMSqLX2EfCV","type":"tool","tool":"read","callID":"toolu_tool-823ab8405ae745998da424d3151b8787","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_build_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_build_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for the build runtime.\"\"\"\n2: \n3: import pytest\n4: from pathlib import Path\n5: import tempfile\n6: import yaml\n7: from unittest.mock import MagicMock, patch, PropertyMock\n8: \n9: from agentcube.runtime.build_runtime import BuildRuntime\n10: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n11: from agentcube.services.docker_service import DockerService\n12: \n13: \n14: class TestBuildRuntime:\n15:     \"\"\"Test cases for BuildRuntime.\"\"\"\n16: \n17:     @pytest.fixture\n18:     def mock_docker_service(self):\n19:         \"\"\"Create a mock DockerService.\"\"\"\n20:         service = MagicMock(spec=DockerService)\n21:         service.check_docker_available.return_value = True\n22:         service.build_image.return_value = {\n23:             \"image_name\": \"test:1.0.1\",\n24:             \"image_id\": \"abc123def456\",\n25:             \"image_size\": \"512.34 MB\",\n26:             \"size_bytes\": 536870912,\n27:             \"build_time\": 1234567890.0,\n28:         }\n29:         return service\n30: \n31:     @pytest.fixture\n32:     def mock_metadata_service(self):\n33:         \"\"\"Create a mock MetadataService.\"\"\"\n34:         service = MagicMock(spec=MetadataService)\n35: \n36:         def load_side_effect(path):\n37:             return AgentMetadata(\n38:                 agent_name=\"test\",\n39:                 entrypoint=\"python main.py\",\n40:                 version=\"1.0.0\",\n41:                 build_mode=\"local\"\n42:             )\n43: \n44:         service.load_metadata.side_effect = load_side_effect\n45:         service.save_metadata = MagicMock()\n46:         return service\n47: \n48:     @pytest.fixture\n49:     def workspace_with_dockerfile(self):\n50:         \"\"\"Create a temporary workspace with Dockerfile.\"\"\"\n51:         with tempfile.TemporaryDirectory() as tmpdir:\n52:             workspace = Path(tmpdir)\n53:             (workspace / \"main.py\").write_text(\"print('hello')\")\n54:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10-slim\")\n55:             metadata = AgentMetadata(\n56:                 agent_name=\"test-agent\",\n57:                 entrypoint=\"python main.py\",\n58:                 version=\"1.0.0\",\n59:                 build_mode=\"local\"\n60:             )\n61:             metadata_service = MetadataService()\n62:             metadata_service.save_metadata(workspace, metadata)\n63:             yield workspace\n64: \n65:     def test_increment_semantic_version(self, workspace_with_dockerfile):\n66:         \"\"\"Test incrementing semantic version patch.\"\"\"\n67:         metadata = AgentMetadata(\n68:             agent_name=\"test\",\n69:             entrypoint=\"python main.py\",\n70:             version=\"1.0.0\"\n71:         )\n72:         runtime = BuildRuntime()\n73:         runtime.metadata_service = MagicMock(spec=MetadataService)\n74:         runtime.metadata_service.save_metadata = MagicMock()\n75: \n76:         new_version = runtime._increment_version(workspace_with_dockerfile, metadata)\n77: \n78:         assert new_version == \"1.0.1\"\n79:         assert metadata.version == \"1.0.1\"\n80:         runtime.metadata_service.save_metadata.assert_called_once()\n81: \n82:     def test_increment_prerelease_version(self):\n83:         \"\"\"Test incrementing prerelease version.\"\"\"\n84:         metadata = AgentMetadata(\n85:             agent_name=\"test\",\n86:             entrypoint=\"python main.py\",\n87:             version=\"1.0.0-alpha.1\"\n88:         )\n89:         runtime = BuildRuntime()\n90:         runtime.metadata_service = MagicMock(spec=MetadataService)\n91:         runtime.metadata_service.save_metadata = MagicMock()\n92: \n93:         with tempfile.TemporaryDirectory() as tmpdir:\n94:             workspace = Path(tmpdir)\n95:             new_version = runtime._increment_version(workspace, metadata)\n96: \n97:             assert new_version == \"1.0.0-alpha.2\"\n98:             assert metadata.version == \"1.0.0-alpha.2\"\n99: \n100:     def test_increment_prerelease_with_suffix(self):\n101:         \"\"\"Test incrementing prerelease version with suffix.\"\"\"\n102:         metadata = AgentMetadata(\n103:             agent_name=\"test\",\n104:             entrypoint=\"python main.py\",\n105:             version=\"1.0.0-beta.1.rc1\"\n106:         )\n107:         runtime = BuildRuntime()\n108:         runtime.metadata_service = MagicMock(spec=MetadataService)\n109:         runtime.metadata_service.save_metadata = MagicMock()\n110: \n111:         with tempfile.TemporaryDirectory() as tmpdir:\n112:             workspace = Path(tmpdir)\n113:             new_version = runtime._increment_version(workspace, metadata)\n114: \n115:             assert new_version == \"1.0.0-beta.2.rc1\"\n116:             assert metadata.version == \"1.0.0-beta.2.rc1\"\n117: \n118:     def test_increment_custom_version(self):\n119:         \"\"\"Test incrementing custom version with suffix.\"\"\"\n120:         metadata = AgentMetadata(\n121:             agent_name=\"test\",\n122:             entrypoint=\"python main.py\",\n123:             version=\"custom-version\"\n124:         )\n125:         runtime = BuildRuntime()\n126:         runtime.metadata_service = MagicMock(spec=MetadataService)\n127:         runtime.metadata_service.save_metadata = MagicMock()\n128: \n129:         with tempfile.TemporaryDirectory() as tmpdir:\n130:             workspace = Path(tmpdir)\n131:             new_version = runtime._increment_version(workspace, metadata)\n132: \n133:             assert new_version == \"custom-version-1\"\n134:             assert metadata.version == \"custom-version-1\"\n135: \n136:     def test_increment_no_version(self):\n137:         \"\"\"Test incrementing when no version exists.\"\"\"\n138:         metadata = AgentMetadata(\n139:             agent_name=\"test\",\n140:             entrypoint=\"python main.py\"\n141:         )\n142:         runtime = BuildRuntime()\n143:         runtime.metadata_service = MagicMock(spec=MetadataService)\n144:         runtime.metadata_service.save_metadata = MagicMock()\n145: \n146:         with tempfile.TemporaryDirectory() as tmpdir:\n147:             workspace = Path(tmpdir)\n148:             new_version = runtime._increment_version(workspace, metadata)\n149: \n150:             assert new_version == \"0.1.0\"\n151:             assert metadata.version == \"0.1.0\"\n152: \n153:     def test_validate_missing_dockerfile(self):\n154:         \"\"\"Test validation when Dockerfile is missing.\"\"\"\n155:         with tempfile.TemporaryDirectory() as tmpdir:\n156:             workspace = Path(tmpdir)\n157:             runtime = BuildRuntime()\n158:             runtime.docker_service = MagicMock(spec=DockerService)\n159:             runtime.docker_service.check_docker_available.return_value = True\n160: \n161:             with pytest.raises(ValueError, match=\"Dockerfile not found\"):\n162:                 runtime._validate_build_prerequisites(workspace)\n163: \n164:     def test_validate_docker_unavailable(self):\n165:         \"\"\"Test validation when Docker is unavailable.\"\"\"\n166:         with tempfile.TemporaryDirectory() as tmpdir:\n167:             workspace = Path(tmpdir)\n168:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n169: \n170:             runtime = BuildRuntime()\n171:             runtime.docker_service = MagicMock(spec=DockerService)\n172:             runtime.docker_service.check_docker_available.return_value = False\n173: \n174:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n175:                 runtime._validate_build_prerequisites(workspace)\n176: \n177:     def test_validate_valid_workspace(self):\n178:         \"\"\"Test validation with valid workspace.\"\"\"\n179:         with tempfile.TemporaryDirectory() as tmpdir:\n180:             workspace = Path(tmpdir)\n181:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n182: \n183:             runtime = BuildRuntime()\n184:             runtime.docker_service = MagicMock(spec=DockerService)\n185:             runtime.docker_service.check_docker_available.return_value = True\n186: \n187:             runtime._validate_build_prerequisites(workspace)\n188:             runtime.docker_service.check_docker_available.assert_called_once()\n189: \n190:     def test_build_local_basic(self, mock_docker_service, mock_metadata_service):\n191:         \"\"\"Test basic local build.\"\"\"\n192:         with tempfile.TemporaryDirectory() as tmpdir:\n193:             workspace = Path(tmpdir)\n194:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n195: \n196:             metadata = AgentMetadata(\n197:                 agent_name=\"test-agent\",\n198:                 entrypoint=\"python main.py\",\n199:                 version=\"1.0.1\"\n200:             )\n201: \n202:             runtime = BuildRuntime()\n203:             runtime.docker_service = mock_docker_service\n204:             runtime.metadata_service = mock_metadata_service\n205: \n206:             result = runtime._build_local(workspace, metadata, {})\n207: \n208:             assert result[\"image_name\"] == \"test-agent:1.0.1\"\n209:             assert \"image_id\" in result\n210:             mock_docker_service.build_image.assert_called_once()\n211: \n212:     def test_build_local_with_proxy(self, mock_docker_service, mock_metadata_service):\n213:         \"\"\"Test local build with proxy.\"\"\"\n214:         with tempfile.TemporaryDirectory() as tmpdir:\n215:             workspace = Path(tmpdir)\n216:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n217: \n218:             metadata = AgentMetadata(\n219:                 agent_name=\"test-agent\",\n220:                 entrypoint=\"python main.py\",\n221:                 version=\"1.0.1\"\n222:             )\n223: \n224:             runtime = BuildRuntime()\n225:             runtime.docker_service = mock_docker_service\n226:             runtime.metadata_service = mock_metadata_service\n227: \n228:             options = {\"proxy\": \"http://proxy.example.com:8080\"}\n229:             result = runtime._build_local(workspace, metadata, options)\n230: \n231:             assert result[\"image_name\"] == \"test-agent:1.0.1\"\n232:             call_kwargs = mock_docker_service.build_image.call_args.kwargs\n233:             assert call_kwargs[\"build_args\"][\"HTTP_PROXY\"] == \"http://proxy.example.com:8080\"\n234:             assert call_kwargs[\"build_args\"][\"HTTPS_PROXY\"] == \"http://proxy.example.com:8080\"\n235: \n236:     def test_build_local_without_version(self, mock_docker_service, mock_metadata_service):\n237:         \"\"\"Test local build without version uses latest tag.\"\"\"\n238:         with tempfile.TemporaryDirectory() as tmpdir:\n239:             workspace = Path(tmpdir)\n240:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n241: \n242:             metadata = AgentMetadata(\n243:                 agent_name=\"test-agent\",\n244:                 entrypoint=\"python main.py\",\n245:                 version=None\n246:             )\n247: \n248:             runtime = BuildRuntime()\n249:             runtime.docker_service = mock_docker_service\n250:             runtime.metadata_service = mock_metadata_service\n251: \n252:             result = runtime._build_local(workspace, metadata, {})\n253: \n254:             assert result[\"image_name\"] == \"test-agent:latest\"\n255:             call_kwargs = mock_docker_service.build_image.call_args.kwargs\n256:             assert call_kwargs[\"tag\"] == \"latest\"\n257: \n258:     def test_build_cloud_with_provider(self, mock_metadata_service):\n259:         \"\"\"Test cloud build with provider.\"\"\"\n260:         with tempfile.TemporaryDirectory() as tmpdir:\n261:             workspace = Path(tmpdir)\n262: \n263:             metadata = AgentMetadata(\n264:                 agent_name=\"test-agent\",\n265:                 entrypoint=\"python main.py\",\n266:                 version=\"1.0.1\"\n267:             )\n268: \n269:             runtime = BuildRuntime()\n270:             runtime.metadata_service = mock_metadata_service\n271: \n272:             options = {\"cloud_provider\": \"huawei\"}\n273:             result = runtime._build_cloud(workspace, metadata, options)\n274: \n275:             assert result[\"image_name\"] == \"huawei/test-agent:1.0.1\"\n276:             assert result[\"image_id\"] == \"cloud-build-id\"\n277: \n278:     def test_build_cloud_default_provider(self, mock_metadata_service):\n279:         \"\"\"Test cloud build uses default provider.\"\"\"\n280:         with tempfile.TemporaryDirectory() as tmpdir:\n281:             workspace = Path(tmpdir)\n282: \n283:             metadata = AgentMetadata(\n284:                 agent_name=\"test-agent\",\n285:                 entrypoint=\"python main.py\",\n286:                 version=\"1.0.1\"\n287:             )\n288: \n289:             runtime = BuildRuntime()\n290:             runtime.metadata_service = mock_metadata_service\n291: \n292:             result = runtime._build_cloud(workspace, metadata, {})\n293: \n294:             assert result[\"image_name\"] == \"huawei/test-agent:1.0.1\"\n295: \n296:     def test_build_cloud_without_version(self, mock_metadata_service):\n297:         \"\"\"Test cloud build without version.\"\"\"\n298:         with tempfile.TemporaryDirectory() as tmpdir:\n299:             workspace = Path(tmpdir)\n300: \n301:             metadata = AgentMetadata(\n302:                 agent_name=\"test-agent\",\n303:                 entrypoint=\"python main.py\",\n304:                 version=None\n305:             )\n306: \n307:             runtime = BuildRuntime()\n308:             runtime.metadata_service = mock_metadata_service\n309: \n310:             result = runtime._build_cloud(workspace, metadata, {})\n311: \n312:             assert result[\"image_name\"] == \"huawei/test-agent:latest\"\n313: \n314:     def test_update_build_metadata(self, mock_metadata_service):\n315:         \"\"\"Test updating metadata with build result.\"\"\"\n316:         with tempfile.TemporaryDirectory() as tmpdir:\n317:             workspace = Path(tmpdir)\n318: \n319:             metadata = AgentMetadata(\n320:                 agent_name=\"test\",\n321:                 entrypoint=\"python main.py\",\n322:                 version=\"1.0.1\"\n323:             )\n324: \n325:             runtime = BuildRuntime()\n326:             runtime.metadata_service = mock_metadata_service\n327: \n328:             build_result = {\n329:                 \"image_name\": \"test:1.0.1\",\n330:                 \"image_id\": \"abc123\",\n331:                 \"image_size\": \"100 MB\"\n332:             }\n333: \n334:             runtime._update_build_metadata(workspace, metadata, build_result)\n335: \n336:             assert metadata.image == build_result\n337:             mock_metadata_service.save_metadata.assert_called_once_with(workspace, metadata)\n338: \n339:     def test_update_build_metadata_merge(self, mock_metadata_service):\n340:         \"\"\"Test merging build result with existing image data.\"\"\"\n341:         with tempfile.TemporaryDirectory() as tmpdir:\n342:             workspace = Path(tmpdir)\n343: \n344:             metadata = AgentMetadata(\n345:                 agent_name=\"test\",\n346:                 entrypoint=\"python main.py\",\n347:                 version=\"1.0.1\",\n348:                 image={\"old_field\": \"old_value\"}\n349:             )\n350: \n351:             runtime = BuildRuntime()\n352:             runtime.metadata_service = mock_metadata_service\n353: \n354:             build_result = {\n355:                 \"image_name\": \"test:1.0.1\",\n356:                 \"image_id\": \"abc123\"\n357:             }\n358: \n359:             runtime._update_build_metadata(workspace, metadata, build_result)\n360: \n361:             assert metadata.image[\"image_name\"] == \"test:1.0.1\"\n362:             assert metadata.image[\"image_id\"] == \"abc123\"\n363:             assert metadata.image[\"old_field\"] == \"old_value\"\n364: \n365:     def test_build_successful_local(self, mock_docker_service, mock_metadata_service):\n366:         \"\"\"Test successful local build.\"\"\"\n367:         with tempfile.TemporaryDirectory() as tmpdir:\n368:             workspace = Path(tmpdir)\n369:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n370: \n371:             def load_side_effect(path):\n372:                 return AgentMetadata(\n373:                     agent_name=\"test-agent\",\n374:                     entrypoint=\"python main.py\",\n375:                     version=\"1.0.0\",\n376:                     build_mode=\"local\"\n377:                 )\n378: \n379:             mock_metadata_service.load_metadata.side_effect = load_side_effect\n380: \n381:             runtime = BuildRuntime()\n382:             runtime.docker_service = mock_docker_service\n383:             runtime.metadata_service = mock_metadata_service\n384: \n385:             result = runtime.build(workspace)\n386: \n387:             assert result[\"image_name\"] == \"test-agent:1.0.1\"\n388:             assert result[\"image_id\"] == \"abc123def456\"\n389:             assert \"image_size\" in result\n390:             assert \"build_time\" in result\n391: \n392:             saved_metadata = mock_metadata_service.save_metadata.call_args[0][1]\n393:             assert saved_metadata.version == \"1.0.1\"\n394:             assert saved_metadata.image is not None\n395: \n396:     def test_build_reverts_version_on_failure(self, mock_docker_service, mock_metadata_service):\n397:         \"\"\"Test version reversion on build failure.\"\"\"\n398:         with tempfile.TemporaryDirectory() as tmpdir:\n399:             workspace = Path(tmpdir)\n400:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n401: \n402:             def load_side_effect(path):\n403:                 return AgentMetadata(\n404:                     agent_name=\"test-agent\",\n405:                     entrypoint=\"python main.py\",\n406:                     version=\"1.0.0\",\n407:                     build_mode=\"local\"\n408:                 )\n409: \n410:             mock_metadata_service.load_metadata.side_effect = load_side_effect\n411:             mock_docker_service.build_image.side_effect = RuntimeError(\"Build failed\")\n412: \n413:             runtime = BuildRuntime()\n414:             runtime.docker_service = mock_docker_service\n415:             runtime.metadata_service = mock_metadata_service\n416: \n417:             with pytest.raises(RuntimeError, match=\"Build failed\"):\n418:                 runtime.build(workspace)\n419: \n420:             saved_metadata = mock_metadata_service.save_metadata.call_args[0][1]\n421:             assert saved_metadata.version == \"1.0.0\"\n422: \n423:     def test_build_cloud_mode(self, mock_metadata_service):\n424:         \"\"\"Test build in cloud mode.\"\"\"\n425:         with tempfile.TemporaryDirectory() as tmpdir:\n426:             workspace = Path(tmpdir)\n427:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n428: \n429:             def load_side_effect(path):\n430:                 return AgentMetadata(\n431:                     agent_name=\"test-agent\",\n432:                     entrypoint=\"python main.py\",\n433:                     version=\"1.0.0\",\n434:                     build_mode=\"cloud\"\n435:                 )\n436: \n437:             mock_metadata_service.load_metadata.side_effect = load_side_effect\n438: \n439:             runtime = BuildRuntime()\n440:             runtime.docker_service = MagicMock(spec=DockerService)\n441:             runtime.docker_service.check_docker_available.return_value = True\n442:             runtime.metadata_service = mock_metadata_service\n443: \n444:             result = runtime.build(workspace)\n445: \n446:             assert result[\"image_name\"] == \"huawei/test-agent:1.0.1\"\n447:             runtime.docker_service.build_image.assert_not_called()\n448: \n449:     def test_build_missing_metadata(self):\n450:         \"\"\"Test build with missing metadata file.\"\"\"\n451:         with tempfile.TemporaryDirectory() as tmpdir:\n452:             workspace = Path(tmpdir)\n453:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n454: \n455:             metadata_service = MetadataService()\n456:             runtime = BuildRuntime()\n457:             runtime.metadata_service = metadata_service\n458:             runtime.docker_service = MagicMock(spec=DockerService)\n459:             runtime.docker_service.check_docker_available.return_value = True\n460: \n461:             with pytest.raises(FileNotFoundError, match=\"No metadata file found\"):\n462:                 runtime.build(workspace)\n463: \n464:     def test_build_invalid_build_mode(self):\n465:         \"\"\"Test build with invalid build mode.\"\"\"\n466:         with tempfile.TemporaryDirectory() as tmpdir:\n467:             workspace = Path(tmpdir)\n468:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n469: \n470:             with pytest.raises(ValueError, match=\"Build mode must be\"):\n471:                 AgentMetadata(\n472:                     agent_name=\"test\",\n473:                     entrypoint=\"python main.py\",\n474:                     build_mode=\"invalid\"\n475:                 )\n476: \n477:     def test_build_with_options_passed_through(self, mock_docker_service, mock_metadata_service):\n478:         \"\"\"Test build passes options through correctly.\"\"\"\n479:         with tempfile.TemporaryDirectory() as tmpdir:\n480:             workspace = Path(tmpdir)\n481:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n482: \n483:             def load_side_effect(path):\n484:                 return AgentMetadata(\n485:                     agent_name=\"test-agent\",\n486:                     entrypoint=\"python main.py\",\n487:                     version=\"1.0.0\",\n488:                     build_mode=\"local\"\n489:                 )\n490: \n491:             mock_metadata_service.load_metadata.side_effect = load_side_effect\n492: \n493:             runtime = BuildRuntime()\n494:             runtime.docker_service = mock_docker_service\n495:             runtime.metadata_service = mock_metadata_service\n496: \n497:             options = {\n498:                 \"proxy\": \"http://proxy.example.com:8080\",\n499:                 \"cloud_provider\": \"huawei\",\n500:                 \"output\": \"/tmp/output\"\n501:             }\n502: \n503:             result = runtime.build(workspace, **options)\n504: \n505:             assert result[\"image_name\"] == \"test-agent:1.0.1\"\n506:             call_kwargs = mock_docker_service.build_image.call_args.kwargs\n507:             assert call_kwargs[\"build_args\"][\"HTTP_PROXY\"] == \"http://proxy.example.com:8080\"\n508: \n509:     def test_verbose_mode_sets_logging(self):\n510:         \"\"\"Test verbose mode sets logging level.\"\"\"\n511:         import logging\n512: \n513:         runtime = BuildRuntime(verbose=True)\n514:         assert runtime.verbose is True\n515: \n516:     def test_non_verbose_mode(self):\n517:         \"\"\"Test non-verbose mode.\"\"\"\n518:         runtime = BuildRuntime(verbose=False)\n519:         assert runtime.verbose is False\n520: \n521:     def test_build_without_version_field(self, mock_docker_service, mock_metadata_service):\n522:         \"\"\"Test build when version field is None.\"\"\"\n523:         with tempfile.TemporaryDirectory() as tmpdir:\n524:             workspace = Path(tmpdir)\n525:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n526: \n527:             def load_side_effect(path):\n528:                 return AgentMetadata(\n529:                     agent_name=\"test-agent\",\n530:                     entrypoint=\"python main.py\",\n531:                     version=None,\n532:                     build_mode=\"local\"\n533:                 )\n534: \n535:             mock_metadata_service.load_metadata.side_effect = load_side_effect\n536: \n537:             runtime = BuildRuntime()\n538:             runtime.docker_service = mock_docker_service\n539:             runtime.metadata_service = mock_metadata_service\n540: \n541:             result = runtime.build(workspace)\n542: \n543:             assert result[\"image_name\"] == \"test-agent:0.1.0\"\n544:             saved_metadata = mock_metadata_service.save_metadata.call_args[0][1]\n545:             assert saved_metadata.version == \"0.1.0\"\n546: \n547:     def test_build_metadata_updated_with_build_result(self, mock_docker_service, mock_metadata_service):\n548:         \"\"\"Test that metadata is updated with build result.\"\"\"\n549:         with tempfile.TemporaryDirectory() as tmpdir:\n550:             workspace = Path(tmpdir)\n551:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n552: \n553:             def load_side_effect(path):\n554:                 return AgentMetadata(\n555:                     agent_name=\"test-agent\",\n556:                     entrypoint=\"python main.py\",\n557:                     version=\"1.0.0\",\n558:                     build_mode=\"local\"\n559:                 )\n560: \n561:             mock_metadata_service.load_metadata.side_effect = load_side_effect\n562: \n563:             runtime = BuildRuntime()\n564:             runtime.docker_service = mock_docker_service\n565:             runtime.metadata_service = mock_metadata_service\n566: \n567:             result = runtime.build(workspace)\n568: \n569:             assert mock_metadata_service.save_metadata.call_count == 2\n570:             final_save = mock_metadata_service.save_metadata.call_args\n571:             saved_metadata = final_save[0][1]\n572:             assert saved_metadata.image is not None\n573:             assert saved_metadata.image[\"image_name\"] == result[\"image_name\"]\n574: \n575:     @pytest.mark.integration\n576:     def test_e2e_build_local(self):\n577:         \"\"\"Test end-to-end local build with real Docker (integration test).\"\"\"\n578:         pytest.skip(\"Integration test - requires Docker daemon\")\n579: \n580:     @pytest.mark.integration\n581:     def test_e2e_build_with_proxy(self):\n582:         \"\"\"Test end-to-end build with proxy (integration test).\"\"\"\n583:         pytest.skip(\"Integration test - requires Docker daemon and proxy\")\n584: \n585:     @pytest.mark.integration\n586:     def test_e2e_build_failure_recovery(self):\n587:         \"\"\"Test end-to-end build failure and recovery (integration test).\"\"\"\n588:         pytest.skip(\"Integration test - requires Docker daemon\")\n\n(End of file - total 588 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for the build runtime.\"\"\"\n\nimport pytest\nfrom pathlib import Path\nimport tempfile\nimport yaml\nfrom unittest.mock import MagicMock, patch, PropertyMock\n\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.services.metadata_serv