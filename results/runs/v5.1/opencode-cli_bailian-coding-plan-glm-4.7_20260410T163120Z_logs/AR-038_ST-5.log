i_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/collector.go","before":"package gc\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\ntype GCCollector struct {\n\tdynamicClient dynamic.Interface\n\tstoreClient   store.Store\n\tconfig        *GCConfig\n\tpolicy        *GCPolicy\n\tmetrics       *GCMetrics\n\tlogger        Logger\n}\n\ntype Logger interface {\n\tInfo(msg string, keysAndValues ...interface{})\n\tError(msg string, keysAndValues ...interface{})\n\tWarning(msg string, keysAndValues ...interface{})\n}\n\ntype DefaultLogger struct{}\n\nfunc (l *DefaultLogger) Info(msg string, keysAndValues ...interface{}) {\n\tklog.InfoS(msg, keysAndValues...)\n}\n\nfunc (l *DefaultLogger) Error(msg string, keysAndValues ...interface{}) {\n\tklog.ErrorS(nil, msg, keysAndValues...)\n}\n\nfunc (l *DefaultLogger) Warning(msg string, keysAndValues ...interface{}) {\n\tklog.V(2).InfoS(msg, keysAndValues...)\n}\n\nfunc NewGCCollector(\n\tdynamicClient dynamic.Interface,\n\tstoreClient store.Store,\n\tconfig *GCConfig,\n\tpolicy *GCPolicy,\n\tmetrics *GCMetrics,\n) *GCCollector {\n\treturn &GCCollector{\n\t\tdynamicClient: dynamicClient,\n\t\tstoreClient:   storeClient,\n\t\tconfig:        config,\n\t\tpolicy:        policy,\n\t\tmetrics:       metrics,\n\t\tlogger:        &DefaultLogger{},\n\t}\n}\n\nfunc (c *GCCollector) Collect(ctx context.Context) (*GCResult, error) {\n\tstartTime := time.Now()\n\tresult := &GCResult{}\n\n\tfinder := NewSandboxFinder(c.dynamicClient, &storeAdapter{c.storeClient}, c.policy)\n\n\tcandidates, err := finder.FindCandidates(ctx)\n\tif err != nil {\n\t\tc.logger.Error(\"Failed to find candidates\", \"error\", err)\n\t\tc.metrics.RecordError(\"find_candidates\")\n\t\tresult.Errors++\n\t\treturn result, err\n\t}\n\n\tresult.Scanned = len(candidates)\n\tc.metrics.RecordScanned(result.Scanned)\n\n\tvar toDelete []*unstructured.Unstructured\n\tfor _, candidate := range candidates {\n\t\tsessionID := GetSessionIDFromSandbox(candidate)\n\t\tsessionInfo, err := c.getSessionInfo(ctx, sessionID)\n\t\tif err != nil {\n\t\t\tc.logger.Warning(\"Failed to get session info\", \"sessionID\", sessionID, \"error\", err)\n\t\t\tc.metrics.RecordError(\"get_session_info\")\n\t\t\tresult.Errors++\n\t\t\tcontinue\n\t\t}\n\n\t\tif c.policy.ShouldGC(candidate, sessionInfo) {\n\t\t\ttoDelete = append(toDelete, candidate)\n\t\t}\n\t}\n\n\tresult.Candidates = len(toDelete)\n\tc.metrics.SetCandidates(result.Candidates)\n\n\tif result.Candidates > 0 {\n\t\tc.logger.Info(\"Found candidates for GC\", \"count\", result.Candidates)\n\t}\n\n\tfor _, sandbox := range toDelete {\n\t\tsessionID := GetSessionIDFromSandbox(sandbox)\n\t\tsessionInfo, err := c.getSessionInfo(ctx, sessionID)\n\t\tif err != nil {\n\t\t\tc.logger.Warning(\"Failed to get session info for deletion\", \"sessionID\", sessionID, \"error\", err)\n\t\t\tc.metrics.RecordError(\"get_session_info_delete\")\n\t\t\tresult.Errors++\n\t\t\tcontinue\n\t\t}\n\n\t\treason := BuildCleanupReasonFromPolicy(c.policy, sandbox, sessionInfo)\n\t\terr = c.Delete(ctx, sandbox, reason)\n\t\tif err != nil {\n\t\t\tresult.Errors++\n\t\t\tc.metrics.RecordError(\"delete\")\n\t\t} else {\n\t\t\tresult.Deleted++\n\t\t\tc.metrics.RecordDeleted(string(reason), sandbox.GetKind())\n\t\t}\n\t}\n\n\tresult.Duration = time.Since(startTime)\n\tc.metrics.RecordDuration(result.Duration.Seconds())\n\tc.metrics.ResetCandidates()\n\n\tc.logger.Info(\"GC collection completed\",\n\t\t\"scanned\", result.Scanned,\n\t\t\"candidates\", result.Candidates,\n\t\t\"deleted\", result.Deleted,\n\t\t\"errors\", result.Errors,\n\t\t\"duration\", result.Duration,\n\t)\n\n\treturn result, nil\n}\n\nfunc (c *GCCollector) Delete(ctx context.Context, sandbox *unstructured.Unstructured, reason wmTypes.SandboxCleanupReason) error {\n\tif c.config.DryRun {\n\t\tc.logger.Info(\"Dry run: would delete sandbox\",\n\t\t\t\"name\", sandbox.GetName(),\n\t\t\t\"namespace\", sandbox.GetNamespace(),\n\t\t\t\"reason\", reason,\n\t\t)\n\t\treturn nil\n\t}\n\n\tgvr := c.getGVRForKind(sandbox.GetKind())\n\n\tdeleteCtx, cancel := context.WithTimeout(ctx, workloadmanager.DeleteTimeout)\n\tdefer cancel()\n\n\terr := c.dynamicClient.Resource(gvr).\n\t\tNamespace(sandbox.GetNamespace()).\n\t\tDelete(deleteCtx, sandbox.GetName(), metav1.DeleteOptions{})\n\n\tif err != nil && !apierrors.IsNotFound(err) {\n\t\tc.logger.Error(\"Failed to delete sandbox\",\n\t\t\t\"name\", sandbox.GetName(),\n\t\t\t\"namespace\", sandbox.GetNamespace(),\n\t\t\t\"error\", err,\n\t\t)\n\t\treturn err\n\t}\n\n\tsessionID := GetSessionIDFromSandbox(sandbox)\n\tif sessionID != \"\" {\n\t\tif err := c.storeClient.DeleteSandboxBySessionID(ctx, sessionID); err != nil {\n\t\t\tc.logger.Warning(\"Failed to delete sandbox from store\",\n\t\t\t\t\"sessionID\", sessionID,\n\t\t\t\t\"error\", err,\n\t\t\t)\n\t\t}\n\t}\n\n\tc.logger.Info(\"Deleted sandbox\",\n\t\t\"name\", sandbox.GetName(),\n\t\t\"namespace\", sandbox.GetNamespace(),\n\t\t\"reason\", reason,\n\t)\n\n\treturn nil\n}\n\nfunc (c *GCCollector) getGVRForKind(kind string) schema.GroupVersionResource {\n\tif kind == \"SandboxClaim\" {\n\t\treturn SandboxClaimGVR\n\t}\n\treturn SandboxGVR\n}\n\nfunc (c *GCCollector) getSessionInfo(ctx context.Context, sessionID string) (*SessionInfo, error) {\n\tif sessionID == \"\" {\n\t\treturn nil, nil\n\t}\n\n\tsandboxInfo, err := c.storeClient.GetSandboxBySessionID(ctx, sessionID)\n\tif err != nil {\n\t\tif err == store.ErrNotFound {\n\t\t\treturn nil, nil\n\t\t}\n\t\treturn nil, err\n\t}\n\n\treturn &SessionInfo{\n\t\tSessionID:        sandboxInfo.SessionID,\n\t\tLastActivityAt:   sandboxInfo.LastActivityAt,\n\t\tExpiresAt:        sandboxInfo.ExpiresAt,\n\t\tHasActiveSession: true,\n\t}, nil\n}\n\ntype storeAdapter struct {\n\tstore store.Store\n}\n\nfunc (a *storeAdapter) GetSandbox(ctx context.Context, sessionID string) (*SessionInfo, error) {\n\tsandboxInfo, err := a.store.GetSandbox(ctx, sessionID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &SessionInfo{\n\t\tSessionID:        sandboxInfo.SessionID,\n\t\tLastActivityAt:   sandboxInfo.LastActivityAt,\n\t\tExpiresAt:        sandboxInfo.ExpiresAt,\n\t\tHasActiveSession: true,\n\t}, nil\n}\n","after":"package gc\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\ntype GCCollector struct {\n\tdynamicClient dynamic.Interface\n\tstoreClient   store.Store\n\tconfig        *GCConfig\n\tpolicy        *GCPolicy\n\tmetrics       *GCMetrics\n\tlogger        Logger\n}\n\ntype Logger interface {\n\tInfo(msg string, keysAndValues ...interface{})\n\tError(msg string, keysAndValues ...interface{})\n\tWarning(msg string, keysAndValues ...interface{})\n}\n\ntype DefaultLogger struct{}\n\nfunc (l *DefaultLogger) Info(msg string, keysAndValues ...interface{}) {\n\tklog.InfoS(msg, keysAndValues...)\n}\n\nfunc (l *DefaultLogger) Error(msg string, keysAndValues ...interface{}) {\n\tklog.ErrorS(nil, msg, keysAndValues...)\n}\n\nfunc (l *DefaultLogger) Warning(msg string, keysAndValues ...interface{}) {\n\tklog.V(2).InfoS(msg, keysAndValues...)\n}\n\nfunc NewGCCollector(\n\tdynamicClient dynamic.Interface,\n\tstoreClient store.Store,\n\tconfig *GCConfig,\n\tpolicy *GCPolicy,\n\tmetrics *GCMetrics,\n) *GCCollector {\n\treturn &GCCollector{\n\t\tdynamicClient: dynamicClient,\n\t\tstoreClient:   storeClient,\n\t\tconfig:        config,\n\t\tpolicy:        policy,\n\t\tmetrics:       metrics,\n\t\tlogger:        &DefaultLogger{},\n\t}\n}\n\nfunc (c *GCCollector) Collect(ctx context.Context) (*GCResult, error) {\n\tstartTime := time.Now()\n\tresult := &GCResult{}\n\n\tfinder := NewSandboxFinder(c.dynamicClient, &storeAdapter{c.storeClient}, c.policy)\n\n\tcandidates, err := finder.FindCandidates(ctx)\n\tif err != nil {\n\t\tc.logger.Error(\"Failed to find candidates\", \"error\", err)\n\t\tc.metrics.RecordError(\"find_candidates\")\n\t\tresult.Errors++\n\t\treturn result, err\n\t}\n\n\tresult.Scanned = len(candidates)\n\tc.metrics.RecordScanned(result.Scanned)\n\n\tvar toDelete []*unstructured.Unstructured\n\tfor _, candidate := range candidates {\n\t\tsessionID := GetSessionIDFromSandbox(candidate)\n\t\tsessionInfo, err := c.getSessionInfo(ctx, sessionID)\n\t\tif err != nil {\n\t\t\tc.logger.Warning(\"Failed to get session info\", \"sessionID\", sessionID, \"error\", err)\n\t\t\tc.metrics.RecordError(\"get_session_info\")\n\t\t\tresult.Errors++\n\t\t\tcontinue\n\t\t}\n\n\t\tif c.policy.ShouldGC(candidate, sessionInfo) {\n\t\t\ttoDelete = append(toDelete, candidate)\n\t\t}\n\t}\n\n\tresult.Candidates = len(toDelete)\n\tc.metrics.SetCandidates(result.Candidates)\n\n\tif result.Candidates > 0 {\n\t\tc.logger.Info(\"Found candidates for GC\", \"count\", result.Candidates)\n\t}\n\n\tfor _, sandbox := range toDelete {\n\t\tsessionID := GetSessionIDFromSandbox(sandbox)\n\t\tsessionInfo, err := c.getSessionInfo(ctx, sessionID)\n\t\tif err != nil {\n\t\t\tc.logger.Warning(\"Failed to get session info for deletion\", \"sessionID\", sessionID, \"error\", err)\n\t\t\tc.metrics.RecordError(\"get_session_info_delete\")\n\t\t\tresult.Errors++\n\t\t\tcontinue\n\t\t}\n\n\t\