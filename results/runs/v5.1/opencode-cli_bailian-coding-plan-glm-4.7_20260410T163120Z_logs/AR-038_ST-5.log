{"type":"tool_use","timestamp":1775892618791,"sessionID":"ses_2849432dfffeJ6QpZ8TqFZAAr6","part":{"id":"prt_d7b72d7d5001kVBbVNjwnaHzRb","messageID":"msg_d7b71ec57001GFdk42M3MgUhBh","sessionID":"ses_2849432dfffeJ6QpZ8TqFZAAr6","type":"tool","tool":"write","callID":"toolu_tool-60d627b6e6ac4e27b674c38253eab315","state":{"status":"completed","input":{"content":"package controller\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/require\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/api\"\n)\n\ntype MockK8sClient struct {\n\tmock.Mock\n}\n\nfunc (m *MockK8sClient) GetAgentRuntime(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) GetCodeInterpreter(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) CreateSandbox(ctx context.Context, namespace string, sandbox *unstructured.Unstructured) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, sandbox)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) GetSandbox(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) DeleteSandbox(ctx context.Context, namespace, name string) error {\n\targs := m.Called(ctx, namespace, name)\n\treturn args.Error(0)\n}\n\nfunc (m *MockK8sClient) GetPodIP(ctx context.Context, sandboxName, namespace string, sandbox *unstructured.Unstructured) (string, error) {\n\targs := m.Called(ctx, sandboxName, namespace, sandbox)\n\treturn args.String(0), args.Error(1)\n}\n\nfunc (m *MockK8sClient) GetSecret(ctx context.Context, namespace, name string) (*corev1.Secret, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*corev1.Secret), args.Error(1)\n}\n\nfunc createAgentRuntime(name, namespace string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\t\"kind\":       \"AgentRuntime\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      name,\n\t\t\t\t\"namespace\": namespace,\n\t\t\t},\n\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\"podTemplate\": map[string]interface{}{\n\t\t\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\t\t\"containers\": []interface{}{\n\t\t\t\t\t\t\tmap[string]interface{}{\n\t\t\t\t\t\t\t\t\"name\":  \"agent\",\n\t\t\t\t\t\t\t\t\"image\": \"python:3.11-slim\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\t\"ports\": []interface{}{\n\t\t\t\t\tmap[string]interface{}{\n\t\t\t\t\t\t\"port\":     int64(8080),\n\t\t\t\t\t\t\"protocol\": \"HTTP\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc createCodeInterpreter(name, namespace string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\t\"kind\":       \"CodeInterpreter\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      name,\n\t\t\t\t\"namespace\": namespace,\n\t\t\t},\n\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\"template\": map[string]interface{}{\n\t\t\t\t\t\"image\": \"python:3.11-slim\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc createSandboxCR(name, namespace, sessionID, workloadName string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n\t\t\t\"kind\":       \"Sandbox\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":              name,\n\t\t\t\t\"namespace\":         namespace,\n\t\t\t\t\"uid\":               \"sandbox-uid-12345\",\n\t\t\t\t\"labels\": map[string]interface{}{\n\t\t\t\t\t\"runtime.agentcube.io/session-id\": sessionID,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc TestSandboxController_CreateAgentRuntimeSandbox(t *testing.T) {\n\tctx := context.Background()\n\n\tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tmockStore := new(MockStore)\n\t\tcontroller := NewSandboxController(mockK8s, mockStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n\t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n\n\t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n\t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.5\", nil)\n\t\tmockStore.On(\"StoreSandbox\", mock.Anything, mock.AnythingOfType(\"*types.SandboxInfo\")).Return(nil)\n\t\tmockStore.On(\"UpdateSandbox\", mock.Anything, mock.AnythingOfType(\"*types.SandboxInfo\")).Return(nil)\n\n\t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.NotEmpty(t, resp.SessionID)\n\t\tassert.NotEmpty(t, resp.SandboxID)\n\t\tassert.NotEmpty(t, resp.SandboxName)\n\t\tassert.Contains(t, resp.SandboxName, \"test-runtime-\")\n\t\tassert.NotEmpty(t, resp.EntryPoints)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.5:8080\", resp.EntryPoints[0].Endpoint)\n\t\tassert.NotEmpty(t, resp.CreatedAt)\n\t\tassert.NotEmpty(t, resp.ExpiresAt)\n\n\t\tmockK8s.AssertExpectations(t)\n\t\tmockStore.AssertExpectations(t)\n\t})\n\n\tt.Run(\"agent runtime not found\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tmockStore := new(MockStore)\n\t\tcontroller := NewSandboxController(mockK8s, mockStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"nonexistent\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"agentruntimes\"), \"nonexistent\")\n\t\tmockK8s.On(\"GetAgentRuntime\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n\n\t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n\n\tt.Run(\"failed to create sandbox\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tmockStore := new(MockStore)\n\t\tcontroller := NewSandboxController(mockK8s, mockStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n\t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n\n\t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n\t\tmockK8s.On(\"CreateSandbox\", mock.Anything, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.Anything, mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"\", assert.AnError).Once()\n\t\tmockK8s.On(\"DeleteSandbox\", mock.Anything, \"default\", mock.MatchedBy(func(s string) bool { return true })).Return(nil).Maybe()\n\t\tmockStore.On(\"StoreSandbox\", mock.Anything, mock.AnythingOfType(\"*types.SandboxInfo\")).Return(nil)\n\t\tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, mock.AnythingOfType(\"string\")).Return(nil).Maybe()\n\n\t\tctx, cancel := context.WithTimeout(ctx, 100*time.Millisecond)\n\t\tdefer cancel()\n\n\t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"timed out\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n}\n\nfunc TestSandboxController_CreateCodeInterpreterSandbox(t *testing.T) {\n\tctx := context.Background()\n\n\tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tmockStore := new(MockStore)\n\t\tcontroller := NewSandboxController(mockK8s, mockStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-interpreter\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tcodeInterpreter := createCodeInterpreter(\"test-interpreter\", \"default\")\n\t\tsandboxCR := createSandboxCR(\"test-interpreter-12345678\", \"default\", \"session-123\", \"test-interpreter\")\n\n\t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"test-interpreter\").Return(codeInterpreter, nil)\n\t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.6\", nil)\n\t\tmockStore.On(\"StoreSandbox\", mock.Anything, mock.AnythingOfType(\"*types.SandboxInfo\")).Return(nil)\n\t\tmockStore.On(\"UpdateSandbox\", mock.Anything, mock.AnythingOfType(\"*types.SandboxInfo\")).Return(nil)\n\n\t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.NotEmpty(t, resp.SessionID)\n\t\tassert.NotEmpty(t, resp.SandboxID)\n\t\tassert.NotEmpty(t, resp.SandboxName)\n\t\tassert.Contains(t, resp.SandboxName, \"test-interpreter-\")\n\t\tassert.NotEmpty(t, resp.EntryPoints)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.6:8080\", resp.EntryPoints[0].Endpoint)\n\n\t\tmockK8s.AssertExpectations(t)\n\t\tmockStore.AssertExpectations(t)\n\t})\n\n\tt.Run(\"code interpreter not found\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tmockStore := new(MockStore)\n\t\tcontroller := NewSandboxController(mockK8s, mockStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"nonexistent\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"codeinterpreters\"), \"nonexistent\")\n\t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n\n\t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n}\n\nfunc TestSandboxController_GetSession(t *testing.T) {\n\tctx := context.Background()\n\n\tt.Run(\"successfully gets session\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tmockStore := new(MockStore)\n\t\tcontroller := NewSandboxController(mockK8s, mockStore)\n\n\t\tsessionID := \"test-session-123\"\n\t\tsandboxInfo := &types.SandboxInfo{\n\t\t\tSessionID:        sessionID,\n\t\t\tSandboxID:        \"sandbox-123\",\n\t\t\tSandboxName:      \"test-sandbox\",\n\t\t\tWorkloadName:     \"test-runtime\",\n\t\t\tNamespace:        \"default\",\n\t\t\tKind:             \"AgentRuntime\",\n\t\t\tPodIP:            \"10.244.1.5\",\n\t\t\tStatus:           \"running\",\n\t\t\tEntryPoints:      []types.SandboxEntryPoint{{Protocol: \"HTTP\", Endpoint: \"10.244.1.5:8080\"}},\n\t\t\tCreatedAt:        time.Now(),\n\t\t\tExpiresAt:        time.Now().Add(8 * time.Hour),\n\t\t\tLastActivityAt:   time.Now(),\n\t\t}\n\n\t\tmockStore.On(\"GetSandboxBySessionID\", ctx, sessionID).Return(sandboxInfo, nil)\n\n\t\tresp, err := controller.GetSession(ctx, sessionID)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.Equal(t, sessionID, resp.SessionID)\n\t\tassert.Equal(t, \"sandbox-123\", resp.SandboxID)\n\t\tassert.Equal(t, \"test-sandbox\", resp.SandboxName)\n\t\tassert.Equal(t, \"AgentRuntime\", resp.Kind)\n\t\tassert.Equal(t, \"test-runtime\", resp.Name)\n\t\tassert.Equal(t, \"default\", resp.Namespace)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\n\t\tmockStore.AssertExpectations(t)\n\t})\n\n\tt.Run(\"session not found\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tmockStore := new(MockStore)\n\t\tcontroller := NewSandboxController(mockK8s, mockStore)\n\n\t\tsessionID := \"nonexistent-session\"\n\n\t\tmockStore.On(\"GetSandboxBySessionID\", ctx, sessionID).Return(nil, store.ErrNotFound)\n\n\t\tresp, err := controller.GetSession(ctx, sessionID)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\n\t\tmockStore.AssertExpectations(t)\n\t})\n}\n\nfunc TestSandboxController_DeleteSession(t *testing.T) {\n\tctx := context.Background()\n\n\tt.Run(\"successfully deletes session\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tmockStore := new(MockStore)\n\t\tcontroller := NewSandboxController(mockK8s, mockStore)\n\n\t\tsessionID := \"test-session-123\"\n\t\tsandboxInfo := &types.SandboxInfo{\n\t\t\tSessionID:        sessionID,\n\t\t\tSandboxID:        \"sandbox-123\",\n\t\t\tSandboxName:      \"test-sandbox\",\n\t\t\tSandboxNamespace: \"default\",\n\t\t\tWorkloadName:     \"test-runtime\",\n\t\t\tKind:             \"AgentRuntime\",\n\t\t}\n\n\t\tmockStore.On(\"GetSandboxBySessionID\", ctx, sessionID).Return(sandboxInfo, nil)\n\t\tmockK8s.On(\"DeleteSandbox\", ctx, \"default\", \"test-sandbox\").Return(nil)\n\t\tmockStore.On(\"DeleteSandboxBySessionID\", ctx, sessionID).Return(nil)\n\n\t\tresp, err := controller.DeleteSession(ctx, sessionID)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.Equal(t, sessionID, resp.SessionID)\n\t\tassert.NotEmpty(t, resp.DeletedAt)\n\n\t\tmockK8s.AssertExpectations(t)\n\t\tmockStore.AssertExpectations(t)\n\t})\n\n\tt.Run(\"session not found\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tmockStore := new(MockStore)\n\t\tcontroller := NewSandboxController(mockK8s, mockStore)\n\n\t\tsessionID := \"nonexistent-session\"\n\n\t\tmockStore.On(\"GetSandboxBySessionID\", ctx, sessionID).Return(nil, store.ErrNotFound)\n\n\t\tresp, err := controller.DeleteSession(ctx, sessionID)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\n\t\tmockStore.AssertExpectations(t)\n\t})\n}\n\nfunc TestSandboxController_BuildEntryPoints(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tpodIP    string\n\t\tports    []interface{}\n\t\texpected []api.EntryPoint\n\t}{\n\t\t{\n\t\t\tname:  \"single HTTP port\",\n\t\t\tpodIP: \"10.244.1.5\",\n\t\t\tports: []interface{}{\n\t\t\t\tmap[string]interface{}{\n\t\t\t\t\t\"port\":     int64(8080),\n\t\t\t\t\t\"protocol\": \"HTTP\",\n\t\t\t\t},\n\t\t\t},\n\t\t\texpected: []api.EntryPoint{\n\t\t\t\t{\n\t\t\t\t\tProtocol: \"HTTP\",\n\t\t\t\t\tEndpoint: \"10.244.1.5:8080\",\n\t\t\t\t\tPort:     8080,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:  \"multiple ports\",\n\t\t\tpodIP: \"10.244.1.5\",\n\t\t\tports: []interface{}{\n\t\t\t\tmap[string]interface{}{\n\t\t\t\t\t\"port\":        int64(8080),\n\t\t\t\t\t\"protocol\":    \"HTTP\",\n\t\t\t\t\t\"pathPrefix\":  \"/api\",\n\t\t\t\t},\n\t\t\t\tmap[string]interface{}{\n\t\t\t\t\t\"port\":     int64(8443),\n\t\t\t\t\t\"protocol\": \"HTTPS\",\n\t\t\t\t},\n\t\t\t},\n\t\t\texpected: []api.EntryPoint{\n\t\t\t\t{\n\t\t\t\t\tProtocol: \"HTTP\",\n\t\t\t\t\tEndpoint: \"10.244.1.5:8080\",\n\t\t\t\t\tPort:     8080,\n\t\t\t\t\tPath:     \"/api\",\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\tProtocol: \"HTTPS\",\n\t\t\t\t\tEndpoint: \"10.244.1.5:8443\",\n\t\t\t\t\tPort:     8443,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"empty ports\",\n\t\t\tpodIP:    \"10.244.1.5\",\n\t\t\tports:    []interface{}{},\n\t\t\texpected: []api.EntryPoint{},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tentryPoints := convertEntryPointsFromTest(tt.podIP, tt.ports)\n\n\t\t\tassert.Len(t, entryPoints, len(tt.expected))\n\t\t\tfor i, ep := range entryPoints {\n\t\t\t\tassert.Equal(t, tt.expected[i].Protocol, ep.Protocol)\n\t\t\t\tassert.Equal(t, tt.expected[i].Endpoint, ep.Endpoint)\n\t\t\t\tassert.Equal(t, tt.expected[i].Port, ep.Port)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc convertEntryPointsFromTest(podIP string, ports []interface{}) []api.EntryPoint {\n\tvar entryPoints []api.EntryPoint\n\tfor _, p := range ports {\n\t\tportMap, ok := p.(map[string]interface{})\n\t\tif !ok {\n\t\t\tcontinue\n\t\t}\n\n\t\tprotocol, _, _ := unstructured.NestedString(portMap, \"protocol\")\n\t\tport, _, _ := unstructured.NestedInt64(portMap, \"port\")\n\t\tpath, _, _ := unstructured.NestedString(portMap, \"pathPrefix\")\n\n\t\tif port == 0 || protocol == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tentryPoints = append(entryPoints, api.EntryPoint{\n\t\t\tProtocol: protocol,\n\t\t\tEndpoint: fmt.Sprintf(\"%s:%d\", podIP, port),\n\t\t\tPath:     path,\n\t\t\tPort:     int32(port),\n\t\t})\n\t}\n\treturn entryPoints\n}\n\nfunc TestSandboxController_GenerateSandboxName(t *testing.T) {\n\tworkloadName := \"test-runtime\"\n\tsandboxName1 := generateSandboxName(workloadName)\n\tsandboxName2 := generateSandboxName(workloadName)\n\n\tassert.Contains(t, sandboxName1, workloadName)\n\tassert.Contains(t, sandboxName2, workloadName)\n\tassert.Equal(t, len(sandboxName1), len(sandboxName2))\n\tassert.NotEqual(t, sandboxName1, sandboxName2)\n}\n\nfunc TestConvertEntryPoints(t *testing.T) {\n\tapiEntryPoints := []api.EntryPoint{\n\t\t{\n\t\t\tProtocol: \"HTTP\",\n\t\t\tEndpoint: \"10.244.1.5:8080\",\n\t\t\tPort:     8080,\n\t\t\tPath:     \"/api\",\n\t\t},\n\t}\n\n\tresult := convertEntryPoints(apiEntryPoints)\n\n\tassert.Len(t, result, 1)\n\tassert.Equal(t, \"HTTP\", result[0].Protocol)\n\tassert.Equal(t, \"10.244.1.5:8080\", result[0].Endpoint)\n\tassert.Equal(t, \"/api\", result[0].Path)\n}\n\nfunc TestConvertToAPIEntryPoints(t *testing.T) {\n\ttypesEntryPoints := []types.SandboxEntryPoint{\n\t\t{\n\t\t\tProtocol: \"HTTP\",\n\t\t\tEndpoint: \"10.244.1.5:8080\",\n\t\t\tPath:     \"/api\",\n\t\t},\n\t}\n\n\tresult := convertToAPIEntryPoints(typesEntryPoints)\n\n\tassert.Len(t, result, 1)\n\tassert.Equal(t, \"HTTP\", result[0].Protocol)\n\tassert.Equal(t, \"10.244.1.5:8080\", result[0].Endpoint)\n\tassert.Equal(t, \"/api\", result[0].Path)\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox_test.go"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/session_manager.go\">\nERROR [94:36] m.storeClient.G