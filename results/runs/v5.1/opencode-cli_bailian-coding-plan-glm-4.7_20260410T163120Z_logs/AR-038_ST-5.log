ce(),\n\t\t\"reason\", reason,\n\t)\n\n\treturn nil\n}\n\nfunc (c *GCCollector) getGVRForKind(kind string) schema.GroupVersionResource {\n\tif kind == \"SandboxClaim\" {\n\t\treturn SandboxClaimGVR\n\t}\n\treturn SandboxGVR\n}\n\nfunc (c *GCCollector) getSessionInfo(ctx context.Context, sessionID string) (*SessionInfo, error) {\n\tif sessionID == \"\" {\n\t\treturn nil, nil\n\t}\n\n\tsandboxInfo, err := c.storeClient.GetSandboxBySessionID(ctx, sessionID)\n\tif err != nil {\n\t\tif err == store.ErrNotFound {\n\t\t\treturn nil, nil\n\t\t}\n\t\treturn nil, err\n\t}\n\n\treturn &SessionInfo{\n\t\tSessionID:        sandboxInfo.SessionID,\n\t\tLastActivityAt:   sandboxInfo.LastActivityAt,\n\t\tExpiresAt:        sandboxInfo.ExpiresAt,\n\t\tHasActiveSession: true,\n\t}, nil\n}\n\ntype storeAdapter struct {\n\tstore store.Store\n}\n\nfunc (a *storeAdapter) GetSandbox(ctx context.Context, sessionID string) (*SessionInfo, error) {\n\tsandboxInfo, err := a.store.GetSandboxBySessionID(ctx, sessionID)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &SessionInfo{\n\t\tSessionID:        sandboxInfo.SessionID,\n\t\tLastActivityAt:   sandboxInfo.LastActivityAt,\n\t\tExpiresAt:        sandboxInfo.ExpiresAt,\n\t\tHasActiveSession: true,\n\t}, nil\n}\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/collector.go","time":{"start":1775892358381,"end":1775892358590}}}}
