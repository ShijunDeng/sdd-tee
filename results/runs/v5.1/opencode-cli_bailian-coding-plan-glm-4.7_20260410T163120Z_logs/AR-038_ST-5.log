\n43: func (m *mockStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n44: \targs := m.Called(ctx, sessionID, info)\n45: \treturn args.Error(0)\n46: }\n47: \n48: func (m *mockStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n49: \targs := m.Called(ctx, sessionID)\n50: \treturn args.Error(0)\n51: }\n52: \n53: func (m *mockStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n54: \targs := m.Called(ctx)\n55: \tif args.Get(0) == nil {\n56: \t\treturn nil, args.Error(1)\n57: \t}\n58: \treturn args.Get(0).(map[string]*types.SandboxInfo), args.Error(1)\n59: }\n60: \n61: func (m *mockStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n62: \targs := m.Called(ctx, sessionID, at)\n63: \treturn args.Error(0)\n64: }\n65: \n66: func (m *mockStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n67: \targs := m.Called(ctx, before, limit)\n68: \tif args.Get(0) == nil {\n69: \t\treturn nil, args.Error(1)\n70: \t}\n71: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n72: }\n73: \n74: func (m *mockStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n75: \targs := m.Called(ctx, before, limit)\n76: \tif args.Get(0) == nil {\n77: \t\treturn nil, args.Error(1)\n78: \t}\n79: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n80: }\n81: \n82: func (m *mockStore) Close() error {\n83: \targs := m.Called()\n84: \treturn args.Error(0)\n85: }\n86: \n87: func buildTestSandbox(name, namespace, sessionID string, age time.Duration) *unstructured.Unstructured {\n88: \treturn &unstructured.Unstructured{\n89: \t\tObject: map[string]interface{}{\n90: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n91: \t\t\t\"kind\":       \"Sandbox\",\n92: \t\t\t\"metadata\": map[string]interface{}{\n93: \t\t\t\t\"name\":              name,\n94: \t\t\t\t\"namespace\":         namespace,\n95: \t\t\t\t\"creationTimestamp\": time.Now().Add(-age).Format(time.RFC3339),\n96: \t\t\t\t\"labels\": map[string]interface{}{\n97: \t\t\t\t\tSessionIDLabelKey: sessionID,\n98: \t\t\t\t},\n99: \t\t\t},\n100: \t\t},\n101: \t}\n102: }\n103: \n104: func TestNewGCCollector(t *testing.T) {\n105: \tmockStore := &mockStore{}\n106: \tscheme := runtime.NewScheme()\n107: \tfakeClient := fake.NewSimpleDynamicClient(scheme)\n108: \n109: \tconfig := DefaultGCConfig()\n110: \tpolicy, _ := NewGCPolicy(config)\n111: \tmetrics := NewGCMetrics()\n112: \n113: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n114: \n115: \tassert.NotNil(t, collector)\n116: \tassert.Equal(t, fakeClient, collector.dynamicClient)\n117: \tassert.Equal(t, mockStore, collector.storeClient)\n118: \tassert.Equal(t, config, collector.config)\n119: \tassert.Equal(t, policy, collector.policy)\n120: \tassert.Equal(t, metrics, collector.metrics)\n121: }\n122: \n123: func TestGCCollector_Collect_NoCandidates(t *testing.T) {\n124: \tmockStore := &mockStore{}\n125: \tscheme := runtime.NewScheme()\n126: \t\n127: \t\tKind:       \"SandboxList\",\n128: \t\tAPIVersion: \"agents.x-k8s.io/v1alpha1\",\n129: \t}\n130: \tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n131: \t\t&unstructured.Unstructured{},\n132: \t\t&unstructured.UnstructuredList{},\n133: \t)\n134: \t\n135: \tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n136: \t\tSandboxGVR: \"SandboxList\",\n137: \t\tSandboxClaimGVR: \"SandboxClaimList\",\n138: \t})\n139: \n140: \tconfig := DefaultGCConfig()\n141: \tpolicy, _ := NewGCPolicy(config)\n142: \tmetrics := NewGCMetrics()\n143: \n144: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n145: \n146: \tctx := context.Background()\n147: \tresult, err := collector.Collect(ctx)\n148: \n149: \tassert.NoError(t, err)\n150: \tassert.NotNil(t, result)\n151: \tassert.Equal(t, 0, result.Scanned)\n152: \tassert.Equal(t, 0, result.Candidates)\n153: \tassert.Equal(t, 0, result.Deleted)\n154: \tassert.Equal(t, 0, result.Errors)\n155: }\n156: \n157: func TestGCCollector_Collect_ExpiredSandbox(t *testing.T) {\n158: \tmockStore := &mockStore{}\n159: \tscheme := runtime.NewScheme()\n160: \t\n161: \tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n162: \t\t&unstructured.Unstructured{},\n163: \t\t&unstructured.UnstructuredList{},\n164: \t)\n165: \t\n166: \tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n167: \t\tSandboxGVR: \"SandboxList\",\n168: \t\tSandboxClaimGVR: \"SandboxClaimList\",\n169: \t})\n170: \n171: \tsessionID := \"test-session\"\n172: \tsandboxInfo := &types.SandboxInfo{\n173: \t\tSessionID:        sessionID,\n174: \t\tSandboxID:        \"test-sandbox\",\n175: \t\tSandboxNamespace: \"default\",\n176: \t\tKind:             \"Sandbox\",\n177: \t\tLastActivityAt:   time.Now(),\n178: \t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n179: \t}\n180: \n181: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n182: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n183: \n184: \tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 24*time.Hour)\n185: \tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n186: \n187: \tconfig := &GCConfig{\n188: \t\tMaxAge:        1 * time.Hour,\n189: \t\tIdleTimeout:   15 * time.Minute,\n190: \t\tDryRun:        false,\n191: \t\tNamespaces:    []string{},\n192: \t\tLabelSelector: \"\",\n193: \t}\n194: \tpolicy, _ := NewGCPolicy(config)\n195: \tmetrics := NewGCMetrics()\n196: \n197: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n198: \n199: \tctx := context.Background()\n200: \tresult, err := collector.Collect(ctx)\n201: \n202: \tassert.NoError(t, err)\n203: \tassert.NotNil(t, result)\n204: \tassert.Equal(t, 1, result.Scanned)\n205: \tassert.Equal(t, 1, result.Candidates)\n206: \tassert.Equal(t, 1, result.Deleted)\n207: \tassert.Equal(t, 0, result.Errors)\n208: \n209: \tmockStore.AssertExpectations(t)\n210: }\n211: \n212: func TestGCCollector_Collect_IdleSandbox(t *testing.T) {\n213: \tmockStore := &mockStore{}\n214: \tscheme := runtime.NewScheme()\n215: \t\n216: \tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n217: \t\t&unstructured.Unstructured{},\n218: \t\t&unstructured.UnstructuredList{},\n219: \t)\n220: \t\n221: \tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n222: \t\tSandboxGVR: \"SandboxList\",\n223: \t\tSandboxClaimGVR: \"SandboxClaimList\",\n224: \t})\n225: \n226: \tsessionID := \"test-session\"\n227: \tsandboxInfo := &types.SandboxInfo{\n228: \t\tSessionID:        sessionID,\n229: \t\tSandboxID:        \"test-sandbox\",\n230: \t\tSandboxNamespace: \"default\",\n231: \t\tKind:             \"Sandbox\",\n232: \t\tLastActivityAt:   time.Now().Add(-30 * time.Minute),\n233: \t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n234: \t}\n235: \n236: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n237: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n238: \n239: \tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 10*time.Minute)\n240: \tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n241: \n242: \tconfig := &GCConfig{\n243: \t\tMaxAge:        1 * time.Hour,\n244: \t\tIdleTimeout:   15 * time.Minute,\n245: \t\tDryRun:        false,\n246: \t\tNamespaces:    []string{},\n247: \t\tLabelSelector: \"\",\n248: \t}\n249: \tpolicy, _ := NewGCPolicy(config)\n250: \tmetrics := NewGCMetrics()\n251: \n252: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n253: \n254: \tctx := context.Background()\n255: \tresult, err := collector.Collect(ctx)\n256: \n257: \tassert.NoError(t, err)\n258: \tassert.NotNil(t, result)\n259: \tassert.Equal(t, 1, result.Scanned)\n260: \tassert.Equal(t, 1, result.Candidates)\n261: \tassert.Equal(t, 1, result.Deleted)\n262: \tassert.Equal(t, 0, result.Errors)\n263: \n264: \tmockStore.AssertExpectations(t)\n265: }\n266: \n267: func TestGCCollector_Collect_DryRun(t *testing.T) {\n268: \tmockStore := &mockStore{}\n269: \tscheme := runtime.NewScheme()\n270: \t\n271: \tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n272: \t\t&unstructured.Unstructured{},\n273: \t\t&unstructured.UnstructuredList{},\n274: \t)\n275: \t\n276: \tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n277: \t\tSandboxGVR: \"SandboxList\",\n278: \t\tSandboxClaimGVR: \"SandboxClaimList\",\n279: \t})\n280: \n281: \tsessionID := \"test-session\"\n282: \tsandboxInfo := &types.SandboxInfo{\n283: \t\tSessionID:        sessionID,\n284: \t\tSandboxID:        \"test-sandbox\",\n285: \t\tSandboxNamespace: \"default\",\n286: \t\tKind:             \"Sandbox\",\n287: \t\tLastActivityAt:   time.Now(),\n288: \t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n289: \t}\n290: \n291: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n292: \n293: \tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 24*time.Hour)\n294: \tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n295: \n296: \tconfig := &GCConfig{\n297: \t\tMaxAge:        1 * time.Hour,\n298: \t\tIdleTimeout:   15 * time.Minute,\n299: \t\tDryRun:        true,\n300: \t\tNamespaces:    []string{},\n301: \t\tLabelSelector: \"\",\n302: \t}\n303: \tpolicy, _ := NewGCPolicy(config)\n304: \tmetrics := NewGCMetrics()\n305: \n306: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n307: \n308: \tctx := context.Background()\n309: \tresult, err := collector.Collect(ctx)\n310: \n311: \tassert.NoError(t, err)\n312: \tassert.NotNil(t, result)\n313: \tassert.Equal(t, 1, result.Scanned)\n314: \tassert.Equal(t, 1, result.Candidates)\n315: \tassert.Equal(t, 0, result.Deleted)\n316: \tassert.Equal(t, 0, result.Errors)\n317: \n318: \tmockStore.AssertNotCalled(t, \"DeleteSandboxBySessionID\")\n319: }\n320: \n321: func TestGCCollector_Collect_SessionNotFound(t *testing.T) {\n322: \tmockStore := &mockStore{}\n323: \tscheme := runtime.NewScheme()\n324: \t\n325: \tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n326: \t\t&unstructured.Unstructured{},\n327: \t\t&unstructured.UnstructuredList{},\n328: \t)\n329: \t\n330: \tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n331: \t\tSandboxGVR: \"SandboxList\",\n332: \t\tSandboxClaimGVR: \"SandboxClaimList\",\n333: \t})\n334: \n335: \tsessionID := \"test-session\"\n336: \n337: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(nil, store.ErrNotFound)\n338: \n339: \tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 24*time.Hour)\n340: \tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n341: \n342: \tconfig := &GCConfig{\n343: \t\tMaxAge:        1 * time.Hour,\n344: \t\tIdleTimeout:   15 * time.Minute,\n345: \t\tDryRun:        false,\n346: \t\tNamespaces:    []string{},\n347: \t\tLabelSelector: \"\",\n348: \t}\n349: \tpolicy, _ := NewGCPolicy(config)\n350: \tmetrics := NewGCMetrics()\n351: \n352: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n353: \n354: \tctx := context.Background()\n355: \tresult, err := collector.Collect(ctx)\n356: \n357: \tassert.NoError(t, err)\n358: \tassert.NotNil(t, result)\n359: \tassert.Equal(t, 1, result.Scanned)\n360: \tassert.Equal(t, 1, result.Candidates)\n361: \tassert.Equal(t, 1, result.Deleted)\n362: \tassert.Equal(t, 0, result.Errors)\n363: }\n364: \n365: func TestGCCollector_Delete_SandboxClaim(t *testing.T) {\n366: \tmockStore := &mockStore{}\n367: \tscheme := runtime.NewScheme()\n368: \t\n369: \tscheme.AddKnownTypes(schema.GroupVersion{Group: \"extensions.agents.x-k8s.io\", Version: \"v1alpha1\"}, \n370: \t\t&unstructured.Unstructured{},\n371: \t\t&unstructured.UnstructuredList{},\n372: \t)\n373: \t\n374: \tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n375: \t\tSandboxClaimGVR: \"SandboxClaimList\",\n376: \t})\n377: \n378: \tsessionID := \"test-session\"\n379: \n380: \tsandbox := &unstructured.Unstructured{\n381: \t\tObject: map[string]interface{}{\n382: \t\t\t\"apiVersion\": \"extensions.agents.x-k8s.io/v1alpha1\",\n383: \t\t\t\"kind\":       \"SandboxClaim\",\n384: \t\t\t\"metadata\": map[string]interface{}{\n385: \t\t\t\t\"name\":      \"test-claim\",\n386: \t\t\t\t\"namespace\": \"default\",\n387: \t\t\t\t\"labels\": map[string]interface{}{\n388: \t\t\t\t\tSessionIDLabelKey: sessionID,\n389: \t\t\t\t},\n390: \t\t\t},\n391: \t\t},\n392: \t}\n393: \n394: \tfakeClient.Resource(SandboxClaimGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n395: \n396: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n397: \n398: \tconfig := DefaultGCConfig()\n399: \tpolicy, _ := NewGCPolicy(config)\n400: \tmetrics := NewGCMetrics()\n401: \n402: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n403: \n404: \tctx := context.Background()\n405: \terr := collector.Delete(ctx, sandbox, wmTypes.CleanupReasonExpired)\n406: \n407: \tassert.NoError(t, err)\n408: \tmockStore.AssertExpectations(t)\n409: }\n410: \n411: func TestGCCollector_getGVRForKind(t *testing.T) {\n412: \tmockStore := &mockStore{}\n413: \tscheme := runtime.NewScheme()\n414: \tfakeClient := fake.NewSimpleDynamicClient(scheme)\n415: \n416: \tconfig := DefaultGCConfig()\n417: \tpolicy, _ := NewGCPolicy(config)\n418: \tmetrics := NewGCMetrics()\n419: \n420: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n421: \n422: \tassert.Equal(t, SandboxGVR, collector.getGVRForKind(\"Sandbox\"))\n423: \tassert.Equal(t, SandboxClaimGVR, collector.getGVRForKind(\"SandboxClaim\"))\n424: \tassert.Equal(t, SandboxGVR, collector.getGVRForKind(\"Unknown\"))\n425: }\n\n(End of file - total 425 lines)\n</content>","metadata":{"preview":"package gc\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/collector_test.go","time":{"start":1775892212184,"end":1775892212202}}}}
