is/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\ntype mockStore struct {\n\tmock.Mock\n}\n\nfunc (m *mockStore) Ping(ctx context.Context) error {\n\targs := m.Called(ctx)\n\treturn args.Error(0)\n}\n\nfunc (m *mockStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\targs := m.Called(ctx, sessionID)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*types.SandboxInfo), args.Error(1)\n}\n\nfunc (m *mockStore) StoreSandbox(ctx context.Context, info *types.SandboxInfo) error {\n\targs := m.Called(ctx, info)\n\treturn args.Error(0)\n}\n\nfunc (m *mockStore) UpdateSandbox(ctx context.Context, info *types.SandboxInfo) error {\n\targs := m.Called(ctx, info)\n\treturn args.Error(0)\n}\n\nfunc (m *mockStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\targs := m.Called(ctx, sessionID)\n\treturn args.Error(0)\n}\n\nfunc (m *mockStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n\targs := m.Called(ctx)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(map[string]*types.SandboxInfo), args.Error(1)\n}\n\nfunc (m *mockStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n\targs := m.Called(ctx, sessionID, at)\n\treturn args.Error(0)\n}\n\nfunc (m *mockStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\targs := m.Called(ctx, before, limit)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n}\n\nfunc (m *mockStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\targs := m.Called(ctx, before, limit)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n}\n\nfunc (m *mockStore) Close() error {\n\targs := m.Called()\n\treturn args.Error(0)\n}\n\nfunc buildTestSandbox(name, namespace, sessionID string, age time.Duration) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n\t\t\t\"kind\":       \"Sandbox\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":              name,\n\t\t\t\t\"namespace\":         namespace,\n\t\t\t\t\"creationTimestamp\": time.Now().Add(-age).Format(time.RFC3339),\n\t\t\t\t\"labels\": map[string]interface{}{\n\t\t\t\t\tSessionIDLabelKey: sessionID,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc TestNewGCCollector(t *testing.T) {\n\tmockStore := &mockStore{}\n\tscheme := runtime.NewScheme()\n\tfakeClient := fake.NewSimpleDynamicClient(scheme)\n\n\tconfig := DefaultGCConfig()\n\tpolicy, _ := NewGCPolicy(config)\n\tmetrics := NewGCMetrics()\n\n\tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n\n\tassert.NotNil(t, collector)\n\tassert.Equal(t, fakeClient, collector.dynamicClient)\n\tassert.Equal(t, mockStore, collector.storeClient)\n\tassert.Equal(t, config, collector.config)\n\tassert.Equal(t, policy, collector.policy)\n\tassert.Equal(t, metrics, collector.metrics)\n}\n\nfunc TestGCCollector_Collect_NoCandidates(t *testing.T) {\n\tmockStore := &mockStore{}\n\tscheme := runtime.NewScheme()\n\n\tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"},\n\t\t&unstructured.Unstructured{},\n\t\t&unstructured.UnstructuredList{},\n\t)\n\n\tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n\t\tSandboxGVR:      \"SandboxList\",\n\t\tSandboxClaimGVR: \"SandboxClaimList\",\n\t})\n\n\tconfig := DefaultGCConfig()\n\tpolicy, _ := NewGCPolicy(config)\n\tmetrics := NewGCMetrics()\n\n\tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n\n\tctx := context.Background()\n\tresult, err := collector.Collect(ctx)\n\n\tassert.NoError(t, err)\n\tassert.NotNil(t, result)\n\tassert.Equal(t, 0, result.Scanned)\n\tassert.Equal(t, 0, result.Candidates)\n\tassert.Equal(t, 0, result.Deleted)\n\tassert.Equal(t, 0, result.Errors)\n}\n\nfunc TestGCCollector_Collect_ExpiredSandbox(t *testing.T) {\n\tmockStore := &mockStore{}\n\tscheme := runtime.NewScheme()\n\n\tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"},\n\t\t&unstructured.Unstructured{},\n\t\t&unstructured.UnstructuredList{},\n\t)\n\n\tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n\t\tSandboxGVR:      \"SandboxList\",\n\t\tSandboxClaimGVR: \"SandboxClaimList\",\n\t})\n\n\tsessionID := \"test-session\"\n\tsandboxInfo := &types.SandboxInfo{\n\t\tSessionID:        sessionID,\n\t\tSandboxID:        \"test-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             \"Sandbox\",\n\t\tLastActivityAt:   time.Now(),\n\t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n\t}\n\n\tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n\tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n\n\tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 24*time.Hour)\n\tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n\n\tconfig := &GCConfig{\n\t\tMaxAge:        1 * time.Hour,\n\t\tIdleTimeout:   15 * time.Minute,\n\t\tDryRun:        false,\n\t\tNamespaces:    []string{},\n\t\tLabelSelector: \"\",\n\t}\n\tpolicy, _ := NewGCPolicy(config)\n\tmetrics := NewGCMetrics()\n\n\tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n\n\tctx := context.Background()\n\tresult, err := collector.Collect(ctx)\n\n\tassert.NoError(t, err)\n\tassert.NotNil(t, result)\n\tassert.Equal(t, 1, result.Scanned)\n\tassert.Equal(t, 1, result.Candidates)\n\tassert.Equal(t, 1, result.Deleted)\n\tassert.Equal(t, 0, result.Errors)\n\n\tmockStore.AssertExpectations(t)\n}\n\nfunc TestGCCollector_Collect_IdleSandbox(t *testing.T) {\n\tmockStore := &mockStore{}\n\tscheme := runtime.NewScheme()\n\n\tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"},\n\t\t&unstructured.Unstructured{},\n\t\t&unstructured.UnstructuredList{},\n\t)\n\n\tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n\t\tSandboxGVR:      \"SandboxList\",\n\t\tSandboxClaimGVR: \"SandboxClaimList\",\n\t})\n\n\tsessionID := \"test-session\"\n\tsandboxInfo := &types.SandboxInfo{\n\t\tSessionID:        sessionID,\n\t\tSandboxID:        \"test-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             \"Sandbox\",\n\t\tLastActivityAt:   time.Now().Add(-30 * time.Minute),\n\t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n\t}\n\n\tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n\tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n\n\tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 10*time.Minute)\n\tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n\n\tconfig := &GCConfig{\n\t\tMaxAge:        1 * time.Hour,\n\t\tIdleTimeout:   15 * time.Minute,\n\t\tDryRun:        false,\n\t\tNamespaces:    []string{},\n\t\tLabelSelector: \"\",\n\t}\n\tpolicy, _ := NewGCPolicy(config)\n\tmetrics := NewGCMetrics()\n\n\tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n\n\tctx := context.Background()\n\tresult, err := collector.Collect(ctx)\n\n\tassert.NoError(t, err)\n\tassert.NotNil(t, result)\n\tassert.Equal(t, 1, result.Scanned)\n\tassert.Equal(t, 1, result.Candidates)\n\tassert.Equal(t, 1, result.Deleted)\n\tassert.Equal(t, 0, result.Errors)\n\n\tmockStore.AssertExpectations(t)\n}\n\nfunc TestGCCollector_Collect_DryRun(t *testing.T) {\n\tmockStore := &mockStore{}\n\tscheme := runtime.NewScheme()\n\n\tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"},\n\t\t&unstructured.Unstructured{},\n\t\t&unstructured.UnstructuredList{},\n\t)\n\n\tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n\t\tSandboxGVR:      \"SandboxList\",\n\t\tSandboxClaimGVR: \"SandboxClaimList\",\n\t})\n\n\tsessionID := \"test-session\"\n\tsandboxInfo := &types.SandboxInfo{\n\t\tSessionID:        sessionID,\n\t\tSandboxID:        \"test-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             \"Sandbox\",\n\t\tLastActivityAt:   time.Now(),\n\t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n\t}\n\n\tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n\n\tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 24*time.Hour)\n\tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n\n\tconfig := &GCConfig{\n\t\tMaxAge:        1 * time.Hour,\n\t\tIdleTimeout:   15 * time.Minute,\n\t\tDryRun:        true,\n\t\tNamespaces:    []string{},\n\t\tLabelSelector: \"\",\n\t}\n\tpolicy, _ := NewGCPolicy(config)\n\tmetrics := NewGCMetrics()\n\n\tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n\n\tctx := context.Background()\n\tresult, err := collector.Collect(ctx)\n\n\tassert.NoError(t, err)\n\tassert.NotNil(t, result)\n\tassert.Equal(t, 1, result.Scanned)\n\tassert.Equal(t, 1, result.Candidates)\n\tassert.Equal(t, 0, result.Deleted)\n\tassert.Equal(t, 0, result.Errors)\n\n\tmockStore.AssertNotCalled(t, \"DeleteSandboxBySessionID\")\n}\n\nfunc TestGCCollector_Collect_SessionNotFound(t *testing.T) {\n\tmockStore := &mockStore{}\n\tscheme := runtime.NewScheme()\n\n\tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"},\n\t\t&unstructured.Unstructured{},\n\t\t&unstructured.UnstructuredList{},\n\t)\n\n\tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n\t\tSandboxGVR:      \"SandboxList\",\n\t\tSandboxClaimGVR: \"SandboxClaimList\",\n\t})\n\n\tsessionID := \"test-session\"\n\n\tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(nil, store.ErrNotFound)\n\n\tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 24*time.Hour)\n\tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n\n\tconfig := &GCConfig{\n\t\tMaxAge:        1 * time.Hour,\n\t\tIdleTimeout:   15 * time.Minute,\n\t\tDryRun:        false,\n\t\tNamespaces:    []string{},\n\t\tLabelSelector: \"\",\n\t}\n\tpolicy, _ := NewGCPolicy(config)\n\tmetrics := NewGCMetrics()\n\n\tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n\n\tctx := context.Background()\n\tresult, err := collector.Collect(ctx)\n\n\tassert.NoError(t, err)\n\tassert.NotNil(t, result)\n\tassert.Equal(t, 1, result.Scanned)\n\tassert.Equal(t, 1, result.Candidates)\n\tassert.Equal(t, 1, result.Deleted)\n\tassert.Equal(t, 0, result.Errors)\n}\n\nfunc TestGCCollector_Delete_SandboxClaim(t *testing.T) {\n\tmockStore := &mockStore{}\n\tscheme := runtime.NewScheme()\n\n\tscheme.AddKnownTypes(schema.GroupVersion{Group: \"extensions.agents.x-k8s.io\", Version: \"v1alpha1\"},\n\t\t&unstructured.Unstructured{},\n\t\t&unstructured.UnstructuredList{},\n\t)\n\n\tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n\t\tSandboxClaimGVR: \"SandboxClaimList\",\n\t})\n\n\tsessionID := \"test-session\"\n\n\tsandbox := &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"extensions.agents.x-k8s.io/v1alpha1\",\n\t\t\t\"kind\":       \"SandboxClaim\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      \"test-claim\",\n\t\t\t\t\"namespace\": \"default\",\n\t\t\t\t\"labels\": map[string]interface{}{\n\t\t\t\t\tSessionIDLabelKey: sessionID,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfakeClient.Resource(SandboxClaimGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n\n\tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n\n\tconfig := DefaultGCConfig()\n\tpolicy, _ := NewGCPolicy(config)\n\tmetrics := NewGCMetrics()\n\n\tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n\n\tctx := context.Background()\n\terr := collector.Delete(ctx, sandbox, wmTypes.CleanupReasonExpired)\n\n\tassert.NoError(t, err)\n\tmockStore.AssertExpectations(t)\n}\n\nfunc TestGCCollector_getGVRForKind(t *testing.T) {\n\tmockStore := &mockStore{}\n\tscheme := runtime.NewScheme()\n\tfakeClient := fake.NewSimpleDynamicClient(scheme)\n\n\tconfig := DefaultGCConfig()\n\tpolicy, _ := NewGCPolicy(config)\n\tmetrics := NewGCMetrics()\n\n\tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n\n\tassert.Equal(t, SandboxGVR, collector.getGVRForKind(\"Sandbox\"))\n\tassert.Equal(t, SandboxClaimGVR, collector.getGVRForKind(\"SandboxClaim\"))\n\tassert.Equal(t, SandboxGVR, collector.getGVRForKind(\"Unknown\"))\n}\n","after":"package gc\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg