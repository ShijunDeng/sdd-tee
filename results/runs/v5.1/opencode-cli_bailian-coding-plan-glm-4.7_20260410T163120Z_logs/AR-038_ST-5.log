structured\")).Return(\"10.244.1.5\", nil)\n169: \n170: \t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n171: \n172: \t\trequire.NoError(t, err)\n173: \t\trequire.NotNil(t, resp)\n174: \t\tassert.NotEmpty(t, resp.SessionID)\n175: \t\tassert.NotEmpty(t, resp.SandboxID)\n176: \t\tassert.NotEmpty(t, resp.SandboxName)\n177: \t\tassert.Contains(t, resp.SandboxName, \"test-runtime-\")\n178: \t\tassert.NotEmpty(t, resp.EntryPoints)\n179: \t\tassert.Len(t, resp.EntryPoints, 1)\n180: \t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n181: \t\tassert.Equal(t, \"10.244.1.5:8080\", resp.EntryPoints[0].Endpoint)\n182: \t\tassert.NotEmpty(t, resp.CreatedAt)\n183: \t\tassert.NotEmpty(t, resp.ExpiresAt)\n184: \n185: \t\tmockK8s.AssertExpectations(t)\n186: \n187: \t\tsandboxInfo, err := redisStore.GetSandbox(ctx, resp.SessionID)\n188: \t\trequire.NoError(t, err)\n189: \t\tassert.Equal(t, resp.SessionID, sandboxInfo.SessionID)\n190: \t\tassert.Equal(t, \"running\", sandboxInfo.Status)\n191: \t\tassert.Equal(t, \"10.244.1.5\", sandboxInfo.PodIP)\n192: \t})\n193: \n194: \tt.Run(\"agent runtime not found\", func(t *testing.T) {\n195: \t\tmockK8s := new(MockK8sClient)\n196: \t\tcontroller := NewSandboxController(mockK8s, redisStore)\n197: \n198: \t\treq := &api.CreateSandboxRequest{\n199: \t\t\tName:      \"nonexistent\",\n200: \t\t\tNamespace: \"default\",\n201: \t\t}\n202: \n203: \t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"agentruntimes\"), \"nonexistent\")\n204: \t\tmockK8s.On(\"GetAgentRuntime\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n205: \n206: \t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n207: \n208: \t\trequire.Error(t, err)\n209: \t\tassert.Nil(t, resp)\n210: \t\tassert.Contains(t, err.Error(), \"not found\")\n211: \n212: \t\tmockK8s.AssertExpectations(t)\n213: \t})\n214: \n215: \tt.Run(\"failed to create sandbox\", func(t *testing.T) {\n216: \t\tmockK8s := new(MockK8sClient)\n217: \t\tcontroller :