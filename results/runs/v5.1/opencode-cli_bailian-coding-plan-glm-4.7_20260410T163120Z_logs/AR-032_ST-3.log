260:     timeoutSeconds: 5\n261:     failureThreshold: 3\n262:   readinessProbe:\n263:     httpGet:\n264:       path: /readyz\n265:       port: 8080\n266:     initialDelaySeconds: 10\n267:     periodSeconds: 5\n268:     timeoutSeconds: 3\n269:     failureThreshold: 3\n270:   autoscaling:\n271:     enabled: false\n272:     minReplicas: 2\n273:     maxReplicas: 10\n274:     targetCPUUtilizationPercentage: 75\n275:     targetMemoryUtilizationPercentage: 80\n276:   podDisruptionBudget:\n277:     enabled: true\n278:     minAvailable: 1\n279:   env: []\n280:   envFrom: []\n281:   extraVolumeMounts: []\n282:   extraVolumes: []\n283:   serviceAccount:\n284:     create: true\n285:     name: \"\"\n286:     annotations: {}\n287:   rbac:\n288:     create: true\n289:     rules: []\n290: \n291: # Router configuration\n292: router:\n293:   enabled: true\n294:   replicaCount: 3\n295:   image:\n296:     repository: agentcube/router\n297:     tag: v1.0.0\n298:     pullPolicy: IfNotPresent\n299:   service:\n300:     type: ClusterIP\n301:     port: 8080\n302:     targetPort: 8080\n303:     annotations: {}\n304:     loadBalancerSourceRanges: []\n305:   ingress:\n306:     enabled: false\n307:     className: nginx\n308:     annotations: {}\n309:     hosts:\n310:       - host: agentcube.example.com\n311:         paths:\n312:           - path: /\n313:             pathType: Prefix\n314:     tls:\n315:       - secretName: agentcube-tls\n316:         hosts:\n317:           - agentcube.example.com\n318:   resources:\n319:     requests:\n320:       cpu: 150m\n321:       memory: 192Mi\n322:     limits:\n323:       cpu: 750m\n324:       memory: 768Mi\n325:   nodeSelector: {}\n326:   tolerations: []\n327:   affinity:\n328:     podAntiAffinity:\n329:       requiredDuringSchedulingIgnoredDuringExecution:\n330:       - labelSelector:\n331:           matchLabels:\n332:             app.kubernetes.io/component: router\n333:         topologyKey: kubernetes.io/hostname\n334:   podAnnotations: {}\n335:   podLabels: {}\n336:   securityContext:\n337:     runAsNonRoot: true\n338:     runAsUser: 1000\n339:     fsGroup: 1000\n340:   containerSecurityContext:\n341:     allowPrivilegeEscalation: false\n342:     capabilities:\n343:       drop:\n344:         - ALL\n345:     readOnlyRootFilesystem: true\n346:   livenessProbe:\n347:     httpGet:\n348:       path: /healthz\n349:       port: 8080\n350:     initialDelaySeconds: 30\n351:     periodSeconds: 10\n352:     timeoutSeconds: 5\n353:     failureThreshold: 3\n354:   readinessProbe:\n355:     httpGet:\n356:       path: /readyz\n357:       port: 8080\n358:     initialDelaySeconds: 10\n359:     periodSeconds: 5\n360:     timeoutSeconds: 3\n361:     failureThreshold: 3\n362:   autoscaling:\n363:     enabled: false\n364:     minReplicas: 3\n365:     maxReplicas: 10\n366:     targetCPUUtilizationPercentage: 70\n367:     targetMemoryUtilizationPercentage: 75\n368:   podDisruptionBudget:\n369:     enabled: true\n370:     minAvailable: 2\n371:   env: []\n372:   envFrom: []\n373:   extraVolumeMounts: []\n374:   extraVolumes: []\n375:   serviceAccount:\n376:     create: true\n377:     name: \"\"\n378:     annotations: {}\n379:   rbac:\n380:     create: true\n381:     rules: []\n382: \n383: # Global RBAC configuration\n384: rbac:\n385:   create: true\n386:   clusterRole:\n387:     create: true\n388:     rules:\n389:     - apiGroups:\n390:       - runtime.agentcube.volcano.sh\n391:       resources:\n392:       - agentruntimes\n393:       - codeinterpreters\n394:       verbs:\n395:       - get\n396:       - list\n397:       - watch\n398:       - create\n399:       - update\n400:       - patch\n401:       - delete\n402:     - apiGroups:\n403:       - runtime.agentcube.volcano.sh\n404:       resources:\n405:       - agentruntimes/status\n406:       - codeinterpreters/status\n407:       verbs:\n408:       - get\n409:       - update\n410:       - patch\n411:     - apiGroups:\n412:       - \"\"\n413:       resources:\n414:       - pods\n415:  