\treturn nil, fmt.Errorf(\"AgentRuntime %s/%s not found\", req.Namespace, req.Name)\n39: \t\t}\n40: \t\treturn nil, fmt.Errorf(\"failed to get AgentRuntime: %w\", err)\n41: \t}\n42: \n43: \tspec, found, err := unstructured.NestedMap(agentRuntime.Object, \"spec\")\n44: \tif err != nil {\n45: \t\treturn nil, fmt.Errorf(\"failed to get spec: %w\", err)\n46: \t}\n47: \tif !found {\n48: \t\treturn nil, fmt.Errorf(\"spec not found\")\n49: \t}\n50: \n51: \tsessionID := uuid.New().String()\n52: \tsandboxName := generateSandboxName(req.Name)\n53: \n54: \tsandboxCR, err := sc.buildAgentRuntimeSandboxCR(agentRuntime, sessionID, sandboxName, req.Name, req.Namespace)\n55: \tif err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to build sandbox CR: %w\", err)\n57: \t}\n58: \n59: \tsandboxInfo := &types.SandboxInfo{\n60: \t\tSessionID:    sessionID,\n61: \t\tSandboxName:  sandboxName,\n62: \t\tWorkloadName: req.Name,\n63: \t\tNamespace:    req.Namespace,\n64: \t\tKind:         \"AgentRuntime\",\n65: \t\tStatus:       \"pending\",\n66: \t\tCreatedAt:    time.Now(),\n67: \t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n68: \t}\n69: \n70: \tif err := sc.store.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n71: \t\treturn nil, fmt.Errorf(\"failed to store sandbox: %w\", err)\n72: \t}\n73: \n74: \tcreatedCR, err := sc.k8sClient.CreateSandbox(ctx, req.Namespace, sandboxCR)\n75: \tif err != nil {\n76: \t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n77: \t\treturn nil, fmt.Errorf(\"failed to create sandbox: %w\", err)\n78: \t}\n79: \n80: \tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\n81: \tdefer cancel()\n82: \n83: \tvar podIP string\n84: \tfor i := 0; i < 60; i++ {\n85: \t\tpodIP, err = sc.k8sClient.GetPodIP(ctx, sandboxName, req.Namespace, createdCR)\n86: \t\tif err == nil {\n87: \t\t\tbreak\n88: \t\t}\n89: \t\tselect {\n90: \t\tcase <-ctx.Done():\n91: \t\t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n92: \t\t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n93: \t\t\treturn nil, fmt.Errorf(\"sandbox creation timed out\")\n94: \t\tcase <-time.After(2 * time.Second):\n95: \t\t\tcontinue\n96: \t\t}\n97: \t}\n98: \n99: \tports, _, err := unstructured.NestedSlice(spec, \"ports\")\n100: \tif err != nil {\n101: \t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n102: \t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n103: \t\treturn nil, fmt.Errorf(\"failed to get ports: %w\", err)\n104: \t}\n105: \n106: \tentryPoints := sc.buildEntryPoints(podIP, ports)\n107: \n108: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n109: \tsandboxInfo.PodIP = podIP\n110: \tsandboxInfo.EntryPoints = convertEntryPoints(entryPoints)\n111: \tsandboxInfo.Status = \"running\"\n112: \n113: \tif err := sc.store.UpdateSandbox(ctx, sessionID, sandboxInfo); err != nil {\n114: \t\treturn nil, fmt.Errorf(\"failed to update sandbox: %w\", err)\n115: \t}\n116: \n117: \treturn &api.CreateSandboxResponse{\n118: \t\tSessionID:   sessionID,\n119: \t\tSandboxID:   sandboxInfo.SandboxID,\n120: \t\tSandboxName: sandboxName,\n121: \t\tEntryPoints: entryPoints,\n122: \t\tCreatedAt:   sandboxInfo.CreatedAt.Format(time.RFC3339),\n123: \t\tExpiresAt:   sandboxInfo.ExpiresAt.Format(time.RFC3339),\n124: \t}, nil\n125: }\n126: \n127: func (sc *SandboxController) CreateCodeInterpreterSandbox(ctx context.Context, req *api.CreateSandboxRequest) (*api.CreateSandboxResponse, error) {\n128: \tcodeInterpreter, err := sc.k8sClient.GetCodeInterpreter(ctx, req.Namespace, req.Name)\n129: \tif err != nil {\n130: \t\tif apierrors.IsNotFound(err) {\n131: \t\t\treturn nil, fmt.Errorf(\"CodeInterpreter %s/%s not found\", req.Namespace, req.Name)\n132: \t\t}\n133: \t\treturn nil, fmt.Errorf(\"failed to get CodeInterpreter: %w\", err)\n134: \t}\n135: \n136: \tspec, found, err := unstructured.NestedMap(codeInterpreter.Object, \"spec\")\n137: \tif err != nil {\n138: \t\treturn nil, fmt.Errorf(\"failed to get spec: %w\", err)\n139: \t}\n140: \tif !found {\n141: \t\treturn nil, fmt.Errorf(\"spec not found\")\n142: \t}\n143: \n144: \tsessionID := uuid.New().String()\n145: \tsandboxName := generateSandboxName(req.Name)\n146: \n147: \tports, _, _ := unstructured.NestedSlice(spec, \"ports\")\n148: \tif len(ports) == 0 {\n149: \t\tports = []interface{}{\n150: \t\t\tmap[string]interface{}{\n151: \t\t\t\t\"port\":     int64(8080),\n152: \t\t\t\t\"protocol\": \"HTTP\",\n153: \t\t\t},\n154: \t\t}\n155: \t}\n156: \n157: \tsandboxCR, err := sc.buildCodeInterpreterSandboxCR(codeInterpreter, sessionID, sandboxName, req.Name, req.Namespace, ports)\n158: \tif err != nil {\n159: \t\treturn nil, fmt.Errorf(\"failed to build sandbox CR: %w\", err)\n160: \t}\n161: \n162: \tsandboxInfo := &types.SandboxInfo{\n163: \t\tSessionID:    sessionID,\n164: \t\tSandboxName:  sandboxName,\n165: \t\tWorkloadName: req.Name,\n166: \t\tNamespace:    req.Namespace,\n167: \t\tKind:         \"CodeInterpreter\",\n168: \t\tStatus:       \"pending\",\n169: \t\tCreatedAt:    time.Now(),\n170: \t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n171: \t}\n172: \n173: \tif err := sc.store.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n174: \t\treturn nil, fmt.Errorf(\"failed to store sandbox: %w\", err)\n175: \t}\n176: \n177: \tcreatedCR, err := sc.k8sClient.CreateSandbox(ctx, req.Namespace, sandboxCR)\n178: \tif err != nil {\n179: \t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n180: \t\treturn nil, fmt.Errorf(\"failed to create sandbox: %w\", err)\n181: \t}\n182: \n183: \tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\n184: \tdefer cancel()\n185: \n186: \tvar podIP string\n187: \tfor i := 0; i < 60; i++ {\n188: \t\tpodIP, err = sc.k8sClient.GetPodIP(ctx, sandboxName, req.Namespace, createdCR)\n189: \t\tif err == nil {\n190: \t\t\tbreak\n191: \t\t}\n192: \t\tselect {\n193: \t\tcase <-ctx.Done():\n194: \t\t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n195: \t\t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n196: \t\t\treturn nil, fmt.Errorf(\"sandbox creation timed out\")\n197: \t\tcase <-time.After(2 * time.Second):\n198: \t\t\tcontinue\n199: \t\t}\n200: \t}\n201: \n202: \tentryPoints := sc.buildEntryPoints(podIP, ports)\n203: \n204: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n205: \tsandboxInfo.PodIP = podIP\n206: \tsandboxInfo.EntryPoints = convertEntryPoints(entryPoints)\n207: \tsandboxInfo.Status = \"running\"\n208: \n209: \tif err := sc.store.UpdateSandbox(ctx, sessionID, sandboxInfo); err != nil {\n210: \t\treturn nil, fmt.Errorf(\"failed to update sandbox: %w\", err)\n211: \t}\n212: \n213: \treturn &api.CreateSandboxResponse{\n214: \t\tSessionID:   sessionID,\n215: \t\tSandboxID:   sandboxInfo.SandboxID,\n216: \t\tSandboxName: sandboxName,\n217: \t\tEntryPoints: entryPoints,\n218: \t\tCreatedAt:   sandboxInfo.CreatedAt.Format(time.RFC3339),\n219: \t\tExpiresAt:   sandboxInfo.ExpiresAt.Format(time.RFC3339),\n220: \t}, nil\n221: }\n222: \n223: func (sc *SandboxController) GetSession(ctx context.Context, sessionID string) (*api.GetSessionResponse, error) {\n224: \tsandboxInfo, err := sc.store.GetSandbox(ctx, sessionID)\n225: \tif err != nil {\n226: \t\tif err == store.ErrNotFound {\n227: \t\t\treturn nil, fmt.Errorf(\"session not found\")\n228: \t\t}\n229: \t\treturn nil, fmt.Errorf(\"failed to get session: %w\", err)\n230: \t}\n231: \n232: \treturn &api.GetSessionResponse{\n233: \t\tSessionID:    sandboxInfo.SessionID,\n234: \t\tSandboxID:    sandboxInfo.SandboxID,\n235: \t\tSandboxName:  sandboxInfo.SandboxName,\n236: \t\tKind:         sandboxInfo.Kind,\n237: \t\tNamespace:    sandboxInfo.Namespace,\n238: \t\tName:         sandboxInfo.WorkloadName,\n239: \t\tEntryPoints:  convertToAPIEntryPoints(sandboxInfo.EntryPoints),\n240: \t\tLastActivity: sandboxInfo.LastActivityAt.Format(time.RFC3339),\n241: \t\tCreatedAt:    sandboxInfo.CreatedAt.Format(time.RFC3339),\n242: \t\tExpiresAt:    sandboxInfo.ExpiresAt.Format(time.RFC3339),\n243: \t\tPodIP:        sandboxInfo.PodIP,\n244: \t}, nil\n245: }\n246: \n247: func (sc *SandboxController) DeleteSession(ctx context.Context, sessionID string) (*api.DeleteSessionResponse, error) {\n248: \tsandboxInfo, err := sc.store.GetSandbox(ctx, sessionID)\n249: \tif err != nil {\n250: \t\tif err == store.ErrNotFound {\n251: \t\t\treturn nil, fmt.Errorf(\"session not found\")\n252: \t\t}\n253: \t\treturn nil, fmt.Errorf(\"failed to get session: %w\", err)\n254: \t}\n255: \n256: \tif err := sc.k8sClient.DeleteSandbox(ctx, sandboxInfo.Namespace, sandboxInfo.SandboxName); err != nil && !apierrors.IsNotFound(err) {\n257: \t\treturn nil, fmt.Errorf(\"failed to delete sandbox: %w\", err)\n258: \t}\n259: \n260: \tif err := sc.store.DeleteSandboxBySessionID(ctx, sessionID); err != nil {\n261: \t\treturn nil, fmt.Errorf(\"failed to delete session: %w\", err)\n262: \t}\n263: \n264: \treturn &api.DeleteSessionResponse{\n265: \t\tSessionID: sessionID,\n266: \t\tDeletedAt: time.Now().Format(time.RFC3339),\n267: \t}, nil\n268: }\n269: \n270: func (sc *SandboxController) buildAgentRuntimeSandboxCR(agentRuntime *unstructured.Unstructured, sessionID, sandboxName, workloadName, namespace string) (*unstructured.Unstructured, error) {\n271: \tcr := &unstructured.Unstructured{}\n272: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n273: \tcr.SetKind(\"Sandbox\")\n274: \tcr.SetName(sandboxName)\n275: \tcr.SetNamespace(namespace)\n276: \n277: \tcr.SetLabels(map[string]string{\n278: \t\tconstants.LabelManagedBy:    constants.LabelManagedByValue,\n279: \t\tconstants.LabelSessionID:    sessionID,\n280: \t\tconstants.LabelWorkloadName: workloadName,\n281: \t\tconstants.LabelSandboxName:  sandboxName,\n282: \t})\n283: \n284: \tcr.SetAnnotations(map[string]string{\n285: \t\tconstants.AnnotationIdleTimeout: \"15m\",\n286: \t})\n287: \n288: \tshutdownTime := time.Now().Add(8 * time.Hour)\n289: \n290: \tspec := map[string]interface{}{\n291: \t\t\"replicas\": int64(1),\n292: \t\t\"lifecycle\": map[string]interface{}{\n293: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n294: \t\t},\n295: \t}\n296: \n297: \tspecMap, found, err := unstructured.NestedMap(agentRuntime.Object, \"spec\", \"podTemplate\")\n298: \tif err != nil {\n299: \t\treturn nil, err\n300: \t}\n301: \tif found {\n302: \t\tspec[\"podTemplate\"] = specMap\n303: \t}\n304: \n305: \tports, _, _ := unstructured.NestedSlice(agentRuntime.Object, \"spec\", \"ports\")\n306: \tif len(ports) > 0 {\n307: \t\tspec[\"ports\"] = ports\n308: \t}\n309: \n310: \tcr.Object[\"spec\"] = spec\n311: \n312: \treturn cr, nil\n313: }\n314: \n315: func (sc *SandboxController) buildCodeInterpreterSandboxCR(codeInterpreter *unstructured.Unstructured, sessionID, sandboxName, workloadName, namespace string, ports []interface{}) (*unstructured.Unstructured, error) {\n316: \tcr := &unstructured.Unstructured{}\n317: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n318: \tcr.SetKind(\"Sandbox\")\n319: \tcr.SetName(sandboxName)\n320: \tcr.SetNamespace(namespace)\n321: \n322: \tcr.SetLabels(map[string]string{\n323: \t\tconstants.LabelManagedBy:    constants.LabelManagedByValue,\n324: \t\tconstants.LabelSessionID:    sessionID,\n325: \t\tconstants.LabelWorkloadName: workloadName,\n326: \t\tconstants.LabelSandboxName:  sandboxName,\n327: \t})\n328: \n329: \tcr.SetAnnotations(map[string]string{\n330: \t\tconstants.AnnotationIdleTimeout: \"15m\",\n331: \t})\n332: \n333: \tshutdownTime := time.Now().Add(8 * time.Hour)\n334: \n335: \tspec := map[string]interface{}{\n336: \t\t\"replicas\": int64(1),\n337: \t\t\"lifecycle\": map[string]interface{}{\n338: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n339: \t\t},\n340: \t}\n341: \n342: \tif len(ports) > 0 {\n343: \t\tspec[\"ports\"] = ports\n344: \t}\n345: \n346: \timage, _, _ := unstructured.NestedString(codeInterpreter.Object, \"spec\", \"template\", \"image\")\n347: \tif image == \"\" {\n348: \t\timage = \"python:3.11-slim\"\n349: \t}\n350: \n351: \tcontainer := corev1.Container{\n352: \t\tName:  \"code-interpreter\",\n353: \t\tImage: image,\n354: \t}\n355: \n356: \tpodSpec := corev1.PodSpec{\n357: \t\tContainers: []corev1.Container{container},\n358: \t}\n359: \n360: \tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n361: \tif err != nil {\n362: \t\treturn nil, fmt.Errorf(\"failed to convert pod spec: %w\", err)\n363: \t}\n364: \n365: \tspec[\"podTemplate\"] = podSpecMap\n366: \n367: \tcr.Object[\"spec\"] = spec\n368: \n369: \treturn cr, nil\n370: }\n371: \n372: func (sc *SandboxController) buildEntryPoints(podIP string, ports []interface{}) []api.EntryPoint {\n373: \tvar entryPoints []api.EntryPoint\n374: \tfor _, p := range ports {\n375: \t\tportMap, ok := p.(map[string]interface{})\n376: \t\tif !ok {\n377: \t\t\tcontinue\n378: \t\t}\n379: \n380: \t\tprotocol, _, _ := unstructured.NestedString(portMap, \"protocol\")\n381: \t\tport, _, _ := unstructured.NestedInt64(portMap, \"port\")\n382: \t\tpath, _, _ := unstructured.NestedString(portMap, \"pathPrefix\")\n383: \n384: \t\tentryPoints = append(entryPoints, api.EntryPoint{\n385: \t\t\tProtocol: protocol,\n386: \t\t\tEndpoint: fmt.Sprintf(\"%s:%d\", podIP, port),\n387: \t\t\tPath:     path,\n388: \t\t\tPort:     int32(port),\n389: \t\t})\n390: \t}\n391: \treturn entryPoints\n392: }\n393: \n394: func convertEntryPoints(entryPoints []api.EntryPoint) []types.SandboxEntryPoint {\n395: \tvar result []types.SandboxEntryPoint\n396: \tfor _, ep := range entryPoints {\n397: \t\tresult = append(result, types.SandboxEntryPoint{\n398: \t\t\tProtocol: ep.Protocol,\n399: \t\t\tEndpoint: ep.Endpoint,\n400: \t\t\tPath:     ep.Path,\n401: \t\t})\n402: \t}\n403: \treturn result\n404: }\n405: \n406: func convertToAPIEntryPoints(entryPoints []types.SandboxEntryPoint) []api.EntryPoint {\n407: \tvar result []api.EntryPoint\n408: \tfor _, ep := range entryPoints {\n409: \t\tresult = append(result, api.EntryPoint{\n410: \t\t\tProtocol: ep.Protocol,\n411: \t\t\tEndpoint: ep.Endpoint,\n412: \t\t\tPath:     ep.Path,\n413: \t\t})\n414: \t}\n415: \treturn result\n416: }\n417: \n418: func generateSandboxName(workloadName string) string {\n419: \treturn fmt.Sprintf(\"%s-%s\", workloadName, RandString(8))\n420: }\n421: \n422: func RandString(n int) string {\n423: \tconst charset = \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\"\n424: \tb := make([]byte, n)\n425: \tfor i := range b {\n426: \t\tb[i] = charset[rand.Intn(len(charset))]\n427: \t}\n428: \treturn string(b)\n429: }\n\n(End of file - total 429 lines)\n</content>","metadata":{"preview":"package controller\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"math/rand\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/api\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/client\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox.go","time":{"start":1775843237131,"end":1775843237145}}}}
