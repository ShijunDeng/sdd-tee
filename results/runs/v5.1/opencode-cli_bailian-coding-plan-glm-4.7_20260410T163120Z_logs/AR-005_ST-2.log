 \tEntryPoints  []EntryPoint `json:\"entryPoints\"`\n37: \tLastActivity string       `json:\"lastActivity\"`\n38: \tCreatedAt    string       `json:\"createdAt\"`\n39: \tExpiresAt    string       `json:\"expiresAt\"`\n40: \tPodIP        string       `json:\"podIp,omitempty\"`\n41: }\n42: \n43: type DeleteSessionRequest struct {\n44: \tSessionID string `uri:\"sessionId\" binding:\"required\"`\n45: }\n46: \n47: type DeleteSessionResponse struct {\n48: \tSessionID string `json:\"sessionId\"`\n49: \tDeletedAt string `json:\"deletedAt\"`\n50: }\n\n(End of file - total 50 lines)\n</content>","metadata":{"preview":"package api\n\ntype CreateSandboxRequest struct {\n\tKind      string `json:\"kind\" binding:\"required\"`\n\tName      string `json:\"name\" binding:\"required\"`\n\tNamespace string `json:\"namespace\" binding:\"required\"`\n}\n\ntype CreateSandboxResponse struct {\n\tSessionID   string       `json:\"sessionId\"`\n\tSandboxID   string       `json:\"sandboxId\"`\n\tSandboxName string       `json:\"sandboxName\"`\n\tEntryPoints []EntryPoint `json:\"entryPoints\"`\n\tCreatedAt   string       `json:\"createdAt\"`\n\tExpiresAt   string       `json:\"expiresAt\"`\n}\n\ntype EntryPoint struct {\n\tProtocol string `json:\"protocol\"`\n\tEndpoint string `json:\"endpoint\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/api/types.go","time":{"start":1775843245303,"end":1775843245312}}}}
{"type":"tool_use","timestamp":1775843245316,"sessionID":"ses_2877ecc48ffeLfo6bU8734TLmk","part":{"id":"prt_d78817cde001Aein6526muFTEE","messageID":"msg_d78815d660018kDEnempbnvL3P","sessionID":"ses_2877ecc48ffeLfo6bU8734TLmk","type":"tool","tool":"read","callID":"toolu_tool-5d346454947a483893708b0195d510a9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go</path>\n<type>file</type>\n<content>\n1: package client\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"time\"\n7: \n8: \tcorev1 \"k8s.io/api/core/v1\"\n9: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n12: \t\"k8s.io/apimachinery/pkg/labels\"\n13: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n14: \t\"k8s.io/client-go/dynamic\"\n15: \t\"k8s.io/client-go/kubernetes\"\n16: \t\"k8s.io/client-go/rest\"\n17: \t\"k8s.io/klog/v2\"\n18: \n19: \t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n20: )\n21: \n22: type K8sClient struct {\n23: \tclientset  kubernetes.Interface\n24: \tdynamic    dynamic.Interface\n25: \tconfig     *rest.Config\n26: \tgvrSandbox schema.GroupVersionResource\n27: \tgvrAgent   schema.GroupVersionResource\n28: \tgvrCode    schema.GroupVersionResource\n29: }\n30: \n31: func NewK8sClient(config *rest.Config) (*K8sClient, error) {\n32: \tclientset, err := kubernetes.NewForConfig(config)\n33: \tif err != nil {\n34: \t\treturn nil, fmt.Errorf(\"failed to create kubernetes clientset: %w\", err)\n35: \t}\n36: \n37: \tdynamicClient, err := dynamic.NewForConfig(config)\n38: \tif err != nil {\n39: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n40: \t}\n41: \n42: \treturn &K8sClient{\n43: \t\tclientset: clientset,\n44: \t\tdynamic:   dynamicClient,\n45: \t\tconfig:    config,\n46: \t\tgvrSandbox: schema.GroupVersionResource{\n47: \t\t\tGroup:    \"agents.x-k8s.io\",\n48: \t\t\tVersion:  \"v1alpha1\",\n49: \t\t\tResource: \"sandboxes\",\n50: \t\t},\n51: \t\tgvrAgent: schema.GroupVersionResource{\n52: \t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n53: \t\t\tVersion:  \"v1alpha1\",\n54: \t\t\tResource: \"agentruntimes\",\n55: \t\t},\n56: \t\tgvrCode: schema.GroupVersionResource{\n57: \t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n58: \t\t\tVersion:  \"v1alpha1\",\n59: \t\t\tResource: \"codeinterpreters\",\n60: \t\t},\n61: \t}, nil\n62: }\n63: \n64: func (c *K8sClient) GetAgentRuntime(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n65: \treturn c.dynamic.Resource(c.gvrAgent).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n66: }\n67: \n68: func (c *K8sClient) GetCodeInterpreter(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n69: \treturn c.dynamic.Resource(c.gvrCode).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n70: }\n71: \n72: func (c *K8sClient) CreateSandbox(ctx context.Context, namespace string, sandbox *unstructured.Unstructured) (*unstructured.Unstructured, error) {\n73: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Create(ctx, sandbox, metav1.CreateOptions{})\n74: }\n75: \n76: func (c *K8sClient) GetSandbox(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n77: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n78: }\n79: \n80: func (c *K8sClient) DeleteSandbox(ctx context.Context, namespace, name string) error {\n81: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Delete(ctx, name, metav1.DeleteOptions{})\n82: }\n83: \n84: func (c *K8sClient) GetPodIP(ctx context.Context, sandboxName, namespace string, sandbox *unstructured.Unstructured) (string, error) {\n85: \tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n86: \tif err == nil && pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n87: \t\treturn pod.Status.PodIP, nil\n88: \t}\n89: \n90: \tannotations := sandbox.GetAnnotations()\n91: \tconst podNameAnnotation = \"agents.x-k8s.io/sandbox-pod-name\"\n92: \tif podName, ok := annotations[podNameAnnotation]; ok && podName != \"\" {\n93: \t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, podName, metav1.GetOptions{})\n94: \t\tif err == nil {\n95: \t\t\tif pod.Status.Phase != corev1.PodRunning {\n96: \t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n97: \t\t\t}\n98: \t\t\tif pod.Status.PodIP == \"\" {\n99: \t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n100: \t\t\t}\n101: \t\t\treturn pod.Status.PodIP, nil\n102: \t\t}\n103: \t}\n104: \n105: \tpods, err := c.clientset.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n106: \t\tLabelSelector: labels.SelectorFromSet(labels.Set{\n107: \t\t\tconstants.LabelSandboxName: sandboxName,\n108: \t\t}).String(),\n109: \t})\n110: \tif err != nil {\n111: \t\treturn \"\", fmt.Errorf(\"failed to list pods: %w\", err)\n112: \t}\n113: \n114: \tfor _, p := range pods.Items {\n115: \t\tfor _, ownerRef := range p.OwnerReferences {\n116: \t\t\tif ownerRef.Kind == \"Sandbox\" && ownerRef.Name == sandboxName {\n117: \t\t\t\tif p.Status.Phase != corev1.PodRunning {\n118: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n119: \t\t\t\t}\n120: \t\t\t\tif p.Status.PodIP == \"\" {\n121: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n122: \t\t\t\t}\n123: \t\t\t\treturn p.Status.PodIP, nil\n124: \t\t\t}\n125: \t\t}\n126: \t}\n127: \n128: \treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n129: }\n130: \n131: func (c *K8sClient) WatchPods(ctx context.Context, namespace string, sandboxName string) (<-chan string, error) {\n132: \tpodCh := make(chan string, 1)\n133: \n134: \tgo func() {\n135: \t\tdefer close(podCh)\n136: \n137: \t\tticker := time.NewTicker(2 * time.Second)\n138: \t\tdefer ticker.Stop()\n139: \n140: \t\tfor {\n141: \t\t\tselect {\n142: \t\t\tcase <-ctx.Done():\n143: \t\t\t\treturn\n144: \t\t\tcase <-ticker.C:\n145: \t\t\t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n146: \t\t\t\tif err != nil {\n147: \t\t\t\t\tif apierrors.IsNotFound(err) {\n148: \t\t\t\t\t\tcontinue\n149: \t\t\t\t\t}\n150: \t\t\t\t\tklog.Errorf(\"Failed to get pod: %v\", err)\n151: \t\t\t\t\tcontinue\n152: \t\t\t\t}\n153: \n154: \t\t\t\tif pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n155: \t\t\t\t\tselect {\n156: \t\t\t\t\tcase podCh <- pod.Status.PodIP:\n157: \t\t\t\t\tdefault:\n158: \t\t\t\t\t}\n159: \t\t\t\t\treturn\n160: \t\t\t\t}\n161: \t\t\t}\n162: \t\t}\n163: \t}()\n164: \n165: \treturn podCh, nil\n166: }\n167: \n168: func (c *K8sClient) GetSecret(ctx context.Context, namespace, name string) (*corev1.Secret, error) {\n169: \treturn c.clientset.CoreV1().Secrets(namespace).Get(ctx, name, metav1.GetOptions{})\n170: }\n\n(End of file - total 170 lines)\n</content>","metadata":{"preview":"package client\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go","time":{"start":1775843245305,"end":1775843245314}}}}
