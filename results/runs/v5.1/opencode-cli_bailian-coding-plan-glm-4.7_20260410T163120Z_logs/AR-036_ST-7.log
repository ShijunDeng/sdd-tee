ter_url(self, provider):\n34:         credentials = {\n35:             \"router_url\": \"\",\n36:             \"workload_manager_url\": \"http://localhost:8081\",\n37:         }\n38:         with pytest.raises(ToolProviderCredentialValidationError):\n39:             provider._validate_credentials(credentials)\n40: \n41:     def test_empty_workload_manager_url(self, provider):\n42:         credentials = {\n43:             \"router_url\": \"http://localhost:8080\",\n44:             \"workload_manager_url\": \"\",\n45:         }\n46:         with pytest.raises(ToolProviderCredentialValidationError):\n47:             provider._validate_credentials(credentials)\n48: \n49:     def test_whitespace_router_url(self, provider):\n50:         credentials = {\n51:             \"router_url\": \"   \",\n52:             \"workload_manager_url\": \"http://localhost:8081\",\n53:         }\n54:         with pytest.raises(ToolProviderCredentialValidationError):\n55:             provider._validate_credentials(credentials)\n56: \n57:     def test_none_router_url(self, provider):\n58:         credentials = {\n59:             \"router_url\": None,\n60:             \"workload_manager_url\": \"http://localhost:8081\",\n61:         }\n62:         with pytest.raises(ToolProviderCredentialValidationError):\n63:             provider._validate_credentials(credentials)\n64: \n65:     def test_none_workload_manager_url(self, provider):\n66:         credentials = {\n67:             \"router_url\": \"http://localhost:8080\",\n68:             \"workload_manager_url\": None,\n69:         }\n70:         with pytest.raises(ToolProviderCredentialValidationError):\n71:             provider._validate_credentials(credentials)\n72: \n73:     def test_extra_parameters_ignored(self, provider):\n74:         credentials = {\n75:             \"router_url\": \"http://localhost:8080\",\n76:             \"workload_manager_url\": \"http://localhost:8081\",\n77:             \"extra_param\": \"value\",\n78:         }\n7