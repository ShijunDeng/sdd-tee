    zh_Hans: 要重用的现有会话 ID\n108:     llm_description:\n109:       en_US: An existing session ID to reuse\n110:       zh_Hans: 要重用的现有会话 ID\n111:     form: llm\n112: \n113:   - name: session_reuse\n114:     type: boolean\n115:     required: false\n116:     label:\n117:       en_US: Session Reuse\n118:       zh_Hans: 会话重用\n119:     human_description:\n120:       en_US: Whether to reuse the session\n121:       zh_Hans: 是否重用会话\n122:     llm_description:\n123:       en_US: If true, the session will be kept alive for reuse\n124:       zh_Hans: 如果为 true，会话将被保持以供重用\n125:     form: llm\n126: \n127:   - name: code_interpreter_id\n128:     type: string\n129:     required: false\n130:     label:\n131:       en_US: Code Interpreter ID\n132:       zh_Hans: 代码解释器 ID\n133:     human_description:\n134:       en_US: The ID of the code interpreter instance\n135:       zh_Hans: 代码解释器实例的 ID\n136:     llm_description:\n137:       en_US: The custom resource name/ID of the code interpreter instance\n138:       zh_Hans: 代码解释器实例的自定义资源名称/ID\n139:     form: llm\n140: \n141: extra:\n142:   python:\n143:     source: tools/agentcube-code-interpreter.py\n\n(End of file - total 143 lines)\n</content>","metadata":{"preview":"identity:\n  name: agentcube-code-interpreter\n  author: agentcube\n  label:\n    en_US: Agentcube Code Interpreter\n    zh_Hans: Agentcube 代码解释器\n  description:\n    human:\n      en_US: Execute code and manage files in secure AgentCube sandboxes\n      zh_Hans: 在安全的 AgentCube 沙箱中执行代码和管理文件\n    llm:\n      en_US: A tool for executing code and managing files in secure AgentCube sandboxes\n      zh_Hans: 用于在安全的 AgentCube 沙箱中执行代码和管理文件的工具\n\nparameters:\n  - name: router_url\n    type: string\n    required: true\n    label:\n      en_US: Router URL","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/integrations/dify-plugin/tools/agentcube-code-interpreter.yaml","time":{"start":1775889688882,"end":1775889688902}}}}
