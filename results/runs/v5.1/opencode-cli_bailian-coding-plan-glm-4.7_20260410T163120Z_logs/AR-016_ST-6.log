/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\nfunc (s *Server) ExecuteHandler(c *gin.Context) {\n\tvar req ExecuteRequest\n\tif err := c.ShouldBindJSON(&req); err != nil {\n\t\tHandleError(c, NewError(ErrInvalidCommand, \"invalid request body\", err.Error(), err))\n\t\treturn\n\t}\n\n\tif len(req.Command) == 0 {\n\t\tHandleError(c, NewError(ErrEmptyCommand, ErrMsgEmptyCommand, \"\", nil))\n\t\treturn\n\t}\n\n\ttimeout := DefaultTimeout\n\tif req.Timeout != \"\" {\n\t\tparsedTimeout, err := time.ParseDuration(req.Timeout)\n\t\tif err != nil {\n\t\t\tHandleError(c, NewError(ErrInvalidTimeout, \"invalid timeout format\", err.Error(), err))\n\t\t\treturn\n\t\t}\n\t\ttimeout = parsedTimeout\n\t}\n\n\tworkingDir := s.workspaceDir\n\tif req.WorkingDir != \"\" {\n\t\tsanitizedDir, err := s.sanitizePath(req.WorkingDir)\n\t\tif err != nil {\n\t\t\tHandleError(c, err)\n\t\t\treturn\n\t\t}\n\t\tworkingDir = sanitizedDir\n\t}\n","exit":0,"description":"Check handlers.go file size and content","truncated":false},"title":"Check handlers.go file size and content","time":{"start":1775860406386,"end":1775860406415}}}}
