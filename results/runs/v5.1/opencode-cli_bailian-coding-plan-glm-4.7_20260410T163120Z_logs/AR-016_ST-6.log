24: **Step 3: Write minimal implementation**\n725: \n726: ```go\n727: // pkg/picod/handlers.go\n728: func (s *Server) ListFilesHandler(c *gin.Context) {\n729: \tpath := c.Query(\"path\")\n730: \tif path == \"\" {\n731: \t\tHandleError(c, NewError(ErrMissingPath, ErrMsgMissingPathParam, \"\", nil))\n732: \t\treturn\n733: \t}\n734: \n735: \tsanitizedPath, err := s.sanitizePath(path)\n736: \tif err != nil {\n737: \t\tHandleError(c, err)\n738: \t\treturn\n739: \t}\n740: \n741: \trecursive := c.Query(\"recursive\") == \"true\"\n742: \n743: \tvar files []FileEntry\n744: \n745: \tif recursive {\n746: \t\terr = filepath.Walk(sanitizedPath, func(filePath string, info os.FileInfo, err error) error {\n747: \t\t\tif err != nil {\n748: \t\t\t\treturn err\n749: \t\t\t}\n750: \n751: \t\t\trelPath, err := filepath.Rel(sanitizedPath, filePath)\n752: \t\t\tif err != nil {\n753: \t\t\t\treturn err\n754: \t\t\t}\n755: \n756: \t\t\t// Skip the root directory itself\n757: \t\t\tif relPath == \".\" {\n758: \t\t\t\treturn nil\n759: \t\t\t}\n760: \n761: \t\t\tfiles = append(files, FileEntry{\n762: \t\t\t\tName:     relPath,\n763: \t\t\t\tSize:     info.Size(),\n764: \t\t\t\tModified: info.ModTime(),\n765: \t\t\t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n766: \t\t\t\tIsDir:    info.IsDir(),\n767: \t\t\t})\n768: \n769: \t\t\treturn nil\n770: \t\t})\n771: \n772: \t\tif err != nil {\n773: \t\t\tif os.IsNotExist(err) {\n774: \t\t\t\tHandleError(c, NewError(ErrDirectoryNotFound, ErrMsgDirectoryNotFound, \"\", err))\n775: \t\t\t} else {\n776: \t\t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to walk directory\", err.Error(), err))\n777: \t\t\t}\n778: \t\t\treturn\n779: \t\t}\n780: \t} else {\n781: \t\tentries, err := os.ReadDir(sanitizedPath)\n782: \t\tif err != nil {\n783: \t\t\tif os.IsNotExist(err) {\n784: \t\t\t\tHandleError(c, NewError(ErrDirectoryNotFound, ErrMsgDirectoryNotFound, \"\", err))\n785: \t\t\t} else {\n786: \t\t\t\tHandleError(c, NewError(ErrServerInternal,