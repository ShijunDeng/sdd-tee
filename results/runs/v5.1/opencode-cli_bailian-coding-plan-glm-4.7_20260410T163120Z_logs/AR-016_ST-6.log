ck.writeLockCount > 0 || lock.readLockCount > 0 {\n1011: \t\tselect {\n1012: \t\tcase <-timeout:\n1013: \t\t\treturn false\n1014: \t\tdefault:\n1015: \t\t\tlock.writeCond.Wait()\n1016: \t\t}\n1017: \t}\n1018: \n1019: \tlock.writeLockCount++\n1020: \treturn true\n1021: }\n1022: \n1023: func (fm *FileLockManager) ReleaseWriteLock(path string) {\n1024: \tabsPath := filepath.Clean(path)\n1025: \n1026: \tfm.mu.RLock()\n1027: \tlock, exists := fm.locks[absPath]\n1028: \tfm.mu.RUnlock()\n1029: \n1030: \tif !exists {\n1031: \t\treturn\n1032: \t}\n1033: \n1034: \tlock.mu.Lock()\n1035: \tlock.writeLockCount--\n1036: \tif lock.writeLockCount == 0 {\n1037: \t\tlock.writeCond.Broadcast()\n1038: \t\tlock.readCond.Broadcast()\n1039: \t}\n1040: \tlock.mu.Unlock()\n1041: \n1042: \tfm.cleanupLock(absPath)\n1043: }\n1044: \n1045: func (fm *FileLockManager) AcquireReadLock(path string) bool {\n1046: \tabsPath := filepath.Clean(path)\n1047: \tlock := fm.getLock(absPath)\n1048: \n1049: \tlock.mu.Lock()\n1050: \tdefer lock.mu.Unlock()\n1051: \n1052: \ttimeout := time.After(FileLockTimeout)\n1053: \n1054: \tfor lock.writeLockCount > 0 {\n1055: \t\tselect {\n1056: \t\tcase <-timeout:\n1057: \t\t\treturn false\n1058: \t\tdefault:\n1059: \t\t\tlock.readCond.Wait()\n1060: \t\t}\n1061: \t}\n1062: \n1063: \tlock.readLockCount++\n1064: \treturn true\n1065: }\n1066: \n1067: func (fm *FileLockManager) ReleaseReadLock(path string) {\n1068: \tabsPath := filepath.Clean(path)\n1069: \n1070: \tfm.mu.RLock()\n1071: \tlock, exists := fm.locks[absPath]\n1072: \tfm.mu.RUnlock()\n1073: \n1074: \tif !exists {\n1075: \t\treturn\n1076: \t}\n1077: \n1078: \tlock.mu.Lock()\n1079: \tlock.readLockCount--\n1080: \tif lock.readLockCount == 0 {\n1081: \t\tlock.writeCond.Broadcast()\n1082: \t}\n1083: \tlock.mu.Unlock()\n1084: \n1085: \tfm.cleanupLock(absPath)\n1086: }\n1087: ```\n1088: \n1089: **Step 4: Integrate locks into handlers**\n1090: \n1091: ```go\n1092: // pkg/picod/server.go\n1093: type Server struct {\n1094: \tengine       *gin.Engine\n1095: \tconfig       Config\n1096: \tauthManager  *AuthManager\n1097: \tstartTime    time.Time\n1098: \tworkspaceDir string\n1099: \thttpServer   *http.Server\n1100: \tlockManager  *FileLockManager // Add this field\n1101: }\n1102: \n1103: func NewServer(config Config) (*Server, error) {\n1104: \t// ... existing code ...\n1105: \n1106: \tserver := &Server{\n1107: \t\tengine:       engine,\n1108: \t\tconfig:       config,\n1109: \t\tauthManager:  authManager,\n1110: \t\tstartTime:    time.Now(),\n1111: \t\tworkspaceDir: absWorkspace,\n1112: \t\tlockManager:  NewFileLockManager(), // Initialize lock manager\n1113: \t}\n1114: \n1115: \t// ... rest of existing code ...\n1116: }\n1117: ```\n1118: \n1119: **Step 5: Apply locks in upload and delete handlers**\n1120: \n1121: ```go\n1122: // pkg/picod/handlers.go\n1123: func (s *Server) UploadFileHandler(c *gin.Context) {\n1124: \t// ... existing validation code ...\n1125: \n1126: \tsanitizedPath, err := s.sanitizePath(path)\n1127: \tif err != nil {\n1128: \t\tHandleError(c, err)\n1129: \t\treturn\n1130: \t}\n1131: \n1132: \t// Acquire write lock\n1133: \tif !s.lockManager.AcquireWriteLock(sanitizedPath) {\n1134: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n1135: \t\treturn\n1136: \t}\n1137: \tdefer s.lockManager.ReleaseWriteLock(sanitizedPath)\n1138: \n1139: \t// ... rest of handler code ...\n1140: }\n1141: \n1142: func (s *Server) DeleteFileHandler(c *gin.Context) {\n1143: \t// ... existing validation code ...\n1144: \n1145: \tsanitizedPath, err := s.sanitizePath(path)\n1146: \tif err != nil {\n1147: \t\tHandleError(c, err)\n1148: \t\treturn\n1149: \t}\n1150: \n1151: \t// Acquire write lock\n1152: \tif !s.lockManager.AcquireWriteLock(sanitizedPath) {\n1153: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n1154: \t\treturn\n1155: \t}\n1156: \tdefer s.lockManager.ReleaseWriteLock(sa