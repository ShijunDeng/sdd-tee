ponse{\n234: \t\tFiles: files,\n235: \t}\n236: \n237: \tc.JSON(http.StatusOK, response)\n238: }\n239: \n240: func (s *Server) DownloadFileHandler(c *gin.Context) {\n241: \tpath := c.Param(\"path\")\n242: \tif path == \"\" {\n243: \t\tHandleError(c, NewError(ErrMissingPath, ErrMsgMissingPathParam, \"\", nil))\n244: \t\treturn\n245: \t}\n246: \n247: \tpath = strings.TrimPrefix(path, \"/\")\n248: \n249: \tsanitizedPath, err := s.sanitizePath(path)\n250: \tif err != nil {\n251: \t\tHandleError(c, err)\n252: \t\treturn\n253: \t}\n254: \n255: \tinfo, err := os.Stat(sanitizedPath)\n256: \tif err != nil {\n257: \t\tif os.IsNotExist(err) {\n258: \t\t\tHandleError(c, NewError(ErrFileNotFound, ErrMsgFileNotFound, \"\", err))\n259: \t\t} else {\n260: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to get file info\", err.Error(), err))\n261: \t\t}\n262: \t\treturn\n263: \t}\n264: \n265: \tif info.IsDir() {\n266: \t\tHandleError(c, NewError(ErrPathIsDirectory, ErrMsgPathIsDirectory, \"\", nil))\n267: \t\treturn\n268: \t}\n269: \n270: \tcontent, err := os.ReadFile(sanitizedPath)\n271: \tif err != nil {\n272: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to read file\", err.Error(), err))\n273: \t\treturn\n274: \t}\n275: \n276: \tc.Header(HeaderContentDescription, \"File Transfer\")\n277: \tc.Header(HeaderContentEncoding, \"binary\")\n278: \tc.Header(HeaderContentDisposition, fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filepath.Base(sanitizedPath)))\n279: \n280: \tmimeType := mime.TypeByExtension(filepath.Ext(sanitizedPath))\n281: \tif mimeType == \"\" {\n282: \t\tmimeType = MIMEOctetStream\n283: \t}\n284: \tc.Header(HeaderContentType, mimeType)\n285: \n286: \tc.Data(http.StatusOK, mimeType, content)\n287: }\n288: \n289: func (s *Server) HealthCheckHandler(c *gin.Context) {\n290: \tuptime := time.Since(s.startTime)\n291: \n292: \tc.JSON(http.StatusOK, gin.H{\n293: \t\t\"status\":  \"ok\",\n294: \t\t\"service\": ServiceName,\n295: \t\t\"version\": Version,\