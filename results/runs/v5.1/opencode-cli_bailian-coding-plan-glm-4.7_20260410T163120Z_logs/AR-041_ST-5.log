Expect(created.Namespace).To(Equal(f.Namespace()))\n\t\t})\n\n\t\tIt(\"should apply default values\", func() {\n\t\t\tci := &runtimev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"test-defaults\",\n\t\t\t\t\tNamespace: f.Namespace(),\n\t\t\t\t},\n\t\t\t\tSpec: runtimev1alpha1.CodeInterpreterSpec{\n\t\t\t\t\tImage: \"python:3.11-slim\",\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tcreated, err := helper.CreateCodeInterpreter(ctx, ci)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tExpect(created.Spec.Runtime).To(Equal(\"python\"))\n\t\t\tExpect(created.Spec.Timeout).NotTo(BeNil())\n\t\t\tExpect(created.Spec.Timeout.Duration).To(Equal(5 * time.Minute))\n\t\t})\n\n\t\tIt(\"should become ready\", func() {\n\t\t\tci := framework.NewTestCodeInterpreter(\"test-ready\")\n\t\t\tci.Namespace = f.Namespace()\n\n\t\t\t_, err := helper.CreateCodeInterpreter(ctx, ci)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = helper.WaitForCodeInterpreterReady(ctx, ci.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tfetched, err := helper.GetCodeInterpreter(ctx, ci.Name)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(fetched.Status.Ready).To(BeTrue())\n\t\t})\n\t})\n\n\tContext(\"Code Execution\", func() {\n\t\tvar (\n\t\t\tci        *runtimev1alpha1.CodeInterpreter\n\t\t\tsessionID string\n\t\t)\n\n\t\tBeforeEach(func() {\n\t\t\tci = framework.NewTestPythonCodeInterpreter(\"test-execution\")\n\t\t\tci.Namespace = f.Namespace()\n\n\t\t\tvar err error\n\t\t\tci, err = helper.CreateCodeInterpreter(ctx, ci)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = helper.WaitForCodeInterpreterReady(ctx, ci.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\treq := framework.NewTestSessionRequest(\"CodeInterpreter\", ci.Name, f.Namespace())\n\t\t\tresp, err := helper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tsessionID = resp.SessionID\n\t\t})\n\n\t\tIt(\"should execute Python code successfully\", func() {\n\t\t\tresp, err := helper.ExecuteCode(ctx, sessionID, `print(\"hello\")`, \"\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(resp).NotTo(BeNil())\n\t\t\tExpect(resp.ExitCode).To(Equal(0))\n\t\t\tExpect(resp.Stdout).To(ContainSubstring(\"hello\"))\n\t\t})\n\n\t\tIt(\"should handle syntax errors\", func() {\n\t\t\tresp, err := helper.ExecuteCode(ctx, sessionID, `print(\"hello`, \"\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(resp).NotTo(BeNil())\n\t\t\tExpect(resp.ExitCode).NotTo(Equal(0))\n\t\t\tExpect(resp.Stderr).NotTo(BeEmpty())\n\t\t})\n\n\t\tIt(\"should handle runtime errors\", func() {\n\t\t\tresp, err := helper.ExecuteCode(ctx, sessionID, `1/0`, \"\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(resp).NotTo(BeNil())\n\t\t\tExpect(resp.ExitCode).NotTo(Equal(0))\n\t\t\tExpect(resp.Stderr).NotTo(BeEmpty())\n\t\t})\n\n\t\tIt(\"should preserve state between executions\", func() {\n\t\t\t_, err := helper.ExecuteCode(ctx, sessionID, `x = 42`, \"\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tresp, err := helper.ExecuteCode(ctx, sessionID, `print(x)`, \"\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(resp.ExitCode).To(Equal(0))\n\t\t\tExpect(resp.Stdout).To(ContainSubstring(\"42\"))\n\t\t})\n\t})\n\n\tContext(\"File Operations\", func() {\n\t\tvar (\n\t\t\tci        *runtimev1alpha1.CodeInterpreter\n\t\t\tsessionID string\n\t\t)\n\n\t\tBeforeEach(func() {\n\t\t\tci = framework.NewTestPythonCodeInterpreter(\"test-file-ops\")\n\t\t\tci.Namespace = f.Namespace()\n\n\t\t\tvar err error\n\t\t\tci, err = helper.CreateCodeInterpreter(ctx, ci)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = helper.WaitForCodeInterpreterReady(ctx, ci.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\treq := framework.NewTestSessionRequest(\"CodeInterpreter\", ci.Name, f.Namespace())\n\t\t\tresp, err := helper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tsessionID = resp.SessionID\n\t\t})\n\n\t\tIt(\"should upload file successfully\", func() {\n\t\t\tcontent := []byte(\"test content\")\n\t\t\terr := helper.UploadFile(ctx, sessionID, \"test.txt\", content, \"base64\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t})\n\n\t\tIt(\"should download file successfully\", func() {\n\t\t\tcontent := []byte(\"test content\")\n\t\t\terr := helper.UploadFile(ctx, sessionID, \"test.txt\", content, \"base64\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tdownloaded, err := helper.DownloadFile(ctx, sessionID, \"test.txt\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(downloaded).To(Equal(content))\n\t\t})\n\n\t\tIt(\"should handle large files\", func() {\n\t\t\tlargeContent := make([]byte, 10*1024*1024)\n\t\t\tfor i := range largeContent {\n\t\t\t\tlargeContent[i] = byte(i % 256)\n\t\t\t}\n\n\t\t\terr := helper.UploadFile(ctx, sessionID, \"large.bin\", largeContent, \"base64\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tdownloaded, err := helper.DownloadFile(ctx, sessionID, \"large.bin\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(len(downloaded)).To(Equal(len(largeContent)))\n\t\t})\n\t})\n\n\tContext(\"CodeInterpreter Error Handling\", func() {\n\t\tIt(\"should reject invalid spec\", func() {\n\t\t\tci := &runtimev1alpha1.CodeInterpreter{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"test-invalid-spec\",\n\t\t\t\t\tNamespace: f.Namespace(),\n\t\t\t\t},\n\t\t\t\tSpec: runtimev1alpha1.CodeInterpreterSpec{},\n\t\t\t}\n\n\t\t\t_, err := helper.CreateCodeInterpreter(ctx, ci)\n\t\t\tExpect(err).To(HaveOccurred())\n\t\t})\n\n\t\tIt(\"should reject non-existent session invocation\", func() {\n\t\t\t_, err := helper.ExecuteCode(ctx, \"non-existent-session\", `print(\"test\")`, \"\")\n\t\t\tExpect(err).To(HaveOccurred())\n\t\t})\n\n\t\tIt(\"should handle malformed code\", func() {\n\t\t\tci := framework.NewTestPythonCodeInterpreter(\"test-malformed\")\n\t\t\tci.Namespace = f.Namespace()\n\n\t\t\t_, er