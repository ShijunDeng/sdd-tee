{"type":"tool_use","timestamp":1775896921615,"sessionID":"ses_284500342ffe3Yogb7xdZXscIa","part":{"id":"prt_d7bb480d9001g54HZc8b1NdiMR","messageID":"msg_d7bb417e4001K6iVuPu9T6GjSw","sessionID":"ses_284500342ffe3Yogb7xdZXscIa","type":"tool","tool":"write","callID":"toolu_tool-e5c7002e579b43198df53e3dfb98c2de","state":{"status":"completed","input":{"content":"package e2e\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\n\t\"github.com/volcano-sh/agentcube/test/e2e/framework\"\n)\n\nvar _ = Describe(\"AgentRuntime E2E\", func() {\n\tvar (\n\t\tf       *framework.TestFramework\n\t\thelper  *framework.AgentRuntimeHelper\n\t\tctx     context.Context\n\t\tcancel  context.CancelFunc\n\t)\n\n\tBeforeSuite(func() {\n\t\tf = framework.NewDefaultFramework(\"agentruntime-e2e\")\n\t\tctx, cancel = context.WithTimeout(context.Background(), 15*time.Minute)\n\t\tdefer cancel()\n\n\t\tExpect(f.Setup(ctx)).To(Succeed())\n\t\tEventually(func() bool {\n\t\t\treturn f.AgentCubeReady()\n\t\t}, 10*time.Minute, 10*time.Second).Should(BeTrue())\n\n\t\thelper = framework.NewAgentRuntimeHelper(f)\n\t})\n\n\tAfterSuite(func() {\n\t\tif f != nil && !f.Options().SkipCleanup {\n\t\t\tExpect(f.Cleanup()).To(Succeed())\n\t\t}\n\t})\n\n\tBeforeEach(func() {\n\t\tctx, cancel = context.WithTimeout(context.Background(), 5*time.Minute)\n\t})\n\n\tAfterEach(func() {\n\t\tcancel()\n\t})\n\n\tContext(\"AgentRuntime Creation\", func() {\n\t\tIt(\"should create AgentRuntime successfully\", func() {\n\t\t\tart := framework.NewTestAgentRuntime(\"test-creation\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\tcreated, err := helper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(created).NotTo(BeNil())\n\t\t\tExpect(created.Name).To(Equal(art.Name))\n\t\t\tExpect(created.Namespace).To(Equal(f.Namespace()))\n\t\t})\n\n\t\tIt(\"should apply default values\", func() {\n\t\t\tart := &runtimev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"test-defaults\",\n\t\t\t\t\tNamespace: f.Namespace(),\n\t\t\t\t},\n\t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n\t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n\t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n\t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\t\t\t\t\tImage: \"nginx:latest\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tcreated, err := helper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tExpect(created.Spec.SessionTimeout).NotTo(BeNil())\n\t\t\tExpect(created.Spec.SessionTimeout.Duration).To(Equal(15 * time.Minute))\n\t\t\tExpect(created.Spec.MaxSessionDuration).NotTo(BeNil())\n\t\t\tExpect(created.Spec.MaxSessionDuration.Duration).To(Equal(8 * time.Hour))\n\t\t})\n\n\t\tIt(\"should become ready\", func() {\n\t\t\tart := framework.NewTestAgentRuntime(\"test-ready\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\t_, err := helper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tfetched, err := helper.GetAgentRuntime(ctx, art.Name)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tfor _, condition := range fetched.Status.Conditions {\n\t\t\t\tif condition.Type == \"Ready\" {\n\t\t\t\t\tExpect(condition.Status).To(Equal(metav1.ConditionTrue))\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t})\n\n\tContext(\"AgentRuntime Invocation\", func() {\n\t\tvar (\n\t\t\tart       *runtimev1alpha1.AgentRuntime\n\t\t\tsessionID string\n\t\t)\n\n\t\tBeforeEach(func() {\n\t\t\tart = framework.NewTestAgentRuntime(\"test-invocation\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\tvar err error\n\t\t\tart, err = helper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t})\n\n\t\tIt(\"should create session successfully\", func() {\n\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\n\t\t\tresp, err := helper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(resp).NotTo(BeNil())\n\t\t\tExpect(resp.SessionID).NotTo(BeEmpty())\n\t\t\tExpect(resp.SandboxID).NotTo(BeEmpty())\n\n\t\t\tsessionID = resp.SessionID\n\t\t})\n\n\t\tIt(\"should invoke session successfully\", func() {\n\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\tresp, err := helper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tsessionID = resp.SessionID\n\n\t\t\tpayload := framework.NewTestInvokePayloadWithString(\"hello\")\n\t\t\tinvokeResp, err := helper.InvokeSession(ctx, sessionID, payload, nil)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(invokeResp).NotTo(BeNil())\n\t\t\tExpect(invokeResp.StatusCode).To(Equal(200))\n\t\t})\n\n\t\tIt(\"should handle concurrent invocations\", func() {\n\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\tresp, err := helper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tsessionID = resp.SessionID\n\n\t\t\terrors := make(chan error, 10)\n\t\t\tfor i := 0; i < 10; i++ {\n\t\t\t\tgo func(id int) {\n\t\t\t\t\tpayload := framework.NewTestInvokePayloadWithID(id)\n\t\t\t\t\t_, err := helper.InvokeSession(ctx, sessionID, payload, nil)\n\t\t\t\t\terrors <- err\n\t\t\t\t}(i)\n\t\t\t}\n\n\t\t\tfor i := 0; i < 10; i++ {\n\t\t\t\terr := <-errors\n\t\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t}\n\t\t})\n\t})\n\n\tContext(\"AgentRuntime Lifecycle\", func() {\n\t\tIt(\"should handle session expiration\", func() {\n\t\t\tart := framework.NewTestAgentRuntimeWithShortTimeout(\"test-expiration\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\t_, err := helper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\tresp, err := helper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tsessionID := resp.SessionID\n\n\t\t\ttime.Sleep(35 * time.Second)\n\n\t\t\t_, err = helper.InvokeSession(ctx, sessionID, []byte(\"{}\"), nil)\n\t\t\tExpect(err).To(HaveOccurred())\n\t\t})\n\n\t\tIt(\"should delete session successfully\", func() {\n\t\t\tart := framework.NewTestAgentRuntime(\"test-deletion\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\t_, err := helper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\tresp, err := helper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tsessionID := resp.SessionID\n\n\t\t\terr = helper.DeleteSession(ctx, sessionID)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\t_, err = helper.InvokeSession(ctx, sessionID, []byte(\"{}\"), nil)\n\t\t\tExpect(err).To(HaveOccurred())\n\t\t})\n\t})\n\n\tContext(\"AgentRuntime Error Handling\", func() {\n\t\tIt(\"should reject invalid spec\", func() {\n\t\t\tart := &runtimev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"test-invalid-spec\",\n\t\t\t\t\tNamespace: f.Namespace(),\n\t\t\t\t},\n\t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n\t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n\t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n\t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\n\t\t\t_, err := helper.CreateAgentRuntime(ctx