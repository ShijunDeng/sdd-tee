{"type":"tool_use","timestamp":1775896893340,"sessionID":"ses_284500342ffe3Yogb7xdZXscIa","part":{"id":"prt_d7bb4126c001nQe8hXlpUjE2gP","messageID":"msg_d7bb39288001bHXB9zWJpkqfwo","sessionID":"ses_284500342ffe3Yogb7xdZXscIa","type":"tool","tool":"write","callID":"toolu_tool-4df71c0bc4134d0cbe6d4f3bb4bcfc2f","state":{"status":"completed","input":{"content":"package framework\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n)\n\ntype TestFailureHandler struct {\n\tframework  *TestFramework\n\toutputPath string\n}\n\ntype TestDiagnostics struct {\n\tTestName       string            `json:\"testName\"`\n\tFailedAt      time.Time         `json:\"failedAt\"`\n\tPodLogs       map[string]string `json:\"podLogs\"`\n\tResourceStatus map[string]interface{} `json:\"resourceStatus\"`\n\tEvents        []corev1.Event   `json:\"events\"`\n\tNamespace     string            `json:\"namespace\"`\n}\n\nfunc NewTestFailureHandler(f *TestFramework) *TestFailureHandler {\n\treturn &TestFailureHandler{\n\t\tframework:  f,\n\t\toutputPath: \"test/e2e/reports/diagnostics\",\n\t}\n}\n\nfunc (h *TestFailureHandler) OnFailure(failedSpec SpecReport) {\n\tif failedSpec.Failed() {\n\t\tfmt.Printf(\"\\n=== Test Failed: %s ===\\n\", failedSpec.LeafNodeText)\n\t\tfmt.Printf(\"Collecting diagnostics...\\n\")\n\n\t\tdiagnostics, err := h.collectDiagnostics(failedSpec)\n\t\tif err != nil {\n\t\t\tfmt.Printf(\"Failed to collect diagnostics: %v\\n\", err)\n\t\t\treturn\n\t\t}\n\n\t\tif err := h.saveDiagnostics(diagnostics); err != nil {\n\t\t\tfmt.Printf(\"Failed to save diagnostics: %v\\n\", err)\n\t\t\treturn\n\t\t}\n\n\t\tfmt.Printf(\"Diagnostics saved to: %s\\n\", diagnostics.TestName+\".json\")\n\t}\n}\n\nfunc (h *TestFailureHandler) collectDiagnostics(spec SpecReport) (*TestDiagnostics, error) {\n\tdiagnostics := &TestDiagnostics{\n\t\tTestName:       spec.LeafNodeText,\n\t\tFailedAt:      spec.EndTime,\n\t\tPodLogs:       make(map[string]string),\n\t\tResourceStatus: make(map[string]interface{}),\n\t\tNamespace:     h.framework.Namespace(),\n\t}\n\n\tif err := h.collectPodLogs(diagnostics); err != nil {\n\t\tfmt.Printf(\"Failed to collect pod logs: %v\\n\", err)\n\t}\n\n\tif err := h.collectResourceStatus(diagnostics); err != nil {\n\t\tfmt.Printf(\"Failed to collect resource status: %v\\n\", err)\n\t}\n\n\tif err := h.collectEvents(diagnostics); err != nil {\n\t\tfmt.Printf(\"Failed to collect events: %v\\n\", err)\n\t}\n\n\treturn diagnostics, nil\n}\n\nfunc (h *TestFailureHandler) collectPodLogs(diagnostics *TestDiagnostics) error {\n\tpods, err := h.framework.Clientset().CoreV1().Pods(h.framework.Namespace()).List(\n\t\tcontext.Background(),\n\t\tmetav1.ListOptions{},\n\t)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list pods: %w\", err)\n\t}\n\n\tfor _, pod := range pods.Items {\n\t\tfor _, container := range pod.Spec.Containers {\n\t\t\tlogReq := h.framework.Clientset().CoreV1().Pods(h.framework.Namespace()).GetLogs(\n\t\t\t\tpod.Name,\n\t\t\t\t&corev1.PodLogOptions{\n\t\t\t\t\tContainer: container.Name,\n\t\t\t\t},\n\t\t\t)\n\n\t\t\tlogs, err := logReq.DoRaw(context.Background())\n\t\t\tif err != nil {\n\t\t\t\tdiagnostics.PodLogs[fmt.Sprintf(\"%s/%s\", pod.Name, container.Name)] = fmt.Sprintf(\"Failed to get logs: %v\", err)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tlogKey := fmt.Sprintf(\"%s-%s\", diagnostics.TestName, pod.Name)\n\t\t\tdiagnostics.PodLogs[logKey] = string(logs)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (h *TestFailureHandler) collectResourceStatus(diagnostics *TestDiagnostics) error {\n\tarts, err := h.framework.AgentClient().RuntimeV1alpha1().AgentRuntimes().List(\n\t\tcontext.Background(),\n\t\tmetav1.ListOptions{Namespace: h.framework.Namespace()},\n\t)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list AgentRuntimes: %w\", err)\n\t}\n\n\tfor _, art := range arts.Items {\n\t\tstatus := map[string]interface{}{\n\t\t\t\"name\":      art.Name,\n\t\t\t\"namespace\": art.Namespace,\n\t\t\t\"ready\":     false,\n\t\t\t\"conditions\": art.Status.Conditions,\n\t\t}\n\n\t\tfor _, condition := range art.Status.Conditions {\n\t\t\tif condition.Type == \"Ready\" && condition.Status == metav1.ConditionTrue {\n\t\t\t\tstatus[\"ready\"] = true\n\t\t\t}\n\t\t}\n\n\t\tdiagnostics.ResourceStatus[fmt.Sprintf(\"agentruntime-%s\", art.Name)] = status\n\t}\n\n\tcis, err := h.framework.AgentClient().RuntimeV1alpha1().CodeInterpreters().List(\n\t\tcontext.Background(),\n\t\tmetav1.ListOptions{Namespace: h.framework.Namespace()},\n\t)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list CodeInterpreters: %w\", err)\n\t}\n\n\tfor _, ci := range cis.Items {\n\t\tstatus := map[string]interface{}{\n\t\t\t\"name\":      ci.Name,\n\t\t\t\"namespace\": ci.Namespace,\n\t\t\t\"ready\":     ci.Status.Ready,\n\t\t\t\"conditions\": ci.Status.Conditions,\n\t\t}\n\n\t\tdiagnostics.ResourceStatus[fmt.Sprintf(\"codeinterpreter-%s\", ci.Name)] = status\n\t}\n\n\tpods, err := h.framework.Clientset().CoreV1().Pods(h.framework.Namespace()).List(\n\t\tcontext.Background(),\n\t\tmetav1.ListOptions{},\n\t)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list pods: %w\", err)\n\t}\n\n\tfor _, pod := range pods.Items {\n\t\tstatus := map[string]interface{}{\n\t\t\t\"name\":      pod.Name,\n\t\t\t\"namespace\": pod.Namespace,\n\t\t\t\"phase\":     pod.Status.Phase,\n\t\t\t\"ready\":     false,\n\t\t\t\"reason\":    pod.Status.Reason,\n\t\t\t\"message\":   pod.Status.Message,\n\t\t}\n\n\t\tfor _, condition := range pod.Status.Conditions {\n\t\t\tif condition.Type == corev1.PodReady && condition.Status == corev1.ConditionTrue {\n\t\t\t\tstatus[\"ready\"] = true\n\t\t\t}\n\t\t}\n\n\t\tdiagnostics.ResourceStatus[fmt.Sprintf(\"pod-%s\", pod.Name)] = status\n\t}\n\n\tservices, err := h.framework.Clientset().CoreV1().Services(h.framework.Namespace()).List(\n\t\tcontext.Background(),\n\t\tmetav1.ListOptions{},\n\t)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list services: %w\", err)\n\t}\n\n\tfor _, svc := range services.Items {\n\t\tstatus := map[string]interface{}{\n\t\t\t\"name\":         svc.Name,\n\t\t\t\"namespace\":    svc.Namespace,\n\t\t\t\"type\":         svc.Spec.Type,\n\t\t\t\"clusterIP\":    svc.Spec.ClusterIP,\n\t\t\t\"externalIP\":   svc.Spec.ExternalIPs,\n\t\t\t\"ports\":        svc.Spec.Ports,\n\t\t\t\"selector\":     svc.Spec.Selector,\n\t\t}\n\n\t\tdiagnostics.ResourceStatus[fmt.Sprintf(\"service-%s\", svc.Name)] = status\n\t}\n\n\treturn nil\n}\n\nfunc (h *TestFailureHandler) collectEvents(diagnostics *TestDiagnostics) error {\n\tevents, err := h.framework.Clientset().CoreV1().Events(h.framework.Namespace()).List(\n\t\tcontext.Background(),\n\t\tmetav1.ListOptions{},\n\t)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to list events: %w\", err)\n\t}\n\n\tdiagnostics.Events = events.Items\n\treturn nil\n}\n\nfunc (h *TestFailureHandler) saveDiagnostics(diagnostics *TestDiagnostics) error {\n\tif err := os.MkdirAll(h.outputPath, 0755); err != nil {\n\t\treturn fmt.Errorf(\"failed to create output directory: %w\", err)\n\t}\n\n\tjsonData, err := json.MarshalIndent(diagnostics, \"\", \"  \")\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal diagnostics: %w\", err)\n\t}\n\n\tfilename := fmt.Sprintf(\"%s-%d.json\", sanitizeFilename(diagnostics.TestName), time.Now().UnixNano())\n\tfilepath := filepath.Join(h.outputPath, filename)\n\n\tif err := os.WriteFile(filepath, jsonData, 0644); err != nil {\n\t\treturn fmt.Errorf(\"failed to write diagnostics file: %w\", err)\n\t}\n\n\tfor podName, logs := range diagnostics.PodLogs {\n\t\tlogFile := filepath.Join(h.outputPath, fmt.Sprintf(\"%s-%s.log\", sanitizeFilename(diagnostics.TestName), podName))\n\t\tif err := os.WriteFile(logFile, []byte(logs), 0644); err != nil {\n\t\t\tfmt.Printf(\"Failed to write log file %s: %v\\n\", logFile, err)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc sanitizeFilename(name string) string {\n\tsanitized := \"\"\n\tfor _, r := range name {\n\t\tif (r >= 'a' && r <= 'z') || (r >= 'A' && r <= 'Z') || (r >= '0' && r <= '9') || r == '-' || r == '_' {\n\t\t\tsanitized += string(r)\n\t\t} else {\n\t\t\tsanitized += \"_\"\n\t\t}\n\t}\n\treturn sanitized\n}\n\nfunc (h *TestFailureHandler) GetDiagnosticsForTest(testName string) (*TestDiagnostics, error) {\n\tmatches, err := filepath.Glob(filepath.Join(h.outputPath, fmt.Sprintf(\"%s-*.json\", sanitizeFilename(testName))))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to glob diagnostics files: %w\", err)\n\t}\n\n\tif len(matches) == 0 {\n\t\treturn nil, fmt.Errorf(\"no diagnostics found for test: %s\", testName)\n\t}\n\n\tlatestFile := matches[len(matches)-1]\n\tdata, err := os.ReadFile(latestFile)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to read diagnostics file: %w\", err)\n\t}\n\n\tvar diagnostics TestDiagnostics\n\tif err := json.Unmarshal(data, &diagnostics); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to unmarshal diagnostics: %w\", err)\n\t}\n\n\treturn &diagnostics, nil\n}\n\nfunc RegisterFailureHandler(f *TestFramework) {\n\thandler := NewTestFailureHandler(f)\n\tReportAfterSuite(\"Test Diagnostics\", func(report SpecReport) {\n\t\thandler.OnFailure(report)\n\t})\n}\n\ntype TestMetrics struct {\n\tTestName       string        `json:\"testName\"`\n\tStartTime      time.Time     `json:\"startTime\"`\n\tEndTime        time.Time     `json:\"endTime\"`\n\tDuration       time.Duration `json:\"duration\"`\n\tAttempts       int           `json:\"attempts\"`\n\tSuccess        bool          `json:\"success\"`\n\tErrorMessage   string        `json:\"errorMessage,omitempty\"`\n}\n\nfunc (h *TestFailureHandler) RecordTestMetrics(testName string, startTime, endTime time.Time, success bool, err error) {\n\tmetrics := TestMetrics{\n\t\tTestName:     testName,\n\t\tStartTime:    startTime,\n\t\tEndTime:      endTime,\n\t\tDuration:     endTime.Sub(startTime),\n\t\tAttempts:     1,\n\t\tSuccess:      success,\n\t\tErrorMessage: \"\",\n\t}\n\n\tif err != nil {\n\t\tmetrics.ErrorMessage = err.Error()\n\t}\n\n\tmetricsData, err := json.MarshalIndent(metrics, \"\", \"  \")\n\tif err != nil {\n\t\tfmt.Printf(\"Failed to marshal test metrics: %v\\n\", err)\n\t\treturn\n\t}\n\n\tmetricsFile := filepath.Join(h.outputPath, fmt.Sprintf(\"metrics-%s.json\", sanitizeFilename(testName)))\n\tif err := os.WriteFile(metricsFile, metricsData, 0644); err != nil {\n\t\tfmt.Printf(\"Failed to write metrics file: %v\\n\", err)\n\t}\n}\n\nfunc (h *TestFailureHandler) PrintSummary(spec SpecReport) {\n\tfmt.Printf(\"\\n=== Test Summary ===\\n\")\n\tfmt.Printf(\"Test Name: %s\\n\", spec.LeafNodeText)\n\tfmt.Printf(\"Duration: %v\\n\", spec.EndTime.Sub(spec.StartTime))\n\tfmt.Printf(\"Passed: %v\\n\", spec.Passed())\n\tfmt.Printf(\"Failed: %v\\n\", spec.Failed())\n\tfmt.Printf(\"Skipped: %v\\n\", spec.Skipped())\n\tfmt.Printf(\"Attempts: %d\\n\", spec.NumAttempts)\n\n\tif spec.Failed() {\n\t\tfmt.Printf(\"Failure Message: %s\\n\", spec.FailureMessage)\n\t\tfmt.Printf(\"Failure Location: %s:%d\\n\", spec.Failure.Location.FileName, spec.Failure.Location.LineNumber)\n\t}\n\n\tfmt.Printf(\"==================\\n\")\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/failure_handler.go"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/client-go/clientset/versioned/clientset.go\">\nERROR [23:2] could not import k8s.io/apimachinery/pkg/runtime (no required module provides package \"k8s.io/apimachinery/pkg/runtime\")\nERROR [24:2] could not import k8s.io/apimachinery/pkg/runti