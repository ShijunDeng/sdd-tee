).NotTo(HaveOccurred())\n\t\t\t}\n\t\t})\n\n\t\tIt(\"should handle 10 concurrent CodeInterpreters\", func() {\n\t\t\terrors := make(chan error, 10)\n\t\t\tvar wg sync.WaitGroup\n\n\t\t\tfor i := 0; i < 10; i++ {\n\t\t\t\twg.Add(1)\n\t\t\t\tgo func(id int) {\n\t\t\t\t\tdefer wg.Done()\n\n\t\t\t\t\tci := framework.NewTestPythonCodeInterpreter(fmt.Sprintf(\"test-ci-scalability-%d\", id))\n\t\t\t\t\tci.Namespace = f.Namespace()\n\n\t\t\t\t\t_, err := ciHelper.CreateCodeInterpreter(ctx, ci)\n\t\t\t\t\terrors <- err\n\n\t\t\t\t\tif err == nil {\n\t\t\t\t\t\terr = ciHelper.WaitForCodeInterpreterReady(ctx, ci.Name, 5*time.Minute)\n\t\t\t\t\t\terrors <- err\n\t\t\t\t\t}\n\t\t\t\t}(i)\n\t\t\t}\n\n\t\t\twg.Wait()\n\t\t\tclose(errors)\n\n\t\t\tfor err := range errors {\n\t\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t}\n\t\t})\n\t})\n\n\tContext(\"Resource Cleanup Integration\", func() {\n\t\tIt(\"should clean up resources correctly\", func() {\n\t\t\tart := framework.NewTestAgentRuntime(\"test-cleanup\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\tci := framework.NewTestPythonCodeInterpreter(\"test-ci-cleanup\")\n\t\t\tci.Namespace = f.Namespace()\n\n\t\t\tvar err error\n\t\t\tart, err = artHelper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tci, err = ciHelper.CreateCodeInterpreter(ctx, ci)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = artHelper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = ciHelper.WaitForCodeInterpreterReady(ctx, ci.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\tresp, err := artHelper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = artHelper.DeleteSession(ctx, resp.SessionID)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = artHelper.DeleteAgentRuntime(ctx, art.Name)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = ciHelper.DeleteCodeInterpreter(ctx, ci.Name)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\t_, err = artHelper.GetAgentRuntime(ctx, art.Name)\n\t\t\tExpect(err).To(HaveOccurred())\n\n\t\t\t_, err = ciHelper.GetCodeInterpreter(ctx, ci.Name)\n\t\t\tExpect(err).To(HaveOccurred())\n\t\t})\n\t})\n\n\tContext(\"Error Recovery Integration\", func() {\n\t\tIt(\"should recover from session failures\", func() {\n\t\t\tart := framework.NewTestAgentRuntime(\"test-recovery\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\tvar err error\n\t\t\tart, err = artHelper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = artHelper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\tresp, err := artHelper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = artHelper.DeleteSession(ctx, resp.SessionID)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\t_, err = artHelper.InvokeSession(ctx, resp.SessionID, []byte(\"{}\"), nil)\n\t\t\tExpect(err).To(HaveOccurred())\n\n\t\t\tnewReq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\tnewResp, err := artHelper.CreateSession(ctx, newReq)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(newResp.SessionID).NotTo(BeEmpty())\n\t\t\tExpect(newResp.SessionID).NotTo(Equal(resp.SessionID))\n\n\t\t\tpayload := framework.NewTestInvokePayloadWithString(\"recovery\")\n\t\t\tnewInvokeResp, err := artHelper.InvokeSession(ctx, newResp.SessionID, payload, nil)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(newInvokeResp.StatusCode).To(Equal(200))\n\t\t})\n\t})\n})\n","additions":1,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/integration/integration_suite_test.go","time":{"start":1775896991255,"end":177589699246