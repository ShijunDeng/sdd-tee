{"type":"tool_use","timestamp":1775896693764,"sessionID":"ses_284500342ffe3Yogb7xdZXscIa","part":{"id":"prt_d7bb109dd001zq7dXqBkVZrZtw","messageID":"msg_d7bb0b3e70017e1mZikDYDKVnS","sessionID":"ses_284500342ffe3Yogb7xdZXscIa","type":"tool","tool":"write","callID":"toolu_tool-d6ae3bf1d4044df79ace282baf046c8a","state":{"status":"completed","input":{"content":"package framework\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\tagentclient \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/client-go/tools/clientcmd\"\n)\n\nconst (\n\tdefaultTimeout       = 5 * time.Minute\n\tdefaultPollInterval  = 1 * time.Second\n\tagentcubeNamespace   = \"agentcube-system\"\n\tagentcubeDeployment  = \"agentcube-controller-manager\"\n\tdefaultReadyTimeout  = 10 * time.Minute\n\tagentcubeService     = \"agentcube-webhook-service\"\n\tagentcubeWebhookPort = 9443\n)\n\nvar (\n\tletters = []rune(\"abcdefghijklmnopqrstuvwxyz0123456789\")\n)\n\ntype TestFramework struct {\n\tconfig       *rest.Config\n\tclientset    *kubernetes.Clientset\n\tagentClient  *agentclient.Clientset\n\thttpClient   *http.Client\n\tnamespace    string\n\tclusterName  string\n\tcleanup      []func() error\n\toptions      FrameworkOptions\n\tmu           sync.RWMutex\n\tinitialized  bool\n}\n\ntype FrameworkOptions struct {\n\tNamespace    string\n\tClusterName  string\n\tTimeout      time.Duration\n\tPollInterval time.Duration\n\tSkipCleanup  bool\n}\n\nfunc NewDefaultFramework(name string) *TestFramework {\n\treturn NewFramework(name, FrameworkOptions{})\n}\n\nfunc NewFramework(name string, opts FrameworkOptions) *TestFramework {\n\tif opts.Timeout == 0 {\n\t\topts.Timeout = defaultTimeout\n\t}\n\tif opts.PollInterval == 0 {\n\t\topts.PollInterval = defaultPollInterval\n\t}\n\tif opts.Namespace == \"\" {\n\t\topts.Namespace = fmt.Sprintf(\"e2e-test-%s-%s\", name, randomString(8))\n\t}\n\n\treturn &TestFramework{\n\t\tnamespace:   opts.Namespace,\n\t\tclusterName: opts.ClusterName,\n\t\toptions:     opts,\n\t\tcleanup:     make([]func() error, 0),\n\t\thttpClient: &http.Client{\n\t\t\tTimeout: opts.Timeout,\n\t\t},\n\t}\n}\n\nfunc (f *TestFramework) Setup(ctx context.Context) error {\n\tf.mu.Lock()\n\tdefer f.mu.Unlock()\n\n\tif f.initialized {\n\t\treturn nil\n\t}\n\n\tconfig, err := rest.InClusterConfig()\n\tif err != nil {\n\t\tkubeconfig := clientcmd.NewDefaultClientConfigLoadingRules().GetDefaultFilename()\n\t\tconfig, err = clientcmd.BuildConfigFromFlags(\"\", kubeconfig)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"failed to build kubeconfig: %w\", err)\n\t\t}\n\t}\n\n\tf.config = config\n\n\tclientset, err := kubernetes.NewForConfig(config)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to create kubernetes clientset: %w\", err)\n\t}\n\tf.clientset = clientset\n\n\tagentClient, err := agentclient.NewForConfig(config)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to create agentcube clientset: %w\", err)\n\t}\n\tf.agentClient = agentClient\n\n\tns := &corev1.Namespace{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName: f.namespace,\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"test\": \"e2e\",\n\t\t\t},\n\t\t},\n\t}\n\n\t_, err = f.clientset.CoreV1().Namespaces().Create(ctx, ns, metav1.CreateOptions{})\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to create namespace %s: %w\", f.namespace, err)\n\t}\n\n\tf.registerCleanup(func() error {\n\t\treturn f.clientset.CoreV1().Namespaces().Delete(context.Background(), f.namespace, metav1.DeleteOptions{})\n\t})\n\n\tf.initialized = true\n\treturn nil\n}\n\nfunc (f *TestFramework) Cleanup() error {\n\tif f.options.SkipCleanup {\n\t\treturn nil\n\t}\n\n\tvar errors []error\n\n\tfor i := len(f.cleanup) - 1; i >= 0; i-- {\n\t\tif err := f.cleanup[i](); err != nil {\n\t\t\terrors = append(errors, err)\n\t\t}\n\t}\n\n\tif len(errors) > 0 {\n\t\treturn fmt.Errorf(\"cleanup failed with %d errors\", len(errors))\n\t}\n\n\treturn nil\n}\n\nfunc (f *TestFramework) registerCleanup(cleanup func() error) {\n\tf.cleanup = append(f.cleanup, cleanup)\n}\n\nfunc (f *TestFramework) Namespace() string {\n\treturn f.namespace\n}\n\nfunc (f *TestFramework) Clientset() *kubernetes.Clientset {\n\tf.mu.RLock()\n\tdefer f.mu.RUnlock()\n\treturn f.clientset\n}\n\nfunc (f *TestClient() *agentclient.Clientset {\n\tf.mu.RLock()\n\tdefer f.mu.RUnlock()\n\treturn f.agentClient\n}\n\nfunc (f *TestFramework) HTTPClient() *http.Client {\n\treturn f.httpClient\n}\n\nfunc (f *TestFramework) Options() FrameworkOptions {\n\treturn f.options\n}\n\nfunc (f *TestFramework) AgentCubeReady() bool {\n\tctx, cancel := context.WithTimeout(context.Background(), defaultReadyTimeout)\n\tdefer cancel()\n\n\tdeployments := f.clientset.AppsV1().Deployments(agentcubeNamespace)\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn false\n\t\tdefault:\n\t\t\tdeploy, err := deployments.Get(context.Background(), agentcubeDeployment, metav1.GetOptions{})\n\t\t\tif err != nil {\n\t\t\t\ttime.Sleep(2 * time.Second)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif deploy.Status.ReadyReplicas == *deploy.Spec.Replicas {\n\t\t\t\treturn true\n\t\t\t}\n\n\t\t\ttime.Sleep(2 * time.Second)\n\t\t}\n\t}\n}\n\nfunc (f *TestFramework) WaitForAgentCubeReady(ctx context.Context) error {\n\tdeployments := f.clientset.AppsV1().Deployments(agentcubeNamespace)\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn fmt.Errorf(\"timeout waiting for AgentCube to be ready\")\n\t\tdefault:\n\t\t\tdeploy, err := deployments.Get(ctx, agentcubeDeployment, metav1.GetOptions{})\n\t\t\tif err != nil {\n\t\t\t\ttime.Sleep(2 * time.Second)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif deploy.Status.ReadyReplicas == *deploy.Spec.Replicas {\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\ttime.Sleep(2 * time.Second)\n\t\t}\n\t}\n}\n\nfunc (f *TestFramework) WaitForPodReady(ctx context.Context, namespace, podName string) error {\n\tpods := f.clientset.CoreV1().Pods(namespace)\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn fmt.Errorf(\"timeout waiting for pod %s/%s to be ready\", namespace, podName)\n\t\tdefault:\n\t\t\tpod, err := pods.Get(ctx, podName, metav1.GetOptions{})\n\t\t\tif err != nil {\n\t\t\t\ttime.Sleep(f.options.PollInterval)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif pod.Status.Phase == corev1.PodRunning {\n\t\t\t\tfor _, containerStatus := range pod.Status.ContainerStatuses {\n\t\t\t\t\tif !containerStatus.Ready {\n\t\t\t\t\t\ttime.Sleep(f.options.PollInterval)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\ttime.Sleep(f.options.PollInterval)\n\t\t}\n\t}\n}\n\nfunc (f *TestFramework) WaitForServiceReady(ctx context.Context, namespace, serviceName string) error {\n\tservices := f.clientset.CoreV1().Services(namespace)\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn fmt.Errorf(\"timeout waiting for service %s/%s to be ready\", namespace, serviceName)\n\t\tdefault:\n\t\t\tsvc, err := services.Get(ctx, serviceName, metav1.GetOptions{})\n\t\t\tif err != nil {\n\t\t\t\ttime.Sleep(f.options.PollInterval)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif svc.Spec.Type == corev1.ServiceTypeLoadBalancer {\n\t\t\t\tif len(svc.Status.LoadBalancer.Ingress) > 0 {\n\t\t\t\t\treturn nil\n\t\t\t\t}\n\t\t\t} else if svc.Spec.Type == corev1.ServiceTypeNodePort {\n\t\t\t\treturn nil\n\t\t\t} else if svc.Spec.Type == corev1.ServiceTypeClusterIP {\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\ttime.Sleep(f.options.PollInterval)\n\t\t}\n\t}\n}\n\nfunc randomString(n int) string {\n\tb := make([]rune, n)\n\tfor i := range b {\n\t\tb[i] = letters[rand.Intn(len(letters))]\n\t}\n\treturn string(b)\n}\n\nfunc init() {\n\trand.Seed(time.Now().UnixNano())\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/framework