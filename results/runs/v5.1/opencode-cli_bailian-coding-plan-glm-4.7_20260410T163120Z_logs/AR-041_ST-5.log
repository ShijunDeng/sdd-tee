onditions\", matcher.expected)\n}\n\nfunc (matcher *haveConditionsMatcher) NegatedFailureMessage(actual interface{}) (message string) {\n\treturn format.Message(actual, \"not to have conditions\", matcher.expected)\n}\n\nfunc BeReady() types.GomegaMatcher {\n\treturn &beReadyMatcher{}\n}\n\ntype beReadyMatcher struct{}\n\nfunc (matcher *beReadyMatcher) Match(actual interface{}) (success bool, err error) {\n\tconditions, ok := actual.([]metav1.Condition)\n\tif !ok {\n\t\treturn false, fmt.Errorf(\"expected []metav1.Condition, got %T\", actual)\n\t}\n\n\tfor _, condition := range conditions {\n\t\tif condition.Type == \"Ready\" && condition.Status == metav1.ConditionTrue {\n\t\t\treturn true, nil\n\t\t}\n\t}\n\n\treturn false, nil\n}\n\nfunc (matcher *beReadyMatcher) FailureMessage(actual interface{}) (message string) {\n\treturn format.Message(actual, \"to have Ready condition with status True\")\n}\n\nfunc (matcher *beReadyMatcher) NegatedFailureMessage(actual interface{}) (message string) {\n\treturn format.Message(actual, \"not to have Ready condition with status True\")\n}\n\nfunc HavePhase(phase string) types.GomegaMatcher {\n\treturn &havePhaseMatcher{\n\t\texpected: phase,\n\t}\n}\n\ntype havePhaseMatcher struct {\n\texpected string\n}\n\nfunc (matcher *havePhaseMatcher) Match(actual interface{}) (success bool, err error) {\n\tobj, ok := actual.(interface{ GetStatus() interface{ GetPhase() string } })\n\tif !ok {\n\t\treturn false, fmt.Errorf(\"expected object with GetStatus().GetPhase(), got %T\", actual)\n\t}\n\n\treturn obj.GetStatus().GetPhase() == matcher.expected, nil\n}\n\nfunc (matcher *havePhaseMatcher) FailureMessage(actual interface{}) (message string) {\n\treturn fmt.Sprintf(\"Expected\\n\\t%#v\\nto have phase\\n\\t%s\", actual, matcher.expected)\n}\n\nfunc (matcher *havePhaseMatcher) NegatedFailureMessage(actual interface{}) (message string) {\n\treturn fmt.Sprintf(\"Expected\\n\\t%#v\\nnot to have phase\\n\\t%s\", actual, matcher.expected)\n}\n\n