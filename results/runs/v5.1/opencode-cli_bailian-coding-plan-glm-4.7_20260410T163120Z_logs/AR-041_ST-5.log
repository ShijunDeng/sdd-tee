an-glm-4.7_20260410T163120Z/test/e2e/integration/integration_suite_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/integration/integration_suite_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/integration/integration_suite_test.go\n@@ -1,8 +1,9 @@\n package e2e\n \n import (\n \t\"context\"\n+\t\"fmt\"\n \t\"sync\"\n \t\"time\"\n \n \t. \"github.com/onsi/ginkgo/v2\"\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/integration/integration_suite_test.go","before":"package e2e\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/test/e2e/framework\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nvar _ = Describe(\"Integration Tests\", func() {\n\tvar (\n\t\tf         *framework.TestFramework\n\t\tartHelper *framework.AgentRuntimeHelper\n\t\tciHelper  *framework.CodeInterpreterHelper\n\t\tctx       context.Context\n\t\tcancel    context.CancelFunc\n\t)\n\n\tBeforeSuite(func() {\n\t\tf = framework.NewDefaultFramework(\"integration-e2e\")\n\t\tctx, cancel = context.WithTimeout(context.Background(), 15*time.Minute)\n\t\tdefer cancel()\n\n\t\tExpect(f.Setup(ctx)).To(Succeed())\n\t\tEventually(func() bool {\n\t\t\treturn f.AgentCubeReady()\n\t\t}, 10*time.Minute, 10*time.Second).Should(BeTrue())\n\n\t\tartHelper = framework.NewAgentRuntimeHelper(f)\n\t\tciHelper = framework.NewCodeInterpreterHelper(f)\n\t})\n\n\tAfterSuite(func() {\n\t\tif f != nil && !f.Options().SkipCleanup {\n\t\t\tExpect(f.Cleanup()).To(Succeed())\n\t\t}\n\t})\n\n\tBeforeEach(func() {\n\t\tctx, cancel = context.WithTimeout(context.Background(), 10*time.Minute)\n\t})\n\n\tAfterEach(func() {\n\t\tcancel()\n\t})\n\n\tContext(\"Workflow Integration\", func() {\n\t\tIt(\"should execute complete workflow\", func() {\n\t\t\tart := framework.NewTestAgentRuntime(\"test-workflow\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\tvar err error\n\t\t\tart, err = artHelper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = artHelper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\tresp, err := artHelper.CreateSession(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(resp.SessionID).NotTo(BeEmpty())\n\n\t\t\tfor i := 0; i < 5; i++ {\n\t\t\t\tpayload := framework.NewTestInvokePayloadWithID(i)\n\t\t\t\tinvokeResp, err := artHelper.InvokeSession(ctx, resp.SessionID, payload, nil)\n\t\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t\tExpect(invokeResp.StatusCode).To(Equal(200))\n\t\t\t}\n\n\t\t\terr = artHelper.DeleteSession(ctx, resp.SessionID)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = artHelper.DeleteAgentRuntime(ctx, art.Name)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t})\n\t})\n\n\tContext(\"Cross-Resource Integration\", func() {\n\t\tIt(\"should manage AgentRuntime and CodeInterpreter together\", func() {\n\t\t\tart := framework.NewTestAgentRuntime(\"test-cross-art\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\tci := framework.NewTestPythonCodeInterpreter(\"test-cross-ci\")\n\t\t\tci.Namespace = f.Namespace()\n\n\t\t\tvar err error\n\t\t\tart, err = artHelper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tci, err = ciHelper.CreateCodeInterpreter(ctx, ci)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = artHelper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = ciHelper.WaitForCodeInterpreterReady(ctx, ci.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tartReq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\tartResp, err := artHelper.CreateSession(ctx, artReq)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tciReq := framework.NewTestSessionRequest(\"CodeInterpreter\", ci.Name, f.Namespace())\n\t\t\tciResp, err := artHelper.CreateSession(ctx, ciReq)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tExpect(artResp.SessionID).NotTo(Equal(ciResp.SessionID))\n\n\t\t\tartPayload := framework.NewTestInvokePayloadWithString(\"agent\")\n\t\t\tartInvokeResp, err := artHelper.InvokeSession(ctx, artResp.SessionID, artPayload, nil)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(artInvokeResp.StatusCode).To(Equal(200))\n\n\t\t\tciExecuteResp, err := ciHelper.ExecuteCode(ctx, ciResp.SessionID, `print(\"interpreter\")`, \"\")\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(ciExecuteResp.ExitCode).To(Equal(0))\n\t\t\tExpect(ciExecuteResp.Stdout).To(ContainSubstring(\"interpreter\"))\n\t\t})\n\t})\n\n\tContext(\"Session Management Integration\", func() {\n\t\tIt(\"should handle multiple sessions for same resource\", func() {\n\t\t\tart := framework.NewTestAgentRuntime(\"test-multi-session\")\n\t\t\tart.Namespace = f.Namespace()\n\n\t\t\tvar err error\n\t\t\tart, err = artHelper.CreateAgentRuntime(ctx, art)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\terr = artHelper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\tsessions := make([]string, 5)\n\t\t\tfor i := 0; i < 5; i++ {\n\t\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n\t\t\t\tresp, err := artHelper.CreateSession(ctx, req)\n\t\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t\tsessions[i] = resp.SessionID\n\t\t\t\tExpect(sessions[i]).NotTo(BeEmpty())\n\t\t\t}\n\n\t\t\tfor _, sessionID := range sessions {\n\t\t\t\tpayload := framework.NewTestInvokePayloadWit