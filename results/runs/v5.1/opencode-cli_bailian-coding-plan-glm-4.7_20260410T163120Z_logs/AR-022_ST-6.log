cally built image for publishing.\"\"\"\n        image_url = options.get(\"image_url\") or metadata.image.get(\"image_name\") if metadata.image else None\n\n        if not image_url:\n            raise ValueError(\n                \"image_url is required for local build mode. \"\n                \"Provide it via --image-url option or build the image first.\"\n            )\n\n        if metadata.image and \"image_name\" in metadata.image:\n            local_image = metadata.image[\"image_name\"]\n            registry_url = options.get(\"image_url\", \"\").rsplit(\":\", 1)[0]\n\n            username = options.get(\"image_username\") or metadata.registry_username\n            password = options.get(\"image_password\") or metadata.registry_password\n\n            if username and password:\n                self.docker_service.push_image(\n                    image_name=local_image,\n                    registry_url=registry_url,\n                    username=username,\n                    password=password,\n                )\n\n        return image_url\n","exit":0,"description":"Check _prepare_local_image return statements","truncated":false},"title":"Check _prepare_local_image return statements","time":{"start":1775868841138,"end":1775868841158}}}}
