  workload_manager_url=\"http://wm:8080\",\n39:         router_url=\"http://router:8080\",\n40:         readiness_probe_path=\"/health\",\n41:         readiness_probe_port=8080,\n42:     )\n43:     return metadata\n44: \n45: \n46: @pytest.fixture\n47: def runtime():\n48:     \"\"\"Create a PublishRuntime instance.\"\"\"\n49:     return PublishRuntime(verbose=True, provider=\"agentcube\")\n50: \n51: \n52: @pytest.fixture\n53: def k8s_runtime():\n54:     \"\"\"Create a PublishRuntime instance with k8s provider.\"\"\"\n55:     return PublishRuntime(verbose=False, provider=\"k8s\")\n56: \n57: \n58: class TestPublishRuntimeInit:\n59:     \"\"\"Test PublishRuntime initialization.\"\"\"\n60: \n61:     def test_init_default(self):\n62:         \"\"\"Test initialization with default parameters.\"\"\"\n63:         runtime = PublishRuntime()\n64:         assert runtime.verbose is False\n65:         assert runtime.provider == \"agentcube\"\n66:         assert runtime.metadata_service is not None\n67:         assert runtime.docker_service is not None\n68: \n69:     def test_init_verbose_true(self):\n70:         \"\"\"Test initialization with verbose=True.\"\"\"\n71:         runtime = PublishRuntime(verbose=True)\n72:         assert runtime.verbose is True\n73:         assert runtime.provider == \"agentcube\"\n74: \n75:     def test_init_provider_k8s(self):\n76:         \"\"\"Test initialization with k8s provider.\"\"\"\n77:         runtime = PublishRuntime(provider=\"k8s\")\n78:         assert runtime.provider == \"k8s\"\n79: \n80:     def test_init_invalid_provider(self):\n81:         \"\"\"Test initialization with invalid provider doesn't fail at init.\"\"\"\n82:         runtime = PublishRuntime(provider=\"invalid\")\n83:         assert runtime.provider == \"invalid\"\n84: \n85: \n86: class TestPublishRuntimePublish:\n87:     \"\"\"Test PublishRuntime.publish method.\"\"\"\n88: \n89:     def test_publish_success_agentcube(self, runtime: PublishRuntime, temp_workspace: Path, sample_metadata: AgentMetadata):\n90:         \"\"\"Test successful publish with agentcube provider.\"\"\"\n91:         with patch.object(runtime.metadata_service, \"load_metadata\", return_value=sample_metadata), \\\n92:              patch.object(runtime, \"_prepare_image_for_publishing\", return_value=\"registry.example.com/test-agent:v1.0.0\"), \\\n93:              patch.object(runtime, \"_publish_cr_to_k8s\", return_value={\n94:                  \"agent_id\": \"test-agent\",\n95:                  \"session_id\": \"abc123\",\n96:                  \"namespace\": \"default\",\n97:                  \"image_url\": \"registry.example.com/test-agent:v1.0.0\",\n98:                  \"provider\": \"agentcube\",\n99:              }), \\\n100:              patch.object(runtime, \"_update_publish_metadata\") as mock_update:\n101: \n102:             result = runtime.publish(temp_workspace, version=\"v1.0.0\")\n103: \n104:             assert result[\"agent_id\"] == \"test-agent\"\n105:             assert result[\"provider\"] == \"agentcube\"\n106:             assert result[\"image_url\"] == \"registry.example.com/test-agent:v1.0.0\"\n107:             mock_update.assert_called_once()\n108: \n109:     def test_publish_success_k8s(self, k8s_runtime: PublishRuntime, temp_workspace: Path, sample_metadata: AgentMetadata):\n110:         \"\"\"Test successful publish with k8s provider.\"\"\"\n111:         with patch.object(k8s_runtime.metadata_service, \"load_metadata\", return_value=sample_metadata), \\\n112:              patch.object(k8s_runtime, \"_prepare_image_for_publishing\", return_value=\"registry.example.com/test-agent:v1.0.0\"), \\\n113:              patch.object(k8s_runtime, \"_publish_k8s\", return_value={\n114:                  \"agent_id\": \"test-agent\",\n115:                  \"session_id\": \"abc123\",\n116:                  \"namespace\": \"default\",\n117:                  \"image_url\": \"registry.example.com/test-agent:v1.0.0\",\n118:                  \"provider\": \"k8s\",\n119:                  \"service_url\": \"http://localhost:30001\",\n120:              }), \\\n121:              patch.object(k8s_runtime, \"_update_publish_metadata\") as mock_update:\n122: \n123:             result = k8s_runtime.publish(temp_workspace, replicas=2, node_port=30001)\n124: \n125:             assert result[\"agent_id\"] == \"test-agent\"\n126:             assert result[\"provider\"] == \"k8s\"\n127:             assert result[\"image_url\"] == \"registry.example.com/test-agent:v1.0.0\"\n128:             mock_update.assert_called_once()\n129: \n130:     def test_publish_invalid_provider(self, temp_workspace: Path, sample_metadata: AgentMetadata):\n131:         \"\"\"Test publish with invalid provider raises ValueError.\"\"\"\n132:         runtime = PublishRuntime(provider=\"invalid\")\n133: \n134:         with patch.object(runtime.metadata_service, \"load_metadata\", return_value=sample_metadata), \\\n135:              patch.object(runtime, \"_prepare_image_for_publishing\", return_value=\"registry.example.com/test:v1\"):\n136:             with pytest.raises(ValueError) as exc_info:\n137:                 runtime.publish(temp_workspace)\n138: \n139:             assert \"Unsupported provider\" in str(exc_info.value)\n140: \n141:     def test_publish_load_metadata_error(self, runtime: PublishRuntime, temp_workspace: Path):\n142:         \"\"\"Test publish when metadata loading fails.\"\"\"\n143:         with patch.object(runtime.metadata_service, \"load_metadata\", side_effect=FileNotFoundError(\"Metadata not found\")):\n144:             with pytest.raises(FileNotFoundError) as exc_info:\n145:                 runtime.publish(temp_workspace)\n146: \n147:             assert \"Metadata not found\" in str(exc_info.value)\n148: \n149:     def test_publish_applies_option_overrides(self, runtime: PublishRuntime, temp_workspace: Path, sample_metadata: AgentMetadata):\n150:         \"\"\"Test publish applies CLI option overrides to metadata.\"\"\"\n151:         with patch.object(runtime.metadata_service, \"load_metadata\", return_value=sample_metadata), \\\n152:              patch.object(runtime, \"_prepare_image_for_publishing\", return_value=\"registry.example.com/test:v2.0.0\") as mock_prepare, \\\n153:              patch.object(runtime, \"_publish_cr_to_k8s\", return_value={\n154:                  \"agent_id\": \"test-agent\",\n155:                  \"namespace\": \"default\",\n156:                  \"image_url\": \"registry.example.com/test:v2.0.0\",\n157:                  \"provider\": \"agentcube\",\n158:              }), \\\n159:              patch.object(runtime, \"_update_publish_metadata\"):\n160: \n161:             options = {\n162:                 \"version\": \"v2.0.0\",\n163:                 \"description\": \"Updated description\",\n164:                 \"region\": \"us-west-2\",\n165:             }\n166: \n167:             runtime.publish(temp_workspace, **options)\n168: \n169:             call_args = mock_prepare.call_args\n170:             assert call_args is not None\n171: \n172: \n173: class TestPrepareImageForPublishing:\n174:     \"\"\"Test _prepare_image_for_publishing method.\"\"\"\n175: \n176:     def test_prepare_image_local_mode(self, runtime: PublishRuntime, temp_workspace: Path, sample_metadata: AgentMetadata):\n177:         \"\"\"Test image preparation for local build mode.\"\"\"\n178:         sample_metadata.build_mode = \"local\"\n179: \n180:         with patch.object(runtime, \"_prepare_local_image\", return_value=\"registry.example.com/test:v1.0.0\") as mock_local:\n181:             result = runtime._prepare_image_for_publishing(temp_workspace, sample_metadata, {})\n182: \n183:             assert result == \"registry.example.com/test:v1.0.0\"\n184:             mock_local.assert_called_once()\n185: \n186:     def test_prepare_image_cloud_mode(self, runtime: PublishRuntime, temp_workspace: Path, sample_metadata: AgentMetadata):\n187:         \"\"\"Test image preparation for cloud build mode.\"\"\"\n188:         sample_metadata.build_mode = \"cloud\"\n189: \n190:         with patch.object(runtime, \"_prepare_cloud_image\", return_value=\"registry.example.com/test:v1.0.0\") as mock_cloud:\n191:             result = runtime._prepare_image_for_publishing(temp_workspace, sample_metadata, {})\n192: \n193:             assert result == \"registry.example.com/test:v1.0.0\"\n194: \n195: \n196: \n197: class TestPrepareLocalImage:\n198:     \"\"\"Test _prepare_local_image method.\"\"\"\n199: \n200:     def test_prepare_local_image_with_image_url(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n201:         \"\"\"Test local image preparation with image_url in options.\"\"\"\n202:         options = {\"image_url\": \"registry.example.com/test:v1.0.0\"}\n203: \n204:         with patch.object(runtime.docker_service, \"check_docker_available\", return_value=True), \\\n205:              patch.object(runtime.docker_service, \"push_image\") as mock_push:\n206: \n207:             result = runtime._prepare_local_image(Path(\"/tmp\"), sample_metadata, options)\n208: \n209:             assert result == \"registry.example.com/test:v1.0.0\"\n210: \n211:     def test_prepare_local_image_with_metadata_image(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n212:         \"\"\"Test local image preparation with image from metadata.\"\"\"\n213:         options = {}\n214: \n215:         with patch.object(runtime.docker_service, \"check_docker_available\", return_value=True), \\\n216:              patch.object(runtime.docker_service, \"push_image\") as mock_push:\n217: \n218:             result = runtime._prepare_local_image(Path(\"/tmp\"), sample_metadata, options)\n219: \n220:             assert result == \"test-agent:latest\"\n221: \n222:     def test_prepare_local_image_missing_image_url(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n223:         \"\"\"Test local image preparation with missing image_url.\"\"\"\n224:         sample_metadata.image = {}\n225:         options = {}\n226: \n227:         with patch.object(runtime.docker_service, \"check_docker_available\", return_value=True):\n228:             with pytest.raises(ValueError) as exc_info:\n229:                 runtime._prepare_local_image(Path(\"/tmp\"), sample_metadata, options)\n230: \n231:             assert \"image_url is required\" in str(exc_info.value)\n232: \n233:     def test_prepare_local_image_docker_unavailable(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n234:         \"\"\"Test local image preparation when Docker is unavailable.\"\"\"\n235:         with patch.object(runtime.docker_service, \"check_docker_available\", return_value=False):\n236:             with pytest.raises(RuntimeError) as exc_info:\n237:                 runtime._prepare_local_image(Path(\"/tmp\"), sample_metadata, {\"image_url\": \"registry.example.com/test:v1\"})\n238: \n239:             assert \"Docker is not available\" in str(exc_info.value)\n240: \n241:     def test_prepare_local_image_with_credentials(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n242:         \"\"\"Test local image preparation with registry credentials.\"\"\"\n243:         options = {\n244:             \"image_url\": \"registry.example.com/test:v1.0.0\",\n245:             \"image_username\": \"user\",\n246:             \"image_password\": \"pass\",\n247:         }\n248: \n249:         with patch.object(runtime.docker_service, \"check_docker_available\", return_value=True), \\\n250:              patch.object(runtime.docker_service, \"push_image\") as mock_push:\n251: \n252:             runtime._prepare_local_image(Path(\"/tmp\"), sample_metadata, options)\n253: \n254:             mock_push.assert_called_once()\n255:             call_kwargs = mock_push.call_args.kwargs\n256:             assert call_kwargs[\"username\"] == \"user\"\n257:             assert call_kwargs[\"password\"] == \"pass\"\n258: \n259:     def test_prepare_local_image_push_failure(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n260:         \"\"\"Test local image preparation when push fails.\"\"\"\n261:         options = {\n262:             \"image_url\": \"registry.example.com/test:v1.0.0\",\n263:             \"image_username\": \"user\",\n264:             \"image_password\": \"pass\",\n265:         }\n266: \n267:         with patch.object(runtime.docker_service, \"check_docker_available\", return_value=True), \\\n268:              patch.object(runtime.docker_service, \"push_image\", side_effect=RuntimeError(\"Push failed\")):\n269:             with pytest.raises(RuntimeError) as exc_info:\n270:                 runtime._prepare_local_image(Path(\"/tmp\"), sample_metadata, options)\n271: \n272:             assert \"Push failed\" in str(exc_info.value)\n273: \n274: \n275: class TestPrepareCloudImage:\n276:     \"\"\"Test _prepare_cloud_image method.\"\"\"\n277: \n278:     def test_prepare_cloud_image_with_image(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n279:         \"\"\"Test cloud image preparation with image in metadata.\"\"\"\n280:         sample_metadata.build_mode = \"cloud\"\n281: \n282:         result = runtime._prepare_cloud_image(Path(\"/tmp\"), sample_metadata, {})\n283: \n284:         assert result == \"test-agent:latest\"\n285: \n286:     def test_prepare_cloud_image_without_image(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n287:         \"\"\"Test cloud image preparation without image in metadata.\"\"\"\n288:         sample_metadata.build_mode = \"cloud\"\n289:         sample_metadata.image = None\n290: \n291:         result = runtime._prepare_cloud_image(Path(\"/tmp\"), sample_metadata, {\"cloud_provider\": \"huawei\"})\n292: \n293:         assert \"huawei\" in result\n294:         assert \"test-agent\" in result\n295: \n296:     def test_prepare_cloud_image_with_version(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n297:         \"\"\"Test cloud image preparation with version.\"\"\"\n298:         sample_metadata.build_mode = \"cloud\"\n299:         sample_metadata.image = None\n300:         sample_metadata.version = \"v2.0.0\"\n301: \n302:         result = runtime._prepare_cloud_image(Path(\"/tmp\"), sample_metadata, {\"cloud_provider\": \"huawei\"})\n303: \n304:         assert \"v2.0.0\" in result\n305: \n306: \n307: class TestPublishCrToK8s:\n308:     \"\"\"Test _publish_cr_to_k8s method.\"\"\"\n309: \n310:     def test_publish_cr_to_k8s_success(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n311:         \"\"\"Test successful publish to agentcube provider.\"\"\"\n312:         with patch(\"agentcube.services.agentcube_provider.config\") as mock_config, \\\n313:              patch(\"agentcube.services.agentcube_provider.client\") as mock_client, \\\n314:              patch(\"agentcube.services.agentcube_provider.CustomObjectsApi\") as mock_custom_api_class:\n315:             mock_config.ConfigException = Exception\n316:             mock_config.load_kube_config = Mock()\n317:             mock_config.load_incluster_config = Mock()\n318: \n319:             mock_custom_api = MagicMock()\n320:             mock_custom_api_class.return_value = mock_custom_api\n321:             mock_client.CustomObjectsApi = mock_custom_api_class\n322: \n323:             with patch.object(runtime, \"_prepare_image_for_publishing\", return_value=\"registry.example.com/test:v1\"):\n324:                 with patch.object(runtime, \"_generate_session_id\", return_value=\"abc123def456\"):\n325:                     result = runtime._publish_cr_to_k8s(Path(\"/tmp\"), sample_metadata)\n326: \n327:                     assert result[\"agent_id\"] == \"test-agent\"\n328:                     assert result[\"session_id\"] == \"abc123def456\"\n329:                     assert result[\"provider\"] == \"agentcube\"\n330:                     assert result[\"namespace\"] == \"default\"\n331:                     assert result[\"image_url\"] == \"registry.example.com/test:v1\"\n332: \n333:     def test_publish_cr_to_k8s_missing_workload_manager_url(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n334:         \"\"\"Test publish to agentcube provider missing workload_manager_url.\"\"\"\n335:         sample_metadata.workload_manager_url = None\n336: \n337:         with pytest.raises(ValueError) as exc_info:\n338:             runtime._publish_cr_to_k8s(Path(\"/tmp\"), sample_metadata)\n339: \n340:         assert \"workload_manager_url\" in str(exc_info.value)\n341: \n342:     def test_publish_cr_to_k8s_missing_router_url(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n343:         \"\"\"Test publish to agentcube provider missing router_url.\"\"\"\n344:         sample_metadata.router_url = None\n345: \n346:         with pytest.raises(ValueError) as exc_info:\n347:             runtime._publish_cr_to_k8s(Path(\"/tmp\"), sample_metadata)\n348: \n349:         assert \"router_url\" in str(exc_info.value)\n350: \n351:     def test_publish_cr_to_k8s_custom_namespace(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n352:         \"\"\"Test publish to agentcube provider with custom namespace.\"\"\"\n353:         with patch(\"agentcube.services.agentcube_provider.config\") as mock_config, \\\n354:              patch(\"agentcube.services.agentcube_provider.client\") as mock_client, \\\n355:              patch(\"agentcube.services.agentcube_provider.CustomObjectsApi\") as mock_custom_api_class:\n356:             mock_config.ConfigException = Exception\n357:             mock_config.load_kube_config = Mock()\n358:             mock_config.load_incluster_config = Mock()\n359: \n360:             mock_custom_api = MagicMock()\n361:             mock_custom_api_class.return_value = mock_custom_api\n362:             mock_client.CustomObjectsApi = mock_custom_api_class\n363: \n364:             with patch.object(runtime, \"_prepare_image_for_publishing\", return_value=\"registry.example.com/test:v1\"):\n365:                 with patch.object(runtime, \"_generate_session_id\", return_value=\"abc123\"):\n366:                     result = runtime._publish_cr_to_k8s(Path(\"/tmp\"), sample_metadata, namespace=\"test-ns\")\n367: \n368:                     assert result[\"namespace\"] == \"test-ns\"\n369: \n370:     def test_publish_cr_to_k8s_with_readiness_probe(self, runtime: PublishRuntime, sample_metadata: AgentMetadata):\n371:         \"\"\"Test publish to agentcube provider with custom readiness probe.\"\"\"\n372:         sample_metadata.readiness_probe_path = \"/custom-health\"\n373:         sample_metadata.readiness_probe_port = 9090\n374: \n375:         with patch(\"agentcube.services.agentcube_provider.config\") as mock_config, \\\n376:              patch(\"agentcube.services.agentcube_provider.client\") as mock_client, \\\n377:              patch(\"agentcube.services.agentcube_provider.CustomObjectsApi\") as mock_custom_api_class:\n378:             mock_config.ConfigException = Exception\n379:             mock_config.load_kube_config = Mock()\n380:             mock_config.load_incluster_config = Mock()\n381: \n382:             mock_custom_api = MagicMock()\n383:             mock_custom_api_class.return_value = mock_custom_api\n384:             mock_client.CustomObjectsApi = mock_custom_api_class\n385: \n386:             with patch.object(runtime, \"_prepare_image_for_publishing\", return_value=\"registry.example.com/test:v1\"):\n387:                 with patch.object(runtime, \"_generate_session_id\", return_value=\"abc123\"):\n388:                     result = runtime._publish_cr_to_k8s(Path(\"/tmp\"), sample_metadata)\n389: \n390:                     assert result[\"agent_id\"] == \"test-agent\"\n391: \n392: \n393: class TestPublishK8s:\n394:     \"\"\"Test _publish_k8s method.\"\"\"\n395: \n396:     def test_publish_k8s_success(self, k8s_runtime: PublishRuntime, sample_metadata: AgentMetadata):\n397:         \"\"\"Test s