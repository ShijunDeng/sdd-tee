       )\n85: \n86:         logger.debug(f\"Loading metadata from {metadata_file}\")\n87:         with open(metadata_file, \"r\") as f:\n88:             data = yaml.safe_load(f) or {}\n89: \n90:         return AgentMetadata(**data)\n91: \n92:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n93:         \"\"\"Save metadata to workspace directory.\"\"\"\n94:         metadata_file = workspace_path / \"agent_metadata.yaml\"\n95:         logger.debug(f\"Saving metadata to {metadata_file}\")\n96: \n97:         with open(metadata_file, \"w\") as f:\n98:             yaml.dump(\n99:                 metadata.model_dump(exclude_none=True),\n100:                 f,\n101:                 default_flow_style=False,\n102:                 indent=2,\n103:                 sort_keys=False,\n104:             )\n105: \n106:     def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n107:         \"\"\"Update metadata with new values.\"\"\"\n108:         metadata = self.load_metadata(workspace_path)\n109:         for key, value in updates.items():\n110:             if value is not None:\n111:                 setattr(metadata, key, value)\n112:         self.save_metadata(workspace_path, metadata)\n113:         return metadata\n114: \n115:     def validate_workspace(self, workspace_path: Path) -> bool:\n116:         \"\"\"Validate workspace structure.\"\"\"\n117:         if not workspace_path.exists():\n118:             raise FileNotFoundError(f\"Workspace directory does not exist: {workspace_path}\")\n119: \n120:         if not workspace_path.is_dir():\n121:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n122: \n123:         return True\n124: \n125:     def _find_metadata_file(self, workspace_path: Path) -> Optional[Path]:\n126:         \"\"\"Find metadata file in workspace directory.\"\"\"\n127:         for filename in (\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"):\n128:             metadata_file = workspace_path / filename\n129:             if metadata_file.exists():\n130:                 return metadata_file\n131:         return None\n132: \n133:     def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n134:         \"\"\"Validate Python workspace structure.\"\"\"\n135:         py_files = list(workspace_path.glob(\"*.py\"))\n136:         if not py_files:\n137:             raise ValueError(\"No Python files found in workspace\")\n138: \n139:     def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n140:         \"\"\"Validate Java workspace structure.\"\"\"\n141:         pom_file = workspace_path / \"pom.xml\"\n142:         if not pom_file.exists():\n143:             raise ValueError(\"Java workspace requires pom.xml file\")\n\n(End of file - total 143 lines)\n</content>","metadata":{"preview":"\"\"\"Service for managing agent metadata.\"\"\"\n\nimport logging\nimport os\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport yaml\nfrom pydantic import BaseModel, field_validator, ConfigDict\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Agent metadata model.\"\"\"\n\n    model_config = ConfigDict(extra=\"allow\", validate_assignment=True)\n\n    agent_name: str","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775865935770,"end":1775865935781}}}}
