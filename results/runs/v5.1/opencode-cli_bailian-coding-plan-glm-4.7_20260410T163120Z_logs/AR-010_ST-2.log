{"type":"tool_use","timestamp":1775849894039,"sessionID":"ses_28719b16dffecOLQtjnU5U7KHJ","part":{"id":"prt_d78e6eb5e001bBOvvolJVhFuME","messageID":"msg_d78e6e18c001uTzfeyEhTcuP4f","sessionID":"ses_28719b16dffecOLQtjnU5U7KHJ","type":"tool","tool":"read","callID":"toolu_tool-e56da945e53f4422af14c15e4c42dd08","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"net/http\"\n5: \n6: \t\"github.com/gin-gonic/gin\"\n7: \t\"github.com/google/uuid\"\n8: \t\"k8s.io/klog/v2\"\n9: \n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: type Handler struct {\n14: \tsessionManager SessionManager\n15: \tjwtManager     *JWTManager\n16: \treverseProxy   *ReverseProxy\n17: }\n18: \n19: func NewHandler(sessionManager SessionManager, jwtManager *JWTManager, reverseProxy *ReverseProxy) *Handler {\n20: \treturn &Handler{\n21: \t\tsessionManager: sessionManager,\n22: \t\tjwtManager:     jwtManager,\n23: \t\treverseProxy:   reverseProxy,\n24: \t}\n25: }\n26: \n27: func (h *Handler) handleHealthLive(c *gin.Context) {\n28: \tc.JSON(http.StatusOK, gin.H{\n29: \t\t\"status\": \"alive\",\n30: \t})\n31: }\n32: \n33: func (h *Handler) handleHealthReady(c *gin.Context) {\n34: \tif h.sessionManager == nil {\n35: \t\tc.JSON(http.StatusServiceUnavailable, NewErrorResponse(\n36: \t\t\t\"session manager not available\",\n37: \t\t\tErrSessionManagerNotReady,\n38: \t\t))\n39: \t\treturn\n40: \t}\n41: \n42: \tif h.jwtManager == nil {\n43: \t\tc.JSON(http.StatusServiceUnavailable, NewErrorResponse(\n44: \t\t\t\"JWT manager not available\",\n45: \t\t\t\"JWT_MANAGER_NOT_READY\",\n46: \t\t))\n47: \t\treturn\n48: \t}\n49: \n50: \tc.JSON(http.StatusOK, gin.H{\n51: \t\t\"status\": \"ready\",\n52: \t})\n53: }\n54: \n55: func (h *Handler) handleAgentInvoke(c *gin.Context) {\n56: \th.handleInvocation(c, types.AgentRuntimeKind)\n57: }\n58: \n59: func (h *Handler) handleCodeInterpreterInvoke(c *gin.Context) {\n60: \th.handleInvocation(c, types.CodeInterpreterKind)\n61: }\n62: \n63: func (h *Handler) handleInvocation(c *gin.Context, kind string) {\n64: \tnamespace := c.Param(\"namespace\")\n65: \tname := c.Param(\"name\")\n66: \tpath := c.Param(\"path\")\n67: \n68: \tif !isValidNamespace(namespace) {\n69: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n70: \t\t\t\"invalid namespace format\",\n71: \t\t\tGetErrorCode(&ValidationError{Field: \"namespace\"}),\n72: \t\t))\n73: \t\treturn\n74: \t}\n75: \n76: \tif !isValidResourceName(name) {\n77: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n78: \t\t\t\"invalid resource name format\",\n79: \t\t\tGetErrorCode(&ValidationError{Field: \"name\"}),\n80: \t\t))\n81: \t\treturn\n82: \t}\n83: \n84: \tsessionID := h.extractSessionID(c)\n85: \n86: \tsandboxInfo, err := h.sessionManager.GetSandboxBySession(c.Request.Context(), sessionID, namespace, name, kind)\n87: \tif err != nil {\n88: \t\tif _, ok := err.(*SandboxNotFoundError); ok {\n89: \t\t\tsessionID, sandboxInfo, err = h.sessionManager.CreateSession(c.Request.Context(), name, namespace, kind)\n90: \t\t\tif err != nil {\n91: \t\t\t\tklog.Warningf(\"Failed to create session: %v\", err)\n92: \t\t\t\tc.JSON(GetHTTPStatusCode(err), NewErrorResponse(err.Error(), GetErrorCode(err)))\n93: \t\t\t\treturn\n94: \t\t\t}\n95: \t\t} else {\n96: \t\t\tklog.Warningf(\"Failed to get sandbox: %v\", err)\n97: \t\t\tc.JSON(GetHTTPStatusCode(err), NewErrorResponse(err.Error(), GetErrorCode(err)))\n98: \t\t\treturn\n99: \t\t}\n100: \t}\n101: \n102: \tif path != \"\" {\n103: \t\tc.Request.URL.Path = \"/\" + path\n104: \t}\n105: \n106: \tc.Header(\"X-Agentcube-Session-ID\", sessionID)\n107: \tc.Request.URL.Path = sanitizePath(c.Request.URL.Path)\n108: \n109: \th.reverseProxy.ServeHTTP(c.Writer, c.Request, sandboxInfo)\n110: }\n111: \n112: func (h *Handler) extractSessionID(c *gin.Context) string {\n113: \tsessionID := c.GetHeader(\"X-Agentcube-Session-ID\")\n114: \tif sessionID != \"\" {\n115: \t\tif err := parseSessionID(sessionID); err == nil {\n116: \t\t\treturn sessionID\n117: \t\t}\n118: \t}\n119: \n120: \treturn uuid.New().String()\n121: }\n122: \n123: func (h *Handler) generateSessionID() string {\n124: \treturn uuid.New().String()\n125: }\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype Handler struct {\n\tsessionManager SessionManager\n\tjwtManager     *JWTManager\n\treverseProxy   *ReverseProxy\n}\n\nfunc NewHandler(sessionManager SessionManager, jwtManager *JWTManager, reverseProxy *ReverseProxy) *Handler {\n\treturn &Handler{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go","time":{"start":1775849894020,"end":1775849894037}}}}
{"type":"tool_use","timestamp":1775849894040,"sessionID":"ses_28719b16dffecOLQtjnU5U7KHJ","part":{"id":"prt_d78e6edff001tjTlma8dEajj8q","messageID":"msg_d78e6e18c001uTzfeyEhTcuP4f","sessionID":"ses_28719b16dffecOLQtjnU5U7KHJ","type":"tool","tool":"read","callID":"toolu_tool-1f06442311f34ef1904a092d1b52af73","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/utils.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/utils.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"net/url\"\n6: \t\"regexp\"\n7: \t\"strings\"\n8: \t\"time\"\n9: \n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: \t\"k8s.io/apimachinery/pkg/util/validation\"\n12: )\n13: \n14: const (\n15: \tsessionTTL = 5 * time.Minute\n16: )\n17: \n18: var (\n19: \tnamespaceRegex    = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)\n20: \tresourceNameRegex = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)\n21: \tsessionIDRegex    = regexp.MustCompile(`^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$`)\n22: )\n23: \n24: func isValidNamespace(namespace string) bool {\n25: \tif namespace == \"\" {\n26: \t\treturn false\n27: \t}\n28: \tif len(namespace) > 63 {\n29: \t\treturn false\n30: \t}\n31: \treturn namespaceRegex.MatchString(namespace)\n32: }\n33: \n34: func isValidResourceName(name string) bool {\n35: \tif name == \"\" {\n36: \t\treturn false\n37: \t}\n38: \tif len(name) > 253 {\n39: \t\treturn false\n40: \t}\n41: \treturn resourceNameRegex.MatchString(name)\n42: }\n43: \n44: func sanitizePath(path string) string {\n45: \tcleanPath := strings.TrimSpace(path)\n46: \tcleanPath = strings.ReplaceAll(cleanPath, \"..\", \"\")\n47: \tcleanPath = strings.ReplaceAll(cleanPath, \"\\\\\", \"\")\n48: \n49: \tif !strings.HasPrefix(cleanPath, \"/\") {\n50: \t\tcleanPath = \"/\" + cleanPath\n51: \t}\n52: \n53: \treturn cleanPath\n54: }\n55: \n56: func normalizeURL(rawURL string) (string, error) {\n57: \tparsed, err := url.Parse(rawURL)\n58: \tif err != nil {\n59: \t\treturn \"\", err\n60: \t}\n61: \n62: \tparsed.Path = sanitizePath(parsed.Path)\n63: \n64: \treturn parsed.String(), nil\n65: }\n66: \n67: func parseSessionID(sessionID string) error {\n68: \tif sessionID == \"\" {\n69: \t\treturn fmt.Errorf(\"session ID is required\")\n70: \t}\n71: \n72: \tif !sessionIDRegex.MatchString(sessionID) {\n73: \t\treturn fmt.Errorf(\"invalid session ID format\")\n74: \t}\n75: \n76: \treturn nil\n77: }\n78: \n79: func validateKind(kind string) error {\n80: \tif kind != types.AgentRuntimeKind && kind != types.CodeInterpreterKind {\n81: \t\treturn fmt.Errorf(\"invalid kind: %s, must be %s or %s\", kind, types.AgentRuntimeKind, types.CodeInterpreterKind)\n82: \t}\n83: \treturn nil\n84: }\n85: \n86: func generateCacheKey(sessionID, namespace, name, kind string) string {\n87: \treturn fmt.Sprintf(\"session:%s:%s:%s:%s\", namespace, kind, name, sessionID)\n88: }\n89: \n90: func isHopByHopHeader(header string) bool {\n91: \thopByHopHeaders := []string{\n92: \t\t\"Connection\",\n93: \t\t\"Keep-Alive\",\n94: \t\t\"Proxy-Authenticate\",\n95: \t\t\"Proxy-Authorization\",\n96: \t\t\"Te\",\n97: \t\t\"Trailers\",\n98: \t\t\"Transfer-Encoding\",\n99: \t\t\"Upgrade\",\n100: \t}\n101: \n102: \tfor _, h := range hopByHopHeaders {\n103: \t\tif strings.EqualFold(header, h) {\n104: \t\t\treturn true\n105: \t\t}\n106: \t}\n107: \treturn false\n108: }\n109: \n110: func constructUpstreamURL(protocol, endpoint string) string {\n111: \tif strings.Contains(endpoint, \"://\") {\n112: \t\treturn endpoint\n113: \t}\n114: \n115: \tif protocol == \"\" {\n116: \t\tprotocol = \"http\"\n117: \t}\n118: \n119: \tif !strings.HasPrefix(endpoint, \"http://\") && !strings.HasPrefix(endpoint, \"https://\") {\n120: \t\tendpoint = fmt.Sprintf(\"%s://%s\", protocol, endpoint)\n121: \t}\n122: \n123: \treturn endpoint\n124: }\n125: \n126: func findMatchingEntryPoint(requestPath string, entryPoints []types.SandboxEntryPoint) *types.SandboxEntryPoint {\n127: \tif len(entryPoints) == 0 {\n128: \t\treturn nil\n129: \t}\n130: \n131: \tfor _, ep := range entryPoints {\n132: \t\tif strings.HasPrefix(requestPath, ep.Path) {\n133: \t\t\treturn &ep\n134: \t\t}\n135: \t}\n136: \n137: \tfor _, ep := range entryPoints {\n138: \t\tif ep.Path == \"/\" || ep.Path == \"\" {\n139: \t\t\treturn &ep\n140: \t\t}\n141: \t}\n142: \n143: \treturn &entryPoints[0]\n144: }\n145: \n146: func getK8sValidation(field string) bool {\n147: \terrs := validation.IsDNS1123Label(field)\n148: \treturn len(errs) == 0\n149: }\n\n(End of file - total 149 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"regexp\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/apimachinery/pkg/util/validation\"\n)\n\nconst (\n\tsessionTTL = 5 * time.Minute\n)\n\nvar (\n\tnamespaceRegex    = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)\n\tresourceNameRegex = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/utils.go","time":{"start":1775849894024,"end":1775849894039}}}}
