{"type":"tool_use","timestamp":1775849759705,"sessionID":"ses_2871baca0ffejE15ebsxkZPstG","part":{"id":"prt_d78e4e108001oznws1IM4tHItr","messageID":"msg_d78e4b8c50019rF8z5knx20NC3","sessionID":"ses_2871baca0ffejE15ebsxkZPstG","type":"tool","tool":"read","callID":"toolu_tool-10e497f8c71f4ad69ae8a6e83d5a1d97","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"net/http\"\n5: \n6: \t\"github.com/gin-gonic/gin\"\n7: \t\"github.com/google/uuid\"\n8: \t\"k8s.io/klog/v2\"\n9: \n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: type Handler struct {\n14: \tsessionManager SessionManager\n15: \tjwtManager     *JWTManager\n16: \treverseProxy   *ReverseProxy\n17: }\n18: \n19: func NewHandler(sessionManager SessionManager, jwtManager *JWTManager, reverseProxy *ReverseProxy) *Handler {\n20: \treturn &Handler{\n21: \t\tsessionManager: sessionManager,\n22: \t\tjwtManager:     jwtManager,\n23: \t\treverseProxy:   reverseProxy,\n24: \t}\n25: }\n26: \n27: func (h *Handler) handleHealthLive(c *gin.Context) {\n28: \tc.JSON(http.StatusOK, gin.H{\n29: \t\t\"status\": \"alive\",\n30: \t})\n31: }\n32: \n33: func (h *Handler) handleHealthReady(c *gin.Context) {\n34: \tif h.sessionManager == nil {\n35: \t\tc.JSON(http.StatusServiceUnavailable, NewErrorResponse(\n36: \t\t\t\"session manager not available\",\n37: \t\t\tErrSessionManagerNotReady,\n38: \t\t))\n39: \t\treturn\n40: \t}\n41: \n42: \tif h.jwtManager == nil {\n43: \t\tc.JSON(http.StatusServiceUnavailable, NewErrorResponse(\n44: \t\t\t\"JWT manager not available\",\n45: \t\t\t\"JWT_MANAGER_NOT_READY\",\n46: \t\t))\n47: \t\treturn\n48: \t}\n49: \n50: \tc.JSON(http.StatusOK, gin.H{\n51: \t\t\"status\": \"ready\",\n52: \t})\n53: }\n54: \n55: func (h *Handler) handleAgentInvoke(c *gin.Context) {\n56: \th.handleInvocation(c, types.AgentRuntimeKind)\n57: }\n58: \n59: func (h *Handler) handleCodeInterpreterInvoke(c *gin.Context) {\n60: \th.handleInvocation(c, types.CodeInterpreterKind)\n61: }\n62: \n63: func (h *Handler) handleInvocation(c *gin.Context, kind string) {\n64: \tnamespace := c.Param(\"namespace\")\n65: \tname := c.Param(\"name\")\n66: \tpath := c.Param(\"path\")\n67: \n68: \tif !isValidNamespace(namespace) {\n69: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n70: \t\t\t\"invalid namespace format\",\n71: \t\t\tGetErrorCode(&ValidationError{Field: \"namespace\"}),\n72: \t\t))\n73: \t\treturn\n74: \t}\n75: \n76: \tif !isValidResourceName(name) {\n77: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n78: \t\t\t\"invalid resource name format\",\n79: \t\t\tGetErrorCode(&ValidationError{Field: \"name\"}),\n80: \t\t))\n81: \t\treturn\n82: \t}\n83: \n84: \tsessionID := h.extractSessionID(c)\n85: \n86: \tsandboxInfo, err := h.sessionManager.GetSandboxBySession(c.Request.Context(), sessionID, namespace, name, kind)\n87: \tif err != nil {\n88: \t\tif _, ok := err.(*SandboxNotFoundError); ok {\n89: \t\t\tsessionID, sandboxInfo, err = h.sessionManager.CreateSession(c.Request.Context(), name, namespace, kind)\n90: \t\t\tif err != nil {\n91: \t\t\t\tklog.Warningf(\"Failed to create session: %v\", err)\n92: \t\t\t\tc.JSON(GetHTTPStatusCode(err), NewErrorResponse(err.Error(), GetErrorCode(err)))\n93: \t\t\t\treturn\n94: \t\t\t}\n95: \t\t} else {\n96: \t\t\tklog.Warningf(\"Failed to get sandbox: %v\", err)\n97: \t\t\tc.JSON(GetHTTPStatusCode(err), NewErrorResponse(err.Error(), GetErrorCode(err)))\n98: \t\t\treturn\n99: \t\t}\n100: \t}\n101: \n102: \tif path != \"\" {\n103: \t\tc.Request.URL.Path = \"/\" + path\n104: \t}\n105: \n106: \tc.Header(\"X-Agentcube-Session-ID\", sessionID)\n107: \tc.Request.URL.Path = sanitizePath(c.Request.URL.Path)\n108: \n109: \th.reverseProxy.ServeHTTP(c.Writer, c.Request, sandboxInfo)\n110: }\n111: \n112: func (h *Handler) extractSessionID(c *gin.Context) string {\n113: \tsessionID := c.GetHeader(\"X-Agentcube-Session-ID\")\n114: \tif sessionID != \"\" {\n115: \t\tif err := parseSessionID(sessionID); err == nil {\n116: \t\t\treturn sessionID\n117: \t\t}\n118: \t}\n119: \n120: \treturn uuid.New().String()\n121: }\n122: \n123: func (h *Handler) generateSessionID() string {\n124: \treturn uuid.New().String()\n125: }\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype Handler struct {\n\tsessionManager SessionManager\n\tjwtManager     *JWTManager\n\treverseProxy   *ReverseProxy\n}\n\nfunc NewHandler(sessionManager SessionManager, jwtManager *JWTManager, reverseProxy *ReverseProxy) *Handler {\n\treturn &Handler{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go","time":{"start":1775849759692,"end":1775849759704}}}}
{"type":"tool_use","timestamp":1775849759707,"sessionID":"ses_2871baca0ffejE15ebsxkZPstG","part":{"id":"prt_d78e4de7f001AzXG3Q6CDF72RY","messageID":"msg_d78e4b8c50019rF8z5knx20NC3","sessionID":"ses_2871baca0ffejE15ebsxkZPstG","type":"tool","tool":"read","callID":"toolu_tool-2a3b9398b107474987a9a7cca025b336","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net\"\n7: \t\"net/http\"\n8: \t\"sync\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"k8s.io/client-go/kubernetes\"\n13: \t\"k8s.io/klog/v2\"\n14: \n15: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n16: )\n17: \n18: type Server struct {\n19: \tconfig         *Config\n20: \tengine         *gin.Engine\n21: \thttpServer     *http.Server\n22: \tsessionManager SessionManager\n23: \tstoreClient    store.Store\n24: \thttpTransport  *http.Transport\n25: \tjwtManager     *JWTManager\n26: \thandler        *Handler\n27: \tlimiter        *ConcurrencyLimiter\n28: \tmetrics        *Metrics\n29: \tmu             sync.RWMutex\n30: }\n31: \n32: func NewServer(cfg *Config, storeClient store.Store, clientset kubernetes.Interface) (*Server, error) {\n33: \tif err := cfg.Validate(); err != nil {\n34: \t\treturn nil, fmt.Errorf(\"invalid configuration: %w\", err)\n35: \t}\n36: \n37: \tif cfg.Debug {\n38: \t\tgin.SetMode(gin.DebugMode)\n39: \t} else {\n40: \t\tgin.SetMode(gin.ReleaseMode)\n41: \t}\n42: \n43: \ts := &Server{\n44: \t\tconfig:        cfg,\n45: \t\tstoreClient:   storeClient,\n46: \t\thttpTransport: configureHTTPTransport(),\n47: \t\tlimiter:       NewConcurrencyLimiter(cfg.MaxConcurrentRequests),\n48: \t\tmetrics:       NewMetrics(),\n49: \t}\n50: \n51: \tif err := s.initializeSessionManager(); err != nil {\n52: \t\treturn nil, fmt.Errorf(\"failed to initialize session manager: %w\", err)\n53: \t}\n54: \n55: \tif err := s.initializeJWTManager(clientset); err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to initialize JWT manager: %w\", err)\n57: \t}\n58: \n59: \ts.handler = NewHandler(s.sessionManager, s.jwtManager, NewReverseProxy(s.jwtManager))\n60: \n61: \ts.engine = gin.New()\n62: \n63: \ts.applyMiddleware()\n64: \n65: \ts.setupRoutes()\n66: \n67: \ts.httpServer = &http.Server{\n68: \t\tAddr:         \":\" + s.config.Port,\n69: \t\tHandler:      s.engine,\n70: \t\tReadTimeout:  time.Duration(s.config.ReadTimeout) * time.Second,\n71: \t\tWriteTimeout: time.Duration(s.config.WriteTimeout) * time.Second,\n72: \t\tIdleTimeout:  time.Duration(s.config.IdleTimeout) * time.Second,\n73: \t}\n74: \n75: \treturn s, nil\n76: }\n77: \n78: func (s *Server) initializeSessionManager() error {\n79: \tsessionManager, err := NewSessionManager(s.storeClient, s.config.WorkloadManagerURL)\n80: \tif err != nil {\n81: \t\treturn err\n82: \t}\n83: \n84: \ts.sessionManager = sessionManager\n85: \treturn nil\n86: }\n87: \n88: func (s *Server) initializeJWTManager(clientset kubernetes.Interface) error {\n89: \tif clientset == nil {\n90: \t\tklog.Warning(\"Kubernetes clientset not provided, JWT manager will not be fully functional\")\n91: \t\ts.jwtManager = &JWTManager{}\n92: \t\treturn nil\n93: \t}\n94: \n95: \tjwtManager, err := NewJWTManager(clientset, s.config.AgentcubeNamespace)\n96: \tif err != nil {\n97: \t\treturn err\n98: \t}\n99: \n100: \ts.jwtManager = jwtManager\n101: \treturn nil\n102: }\n103: \n104: func (s *Server) applyMiddleware() {\n105: \ts.engine.Use(recoveryMiddleware())\n106: \ts.engine.Use(loggingMiddleware())\n107: \ts.engine.Use(correlationIDMiddleware())\n108: \ts.engine.Use(concurrencyLimitMiddleware(s.limiter))\n109: \ts.engine.Use(metricsMiddleware(s.metrics))\n110: }\n111: \n112: func (s *Server) setupRoutes() {\n113: \ts.engine.GET(\"/health/live\", s.handler.handleHealthLive)\n114: \ts.engine.GET(\"/health/ready\", s.handler.handleHealthReady)\n115: \n116: \tv1 := s.engine.Group(\"/v1\")\n117: \t{\n118: \t\tnamespaces := v1.Group(\"/namespaces/:namespace\")\n119: \t\t{\n120: \t\t\tagentRuntimes := namespaces.Group(\"/agent-runtimes/:name\")\n121: \t\t\t{\n122: \t\t\t\tagentRuntimes.Any(\"/invocations/*path\", s.handler.handleAgentInvoke)\n123: \t\t\t}\n124: \n125: \t\t\tcodeInterpreters := namespaces.Group(\"/code-interpreters/:name\")\n126: \t\t\t{\n127: \t\t\t\tcodeInterpreters.Any(\"/invocations/*path\", s.handler.handleCodeInterpreterInvoke)\n128: \t\t\t}\n129: \t\t}\n130: \t}\n131: }\n132: \n133: func (s *Server) Start(ctx context.Context) error {\n134: \tlistener, err := net.Listen(\"tcp\", s.httpServer.Addr)\n135: \tif err != nil {\n136: \t\treturn fmt.Errorf(\"failed to listen on %s: %w\", s.httpServer.Addr, err)\n137: \t}\n138: \n139: \tklog.Infof(\"Starting HTTP server on %s\", s.httpServer.Addr)\n140: \tklog.Infof(\"TLS enabled: %v\", s.config.EnableTLS)\n141: \tklog.Infof(\"Max concurrent requests: %d\", s.config.MaxConcurrentRequests)\n142: \n143: \terrChan := make(chan error, 1)\n144: \n145: \tgo func() {\n146: \t\tif s.config.EnableTLS {\n147: \t\t\terrChan <- s.httpServer.ServeTLS(listener, s.config.TLSCert, s.config.TLSKey)\n148: \t\t} else {\n149: \t\t\terrChan <- s.httpServer.Serve(listener)\n150: \t\t}\n151: \t}()\n152: \n153: \tselect {\n154: \tcase err := <-errChan:\n155: \t\tif err != nil && err != http.ErrServerClosed {\n156: \t\t\treturn fmt.Errorf(\"server error: %w\", err)\n157: \t\t}\n158: \t\treturn err\n159: \tcase <-ctx.Done():\n160: \t\treturn s.Shutdown(ctx)\n161: \t}\n162: }\n163: \n164: func (s *Server) Shutdown(ctx context.Context) error {\n165: \tklog.Info(\"Shutting down HTTP server...\")\n166: \n167: \tshutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n168: \tdefer cancel()\n169: \n170: \tif err := s.httpServer.Shutdown(shutdownCtx); err != nil {\n171: \t\tklog.Warningf(\"Error during server shutdown: %v\", err)\n172: \t\treturn err\n173: \t}\n174: \n175: \tklog.Info(\"HTTP server stopped\")\n176: \n177: \treturn nil\n178: }\n179: \n180: func (s *Server) GetMetrics() *Metrics {\n181: \treturn s.metrics\n182: }\n183: \n184: func (s *Server) GetActiveConnections() int {\n185: \treturn s.limiter.semaphoreLen()\n186: }\n187: \n188: func (l *ConcurrencyLimiter) semaphoreLen() int {\n189: \treturn len(l.semaphore)\n190: }\n\n(End of file - total 190 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go","time":{"start":1775849759690,"end":1775849759706}}}}
