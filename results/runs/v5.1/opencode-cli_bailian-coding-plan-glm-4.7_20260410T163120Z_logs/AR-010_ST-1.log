pencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/doc.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/validation_test.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/validation.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/constants_test.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/constants.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/deepcopy.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/register.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types.go","metadata":{"count":66,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z","time":{"start":1775849730864,"end":1775849730882}}}}
