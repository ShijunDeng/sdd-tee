{"type":"tool_use","timestamp":1775860543719,"sessionID":"ses_286770cfaffeR29vjcgpE3XaCv","part":{"id":"prt_d798970dc0018Dru55CMGLXcKG","messageID":"msg_d79895748001WL6nd1FB5NFP81","sessionID":"ses_286770cfaffeR29vjcgpE3XaCv","type":"tool","tool":"read","callID":"toolu_tool-1e5179f10971429181e5fbc9f50fab25","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/auth_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/auth_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"crypto/rand\"\n5: \t\"crypto/rsa\"\n6: \t\"crypto/x509\"\n7: \t\"encoding/pem\"\n8: \t\"os\"\n9: \t\"testing\"\n10: \t\"time\"\n11: \n12: \t\"github.com/golang-jwt/jwt/v5\"\n13: \t\"github.com/stretchr/testify/assert\"\n14: \t\"github.com/stretchr/testify/require\"\n15: )\n16: \n17: func generateTestKeyPair(t *testing.T) (*rsa.PrivateKey, *rsa.PublicKey) {\n18: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n19: \trequire.NoError(t, err)\n20: \treturn privateKey, &privateKey.PublicKey\n21: }\n22: \n23: func publicKeyToPEM(t *testing.T, publicKey *rsa.PublicKey) string {\n24: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n25: \trequire.NoError(t, err)\n26: \n27: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n28: \t\tType:  \"PUBLIC KEY\",\n29: \t\tBytes: publicKeyBytes,\n30: \t})\n31: \n32: \treturn string(publicKeyPEM)\n33: }\n34: \n35: func createTestToken(t *testing.T, privateKey *rsa.PrivateKey) string {\n36: \tclaims := AuthClaims{\n37: \t\tRegisteredClaims: jwt.RegisteredClaims{\n38: \t\t\tIssuedAt:  jwt.NewNumericDate(time.Now()),\n39: \t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),\n40: \t\t},\n41: \t}\n42: \n43: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n44: \ttokenString, err := token.SignedString(privateKey)\n45: \trequire.NoError(t, err)\n46: \n47: \treturn tokenString\n48: }\n49: \n50: func TestNewAuthManager(t *testing.T) {\n51: \t_, publicKey := generateTestKeyPair(t)\n52: \tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n53: \n54: \ttests := []struct {\n55: \t\tname     string\n56: \t\tsetupEnv func()\n57: \t\twantErr  bool\n58: \t\terrMsg   string\n59: \t\tcleanup  func()\n60: \t}{\n61: \t\t{\n62: \t\t\tname: \"success with valid public key\",\n63: \t\t\tsetupEnv: func() {\n64: \t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n65: \t\t\t},\n66: \t\t\twantErr: false,\n67: \t\t\tcleanup: func() {\n68: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n69: \t\t\t},\n70: \t\t},\n71: \t\t{\n72: \t\t\tname: \"error when public key not set\",\n73: \t\t\tsetupEnv: func() {\n74: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n75: \t\t\t},\n76: \t\t\twantErr: true,\n77: \t\t\terrMsg:  \"public key not found\",\n78: \t\t\tcleanup: func() {\n79: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n80: \t\t\t},\n81: \t\t},\n82: \t\t{\n83: \t\t\tname: \"error with invalid PEM format\",\n84: \t\t\tsetupEnv: func() {\n85: \t\t\t\tos.Setenv(PublicKeyEnvVar, \"invalid pem\")\n86: \t\t\t},\n87: \t\t\twantErr: true,\n88: \t\t\terrMsg:  \"invalid PEM format\",\n89: \t\t\tcleanup: func() {\n90: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n91: \t\t\t},\n92: \t\t},\n93: \t}\n94: \n95: \tfor _, tt := range tests {\n96: \t\tt.Run(tt.name, func(t *testing.T) {\n97: \t\t\ttt.setupEnv()\n98: \t\t\tdefer tt.cleanup()\n99: \n100: \t\t\tam, err := NewAuthManager()\n101: \n102: \t\t\tif tt.wantErr {\n103: \t\t\t\tassert.Error(t, err)\n104: \t\t\t\tassert.Nil(t, am)\n105: \t\t\t\tif tt.errMsg != \"\" {\n106: \t\t\t\t\tassert.Contains(t, err.Error(), tt.errMsg)\n107: \t\t\t\t}\n108: \t\t\t} else {\n109: \t\t\t\tassert.NoError(t, err)\n110: \t\t\t\tassert.NotNil(t, am)\n111: \t\t\t\tassert.NotNil(t, am.publicKey)\n112: \t\t\t}\n113: \t\t})\n114: \t}\n115: }\n116: \n117: func TestValidateToken(t *testing.T) {\n118: \tprivateKey, publicKey := generateTestKeyPair(t)\n119: \tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n120: \n121: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n122: \tdefer os.Unsetenv(PublicKeyEnvVar)\n123: \n124: \tam, err := NewAuthManager()\n125: \trequire.NoError(t, err)\n126: \n127: \tvalidToken := createTestToken(t, privateKey)\n128: \n129: \texpiredClaims := AuthClaims{\n130: \t\tRegisteredClaims: jwt.RegisteredClaims{\n131: \t\t\tIssuedAt:  jwt.NewNumericDate(time.Now().Add(-2 * time.Hour)),\n132: \t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(-1 * time.Hour)),\n133: \t\t},\n134: \t}\n135: \texpiredToken := jwt.NewWithClaims(jwt.SigningMethodRS256, expiredClaims)\n136: \texpiredTokenString, _ := expiredToken.SignedString(privateKey)\n137: \n138: \ttests := []struct {\n139: \t\tname        string\n140: \t\ttoken       string\n141: \t\twantErr     bool\n142: \t\terrContains string\n143: \t}{\n144: \t\t{\n145: \t\t\tname:    \"valid token\",\n146: \t\t\ttoken:   validToken,\n147: \t\t\twantErr: false,\n148: \t\t},\n149: \t\t{\n150: \t\t\tname:        \"invalid token format\",\n151: \t\t\ttoken:       \"invalid.token.string\",\n152: \t\t\twantErr:     true,\n153: \t\t\terrContains: \"invalid token\",\n154: \t\t},\n155: \t\t{\n156: \t\t\tname:        \"expired token\",\n157: \t\t\ttoken:       expiredTokenString,\n158: \t\t\twantErr:     true,\n159: \t\t\terrContains: \"expired\",\n160: \t\t},\n161: \t\t{\n162: \t\t\tname:        \"empty token\",\n163: \t\t\ttoken:       \"\",\n164: \t\t\twantErr:     true,\n165: \t\t\terrContains: \"invalid token\",\n166: \t\t},\n167: \t}\n168: \n169: \tfor _, tt := range tests {\n170: \t\tt.Run(tt.name, func(t *testing.T) {\n171: \t\t\tclaims, err := am.ValidateToken(tt.token)\n172: \n173: \t\t\tif tt.wantErr {\n174: \t\t\t\tassert.Error(t, err)\n175: \t\t\t\tassert.Nil(t, claims)\n176: \t\t\t\tif tt.errContains != \"\" {\n177: \t\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n178: \t\t\t\t}\n179: \t\t\t} else {\n180: \t\t\t\tassert.NoError(t, err)\n181: \t\t\t\tassert.NotNil(t, claims)\n182: \t\t\t}\n183: \t\t})\n184: \t}\n185: }\n\n(End of file - total 185 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc generateTestKeyPair(t *testing.T) (*rsa.PrivateKey, *rsa.PublicKey) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\treturn privateKey, &privateKey.PublicKey","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/auth_test.go","time":{"start":1775860543710,"end":1775860543716}}}}
