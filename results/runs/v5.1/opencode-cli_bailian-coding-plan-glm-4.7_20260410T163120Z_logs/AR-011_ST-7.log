{"type":"tool_use","timestamp":1775852561991,"sessionID":"ses_286f0e191ffefhAfcDY3aVnFTa","part":{"id":"prt_d790fa3ca0019OZFY7Fdzsw6Js","messageID":"msg_d790f8b68001sr4DQU51ylRI7Y","sessionID":"ses_286f0e191ffefhAfcDY3aVnFTa","type":"tool","tool":"read","callID":"toolu_tool-bae877d3e5cb487aa3d19319de33fed2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"net/http\"\n5: \n6: \t\"github.com/gin-gonic/gin\"\n7: \t\"github.com/google/uuid\"\n8: \t\"k8s.io/klog/v2\"\n9: \n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: type Handler struct {\n14: \tsessionManager SessionManager\n15: \tjwtManager     *JWTManager\n16: \treverseProxy   *ReverseProxy\n17: }\n18: \n19: func NewHandler(sessionManager SessionManager, jwtManager *JWTManager, reverseProxy *ReverseProxy) *Handler {\n20: \treturn &Handler{\n21: \t\tsessionManager: sessionManager,\n22: \t\tjwtManager:     jwtManager,\n23: \t\treverseProxy:   reverseProxy,\n24: \t}\n25: }\n26: \n27: func (h *Handler) handleHealthLive(c *gin.Context) {\n28: \tc.JSON(http.StatusOK, gin.H{\n29: \t\t\"status\": \"alive\",\n30: \t})\n31: }\n32: \n33: func (h *Handler) handleHealthReady(c *gin.Context) {\n34: \tif h.sessionManager == nil {\n35: \t\tc.JSON(http.StatusServiceUnavailable, NewErrorResponse(\n36: \t\t\t\"session manager not available\",\n37: \t\t\tErrSessionManagerNotReady,\n38: \t\t))\n39: \t\treturn\n40: \t}\n41: \n42: \tif h.jwtManager == nil {\n43: \t\tc.JSON(http.StatusServiceUnavailable, NewErrorResponse(\n44: \t\t\t\"JWT manager not available\",\n45: \t\t\t\"JWT_MANAGER_NOT_READY\",\n46: \t\t))\n47: \t\treturn\n48: \t}\n49: \n50: \tc.JSON(http.StatusOK, gin.H{\n51: \t\t\"status\": \"ready\",\n52: \t})\n53: }\n54: \n55: func (h *Handler) handleAgentInvoke(c *gin.Context) {\n56: \th.handleInvocation(c, types.AgentRuntimeKind)\n57: }\n58: \n59: func (h *Handler) handleCodeInterpreterInvoke(c *gin.Context) {\n60: \th.handleInvocation(c, types.CodeInterpreterKind)\n61: }\n62: \n63: func (h *Handler) handleInvocation(c *gin.Context, kind string) {\n64: \tnamespace := c.Param(\"namespace\")\n65: \tname := c.Param(\"name\")\n66: \tpath := c.Param(\"path\")\n67: \n68: \tif !isValidNamespace(namespace) {\n69: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n70: \t\t\t\"invalid namespace format\",\n71: \t\t\tGetErrorCode(&ValidationError{Field: \"namespace\"}),\n72: \t\t))\n73: \t\treturn\n74: \t}\n75: \n76: \tif !isValidResourceName(name) {\n77: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n78: \t\t\t\"invalid resource name format\",\n79: \t\t\tGetErrorCode(&ValidationError{Field: \"name\"}),\n80: \t\t))\n81: \t\treturn\n82: \t}\n83: \n84: \tsessionID := h.extractSessionID(c)\n85: \n86: \tsandboxInfo, err := h.sessionManager.GetSandboxBySession(c.Request.Context(), sessionID, namespace, name, kind)\n87: \tif err != nil {\n88: \t\tif _, ok := err.(*SandboxNotFoundError); ok {\n89: \t\t\tsessionID, sandboxInfo, err = h.sessionManager.CreateSession(c.Request.Context(), name, namespace, kind)\n90: \t\t\tif err != nil {\n91: \t\t\t\tklog.Warningf(\"Failed to create session: %v\", err)\n92: \t\t\t\tc.JSON(GetHTTPStatusCode(err), NewErrorResponse(err.Error(), GetErrorCode(err)))\n93: \t\t\t\treturn\n94: \t\t\t}\n95: \t\t} else {\n96: \t\t\tklog.Warningf(\"Failed to get sandbox: %v\", err)\n97: \t\t\tc.JSON(GetHTTPStatusCode(err), NewErrorResponse(err.Error(), GetErrorCode(err)))\n98: \t\t\treturn\n99: \t\t}\n100: \t}\n101: \n102: \tif path != \"\" {\n103: \t\tc.Request.URL.Path = \"/\" + path\n104: \t}\n105: \n106: \tc.Header(\"X-Agentcube-Session-ID\", sessionID)\n107: \tc.Request.URL.Path = sanitizePath(c.Request.URL.Path)\n108: \n109: \th.reverseProxy.ServeHTTP(c.Writer, c.Request, sandboxInfo)\n110: }\n111: \n112: func (h *Handler) extractSessionID(c *gin.Context) string {\n113: \tsessionID := c.GetHeader(\"X-Agentcube-Session-ID\")\n114: \tif sessionID != \"\" {\n115: \t\tif err := parseSessionID(sessionID); err == nil {\n116: \t\t\treturn sessionID\n117: \t\t}\n118: \t}\n119: \n120: \treturn uuid.New().String()\n121: }\n122: \n123: func (h *Handler) generateSessionID() string {\n124: \treturn uuid.New().String()\n125: }\n126: \n127: func (h *Handler) handleCreateSession(c *gin.Context) {\n128: \tkind := c.Param(\"kind\")\n129: \tnamespace := c.Param(\"namespace\")\n130: \tname := c.Param(\"name\")\n131: \n132: \tif kind != \"agent-runtimes\" && kind != \"code-interpreters\" {\n133: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n134: \t\t\t\"invalid kind, must be agent-runtimes or code-interpreters\",\n135: \t\t\t\"INVALID_KIND\",\n136: \t\t))\n137: \t\treturn\n138: \t}\n139: \n140: \tkindType := types.AgentRuntimeKind\n141: \tif kind == \"code-interpreters\" {\n142: \t\tkindType = types.CodeInterpreterKind\n143: \t}\n144: \n145: \tif !isValidNamespace(namespace) {\n146: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n147: \t\t\t\"invalid namespace format\",\n148: \t\t\t\"VALIDATION_ERROR\",\n149: \t\t))\n150: \t\treturn\n151: \t}\n152: \n153: \tif !isValidResourceName(name) {\n154: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n155: \t\t\t\"invalid resource name format\",\n156: \t\t\t\"VALIDATION_ERROR\",\n157: \t\t))\n158: \t\treturn\n159: \t}\n160: \n161: \tsessionID, sandboxInfo, err := h.sessionManager.CreateSession(c.Request.Context(), name, namespace, kindType)\n162: \tif err != nil {\n163: \t\tklog.Warningf(\"Failed to create session: %v\", err)\n164: \t\tc.JSON(GetHTTPStatusCode(err), NewErrorResponse(err.Error(), GetErrorCode(err)))\n165: \t\treturn\n166: \t}\n167: \n168: \ttoken, err := h.jwtManager.GenerateToken(sessionID)\n169: \tif err != nil {\n170: \t\tklog.Warningf(\"Failed to generate JWT token: %v\", err)\n171: \t\tc.JSON(http.StatusInternalServerError, NewErrorResponse(\n172: \t\t\t\"failed to generate authentication token\",\n173: \t\t\t\"JWT_SIGNING_FAILED\",\n174: \t\t))\n175: \t\treturn\n176: \t}\n177: \n178: \tresponse := &CreateSessionResponse{\n179: \t\tSessionID:   sessionID,\n180: \t\tSandboxID:   sandboxInfo.SandboxID,\n181: \t\tSandboxName: sandboxInfo.SandboxName,\n182: \t\tToken:       token,\n183: \t\tEntryPoints: sandboxInfo.EntryPoints,\n184: \t}\n185: \n186: \tc.JSON(http.StatusOK, response)\n187: }\n188: \n189: func (h *Handler) handleGetSession(c *gin.Context) {\n190: \tsessionID := c.Param(\"sessionID\")\n191: \n192: \tif sessionID == \"\" {\n193: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n194: \t\t\t\"session ID is required\",\n195: \t\t\t\"VALIDATION_ERROR\",\n196: \t\t))\n197: \t\treturn\n198: \t}\n199: \n200: \tsessions, err := h.sessionManager.ListSessions(c.Request.Context())\n201: \tif err != nil {\n202: \t\tklog.Warningf(\"Failed to list sessions: %v\", err)\n203: \t\tc.JSON(http.StatusInternalServerError, NewErrorResponse(\n204: \t\t\t\"failed to retrieve sessions\",\n205: \t\t\t\"INTERNAL_ERROR\",\n206: \t\t))\n207: \t\treturn\n208: \t}\n209: \n210: \tfor _, session := range sessions {\n211: \t\tif session.SessionID == sessionID {\n212: \t\t\tc.JSON(http.StatusOK, session)\n213: \t\t\treturn\n214: \t\t}\n215: \t}\n216: \n217: \tc.JSON(http.StatusNotFound, NewErrorResponse(\n218: \t\t\"session not found\",\n219: \t\t\"SESSION_NOT_FOUND\",\n220: \t))\n221: }\n\n(End of file - total 221 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype Handler struct {\n\tsessionManager SessionManager\n\tjwtManager     *JWTManager\n\treverseProxy   *ReverseProxy\n}\n\nfunc NewHandler(sessionManager Sess