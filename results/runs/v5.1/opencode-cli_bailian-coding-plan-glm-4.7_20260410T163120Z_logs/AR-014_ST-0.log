{"type":"tool_use","timestamp":1775856796917,"sessionID":"ses_286b066a1ffeuIkVCINkfD0aS1","part":{"id":"prt_d795044c90011n3CpUgEVr7Igq","messageID":"msg_d79501a9d0013ORd8zR7iC1xv4","sessionID":"ses_286b066a1ffeuIkVCINkfD0aS1","type":"tool","tool":"read","callID":"toolu_tool-96799f7675e247f69a6a37490043fd73","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey_test.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"os\"\n6: \t\"testing\"\n7: \t\"time\"\n8: \n9: \t\"github.com/stretchr/testify/assert\"\n10: \t\"github.com/stretchr/testify/require\"\n11: \n12: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n13: )\n14: \n15: func TestValkeyStore(t *testing.T) {\n16: \tvalkeyAddr := os.Getenv(\"VALKEY_TEST_ADDR\")\n17: \tif valkeyAddr == \"\" {\n18: \t\tt.Skip(\"Skipping Valkey tests: VALKEY_TEST_ADDR not set\")\n19: \t}\n20: \n21: \tvalkeyPassword := os.Getenv(\"VALKEY_TEST_PASSWORD\")\n22: \n23: \tstore, err := newValkeyStore(valkeyAddr, valkeyPassword, 0)\n24: \trequire.NoError(t, err)\n25: \trequire.NotNil(t, store)\n26: \n27: \tdefer store.Close()\n28: \n29: \tctx := context.Background()\n30: \n31: \tt.Run(\"Ping\", func(t *testing.T) {\n32: \t\terr := store.Ping(ctx)\n33: \t\tassert.NoError(t, err)\n34: \t})\n35: \n36: \tt.Run(\"Store and Get Sandbox\", func(t *testing.T) {\n37: \t\tsessionID := \"valkey-test-session-1\"\n38: \t\tinfo := &types.SandboxInfo{\n39: \t\t\tSessionID:    sessionID,\n40: \t\t\tSandboxName:  \"test-sandbox\",\n41: \t\t\tWorkloadName: \"test-workload\",\n42: \t\t\tNamespace:    \"default\",\n43: \t\t\tKind:         \"AgentRuntime\",\n44: \t\t\tStatus:       \"running\",\n45: \t\t\tCreatedAt:    time.Now(),\n46: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n47: \t\t\tPodIP:        \"10.0.0.1\",\n48: \t\t}\n49: \n50: \t\terr := store.StoreSandbox(ctx, info)\n51: \t\trequire.NoError(t, err)\n52: \n53: \t\tretrieved, err := store.GetSandboxBySessionID(ctx, sessionID)\n54: \t\trequire.NoError(t, err)\n55: \t\tassert.Equal(t, sessionID, retrieved.SessionID)\n56: \t\tassert.Equal(t, \"test-sandbox\", retrieved.SandboxName)\n57: \t\tassert.Equal(t, \"AgentRuntime\", retrieved.Kind)\n58: \t})\n59: \n60: \tt.Run(\"Store Sandbox Nil\", func(t *testing.T) {\n61: \t\terr := store.StoreSandbox(ctx, nil)\n62: \t\tassert.Error(t, err)\n63: \t\tassert.Contains(t, err.Error(), \"cannot be nil\")\n64: \t})\n65: \n66: \tt.Run(\"Store Sandbox Empty SessionID\", func(t *testing.T) {\n67: \t\tinfo := &types.SandboxInfo{\n68: \t\t\tSandboxName: \"test-sandbox\",\n69: \t\t\tCreatedAt:   time.Now(),\n70: \t\t\tExpiresAt:   time.Now().Add(8 * time.Hour),\n71: \t\t}\n72: \n73: \t\terr := store.StoreSandbox(ctx, info)\n74: \t\tassert.Error(t, err)\n75: \t\tassert.Contains(t, err.Error(), \"session ID cannot be empty\")\n76: \t})\n77: \n78: \tt.Run(\"Store Sandbox Zero ExpiresAt\", func(t *testing.T) {\n79: \t\tinfo := &types.SandboxInfo{\n80: \t\t\tSessionID:   \"test-session\",\n81: \t\t\tSandboxName: \"test-sandbox\",\n82: \t\t\tCreatedAt:   time.Now(),\n83: \t\t}\n84: \n85: \t\terr := store.StoreSandbox(ctx, info)\n86: \t\tassert.Error(t, err)\n87: \t\tassert.Contains(t, err.Error(), \"expires at cannot be zero\")\n88: \t})\n89: \n90: \tt.Run(\"Get Non-Existent Sandbox\", func(t *testing.T) {\n91: \t\t_, err := store.GetSandboxBySessionID(ctx, \"valkey-non-existent\")\n92: \t\tassert.Error(t, err)\n93: \t\tassert.Equal(t, ErrNotFound, err)\n94: \t})\n95: \n96: \tt.Run(\"Update Sandbox\", func(t *testing.T) {\n97: \t\tsessionID := \"valkey-test-session-2\"\n98: \t\tinfo := &types.SandboxInfo{\n99: \t\t\tSessionID:    sessionID,\n100: \t\t\tSandboxName:  \"test-sandbox-2\",\n101: \t\t\tWorkloadName: \"test-workload\",\n102: \t\t\tNamespace:    \"default\",\n103: \t\t\tKind:         \"CodeInterpreter\",\n104: \t\t\tStatus:       \"pending\",\n105: \t\t\tCreatedAt:    time.Now(),\n106: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n107: \t\t}\n108: \n109: \t\terr := store.StoreSandbox(ctx, info)\n110: \t\trequire.NoError(t, err)\n111: \n112: \t\tinfo.Status = \"running\"\n113: \t\tinfo.PodIP = \"10.0.0.2\"\n114: \n115: \t\terr = store.UpdateSandbox(ctx, info)\n116: \t\trequire.NoError(t, err)\n117: \n118: \t\tretrieved, err := store.GetSandboxBySessionID(ctx, sessionID)\n119: \t\trequire.NoError(t, err)\n120: \t\tassert.Equal(t, \"running\", retrieved.Status)\n121: \t\tassert.Equal(t, \"10.0.0.2\", retrieved.PodIP)\n122: \t})\n123: \n124: \tt.Run(\"Update Non-Existent Sandbox\", func(t *testing.T) {\n125: \t\tinfo := &types.SandboxInfo{\n126: \t\t\tSessionID:   \"valkey-non-existent\",\n127: \t\t\tSandboxName: \"test-sandbox\",\n128: \t\t\tCreatedAt:   time.Now(),\n129: \t\t\tExpiresAt:   time.Now().Add(8 * time.Hour),\n130: \t\t}\n131: \n132: \t\terr := store.UpdateSandbox(ctx, info)\n133: \t\tassert.Error(t, err)\n134: \t\tassert.Equal(t, ErrNotFound, err)\n135: \t})\n136: \n137: \tt.Run(\"Update Sandbox Nil\", func(t *testing.T) {\n138: \t\terr := store.UpdateSandbox(ctx, nil)\n139: \t\tassert.Error(t, err)\n140: \t\tassert.Contains(t, err.Error(), \"cannot be nil\")\n141: \t})\n142: \n143: \tt.Run(\"Update Sandbox Empty SessionID\", func(t *testing.T) {\n144: \t\tinfo := &types.SandboxInfo{\n145: \t\t\tSandboxName: \"test-sandbox\",\n146: \t\t\tCreatedAt:   time.Now(),\n147: \t\t\tExpiresAt:   time.Now().Add(8 * time.Hour),\n148: \t\t}\n149: \n150: \t\terr := store.UpdateSandbox(ctx, info)\n151: \t\tassert.Error(t, err)\n152: \t\tassert.Contains(t, err.Error(), \"session ID cannot be empty\")\n153: \t})\n154: \n155: \tt.Run(\"Delete Sandbox\", func(t *testing.T) {\n156: \t\tsessionID := \"valkey-test-session-3\"\n157: \t\tinfo := &types.SandboxInfo{\n158: \t\t\tSess