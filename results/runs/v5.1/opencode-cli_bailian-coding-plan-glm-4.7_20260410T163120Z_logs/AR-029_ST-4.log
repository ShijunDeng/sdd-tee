L\n            namespace: Kubernetes namespace\n            agent_name: Agent name\n            timeout: Read timeout in seconds (default: 120)\n            connect_timeout: Connect timeout in seconds (default: 5.0)\n            pool_connections: Connection pool size (default: 10)\n            pool_maxsize: Max connections per pool (default: 10)\n        \"\"\"\n        self.router_url = router_url\n        self.namespace = namespace\n        self.agent_name = agent_name\n        self.timeout = timeout\n        self.connect_timeout = connect_timeout\n\n        base_path = f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n        self.base_url = urljoin(router_url, base_path)\n\n        self.session = create_session(\n            pool_connections=pool_connections,\n            pool_maxsize=pool_maxsize,\n        )\n\n    def bootstrap_session_id(self) -> str:\n        \"\"\"Bootstrap session ID from Agent Runtime endpoint.\n\n        Returns:\n            Session ID from response header\n\n        Raises:\n            ValueError: If session_id header not present\n            requests.exceptions.RequestException: On HTTP errors\n        \"\"\"\n        try:\n            response = self.session.get(\n                self.base_url,\n                timeout=(self.connect_timeout, self.timeout)\n            )\n            response.raise_for_status()\n\n            session_id = response.headers.get(self.SESSION_HEADER)\n            if not session_id:\n                raise ValueError(f\"Missing required response header: {self.SESSION_HEADER}\")\n\n            return session_id\n\n        except requests.exceptions.RequestException as e:\n            raise\n\n    def invoke(\n        self,\n        session_id: str,\n        payload: Dict[str, Any],\n        timeout: Optional[float] = None,\n    ) -> requests.Response:\n        \"\"\"Invoke agent with payload.\n\n        Args:\n            session_id: Session ID for header\n            payload: Agent invocation payload (JSON-serializable)\n            timeout: Request timeout in seconds (None for default)\n\n        Returns:\n            requests.Response object\n\n        Raises:\n            ValueError: If session_id is falsy\n            requests.exceptions.RequestException: On HTTP errors\n        \"\"\"\n        if not session_id:\n            raise ValueError(\"AgentRuntime session_id is not initialized\")\n\n        headers = {\n            self.SESSION_HEADER: session_id,\n            \"Content-Type\": \"application/json\",\n        }\n\n        timeout_value = timeout if timeout is not None else self.timeout\n\n        try:\n            response = self.session.post(\n                self.base_url,\n                json=payload,\n                headers=headers,\n                timeout=(self.connect_timeout, timeout_value)\n            )\n            response.raise_for_status()\n            return response\n\n        except requests.exceptions.RequestException as e:\n            raise\n\n    def close(self) -> None:\n        \"\"\"Close the HTTP session and release resources.\"\"\"\n        self.session.close()\n```\n\n```python\n# agentcube/clients/__init__.py\nfrom .control_plane import ControlPlaneClient\nfrom .code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom .agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n\n__all__ = [\n    \"ControlPlaneClient\",\n    \"CodeInterpreterDataPlaneClient\",\n    \"AgentRuntimeDataPlaneClient\",\n]\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_agent_runtime_data_plane.py -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/clients/agent_runtime_data_plane.py agentcube/clients/__init__.py tests/test_agent_runtime_data_plane.py\ngit commit -m \"feat(ar-029): implement AgentRuntimeDataPlaneClient\"\n```\n\n---\n\n### Task 13: Verify and implement CodeInterpreterClient initialization\n\n**Files:**\n- Create: `agentcube/code_interpreter.py`\n- Create: `agentcube/__init__.py`\n- Create: `tests/test_code_interpreter_client.py`\n\n**Step 1: Write the failing test**\n\n```python\n# tests/test_code_interpreter_client.py\nimport os\nfrom unittest.mock import patch, MagicMock\nimport pytest\nfrom agentcube import CodeInterpreterClient\n\n\ndef test_code_interpreter_client_initialization_with_all_params():\n    \"\"\"Test CodeInterpreterClient initialization with all parameters.\"\"\"\n    with patch(\"agentcube.code_interpreter.ControlPlaneClient\") as mock_cp:\n        mock_cp_instance = MagicMock()\n        mock_cp_instance.create_session.return_value = \"test-session-id\"\n        mock_cp.return_value = mock_cp_instance\n\n        client = CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"production\",\n            ttl=7200,\n            workload_manager_url=\"http://wm:8080\",\n            router_url=\"http://router:8080\",\n            auth_token=\"test-token\",\n            verbose=True,\n        )\n\n        assert client.name == \"test-interpreter\"\n        assert client.namespace == \"production\"\n        assert client.ttl == 7200\n        assert client.router_url == \"http://router:8080\"\n\n        client.stop()\n\n\ndef test_code_interpreter_client_initialization_with_existing_session_id():\n    \"\"\"Test CodeInterpreterClient initialization with existing session_id.\"\"\"\n    with patch(\"agentcube.code_interpreter.ControlPlaneClient\") as mock_cp:\n        mock_cp_instance = MagicMock()\n        mock_cp.return_value = mock_cp_instance\n\n        client = CodeInterpreterClient(\n            name=\"test-interpreter\",\n            router_url=\"http://router:8080\",\n            session_id=\"existing-session-id\",\n        )\n\n        assert client.session_id == \"existing-session-id\"\n        mock_cp_instance.create_session.assert_not_called()\n\n        client.stop()\n\n\ndef test_code_interpreter_client_requires_router_url():\n    \"\"\"Test