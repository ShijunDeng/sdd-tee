ogging.Logger instance.\"\"\"\n    logger = get_logger(\"test_logger\")\n\n    assert isinstance(logger, logging.Logger)\n    assert logger.name == \"test_logger\"\n\n\ndef test_get_logger_default_level():\n    \"\"\"Test get_logger sets default level to INFO.\"\"\"\n    logger = get_logger(\"test_logger_default\")\n\n    assert logger.level == logging.INFO\n\n\ndef test_get_logger_custom_level():\n    \"\"\"Test get_logger sets custom level.\"\"\"\n    logger = get_logger(\"test_logger_custom\", level=logging.DEBUG)\n\n    assert logger.level == logging.DEBUG\n\n\ndef test_get_logger_string_level():\n    \"\"\"Test get_logger accepts string level.\"\"\"\n    logger = get_logger(\"test_logger_string\", level=\"DEBUG\")\n\n    assert logger.level == logging.DEBUG\n\n\ndef test_get_logger_same_instance():\n    \"\"\"Test get_logger returns same instance for same name.\"\"\"\n    logger1 = get_logger(\"test_logger_same\")\n    logger2 = get_logger(\"test_logger_same\")\n\n    assert logger1 is logger2\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `python -m pytest tests/test_log_utils.py -v`\nExpected: FAIL (import error or function not found)\n\n**Step 3: Implement get_logger**\n\n```python\n# agentcube/utils/log.py\nimport logging\nfrom typing import Union\n\n\ndef get_logger(name: str, level: Union[int, str] = logging.INFO) -> logging.Logger:\n    \"\"\"Get configured logger instance.\n\n    Args:\n        name: Logger name (typically __name__)\n        level: Logging level (default: logging.INFO)\n\n    Returns:\n        Configured logger instance\n    \"\"\"\n    logger = logging.getLogger(name)\n    logger.setLevel(level)\n    return logger\n```\n\n```python\n# agentcube/utils/__init__.py\nfrom .http import create_session\nfrom .utils import read_token_from_file\nfrom .log import get_logger\n\n__all__ = [\"create_session\", \"read_token_from_file\", \"get_logger\"]\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_log_utils.py -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/utils/log.py agentcube/utils/__init__.py tests/test_log_utils.py\ngit commit -m \"feat(ar-029): implement get_logger utility\"\n```\n\n---\n\n### Task 4: Verify and implement exception hierarchy\n\n**Files:**\n- Create: `agentcube/exceptions.py`\n- Create: `tests/test_exceptions.py`\n\n**Step 1: Write the failing test**\n\n```python\n# tests/test_exceptions.py\nimport pytest\nfrom agentcube.exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    SessionError,\n    DataPlaneError,\n)\n\n\ndef test_agent_cube_error_base_exception():\n    \"\"\"Test AgentCubeError is an Exception.\"\"\"\n    assert issubclass(AgentCubeError, Exception)\n\n\ndef test_command_execution_error_inherits():\n    \"\"\"Test CommandExecutionError inherits from AgentCubeError.\"\"\"\n    assert issubclass(CommandExecutionError, AgentCubeError)\n\n\ndef test_command_execution_error_attributes():\n    \"\"\"Test CommandExecutionError has correct attributes.\"\"\"\n    error = CommandExecutionError(\n        exit_code=1,\n        stderr=\"Error message\",\n        command=\"test command\"\n    )\n\n    assert error.exit_code == 1\n    assert error.stderr == \"Error message\"\n    assert error.command == \"test command\"\n    assert \"Command failed (exit 1): Error message\" in str(error)\n\n\ndef test_command_execution_error_without_command():\n    \"\"\"Test CommandExecutionError without optional command.\"\"\"\n    error = CommandExecutionError(\n        exit_code=2,\n        stderr=\"Another error\"\n    )\n\n    assert error.exit_code == 2\n    assert error.stderr == \"Another error\"\n    assert error.command is None\n    assert \"Command failed (exit 2): Another error\" in str(error)\n\n\ndef test_session_error_inherits():\n    \"\"\"Test SessionError inherits from AgentCubeError.\"\"\"\n    assert issubclass(SessionError, AgentCubeError)\n\n\ndef test_data_plane_error_inherits():\n    \"\"\"Test DataPlaneError inherits from AgentCubeError.\"\"\"\n    assert issubclass(DataPlaneError, AgentCubeError)\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `python -m pytest tests/test_exceptions.py -v`\nExpected: FAIL (import error)\n\n**Step 3: Implement exception hierarchy**\n\n```python\n# agentcube/exceptions.py\n\n\nclass AgentCubeError(Exception):\n    \"\"\"Base exception for AgentCube SDK.\"\"\"\n    pass\n\n\nclass CommandExecutionError(AgentCubeError):\n    \"\"\"Raised when command execution fails with non-zero exit code.\"\"\"\n    def __init__(self, exit_code, stderr, command=None):\n        self.exit_code = exit_code\n        self.stderr = stderr\n        self.command = command\n        super().__init__(f\"Command failed (exit {exit_code}): {stderr}\")\n\n\nclass SessionError(AgentCubeError):\n    \"\"\"Raised when session creation or management fails.\"\"\"\n    pass\n\n\nclass DataPlaneError(AgentCubeError):\n    \"\"\"Raised when Data Plane operations fail.\"\"\"\n    pass\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_exceptions.py -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/exceptions.py tests/test_exceptions.py\ngit commit -m \"feat(ar-029): implement exception hierarchy\"\n```\n\n---\n\n### Task 5: Verify and implement ControlPlaneClient initialization\n\n**Files:**\n- Create: `agentcube/clients/__init__.py`\n- Create: `agentcube/clients/control_plane.py`\n- Create: `tests/test_control_plane_client.py`\n\n**Step 1: Write the failing test**\n\n```python\n# tests/test_control_plane_client.py\nimport os\nfrom unittest.mock import patch, MagicMock\nimport pytest\nfrom agentcube.clients import ControlPlaneClient\n\n\ndef test_control_plane_client_initialization_with_all_params():\n    \"\"\"Test ControlPlaneClient initialization with all parameters.\"\"\"\n    with patch(\"agentcube.clients.control_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\