"Close the HTTP session and release resources.\"\"\"\n        self.session.close()\n```\n\n```python\n# agentcube/clients/__init__.py\nfrom .control_plane import ControlPlaneClient\nfrom .code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n\n__all__ = [\"ControlPlaneClient\", \"CodeInterpreterDataPlaneClient\"]\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_code_interpreter_data_plane.py -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/clients/code_interpreter_data_plane.py agentcube/clients/__init__.py tests/test_code_interpreter_data_plane.py\ngit commit -m \"feat(ar-029): implement CodeInterpreterDataPlaneClient initialization\"\n```\n\n---\n\n### Task 9: Verify and implement CodeInterpreterDataPlaneClient execute_command method\n\n**Files:**\n- Modify: `agentcube/clients/code_interpreter_data_plane.py`\n- Modify: `tests/test_code_interpreter_data_plane.py`\n\n**Step 1: Write the failing test**\n\n```python\n# Add to tests/test_code_interpreter_data_plane.py\nfrom agentcube.exceptions import CommandExecutionError\n\n\ndef test_execute_command_success():\n    \"\"\"Test execute_command with successful execution.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\n            \"exit_code\": 0,\n            \"stdout\": \"output\",\n            \"stderr\": \"\"\n        }\n        mock_session.post.return_value = mock_response\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/test/\",\n        )\n\n        result = client.execute_command([\"python3\", \"script.py\"])\n\n        assert result == \"output\"\n\n        client.close()\n\n\ndef test_execute_command_non_zero_exit_raises_error():\n    \"\"\"Test execute_command raises error on non-zero exit.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\n            \"exit_code\": 1,\n            \"stdout\": \"\",\n            \"stderr\": \"Error: something went wrong\"\n        }\n        mock_session.post.return_value = mock_response\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/test/\",\n        )\n\n        with pytest.raises(CommandExecutionError) as exc_info:\n            client.execute_command([\"python3\", \"script.py\"])\n\n        assert exc_info.value.exit_code == 1\n        assert \"Error: something went wrong\" in exc_info.value.stderr\n\n        client.close()\n\n\ndef test_execute_command_with_string_command():\n    \"\"\"Test execute_command with string command.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\n            \"exit_code\": 0,\n            \"stdout\": \"output\",\n            \"stderr\": \"\"\n        }\n        mock_session.post.return_value = mock_response\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/test/\",\n        )\n\n        result = client.execute_command(\"python3 script.py\")\n\n        assert result == \"output\"\n\n        client.close()\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `python -m pytest tests/test_code_interpreter_data_plane.py -v -k execute_command`\nExpected: FAIL (method not found)\n\n**Step 3: Implement execute_command method**\n\n```python\n# Add to agentcube/clients/code_interpreter_data_plane.py\nfrom agentcube.exceptions import CommandExecutionError, DataPlaneError\n\n    def execute_command(\n        self,\n        command: Union[str, list],\n        timeout: Optional[float] = None\n    ) -> str:\n        \"\"\"Execute command in Code Interpreter session.\n\n        Args:\n            command: Command string or list of arguments\n            timeout: Command timeout in seconds (None for default)\n\n        Returns:\n            Command stdout output\n\n        Raises:\n            CommandExecutionError: If command exits with non-zero code\n            requests.exceptions.RequestException: On HTTP errors\n        \"\"\"\n        if isinstance(command, str):\n            command = command.split()\n\n        body = {\n            \"command\": command,\n        }\n\n        if timeout is not None:\n            body[\"timeout\"] = f\"{timeout}s\"\n\n        url = urljoin(self.base_url, \"api/execute\")\n\n        try:\n            timeout_value = timeout + 2.0 if timeout else self.timeout\n            response = self.session.post(\n                url,\n                json=body,\n                timeout=(self.connect_timeout, timeout_value)\n            )\n            response.raise_for_status()\n\n            data = response.json()\n\n            exit_code = data.get(\"exit_code\", 0)\n            stdout = data.get(\"stdout\", \"\")\n            stderr = data.get(\"stderr\", \"\")\n\n            if exit_code != 0:\n                raise CommandExecutionError(\n                    exit_code=exit_code,\n                    stderr=stderr,\n                    command=command\n                )\n\n            return stdout\n\n        except requests.exceptions.RequestException as e:\n            raise DataPlaneError(f\"Command execution failed: {e}\") from e\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_code_interpreter_data_plane.py -v -k execute_command`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/clients/code_interpreter_data_plane.py tests/test_code_interpreter_data_plane.py\ngit commit -m \"feat(ar-029): implement CodeInterpreterDataPlaneClient execute_command method\"\n```\n\n---\n\n### Task 10: Verify and implement CodeInterpreterDataPlaneClient file operations\n\n**Files:**\n- Modify: `agentcube/clients/code_interpreter_data_plane.py`\n- Modify: `tests/test_code_interpreter_data_plane.py`\n\n**Step 1: Write the failing test**\n\n```python\n# Add to tests/test_code_interpreter_data_plane.py\nimport base64\nimport tempfile\nimport os\n\n\ndef test_write_file():\n    \"\"\"Test write_file method.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        mock_session.post.return_value = mock_response\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/test/\",\n        )\n\n        client.write_file(\"Hello World\", \"/path/to/file.txt\")\n\n        mock_session.post.assert_called_once()\n\n        client.close()\n\n\ndef test_upload_file():\n    \"\"\"Test upload_file method.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        mock_session.post.return_value = mock_response\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/test/\",\n        )\n\n        with tempfile.NamedTemporaryFile(mode='w', delete=False) as f:\n            f.write(\"test content\")\n            temp_path = f.name\n\n        try:\n            client.upload_file(temp_path, \"/remote/path.txt\")\n            mock_session.post.assert_called_once()\n        finally:\n            os.unlink(temp_path)\n\n        client.close()\n\n\ndef test_download_file():\n    \"\"\"Test download_file method.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.iter_content = MagicMock(return_value=[b\"test\", b\"content\"])\n        mock_session.get.return_value = mock_response\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/test/\",\n        )\n\n        with tempfile.NamedTemporaryFile(mode='wb', delete=False) as f:\n            temp_path = f.name\n\n        try:\n            client.download_file(\"/remote/path.txt\", temp_path)\n\n            with open(temp_path, 'rb') as f:\n                content = f.read()\n                assert content == b\"testcontent\"\n        finally:\n            os.unlink(temp_path)\n\n        client.close()\n\n\ndef test_list_files():\n    \"\"\"Test list_files method.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\n            \"files\": [\n                {\"name\": \"file1.txt\", \"size\": 1024, \"mode\": \"0644\"},\n                {\"name\": \"file2.py\", \"size\": 2048, \"mode\": \"0755\"}\n            ]\n        }\n        mock_session.get.return_value = mock_response\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/test/\",\n        )\n\n        result = client.list_files(\"/path\")\n\n        assert \"files\" in result\n        assert len(result[\"files\"]) == 2\n\n        client.close()\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `python -m pytest tests/test_code_interpreter_data_plane.py -v -k \"write_file or upload_file or download_file or list_files\"`\nExpected: FAIL (methods not found)\n\n**Step 3: Implement file operation methods**\n\n```python\n# Add to agentcube/clients/code_interpreter_data_plane.py\nimport base64\n    def write_file(self, content: str, remote_path: str) -> None:\n        \"\"\"Write content to remote file.\n\n        Args:\n            content: File content as string\n            remote_path: Remote file path\n\n        Raises:\n            DataPlaneError: On write failure\n        \"\"\"\n        url = urljoin(self.base_url, \"api/files\")\n        body = {\n            \"path\": remote_path,\n            \"content\": base64.b64encode(content.encode()).decode(),\n            \"mode\": \"0644\"\n        }\n\n        try:\n            response = self.session.post(\n                url,\n                json=body,\n                timeout=(self.connect_timeout, self.timeout)\n            )\n            response.raise_for_status()\n        except requests.exceptions.RequestException as e:\n            raise DataPlaneError(f\"Failed to write file: {e}\") from e\n\n    def upload_file(self, local_path: str, remote_path: str) -> None:\n        \"\"\"Upload local file to remote path.\n\n        Args:\n            local_path: Local file path\n            remote_path: Remote file path\n\n        Raises:\n            FileNotFoundError: If local file doesn't exist\n            DataPlaneError: On upload failure\n        \"\"\"\n        if not os.path.exists(local_path):\n            raise FileNotFoundError(f\"Local file not found: {local_path}\")\n\n        url = urljoin(self.base_url, \"api/files\")\n\n        try:\n            with open(local_path, 'rb') as f:\n                files = {'file': (os.path.basename(local_path), f)}\n                data = {'path': remote_path, 'mode': '0644'}\n\n                response = self.session.post(\n                    url,\n                    files=files,\n                    data=data,\n                    timeout=(self.connect_timeout, self.timeout)\n                )\n                response.raise_for_status()\n        except requests.exceptions.RequestException as e:\n            raise DataPlaneError(f\"Failed to upload file: {e}\") from e\n\n    def download_file(self, remote_path: str, local_path: str) -> None:\n        \"\"\"Download remote file to local path.\n\n        Args:\n            remote_path: Remote file path\n            local_path: Local file path\n\n        Raises:\n            DataPlaneError: On download failure\n        \"\"\"\n        clean_path = remote_path.lstrip(\"/\")\n        url = urljoin(self.base_url, f\"api/files/{clean_path}\")\n\n        try:\n            response = self.session.get(\n                url,\n                stream=True,\n                timeout=(self.connect_timeout, self.timeout)\n            )\n            response.raise_for_status()\n\n            with open(local_path, 'wb') as f:\n                for chunk in response.iter_content(chunk_size=8192):\n                    f.write(chunk)\n        except requests.exceptions.RequestException as e:\n            raise DataPlaneError(f\"Failed to download file: {e}\") from e\n\n    def list_files(self, path: str = \".\") -> Any:\n        \"\"\"List files in remote path.\n\n        Args:\n            path: Remote path (default: \".\")\n\n        Returns:\n            Directory listing structure\n\n        Raises:\n            DataPlaneError: On list failure\n        \"\"\"\n        url = urljoin(self.base_url, \"api/files\")\n\n        try:\n            response = self.session.get(\n                url,\n                params={\"path\": path},\n                timeout=(self.connect_timeout, self.timeout)\n            )\n            response.raise_for_status()\n            return response.json()\n        except requests.exceptions.RequestException as e:\n            raise DataPlaneError(f\"Failed to list files: {e}\") from e\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_code_interpreter_data_plane.py -v -k \"write_file or upload_file or download_file or list_files\"`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/clients/code_interpreter_data_plane.py tests/test_code_interpreter_data_plane.py\ngit commit -m \"feat(ar-029): implement CodeInterpreterDataPlaneClient file operations\"\n```\n\n---\n\n### Task 11: Verify and implement CodeInterpreterDataPlaneClient run_code method\n\n**Files:**\n- Modify: `agentcube/clients/code_interpreter_data_plane.py`\n- Modify: `tests/test_code_interpreter_data_plane.py`\n\n**Step 1: Write the failing test**\n\n```python\n# Add to tests/test_code_interpreter_data_plane.py\n\n\ndef test_run_code_python():\n    \"\"\"Test run_code with Python language.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\n            \"exit_code\": 0,\n            \"stdout\": \"42\\n\",\n            \"stderr\": \"\"\n        }\n        mock_session.post.return_value = mock_response\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/test/\",\n        )\n\n        result = client.run_code(\"python\", \"print(42)\")\n\n        assert \"42\" in result\n\n        client.close()\n\n\ndef test_run_code_python3():\n    \"\"\"Test run_code with python3 language.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n       