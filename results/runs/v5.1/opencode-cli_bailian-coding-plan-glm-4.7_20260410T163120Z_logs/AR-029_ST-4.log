lients.control_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n        client.close()\n\n        mock_session.close.assert_called_once()\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `python -m pytest tests/test_control_plane_client.py -v`\nExpected: FAIL (import error)\n\n**Step 3: Implement ControlPlaneClient initialization**\n\n```python\n# agentcube/clients/control_plane.py\nimport os\nfrom typing import Optional, Dict, Any\nimport requests\nfrom agentcube.utils import create_session, read_token_from_file, get_logger\nfrom agentcube.exceptions import AgentCubeError\n\n\nclass ControlPlaneClient:\n    def __init__(\n        self,\n        workload_manager_url: Optional[str] = None,\n        auth_token: Optional[str] = None,\n        timeout: int = 120,\n        connect_timeout: float = 5.0,\n        pool_connections: int = 10,\n        pool_maxsize: int = 10,\n    ):\n        \"\"\"Initialize control plane client.\n\n        Args:\n            workload_manager_url: Base URL for Workload Manager API\n                                  (defaults to WORKLOAD_MANAGER_URL env var)\n            auth_token: Authentication token (defaults to SA token file)\n            timeout: Read timeout in seconds (default: 120)\n            connect_timeout: Connect timeout in seconds (default: 5.0)\n            pool_connections: Connection pool size (default: 10)\n            pool_maxsize: Max connections per pool (default: 10)\n        \"\"\"\n        self.base_url = workload_manager_url or os.environ.get(\"WORKLOAD_MANAGER_URL\", \"\")\n        self.timeout = timeout\n        self.connect_timeout = connect_timeout\n        self.logger = get_logger(__name__)\n\n        self.session = create_session(\n            pool_connections=pool_connections,\n            pool_maxsize=pool_maxsize,\n        )\n\n        self.session.headers[\"Content-Type\"] = \"application/json\"\n\n        if auth_token:\n            self.session.headers[\"Authorization\"] = f\"Bearer {auth_token}\"\n        else:\n            token = read_token_from_file(\"/var/run/secrets/kubernetes.io/serviceaccount/token\")\n            if token:\n                self.session.headers[\"Authorization\"] = f\"Bearer {token}\"\n\n    def close(self) -> None:\n        \"\"\"Close the HTTP session and release resources.\"\"\"\n        self.session.close()\n```\n\n```python\n# agentcube/clients/__init__.py\nfrom .control_plane import ControlPlaneClient\n\n__all__ = [\"ControlPlaneClient\"]\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_control_plane_client.py -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/clients/ tests/test_control_plane_client.py\ngit commit -m \"feat(ar-029): implement ControlPlaneClient initialization\"\n```\n\n---\n\n### Task 6: Verify and implement ControlPlaneClient create_session method\n\n**Files:**\n- Modify: `agentcube/clients/control_plane.py`\n- Modify: `tests/test_control_plane_client.py`\n\n**Step 1: Write the failing test**\n\n```python\n# Add to tests/test_control_plane_client.py\nfrom unittest.mock import patch, MagicMock\nimport pytest\n\n\ndef test_create_session_success():\n    \"\"\"Test create_session method with successful response.\"\"\"\n    with patch(\"agentcube.clients.control_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"sessionId\": \"test-session-123\"}\n        mock_session.post.return_value = mock_response\n\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n\n        session_id = client.create_session(\n            name=\"test-interpreter\",\n            namespace=\"default\",\n            metadata={\"key\": \"value\"},\n            ttl=3600,\n        )\n\n        assert session_id == \"test-session-123\"\n        mock_session.post.assert_called_once()\n\n        client.close()\n\n\ndef test_create_session_missing_session_id_raises_error():\n    \"\"\"Test create_session raises ValueError when sessionId not in response.\"\"\"\n    with patch(\"agentcube.clients.control_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.json.return_value = {}\n        mock_session.post.return_value = mock_response\n\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n\n        with pytest.raises(ValueError, match=\"sessionId not found in response\"):\n            client.create_session(name=\"test\", namespace=\"default\")\n\n        client.close()\n\n\ndef test_create_session_http_error_propagates():\n    \"\"\"Test create_session propagates HTTP errors.\"\"\"\n    with patch(\"agentcube.clients.control_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_session.post.side_effect = requests.exceptions.RequestException(\"Network error\")\n\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n\n        with pytest.raises(requests.exceptions.RequestException):\n            client.create_session(name=\"test\", namespace=\"default\")\n\n        client.close()\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `python -m pytest tests/test_control_plane_client.py -v -k create_session`\nExpected: FAIL (method not found)\n\n**Step 3: Implement create_session method**\n\n```python\n# Add to agentcube/clients/control_plane.py\n    def create_session(\n        self,\n        name: str = \"my-interpreter\",\n        namespace: str = \"default\",\n        metadata: Optional[Dict[str, Any]] = None,\n        ttl: int = 3600,\n    ) -> str:\n        \"\"\"Create a new Code Interpreter session.\n\n        Args:\n            name: Session name\n            namespace: Kubernetes namespace\n            metadata: Optional metadata dictionary\n            ttl: Time-to-live in seconds (default: 3600)\n\n        Returns:\n            Session ID string\n\n        Raises:\n            ValueError: If sessionId not in response\n            requests.exceptions.RequestException: On HTTP errors\n        \"\"\"\n        url = f\"{self.base_url}/v1/code-interpreter\"\n        body = {\n            \"name\": name,\n            \"namespace\": namespace,\n            \"ttl\": ttl,\n        }\n        if metadata:\n            body[\"metadata\"] = metadata\n\n        response = self.session.post(\n            url,\n            json=body,\n            timeout=(self.connect_timeout, self.timeout)\n        )\n\n        response.raise_for_status()\n        data = response.json()\n\n        if \"sessionId\" not in data:\n            raise ValueError(\"sessionId not found in response\")\n\n        return data[\"sessionId\"]\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_control_plane_client.py -v -k create_session`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/clients/control_plane.py tests/test_control_plane_client.py\ngit commit -m \"feat(ar-029): implement ControlPlaneClient create_session method\"\n```\n\n---\n\n### Task 7: Verify and implement ControlPlaneClient delete_session method\n\n**Files:**\n- Modify: `agentcube/clients/control_plane.py`\n- Modify: `tests/test_control_plane_client.py`\n\n**Step 1: Write the failing test**\n\n```python\n# Add to tests/test_control_plane_client.py\ndef test_delete_session_success():\n    \"\"\"Test delete_session method with successful deletion.\"\"\"\n    with patch(\"agentcube.clients.control_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.status_code = 200\n        mock_session.delete.return_value = mock_response\n\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n\n        result = client.delete_session(\"test-session-id\")\n\n        assert result is True\n        mock_session.delete.assert_called_once()\n\n        client.close()\n\n\ndef test_delete_session_404_returns_true():\n    \"\"\"Test delete_session returns True on 404 (idempotent).\"\"\"\n    with patch(\"agentcube.clients.control_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_response = MagicMock()\n        mock_response.status_code = 404\n        mock_session.delete.return_value = mock_response\n\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n\n        result = client.delete_session(\"test-session-id\")\n\n        assert result is True\n\n        client.close()\n\n\ndef test_delete_session_error_returns_false():\n    \"\"\"Test delete_session returns False on other errors.\"\"\"\n    with patch(\"agentcube.clients.control_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        mock_session.delete.side_effect = requests.exceptions.RequestException(\"Error\")\n\n        client = ControlPlaneClient(workload_manager_url=\"http://wm:8080\")\n\n        result = client.delete_session(\"test-session-id\")\n\n        assert result is False\n\n        client.close()\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `python -m pytest tests/test_control_plane_client.py -v -k delete_session`\nExpected: FAIL (method not found)\n\n**Step 3: Implement delete_session method**\n\n```python\n# Add to agentcube/clients/control_plane.py\n    def delete_session(self, session_id: str) -> bool:\n        \"\"\"Delete a Code Interpreter session.\n\n        Args:\n            session_id: Session ID to delete\n\n        Returns:\n            True if deletion succeeded (including 404), False otherwise\n\n        Note:\n            404 responses are treated as success (idempotent delete)\n        \"\"\"\n        url = f\"{self.base_url}/v1/code-interpreter/sessions/{session_id}\"\n\n        try:\n            response = self.session.delete(\n                url,\n                timeout=(self.connect_timeout, self.timeout)\n            )\n            # 404 is treated as success (session doesn't exist)\n            if response.status_code == 404:\n                return True\n            response.raise_for_status()\n            return True\n        except requests.exceptions.RequestException as e:\n            self.logger.error(f\"Failed to delete session {session_id}: {e}\")\n            return False\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_control_plane_client.py -v -k delete_session`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/clients/control_plane.py tests/test_control_plane_client.py\ngit commit -m \"feat(ar-029): implement ControlPlaneClient delete_session method\"\n```\n\n---\n\n### Task 8: Verify and implement CodeInterpreterDataPlaneClient initialization\n\n**Files:**\n- Modify: `agentcube/clients/__init__.py`\n- Create: `agentcube/clients/code_interpreter_data_plane.py`\n- Create: `tests/test_code_interpreter_data_plane.py`\n\n**Step 1: Write the failing test**\n\n```python\n# tests/test_code_interpreter_data_plane.py\nfrom unittest.mock import patch, MagicMock\nimport pytest\nfrom agentcube.clients import CodeInterpreterDataPlaneClient\n\n\ndef test_data_plane_client_initialization_with_base_url():\n    \"\"\"Test CodeInterpreterDataPlaneClient initialization with full base_url.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/v1/namespaces/default/code-interpreters/test/invocations/\",\n            timeout=180,\n            connect_timeout=10.0,\n        )\n\n        assert client.base_url == \"http://router:8080/v1/namespaces/default/code-interpreters/test/invocations/\"\n        assert client.session_id == \"test-session\"\n\n        client.close()\n\n\ndef test_data_plane_client_initialization_with_components():\n    \"\"\"Test CodeInterpreterDataPlaneClient initialization with URL components.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            router_url=\"http://router:8080\",\n            namespace=\"production\",\n            cr_name=\"my-interpreter\",\n        )\n\n        expected_url = \"http://router:8080/v1/namespaces/production/code-interpreters/my-interpreter/invocations/\"\n        assert client.base_url == expected_url\n        assert client.session_id == \"test-session\"\n\n        client.close()\n\n\ndef test_data_plane_client_session_header():\n    \"\"\"Test CodeInterpreterDataPlaneClient sets session header.\"\"\"\n    with patch(\"agentcube.clients.code_interpreter_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"test-session\",\n            base_url=\"http://router:8080/test/\",\n        )\n\n        assert client.session.headers[\"x-agentcube-session-id\"] == \"test-session\"\n\n        client.close()\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `python -m pytest tests/test_code_interpreter_data_plane.py -v`\nExpected: