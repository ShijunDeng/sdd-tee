_url,\n            auth_token=auth_token,\n        )\n\n        if session_id:\n            self.session_id = session_id\n        else:\n            metadata = {\"name\": name} if name else None\n            self.session_id = self.cp_client.create_session(\n                name=name,\n                namespace=namespace,\n                metadata=metadata,\n                ttl=ttl,\n            )\n            self._created_session = True\n\n        self.dp_client = CodeInterpreterDataPlaneClient(\n            session_id=self.session_id,\n            router_url=self.router_url,\n            namespace=namespace,\n            cr_name=self.session_id,\n        )\n\n    def __enter__(self) -> \"CodeInterpreterClient\":\n        return self\n\n    def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n        self.stop()\n\n    def stop(self) -> None:\n        \"\"\"Stop Code Interpreter session.\n\n        Closes data plane, deletes control plane session (if created),\n        and closes control plane HTTP session.\n        \"\"\"\n        if hasattr(self, 'dp_client'):\n            self.dp_client.close()\n\n        if hasattr(self, '_created_session') and self._created_session:\n            self.cp_client.delete_session(self.session_id)\n\n        if hasattr(self, 'cp_client'):\n            self.cp_client.close()\n```\n\n```python\n# agentcube/__init__.py\nfrom .code_interpreter import CodeInterpreterClient\nfrom .agent_runtime import AgentRuntimeClient\nfrom .exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    SessionError,\n    DataPlaneError,\n)\n\n__all__ = [\n    \"CodeInterpreterClient\",\n    \"AgentRuntimeClient\",\n    \"AgentCubeError\",\n    \"CommandExecutionError\",\n    \"SessionError\",\n    \"DataPlaneError\",\n]\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_code_interpreter_client.py -v -k initialization`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add agentcube/code_interpreter.py