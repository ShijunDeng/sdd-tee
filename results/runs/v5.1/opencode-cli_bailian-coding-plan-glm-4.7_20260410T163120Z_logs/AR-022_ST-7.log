{"type":"tool_use","timestamp":1775868915382,"sessionID":"ses_285f73853ffeHzQ17gbOQP6Q43","part":{"id":"prt_d7a092b49001rI29ZfupMC0yS8","messageID":"msg_d7a091f34001s9t7yg6xq5rG2F","sessionID":"ses_285f73853ffeHzQ17gbOQP6Q43","type":"tool","tool":"read","callID":"toolu_tool-e2cd8a54d51841a2baf1e045389f3278","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Runtime for the publish command.\"\"\"\n2: \n3: import logging\n4: import secrets\n5: import string\n6: from pathlib import Path\n7: from typing import Any, Dict\n8: \n9: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n10: from agentcube.services.docker_service import DockerService\n11: from agentcube.services.k8s_provider import KubernetesProvider\n12: from agentcube.services.agentcube_provider import AgentCubeProvider\n13: \n14: \n15: logger = logging.getLogger(__name__)\n16: \n17: \n18: class PublishRuntime:\n19:     \"\"\"Runtime for publishing agents.\"\"\"\n20: \n21:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n22:         \"\"\"Initialize the publish runtime.\"\"\"\n23:         self.verbose = verbose\n24:         self.provider = provider\n25:         if verbose:\n26:             logging.basicConfig(level=logging.DEBUG)\n27:         self.metadata_service = MetadataService(verbose=verbose)\n28:         self.docker_service = DockerService(verbose=verbose)\n29: \n30:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n31:         \"\"\"Publish an agent to the specified provider.\"\"\"\n32:         logger.info(f\"Publishing workspace: {workspace_path} to provider: {self.provider}\")\n33: \n34:         metadata = self.metadata_service.load_metadata(workspace_path)\n35: \n36:         image_url = self._prepare_image_for_publishing(\n37:             workspace_path, metadata, options\n38:         )\n39: \n40:         agent_info: Dict[str, Any] = {}\n41: \n42:         if self.provider == \"agentcube\":\n43:             agent_info = self._publish_cr_to_k8s(\n44:                 workspace_path, metadata, **options\n45:             )\n46:         elif self.provider == \"k8s\":\n47:             agent_info = self._publish_k8s(\n48:                 workspace_path, metadata, image_url, **options\n49:             )\n50:         else:\n51:             raise ValueError(f\"Unsupported provider: {self.provider}\")\n52: \n53:         self._update_publish_metadata(workspace_path, agent_info)\n54:         return agent_info\n55: \n56:     def _prepare_image_for_publishing(\n57:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n58:     ) -> str:\n59:         \"\"\"Prepare the image for publishing.\"\"\"\n60:         if metadata.build_mode == \"local\":\n61:             return self._prepare_local_image(\n62:                 workspace_path, metadata, options\n63:             )\n64:         else:\n65:             return self._prepare_cloud_image(\n66:                 workspace_path, metadata, options\n67:             )\n68: \n69:     def _prepare_local_image(\n70:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n71:     ) -> str:\n72:         \"\"\"Prepare a locally built image for publishing.\"\"\"\n73:         image_url = options.get(\"image_url\") or metadata.image.get(\"image_name\") if metadata.image else None\n74: \n75:         if not image_url:\n76:             raise ValueError(\n77:                 \"image_url is required for local build mode. \"\n78:                 \"Provide it via --image-url option or build the image first.\"\n79:             )\n80: \n81:         if metadata.image and \"image_name\" in metadata.image:\n82:             local_image = metadata.image[\"image_name\"]\n83:             registry_url = options.get(\"image_url\", \"\").rsplit(\":\", 1)[0]\n84: \n85:             username = options.get(\"image_username\") or metadata.registry_username\n86:             password = options.get(\"image_password\") or metadata.registry_password\n87: \n88:             if username and password:\n89:                 self.docker_service.push_image(\n90:                     image_name=local_image,\n91:                     registry_url=registry_url,\n92:                     username=username,\n93:                     password=password,\n94:                 )\n95: \n96:         return image_url\n97: \n98:     def _prepare_cloud_image(\n99:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n100:     ) -> str:\n101:         \"\"\"Prepare a cloud-built image for publishing.\"\"\"\n102:         if metadata.image and \"image_name\" in metadata.image:\n103:             return metadata.image[\"image_name\"]\n104: \n105:         cloud_provider = options.get(\"cloud_provider\", \"huawei\")\n106:         version = options.get(\"version\") or metadata.version or \"latest\"\n107: \n108:         return f\"{cloud_provider}/{metadata.agent_name}:{version}\"\n109: \n110:     def _publish_cr_to_k8s(\n111:         self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n112:     ) -> Dict[str, Any]:\n113:         \"\"\"Publish using AgentCube AgentRuntime custom resource.\"\"\"\n114:         namespace = options.get(\"namespace\") or \"default\"\n115: \n116:         if not metadata.workload_manager_url or not metadata.router_url:\n117:             raise ValueError(\n118:                 \"Both workload_manager_url and router_url are required for agentcube provider. \"\n119:                 \"Please set them in agent_metadata.yaml.\"\n120:             )\n121: \n122:         provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n123:         image_url = self._prepare_image_for_publishing(\n124:             workspace_path, metadata, options\n125:         )\n126: \n127:         result = provider.deploy_agent_runtime(\n128:             agent_name=metadata.agent_name,\n129:             image_url=image_url,\n130:             port=metadata.port,\n131:             entrypoint=metadata.entrypoint,\n132:             env_vars=None,\n133:             workload_manager_url=metadata.workload_manager_url,\n134:             router_url=metadata.router_url,\n135:             readiness_probe_path=metadata.readiness_probe_path,\n136:             readiness_probe_port=metadata.readiness_probe_port,\n137:         )\n138: \n139:         session_id = self._generate_session_id()\n140:         agent_id = result.get(\"agent_name\", metadata.agent_name)\n141: \n142:         result.update({\n143:             \"agent_id\": agent_id,\n144:             \"session_id\": session_id,\n145:             \"namespace\": namespace,\n146:             \"image_url\": image_url,\n147:             \"provider\": \"agentcube\",\n148:         })\n149: \n150:         return result\n151: \n152:     def _publish_k8s(\n153:         self, workspace_path: Path, metadata: AgentMetadata, image_url: str, **options: Any\n154:     ) -> Dict[str, Any]:\n155:         \"\"\"Publish using standard Kubernetes Deployment and Service.\"\"\"\n156:         namespace = options.get(\"namespace\") or \"default\"\n157:         replicas = options.get(\"replicas\", 1)\n158:         node_port = options.get(\"node_port\")\n159: \n160:         if node_port and not (30000 <= node_port <= 32767):\n161:             raise ValueError(f\"NodePort must be between 30000 and 32767, got {node_port}\")\n162: \n163:         provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n164: \n165:         result = provider.deploy_agent(\n166:             agent_name=metadata.agent_name,\n167:             image_url=image_url,\n168:             port=metadata.port,\n169:             entrypoint=metadata.entrypoint,\n170:             replicas=replicas,\n171:             node_port=node_port,\n172:             env_vars=None,\n173:         )\n174: \n175:         session_id = self._generate_session_id()\n176: \n177:         result.update({\n178:             \"agent_id\": result.get(\"deployment_name\", metadata.agent_name),\n179:             \"session_id\": session_id,\n180:             \"namespace\": namespace,\n181:             \"image_url\": image_url,\n182:             \"provider\": \"k8s\",\n183:         })\n184: \n185:         return result\n186: \n187:     def _update_publish_metadata(self, workspace_path: Path, agent_info: Dict[str, Any]) -> None:\n188:         \"\"\"Update metadata with publish information.\"\"\"\n189:         metadata = self.metadata_service.load_metadata(workspace_path)\n190: \n191:         if \"agent_id\" in agent_info:\n192:             metadata.agent_id = agent_info[\"agent_id\"]\n193:         if \"session_id\" in agent_info:\n194:             metadata.session_id = agent_info[\"session_id\"]\n195:         if \"k8s_deployment\" in agent_info:\n196:             metadata.k8s_deployment = agent_info[\"k8s_deployment\"]\n197:         if \"agent_endpoint\" in agent_info:\n198:             metadata.agent_endpoint = agent_info[\"agent_endpoint\"]\n199: \n200:         self.metadata_service.save_metadata(workspace_path, metadata)\n201: \n202:     def _generate_session_id(self) -> str:\n203:         \"\"\"Generate a unique session ID.\"\"\"\n204:         alphabet = string.ascii_letters + string.digits\n205:         return \"\".join(secrets.choice(alphabet) for _ in range(32))\n\n(End of file - total 205 lines)\n</content>","metadata":{"preview":"\"\"\"Runtime for the publish command.\"\"\"\n\nimport logging\nimport secrets\nimport string\nfrom pathlib import Path\nfrom typing import Any, Dict\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass PublishRuntime:\n    \"\"\"Runtime for publishing agents.\"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/publish_runtime.py","time":{"start":1775868915359,"end":1775868915380}}}}
