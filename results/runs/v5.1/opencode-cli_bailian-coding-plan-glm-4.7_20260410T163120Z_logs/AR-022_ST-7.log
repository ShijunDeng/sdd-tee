Runtime instance.\"\"\"\n    return PublishRuntime(verbose=True, provider=\"agentcube\")\n\n\n@pytest.fixture\ndef k8s_runtime():\n    \"\"\"Create a PublishRuntime instance with k8s provider.\"\"\"\n    return PublishRuntime(verbose=False, provider=\"k8s\")\n\n\nclass TestPublishRuntimeInit:\n    \"\"\"Test PublishRuntime initialization.\"\"\"\n\n    def test_init_default(self):\n        \"\"\"Test initialization with default parameters.\"\"\"\n        runtime = PublishRuntime()\n        assert runtime.verbose is False\n        assert runtime.provider == \"agentcube\"\n        assert runtime.metadata_service is not None\n        assert runtime.docker_service is not None\n\n    def test_init_verbose_true(self):\n        \"\"\"Test initialization with verbose=True.\"\"\"\n        runtime = PublishRuntime(verbose=True)\n        assert runtime.verbose is True\n        assert runtime.provider == \"agentcube\"\n\n    def test_init_provider_k8s(self):\n        \"\"\"Test initialization with k8s provider.\"\"\"\n        runtime = PublishRuntime(provider=\"k8s\")\n        assert runtime.provider == \"k8s\"\n\n    def test_init_invalid_provider(self):\n        \"\"\"Test initialization with invalid provider doesn't fail at init.\"\"\"\n        runtime = PublishRuntime(provider=\"invalid\")\n        assert runtime.provider == \"invalid\"\n\n\nclass TestPublishRuntimePublish:\n    \"\"\"Test PublishRuntime.publish method.\"\"\"\n\n    def test_publish_success_agentcube(self, runtime: PublishRuntime, temp_workspace: Path, sample_metadata: AgentMetadata):\n        \"\"\"Test successful publish with agentcube provider.\"\"\"\n        with patch.object(runtime.metadata_service, \"load_metadata\", return_value=sample_metadata), \\\n             patch.object(runtime, \"_prepare_image_for_publishing\", return_value=\"registry.example.com/test-agent:v1.0.0\"), \\\n             patch.object(runtime, \"_publish_cr_to_k8s\", return_value={\n                 \"agent_id\": \"test-agent\",\