on or \"latest\"\n\n        return f\"{cloud_provider}/{metadata.agent_name}:{version}\"\n\n    def _publish_cr_to_k8s(\n        self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n    ) -> Dict[str, Any]:\n        \"\"\"Publish using AgentCube AgentRuntime custom resource.\"\"\"\n        namespace = options.get(\"namespace\") or \"default\"\n\n        if not metadata.workload_manager_url or not metadata.router_url:\n            raise ValueError(\n                \"Both workload_manager_url and router_url are required for agentcube provider. \"\n","metadata":{"output":"            return self._prepare_cloud_image(\n                workspace_path, metadata, options\n            )\n\n    def _prepare_local_image(\n        self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n    ) -> str:\n        \"\"\"Prepare a locally built image for publishing.\"\"\"\n        image_url = options.get(\"image_url\") or metadata.image.get(\"image_name\") if metadata.image else None\n\n        if not image_url:\n            raise ValueError(\n                \"image_url is required for local build mode. \"\n                \"Provide it via --image-url option or build the image first.\"\n            )\n\n        if metadata.image and \"image_name\" in metadata.image:\n            local_image = metadata.image[\"image_name\"]\n            registry_url = options.get(\"image_url\", \"\").rsplit(\":\", 1)[0]\n\n            username = options.get(\"image_username\") or metadata.registry_username\n--\n    def _prepare_cloud_image(\n        self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n    ) -> str:\n        \"\"\"Prepare a cloud-built image for publishing.\"\"\"\n        if metadata.image and \"image_name\" in metadata.image:\n            return metadata.image[\"image_name\"]\n\n        cloud_provider = options.get(\"cloud_provider\", \"huawei\")\n        version = options.get(\"version\") or metadata.version or \"latest\"\n\n        return f\"{cloud_provider}/{metadata.agent_name}:{version}\"\n\n    def _publish_cr_to_k8s(\n        self, workspace_path: Path, metadata: AgentMetadata, **options: Any\n    ) -> Dict[str, Any]:\n        \"\"\"Publish using AgentCube AgentRuntime custom resource.\"\"\"\n        namespace = options.get(\"namespace\") or \"default\"\n\n        if not metadata.workload_manager_url or not metadata.router_url:\n            raise ValueError(\n                \"Both workload_manager_url and router_url are required for agentcube provider. \"\n","exit":0,"description":"Check cloud image preparation implementation","truncated":false},"title":"Check cloud image preparation implementation","time":{"start":1775868986834,"end":1775868986849}}}}
