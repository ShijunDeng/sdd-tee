\tLabelSelector *SandboxLabelSelector `json:\"labelSelector,omitempty\"`\n634: \n635: \t// Namespaces specifies the namespaces.\n636: \t// +optional\n637: \tNamespaces []string `json:\"namespaces,omitempty\"`\n638: \n639: \t// TopologyKey is the topology key.\n640: \t// +required\n641: \tTopologyKey string `json:\"topologyKey\"`\n642: \n643: \t// NamespaceSelector defines the namespace selector.\n644: \t// +optional\n645: \tNamespaceSelector *SandboxLabelSelector `json:\"namespaceSelector,omitempty\"`\n646: }\n647: \n648: // SandboxLabelSelector defines a label selector.\n649: type SandboxLabelSelector struct {\n650: \t// MatchLabels is a map of label keys and values.\n651: \t// +optional\n652: \tMatchLabels map[string]string `json:\"matchLabels,omitempty\"`\n653: \n654: \t// MatchExpressions is a list of label selector requirements.\n655: \t// +optional\n656: \tMatchExpressions []SandboxLabelSelectorRequirement `json:\"matchExpressions,omitempty\"`\n657: }\n658: \n659: // SandboxLabelSelectorRequirement defines a label selector requirement.\n660: type SandboxLabelSelectorRequirement struct {\n661: \t// Key is the label key.\n662: \t// +required\n663: \tKey string `json:\"key\"`\n664: \n665: \t// Operator is the operator.\n666: \t// +required\n667: \tOperator string `json:\"operator\"`\n668: \n669: \t// Values is the values.\n670: \t// +optional\n671: \tValues []string `json:\"values,omitempty\"`\n672: }\n673: \n674: // SandboxWeightedPodAffinityTerm defines a weighted pod affinity term.\n675: type SandboxWeightedPodAffinityTerm struct {\n676: \t// Weight is the weight.\n677: \t// +required\n678: \t// +kubebuilder:validation:Minimum=1\n679: \t// +kubebuilder:validation:Maximum=100\n680: \tWeight int32 `json:\"weight\"`\n681: \n682: \t// PodAffinityTerm is the pod affinity term.\n683: \t// +required\n684: \tPodAffinityTerm SandboxPodAffinityTerm `json:\"podAffinityTerm\"`\n685: }\n686: \n687: // SandboxToleration defines a pod toleration.\n688: type SandboxToleration