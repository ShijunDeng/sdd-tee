{"type":"tool_use","timestamp":1775887760553,"sessionID":"ses_284daec25ffeYvCPebmDHCWqiD","part":{"id":"prt_d7b28b7c2001k9tzZMAecf0o0m","messageID":"msg_d7b2870c30019hKtb4yl2KAnb8","sessionID":"ses_284daec25ffeYvCPebmDHCWqiD","type":"tool","tool":"write","callID":"toolu_tool-0d64f1fc2afb43de9562412e154b3a64","state":{"status":"completed","input":{"content":"/*\nCopyright 2024 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage externalversions\n\nimport (\n\t\"fmt\"\n\t\"sync\"\n\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-go/rest\"\n\t\"sync/atomic\"\n\n\t\"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n\tclientset \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n\truntimev1alpha1informers \"github.com/volcano-sh/agentcube/client-go/informers/externalversions/runtime/v1alpha1\"\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\ntype SharedInformerFactory interface {\n\tForResource(resource schema.GroupVersionResource) (GenericInformer, error)\n\tInformerFor(obj runtime.Object, newFunc NewInformerFunc) informers.SharedIndexInformer\n\tRuntime() runtime.Interface\n\tStart(stopCh <-chan struct{})\n\tShutdown()\n\tWaitForCacheSync(stopCh <-chan struct{}) map[reflect.Type]bool\n}\n\ntype SharedInformerOption func(*sharedInformerFactory) *sharedInformerFactory\n\ntype TweakListOptionsFunc func(*metav1.ListOptions)\n\nfunc WithTweakListOptions(tweakListOptions TweakListOptionsFunc) SharedInformerOption {\n\treturn func(factory *sharedInformerFactory) *sharedInformerFactory {\n\t\tfactory.tweakListOptions = tweakListOptions\n\t\treturn factory\n\t}\n}\n\nfunc WithNamespace(namespace string) SharedInformerOption {\n\treturn func(factory *sharedInformerFactory) *sharedInformerFactory {\n\t\tfactory.namespace = namespace\n\t\treturn factory\n\t}\n}\n\nfunc WithCustomResync(resync map[reflect.Type]time.Duration) SharedInformerOption {\n\treturn func(factory *sharedInformerFactory) *sharedInformerFactory {\n\t\tfactory.customResync = resync\n\t\treturn factory\n\t}\n}\n\ntype sharedInformerFactory struct {\n\tclient           clientset.Interface\n\tnamespace        string\n\ttweakListOptions TweakListOptionsFunc\n\tlock             sync.Mutex\n\tdefaultResync    time.Duration\n\tcustomResync     map[reflect.Type]time.Duration\n\tinformers        map[reflect.Type]informers.SharedIndexInformer\n\tstartedInformers map[reflect.Type]bool\n}\n\nfunc NewSharedInformerFactory(client clientset.Interface, defaultResync time.Duration) SharedInformerFactory {\n\treturn NewSharedInformerFactoryWithOptions(client, defaultResync)\n}\n\nfunc NewSharedInformerFactoryWithOptions(client clientset.Interface, defaultResync time.Duration, options ...SharedInformerOption) SharedInformerFactory {\n\tfactory := &sharedInformerFactory{\n\t\tclient:           client,\n\t\tnamespace:        metav1.NamespaceAll,\n\t\tdefaultResync:    defaultResync,\n\t\tinformers:        make(map[reflect.Type]informers.SharedIndexInformer),\n\t\tstartedInformers: make(map[reflect.Type]bool),\n\t\tcustomResync:     make(map[reflect.Type]time.Duration),\n\t}\n\n\tfor _, opt := range options {\n\t\tfactory = opt(factory)\n\t}\n\n\treturn factory\n}\n\nfunc (f *sharedInformerFactory) Start(stopCh <-chan struct{}) {\n\tf.lock.Lock()\n\tdefer f.lock.Unlock()\n\n\tfor informerType, informer := range f.informers {\n\t\tif !f.startedInformers[informerType] {\n\t\t\tgo informer.Run(stopCh)\n\t\t\tf.startedInformers[informerType] = true\n\t\t}\n\t}\n}\n\nfunc (f *sharedInformerFactory) Shutdown() {\n\tf.lock.Lock()\n\tdefer f.lock.Unlock()\n\n\tfor informerType, informer := range f.informers {\n\t\tif f.startedInformers[informerType] {\n\t\t\tinformer.Shutdown()\n\t\t\tf.startedInformers[informerType] = false\n\t\t}\n\t}\n}\n\nfunc (f *sharedInformerFactory) WaitForCacheSync(stopCh <-chan struct{}) map[reflect.Type]bool {\n\tinformers := func() []informers.SharedIndexInformer {\n\t\tf.lock.Lock()\n\t\tdefer f.lock.Unlock()\n\n\t\tinfos := make([]informers.SharedIndexInformer, 0, len(f.informers))\n\t\tfor _, informer := range f.informers {\n\t\t\tif f.startedInformers[informer.Type()] {\n\t\t\t\tinfos = append(infos, informer)\n\t\t\t}\n\t\t}\n\t\treturn infos\n\t}()\n\n\tres := make(map[reflect.Type]bool)\n\tfor _, informer := range informers {\n\t\tres[informer.Type()] = informer.HasSynced()\n\t}\n\treturn res\n}\n\nfunc (f *sharedInformerFactory) InformerFor(obj runtime.Object, newFunc NewInformerFunc) informers.SharedIndexInformer {\n\tf.lock.Lock()\n\tdefer f.lock.Unlock()\n\n\tinformerType := reflect.TypeOf(obj)\n\tinformer, exists := f.informers[informerType]\n\tif exists {\n\t\treturn informer\n\t}\n\n\tresyncPeriod, exists := f.customResync[informerType]\n\tif !exists {\n\t\tresyncPeriod = f.defaultResync\n\t}\n\n\tinformer = newFunc(f.client, resyncPeriod)\n\tf.informers[informerType] = informer\n\n\treturn informer\n}\n\nfunc (f *sharedInformerFactory) Runtime() runtime.Interface {\n\treturn &runtime{factory: f}\n}\n\nfunc (f *sharedInformerFactory) defaultTweakListOptions(options *metav1.ListOptions) {\n\tif f.tweakListOptions != nil {\n\t\tf.tweakListOptions(options)\n\t}\n}\n\ntype NewInformerFunc func(client clientset.Interface, resyncPeriod time.Duration) informers.SharedIndexInformer\n\nvar _ SharedInformerFactory = &sharedInformerFactory{}","filePath":"/hom