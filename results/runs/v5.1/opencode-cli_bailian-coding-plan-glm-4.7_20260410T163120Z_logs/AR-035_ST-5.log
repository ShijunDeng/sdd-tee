lse\"\n225:                       - Unknown\n226:                       type: string\n227:                     type:\n228:                       description: type of condition in CamelCase or in foo.example.com/CamelCase.\n229:                       maxLength: 316\n230:                       pattern: ^([a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])$\n231:                       type: string\n232:                   required:\n233:                   - lastTransitionTime\n234:                   - message\n235:                   - reason\n236:                   - status\n237:                   - type\n238:                   type: object\n239:                 type: array\n240:               observedGeneration:\n241:                 description: ObservedGeneration is the most recent generation observed\n242:                   by the controller.\n243:                 format: int64\n244:                 type: integer\n245:               ready:\n246:                 description: Ready indicates whether the interpreter is ready to execute\n247:                   code.\n248:                 type: boolean\n249:             type: object\n250:         type: object\n251:     served: true\n252:     storage: true\n253:     subresources:\n254:       status: {}\n\n(End of file - total 254 lines)\n</content>","metadata":{"preview":"---\napiVersion: apiextensions.k8s.io/v1\nkind: CustomResourceDefinition\nmetadata:\n  annotations:\n    controller-gen.kubebuilder.io/version: v0.20.1\n  name: codeinterpreters.runtime.agentcube.volcano.sh\nspec:\n  group: runtime.agentcube.volcano.sh\n  names:\n    kind: CodeInterpreter\n    listKind: CodeInterpreterList\n    plural: codeinterpreters\n    shortNames:\n    - ci\n    - codeinterpreter\n    singular: codeinterpreter\n  scope: Namespaced\n  versions:\n  - additionalPrinterColumns:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260