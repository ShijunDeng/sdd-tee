overy.NewDiscoveryClientForConfig(&configShallowCopy)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar cs Clientset\n\tcs.runtimeV1alpha1, err = runtimev1alpha1.NewForConfig(&configShallowCopy)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tcs.DiscoveryClient = discoveryClient\n\treturn &cs, nil\n}\n\nfunc NewForConfig(c *rest.Config) (*Clientset, error) {\n\tconfigShallowCopy := *c\n\tif configShallowCopy.RateLimiter == nil && configShallowCopy.QPS > 0 {\n\t\tif configShallowCopy.Burst <= 0 {\n\t\t\treturn nil, fmt.Errorf(\"burst is required to be greater than 0 when RateLimiter is not set and QPS is set to greater than 0\")\n\t\t}\n\t\tconfigShallowCopy.RateLimiter = createDefaultRateLimiter(configShallowCopy.QPS, configShallowCopy.Burst)\n\t}\n\n\tvar cs Clientset\n\tvar err error\n\tcs.runtimeV1alpha1, err = runtimev1alpha1.NewForConfig(&configShallowCopy)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tcs.DiscoveryClient, err = discovery.NewDiscoveryClientForConfig(&configShallowCopy)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cs, nil\n}\n\nfunc NewForConfigAndClient(c *rest.Config, httpClient *rest.HttpClient) (*Clientset, error) {\n\tconfigShallowCopy := *c\n\tif configShallowCopy.RateLimiter == nil && configShallowCopy.QPS > 0 {\n\t\tif configShallowCopy.Burst <= 0 {\n\t\t\treturn nil, fmt.Errorf(\"burst is required to be greater than 0 when RateLimiter is not set and QPS is set to greater than 0\")\n\t\t}\n\t\tconfigShallowCopy.RateLimiter = createDefaultRateLimiter(configShallowCopy.QPS, configShallowCopy.Burst)\n\t}\n\n\tvar cs Clientset\n\tvar err error\n\tcs.runtimeV1alpha1, err = runtimev1alpha1.NewForConfigAndClient(&configShallowCopy, httpClient)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tcs.DiscoveryClient, err = discovery.NewDiscoveryClientForConfigAndClient(&configShallowCopy, httpClient)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cs, nil\n}\n\nfunc NewForConfigOrDie(c *rest.Config) *Clientset {\n\tvar cs Clientset\n\tcs.runtimeV1alpha1 = runtimev1alpha1.NewForConfigOrDie(c)\n\tcs.DiscoveryClient = discovery.NewDiscoveryClientForConfigOrDie(c)\n\treturn &cs\n}\n\nfunc (c *Clientset) RuntimeV1alpha1() runtimev1alpha1.RuntimeV1alpha1Interface {\n\treturn c.runtimeV1alpha1\n}\n\nfunc NewConfig(hostname string, httpClient *rest.HttpClient) *rest.Config {\n\tif httpClient == nil {\n\t\thttpClient = rest.DefaultClient\n\t}\n\treturn &rest.Config{\n\t\tHost: hostname,\n\t\tTLSClientConfig: rest.TLSClientConfig{\n\t\t\tInsecure: true,\n\t\t},\n\t\tAPIPath: \"/apis\",\n\t\tContentConfig: rest.ContentConfig{\n\t\t\tContentType:          \"application/json\",\n\t\t\tGroupVersion:         &schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"},\n\t\t\tNegotiatedSerializer: createNegotiatedSerializer(),\n\t\t},\n\t\tRateLimiter:    createDefaultRateLimiter(5, 10),\n\t\tTimeout:        30,\n\t\tDial:           httpClient.Dial,\n\t\tTransport:      httpClient.Transport,\n\t\tWrappedTransport: httpClient.WrappedTransport,\n\t\tUserAgent:      rest.DefaultKubernetesUserAgent(),\n\t}\n}\n\nfunc createDefaultRateLimiter(qps float32, burst int) rest.RateLimiter {\n\treturn rest.NewTokenBucketRateLimiter(qps, burst)\n}\n\nfunc createNegotiatedSerializer() runtime.NegotiatedSerializer {\n\treturn serializer.NewCodecFactory(scheme.Scheme).WithoutConversion()\n}\n\nfunc DefaultConfig() *rest.Config {\n\tconfig := rest.DefaultClientConfig(rest.DefaultClientConfigOverrides{})\n\trestConfig, err := config.ClientConfig()\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\treturn restConfig\n}\n\nfunc DefaultClientConfig() (*rest.Config, error) {\n\treturn config.ClientConfig()\n}\n\nfunc (c *Clientset) Discovery() discovery.DiscoveryInterface {\n\tif c == nil {\n\t\treturn nil\n\t}\n\treturn c.DiscoveryClient\n}\n\nfunc (c *Clientset) DiscoveryCache() discovery.CachedDiscoveryInterface {\n\tif c == nil {\n\t\treturn nil\n\t}\n\treturn memory.NewMemCacheClient(c.DiscoveryClient)\n}\n\nfunc (c *Clientset) RESTClient() rest.Interface {\n\tif c == nil {\n\t\treturn nil\n\t}\n\treturn c.runtimeV1alpha1.RESTClient()\n}\n\nfunc (c *Clientset) RuntimeAPI() (*RESTClient, error) {\n\treturn c.runtimeV1alpha1.RESTClient(), nil\n}\n\nfunc NewRESTClient(baseURL string) (*RESTClient, error) {\n\tconfig := NewConfig(baseURL, rest.DefaultClient)\n\tconfig.GroupVersion = &schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"}\n\tconfig.APIPath = \"/apis/runtime.agentcube.volcano.sh/v1alpha1\"\n\t\n\trestClient, err := rest.RESTClientFor(config)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\t\n\treturn &RESTClient{\n\t\tRESTClient: restClient,\n\t}, nil\n}\n\ntype RESTClient struct {\n\trest.Interface\n}\n\nfunc (c *Clientset) DynamicClient() (dynamic.Interface, error) {\n\tif c == nil {\n\t\treturn nil, fmt.Errorf(\"clientset is nil\")\n\t}\n\t\n\tdynamicConfig := rest.CopyConfig(c.runtimeV1alpha1.RESTClient().(*rest.RESTClient).Config)\n\tdynamicConfig.GroupVersion = nil\n\tdynamicConfig.NegotiatedSerializer = createNegotiatedSerializer()\n\t\n\tdynamicClient, err := dynamic.NewForConfig(dynamicConfig)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\t\n\treturn dynamicClient, nil\n}\n\nfunc (c *Clientset) RESTMapper() (restmapper.ResettableRESTMapper, error) {\n\tif c == nil {\n\t\treturn nil, fmt.Errorf(\"clientset is nil\")\n\t}\n\t\n\tdiscoveryClient := c.Discovery()\n\tif discoveryClient == nil {\n\t\treturn nil, fmt.Errorf(\"discovery client is nil\")\n\t}\n\t\n\tgroupResources, err := restmapper.GetAPIGroupResources(discoveryClient)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\t\n\treturn restmapper.NewDiscoveryRESTMapper(groupResources), nil\n}\n\nfunc init() {\n\tutilruntime.Must(scheme.AddToScheme(scheme.Scheme))\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/client-go/clientset/versioned/clientset.go"},"output":"Wrote file successfully.\n\nLSP errors d