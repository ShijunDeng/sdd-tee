ient.RuntimeV1alpha1().AgentRuntimes(namespace).List(context.TODO(), options)\n\t\t\t},\n\t\t\tWatchFunc: func(options metav1.ListOptions) (watch.Interface, error) {\n\t\t\t\tif tweakListOptions != nil {\n\t\t\t\t\ttweakListOptions(&options)\n\t\t\t\t}\n\t\t\t\treturn client.RuntimeV1alpha1().AgentRuntimes(namespace).Watch(context.TODO(), options)\n\t\t\t},\n\t\t},\n\t\t&runtimev1alpha1.AgentRuntime{},\n\t\tresyncPeriod,\n\t\tcache.Indexers{cache.NamespaceIndex: cache.MetaNamespaceIndexFunc},\n\t)\n}\n\ntype agentRuntimeInformer struct {\n\tfactory          internalinterfaces.SharedInformerFactory\n\ttweakListOptions internalinterfaces.TweakListOptionsFunc\n\tnamespace        string\n}\n\nfunc NewAgentRuntimeInformer(client clientset.Interface, namespace string, resyncPeriod time.Duration) cache.SharedIndexInformer {\n\treturn newFilteredAgentRuntimeInformer(client, namespace, resyncPeriod, nil)\n}\n\nfunc NewFilteredAgentRuntimeInformer(client clientset.Interface, namespace string, resyncPeriod time.Duration, tweakListOptions internalinterfaces.TweakListOptionsFunc) cache.SharedIndexInformer {\n\treturn newFilteredAgentRuntimeInformer(client, namespace, resyncPeriod, tweakListOptions)\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli-bailian-coding-plan-glm-4.7_20260410T163120Z/client-go/informers/externalversions/runtime/v1alpha1/agentruntime.go"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/codeinterpreter.go\">\nERROR [63:7] undefined: statusConditionsEqual\nERROR [106:6] undefined: statusConditionsEqual\nERROR [173:2] declared and not used: logger\nERROR [242:5] undefined: podSpecsEqual\nERROR [267:29] undefined: convertEnvVars\nERROR [274:25] undefined: convertResources\nERROR [326:6] undefined: statusConditionsEqual\n</diagnostics>\n\nLSP errors detected in othe