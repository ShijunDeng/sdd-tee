istOptions: v.tweakListOptions}\n}\n\nfunc (v *v1alpha1) CodeInterpreters() CodeInterpreterInformer {\n\treturn &codeInterpreterInformer{factory: v.factory, namespace: v.namespace, tweakListOptions: v.tweakListOptions}\n}\n\ntype AgentRuntimeInformer interface {\n\tInformer() informers.SharedIndexInformer\n\tLister() runtimev1alpha1.AgentRuntimeLister\n}\n\ntype agentRuntimeInformer struct {\n\tfactory          externalversions.SharedInformerFactory\n\tnamespace        string\n\ttweakListOptions externalversions.TweakListOptionsFunc\n}\n\nfunc (f *agentRuntimeInformer) Informer() informers.SharedIndexInformer {\n\treturn f.factory.InformerFor(&runtimev1alpha1.AgentRuntime{}, func(client clientset.Interface, resyncPeriod time.Duration) informers.SharedIndexInformer {\n\t\treturn newFilteredAgentRuntimeInformer(client, f.namespace, resyncPeriod, f.tweakListOptions)\n\t})\n}\n\nfunc (f *agentRuntimeInformer) Lister() runtimev1alpha1.AgentRuntimeLister {\n\treturn nil\n}\n\ntype CodeInterpreterInformer interface {\n\tInformer() informers.SharedIndexInformer\n\tLister() runtimev1alpha1.CodeInterpreterLister\n}\n\ntype codeInterpreterInformer struct {\n\tfactory          externalversions.SharedInformerFactory\n\tnamespace        string\n\ttweakListOptions externalversions.TweakListOptionsFunc\n}\n\nfunc (f *codeInterpreterInformer) Informer() informers.SharedIndexInformer {\n\treturn f.factory.InformerFor(&runtimev1alpha1.CodeInterpreter{}, func(client clientset.Interface, resyncPeriod time.Duration) informers.SharedIndexInformer {\n\t\treturn newFilteredCodeInterpreterInformer(client, f.namespace, resyncPeriod, f.tweakListOptions)\n\t})\n}\n\nfunc (f *codeInterpreterInformer) Lister() runtimev1alpha1.CodeInterpreterLister {\n\treturn nil\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli-bailian-coding-plan-glm-4.7_20260410T163120Z/client-go/informers/externalversions/runtime/v1alpha1/interface.go"},"output":"Wrote file successfully.\n\nLSP errors detected 