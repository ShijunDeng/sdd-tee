r: s.indexer, namespace: namespace}\n}\n\ntype CodeInterpreterNamespaceLister interface {\n\tList(selector labels.Selector) (ret []*runtimev1alpha1.CodeInterpreter, err error)\n\tGet(name string) (*runtimev1alpha1.CodeInterpreter, error)\n\tCodeInterpreterNamespaceListerExpansion\n}\n\ntype codeInterpreterNamespaceLister struct {\n\tindexer   cache.Indexer\n\tnamespace string\n}\n\nfunc (s *codeInterpreterNamespaceLister) List(selector labels.Selector) (ret []*runtimev1alpha1.CodeInterpreter, err error) {\n\terr = cache.ListAllByNamespace(s.indexer, s.namespace, selector, func(m interface{}) {\n\t\tret = append(ret, m.(*runtimev1alpha1.CodeInterpreter))\n\t})\n\treturn ret, err\n}\n\nfunc (s *codeInterpreterNamespaceLister) Get(name string) (*runtimev1alpha1.CodeInterpreter, error) {\n\tobj, exists, err := s.indexer.GetByKey(s.namespace + \"/\" + name)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tif !exists {\n\t\treturn nil, &cache.ErrKeyNotFound{Key: name}\n\t}\n\treturn obj.(*runtimev1alpha1.CodeInterpreter), nil\n}\n\ntype CodeInterpreterListerExpansion interface{}\ntype CodeInterpreterNamespaceListerExpansion interface{}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli-bailian-coding-plan-glm-4.7_20260410T163120Z/client-go/listers/runtime/v1alpha1/codeinterpreter.go"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/codeinterpreter.go\">\nERROR [63:7] undefined: statusConditionsEqual\nERROR [106:6] undefined: statusConditionsEqual\nERROR [173:2] declared and not used: logger\nERROR [242:5] undefined: podSpecsEqual\nERROR [267:29] undefined: convertEnvVars\nERROR [274:25] undefined: convertResources\nERROR [326:6] undefined: statusConditionsEqual\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cl