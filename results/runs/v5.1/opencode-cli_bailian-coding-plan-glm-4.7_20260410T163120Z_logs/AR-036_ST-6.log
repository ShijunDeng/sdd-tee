     @patch('tools.agentcube_code_interpreter.CodeInterpreterClient')\n83:     def test_full_workflow_error_handling(self, mock_client_class, provider, tool):\n84:         mock_client = MagicMock()\n85:         mock_client_class.return_value.__enter__.return_value = mock_client\n86:         mock_client.session_id = \"test-session-id\"\n87:         from agentcube.exceptions import CommandExecutionError\n88:         error = CommandExecutionError(\"Command failed\", exit_code=1, stderr=\"Error\")\n89:         mock_client.execute_command.side_effect = error\n90: \n91:         credentials = {\n92:             \"router_url\": \"http://localhost:8080\",\n93:             \"workload_manager_url\": \"http://localhost:8081\",\n94:         }\n95: \n96:         provider._validate_credentials(credentials)\n97: \n98:         tool_parameters = {\n99:             **credentials,\n100:             \"command\": \"invalid-command\",\n101:         }\n102: \n103:         messages = list(tool._invoke(tool_parameters))\n104: \n105:         assert len(messages) == 1\n106:         message = messages[0]\n107:         assert message.type == \"json\"\n108:         assert message.message[\"success\"] is False\n109:         assert message.message[\"error\"] == \"Command failed\"\n110: \n111:     @patch('tools.agentcube_code_interpreter.CodeInterpreterClient')\n112:     def test_multi_language_execution(self, mock_client_class, provider, tool):\n113:         mock_client = MagicMock()\n114:         mock_client_class.return_value.__enter__.return_value = mock_client\n115:         mock_client.session_id = \"test-session-id\"\n116:         mock_client.run_code.return_value = \"output\"\n117: \n118:         credentials = {\n119:             \"router_url\": \"http://localhost:8080\",\n120:             \"workload_manager_url\": \"http://localhost:8081\",\n121:         }\n122: \n123:         provider._validate_credentials(credentials)\n124: \n125:         languages = [\"python\", \"javascript\", \"typescript\"]\n126: \n127:         for language in languages:\n128:             tool_parameters = {\n129:                 **credentials,\n130:                 \"language\": language,\n131:                 \"code\": f\"console.log('{language}')\",\n132:             }\n133: \n134:             messages = list(tool._invoke(tool_parameters))\n135: \n136:             assert len(messages) == 1\n137:             message = messages[0]\n138:             assert message.message[\"success\"] is True\n139:             assert message.message[\"language\"] == language\n140: \n141:     @patch('tools.agentcube_code_interpreter.CodeInterpreterClient')\n142:     def test_session_reuse_workflow(self, mock_client_class, provider, tool):\n143:         mock_client = MagicMock()\n144:         mock_client_class.return_value.__enter__.return_value = mock_client\n145:         mock_client.session_id = \"existing-session-id\"\n146:         mock_client.run_code.return_value = \"output\"\n147: \n148:         credentials = {\n149:             \"router_url\": \"http://localhost:8080\",\n150:             \"workload_manager_url\": \"http://localhost:8081\",\n151:         }\n152: \n153:         provider._validate_credentials(credentials)\n154: \n155:         tool_parameters = {\n156:             **credentials,\n157:             \"session_id\": \"existing-session-id\",\n158:             \"session_reuse\": True,\n159:             \"code\": \"print(1)\",\n160:         }\n161: \n162:         messages = list(tool._invoke(tool_parameters))\n163: \n164:         assert len(messages) == 1\n165:         message = messages[0]\n166:         assert message.message[\"success\"] is True\n167:         assert message.message[\"session_id\"] == \"existing-session-id\"\n168: \n169:     @patch('tools.agentcube_code_interpreter.CodeInterpreterClient')\n170:     def test_custom_interpreter_workflow(self, mock_client_class, provider, tool):\n171:         mock_client = MagicMock()\n172:         mock_client_class.return_value.__enter_