 )\n155: \n156:         assert result[\"success\"] is False\n157:         assert result[\"output\"] is None\n158:         assert \"Command failed\" in result[\"error\"]\n159:         assert result[\"exit_code\"] == 1\n160:         assert result[\"stderr\"] == \"Error output\"\n161: \n162:     @patch('tools.agentcube_code_interpreter.CodeInterpreterClient')\n163:     def test_execute_general_exception(self, mock_client_class, tool):\n164:         mock_client = MagicMock()\n165:         mock_client_class.return_value.__enter__.return_value = mock_client\n166:         mock_client.session_id = \"test-session-id\"\n167:         mock_client.run_code.side_effect = Exception(\"General error\")\n168: \n169:         result = tool.execute(\n170:             router_url=\"http://localhost:8080\",\n171:             workload_manager_url=\"http://localhost:8081\",\n172:             code=\"invalid-code\"\n173:         )\n174: \n175:         assert result[\"success\"] is False\n176:         assert result[\"output\"] is None\n177:         assert \"General error\" in result[\"error\"]\n178: \n179:     def test_execute_missing_code_and_command(self, tool):\n180:         with pytest.raises(ValueError, match=\"Either 'code' or 'command'\"):\n181:             tool.execute(\n182:                 router_url=\"http://localhost:8080\",\n183:                 workload_manager_url=\"http://localhost:8081\"\n184:             )\n185: \n186:     @patch('tools.agentcube_code_interpreter.CodeInterpreterClient')\n187:     def test_invoke_success(self, mock_client_class, tool):\n188:         mock_client = MagicMock()\n189:         mock_client_class.return_value.__enter__.return_value = mock_client\n190:         mock_client.session_id = \"test-session-id\"\n191:         mock_client.run_code.return_value = \"Output\"\n192: \n193:         tool_parameters = {\n194:             \"router_url\": \"http://localhost:8080\",\n195:             \"workload_manager_url\": \"http://localhost:8081\",\n196:             \"code\": \"print(1)\"\n197:         }\n198: \n199:         messages = list(tool._invoke(tool_parameters))\n200: \n201:         assert len(messages) == 1\n202:         message = messages[0]\n203:         assert message.type == \"json\"\n204:         assert message.message[\"success\"] is True\n205: \n206:     @patch('tools.agentcube_code_interpreter.CodeInterpreterClient')\n207:     def test_invoke_error(self, mock_client_class, tool):\n208:         mock_client_class.side_effect = Exception(\"Connection error\")\n209: \n210:         tool_parameters = {\n211:             \"router_url\": \"http://localhost:8080\",\n212:             \"workload_manager_url\": \"http://localhost:8081\",\n213:             \"code\": \"print(1)\"\n214:         }\n215: \n216:         messages = list(tool._invoke(tool_parameters))\n217: \n218:         assert len(messages) == 1\n219:         message = messages[0]\n220:         assert message.type == \"text\"\n221:         assert \"Error\" in message.message\n222: \n223:     @patch('tools.agentcube_code_interpreter.CodeInterpreterClient')\n224:     def test_execute_with_session_reuse(self, mock_client_class, tool):\n225:         mock_client = MagicMock()\n226:         mock_client_class.return_value.__enter__.return_value = mock_client\n227:         mock_client.session_id = \"test-session-id\"\n228:         mock_client.run_code.return_value = \"Output\"\n229: \n230:         result = tool.execute(\n231:             router_url=\"http://localhost:8080\",\n232:             workload_manager_url=\"http://localhost:8081\",\n233:             code=\"print(1)\",\n234:             session_reuse=True\n235:         )\n236: \n237:         assert result[\"success\"] is True\n238: \n239:     @patch('tools.agentcube_code_interpreter.CodeInterpreterClient')\n240:     def test_default_interpreter_name(self, mock_client_class, tool):\n241:         mock_client = MagicMock()\n242:         mock_client_class.return_value.__enter__.return_value = mock_client\n243:      