code' or 'command' parameter must be provided\")\n34: \n35:         interpreter_name = code_interpreter_id or \"my-interpreter\"\n36:         namespace = \"default\"\n37:         ttl = 3600\n38: \n39:         with CodeInterpreterClient(\n40:             name=interpreter_name,\n41:             namespace=namespace,\n42:             ttl=ttl,\n43:             workload_manager_url=workload_manager_url,\n44:             router_url=router_url,\n45:             session_id=session_id,\n46:             verbose=False,\n47:         ) as client:\n48:             try:\n49:                 if code:\n50:                     output = client.run_code(language=language, code=code)\n51:                     result = {\n52:                         \"success\": True,\n53:                         \"output\": output,\n54:                         \"error\": None,\n55:                         \"session_id\": client.session_id,\n56:                         \"type\": \"code\",\n57:                         \"language\": language,\n58:                     }\n59:                 elif command:\n60:                     output = client.execute_command(command=command)\n61:                     result = {\n62:                         \"success\": True,\n63:                         \"output\": output,\n64:                         \"error\": None,\n65:                         \"session_id\": client.session_id,\n66:                         \"type\": \"command\",\n67:                         \"command\": command,\n68:                     }\n69: \n70:                 return result\n71: \n72:             except CommandExecutionError as e:\n73:                 return {\n74:                     \"success\": False,\n75:                     \"output\": None,\n76:                     \"error\": str(e),\n77:                     \"session_id\": client.session_id,\n78:                     \"exit_code\": e.exit_code,\n79:                     \"stderr\": e.stderr,\n80:                 }\n81:             except Exception as e:\n82:                 return {\n83:                     \"success\": False,\n84:                     \"output\": None,\n85:                     \"error\": str(e),\n86:                     \"session_id\": client.session_id,\n87:                 }\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"from collections.abc import Generator\nfrom typing import Any, Optional\nfrom dify_plugin import Tool\nfrom dify_plugin.entities.tool import ToolInvokeMessage\nfrom agentcube import CodeInterpreterClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\nclass AgentcubeCodeInterpreterTool(Tool):\n    def _invoke(\n        self,\n        tool_parameters: dict[str, Any]\n    ) -> Generator[ToolInvokeMessage, None, None]:\n        try:\n            result = self.execute(**tool_parameters)\n            yield self.create_json_message(result)\n        except Exception as e:\n            yield self.create_text_message(f\"Error: {str(e)}\")\n\n    def execute(","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/integrations/dify-plugin/tools/agentcube-code-interpreter.py","time":{"start":1775889552308,"end":1775889552341}}}}
