nvocation(\n         self,\n         endpoint: str,\n-        payload: dict[str, Any],\n-        headers: dict[str, str] | None,\n+        payload: Dict[str, Any],\n+        headers: Optional[Dict[str, str]],\n         workspace_path: Path,\n-    ) -> dict[str, Any]:\n+    ) -> Dict[str, Any]:\n         \"\"\"Invoke agent via direct HTTP.\"\"\"\n         async with httpx.AsyncClient(timeout=60.0) as client:\n             response = await client.post(\n                 endpoint,\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/invoke_runtime.py","before":"\"\"\"Runtime for the invoke command.\"\"\"\n\nimport asyncio\nimport logging\nfrom pathlib import Path\nfrom typing import Any\n\nimport httpx\n\nlogger = logging.getLogger(__name__)\n\n\nclass InvokeRuntime:\n    \"\"\"Runtime for invoking published agents.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        \"\"\"Initialize the invoke runtime.\"\"\"\n        self.verbose = verbose\n        self.provider = provider\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n    def invoke(\n        self, workspace_path: Path, payload: dict[str, Any], headers: dict[str, str] | None = None\n    ) -> Any:\n        \"\"\"Invoke a published agent with the given payload.\"\"\"\n        logger.info(f\"Invoking agent at: {workspace_path}\")\n\n        metadata, endpoint, namespace = self._validate_invoke_prerequisites(workspace_path)\n\n        if (\n            self.provider == \"agentcube\"\n            and metadata.k8s_deployment\n            and metadata.k8s_deployment.get(\"type\") == \"AgentRuntime\"\n        ):\n            base_url = endpoint.rsplit(\"/\", 1)[0]\n            endpoint = (\n                f\"{base_url}/v1/namespaces/{namespace}/agent-runtimes/\"\n                f\"{metadata.agent_name}/invocations/\"\n            )\n\n        headers = headers or {}\n        if metadata.session_id:\n            headers[\"X-Agentcube-Session-Id\"] = metadata.session_id\n\n        try:\n            result = asyncio.run(self._invoke_agent_via_agentcube(\n                agent_id=metadata.agent_id or metadata.agent_name,\n                payload=payload,\n                headers=headers,\n                endpoint=endpoint,\n                workspace_path=workspace_path,\n            ))\n            return result\n        except Exception:\n            if endpoint.startswith(\"http\"):\n                return asyncio.run(self._direct_http_invocation(\n                    endpoint=endpoint,\n                    payload=payload,\n                    headers=headers,\n                    workspace_path=workspace_path,\n                ))\n            else:\n                return {\"error\": \"Invalid endpoint format\", \"endpoint\": endpoint}\n\n    def _validate_invoke_prerequisites(self, workspace_path: Path) -> tuple:\n        \"\"\"Validate that invocation prerequisites are met.\"\"\"\n        from agentcube.services.metadata_service import MetadataService\n\n        metadata_service = MetadataService(verbose=self.verbose)\n        metadata = metadata_service.load_metadata(workspace_path)\n\n        if not metadata.agent_id and not metadata.agent_endpoint:\n            raise ValueError(\n                \"Agent has not been published. Please run 'agentcube publish' first.\"\n            )\n\n        endpoint = metadata.agent_endpoint or (\n            metadata.k8s_deployment.get(\"service_url\") if metadata.k8s_deployment else None\n        )\n\n        if not endpoint:\n            raise ValueError(\"No endpoint found in metadata. Please publish the agent first.\")\n\n        namespace = (\n            metadata.k8s_deployment.get(\"namespace\") if metadata.k8s_deployment else \"default\"\n        )\n\n        return metadata, endpoint, namespace\n\n    async def _invoke_agent_via_agentcube(\n        self,\n        agent_id: str,\n        payload: dict[str, Any],\n        headers: dict[str, str] | None,\n        endpoint: str,\n        workspace_path: Path,\n    ) -> Any:\n        \"\"\"Invoke agent via AgentCube provider.\"\"\"\n        if endpoint.startswith(\"http\"):\n            async with httpx.AsyncClient(timeout=60.0) as client:\n                response = await client.post(\n                    endpoint,\n                    json=payload,\n                    headers=headers,\n                )\n                response.raise_for_status()\n                return response.json()\n        return {\"error\": \"Invalid endpoint format\", \"endpoint\": endpoint}\n\n    async def _direct_http_invocation(\n        self,\n        endpoint: str,\n        payload: dict[str, Any],\n        headers: dict[str, str] | None,\n        workspace_path: Path,\n    ) -> dict[str, Any]:\n        \"\"\"Invoke agent via direct HTTP.\"\"\"\n        async with httpx.AsyncClient(timeout=60.0) as client:\n            response = await client.post(\n                endpoint,\n                json=payload,\n                headers=headers,\n            )\n            response.raise_for_status()\n            return response.json()\n","after":"\"\"\"Runtime for the invoke command.\"\"\"\n\nimport asyncio\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport httpx\n\nlogger = logging.getLogger(__name__)\n\n\nclass InvokeRuntime:\n    \"\"\"Runtime for invoking published agents.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        \"\"\"Initialize the invoke runtime.\"\"\"\n        self.verbose = verbose\n        self.provider = provider\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n    def invoke(\n            self, workspace_path: Path, payload: Dict[str, Any], headers: Optional[Dict[str, str]] = None\n        ) -> Any:\n        \"\"\"Invoke a published agent with the given payload.\"\"\"\n        logger.info(f\"Invoking agent at: {workspace_path}\")\n\n        metadata, endpoint, namespace = self._validate_invoke_prerequisites(workspace_path)\n\n        if (\n            self.provider == \"agentcube\"\n            and metadata.k8s_deployment\n            and metadata.k8s_deployment.get(\"type\") == \"AgentRuntime\"\n        ):\n            base_url = endpoint.rsplit(\"/\", 1)[0]\n            endpoint = (\n                f\"{base_url}/v1/namespaces/{namespace}/agent-runtimes/\"\n                f\"{metadata.agent_name}/invocations/\"\n            )\n\n        headers = headers or {}\n        if metadata.session_id:\n            headers[\"X-Agentcube-Session-Id\"] = metadata.session_id\n\n        try:\n            result = asyncio.run(self._invoke_agent_via_agentcube(\n                agent_id=metadata.agent_id or metadata.agent_name,\n                payload=payload,\n                headers=headers,\n                endpoint=endpoint,\n                workspace_path=workspace_path,\n            ))\n            return result\n        except Exception:\n            if endpoint.startswith(\"http\"):\n                return asyncio.run(self._direct_http_invocation(\n                    endpoint=endpoint,\n                    payload=payload,\n                    headers=headers,\n                    workspace_path=workspace_path,\n                ))\n            else:\n                return {\"error\": \"Invalid endpoint format\", \"endpoint\": endpoint}\n\n    def _validate_invoke_prerequisites(self, workspace_path: Path) -> tuple:\n        \"\"\"Validate that invocation prerequisites are met.\"\"\"\n        from agentcube.services.metadata_service import MetadataService\n\n        metadata_service = MetadataService(verbose=self.verbose)\n        metadata = metadata_service.load_metadata(workspace_path)\n\n        if not metadata.agent_id and not metadata.agent_endpoint:\n            raise ValueError(\n                \"Agent has not been published. Please run 'agentcube publish' first.\"\n            )\n\n        endpoint = metadata.agent_endpoint or (\n            metadata.k8s_deployment.get(\"service_url\") if metadata.k8s_deployment else None\n        )\n\n        if not endpoint:\n            raise ValueError(\"No endpoint found in metadata. Please publish the agent first.\")\n\n        namespace = (\n            metadata.k8s_deployment.get(\"namespace\") if metadata.k8s_deployment else \"default\"\n        )\n\n        return metadata, endpoint, namespace\n\n    async def _invoke_agent_via_agentcube(\n        self,\n        agent_id: str,\n        payload: Dict[str, Any],\n        headers: Optional[Dict[str, str]],\n        endpoint: str,\n        workspace_path: Path,\n    ) -> Any:\n        \"\"\"Invoke agent via AgentCube provider.\"\"\"\n        if endpoint.startswith(\"http\"):\n            async with httpx.AsyncClient(timeout=60.0) as client:\n                response = await client.post(\n                    endpoint,\n                    json=payload,\n                    headers=headers,\n                )\n                response.raise_for_status()\n                return response.json()\n        return {\"error\": \"Invalid endpoint format\", \"endpoint\": endpoint}\n\n    async def _direct_http_invocation(\n        self,\n        endpoint: str,\n        payload: Dict[str, Any],\n        headers: Optional[Dict[str, str]],\n        workspace_path: Path,\n    ) -> Dict[str, Any]:\n        \"\"\"Invoke agent via direct HTTP.\"\"\"\n        async with httpx.AsyncClient(timeout=60.0) as client:\n            response = await client.post(\n                endpoint,\n                json=payload,\n                headers=headers,\n            )\n            response.raise_for_status()\n            return response.json()\n","additions":8,"deletions":8},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/invoke_runtime.py","time":{"start":1775870440714,"end":1775870441374}}}}
