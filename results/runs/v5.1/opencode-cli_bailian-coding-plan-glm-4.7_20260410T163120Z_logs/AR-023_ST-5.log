          return {\n34:                 \"status\": \"not_published\",\n35:                 \"message\": \"Agent has not been published\",\n36:             }\n37: \n38:         try:\n39:             if provider == \"agentcube\":\n40:                 return self._get_cr_k8s_status(metadata)\n41:             elif provider == \"k8s\":\n42:                 return self._get_k8s_status(metadata)\n43:             else:\n44:                 raise ValueError(f\"Unsupported provider: {provider}\")\n45:         except Exception as e:\n46:             logger.error(f\"Error getting status: {e}\")\n47:             return {\n48:                 \"status\": \"error\",\n49:                 \"message\": str(e),\n50:             }\n51: \n52:     def _get_k8s_status(self, metadata: Any) -> dict[str, Any]:\n53:         \"\"\"Get status for standard Kubernetes deployment.\"\"\"\n54:         if not metadata.k8s_deployment:\n55:             return {\n56:                 \"status\": \"not_published\",\n57:                 \"message\": \"No Kubernetes deployment found\",\n58:             }\n59: \n60:         namespace = metadata.k8s_deployment.get(\"namespace\", \"default\")\n61:         deployment_name = metadata.k8s_deployment.get(\"deployment_name\", metadata.agent_name)\n62: \n63:         provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n64: \n65:         try:\n66:             status = provider.get_agent_status(deployment_name)\n67: \n68:             result = {\n69:                 \"status\": status.get(\"status\", \"unknown\"),\n70:                 \"provider\": \"k8s\",\n71:                 \"namespace\": namespace,\n72:                 \"deployment_name\": deployment_name,\n73:                 \"replicas\": status.get(\"replicas\", 0),\n74:                 \"ready_replicas\": status.get(\"ready_replicas\", 0),\n75:             }\n76: \n77:             if status.get(\"status\") == \"not_found\":\n78:                 result[\"message\"] = \"Deployment not found in Kubernetes\"\n79:             elif status.get(\"ready_replicas\", 0) < status.get(\"replicas\", 0):\n80:                 result[\"message\"] = \"Deployment is not fully ready\"\n81: \n82:             return result\n83: \n84:         except Exception as e:\n85:             logger.error(f\"Error getting k8s status: {e}\")\n86:             return {\n87:                 \"status\": \"error\",\n88:                 \"message\": str(e),\n89:                 \"provider\": \"k8s\",\n90:             }\n91: \n92:     def _get_cr_k8s_status(self, metadata: Any) -> dict[str, Any]:\n93:         \"\"\"Get status for AgentCube AgentRuntime CR.\"\"\"\n94:         if not metadata.agent_id:\n95:             return {\n96:                 \"status\": \"not_published\",\n97:                 \"message\": \"Agent has not been published\",\n98:             }\n99: \n100:         namespace = metadata.k8s_deployment.get(\"namespace\") if metadata.k8s_deployment else \"default\"\n101: \n102:         provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n103: \n104:         try:\n105:             cr_object = provider.get_agent_runtime(metadata.agent_name, namespace)\n106: \n107:             if cr_object is None:\n108:                 return {\n109:                     \"status\": \"not_found_in_k8s\",\n110:                     \"message\": \"AgentRuntime not found in Kubernetes\",\n111:                     \"provider\": \"agentcube\",\n112:                     \"namespace\": namespace,\n113:                 }\n114: \n115:             if \"status\" in cr_object:\n116:                 status_info = cr_object[\"status\"]\n117:                 return {\n118:                     \"status\": status_info.get(\"status\", \"created_no_status\"),\n119:                     \"provider\": \"agentcube\",\n120:                     \"namespace\": namespace,\n121:                     \"agent_name\": metadata.agent_name,\n122:                     \"agent_endpoint\": status_info.get(\"agentEndpoint\"),\n123:                     \"message\": status_info.get(\"message\", \"\"),\n124:                 }\n125:             else:\n126:                 return {\n127:                     \"status\": \"created_no_status\",\n128:                     \"message\": \"AgentRuntime created but no status available yet\",\n129:                     \"provider\": \"agentcube\",\n130:                     \"namespace\": namespace,\n131:                 }\n132: \n133:         except Exception as e:\n134:             logger.error(f\"Error getting CR status: {e}\")\n135:             return {\n136:                 \"status\": \"error\",\n137:                 \"message\": str(e),\n138:                 \"provider\": \"agentcube\",\n139:             }\n\n(End of file - total 139 lines)\n</content>","metadata":{"preview":"\"\"\"Runtime for the status command.\"\"\"\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.metadata_service import MetadataService\n\nlogger = logging.getLogger(__name__)\n\n\nclass StatusRuntime:\n    \"\"\"Runtime for checking agent status.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        \"\"\"Initialize the status runtime.\"\"\"\n        self.verbose = verbose\n        self.provider = provider","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/status_runtime.py","time":{"start":1775870400268,"end":1775870400277}}}}
