encode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_status_runtime.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_status_runtime.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_status_runtime.py\n@@ -179,9 +179,9 @@\n             \n             assert status[\"provider\"] == \"k8s\"\n     \n     def test_get_status_unsupported_provider(self, tmp_path: Path) -> None:\n-        \"\"\"Test get_status raises ValueError for unsupported provider.\"\"\"\n+        \"\"\"Test get_status handles unsupported provider gracefully.\"\"\"\n         metadata_file = tmp_path / \"agent_metadata.yaml\"\n         metadata_file.write_text(\"\"\"\n agent_name: test-agent\n entrypoint: python main.py\n@@ -192,10 +192,12 @@\n \"\"\")\n         \n         runtime = StatusRuntime()\n         \n-        with pytest.raises(ValueError, match=\"Unsupported provider\"):\n-            runtime.get_status(tmp_path, provider=\"invalid\")\n+        status = runtime.get_status(tmp_path, provider=\"invalid\")\n+        \n+        assert status[\"status\"] == \"error\"\n+        assert \"Unsupported provider\" in status[\"message\"]\n     \n     def test_get_status_provider_error(self, tmp_path: Path) -> None:\n         \"\"\"Test get_status handles provider errors gracefully.\"\"\"\n         metadata_file = tmp_path / \"agent_metadata.yaml\"\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_status_runtime.py","before":"\"\"\"Tests for StatusRuntime.\"\"\"\n\nimport pytest\nfrom pathlib import Path\nfrom typing import Any, Dict\nfrom unittest.mock import MagicMock, patch\n\nfrom agentcube.runtime.status_runtime import StatusRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\n@pytest.fixture\ndef tmp_path(tmp_path: Path) -> Path:\n    \"\"\"Create a temporary path for testing.\"\"\"\n    return tmp_path\n\n\n@pytest.fixture\ndef mock_agentcube_provider() -> MagicMock:\n    \"\"\"Create a mock AgentCube provider.\"\"\"\n    provider = MagicMock()\n    provider.get_agent_runtime.return_value = {\n        \"metadata\": {\"name\": \"test-agent\"},\n        \"status\": {\n            \"status\": \"Running\",\n            \"agentEndpoint\": \"http://localhost:8080\",\n            \"message\": \"Agent is running\",\n        }\n    }\n    return provider\n\n\n@pytest.fixture\ndef mock_k8s_provider() -> MagicMock:\n    \"\"\"Create a mock Kubernetes provider.\"\"\"\n    provider = MagicMock()\n    provider.get_agent_status.return_value = {\n        \"status\": \"running\",\n        \"replicas\": 2,\n        \"ready_replicas\": 2,\n        \"available_replicas\": 2,\n    }\n    return provider\n\n\nclass TestStatusRuntimeInit:\n    \"\"\"Tests for StatusRuntime.__init__.\"\"\"\n    \n    def test_init_default(self) -> None:\n        \"\"\"Test initialization with default parameters.\"\"\"\n        runtime = StatusRuntime()\n        assert runtime.verbose is False\n        assert runtime.provider == \"agentcube\"\n    \n    def test_init_with_verbose(self) -> None:\n        \"\"\"Test initialization with verbose flag.\"\"\"\n        runtime = StatusRuntime(verbose=True)\n        assert runtime.verbose is True\n        assert runtime.provider == \"agentcube\"\n    \n    def test_init_with_provider(self) -> None:\n        \"\"\"Test initialization with custom provider.\"\"\"\n        runtime = StatusRuntime(provider=\"k8s\")\n        assert runtime.verbose is False\n        assert runtime.provider == \"k8s\"\n    \n    def test_init_with_all_params(self) -> None:\n        \"\"\"Test initialization with all parameters.\"\"\"\n        runtime = StatusRuntime(verbose=True, provider=\"k8s\")\n        assert runtime.verbose is True\n        assert runtime.provider == \"k8s\"\n\n\nclass TestGetStatus:\n    \"\"\"Tests for StatusRuntime.get_status.\"\"\"\n    \n    def test_get_status_not_published(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status returns not_published when agent not published.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\n\"\"\")\n        \n        runtime = StatusRuntime()\n        status = runtime.get_status(tmp_path)\n        \n        assert status[\"status\"] == \"not_published\"\n        assert \"not been published\" in status[\"message\"].lower()\n    \n    def test_get_status_agentcube_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status with agentcube provider.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime(provider=\"agentcube\")\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path)\n            \n            assert status[\"status\"] == \"Running\"\n            assert status[\"provider\"] == \"agentcube\"\n            assert status[\"agent_endpoint\"] == \"http://localhost:8080\"\n    \n    def test_get_status_k8s_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status with k8s provider.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nk8s_deployment:\n  type: Deployment\n  namespace: default\n  deployment_name: test-agent\n  service_url: http://localhost:8080\n\"\"\")\n        \n        runtime = StatusRuntime(provider=\"k8s\")\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 2,\n                \"ready_replicas\": 2,\n                \"available_replicas\": 2,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path)\n            \n            assert status[\"status\"] == \"running\"\n            assert status[\"provider\"] == \"k8s\"\n            assert status[\"replicas\"] == 2\n            assert status[\"ready_replicas\"] == 2\n    \n    def test_get_status_provider_override(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status with provider parameter override.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime(provider=\"agentcube\")\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 1,\n                \"ready_replicas\": 1,\n                \"available_replicas\": 1,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path, provider=\"k8s\")\n            \n            assert status[\"provider\"] == \"k8s\"\n    \n    def test_get_status_unsupported_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status raises ValueError for unsupported provider.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime()\n        \n        with pytest.raises(ValueError, match=\"Unsupported provider\"):\n            runtime.get_status(tmp_path, provider=\"invalid\")\n    \n    def test_get_status_provider_error(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status handles provider errors gracefully.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.side_effect = Exception(\"Provider error\")\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path)\n            \n            assert status[\"status\"] == \"error\"\n            assert \"Provider error\" in status[\"message\"]\n\n\nclass TestGetK8sStatus:\n    \"\"\"Tests for StatusRuntime._get_k8s_status.\"\"\"\n    \n    def test_get_k8s_status_success(self) -> None:\n        \"\"\"Test successful k8s status retrieval.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"test-ns\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 3,\n                \"ready_replicas\": 3,\n                \"available_replicas\": 3,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"running\"\n            assert status[\"provider\"] == \"k8s\"\n            assert status[\"namespace\"] == \"test-ns\"\n            assert status[\"deployment_name\"] == \"test-agent\"\n            assert status[\"replicas\"] == 3\n            assert status[\"ready_replicas\"] == 3\n    \n    def test_get_k8s_status_no_deployment(self) -> None:\n        \"\"\"Test k8s status with no k8s_deployment.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n        )\n        \n        runtime = StatusRuntime()\n        status = runtime._get_k8s_status(metadata)\n        \n        assert status[\"status\"] == \"not_published\"\n        assert \"No Kubernetes deployment found\" in status[\"message\"]\n    \n    def test_get_k8s_status_not_found(self) -> None:\n        \"\"\"Test k8s status when deployment not found.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"default\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"not_found\"\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"not_found\"\n            assert \"Deployment not found\" in status[\"message\"]\n    \n    def test_get_k8s_status_partial_ready(self) -> None:\n        \"\"\"Test k8s status when deployment is partially ready.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"default\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 3,\n                \"ready_replicas\": 1,\n                \"available_replicas\": 1,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"running\"\n            assert status[\"replicas\"] == 3\n            assert status[\"ready_replicas\"] == 1\n            assert \"not fully ready\" in status[\"message\"]\n    \n    def test_get_k8s_status_default_namespace(self) -> None:\n        \"\"\"Test k8s status with default namespace.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 1,\n                \"ready_replicas\": 1,\n                \"available_replicas\": 1,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"namespace\"] == \"default\"\n            mock_provider_class.assert_called_once_with(namespace=\"default\", verbose=False)\n    \n    def test_get_k8s_status_deployment_name_fallback(self) -> None:\n        \"\"\"Test k8s status uses agent_name as deployment_name.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"my-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 1,\n                \"ready_replicas\": 1,\n                \"available_replicas\": 1,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"deployment_name\"] == \"my-agent\"\n            mock_provider.get_agent_status.assert_called_once_with(\"my-agent\")\n    \n    def test_get_k8s_status_error(self) -> None:\n        \"\"\"Test k8s status handles provider errors.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"default\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.side_effect = Exception(\"K8s API error\")\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"error\"\n            assert \"K8s API error\" in status[\"message\"]\n\n\nclass TestGetCrK8sStatus:\n    \"\"\"Tests for StatusRuntime._get_cr_k8s_status.\"\"\"\n    \n    def test_get_cr_k8s_status_running(self) -> None:\n        \"\"\"Test CR status when agent is running.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"test-ns\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                    \"message\": \"Agent is running\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"Running\"\n            assert status[\"provider\"] == \"agentcube\"\n            assert status[\"namespace\"] == \"test-ns\"\n            assert status[\"agent_endpoint\"] == \"http://localhost:8080\"\n            assert status[\"message\"] == \"Agent is running\"\n    \n    def test_get_cr_k8s_status_not_published(self) -> None:\n        \"\"\"Test CR status when agent not published.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n        )\n        \n        runtime = StatusRuntime()\n        status = runtime._get_cr_k8s_status(metadata)\n        \n        assert status[\"status\"] == \"not_published\"\n        assert \"not been published\" in status[\"message\"].lower()\n    \n    def test_get_cr_k8s_status_not_found(self) -> None:\n        \"\"\"Test CR status when CR not found in Kubernetes.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = None\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"not_found_in_k8s\"\n            assert \"not found\" in status[\"message\"].lower()\n    \n    def test_get_cr_k8s_status_created_no_status(self) -> None:\n        \"\"\"Test CR status when CR exists but has no status.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"created_no_status\"\n            assert \"no status available\" in status[\"message\"].lower()\n    \n    def test_get_cr_k8s_status_default_namespace(self) -> None:\n        \"\"\"Test CR status with default namespace.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"namespace\"] == \"default\"\n            mock_provider_class.assert_called_once_with(namespace=\"default\", verbose=False)\n            mock_provider.get_agent_runtime.assert_called_once_with(\"test-agent\", \"default\")\n    \n    def test_get_cr_k8s_status_custom_namespace(self) -> None:\n        \"\"\"Test CR status with custom namespace.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"custom-ns\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"namespace\"] == \"custom-ns\"\n            mock_provider_class.assert_called_once_with(namespace=\"custom-ns\", verbose=False)\n            mock_provider.get_agent_runtime.assert_called_once_with(\"test-agent\", \"custom-ns\")\n    \n    def test_get_cr_k8s_status_error(self) -> None:\n        \"\"\"Test CR status handles provider errors.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.side_effect = Exception(\"CR API error\")\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"error\"\n            assert \"CR API error\" in status[\"message\"]\n    \n    def test_get_cr_k8s_status_missing_agent_endpoint(self) -> None:\n        \"\"\"Test CR status when agentEndpoint is missing.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Pending\",\n                    \"message\": \"Agent is starting\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"Pending\"\n            assert status.get(\"agent_endpoint\") is None\n            assert status[\"message\"] == \"Agent is starting\"\n\n\nclass TestStatusVerboseMode:\n    \"\"\"Tests for StatusRuntime verbose mode.\"\"\"\n    \n    def test_verbose_mode_logging(self, tmp_path: Path) -> None:\n        \"\"\"Test verbose mode enables debug logging.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime(verbose=True)\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path)\n            \n            assert status[\"status\"] == \"Running\"\n            mock_provider_class.assert_called_once_with(namespace=\"default\", verbose=True)","after":"\"\"\"Tests for StatusRuntime.\"\"\"\n\nimport pytest\nfrom pathlib import Path\nfrom typing import Any, Dict\nfrom unittest.mock import MagicMock, patch\n\nfrom agentcube.runtime.status_runtime import StatusRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\n@pytest.fixture\ndef tmp_path(tmp_path: Path) -> Path:\n    \"\"\"Create a temporary path for testing.\"\"\"\n    return tmp_path\n\n\n@pytest.fixture\ndef mock_agentcube_provider() -> MagicMock:\n    \"\"\"Create a mock AgentCube provider.\"\"\"\n    provider = MagicMock()\n    provider.get_agent_runtime.return_value = {\n        \"metadata\": {\"name\": \"test-agent\"},\n        \"status\": {\n            \"status\": \"Running\",\n            \"agentEndpoint\": \"http://localhost:8080\",\n            \"message\": \"Agent is running\",\n        }\n    }\n    return provider\n\n\n@pytest.fixture\ndef mock_k8s_provider() -> MagicMock:\n    \"\"\"Create a mock Kubernetes provider.\"\"\"\n    provider = MagicMock()\n    provider.get_agent_status.return_value = {\n        \"status\": \"running\",\n        \"replicas\": 2,\n        \"ready_replicas\": 2,\n        \"available_replicas\": 2,\n    }\n    return provider\n\n\nclass TestStatusRuntimeInit:\n    \"\"\"Tests for StatusRuntime.__init__.\"\"\"\n    \n    def test_init_default(self) -> None:\n        \"\"\"Test initialization with default parameters.\"\"\"\n        runtime = StatusRuntime()\n        assert runtime.verbose is False\n        assert runtime.provider == \"agentcube\"\n    \n    def test_init_with_verbose(self) -> None:\n        \"\"\"Test initialization with verbose flag.\"\"\"\n        runtime = StatusRuntime(verbose=True)\n        assert runtime.verbose is True\n        assert runtime.provider == \"agentcube\"\n    \n    def test_init_with_provider(self) -> None:\n        \"\"\"Test initialization with custom provider.\"\"\"\n        runtime = StatusRuntime(provider=\"k8s\")\n        assert runtime.verbose is False\n        assert runtime.provider == \"k8s\"\n    \n    def test_init_with_all_params(self) -> None:\n        \"\"\"Test initialization with all parameters.\"\"\"\n        runtime = StatusRuntime(verbose=True, provider=\"k8s\")\n        assert runtime.verbose is True\n        assert runtime.provider == \"k8s\"\n\n\nclass TestGetStatus:\n    \"\"\"Tests for StatusRuntime.get_status.\"\"\"\n    \n    def test_get_status_not_published(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status returns not_published when agent not published.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\n\"\"\")\n        \n        runtime = StatusRuntime()\n        status = runtime.get_status(tmp_path)\n        \n        assert status[\"status\"] == \"not_published\"\n        assert \"not been published\" in status[\"message\"].lower()\n    \n    def test_get_status_agentcube_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status with agentcube provider.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime(provider=\"agentcube\")\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path)\n            \n            assert status[\"status\"] == \"Running\"\n            assert status[\"provider\"] == \"agentcube\"\n            assert status[\"agent_endpoint\"] == \"http://localhost:8080\"\n    \n    def test_get_status_k8s_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status with k8s provider.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nk8s_deployment:\n  type: Deployment\n  namespace: default\n  deployment_name: test-agent\n  service_url: http://localhost:8080\n\"\"\")\n        \n        runtime = StatusRuntime(provider=\"k8s\")\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 2,\n                \"ready_replicas\": 2,\n                \"available_replicas\": 2,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path)\n            \n            assert status[\"status\"] == \"running\"\n            assert status[\"provider\"] == \"k8s\"\n            assert status[\"replicas\"] == 2\n            assert status[\"ready_replicas\"] == 2\n    \n    def test_get_status_provider_override(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status with provider parameter override.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime(provider=\"agentcube\")\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 1,\n                \"ready_replicas\": 1,\n                \"available_replicas\": 1,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path, provider=\"k8s\")\n            \n            assert status[\"provider\"] == \"k8s\"\n    \n    def test_get_status_unsupported_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status handles unsupported provider gracefully.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime()\n        \n        status = runtime.get_status(tmp_path, provider=\"invalid\")\n        \n        assert status[\"status\"] == \"error\"\n        assert \"Unsupported provider\" in status[\"message\"]\n    \n    def test_get_status_provider_error(self, tmp_path: Path) -> None:\n        \"\"\"Test get_status handles provider errors gracefully.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.side_effect = Exception(\"Provider error\")\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path)\n            \n            assert status[\"status\"] == \"error\"\n            assert \"Provider error\" in status[\"message\"]\n\n\nclass TestGetK8sStatus:\n    \"\"\"Tests for StatusRuntime._get_k8s_status.\"\"\"\n    \n    def test_get_k8s_status_success(self) -> None:\n        \"\"\"Test successful k8s status retrieval.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"test-ns\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 3,\n                \"ready_replicas\": 3,\n                \"available_replicas\": 3,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"running\"\n            assert status[\"provider\"] == \"k8s\"\n            assert status[\"namespace\"] == \"test-ns\"\n            assert status[\"deployment_name\"] == \"test-agent\"\n            assert status[\"replicas\"] == 3\n            assert status[\"ready_replicas\"] == 3\n    \n    def test_get_k8s_status_no_deployment(self) -> None:\n        \"\"\"Test k8s status with no k8s_deployment.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n        )\n        \n        runtime = StatusRuntime()\n        status = runtime._get_k8s_status(metadata)\n        \n        assert status[\"status\"] == \"not_published\"\n        assert \"No Kubernetes deployment found\" in status[\"message\"]\n    \n    def test_get_k8s_status_not_found(self) -> None:\n        \"\"\"Test k8s status when deployment not found.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"default\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"not_found\"\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"not_found\"\n            assert \"Deployment not found\" in status[\"message\"]\n    \n    def test_get_k8s_status_partial_ready(self) -> None:\n        \"\"\"Test k8s status when deployment is partially ready.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"default\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 3,\n                \"ready_replicas\": 1,\n                \"available_replicas\": 1,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"running\"\n            assert status[\"replicas\"] == 3\n            assert status[\"ready_replicas\"] == 1\n            assert \"not fully ready\" in status[\"message\"]\n    \n    def test_get_k8s_status_default_namespace(self) -> None:\n        \"\"\"Test k8s status with default namespace.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 1,\n                \"ready_replicas\": 1,\n                \"available_replicas\": 1,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"namespace\"] == \"default\"\n            mock_provider_class.assert_called_once_with(namespace=\"default\", verbose=False)\n    \n    def test_get_k8s_status_deployment_name_fallback(self) -> None:\n        \"\"\"Test k8s status uses agent_name as deployment_name.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"my-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.return_value = {\n                \"status\": \"running\",\n                \"replicas\": 1,\n                \"ready_replicas\": 1,\n                \"available_replicas\": 1,\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"deployment_name\"] == \"my-agent\"\n            mock_provider.get_agent_status.assert_called_once_with(\"my-agent\")\n    \n    def test_get_k8s_status_error(self) -> None:\n        \"\"\"Test k8s status handles provider errors.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            k8s_deployment={\n                \"type\": \"Deployment\",\n                \"namespace\": \"default\",\n                \"deployment_name\": \"test-agent\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.KubernetesProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_status.side_effect = Exception(\"K8s API error\")\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"error\"\n            assert \"K8s API error\" in status[\"message\"]\n\n\nclass TestGetCrK8sStatus:\n    \"\"\"Tests for StatusRuntime._get_cr_k8s_status.\"\"\"\n    \n    def test_get_cr_k8s_status_running(self) -> None:\n        \"\"\"Test CR status when agent is running.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"test-ns\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                    \"message\": \"Agent is running\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"Running\"\n            assert status[\"provider\"] == \"agentcube\"\n            assert status[\"namespace\"] == \"test-ns\"\n            assert status[\"agent_endpoint\"] == \"http://localhost:8080\"\n            assert status[\"message\"] == \"Agent is running\"\n    \n    def test_get_cr_k8s_status_not_published(self) -> None:\n        \"\"\"Test CR status when agent not published.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n        )\n        \n        runtime = StatusRuntime()\n        status = runtime._get_cr_k8s_status(metadata)\n        \n        assert status[\"status\"] == \"not_published\"\n        assert \"not been published\" in status[\"message\"].lower()\n    \n    def test_get_cr_k8s_status_not_found(self) -> None:\n        \"\"\"Test CR status when CR not found in Kubernetes.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = None\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"not_found_in_k8s\"\n            assert \"not found\" in status[\"message\"].lower()\n    \n    def test_get_cr_k8s_status_created_no_status(self) -> None:\n        \"\"\"Test CR status when CR exists but has no status.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"created_no_status\"\n            assert \"no status available\" in status[\"message\"].lower()\n    \n    def test_get_cr_k8s_status_default_namespace(self) -> None:\n        \"\"\"Test CR status with default namespace.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"namespace\"] == \"default\"\n            mock_provider_class.assert_called_once_with(namespace=\"default\", verbose=False)\n            mock_provider.get_agent_runtime.assert_called_once_with(\"test-agent\", \"default\")\n    \n    def test_get_cr_k8s_status_custom_namespace(self) -> None:\n        \"\"\"Test CR status with custom namespace.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"custom-ns\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"namespace\"] == \"custom-ns\"\n            mock_provider_class.assert_called_once_with(namespace=\"custom-ns\", verbose=False)\n            mock_provider.get_agent_runtime.assert_called_once_with(\"test-agent\", \"custom-ns\")\n    \n    def test_get_cr_k8s_status_error(self) -> None:\n        \"\"\"Test CR status handles provider errors.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.side_effect = Exception(\"CR API error\")\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"error\"\n            assert \"CR API error\" in status[\"message\"]\n    \n    def test_get_cr_k8s_status_missing_agent_endpoint(self) -> None:\n        \"\"\"Test CR status when agentEndpoint is missing.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n        \n        runtime = StatusRuntime()\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Pending\",\n                    \"message\": \"Agent is starting\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime._get_cr_k8s_status(metadata)\n            \n            assert status[\"status\"] == \"Pending\"\n            assert status.get(\"agent_endpoint\") is None\n            assert status[\"message\"] == \"Agent is starting\"\n\n\nclass TestStatusVerboseMode:\n    \"\"\"Tests for StatusRuntime verbose mode.\"\"\"\n    \n    def test_verbose_mode_logging(self, tmp_path: Path) -> None:\n        \"\"\"Test verbose mode enables debug logging.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = StatusRuntime(verbose=True)\n        \n        with patch(\"agentcube.runtime.status_runtime.AgentCubeProvider\") as mock_provider_class:\n            mock_provider = MagicMock()\n            mock_provider.get_agent_runtime.return_value = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\n                    \"status\": \"Running\",\n                    \"agentEndpoint\": \"http://localhost:8080\",\n                }\n            }\n            mock_provider_class.return_value = mock_provider\n            \n            status = runtime.get_status(tmp_path)\n            \n            assert status[\"status\"] == \"Running\"\n            mock_provider_class.assert_called_once_with(namespace=\"default\", verbose=True)","additions":5,"deletions":3},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_status_runtime.py","time":{"start":1775870304641,"end":1775870305323}}}}
