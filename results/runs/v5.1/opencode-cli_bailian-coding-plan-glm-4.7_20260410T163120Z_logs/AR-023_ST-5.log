ons/\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        mock_response = AsyncMock()\n        mock_response.status_code = 200\n        mock_response.json = AsyncMock(return_value={\"result\": \"success\"})\n        mock_response.raise_for_status = MagicMock()\n        \n        async def mock_post(url, json=None, headers=None):\n            return mock_response\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_client.post = mock_post\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = await runtime._invoke_agent_via_agentcube(\n                agent_id=\"test-agent\",\n                payload=payload,\n                headers=headers,\n                endpoint=endpoint,\n                workspace_path=Path(\"/tmp\"),\n            )\n            \n            assert result == {\"result\": \"success\"}\n    \n    @pytest.mark.asyncio\n    async def test_invoke_via_agentcube_http_error(self) -> None:\n        \"\"\"Test invocation handles HTTP errors.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/invocations/\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 500\n            mock_response.raise_for_status.side_effect = httpx.HTTPStatusError(\n                \"Server error\", request=MagicMock(), response=mock_response\n            )\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            with pytest.raises(httpx.HTTPStatusError):\n                await runtime._invoke_agent_via_agentcube(\n                    agent_id=\"test-agent\",\n                    payload=payload,\n                    headers=headers,\n                    endpoint=endpoint,\n                    workspace_path=Path(\"/tmp\"),\n                )\n    \n    @pytest.mark.asyncio\n    async def test_invoke_via_agentcube_invalid_endpoint(self) -> None:\n        \"\"\"Test invocation with invalid endpoint format.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"invalid-endpoint\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        result = await runtime._invoke_agent_via_agentcube(\n            agent_id=\"test-agent\",\n            payload=payload,\n            headers=headers,\n            endpoint=endpoint,\n            workspace_path=Path(\"/tmp\"),\n        )\n        \n        assert \"error\" in result\n        assert result[\"endpoint\"] == endpoint\n\n\nclass TestDirectHttpInvocation:\n    \"\"\"Tests for InvokeRuntime._direct_http_invocation.\"\"\"\n    \n    @pytest.mark.asyncio\n    async def test_direct_http_invocation_success(self) -> None:\n        \"\"\"Test successful direct HTTP invocation.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/invoke\"\n        payload = {\"message\": \"hello\"}\n        headers = {\"X-Custom-Header\": \"value\"}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = await runtime._direct_http_invocation(\n                endpoint=endpoint,\n                payload=payload,\n                headers=headers,\n                workspace_path=Path(\"/tmp\"),\n            )\n            \n            assert result == {\"result\": \"success\"}\n            mock_client.post.assert_called_once_with(\n                endpoint,\n                json=payload,\n                headers=headers,\n            )\n    \n    @pytest.mark.asyncio\n    async def test_direct_http_invocation_timeout(self) -> None:\n        \"\"\"Test direct HTTP invocation handles timeout.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/invoke\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_client.post.side_effect = httpx.TimeoutException(\"Request timed out\")\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            with pytest.raises(httpx.TimeoutException):\n                await runtime._direct_http_invocation(\n                    endpoint=endpoint,\n                    payload=payload,\n                    headers=headers,\n                    workspace_path=Path(\"/tmp\"),\n                )\n    \n    @pytest.mark.asyncio\n    async def test_direct_http_invocation_connection_error(self) -> None:\n        \"\"\"Test direct HTTP invocation handles connection errors.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/invoke\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_client.post.side_effect = httpx.ConnectError(\"Connection failed\")\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            with pytest.raises(httpx.ConnectError):\n                await runtime._direct_http_invocation(\n                    endpoint=endpoint,\n                    payload=payload,\n                    headers=headers,\n                    workspace_path=Path(\"/tmp\"),\n                )\n\n\nclass TestInvoke:\n    \"\"\"Tests for InvokeRuntime.invoke.\"\"\"\n    \n    def test_invoke_success_agentcube_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test successful invoke with agentcube provider.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nagent_endpoint: http://localhost:8080\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"agentcube\")\n        payload = {\"message\": \"hello\"}\n        headers = {\"X-Custom-Header\": \"value\"}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = runtime.invoke(tmp_path, payload, headers)\n            \n            assert result == {\"result\": \"success\"}\n    \n    def test_invoke_with_session_id(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke includes session_id header.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nagent_endpoint: http://localhost:8080\nsession_id: session123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"agentcube\")\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            \n            async def mock_post(url, json=None, headers=None):\n                assert headers.get(\"X-Agentcube-Session-Id\") == \"session123\"\n                return mock_response\n            \n            mock_client.post = mock_post\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = runtime.invoke(tmp_path, payload, headers)\n            \n            assert result == {\"result\": \"success\"}\n    \n    def test_invoke_k8s_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke with k8s provider.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_endpoint: http://localhost:8080\nk8s_deployment:\n  type: Deployment\n  namespace: default\n  service_url: http://localhost:8080\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"k8s\")\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = runtime.invoke(tmp_path, payload, headers)\n            \n            assert result == {\"result\": \"success\"}\n    \n    def test_invoke_not_published(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke raises ValueError when agent not published.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        payload = {\"message\": \"hello\"}\n        \n        with pytest.raises(ValueError, match=\"Agent has not been published\"):\n            runtime.invoke(tmp_path, payload)\n    \n    def test_invoke_no_endpoint(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke raises ValueError when no endpoint found.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        payload = {\"message\": \"hello\"}\n        \n        with pytest.raises(ValueError, match=\"No endpoint found\"):\n            runtime.invoke(tmp_path, payload)\n    \n    def test_invoke_agentcube_error_fallback(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke falls back to direct HTTP on agentcube error.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_endpoint: http://localhost:8080\nk8s_deployment:\n  type: Deployment\n  namespace: default\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"agentcube\")\n        payload = {\"message\": \"hello\"}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            \n            async def mock_post_error(url, json=None, headers=None):\n                raise httpx.ConnectError(\"Connection failed\")\n            \n            async def mock_post_success(url, json=None, headers=None):\n                mock_response = AsyncMock()\n                mock_response.status_code = 200\n                mock_response.json.return_value = {\"result\": \"success\"}\n                mock_response.raise_for_status = MagicMock()\n                return mock_response\n            \n            call_count = [0]\n            \n            async def mock_post(url, json=None, headers=None):\n                call_count[0] += 1\n                if call_count[0] == 1:\n                    raise httpx.ConnectError(\"Connection failed\")\n                return await mock_post_success(url, json, headers)\n            \n            mock_client.post = mock_post\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = runtime.invoke(tmp_path, payload)\n            \n            assert result == {\"result\": \"success\"}\n            assert call_count[0] == 2\n    \n    def test_invoke_invalid_endpoint_format(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke handles invalid endpoint format.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_endpoint: invalid-endpoint\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"agentcube\")\n        payload = {\"message\": \"hello\"}\n        \n        result = runtime.invoke(tmp_path, payload)\n        \n        assert \"error\" in result\n        assert result[\"endpoint\"] == \"invalid-endpoint\"\n    \n    def test_invoke_verbose_logging(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke with verbose logging enabled.\"\"\"\n