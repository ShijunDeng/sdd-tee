/blob/main/docs/configuration.md#reportAttributeAccessIssue"}},{"range":{"start":{"line":264,"character":17},"end":{"line":264,"character":23}},"message":"Cannot access attribute \"status\" for class \"Exception\"\n  Attribute \"status\" is unknown","severity":1,"code":"reportAttributeAccessIssue","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportAttributeAccessIssue"}}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/cli/main.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/models/pack_models.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/metadata_service.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_invoke_runtime.py":[{"range":{"start":{"line":430,"character":31},"end":{"line":430,"character":34}},"message":"\"get\" is not a known attribute of \"None\"","severity":1,"code":"reportOptionalMemberAccess","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportOptionalMemberAccess"}}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_status_runtime.py":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_invoke_runtime.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_invoke_runtime.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_invoke_runtime.py\n@@ -215,15 +215,19 @@\n endpoint = \"http://localhost:8080/invocations/\"\n payload = {\"message\": \"hello\"}\n headers = {}\n \n+mock_response = AsyncMock()\n+mock_response.status_code = 200\n+mock_response.json = AsyncMock(return_value={\"result\": \"success\"})\n+mock_response.raise_for_status = MagicMock()\n+\n+async def mock_post(url, json=None, headers=None):\n+    return mock_response\n+\n with patch(\"httpx.AsyncClient\") as mock_client_class:\n     mock_client = AsyncMock()\n-    mock_response = AsyncMock()\n-    mock_response.status_code = 200\n-    mock_response.json.return_value = {\"result\": \"success\"}\n-    mock_response.raise_for_status = MagicMock()\n-    mock_client.post.return_value = mock_response\n+    mock_client.post = mock_post\n     mock_client.__aenter__.return_value = mock_client\n     mock_client_class.return_value = mock_client\n     \n     result = await runtime._invoke_agent_via_agentcube(\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_invoke_runtime.py","before":"\"\"\"Tests for InvokeRuntime.\"\"\"\n\nimport asyncio\nimport json\nimport pytest\nfrom pathlib import Path\nfrom typing import Any, Dict\nfrom unittest.mock import MagicMock, AsyncMock, patch\n\nimport httpx\n\nfrom agentcube.runtime.invoke_runtime import InvokeRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\n@pytest.fixture\ndef tmp_path(tmp_path: Path) -> Path:\n    \"\"\"Create a temporary path for testing.\"\"\"\n    return tmp_path\n\n\n@pytest.fixture\ndef mock_metadata_service(tmp_path: Path) -> MagicMock:\n    \"\"\"Create a mock metadata service.\"\"\"\n    service = MagicMock()\n    \n    def load_side_effect(path: Path) -> AgentMetadata:\n        if path == tmp_path / \"no_metadata\":\n            raise FileNotFoundError(f\"No metadata file found in {path}\")\n        return AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            agent_endpoint=\"http://localhost:8080\",\n            session_id=\"session123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n    \n    service.load_metadata.side_effect = load_side_effect\n    return service\n\n\n@pytest.fixture\ndef mock_httpx_client() -> AsyncMock:\n    \"\"\"Create a mock httpx AsyncClient.\"\"\"\n    client = AsyncMock()\n    \n    response = AsyncMock()\n    response.status_code = 200\n    response.json.return_value = {\"result\": \"success\", \"data\": \"test response\"}\n    response.raise_for_status = MagicMock()\n    \n    client.post.return_value = response\n    return client\n\n\nclass TestInvokeRuntimeInit:\n    \"\"\"Tests for InvokeRuntime.__init__.\"\"\"\n    \n    def test_init_default(self) -> None:\n        \"\"\"Test initialization with default parameters.\"\"\"\n        runtime = InvokeRuntime()\n        assert runtime.verbose is False\n        assert runtime.provider == \"agentcube\"\n    \n    def test_init_with_verbose(self) -> None:\n        \"\"\"Test initialization with verbose flag.\"\"\"\n        runtime = InvokeRuntime(verbose=True)\n        assert runtime.verbose is True\n        assert runtime.provider == \"agentcube\"\n    \n    def test_init_with_provider(self) -> None:\n        \"\"\"Test initialization with custom provider.\"\"\"\n        runtime = InvokeRuntime(provider=\"k8s\")\n        assert runtime.verbose is False\n        assert runtime.provider == \"k8s\"\n    \n    def test_init_with_all_params(self) -> None:\n        \"\"\"Test initialization with all parameters.\"\"\"\n        runtime = InvokeRuntime(verbose=True, provider=\"k8s\")\n        assert runtime.verbose is True\n        assert runtime.provider == \"k8s\"\n\n\nclass TestValidateInvokePrerequisites:\n    \"\"\"Tests for InvokeRuntime._validate_invoke_prerequisites.\"\"\"\n    \n    def test_validate_success_with_agent_id(self, tmp_path: Path) -> None:\n        \"\"\"Test validation with agent_id present.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nagent_endpoint: http://localhost:8080\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        metadata, endpoint, namespace = runtime._validate_invoke_prerequisites(tmp_path)\n        \n        assert metadata.agent_id == \"abc123\"\n        assert endpoint == \"http://localhost:8080\"\n        assert namespace == \"default\"\n    \n    def test_validate_success_with_endpoint(self, tmp_path: Path) -> None:\n        \"\"\"Test validation with agent_endpoint present.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_endpoint: http://localhost:8080\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        metadata, endpoint, namespace = runtime._validate_invoke_prerequisites(tmp_path)\n        \n        assert metadata.agent_endpoint == \"http://localhost:8080\"\n        assert endpoint == \"http://localhost:8080\"\n        assert namespace == \"default\"\n    \n    def test_validate_with_k8s_deployment(self, tmp_path: Path) -> None:\n        \"\"\"Test validation with k8s_deployment.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: test-ns\n  service_url: http://localhost:8080\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        metadata, endpoint, namespace = runtime._validate_invoke_prerequisites(tmp_path)\n        \n        assert metadata.agent_id == \"abc123\"\n        assert endpoint == \"http://localhost:8080\"\n        assert namespace == \"test-ns\"\n    \n    def test_validate_not_published(self, tmp_path: Path) -> None:\n        \"\"\"Test validation raises ValueError when agent not published.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        with pytest.raises(ValueError, match=\"Agent has not been published\"):\n            runtime._validate_invoke_prerequisites(tmp_path)\n    \n    def test_validate_no_endpoint(self, tmp_path: Path) -> None:\n        \"\"\"Test validation raises ValueError when no endpoint found.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        with pytest.raises(ValueError, match=\"No endpoint found\"):\n            runtime._validate_invoke_prerequisites(tmp_path)\n    \n    def test_validate_no_metadata(self, tmp_path: Path) -> None:\n        \"\"\"Test validation raises FileNotFoundError when metadata not found.\"\"\"\n        runtime = InvokeRuntime()\n        with pytest.raises(FileNotFoundError, match=\"No metadata file found\"):\n            runtime._validate_invoke_prerequisites(tmp_path / \"nonexistent\")\n\n\nclass TestInvokeAgentViaAgentcube:\n    \"\"\"Tests for InvokeRuntime._invoke_agent_via_agentcube.\"\"\"\n    \n    @pytest.mark.asyncio\n    async def test_invoke_via_agentcube_success(self) -> None:\n        \"\"\"Test successful invocation via AgentCube provider.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/v1/namespaces/default/agent-runtimes/test-agent/invocations/\"\n        payload = {\"message\": \"hello\"}\n        headers = {\"X-Custom-Header\": \"value\"}\n        \n        mock_response = AsyncMock()\n        mock_response.status_code = 200\n        mock_response.json = AsyncMock(return_value={\"result\": \"success\"})\n        mock_response.raise_for_status = MagicMock()\n        \n        async def mock_post(url, json=None, headers=None):\n            return mock_response\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_client.post = mock_post\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = await runtime._invoke_agent_via_agentcube(\n                agent_id=\"test-agent\",\n                payload=payload,\n                headers=headers,\n                endpoint=endpoint,\n                workspace_path=Path(\"/tmp\"),\n            )\n            \n            assert result == {\"result\": \"success\"}\n    \n    @pytest.mark.asyncio\n    async def test_invoke_via_agentcube_with_session_id(self) -> None:\n        \"\"\"Test invocation with session_id header.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/invocations/\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = await runtime._invoke_agent_via_agentcube(\n                agent_id=\"test-agent\",\n                payload=payload,\n                headers=headers,\n                endpoint=endpoint,\n                workspace_path=Path(\"/tmp\"),\n            )\n            \n            assert result == {\"result\": \"success\"}\n    \n    @pytest.mark.asyncio\n    async def test_invoke_via_agentcube_http_error(self) -> None:\n        \"\"\"Test invocation handles HTTP errors.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/invocations/\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 500\n            mock_response.raise_for_status.side_effect = httpx.HTTPStatusError(\n                \"Server error\", request=MagicMock(), response=mock_response\n            )\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            with pytest.raises(httpx.HTTPStatusError):\n                await runtime._invoke_agent_via_agentcube(\n                    agent_id=\"test-agent\",\n                    payload=payload,\n                    headers=headers,\n                    endpoint=endpoint,\n                    workspace_path=Path(\"/tmp\"),\n                )\n    \n    @pytest.mark.asyncio\n    async def test_invoke_via_agentcube_invalid_endpoint(self) -> None:\n        \"\"\"Test invocation with invalid endpoint format.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"invalid-endpoint\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        result = await runtime._invoke_agent_via_agentcube(\n            agent_id=\"test-agent\",\n            payload=payload,\n            headers=headers,\n            endpoint=endpoint,\n            workspace_path=Path(\"/tmp\"),\n        )\n        \n        assert \"error\" in result\n        assert result[\"endpoint\"] == endpoint\n\n\nclass TestDirectHttpInvocation:\n    \"\"\"Tests for InvokeRuntime._direct_http_invocation.\"\"\"\n    \n    @pytest.mark.asyncio\n    async def test_direct_http_invocation_success(self) -> None:\n        \"\"\"Test successful direct HTTP invocation.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/invoke\"\n        payload = {\"message\": \"hello\"}\n        headers = {\"X-Custom-Header\": \"value\"}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = await runtime._direct_http_invocation(\n                endpoint=endpoint,\n                payload=payload,\n                headers=headers,\n                workspace_path=Path(\"/tmp\"),\n            )\n            \n            assert result == {\"result\": \"success\"}\n            mock_client.post.assert_called_once_with(\n                endpoint,\n                json=payload,\n                headers=headers,\n            )\n    \n    @pytest.mark.asyncio\n    async def test_direct_http_invocation_timeout(self) -> None:\n        \"\"\"Test direct HTTP invocation handles timeout.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/invoke\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_client.post.side_effect = httpx.TimeoutException(\"Request timed out\")\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            with pytest.raises(httpx.TimeoutException):\n                await runtime._direct_http_invocation(\n                    endpoint=endpoint,\n                    payload=payload,\n                    headers=headers,\n                    workspace_path=Path(\"/tmp\"),\n                )\n    \n    @pytest.mark.asyncio\n    async def test_direct_http_invocation_connection_error(self) -> None:\n        \"\"\"Test direct HTTP invocation handles connection errors.\"\"\"\n        runtime = InvokeRuntime()\n        endpoint = \"http://localhost:8080/invoke\"\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_client.post.side_effect = httpx.ConnectError(\"Connection failed\")\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            with pytest.raises(httpx.ConnectError):\n                await runtime._direct_http_invocation(\n                    endpoint=endpoint,\n                    payload=payload,\n                    headers=headers,\n                    workspace_path=Path(\"/tmp\"),\n                )\n\n\nclass TestInvoke:\n    \"\"\"Tests for InvokeRuntime.invoke.\"\"\"\n    \n    def test_invoke_success_agentcube_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test successful invoke with agentcube provider.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nagent_endpoint: http://localhost:8080\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"agentcube\")\n        payload = {\"message\": \"hello\"}\n        headers = {\"X-Custom-Header\": \"value\"}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = runtime.invoke(tmp_path, payload, headers)\n            \n            assert result == {\"result\": \"success\"}\n    \n    def test_invoke_with_session_id(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke includes session_id header.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nagent_endpoint: http://localhost:8080\nsession_id: session123\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"agentcube\")\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            \n            async def mock_post(url, json=None, headers=None):\n                assert headers.get(\"X-Agentcube-Session-Id\") == \"session123\"\n                return mock_response\n            \n            mock_client.post = mock_post\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = runtime.invoke(tmp_path, payload, headers)\n            \n            assert result == {\"result\": \"success\"}\n    \n    def test_invoke_k8s_provider(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke with k8s provider.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_endpoint: http://localhost:8080\nk8s_deployment:\n  type: Deployment\n  namespace: default\n  service_url: http://localhost:8080\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"k8s\")\n        payload = {\"message\": \"hello\"}\n        headers = {}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = runtime.invoke(tmp_path, payload, headers)\n            \n            assert result == {\"result\": \"success\"}\n    \n    def test_invoke_not_published(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke raises ValueError when agent not published.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        payload = {\"message\": \"hello\"}\n        \n        with pytest.raises(ValueError, match=\"Agent has not been published\"):\n            runtime.invoke(tmp_path, payload)\n    \n    def test_invoke_no_endpoint(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke raises ValueError when no endpoint found.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        payload = {\"message\": \"hello\"}\n        \n        with pytest.raises(ValueError, match=\"No endpoint found\"):\n            runtime.invoke(tmp_path, payload)\n    \n    def test_invoke_agentcube_error_fallback(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke falls back to direct HTTP on agentcube error.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_endpoint: http://localhost:8080\nk8s_deployment:\n  type: Deployment\n  namespace: default\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"agentcube\")\n        payload = {\"message\": \"hello\"}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            \n            async def mock_post_error(url, json=None, headers=None):\n                raise httpx.ConnectError(\"Connection failed\")\n            \n            async def mock_post_success(url, json=None, headers=None):\n                mock_response = AsyncMock()\n                mock_response.status_code = 200\n                mock_response.json.return_value = {\"result\": \"success\"}\n                mock_response.raise_for_status = MagicMock()\n                return mock_response\n            \n            call_count = [0]\n            \n            async def mock_post(url, json=None, headers=None):\n                call_count[0] += 1\n                if call_count[0] == 1:\n                    raise httpx.ConnectError(\"Connection failed\")\n                return await mock_post_success(url, json, headers)\n            \n            mock_client.post = mock_post\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = runtime.invoke(tmp_path, payload)\n            \n            assert result == {\"result\": \"success\"}\n            assert call_count[0] == 2\n    \n    def test_invoke_invalid_endpoint_format(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke handles invalid endpoint format.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_endpoint: invalid-endpoint\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = InvokeRuntime(provider=\"agentcube\")\n        payload = {\"message\": \"hello\"}\n        \n        result = runtime.invoke(tmp_path, payload)\n        \n        assert \"error\" in result\n        assert result[\"endpoint\"] == \"invalid-endpoint\"\n    \n    def test_invoke_verbose_logging(self, tmp_path: Path) -> None:\n        \"\"\"Test invoke with verbose logging enabled.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_endpoint: http://localhost:8080\nk8s_deployment:\n  type: AgentRuntime\n  namespace: default\n\"\"\")\n        \n        runtime = InvokeRuntime(verbose=True)\n        payload = {\"message\": \"hello\"}\n        \n        with patch(\"httpx.AsyncClient\") as mock_client_class:\n            mock_client = AsyncMock()\n            mock_response = AsyncMock()\n            mock_response.status_code = 200\n            mock_response.json.return_value = {\"result\": \"success\"}\n            mock_response.raise_for_status = MagicMock()\n            mock_client.post.return_value = mock_response\n            mock_client.__aenter__.return_value = mock_client\n            mock_client_class.return_value = mock_client\n            \n            result = runtime.invoke(tmp_path, payload)\n            \n            assert result == {\"result\": \"success\"}","after":"\"\"\"Tests for InvokeRuntime.\"\"\"\n\nimport asyncio\nimport json\nimport pytest\nfrom pathlib import Path\nfrom typing import Any, Dict\nfrom unittest.mock import MagicMock, AsyncMock, patch\n\nimport httpx\n\nfrom agentcube.runtime.invoke_runtime import InvokeRuntime\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\n@pytest.fixture\ndef tmp_path(tmp_path: Path) -> Path:\n    \"\"\"Create a temporary path for testing.\"\"\"\n    return tmp_path\n\n\n@pytest.fixture\ndef mock_metadata_service(tmp_path: Path) -> MagicMock:\n    \"\"\"Create a mock metadata service.\"\"\"\n    service = MagicMock()\n    \n    def load_side_effect(path: Path) -> AgentMetadata:\n        if path == tmp_path / \"no_metadata\":\n            raise FileNotFoundError(f\"No metadata file found in {path}\")\n        return AgentMetadata(\n            agent_name=\"test-agent\",\n            entrypoint=\"python main.py\",\n            agent_id=\"abc123\",\n            agent_endpoint=\"http://localhost:8080\",\n            session_id=\"session123\",\n            k8s_deployment={\n                \"type\": \"AgentRuntime\",\n                \"namespace\": \"default\",\n            }\n        )\n    \n    service.load_metadata.side_effect = load_side_effect\n    return service\n\n\n@pytest.fixture\ndef mock_httpx_client() -> AsyncMock:\n    \"\"\"Create a mock httpx AsyncClient.\"\"\"\n    client = AsyncMock()\n    \n    response = AsyncMock()\n    response.status_code = 200\n    response.json.return_value = {\"result\": \"success\", \"data\": \"test response\"}\n    response.raise_for_status = MagicMock()\n    \n    client.post.return_value = response\n    return client\n\n\nclass TestInvokeRuntimeInit:\n    \"\"\"Tests for InvokeRuntime.__init__.\"\"\"\n    \n    def test_init_default(self) -> None:\n        \"\"\"Test initialization with default parameters.\"\"\"\n        runtime = InvokeRuntime()\n        assert runtime.verbose is False\n        assert runtime.provider == \"agentcube\"\n    \n    def test_init_with_verbose(self) -> None:\n        \"\"\"Test initialization with verbose flag.\"\"\"\n        runtime = InvokeRuntime(verbose=True)\n        assert runtime.verbose is True\n        assert runtime.provider == \"agentcube\"\n    \n    def test_init_with_provider(self) -> None:\n        \"\"\"Test initialization with custom provider.\"\"\"\n        runtime = InvokeRuntime(provider=\"k8s\")\n        assert runtime.verbose is False\n        assert runtime.provider == \"k8s\"\n    \n    def test_init_with_all_params(self) -> None:\n        \"\"\"Test initialization with all parameters.\"\"\"\n        runtime = InvokeRuntime(verbose=True, provider=\"k8s\")\n        assert runtime.verbose is True\n        assert runtime.provider == \"k8s\"\n\n\nclass TestValidateInvokePrerequisites:\n    \"\"\"Tests for InvokeRuntime._validate_invoke_prerequisites.\"\"\"\n    \n    def test_validate_success_with_agent_id(self, tmp_path: Path) -> None:\n        \"\"\"Test validation with agent_id present.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_id: abc123\nagent_endpoint: http://localhost:8080\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        metadata, endpoint, namespace = runtime._validate_invoke_prerequisites(tmp_path)\n        \n        assert metadata.agent_id == \"abc123\"\n        assert endpoint == \"http://localhost:8080\"\n        assert namespace == \"default\"\n    \n    def test_validate_success_with_endpoint(self, tmp_path: Path) -> None:\n        \"\"\"Test validation with agent_endpoint present.\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(\"\"\"\nagent_name: test-agent\nentrypoint: python main.py\nagent_endpoint: http://localhost:8080\n\"\"\")\n        \n        runtime = InvokeRuntime()\n        metadata, endpoint, namespace = runtime._validate_invoke_p