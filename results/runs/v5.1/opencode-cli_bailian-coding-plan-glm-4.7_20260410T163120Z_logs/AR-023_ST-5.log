":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/status_runtime.py","before":"\"\"\"Runtime for the status command.\"\"\"\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.metadata_service import MetadataService\n\nlogger = logging.getLogger(__name__)\n\n\nclass StatusRuntime:\n    \"\"\"Runtime for checking agent status.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        \"\"\"Initialize the status runtime.\"\"\"\n        self.verbose = verbose\n        self.provider = provider\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n    def get_status(self, workspace_path: Path, provider: str | None = None) -> dict[str, Any]:\n        \"\"\"Get the status of a published agent.\"\"\"\n        logger.info(f\"Getting status for: {workspace_path}\")\n\n        provider = provider or self.provider\n        metadata_service = MetadataService(verbose=self.verbose)\n        metadata = metadata_service.load_metadata(workspace_path)\n\n        if not metadata.agent_id and not metadata.k8s_deployment:\n            return {\n                \"status\": \"not_published\",\n                \"message\": \"Agent has not been published\",\n            }\n\n        try:\n            if provider == \"agentcube\":\n                return self._get_cr_k8s_status(metadata)\n            elif provider == \"k8s\":\n                return self._get_k8s_status(metadata)\n            else:\n                raise ValueError(f\"Unsupported provider: {provider}\")\n        except Exception as e:\n            logger.error(f\"Error getting status: {e}\")\n            return {\n                \"status\": \"error\",\n                \"message\": str(e),\n            }\n\n    def _get_k8s_status(self, metadata: Any) -> dict[str, Any]:\n        \"\"\"Get status for standard Kubernetes deployment.\"\"\"\n        if not metadata.k8s_deployment:\n            return {\n                \"status\": \"not_published\",\n                \"message\": \"No Kubernetes deployment found\",\n            }\n\n        namespace = metadata.k8s_deployment.get(\"namespace\", \"default\")\n        deployment_name = metadata.k8s_deployment.get(\"deployment_name\", metadata.agent_name)\n\n        provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n\n        try:\n            status = provider.get_agent_status(deployment_name)\n\n            result = {\n                \"status\": status.get(\"status\", \"unknown\"),\n                \"provider\": \"k8s\",\n                \"namespace\": namespace,\n                \"deployment_name\": deployment_name,\n                \"replicas\": status.get(\"replicas\", 0),\n                \"ready_replicas\": status.get(\"ready_replicas\", 0),\n            }\n\n            if status.get(\"status\") == \"not_found\":\n                result[\"message\"] = \"Deployment not found in Kubernetes\"\n            elif status.get(\"ready_replicas\", 0) < status.get(\"replicas\", 0):\n                result[\"message\"] = \"Deployment is not fully ready\"\n\n            return result\n\n        except Exception as e:\n            logger.error(f\"Error getting k8s status: {e}\")\n            return {\n                \"status\": \"error\",\n                \"message\": str(e),\n                \"provider\": \"k8s\",\n            }\n\n    def _get_cr_k8s_status(self, metadata: Any) -> dict[str, Any]:\n        \"\"\"Get status for AgentCube AgentRuntime CR.\"\"\"\n        if not metadata.agent_id:\n            return {\n                \"status\": \"not_published\",\n                \"message\": \"Agent has not been published\",\n            }\n\n        namespace = (\n            metadata.k8s_deployment.get(\"namespace\") if metadata.k8s_deployment else \"default\"\n        )\n\n        provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n\n        try:\n            cr_object = provider.get_agent_runtime(metadata.agent_name, namespace)\n\n            if cr_object is None:\n                return {\n                    \"status\": \"not_found_in_k8s\",\n                    \"message\": \"AgentRuntime not found in Kubernetes\",\n                    \"provider\": \"agentcube\",\n                    \"namespace\": namespace,\n                }\n\n            if \"status\" in cr_object:\n                status_info = cr_object[\"status\"]\n                return {\n                    \"status\": status_info.get(\"status\", \"created_no_status\"),\n                    \"provider\": \"agentcube\",\n                    \"namespace\": namespace,\n                    \"agent_name\": metadata.agent_name,\n                    \"agent_endpoint\": status_info.get(\"agentEndpoint\"),\n                    \"message\": status_info.get(\"message\", \"\"),\n                }\n            else:\n                return {\n                    \"status\": \"created_no_status\",\n                    \"message\": \"AgentRuntime created but no status available yet\",\n                    \"provider\": \"agentcube\",\n                    \"namespace\": namespace,\n                }\n\n        except Exception as e:\n            logger.error(f\"Error getting CR status: {e}\")\n            return {\n                \"status\": \"error\",\n                \"message\": str(e),\n                \"provider\": \"agentcube\",\n            }\n","after":"\"\"\"Runtime for the status command.\"\"\"\n\nimport logging\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.metadata_service import MetadataService\n\nlogger = logging.getLogger(__name__)\n\n\nclass StatusRuntime:\n    \"\"\"Runtime for checking agent status.\"\"\"\n\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        \"\"\"Initialize the status runtime.\"\"\"\n        self.verbose = verbose\n        self.provider = provider\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n\n    def get_status(self, workspace_path: Path, provider: Optional[str] = None) -> Dict[str, Any]:\n        \"\"\"Get the status of a published agent.\"\"\"\n        logger.info(f\"Getting status for: {workspace_path}\")\n\n        provider = provider or self.provider\n        metadata_service = MetadataService(verbose=self.verbose)\n        metadata = metadata_service.load_metadata(workspace_path)\n\n        if not metadata.agent_id and not metadata.k8s_deployment:\n            return {\n                \"status\": \"not_published\",\n                \"message\": \"Agent has not been published\",\n            }\n\n        try:\n            if provider == \"agentcube\":\n                return self._get_cr_k8s_status(metadata)\n            elif provider == \"k8s\":\n                return self._get_k8s_status(metadata)\n            else:\n                raise ValueError(f\"Unsupported provider: {provider}\")\n        except Exception as e:\n            logger.error(f\"Error getting status: {e}\")\n            return {\n                \"status\": \"error\",\n                \"message\": str(e),\n            }\n\n    def _get_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n        \"\"\"Get status for standard Kubernetes deployment.\"\"\"\n        if not metadata.k8s_deployment:\n            return {\n                \"status\": \"not_published\",\n                \"message\": \"No Kubernetes deployment found\",\n            }\n\n        namespace = metadata.k8s_deployment.get(\"namespace\", \"default\")\n        deployment_name = metadata.k8s_deployment.get(\"deployment_name\", metadata.agent_name)\n\n        provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n\n        try:\n            status = provider.get_agent_status(deployment_name)\n\n            result = {\n                \"status\": status.get(\"status\", \"unknown\"),\n                \"provider\": \"k8s\",\n                \"namespace\": namespace,\n                \"deployment_name\": deployment_name,\n                \"replicas\": status.get(\"replicas\", 0),\n                \"ready_replicas\": status.get(\"ready_replicas\", 0),\n            }\n\n            if status.get(\"status\") == \"not_found\":\n                result[\"message\"] = \"Deployment not found in Kubernetes\"\n            elif status.get(\"ready_replicas\", 0) < status.get(\"replicas\", 0):\n                result[\"message\"] = \"Deployment is not fully ready\"\n\n            return result\n\n        except Exception as e:\n            logger.error(f\"Error getting k8s status: {e}\")\n            return {\n                \"status\": \"error\",\n                \"message\": str(e),\n                \"provider\": \"k8s\",\n            }\n\n    def _get_cr_k8s_status(self, metadata: Any) -> Dict[str, Any]:\n        \"\"\"Get status for AgentCube AgentRuntime CR.\"\"\"\n        if not metadata.agent_id:\n            return {\n                \"status\": \"not_published\",\n                \"message\": \"Agent has not been published\",\n            }\n\n        namespace = (\n            metadata.k8s_deployment.get(\"namespace\") if metadata.k8s_deployment else \"default\"\n        )\n\n        provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n\n        try:\n            cr_object = provider.get_agent_runtime(metadata.agent_name, namespace)\n\n            if cr_object is None:\n                return {\n                    \"status\": \"not_found_in_k8s\",\n                    \"message\": \"AgentRuntime not found in Kubernetes\",\n                    \"provider\": \"agentcube\",\n                    \"namespace\": namespace,\n                }\n\n            if \"status\" in cr_object:\n                status_info = cr_object[\"status\"]\n                return {\n                    \"status\": status_info.get(\"status\", \"created_no_status\"),\n                    \"provider\": \"agentcube\",\n                    \"namespace\": namespace,\n                    \"agent_name\": metadata.agent_name,\n                    \"agent_endpoint\": status_info.get(\"agentEndpoint\"),\n                    \"message\": status_info.get(\"message\", \"\"),\n                }\n            else:\n                return {\n                    \"status\": \"created_no_status\",\n                    \"message\": \"AgentRuntime created but no status available yet\",\n                    \"provider\": \"agentcube\",\n                    \"namespace\": namespace,\n                }\n\n        except Exception as e:\n            logger.error(f\"Error getting CR status: {e}\")\n            return {\n                \"status\": \"error\",\n                \"message\": str(e),\n                \"provider\": \"agentcube\",\n            }\n","additions":4,"deletions":4},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/status_runtime.py","time":{"start":1775870467763,"end":1775870468418}}}}
