{"type":"tool_use","timestamp":1775869990289,"sessionID":"ses_285e719caffed1lsPrEfzDjxoJ","part":{"id":"prt_d7a1989f2001Mrq32hxjoncPH5","messageID":"msg_d7a1959fe001JBGCV9MgfwKG32","sessionID":"ses_285e719caffed1lsPrEfzDjxoJ","type":"tool","tool":"read","callID":"toolu_tool-9222980b7688449c9e20fe4838ccbc9a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/cli/main.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/cli/main.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Main CLI module for AgentCube using Typer.\"\"\"\n2: \n3: import json\n4: import logging\n5: import os\n6: import sys\n7: import traceback\n8: from pathlib import Path\n9: from typing import Any, Dict, List, Optional\n10: \n11: import typer\n12: from rich.console import Console\n13: from rich.progress import Progress, SpinnerColumn, TextColumn\n14: \n15: from agentcube import __version__\n16: from agentcube.runtime.build_runtime import BuildRuntime\n17: from agentcube.runtime.invoke_runtime import InvokeRuntime\n18: from agentcube.runtime.pack_runtime import PackRuntime\n19: from agentcube.runtime.publish_runtime import PublishRuntime\n20: from agentcube.runtime.status_runtime import StatusRuntime\n21: \n22: app = typer.Typer(\n23:     name=\"agentcube\",\n24:     help=\"AgentCube CLI - A developer tool for AI agent lifecycle management.\",\n25:     no_args_is_help=True,\n26:     rich_markup_mode=\"rich\",\n27:     add_completion=False,\n28: )\n29: \n30: console = Console()\n31: \n32: \n33: def version_callback(value: bool) -> None:\n34:     \"\"\"Display version and exit.\"\"\"\n35:     if value:\n36:         console.print(f\"[bold green]AgentCube CLI (kubectl agentcube) version: {__version__}[/]\")\n37:         raise typer.Exit()\n38: \n39: \n40: @app.callback()\n41: def main(\n42:     version: Optional[bool] = typer.Option(\n43:         None,\n44:         \"--version\",\n45:         help=\"Show version and exit\",\n46:         callback=version_callback,\n47:         is_eager=True,\n48:     ),\n49:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Enable verbose output\"),\n50: ) -> None:\n51:     \"\"\"AgentCube CLI - A developer tool for AI agent lifecycle management.\"\"\"\n52:     if verbose:\n53:         logging.basicConfig(level=logging.DEBUG)\n54: \n55: \n56: def _handle_error(e: Exception, command_name: str, verbose: bool) -> None:\n57:     \"\"\"Handle errors consistently across commands.\"\"\"\n58:     console.print(f\"[bold red]Error {command_name}: {e}[/]\")\n59:     if verbose:\n60:         console.print(\"[bold red]Traceback:[/]\")\n61:         traceback.print_exc()\n62:     raise typer.Exit(1)\n63: \n64: \n65: @app.command()\n66: def pack(\n67:     workspace: str = typer.Option(\n68:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n69:     ),\n70:     agent_name: Optional[str] = typer.Option(None, \"--agent-name\", help=\"Override the agent name\"),\n71:     language: Optional[str] = typer.Option(\n72:         None, \"--language\", help=\"Programming language (python, java)\"\n73:     ),\n74:     entrypoint: Optional[str] = typer.Option(\n75:         None, \"--entrypoint\", help=\"Override the entrypoint command\"\n76:     ),\n77:     port: Optional[int] = typer.Option(\n78:         None, \"--port\", help=\"Port to expose in the Dockerfile\"\n79:     ),\n80:     build_mode: Optional[str] = typer.Option(\n81:         None, \"--build-mode\", help=\"Build strategy: local or cloud\"\n82:     ),\n83:     description: Optional[str] = typer.Option(\n84:         None, \"--description\", help=\"Agent description\"\n85:     ),\n86:     output: Optional[str] = typer.Option(\n87:         None, \"--output\", help=\"Output path for packaged workspace\"\n88:     ),\n89:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n90: ) -> None:\n91:     \"\"\"Package an agent workspace by validating and preparing it.\"\"\"\n92:     try:\n93:         if verbose:\n94:             logging.basicConfig(level=logging.DEBUG)\n95: \n96:         runtime = PackRuntime(verbose=verbose)\n97:         workspace_path = Path(workspace).resolve()\n98: \n99:         with Progress(\n100:             SpinnerColumn(),\n101:             TextColumn(\"[progress.description]{task.description}\"),\n102:             console=console,\n103:         ) as progress:\n104:             task = progress.add_task(\"[cyan]Packaging agent...\", total=None)\n105: \n106:             options: Dict[str, Any] = {\n107:                 \"agent_name\": agent_name,\n108:                 \"language\": language,\n109:                 \"entrypoint\": entrypoint,\n110:                 \"port\": port,\n111:                 \"build_mode\": build_mode,\n112:                 \"description\": description,\n113:                 \"output\": output,\n114:             }\n115: \n116:             result = runtime.pack(workspace_path, **options)\n117: \n118:             progress.update(task, description=\"[cyan]Packaging complete!\", completed=True)\n119: \n120:         console.print(f\"[bold green]✓[/] Successfully packaged agent\")\n121:         console.print(f\"  Agent name: [cyan]{result['agent_name']}[/]\")\n122:         console.print(f\"  Workspace: [cyan]{result['workspace_path']}[/]\")\n123:         console.print(f\"  Metadata: [cyan]{result['metadata_path']}[/]\")\n124: \n125:     except Exception as e:\n126:         _handle_error(e, \"packaging agent\", verbose)\n127: \n128: \n129: @app.command()\n130: def build(\n131:     workspace: str = typer.Option(\n132:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n133:     ),\n134:     proxy: Optional[str] = typer.Option(\n135:         None, \"-p\", \"--proxy\", help=\"Custom proxy URL for dependency resolution\"\n136:     ),\n137:     cloud_provider: Optional[str] = typer.Option(\n138:         None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei)\"\n139:     ),\n140:     output: Optional[str] = typer.Option(\n141:         None, \"--output\", help=\"Output path for build artifacts\"\n142:     ),\n143:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n144: ) -> None:\n145:     \"\"\"Build a container image from the packaged agent workspace.\"\"\"\n146:     try:\n147:         if verbose:\n148:             logging.basicConfig(level=logging.DEBUG)\n149: \n150:         runtime = BuildRuntime(verbose=verbose)\n151:         workspace_path = Path(workspace).resolve()\n152: \n153:         with Progress(\n154:             SpinnerColumn(),\n155:             TextColumn(\"[progress.description]{task.description}\"),\n156:             console=console,\n157:         ) as progress:\n158:             task = progress.add_task(\"[cyan]Building image...\", total=None)\n159: \n160:             options: Dict[str, Any] = {\n161:                 \"proxy\": proxy,\n162:                 \"cloud_provider\": cloud_provider,\n163:                 \"output\": output,\n164:             }\n165: \n166:             result = runtime.build(workspace_path, **options)\n167: \n168:             progress.update(task, description=\"[cyan]Build complete!\", completed=True)\n169: \n170:         console.print(f\"[bold green]✓[/] Successfully built image\")\n171:         console.print(f\"  Image name: [cyan]{result['image_name']}[/]\")\n172:         console.print(f\"  Image ID: [cyan]{result['image_id']}[/]\")\n173:         console.print(f\"  Image size: [cyan]{result['image_size']}[/]\")\n174: \n175:     except Exception as e:\n176:         _handle_error(e, \"building image\", verbose)\n177: \n178: \n179: @app.command()\n180: def publish(\n181:     workspace: str = typer.Option(\n182:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n183:     ),\n184:     version: Optional[str] = typer.Option(\n185:         None, \"--version\", help=\"Semantic version string (e.g., v1.0.0)\"\n186:     ),\n187:     image_url: Optional[str] = typer.Option(\n188:         None, \"--image-url\", help=\"Image repository URL (required in local build mode)\"\n189:     ),\n190:     image_username: Optional[str] = typer.Option(\n191:         None, \"--image-username\", help=\"Username for image repository\"\n192:     ),\n193:     image_password: Optional[str] = typer.Option(\n194:         None, \"--image-password\", help=\"Password for image repository\"\n195:     ),\n196:     description: Optional[str] = typer.Option(\n197:         None, \"--description\", help=\"Agent description\"\n198:     ),\n199:     region: Optional[str] = typer.Option(\n200:         None, \"--region\", help=\"Deployment region\"\n201:     ),\n202:     cloud_provider: Optional[str] = typer.Option(\n203:         None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei)\"\n204:     ),\n205:     provider: str = typer.Option(\n206:         \"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' or 'k8s'\"\n207:     ),\n208:     node_port: Optional[int] = typer.Option(\n209:         None, \"--node-port\", help=\"Specific NodePort to use (30000-32767) for K8s deployment\"\n210:     ),\n211:     replicas: Optional[int] = typer.Option(\n212:         None, \"--replicas\", help=\"Number of replicas for K8s deployment\"\n213:     ),\n214:     namespace: Optional[str] = typer.Option(\n215:         None, \"--namespace\", help=\"The namespace for the deployment\"\n216:     ),\n217:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n218: ) -> None:\n219:     \"\"\"Publish an agent to the specified provider.\"\"\"\n220:     try:\n221:         if verbose:\n222:             logging.basicConfig(level=logging.DEBUG)\n223: \n224:         runtime = PublishRuntime(verbose=verbose, provider=provider)\n225:         workspace_path = Path(workspace).resolve()\n226: \n227:         with Progress(\n228:             SpinnerColumn(),\n229:             TextColumn(\"[progress.description]{task.description}\"),\n230:             console=console,\n231:         ) as progress:\n232:             task = progress.add_task(\"[cyan]Publishing agent...\", total=None)\n233: \n234:             options: Dict[str, Any] = {\n235:                 \"version\": version,\n236:                 \"image_url\": image_url,\n237:                 \"image_username\": image_username,\n238:                 \"image_password\": image_password,\n239:                 \"description\": description,\n240:                 \"region\": region,\n241:                 \"cloud_provider\": cloud_provider,\n242:                 \"node_port\": node_port,\n243:                 \"replicas\": replicas,\n244:                 \"namespace\": namespace,\n245:             }\n246: \n247:             result = runtime.publish(workspace_path, **options)\n248: \n249:             progress.update(task, description=\"[cyan]Publish complete!\", completed=True)\n250: \n251:         console.print(f\"[bold green]✓[/] Successfully published agent\")\n252:         console.print(f\"  Agent ID: [cyan]{result.get('agent_id', 'N/A')}[/]\")\n253:         console.print(f\"  Endpoint: [cyan]{result.get('endpoint', 'N/A')}[/]\")\n254: \n255:     except Exception as e:\n256:         _handle_error(e, \"publishing agent\", verbose)\n257: \n258: \n259: @app.command()\n260: def invoke(\n261:     workspace: str = typer.Option(\n262:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n263:     ),\n264:     payload: str = typer.Option(\n265:         \"{}\", \"--payload\", help=\"JSON-formatted input passed to the agent\"\n266:     ),\n267:     header_list: Optional[List[str]] = typer.Option(\n268:         None,\n269:         \"--header\",\n270:         help=\"Custom HTTP headers (e.g., 'Authorization: Bearer token'). Can be specified multiple times.\",\n271:     ),\n272:     provider: str = typer.Option(\n273:         \"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' or 'k8s'\"\n274:     ),\n275:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n276: ) -> None:\n277:     \"\"\"Invoke a published agent with the given payload.\"\"\"\n278:     try:\n279:         if verbose:\n280:             logging.basicConfig(level=logging.DEBUG)\n281: \n282:         workspace_path = Path(workspace).resolve()\n283: \n284:         try:\n285:             payload_data: Dict[str, Any] = json.loads(payload)\n286:         except json.JSONDecodeError as e:\n287:             console.print(f\"[bold red]Invalid JSON payload: {e}[/]\")\n288:             raise typer.Exit(1)\n289: \n290:         headers: Dict[str, str] = {}\n291:         if header_list:\n292:             for header in header_list:\n293:                 if \":\" not in header:\n294:                     console.print(f\"[bold red]Invalid header format. Expected 'key:value', got: {header}[/]\")\n295:                     raise typer.Exit(1)\n296:                 key, value = header.split(\":\", 1)\n297:                 headers[key.strip()] = value.strip()\n298: \n299:         runtime = InvokeRuntime(verbose=verbose, provider=provider)\n300: \n301:         with Progress(\n302:             SpinnerColumn(),\n303:             TextColumn(\"[progress.description]{task.description}\"),\n304:             console=console,\n305:         ) as progress:\n306:             task = progress.add_task(\"[cyan]Invoking agent...\", total=None)\n307: \n308:             result = runtime.invoke(workspace_path, payload_data, headers)\n309: \n310:             progress.update(task, description=\"[cyan]Invoke complete!\", completed=True)\n311: \n312:         console.print(f\"[bold green]✓[/] Successfully invoked agent\")\n313:         console.print(f\"  Response: [cyan]{json.dumps(result, indent=2)}[/]\")\n314: \n315:     except typer.Exit:\n316:         raise\n317:     except Exception as e:\n318:         _handle_error(e, \"invoking agent\", verbose)\n319: \n320: \n321: @app.command()\n322: def status(\n323:     workspace: str = typer.Option(\n324:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n325:     ),\n326:     provider: str = typer.Option(\n327:         \"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' or 'k8s'\"\n328:     ),\n329:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n330: ) -> None:\n331:     \"\"\"Get the status of a published agent.\"\"\"\n332:     try:\n333:         if verbose:\n334:             logging.basicConfig(level=logging.DEBUG)\n335: \n336:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n337:         workspace_path = Path(workspace).resolve()\n338: \n339:         with Progress(\n340:             SpinnerColumn(),\n341:             TextColumn(\"[progress.description]{task.description}\"),\n342:             console=console,\n343:         ) as progress:\n344:             task = progress.add_task(\"[cyan]Getting status...\", total=None)\n345: \n346:             result = runtime.get_status(workspace_path, provider)\n347: \n348:             progress.update(task, description=\"[cyan]Status retrieved!\", completed=True)\n349: \n350:         if result[\"status\"] in (\"not_published\", \"error\"):\n351:             console.print(f\"[bold red]✗[/] Agent status: {result['status']}[/]\")\n352:             if result[\"status\"] == \"not_published\":\n353:                 console.print(\"  Please publish the agent first using 'agentcube publish'\")\n354:             raise typer.Exit(1)\n355: \n356:         console.print(f\"[bold green]✓[/] Agent status: {result['status']}[/]\")\n357:         for key, value in result.items():\n358:             if key != \"status\":\n359:                 console.print(f\"  {key}: [cyan]{value}[/]\")\n360: \n361:     except typer.Exit:\n362:         raise\n363:     except Exception as e:\n364:         _handle_error(e, \"getting status\", verbose)\n365: \n366: \n367: if __name__ == \"__main__\":\n368:     app()\n\n(End of file - total 368 lines)\n</content>","metadata":{"preview":"\"\"\"Main CLI module for AgentCube using Typer.\"\"\"\n\nimport json\nimport logging\nimport os\nimport sys\nimport traceback\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\n\nfrom agentcube import __version__\nfrom agentcube.runtime.build_runtime import BuildRuntime\nfrom agentcube.runtime.invoke_runtime import InvokeRuntime\nfrom agentcube.runtime.pack_runtime import PackRuntime\nfrom agentcube.runtime.publish_runtime import PublishRuntime\nfrom agentcube.runtime.status_runtime import StatusRuntime","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/cli/main.py","time":{"start":1775869990269,"end":1775869990286}}}}
