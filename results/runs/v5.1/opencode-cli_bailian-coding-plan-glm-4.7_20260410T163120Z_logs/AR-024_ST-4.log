ck.writeLockCount > 0 || lock.readLockCount > 0 {\n1011: \t\tselect {\n1012: \t\tcase <-timeout:\n1013: \t\t\treturn false\n1014: \t\tdefault:\n1015: \t\t\tlock.writeCond.Wait()\n1016: \t\t}\n1017: \t}\n1018: \n1019: \tlock.writeLockCount++\n1020: \treturn true\n1021: }\n1022: \n1023: func (fm *FileLockManager) ReleaseWriteLock(path string) {\n1024: \tabsPath := filepath.Clean(path)\n1025: \n1026: \tfm.mu.RLock()\n1027: \tlock, exists := fm.locks[absPath]\n1028: \tfm.mu.RUnlock()\n1029: \n1030: \tif !exists {\n1031: \t\treturn\n1032: \t}\n1033: \n1034: \tlock.mu.Lock()\n1035: \tlock.writeLockCount--\n1036: \tif lock.writeLockCount == 0 {\n1037: \t\tlock.writeCond.Broadcast()\n1038: \t\tlock.readCond.Broadcast()\n1039: \t}\n1040: \tlock.mu.Unlock()\n1041: \n1042: \tfm.cleanupLock(absPath)\n1043: }\n1044: \n1045: func (fm *FileLockManager) AcquireReadLock(path string) bool {\n1046: \tabsPath := filepath.Clean(path)\n1047: \tlock := fm.getLock(absPath)\n1048: \n1049: \tlock.mu.Lock()\n1050: \tdefer lock.mu.Unlock()\n1051: \n1052: \ttimeout := time.After(FileLockTimeout)\n1053: \n1054: \tfor lock.writeLockCount > 0 {\n1055: \t\tselect {\n1056: \t\tcase <-timeout:\n1057: \t\t\treturn false\n1058: \t\tdefault:\n1059: \t\t\tlock.readCond.Wait()\n1060: \t\t}\n1061: \t}\n1062: \n1063: \tlock.readLockCount++\n1064: \treturn true\n1065: }\n1066: \n1067: func (fm *FileLockManager) ReleaseReadLock(path string) {\n1068: \tabsPath := filepath.Clean(path)\n1069: \n1070: \tfm.mu.RLock()\n1071: \tlock, exists := fm.locks[absPath]\n1072: \tfm.mu.RUnlock()\n1073: \n1074: \tif !exists {\n1075: \t\treturn\n1076: \t}\n1077: \n1078: \tlock.mu.Lock()\n1079: \tlock.readLockCount--\n1080: \tif lock.readLockCount == 0 {\n1081: \t\tlock.writeCond.Broadcast()\n1082: \t}\n1083: \tlock.mu.Unlock()\n1084: \n1085: \tfm.cleanupLock(absPath)\n1086: }\n1087: ```\n1088: \n1089: **Step 4: Integrate locks into handlers**\n1090: \n1091: ```go\n1092: // pkg/picod/server.go\n1093: type Server struct {\n1094: \tengine       *gin.Engine\n1095: \tconfig       Config\n1096: \tauthManager  *AuthManager\n1097: \tstartTime    time.Time\n1098: \tworkspaceDir string\n1099: \thttpServer   *http.Server\n1100: \tlockManager  *FileLockManager // Add this field\n1101: }\n1102: \n1103: func NewServer(config Config) (*Server, error) {\n1104: \t// ... existing code ...\n1105: \n1106: \tserver := &Server{\n1107: \t\tengine:       engine,\n1108: \t\tconfig:       config,\n1109: \t\tauthManager:  authManager,\n1110: \t\tstartTime:    time.Now(),\n1111: \t\tworkspaceDir: absWorkspace,\n1112: \t\tlockManager:  NewFileLockManager(), // Initialize lock manager\n1113: \t}\n1114: \n1115: \t// ... rest of existing code ...\n1116: }\n1117: ```\n1118: \n1119: **Step 5: Apply locks in upload and delete handlers**\n1120: \n1121: ```go\n1122: // pkg/picod/handlers.go\n1123: func (s *Server) UploadFileHandler(c *gin.Context) {\n1124: \t// ... existing validation code ...\n1125: \n1126: \tsanitizedPath, err := s.sanitizePath(path)\n1127: \tif err != nil {\n1128: \t\tHandleError(c, err)\n1129: \t\treturn\n1130: \t}\n1131: \n1132: \t// Acquire write lock\n1133: \tif !s.lockManager.AcquireWriteLock(sanitizedPath) {\n1134: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n1135: \t\treturn\n1136: \t}\n1137: \tdefer s.lockManager.ReleaseWriteLock(sanitizedPath)\n1138: \n1139: \t// ... rest of handler code ...\n1140: }\n1141: \n1142: func (s *Server) DeleteFileHandler(c *gin.Context) {\n1143: \t// ... existing validation code ...\n1144: \n1145: \tsanitizedPath, err := s.sanitizePath(path)\n1146: \tif err != nil {\n1147: \t\tHandleError(c, err)\n1148: \t\treturn\n1149: \t}\n1150: \n1151: \t// Acquire write lock\n1152: \tif !s.lockManager.AcquireWriteLock(sanitizedPath) {\n1153: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n1154: \t\treturn\n1155: \t}\n1156: \tdefer s.lockManager.ReleaseWriteLock(sanitizedPath)\n1157: \n1158: \t// ... rest of handler code ...\n1159: }\n1160: \n1161: func (s *Server) DownloadFileHandler(c *gin.Context) {\n1162: \t// ... existing validation code ...\n1163: \n1164: \tsanitizedPath, err := s.sanitizePath(path)\n1165: \tif err != nil {\n1166: \t\tHandleError(c, err)\n1167: \t\treturn\n1168: \t}\n1169: \n1170: \t// Acquire read lock\n1171: \tif !s.lockManager.AcquireReadLock(sanitizedPath) {\n1172: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n1173: \t\treturn\n1174: \t}\n1175: \tdefer s.lockManager.ReleaseReadLock(sanitizedPath)\n1176: \n1177: \t// ... rest of handler code ...\n1178: }\n1179: ```\n1180: \n1181: **Step 6: Run test to verify it passes**\n1182: \n1183: Run: `go test ./pkg/picod/ -run TestFileLocks -v`\n1184: Expected: PASS\n1185: \n1186: **Step 7: Commit**\n1187: \n1188: ```bash\n1189: git add pkg/picod/locks.go pkg/picod/server.go pkg/picod/handlers.go pkg/picod/locks_test.go\n1190: git commit -m \"feat(ar-016): add file operation locks for concurrency control\"\n1191: ```\n1192: \n1193: ---\n1194: \n1195: ### Task 6: Enhance path security with symlink resolution\n1196: \n1197: **Files:**\n1198: - Modify: `pkg/picod/files.go`\n1199: \n1200: **Step 1: Write the failing test**\n1201: \n1202: ```go\n1203: // pkg/picod/files_test.go\n1204: package picod\n1205: \n1206: import (\n1207: \t\"os\"\n1208: \t\"path/filepath\"\n1209: \t\"testing\"\n1210: \n1211: \t. \"github.com/onsi/gomega\"\n1212: )\n1213: \n1214: func TestSanitizePathWithSymlinks(t *testing.T) {\n1215: \tg := NewGomegaWithT(t)\n1216: \n1217: \ttempDir := t.TempDir()\n1218: \tserver := &Server{\n1219: \t\tworkspaceDir: tempDir,\n1220: \t\tauthManager:  nil,\n1221: \t}\n1222: \n1223: \t// Create a file outside workspace\n1224: \toutsideFile := filepath.Join(filepath.Dir(tempDir), \"outside.txt\")\n1225: \tif err := os.WriteFile(outsideFile, []byte(\"outside content\"), 0644); err != nil {\n1226: \t\tt.Fatalf(\"Failed to create outside file: %v\", err)\n1227: \t}\n1228: \n1229: \t// Create a symlink inside workspace pointing outside\n1230: \tsymlinkPath := filepath.Join(tempDir, \"escape_link\")\n1231: \tif err := os.Symlink(outsideFile, symlinkPath); err != nil {\n1232: \t\tt.Fatalf(\"Failed to create symlink: %v\", err)\n1233: \t}\n1234: \n1235: \t// Test that symlink escaping is blocked\n1236: \tsanitized, err := server.sanitizePath(\"escape_link\")\n1237: \tg.Expect(err).To(HaveOccurred())\n1238: \tg.Expect(err).To(MatchError(ContainSubstring(ErrAccessDenied)))\n1239: \n1240: \t// Test valid symlink within workspace\n1241: \tinsideFile := filepath.Join(tempDir, \"inside.txt\")\n1242: \tos.WriteFile(insideFile, []byte(\"inside content\"), 0644)\n1243: \n1244: \tvalidSymlink := filepath.Join(tempDir, \"valid_link\")\n1245: \tos.Symlink(\"inside.txt\", validSymlink)\n1246: \n1247: \tsanitized, err = server.sanitizePath(\"valid_link\")\n1248: \tg.Expect(err).NotTo(HaveOccurred())\n1249: \tg.Expect(sanitized).To(Equal(validSymlink))\n1250: \n1251: \t// Test symlink chain\n1252: \tchain1 := filepath.Join(tempDir, \"chain1\")\n1253: \tchain2 := filepath.Join(tempDir, \"chain2\")\n1254: \tos.Symlink(\"chain2\", chain1)\n1255: \tos.Symlink(\"inside.txt\", chain2)\n1256: \n1257: \tsanitized, err = server.sanitizePath(\"chain1\")\n1258: \tg.Expect(err).NotTo(HaveOccurred())\n1259: }\n1260: \n1261: func TestSanitizePathPreventsEscape(t *testing.T) {\n1262: \tg := NewGomegaWithT(t)\n1263: \n1264: \ttempDir := t.TempDir()\n1265: \tserver := &Server{\n1266: \t\tworkspaceDir: tempDir,\n1267: \t\tauthManager:  nil,\n1268: \t}\n1269: \n1270: \tescapeAttempts := []string{\n1271: \t\t\"../etc/passwd\",\n1272: \t\t\"../../etc/passwd\",\n1273: \t\t\"../../../etc/passwd\",\n1274: \t\t\"/etc/passwd\",\n1275: \t\t\"..\",\n1276: \t\t\"../..\",\n1277: \t}\n1278: \n1279: \tfor _, attempt := range escapeAttempts {\n1280: \t\t_, err := server.sanitizePath(attempt)\n1281: \t\tg.Expect(err).To(HaveOccurred(), \"Should reject escape attempt: %s\", attempt)\n1282: \t\tg.Expect(err).To(MatchError(ContainSubstring(ErrAccessDenied)))\n1283: \t}\n1284: }\n1285: ```\n1286: \n1287: **Step 2: Run test to verify it fails**\n1288: \n1289: Run: `go test ./pkg/picod/ -run TestSanitizePathWithSymlinks -v`\n1290: Expected: FAIL with existing sanitizePath not handling all symlink cases\n1291: \n1292: **Step 3: Write enhanced implementation**\n1293: \n1294: ```go\n1295: // pkg/picod/files.go\n1296: func (s *Server) sanitizePath(path string) (string, error) {\n1297: \tif s.workspaceDir == \"\" {\n1298: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, ErrMsgWorkspaceNotInit, nil)\n1299: \t}\n1300: \n1301: \t// Resolve workspace path fully\n1302: \tresolvedWorkspace, err := filepath.EvalSymlinks(s.workspaceDir)\n1303: \tif err != nil {\n1304: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"failed to resolve workspace: \"+err.Error(), err)\n1305: \t}\n1306: \tresolvedWorkspace = filepath.Clean(resolvedWorkspace)\n1307: \n1308: \t// Clean the input path\n1309: \tcleanPath := filepath.Clean(path)\n1310: \n1311: \t// Remove leading slash if present to make it relative\n1312: \tif filepath.IsAbs(cleanPath) {\n1313: \t\tcleanPath = strings.TrimPrefix(cleanPath, string(os.PathSeparator))\n1314: \t\tcleanPath = strings.TrimPrefix(cleanPath, \"/\")\n1315: \t}\n1316: \n1317: \t// Check for obvious escape attempts\n1318: \tif strings.Contains(cleanPath, \"..\") {\n1319: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"path contains parent directory references\", nil)\n1320: \t}\n1321: \n1322: \t// Join with workspace and clean\n1323: \tfullPath := filepath.Clean(filepath.Join(resolvedWorkspace, cleanPath))\n1324: \n1325: \t// Resolve symlinks in the full path\n1326: \tresolvedPath, err := filepath.EvalSymlinks(fullPath)\n1327: \tif err != nil && !os.IsNotExist(err) {\n1328: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"failed to resolve path: \"+err.Error(), err)\n1329: \t}\n1330: \n1331: \t// If the path doesn't exist yet, use the unresolved path\n1332: \tfinalPath := resolvedPath\n1333: \tif os.IsNotExist(err) {\n1334: \t\t// For paths that don't exist, check each parent component\n1335: \t\tfinalPath = fullPath\n1336: \t\tparentPath := filepath.Dir(fullPath)\n1337: \t\tfor parentPath != resolvedWorkspace && parentPath != \".\" {\n1338: \t\t\tresolvedParent, err := filepath.EvalSymlinks(parentPath)\n1339: \t\t\tif err != nil && !os.IsNotExist(err) {\n1340: \t\t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"failed to resolve parent path: \"+err.Error(), err)\n1341: \t\t\t}\n1342: \t\t\tif !os.IsNotExist(err) {\n1343: \t\t\t\trelParent, err := filepath.Rel(resolvedWorkspace, resolvedParent)\n1344: \t\t\t\tif err != nil || strings.HasPrefix(relParent, \"..\"+string(os.PathSeparator)) {\n1345: \t\t\t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"parent path escapes workspace\", nil)\n1346: \t\t\t\t}\n1347: \t\t\t}\n1348: \t\t\tparentPath = filepath.Dir(parentPath)\n1349: \t\t}\n1350: \t} else {\n1351: \t\t// Verify the resolved path is still within workspace\n1352: \t\trelPath, err := filepath.Rel(resolvedWorkspace, resolvedPath)\n1353: \t\tif err != nil {\n1354: \t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"failed to compute relative path: \"+err.Error(), err)\n1355: \t\t}\n1356: \n1357: \t\tif strings.HasPrefix(relPath, \"..\"+string(os.PathSeparator)) || relPath == \"..\" {\n1358: \t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"resolved path escapes workspace\", nil)\n1359: \t\t}\n1360: \t\tfinalPath = resolvedPath\n1361: \t}\n1362: \n1363: \t// Final verification\n1364: \trelPath, err := filepath.Rel(resolvedWorkspace, finalPath)\n1365: \tif err != nil {\n1366: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"final verification failed\", err)\n1367: \t}\n1368: \n1369: \tif strings.HasPrefix(relPath, \"..\"+string(os.PathSeparator)) || relPath == \"..\" {\n1370: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"path escapes workspace\", nil)\n1371: \t}\n1372: \n1373: \treturn finalPath, nil\n1374: }\n1375: ```\n1376: \n1377: **Step 4: Run test to verify it passes**\n1378: \n1379: Run: `go test ./pkg/picod/ -run TestSanitizePathWithSymlinks -v`\n1380: Expected: PASS\n1381: \n1382: **Step 5: Commit**\n1383: \n1384: ```bash\n1385: git add pkg/picod/files.go pkg/picod/files_test.go\n1386: git commit -m \"feat(ar-016): enhance path security with symlink resolution\"\n1387: ```\n1388: \n1389: ---\n1390: \n1391: ### Task 7: Add comprehensive integration tests\n1392: \n1393: **Files:**\n1394: - Create: `pkg/picod/integration_test.go`\n1395: \n1396: **Step 1: Write integration tests**\n1397: \n1398: ```go\n1399: // pkg/picod/integration_test.go\n1400: //go:build integration\n1401: // +build integration\n1402: \n1403: package picod\n1404: \n1405: import (\n1406: \t\"bytes\"\n1407: \t\"encoding/base64\"\n1408: \t\"encoding/json\"\n1409: \t\"fmt\"\n1410: \t\"io\"\n1411: \t\"mime/multipart\"\n1412: \t\"net/http\"\n1413: \t\"net/http/httptest\"\n1414: \t\"os\"\n1415: \t\"path/filepath\"\n1416: \t\"strings\"\n1417: \t\"testing\"\n1418: \t\"time\"\n1419: \n1420: \t. \"github.com/onsi/gomega\"\n1421: )\n1422: \n1423: func TestFullFileManagementWorkflow(t *testing.T) {\n1424: \tg := NewGomegaWithT(t)\n1425: \n1426: \tgin.SetMode(gin.TestMode)\n1427: \ttempDir := t.TempDir()\n1428: \n1429: \tconfig := Config{\n1430: \t\tWorkspace: tempDir,\n1431: \t\tPort:      0, // Use random port\n1432: \t}\n1433: \n1434: \t// Create server without auth for testing\n1435: \tserver := &Server{\n1436: \t\tworkspaceDir: tempDir,\n1437: \t\tauthManager:  nil,\n1438: \t\tlockManager:  NewFileLockManager(),\n1439: \t}\n1440: \n1441: \trouter := gin.New()\n1442: \trouter.Use(func(c *gin.Context) {\n1443: \t\t// Mock auth middleware\n1444: \t\tc.Next()\n1445: \t})\n1446: \n1447: \tapi := router.Group(\"/api\")\n1448: \tapi.POST(\"/files\", server.UploadFileHandler)\n1449: \tapi.GET(\"/files\", server.ListFilesHandler)\n1450: \tapi.GET(\"/files/*path\", server.DownloadFileHandler)\n1451: \tapi.PUT(\"/files/*path\", server.CreateDirectoryHandler)\n1452: \tapi.DELETE(\"/files/*path\", server.DeleteFileHandler)\n1453: \n1454: \t// Step 1: Create directory structure\n1455: \treq, _ := http.NewRequest(\"PUT\", \"/api/files/workdir\", nil)\n1456: \tw := httptest.NewRecorder()\n1457: \trouter.ServeHTTP(w, req)\n1458: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1459: \n1460: \treq, _ = http.NewRequest(\"PUT\", \"/api/files/workdir/subdir\", nil)\n1461: \tw = httptest.NewRecorder()\n1462: \trouter.ServeHTTP(w, req)\n1463: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1464: \n1465: \t// Step 2: Upload files via multipart\n1466: \tbody := &bytes.Buffer{}\n1467: \twriter := multipart.NewWriter(body)\n1468: \twriter.WriteField(\"path\", \"workdir/file1.txt\")\n1469: \tpart, _ := writer.CreateFormFile(\"file\", \"file1.txt\")\n1470: \tio.WriteString(part, \"content of file 1\")\n1471: \twriter.WriteField(\"mode\", \"0644\")\n1472: \twriter.Close()\n1473: \n1474: \treq, _ = http.NewRequest(\"POST\", \"/api/files\", body)\n1475: \treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n1476: \tw = httptest.NewRecorder()\n1477: \trouter.ServeHTTP(w, req)\n1478: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1479: \n1480: \t// Step 3: Upload file via JSON Base64\n1481: \tuploadReq := UploadFileRequest{\n1482: \t\tPath:    \"workdir/subdir/file2.txt\",\n1483: \t\tContent: base64.StdEncoding.EncodeToString([]byte(\"content of file 2\")),\n1484: \t\tMode:    \"0644\",\n1485: \t}\n1486: \treqBody, _ := json.Marshal(uploadReq)\n1487: \treq, _ = http.NewRequest(\"POST\", \"/api/files\", bytes.NewReader(reqBody))\n1488: \treq.Header.Set(\"Content-Type\", \"application/json\")\n1489: \tw = httptest.NewRecorder()\n1490: \trouter.ServeHTTP(w, req)\n1491: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1492: \n1493: \t// Step 4: List files (non-recursive)\n1494: \treq, _ = http.NewRequest(\"GET\", \"/api/files?path=workdir&recursive=false\", nil)\n1495: \tw = httptest.NewRecorder()\n1496: \trouter.ServeHTTP(w, req)\n1497: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1498: \n1499: \tvar listResp ListFilesResponse\n1500: \tjson.Unmarshal(w.Body.Bytes(), &listResp)\n1501: \tg.Expect(len(listResp.Files)).To(BeNumerically(\">=\", 2))\n1502: \n1503: \t// Step 5: List files (recursive)\n1504: \treq, _ = http.NewRequest(\"GET\", \"/api/files?path=workdir&recursive=true\", nil)\n1505: \tw = httptest.NewRecorder()\n1506: \trouter.ServeHTTP(w, req)\n1507: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1508: \n1509: \tjson.Unmarshal(w.Body.Bytes(), &listResp)\n1510: \tg.Expect(len(listResp.Files)).To(BeNumerically(\">=\", 3))\n1511: \n1512: \t// Step 6: Get file metadata\n1513: \treq, _ = http.NewRequest(\"GET\", \"/api/files/workdir/file1.txt?metadata=true\", nil)\n1514: \tw = httptest.NewRecorder()\n1515: \trouter.ServeHTTP(w, req)\n1516: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1517: \n1518: \tvar metadata FileMetadata\n1519: \tjson.Unmarshal(w.Body.Bytes(), &metadata)\n1520: \tg.Expect(metadata.Path).To(ContainSubstring(\"workdir/file1.txt\"))\n1521: \tg.Expect(metadata.Size).To(Equal(int64(14)))\n1522: \tg.Expect(metadata.IsDir).To(BeFalse())\n1523: \n1524: \t// Step 7: Download file\n1525: \treq, _ = http.NewRequest(\"GET\", \"/api/files/workdir/file1.txt\", nil)\n1526: \tw = httptest.NewRecorder()\n1527: \trouter.ServeHTTP(w, req)\n1528: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1529: \tg.Expect(w.Body.String()).To(Equal(\"content of file 1\"))\n1530: \n1531: \t// Step 8: Delete single file\n1532: \treq, _ = http.NewRequest(\"DELETE\", \"/api/files/workdir/file1.txt\", nil)\n1533: \tw = httptest.NewRecorder()\n1534: \trouter.ServeHTTP(w, req)\n1535: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1536: \n1537: \t// Verify deletion\n1538: \treq, _ = http.NewRequest(\"GET\", \"/api/files/workdir/file1.txt\", nil)\n1539: \tw = httptest.NewRecorder()\n1540: \trouter.ServeHTTP(w, req)\n1541: \tg.Expect(w.Code).To(Equal(http.StatusNotFound))\n1542: \n1543: \t// Step 9: Delete directory recursively\n1544: \treq, _ = http.NewRequest(\"DELETE\", \"/api/files/workdir?recursive=true\", nil)\n1545: \tw = httptest.NewRecorder()\n1546: \trouter.ServeHTTP(w, req)\n1547: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1548: \n1549: \t// Verify deletion\n1550: \treq, _ = http.NewRequest(\"GET\", \"/api/files?path=workdir\", nil)\n1551: \tw = httptest.NewRecorder()\n1552: \trouter.ServeHTTP(w, req)\n1553: \tg.Expect(w.Code).To(Equal(http.StatusNotFound))\n1554: }\n1555: \n1556: func TestConcurrentFileOperations(t *testing.T) {\n1557: \tg := NewGomegaWithT(t)\n1558: \n1559: \tgin.SetMode(gin.TestMode)\n1560: \ttempDir := t.TempDir()\n1561: \n1562: \tserver := &Server{\n1563: \t\tworkspaceDir: tempDir,\n1564: \t\tauthManager:  nil,\n1565: \t\tlockManager:  NewFileLockManager(),\n1566: \t}\n1567: \n1568: \trouter := gin.New()\n1569: \tapi := router.Group(\"/api\")\n1570: \tapi.POST(\"/files\", server.UploadFileHandler)\n1571: \tapi.GET(\"/files/*path\", server.DownloadFileHandler)\n1572: \n1573: \t// Create multiple goroutines to upload to the same file\n1574: \tdone := make(chan bool, 10)\n1575: \tfor i := 0; i < 10; i++ {\n1576: \t\tgo func(idx int) {\n1577: \t\t\tdefer func() { done <- true }()\n1578: \n1579: \t\t\tuploadReq := UploadFileRequest{\n1580: \t\t\t\tPath:    fmt.Sprintf(\"concurrent.txt\"),\n1581: \t\t\t\tContent: base64.StdEncoding.EncodeToString([]byte(fmt.Sprintf(\"content %d\", idx))),\n1582: \t\t\t\tMode:    \"0644\",\n1583: \t\t\t}\n1584: \t\t\treqBody, _ := json.Marshal(uploadReq)\n1585: \t\t\treq, _ := http.NewRequest(\"POST\", \"/api/files\", bytes.NewReader(reqBody))\n1586: \t\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n1587: \t\t\tw := httptest.NewRecorder()\n1588: \t\t\trouter.ServeHTTP(w, req)\n1589: \t\t}(i)\n1590: \t}\n1591: \n1592: \t// Wait for all operations to complete\n1593: \tfor i := 0; i < 10; i++ {\n1594: \t\t<-done\n1595: \t}\n1596: \n1597: \t// Verify the file exists and is valid\n1598: \tfilePath := filepath.Join(tempDir, \"concurrent.txt\")\n1599: \tcontent, err := os.ReadFile(filePath)\n1600: \tg.Expect(err).NotTo(HaveOccurred())\n1601: \tg.Expect(len(content)).To(BeNumerically(\">\", 0))\n1602: }\n1603: \n1604: func TestSecurityEscalationPrevention(t *testing.T) {\n1605: \tg := NewGomegaWithT(t)\n1606: \n1607: \tgin.SetMode(gin.TestMode)\n1608: \ttempDir := t.TempDir()\n1609: \n1610: \tserver := &Server{\n1611: \t\tworkspaceDir: tempDir,\n1612: \t\tauthManager:  nil,\n1613: \t\tlockManager:  NewFileLockManager(),\n1614: \t}\n1615: \n1616: \trouter := gin.New()\n1617: \tapi := router.Group(\"/api\")\n1618: \tapi.POST(\"/files\", server.UploadFileHandler)\n1619: \tapi.GET(\"/files/*path\", server.DownloadFileHandler)\n1620: \n1621: \t// Test path escape attempts\n1622: \tescapeAttempts := []string{\n1623: \t\t\"../../../etc/passwd\",\n1624: \t\t\"../../etc/passwd\",\n1625: \t\t\"../test.txt\",\n1626: \t\t\"/etc/passwd\",\n1627: \t}\n1628: \n1629: \tfor _, attempt := range escapeAttempts {\n1630: \t\tuploadReq := UploadFileRequest{\n1631: \t\t\tPath:    attempt,\n1632: \t\t\tContent: base64.StdEncoding.EncodeToString([]byte(\"malicious\")),\n1633: \t\t}\n1634: \t\treqBody, _ := json.Marshal(uploadReq)\n1635: \t\treq, _ := http.NewRequest(\"POST\", \"/api/files\", bytes.NewReader(reqBody))\n1636: \t\treq.Header.Set(\"Content-Type\", \"application/json\")\n1637: \t\tw := httptest.NewRecorder()\n1638: \t\trouter.ServeHTTP(w, req)\n1639: \t\tg.Expect(w.Code).To(Equal(http.StatusBadRequest), \"Should reject escape attempt: %s\", attempt)\n1640: \t}\n1641: }\n1642: \n1643: func TestLargeFileUpload(t *testing.T) {\n1644: \tg := NewGomegaWithT(t)\n1645: \n1646: \tgin.SetMode(gin.TestMode)\n1647: \ttempDir := t.TempDir()\n1648: \n1649: \tserver := &Server{\n1650: \t\tworkspaceDir: tempDir,\n1651: \t\tauthManager:  nil,\n1652: \t\tlockManager:  NewFileLockManager(),\n1653: \t}\n1654: \n1655: \trouter := gin.New()\n1656: \tapi := router.Group(\"/api\")\n1657: \tapi.POST(\"/files\", server.UploadFileHandler)\n1658: \n1659: \t// Create a moderately large file (1MB)\n1660: \tlargeContent := make([]byte, 1<<20) // 1MB\n1661: \tfor i := range largeContent {\n1662: \t\tlargeContent[i] = byte(i % 256)\n1663: \t}\n1664: \n1665: \tuploadReq := UploadFileRequest{\n1666: \t\tPath:    \"largefile.bin\",\n1667: \t\tContent: base64.StdEncoding.EncodeToString(largeContent),\n1668: \t\tMode:    \"0644\",\n1669: \t}\n1670: \treqBody, _ := json.Marshal(uploadReq)\n1671: \treq, _ := http.NewRequest(\"POST\", \"/api/files\", bytes.NewReader(reqBody))\n1672: \treq.Header.Set(\"Content-Type\", \"application/json\")\n1673: \tw := httptest.NewRecorder()\n1674: \n1675: \tstart := time.Now()\n1676: \trouter.ServeHTTP(w, req)\n1677: \tduration := time.Since(start)\n1678: \n1679: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n1680: \tg.Expect(duration).To(BeNumerically(\"<\", 5*time.Second), \"Large file upload should complete quickly\")\n1681: \n1682: \t// Verify file content\n1683: \tdownloaded, err := os.ReadFile(filepath.Join(tempDir, \"largefile.bin\"))\n1684: \tg.Expect(err).NotTo(HaveOccurred())\n1685: \tg.Expect(len(downloaded)).To(Equal(len(largeContent)))\n1686: }\n1687: ```\n1688: \n1689: **Step 2: Run integration tests**\n1690: \n1691: Run: `go test ./pkg/picod/ -tags=integration -v`\n1692: Expected: PASS\n1693: \n1694: **Step 3: Commit**\n1695: \n1696: ```bash\n1697: git add pkg/picod/integration_test.go\n1698: git commit -m \"feat(ar-016): add comprehensive integration tests\"\n1699: ```\n1700: \n1701: ---\n1702: \n1703: ### Task 8: Run all tests and verify coverage\n1704: \n1705: **Files:**\n1706: - None (verification task)\n1707: \n1708: **Step 1: Run all tests**\n1709: \n1710: ```bash\n1711: go test ./pkg/picod/ -v -coverprofile=coverage.out\n1712: ```\n1713: \n1714: **Step 2: Check coverage**\n1715: \n1716: ```bash\n1717: go tool cover -func=coverage.out | grep total\n1718: ```\n1719: \n1720: Expected: Coverage >90%\n1721: \n1722: **Step 3: Generate coverage report**\n1723: \n1724: ```bash\n1725: go tool cover -html=coverage.out -o coverage.html\n1726: ```\n1727: \n1728: **Step 4: Fix any coverage gaps if below 90%**\n1729: \n1730: Identify uncovered code paths and add tests as needed.\n1731: \n1732: **Step 5: Run linter**\n1733: \n1734: ```bash\n1735: golangci-lint run ./pkg/picod/\n1736: ```\n1737: \n1738: Fix any linting issues.\n1739: \n1740: **Step 6: Verify package builds**\n1741: \n1742: ```bash\n1743: go build ./pkg/picod/\n1744: ```\n1745: \n1746: **Step 7: Update documentation**\n1747: \n1748: Update README.md and API documentation to reflect new endpoints.\n1749: \n1750: **Step 8: Final commit**\n1751: \n1752: ```bash\n1753: git add README.md docs/api.md\n1754: git commit -m \"docs(ar-016): update documentation for file management API\"\n1755: ```\n1756: \n1757: ---\n1758: \n1759: ## Summary\n1760: \n1761: This implementation plan breaks down AR-016 (PicoD 文件管理 API) into 8 atomic, independently verifiable tasks:\n1762: \n1763: 1. **DELETE handler** - File and directory deletion with recursive support\n1764: 2. **PUT handler** - Directory creation with recursive support\n1765: 3. **Metadata query parameter** - Detailed file metadata retrieval\n1766: 4. **Recursive directory listing** - Recursive query parameter for GET /api/files\n1767: 5. **File operation locks** - Concurrency control for file operations\n1768: 6. **Enhanced path security** - Symlink resolution and escape prevention\n1769: 7. **Integration tests** - Comprehensive end-to-end testing\n1770: 8. **Final verification** - Coverage, linting, and documentation\n1771: \n1772: Each task follows the TDD pattern:\n1773: - Write failing test\n1774: - Run test to verify failure\n1775: - Write minimal implementation\n1776: - Run test to verify success\n1777: - Commit changes\n1778: \n1779: The implementation ensures:\n1780: - All file operations are protected by JWT authentication\n1781: - Strict path security prevents workspace escape\n1782: - Concurrent operations are properly synchronized\n1783: - Error handling is consistent and secure\n1784: - High test coverage and reliability\n\n(End of file - total 1784 lines)\n</content>","metadata":{"preview":"# AR-016 Implementation Plan\n\n**Feature:** AR-016 — PicoD 文件管理 API\n**Goal:** 实现完整的文件管理 API，包括文件上传、下载、列表查询、删除、目录创建和元数据查询，提供安全的文件操作能力。\n**Acceptance Criteria:**\n- DELETE /api/files/*path 支持文件和目录删除，包括递归删除\n- PUT /api/files/*path 支持目录创建，包括递归创建\n- GET /api/files/*path 支持通过 metadata=true 参数获取详细文件元数据\n- GET /api/files 支持通过 recursive 参数递归列出目录内容\n- 所有路径操作都经过严格的安全验证（工作空间监狱）\n- 实现文件操作锁，防止并发写入冲突\n- 所有端点返回统一的 JSON 错误响应格式\n- 单元测试覆盖率 >90%\n- 集成测试覆盖所有 API 端点\n**Architecture:** RESTful API 设计，基于 Gin 框架，JWT 认证保护所有端点，路径安全验证确保工作空间隔离。\n**Tech Stack:** Go 1.25, Gin, JWT, 标准库文件操作\n**前端验证:** No\n\n---\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tasks.md","time":{"start":1775871111684,"end":1775871111706}}}}
