39:         mock_client.ping.return_value = True\n40:         docker_service._client = mock_client\n41: \n42:         result = docker_service.check_docker_available()\n43: \n44:         assert result is True\n45:         mock_client.ping.assert_called_once()\n46: \n47:     def test_check_docker_available_failure(self, docker_service):\n48:         \"\"\"Test Docker availability check when unavailable.\"\"\"\n49:         mock_client = MagicMock()\n50:         mock_client.ping.side_effect = DockerException(\"Docker daemon not running\")\n51:         docker_service._client = mock_client\n52: \n53:         result = docker_service.check_docker_available()\n54: \n55:         assert result is False\n56: \n57:     def test_build_image_success(self, docker_service, mock_docker_image, tmp_path):\n58:         \"\"\"Test successful image build.\"\"\"\n59:         dockerfile_path = tmp_path / \"Dockerfile\"\n60:         dockerfile_path.write_text(\"FROM python:3.10\")\n61: \n62:         mock_client = MagicMock()\n63:         mock_images = MagicMock()\n64:         mock_images.build.return_value = (mock_docker_image, [])\n65:         mock_client.images = mock_images\n66: \n67:         docker_service._client = mock_client\n68: \n69:         with patch.object(docker_service, \"get_image_info\", return_value={\n70:             \"image_name\": \"test:1.0.0\",\n71:             \"image_id\": \"abc123def456\",\n72:             \"image_size\": \"512.34 MB\",\n73:             \"size_bytes\": 536870912,\n74:         }):\n75:             result = docker_service.build_image(\n76:                 dockerfile_path=dockerfile_path,\n77:                 context_path=tmp_path,\n78:                 image_name=\"test\",\n79:                 tag=\"1.0.0\"\n80:             )\n81: \n82:             assert result[\"image_name\"] == \"test:1.0.0\"\n83:             assert result[\"image_id\"] == \"abc123def456\"\n84:             assert result[\"image_size\"] == \"512.34 MB\"\n85:             mock_images.build.assert_called_once()\n86: \n87:     def test_build_image_with_custom_tag(self, docker_service, mock_docker_image, tmp_path):\n88:         \"\"\"Test building image with custom tag.\"\"\"\n89:         dockerfile_path = tmp_path / \"Dockerfile\"\n90:         dockerfile_path.write_text(\"FROM python:3.10\")\n91: \n92:         mock_client = MagicMock()\n93:         mock_images = MagicMock()\n94:         mock_images.build.return_value = (mock_docker_image, [])\n95:         mock_client.images = mock_images\n96: \n97:         docker_service._client = mock_client\n98: \n99:         with patch.object(docker_service, \"get_image_info\", return_value={\n100:             \"image_name\": \"test:v1.0.0\",\n101:             \"image_id\": \"abc123def456\",\n102:             \"image_size\": \"512.34 MB\",\n103:             \"size_bytes\": 536870912,\n104:         }):\n105:             result = docker_service.build_image(\n106:                 dockerfile_path=dockerfile_path,\n107:                 context_path=tmp_path,\n108:                 image_name=\"test\",\n109:                 tag=\"v1.0.0\"\n110:             )\n111: \n112:             assert result[\"image_name\"] == \"test:v1.0.0\"\n113:             call_args = mock_images.build.call_args\n114:             assert call_args.kwargs[\"tag\"] == \"test:v1.0.0\"\n115: \n116:     def test_build_image_with_build_args(self, docker_service, mock_docker_image, tmp_path):\n117:         \"\"\"Test building image with build arguments.\"\"\"\n118:         dockerfile_path = tmp_path / \"Dockerfile\"\n119:         dockerfile_path.write_text(\"FROM python:3.10\")\n120: \n121:         mock_client = MagicMock()\n122:         mock_images = MagicMock()\n123:         mock_images.build.return_value = (mock_docker_image, [])\n124:         mock_client.images = mock_images\n125: \n126:         docker_service._client = mock_client\n127: \n128:         with patch.object(docker_service, \"get_image_info\", return_value={\n129:             \"image_name\": \"test:1.0.0\",\n130:             \"image_id\": \"abc123def456\",\n131:             \"image_size\": \"512.34 MB\",\n132:             \"size_bytes\": 536870912,\n133:         }):\n134:             build_args = {\n135:                 \"HTTP_PROXY\": \"http://proxy.example.com:8080\",\n136:                 \"HTTPS_PROXY\": \"http://proxy.example.com:8080\"\n137:             }\n138: \n139:             result = docker_service.build_image(\n140:                 dockerfile_path=dockerfile_path,\n141:                 context_path=tmp_path,\n142:                 image_name=\"test\",\n143:                 tag=\"1.0.0\",\n144:                 build_args=build_args\n145:             )\n146: \n147:             assert result[\"image_name\"] == \"test:1.0.0\"\n148:             call_args = mock_images.build.call_args\n149:             assert call_args.kwargs[\"buildargs\"] == build_args\n150: \n151:     def test_build_image_docker_unavailable(self, docker_service, tmp_path):\n152:         \"\"\"Test building image when Docker is unavailable.\"\"\"\n153:         dockerfile_path = tmp_path / \"Dockerfile\"\n154:         dockerfile_path.write_text(\"FROM python:3.10\")\n155: \n156:         with patch.object(docker_service, \"check_docker_available\", return_value=False):\n157:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n158:                 docker_service.build_image(\n159:                     dockerfile_path=dockerfile_path,\n160:                     context_path=tmp_path,\n161:                     image_name=\"test\"\n162:                 )\n163: \n164:     def test_build_image_docker_exception(self, docker_service, tmp_path):\n165:         \"\"\"Test building image when Docker build fails.\"\"\"\n166:         dockerfile_path = tmp_path / \"Dockerfile\"\n167:         dockerfile_path.write_text(\"FROM python:3.10\")\n168: \n169:         mock_client = MagicMock()\n170:         mock_images = MagicMock()\n171:         mock_images.build.side_effect = DockerException(\"Build failed\")\n172:         mock_client.images = mock_images\n173: \n174:         docker_service._client = mock_client\n175: \n176:         with pytest.raises(RuntimeError, match=\"Failed to build Docker image\"):\n177:             docker_service.build_image(\n178:                 dockerfile_path=dockerfile_path,\n179:                 context_path=tmp_path,\n180:                 image_name=\"test\"\n181:             )\n182: \n183:     def test_get_image_info_success(self, docker_service, mock_docker_image):\n184:         \"\"\"Test getting image info successfully.\"\"\"\n185:         mock_client = MagicMock()\n186:         mock_images = MagicMock()\n187:         mock_images.get.return_value = mock_docker_image\n188:         mock_client.images = mock_images\n189: \n190:         docker_service._client = mock_client\n191: \n192:         result = docker_service.get_image_info(\"test:1.0.0\")\n193: \n194:         assert result[\"image_name\"] == \"test:1.0.0\"\n195:         assert result[\"image_id\"] == \"abc123def456\"\n196:         assert result[\"size_bytes\"] == 536870912\n197:         assert result[\"image_size\"] == \"512.00 MB\"\n198: \n199:     def test_get_image_info_not_found(self, docker_service):\n200:         \"\"\"Test getting image info when image not found.\"\"\"\n201:         mock_client = MagicMock()\n202:         mock_images = MagicMock()\n203:         mock_images.get.side_effect = DockerException(\"Image not found\")\n204:         mock_client.images = mock_images\n205: \n206:         docker_service._client = mock_client\n207: \n208:         result = docker_service.get_image_info(\"test:1.0.0\")\n209: \n210:         assert result == {}\n211: \n212:     def test_format_size_bytes(self, docker_service):\n213:         \"\"\"Test formatting size in bytes.\"\"\"\n214:         result = docker_service._format_size(512)\n215:         assert result == \"512.00 B\"\n216: \n217:     def test_format_size_kb(self, docker_service):\n218:         \"\"\"Test formatting size in kilobytes.\"\"\"\n219:         result = docker_service._format_size(2048)\n220:         assert result == \"2.00 KB\"\n221: \n222:     def test_format_size_mb(self, docker_service):\n223:         \"\"\"Test formatting size in megabytes.\"\"\"\n224:         result = docker_service._format_size(1048576)\n225:         assert result == \"1.00 MB\"\n226: \n227:     def test_format_size_gb(self, docker_service):\n228:         \"\"\"Test formatting size in gigabytes.\"\"\"\n229:         result = docker_service._format_size(1073741824)\n230:         assert result == \"1.00 GB\"\n231: \n232:     def test_format_size_tb(self, docker_service):\n233:         \"\"\"Test formatting size in terabytes.\"\"\"\n234:         result = docker_service._format_size(1099511627776)\n235:         assert result == \"1.00 TB\"\n236: \n237:     def test_format_size_zero(self, docker_service):\n238:         \"\"\"Test formatting zero size.\"\"\"\n239:         result = docker_service._format_size(0)\n240:         assert result == \"0.00 B\"\n241: \n242:     def test_push_image_to_default_registry(self, docker_service):\n243:         \"\"\"Test pushing image to default registry.\"\"\"\n244:         mock_client = MagicMock()\n245:         mock_images = MagicMock()\n246: \n247:         push_logs = [\n248:             {\"status\": \"Pushing\"},\n249:             {\"status\": \"Pushed\"},\n250:         ]\n251:         mock_images.push.return_value = push_logs\n252:         mock_client.images = mock_images\n253: \n254:         docker_service._client = mock_client\n255: \n256:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n257:             result = docker_service.push_image(\"test:1.0.0\")\n258: \n259:             assert result[\"pushed_image\"] == \"test:1.0.0\"\n260:             assert \"push_time\" in result\n261:             mock_images.push.assert_called_once_with(\"test:1.0.0\", stream=True, decode=True)\n262: \n263: