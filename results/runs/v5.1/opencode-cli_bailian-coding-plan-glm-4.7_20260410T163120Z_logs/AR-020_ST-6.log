er.py` | `AgentCubeProvider` |\n25: | `agentcube/operations/__init__.py` | Placeholder module docstring (no symbols) |\n26: | `examples/hello-agent/main.py` | Example agent |\n27: | `examples/math-agent/main.py` | Example agent |\n28: \n29: **Setuptools packages** (from `pyproject.toml` `[tool.setuptools]`):  \n30: `agentcube`, `agentcube.cli`, `agentcube.runtime`, `agentcube.operations`, `agentcube.services`  \n31: *(Note: `agentcube.models` is not listed in `[tool.setuptools] packages` but is imported; packaging may rely on setuptools discovery for subpackages — reconstruct imports from source as above.)*\n32: \n33: ## Console script entry point\n34: \n35: ```toml\n36: [project.scripts]\n37: kubectl-agentcube = \"agentcube.cli.main:app\"\n38: ```\n39: \n40: Typer app object: `app = typer.Typer(name=\"agentcube\", help=\"...\", no_args_is_help=True, rich_markup_mode=\"rich\", add_completion=False)`.\n41: \n42: ## Typer — root callback\n43: \n44: ```python\n45: def main(\n46:     version: Optional[bool] = typer.Option(\n47:         None, \"--version\", help=\"Show version and exit\",\n48:         callback=version_callback, is_eager=True,\n49:     ),\n50:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Enable verbose output\"),\n51: ) -> None:\n52:     \"\"\"AgentCube CLI - A developer tool for AI agent lifecycle management.\"\"\"\n53: ```\n54: \n55: ## Typer — `pack`\n56: \n57: ```python\n58: def pack(\n59:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n60:     agent_name: Optional[str] = typer.Option(None, \"--agent-name\", help=\"Override the agent name\"),\n61:     language: Optional[str] = typer.Option(None, \"--language\", help=\"Programming language (python, java)\"),\n62:     entrypoint: Optional[str] = typer.Option(None, \"--entrypoint\", help=\"Override the entrypoint command\"),\n63:     port: Optional[int] = typer.Option(None, \"--port\", help=\"Port to expose in the Dockerfile\"),\n64:     build_mode: Optional[str] = typer.Option(None, \"--build-mode\", help=\"Build strategy: local or cloud\"),\n65:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description\"),\n66:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for packaged workspace\"),\n67:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n68: ) -> None:\n69: ```\n70: \n71: ## Typer — `build`\n72: \n73: ```python\n74: def build(\n75:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n76:     proxy: Optional[str] = typer.Option(None, \"-p\", \"--proxy\", help=\"Custom proxy URL for dependency resolution\"),\n77:     cloud_provider: Optional[str] = typer.Option(None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei)\"),\n78:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for build artifacts\"),\n79:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n80: ) -> None:\n81: ```\n82: \n83: ## Typer — `publish`\n84: \n85: ```python\n86: def publish(\n87:     workspace: str = typer.Option(\".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True),\n88:     version: Optional[str] = typer.Option(None, \"--version\", help=\"Semantic version string (e.g., v1.0.0)\"),\n89:     image_url: Optional[str] = typer.Option(None, \"--image-url\", help=\"Image repository URL (required in local build mode)\"),\n90:     image_username: Optional[str] = typer.Option(None, \"--image-username\", help=\"Username for image repository\"),\n91:     image_password: Optional[str] = typer.Option(None, \"--image-password\", help=\"Password for image repository\"),\n92:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description\"),\n93:    