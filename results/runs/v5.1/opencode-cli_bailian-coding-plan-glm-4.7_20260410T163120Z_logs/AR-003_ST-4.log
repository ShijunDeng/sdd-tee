nc init() {\n36: \t// Add the Kubernetes types to the scheme.\n37: \tmetav1.AddToGroupVersion(Scheme, schema.GroupVersion{Version: \"v1\"})\n38: \tk8sutil.Must(AddToScheme(Scheme))\n39: }\n40: \n41: // addKnownTypes adds the set of known types to the supplied scheme.\n42: func addKnownTypes(scheme *k8sruntime.Scheme) error {\n43: \tscheme.AddKnownTypes(SchemeGroupVersion,\n44: \t\t&AgentRuntime{},\n45: \t\t&AgentRuntimeList{},\n46: \t\t&CodeInterpreter{},\n47: \t\t&CodeInterpreterList{},\n48: \t)\n49: \tmetav1.AddToGroupVersion(scheme, SchemeGroupVersion)\n50: \treturn nil\n51: }\n\n(End of file - total 51 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\tk8sruntime \"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/apimachinery/pkg/runtime/serializer\"\n\tk8sutil \"k8s.io/apimachinery/pkg/util/runtime\"\n)\n\nvar (\n\tSchemeBuilder = k8sruntime.NewSchemeBuilder(addKnownTypes)\n\tAddToScheme   = SchemeBuilder.AddToScheme\n)\n\n// SchemeGroupVersion is group version used to register these objects.\nvar SchemeGroupVersion = schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"}\n\n// Resource takes an unqualified resource and returns a Group qualified GroupResource.\nfunc Resource(resource string) schema.GroupResource {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/register.go","time":{"start":1775841186344,"end":1775841186358}}}}
