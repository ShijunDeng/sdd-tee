"\n52:         ;;\n53:     agentcube|cli)\n54:         build_component \"agentcube\"\n55:         ;;\n56:     agentcube-util)\n57:         build_component \"agentcube-util\"\n58:         ;;\n59:     code-interpreter)\n60:         build_component \"code-interpreter\"\n61:         ;;\n62:     agent-runtime|runtime)\n63:         build_component \"agent-runtime\"\n64:         ;;\n65:     *)\n66:         echo \"Unknown component: $COMPONENT\"\n67:         echo \"\"\n68:         echo \"Usage: $0 [component]\"\n69:         echo \"\"\n70:         echo \"Components:\"\n71:         echo \"  all           Build all components (default)\"\n72:         echo \"  go            Build all Go components\"\n73:         echo \"  python        Build all Python components\"\n74:         echo \"  agentd        Build agentd\"\n75:         echo \"  picod         Build picod\"\n76:         echo \"  agentcube     Build agentcube CLI\"\n77:         echo \"  agentcube-util Build agentcube-util\"\n78:         echo \"  code-interpreter Build code-interpreter\"\n79:         echo \"  agent-runtime Build agent-runtime\"\n80:         echo \"\"\n81:         exit 1\n82:         ;;\n83: esac\n84: \n85: echo \"\"\n86: echo \"Build completed successfully!\"\n\n(End of file - total 86 lines)\n</content>","metadata":{"preview":"#!/bin/bash\n# Build script for AgentCube project\n# This script builds all components of the project\n\nset -e\n\necho \"Building AgentCube project...\"\n\n# Get the script directory\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nPROJECT_ROOT=\"$(dirname \"$SCRIPT_DIR\")\"\n\n# Change to project root\ncd \"$PROJECT_ROOT\"\n\n# Parse command line arguments\nBUILD_MODE=\"${BUILD_MODE:-dev}\"\nCOMPONENT=\"${1:-all}\"\n\necho \"Build mode: $BUILD_MODE\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/scripts/build.sh","time":{"start":1775885032447,"end":1775885032485}}}}
