\\033[0;32m\\nYELLOW := \\\\033[1;33m\\nRED := \\\\033[0;31m\\nNC := \\\\033[0m\\n\\n# Define version information\\nVERSION := $(shell cat VERSION 2>/dev/null || echo \\\"0.1.0\\\")\\nGIT_COMMIT := $(shell git rev-parse --short HEAD 2>/dev/null || echo \\\"unknown\\\")\\nGIT_BRANCH := $(shell git rev-parse --abbrev-ref HEAD 2>/dev/null || echo \\\"unknown\\\")\\nBUILD_TIME := $(shell date -u +%Y-%m-%dT%H:%M:%SZ)\\n\\n# Go related variables\\nGO := go\\nGO_VERSION := 1.25\\nGOFLAGS :=\\nBUILD_DIR := bin\\nDIST_DIR := dist\\nCOVERAGE_DIR := coverage\\nREPORT_DIR := reports\\n\\n# Go build flags\\nifeq ($(BUILD_MODE),release)\\n\\tGO_BUILD_FLAGS := -ldflags=\\\"-s -w -X main.version=$(VERSION) -X main.commit=$(GIT_COMMIT) -X main.buildTime=$(BUILD_TIME)\\\"\\nelse\\n\\tGO_BUILD_FLAGS := -race -ldflags=\\\"-X main.version=$(VERSION) -X main.commit=$(GIT_COMMIT) -X main.buildTime=$(BUILD_TIME)\\\"\\nendif\\n\\n# Python related variables\\nPYTHON := python3\\nPIP := pip3\\nPYTHON_VERSION := 3.10\\nVENV_DIR := .venv\\n\\n# Docker related variables\\nDOCKER := docker\\nDOCKER_REGISTRY :=\\nIMAGE_NAME := agentcube\\nIMAGE_TAG := $(VERSION)\\n\\n# Platform variables\\nGOOS ?= $(shell go env GOOS)\\nGOARCH ?= $(shell go env GOARCH)\\nPLATFORM := $(GOOS)_$(GOARCH)\\n\\n# Test flags\\nTEST_FLAGS := -v\\nTEST_TIMEOUT := 30m\\nGO_TEST_COVERAGE := $(COVERAGE_DIR)/go_coverage.out\\nGO_TEST_COVERAGE_HTML := $(COVERAGE_DIR)/go_coverage.html\\nPYTHON_TEST_COVERAGE := $(COVERAGE_DIR)/python_coverage\\n\\n# Binary names\\nAGENTD_BIN := $(BUILD_DIR)/$(PLATFORM)/agentd\\nPICOD_BIN := $(BUILD_DIR)/$(PLATFORM)/picod\\nAGENT...\n  Line 67: {\"type\":\"tool_use\",\"timestamp\":1775884812047,\"sessionID\":\"ses_28508bd72ffeXIhFXu0VWKX43w\",\"part\":{\"id\":\"prt_d7afb96ff001KuvB7UhHIfGP4f\",\"messageID\":\"msg_d7afa9cac001OPkqAKmAFRjI50\",\"sessionID\":\"ses_28508bd72ffeXIhFXu0VWKX43w\",\"type\":\"tool\",\"tool\":\"write\",\"callID\":\"toolu_tool-344e3e941b5049209b1a6c01f4edabc3\",\"state\":{\"