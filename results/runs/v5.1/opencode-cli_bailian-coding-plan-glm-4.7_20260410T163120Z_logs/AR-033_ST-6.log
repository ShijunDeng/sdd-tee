linting checks...$(NC)\"\n36: \t@if command -v ruff > /dev/null 2>&1; then \\\n37: \t\techo \"$(BLUE)Running ruff...$(NC)\"; \\\n38: \t\truff check .; \\\n39: \telse \\\n40: \t\techo \"$(YELLOW)ruff not found, skipping...$(NC)\"; \\\n41: \tfi\n42: \t@if command -v mypy > /dev/null 2>&1; then \\\n43: \t\techo \"$(BLUE)Running mypy...$(NC)\"; \\\n44: \t\tmypy agentcube/ --ignore-missing-imports || true; \\\n45: \telse \\\n46: \t\techo \"$(YELLOW)mypy not found, skipping...$(NC)\"; \\\n47: \tfi\n48: \t@if command -v flake8 > /dev/null 2>&1; then \\\n49: \t\techo \"$(BLUE)Running flake8...$(NC)\"; \\\n50: \t\tflake8 agentcube/ --max-line-length=100 || true; \\\n51: \telse \\\n52: \t\techo \"$(YELLOW)flake8 not found, skipping...$(NC)\"; \\\n53: \tfi\n54: \t@echo \"$(GREEN)✓ Python linting passed$(NC)\"\n55: \n56: .PHONY: lint-python-fix\n57: lint-python-fix: ## Auto-fix Python linting issues\n58: \t@echo \"$(BLUE)Fixing Python linting issues...$(NC)\"\n59: \t@if command -v ruff > /dev/null 2>&1; then \\\n60: \t\techo \"$(BLUE)Running ruff with fixes...$(NC)\"; \\\n61: \t\truff check --fix .; \\\n62: \tfi\n63: \t@if command -v black > /dev/null 2>&1; then \\\n64: \t\techo \"$(BLUE)Running black...$(NC)\"; \\\n65: \t\tblack agentcube/; \\\n66: \tfi\n67: \t@if command -v isort > /dev/null 2>&1; then \\\n68: \t\techo \"$(BLUE)Running isort...$(NC)\"; \\\n69: \t\tisort agentcube/; \\\n70: \tfi\n71: \t@echo \"$(GREEN)✓ Python linting fixes applied$(NC)\"\n72: \n73: .PHONY: lint-docker\n74: lint-docker: ## Run Docker linting checks\n75: \t@echo \"$(BLUE)Running Docker linting checks...$(NC)\"\n76: \t@if command -v hadolint > /dev/null 2>&1; then \\\n77: \t\techo \"$(BLUE)Running hadolint...$(NC)\"; \\\n78: \t\tfind . -name \"Dockerfile*\" -exec hadolint {} \\+; \\\n79: \telse \\\n80: \t\techo \"$(YELLOW)hadolint not found, skipping...$(NC)\"; \\\n\n(Showing lines 1-80 of 220. Use offset=81 to continue.)\n</content>","metadata":{"preview":".PHONY: lint\nlint: lint-go lint-pytho