D to reuse\n36: \n37:         Raises:\n38:             ValueError: If router_url is not provided or found in environment\n39:         \"\"\"\n40:         self.name = name\n41:         self.namespace = namespace\n42:         self.ttl = ttl\n43:         self.verbose = verbose\n44:         self.logger = get_logger(f\"{__name__}.CodeInterpreterClient\")\n45: \n46:         if verbose:\n47:             self.logger.setLevel(10)\n48: \n49:         self.router_url = router_url or os.getenv(\"ROUTER_URL\")\n50: \n51:         if not self.router_url:\n52:             raise ValueError(\n53:                 \"Router URL must be provided via router_url argument or ROUTER_URL environment variable\"\n54:             )\n55: \n56:         self.session_id = session_id\n57:         self.cp_client = ControlPlaneClient(\n58:             workload_manager_url=workload_manager_url,\n59:             auth_token=auth_token,\n60:         )\n61:         self.dp_client: Optional[CodeInterpreterDataPlaneClient] = None\n62: \n63:         if self.session_id:\n64:             self.logger.info(f\"Reusing existing session: {self.session_id}\")\n65:             self._init_data_plane()\n66:         else:\n67:             self._create_session()\n68: \n69:     def _create_session(self) -> None:\n70:         \"\"\"Create a new session via control plane.\"\"\"\n71:         self.session_id = self.cp_client.create_session(\n72:             name=self.name,\n73:             namespace=self.namespace,\n74:             ttl=self.ttl,\n75:         )\n76:         self._init_data_plane()\n77: \n78:     def _init_data_plane(self) -> None:\n79:         \"\"\"Initialize the data plane client.\n80: \n81:         Raises:\n82:             Exception: If initialization fails, cleans up session\n83:         \"\"\"\n84:         try:\n85:             if not self.session_id:\n86:                 raise ValueError(\"session_id is required to initialize data plane client\")\n87: \n88:             self.dp_client = CodeInterpreterDataPlaneClient(\n89:                 session_id=self.session_id,\n90:                 router_url=self.router_url,\n91:                 namespace=self.namespace,\n92:                 cr_name=self.name,\n93:             )\n94:         except Exception as e:\n95:             if self.session_id and self.cp_client:\n96:                 self.logger.warning(\n97:                     f\"Data plane initialization failed, cleaning up session: {e}\"\n98:                 )\n99:                 self.cp_client.delete_session(self.session_id)\n100:                 self.session_id = None\n101:             raise\n102: \n103:     def __enter__(self) -> \"CodeInterpreterClient\":\n104:         \"\"\"Enter context manager.\n105: \n106:         Returns:\n107:             Self\n108:         \"\"\"\n109:         return self\n110: \n111:     def __exit__(self, exc_type: Optional[object], exc_val: Optional[object], exc_tb: Optional[object]) -> None:\n112:         \"\"\"Exit context manager and cleanup.\n113: \n114:         Args:\n115:             exc_type: Exception type\n116:             exc_val: Exception value\n117:             exc_tb: Exception traceback\n118:         \"\"\"\n119:         self.stop()\n120: \n121:     def stop(self) -> None:\n122:         \"\"\"Stop the session and cleanup resources.\"\"\"\n123:         if self.dp_client:\n124:             self.dp_client.close()\n125:             self.dp_client = None\n126: \n127:         if self.session_id and self.cp_client:\n128:             self.cp_client.delete_session(self.session_id)\n129:             self.session_id = None\n130: \n131:         if self.cp_client:\n132:             self.cp_client.close()\n133: \n134:         self.logger.info(\"Stopped Code Interpreter session\")\n135: \n136:     def execute_command(self, command: str, timeout: Optional[float] = None) -> str:\n137:         \"\"\"Execute a command in the session.\n138: \n139:         Args:\n140:             command: Command to execute\n141:             timeout: Timeout in