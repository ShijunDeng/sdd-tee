name)\n38:             timeout: Request timeout in seconds\n39:             connect_timeout: Connection timeout in seconds\n40:             pool_connections: Number of connection pools to cache\n41:             pool_maxsize: Maximum number of connections in pool\n42:         \"\"\"\n43:         self.session_id = session_id\n44:         self.timeout = timeout\n45:         self.connect_timeout = connect_timeout\n46:         self.logger = get_logger(f\"{__name__}.CodeInterpreterDataPlaneClient\")\n47:         self.session = create_session(pool_connections=pool_connections, pool_maxsize=pool_maxsize)\n48: \n49:         if base_url:\n50:             self.base_url = base_url\n51:         elif router_url and namespace and cr_name:\n52:             base_path = f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\"\n53:             self.base_url = urljoin(router_url, base_path)\n54:         else:\n55:             raise ValueError(\"Either base_url or (router_url, namespace, cr_name) must be provided\")\n56: \n57:         self.session.headers.update({\"x-agentcube-session-id\": session_id})\n58:         self.logger.debug(f\"Initialized data plane client with base_url: {self.base_url}\")\n59: \n60:     def _request(\n61:         self,\n62:         method: str,\n63:         endpoint: str,\n64:         body: Optional[bytes] = None,\n65:     ) -> requests.Response:\n66:         \"\"\"Make a request to the data plane.\n67: \n68:         Args:\n69:             method: HTTP method\n70:             endpoint: API endpoint relative to base_url\n71:             body: Request body as bytes\n72: \n73:         Returns:\n74:             Response object\n75: \n76:         Raises:\n77:             requests.RequestException: If the request fails\n78:         \"\"\"\n79:         url = f\"{self.base_url}{endpoint}\"\n80:         headers: dict[str, str] = {}\n81: \n82:         if body is not None:\n83:             headers[\"Content-Type\"] = \"application/json\"\n84: \n85:         response = self.session.request(\n86:             method,\n87:             url,\n88:             data=body,\n89:             headers=headers,\n90:             timeout=(self.connect_timeout, self.timeout),\n91:         )\n92: \n93:         response.raise_for_status()\n94:         return response\n95: \n96:     def execute_command(\n97:         self,\n98:         command: Union[str, list[str]],\n99:         timeout: Optional[float] = None,\n100:     ) -> str:\n101:         \"\"\"Execute a command in the Code Interpreter session.\n102: \n103:         Args:\n104:             command: Command string or list of arguments\n105:             timeout: Timeout in seconds (uses instance default if None)\n106: \n107:         Returns:\n108:             Command output\n109: \n110:         Raises:\n111:             CommandExecutionError: If command exits with non-zero code\n112:             requests.RequestException: If the request fails\n113:         \"\"\"\n114:         if isinstance(command, str):\n115:             command_list = [command]\n116:         else:\n117:             command_list = command\n118: \n119:         timeout_value = timeout if timeout is not None else self.timeout\n120:         timeout_str = f\"{timeout_value}s\"\n121: \n122:         body = {\"command\": command_list, \"timeout\": timeout_str}\n123:         body_bytes = json.dumps(body).encode(\"utf-8\")\n124: \n125:         read_timeout = timeout_value + 2.0\n126: \n127:         self.logger.debug(f\"Executing command: {' '.join(command_list)}\")\n128: \n129:         response = self.session.post(\n130:             f\"{self.base_url}api/execute\",\n131:             data=body_bytes,\n132:             headers={\"Content-Type\": \"application/json\", \"x-agentcube-session-id\": self.session_id},\n133:             timeout=(self.connect_timeout, read_timeout),\n134:         )\n135: \n136:         response.raise_for_status()\n137:         data = response.json()\n138: \n139:         exit_code = data.get(\"exit_code\", 0)\n140: \n141:         if exit_code != 0:\n142:             stderr = data.get(\"stderr\", \"\")\n143:             cmd_str = \" \".join(command_list)\n144:             self.logger.error(f\"Command failed with exit code {exit_code}: {stderr}\")\n145:             raise CommandExecutionError(exit_code=exit_code, stderr=stderr, command=cmd_str)\n146: \n147:         stdout = data.get(\"stdout\", \"\")\n148:         return stdout\n149: \n150:     def run_code(\n151:         self,\n152:         language: str,\n153:         code: str,\n154:         timeout: Optional[float] = None,\n155:     ) -> str:\n156:         \"\"\"Run code in the specified language.\n157: \n158:         Args:\n159:             language: Programming language (python, py, python3 supported)\n160:             code: Source code to execute\n161:             timeout: Timeout in seconds\n162: \n163:         Returns:\n164:             Execution output\n165: \n166:         Raises:\n167:             ValueError: If language is not supported\n168:         \"\"\"\n169:         language_lower = language.lower()\n170: \n171:         if language_lower not in (\"python\", \"py\", \"python3\"):\n172:             raise ValueError(f\"Unsupported language: {language}\")\n173: \n174:         timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S_%f\")\n175:         file_name = f\"code_{timestamp}.py\"\n176: \n177:         self.write_file(code, file_name)\n178: \n179:         command = f\"python3 {file_name}\"\n180:         return self.execute_command(command, timeout=timeout)\n181: \n182:     def write_file(self, content: str, remote_path: str) -> None:\n183:         \"\"\"Write content to a file in the session.\n184: \n185:         Args:\n186:             content: File content as string\n187:             remote_path: Remote file path\n188: \n189:         Raises:\n190:             requests.RequestException: If the request fails\n191:         \"\"\"\n192:         content_b64 = base64.b64encode(content.encode(\"utf-8\")).decode(\"utf-8\")\n193: \n194:         body = {\"path\": remote_path, \"content\": content_b64, \"mode\": \"0644\"}\n195:         body_bytes = json.dumps(body).encode(\"utf-8\")\n196: \n197:         self.logger.debug(f\"Writing file: {remote_path}\")\n198: \n199:         self._request(\"POST\", \"api/files\", body=body_bytes)\n200: \n201:     def upload_file(self, local_path: str, remote_path: str) -> None:\n202:         \"\"\"Upload a local file to the session.\n203: \n204:         Args:\n205:             local_path: Local file path\n206:             remote_path: Remote file path\n207: \n208:         Raises:\n209:             requests.RequestException: If the request fails\n210:         \"\"\"\n211:         self.logger.debug(f\"Uploading file: {local_path} -> {remote_path}\")\n212: \n213:         with open(local_path, \"rb\") as f:\n214:             files = {\"file\": f}\n215:             data = {\"path\": remote_path, \"mode\": \"0644\"}\n216: \n217:             response = self.session.post(\n218:                 f\"{self.base_url}api/files\",\n219:                 files=files,\n220:                 data=data,\n221:                 headers={\"x-agentcube-session-id\": self.session_id},\n222:                 timeout=(self.connect_timeout, self.timeout),\n223:             )\n224: \n225:             response.raise_for_status()\n226: \n227:     def download_file(self, remote_path: str, local_path: str) -> None:\n228:         \"\"\"Download a file from the session.\n229: \n230:         Args:\n231:             remote_path: Remote file path\n232:             local_path: Local file path\n233: \n234:         Raises:\n235:             requests.RequestException: If the request fails\n236:         \"\"\"\n237:         clean_path = remote_path.lstrip(\"/\")\n238: \n239:         self.logger.debug(f\"Downloading file: {remote_path} -> {local_path}\")\n240: \n241:         response = self.session.get(\n242:             f\"{self.base_url}api/files/{clean_path}\",\n243:             headers={\"x-agentcube-session-id\": self.session_id},\n244:             timeout=(self.connect_timeout, self.timeout),\n245:             stream=True,\n246:         )\n247: \n248:         response.raise_for_status()\n249: \n250:         with open(local_path, \"wb\") as f:\n251:             for chunk in response.iter_content(chunk_size=8192):\n252:                 f.write(chunk)\n253: \n254:     def list_files(self, path: str = \".\") -> Any:\n255:         \"\"\"List files in the session.\n256: \n257:         Args:\n258:             path: Directory path to list\n259: \n260:         Returns:\n261:             JSON response with file listing\n262: \n263:         Raises:\n264:             requests.RequestException: If the request fails\n265:         \"\"\"\n266:         self.logger.debug(f\"Listing files: {path}\")\n267: \n268:         response = self.session.get(\n269:             f\"{self.base_url}api/files\",\n270:             headers={\"x-agentcube-session-id\": self.session_id},\n271:             params={\"path\": path},\n272:             timeout=(self.connect_timeout, self.timeout),\n273:         )\n274: \n275:         response.raise_for_status()\n276:         return response.json()\n277: \n278:     def close(self) -> None:\n279:         \"\"\"Close the HTTP session.\"\"\"\n280:         self.session.close()\n281:         self.logger.debug(\"Closed code interpreter data plane session\")\n\n(End of file - total 281 lines)\n</content>","metadata":{"preview":"\"\"\"Data plane client for Code Interpreter operations.\"\"\"\n\nimport base64\nimport json\nfrom datetime import datetime\nfrom typing import Any, Optional, Union\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom ..exceptions import CommandExecutionError\nfrom ..utils import create_session, get_logger\n\n\nclass CodeInterpreterDataPlaneClient:\n    \"\"\"Client for Code Interpreter data plane operations via Router.\"\"\"\n\n    def __init__(\n        self,\n        session_id: str,","truncated":false,"