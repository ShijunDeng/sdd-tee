s whether the ConfigMap must exist.\n370:                               type: boolean\n371:                           required:\n372:                           - key\n373:                           - name\n374:                           type: object\n375:                         fieldRef:\n376:                           description: FieldRef selects a field from the pod.\n377:                           properties:\n378:                             fieldPath:\n379:                               description: FieldPath is the path of the field.\n380:                               type: string\n381:                           required:\n382:                           - fieldPath\n383:                           type: object\n384:                         secretKeyRef:\n385:                           description: SecretKeyRef selects a key from a Secret.\n386:                           properties:\n387:                             key:\n388:                               description: Key is the key to select.\n389:                               type: string\n390:                             name:\n391:                               description: Name is the name of the Secret.\n392:                               type: string\n393:                             optional:\n394:                               description: Optional specifies whether the Secret must exist.\n395:                               type: boolean\n396:                           required:\n397:                           - key\n398:                           - name\n399:                           type: object\n400:                       type: object\n401:                   required:\n402:                   - name\n403:                   type: object\n404:                 type: array\n405:               image:\n406:                 description: Image is the container image for the interpreter.\n407:                 type: string\n408:               resources:\n409:                 description: Resources defines