{"type":"tool_use","timestamp":1775851438503,"sessionID":"ses_28701c770ffe7IF9hHkfCd4Qlx","part":{"id":"prt_d78fe817e001v325LmGtOK7atJ","messageID":"msg_d78fe6dd6001QVOJD22n5pXkVw","sessionID":"ses_28701c770ffe7IF9hHkfCd4Qlx","type":"tool","tool":"read","callID":"toolu_tool-90bdf765a5c74f72a738f71c4eeb8872","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/middleware.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/middleware.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"net/http\"\n6: \t\"sync\"\n7: \t\"time\"\n8: \n9: \t\"github.com/gin-gonic/gin\"\n10: \t\"github.com/google/uuid\"\n11: \t\"k8s.io/klog/v2\"\n12: )\n13: \n14: type ConcurrencyLimiter struct {\n15: \tsemaphore chan struct{}\n16: }\n17: \n18: func NewConcurrencyLimiter(maxConcurrent int) *ConcurrencyLimiter {\n19: \treturn &ConcurrencyLimiter{\n20: \t\tsemaphore: make(chan struct{}, maxConcurrent),\n21: \t}\n22: }\n23: \n24: func (l *ConcurrencyLimiter) Acquire() bool {\n25: \tselect {\n26: \tcase l.semaphore <- struct{}{}:\n27: \t\treturn true\n28: \tdefault:\n29: \t\treturn false\n30: \t}\n31: }\n32: \n33: func (l *ConcurrencyLimiter) Release() {\n34: \t<-l.semaphore\n35: }\n36: \n37: func concurrencyLimitMiddleware(limiter *ConcurrencyLimiter) gin.HandlerFunc {\n38: \treturn func(c *gin.Context) {\n39: \t\tif !limiter.Acquire() {\n40: \t\t\tc.JSON(http.StatusTooManyRequests, NewErrorResponse(\n41: \t\t\t\t\"server overloaded, please try again later\",\n42: \t\t\t\tErrServerOverloaded,\n43: \t\t\t))\n44: \t\t\tc.Abort()\n45: \t\t\treturn\n46: \t\t}\n47: \t\tdefer limiter.Release()\n48: \n49: \t\tc.Next()\n50: \t}\n51: }\n52: \n53: func loggingMiddleware() gin.HandlerFunc {\n54: \treturn func(c *gin.Context) {\n55: \t\tstart := time.Now()\n56: \n57: \t\tcorrelationID := c.GetHeader(\"X-Request-ID\")\n58: \t\tif correlationID == \"\" {\n59: \t\t\tcorrelationID = uuid.New().String()\n60: \t\t\tc.Header(\"X-Request-ID\", correlationID)\n61: \t\t}\n62: \t\tc.Set(\"correlationID\", correlationID)\n63: \n64: \t\tklog.V(4).Infof(\"[%s] %s %s\", correlationID, c.Request.Method, c.Request.URL.Path)\n65: \n66: \t\tc.Next()\n67: \n68: \t\tduration := time.Since(start)\n69: \t\tklog.V(4).Infof(\"[%s] %s %s - Status: %d - Duration: %v\",\n70: \t\t\tcorrelationID,\n71: \t\t\tc.Request.Method,\n72: \t\t\tc.Request.URL.Path,\n73: \t\t\tc.Writer.Status(),\n74: \t\t\tduration,\n75: \t\t)\n76: \t}\n77: }\n78: \n79: func recoveryMiddleware() gin.HandlerFunc {\n80: \treturn func(c *gin.Context) {\n81: \t\tdefer func() {\n82: \t\t\tif err := recover(); err != nil {\n83: \t\t\t\tcorrelationID, _ := c.Get(\"correlationID\")\n84: \t\t\t\tklog.Errorf(\"[%v] Panic recovered: %v\", correlationID, err)\n85: \n86: \t\t\t\tc.JSON(http.StatusInternalServerError, NewErrorResponse(\n87: \t\t\t\t\t\"internal server error\",\n88: \t\t\t\t\t\"\",\n89: \t\t\t\t))\n90: \t\t\t\tc.Abort()\n91: \t\t\t}\n92: \t\t}()\n93: \n94: \t\tc.Next()\n95: \t}\n96: }\n97: \n98: func correlationIDMiddleware() gin.HandlerFunc {\n99: \treturn func(c *gin.Context) {\n100: \t\tcorrelationID := c.GetHeader(\"X-Request-ID\")\n101: \t\tif correlationID == \"\" {\n102: \t\t\tcorrelationID = uuid.New().String()\n103: \t\t}\n104: \n105: \t\tc.Set(\"correlationID\", correlationID)\n106: \t\tc.Header(\"X-Request-ID\", correlationID)\n107: \n108: \t\tc.Next()\n109: \t}\n110: }\n111: \n112: type Metrics struct {\n113: \trequestCount      map[string]int64\n114: \tresponseTime      map[string][]time.Duration\n115: \tactiveConnections int\n116: \tmu                sync.RWMutex\n117: }\n118: \n119: func NewMetrics() *Metrics {\n120: \treturn &Metrics{\n121: \t\trequestCount: make(map[string]int64),\n122: \t\tresponseTime: make(map[string][]time.Duration),\n123: \t}\n124: }\n125: \n126: func (m *Metrics) RecordRequest(method, path string, duration time.Duration) {\n127: \tm.mu.Lock()\n128: \tdefer m.mu.Unlock()\n129: \n130: \tkey := fmt.Sprintf(\"%s %s\", method, path)\n131: \tm.requestCount[key]++\n132: \tm.responseTime[key] = append(m.responseTime[key], duration)\n133: \n134: \tif len(m.responseTime[key]) > 1000 {\n135: \t\tm.responseTime[key] = m.responseTime[key][1:]\n136: \t}\n137: }\n138: \n139: func (m *Metrics) IncrementActiveConnections() {\n140: \tm.mu.Lock()\n141: \tdefer m.mu.Unlock()\n142: \tm.activeConnections++\n143: }\n144: \n145: func (m *Metrics) DecrementActiveConnections() {\n146: \tm.mu.Lock()\n147: \tdefer m.mu.Unlock()\n148: \tm.activeConnections--\n149: }\n150: \n151: func (m *Metrics) GetActiveConnections() int {\n152: \tm.mu.RLock()\n153: \tdefer m.mu.RUnlock()\n154: \treturn m.activeConnections\n155: }\n156: \n157: func metricsMiddleware(metrics *Metrics) gin.HandlerFunc {\n158: \treturn func(c *gin.Context) {\n159: \t\tstart := time.Now()\n160: \n161: \t\tmetrics.IncrementActiveConnections()\n162: \t\tdefer metrics.DecrementActiveConnections()\n163: \n164: \t\tc.Next()\n165: \n166: \t\tduration := time.Since(start)\n167: \t\tmetrics.RecordRequest(c.Request.Method, c.FullPath(), duration)\n168: \t}\n169: }\n\n(End of file - total 169 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype ConcurrencyLimiter struct {\n\tsemaphore chan struct{}\n}\n\nfunc NewConcurrencyLimiter(maxConcurrent int) *ConcurrencyLimiter {\n\treturn &ConcurrencyLimiter{\n\t\tsemaphore: make(chan struct{}, maxConcurrent),","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/middleware.go","time":{"start":1775851438481,"end":1775851438500}}}}
