pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: statusConditionsEqual"},{"range":{"start":{"line":105,"character":5},"end":{"line":105,"character":26}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: statusConditionsEqual"},{"range":{"start":{"line":172,"character":1},"end":{"line":172,"character":7}},"severity":1,"code":"UnusedVar","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UnusedVar"},"source":"compiler","message":"declared and not used: logger","tags":[1]},{"range":{"start":{"line":241,"character":4},"end":{"line":241,"character":17}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: podSpecsEqual"},{"range":{"start":{"line":266,"character":28},"end":{"line":266,"character":42}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: convertEnvVars"},{"range":{"start":{"line":273,"character":24},"end":{"line":273,"character":40}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: convertResources"},{"range":{"start":{"line":325,"character":5},"end":{"line":325,"character":26}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: statusConditionsEqual"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/controller.go":[{"range":{"start":{"line":56,"character":2},"end":{"line":56,"character":20}},"severity":1,"code":"MissingLitField","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#MissingLitField"},"source":"compiler","message":"unknown field MetricsBindAddress in struct literal of type controllerruntime.Options"},{"range":{"start":{"line":57,"character":2},"end":{"line":57,"character":6}},"severity":1,"code":"MissingLitField","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#MissingLitField"},"source":"compiler","message":"unknown field Port in struct literal of type controllerruntime.Options"},{"range":{"start":{"line":61,"character":2},"end":{"line":61,"character":12}},"severity":1,"code":"MissingLitField","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#MissingLitField"},"source":"compiler","message":"unknown field SyncPeriod in struct literal of type controllerruntime.Options"},{"range":{"start":{"line":87,"character":16},"end":{"line":87,"character":38}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: AgentRuntimeReconciler"},{"range":{"start":{"line":97,"character":14},"end":{"line":97,"character":80}},"severity":1,"code":"IncompatibleAssign","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#IncompatibleAssign"},"source":"compiler","message":"cannot use ctrl.Options{…} (value of struct type controllerruntime.Options) as controller.TypedOptions[reconcile.Request] value in argument to ctrl.NewControllerManagedBy(mgr).For(&runtimev1alpha1.AgentRuntime{}).WithEventFilter(&ResourceGenerationChangedPredicate{}).WithOptions"},{"range":{"start":{"line":97,"character":27},"end":{"line":97,"character":50}},"severity":1,"code":"MissingLitField","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/