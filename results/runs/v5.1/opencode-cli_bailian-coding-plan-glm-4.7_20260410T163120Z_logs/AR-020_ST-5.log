{"type":"tool_use","timestamp":1775865626196,"sessionID":"ses_2862e79c9ffeeyo7XEFl77yktq","part":{"id":"prt_d79d6fc54001ORZrtbFgN77Mlw","messageID":"msg_d79d6c2f8001S3qgLvbFHsrujL","sessionID":"ses_2862e79c9ffeeyo7XEFl77yktq","type":"tool","tool":"write","callID":"toolu_tool-0cc1942c52864caba104d4b337587c68","state":{"status":"completed","input":{"content":"\"\"\"Tests for the metadata service.\"\"\"\n\nimport pytest\nfrom pathlib import Path\nimport tempfile\nimport yaml\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\n\n\nclass TestAgentMetadata:\n    \"\"\"Test cases for AgentMetadata.\"\"\"\n\n    def test_create_valid_metadata(self):\n        \"\"\"Test creating valid metadata.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=8080,\n            build_mode=\"local\",\n        )\n\n        assert metadata.agent_name == \"test-agent\"\n        assert metadata.language == \"python\"\n        assert metadata.port == 8080\n        assert metadata.build_mode == \"local\"\n\n    def test_language_validation(self):\n        \"\"\"Test language validation.\"\"\"\n        with pytest.raises(ValueError, match=\"Language must be 'python' or 'java'\"):\n            AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"invalid\",\n                entrypoint=\"python main.py\",\n            )\n\n    def test_language_case_normalization(self):\n        \"\"\"Test language case normalization.\"\"\"\n        metadata = AgentMetadata(\n            agent_name=\"test-agent\",\n            language=\"PYTHON\",\n            entrypoint=\"python main.py\",\n        )\n\n        assert metadata.language == \"python\"\n\n    def test_build_mode_validation(self):\n        \"\"\"Test build mode validation.\"\"\"\n        with pytest.raises(ValueError, match=\"Build mode must be 'local' or 'cloud'\"):\n            AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                build_mode=\"invalid\",\n            )\n\n    def test_port_validation(self):\n        \"\"\"Test port validation.\"\"\"\n        with pytest.raises(ValueError, match=\"Port must be between 1 and 65535\"):\n            AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=70000,\n            )\n\n        with pytest.raises(ValueError, match=\"Port must be between 1 and 65535\"):\n            AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=0,\n            )\n\n\nclass TestMetadataService:\n    \"\"\"Test cases for MetadataService.\"\"\"\n\n    def test_save_and_load_metadata(self):\n        \"\"\"Test saving and loading metadata.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n                build_mode=\"local\",\n            )\n\n            service = MetadataService()\n            service.save_metadata(workspace, metadata)\n\n            loaded_metadata = service.load_metadata(workspace)\n\n            assert loaded_metadata.agent_name == metadata.agent_name\n            assert loaded_metadata.language == metadata.language\n            assert loaded_metadata.port == metadata.port\n\n    def test_load_metadata_fallback(self):\n        \"\"\"Test loading metadata with fallback files.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n            )\n\n            service = MetadataService()\n\n            metadata_file = workspace / \"agent.yaml\"\n            with open(metadata_file, \"w\") as f:\n                yaml.dump(metadata.model_dump(exclude_none=True), f)\n\n            loaded_metadata = service.load_metadata(workspace)\n            assert loaded_metadata.agent_name == \"test-agent\"\n\n    def test_update_metadata(self):\n        \"\"\"Test updating metadata.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n            )\n\n            service = MetadataService()\n            service.save_metadata(workspace, metadata)\n\n            updated_metadata = service.update_metadata(\n                workspace, {\"port\": 9090, \"description\": \"Updated\"}\n            )\n\n            assert updated_metadata.port == 9090\n            assert updated_metadata.description == \"Updated\"\n\n    def test_validate_workspace_exists(self):\n        \"\"\"Test workspace validation when workspace exists.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            service = MetadataService()\n\n            assert service.validate_workspace(workspace) is True\n\n    def test_validate_workspace_not_exists(self):\n        \"\"\"Test workspace validation when workspace doesn't exist.\"\"\"\n        workspace = Path(\"/nonexistent/path\")\n        service = MetadataService()\n\n        with pytest.raises(FileNotFoundError, match=\"does not exist\"):\n            service.validate_workspace(workspace)\n\n    def test_load_metadata_not_found(self):\n        \"\"\"Test loading metadata when file doesn't exist.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n            service = MetadataService()\n\n            with pytest.raises(FileNotFoundError, match=\"No metadata file found\"):\n                service.load_metadata(workspace)\n\n    def test_save_excludes_none_values(self):\n        \"\"\"Test that save excludes None values.\"\"\"\n        with tempfile.TemporaryDirectory() as tmpdir:\n            workspace = Path(tmpdir)\n\n            metadata = AgentMetadata(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=8080,\n                description=None,\n                region=None,\n            )\n\n            service = MetadataService()\n            service.save_metadata(workspace, metadata)\n\n            metadata_file = workspace / \"agent_metadata.yaml\"\n            with open(metadata_file) as f:\n                data = yaml.safe_load(f)\n\n            assert \"description\" not in data\n            assert \"region\" not in data\n            assert \"agent_name\" in data","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_metadata_service.py"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go\">\nERROR [50:27] undefined: store.NewValkeyStore\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/handler/sandbox_test.go\">\nERROR [138:50] cannot use mockStore (variable of type *mockStore) as store.Store value in argument to NewSandboxHandler: *mockStore does not implement store.Store (missing method GetSa