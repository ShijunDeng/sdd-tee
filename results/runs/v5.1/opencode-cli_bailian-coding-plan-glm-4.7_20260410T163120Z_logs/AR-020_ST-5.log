ilename to use to create the resource\")\n538: \n539: \treturn cmd\n540: }\n541: \n542: func interpreterUpdateCmd() *cobra.Command {\n543: \tvar fileName string\n544: \n545: \tcmd := &cobra.Command{\n546: \t\tUse:   \"update -f FILENAME\",\n547: \t\tShort: \"Update a CodeInterpreter resource from a file\",\n548: \t\tRun: func(cmd *cobra.Command, args []string) {\n549: \t\t\tif fileName == \"\" {\n550: \t\t\t\tcmd.Help()\n551: \t\t\t\tos.Exit(cli.ExitCodeFailure)\n552: \t\t\t}\n553: \n554: \t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n555: \t\t\tif err != nil {\n556: \t\t\t\tcli.HandleError(err)\n557: \t\t\t}\n558: \n559: \t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n560: \t\t\tif err != nil {\n561: \t\t\t\tcli.HandleError(err)\n562: \t\t\t}\n563: \n564: \t\t\tdata, err := os.ReadFile(fileName)\n565: \t\t\tif err != nil {\n566: \t\t\t\tcli.HandleError(err)\n567: \t\t\t}\n568: \n569: \t\t\tinterpreter := &runtimev1alpha1.CodeInterpreter{}\n570: \t\t\tif err := yaml.Unmarshal(data, interpreter); err != nil {\n571: \t\t\t\tcli.HandleError(err)\n572: \t\t\t}\n573: \n574: \t\t\tupdated, err := interpreterClient.Update(cmd.Context(), interpreter, metav1.UpdateOptions{})\n575: \t\t\tif err != nil {\n576: \t\t\t\tcli.HandleError(err)\n577: \t\t\t}\n578: \n579: \t\t\tprinter := &cli.PrintOptions{\n580: \t\t\t\tFormat: cli.OutputFormatYAML,\n581: \t\t\t\tOutput: os.Stdout,\n582: \t\t\t}\n583: \t\t\tif err := cli.Print(updated, printer); err != nil {\n584: \t\t\t\tcli.HandleError(err)\n585: \t\t\t}\n586: \t\t},\n587: \t}\n588: \n589: \tcmd.Flags().StringVarP(&fileName, \"filename\", \"f\", \"\", \"Filename to use to update the resource\")\n590: \n591: \treturn cmd\n592: }\n593: \n594: func interpreterDeleteCmd() *cobra.Command {\n595: \tvar force bool\n596: \n597: \tcmd := &cobra.Command{\n598: \t\tUse:   \"delete NAME\",\n599: \t\tShort: \"Delete a CodeInterpreter resource\",\n600: \t\tArgs:  cobra.ExactArgs(1),\n601: \t\tRun: func(cmd *cobra.Command, args []string) {\n602: \t\t\tif !force {\n603: \t\t\t\tif !cli.Confirm(fmt.Sprintf(\"Are you sure you want to delete CodeInterpreter %q?\", args[0])) {\n604: \t\t\t\t\tfmt.Println(\"Deletion cancelled\")\n605: \t\t\t\t\tos.Exit(cli.ExitCodeSuccess)\n606: \t\t\t\t}\n607: \t\t\t}\n608: \n609: \t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n610: \t\t\tif err != nil {\n611: \t\t\t\tcli.HandleError(err)\n612: \t\t\t}\n613: \n614: \t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n615: \t\t\tif err != nil {\n616: \t\t\t\tcli.HandleError(err)\n617: \t\t\t}\n618: \n619: \t\t\tif err := interpreterClient.Delete(cmd.Context(), args[0], metav1.DeleteOptions{}); err != nil {\n620: \t\t\t\tcli.HandleError(err)\n621: \t\t\t}\n622: \n623: \t\t\tfmt.Printf(\"CodeInterpreter %q deleted\\n\", args[0])\n624: \t\t},\n625: \t}\n626: \n627: \tcmd.Flags().BoolVarP(&force, \"force\", \"\", false, \"Delete without confirmation\")\n628: \n629: \treturn cmd\n630: }\n631: \n632: func interpreterWatchCmd() *cobra.Command {\n633: \tcmd := &cobra.Command{\n634: \t\tUse:   \"watch\",\n635: \t\tShort: \"Watch CodeInterpreter resources for changes\",\n636: \t\tRun: func(cmd *cobra.Command, args []string) {\n637: \t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n638: \t\t\tif err != nil {\n639: \t\t\t\tcli.HandleError(err)\n640: \t\t\t}\n641: \n642: \t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n643: \t\t\tif err != nil {\n644: \t\t\t\tcli.HandleError(err)\n645: \t\t\t}\n646: \n647: \t\t\twatcher, err := interpreterClient.Watch(cmd.Context(), metav1.ListOptions{})\n648: \t\t\tif err != nil {\n649: \t\t\t\tcli.HandleError(err)\n650: \t\t\t}\n651: \t\t\tdefer watcher.Stop()\n652: \n653: \t\t\tfor event := range watcher.ResultChan() {\n654: \t\t\t\tinterpreter, ok := event.Object.(*runtimev1alpha1.CodeInterpreter)\n655: \t\t\t\tif !ok {\n656: \t\t\t\t\tcontinue\n657: \t\t\t\t}\n658: \n659: \t\t\t\tswitch event.Type {\n660: \t\t\t\tcase watch.Added:\n661: \t\t\t\t\tfmt.Printf(\"ADDED\\t%s\\n\", interpreter.Name)\n662: \t\t\t\tcase watch.Modified:\n663: \t\t\t\t\tfmt.Printf(\"MODIFIED\\t%s\\n\", interpreter.Name)\n664: \t\t\t\tcase watch.Deleted:\n665: \t\t\t\t\tfmt.Printf(\"DELETED\\t%s\\n\", interpreter.Name)\n666: \t\t\t\tcase watch.Error:\n667: \t\t\t\t\tfmt.Printf(\"ERROR\\t%v\\n\", event.Object)\n668: \t\t\t\t}\n669: \t\t\t}\n670: \t\t},\n671: \t}\n672: \n673: \treturn cmd\n674: }\n675: \n676: func completionBashCmd() *cobra.Command {\n677: \tcmd := &cobra.Command{\n678: \t\tUse:   \"bash\",\n679: \t\tShort: \"Generate bash completion script\",\n680: \t\tRun: func(cmd *cobra.Command, args []string) {\n681: \t\t\tcmd.Root().GenBashCompletion(os.Stdout)\n682: \t\t},\n683: \t}\n684: \n685: \treturn cmd\n686: }\n687: \n688: func completionZshCmd() *cobra.Command {\n689: \tcmd := &cobra.Command{\n690: \t\tUse:   \"zsh\",\n691: \t\tShort: \"Generate zsh completion script\",\n692: \t\tRun: func(cmd *cobra.Command, args []string) {\n693: \t\t\tcmd.Root().GenZshCompletion(os.Stdout)\n694: \t\t},\n695: \t}\n696: \n697: \treturn cmd\n698: }\n699: \n700: func completionFishCmd() *cobra.Command {\n701: \tcmd := &cobra.Command{\n702: \t\tUse:   \"fish\",\n703: \t\tShort: \"Generate fish completion script\",\n704: \t\tRun: func(cmd *cobra.Command, args []string) {\n705: \t\t\tcmd.Root().GenFishCompletion(os.Stdout, true)\n706: \t\t},\n707: \t}\n708: \n709: \treturn cmd\n710: }\n711: \n712: func completionPowerShellCmd() *cobra.Command {\n713: \tcmd := &cobra.Command{\n714: \t\tUse:   \"powershell\",\n715: \t\tShort: \"Generate PowerShell completion script\",\n716: \t\tRun: func(cmd *cobra.Command, args []string) {\n717: \t\t\tcmd.Root().GenPowerShellCompletionWithDesc(os.Stdout)\n718: \t\t},\n719: \t}\n720: \n721: \treturn cmd\n722: }\n\n(End of file - total 722 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\n\t\"github.com/spf13/cobra\"\n\truntimev1alpha1 \"