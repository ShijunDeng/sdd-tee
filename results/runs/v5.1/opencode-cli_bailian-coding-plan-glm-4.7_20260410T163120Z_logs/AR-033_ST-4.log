\\n14: }\\n15: \\n16: log_warn() {\\n17:     echo -e \\\"${YELLOW}[WARN]${NC} $1\\\"\\n18: }\\n19: \\n20: log_error() {\\n21:     echo -e \\\"${RED}[ERROR]${NC} $1\\\"\\n22: }\\n23: \\n24: log_success() {\\n25:     echo -e \\\"${GREEN}[SUCCESS]${NC} $1\\\"\\n26: }\\n27: \\n28: # Check if docker is available\\n29: if ! command -v docker &> /dev/null; then\\n30:     log_error \\\"Docker is not installed or not in PATH\\\"\\n31:     exit 1\\n32: fi\\n33: \\n34: # Check if image exists\\n35: if ! docker images agentcube:latest --format \\\"{{.Repository}}\\\" | grep -q agentcube; then\\n36:     log_error \\\"agentcube:latest image not found. Please build the image first.\\\"\\n37:     exit 1\\n38: fi\\n39: \\n40: log_info \\\"Validating runtime container...\\\"\\n41: \\n42: # Test 1: Container startup\\n43: log_info \\\"Test 1: Container startup...\\\"\\n44: CONTAINER_ID=$(docker run -d --name agentcube-runtime-test agentcube:latest sleep 30)\\n45: \\n46: # Wait a moment for container to start\\n47: sleep 2\\n48: \\n49: STATUS=$(docker inspect --format='{{.State.Status}}' $CONTAINER_ID)\\n50: i... (line truncated to 2000 chars)\n{\"type\":\"step_finish\",\"timestamp\":1775883769336,\"sessionID\":\"ses_285145990ffeGNJC0HW8x46cPZ\",\"part\":{\"id\":\"prt_d7aebd5cb00157dPt4JyMDzM5F\",\"reason\":\"tool-calls\",\"snapshot\":\"f33c5114db06c230ebdbad281b75532a26b6f114\",\"messageID\":\"msg_d7aebc1e20014fDLi0vWQaZmiB\",\"sessionID\":\"ses_285145990ffeGNJC0HW8x46cPZ\",\"type\":\"step-finish\",\"tokens\":{\"total\":20743,\"input\":5432,\"output\":208,\"reasoning\":0,\"cache\":{\"write\":0,\"read\":15103}},\"cost\":0}}\n{\"type\":\"step_start\",\"timestamp\":1775883772836,\"sessionID\":\"ses_285145990ffeGNJC0HW8x46cPZ\",\"part\":{\"id\":\"prt_d7aebe3a1001pA1GHD1nNwLoSi\",\"messageID\":\"msg_d7aebd615001b2KejcMXt1oZ5f\",\"sessionID\":\"ses_285145990ffeGNJC0HW8x46cPZ\",\"snapshot\":\"f33c5114db06c230ebdbad281b75532a26b6f114\",\"type\":\"step-start\"}}\n{\"type\":\"tool_use\",\"times