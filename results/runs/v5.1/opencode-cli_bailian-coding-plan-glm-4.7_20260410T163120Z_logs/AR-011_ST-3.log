4: \n205: \treq, err := http.NewRequestWithContext(ctx, http.MethodGet, endpoint, nil)\n206: \tif err != nil {\n207: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n208: \t}\n209: \n210: \tresp, err := m.httpClient.Do(req)\n211: \tif err != nil {\n212: \t\treturn nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusServiceUnavailable}\n213: \t}\n214: \tdefer resp.Body.Close()\n215: \n216: \tbody, err := io.ReadAll(resp.Body)\n217: \tif err != nil {\n218: \t\treturn nil, fmt.Errorf(\"failed to read response body: %w\", err)\n219: \t}\n220: \n221: \tif resp.StatusCode == http.StatusNotFound {\n222: \t\treturn nil, &SandboxNotFoundError{SessionID: sessionID}\n223: \t}\n224: \n225: \tif resp.StatusCode != http.StatusOK {\n226: \t\treturn nil, &WorkloadManagerError{\n227: \t\t\tMessage: string(body),\n228: \t\t\tCode:    resp.StatusCode,\n229: \t\t}\n230: \t}\n231: \n232: \tvar getSessionResp WorkloadManagerGetSessionResponse\n233: \tif err := json.Unmarshal(body, &getSessionResp); err != nil {\n234: \t\treturn nil, fmt.Errorf(\"failed to unmarshal get session response: %w\", err)\n235: \t}\n236: \n237: \tsandboxInfo := SandboxInfoFromWorkloadManager(&getSessionResp, sessionID)\n238: \n239: \tif err := m.storeClient.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n240: \t\tklog.Warningf(\"Failed to cache sandbox info: %v\", err)\n241: \t}\n242: \n243: \treturn sandboxInfo, nil\n244: }\n245: \n246: func (m *manager) isResourceActive(namespace string, name string, kind string) bool {\n247: \tif m.resourceCache == nil {\n248: \t\treturn true\n249: \t}\n250: \n251: \tif kind == types.AgentRuntimeKind {\n252: \t\tar, err := m.resourceCache.GetAgentRuntime(namespace, name)\n253: \t\tif err != nil || ar == nil {\n254: \t\t\treturn true\n255: \t\t}\n256: \n257: \t\tif !isResourceReady(ar.Status.Conditions) {\n258: \t\t\treturn false\n259: \t\t}\n260: \n261: \t\tif isResourceBeingDeleted(ar) {\n262: \t\t\treturn false\n263: \t\t}\n264: \n265: \t\treturn true\n266: \t} else if kind == types.CodeInterpreterKind {\n267: \t\tci, err := m.resourceCache.GetCodeInterpreter(namespace, name)\n268: \t\tif err != nil || ci == nil {\n269: \t\t\treturn true\n270: \t\t}\n271: \n272: \t\tif !ci.Status.Ready {\n273: \t\t\treturn false\n274: \t\t}\n275: \n276: \t\tif isResourceBeingDeleted(ci) {\n277: \t\t\treturn false\n278: \t\t}\n279: \n280: \t\treturn true\n281: \t}\n282: \n283: \treturn true\n284: }\n285: \n286: func isResourceReady(conditions []metav1.Condition) bool {\n287: \tif len(conditions) == 0 {\n288: \t\treturn false\n289: \t}\n290: \n291: \tfor _, cond := range conditions {\n292: \t\tif cond.Type == \"Ready\" && cond.Status == metav1.ConditionTrue {\n293: \t\t\treturn true\n294: \t\t}\n295: \t}\n296: \n297: \treturn false\n298: }\n299: \n300: func isResourceBeingDeleted(obj metav1.Object) bool {\n301: \treturn !obj.GetDeletionTimestamp().IsZero()\n302: }\n303: \n304: func conditionsChanged(oldConditions, newConditions []metav1.Condition) bool {\n305: \tif len(oldConditions) != len(newConditions) {\n306: \t\treturn true\n307: \t}\n308: \n309: \tfor i := range oldConditions {\n310: \t\tif oldConditions[i].Type != newConditions[i].Type ||\n311: \t\t\toldConditions[i].Status != newConditions[i].Status ||\n312: \t\t\toldConditions[i].Reason != newConditions[i].Reason {\n313: \t\t\treturn true\n314: \t\t}\n315: \t}\n316: \n317: \treturn false\n318: }\n319: \n320: func GetResourceStatus(conditions []metav1.Condition) string {\n321: \tif len(conditions) == 0 {\n322: \t\treturn \"Unknown\"\n323: \t}\n324: \n325: \tfor _, cond := range conditions {\n326: \t\tif cond.Type == \"Ready\" {\n327: \t\t\tif cond.Status == metav1.ConditionTrue {\n328: \t\t\t\treturn \"Ready\"\n329: \t\t\t}\n330: \t\t\treturn cond.Reason\n331: \t\t}\n332: \t}\n333: \n334: \treturn conditions[0].Type\n335: }\n\n(End of file - total 335 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"en