50: \n51: \tif err := s.initializeSessionManager(); err != nil {\n52: \t\treturn nil, fmt.Errorf(\"failed to initialize session manager: %w\", err)\n53: \t}\n54: \n55: \tif err := s.initializeJWTManager(clientset); err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to initialize JWT manager: %w\", err)\n57: \t}\n58: \n59: \ts.handler = NewHandler(s.sessionManager, s.jwtManager, NewReverseProxy(s.jwtManager))\n60: \n61: \ts.engine = gin.New()\n62: \n63: \ts.applyMiddleware()\n64: \n65: \ts.setupRoutes()\n66: \n67: \ts.httpServer = &http.Server{\n68: \t\tAddr:         \":\" + s.config.Port,\n69: \t\tHandler:      s.engine,\n70: \t\tReadTimeout:  time.Duration(s.config.ReadTimeout) * time.Second,\n71: \t\tWriteTimeout: time.Duration(s.config.WriteTimeout) * time.Second,\n72: \t\tIdleTimeout:  time.Duration(s.config.IdleTimeout) * time.Second,\n73: \t}\n74: \n75: \treturn s, nil\n76: }\n77: \n78: func (s *Server) initializeSessionManager() error {\n79: \tsessionManager, err := NewSessionManager(s.storeClient, s.config.WorkloadManagerURL)\n80: \tif err != nil {\n81: \t\treturn err\n82: \t}\n83: \n84: \ts.sessionManager = sessionManager\n85: \treturn nil\n86: }\n87: \n88: func (s *Server) initializeJWTManager(clientset kubernetes.Interface) error {\n89: \tif clientset == nil {\n90: \t\tklog.Warning(\"Kubernetes clientset not provided, JWT manager will not be fully functional\")\n91: \t\ts.jwtManager = &JWTManager{}\n92: \t\treturn nil\n93: \t}\n94: \n95: \tjwtManager, err := NewJWTManager(clientset, s.config.AgentcubeNamespace)\n96: \tif err != nil {\n97: \t\treturn err\n98: \t}\n99: \n100: \ts.jwtManager = jwtManager\n101: \treturn nil\n102: }\n103: \n104: func (s *Server) applyMiddleware() {\n105: \ts.engine.Use(recoveryMiddleware())\n106: \ts.engine.Use(loggingMiddleware())\n107: \ts.engine.Use(correlationIDMiddleware())\n108: \ts.engine.Use(concurrencyLimitMiddleware(s.limiter))\n109: \ts.engine.Use(metricsMiddleware(s.metrics))\n110: }\n111: \n112: func (s *Server) setupRoutes() {\n113: \ts.engine.GET(\"/health/live\", s.handler.handleHealthLive)\n114: \ts.engine.GET(\"/health/ready\", s.handler.handleHealthReady)\n115: \n116: \tv1 := s.engine.Group(\"/v1\")\n117: \t{\n118: \t\tnamespaces := v1.Group(\"/namespaces/:namespace\")\n119: \t\t{\n120: \t\t\tagentRuntimes := namespaces.Group(\"/agent-runtimes/:name\")\n121: \t\t\t{\n122: \t\t\t\tagentRuntimes.Any(\"/invocations/*path\", s.handler.handleAgentInvoke)\n123: \t\t\t}\n124: \n125: \t\t\tcodeInterpreters := namespaces.Group(\"/code-interpreters/:name\")\n126: \t\t\t{\n127: \t\t\t\tcodeInterpreters.Any(\"/invocations/*path\", s.handler.handleCodeInterpreterInvoke)\n128: \t\t\t}\n129: \t\t}\n130: \t}\n131: }\n132: \n133: func (s *Server) Start(ctx context.Context) error {\n134: \tlistener, err := net.Listen(\"tcp\", s.httpServer.Addr)\n135: \tif err != nil {\n136: \t\treturn fmt.Errorf(\"failed to listen on %s: %w\", s.httpServer.Addr, err)\n137: \t}\n138: \n139: \tklog.Infof(\"Starting HTTP server on %s\", s.httpServer.Addr)\n140: \tklog.Infof(\"TLS enabled: %v\", s.config.EnableTLS)\n141: \tklog.Infof(\"Max concurrent requests: %d\", s.config.MaxConcurrentRequests)\n142: \n143: \terrChan := make(chan error, 1)\n144: \n145: \tgo func() {\n146: \t\tif s.config.EnableTLS {\n147: \t\t\terrChan <- s.httpServer.ServeTLS(listener, s.config.TLSCert, s.config.TLSKey)\n148: \t\t} else {\n149: \t\t\terrChan <- s.httpServer.Serve(listener)\n150: \t\t}\n151: \t}()\n152: \n153: \tselect {\n154: \tcase err := <-errChan:\n155: \t\tif err != nil && err != http.ErrServerClosed {\n156: \t\t\treturn fmt.Errorf(\"server error: %w\", err)\n157: \t\t}\n158: \t\treturn err\n159: \tcase <-ctx.Done():\n160: \t\treturn s.Shutdown(ctx)\n161: \t}\n162: }\n163: \n164: func (s *Server) Shutdown(ctx context.Context) error {\n165: \tklog.Info(\"Shutting down HTTP server...\")\n166: \n167: \tshutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n168: \tdefer cancel()\n169: \n170: \tif err := s.httpServer.Shutdown(shutdownCtx); err != nil {\n171: \t\tklog.Warningf(\"Error during server shutdown: %v\", err)\n172: \t\treturn err\n173: \t}\n174: \n175: \tklog.Info(\"HTTP server stopped\")\n176: \n177: \treturn nil\n178: }\n179: \n180: func (s *Server) GetMetrics() *Metrics {\n181: \treturn s.metrics\n182: }\n183: \n184: func (s *Server) GetActiveConnections() int {\n185: \treturn s.limiter.semaphoreLen()\n186: }\n187: \n188: func (l *ConcurrencyLimiter) semaphoreLen() int {\n189: \treturn len(l.semaphore)\n190: }\n\n(End of file - total 190 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go","time":{"start":1775851623603,"end":1775851623622}}}}
