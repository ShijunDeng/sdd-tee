 ### Helper Templates (_helpers.tpl)\n576: \n577: ```yaml\n578: {{/*\n579: Expand the name of the chart.\n580: */}}\n581: {{- define \"agentcube.name\" -}}\n582: {{- default .Chart.Name .Values.nameOverride | trunc 63 | trimSuffix \"-\" }}\n583: {{- end }}\n584: \n585: {{/*\n586: Create a default fully qualified app name.\n587: */}}\n588: {{- define \"agentcube.fullname\" -}}\n589: {{- if .Values.fullnameOverride }}\n590: {{- .Values.fullnameOverride | trunc 63 | trimSuffix \"-\" }}\n591: {{- else }}\n592: {{- $name := default .Chart.Name .Values.nameOverride }}\n593: {{- if contains $name .Release.Name }}\n594: {{- .Release.Name | trunc 63 | trimSuffix \"-\" }}\n595: {{- else }}\n596: {{- printf \"%s-%s\" .Release.Name $name | trunc 63 | trimSuffix \"-\" }}\n597: {{- end }}\n598: {{- end }}\n599: {{- end }}\n600: \n601: {{/*\n602: Create chart name and version as used by the chart label.\n603: */}}\n604: {{- define \"agentcube.chart\" -}}\n605: {{- printf \"%s-%s\" .Chart.Name .Chart.Version | replace \"+\" \"_\" | trunc 63 | trimSuffix \"-\" }}\n606: {{- end }}\n607: \n608: {{/*\n609: Common labels\n610: */}}\n611: {{- define \"agentcube.labels\" -}}\n612: helm.sh/chart: {{ include \"agentcube.chart\" . }}\n613: {{ include \"agentcube.selectorLabels\" . }}\n614: {{- if .Chart.AppVersion }}\n615: app.kubernetes.io/version: {{ .Chart.AppVersion | quote }}\n616: {{- end }}\n617: app.kubernetes.io/managed-by: {{ .Release.Service }}\n618: {{- end }}\n619: \n620: {{/*\n621: Selector labels\n622: */}}\n623: {{- define \"agentcube.selectorLabels\" -}}\n624: app.kubernetes.io/name: {{ include \"agentcube.name\" . }}\n625: app.kubernetes.io/instance: {{ .Release.Name }}\n626: {{- end }}\n627: \n628: {{/*\n629: Create the name of the service account to use\n630: */}}\n631: {{- define \"agentcube.controllerManager.serviceAccountName\" -}}\n632: {{- if .Values.controllerManager.serviceAccount.create }}\n633: {{- default (include \"agentcube.fullname\" .) .Values.controllerManager.serviceAccount.name }}\n634: {{- else }}\n635: {{- default \"default\" .Values.controllerManager.serviceAccount.name }}\n636: {{- end }}\n637: {{- end }}\n638: \n639: {{/*\n640: Create the name of the service account to use\n641: */}}\n642: {{- define \"agentcube.workloadManager.serviceAccountName\" -}}\n643: {{- if .Values.workloadManager.serviceAccount.create }}\n644: {{- default (printf \"%s-workload-manager\" (include \"agentcube.fullname\" .)) .Values.workloadManager.serviceAccount.name }}\n645: {{- else }}\n646: {{- default \"default\" .Values.workloadManager.serviceAccount.name }}\n647: {{- end }}\n648: {{- end }}\n649: \n650: {{/*\n651: Create the name of the service account to use\n652: */}}\n653: {{- define \"agentcube.router.serviceAccountName\" -}}\n654: {{- if .Values.router.serviceAccount.create }}\n655: {{- default (printf \"%s-router\" (include \"agentcube.fullname\" .)) .Values.router.serviceAccount.name }}\n656: {{- else }}\n657: {{- default \"default\" .Values.router.serviceAccount.name }}\n658: {{- end }}\n659: {{- end }}\n660: \n661: {{/*\n662: Image registry helper\n663: */}}\n664: {{- define \"agentcube.imageRegistry\" -}}\n665: {{- .Values.global.imageRegistry | default \"\" -}}\n666: {{- end }}\n667: \n668: {{/*\n669: Build fully qualified image reference\n670: */}}\n671: {{- define \"agentcube.image\" -}}\n672: {{- $registry := include \"agentcube.imageRegistry\" . -}}\n673: {{- if $registry }}\n674: {{- printf \"%s/%s:%s\" $registry .repository .tag }}\n675: {{- else }}\n676: {{- printf \"%s:%s\" .repository .tag }}\n677: {{- end }}\n678: {{- end }}\n679: ```\n680: \n681: ## API Contracts\n682: \n683: ### Template: CRD Installation\n684: \n685: **File:** `templates/crds/agentruntime.yaml`\n686: \n687: ```yaml\n688: {{- if .Values.controllerManager.enabled }}\n689: apiVersion: apiextensions.k8s.io/v1\n690: kind: CustomResourceDefinition\n691: metadata:\n692:   name: agentruntimes.runtime.agentcube.volcano.sh\n693:   annotations:\n694:     helm.sh/hook: crd-install\n695:     helm.sh/hook-weight: \"-5\"\n696:     helm.sh/hook-delete-policy: before-hook-creation\n697:   labels:\n698:     {{- include \"agentcube.labels\" . | nindent 4 }}\n699: spec:\n700:   group: runtime.agentcube.volcano.sh\n701:   names:\n702:     kind: AgentRuntime\n703:     listKind: AgentRuntimeList\n704:     plural: agentruntimes\n705:     shortNames:\n706:     - art\n707:     singular: agentruntime\n708:   scope: Namespaced\n709:   versions:\n710:   - name: v1alpha1\n711:     served: true\n712:     storage: true\n713:     schema:\n714:       openAPIV3Schema:\n715:         type: object\n716:         properties:\n717:           apiVersion:\n718:             type: string\n719:           kind:\n720:             type: string\n721:           metadata:\n722:             type: object\n723:           spec:\n724:             type: object\n725:             properties:\n726:               maxSessionDuration:\n727:                 type: string\n728:                 default: \"8h\"\n729:               sessionTimeout:\n730:                 type: string\n731:                 default: \"15m\"\n732:               podTemplate:\n733:                 type: object\n734:                 properties:\n735:                   metadata:\n736:                     type: object\n737:                   spec:\n738:                     type: object\n739:               targetPort:\n740:                 type: array\n741:                 items:\n742:                   type: object\n743:                   properties:\n744:                     port:\n745:                       type: integer\n746:                       format: int32\n747:                     protocol:\n748:                       type: string\n749:                       enum: [\"HTTP\", \"HTTPS\"]\n750:                     pathPrefix:\n751:                       type: string\n752:                     name:\n753:                       type: string\n754:                 required: [\"port\", \"protocol\"]\n755:             required: [\"maxSessionDuration\", \"sessionTimeout\", \"podTemplate\", \"targetPort\"]\n756:           status:\n757:             type: object\n758:             properties:\n759:               conditions:\n760:                 type: array\n761:                 items:\n762:                   type: object\n763:                   properties:\n764:                     lastTransitionTime:\n765:                       format: date-time\n766:                       type: string\n767:                     message:\n768:                       type: string\n769:                     reason:\n770:                       type: string\n771:                     status:\n772:                       type: string\n773:                     type:\n774:                       type: string\n775:                     observedGeneration:\n776:                       format: int64\n777:                       type: integer\n778:               observedGeneration:\n779:                 format: int64\n780:                 type: integer\n781:     subresources:\n782:       status: {}\n783:     additionalPrinterColumns:\n784:     - name: Age\n785:       type: date\n786:       jsonPath: .metadata.creationTimestamp\n787: {{- end }}\n788: ```\n789: \n790: ### Template: Controller Manager Deployment\n791: \n792: **File:** `templates/controller-manager/deployment.yaml`\n793: \n794: ```yaml\n795: {{- if .Values.controllerManager.enabled }}\n796: apiVersion: apps/v1\n797: kind: Deployment\n798: metadata:\n799:   name: {{ include \"agentcube.fullname\" . }}\n800:   namespace: {{ include \"agentcube.namespace\" . }}\n801:   labels:\n802:     {{- include \"agentcube.labels\" . | nindent 4 }}\n803:     app.kubernetes.io/component: controller-manager\n804: spec:\n805:   replicas: {{ .Values.controllerManager.replicaCount }}\n806:   selector:\n807:     matchLabels:\n808:       {{- include \"agentcube.selectorLabels\" . | nindent 6 }}\n809:       app.kubernetes.io/component: controller-manager\n810:   template:\n811:     metadata:\n812:       annotations:\n813:         checksum/config: {{ include (print $.Template.BasePath \"/configmaps/config.yaml\") . | sha256sum }}\n814:         {{- with .Values.controllerManager.podAnnotations }}\n815:         {{- toYaml . | nindent 8 }}\n816:         {{- end }}\n817:       labels:\n818:         {{- include \"agentcube.selectorLabels\" . | nindent 8 }}\n819:         app.kubernetes.io/component: controller-manager\n820:         {{- with .Values.controllerManager.podLabels }}\n821:         {{- toYaml . | nindent 8 }}\n822:         {{- end }}\n823:     spec:\n824:       {{- with .Values.imagePullSecrets }}\n825:       imagePullSecrets:\n826:         {{- toYaml . | nindent 8 }}\n827:       {{- end }}\n828:       serviceAccountName: {{ include \"agentcube.controllerManager.serviceAccountName\" . }}\n829:       securityContext:\n830:         {{- toYaml .Values.controllerManager.securityContext | nindent 8 }}\n831:       {{- with .Values.controllerManager.nodeSelector }}\n832:       nodeSelector:\n833:         {{- toYaml . | nindent 8 }}\n834:       {{- end }}\n835:       {{- with .Values.controllerManager.affinity }}\n836:       affinity:\n837:         {{- toYaml . | nindent 8 }}\n838:       {{- end }}\n839:       {{- with .Values.controllerManager.tolerations }}\n840:       tolerations:\n841:         {{- toYaml . | nindent 8 }}\n842:       {{- end }}\n843:       {{- if .Values.priorityClassName }}\n844:       priorityClassName: {{ .Values.priorityClassName }}\n845:       {{- end }}\n846:       containers:\n847:       - name: controller-manager\n848:         securityContext:\n849:           {{- toYaml .Values.controllerManager.containerSecurityContext | nindent 10 }}\n850:         image: \"{{ include \"agentcube.image\" (dict \"registry\" .Values.global.imageRegistry \"repository\" .Values.controllerManager.image.repository \"tag\" .Values.controllerManager.image.tag) }}\"\n851:         imagePullPolicy: {{ .Values.controllerManager.image.pullPolicy }}\n852:         args:\n853:         - --leader-elect\n854:         - --health-probe-bind-address=:8080\n855:         - --metrics-bind-address=:9090\n856:         ports:\n857:         - name: http\n858:           containerPort: 8080\n859:           protocol: TCP\n860:         - name: metrics\n861:           containerPort: 9090\n862:           protocol: TCP\n863:         {{- with .Values.controllerManager.livenessProbe }}\n864:         livenessProbe:\n865:           {{- toYaml . | nindent 10 }}\n866:         {{- end }}\n867:         {{- with .Values.controllerManager.readinessProbe }}\n868:         readinessProbe:\n869:           {{- toYaml . | nindent 10 }}\n870:         {{- end }}\n871:         resources:\n872:           {{- toYaml .Values.controllerManager.resources | nindent 10 }}\n873:         {{- with .Values.controllerManager.env }}\n874:         env:\n875:           {{- toYaml . | nindent 10 }}\n876:         {{- end }}\n877:         {{- with .Values.controllerManager.envFrom }}\n878:         envFrom:\n879:           {{- toYaml . | nindent 10 }}\n880:         {{- end }}\n881:         {{- with .Values.controllerManager.extraVolumeMounts }}\n882:         volumeMounts:\n883:           {{- toYaml . | nindent 10 }}\n884:         {{- end }}\n885:       {{- with .Values.controllerManager.extraVolumes }}\n886:       volumes:\n887:         {{- toYaml . | nindent 6 }}\n888:       {{- end }}\n889: {{- end }}\n890: ```\n891: \n892: ### Template: Controller Manager Service\n893: \n894: **File:** `templates/controller-manager/service.yaml`\n895: \n896: ```yaml\n897: {{- if .Values.controllerManager.enabled }}\n898: apiVersion: v1\n899: kind: Service\n900: metadata:\n901:   name: {{ include \"agentcube.fullname\" . }}\n902:   namespace: {{ include \"agentcube.namespace\" . }}\n903:   labels:\n904:     {{- include \"agentcube.labels\" . | nindent 4 }}\n905:     app.kubernetes.io/component: controller-manager\n906:   {{- with .Values.controllerManager.service.annotations }}\n907:   annotations:\n908:     {{- toYaml . | nindent 4 }}\n909:   {{- end }}\n910: spec:\n911:   type: {{ .Values.controllerManager.service.type }}\n912:   ports:\n913:   - port: {{ .Values.controllerManager.service.port }}\n914:     targetPort: http\n915:     protocol: TCP\n916:     name: http\n917:   selector:\n918:     {{- include \"agentcube.selectorLabels\" . | nindent 4 }}\n919:     app.kubernetes.io/component: controller-manager\n920: {{- end }}\n921: ```\n922: \n923: ### Template: Controller Manager ServiceAccount\n924: \n925: **File:** `templates/controller-manager/serviceaccount.yaml`\n926: \n927: ```yaml\n928: {{- if and .Values.controllerManager.enabled .Values.controllerManager.serviceAccount.create }}\n929: apiVersion: v1\n930: kind: ServiceAccount\n931: metadata:\n932:   name: {{ include \"agentcube.controllerManager.serviceAccountName\" . }}\n933:   namespace: {{ include \"agentcube.namespace\" . }}\n934:   labels:\n935:     {{- include \"agentcube.labels\" . | nindent 4 }}\n936:     app.kubernetes.io/component: controller-manager\n937:   {{- with .Values.controllerManager.serviceAccount.annotations }}\n938:   annotations:\n939:     {{- toYaml . | nindent 4 }}\n940:   {{- end }}\n941: {{- end }}\n942: ```\n943: \n944: ### Template: Controller Manager RBAC\n945: \n946: **File:** `templates/controller-manager/rbac.yaml`\n947: \n948: ```yaml\n949: {{- if and .Values.controllerManager.enabled .Values.controllerManager.rbac.create }}\n950: apiVersion: rbac.authorization.k8s.io/v1\n951: kind: Role\n952: metadata:\n953:   name: {{ include \"agentcube.fullname\" . }}\n954:   namespace: {{ include \"agentcube.namespace\" . }}\n955:   labels:\n956:     {{- include \"agentcube.labels\" . | nindent 4 }}\n957:     app.kubernetes.io/component: controller-manager\n958: rules:\n959: {{- toYaml .Values.controllerManager.rbac.rules | nindent 0 }}\n960: ---\n961: apiVersion: rbac.authorization.k8s.io/v1\n962: kind: RoleBinding\n963: metadata:\n964:   name: {{ include \"agentcube.fullname\" . }}\n965:   namespace: {{ include \"agentcube.namespace\" . }}\n966:   labels:\n967:     {{- include \"agentcube.labels\" . | nindent 4 }}\n968:     app.kubernetes.io/component: controller-manager\n969: roleRef:\n970:   apiGroup: rbac.authorization.k8s.io\n971:   kind: Role\n972:   name: {{ include \"agentcube.fullname\" . }}\n973: subjects:\n974: - kind: ServiceAccount\n975:   name: {{ include \"agentcube.controllerManager.serviceAccountName\" . }}\n976:   namespace: {{ include \"agentcube.namespace\" . }}\n977: {{- end }}\n978: ```\n979: \n980: ### Template: Workload Manager Deployment\n981: \n982: **File:** `templates/workload-manager/deployment.yaml`\n983: \n984: ```yaml\n985: {{- if .Values.workloadManager.enabled }}\n986: apiVersion: apps/v1\n987: kind: Deployment\n988: metadata:\n989:   name: {{ printf \"%s-workload-manager\" (include \"agentcube.fullname\" .) }}\n990:   namespace: {{ include \"agentcube.namespace\" . }}\n991:   labels:\n992:     {{- include \"agentcube.labels\" . | nindent 4 }}\n993:     app.kubernetes.io/component: workload-manager\n994: spec:\n995:   replicas: {{ .Values.workloadManager.replicaCount }}\n996:   selector:\n997:     matchLabels:\n998:       {{- include \"agentcube.selectorLabels\" . | nindent 6 }}\n999:       app.kubernetes.io/component: workload-manager\n1000:   template:\n1001:     metadata:\n1002:       annotations:\n1003:         checksum/config: {{ include (print $.Template.BasePath \"/configmaps/config.yaml\") . | sha256sum }}\n1004:         {{- with .Values.workloadManager.podAnnotations }}\n1005:         {{- toYaml . | nindent 8 }}\n1006:         {{- end }}\n1007:       labels:\n1008:         {{- include \"agentcube.selectorLabels\" . | nindent 8 }}\n1009:         app.kubernetes.io/component: workload-manager\n1010:         {{- with .Values.workloadManager.podLabels }}\n1011:         {{- toYaml . | nindent 8 }}\n1012:         {{- end }}\n1013:     spec:\n1014:       {{- with .Values.imagePullSecrets }}\n1015:       imagePullSecrets:\n1016:         {{- toYaml . | nindent 8 }}\n1017:       {{- end }}\n1018:       serviceAccountName: {{ include \"agentcube.workloadManager.serviceAccountName\" . }}\n1019:       securityContext:\n1020:         {{- toYaml .Values.workloadManager.securityContext | nindent 8 }}\n1021:       {{- with .Values.workloadManager.nodeSelector }}\n1022:       nodeSelector:\n1023:         {{- toYaml . | nindent 8 }}\n1024:       {{- end }}\n1025:       {{- with .Values.workloadManager.affinity }}\n1026:       affinity:\n1027:         {{- toYaml . | nindent 8 }}\n1028:       {{- end }}\n1029:       {{- with .Values.workloadManager.tolerations }}\n1030:       tolerations:\n1031:         {{- toYaml . | nindent 8 }}\n1032:       {{- end }}\n1033:       {{- if .Values.priorityClassName }}\n1034:       priorityClassName: {{ .Values.priorityClassName }}\n1035:       {{- end }}\n1036:       containers:\n1037:       - name: workload-manager\n1038:         securityContext:\n1039:           {{- toYaml .Values.workloadManager.containerSecurityContext | nindent 10 }}\n1040:         image: \"{{ include \"agentcube.image\" (dict \"registry\" .Values.global.imageRegistry \"repository\" .Values.workloadManager.image.repository \"tag\" .Values.workloadManager.image.tag) }}\"\n1041:         imagePullPolicy: {{ .Values.workloadManager.image.pullPolicy }}\n1042:         args:\n1043:         - --leader-elect\n1044:         - --health-probe-bind-address=:8080\n1045:         - --metrics-bind-address=:9090\n1046:         ports:\n1047:         - name: http\n1048:           containerPort: 8080\n1049:           protocol: TCP\n1050:         - name: metrics\n1051:           containerPort: 9090\n1052:           protocol: TCP\n1053:         {{- with .Values.workloadManager.livenessProbe }}\n1054:         livenessProbe:\n1055:           {{- toYaml . | nindent 10 }}\n1056:         {{- end }}\n1057:         {{- with .Values.workloadManager.readinessProbe }}\n1058:         readinessProbe:\n1059:           {{- toYaml . | nindent 10 }}\n1060:         {{- end }}\n1061:         resources:\n1062:           {{- toYaml .Values.workloadManager.resources | nindent 10 }}\n1063:         {{- with .Values.workloadManager.env }}\n1064:         env:\n1065:           {{- toYaml . | nindent 10 }}\n1066:         {{- end }}\n1067:         {{- with .Values.workloadManager.envFrom }}\n1068:         envFrom:\n1069:           {{- toYaml . | nindent 10 }}\n1070:         {{- end }}\n1071:         {{- with .Values.workloadManager.extraVolumeMounts }}\n1072:         volumeMounts:\n1073:           {{- toYaml . | nindent 10 }}\n1074:         {{- end }}\n1075:       {{- with .Values.workloadManager.extraVolumes }}\n1076:       volumes:\n1077:         {{- toYaml . | nindent 6 }}\n1078:       {{- end }}\n1079: {{- end }}\n1080: ```\n1081: \n1082: ### Template: Router Deployment\n1083: \n1084: **File:** `templates/router/deployment.yaml`\n1085: \n1086: ```yaml\n1087: {{- if .Values.router.enabled }}\n1088: apiVersion: apps/v1\n1089: kind: Deployment\n1090: metadata:\n1091:   name: {{ printf \"%s-router\" (include \"agentcube.fullname\" .) }}\n1092:   namespace: {{ include \"agentcube.namespace\" . }}\n1093:   labels:\n1094:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1095:     app.kubernetes.io/component: router\n1096: spec:\n1097:   replicas: {{ .Values.router.replicaCount }}\n1098:   selector:\n1099:     matchLabels:\n1100:       {{- include \"agentcube.selectorLabels\" . | nindent 6 }}\n1101:       app.kubernetes.io/component: router\n1102:   template:\n1103:     metadata:\n1104:       annotations:\n1105:         checksum/config: {{ include (print $.Template.BasePath \"/configmaps/config.yaml\") . | sha256sum }}\n1106:         {{- with .Values.router.podAnnotations }}\n1107:         {{- toYaml . | nindent 8 }}\n1108:         {{- end }}\n1109:       labels:\n1110:         {{- include \"agentcube.selectorLabels\" . | nindent 8 }}\n1111:         app.kubernetes.io/component: router\n1112:         {{- with .Values.router.podLabels }}\n1113:         {{- toYaml . | nindent 8 }}\n1114:         {{- end }}\n1115:     spec:\n1116:       {{- with .Values.imagePullSecrets }}\n1117:       imagePullSecrets:\n1118:         {{- toYaml . | nindent 8 }}\n1119:       {{- end }}\n1120:       serviceAccountName: {{ include \"agentcube.router.serviceAccountName\" . }}\n1121:       securityContext:\n1122:         {{- toYaml .Values.router.securityContext | nindent 8 }}\n1123:       {{- with .Values.router.nodeSelector }}\n1124:       nodeSelector:\n1125:         {{- toYaml . | nindent 8 }}\n1126:       {{- end }}\n1127:       {{- with .Values.router.affinity }}\n1128:       affinity:\n1129:         {{- toYaml . | nindent 8 }}\n1130:       {{- end }}\n1131:       {{- with .Values.router.tolerations }}\n1132:       tolerations:\n1133:         {{- toYaml . | nindent 8 }}\n1134:       {{- end }}\n1135:       {{- if .Values.priorityClassName }}\n1136:       priorityClassName: {{ .Values.priorityClassName }}\n1137:       {{- end }}\n1138:       containers:\n1139:       - name: router\n1140:         securityContext:\n1141:           {{- toYaml .Values.router.containerSecurityContext | nindent 10 }}\n1142:         image: \"{{ include \"agentcube.image\" (dict \"registry\" .Values.global.imageRegistry \"repository\" .Values.router.image.repository \"tag\" .Values.router.image.tag) }}\"\n1143:         imagePullPolicy: {{ .Values.router.image.pullPolicy }}\n1144:         args:\n1145:         - --leader-elect\n1146:         - --health-probe-bind-address=:8080\n1147:         - --metrics-bind-address=:9090\n1148:         ports:\n1149:         - name: http\n1150:           containerPort: 8080\n1151:           protocol: TCP\n1152:         - name: metrics\n1153:           containerPort: 9090\n1154:           protocol: TCP\n1155:         {{- with .Values.router.livenessProbe }}\n1156:         livenessProbe:\n1157:           {{- toYaml . | nindent 10 }}\n1158:         {{- end }}\n1159:         {{- with .Values.router.readinessProbe }}\n1160:         readinessProbe:\n1161:           {{- toYaml . | nindent 10 }}\n1162:         {{- end }}\n1163:         resources:\n1164:           {{- toYaml .Values.router.resources | nindent 10 }}\n1165:         {{- with .Values.router.env }}\n1166:         env:\n1167:           {{- toYaml . | nindent 10 }}\n1168:         {{- end }}\n1169:         {{- with .Values.router.envFrom }}\n1170:         envFrom:\n1171:           {{- toYaml . | nindent 10 }}\n1172:         {{- end }}\n1173:         {{- with .Values.router.extraVolumeMounts }}\n1174:         volumeMounts:\n1175:           {{- toYaml . | nindent 10 }}\n1176:         {{- end }}\n1177:       {{- with .Values.router.extraVolumes }}\n1178:       volumes:\n1179:         {{- toYaml . | nindent 6 }}\n1180:       {{- end }}\n1181: {{- end }}\n1182: ```\n1183: \n1184: ### Template: ServiceMonitor\n1185: \n1186: **File:** `templates/monitoring/servicemonitor.yaml`\n1187: \n1188: ```yaml\n1189: {{- if and .Values.monitoring.enabled .Values.monitoring.serviceMonitor.enabled }}\n1190: apiVersion: monitoring.coreos.com/v1\n1191: kind: ServiceMonitor\n1192: metadata:\n1193:   name: {{ include \"agentcube.fullname\" . }}\n1194:   namespace: {{ include \"agentcube.namespace\" . }}\n1195:   labels:\n1196:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1197:     {{- with .Values.monitoring.serviceMonitor.labels }}\n1198:     {{- toYaml . | nindent 4 }}\n1199:     {{- end }}\n1200:   {{- with .Values.monitoring.serviceMonitor.annotations }}\n1201:   annotations:\n1202:     {{- toYaml . | nindent 4 }}\n1203:   {{- end }}\n1204: spec:\n1205:   selector:\n1206:     matchLabels:\n1207:       {{- include \"agentcube.selectorLabels\" . | nindent 6 }}\n1208:   namespaceSelector:\n1209:     matchNames:\n1210:       - {{ include \"agentcube.namespace\" . }}\n1211:   endpoints:\n1212:   - port: metrics\n1213:     interval: {{ .Values.monitoring.serviceMonitor.interval }}\n1214:     scrapeTimeout: {{ .Values.monitoring.serviceMonitor.scrapeTimeout }}\n1215:     path: /metrics\n1216:     {{- with .Values.monitoring.serviceMonitor.metricRelabelings }}\n1217:     metricRelabelings:\n1218:       {{- toYaml . | nindent 4 }}\n1219:     {{- end }}\n1220:     {{- with .Values.monitoring.serviceMonitor.relabelings }}\n1221:     relabelings:\n1222:       {{- toYaml . | nindent 4 }}\n1223:     {{- end }}\n1224: {{- end }}\n1225: ```\n1226: \n1227: ### Template: PodDisruptionBudget\n1228: \n1229: **File:** `templates/poddisruptionbudgets/controller-manager.yaml`\n1230: \n1231: ```yaml\n1232: {{- if and .Values.controllerManager.enabled .Values.controllerManager.podDisruptionBudget.enabled }}\n1233: apiVersion: policy/v1\n1234: kind: PodDisruptionBudget\n1235: metadata:\n1236:   name: {{ include \"agentcube.fullname\" . }}\n1237:   namespace: {{ include \"agentcube.namespace\" . }}\n1238:   labels:\n1239:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1240:     app.kubernetes.io/component: controller-manager\n1241: spec:\n1242:   minAvailable: {{ .Values.controllerManager.podDisruptionBudget.minAvailable }}\n1243:   selector:\n1244:     matchLabels:\n1245:       {{- include \"agentcube.selectorLabels\" . | nindent 6 }}\n1246:       app.kubernetes.io/component: controller-manager\n1247: {{- end }}\n1248: ```\n1249: \n1250: ### Template: Ingress\n1251: \n1252: **File:** `templates/ingress.yaml`\n1253: \n1254: ```yaml\n1255: {{- if .Values.ingress.enabled }}\n1256: apiVersion: networking.k8s.io/v1\n1257: kind: Ingress\n1258: metadata:\n1259:   name: {{ include \"agentcube.fullname\" . }}\n1260:   namespace: {{ include \"agentcube.namespace\" . }}\n1261:   labels:\n1262:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1263:   {{- with .Values.ingress.annotations }}\n1264:   annotations:\n1265:     {{- toYaml . | nindent 4 }}\n1266:   {{- end }}\n1267: spec:\n1268:   ingressClassName: {{ .Values.ingress.className }}\n1269:   {{- if .Values.ingress.tls }}\n1270:   tls:\n1271:     {{- range .Values.ingress.tls }}\n1272:     - hosts:\n1273:         {{- range .hosts }}\n1274:         - {{ . | quote }}\n1275:         {{- end }}\n1276:       secretName: {{ .secretName }}\n1277:     {{- end }}\n1278:   {{- end }}\n1279:   rules:\n1280:     {{- range .Values.ingress.hosts }}\n1281:     - host: {{ .host | quote }}\n1282:       http:\n1283:         paths:\n1284:           {{- range .paths }}\n1285:           - path: {{ .path }}\n1286:             pathType: {{ .pathType }}\n1287:             backend:\n1288:               service:\n1289:                 name: {{ .backend.service.name | default (printf \"%s-router\" (include \"agentcube.fullname\" $)) }}\n1290:                 port:\n1291:                   number: {{ .backend.service.port.number | default 8080 }}\n1292:           {{- end }}\n1293:     {{- end }}\n1294: {{- end }}\n1295: ```\n1296: \n1297: ### Template: NetworkPolicy\n1298: \n1299: **File:** `templates/networkpolicies/networkpolicy.yaml`\n1300: \n1301: ```yaml\n1302: {{- if .Values.networkPolicies.enabled }}\n1303: apiVersion: networking.k8s.io/v1\n1304: kind: NetworkPolicy\n1305: metadata:\n1306:   name: {{ include \"agentcube.fullname\" . }}\n1307:   namespace: {{ include \"agentcube.namespace\" . }}\n1308:   labels:\n1309:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1310: spec:\n1311:   podSelector: {}\n1312:   {{- if .Values.networkPolicies.defaultDeny }}\n1313:   policyTypes:\n1314:   - Ingress\n1315:   - Egress\n1316:   {{- end }}\n1317:   ingress:\n1318:   {{- range .Values.networkPolicies.rules.controllerManager.ingress }}\n1319:   - from:\n1320:     {{- range .from }}\n1321:     {{- toYaml . | nindent 6 }}\n1322:     {{- end }}\n1323:     ports:\n1324:     {{- range .ports }}\n1325:     - {{ toYaml . | nindent 8 }}\n1326:     {{- end }}\n1327:   {{- end }}\n1328:   egress:\n1329:   {{- range .Values.networkPolicies.rules.controllerManager.egress }}\n1330:   - to:\n1331:     {{- range .to }}\n1332:     {{- toYaml . | nindent 6 }}\n1333:     {{- end }}\n1334:     ports:\n1335:     {{- range .ports }}\n1336:     - {{ toYaml . | nindent 8 }}\n1337:     {{- end }}\n1338:   {{- end }}\n1339: {{- end }}\n1340: ```\n1341: \n1342: ### Template: ConfigMap\n1343: \n1344: **File:** `templates/configmaps/config.yaml`\n1345: \n1346: ```yaml\n1347: {{- if .Values.configMaps.agentcubeConfig.create }}\n1348: apiVersion: v1\n1349: kind: ConfigMap\n1350: metadata:\n1351:   name: {{ include \"agentcube.fullname\" . }}-config\n1352:   namespace: {{ include \"agentcube.namespace\" . }}\n1353:   labels:\n1354:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1355: data:\n1356:   {{- toYaml .Values.configMaps.agentcubeConfig.data | nindent 2 }}\n1357: {{- end }}\n1358: ```\n1359: \n1360: ### Template: Secret\n1361: \n1362: **File:** `templates/secrets/secret.yaml`\n1363: \n1364: ```yaml\n1365: {{- if .Values.secrets.create }}\n1366: apiVersion: v1\n1367: kind: Secret\n1368: metadata:\n1369:   name: {{ .Values.secrets.name | default (printf \"%s-secrets\" (include \"agentcube.fullname\" .)) }}\n1370:   namespace: {{ include \"agentcube.namespace\" . }}\n1371:   labels:\n1372:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1373: type: Opaque\n1374: data:\n1375:   {{- range $key, $value := .Values.secrets.data }}\n1376:   {{ $key }}: {{ $value | b64enc }}\n1377:   {{- end }}\n1378: {{- end }}\n1379: ```\n1380: \n1381: ### Template: NOTES.txt\n1382: \n1383: **File:** `templates/NOTES.txt`\n1384: \n1385: ```yaml\n1386: Thank you for installing {{ .Chart.Name }}!\n1387: \n1388: Your release is named {{ .Release.Name }}.\n1389: \n1390: To learn more about the release, try:\n1391: \n1392:   $ helm status {{ .Release.Name }}\n1393:   $ helm get all {{ .Release.Name }}\n1394: \n1395: {{- if .Values.ingress.enabled }}\n1396: To access the AgentCube Router:\n1397: \n1398:   {{- range .Values.ingress.hosts }}\n1399:   http{{ if $.Values.ingress.tls }}s{{ end }}://{{ .host }}\n1400:   {{- end }}\n1401: \n1402: {{- else if contains \"NodePort\" .Values.router.service.type }}\n1403: \n1404: Get the Router URL by running these commands:\n1405: \n1406:   export NODE_PORT=$(kubectl get --namespace {{ include \"agentcube.namespace\" . }} -o jsonpath=\"{.spec.ports[0].nodePort}\" services {{ printf \"%s-router\" (include \"agentcube.fullname\" .) }})\n1407:   export NODE_IP=$(kubectl get nodes --namespace {{ include \"agentcube.namespace\" . }} -o jsonpath=\"{.items[0].status.addresses[0].address}\")\n1408: \n1409:   echo http://$NODE_IP:$NODE_PORT\n1410: \n1411: {{- else if contains \"LoadBalancer\" .Values.router.service.type }}\n1412: \n1413: Get the Router URL by running these commands:\n1414: \n1415:   NOTE: It may take a few minutes for the LoadBalancer IP to be available.\n1416:         You can watch the status by running 'kubectl get svc --namespace {{ include \"agentcube.namespace\" . }} -w {{ printf \"%s-router\" (include \"agentcube.fullname\" .) }}'\n1417: \n1418:   export SERVICE_IP=$(kubectl get svc --namespace {{ include \"agentcube.namespace\" . }} {{ printf \"%s-router\" (include \"agentcube.fullname\" .) }} -o jsonpath='{.status.loadBalancer.ingress[0].ip}')\n1419: \n1420:   echo http://$SERVICE_IP:{{ .Values.router.service.port }}\n1421: \n1422: {{- else if contains \"ClusterIP\" .Values.router.service.type }}\n1423: \n1424: Get the Router URL by running these commands:\n1425: \n1426:   export POD_NAME=$(kubectl get pods --namespace {{ include \"agentcube.namespace\" . }} -l \"app.kubernetes.io/name={{ include \"agentcube.name\" . }},app.kubernetes.io/instance={{ .Release.Name }},app.kubernetes.io/component=router\" -o jsonpath=\"{.items[0].metadata.name}\")\n1427: \n1428:   kubectl port-forward --namespace {{ include \"agentcube.namespace\" . }} $POD_NAME 8080:8080\n1429: \n1430:   echo \"Visit http://127.0.0.1:8080 to use the AgentCube Router\"\n1431: \n1432: {{- end }}\n1433: \n1434: {{- if .Values.monitoring.enabled }}\n1435: \n1436: Monitoring is enabled. ServiceMonitor {{ include \"agentcube.fullname\" . }} has been created.\n1437: \n1438: To verify Prometheus is scraping metrics:\n1439: \n1440:   $ kubectl get servicemonitor {{ include \"agentcube.fullname\" . }} -n {{ include \"agentcube.namespace\" . }}\n1441: \n1442: {{- end }}\n1443: \n1444: For more information, visit:\n1445:   https://github.com/volcano-sh/agentcube\n1446: ```\n1447: \n1448: ## Error Handling\n1449: \n1450: ### Helm Template Validation\n1451: \n1452: **Linting:**\n1453: ```bash\n1454: helm lint ./agentcube\n1455: ```\n1456: \n1457: **Template rendering validation:**\n1458: ```bash\n1459: helm template agentcube ./agentcube --debug\n1460: ```\n1461: \n1462: **Values validation:**\n1463: ```bash\n1464: helm show values ./agentcube > values.yaml\n1465: # Validate values.yaml manually or with schema validation tool\n1466: ```\n1467: \n1468: ### Common Template Errors\n1469: \n1470: | Error Type | Cause | Resolution |\n1471: |------------|-------|------------|\n1472: | `variable not defined` | Reference to undefined template variable | Ensure variable is defined in _helpers.tpl or passed as parameter |\n1473: | `invalid type for index` | Trying to index non-map/slice type | Check value type before indexing |\n1474: | `nil pointer dereference` | Accessing field of nil value | Use `with` or `if` to check for nil |\n1475: | `unexpected end` | Unclosed template block | Check for matching `{{-` and `}}` |\n1476: | `redefinition` | Duplicate template definition | Ensure each template has unique name |\n1477: | `unknown identifier` | Reference to unknown Go template function | Use available Helm template functions only |\n1478: \n1479: ### Values Validation Errors\n1480: \n1481: | Error | Condition | Message |\n1482: |-------|-----------|---------|\n1483: | Invalid port | Port outside 1-65535 range | \"Port must be between 1 and 65535\" |\n1484: | Invalid replica count | Replica count < 0 | \"Replica count must be non-negative\" |\n1485: | Missing required value | Required field not set | \"Required value 'X' not set\" |\n1486: | Invalid image tag | Empty image tag with tag required | \"Image tag cannot be empty\" |\n1487: | Invalid resource request | CPU/memory request > limit | \"Resource request cannot exceed limit\" |\n1488: \n1489: ### Installation/Upgrade Errors\n1490: \n1491: ```bash\n1492: # Error: CRD already exists with different schema\n1493: Solution: helm upgrade --install --force or manually delete CRD\n1494: \n1495: # Error: Namespace does not exist\n1496: Solution: kubectl create namespace <namespace>\n1497: \n1498: # Error: Image pull failure\n1499: Solution: Check imagePullSecrets and image registry access\n1500: \n1501: # Error: Insufficient resources\n1502: Solution: Adjust resource requests/limits in values.yaml\n1503: \n1504: # Error: RBAC permissions denied\n1505: Solution: Ensure cluster-admin role or create necessary RBAC\n1506: ```\n1507: \n1508: ### Rollback Strategy\n1509: \n1510: ```bash\n1511: # View revision history\n1512: helm history <release-name>\n1513: \n1514: # Rollback to previous version\n1515: helm rollback <release-name> <revision>\n1516: \n1517: # Rollback with specific values\n1518: helm rollback <release-name> <revision> --reuse-values\n1519: \n1520: # Rollback and reconfigure\n1521: helm rollback <release-name> <revision> -f values.yaml\n1522: ```\n1523: \n1524: ### Error Reporting\n1525: \n1526: **Custom error messages in templates:**\n1527: ```yaml\n1528: {{- if not .Values.controllerManager.enabled }}\n1529: {{- fail \"Controller Manager must be enabled for AgentCube to function\" }}\n1530: {{- end }}\n1531: \n1532: {{- if lt .Values.router.replicaCount 1 }}\n1533: {{- fail \"Router replica count must be at least 1\" }}\n1534: {{- end }}\n1535: \n1536: {{- if not (hasKey .Values.controllerManager.image \"tag\") }}\n1537: {{- fail \"Controller Manager image tag is required\" }}\n1538: {{- end }}\n1539: ```\n1540: \n1541: ## Testing Strategy\n1542: \n1543: ### Unit Tests\n1544: \n1545: **Template Testing:**\n1546: \n1547: ```yaml\n1548: # tests/controller-manager_test.yaml\n1549: suite: controller manager deployment test\n1550: templates:\n1551:   - templates/controller-manager/deployment.yaml\n1552: tests:\n1553:   - it: should render deployment\n1554:     asserts:\n1555:       - isKind:\n1556:           of: Deployment\n1557:       - equal:\n1558:           path: metadata.name\n1559:           value: agentcube\n1560:   - it: should set correct replicas\n1561:     asserts:\n1562:       - equal:\n1563:           path: spec.replicas\n1564:           value: 2\n1565:   - it: should set correct image\n1566:     asserts:\n1567:       - equal:\n1568:           path: spec.template.spec.containers[0].image\n1569:           value: agentcube/controller-manager:v1.0.0\n1570:   - it: should set correct resource limits\n1571:     asserts:\n1572:       - equal:\n1573:           path: spec.template.spec.containers[0].resources.limits.cpu\n1574:           value: 500m\n1575:       - equal:\n1576:           path: spec.template.spec.containers[0].resources.limits.memory\n1577:           value: 512Mi\n1578:   - it: should set security context\n1579:     asserts:\n1580:       - equal:\n1581:           path: spec.template.spec.securityContext.runAsNonRoot\n1582:           value: true\n1583:   - it: should disable deployment when disabled\n1584:     set:\n1585:       controllerManager.enabled: false\n1586:     asserts:\n1587:       - hasDocuments:\n1588:           count: 0\n1589: ```\n1590: \n1591: **Values Testing:**\n1592: \n1593: ```yaml\n1594: # tests/values_test.yaml\n1595: suite: values validation\n1596: tests:\n1597:   - it: should require valid replica count\n1598:     set:\n1599:       controllerManager.replicaCount: -1\n1600:     asserts:\n1601:       - failedTemplate:\n1602:           errorMessage: \"Replica count must be non-negative\"\n1603:   - it: should require valid port\n1604:     set:\n1605:       controllerManager.service.port: 70000\n1606:     asserts:\n1607:       - failedTemplate:\n1608:           errorMessage: \"Port must be between 1 and 65535\"\n1609: ```\n1610: \n1611: **Helper Template Testing:**\n1612: \n1613: ```yaml\n1614: # tests/helpers_test.yaml\n1615: suite: helper templates\n1616: templates:\n1617:   - templates/_helpers.tpl\n1618: tests:\n1619:   - it: should generate correct full name\n1620:     asserts:\n1621:       - matchRegex:\n1622:           path: agentcube.fullname\n1623:           pattern: \"^agentcube-.*\"\n1624:   - it: should generate correct labels\n1625:     asserts:\n1626:       - contains:\n1627:           path: agentcube.labels\n1628:           content: app.kubernetes.io/name\n1629:       - contains:\n1630:           path: agentcube.labels\n1631:           content: helm.sh/chart\n1632: ```\n1633: \n1634: ### Integration Tests\n1635: \n1636: **Installation Test:**\n1637: \n1638: ```bash\n1639: #!/bin/bash\n1640: # test/integration/install_test.sh\n1641: \n1642: set -e\n1643: \n1644: echo \"Testing Helm Chart Installation...\"\n1645: \n1646: # Create namespace\n1647: kubectl create namespace agentcube-test --dry-run=client -o yaml | kubectl apply -f -\n1648: \n1649: # Install chart\n1650: helm install agentcube-test ./agentcube \\\n1651:   --namespace agentcube-test \\\n1652:   --values values-test.yaml \\\n1653:   --wait --timeout 5m\n1654: \n1655: # Verify deployments\n1656: kubectl rollout status deployment/agentcube-test -n agentcube-test\n1657: kubectl rollout status deployment/agentcube-test-workload-manager -n agentcube-test\n1658: kubectl rollout status deployment/agentcube-test-router -n agentcube-test\n1659: \n1660: # Verify services\n1661: kubectl get svc -n agentcube-test\n1662: kubectl get endpoints -n agentcube-test\n1663: \n1664: # Verify pods are running\n1665: kubectl get pods -n agentcube-test -l app.kubernetes.io/name=agentcube\n1666: \n1667: echo \"Installation test passed!\"\n1668: ```\n1669: \n1670: **Upgrade Test:**\n1671: \n1672: ```bash\n1673: #!/bin/bash\n1674: # test/integration/upgrade_test.sh\n1675: \n1676: set -e\n1677: \n1678: echo \"Testing Helm Chart Upgrade...\"\n1679: \n1680: # Initial installation\n1681: helm install agentcube-upgrade ./agentcube \\\n1682:   --namespace agentcube-upgrade \\\n1683:   --values values-test.yaml \\\n1684:   --set controllerManager.replicaCount=2\n1685: \n1686: # Upgrade with new values\n1687: helm upgrade agentcube-upgrade ./agentcube \\\n1688:   --namespace agentcube-upgrade \\\n1689:   --values values-test.yaml \\\n1690:   --set controllerManager.replicaCount=3 \\\n1691:   --reuse-values\n1692: \n1693: # Verify upgrade\n1694: kubectl rollout status deployment/agentcube-upgrade -n agentcube-upgrade\n1695: \n1696: # Check replica count\n1697: REPLICAS=$(kubectl get deployment agentcube-upgrade -n agentcube-upgrade -o jsonpath='{.spec.replicas}')\n1698: if [ \"$REPLICAS\" != \"3\" ]; then\n1699:   echo \"Upgrade test failed: expected 3 replicas, got $REPLICAS\"\n1700:   exit 1\n1701: fi\n1702: \n1703: echo \"Upgrade test passed!\"\n1704: ```\n1705: \n1706: **Rollback Test:**\n1707: \n1708: ```bash\n1709: #!/bin/bash\n1710: # test/integration/rollback_test.sh\n1711: \n1712: set -e\n1713: \n1714: echo \"Testing Helm Chart Rollback...\"\n1715: \n1716: # Install and upgrade\n1717: helm install agentcube-rollback ./agentcube \\\n1718:   --namespace agentcube-rollback \\\n1719:   --values values-test.yaml \\\n1720:   --set controllerManager.replicaCount=2\n1721: \n1722: helm upgrade agentcube-rollback ./agentcube \\\n1723:   --namespace agentcube-rollback \\\n1724:   --values values-test.yaml \\\n1725:   --set controllerManager.replicaCount=3 \\\n1726:   --reuse-values\n1727: \n1728: # Rollback\n1729: helm rollback agentcube-rollback 0 -n agentcube-rollback\n1730: \n1731: # Verify rollback\n1732: REPLICAS=$(kubectl get deployment agentcube-rollback -n agentcube-rollback -o jsonpath='{.spec.replicas}')\n1733: if [ \"$REPLICAS\" != \"2\" ]; then\n1734:   echo \"Rollback test failed: expected 2 replicas, got $REPLICAS\"\n1735:   exit 1\n1736: fi\n1737: \n1738: echo \"Rollback test passed!\"\n1739: ```\n1740: \n1741: ### E2E Tests\n1742: \n1743: **Functional Test:**\n1744: \n1745: ```bash\n1746: #!/bin/bash\n1747: # test/e2e/functional_test.sh\n1748: \n1749: set -e\n1750: \n1751: echo \"Running E2E Functional Tests...\"\n1752: \n1753: # Install chart\n1754: helm install agentcube-e2e ./agentcube \\\n1755:   --namespace agentcube-e2e \\\n1756:   --values values-test.yaml \\\n1757:   --wait\n1758: \n1759: # Test CRD creation\n1760: kubectl apply -f ../config/samples/runtime_v1alpha1_agentruntime.yaml\n1761: \n1762: # Wait for resource reconciliation\n1763: sleep 10\n1764: \n1765: # Verify AgentRuntime status\n1766: STATUS=$(kubectl get agentruntime example-runtime -n default -o jsonpath='{.status.conditions[0].status}')\n1767: if [ \"$STATUS\" != \"True\" ]; then\n1768:   echo \"Functional test failed: AgentRuntime not ready\"\n1769:   exit 1\n1770: fi\n1771: \n1772: # Test endpoint connectivity\n1773: SERVICE_IP=$(kubectl get svc agentcube-e2e-router -n agentcube-e2e -o jsonpath='{.spec.clusterIP}')\n1774: curl -f http://$SERVICE_IP:8080/healthz || exit 1\n1775: \n1776: echo \"E2E Functional test passed!\"\n1777: ```\n1778: \n1779: **Environment Test:**\n1780: \n1781: ```bash\n1782: #!/bin/bash\n1783: # test/e2e/environment_test.sh\n1784: \n\n(Output capped at 50 KB. Showing lines 1-1784. Use offset=1785 to continue.)\n</content>","metadata":{"preview":"# AR-030: Helm Chart 模板与 Values — Design\n\n## Overview\n\nHelm Chart for AgentCube platform provides a standardized, configurable, and reusable Kubernetes deployment solution. The chart encapsulates all necessary Kubernetes resources (CRDs, Deployments, Services, ConfigMaps, RBAC) and enables flexible configuration through Values files, simplifying deployment across multiple environments.\n\n**Module:** `manifests`  \n**Language:** YAML + Go Templates  \n**Source Root:** `manifests/charts/agentcube/`  \n**Size:** L\n\n## Architecture\n\n### Chart Structure\n\n```\nagentcube/\n├── Chart.yaml                          # Chart metadata\n├── values.yaml                         # Default configuration\n├── values-dev.yaml                     # Development environment overrides","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-030/design.md","time":{"start":1775881786495,"end":1775881786520}}}}
{"type":"tool_use","timestamp":1775881786526,"sessionID":"ses_285328e42ffe4dxRGltM8RDug6","part":{"id":"prt_d7acd8f92001K801Q6Ru6d167Z","messageID":"msg_d7acd82bc0016MNO6Cpi653I6q","sessionID":"ses_285328e42ffe4dxRGltM8RDug6","type":"tool","tool":"read","callID":"toolu_tool-717c3e992836436aa3a0c5f3e1ff1a6b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-030/CHANGE.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-030/CHANGE.md</path>\n<type>file</type>\n<content>\n1: # AR-030 — Helm Chart 模板与 Values\n2: \n3: ## Metadata\n4: - **AR**: AR-030\n5: - **Title**: Helm Chart 模板与 Values\n6: - **Module**: manifests\n7: - **Language**: YAML\n8: - **Size**: L\n9: - **Status**: Pending\n10: \n11: ## Description\n12: Create Helm chart templates and values files for deploying AgentCube components.\n13: \n14: ## Dependencies\n15: None\n16: \n17: ## Related Changes\n18: None\n\n(End of file - total 18 lines)\n</content>","metadata":{"preview":"# AR-030 — Helm Chart 模板与 Values\n\n## Metadata\n- **AR**: AR-030\n- **Title**: Helm Chart 模板与 Values\n- **Module**: manifests\n- **Language**: YAML\n- **Size**: L\n- **Status**: Pending\n\n## Description\nCreate Helm chart templates and values files for deploying AgentCube components.\n\n## Dependencies\nNone\n\n## Related Changes\nNone","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-030/CHANGE.md","time":{"start":1775881786492,"end":1775881786525}}}}
{"type":"tool_use","timestamp":1775881786529,"sessionID":"ses_285328e42ffe4dxRGltM8RDug6","part":{"id":"prt_d7acd9460001lVQmyG4HH7T64L","messageID":"msg_d7acd82bc0016MNO6Cpi653I6q","sessionID":"ses_285328e42ffe4dxRGltM8RDug6","type":"tool","tool":"read","callID":"toolu_tool-9af44aa13ad14fc49b11ab3f788bffcc","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-030/delta-spec.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-030/delta-spec.md</path>\n<type>file</type>\n<content>\n1: # AR-030 — Helm Chart 模板与 Values Delta Specification\n2: \n3: ## Purpose\n4: \n5: This delta specification provides comprehensive acceptance criteria for the Helm Chart templates and Values configuration for deploying the AgentCube platform components. It extends the base deployment specifications with detailed GIVEN/WHEN/THEN scenarios for all chart operations, configuration options, and lifecycle management.\n6: \n7: ## Requirements\n8: \n9: ### Requirement: Chart.yaml metadata validation\n10: \n11: The system SHALL provide a valid Helm Chart.yaml with proper metadata and version information.\n12: \n13: #### Scenario: Chart.yaml contains required metadata fields\n14: - **GIVEN** a Helm chart directory structure exists\n15: - **WHEN** the Chart.yaml file is present\n16: - **THEN** it SHALL contain fields: apiVersion, name, description, type, version, appVersion\n17: - **AND** apiVersion SHALL be set to v2\n18: - **AND** type SHALL be set to application\n19: - **AND** version SHALL follow semantic versioning (e.g., 1.0.0)\n20: \n21: #### Scenario: Chart keywords and maintainers are present\n22: - **GIVEN** a valid Chart.yaml file\n23: - **WHEN** inspecting the chart metadata\n24: - **THEN** keywords SHALL include relevant terms: agentcube, ai, code-interpreter, agent-runtime\n25: - **AND** maintainers SHALL be defined with name and email fields\n26: \n27: ### Requirement: Default values.yaml structure\n28: \n29: The system SHALL provide a comprehensive default values.yaml with all configurable parameters.\n30: \n31: #### Scenario: Global configuration section exists\n32: - **GIVEN** the default values.yaml file\n33: - **WHEN** reading the global configuration section\n34: - **THEN** it SHALL include: imageRegistry, imagePullSecrets, namespace, labels\n35: - **AND** imageRegistry SHALL default to empty string (allow Docker Hub)\n36: - **AND** imagePullSecrets SHALL default to empty list\n37: - **AND** namespace SHALL default to agentcube\n38: \n39: #### Scenario: Controller Manager configuration exists\n40: - **GIVEN** the default values.yaml file\n41: - **WHEN** reading the controllerManager section\n42: - **THEN** it SHALL include: enabled, replicaCount, image, service, resources, nodeSelector, tolerations, affinity\n43: - **AND** enabled SHALL default to true\n44: - **AND** replicaCount SHALL default to 2\n45: - **AND** image.repository SHALL default to agentcube/controller-manager\n46: - **AND** image.pullPolicy SHALL default to IfNotPresent\n47: \n48: #### Scenario: Workload Manager configuration exists\n49: - **GIVEN** the default values.yaml file\n50: - **WHEN** reading the workloadManager section\n51: - **THEN** it SHALL include: enabled, replicaCount, image, service, resources, nodeSelector, tolerations, affinity\n52: - **AND** enabled SHALL default to true\n53: - **AND** replicaCount SHALL default to 2\n54: - **AND** image.repository SHALL default to agentcube/workload-manager\n55: \n56: #### Scenario: Router configuration exists\n57: - **GIVEN** the default values.yaml file\n58: - **WHEN** reading the router section\n59: - **THEN** it SHALL include: enabled, replicaCount, image, service, resources, nodeSelector, tolerations, affinity\n60: - **AND** enabled SHALL default to true\n61: - **AND** replicaCount SHALL default to 3\n62: - **AND** image.repository SHALL default to agentcube/router\n63: \n64: #### Scenario: RBAC configuration exists\n65: - **GIVEN** the default values.yaml file\n66: - **WHEN** reading the rbac section\n67: - **THEN** it SHALL include: create field\n68: - **AND** create SHALL default to true\n69: \n70: #### Scenario: Monitoring configuration exists\n71: - **GIVEN** the default values.yaml file\n72: - **WHEN** reading the monitoring section\n73: - **THEN** it SHALL include: enabled and serviceMonitor fields\n74: - **AND** enabled SHALL default to false\n75: - **AND** serviceMonitor.enabled SHALL default to false\n76: - **AND** serviceMonitor.interval SHALL default to 30s\n77: - **AND** serviceMonitor.scrapeTimeout SHALL default to 10s\n78: \n79: #### Scenario: Security contexts are configured\n80: - **GIVEN** the default values.yaml file\n81: - **WHEN** reading the security context sections\n82: - **THEN** podSecurityContext SHALL include: runAsNonRoot, runAsUser, fsGroup\n83: - **AND** runAsNonRoot SHALL default to true\n84: - **AND** runAsUser SHALL default to 1000\n85: - **AND** containerSecurityContext SHALL include: allowPrivilegeEscalation, capabilities, readOnlyRootFilesystem\n86: - **AND** allowPrivilegeEscalation SHALL default to false\n87: \n88: ### Requirement: CRD template installation\n89: \n90: The system SHALL install Custom Resource Definitions as part of the Helm chart.\n91: \n92: #### Scenario: CRD templates exist in correct location\n93: - **GIVEN** the Helm chart templates directory\n94: - **WHEN** listing the templates/crds/ directory\n95: - **THEN** agentruntime.yaml SHALL be present\n96: - **AND** codeinterpreter.yaml SHALL be present\n97: - **AND** CRD templates SHALL use helm.sh/resource-policy: keep annotation\n98: \n99: #### Scenario: CRDs install with correct metadata\n100: - **GIVEN** a Helm install command is executed\n101: - **WHEN** the CRD templates are rendered and applied\n102: - **THEN** both CRDs SHALL use API group runtime.agentcube.volcano.sh\n103: - **AND** version SHALL be v1alpha1\n104: - **AND** scope SHALL be Namespaced\n105: - **AND** CRDs SHALL be installed before other resources\n106: \n107: #### Scenario: CRDs support version upgrades\n108: - **GIVEN** an existing AgentCube CRD installation\n109: - **WHEN** upgrading to a new chart version with CRD changes\n110: - **THEN** the CRDs SHALL be updated using helm.sh/hook: crd-install\n111: - **AND** existing CRD instances SHALL be preserved during upgrade\n112: - **AND** the upgrade SHALL not break existing resources\n113: \n114: ### Requirement: Controller Manager deployment template\n115: \n116: The system SHALL provide a Deployment template for the Controller Manager component.\n117: \n118: #### Scenario: Controller Manager Deployment renders correctly\n119: - **GIVEN** the controller-manager/deployment.yaml template\n120: - **WHEN** the chart is rendered with default values\n121: - **THEN** the Deployment SHALL be named agentcube-controller-manager\n122: - **AND** replicas SHALL match controllerManager.replicaCount from values\n123: - **AND** the container SHALL use the image specified in values\n124: - **AND** imagePullPolicy SHALL match the configured value\n125: \n126: #### Scenario: Controller Manager Service is created\n127: - **GIVEN** the controller-manager/service.yaml template\n128: - **WHEN** the chart is rendered\n129: - **THEN** the Service SHALL be named agentcube-controller-manager\n130: - **AND** the Service type SHALL match controllerManager.service.type\n131: - **AND** the Service port SHALL match controllerManager.service.port\n132: - **AND** the Service SHALL target port 8080\n133: \n134: #### Scenario: Controller Manager ServiceAccount is created\n135: - **GIVEN** the controller-manager/serviceaccount.yaml template\n136: - **WHEN** the chart is rendered with rbac.create=true\n137: - **THEN** a ServiceAccount SHALL be created for the Controller Manager\n138: - **AND** the ServiceAccount SHALL have appropriate labels\n139: - **AND** the Deployment SHALL use this ServiceAccount\n140: \n141: #### Scenario: Controller Manager disabled via values\n142: - **GIVEN** values.yaml with controllerManager.enabled=false\n143: - **WHEN** the chart is rendered\n144: - **THEN** Controller Manager Deployment SHALL NOT be created\n145: - **AND** Controller Manager Service SHALL NOT be created\n146: - **AND** Controller Manager ServiceAccount SHALL NOT be created\n147: \n148: ### Requirement: Workload Manager deployment template\n149: \n150: The system SHALL provide a Deployment template for the Workload Manager component.\n151: \n152: #### Scenario: Workload Manager Deployment renders correctly\n153: - **GIVEN** the workload-manager/deployment.yaml template\n154: - **WHEN** the chart is rendered with default values\n155: - **THEN** the Deployment SHALL be named workloadmanager\n156: - **AND** replicas SHALL match workloadManager.replicaCount from values\n157: - **AND** the container SHALL expose HTTP on port 8080\n158: - **AND** liveness and readiness probes SHALL be configured\n159: \n160: #### Scenario: Workload Manager health checks are configured\n161: - **GIVEN** the Workload Manager Deployment template\n162: - **WHEN** the chart is rendered\n163: - **THEN** livenessProbe SHALL be configured with HTTP GET /health\n164: - **AND** readinessProbe SHALL be configured with HTTP GET /health\n165: - **AND** both probes SHALL use port 8080\n166: - **AND** initialDelaySeconds SHALL be 10\n167: - **AND** periodSeconds SHALL be 10\n168: \n169: #### Scenario: Workload Manager Service is created\n170: - **GIVEN** the workload-manager/service.yaml template\n171: - **WHEN** the chart is rendered\n172: - **THEN** the Service SHALL be named workloadmanager\n173: - **AND** the Service type SHALL be ClusterIP\n174: - **AND** the Service SHALL expose port matching values configuration\n175: - **AND** the Service SHALL select pods with correct labels\n176: \n177: #### Scenario: Workload Manager disabled via values\n178: - **GIVEN** values.yaml with workloadManager.enabled=false\n179: - **WHEN** the chart is rendered\n180: - **THEN** Workload Manager Deployment SHALL NOT be created\n181: - **AND** Workload Manager Service SHALL NOT be created\n182: - **AND** Workload Manager ServiceAccount SHALL NOT be created\n183: \n184: ### Requirement: Router deployment template\n185: \n186: The system SHALL provide a Deployment template for the Router component.\n187: \n188: #### Scenario: Router Deployment renders correctly\n189: - **GIVEN** the router/deployment.yaml template\n190: - **WHEN** the chart is rendered with default values\n191: - **THEN** the Deployment SHALL be named agentcube-router\n192: - **AND** replicas SHALL match router.replicaCount from values\n193: - **AND** the container SHALL expose HTTP on port 8080\n194: - **AND** container args SHALL include --port=<targetPort> and --debug\n195: \n196: #### Scenario: Router configures Workload Manager URL\n197: - **GIVEN** the Router Deployment template\n198: - **WHEN** the chart is rendered in namespace N\n199: - **THEN** the Router pod SHALL have WORKLOAD_MANAGER_URL environment variable\n200: - **AND** WORKLOAD_MANAGER_URL SHALL be set to http://workloadmanager.N.svc.cluster.local:P\n201: - **AND** P SHALL be the Workload Manager service port from values\n202: \n203: #### Scenario: Router Service supports multiple types\n204: - **GIVEN** the router/service.yaml template\n205: - **WHEN** the chart is rendered with router.service.type=LoadBalancer\n206: - **THEN** the Service SHALL be of type LoadBalancer\n207: - **AND** the Service SHALL be named agentcube-router\n208: - **AND** externalTrafficPolicy SHALL be set to Local (if applicable)\n209: - **AND** annotations SHALL be preserved from values\n210: \n211: #### Scenario: Router disabled via values\n212: - **GIVEN** values.yaml with router.enabled=false\n213: - **WHEN** the chart is rendered\n214: - **THEN** Router Deployment SHALL NOT be created\n215: - **AND** Router Service SHALL NOT be created\n216: - **AND** Router ServiceAccount SHALL NOT be created\n217: \n218: ### Requirement: RBAC resources creation\n219: \n220: The system SHALL create appropriate RBAC resources for all components when enabled.\n221: \n222: #### Scenario: Workload Manager ClusterRole is created\n223: - **GIVEN** rbac.create=true in values\n224: - **WHEN** the chart is rendered\n225: - **THEN** a ServiceAccount named workloadmanager SHALL be created\n226: - **AND** a ClusterRole named workloadmanager SHALL be created\n227: - **AND** a ClusterRoleBinding named workloadmanager SHALL be created\n228: - **AND** the Binding SHALL tie the ServiceAccount to the ClusterRole\n229: \n230: #### Scenario: Workload Manager ClusterRole has required permissions\n231: - **GIVEN** the Workload Manager ClusterRole template\n232: - **WHEN** the chart is rendered\n233: - **THEN** rules SHALL include permissions for agent-sandbox resources\n234: - **AND** rules SHALL include permissions for AgentCube runtime CRDs\n235: - **AND** rules SHALL include permissions for core workloads (pods, deployments)\n236: - **AND** rules SHALL include permissions for auth (tokenreviews)\n237: - **AND** rules SHALL include permissions for secrets\n238: \n239: #### Scenario: Router RBAC is optional\n240: - **GIVEN** values.yaml with router.rbac.create=true\n241: - **WHEN** the chart is rendered\n242: - **THEN** Router ServiceAccount SHALL be created\n243: - **AND** Router Role SHALL be created in the release namespace\n244: - **AND** Router RoleBinding SHALL be created\n245: - **AND** the Role SHALL allow verbs on secrets in that namespace\n246: \n247: #### Scenario: RBAC disabled via values\n248: - **GIVEN** values.yaml with rbac.create=false\n249: - **WHEN** the chart is rendered\n250: - **THEN** no RBAC resources SHALL be created\n251: - **AND** Deployments SHALL use default ServiceAccount\n252: \n253: ### Requirement: Resource limits and requests\n254: \n255: The system SHALL support configurable resource limits and requests for all components.\n256: \n257: #### Scenario: Default resources are applied\n258: - **GIVEN** the default values.yaml with resource specifications\n259: - **WHEN** the chart is rendered\n260: - **THEN** each component Deployment SHALL have resource requests\n261: - **AND** requests.cpu SHALL be 100m by default\n262: - **AND** requests.memory SHALL be 128Mi by default\n263: - **AND** limits.cpu SHALL be 500m by default\n264: - **AND** limits.memory SHALL be 512Mi by default\n265: \n266: #### Scenario: Custom resources override defaults\n267: - **GIVEN** custom values.yaml with custom resource specifications\n268: - **WHEN** the chart is rendered with custom values\n269: - **THEN** resource requests SHALL match the custom values\n270: - **AND** resource limits SHALL match the custom values\n271: - **AND** default values SHALL be overridden\n272: \n273: #### Scenario: Resources can be disabled\n274: - **GIVEN** values.yaml with empty resource sections\n275: - **WHEN** the chart is rendered\n276: - **THEN** containers SHALL NOT have resource requests\n277: - **AND** containers SHALL NOT have resource limits\n278: \n279: ### Requirement: Node selectors and affinity\n280: \n281: The system SHALL support node selectors and affinity rules for pod scheduling.\n282: \n283: #### Scenario: Node selectors are applied\n284: - **GIVEN** values.yaml with nodeSelector configuration\n285: - **WHEN** the chart is rendered\n286: - **THEN** each component Deployment SHALL have the specified nodeSelector\n287: - **AND** pods SHALL only schedule on matching nodes\n288: \n289: #### Scenario: Tolerations are applied\n290: - **GIVEN** values.yaml with tolerations configuration\n291: - **WHEN** the chart is rendered\n292: - **THEN** each component Deployment SHALL have the specified tolerations\n293: - **AND** pods SHALL be able to schedule on tainted nodes\n294: \n295: #### Scenario: Affinity rules are applied\n296: - **GIVEN** values.yaml with affinity configuration\n297: - **WHEN** the chart is rendered\n298: - **THEN** each component Deployment SHALL have the specified affinity rules\n299: - **AND** podAntiAffinity rules SHALL be respected during scheduling\n300: \n301: ### Requirement: High availability configuration\n302: \n303: The system SHALL support high availability through replica count and anti-affinity configuration.\n304: \n305: #### Scenario: Multiple replicas are scheduled\n306: - **GIVEN** values.yaml with controllerManager.replicaCount=3\n307: - **WHEN** the chart is rendered\n308: - **THEN** the Controller Manager Deployment SHALL have 3 replicas\n309: - **AND** 3 pods SHALL be scheduled (subject to resource availability)\n310: \n311: #### Scenario: Pod anti-affinity prevents single node failure\n312: - **GIVEN** values.yaml with podAntiAffinity configuration\n313: - **WHEN** the chart is rendered\n314: - **THEN** pods SHALL have anti-affinity rules configured\n315: - **AND** pods SHALL prefer to run on different nodes\n316: - **AND** pod disruption budget SHALL prevent single node failures\n317: \n318: ### Requirement: Monitoring integration\n319: \n320: The system SHALL support optional Prometheus monitoring through ServiceMonitor resources.\n321: \n322: #### Scenario: ServiceMonitor is not created by default\n323: - **GIVEN** values.yaml with monitoring.enabled=false (default)\n324: - **WHEN** the chart is rendered\n325: - **THEN** no ServiceMonitor resources SHALL be created\n326: \n327: #### Scenario: ServiceMonitor is created when enabled\n328: - **GIVEN** values.yaml with monitoring.enabled=true and serviceMonitor.enabled=true\n329: - **WHEN** the chart is rendered\n330: - **THEN** ServiceMonitor resources SHALL be created for each enabled component\n331: - **AND** ServiceMonitor interval SHALL match values configuration\n332: - **AND** ServiceMonitor scrapeTimeout SHALL match values configuration\n333: - **AND** ServiceMonitor SHALL select pods with appropriate labels\n334: \n335: #### Scenario: ServiceMonitor labels are configurable\n336: - **GIVEN** values.yaml with custom serviceMonitor labels\n337: - **WHEN** the chart is rendered\n338: - **THEN** ServiceMonitor SHALL have the specified labels\n339: - **AND** Prometheus SHALL discover the ServiceMonitor based on labels\n340: \n341: ### Requirement: Image pull secrets and registry configuration\n342: \n343: The system SHALL support configuring image registry and pull secrets.\n344: \n345: #### Scenario: Global image registry is applied\n346: - **GIVEN** values.yaml with global.imageRegistry=registry.example.com\n347: - **WHEN** the chart is rendered\n348: - **THEN** all component images SHALL use the registry.example.com prefix\n349: - **AND** image references SHALL be formatted as registry.example.com/component:tag\n350: \n351: #### Scenario: Image pull secrets are configured\n352: - **GIVEN** values.yaml with global.imagePullSecrets=[my-secret]\n353: - **WHEN** the chart is rendered\n354: - **THEN** all component ServiceAccounts SHALL have imagePullSecrets\n355: - **AND** the secret my-secret SHALL be referenced\n356: - **AND** multiple secrets SHALL be supported\n357: \n358: #### Scenario: Component-specific image tags override global\n359: - **GIVEN** values.yaml with global image configuration and component-specific tags\n360: - **WHEN** the chart is rendered\n361: - **THEN** component-specific image tags SHALL take precedence over global settings\n362: - **AND** each component SHALL use its configured tag\n363: \n364: ### Requirement: Development environment configuration\n365: \n366: The system SHALL provide a values-dev.yaml file for development deployments.\n367: \n368: #### Scenario: Dev values use minimal resources\n369: - **GIVEN** the values-dev.yaml file\n370: - **WHEN** the chart is rendered with -f values-dev.yaml\n371: - **THEN** component replicaCounts SHALL be 1\n372: - **AND** resource requests SHALL be minimal (e.g., 50m cpu, 64Mi memory)\n373: - **AND** resource limits SHALL be conservative\n374: \n375: #### Scenario: Dev values disable monitoring\n376: - **GIVEN** the values-dev.yaml file\n377: - **WHEN** the chart is rendered with -f values-dev.yaml\n378: - **THEN** monitoring SHALL be disabled\n379: - **AND** no ServiceMonitor resources SHALL be created\n380: \n381: #### Scenario: Dev values allow insecure configurations\n382: - **GIVEN** the values-dev.yaml file\n383: - **WHEN** the chart is rendered with -f values-dev.yaml\n384: - **THEN** security contexts MAY be relaxed for development\n385: - **AND** debug flags MAY be enabled\n386: \n387: ### Requirement: Production environment configuration\n388: \n389: The system SHALL provide a values-prod.yaml file for production deployments.\n390: \n391: #### Scenario: Prod values use high availability configuration\n392: - **GIVEN** the values-prod.yaml file\n393: - **WHEN** the chart is rendered with -f values-prod.yaml\n394: - **THEN** Controller Manager replicaCount SHALL be 2 or more\n395: - **AND** Workload Manager replicaCount SHALL be 2 or more\n396: - **AND** Router replicaCount SHALL be 3 or more\n397: \n398: #### Scenario: Prod values enable monitoring\n399: - **GIVEN** the values-prod.yaml file\n400: - **WHEN** the chart is rendered with -f values-prod.yaml\n401: - **THEN** monitoring SHALL be enabled\n402: - **AND** ServiceMonitor SHALL be created\n403: \n404: #### Scenario: Prod values configure pod anti-affinity\n405: - **GIVEN** the values-prod.yaml file\n406: - **WHEN** the chart is rendered with -f values-prod.yaml\n407: - **THEN** podAntiAffinity rules SHALL be configured\n408: - **AND** pods SHALL prefer different nodes\n409: - **AND** PodDisruptionBudget SHALL be configured\n410: \n411: #### Scenario: Prod values use production resources\n412: - **GIVEN** the values-prod.yaml file\n413: - **WHEN** the chart is rendered with -f values-prod.yaml\n414: - **THEN** resource requests SHALL be appropriate for production load\n415: - **AND** resource limits SHALL be configured to prevent resource exhaustion\n416: \n417: ### Requirement: Helm chart installation workflow\n418: \n419: The system SHALL support standard Helm installation, upgrade, and rollback workflows.\n420: \n421: #### Scenario: Fresh install with default values\n422: - **GIVEN** a Kubernetes cluster and Helm 3\n423: - **WHEN** running `helm install agentcube ./agentcube --namespace agentcube --create-namespace`\n424: - **THEN** all CRDs SHALL be installed\n425: - **AND** all enabled components SHALL be deployed\n426: - **AND** all Services SHALL be created\n427: - **AND** all RBAC resources SHALL be created\n428: - **AND** pods SHALL become ready within reasonable time\n429: \n430: #### Scenario: Install with custom values file\n431: - **GIVEN** a custom values file custom-values.yaml\n432: - **WHEN** running `helm install agentcube ./agentcube -f custom-values.yaml`\n433: - **THEN** the installation SHALL use the custom values\n434: - **AND** all customizations SHALL be applied\n435: - **AND** default values SHALL be overridden where specified\n436: \n437: #### Scenario: Install with inline values\n438: - **GIVEN** the Helm chart\n439: - **WHEN** running `helm install agentcube ./agentcube --set controllerManager.replicaCount=5`\n440: - **THEN** the Controller Manager SHALL use 5 replicas\n441: - **AND** other components SHALL use default values\n442: \n443: #### Scenario: Upgrade preserves existing configuration\n444: - **GIVEN** an existing Helm installation\n445: - **WHEN** running `helm upgrade agentcube ./agentcube`\n446: - **THEN** existing resources SHALL be updated in-place\n447: - **AND** persistent data SHALL be preserved\n448: - **AND** pods SHALL be restarted gracefully\n449: \n450: #### Scenario: Rollback restores previous version\n451: - **GIVEN** a Helm installation that has been upgraded\n452: - **WHEN** running `helm rollback agentcube`\n453: - **THEN** the chart SHALL be restored to the previous version\n454: - **AND** all resources SHALL be reverted to previous state\n455: - **AND** the rollback SHALL not cause downtime\n456: \n457: #### Scenario: Uninstall removes all resources\n458: - **GIVEN** an existing Helm installation\n459: - **WHEN** running `helm uninstall agentcube`\n460: - **THEN** all Deployments SHALL be deleted\n461: - **AND** all Services SHALL be deleted\n462: - **AND** all RBAC resources SHALL be deleted\n463: - **AND** CRDs SHALL be kept (due to resource-policy: keep annotation)\n464: \n465: ### Requirement: Chart documentation\n466: \n467: The system SHALL provide comprehensive documentation for the Helm chart.\n468: \n469: #### Scenario: README.md contains installation instructions\n470: - **GIVEN** the Helm chart README.md file\n471: - **WHEN** reading the documentation\n472: - **THEN** it SHALL contain installation instructions\n473: - **AND** it SHALL describe all configuration options\n474: - **AND** it SHALL provide example values files\n475: - **AND** it SHALL include troubleshooting guidance\n476: \n477: #### Scenario: values.yaml has inline comments\n478: - **GIVEN** the default values.yaml file\n479: - **WHEN** inspecting the values\n480: - **THEN** each configuration section SHALL have descriptive comments\n481: - **AND** important parameters SHALL be documented\n482: - **AND** default values SHALL be explained\n483: \n484: #### Scenario: NOTES.txt provides post-install information\n485: - **GIVEN** the Helm chart templates/NOTES.txt file\n486: - **WHEN** an installation completes\n487: - **THEN** useful information SHALL be displayed\n488: - **AND** the information SHALL include: how to access services, how to check status, next steps\n489: \n490: ### Requirement: Template validation and linting\n491: \n492: The system SHALL provide valid templates that pass Helm linting.\n493: \n494: #### Scenario: Chart passes helm lint\n495: - **GIVEN** the Helm chart directory\n496: - **WHEN** running `helm lint ./agentcube`\n497: - **THEN** the linting SHALL pass without errors\n498: - **AND** no warnings SHALL be raised\n499: \n500: #### Scenario: Chart passes helm template render\n501: - **GIVEN** the Helm chart directory\n502: - **WHEN** running `helm template test ./agentcube`\n503: - **THEN** the template SHALL render successfully\n504: - **AND** valid YAML SHALL be produced\n505: - **AND** no rendering errors SHALL occur\n506: \n507: #### Scenario: Chart syntax is valid\n508: - **GIVEN** the Helm chart templates\n509: - **WHEN** validating Go template syntax\n510: - **THEN** all templates SHALL have valid syntax\n511: - **AND** all variables SHALL be properly referenced\n512: - **AND** all conditionals SHALL be properly formatted\n513: \n514: ---\n515: \n516: ## Backward Compatibility\n517: \n518: This delta specification introduces new Helm Chart functionality without breaking changes to existing deployment methods. The Helm chart is an additional deployment option that can coexist with existing manual YAML deployment approaches.\n519: \n520: ## Dependencies\n521: \n522: This delta specification depends on:\n523: - Kubernetes 1.20+ (as specified in base requirements)\n524: - Helm 3.0+ for chart installation and management\n525: - Base deployment specifications: `deployment/spec.md`\n526: - Existing CRD definitions: `config/crd/bases/`\n527: - Base component configurations from `deployment/spec.md`\n528: \n529: ## Breaking Changes\n530: \n531: None. This delta specification defines a new Helm Chart deployment mechanism that provides an alternative to existing deployment methods without introducing breaking changes to existing functionality or APIs.\n532: \n533: ## Security Considerations\n534: \n535: 1. **RBAC Permissions**: The chart creates RBAC resources with minimal required permissions following the principle of least privilege\n536: 2. **Secrets Management**: The chart supports pulling images from private registries using image pull secrets without storing secrets in values files\n537: 3. **Security Contexts**: The chart applies non-root user, read-only filesystem, and dropped capabilities by default\n538: 4. **Network Policies**: While not explicitly required in this spec, the chart should support network policy configuration for pod-to-pod communication\n539: 5. **Image Security**: The chart supports image pull policy configuration and private registry authentication\n540: \n541: ## Testing Strategy\n542: \n543: ### Template Tests\n544: - Verify all templates render correctly with default values\n545: - Verify all templates render correctly with custom values\n546: - Verify templates fail gracefully with invalid values\n547: - Verify CRD templates install and upgrade correctly\n548: \n549: ### Installation Tests\n550: - Test fresh installation with default values\n551: - Test installation with custom values files\n552: - Test installation with inline value overrides\n553: - Verify all resources are created correctly\n554: - Verify pods become ready and services are accessible\n555: \n556: ### Upgrade Tests\n557: - Test upgrade from one chart version to another\n558: - Verify existing resources are updated in-place\n559: - Verify data persistence during upgrades\n560: - Verify no downtime during upgrades\n561: \n562: ### Rollback Tests\n563: - Test rollback to previous chart version\n564: - Verify resources are restored to previous state\n565: - Verify no data loss during rollback\n566: \n567: ### Multi-Environment Tests\n568: - Test deployment with values-dev.yaml\n569: - Test deployment with values-prod.yaml\n570: - Verify environment-specific configurations are applied\n571: \n572: ### Integration Tests\n573: - Test interaction between components (Router → Workload Manager)\n574: - Verify service discovery works correctly\n575: - Test RBAC permissions are correct\n576: - Verify CRDs can be created and managed\n577: \n578: ### Validation Tests\n579: - Run `helm lint` to verify chart syntax\n580: - Run `helm template` to verify rendering\n581: - Verify Chart.yaml follows Helm best practices\n582: - Verify values.yaml is properly structured and documented\n\n(End of file - total 582 lines)\n</content>","metadata":{"preview":"# AR-030 — Helm Chart 模板与 Values Delta Specification\n\n## Purpose\n\nThis delta specification provides comprehensive acceptance criteria for the Helm Chart templates and Values configuration for deploying the AgentCube platform components. It extends the base deployment specifications with detailed GIVEN/WHEN/THEN scenarios for all chart operations, configuration options, and lifecycle management.\n\n## Requirements\n\n### Requirement: Chart.yaml metadata validation\n\nThe system SHALL provide a valid Helm Chart.yaml with proper metadata and version information.\n\n#### Scenario: Chart.yaml contains required metadata fields\n- **GIVEN** a Helm chart directory structure exists\n- **WHEN** the Chart.yaml file is present\n- **THEN** it SHALL contain fields: apiVersion, name, description, type, version, appVersion\n- **AND** apiVersion SHALL be set to v2\n- **AND** type SHALL be set to application\n- **AND** version SHALL follow semantic versioning (e.g., 1.0.0)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-030/delta-spec.md","time":{"start":1775881786497,"end":1775881786526}}}}
