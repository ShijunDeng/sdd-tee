Server                │\n40: │                                                          │\n41: │  ┌──────────────────────────────────────────────────┐  │\n42: │  │         runtime.agentcube.volcano.sh/v1alpha1    │  │\n43: │  │  ┌────────────────────────────────────────────┐  │  │\n44: │  │  │  agentruntimes.runtime.agentcube.volcano.sh │  │  │\n45: │  │  └────────────────────────────────────────────┘  │  │\n46: │  │  ┌────────────────────────────────────────────┐  │  │\n47: │  │  │  codeinterpreters.runtime.agentcube.volcano.sh││  │\n48: │  │  └────────────────────────────────────────────┘  │  │\n49: │  └──────────────────────────────────────────────────┘  │\n50: └─────────────────────────────────────────────────────────┘\n51:                           │\n52:                           │ k8s client-go\n53:                           ▼\n54: ┌─────────────────────────────────────────────────────────┐\n55: │                 client-go (Generated)                   │\n56: │  ┌──────────────────────────────────────────────────┐  │\n57: │  │  clientset/versioned/typed/runtime/v1alpha1/     │  │\n58: │  │    • AgentRuntimeInterface                       │  │\n59: │  │    • CodeInterpreterInterface                    │  │\n60: │  │    • REST CRUD + Watch                           │  │\n61: │  └──────────────────────────────────────────────────┘  │\n62: │  ┌──────────────────────────────────────────────────┐  │\n63: │  │  informers/externalversions/runtime/v1alpha1/    │  │\n64: │  │    • AgentRuntimeInformer                        │  │\n65: │  │    • CodeInterpreterInformer                     │  │\n66: │  └──────────────────────────────────────────────────┘  │\n67: │  ┌──────────────────────────────────────────────────┐  │\n68: │  │  listers/runtime/v1alpha1/                      │  │\n69: │  │    • AgentRuntimeLister                          │  │\n70: │  │    • CodeInterpreterLister                       │  │\n71: │  └──────────────────────────────────────────────────┘  │\n72: └─────────────────────────────────────────────────────────┘\n73: ```\n74: \n75: ## Data Structures\n76: \n77: ### AgentRuntime\n78: \n79: **File**: `pkg/apis/runtime/v1alpha1/agentruntime_types.go`\n80: \n81: ```go\n82: // AgentRuntimeSpec defines the desired state of AgentRuntime\n83: type AgentRuntimeSpec struct {\n84:     // MaxSessionDuration is the maximum duration for any session\n85:     // +kubebuilder:default=\"8h\"\n86:     MaxSessionDuration string `json:\"maxSessionDuration\"`\n87:     \n88:     // SessionTimeout is the idle timeout before a session is terminated\n89:     // +kubebuilder:default=\"15m\"\n90:     SessionTimeout string `json:\"sessionTimeout\"`\n91:     \n92:     // TargetPort specifies the HTTP/HTTPS ports to expose\n93:     // +kubebuilder:validation:MinItems=1\n94:     TargetPort []TargetPort `json:\"targetPort\"`\n95:     \n96:     // PodTemplate defines the pod template for agent sandbox pods\n97:     PodTemplate PodTemplateSpec `json:\"podTemplate\"`\n98: }\n99: \n100: // AgentRuntimeStatus defines the observed state of AgentRuntime\n101: type AgentRuntimeStatus struct {\n102:     // Conditions represent the latest available observations\n103:     Conditions []metav1.Condition `json:\"conditions,omitempty\"`\n104:     \n105:     // ObservedGeneration is the most recent generation observed\n106:     ObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n107: }\n108: \n109: // TargetPort defines a single HTTP/HTTPS port target\n110: type TargetPort struct {\n111:     // Port is the port number\n112:     // +kubebuilder:validation:Minimum=1\n113:     // +kubebuilder:validation:Maximum=65535\n114:     Port int32 `json:\"port\"`\n115:     \n116:     // Protocol must be \"HTTP\" or \"HTTPS\"\n117:     // +kubebuilder:validation:Enum=HTTP;HTTPS\n118:     Protocol string `json:\"protocol\"`\n119:     \n120:     // Name is an optional name for the port\n121:     Name string `json:\"name,omitempty\"`\n122:     \n123:     // PathPrefix is the URL path prefix for this port\n124:     PathPrefix string `json:\"pathPrefix,omitempty\"`\n125: }\n126: \n127: // PodTemplateSpec defines the pod template specification\n128: type PodTemplateSpec struct {\n129:     // Metadata for the pod\n130:     Metadata metav1.ObjectMeta `json:\"metadata,omitempty\"`\n131:     \n132:     // Spec for the pod\n133:     Spec PodSpec `json:\"spec,omitempty\"`\n134: }\n135: \n136: // AgentRuntime is the Schema for the agentruntimes API\n137: // +kubebuilder:object:root=true\n138: // +kubebuilder:subresource:status\n139: // +kubebuilder:resource:shortName=art\n140: // +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n141: type AgentRuntime struct {\n142:     metav1.TypeMeta   `json:\",inline\"`\n143:     metav1.ObjectMeta `json:\"metadata,omitempty\"`\n144:     \n145:     Spec   AgentRuntimeSpec   `json:\"spec,omitempty\"`\n146:     Status AgentRuntimeStatus `json:\"status,omitempty\"`\n147: }\n148: \n149: // AgentRuntimeList contains a list of AgentRuntime\n150: // +kubebuilder:object:root=true\n151: type AgentRuntimeList struct {\n152:     metav1.TypeMeta `json:\",inline\"`\n153:     metav1.ListMeta `json:\"metadata,omitempty\"`\n154:     \n155:     Items []AgentRuntime `json:\"items\"`\n156: }\n157: ```\n158: \n159: ### CodeInterpreter\n160: \n161: **File**: `pkg/apis/runtime/v1alpha1/codeinterpreter_types.go`\n162: \n163: ```go\n164: // CodeInterpreterSpec defines the desired state of CodeInterpreter\n165: type CodeInterpreterSpec struct {\n166:     // AuthMode specifies the authentication mode\n167:     // +kubebuilder:default=\"picod\"\n168:     // +kubebuilder:validation:Enum=picod;none\n169:     AuthMode string `json:\"authMode\"`\n170:     \n171:     // MaxSessionDuration is the maximum duration for any session\n172:     // +kubebuilder:default=\"8h\"\n173:     MaxSessionDuration string `json:\"maxSessionDuration\"`\n174:     \n175:     // SessionTimeout is the idle timeout before a session is terminated\n176:     // +kubebuilder:default=\"15m\"\n177:     SessionTimeout string `json:\"sessionTimeout\"`\n178:     \n179:     // Ports specifies the HTTP/HTTPS ports to expose\n180:     // +kubebuilder:validation:MinItems=1\n181:     Ports []TargetPort `json:\"ports\"`\n182:     \n183:     // Template defines the pod template for code interpreter pods\n184:     Template InterpreterTemplateSpec `json:\"template\"`\n185:     \n186:     // WarmPoolSize is the size of the warm pool\n187:     // +kubebuilder:validation:Minimum=0\n188:     WarmPoolSize int32 `json:\"warmPoolSize,omitempty\"`\n189: }\n190: \n191: // CodeInterpreterStatus defines the observed state of CodeInterpreter\n192: type CodeInterpreterStatus struct {\n193:     // Conditions represent the latest available observations\n194:     Conditions []metav1.Condition `json:\"conditions,omitempty\"`\n195:     \n196:     // Ready indicates the code interpreter is ready\n197:     Ready bool `json:\"ready,omitempty\"`\n198:     \n199:     // ObservedGeneration is the most recent generation observed\n200:     ObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n201: }\n202: \n203: // InterpreterTemplateSpec defines the interpreter pod template\n204: type InterpreterTemplateSpec struct {\n205:     // Metadata for the pod\n206:     Metadata metav1.ObjectMeta `json:\"metadata,omitempty\"`\n207:     \n208:     // Spec for the pod\n209:     Spec PodSpec `json:\"spec,omitempty\"`\n210: }\n211: \n212: // PodSpec defines the pod specification (subset of core v1.PodSpec)\n213: type PodSpec struct {\n214:     // Containers in the pod\n215:     Containers []Container `json:\"containers,omitempty\"`\n216:     \n217:     // Init containers\n218:     InitContainers []Container `json:\"initContainers,omitempty\"`\n219:     \n220:     // Volumes in the pod\n221:     Volumes []Volume `json:\"volumes,omitempty\"`\n222:     \n223:     // Restart policy\n224:     RestartPolicy string `json:\"restartPolicy,omitempty\"`\n225:     \n226:     // Service account name\n227:     ServiceAccountName string `json:\"serviceAccountName,omitempty\"`\n228:     \n229:     // Runtime class name\n230:     RuntimeClassName string `json:\"runtimeClassName,omitempty\"`\n231:     \n232:     // Node selector\n233:     NodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n234:     \n235:     // Affinity rules\n236:     Affinity *Affinity `json:\"affinity,omitempty\"`\n237:     \n238:     // Tolerations\n239:     Tolerations []Toleration `json:\"tolerations,omitempty\"`\n240:     \n241:     // Resource requirements\n242:     Resources *ResourceRequirements `json:\"resources,omitempty\"`\n243: }\n244: \n245: // Container defines a container in the pod\n246: type Container struct {\n247:     Name            string            `json:\"name\"`\n248:     Image           string            `json:\"image\"`\n249:     Command         []string          `json:\"command,omitempty\"`\n250:     Args            []string          `json:\"args,omitempty\"`\n251:     WorkingDir      string            `json:\"workingDir,omitempty\"`\n252:     Ports           []ContainerPort   `json:\"ports,omitempty\"`\n253:     Env             []EnvVar          `json:\"env,omitempty\"`\n254:     Resources       *ResourceRequirements `json:\"resources,omitempty\"`\n255:     VolumeMounts    []VolumeMount     `json:\"volumeMounts,omitempty\"`\n256:     LivenessProbe   *Probe            `json:\"livenessProbe,omitempty\"`\n257:     ReadinessProbe  *Probe            `json:\"readinessProbe,omitempty\"`\n258:     SecurityContext *SecurityContext   `json:\"securityContext,omitempty\"`\n259: }\n260: \n261: // CodeInterpreter is the Schema for the codeinterpreters API\n262: // +kubebuilder:object:root=true\n263: // +kubebuilder:subresource:status\n264: // +kubebuilder:resource:shortName=ci\n265: // +kubebuilder:printcolumn:name=\"Ready\",type=\"boolean\",JSONPath=\".status.ready\"\n266: // +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n267: type CodeInterpreter struct {\n268:     metav1.TypeMeta   `json:\",inline\"`\n269:     metav1.ObjectMeta `json:\"metadata,omitempty\"`\n270:     \n271:     Spec   CodeInterpreterSpec   `json:\"spec,omitempty\"`\n272:     Status CodeInterpreterStatus `json:\"status,omitempty\"`\n273: }\n274: \n275: // CodeInterpreterList contains a list of CodeInterpreter\n276: // +kubebuilder:object:root=true\n277: type CodeInterpreterList struct {\n278:     metav1.TypeMeta `json:\",inline\"`\n279:     metav1.ListMeta `json:\"metadata,omitempty\"`\n280:     \n281:     Items []CodeInterpreter `json:\"items\"`\n282: }\n283: ```\n284: \n285: ### Helper Types\n286: \n287: **File**: `pkg/apis/runtime/v1alpha1/types.go`\n288: \n289: ```go\n290: // ContainerPort defines a container port\n291: type ContainerPort struct {\n292:     Name          string `json:\"name,omitempty\"`\n293:     ContainerPort int32  `json:\"containerPort\"`\n294:     Protocol      string `json:\"protocol,omitempty\"`\n295:     HostPort      int32  `json:\"hostPort,omitempty\"`\n296: }\n297: \n298: // EnvVar defines an environment variable\n299: type EnvVar struct {\n300:     Name  string      `json:\"name\"`\n301:     Value string      `json:\"value,omitempty\"`\n302:     ValueFrom *EnvVarSource `json:\"valueFrom,omitempty\"`\n303: }\n304: \n305: // EnvVarSource defines a source for environment variable\n306: type EnvVarSource struct {\n307:     FieldRef *ObjectFieldSelector `json:\"fieldRef,omitempty\"`\n308: }\n309: \n310: // ObjectFieldSelector selects a field from an object\n311: type ObjectFieldSelector struct {\n312:     FieldPath string `json:\"fieldPath\"`\n313: }\n314: \n315: // ResourceRequirements describes compute resource requirements\n316: type ResourceRequirements struct {\n317:     Limits   ResourceList `json:\"limits,omitempty\"`\n318:     Requests ResourceList `json:\"requests,omitempty\"`\n319: }\n320: \n321: // ResourceList is a set of resource names and quantities\n322: type ResourceList map[string]string\n323: \n324: // Volume defines a volume\n325: type Volume struct {\n326:     Name   string      `json:\"name\"`\n327:     Secret *SecretVolumeSource `json:\"secret,omitempty\"`\n328:     ConfigMap *ConfigMapVolumeSource `json:\"configMap,omitempty\"`\n329:     EmptyDir *EmptyDirVolumeSource `json:\"emptyDir,omitempty\"`\n330: }\n331: \n332: // SecretVolumeSource adapts a Secret into a volume\n333: type SecretVolumeSource struct {\n334:     SecretName string `json:\"secretName\"`\n335: }\n336: \n337: // ConfigMapVolumeSource adapts a ConfigMap into a volume\n338: type ConfigMapVolumeSource struct {\n339:     LocalObjectReference `json:\",inline\"`\n340: }\n341: \n342: // EmptyDirVolumeSource represents an empty directory for a pod\n343: type EmptyDirVolumeSource struct {\n344:     Medium string `json:\"medium,omitempty\"`\n345: }\n346: \n347: // VolumeMount defines a volume mount\n348: type VolumeMount struct {\n349:     Name      string `json:\"name\"`\n350:     MountPath string `json:\"mountPath\"`\n351:     ReadOnly  bool   `json:\"readOnly,omitempty\"`\n352: }\n353: \n354: // Probe defines a health check\n355: type Probe struct {\n356:     ProbeHandler `json:\",inline\"`\n357:     InitialDelaySeconds int32 `json:\"initialDelaySeconds,omitempty\"`\n358:     TimeoutSeconds      int32 `json:\"timeoutSeconds,omitempty\"`\n359:     PeriodSeconds       int32 `json:\"periodSeconds,omitempty\"`\n360:     SuccessThreshold    int32 `json:\"successThreshold,omitempty\"`\n361:     FailureThreshold    int32 `json:\"failureThreshold,omitempty\"`\n362: }\n363: \n364: // ProbeHandler defines a handler for a probe\n365: type ProbeHandler struct {\n366:     HTTPGet *HTTPGetAction `json:\"httpGet,omitempty\"`\n367:     Exec    *ExecAction    `json:\"exec,omitempty\"`\n368:     TCPSocket *TCPSocketAction `json:\"tcpSocket,omitempty\"`\n369: }\n370: \n371: // HTTPGetAction defines an HTTP GET request\n372: type HTTPGetAction struct {\n373:     Path string `json:\"path,omitempty\"`\n374:     Port intstr.IntOrString `json:\"port\"`\n375:     Scheme string `json:\"scheme,omitempty\"`\n376: }\n377: \n378: // ExecAction defines a command to execute\n379: type ExecAction struct {\n380:     Command []string `json:\"command\"`\n381: }\n382: \n383: // TCPSocketAction defines a TCP socket check\n384: type TCPSocketAction struct {\n385:     Port intstr.IntOrString `json:\"port\"`\n386: }\n387: \n388: // SecurityContext defines security settings\n389: type SecurityContext struct {\n390:     RunAsUser            *int64  `json:\"runAsUser,omitempty\"`\n391:     RunAsGroup           *int64  `json:\"runAsGroup,omitempty\"`\n392:     RunAsNonRoot         *bool   `json:\"runAsNonRoot,omitempty\"`\n393:     ReadOnlyRootFilesystem *bool `json:\"readOnlyRootFilesystem,omitempty\"`\n394:     AllowPrivilegeEscalation *bool `json:\"allowPrivilegeEscalation,omitempty\"`\n395:     Capabilities *Capabilities `json:\"capabilities,omitempty\"`\n396: }\n397: \n398: // Capabilities adds and removes POSIX capabilities\n399: type Capabilities struct {\n400:     Add  []string `json:\"add,omitempty\"`\n401:     Drop []string `json:\"drop,omitempty\"`\n402: }\n403: \n404: // Affinity defines pod affinity/anti-affinity rules\n405: type Affinity struct {\n406:     NodeAffinity    *NodeAffinity    `json:\"nodeAffinity,omitempty\"`\n407:     PodAffinity     *PodAffinity     `json:\"podAffinity,omitempty\"`\n408:     PodAntiAffinity *PodAntiAffinity `json:\"podAntiAffinity,omitempty\"`\n409: }\n410: \n411: // NodeAffinity defines node affinity rules\n412: type NodeAffinity struct {\n413:     RequiredDuringSchedulingIgnoredDuringExecution *NodeSelector `json:\"requiredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n414: }\n415: \n416: // NodeSelector defines node selection requirements\n417: type NodeSelector struct {\n418:     NodeSelectorTerms []NodeSelectorTerm `json:\"nodeSelectorTerms\"`\n419: }\n420: \n421: // NodeSelectorTerm defines node selector term\n422: type NodeSelectorTerm struct {\n423:     MatchExpressions []NodeSelectorRequirement `json:\"matchExpressions,omitempty\"`\n424: }\n425: \n426: // NodeSelectorRequirement defines node selector requirement\n427: type NodeSelectorRequirement struct {\n428:     Key      string   `json:\"key\"`\n429:     Operator string   `json:\"operator\"`\n430:     Values   []string `json:\"values,omitempty\"`\n431: }\n432: \n433: // PodAffinity defines pod affinity rules\n434: type PodAffinity struct {\n435:     PreferredDuringSchedulingIgnoredDuringExecution []WeightedPodAffinityTerm `json:\"preferredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n436: }\n437: \n438: // WeightedPodAffinityTerm defines weighted pod affinity term\n439: type WeightedPodAffinityTerm struct {\n440:     Weight int32             `json:\"weight\"`\n441:     PodAffinityTerm PodAffinityTerm `json:\"podAffinityTerm\"`\n442: }\n443: \n444: // PodAffinityTerm defines pod affinity term\n445: type PodAffinityTerm struct {\n446:     LabelSelector *metav1.LabelSelector `json:\"labelSelector,omitempty\"`\n447:     TopologyKey   string `json:\"topologyKey\"`\n448: }\n449: \n450: // PodAntiAffinity defines pod anti-affinity rules\n451: type PodAntiAffinity struct {\n452:     PreferredDuringSchedulingIgnoredDuringExecution []WeightedPodAffinityTerm `json:\"preferredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n453: }\n454: \n455: // Toleration defines a pod toleration\n456: type Toleration struct {\n457:     Key               string `json:\"key,omitempty\"`\n458:     Operator          string `json:\"operator,omitempty\"`\n459:     Value             string `json:\"value,omitempty\"`\n460:     Effect            string `json:\"effect,omitempty\"`\n461:     TolerationSeconds *int64 `json:\"tolerationSeconds,omitempty\"`\n462: }\n463: \n464: // LocalObjectReference is a reference to an object in the same namespace\n465: type LocalObjectReference struct {\n466:     Name string `json:\"name,omitempty\"`\n467: }\n468: ```\n469: \n470: ### Scheme Registration\n471: \n472: **File**: `pkg/apis/runtime/v1alpha1/groupversion_info.go`\n473: \n474: ```go\n475: // +groupName=runtime.agentcube.volcano.sh\n476: package v1alpha1\n477: \n478: import (\n479:     \"k8s.io/apimachinery/pkg/runtime/schema\"\n480:     \"sigs.k8s.io/controller-runtime/pkg/scheme\"\n481: )\n482: \n483: var (\n484:     // GroupVersion is group version used to register these objects\n485:     GroupVersion = schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"}\n486: \n487:     // SchemeBuilder is used to add go types to the GroupVersionKind scheme\n488:     SchemeBuilder = &scheme.Builder{GroupVersion: GroupVersion}\n489: \n490:     // AddToScheme adds the types in this group-version to the given scheme.\n491:     AddToScheme = SchemeBuilder.AddToScheme\n492: )\n493: \n494: func Resource(resource string) schema.GroupResource {\n495:     return GroupVersion.WithResource(resource).GroupResource()\n496: }\n497: ```\n498: \n499: **File**: `pkg/apis/runtime/v1alpha1/register.go`\n500: \n501: ```go\n502: package v1alpha1\n503: \n504: import (\n505:     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n506:     \"k8s.io/apimachinery/pkg/runtime\"\n507:     \"k8s.io/apimachinery/pkg/runtime/schema\"\n508: )\n509: \n510: // SchemeGroupVersion is group version used to register these objects\n511: var SchemeGroupVersion = schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"}\n512: \n513: // Kind takes an unqualified kind and returns a Group qualified GroupKind\n514: func Kind(kind string) schema.GroupKind {\n515:     return SchemeGroupVersion.WithKind(kind).GroupKind()\n516: }\n517: \n518: // Resource takes an unqualified resource and returns a Group qualified GroupResource\n519: func Resource(resource string) schema.GroupResource {\n520:     return SchemeGroupVersion.WithResource(resource).G