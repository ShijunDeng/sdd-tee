{"type":"tool_use","timestamp":1775862726073,"sessionID":"ses_28655b065ffe5esZZd4x0I346i","part":{"id":"prt_d79aabd88001kcRm3VgRyEYVTJ","messageID":"msg_d79aab371001oTnPql1vHMBsEk","sessionID":"ses_28655b065ffe5esZZd4x0I346i","type":"tool","tool":"read","callID":"toolu_tool-84675f0e93c247d4b08d9e0c367337c1","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/agentd/controller_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/agentd/controller_test.go</path>\n<type>file</type>\n<content>\n1: package agentd\n2: \n3: import (\n4: \t\"context\"\n5: \t\"testing\"\n6: \t\"time\"\n7: \n8: \t\"github.com/stretchr/testify/assert\"\n9: \t\"github.com/stretchr/testify/require\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: \t\"k8s.io/apimachinery/pkg/runtime\"\n12: \t\"k8s.io/apimachinery/pkg/types\"\n13: \t\"k8s.io/client-go/kubernetes/scheme\"\n14: \tctrl \"sigs.k8s.io/controller-runtime\"\n15: \t\"sigs.k8s.io/controller-runtime/pkg/client/fake\"\n16: )\n17: \n18: var (\n19: \ttestScheme = runtime.NewScheme()\n20: )\n21: \n22: func init() {\n23: \t_ = scheme.AddToScheme(testScheme)\n24: \t_ = AddToScheme(testScheme)\n25: }\n26: \n27: func newTestSandbox(name, namespace string, annotations map[string]string) *Sandbox {\n28: \treturn &Sandbox{\n29: \t\tObjectMeta: metav1.ObjectMeta{\n30: \t\t\tName:        name,\n31: \t\t\tNamespace:   namespace,\n32: \t\t\tAnnotations: annotations,\n33: \t\t},\n34: \t}\n35: }\n36: \n37: func TestReconcile_NotFound(t *testing.T) {\n38: \tfakeClient := fake.NewClientBuilder().\n39: \t\tWithScheme(testScheme).\n40: \t\tBuild()\n41: \n42: \treconciler := &Reconciler{\n43: \t\tClient: fakeClient,\n44: \t\tScheme: testScheme,\n45: \t}\n46: \n47: \treq := ctrl.Request{\n48: \t\tNamespacedName: types.NamespacedName{\n49: \t\t\tName:      \"nonexistent\",\n50: \t\t\tNamespace: \"default\",\n51: \t\t},\n52: \t}\n53: \n54: \tresult, err := reconciler.Reconcile(context.Background(), req)\n55: \n56: \tassert.NoError(t, err)\n57: \tassert.Equal(t, ctrl.Result{}, result, \"Should return empty result without error\")\n58: }\n59: \n60: func TestReconcile_MissingAnnotation(t *testing.T) {\n61: \tsandbox := newTestSandbox(\"test-sandbox\", \"default\", nil)\n62: \n63: \tfakeClient := fake.NewClientBuilder().\n64: \t\tWithScheme(testScheme).\n65: \t\tWithObjects(sandbox).\n66: \t\tBuild()\n67: \n68: \treconciler := &Reconciler{\n69: \t\tClient: fakeClient,\n70: \t\tScheme: testScheme,\n71: \t}\n72: \n73: \treq := ctrl.Request{\n74: \t\tNamespacedName: types.NamespacedName{\n75: \t\t\tName:      \"test-sandbox\",\n76: \t\t\tNamespace: \"default\",\n77: \t\t},\n78: \t}\n79: \n80: \tresult, err := reconciler.Reconcile(context.Background(), req)\n81: \n82: \tassert.NoError(t, err)\n83: \tassert.Equal(t, ctrl.Result{}, result, \"Should return empty result without error\")\n84: \n85: \tvar retrieved Sandbox\n86: \terr = fakeClient.Get(context.Background(), req.NamespacedName, &retrieved)\n87: \tassert.NoError(t, err, \"Sandbox should still exist\")\n88: }\n89: \n90: func TestReconcile_EmptyAnnotation(t *testing.T) {\n91: \tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n92: \t\tLastActivityAnnotationKey: \"\",\n93: \t})\n94: \n95: \tfakeClient := fake.NewClientBuilder().\n96: \t\tWithScheme(testScheme).\n97: \t\tWithObjects(sandbox).\n98: \t\tBuild()\n99: \n100: \treconciler := &Reconciler{\n101: \t\tClient: fakeClient,\n102: \t\tScheme: testScheme,\n103: \t}\n104: \n105: \treq := ctrl.Request{\n106: \t\tNamespacedName: types.NamespacedName{\n107: \t\t\tName:      \"test-sandbox\",\n108: \t\t\tNamespace: \"default\",\n109: \t\t},\n110: \t}\n111: \n112: \tresult, err := reconciler.Reconcile(context.Background(), req)\n113: \n114: \tassert.NoError(t, err)\n115: \tassert.Equal(t, ctrl.Result{}, result, \"Should return empty result without error\")\n116: }\n117: \n118: func TestReconcile_InvalidAnnotation(t *testing.T) {\n119: \tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n120: \t\tLastActivityAnnotationKey: \"invalid-time-format\",\n121: \t})\n122: \n123: \tfakeClient := fake.NewClientBuilder().\n124: \t\tWithScheme(testScheme).\n125: \t\tWithObjects(sandbox).\n126: \t\tBuild()\n127: \n128: \treconciler := &Reconciler{\n129: \t\tClient: fakeClient,\n130: \t\tScheme: testScheme,\n131: \t}\n132: \n133: \treq := ctrl.Request{\n134: \t\tNamespacedName: types.NamespacedName{\n135: \t\t\tName:      \"test-sandbox\",\n136: \t\t\tNamespace: \"default\",\n137: \t\t},\n138: \t}\n139: \n140: \tresult, err := reconciler.Reconcile(context.Background(), req)\n141: \n142: \tassert.Error(t, err, \"Should return error for invalid time format\")\n143: \tassert.Contains(t, err.Error(), \"failed to parse last activity time\")\n144: \tassert.Equal(t, DefaultRequeueInterval, result.RequeueAfter, \"Should requeue after default interval\")\n145: \n146: \tvar retrieved Sandbox\n147: \terr = fakeClient.Get(context.Background(), req.NamespacedName, &retrieved)\n148: \tassert.NoError(t, err, \"Sandbox should still exist\")\n149: }\n150: \n151: func TestReconcile_NotExpired(t *testing.T) {\n152: \tlastActivity := time.Now().Add(-5 * time.Minute)\n153: \tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n154: \t\tLastActivityAnnotationKey: lastActivity.Format(time.RFC3339),\n155: \t})\n156: \n157: \tfakeClient := fake.NewClientBuilder().\n158: \t\tWithScheme(testScheme).\n159: \t\tWithObjects(sandbox).\n160: \t\tBuild()\n161: \n162: \treconciler := &Reconciler{\n163: \t\tClient: fakeClient,\n164: \t\tScheme: testScheme,\n165: \t}\n166: \n167: \treq := ctrl.Request{\n168: \t\tNamespacedName: types.NamespacedName{\n169: \t\t\tName:      \"test-sandbox\",\n170: \t\t\tNamespace: \"default\",\n171: \t\t},\n172: \t}\n173: \n174: \tresult, err := reconciler.Reconcile(context.Background(), req)\n175: \n176: \tassert.NoError(t, err)\n177: \tassert.Greater(t, result.RequeueAfter, time.Duration(0), \"Should have positive requeue delay\")\n178: \n179: \texpectedRequeue := time.Until(lastActivity.Add(SessionExpirationTimeout))\n180: \tassert.InDelta(t, expectedRequeue.Seconds(), result.RequeueAfter.Seconds(), 1.0, \"Requeue should be until expiration\")\n181: \n182: \tvar retrieved Sandbox\n183: \terr = fakeClient.Get(context.Background(), req.NamespacedName, &retrieved)\n184: \tassert.NoError(t, err, \"Sandbox should still exist\")\n185: }\n186: \n187: func TestReconcile_Expired(t *testing.T) {\n188: \tlastActivity := time.Now().Add(-20 * time.Minute)\n189: \tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n190: \t\tLastActivityAnnotationKey: lastActivity.Format(time.RFC3339),\n191: \t})\n192: \n193: \tfakeClient := fake.NewClientBuilder().\n194: \t\tWithScheme(testScheme).\n195: \t\tWithObjects(sandbox).\n196: \t\tBuild()\n197: \n198: \treconciler := &Reconciler{\n199: \t\tClient: fakeClient,\n200: \t\tScheme: testScheme,\n201: \t}\n202: \n203: \treq := ctrl.Request{\n204: \t\tNamespacedName: types.NamespacedName{\n205: \t\t\tName:      \"test-sandbox\",\n206: \t\t\tNamespace: \"default\",\n207: \t\t},\n208: \t}\n209: \n210: \tresult, err := reconciler.Reconcile(context.Background(), req)\n211: \n212: \tassert.NoError(t, err)\n213: \tassert.Equal(t, ctrl.Result{}, result, \"Should return empty result after deletion\")\n214: \n215: \tvar retrieved Sandbox\n216: \terr = fakeClient.Get(context.Background(), req.NamespacedName, &retrieved)\n217: \tassert.Error(t, err, \"Sandbox should be deleted\")\n218: }\n219: \n220: func TestReconcile_Expired_DeleteAlreadyDeleted(t *testing.T) {\n221: \tfakeClient := fake.NewClientBuilder().\n222: \t\tWithScheme(testScheme).\n223: \t\tBuild()\n224: \n225: \treconciler := &Reconciler{\n226: \t\tClient: fakeClient,\n227: \t\tScheme: testScheme,\n228: \t}\n229: \n230: \treq := ctrl.Request{\n231: \t\tNamespacedName: types.NamespacedName{\n232: \t\t\tName:      \"test-sandbox\",\n233: \t\t\tNamespace: \"default\",\n234: \t\t},\n235: \t}\n236: \n237: \tresult, err := reconciler.Reconcile(context.Background(), req)\n238: \n239: \tassert.NoError(t, err)\n240: \tassert.Equal(t, ctrl.Result{}, result, \"Should return empty result\")\n241: }\n242: \n243: func TestReconcile_NearExpiration(t *testing.T) {\n244: \tlastActivity := time.Now().Add(-14 * time.Minute)\n245: \tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n246: \t\tLastActivityAnnotationKey: lastActivity.Format(time.RFC3339),\n247: \t})\n248: \n249: \tfakeClient := fake.NewClientBuilder().\n250: \t\tWithScheme(testScheme).\n251: \t\tWithObjects(sandbox).\n252: \t\tBuild()\n253: \n254: \treconciler := &Reconciler{\n255: \t\tClient: fakeClient,\n256: \t\tScheme: testScheme,\n257: \t}\n258: \n259: \treq := ctrl.Request{\n260: \t\tNamespacedName: types.NamespacedName{\n261: \t\t\tName:      \"test-sandbox\",\n262: \t\t\tNamespace: \"default\",\n263: \t\t},\n264: \t}\n265: \n266: \tresult, err := reconciler.Reconcile(context.Background(), req)\n267: \n268: \tassert.NoError(t, err)\n269: \tassert.Greater(t, result.RequeueAfter, time.Duration(0), \"Should have positive requeue delay\")\n270: \tassert.Less(t, result.RequeueAfter, 2*time.Minute, \"Should requeue in less than 2 minutes\")\n271: \n272: \tvar retrieved Sandbox\n273: \terr = fakeClient.Get(context.Background(), req.NamespacedName, &retrieved)\n274: \tassert.NoError(t, err, \"Sandbox should still exist\")\n275: }\n276: \n277: func TestReconcile_JustExpired(t *testing.T) {\n278: \tlastActivity := time.Now().Add(-15 * time.Minute).Add(-1 * time.Second)\n279: \tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n280: \t\tLastActivityAnnotationKey: lastActivity.Format(time.RFC3339),\n281: \t})\n282: \n283: \tfakeClient := fake.NewClientBuilder().\n284: \t\tWithScheme(testScheme).\n285: \t\tWithObjects(sandbox).\n286: \t\tBuild()\n287: \n288: \treconciler := &Reconciler{\n289: \t\tClient: fakeClient,\n290: \t\tScheme: testScheme,\n291: \t}\n292: \n293: \treq := ctrl.Request{\n294: \t\tNamespacedName: types.NamespacedName{\n295: \t\t\tName:      \"test-sandbox\",\n296: \t\t\tNamespace: \"default\",\n297: \t\t},\n298: \t}\n299: \n300: \tresult, err := reconciler.Reconcile(context.Background(), req)\n301: \n302: \tassert.NoError(t, err)\n303: \tassert.Equal(t, ctrl.Result{}, result, \"Should return empty result after deletion\")\n304: \n305: \tvar retrieved Sandbox\n306: \terr = fakeClient.Get(context.Background(), req.NamespacedName, &retrieved)\n307: \tassert.Error(t, err, \"Sandbox should be deleted\")\n308: }\n309: \n310: func TestReconcile_ValidRFC3339Formats(t *testing.T) {\n311: \ttestCases := []struct {\n312: \t\tname          string\n313: \t\ttimeFormat    string\n314: \t\tshouldWork    bool\n315: \t\texpectedError string\n316: \t}{\n317: \t\t{\n318: \t\t\tname:       \"RFC3339 with seconds\",\n319: \t\t\ttimeFormat: time.RFC3339,\n320: \t\t\tshouldWork: true,\n321: \t\t},\n322: \t\t{\n323: \t\t\tname:       \"RFC3339Nano\",\n324: \t\t\ttimeFormat: time.RFC3339Nano,\n325: \t\t\tshouldWork: true,\n326: \t\t},\n327: \t\t{\n328: \t\t\tname:          \"Invalid format\",\n329: \t\t\ttimeFormat:    \"2006-01-02 15:04:05\",\n330: \t\t\tshouldWork:    false,\n331: \t\t\texpectedError: \"failed to parse last activity time\",\n332: \t\t},\n333: \t}\n334: \n335: \tfor _, tc := range testCases {\n336: \t\tt.Run(tc.name, func(t *testing.T) {\n337: \t\t\tlastActivity := time.Now().Add(-5 * time.Minute)\n338: \t\t\tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n339: \t\t\t\tLastActivityAnnotationKey: lastActivity.Format(tc.timeFormat),\n340: \t\t\t})\n341: \n342: \t\t\tfakeClient := fake.NewClientBuilder().\n343: \t\t\t\tWithScheme(testScheme).\n344: \t\t\t\tWithObjects(sandbox).\n345: \t\t\t\tBuild()\n346: \n347: \t\t\treconciler := &Reconciler{\n348: \t\t\t\tClient: fakeClient,\n349: \t\t\t\tScheme: testScheme,\n350: \t\t\t}\n351: \n352: \t\t\treq := ctrl.Request{\n353: \t\t\t\tNamespacedName: types.NamespacedName{\n354: \t\t\t\t\tName:      \"test-sandbox\",\n355: \t\t\t\t\tNamespace: \"default\",\n356: \t\t\t\t},\n357: \t\t\t}\n358: \n359: \t\t\tresult, err := reconciler.Reconcile(context.Background(), req)\n360: \n361: \t\t\tif tc.shouldWork {\n362: \t\t\t\tassert.NoError(t, err)\n363: \t\t\t\tassert.Greater(t, result.RequeueAfter, time.Duration(0), \"Should have positive requeue delay\")\n364: \t\t\t} else {\n365: \t\t\t\tassert.Error(t, err)\n366: \t\t\t\tassert.Contains(t, err.Error(), tc.expectedError)\n367: \t\t\t}\n368: \t\t})\n369: \t}\n370: }\n371: \n372: func TestReconcile_NegativeRequeueAfter(t *testing.T) {\n373: \tlastActivity := time.Now().Add(-16 * time.Minute)\n374: \tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n375: \t\tLastActivityAnnotationKey: lastActivity.Format(time.RFC3339),\n376: \t})\n377: \n378: \tfakeClient := fake.NewClientBuilder().\n379: \t\tWithScheme(testScheme).\n380: \t\tWithObjects(sandbox).\n381: \t\tBuild()\n382: \n383: \treconciler := &Reconciler{\n384: \t\tClient: fakeClient,\n385: \t\tScheme: testScheme,\n386: \t}\n387: \n388: \treq := ctrl.Request{\n389: \t\tNamespacedName: types.NamespacedName{\n390: \t\t\tName:      \"test-sandbox\",\n391: \t\t\tNamespace: \"default\",\n392: \t\t},\n393: \t}\n394: \n395: \tresult, err := reconciler.Reconcile(context.Background(), req)\n396: \n397: \tassert.NoError(t, err)\n398: \tassert.Equal(t, ctrl.Result{}, result, \"Should delete and return empty result\")\n399: \n400: \tvar retrieved Sandbox\n401: \terr = fakeClient.Get(context.Background(), req.NamespacedName, &retrieved)\n402: \tassert.Error(t, err, \"Sandbox should be deleted\")\n403: }\n404: \n405: func TestReconcile_MultipleNamespaces(t *testing.T) {\n406: \tnamespaces := []string{\"default\", \"test\", \"prod\"}\n407: \n408: \tfor _, ns := range namespaces {\n409: \t\tlastActivity := time.Now().Add(-20 * time.Minute)\n410: \t\tsandbox := newTestSandbox(\"test-sandbox-\"+ns, ns, map[string]string{\n411: \t\t\tLastActivityAnnotationKey: lastActivity.Format(time.RFC3339),\n412: \t\t})\n413: \n414: \t\tfakeClient := fake.NewClientBuilder().\n415: \t\t\tWithScheme(testScheme).\n416: \t\t\tWithObjects(sandbox).\n417: \t\t\tBuild()\n418: \n419: \t\treconciler := &Reconciler{\n420: \t\t\tClient: fakeClient,\n421: \t\t\tScheme: testScheme,\n422: \t\t}\n423: \n424: \t\treq := ctrl.Request{\n425: \t\t\tNamespacedName: types.NamespacedName{\n426: \t\t\t\tName:      \"test-sandbox-\" + ns,\n427: \t\t\t\tNamespace: ns,\n428: \t\t\t},\n429: \t\t}\n430: \n431: \t\tresult, err := reconciler.Reconcile(context.Background(), req)\n432: \n433: \t\tassert.NoError(t, err, \"Should succeed for namespace %s\", ns)\n434: \t\tassert.Equal(t, ctrl.Result{}, result, \"Should delete sandbox in namespace %s\", ns)\n435: \t}\n436: }\n437: \n438: func TestReconcile_LargeAnnotationValue(t *testing.T) {\n439: \tlastActivity := time.Now().Add(-5 * time.Minute)\n440: \tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n441: \t\tLastActivityAnnotationKey: lastActivity.Format(time.RFC3339),\n442: \t})\n443: \n444: \tfakeClient := fake.NewClientBuilder().\n445: \t\tWithScheme(testScheme).\n446: \t\tWithObjects(sandbox).\n447: \t\tBuild()\n448: \n449: \treconciler := &Reconciler{\n450: \t\tClient: fakeClient,\n451: \t\tScheme: testScheme,\n452: \t}\n453: \n454: \treq := ctrl.Request{\n455: \t\tNamespacedName: types.NamespacedName{\n456: \t\t\tName:      \"test-sandbox\",\n457: \t\t\tNamespace: \"default\",\n458: \t\t},\n459: \t}\n460: \n461: \tresult, err := reconciler.Reconcile(context.Background(), req)\n462: \n463: \tassert.NoError(t, err)\n464: \tassert.Greater(t, result.RequeueAfter, time.Duration(0), \"Should handle large annotations\")\n465: }\n466: \n467: func TestReconcile_RFC3339WithTimezone(t *testing.T) {\n468: \ttimezones := []string{\n469: \t\t\"UTC\",\n470: \t\t\"America/New_York\",\n471: \t\t\"Asia/Tokyo\",\n472: \t\t\"Europe/London\",\n473: \t}\n474: \n475: \tfor _, tz := range timezones {\n476: \t\tt.Run(tz, func(t *testing.T) {\n477: \t\t\tloc, err := time.LoadLocation(tz)\n478: \t\t\trequire.NoError(t, err)\n479: \n480: \t\t\tlastActivity := time.Now().In(loc).Add(-5 * time.Minute)\n481: \t\t\tsandbox := newTestSandbox(\"test-sandbox\", \"default\", map[string]string{\n482: \t\t\t\tLastActivityAnnotationKey: lastActivity.Format(time.RFC3339),\n483: \t\t\t})\n484: \n485: \t\t\tfakeClient := fake.NewClientBuilder().\n486: \t\t\t\tWithScheme(testScheme).\n487: \t\t\t\tWithObjects(sandbox).\n488: \t\t\t\tBuild()\n489: \n490: \t\t\treconciler := &Reconciler{\n491: \t\t\t\tClient: fakeClient,\n492: \t\t\t\tScheme: testScheme,\n493: \t\t\t}\n494: \n495: \t\t\treq := ctrl.Request{\n496: \t\t\t\tNamespacedName: types.NamespacedName{\n497: \t\t\t\t\tName:      \"test-sandbox\",\n498: \t\t\t\t\tNamespace: \"default\",\n499: \t\t\t\t},\n500: \t\t\t}\n501: \n502: \t\t\tresult, err := reconciler.Reconcile(context.Background(), req)\n503: \n504: \t\t\tassert.NoError(t, err)\n505: \t\t\tassert.Greater(t, result.RequeueAfter, time.Duration(0), \"Should handle timezone correctly\")\n506: \t\t})\n507: \t}\n508: }\n509: \n510: func TestDeepCopy(t *testing.T) {\n511: \toriginal := &Sandbox{\n512: \t\tObjectMeta: metav1.ObjectMeta{\n513: \t\t\tName:      \"test\",\n514: \t\t\tNamespace: \"default\",\n515: \t\t\tAnnotations: map[string]string{\n516: \t\t\t\tLastActivityAnnotationKey: time.Now().Format(time.RFC3339),\n517: \t\t\t},\n518: \t\t},\n519: \t}\n520: \n521: \tcopied := original.DeepCopyObject().(*Sandbox)\n522: \n523: \tassert.Equal(t, original.Name, copied.Name)\n524: \tassert.Equal(t, original.Namespace, copied.Namespace)\n525: \tassert.Equal(t, original.Annotations, copied.Annotations)\n526: \n527: \tcopied.Annotations[\"new-key\"] = \"new-value\"\n528: \tassert.NotContains(t, original.Annotations, \"new-key\", \"Modifying copy should not affect original\")\n529: }\n530: \n531: func TestDeepCopyList(t *testing.T) {\n532: \toriginal := &SandboxList{\n533: \t\tItems: []Sandbox{\n534: \t\t\t{\n535: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n536: \t\t\t\t\tName:      \"test1\",\n537: \t\t\t\t\tNamespace: \"default\",\n538: \t\t\t\t\tAnnotations: map[string]string{\n539: \t\t\t\t\t\tLastActivityAnnotationKey: time.Now().Format(time.RFC3339),\n540: \t\t\t\t\t},\n541: \t\t\t\t},\n542: \t\t\t},\n543: \t\t\t{\n544: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n545: \t\t\t\t\tName:      \"test2\",\n546: \t\t\t\t\tNamespace: \"test\",\n547: \t\t\t\t\tAnnotations: map[string]string{\n548: \t\t\t\t\t\tLastActivityAnnotationKey: time.Now().Format(time.RFC3339),\n549: \t\t\t\t\t},\n550: \t\t\t\t},\n551: \t\t\t},\n552: \t\t},\n553: \t}\n554: \n555: \tcopied := original.DeepCopyObject().(*SandboxList)\n556: \n557: \tassert.Equal(t, len(original.Items), len(copied.Items))\n558: \tfor i := range original.Items {\n559: \t\tassert.Equal(t, original.Items[i].Name, copied.Items[i].Name)\n560: \t\tassert.Equal(t, original.Items[i].Namespace, copied.Items[i].Namespace)\n561: \t}\n562: \n563: \tcopied.Items[0].Annotations[\"new-key\"] = \"new-value\"\n564: \tassert.NotContains(t, original.Items[0].Annotations, \"new-key\", \"Modifying copy should not affect original\")\n565: }\n\n(End of file - total 565 lines)\n</content>","metadata":{"preview":"package agentd\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"k8s.io/client-go/kubernetes/scheme\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client/fake\"\n)\n\nvar (\n\ttestScheme = runtime.NewScheme()\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/agentd/controller_test.go","time":{"start":1775862726056,"end":1775862726071}}}}
