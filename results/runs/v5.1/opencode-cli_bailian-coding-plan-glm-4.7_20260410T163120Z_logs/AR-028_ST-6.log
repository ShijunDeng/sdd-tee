D to reuse\n36: \n37:         Raises:\n38:             ValueError: If router_url is not provided or found in environment\n39:         \"\"\"\n40:         self.name = name\n41:         self.namespace = namespace\n42:         self.ttl = ttl\n43:         self.verbose = verbose\n44:         self.logger = get_logger(f\"{__name__}.CodeInterpreterClient\")\n45: \n46:         if verbose:\n47:             self.logger.setLevel(10)\n48: \n49:         self.router_url = router_url or os.getenv(\"ROUTER_URL\")\n50: \n51:         if not self.router_url:\n52:             raise ValueError(\n53:                 \"Router URL must be provided via router_url argument or ROUTER_URL environment variable\"\n54:             )\n55: \n56:         self.session_id = session_id\n57:         self.cp_client = ControlPlaneClient(\n58:             workload_manager_url=workload_manager_url,\n59:             auth_token=auth_token,\n60:         )\n61:         self.dp_client: CodeInterpreterDataPlaneClient | None = None\n62: \n63:         if self.session_id:\n64:             self.logger.info(f\"Reusing existing session: {self.session_id}\")\n65:             self._init_data_plane()\n66:         else:\n67:             self._create_session()\n68: \n69:     def _create_session(self) -> None:\n70:         \"\"\"Create a new session via control plane.\"\"\"\n71:         self.session_id = self.cp_client.create_session(\n72:             name=self.name,\n73:             namespace=self.namespace,\n74:             ttl=self.ttl,\n75:         )\n76:         self._init_data_plane()\n77: \n78:     def _init_data_plane(self) -> None:\n79:         \"\"\"Initialize the data plane client.\n80: \n81:         Raises:\n82:             Exception: If initialization fails, cleans up session\n83:         \"\"\"\n84:         try:\n85:             self.dp_client = CodeInterpreterDataPlaneClient(\n86:                 session_id=self.session_id,\n87:                 router_url=self.router_url,\n88:                 namespace=self.namespace,\n89:                 cr_name=self.name,\n90:             )\n91:         except Exception as e:\n92:             if self.session_id and self.cp_client:\n93:                 self.logger.warning(\n94:                     f\"Data plane initialization failed, cleaning up session: {e}\"\n95:                 )\n96:                 self.cp_client.delete_session(self.session_id)\n97:                 self.session_id = None\n98:             raise\n99: \n100:     def __enter__(self) -> \"CodeInterpreterClient\":\n101:         \"\"\"Enter context manager.\n102: \n103:         Returns:\n104:             Self\n105:         \"\"\"\n106:         return self\n107: \n108:     def __exit__(self, exc_type: Optional[object], exc_val: Optional[object], exc_tb: Optional[object]) -> None:\n109:         \"\"\"Exit context manager and cleanup.\n110: \n111:         Args:\n112:             exc_type: Exception type\n113:             exc_val: Exception value\n114:             exc_tb: Exception traceback\n115:         \"\"\"\n116:         self.stop()\n117: \n118:     def stop(self) -> None:\n119:         \"\"\"Stop the session and cleanup resources.\"\"\"\n120:         if self.dp_client:\n121:             self.dp_client.close()\n122:             self.dp_client = None\n123: \n124:         if self.session_id and self.cp_client:\n125:             self.cp_client.delete_session(self.session_id)\n126:             self.session_id = None\n127: \n128:         if self.cp_client:\n129:             self.cp_client.close()\n130: \n131:         self.logger.info(\"Stopped Code Interpreter session\")\n132: \n133:     def execute_command(self, command: str, timeout: Optional[float] = None) -> str:\n134:         \"\"\"Execute a command in the session.\n135: \n136:         Args:\n137:             command: Command to execute\n138:             timeout: Timeout in seconds\n139: \n140:         Returns:\n141:             Command output\n142: \n143:         Raises:\n144:             ValueError: If data plane client