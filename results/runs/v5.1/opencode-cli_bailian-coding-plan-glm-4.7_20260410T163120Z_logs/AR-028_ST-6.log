ient.upload_file(local_path, remote_path)\n199: \n200:     def download_file(self, remote_path: str, local_path: str) -> None:\n201:         \"\"\"Download a file from the session.\n202: \n203:         Args:\n204:             remote_path: Remote file path\n205:             local_path: Local file path\n206: \n207:         Raises:\n208:             ValueError: If data plane client is not initialized\n209:         \"\"\"\n210:         if not self.dp_client:\n211:             raise ValueError(\"Data plane client not initialized\")\n212: \n213:         self.dp_client.download_file(remote_path, local_path)\n214: \n215:     def list_files(self, path: str = \".\") -> Any:\n216:         \"\"\"List files in the session.\n217: \n218:         Args:\n219:             path: Directory path\n220: \n221:         Returns:\n222:             File listing\n223: \n224:         Raises:\n225:             ValueError: If data plane client is not initialized\n226:         \"\"\"\n227:         if not self.dp_client:\n228:             raise ValueError(\"Data plane client not initialized\")\n229: \n230:         return self.dp_client.list_files(path)\n\n(End of file - total 230 lines)\n</content>","metadata":{"preview":"\"\"\"Code Interpreter client for managing interpreter sessions.\"\"\"\n\nimport os\nfrom typing import Any, Optional\n\nfrom .clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom .clients.control_plane import ControlPlaneClient\nfrom .utils import get_logger\n\n\nclass CodeInterpreterClient:\n    \"\"\"Main client for Code Interpreter session management and operations.\"\"\"\n\n    def __init__(\n        self,\n        name: str = \"my-interpreter\",\n        namespace: str = \"default\",\n        ttl: int = 3600,\n        workload_manager_url: Optional[str] = None,\n        router_url: Optional[str] = None,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/agentcube/code_interpreter.py","