InformerManager(t *testing.T) {\n1712:     k8sClient := &K8sClient{}\n1713:     server := &Server{}\n1714:     workspaceManager := &WorkspaceManager{}\n1715:     statusReporter := &StatusReporter{}\n1716: \n1717:     im := NewInformerManager(k8sClient, server, workspaceManager, statusReporter)\n1718: \n1719:     assert.NotNil(t, im)\n1720:     assert.Equal(t, k8sClient, im.k8sClient)\n1721:     assert.Equal(t, server, im.server)\n1722:     assert.Equal(t, workspaceManager, im.workspaceManager)\n1723:     assert.Equal(t, statusReporter, im.statusReporter)\n1724: }\n1725: ```\n1726: \n1727: **Step 2: Test spec comparison functions**\n1728: \n1729: ```go\n1730: func TestInformerManager_SpecsEqual_AgentRuntime(t *testing.T) {\n1731:     im := &InformerManager{}\n1732: \n1733:     spec1 := runtimev1alpha1.AgentRuntimeSpec{\n1734:         SessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n1735:         MaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n1736:     }\n1737: \n1738:     spec2 := runtimev1alpha1.AgentRuntimeSpec{\n1739:         SessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n1740:         MaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n1741:     }\n1742: \n1743:     assert.True(t, im.specsEqual(spec1, spec2))\n1744: }\n1745: \n1746: func TestInformerManager_SpecsEqual_DifferentTimeout(t *testing.T) {\n1747:     im := &InformerManager{}\n1748: \n1749:     spec1 := runtimev1alpha1.AgentRuntimeSpec{\n1750:         SessionTimeout: &metav1.Duration{Duration: 15 * time.Minute},\n1751:     }\n1752: \n1753:     spec2 := runtimev1alpha1.AgentRuntimeSpec{\n1754:         SessionTimeout: &metav1.Duration{Duration: 30 * time.Minute},\n1755:     }\n1756: \n1757:     assert.False(t, im.specsEqual(spec1, spec2))\n1758: }\n1759: \n1760: func TestInformerManager_SpecsEqual_CodeInterpreter(t *testing.T) {\n1761:     im := &InformerManager{}\n1762: \n1763:     spec1 := runtimev1alpha1.CodeInterpreterSpec{\n1764:         Image:   \"python:3.11\",\n1765:         Runtime: \"python\",\n1766:         Timeout: &metav1.Duration{Duration: 5 * time.Minute},\n1767:     }\n1768: \n1769:     spec2 := runtimev1alpha1.CodeInterpreterSpec{\n1770:         Image:   \"python:3.11\",\n1771:         Runtime: \"python\",\n1772:         Timeout: &metav1.Duration{Duration: 5 * time.Minute},\n1773:     }\n1774: \n1775:     assert.True(t, im.specsEqual(spec1, spec2))\n1776: }\n1777: \n1778: func TestInformerManager_SpecsEqual_DifferentImage(t *testing.T) {\n1779:     im := &InformerManager{}\n1780: \n1781:     spec1 := runtimev1alpha1.CodeInterpreterSpec{\n1782:         Image:   \"python:3.11\",\n1783:         Runtime: \"python\",\n1784:     }\n1785: \n1786:     spec2 := runtimev1alpha1.CodeInterpreterSpec{\n1787:         Image:   \"python:3.12\",\n1788:         Runtime: \"python\",\n1789:     }\n1790: \n1791:     assert.False(t, im.specsEqual(spec1, spec2))\n1792: }\n1793: ```\n1794: \n1795: **Step 3: Test deep equality function**\n1796: \n1797: ```go\n1798: func TestInformerManager_DeepEqual_NilFields(t *testing.T) {\n1799:     im := &InformerManager{}\n1800: \n1801:     spec1 := runtimev1alpha1.AgentRuntimeSpec{\n1802:         SessionTimeout: nil,\n1803:     }\n1804: \n1805:     spec2 := runtimev1alpha1.AgentRuntimeSpec{\n1806:         SessionTimeout: &metav1.Duration{Duration: 15 * time.Minute},\n1807:     }\n1808: \n1809:     assert.False(t, im.deepEqual(spec1, spec2))\n1810: }\n1811: \n1812: func TestInformerManager_DeepEqual_BothNil(t *testing.T) {\n1813:     im := &InformerManager{}\n1814: \n1815:     spec1 := runtimev1alpha1.AgentRuntimeSpec{\n1816:         SessionTimeout: nil,\n1817:     }\n1818: \n1819:     spec2 := runtimev1alpha1.AgentRuntimeSpec{\n1820:         SessionTimeout: nil,\n1821:     }\n1822: \n1823:     assert.True(t, im.deepEqual(spec1, spec2))\n1824: }\n1825: ```\n1826: \n1827: **Step 4: Test handler functions**\n1828: \n1829: ```go\n1830: func TestInformerManager_HandleSpecUpdate(t *testing.T) {\n1831:     im := &InformerManager{}\n1832: \n1833:     ar := &runtimev1alpha1.AgentRuntime{\n1834:         Spec: runtimev1alpha1.AgentRuntimeSpec{\n1835:             SessionTimeout:     &metav1.Duration{Duration: 20 * time.Minute},\n1836:             MaxSessionDuration: &metav1.Duration{Duration: 10 * time.Hour},\n1837:         },\n1838:     }\n1839: \n1840:     im.handleSpecUpdate(ar)\n1841: }\n1842: \n1843: func TestInformerManager_HandleCodeInterpreterUpdate(t *testing.T) {\n1844:     im := &InformerManager{}\n1845: \n1846:     ci := &runtimev1alpha1.CodeInterpreter{\n1847:         Spec: runtimev1alpha1.CodeInterpreterSpec{\n1848:             Image:   \"python:3.12\",\n1849:             Runtime: \"python\",\n1850:         },\n1851:     }\n1852: \n1853:     im.handleCodeInterpreterUpdate(ci)\n1854: }\n1855: \n1856: func TestInformerManager_HandleAgentRuntimeDeletion_Matching(t *testing.T) {\n1857:     tmpDir := t.TempDir()\n1858: \n1859:     k8sClient := &K8sClient{\n1860:         agentRuntimeName: \"test-runtime\",\n1861:     }\n1862: \n1863:     workspaceManager := &WorkspaceManager{\n1864:         workspaceDir: tmpDir,\n1865:     }\n1866: \n1867:     im := &InformerManager{\n1868:         k8sClient:        k8sClient,\n1869:         workspaceManager: workspaceManager,\n1870:     }\n1871: \n1872:     ar := &runtimev1alpha1.AgentRuntime{\n1873:         ObjectMeta: metav1.ObjectMeta{\n1874:             Name: \"test-runtime\",\n1875:         },\n1876:     }\n1877: \n1878:     assert.Panics(t, func() {\n1879:         im.handleAgentRuntimeDeletion(ar)\n1880:     })\n1881: }\n1882: \n1883: func TestInformerManager_HandleAgentRuntimeDeletion_NonMatching(t *testing.T) {\n1884:     k8sClient := &K8sClient{\n1885:         agentRuntimeName: \"my-runtime\",\n1886:     }\n1887: \n1888:     im := &InformerManager{\n1889:         k8sClient: k8sClient,\n1890:     }\n1891: \n1892:     ar := &runtimev1alpha1.AgentRuntime{\n1893:         ObjectMeta: metav1.ObjectMeta{\n1894:             Name: \"other-runtime\",\n1895:         },\n1896:     }\n1897: \n1898:     assert.NotPanics(t, func() {\n1899:         im.handleAgentRuntimeDeletion(ar)\n1900:     })\n1901: }\n1902: ```\n1903: \n1904: ---\n1905: \n1906: ## Phase 4: Integration and Verification\n1907: \n1908: ### Task 15: Run all tests and verify coverage\n1909: \n1910: **Step 1: Run router module tests**\n1911: \n1912: ```bash\n1913: go test -v -cover ./pkg/router/...\n1914: ```\n1915: \n1916: **Step 2: Run store module tests**\n1917: \n1918: ```bash\n1919: go test -v -cover ./pkg/store/...\n1920: ```\n1921: \n1922: **Step 3: Run picod module tests**\n1923: \n1924: ```bash\n1925: go test -v -cover ./pkg/picod/...\n1926: ```\n1927: \n1928: **Step 4: Generate coverage reports**\n\n(Output capped at 50 KB. Showing lines 1-1928. Use offset=1929 to continue.)\n</content>","metadata":{"preview":"# AR-039 Implementation Plan\n\n**Feature:** AR-039 — Go 单元测试 (router/store/picod)\n**Goal:** 为 pkg/router、pkg/store、pkg/picod 模块编写全面的单元测试，确保所有核心组件、处理器、工具函数都有充分的测试覆盖。\n**Acceptance Criteria:**\n- 所有核心组件（router、store、picod）都有对应的 *_test.go 文件\n- 测试覆盖率 >80%\n- 所有测试可通过 `go test ./pkg/router/...`、`go test ./pkg/store/...`、`go test ./pkg/picod/...` 运行\n- 测试遵循 testify/assert 和 mock 的使用模式\n- 测试用例覆盖正常流程、边界条件和错误场景\n- 遵循 test_spec.md 中定义的测试用例（TestCase-RT-001, TestCase-RT-002, TestCase-RT-003, TestCase-ST-001, TestCase-ST-002, TestCase-PD-001, TestCase-PD-002）\n**Architecture:** Go 单元测试，使用 testify 框架，mock dependencies\n**Tech Stack:** Go 1.21+, testify\n**Frontend validation:** No\n\n---\n\n## Phase 1: pkg/router Module Tests\n\n### Task 1: Create errors_test.go for router module","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tasks.md","time":{"start":1775894824712,"end":1775894824736}}}}
