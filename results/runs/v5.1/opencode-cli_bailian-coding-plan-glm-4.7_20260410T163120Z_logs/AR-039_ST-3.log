ext.WithTimeout(context.Background(), timeout)\n53: \tdefer cancel()\n54: \n55: \tcmd := exec.CommandContext(ctx, req.Command[0], req.Command[1:]...)\n56: \tcmd.Dir = workingDir\n57: \n58: \tenv := os.Environ()\n59: \tfor k, v := range req.Env {\n60: \t\tenv = append(env, fmt.Sprintf(\"%s=%s\", k, v))\n61: \t}\n62: \tcmd.Env = env\n63: \n64: \tstartTime := time.Now()\n65: \tstdout, err := cmd.CombinedOutput()\n66: \tendTime := time.Now()\n67: \tduration := endTime.Sub(startTime)\n68: \n69: \texitCode := 0\n70: \tif err != nil {\n71: \t\tif ctx.Err() == context.DeadlineExceeded {\n72: \t\t\texitCode = TimeoutExitCode\n73: \t\t} else {\n74: \t\t\tif exitError, ok := err.(*exec.ExitError); ok {\n75: \t\t\t\texitCode = exitError.ExitCode()\n76: \t\t\t} else {\n77: \t\t\t\texitCode = 1\n78: \t\t\t}\n79: \t\t}\n80: \t}\n81: \n82: \tresponse := ExecuteResponse{\n83: \t\tStdout:    string(stdout),\n84: \t\tStderr:    \"\",\n85: \t\tExitCode:  exitCode,\n86: \t\tDuration:  duration.Seconds(),\n87: \t\tStartTime: startTime.UTC(),\n88: \t\tEndTime:   endTime.UTC(),\n89: \t}\n90: \n91: \tc.JSON(http.StatusOK, response)\n92: }\n93: \n94: func (s *Server) UploadFileHandler(c *gin.Context) {\n95: \tcontentType := c.GetHeader(HeaderContentType)\n96: \n97: \tif strings.HasPrefix(contentType, MIMEMultipart) {\n98: \t\tif err := c.Request.ParseMultipartForm(32 << 20); err != nil {\n99: \t\t\tHandleError(c, NewError(ErrInvalidCommand, \"failed to parse multipart form\", err.Error(), err))\n100: \t\t\treturn\n101: \t\t}\n102: \n103: \t\tpath := c.PostForm(\"path\")\n104: \t\tfile, header, err := c.Request.FormFile(\"file\")\n105: \t\tif err != nil {\n106: \t\t\tHandleError(c, NewError(ErrMissingPath, \"path or file form field missing\", \"\", err))\n107: \t\t\treturn\n108: \t\t}\n109: \t\tdefer file.Close()\n110: \n111: \t\tif path == \"\" {\n112: \t\t\tHandleError(c, NewError(ErrMissingPath, \"path form field missing\", \"\", nil))\n113: \t\t\treturn\n114: \t\t}\n115: \n116: \t\tmodeStr := c.PostForm(\"mode\")\n117: \t\tmode := parseFileMode(modeStr)\n118: \n119: \t\tsanitizedPath, err := s.sanitizePath(path)\n120: \t\tif err != nil {\n121: \t\t\tHandleError(c, err)\n122: \t\t\treturn\n123: \t\t}\n124: \n125: \t\tif err := os.MkdirAll(filepath.Dir(sanitizedPath), DefaultDirMode); err != nil {\n126: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to create directory\", err.Error(), err))\n127: \t\t\treturn\n128: \t\t}\n129: \n130: \t\tdst, err := os.OpenFile(sanitizedPath, os.O_WRONLY|os.O_CREATE|os.O_TRUNC, mode)\n131: \t\tif err != nil {\n132: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to create file\", err.Error(), err))\n133: \t\t\treturn\n134: \t\t}\n135: \t\tdefer dst.Close()\n136: \n137: \t\tif _, err := io.Copy(dst, file); err != nil {\n138: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to write file\", err.Error(), err))\n139: \t\t\treturn\n140: \t\t}\n141: \n142: \t\tklog.Infof(\"Uploaded file: %s (size: %d, original: %s)\", sanitizedPath, header.Size, header.Filename)\n143: \n144: \t\tfileInfo, err := s.getFileInfo(sanitizedPath)\n145: \t\tif err != nil {\n146: \t\t\tHandleError(c, err)\n147: \t\t\treturn\n148: \t\t}\n149: \n150: \t\tc.JSON(http.StatusOK, fileInfo)\n151: \t} else {\n152: \t\tvar req UploadFileRequest\n153: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n154: \t\t\tHandleError(c, NewError(ErrInvalidCommand, \"invalid request body\", err.Error(), err))\n155: \t\t\treturn\n156: \t\t}\n157: \n158: \t\tcontent, err := base64.StdEncoding.DecodeString(req.Content)\n159: \t\tif err != nil {\n160: \t\t\tHandleError(c, NewError(ErrInvalidBase64, ErrMsgInvalidBase64, err.Error(), err))\n161: \t\t\treturn\n162: \t\t}\n163: \n164: \t\tsanitizedPath, err := s.sanitizePath(req.Path)\n165: \t\tif err != nil {\n166: \t\t\tHandleError(c, err)\n167: \t\t\treturn\n168: \t\t}\n169: \n170: \t\tif err := os.MkdirAll(filepath.Dir(sanitizedPath), DefaultDirMode); err != nil {\n171: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to create directory\", err.Error(), err))\n172: \t\t\treturn\n173: \t\t}\n174: \n175: \t\tmode := parseFileMode(req.Mode)\n176: \t\tif err := os.WriteFile(sanitizedPath, content, mode); err != nil {\n177: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to write file\", err.Error(), err))\n178: \t\t\treturn\n179: \t\t}\n180: \n181: \t\tklog.Infof(\"Uploaded file: %s (size: %d)\", sanitizedPath, len(content))\n182: \n183: \t\tfileInfo, err := s.getFileInfo(sanitizedPath)\n184: \t\tif err != nil {\n185: \t\t\tHandleError(c, err)\n186: \t\t\treturn\n187: \t\t}\n188: \n189: \t\tc.JSON(http.StatusOK, fileInfo)\n190: \t}\n191: }\n192: \n193: func (s *Server) ListFilesHandler(c *gin.Context) {\n194: \tpath := c.Query(\"path\")\n195: \tif path == \"\" {\n196: \t\tHandleError(c, NewError(ErrMissingPath, ErrMsgMissingPathParam, \"\", nil))\n197: \t\treturn\n198: \t}\n199: \n200: \tsanitizedPath, err := s.sanitizePath(path)\n201: \tif err != nil {\n202: \t\tHandleError(c, err)\n203: \t\treturn\n204: \t}\n205: \n206: \tentries, err := os.ReadDir(sanitizedPath)\n207: \tif err != nil {\n208: \t\tif os.IsNotExist(err) {\n209: \t\t\tHandleError(c, NewError(ErrDirectoryNotFound, ErrMsgDirectoryNotFound, \"\", err))\n210: \t\t} else {\n211: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to read directory\", err.Error(), err))\n212: \t\t}\n213: \t\treturn\n214: \t}\n215: \n216: \tvar files []FileEntry\n217: \tfor _, entry := range entries {\n218: \t\tinfo, err := entry.Info()\n219: \t\tif err != nil {\n220: \t\t\tklog.Warningf(\"Failed to get info for %s: %v\", entry.Name(), err)\n221: \t\t\tcontinue\n222: \t\t}\n223: \n224: \t\tfiles = append(files, FileEntry{\n225: \t\t\tName:     entry.Name(),\n226: \t\t\tSize:     info.Size(),\n227: \t\t\tModified: info.ModTime(),\n228: \t\t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n229: \t\t\tIsDir:    entry.IsDir(),\n230: \t\t})\n231: \t}\n232: \n233: \tresponse := ListFilesResponse{\n234: \t\tFiles: files,\n235: \t}\n236: \n237: \tc.JSON(http.StatusOK, response)\n238: }\n239: \n240: func (s *Server) DownloadFileHandler(c *gin.Context) {\n241: \tpath := c.Param(\"path\")\n242: \tif path == \"\" {\n243: \t\tHandleError(c, NewError(ErrMissingPath, ErrMsgMissingPathParam, \"\", nil))\n244: \t\treturn\n245: \t}\n246: \n247: \tpath = strings.TrimPrefix(path, \"/\")\n248: \n249: \tsanitizedPath, err := s.sanitizePath(path)\n250: \tif err != nil {\n251: \t\tHandleError(c, err)\n252: \t\treturn\n253: \t}\n254: \n255: \tinfo, err := os.Stat(sanitizedPath)\n256: \tif err != nil {\n257: \t\tif os.IsNotExist(err) {\n258: \t\t\tHandleError(c, NewError(ErrFileNotFound, ErrMsgFileNotFound, \"\", err))\n259: \t\t} else {\n260: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to get file info\", err.Error(), err))\n261: \t\t}\n262: \t\treturn\n263: \t}\n264: \n265: \tif info.IsDir() {\n266: \t\tHandleError(c, NewError(ErrPathIsDirectory, ErrMsgPathIsDirectory, \"\", nil))\n267: \t\treturn\n268: \t}\n269: \n270: \tcontent, err := os.ReadFile(sanitizedPath)\n271: \tif err != nil {\n272: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to read file\", err.Error(), err))\n273: \t\treturn\n274: \t}\n275: \n276: \tc.Header(HeaderContentDescription, \"File Transfer\")\n277: \tc.Header(HeaderContentEncoding, \"binary\")\n278: \tc.Header(HeaderContentDisposition, fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filepath.Base(sanitizedPath)))\n279: \n280: \tmimeType := mime.TypeByExtension(filepath.Ext(sanitizedPath))\n281: \tif mimeType == \"\" {\n282: \t\tmimeType = MIMEOctetStream\n283: \t}\n284: \tc.Header(HeaderContentType, mimeType)\n285: \n286: \tc.Data(http.StatusOK, mimeType, content)\n287: }\n288: \n289: func (s *Server) HealthCheckHandler(c *gin.Context) {\n290: \tuptime := time.Since(s.startTime)\n291: \n292: \tc.JSON(http.StatusOK, gin.H{\n293: \t\t\"status\":  \"ok\",\n294: \t\t\"service\": ServiceName,\n295: \t\t\"version\": Version,\n296: \t\t\"uptime\":  uptime.String(),\n297: \t})\n298: }\n\n(End of file - total 298 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\nfunc (s *Server) ExecuteHandler(c *gin.Context) {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/handlers.go","time":{"start":1775893605123,"end":1775893605140}}}}
