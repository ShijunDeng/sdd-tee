\t\tcorrelationID := c.GetHeader(\"X-Request-ID\")\n59: \t\tif correlationID == \"\" {\n60: \t\t\tcorrelationID = uuid.New().String()\n61: \t\t\tc.Header(\"X-Request-ID\", correlationID)\n62: \t\t}\n63: \t\tc.Set(\"correlationID\", correlationID)\n64: \n65: \t\tklog.V(4).Infof(\"[%s] %s %s\", correlationID, c.Request.Method, c.Request.URL.Path)\n66: \n67: \t\tc.Next()\n68: \n69: \t\tduration := time.Since(start)\n70: \t\tklog.V(4).Infof(\"[%s] %s %s - Status: %d - Duration: %v\",\n71: \t\t\tcorrelationID,\n72: \t\t\tc.Request.Method,\n73: \t\t\tc.Request.URL.Path,\n74: \t\t\tc.Writer.Status(),\n75: \t\t\tduration,\n76: \t\t)\n77: \t}\n78: }\n79: \n80: func recoveryMiddleware() gin.HandlerFunc {\n81: \treturn func(c *gin.Context) {\n82: \t\tdefer func() {\n83: \t\t\tif err := recover(); err != nil {\n84: \t\t\t\tcorrelationID, _ := c.Get(\"correlationID\")\n85: \t\t\t\tklog.Errorf(\"[%v] Panic recovered: %v\", correlationID, err)\n86: \n87: \t\t\t\tc.JSON(http.StatusInternalServerError, NewErrorResponse(\n88: \t\t\t\t\t\"internal server error\",\n89: \t\t\t\t\t\"\",\n90: \t\t\t\t))\n91: \t\t\t\tc.Abort()\n92: \t\t\t}\n93: \t\t}()\n94: \n95: \t\tc.Next()\n96: \t}\n97: }\n98: \n99: func correlationIDMiddleware() gin.HandlerFunc {\n100: \treturn func(c *gin.Context) {\n101: \t\tcorrelationID := c.GetHeader(\"X-Request-ID\")\n102: \t\tif correlationID == \"\" {\n103: \t\t\tcorrelationID = uuid.New().String()\n104: \t\t}\n105: \n106: \t\tc.Set(\"correlationID\", correlationID)\n107: \t\tc.Header(\"X-Request-ID\", correlationID)\n108: \n109: \t\tc.Next()\n110: \t}\n111: }\n112: \n113: type Metrics struct {\n114: \trequestCount      map[string]int64\n115: \tresponseTime      map[string][]time.Duration\n116: \tactiveConnections int\n117: \tmu                sync.RWMutex\n118: }\n119: \n120: func NewMetrics() *Metrics {\n121: \treturn &Metrics{\n122: \t\trequestCount: make(map[string]int64),\n123: \t\tresponseTime: make(map[string][]time.Duration),\n124: \t}\n125: }\n126: \n127: func (m *Metrics) RecordRequest(method, path string, duration time.Duration) {\n128: \tm.mu.Lock()\n129: \tdefer m.mu.Unlock()\n130: \n131: \tkey := fmt.Sprintf(\"%s %s\", method, path)\n132: \tm.requestCount[key]++\n133: \tm.responseTime[key] = append(m.responseTime[key], duration)\n134: \n135: \tif len(m.responseTime[key]) > 1000 {\n136: \t\tm.responseTime[key] = m.responseTime[key][1:]\n137: \t}\n138: }\n139: \n140: func (m *Metrics) IncrementActiveConnections() {\n141: \tm.mu.Lock()\n142: \tdefer m.mu.Unlock()\n143: \tm.activeConnections++\n144: }\n145: \n146: func (m *Metrics) DecrementActiveConnections() {\n147: \tm.mu.Lock()\n148: \tdefer m.mu.Unlock()\n149: \tm.activeConnections--\n150: }\n151: \n152: func (m *Metrics) GetActiveConnections() int {\n153: \tm.mu.RLock()\n154: \tdefer m.mu.RUnlock()\n155: \treturn m.activeConnections\n156: }\n157: \n158: func metricsMiddleware(metrics *Metrics) gin.HandlerFunc {\n159: \treturn func(c *gin.Context) {\n160: \t\tstart := time.Now()\n161: \n162: \t\tmetrics.IncrementActiveConnections()\n163: \t\tdefer metrics.DecrementActiveConnections()\n164: \n165: \t\tc.Next()\n166: \n167: \t\tduration := time.Since(start)\n168: \t\tmetrics.RecordRequest(c.Request.Method, c.FullPath(), duration)\n169: \t}\n170: }\n171: \n172: func jwtAuthMiddleware(jwtManager *JWTManager) gin.HandlerFunc {\n173: \treturn func(c *gin.Context) {\n174: \t\tif jwtManager == nil {\n175: \t\t\tc.JSON(http.StatusUnauthorized, NewErrorResponse(\n176: \t\t\t\t\"authentication service unavailable\",\n177: \t\t\t\t\"AUTH_UNAVAILABLE\",\n178: \t\t\t))\n179: \t\t\tc.Abort()\n180: \t\t\treturn\n181: \t\t}\n182: \n183: \t\tauthHeader := c.GetHeader(\"Authorization\")\n184: \t\tif authHeader == \"\" {\n185: \t\t\tc.JSON(http.StatusUnauthorized, NewErrorResponse(\n186: \t\t\t\t\"missing authorization header\",\n187: \t\t\t\t\"MISSING_TOKEN\",\n188: \t\t\t))\n189: \t\t\tc.Abort()\n190: \t\t\treturn\n191: \t\t}\n192: \n193: \t\tconst bearerPrefix = \"Bearer \"\n194: \t\tif !strings.HasPrefix(authHeader, bearerPrefix) {\n195: \t\t\tc.JSON(http.StatusUnauthorized, NewErrorResponse(\n196: \t\t\t\t\"invalid authorization header format\",\n197: \t\t\t\t\"INVALID_TOKEN_FORMAT\",\n198: \t\t\t))\n199: \t\t\tc.Abort()\n200: \t\t\treturn\n201: \t\t}\n202: \n203: \t\ttokenString := strings.TrimPrefix(authHeader, bearerPrefix)\n204: \t\tclaims, err := jwtManager.ValidateToken(tokenString)\n205: \t\tif err != nil {\n206: \t\t\tcorrelationID, _ := c.Get(\"correlationID\")\n207: \t\t\tklog.Warningf(\"[%v] JWT validation failed: %v\", correlationID, err)\n208: \n209: \t\t\terrorCode := \"INVALID_TOKEN\"\n210: \t\t\tif strings.Contains(err.Error(), \"expired\") {\n211: \t\t\t\terrorCode = \"TOKEN_EXPIRED\"\n212: \t\t\t}\n213: \n214: \t\t\tc.JSON(http.StatusUnauthorized, NewErrorResponse(\n215: \t\t\t\t\"invalid or expired token\",\n216: \t\t\t\terrorCode,\n217: \t\t\t))\n218: \t\t\tc.Abort()\n219: \t\t\treturn\n220: \t\t}\n221: \n222: \t\tc.Set(\"sessionID\", claims.SessionID)\n223: \t\tc.Next()\n224: \t}\n225: }\n\n(End of file - total 225 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype ConcurrencyLimiter struct {\n\tsemaphore chan struct{}\n}\n\nfunc NewConcurrencyLimiter(maxConcurrent int) *ConcurrencyLimiter {\n\treturn &ConcurrencyLimiter{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/middleware.go","time":{"start":1775893564828,"end":1775893564853}}}}
{"type":"tool_use","timestamp":1775893564856,"sessionID":"ses_2847f24caffeU2hNyOZ4x5EBWx","part":{"id":"prt_d7b814d7b001kr8m96PEEfIQp8","messageID":"msg_d7b811a7800114R2VhoZXZqBHP","sessionID":"ses_2847f24caffeU2hNyOZ4x5EBWx","type":"tool","tool":"read","callID":"toolu_tool-3dbe6db239a9468786766d98d748c44a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_redis.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_redis.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"time\"\n7: \n8: \t\"github.com/redis/go-redis/v9\"\n9: \n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: type redisStore struct {\n14: \tcli                  *redis.Client\n15: \tsessionPrefix        string\n16: \texpiryIndexKey       string\n17: \tlastActivityIndexKey string\n18: }\n19: \n20: func newRedisStore(addr string, password string, db int) (Store, error) {\n21: \tcli := redis.NewClient(&redis.Options{\n22: \t\tAddr:     addr,\n23: \t\tPassword: password,\n24: \t\tDB:       db,\n25: \t})\n26: \n27: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n28: \tdefer cancel()\n29: \n30: \tif err := cli.Ping(ctx).Err(); err != nil {\n31: \t\treturn nil, fmt.Errorf(\"failed to connect to redis: %w\", err)\n32: \t}\n33: \n34: \treturn &redisStore{\n35: \t\tcli:                  cli,\n36: \t\tsessionPrefix:        \"session:\",\n37: \t\texpiryIndexKey:       \"session:expiry\",\n38: \t\tlastActivityIndexKey: \"session:last_activity\",\n39: \t}, nil\n40: }\n41: \n42: func (s *redisStore) Ping(ctx context.Context) error {\n43: \tresult := s.cli.Ping(ctx)\n44: \tif result.Err() != nil {\n45: \t\treturn result.Err()\n46: \t}\n47: \tif result.Val() != \"PONG\" {\n48: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", result.Val())\n49: \t}\n50: \treturn nil\n51: }\n52: \n53: func (s *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n54: \tkey := s.sessionPrefix + sessionID\n55: \tdata, err := s.cli.Get(ctx, key).Result()\n56: \tif err != nil {\n57: \t\tif err == redis.Nil {\n58: \t\t\treturn nil, ErrNotFound\n59: \t\t}\n60: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n61: \t}\n62: \n63: \tinfo := &types.SandboxInfo{}\n64: \tif err := unmarshalSandboxInfo(data, info); err != nil {\n65: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n66: \t}\n67: \n68: \treturn info, nil\n69: }\n70: \n71: func (s *redisStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n72: \tif sandboxStore == nil {\n73: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n74: \t}\n75: \tif sandboxStore.SessionID == \"\" {\n76: \t\treturn fmt.Errorf(\"session ID cannot be empty\")\n77: \t}\n78: \tif sandboxStore.ExpiresAt.IsZero() {\n79: \t\treturn fmt.Errorf(\"expires at cannot be zero\")\n80: \t}\n81: \n82: \tkey := s.sessionPrefix + sandboxStore.SessionID\n83: \tdata, err := marshalSandboxInfo(sandboxStore)\n84: \tif err != nil {\n85: \t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n86: \t}\n87: \n88: \tpipe := s.cli.Pipeline()\n89: \n90: \tpipe.SetNX(ctx, key, data, 0)\n91: \n92: \tpipe.ZAdd(ctx, s.expiryIndexKey, redis.Z{\n93: \t\tScore:  float64(sandboxStore.ExpiresAt.Unix()),\n94: \t\tMember: sandboxStore.SessionID,\n95: \t})\n96: \n97: \tpipe.ZAdd(ctx, s.lastActivityIndexKey, redis.Z{\n98: \t\tScore:  float64(time.Now().Unix()),\n99: \t\tMember: sandboxStore.SessionID,\n100: \t})\n101: \n102: \tif _, err := pipe.Exec(ctx); err != nil {\n103: \t\treturn fmt.Errorf(\"failed to store sandbox: %w\", err)\n104: \t}\n105: \n106: \treturn nil\n107: }\n108: \n109: func (s *redisStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n110: \tif sandboxStore == nil {\n111: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n112: \t}\n113: \tif sandboxStore.SessionID == \"\" {\n114: \t\treturn fmt.Errorf(\"session ID cannot be empty\")\n115: \t}\n116: \n117: \tkey := s.sessionPrefix + sandboxStore.SessionID\n118: \tdata, err := marshalSandboxInfo(sandboxStore)\n119: \tif err != nil {\n120: \t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n121: \t}\n122: \n123: \tresult, err := s.cli.Set(ctx, key, data, 0).Result()\n124: \tif err != nil {\n125: \t\treturn fmt.Errorf(\"failed to update sandbox: %w\", err)\n126: \t}\n127: \tif result != \"OK\" {\n128: \t\treturn ErrNotFound\n129: \t}\n130: \n131: \treturn nil\n132: }\n133: \n134: func (s *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n135: \tkey := s.sessionPrefix + sessionID\n136: \n137: \tpipe := s.cli.Pipeline()\n138: \n139: \tpipe.Del(ctx, key)\n140: \n141: \tpipe.ZRem(ctx, s.expiryIndexKey, sessionID)\n142: \n143: \tpipe.ZRem(ctx, s.lastActivityIndexKey, sessionID)\n144: \n145: \tif _, err := pipe.Exec(ctx); err != nil {\n146: \t\treturn fmt.Errorf(\"failed to delete sandbox: %w\", err)\n147: \t}\n148: \n149: \treturn nil\n150: }\n151: \n152: func (s *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n153: \tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.expiryIndexKey, &redis.ZRangeBy{\n154: \t\tMin:    \"-inf\",\n155: \t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n156: \t\tOffset: 0,\n157: \t\tCount:  limit,\n158: \t}).Result()\n159: \tif err != nil {\n160: \t\treturn nil, fmt.Errorf(\"failed to list expired sandboxes: %w\", err)\n161: \t}\n162: \n163: \treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n164: }\n165: \n166: func (s *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n167: \tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.lastActivityIndexKey, &redis.ZRangeBy{\n168: \t\tMin:    \"-inf\",\n169: \t\tMax:    fmt.Sprintf(\"%d\", before.Unix()),\n170: \t\tOffset: 0,\n171: \t\tCount:  limit,\n172: \t}).Result()\n173: \tif err != nil {\n174: \t\treturn nil, fmt.Errorf(\"failed to list inactive sandboxes: %w\", err)\n175: \t}\n176: \n177: \treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n178: }\n179: \n180: func (s *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n181: \tkey := s.sessionPrefix + sessionID\n182: \n183: \texists, err := s.cli.Exists(ctx, key).Result()\n184: \tif err != nil {\n185: \t\treturn fmt.Errorf(\"failed to check session existence: %w\", err)\n186: \t}\n187: \tif exists == 0 {\n188: \t\treturn ErrNotFound\n189: \t}\n190: \n191: \tif err := s.cli.ZAdd(ctx, s.lastActivityIndexKey, redis.Z{\n192: \t\tScore:  float64(at.Unix()),\n193: \t\tMember: sessionID,\n194: \t}).Err(); err != nil {\n195: \t\treturn fmt.Errorf(\"failed to update last activity: %w\", err)\n196: \t}\n197: \n198: \treturn nil\n199: }\n200: \n201: func (s *redisStore) Close() error {\n202: \treturn s.cli.Close()\n203: }\n204: \n205: func (s *redisStore) getSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n206: \tif len(sessionIDs) == 0 {\n207: \t\treturn []*types.SandboxInfo{}, nil\n208: \t}\n209: \n210: \tkeys := make([]string, len(sessionIDs))\n211: \tfor i, sessionID := range sessionIDs {\n212: \t\tkeys[i] = s.sessionPrefix + sessionID\n213: \t}\n214: \n215: \tvalues, err := s.cli.MGet(ctx, keys...).Result()\n216: \tif err != nil {\n217: \t\treturn nil, fmt.Errorf(\"failed to get sandbox data: %w\", err)\n218: \t}\n219: \n220: \tresult := make([]*types.SandboxInfo, 0, len(sessionIDs))\n221: \tfor _, value := range values {\n222: \t\tif value == nil {\n223: \t\t\tcontinue\n224: \t\t}\n225: \t\tdata, ok := value.(string)\n226: \t\tif !ok {\n227: \t\t\tcontinue\n228: \t\t}\n229: \n230: \t\tinfo := &types.SandboxInfo{}\n231: \t\tif err := unmarshalSandboxInfo(data, info); err != nil {\n232: \t\t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n233: \t\t}\n234: \n235: \t\tresult = append(result, info)\n236: \t}\n237: \n238: \treturn result, nil\n239: }\n\n(End of file - total 239 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/redis/go-redis/v9\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype redisStore struct {\n\tcli                  *redis.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc newRedisStore(addr string, password string, db int) (Store, error) {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_redis.go","time":{"start":1775893564830,"end":1775893564854}}}}
