t:       clientset,\n47: \t\tinformerFactory: informerFactory,\n48: \t\tresourceCache:   resourceCache,\n49: \t\tstopCh:          make(chan struct{}),\n50: \t\tresyncPeriod:    resyncPeriod,\n51: \t\tnamespace:       namespace,\n52: \t}, nil\n53: }\n54: \n55: func (im *InformerManager) Start() {\n56: \tif im.clientset == nil {\n57: \t\tklog.Info(\"Kubernetes clientset not available, informer manager not starting\")\n58: \t\treturn\n59: \t}\n60: \n61: \tklog.Info(\"Starting informer manager\")\n62: \tdefer runtime.HandleCrash()\n63: \n64: \tgo im.informerFactory.Start(im.stopCh)\n65: \n66: \tklog.Info(\"Informer manager started\")\n67: }\n68: \n69: func (im *InformerManager) Stop() {\n70: \tif im.stopCh != nil {\n71: \t\tklog.Info(\"Stopping informer manager\")\n72: \t\tclose(im.stopCh)\n73: \t\tif im.informerFactory != nil {\n74: \t\t\tim.informerFactory.Shutdown()\n75: \t\t}\n76: \t\tklog.Info(\"Informer manager stopped\")\n77: \t}\n78: }\n79: \n80: func (im *InformerManager) WaitForCacheSync(stopCh <-chan struct{}) bool {\n81: \tif im.clientset == nil {\n82: \t\treturn true\n83: \t}\n84: \n85: \tklog.Info(\"Waiting for informer caches to sync\")\n86: \n87: \tsynced := im.informerFactory.WaitForCacheSync(stopCh)\n88: \n89: \tallSynced := true\n90: \tfor _, v := range synced {\n91: \t\tif !v {\n92: \t\t\tallSynced = false\n93: \t\t\tbreak\n94: \t\t}\n95: \t}\n96: \n97: \tif allSynced {\n98: \t\tklog.Info(\"Informer caches synced successfully\")\n99: \t} else {\n100: \t\tklog.Warning(\"Informer caches failed to sync\")\n101: \t}\n102: \n103: \treturn allSynced\n104: }\n105: \n106: func (im *InformerManager) GetResourceCache() *ResourceCache {\n107: \treturn im.resourceCache\n108: }\n109: \n110: func (im *InformerManager) GetResyncPeriod() time.Duration {\n111: \treturn im.resyncPeriod\n112: }\n113: \n114: func (im *InformerManager) GetNamespace() string {\n115: \treturn im.namespace\n116: }\n117: \n118: func (im *InformerManager) IsReady() bool {\n119: \treturn im.cl