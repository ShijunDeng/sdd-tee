\n46: \n47: func TestSessionManager_InitializeInformers(t *testing.T) {\n48: \tt.Run(\"With valid clientset\", func(t *testing.T) {\n49: \t\tfakeStore := &fakeStore{}\n50: \t\tfakeClientset := fake.NewSimpleClientset()\n51: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n52: \t\tif err != nil {\n53: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n54: \t\t}\n55: \n56: \t\terr = manager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n57: \t\tif err != nil {\n58: \t\t\tt.Errorf(\"InitializeInformers returned error: %v\", err)\n59: \t\t}\n60: \t})\n61: \n62: \tt.Run(\"With nil clientset\", func(t *testing.T) {\n63: \t\tfakeStore := &fakeStore{}\n64: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n65: \t\tif err != nil {\n66: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n67: \t\t}\n68: \n69: \t\terr = manager.InitializeInformers(nil, \"default\", 10*time.Minute)\n70: \t\tif err != nil {\n71: \t\t\tt.Errorf(\"InitializeInformers with nil clientset should not return error: %v\", err)\n72: \t\t}\n73: \t})\n74: }\n75: \n76: func TestSessionManager_StartInformers(t *testing.T) {\n77: \tfakeStore := &fakeStore{}\n78: \tfakeClientset := fake.NewSimpleClientset()\n79: \tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n80: \tif err != nil {\n81: \t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n82: \t}\n83: \n84: \tmanager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n85: \tmanager.StartInformers()\n86: \n87: \ttime.Sleep(50 * time.Millisecond)\n88: }\n89: \n90: func TestSessionManager_StopInformers(t *testing.T) {\n91: \tfakeStore := &fakeStore{}\n92: \tfakeClientset := fake.NewSimpleClientset()\n93: \tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n94: \tif err != nil {\n95: \t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n96: \t}\n97: \n98: \tmanager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n99: \tmanager.StartInformers()\n100: \ttime.Sleep(50 * time.Millisecond)\n101: \tmanager.StopInformers()\n102: }\n103: \n104: func TestSessionManager_WaitForCacheSync(t *testing.T) {\n105: \tt.Run(\"With informers\", func(t *testing.T) {\n106: \t\tfakeStore := &fakeStore{}\n107: \t\tfakeClientset := fake.NewSimpleClientset()\n108: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n109: \t\tif err != nil {\n110: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n111: \t\t}\n112: \n113: \t\tmanager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n114: \t\tmanager.StartInformers()\n115: \n116: \t\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n117: \t\tdefer cancel()\n118: \n119: \t\tsynced := manager.WaitForCacheSync(ctx)\n120: \t\tif !synced {\n121: \t\t\tt.Error(\"Informers should sync successfully\")\n122: \t\t}\n123: \n124: \t\tmanager.StopInformers()\n125: \t})\n126: \n127: \tt.Run(\"Without informers\", func(t *testing.T) {\n128: \t\tfakeStore := &fakeStore{}\n129: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n130: \t\tif err != nil {\n131: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n132: \t\t}\n133: \n134: \t\tsynced := manager.WaitForCacheSync(context.Background())\n135: \t\tif !synced {\n136: \t\t\tt.Error(\"WaitForCacheSync should return true when informers are not initialized\")\n137: \t\t}\n138: \t})\n139: }\n140: \n141: func TestSessionManager_CreateSession(t *testing.T) {\n142: \tt.Run(\"Valid session creation\", func(t *testing.T) {\n143: \t\tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n144: \t\t\tif r.Method == http.MethodPost && r.URL.Path == \"/v1/agent-runtime\" {\n145: \t\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n146: \t\t\t\tw.WriteHeader(http.StatusOK)\n147: \t\t\t\tw.Write([]byte(`{\n148: \t\t\t\t\t\"sessionId\": \"test-session-id\",\n149: \t\t\t\t\t\"sandboxId\": \"test-sandbox-id\",\n150: \t\t\t\t\t\"sandboxName\": \"test-sandbox\",\n151: \t\t\t\t\t\"entryPoints\": []\n152: \t\t\t\t}`))\n153: \t\t\t} else if r.Method == http.MethodGet && r.URL.Path == \"/v1/session/test-session-id\" {\n154: \t\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n155: \t\t\t\tw.WriteHeader(http.StatusOK)\n156: \t\t\t\tw.Write([]byte(`{\n157: \t\t\t\t\t\"sessionId\": \"test-session-id\",\n158: \t\t\t\t\t\"sandboxId\": \"test-sandbox-id\",\n159: \t\t\t\t\t\"sandboxName\": \"test-sandbox\",\n160: \t\t\t\t\t\"kind\": \"AgentRuntime\",\n161: \t\t\t\t\t\"name\": \"test\",\n162: \t\t\t\t\t\"namespace\": \"default\",\n163: \t\t\t\t\t\"entryPoints\": [],\n164: \t\t\t\t\t\"lastActivity\": \"` + time.Now().Format(time.RFC3339) + `\",\n165: \t\t\t\t\t\"createdAt\": \"` + time.Now().Format(time.RFC3339) + `\",\n166: \t\t\t\t\t\"expiresAt\": \"` + time.Now().Add(8*time.Hour).Format(time.RFC3339) + `\"\n167: \t\t\t\t}`))\n168: \t\t\t} else {\n169: \t\t\t\tt.Errorf(\"Unexpected request: %s %s\", r.Method, r.URL.Path)\n170: \t\t\t\tw.WriteHeader(http.StatusNotFound)\n171: \t\t\t}\n172: \t\t}))\n173: \t\tdefer server.Close()\n174: \n175: \t\tfakeStore := &fakeStore{}\n176: \t\tmanager, err := NewSessionManager(fakeStore, server.URL)\n177: \t\tif err != nil {\n178: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n179: \t\t}\n180: \n181: \t\tsessionID, sandboxInfo, err := manager.CreateSession(context.Background(), \"test\", \"default\", types.AgentRuntimeKind)\n182: \t\tif err != nil {\n183: \t\t\tt.Errorf(\"CreateSession returned error: %v\", err)\n184: \t\t}\n185: \n186: \t\tif sessionID == \"\" {\n187: \t\t\tt.Error(\"Expected non-empty session ID\")\n188: \t\t}\n189: \n190: \t\tif sandboxInfo == nil {\n191: \t\t\tt.Error(\"Expected non-nil sandbox info\")\n192: \t\t}\n193: \t})\n194: \n195: \tt.Run(\"Invalid kind\", func(t *testing.T) {\n196: \t\tfakeStore := &fakeStore{}\n197: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n198: \t\tif err != nil {\n199: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n200: \t\t}\n201: \n202: \t\t_, _, err = manager.CreateSession(context.Background(), \"test\", \"default\", \"InvalidKind\")\n203: \t\tif err == nil {\n204: \t\t\tt.Error(\"Expected error for invalid kind\")\n205: \t\t}\n206: \t})\n207: \n208: \tt.Run(\"Invalid namespace\", func(t *testing.T) {\n209: \t\tfakeStore := &fakeStore{}\n210: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n211: \t\tif err != nil {\n212: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n213: \t\t}\n214: \n215: \t\t_, _, err = manager.CreateSession(context.Background(), \"test\", \"INVALID_NAMESPACE\", types.AgentRuntimeKind)\n216: \t\tif err == nil {\n217: \t\t\tt.Error(\"Expected error for invalid namespace\")\n218: \t\t}\n219: \t})\n220: \n221: \tt.Run(\"Invalid resource name\", func(t *testing.T) {\n222: \t\tfakeStore := &fakeStore{}\n223: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n224: \t\tif err != nil {\n225: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n226: \t\t}\n227: \n228: \t\t_, _, err = manager.CreateSession(context.Background(), \"INVALID_NAME\", \"default\", types.AgentRuntimeKind)\n229: \t\tif err == nil {\n230: \t\t\tt.Error(\"Expected error for invalid resource name\")\n231: \t\t}\n232: \t})\n233: \n234: \tt.Run(\"Workload manager error\", func(t *testing.T) {\n235: \t\tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n236: \t\t\tw.WriteHeader(http.StatusInternalServerError)\n237: \t\t\tw.Write([]byte(`{\"error\": \"internal server error\"}`))\n238: \t\t}))\n239: \t\tdefer server.Close()\n240: \n241: \t\tfakeStore := &fakeStore{}\n242: \t\tmanager, err := NewSessionManager(fakeStore, server.URL)\n243: \t\tif err != nil {\n244: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n245: \t\t}\n246: \n247: \t\t_, _, err = manager.CreateSession(context.Background(), \"test\", \"default\", types.AgentRuntimeKind)\n248: \t\tif err == nil {\n249: \t\t\tt.Error(\"Expected error from workload manager\")\n250: \t\t}\n251: \t})\n252: }\n253: \n254: func TestSessionManager_GetSandboxBySession(t *testing.T) {\n255: \tt.Run(\"Cache hit\", func(t *testing.T) {\n256: \t\texpectedSandbox := &types.SandboxInfo{\n257: \t\t\tSessionID: \"test-session-id\",\n258: \t\t\tName:      \"test\",\n259: \t\t\tNamespace: \"default\",\n260: \t\t\tKind:      types.AgentRuntimeKind,\n261: \t\t\tStatus:    \"Ready\",\n262: \t\t}\n263: \n264: \t\tfakeStore := &fakeStore{\n265: \t\t\tsandboxes: map[string]*types.SandboxInfo{\n266: \t\t\t\t\"test-session-id\": expectedSandbox,\n267: \t\t\t},\n268: \t\t}\n269: \n270: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n271: \t\tif err != nil {\n272: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n273: \t\t}\n274: \n275: \t\terr = manager.InitializeInformers(nil, \"default\", 10*time.Minute)\n276: \t\tif err != nil {\n277: \t\t\tt.Fatalf(\"InitializeInformers returned error: %v\", err)\n278: \t\t}\n279: \n280: \t\tsandboxInfo, err := manager.GetSandboxBySession(context.Background(), \"test-session-id\", \"default\", \"test\", types.AgentRuntimeKind)\n281: \t\tif err != nil {\n282: \t\t\tt.Errorf(\"GetSandboxBySession returned error: %v\", err)\n283: \t\t}\n284: \n285: \t\tif sandboxInfo == nil {\n286: \t\t\tt.Fatal(\"Expected non-nil sandbox info\")\n287: \t\t}\n288: \n289: \t\tif sandboxInfo.SessionID != expectedSandbox.SessionID {\n290: \t\t\tt.Errorf(\"Expected session ID '%s', got '%s'\", expectedSandbox.SessionID, sandboxInfo.SessionID)\n291: \t\t}\n292: \t})\n293: \n294: \tt.Run(\"Cache miss\", func(t *testing.T) {\n295: \t\tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n296: \t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n297: \t\t\tw.WriteHeader(http.StatusOK)\n298: \t\t\tw.Write([]byte(`{\n299: \t\t\t\t\"sessionId\": \"test-session-id\",\n300: \t\t\t\t\"sandboxId\": \"test-sandbox-id\",\n301: \t\t\t\t\"sandboxName\": \"test-sandbox\",\n302: \t\t\t\t\"kind\": \"AgentRuntime\",\n303: \t\t\t\t\"name\": \"test\",\n304: \t\t\t\t\"namespace\": \"default\",\n305: \t\t\t\t\"entryPoints\": [],\n306: \t\t\t\t\"lastActivity\": \"` + time.Now().Format(time.RFC3339) + `\",\n307: \t\t\t\t\"createdAt\": \"` + time.Now().Format(time.RFC3339) + `\",\n308: \t\t\t\t\"expiresAt\": \"` + time.Now().Add(8*time.Hour).Format(time.RFC3339) + `\"\n309: \t\t\t}`))\n310: \t\t}))\n311: \t\tdefer server.Close()\n312: \n313: \t\tfakeStore := &fakeStore{}\n314: \t\tmanager, err := NewSessionManager(fakeStore, server.URL)\n315: \t\tif err != nil {\n316: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n317: \t\t}\n318: \n319: \t\tsandboxInfo, err := manager.GetSandboxBySession(context.Background(), \"test-session-id\", \"default\", \"test\", types.AgentRuntimeKind)\n320: \t\tif err != nil {\n321: \t\t\tt.Errorf(\"GetSandboxBySession returned error: %v\", err)\n322: \t\t}\n323: \n324: \t\tif sandboxInfo == nil {\n325: \t\t\tt.Fatal(\"Expected non-nil sandbox info\")\n326: \t\t}\n327: \n328: \t\tif sandboxInfo.SessionID != \"test-session-id\" {\n329: \t\t\tt.Errorf(\"Expected session ID 'test-session-id', got '%s'\", sandboxInfo.SessionID)\n330: \t\t}\n331: \t})\n332: \n333: \tt.Run(\"Session not found\", func(t *testing.T) {\n334: \t\tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n335: \t\t\tw.WriteHeader(http.StatusNotFound)\n336: \t\t\tw.Write([]byte(`{\"error\": \"session not found\"}`))\n337: \t\t}))\n338: \t\tdefer server.Close()\n339: \n340: \t\tfakeStore := &fakeStore{}\n341: \t\tmanager, err := NewSessionManager(fakeStore, server.URL)\n342: \t\tif err != nil {\n343: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n344: \t\t}\n345: \n346: \t\t_, err = manager.GetSandboxBySession(context.Background(), \"nonexistent-session\", \"default\", \"test\", types.AgentRuntimeKind)\n347: \t\tif err == nil {\n348: \t\t\tt.Error(\"Expected error for non-existent session\")\n349: \t\t}\n350: \n351: \t\tvar notFoundErr *SandboxNotFoundError\n352: \t\tif !errors.As(err, &notFoundErr) {\n353: \t\t\tt.Errorf(\"Expected SandboxNotFoundError, got %T\", err)\n354: \t\t}\n355: \t})\n356: }\n357: \n358: func TestSessionManager_ListSessions(t *testing.T) {\n359: \texpectedSandboxes := map[string]*types.SandboxInfo{\n360: \t\t\"session-1\": {\n361: \t\t\tSessionID: \"session-1\",\n362: \t\t\tName:      \"test-1\",\n363: \t\t\tNamespace: \"default\",\n364: \t\t\tKind:      types.AgentRuntimeKind,\n365: \t\t},\n366: \t\t\"session-2\": {\n367: \t\t\tSessionID: \"session-2\",\n368: \t\t\tName:      \"test-2\",\n369: \t\t\tNamespace: \"default\",\n370: \t\t\tKind:      types.CodeInterpreterKind,\n371: \t\t},\n372: \t}\n373: \n374: \tfakeStore := &fakeStore{\n375: \t\tsandboxes: expectedSandboxes,\n376: \t}\n377: \n378: \tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n379: \tif err != nil {\n380: \t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n381: \t}\n382: \n383: \tsessions, err := manager.ListSessions(context.Background())\n384: \tif err != nil {\n385: \t\tt.Errorf(\"ListSessions returned error: %v\", err)\n386: \t}\n387: \n388: \tif len(sessions) != len(expectedSandboxes) {\n389: \t\tt.Errorf(\"Expected %d sessions, got %d\", len(expectedSandboxes), len(sessions))\n390: \t}\n391: }\n392: \n393: func TestIsResourceReady(t *testing.T) {\n394: \tt.Run(\"Ready condition true\", func(t *testing.T) {\n395: \t\tconditions := []metav1.Condition{\n396: \t\t\t{\n397: \t\t\t\tType:   \"Ready\",\n398: \t\t\t\tStatus: metav1.ConditionTrue,\n399: \t\t\t},\n400: \t\t}\n401: \n402: \t\tif !isResourceReady(conditions) {\n403: \t\t\tt.Error(\"Expected resource to be ready\")\n404: \t\t}\n405: \t})\n406: \n407: \tt.Run(\"Ready condition false\", func(t *testing.T) {\n408: \t\tconditions := []metav1.Condition{\n409: \t\t\t{\n410: \t\t\t\tType:   \"Ready\",\n411: \t\t\t\tStatus: metav1.ConditionFalse,\n412: \t\t\t},\n413: \t\t}\n414: \n415: \t\tif isResourceReady(conditions) {\n416: \t\t\tt.Error(\"Expected resource not to be ready\")\n417: \t\t}\n418: \t})\n419: \n420: \tt.Run(\"No conditions\", func(t *testing.T) {\n421: \t\tconditions := []metav1.Condition{}\n422: \n423: \t\tif isResourceReady(conditions) {\n424: \t\t\tt.Error(\"Expected resource not to be ready with no conditions\")\n425: \t\t}\n426: \t})\n427: \n428: \tt.Run(\"Other conditions\", func(t *testing.T) {\n429: \t\tconditions := []metav1.Condition{\n430: \t\t\t{\n431: \t\t\t\tType:   \"Other\",\n432: \t\t\t\tStatus: metav1.ConditionTrue,\n433: \t\t\t},\n434: \t\t}\n435: \n436: \t\tif isResourceReady(conditions) {\n437: \t\t\tt.Error(\"Expected resource not to be ready with other conditions\")\n438: \t\t}\n439: \t})\n440: }\n441: \n442: func TestIsResourceBeingDeleted(t *testing.T) {\n443: \tt.Run(\"Not being deleted\", func(t *testing.T) {\n444: \t\tobj := &metav1.ObjectMeta{\n445: \t\t\tName:              \"test\",\n446: \t\t\tDeletionTimestamp: nil,\n447: \t\t}\n448: \n449: \t\tif isResourceBeingDeleted(obj) {\n450: \t\t\tt.Error(\"Expected resource not to be deleted\")\n451: \t\t}\n452: \t})\n453: \n454: \tt.Run(\"Being deleted\", func(t *testing.T) {\n455: \t\tnow := metav1.Now()\n456: \t\tobj := &metav1.ObjectMeta{\n457: \t\t\tName:              \"test\",\n458: \t\t\tDeletionTimestamp: &now,\n459: \t\t}\n460: \n461: \t\tif !isResourceBeingDeleted(obj) {\n462: \t\t\tt.Error(\"Expected resource to be deleted\")\n463: \t\t}\n464: \t})\n465: }\n466: \n467: func TestConditionsChanged(t *testing.T) {\n468: \tt.Run(\"Same conditions\", func(t *testing.T) {\n469: \t\toldConditions := []metav1.Condition{\n470: \t\t\t{\n471: \t\t\t\tType:   \"Ready\",\n472: \t\t\t\tStatus: metav1.ConditionTrue,\n473: \t\t\t\tReason: \"Ready\",\n474: \t\t\t},\n475: \t\t}\n476: \n477: \t\tnewConditions := []metav1.Condition{\n478: \t\t\t{\n479: \t\t\t\tType:   \"Ready\",\n480: \t\t\t\tStatus: metav1.ConditionTrue,\n481: \t\t\t\tReason: \"Ready\",\n482: \t\t\t},\n483: \t\t}\n484: \n485: \t\tif conditionsChanged(oldConditions, newConditions) {\n486: \t\t\tt.Error(\"Expected conditions not to have changed\")\n487: \t\t}\n488: \t})\n489: \n490: \tt.Run(\"Different status\", func(t *testing.T) {\n491: \t\toldConditions := []metav1.Condition{\n492: \t\t\t{\n493: \t\t\t\tType:   \"Ready\",\n494: \t\t\t\tStatus: metav1.ConditionTrue,\n495: \t\t\t\tReason: \"Ready\",\n496: \t\t\t},\n497: \t\t}\n498: \n499: \t\tnewConditions := []metav1.Condition{\n500: \t\t\t{\n501: \t\t\t\tType:   \"Ready\",\n502: \t\t\t\tStatus: metav1.ConditionFalse,\n503: \t\t\t\tReason: \"NotReady\",\n504: \t\t\t},\n505: \t\t}\n506: \n507: \t\tif !conditionsChanged(oldConditions, newConditions) {\n508: \t\t\tt.Error(\"Expected conditions to have changed\")\n509: \t\t}\n510: \t})\n511: \n512: \tt.Run(\"Different length\", func(t *testing.T) {\n513: \t\toldConditions := []metav1.Condition{\n514: \t\t\t{\n515: \t\t\t\tType:   \"Ready\",\n516: \t\t\t\tStatus: metav1.ConditionTrue,\n517: \t\t\t},\n518: \t\t}\n519: \n520: \t\tnewConditions := []metav1.Condition{\n521: \t\t\t{\n522: \t\t\t\tType:   \"Ready\",\n523: \t\t\t\tStatus: metav1.ConditionTrue,\n524: \t\t\t},\n525: \t\t\t{\n526: \t\t\t\tType:   \"Available\",\n527: \t\t\t\tStatus: metav1.ConditionTrue,\n528: \t\t\t},\n529: \t\t}\n530: \n531: \t\tif !conditionsChanged(oldConditions, newConditions) {\n532: \t\t\tt.Error(\"Expected conditions to have changed\")\n533: \t\t}\n534: \t})\n535: }\n536: \n537: func TestGetResourceStatus(t *testing.T) {\n538: \tt.Run(\"Ready condition true\", func(t *testing.T) {\n539: \t\tconditions := []metav1.Condition{\n540: \t\t\t{\n541: \t\t\t\tType:   \"Ready\",\n542: \t\t\t\tStatus: metav1.ConditionTrue,\n543: \t\t\t},\n544: \t\t}\n545: \n546: \t\tstatus := GetResourceStatus(conditions)\n547: \t\tif status != \"Ready\" {\n548: \t\t\tt.Errorf(\"Expected status 'Ready', got '%s'\", status)\n549: \t\t}\n550: \t})\n551: \n552: \tt.Run(\"Ready condition false with reason\", func(t *testing.T) {\n553: \t\tconditions := []metav1.Condition{\n554: \t\t\t{\n555: \t\t\t\tType:   \"Ready\",\n556: \t\t\t\tStatus: metav1.ConditionFalse,\n557: \t\t\t\tReason: \"NotReady\",\n558: \t\t\t},\n559: \t\t}\n560: \n561: \t\tstatus := GetResourceStatus(conditions)\n562: \t\tif status != \"NotReady\" {\n563: \t\t\tt.Errorf(\"Expected status 'NotReady', got '%s'\", status)\n564: \t\t}\n565: \t})\n566: \n567: \tt.Run(\"No conditions\", func(t *testing.T) {\n568: \t\tconditions := []metav1.Condition{}\n569: \n570: \t\tstatus := GetResourceStatus(conditions)\n571: \t\tif status != \"Unknown\" {\n572: \t\t\tt.Errorf(\"Expected status 'Unknown', got '%s'\", status)\n573: \t\t}\n574: \t})\n575: }\n576: \n577: type fakeStore struct {\n578: \tsandboxes map[string]*types.SandboxInfo\n579: }\n580: \n581: func (fs *fakeStore) Ping(ctx context.Context) error {\n582: \treturn nil\n583: }\n584: \n585: func (fs *fakeStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n586: \tif fs.sandboxes == nil {\n587: \t\treturn nil, store.ErrNotFound\n588: \t}\n589: \n590: \tsandbox, exists := fs.sandboxes[sessionID]\n591: \tif !exists {\n592: \t\treturn nil, store.ErrNotFound\n593: \t}\n594: \n595: \treturn sandbox, nil\n596: }\n597: \n598: func (fs *fakeStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n599: \tif fs.sandboxes == nil {\n600: \t\tfs.sandboxes = make(map[string]*types.SandboxInfo)\n601: \t}\n602: \n603: \tfs.sandboxes[sessionID] = info\n604: \treturn nil\n605: }\n606: \n607: func (fs *fakeStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n608: \treturn fs.StoreSandbox(ctx, sessionID, info)\n609: }\n610: \n611: func (fs *fakeStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n612: \tif fs.sandboxes == nil {\n613: \t\treturn nil\n614: \t}\n615: \n616: \tdelete(fs.sandboxes, sessionID)\n617: \treturn nil\n618: }\n619: \n620: func (fs *fakeStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n621: \tif fs.sandboxes == nil {\n622: \t\treturn make(map[string]*types.SandboxInfo), nil\n623: \t}\n624: \n625: \treturn fs.sandboxes, nil\n626: }\n627: \n628: func (fs *fakeStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n629: \treturn nil\n630: }\n631: \n632: func (fs *fakeStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n633: \treturn nil, nil\n634: }\n635: \n636: func (fs *fakeStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n637: \treturn nil, nil\n638: }\n639: \n640: func (fs *fakeStore) Close() error {\n641: \treturn nil\n642: }\n\n(End of file - total 642 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\nfunc TestNewSessionManager(t *testing.T) {\n\tt.Run(\"Valid parameters\", func(t *testing.T) {\n\t\tfakeStore := &fakeStore{}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/session_manager_test.go","time":{"start":1775893577898,"end":1775893577916}}}}
{"type":"tool_use","timestamp":1775893577920,"sessionID":"ses_2847f24caffeU2hNyOZ4x5EBWx","part":{"id":"prt_d7b817bb5001nEzK9KoRbiGnBp","messageID":"msg_d7b814df9001DhxA9zVidFAQnS","sessionID":"ses_2847f24caffeU2hNyOZ4x5EBWx","type":"tool","tool":"read","callID":"toolu_tool-6fdf0527cfbd4555a57e644694b9ffcd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_test.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"os\"\n6: \t\"testing\"\n7: \t\"time\"\n8: \n9: \t\"github.com/alicebob/miniredis/v2\"\n10: \t\"github.com/stretchr/testify/assert\"\n11: \t\"github.com/stretchr/testify/require\"\n12: \n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: )\n15: \n16: func TestRedisStore(t *testing.T) {\n17: \ts := miniredis.RunT(t)\n18: \n19: \tstore, err := newRedisStore(s.Addr(), \"\", 0)\n20: \trequire.NoError(t, err)\n21: \trequire.NotNil(t, store)\n22: \n23: \tdefer store.Close()\n24: \n25: \tctx := context.Background()\n26: \n27: \tt.Run(\"Ping\", func(t *testing.T) {\n28: \t\terr := store.Ping(ctx)\n29: \t\tassert.NoError(t, err)\n30: \t})\n31: \n32: \tt.Run(\"Store and Get Sandbox\", func(t *testing.T) {\n33: \t\tsessionID := \"test-session-1\"\n34: \t\tinfo := &types.SandboxInfo{\n35: \t\t\tSessionID:    sessionID,\n36: \t\t\tSandboxName:  \"test-sandbox\",\n37: \t\t\tWorkloadName: \"test-workload\",\n38: \t\t\tNamespace:    \"default\",\n39: \t\t\tKind:         \"AgentRuntime\",\n40: \t\t\tStatus:       \"running\",\n41: \t\t\tCreatedAt:    time.Now(),\n42: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n43: \t\t\tPodIP:        \"10.0.0.1\",\n44: \t\t}\n45: \n46: \t\terr := store.StoreSandbox(ctx, info)\n47: \t\trequire.NoError(t, err)\n48: \n49: \t\tretrieved, err := store.GetSandboxBySessionID(ctx, sessionID)\n50: \t\trequire.NoError(t, err)\n51: \t\tassert.Equal(t, sessionID, retrieved.SessionID)\n52: \t\tassert.Equal(t, \"test-sandbox\", retrieved.SandboxName)\n53: \t\tassert.Equal(t, \"AgentRuntime\", retrieved.Kind)\n54: \t})\n55: \n56: \tt.Run(\"Store Sandbox Nil\", func(t *testing.T) {\n57: \t\terr := store.StoreSandbox(ctx, nil)\n58: \t\tassert.Error(t, err)\n59: \t\tassert.Contains(t, err.Error(), \"cannot be nil\")\n60: \t})\n61: \n62: \tt.Run(\"Store Sandbox Empty SessionID\", func(t *testing.T) {\n63: \t\tinfo := &types.SandboxInfo{\n64: \t\t\tSandboxName: \"test-sandbox\",\n65: \t\t\tCreatedAt:   time.Now(),\n66: \t\t\tExpiresAt:   time.Now().Add(8 * time.Hour),\n67: \t\t}\n68: \n69: \t\terr := store.StoreSandbox(ctx, info)\n70: \t\tassert.Error(t, err)\n71: \t\tassert.Contains(t, err.Error(), \"session ID cannot be empty\")\n72: \t})\n73: \n74: \tt.Run(\"Store Sandbox Zero ExpiresAt\", func(t *testing.T) {\n75: \t\tinfo := &types.SandboxInfo{\n76: \t\t\tSessionID:   \"test-session\",\n77: \t\t\tSandboxName: \"test-sandbox\",\n78: \t\t\tCreatedAt:   time.Now(),\n79: \t\t}\n80: \n81: \t\terr := store.StoreSandbox(ctx, info)\n82: \t\tassert.Error(t, err)\n83: \t\tassert.Contains(t, err.Error(), \"expires at cannot be zero\")\n84: \t})\n85: \n86: \tt.Run(\"Get Non-Existent Sandbox\", func(t *testing.T) {\n87: \t\t_, err := store.GetSandboxBySessionID(ctx, \"non-existent\")\n88: \t\tassert.Error(t, err)\n89: \t\tassert.Equal(t, ErrNotFound, err)\n90: \t})\n91: \n92: \tt.Run(\"Update Sandbox\", func(t *testing.T) {\n93: \t\tsessionID := \"test-session-2\"\n94: \t\tinfo := &types.SandboxInfo{\n95: \t\t\tSessionID:    sessionID,\n96: \t\t\tSandboxName:  \"test-sandbox-2\",\n97: \t\t\tWorkloadName: \"test-workload\",\n98: \t\t\tNamespace:    \"default\",\n99: \t\t\tKind:         \"CodeInterpreter\",\n100: \t\t\tStatus:       \"pending\",\n101: \t\t\tCreatedAt:    time.Now(),\n102: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n103: \t\t}\n104: \n105: \t\terr := store.StoreSandbox(ctx, info)\n106: \t\trequire.NoError(t, err)\n107: \n108: \t\tinfo.Status = \"running\"\n109: \t\tinfo.PodIP = \"10.0.0.2\"\n110: \n111: \t\terr = store.UpdateSandbox(ctx, info)\n112: \t\trequire.NoError(t, err)\n113: \n114: \t\tretrieved, err := store.GetSandboxBySessionID(ctx, sessionID)\n115: \t\trequire.NoError(t, err)\n116: \t\tassert.Equal(t, \"running\", retrieved.Status)\n117: \t\tassert.Equal(t, \"10.0.0.2\", retrieved.PodIP)\n118: \t})\n119: \n120: \tt.Run(\"Update Non-Existent Sandbox\", func(t *testing.T) {\n121: \t\tinfo := &types.SandboxInfo{\n122: \t\t\tSessionID:   \"non-existent\",\n123: \t\t\tSandboxName: \"test-sandbox\",\n124: \t\t\tCreatedAt:   time.Now(),\n125: \t\t\tExpiresAt:   time.Now().Add(8 * time.Hour),\n126: \t\t}\n127: \n128: \t\terr := store.UpdateSandbox(ctx, info)\n129: \t\tassert.Error(t, err)\n130: \t\tassert.Equal(t, ErrNotFound, err)\n131: \t})\n132: \n133: \tt.Run(\"Update Sandbox Nil\", func(t *testing.T) {\n134: \t\terr := store.UpdateSandbox(ctx, nil)\n135: \t\tassert.Error(t, err)\n136: \t\tassert.Contains(t, err.Error(), \"cannot be nil\")\n137: \t})\n138: \n139: \tt.Run(\"Update Sandbox Empty SessionID\", func(t *testing.T) {\n140: \t\tinfo := &types.SandboxInfo{\n141: \t\t\tSandboxName: \"test-sandbox\",\n142: \t\t\tCreatedAt:   time.Now(),\n143: \t\t\tExpiresAt:   time.Now().Add(8 * time.Hour),\n144: \t\t}\n145: \n146: \t\terr := store.UpdateSandbox(ctx, info)\n147: \t\tassert.Error(t, err)\n148: \t\tassert.Contains(t, err.Error(), \"session ID cannot be empty\")\n149: \t})\n150: \n151: \tt.Run(\"Delete Sandbox\", func(t *testing.T) {\n152: \t\tsessionID := \"test-session-3\"\n153: \t\tinfo := &types.SandboxInfo{\n154: \t\t\tSessionID:    sessionID,\n155: \t\t\tSandboxName:  \"test-sandbox-3\",\n156: \t\t\tWorkloadName: \"test-workload\",\n157: \t\t\tNamespace:    \"default\",\n158: \t\t\tKind:         \"AgentRuntime\",\n159: \t\t\tStatus:       \"running\",\n160: \t\t\tCreatedAt:    time.Now(),\n161: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n162: \t\t}\n163: \n164: \t\terr := store.StoreSandbox(ctx, info)\n165: \t\trequire.NoError(t, err)\n166: \n167: \t\terr = store.DeleteSandboxBySessionID(ctx, sessionID)\n168: \t\trequire.NoError(t, err)\n169: \n170: \t\t_, err = store.GetSandboxBySessionID(ctx, sessionID)\n171: \t\tassert.Error(t, err)\n172: \t\tassert.Equal(t, ErrNotFound, err)\n173: \t})\n174: \n175: \tt.Run(\"Update Session Last Activity\", func(t *testing.T) {\n176: \t\tsessionID := \"test-session-4\"\n177: \t\tinfo := &types.SandboxInfo{\n178: \t\t\tSessionID:    sessionID,\n179: \t\t\tSandboxName:  \"test-sandbox-4\",\n180: \t\t\tWorkloadName: \"test-workload\",\n181: \t\t\tNamespace:    \"default\",\n182: \t\t\tKind:         \"AgentRuntime\",\n183: \t\t\tStatus:       \"running\",\n184: \t\t\tCreatedAt:    time.Now().Add(-1 * time.Hour),\n185: \t\t\tExpiresAt:    time.Now().Add(7 * time.Hour),\n186: \t\t}\n187: \n188: \t\terr := store.StoreSandbox(ctx, info)\n189: \t\trequire.NoError(t, err)\n190: \n191: \t\tnewActivityTime := time.Now()\n192: \t\terr = store.UpdateSessionLastActivity(ctx, sessionID, newActivityTime)\n193: \t\trequire.NoError(t, err)\n194: \n195: \t\tretrieved, err := store.GetSandboxBySessionID(ctx, sessionID)\n196: \t\trequire.NoError(t, err)\n197: \t\tassert.WithinDuration(t, newActivityTime, retrieved.LastActivityAt, time.Second)\n198: \t})\n199: \n200: \tt.Run(\"Update Session Last Activity Non-Existent\", func(t *testing.T) {\n201: \t\terr := store.UpdateSessionLastActivity(ctx, \"non-existent\", time.Now())\n202: \t\tassert.Error(t, err)\n203: \t\tassert.Equal(t, ErrNotFound, err)\n204: \t})\n205: \n206: \tt.Run(\"List Expired Sandboxes\", func(t *testing.T) {\n207: \t\tsessionID1 := \"expired-session-1\"\n208: \t\tsessionID2 := \"expired-session-2\"\n209: \t\tsessionID3 := \"active-session\"\n210: \n211: \t\tnow := time.Now()\n212: \n213: \t\texpiredInfo1 := &types.SandboxInfo{\n214: \t\t\tSessionID:    sessionID1,\n215: \t\t\tSandboxName:  \"expired-1\",\n216: \t\t\tWorkloadName: \"test\",\n217: \t\t\tNamespace:    \"default\",\n218: \t\t\tKind:         \"AgentRuntime\",\n219: \t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n220: \t\t\tExpiresAt:    now.Add(-1 * time.Hour),\n221: \t\t}\n222: \n223: \t\texpiredInfo2 := &types.SandboxInfo{\n224: \t\t\tSessionID:    sessionID2,\n225: \t\t\tSandboxName:  \"expired-2\",\n226: \t\t\tWorkloadName: \"test\",\n227: \t\t\tNamespace:    \"default\",\n228: \t\t\tKind:         \"AgentRuntime\",\n229: \t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n230: \t\t\tExpiresAt:    now.Add(-30 * time.Minute),\n231: \t\t}\n232: \n233: \t\tactiveInfo := &types.SandboxInfo{\n234: \t\t\tSessionID:    sessionID3,\n235: \t\t\tSandboxName:  \"active\",\n236: \t\t\tWorkloadName: \"test\",\n237: \t\t\tNamespace:    \"default\",\n238: \t\t\tKind:         \"AgentRuntime\",\n239: \t\t\tCreatedAt:    now,\n240: \t\t\tExpiresAt:    now.Add(8 * time.Hour),\n241: \t\t}\n242: \n243: \t\trequire.NoError(t, store.StoreSandbox(ctx, expiredInfo1))\n244: \t\trequire.NoError(t, store.StoreSandbox(ctx, expiredInfo2))\n245: \t\trequire.NoError(t, store.StoreSandbox(ctx, activeInfo))\n246: \n247: \t\texpired, err := store.ListExpiredSandboxes(ctx, now, 10)\n248: \t\trequire.NoError(t, err)\n249: \t\tassert.Len(t, expired, 2)\n250: \n251: \t\tsessionIDs := make([]string, 0, len(expired))\n252: \t\tfor _, sb := range expired {\n253: \t\t\tsessionIDs = append(sessionIDs, sb.SessionID)\n254: \t\t}\n255: \t\tassert.Contains(t, sessionIDs, sessionID1)\n256: \t\tassert.Contains(t, sessionIDs, sessionID2)\n257: \t\tassert.NotContains(t, sessionIDs, sessionID3)\n258: \t})\n259: \n260: \tt.Run(\"List Expired Sandboxes With Limit\", func(t *testing.T) {\n261: \t\tsessionID1 := \"expired-limit-1\"\n262: \t\tsessionID2 := \"expired-limit-2\"\n263: \t\tsessionID3 := \"expired-limit-3\"\n264: \n265: \t\tnow := time.Now()\n266: \n267: \t\tfor i, sessionID := range []string{sessionID1, sessionID2, sessionID3} {\n268: \t\t\tinfo := &types.SandboxInfo{\n269: \t\t\t\tSessionID:    sessionID,\n270: \t\t\t\tSandboxName:  \"expired-limit\",\n271: \t\t\t\tWorkloadName: \"test\",\n272: \t\t\t\tNamespace:    \"default\",\n273: \t\t\t\tKind:         \"AgentRuntime\",\n274: \t\t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n275: \t\t\t\tExpiresAt:    now.Add(-time.Duration(i+1) * time.Hour),\n276: \t\t\t}\n277: \t\t\trequire.NoError(t, store.StoreSandbox(ctx, info))\n278: \t\t}\n279: \n280: \t\texpired, err := store.ListExpiredSandboxes(ctx, now, 2)\n281: \t\trequire.NoError(t, err)\n282: \t\tassert.Len(t, expired, 2)\n283: \t})\n284: \n285: \tt.Run(\"List Expired Sandboxes None\", func(t *testing.T) {\n286: \t\texpired, err := store.ListExpiredSandboxes(ctx, time.Now().Add(-1*time.Hour), 10)\n287: \t\trequire.NoError(t, err)\n288: \t\tassert.Len(t, expired, 0)\n289: \t})\n290: \n291: \tt.Run(\"List Inactive Sandboxes\", func(t *testing.T) {\n292: \t\tsessionID1 := \"inactive-session-test-1\"\n293: \t\tsessionID2 := \"inactive-session-test-2\"\n294: \t\tsessionID3 := \"recent-session-test\"\n295: \n296: \t\tnow := time.Now()\n297: \t\tinactiveThreshold := now.Add(-15 * time.Minute)\n298: \n299: \t\tinactiveInfo1 := &types.SandboxInfo{\n300: \t\t\tSessionID:      sessionID1,\n301: \t\t\tSandboxName:    \"inactive-1\",\n302: \t\t\tWorkloadName:   \"test\",\n303: \t\t\tNamespace:      \"default\",\n304: \t\t\tKind:           \"AgentRuntime\",\n305: \t\t\tCreatedAt:      now.Add(-1 * time.Hour),\n306: \t\t\tExpiresAt:      now.Add(7 * time.Hour),\n307: \t\t\tLastActivityAt: now.Add(-20 * time.Minute),\n308: \t\t}\n309: \n310: \t\tinactiveInfo2 := &types.SandboxInfo{\n311: \t\t\tSessionID:      sessionID2,\n312: \t\t\tSandboxName:    \"inactive-2\",\n313: \t\t\tWorkloadName:   \"test\",\n314: \t\t\tNamespace:      \"default\",\n315: \t\t\tKind:           \"AgentRuntime\",\n316: \t\t\tCreatedAt:      now.Add(-1 * time.Hour),\n317: \t\t\tExpiresAt:      now.Add(7 * time.Hour),\n318: \t\t\tLastActivityAt: now.Add(-30 * time.Minute),\n319: \t\t}\n320: \n321: \t\trecentInfo := &types.SandboxInfo{\n322: \t\t\tSessionID:      sessionID3,\n323: \t\t\tSandboxName:    \"recent\",\n324: \t\t\tWorkloadName:   \"test\",\n325: \t\t\tNamespace:      \"default\",\n326: \t\t\tKind:           \"AgentRuntime\",\n327: \t\t\tCreatedAt:      now,\n328: \t\t\tExpiresAt:      now.Add(8 * time.Hour),\n329: \t\t\tLastActivityAt: now,\n330: \t\t}\n331: \n332: \t\trequire.NoError(t, store.StoreSandbox(ctx, inactiveInfo1))\n333: \t\trequire.NoError(t, store.StoreSandbox(ctx, inactiveInfo2))\n334: \t\trequire.NoError(t, store.StoreSandbox(ctx, recentInfo))\n335: \n336: \t\tinactive, err := store.ListInactiveSandboxes(ctx, inactiveThreshold, 10)\n337: \t\trequire.NoError(t, err)\n338: \n339: \t\tinactiveSessionIDs := make([]string, 0)\n340: \t\tfor _, sb := range inactive {\n341: \t\t\tif sb.SessionID == sessionID1 || sb.SessionID == sessionID2 {\n342: \t\t\t\tinactiveSessionIDs = append(inactiveSessionIDs, sb.SessionID)\n343: \t\t\t}\n344: \t\t}\n345: \n346: \t\tassert.Contains(t, inactiveSessionIDs, sessionID1)\n347: \t\tassert.Contains(t, inactiveSessionIDs, sessionID2)\n348: \t})\n349: \n350: \tt.Run(\"List Inactive Sandboxes None\", func(t *testing.T) {\n351: \t\tinactive, err := store.ListInactiveSandboxes(ctx, time.Now().Add(-1*time.Hour), 10)\n352: \t\trequire.NoError(t, err)\n353: \t\tassert.Len(t, inactive, 0)\n354: \t})\n355: }\n356: \n357: func TestSingleton(t *testing.T) {\n358: \tt.Run(\"Invalid Store Type\", func(t *testing.T) {\n359: \t\tos.Setenv(\"STORE_TYPE\", \"invalid\")\n360: \t\tdefer os.Unsetenv(\"STORE_TYPE\")\n361: \n362: \t\terr := initStore()\n363: \t\tassert.Error(t, err)\n364: \t\tassert.Contains(t, err.Error(), \"invalid store type\")\n365: \t})\n366: \n367: \tt.Run(\"Redis Store Type\", func(t *testing.T) {\n368: \t\ts := miniredis.RunT(t)\n369: \n370: \t\tos.Setenv(\"STORE_TYPE\", \"redis\")\n371: \t\tos.Setenv(\"REDIS_ADDR\", s.Addr())\n372: \t\tdefer func() {\n373: \t\t\tos.Unsetenv(\"STORE_TYPE\")\n374: \t\t\tos.Unsetenv(\"REDIS_ADDR\")\n375: \t\t}()\n376: \n377: \t\terr := initStore()\n378: \t\trequire.NoError(t, err)\n379: \t\trequire.NotNil(t, storeInstance)\n380: \n381: \t\tassert.IsType(t, &redisStore{}, storeInstance)\n382: \n383: \t\tif store, ok := storeInstance.(*redisStore); ok {\n384: \t\t\trequire.NoError(t, store.Close())\n385: \t\t}\n386: \t})\n387: \n388: \tt.Run(\"Default Store Type\", func(t *testing.T) {\n389: \t\ts := miniredis.RunT(t)\n390: \n391: \t\tos.Setenv(\"REDIS_ADDR\", s.Addr())\n392: \t\tdefer os.Unsetenv(\"REDIS_ADDR\")\n393: \n394: \t\tstore, err := newRedisStore(s.Addr(), \"\", 0)\n395: \t\trequire.NoError(t, err)\n396: \t\trequire.NotNil(t, store)\n397: \n398: \t\tassert.IsType(t, &redisStore{}, store)\n399: \n400: \t\trequire.NoError(t, store.Close())\n401: \t})\n402: }\n403: \n404: func TestInvalidStoreTypeError(t *testing.T) {\n405: \terr := newInvalidStoreTypeError(\"invalid-type\")\n406: \tassert.Error(t, err)\n407: \tassert.Contains(t, err.Error(), \"invalid store type: invalid-type\")\n408: }\n\n(End of file - total 408 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestRedisStore(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tstore, err := newRedisStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_test.go","time":{"start":1775893577900,"end":1775893577918}}}}
{"type":"tool_use","timestamp":1775893577922,"sessionID":"ses_2847f24caffeU2hNyOZ4x5EBWx","part":{"id":"prt_d7b818089001CvoMejJ963C9ux","messageID":"msg_d7b814df9001DhxA9zVidFAQnS","sessionID":"ses_2847f24caffeU2hNyOZ4x5EBWx","type":"tool","tool":"read","callID":"toolu_tool-cb7f6e2eb4c3453fafef4256692db130","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"net/http/httptest\"\n6: \t\"os\"\n7: \t\"testing\"\n8: \t\"time\"\n9: \n10: \t\"github.com/gin-gonic/gin\"\n11: \t\"github.com/stretchr/testify/assert\"\n12: \t\"github.com/stretchr/testify/require\"\n13: )\n14: \n15: func setupTestServer(t *testing.T) *Server {\n16: \tworkspace := t.TempDir()\n17: \n18: \t_, publicKey := generateTestKeyPair(t)\n19: \tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n20: \n21: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n22: \tdefer os.Unsetenv(PublicKeyEnvVar)\n23: \n24: \tconfig := Config{\n25: \t\tPort:      0,\n26: \t\tWorkspace: workspace,\n27: \t}\n28: \n29: \tserver, err := NewServer(config)\n30: \trequire.NoError(t, err)\n31: \n32: \tgin.SetMode(gin.TestMode)\n33: \n34: \treturn server\n35: }\n36: \n37: func cleanupTestServer(t *testing.T, server *Server) {\n38: \tos.Unsetenv(PublicKeyEnvVar)\n39: }\n40: \n41: func TestSanitizePath(t *testing.T) {\n42: \tserver := setupTestServer(t)\n43: \tdefer cleanupTestServer(t, server)\n44: \n45: \ttests := []struct {\n46: \t\tname        string\n47: \t\tpath        string\n48: \t\twantErr     bool\n49: \t\terrContains string\n50: \t}{\n51: \t\t{\n52: \t\t\tname:    \"valid relative path\",\n53: \t\t\tpath:    \"test/file.txt\",\n54: \t\t\twantErr: false,\n55: \t\t},\n56: \t\t{\n57: \t\t\tname:    \"valid absolute path\",\n58: \t\t\tpath:    \"/test/file.txt\",\n59: \t\t\twantErr: false,\n60: \t\t},\n61: \t\t{\n62: \t\t\tname:        \"path traversal attempt\",\n63: \t\t\tpath:        \"../../etc/passwd\",\n64: \t\t\twantErr:     true,\n65: \t\t\terrContains: \"Access denied\",\n66: \t\t},\n67: \t\t{\n68: \t\t\tname:    \"empty path\",\n69: \t\t\tpath:    \"\",\n70: \t\t\twantErr: false,\n71: \t\t},\n72: \t\t{\n73: \t\t\tname:    \"single dot\",\n74: \t\t\tpath:    \".\",\n75: \t\t\twantErr: false,\n76: \t\t},\n77: \t\t{\n78: \t\t\tname:        \"double dot at root\",\n79: \t\t\tpath:        \"..\",\n80: \t\t\twantErr:     true,\n81: \t\t\terrContains: \"Access denied\",\n82: \t\t},\n83: \t}\n84: \n85: \tfor _, tt := range tests {\n86: \t\tt.Run(tt.name, func(t *testing.T) {\n87: \t\t\tresult, err := server.sanitizePath(tt.path)\n88: \n89: \t\t\tif tt.wantErr {\n90: \t\t\t\tassert.Error(t, err)\n91: \t\t\t\tif tt.errContains != \"\" {\n92: \t\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n93: \t\t\t\t}\n94: \t\t\t} else {\n95: \t\t\t\tassert.NoError(t, err)\n96: \t\t\t\tassert.NotEmpty(t, result)\n97: \t\t\t}\n98: \t\t})\n99: \t}\n100: }\n101: \n102: func TestParseFileMode(t *testing.T) {\n103: \ttests := []struct {\n104: \t\tname     string\n105: \t\tmodeStr  string\n106: \t\texpected int\n107: \t}{\n108: \t\t{\n109: \t\t\tname:     \"default mode\",\n110: \t\t\tmodeStr:  \"\",\n111: \t\t\texpected: 0644,\n112: \t\t},\n113: \t\t{\n114: \t\t\tname:     \"valid octal mode\",\n115: \t\t\tmodeStr:  \"0644\",\n116: \t\t\texpected: 0644,\n117: \t\t},\n118: \t\t{\n119: \t\t\tname:     \"valid octal mode 0755\",\n120: \t\t\tmodeStr:  \"0755\",\n121: \t\t\texpected: 0755,\n122: \t\t},\n123: \t\t{\n124: \t\t\tname:     \"invalid format\",\n125: \t\t\tmodeStr:  \"invalid\",\n126: \t\t\texpected: 0644,\n127: \t\t},\n128: \t\t{\n129: \t\t\tname:     \"exceeds max\",\n130: \t\t\tmodeStr:  \"10000\",\n131: \t\t\texpected: 0644,\n132: \t\t},\n133: \t}\n134: \n135: \tfor _, tt := range tests {\n136: \t\tt.Run(tt.name, func(t *testing.T) {\n137: \t\t\tresult := parseFileMode(tt.modeStr)\n138: \t\t\tassert.Equal(t, int(result), tt.expected)\n139: \t\t})\n140: \t}\n141: }\n142: \n143: func TestAuthMiddleware(t *testing.T) {\n144: \tserver := setupTestServer(t)\n145: \tdefer cleanupTestServer(t, server)\n146: \n147: \tprivateKey, publicKey := generateTestKeyPair(t)\n148: \tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n149: \n150: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n151: \tdefer os.Unsetenv(PublicKeyEnvVar)\n152: \n153: \tserver, err := NewServer(Config{\n154: \t\tPort:      0,\n155: \t\tWorkspace: t.TempDir(),\n156: \t})\n157: \trequire.NoError(t, err)\n158: \n159: \tvalidToken := createTestToken(t, privateKey)\n160: \n161: \ttests := []struct {\n162: \t\tname           string\n163: \t\tsetupRequest   func(*http.Request)\n164: \t\twantStatusCode int\n165: \t\twantError      string\n166: \t}{\n167: \t\t{\n168: \t\t\tname: \"valid token\",\n169: \t\t\tsetupRequest: func(req *http.Request) {\n170: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+validToken)\n171: \t\t\t},\n172: \t\t\twantStatusCode: http.StatusOK,\n173: \t\t},\n174: \t\t{\n175: \t\t\tname: \"missing authorization header\",\n176: \t\t\tsetupRequest: func(req *http.Request) {\n177: \t\t\t},\n178: \t\t\twantStatusCode: http.StatusUnauthorized,\n179: \t\t\twantError:      ErrMsgMissingAuthHeader,\n180: \t\t},\n181: \t\t{\n182: \t\t\tname: \"invalid authorization format\",\n183: \t\t\tsetupRequest: func(req *http.Request) {\n184: \t\t\t\treq.Header.Set(HeaderAuthorization, \"InvalidFormat token\")\n185: \t\t\t},\n186: \t\t\twantStatusCode: http.StatusUnauthorized,\n187: \t\t\twantError:      \"Use Bearer\",\n188: \t\t},\n189: \t\t{\n190: \t\t\tname: \"invalid token\",\n191: \t\t\tsetupRequest: func(req *http.Request) {\n192: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer invalid.token.here\")\n193: \t\t\t},\n194: \t\t\twantStatusCode: http.StatusUnauthorized,\n195: \t\t},\n196: \t}\n197: \n198: \tfor _, tt := range tests {\n199: \t\tt.Run(tt.name, func(t *testing.T) {\n200: \t\t\trouter := gin.New()\n201: \t\t\trouter.Use(AuthMiddleware(server.authManager))\n202: \t\t\trouter.GET(\"/test\", func(c *gin.Context) {\n203: \t\t\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n204: \t\t\t})\n205: \n206: \t\t\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n207: \t\t\ttt.setupRequest(req)\n208: \t\t\tw := httptest.NewRecorder()\n209: \n210: \t\t\trouter.ServeHTTP(w, req)\n211: \n212: \t\t\tassert.Equal(t, tt.wantStatusCode, w.Code)\n213: \t\t\tif tt.wantError != \"\" {\n214: \t\t\t\tassert.Contains(t, w.Body.String(), tt.wantError)\n215: \t\t\t}\n216: \t\t})\n217: \t}\n218: }\n219: \n220: func TestHealthCheckHandler(t *testing.T) {\n221: \tserver := setupTestServer(t)\n222: \tdefer cleanupTestServer(t, server)\n223: \n224: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n225: \tw := httptest.NewRecorder()\n226: \n227: \tserver.engine.ServeHTTP(w, req)\n228: \n229: \tassert.Equal(t, http.StatusOK, w.Code)\n230: \tassert.Contains(t, w.Body.String(), `\"status\":\"ok\"`)\n231: \tassert.Contains(t, w.Body.String(), `\"service\":\"PicoD\"`)\n232: \tassert.Contains(t, w.Body.String(), `\"version\":\"0.0.1\"`)\n233: \tassert.Contains(t, w.Body.String(), `\"uptime\"`)\n234: }\n235: \n236: func TestNewServer(t *testing.T) {\n237: \t_, publicKey := generateTestKeyPair(t)\n238: \tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n239: \n240: \ttests := []struct {\n241: \t\tname     string\n242: \t\tconfig   Config\n243: \t\tsetupEnv func()\n244: \t\tcleanup  func()\n245: \t\twantErr  bool\n246: \t\terrMsg   string\n247: \t}{\n248: \t\t{\n249: \t\t\tname: \"success with default workspace\",\n250: \t\t\tconfig: Config{\n251: \t\t\t\tPort: DefaultPort,\n252: \t\t\t},\n253: \t\t\tsetupEnv: func() {\n254: \t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n255: \t\t\t},\n256: \t\t\tcleanup: func() {\n257: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n258: \t\t\t},\n259: \t\t\twantErr: false,\n260: \t\t},\n261: \t\t{\n262: \t\t\tname: \"success with custom workspace\",\n263: \t\t\tconfig: Config{\n264: \t\t\t\tPort:      9090,\n265: \t\t\t\tWorkspace: t.TempDir(),\n266: \t\t\t},\n267: \t\t\tsetupEnv: func() {\n268: \t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n269: \t\t\t},\n270: \t\t\tcleanup: func() {\n271: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n272: \t\t\t},\n273: \t\t\twantErr: false,\n274: \t\t},\n275: \t\t{\n276: \t\t\tname: \"error without public key\",\n277: \t\t\tconfig: Config{\n278: \t\t\t\tPort: DefaultPort,\n279: \t\t\t},\n280: \t\t\tsetupEnv: func() {\n281: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n282: \t\t\t},\n283: \t\t\tcleanup: func() {\n284: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n285: \t\t\t},\n286: \t\t\twantErr: true,\n287: \t\t\terrMsg:  \"public key not found\",\n288: \t\t},\n289: \t}\n290: \n291: \tfor _, tt := range tests {\n292: \t\tt.Run(tt.name, func(t *testing.T) {\n293: \t\t\ttt.setupEnv()\n294: \t\t\tdefer tt.cleanup()\n295: \n296: \t\t\tserver, err := NewServer(tt.config)\n297: \n298: \t\t\tif tt.wantErr {\n299: \t\t\t\tassert.Error(t, err)\n300: \t\t\t\tassert.Nil(t, server)\n301: \t\t\t\tif tt.errMsg != \"\" {\n302: \t\t\t\t\tassert.Contains(t, err.Error(), tt.errMsg)\n303: \t\t\t\t}\n304: \t\t\t} else {\n305: \t\t\t\tassert.NoError(t, err)\n306: \t\t\t\tassert.NotNil(t, server)\n307: \t\t\t\tassert.Equal(t, tt.config.Port, server.config.Port)\n308: \t\t\t\tassert.NotEmpty(t, server.workspaceDir)\n309: \t\t\t\tassert.NotNil(t, server.authManager)\n310: \t\t\t\tassert.True(t, time.Since(server.startTime) < time.Second)\n311: \t\t\t}\n312: \t\t})\n313: \t}\n314: }\n315: \n316: func TestDefaultConfig(t *testing.T) {\n317: \tconfig := DefaultConfig()\n318: \n319: \tassert.Equal(t, DefaultPort, config.Port)\n320: \tassert.Empty(t, config.Workspace)\n321: }\n322: \n323: func TestPicoDError(t *testing.T) {\n324: \ttests := []struct {\n325: \t\tname    string\n326: \t\terr     *PicoDError\n327: \t\twantMsg string\n328: \t}{\n329: \t\t{\n330: \t\t\tname: \"error without underlying error\",\n331: \t\t\terr: &PicoDError{\n332: \t\t\t\tCode:    \"TestCode\",\n333: \t\t\t\tMessage: \"Test message\",\n334: \t\t\t\tDetail:  \"Test detail\",\n335: \t\t\t},\n336: \t\t\twantMsg: \"TestCode: Test message\",\n337: \t\t},\n338: \t\t{\n339: \t\t\tname: \"error with underlying error\",\n340: \t\t\terr: &PicoDError{\n341: \t\t\t\tCode:    \"TestCode\",\n342: \t\t\t\tMessage: \"Test message\",\n343: \t\t\t\tDetail:  \"Test detail\",\n344: \t\t\t\tErr:     assert.AnError,\n345: \t\t\t},\n346: \t\t\twantMsg: \"TestCode: Test message (caused by: \",\n347: \t\t},\n348: \t}\n349: \n350: \tfor _, tt := range tests {\n351: \t\tt.Run(tt.name, func(t *testing.T) {\n352: \t\t\terrMsg := tt.err.Error()\n353: \t\t\tassert.Contains(t, errMsg, tt.wantMsg)\n354: \n355: \t\t\tif tt.err.Err != nil {\n356: \t\t\t\tassert.Equal(t, tt.err.Err, tt.err.Unwrap())\n357: \t\t\t}\n358: \t\t})\n359: \t}\n360: }\n361: \n362: func TestNewError(t *testing.T) {\n363: \terr := NewError(\"TestCode\", \"Test message\", \"Test detail\", nil)\n364: \n365: \tassert.Equal(t, \"TestCode\", err.Code)\n366: \tassert.Equal(t, \"Test message\", err.Message)\n367: \tassert.Equal(t, \"Test detail\", err.Detail)\n368: \tassert.Nil(t, err.Err)\n369: }\n370: \n371: func TestStatusCodeMap(t *testing.T) {\n372: \ttests := []struct {\n373: \t\tname           string\n374: \t\tcode           string\n375: \t\texpectedStatus int\n376: \t}{\n377: \t\t{\n378: \t\t\tname:           \"bad request\",\n379: \t\t\tcode:           ErrInvalidCommand,\n380: \t\t\texpectedStatus: http.StatusBadRequest,\n381: \t\t},\n382: \t\t{\n383: \t\t\tname:           \"unauthorized\",\n384: \t\t\tcode:           ErrMissingAuthHeader,\n385: \t\t\texpectedStatus: http.StatusUnauthorized,\n386: \t\t},\n387: \t\t{\n388: \t\t\tname:           \"not found\",\n389: \t\t\tcode:           ErrFileNotFound,\n390: \t\t\texpectedStatus: http.StatusNotFound,\n391: \t\t},\n392: \t\t{\n393: \t\t\tname:           \"internal error\",\n394: \t\t\tcode:           ErrServerInternal,\n395: \t\t\texpectedStatus: http.StatusInternalServerError,\n396: \t\t},\n397: \t}\n398: \n399: \tfor _, tt := range tests {\n400: \t\tt.Run(tt.name, func(t *testing.T) {\n401: \t\t\tstatus, exists := statusCodeMap[tt.code]\n402: \t\t\tassert.True(t, exists)\n403: \t\t\tassert.Equal(t, tt.expectedStatus, status)\n404: \t\t})\n405: \t}\n406: }\n407: \n408: func TestHandleError(t *testing.T) {\n409: \tgin.SetMode(gin.TestMode)\n410: \n411: \ttests := []struct {\n412: \t\tname           string\n413: \t\terr            error\n414: \t\texpectedStatus int\n415: \t\tcontains       string\n416: \t}{\n417: \t\t{\n418: \t\t\tname:           \"picoD error\",\n419: \t\t\terr:            NewError(ErrInvalidCommand, \"Test message\", \"\", nil),\n420: \t\t\texpectedStatus: http.StatusBadRequest,\n421: \t\t\tcontains:       \"Test message\",\n422: \t\t},\n423: \t\t{\n424: \t\t\tname:           \"generic error\",\n425: \t\t\terr:            assert.AnError,\n426: \t\t\texpectedStatus: http.StatusInternalServerError,\n427: \t\t\tcontains:       \"Error\",\n428: \t\t},\n429: \t}\n430: \n431: \tfor _, tt := range tests {\n432: \t\tt.Run(tt.name, func(t *testing.T) {\n433: \t\t\tw := httptest.NewRecorder()\n434: \t\t\tc, _ := gin.CreateTestContext(w)\n435: \n436: \t\t\tHandleError(c, tt.err)\n437: \n438: \t\t\tassert.Equal(t, tt.expectedStatus, w.Code)\n439: \t\t\tassert.Contains(t, w.Body.String(), tt.contains)\n440: \t\t})\n441: \t}\n442: }\n\n(End of file - total 442 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc setupTestServer(t *testing.T) *Server {\n\tworkspace := t.TempDir()\n\n\t_, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go","time":{"start":1775893577902,"end":1775893577920}}}}
