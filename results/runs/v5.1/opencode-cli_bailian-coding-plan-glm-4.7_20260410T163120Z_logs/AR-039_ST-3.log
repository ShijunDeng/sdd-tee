toreClient == nil {\n40: \t\treturn nil, fmt.Errorf(\"store client is required\")\n41: \t}\n42: \n43: \tif workloadMgrAddr == \"\" {\n44: \t\treturn nil, fmt.Errorf(\"workload manager address is required\")\n45: \t}\n46: \n47: \treturn &manager{\n48: \t\tstoreClient:     storeClient,\n49: \t\tworkloadMgrAddr: workloadMgrAddr,\n50: \t\thttpClient:      &http.Client{Timeout: 30 * time.Second},\n51: \t\tresourceCache:   NewResourceCache(),\n52: \t}, nil\n53: }\n54: \n55: func (m *manager) InitializeInformers(clientset kubernetes.Interface, namespace string, resyncPeriod time.Duration) error {\n56: \tif clientset == nil {\n57: \t\tklog.Info(\"Kubernetes clientset not provided, informers not initialized\")\n58: \t\treturn nil\n59: \t}\n60: \n61: \tinformerManager, err := NewInformerManager(clientset, namespace, resyncPeriod)\n62: \tif err != nil {\n63: \t\treturn fmt.Errorf(\"failed to create informer manager: %w\", err)\n64: \t}\n65: \n66: \tm.informerManager = informerManager\n67: \tm.resourceCache = informerManager.GetResourceCache()\n68: \n69: \tklog.Infof(\"Informers initialized for namespace: %s\", namespace)\n70: \treturn nil\n71: }\n72: \n73: func (m *manager) StartInformers() {\n74: \tif m.informerManager != nil {\n75: \t\tm.informerManager.Start()\n76: \t}\n77: }\n78: \n79: func (m *manager) StopInformers() {\n80: \tif m.informerManager != nil {\n81: \t\tm.informerManager.Stop()\n82: \t}\n83: }\n84: \n85: func (m *manager) WaitForCacheSync(ctx context.Context) bool {\n86: \tif m.informerManager == nil {\n87: \t\treturn true\n88: \t}\n89: \n90: \treturn m.informerManager.WaitForCacheSync(ctx.Done())\n91: }\n92: \n93: func (m *manager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n94: \tsandboxInfo, err := m.storeClient.GetSandbox(ctx, sessionID)\n95: \tif err == nil {\n96: \t\tklog.V(4).Infof(\"Cache hit for session: %s\", sessionID)\n97: \n98: \t\tif m.isResourceActive(namespace, name, kind) {\n99: \t\t\treturn sandboxInfo, nil\n100: \t\t}\n101: \n102: \t\tklog.V(4).Infof(\"Resource not active, removing from cache: %s\", sessionID)\n103: \t\tm.storeClient.DeleteSandboxBySessionID(ctx, sessionID)\n104: \n105: \t\tklog.V(4).Infof(\"Cache miss for session: %s, querying workload manager\", sessionID)\n106: \t\treturn m.getSandboxFromWorkloadManager(ctx, sessionID)\n107: \t}\n108: \n109: \tif err != store.ErrNotFound {\n110: \t\tklog.Warningf(\"Failed to get sandbox from store: %v\", err)\n111: \t}\n112: \n113: \tklog.V(4).Infof(\"Cache miss for session: %s, querying workload manager\", sessionID)\n114: \treturn m.getSandboxFromWorkloadManager(ctx, sessionID)\n115: }\n116: \n117: func (m *manager) CreateSession(ctx context.Context, name string, namespace string, kind string) (string, *types.SandboxInfo, error) {\n118: \tif err := validateKind(kind); err != nil {\n119: \t\treturn \"\", nil, err\n120: \t}\n121: \n122: \tif !isValidNamespace(namespace) {\n123: \t\treturn \"\", nil, &ValidationError{Field: \"namespace\", Message: \"invalid namespace format\"}\n124: \t}\n125: \n126: \tif !isValidResourceName(name) {\n127: \t\treturn \"\", nil, &ValidationError{Field: \"name\", Message: \"invalid resource name format\"}\n128: \t}\n129: \n130: \tcreateReq := &WorkloadManagerCreateRequest{\n131: \t\tKind:      kind,\n132: \t\tName:      name,\n133: \t\tNamespace: namespace,\n134: \t}\n135: \n136: \treqBody, err := json.Marshal(createReq)\n137: \tif err != nil {\n138: \t\treturn \"\", nil, fmt.Errorf(\"failed to marshal create request: %w\", err)\n139: \t}\n140: \n141: \tvar endpoint string\n142: \tif kind == types.AgentRuntimeKind {\n143: \t\tendpoint = fmt.Sprintf(\"%s/v1/agent-runtime\", m.workloadMgrAddr)\n144: \t} else {\n145: \t\tendpoint = fmt.Sprintf(\"%s/v1/code-interpreter\", m.workloadMgrAddr)\n146: \t}\n147: \n148: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(reqBody))\n149: \tif err != nil {\n150: \t\treturn \"\", nil, fmt.Errorf(\"failed to create request: %w\", err)\n151: \t}\n152: \n153: \treq.Header.Set(\"Content-Type\", \"application/json\")\n154: \n155: \tresp, err := m.httpClient.Do(req)\n156: \tif err != nil {\n157: \t\treturn \"\", nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusServiceUnavailable}\n158: \t}\n159: \tdefer resp.Body.Close()\n160: \n161: \tbody, err := io.ReadAll(resp.Body)\n162: \tif err != nil {\n163: \t\treturn \"\", nil, fmt.Errorf(\"failed to read response body: %w\", err)\n164: \t}\n165: \n166: \tif resp.StatusCode != http.StatusOK {\n167: \t\treturn \"\", nil, &WorkloadManagerError{\n168: \t\t\tMessage: string(body),\n169: \t\t\tCode:    resp.StatusCode,\n170: \t\t}\n171: \t}\n172: \n173: \tvar createResp WorkloadManagerCreateResponse\n174: \tif err := json.Unmarshal(body, &createResp); err != nil {\n175: \t\treturn \"\", nil, fmt.Errorf(\"failed to unmarshal create response: %w\", err)\n176: \t}\n177: \n178: \tsessionID := createResp.SessionID\n179: \n180: \tgetSandboxResp, err := m.getSandboxFromWorkloadManager(ctx, sessionID)\n181: \tif err != nil {\n182: \t\treturn \"\", nil, fmt.Errorf(\"created session but failed to get sandbox info: %w\", err)\n183: \t}\n184: \n185: \treturn sessionID, getSandboxResp, nil\n186: }\n187: \n188: func (m *manager) ListSessions(ctx context.Context) ([]*types.SandboxInfo, error) {\n189: \tsandboxes, err := m.storeClient.ListSandboxes(ctx)\n190: \tif err != nil {\n191: \t\treturn nil, fmt.Errorf(\"failed to list sessions from store: %w\", err)\n192: \t}\n193: \n194: \tresult := make([]*types.SandboxInfo, 0, len(sandboxes))\n195: \tfor _, sandbox := range sandboxes {\n196: \t\tresult = append(result, sandbox)\n197: \t}\n198: \n199: \treturn result, nil\n200: }\n201: \n202: func (m *manager) getSandboxFromWorkloadManager(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n203: \tendpoint := fmt.Sprintf(\"%s/v1/session/%s\", m.workloadMgrAddr, sessionID)\n204: \n205: \treq, err := http.NewRequestWithContext(ctx, http.MethodGet, endpoint, nil)\n206: \tif err != nil {\n207: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n208: \t}\n209: \n210: \tresp, err := m.httpClient.Do(req)\n211: \tif err != nil {\n212: \t\treturn nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusServiceUnavailable}\n213: \t}\n214: \tdefer resp.Body.Close()\n215: \n216: \tbody, err := io.ReadAll(resp.Body)\n217: \tif err != nil {\n218: \t\treturn nil, fmt.Errorf(\"failed to read response body: %w\", err)\n219: \t}\n220: \n221: \tif resp.StatusCode == http.StatusNotFound {\n222: \t\treturn nil, &SandboxNotFoundError{SessionID: sessionID}\n223: \t}\n224: \n225: \tif resp.StatusCode != http.StatusOK {\n226: \t\treturn nil, &WorkloadManagerError{\n227: \t\t\tMessage: string(body),\n228: \t\t\tCode:    resp.StatusCode,\n229: \t\t}\n230: \t}\n231: \n232: \tvar getSessionResp WorkloadManagerGetSessionResponse\n233: \tif err := json.Unmarshal(body, &getSessionResp); err != nil {\n234: \t\treturn nil, fmt.Errorf(\"failed to unmarshal get session response: %w\", err)\n235: \t}\n236: \n237: \tsandboxInfo := SandboxInfoFromWorkloadManager(&getSessionResp, sessionID)\n238: \n239: \tif err := m.storeClient.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n240: \t\tklog.Warningf(\"Failed to cache sandbox info: %v\", err)\n241: \t}\n242: \n243: \treturn sandboxInfo, nil\n244: }\n245: \n246: func (m *manager) isResourceActive(namespace string, name string, kind string) bool {\n247: \tif m.resourceCache == nil {\n248: \t\treturn true\n249: \t}\n250: \n251: \tif kind == types.AgentRuntimeKind {\n252: \t\tar, err := m.resourceCache.GetAgentRuntime(namespace, name)\n253: \t\tif err != nil || ar == nil {\n254: \t\t\treturn true\n255: \t\t}\n256: \n257: \t\tif !isResourceReady(ar.Status.Conditions) {\n258: \t\t\treturn false\n259: \t\t}\n260: \n261: \t\tif isResourceBeingDeleted(ar) {\n262: \t\t\treturn false\n263: \t\t}\n264: \n265: \t\treturn true\n266: \t} else if kind == types.CodeInterpreterKind {\n267: \t\tci, err := m.resourceCache.GetCodeInterpreter(namespace, name)\n268: \t\tif err != nil || ci == nil {\n269: \t\t\treturn true\n270: \t\t}\n271: \n272: \t\tif !ci.Status.Ready {\n273: \t\t\treturn false\n274: \t\t}\n275: \n276: \t\tif isResourceBeingDeleted(ci) {\n277: \t\t\treturn false\n278: \t\t}\n279: \n280: \t\treturn true\n281: \t}\n282: \n283: \treturn true\n284: }\n285: \n286: func isResourceReady(conditions []metav1.Condition) bool {\n287: \tif len(conditions) == 0 {\n288: \t\treturn false\n289: \t}\n290: \n291: \tfor _, cond := range conditions {\n292: \t\tif cond.Type == \"Ready\" && cond.Status == metav1.ConditionTrue {\n293: \t\t\treturn true\n294: \t\t}\n295: \t}\n296: \n297: \treturn false\n298: }\n299: \n300: func isResourceBeingDeleted(obj metav1.Object) bool {\n301: \treturn !obj.GetDeletionTimestamp().IsZero()\n302: }\n303: \n304: func conditionsChanged(oldConditions, newConditions []metav1.Condition) bool {\n305: \tif len(oldConditions) != len(newConditions) {\n306: \t\treturn true\n307: \t}\n308: \n309: \tfor i := range oldConditions {\n310: \t\tif oldConditions[i].Type != newConditions[i].Type ||\n311: \t\t\toldConditions[i].Status != newConditions[i].Status ||\n312: \t\t\toldConditions[i].Reason != newConditions[i].Reason {\n313: \t\t\treturn true\n314: \t\t}\n315: \t}\n316: \n317: \treturn false\n318: }\n319: \n320: func GetResourceStatus(conditions []metav1.Condition) string {\n321: \tif len(conditions) == 0 {\n322: \t\treturn \"Unknown\"\n323: \t}\n324: \n325: \tfor _, cond := range conditions {\n326: \t\tif cond.Type == \"Ready\" {\n327: \t\t\tif cond.Status == metav1.ConditionTrue {\n328: \t\t\t\treturn \"Ready\"\n329: \t\t\t}\n330: \t\t\treturn cond.Reason\n331: \t\t}\n332: \t}\n333: \n334: \treturn conditions[0].Type\n335: }\n\n(End of file - total 335 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"en