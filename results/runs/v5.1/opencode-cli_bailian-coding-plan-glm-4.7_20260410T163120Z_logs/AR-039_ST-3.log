\n47: \tauthManager, err := NewAuthManager()\n48: \tif err != nil {\n49: \t\treturn nil, err\n50: \t}\n51: \n52: \tgin.SetMode(gin.ReleaseMode)\n53: \tengine := gin.New()\n54: \n55: \tengine.Use(gin.Recovery())\n56: \tengine.Use(gin.Logger())\n57: \n58: \tserver := &Server{\n59: \t\tengine:       engine,\n60: \t\tconfig:       config,\n61: \t\tauthManager:  authManager,\n62: \t\tstartTime:    time.Now(),\n63: \t\tworkspaceDir: absWorkspace,\n64: \t}\n65: \n66: \tserver.registerRoutes()\n67: \n68: \tif config.K8sConfig != nil {\n69: \t\tk8sClient, err := NewK8sClient(*config.K8sConfig)\n70: \t\tif err != nil {\n71: \t\t\tklog.Warningf(\"Failed to create Kubernetes client: %v\", err)\n72: \t\t} else {\n73: \t\t\tserver.k8sClient = k8sClient\n74: \t\t\tklog.Infof(\"Kubernetes client initialized for namespace: %s\", k8sClient.GetNamespace())\n75: \n76: \t\t\tworkspaceManager, err := NewWorkspaceManager(absWorkspace, k8sClient)\n77: \t\t\tif err != nil {\n78: \t\t\t\tklog.Warningf(\"Failed to create workspace manager: %v\", err)\n79: \t\t\t} else {\n80: \t\t\t\tserver.workspaceManager = workspaceManager\n81: \t\t\t\tklog.Infof(\"Workspace manager initialized at: %s\", absWorkspace)\n82: \n83: \t\t\t\tif k8sClient.GetAgentRuntimeName() != \"\" {\n84: \t\t\t\t\tstatusReporter := NewStatusReporter(k8sClient, workspaceManager, k8sClient.GetAgentRuntimeName(), time.Minute)\n85: \t\t\t\t\tserver.statusReporter = statusReporter\n86: \t\t\t\t\tgo statusReporter.Start()\n87: \t\t\t\t\tklog.Infof(\"Status reporter started for AgentRuntime: %s\", k8sClient.GetAgentRuntimeName())\n88: \n89: \t\t\t\t\tinformerManager := NewInformerManager(k8sClient, server, workspaceManager, statusReporter)\n90: \t\t\t\t\tserver.informerManager = informerManager\n91: \n92: \t\t\t\t\tif err := informerManager.SetupAgentRuntimeInformer(); err != nil {\n93: \t\t\t\t\t\tklog.Errorf(\"Failed to setup AgentRuntime informer: %v\", err)\n94: \t\t\t\t\t} else {\n95: \t\t\t\t\t\tklog.Info(\"AgentRuntime informer setup completed\")\n96: \t\t\t\t\t}\n97: \n98: \t\t\t\t\tif err := informerManager.SetupCodeInterpreterInformer(); err != nil {\n99: \t\t\t\t\t\tklog.Errorf(\"Failed to setup CodeInterpreter informer: %v\", err)\n100: \t\t\t\t\t} else {\n101: \t\t\t\t\t\tklog.Info(\"CodeInterpreter informer setup completed\")\n102: \t\t\t\t\t}\n103: \n104: \t\t\t\t\tk8sClient.StartInformers()\n105: \t\t\t\t\tsynced := k8sClient.WaitForCacheSync()\n106: \t\t\t\t\tklog.Infof(\"Informer cache sync: %v\", synced)\n107: \t\t\t\t}\n108: \t\t\t}\n109: \t\t}\n110: \t}\n111: \n112: \treturn server, nil\n113: }\n114: \n115: func (s *Server) registerRoutes() {\n116: \tapi := s.engine.Group(\"/api\")\n117: \tapi.Use(AuthMiddleware(s.authManager))\n118: \t{\n119: \t\tapi.POST(\"/execute\", s.ExecuteHandler)\n120: \t\tapi.POST(\"/files\", s.UploadFileHandler)\n121: \t\tapi.GET(\"/files\", s.ListFilesHandler)\n122: \t\tapi.GET(\"/files/*path\", s.DownloadFileHandler)\n123: \t}\n124: \n125: \ts.engine.GET(\"/health\", s.HealthCheckHandler)\n126: }\n127: \n128: func (s *Server) Run() error {\n129: \taddr := fmt.Sprintf(\":%d\", s.config.Port)\n130: \ts.httpServer = &http.Server{\n131: \t\tAddr:              addr,\n132: \t\tHandler:           s.engine,\n133: \t\tReadHeaderTimeout: ReadHeaderTimeout,\n134: \t}\n135: \n136: \tklog.Infof(\"Starting %s server on port %d\", ServiceName, s.config.Port)\n137: \tklog.Infof(\"Workspace directory: %s\", s.workspaceDir)\n138: \tklog.Infof(\"Server version: %s\", Version)\n139: \n140: \tif s.k8sClient != nil {\n141: \t\tklog.Infof(\"Kubernetes integration enabled for AgentRuntime: %s\", s.k8sClient.GetAgentRuntimeName())\n142: \t}\n143: \n144: \tif err := s.httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n145: \t\treturn err\n146: \t}\n147: \n148: \treturn nil\n149: }\n150: \n151: func (s *Server) Shutdown(ctx context.Context) error {\n152: \tklog.Info(\"Shutting down server...\")\n153: \n154: \tif s.statusReporter != nil {\n155: \t\ts.statusReporter.Stop()\n156: \t\tklog.Info(\"Status reporter stopped\")\n157: \t}\n158: \n159: \tif s.k8sClient != nil {\n160: \t\ts.k8sClient.Stop()\n161: \t\tklog.Info(\"Kubernetes client stopped\")\n162: \t}\n163: \n164: \tif err := s.httpServer.Shutdown(ctx); err != nil {\n165: \t\treturn err\n166: \t}\n167: \n168: \tklog.Info(\"Server shutdown complete\")\n169: \treturn nil\n170: }\n171: \n172: func (s *Server) GetWorkspaceManager() *WorkspaceManager {\n173: \treturn s.workspaceManager\n174: }\n175: \n176: func (s *Server) GetK8sClient() *K8sClient {\n177: \treturn s.k8sClient\n178: }\n\n(End of file - total 178 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tengine           *gin.Engine\n\tconfig           Config\n\tauthManager      *AuthManager\n\tstartTime        time.Time\n\tworkspaceDir     string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server.go","time":{"start":1775893551648,"end":1775893551673}}}}
{"type":"tool_use","timestamp":1775893551676,"sessionID":"ses_2847f24caffeU2hNyOZ4x5EBWx","part":{"id":"prt_d7b811a00001TMsRH1Ixg54kPQ","messageID":"msg_d7b81010c001wsCeqXelXNFyYY","sessionID":"ses_2847f24caffeU2hNyOZ4x5EBWx","type":"tool","tool":"read","callID":"toolu_tool-f8bfb9b89ac74e6fa3501f5c6f596d2b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net\"\n7: \t\"net/http\"\n8: \t\"sync\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"k8s.io/client-go/kubernetes\"\n13: \t\"k8s.io/klog/v2\"\n14: \n15: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n16: )\n17: \n18: type Server struct {\n19: \tconfig         *Config\n20: \tengine         *gin.Engine\n21: \thttpServer     *http.Server\n22: \tsessionManager SessionManager\n23: \tstoreClient    store.Store\n24: \thttpTransport  *http.Transport\n25: \tjwtManager     *JWTManager\n26: \thandler        *Handler\n27: \tlimiter        *ConcurrencyLimiter\n28: \tmetrics        *Metrics\n29: \tmu             sync.RWMutex\n30: }\n31: \n32: func NewServer(cfg *Config, storeClient store.Store, clientset kubernetes.Interface) (*Server, error) {\n33: \tif err := cfg.Validate(); err != nil {\n34: \t\treturn nil, fmt.Errorf(\"invalid configuration: %w\", err)\n35: \t}\n36: \n37: \tif cfg.Debug {\n38: \t\tgin.SetMode(gin.DebugMode)\n39: \t} else {\n40: \t\tgin.SetMode(gin.ReleaseMode)\n41: \t}\n42: \n43: \ts := &Server{\n44: \t\tconfig:        cfg,\n45: \t\tstoreClient:   storeClient,\n46: \t\thttpTransport: configureHTTPTransport(),\n47: \t\tlimiter:       NewConcurrencyLimiter(cfg.MaxConcurrentRequests),\n48: \t\tmetrics:       NewMetrics(),\n49: \t}\n50: \n51: \tif err := s.initializeSessionManager(); err != nil {\n52: \t\treturn nil, fmt.Errorf(\"failed to initialize session manager: %w\", err)\n53: \t}\n54: \n55: \tif err := s.initializeJWTManager(clientset); err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to initialize JWT manager: %w\", err)\n57: \t}\n58: \n59: \ts.handler = NewHandler(s.sessionManager, s.jwtManager, NewReverseProxy(s.jwtManager))\n60: \n61: \ts.engine = gin.New()\n62: \n63: \ts.applyMiddleware()\n64: \n65: \ts.setupRoutes()\n66: \n67: \ts.httpServer = &http.Server{\n68: \t\tAddr:         \":\" + s.config.Port,\n69: \t\tHandler:      s.engine,\n70: \t\tReadTimeout:  time.Duration(s.config.ReadTimeout) * time.Second,\n71: \t\tWriteTimeout: time.Duration(s.config.WriteTimeout) * time.Second,\n72: \t\tIdleTimeout:  time.Duration(s.config.IdleTimeout) * time.Second,\n73: \t}\n74: \n75: \treturn s, nil\n76: }\n77: \n78: func (s *Server) initializeSessionManager() error {\n79: \tsessionManager, err := NewSessionManager(s.storeClient, s.config.WorkloadManagerURL)\n80: \tif err != nil {\n81: \t\treturn err\n82: \t}\n83: \n84: \ts.sessionManager = sessionManager\n85: \treturn nil\n86: }\n87: \n88: func (s *Server) initializeJWTManager(clientset kubernetes.Interface) error {\n89: \tif clientset == nil {\n90: \t\tklog.Warning(\"Kubernetes clientset not provided, JWT manager will not be fully functional\")\n91: \t\ts.jwtManager = &JWTManager{}\n92: \t\treturn nil\n93: \t}\n94: \n95: \tjwtManager, err := NewJWTManager(clientset, s.config.AgentcubeNamespace)\n96: \tif err != nil {\n97: \t\treturn err\n98: \t}\n99: \n100: \ts.jwtManager = jwtManager\n101: \treturn nil\n102: }\n103: \n104: func (s *Server) applyMiddleware() {\n105: \ts.engine.Use(recoveryMiddleware())\n106: \ts.engine.Use(loggingMiddleware())\n107: \ts.engine.Use(correlationIDMiddleware())\n108: \ts.engine.Use(concurrencyLimitMiddleware(s.limiter))\n109: \ts.engine.Use(metricsMiddleware(s.metrics))\n110: }\n111: \n112: func (s *Server) setupRoutes() {\n113: \ts.engine.GET(\"/health/live\", s.handler.handleHealthLive)\n114: \ts.engine.GET(\"/health/ready\", s.handler.handleHealthReady)\n115: \n116: \tv1 := s.engine.Group(\"/v1\")\n117: \t{\n118: \t\tsessions := v1.Group(\"/sessions\")\n119: \t\t{\n120: \t\t\tsessions.POST(\"/namespaces/:namespace/:kind/:name\", s.handler.handleCreateSession)\n121: \t\t}\n122: \n123: \t\tprotected := v1.Group(\"\")\n124: \t\tprotected.Use(jwtAuthMiddleware(s.jwtManager))\n125: \t\t{\n126: \t\t\tprotected.GET(\"/sessions/:sessionID\", s.handler.handleGetSession)\n127: \t\t}\n128: \n129: \t\tnamespaces := v1.Group(\"/namespaces/:namespace\")\n130: \t\t{\n131: \t\t\tagentRuntimes := namespaces.Group(\"/agent-runtimes/:name\")\n132: \t\t\t{\n133: \t\t\t\tagentRuntimes.Any(\"/invocations/*path\", s.handler.handleAgentInvoke)\n134: \t\t\t}\n135: \n136: \t\t\tcodeInterpreters := namespaces.Group(\"/code-interpreters/:name\")\n137: \t\t\t{\n138: \t\t\t\tcodeInterpreters.Any(\"/invocations/*path\", s.handler.handleCodeInterpreterInvoke)\n139: \t\t\t}\n140: \t\t}\n141: \t}\n142: }\n143: \n144: func (s *Server) Start(ctx context.Context) error {\n145: \tlistener, err := net.Listen(\"tcp\", s.httpServer.Addr)\n146: \tif err != nil {\n147: \t\treturn fmt.Errorf(\"failed to listen on %s: %w\", s.httpServer.Addr, err)\n148: \t}\n149: \n150: \tklog.Infof(\"Starting HTTP server on %s\", s.httpServer.Addr)\n151: \tklog.Infof(\"TLS enabled: %v\", s.config.EnableTLS)\n152: \tklog.Infof(\"Max concurrent requests: %d\", s.config.MaxConcurrentRequests)\n153: \n154: \terrChan := make(chan error, 1)\n155: \n156: \tgo func() {\n157: \t\tif s.config.EnableTLS {\n158: \t\t\terrChan <- s.httpServer.ServeTLS(listener, s.config.TLSCert, s.config.TLSKey)\n159: \t\t} else {\n160: \t\t\terrChan <- s.httpServer.Serve(listener)\n161: \t\t}\n162: \t}()\n163: \n164: \tselect {\n165: \tcase err := <-errChan:\n166: \t\tif err != nil && err != http.ErrServerClosed {\n167: \t\t\treturn fmt.Errorf(\"server error: %w\", err)\n168: \t\t}\n169: \t\treturn err\n170: \tcase <-ctx.Done():\n171: \t\treturn s.Shutdown(ctx)\n172: \t}\n173: }\n174: \n175: func (s *Server) Shutdown(ctx context.Context) error {\n176: \tklog.Info(\"Shutting down HTTP server...\")\n177: \n178: \tshutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n179: \tdefer cancel()\n180: \n181: \tif err := s.httpServer.Shutdown(shutdownCtx); err != nil {\n182: \t\tklog.Warningf(\"Error during server shutdown: %v\", err)\n183: \t\treturn err\n184: \t}\n185: \n186: \tklog.Info(\"HTTP server stopped\")\n187: \n188: \treturn nil\n189: }\n190: \n191: func (s *Server) GetMetrics() *Metrics {\n192: \treturn s.metrics\n193: }\n194: \n195: func (s *Server) GetActiveConnections() int {\n196: \treturn s.limiter.semaphoreLen()\n197: }\n198: \n199: func (l *ConcurrencyLimiter) semaphoreLen() int {\n200: \treturn len(l.semaphore)\n201: }\n\n(End of file - total 201 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go","time":{"start":1775893551650,"end":1775893551674}}}}
