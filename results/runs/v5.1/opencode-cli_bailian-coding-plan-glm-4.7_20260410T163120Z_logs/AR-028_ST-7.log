{"type":"tool_use","timestamp":1775879142097,"sessionID":"ses_2855b39bdffecO2fXIunWqEVjF","part":{"id":"prt_d7aa53a830012UTs7A97w2aI8U","messageID":"msg_d7aa514eb0015azHgcBmhkyu4h","sessionID":"ses_2855b39bdffecO2fXIunWqEVjF","type":"tool","tool":"read","callID":"toolu_tool-2402c48115f5434c9337f9bd959a415d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_agent_runtime_client.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_agent_runtime_client.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for AgentRuntimeClient.\"\"\"\n2: \n3: import os\n4: from unittest.mock import MagicMock, patch\n5: \n6: import pytest\n7: \n8: from agentcube.agent_runtime import AgentRuntimeClient\n9: \n10: \n11: @pytest.fixture\n12: def mock_router_url():\n13:     \"\"\"Return a mock router URL.\"\"\"\n14:     return \"http://router:8080\"\n15: \n16: \n17: @pytest.fixture\n18: def mock_agent_runtime_client(mock_router_url):\n19:     \"\"\"Return a mocked AgentRuntimeClient instance.\"\"\"\n20:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp_class:\n21:         mock_dp_instance = MagicMock()\n22:         mock_dp_instance.bootstrap_session_id.return_value = \"test-session-id\"\n23:         mock_dp_class.return_value = mock_dp_instance\n24: \n25:         client = AgentRuntimeClient(\n26:             agent_name=\"test-agent\",\n27:             namespace=\"default\",\n28:             router_url=mock_router_url,\n29:         )\n30: \n31:         yield client\n32: \n33:         client.close()\n34: \n35: \n36: def test_agent_runtime_client_init(mock_router_url):\n37:     \"\"\"Test AgentRuntimeClient initialization.\"\"\"\n38:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp_class:\n39:         mock_dp_instance = MagicMock()\n40:         mock_dp_instance.bootstrap_session_id.return_value = \"test-session-id\"\n41:         mock_dp_class.return_value = mock_dp_instance\n42: \n43:         client = AgentRuntimeClient(\n44:             agent_name=\"test-agent\",\n45:             namespace=\"default\",\n46:             router_url=mock_router_url,\n47:         )\n48: \n49:         assert client.agent_name == \"test-agent\"\n50:         assert client.namespace == \"default\"\n51:         assert client.router_url == mock_router_url\n52:         assert client.session_id == \"test-session-id\"\n53:         client.close()\n54: \n55: \n56: def test_agent_runtime_client_init_from_env(mock_router_url):\n57:     \"\"\"Test AgentRuntimeClient initialization from environment variable.\"\"\"\n58:     with patch.dict(os.environ, {\"ROUTER_URL\": mock_router_url}), patch(\n59:         \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\"\n60:     ) as mock_dp_class:\n61:         mock_dp_instance = MagicMock()\n62:         mock_dp_instance.bootstrap_session_id.return_value = \"test-session-id\"\n63:         mock_dp_class.return_value = mock_dp_instance\n64: \n65:         client = AgentRuntimeClient(\n66:             agent_name=\"test-agent\",\n67:             namespace=\"default\",\n68:         )\n69: \n70:         assert client.router_url == mock_router_url\n71:         client.close()\n72: \n73: \n74: def test_agent_runtime_client_init_with_session_id(mock_router_url):\n75:     \"\"\"Test AgentRuntimeClient initialization with existing session_id.\"\"\"\n76:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp_class:\n77:         mock_dp_instance = MagicMock()\n78:         mock_dp_class.return_value = mock_dp_instance\n79: \n80:         client = AgentRuntimeClient(\n81:             agent_name=\"test-agent\",\n82:             namespace=\"default\",\n83:             router_url=mock_router_url,\n84:             session_id=\"existing-session-id\",\n85:         )\n86: \n87:         assert client.session_id == \"existing-session-id\"\n88:         mock_dp_instance.bootstrap_session_id.assert_not_called()\n89:         client.close()\n90: \n91: \n92: def test_context_manager(mock_agent_runtime_client):\n93:     \"\"\"Test AgentRuntimeClient as context manager.\"\"\"\n94:     with patch.object(mock_agent_runtime_client, \"close\") as mock_close:\n95:         with mock_agent_runtime_client:\n96:             pass\n97: \n98:         mock_close.assert_called_once()\n99: \n100: \n101: def test_context_manager_with_exception(mock_router_url):\n102:     \"\"\"Test AgentRuntimeClient context manager with exception.\"\"\"\n103:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp_class:\n104:         mock_dp_instance = MagicMock()\n105:         mock_dp_instance.bootstrap_session_id.return_value = \"test-session-id\"\n106:         mock_dp_class.return_value = mock_dp_instance\n107: \n108:         with patch.object(AgentRuntimeClient, \"close\") as mock_close:\n109:             with pytest.raises(ValueError):\n110:                 with AgentRuntimeClient(\n111:                     agent_name=\"test-agent\",\n112:                     namespace=\"default\",\n113:                     router_url=mock_router_url,\n114:                 ):\n115:                     raise ValueError(\"Test error\")\n116: \n117:             mock_close.assert_called_once()\n118: \n119: \n120: def test_invoke_success(mock_agent_runtime_client):\n121:     \"\"\"Test invoke method success.\"\"\"\n122:     payload = {\"key\": \"value\"}\n123:     session_id = \"test-session-id\"\n124: \n125:     with patch.object(mock_agent_runtime_client.dp_client, \"invoke\") as mock_invoke:\n126:         mock_response = MagicMock()\n127:         mock_response.json.return_value = {\"result\": \"success\"}\n128:         mock_invoke.return_value = mock_response\n129: \n130:         result = mock_agent_runtime_client.invoke(payload)\n131: \n132:         assert result == {\"result\": \"success\"}\n133:         mock_invoke.assert_called_once_with(session_id, payload, timeout=None)\n134: \n135: \n136: def test_invoke_with_timeout(mock_agent_runtime_client):\n137:     \"\"\"Test invoke with custom timeout.\"\"\"\n138:     payload = {\"key\": \"value\"}\n139:     session_id = \"test-session-id\"\n140: \n141:     with patch.object(mock_agent_runtime_client.dp_client, \"invoke\") as mock_invoke:\n142:         mock_response = MagicMock()\n143:         mock_response.json.return_value = {\"result\": \"success\"}\n144:         mock_invoke.return_value = mock_response\n145: \n146:         result = mock_agent_runtime_client.invoke(payload, timeout=60.0)\n147: \n148:         assert result == {\"result\": \"success\"}\n149:         mock_invoke.assert_called_once_with(session_id, payload, timeout=60.0)\n150: \n151: \n152: def test_invoke_no_session_id():\n153:     \"\"\"Test invoke without session_id.\"\"\"\n154:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp_class:\n155:         mock_dp_instance = MagicMock()\n156:         mock_dp_class.return_value = mock_dp_instance\n157: \n158:         client = AgentRuntimeClient(\n159:             agent_name=\"test-agent\",\n160:             namespace=\"default\",\n161:             router_url=\"http://router:8080\",\n162:             session_id=None,\n163:         )\n164:         client.session_id = None\n165: \n166:         with pytest.raises(ValueError, match=\"AgentRuntime session_id is not initialized\"):\n167:             client.invoke({\"key\": \"value\"})\n168: \n169:         client.close()\n170: \n171: \n172: def test_close(mock_agent_runtime_client):\n173:     \"\"\"Test close method.\"\"\"\n174:     mock_agent_runtime_client.close()\n175:     mock_agent_runtime_client.close()\n176: \n177: \n178: def test_verbose_logging(mock_router_url):\n179:     \"\"\"Test verbose logging.\"\"\"\n180:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp_class:\n181:      