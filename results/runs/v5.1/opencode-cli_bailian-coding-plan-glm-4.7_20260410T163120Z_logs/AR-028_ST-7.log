: def test_custom_agent_name(mock_router_url):\n234:     \"\"\"Test custom agent name.\"\"\"\n235:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp_class:\n236:         mock_dp_instance = MagicMock()\n237:         mock_dp_instance.bootstrap_session_id.return_value = \"test-session-id\"\n238:         mock_dp_class.return_value = mock_dp_instance\n239: \n240:         client = AgentRuntimeClient(\n241:             agent_name=\"custom-agent\",\n242:             namespace=\"default\",\n243:             router_url=mock_router_url,\n244:         )\n245: \n246:         assert client.agent_name == \"custom-agent\"\n247:         client.close()\n\n(End of file - total 247 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentRuntimeClient.\"\"\"\n\nimport os\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\n\n\n@pytest.fixture\ndef mock_router_url():\n    \"\"\"Return a mock router URL.\"\"\"\n    return \"http://router:8080\"\n\n\n@pytest.fixture\ndef mock_agent_runtime_client(mock_router_url):\n    \"\"\"Return a mocked AgentRuntimeClient instance.\"\"\"\n    with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\") as mock_dp_class:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_agent_runtime_client.py","time":{"start":1775879142076,"end":1775879142095}}}}
