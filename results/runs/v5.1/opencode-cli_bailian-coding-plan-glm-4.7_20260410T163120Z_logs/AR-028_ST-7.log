verbose\n39:         self.logger = get_logger(f\"{__name__}.AgentRuntimeClient\")\n40: \n41:         if verbose:\n42:             self.logger.setLevel(10)\n43: \n44:         self.router_url = router_url or os.getenv(\"ROUTER_URL\", \"\")\n45: \n46:         if not self.router_url:\n47:             self.logger.warning(\"ROUTER_URL not set\")\n48: \n49:         self.session_id = session_id\n50:         self.dp_client = AgentRuntimeDataPlaneClient(\n51:             router_url=self.router_url,\n52:             namespace=namespace,\n53:             agent_name=agent_name,\n54:             timeout=timeout,\n55:             connect_timeout=connect_timeout,\n56:         )\n57: \n58:         if not self.session_id:\n59:             self.session_id = self.dp_client.bootstrap_session_id()\n60: \n61:     def __enter__(self) -> \"AgentRuntimeClient\":\n62:         \"\"\"Enter context manager.\n63: \n64:         Returns:\n65:             Self\n66:         \"\"\"\n67:         return self\n68: \n69:     def __exit__(self, exc_type: Optional[object], exc_val: Optional[object], exc_tb: Optional[object]) -> None:\n70:         \"\"\"Exit context manager and cleanup.\n71: \n72:         Args:\n73:             exc_type: Exception type\n74:             exc_val: Exception value\n75:             exc_tb: Exception traceback\n76:         \"\"\"\n77:         self.close()\n78: \n79:     def invoke(self, payload: dict[str, Any], timeout: Optional[float] = None) -> dict[str, Any]:\n80:         \"\"\"Invoke the Agent Runtime with a payload.\n81: \n82:         Args:\n83:             payload: JSON payload to send\n84:             timeout: Timeout in seconds\n85: \n86:         Returns:\n87:             Response JSON\n88: \n89:         Raises:\n90:             ValueError: If session_id is not initialized\n91:         \"\"\"\n92:         if not self.session_id:\n93:             raise ValueError(\"AgentRuntime session_id is not initialized\")\n94: \n95:         response = self.dp_client.invoke(self.session_id, payload, timeout=timeout)\n96:         return response.json()\n97: \n98:     def close(self) -> None:\n99:         \"\"\"Close the underlying HTTP session.\"\"\"\n100:         self.dp_client.close()\n101:         self.logger.info(\"Closed Agent Runtime client\")\n\n(End of file - total 101 lines)\n</content>","metadata":{"preview":"\"\"\"Agent Runtime client for invoking agent workloads.\"\"\"\n\nimport os\nfrom typing import Any, Optional\n\nfrom .clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom .utils import get_logger\n\n\nclass AgentRuntimeClient:\n    \"\"\"Client for Agent Runtime invocation.\"\"\"\n\n    def __init__(\n        self,\n        agent_name: str,\n        namespace: str = \"default\",\n        router_url: Optional[str] = None,\n        verbose: bool = False,\n        session_id: Optional[str] = None,\n        timeout: int = 120,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/agentcube/agent_runtime.py","time":{"start":1775879132325,"end":1775879132339}}}}
