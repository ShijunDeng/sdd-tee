rpreters[key]\n43: \tif !exists {\n44: \t\treturn nil, nil\n45: \t}\n46: \n47: \treturn ci, nil\n48: }\n49: \n50: func (rc *ResourceCache) UpdateAgentRuntime(ar *agentcubev1alpha1.AgentRuntime) {\n51: \trc.mu.Lock()\n52: \tdefer rc.mu.Unlock()\n53: \n54: \tkey := rc.agentRuntimeKey(ar.Namespace, ar.Name)\n55: \trc.agentRuntimes[key] = ar\n56: \trc.resourceVersions[key] = ar.ResourceVersion\n57: }\n58: \n59: func (rc *ResourceCache) UpdateCodeInterpreter(ci *agentcubev1alpha1.CodeInterpreter) {\n60: \trc.mu.Lock()\n61: \tdefer rc.mu.Unlock()\n62: \n63: \tkey := rc.codeInterpreterKey(ci.Namespace, ci.Name)\n64: \trc.codeInterpreters[key] = ci\n65: \trc.resourceVersions[key] = ci.ResourceVersion\n66: }\n67: \n68: func (rc *ResourceCache) DeleteAgentRuntime(namespace, name string) {\n69: \trc.mu.Lock()\n70: \tdefer rc.mu.Unlock()\n71: \n72: \tkey := rc.agentRuntimeKey(namespace, name)\n73: \tdelete(rc.agentRuntimes, key)\n74: \tdelete(rc.resourceVersions, key)\n75: }\n76: \n77: func (rc *ResourceCache) DeleteCodeInterpreter(namespace, name string) {\n78: \trc.mu.Lock()\n79: \tdefer rc.mu.Unlock()\n80: \n81: \tkey := rc.codeInterpreterKey(namespace, name)\n82: \tdelete(rc.codeInterpreters, key)\n83: \tdelete(rc.resourceVersions, key)\n84: }\n85: \n86: func (rc *ResourceCache) HasResourceChanged(namespace, name, kind, resourceVersion string) bool {\n87: \trc.mu.RLock()\n88: \tdefer rc.mu.RUnlock()\n89: \n90: \tvar key string\n91: \tif kind == \"AgentRuntime\" {\n92: \t\tkey = rc.agentRuntimeKey(namespace, name)\n93: \t} else if kind == \"CodeInterpreter\" {\n94: \t\tkey = rc.codeInterpreterKey(namespace, name)\n95: \t} else {\n96: \t\treturn true\n97: \t}\n98: \n99: \tstoredVersion, exists := rc.resourceVersions[key]\n100: \tif !exists {\n101: \t\treturn true\n102: \t}\n103: \n104: \treturn storedVersion != resourceVersion\n105: }\n106: \n107: func (rc *ResourceCache) ListAgentRuntimes() []*agentcubev1alpha1.AgentRuntime {\n108: \trc.mu.RLock()\n109: \tdefer rc.mu.RUnlock