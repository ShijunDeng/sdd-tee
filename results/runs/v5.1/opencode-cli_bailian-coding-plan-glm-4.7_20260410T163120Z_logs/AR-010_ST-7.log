 \t\t}\n44: \t})\n45: }\n46: \n47: func TestSessionManager_InitializeInformers(t *testing.T) {\n48: \tt.Run(\"With valid clientset\", func(t *testing.T) {\n49: \t\tfakeStore := &fakeStore{}\n50: \t\tfakeClientset := fake.NewSimpleClientset()\n51: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n52: \t\tif err != nil {\n53: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n54: \t\t}\n55: \n56: \t\terr = manager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n57: \t\tif err != nil {\n58: \t\t\tt.Errorf(\"InitializeInformers returned error: %v\", err)\n59: \t\t}\n60: \t})\n61: \n62: \tt.Run(\"With nil clientset\", func(t *testing.T) {\n63: \t\tfakeStore := &fakeStore{}\n64: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n65: \t\tif err != nil {\n66: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n67: \t\t}\n68: \n69: \t\terr = manager.InitializeInformers(nil, \"default\", 10*time.Minute)\n70: \t\tif err != nil {\n71: \t\t\tt.Errorf(\"InitializeInformers with nil clientset should not return error: %v\", err)\n72: \t\t}\n73: \t})\n74: }\n75: \n76: func TestSessionManager_StartInformers(t *testing.T) {\n77: \tfakeStore := &fakeStore{}\n78: \tfakeClientset := fake.NewSimpleClientset()\n79: \tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n80: \tif err != nil {\n81: \t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n82: \t}\n83: \n84: \tmanager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n85: \tmanager.StartInformers()\n86: \n87: \ttime.Sleep(50 * time.Millisecond)\n88: }\n89: \n90: func TestSessionManager_StopInformers(t *testing.T) {\n91: \tfakeStore := &fakeStore{}\n92: \tfakeClientset := fake.NewSimpleClientset()\n93: \tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n94: \tif err != nil {\n95: \t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n96: \t}\n97: \n98: \tmanager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n99: \tmanager.StartInformers()\n100: \ttime.Sleep(50 * time.Millisecond)\n\n(Showing lines 1-100 of 642. Use offset=101 to continue.)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\nfunc TestNewSessionManager(t *testing.T) {\n\tt.Run(\"Valid parameters\", func(t *testing.T) {\n\t\tfakeStore := &fakeStore{}","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/session_manager_test.go","time":{"start":1775851222076,"end":1775851222100}}}}
