ientset != nil && im.informerFactory != nil\n120: }\n\n(End of file - total 120 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"time\"\n\n\t\"k8s.io/apimachinery/pkg/util/runtime\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype InformerManager struct {\n\tclientset       kubernetes.Interface\n\tinformerFactory informers.SharedInformerFactory\n\tresourceCache   *ResourceCache\n\tstopCh          chan struct{}\n\tresyncPeriod    time.Duration\n\tnamespace       string\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/informer_manager.go","time":{"start":1775851177796,"end":1775851177813}}}}
