 integration tests**\n\n```python\n# tests/integration/test_agent_runtime_integration.py\nimport pytest\nfrom unittest.mock import MagicMock, patch\nfrom agentcube import AgentRuntimeClient\n\n\n@pytest.fixture\ndef mock_router():\n    \"\"\"Create a mock Router service.\"\"\"\n    with patch(\"agentcube.clients.agent_runtime_data_plane.create_session\") as mock_create:\n        mock_session = MagicMock()\n        mock_create.return_value = mock_session\n        yield mock_session\n\n\ndef test_end_to_end_invocation(mock_router):\n    \"\"\"Test end-to-end agent invocation workflow.\"\"\"\n    # Mock session bootstrap\n    mock_bootstrap_response = MagicMock()\n    mock_bootstrap_response.headers = {\"x-agentcube-session-id\": \"test-session-123\"}\n    mock_router.get.return_value = mock_bootstrap_response\n\n    # Mock invoke response\n    mock_invoke_response = MagicMock()\n    mock_invoke_response.json.return_value = {\n        \"result\": \"success\",\n        \"answer\": \"Paris is the capital of France\"\n    }\n    mock_router.post.return_value = mock_invoke_response\n\n    # Use client in context manager\n    with AgentRuntimeClient(\n        agent_name=\"my-agent\",\n        namespace=\"default\",\n        router_url=\"http://router:8080\"\n    ) as client:\n        result = client.invoke({\"query\": \"What is the capital of France?\"})\n\n        assert result[\"result\"] == \"success\"\n        assert \"Paris\" in result[\"answer\"]\n\n    # Verify session was closed\n    mock_router.close.assert_called_once()\n\n\ndef test_session_reuse_across_invocations(mock_router):\n    \"\"\"Test session is reused across multiple invocations.\"\"\"\n    # Mock session bootstrap\n    mock_bootstrap_response = MagicMock()\n    mock_bootstrap_response.headers = {\"x-agentcube-session-id\": \"test-session-456\"}\n    mock_router.get.return_value = mock_bootstrap_response\n\n    # Mock invoke responses\n    mock_invoke_response = MagicMock()\n    mock_invoke_response.json.return_value = {\"result\": \"ok\"}\n    mock_router.post.return_value = mock_invoke_response\n\n    with AgentRuntimeClient(\n        agent_name=\"my-agent\",\n        router_url=\"http://router:8080\"\n    ) as client:\n        # First invocation\n        result1 = client.invoke({\"query\": \"first\"})\n        assert result1[\"result\"] == \"ok\"\n\n        # Second invocation - should reuse same session\n        result2 = client.invoke({\"query\": \"second\"})\n        assert result2[\"result\"] == \"ok\"\n\n    # Verify bootstrap was called only once\n    mock_router.get.assert_called_once()\n\n    # Verify invoke was called twice\n    assert mock_router.post.call_count == 2\n\n\ndef test_multiple_invocations_with_different_timeouts(mock_router):\n    \"\"\"Test multiple invocations with different timeouts.\"\"\"\n    mock_bootstrap_response = MagicMock()\n    mock_bootstrap_response.headers = {\"x-agentcube-session-id\": \"test-session-789\"}\n    mock_router.get.return_value = mock_bootstrap_response\n\n    mock_invoke_response = MagicMock()\n    mock_invoke_response.json.return_value = {\"result\": \"ok\"}\n    mock_router.post.return_value = mock_invoke_response\n\n    with AgentRuntimeClient(\n        agent_name=\"my-agent\",\n        router_url=\"http://router:8080\"\n    ) as client:\n        # Short timeout invocation\n        result1 = client.invoke({\"query\": \"quick\"}, timeout=30.0)\n        assert result1[\"result\"] == \"ok\"\n\n        # Long timeout invocation\n        result2 = client.invoke({\"query\": \"slow\"}, timeout=300.0)\n        assert result2[\"result\"] == \"ok\"\n\n    # Verify timeouts were passed correctly\n    first_call = mock_router.post.call_args_list[0]\n    second_call = mock_router.post.call_args_list[1]\n\n    # First call should have (5.0, 30.0) timeout tuple\n    assert first_call.kwargs[\"timeout\"] == (5.0, 30.0)\n\n    # Second call should have (5.0, 300.0) timeout tuple\n    assert second_call.kwargs[\"timeout\"] == (5.0, 300.0)\n```\n\n**Step 2: Run integration tests**\n\n```bash\npython -m pytest tests/integration/ -v\n```\n\nExpected: All integration tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add tests/integration/test_agent_runtime_integration.py\ngit commit -m \"test(ar-028): add integration tests with mock Router\"\n```\n\n---\n\n### Task 13: Create usage examples\n\n**Files:**\n- Create: `examples/agent_runtime_basic.py`\n- Create: `examples/agent_runtime_session_reuse.py`\n- Create: `examples/agent_runtime_custom_timeout.py`\n\n**Step 1: Create basic usage example**\n\n```python\n# examples/agent_runtime_basic.py\n\"\"\"Basic AgentRuntimeClient usage example.\"\"\"\n\nfrom agentcube import AgentRuntimeClient\n\n\ndef main():\n    \"\"\"Demonstrate basic agent invocation.\"\"\"\n    # Initialize client and use as context manager\n    with AgentRuntimeClient(\n        agent_name=\"my-agent\",\n        namespace=\"default\",\n        router_url=\"http://router:8080\"\n    ) as client:\n        # Invoke agent with a query\n        result = client.invoke({\"query\": \"What is the capital of France?\"})\n\n        print(\"Agent response:\")\n        print(result)\n\n\nif __name__ == \"__main__\":\n    main()\n```\n\n**Step 2: Create session reuse example**\n\n```python\n# examples/agent_runtime_session_reuse.py\n\"\"\"AgentRuntimeClient session reuse example.\"\"\"\n\nfrom agentcube import AgentRuntimeClient\n\n\ndef main():\n    \"\"\"Demonstrate session reuse across multiple invocations.\"\"\"\n    with AgentRuntimeClient(\n        agent_name=\"my-agent\",\n        router_url=\"http://router:8080\"\n    ) as client:\n        # Session is bootstrapped on first use\n        result1 = client.invoke({\"query\": \"What is 2 + 2?\"})\n        print(f\"Result 1: {result1}\")\n\n        # Same session is reused\n        result2 = client.invoke({\"query\": \"What is 3 + 3?\"})\n        print(f\"Result 2: {result2}\")\n\n        result3 = client.invoke({\"query\": \"What is 4 + 4?\"})\n        print(f\"Result 3: {result3}\")\n\n\nif __name__ == \"__main__\":\n    main()\n```\n\n**Step 3: Create custom timeout example**\n\n```python\n# examples/agent_runtime_custom_timeout.py\n\"\"\"AgentRuntimeClient custom timeout example.\"\"\"\n\nfrom agentcube import AgentRuntimeClient\n\n\ndef main():\n    \"\"\"Demonstrate custom timeout configuration.\"\"\"\n    # Client with long default timeout\n    with AgentRuntimeClient(\n        agent_name=\"my-agent\",\n        router_url=\"http://router:8080\",\n        timeout=300,  # 5 minutes\n        connect_timeout=10.0  # 10 seconds\n    ) as client:\n        # Quick query with default timeout\n        result1 = client.invoke({\"query\": \"Quick question\"})\n        print(f\"Quick result: {result1}\")\n\n        # Long-running query with per-call timeout override\n        result2 = client.invoke(\n            {\"query\": \"Complex analysis\"},\n            timeout=600  # 10 minutes\n        )\n        print(f\"Long result: {result2}\")\n\n\nif __name__ == \"__main__\":\n    main()\n```\n\n**Step 4: Commit**\n\n```bash\ngit add examples/agent_runtime_basic.py examples/agent_runtime_session_reuse.py examples/agent_runtime_custom_timeout.py\ngit commit -m \"docs(ar-028): add usage examples for AgentRuntimeClient\"\n```\n\n---\n\n### Task 14: Update documentation\n\n**Files:**\n- Modify: `README.md`\n- Create: `docs/agent_runtime_client.md`\n\n**Step 1: Create AgentRuntimeClient documentation**\n\n```markdown\n# AgentRuntimeClient Documentation\n\nThe AgentRuntimeClient provides a high-level interface for invoking agent runtime workloads through the Router service.\n\n## Installation\n\n```bash\npip install agentcube-sdk\n```\n\n## Quick Start\n\n```python\nfrom agentcube import AgentRuntimeClient\n\nwith AgentRuntimeClient(\n    agent_name=\"my-agent\",\n    router_url=\"http://router:8080\"\n) as client:\n    result = client.invoke({\"query\": \"What is the capital of France?\"})\n    print(result)\n```\n\n## Configuration\n\n### Environment Variables\n\n| Variable | Description | Required |\n|----------|-------------|----------|\n| `ROUTER_URL` | Router service URL | No (can be passed to constructor) |\n\n### Constructor Parameters\n\n| Parameter | Type | Default | Description |\n|-----------|------|---------|-------------|\n| `agent_name` | str | Required | Agent runtime name |\n| `namespace` | str | \"default\" | Kubernetes namespace |\n| `router_url` | str \\| None | None | Router URL |\n| `verbose` | bool | False | Enable verbose logging |\n| `session_id` | str \\| None | None | Existing session ID to reuse |\n| `timeout` | int | 120 | Read timeout in seconds |\n| `connect_timeout` | float | 5.0 | Connection timeout in seconds |\n\n## API Reference\n\n### AgentRuntimeClient\n\n#### `__init__(agent_name, namespace=\"default\", router_url=None, verbose=False, session_id=None, timeout=120, connect_timeout=5.0)`\n\nInitialize the AgentRuntimeClient.\n\n#### `__enter__()`\n\nEnter context manager. Returns `self`.\n\n#### `__exit__(exc_type, exc_val, exc_tb)`\n\nExit context manager. Calls `close()`.\n\n#### `invoke(payload, timeout=None)`\n\nInvoke the agent runtime with a payload.\n\n**Parameters:**\n- `payload`: Dict[str, Any] - JSON payload to send\n- `timeout`: Optional[float] - Timeout in seconds (overrides default)\n\n**Returns:** Dict[str, Any] - Response JSON\n\n**Raises:**\n- `ValueError`: If session_id is not initialized\n- `requests.RequestException`: If the request fails\n\n#### `close()`\n\nClose the underlying HTTP session.\n\n## Session Management\n\n### Automatic Session Bootstrap\n\nWhen `session_id` is not provided, the client automatically bootstraps a session ID from the Router:\n\n```python\nclient = AgentRuntimeClient(agent_name=\"my-agent\")\n# Session ID is bootstrapped on first use\nresult = client.invoke({\"query\": \"hello\"})\n```\n\n### Session Reuse\n\nYou can reuse an existing session by providing `session_id`:\n\n```python\nclient = AgentRuntimeClient(\n    agent_name=\"my-agent\",\n    session_id=\"existing-session-id\"\n)\n# Skips bootstrap, uses provided session ID\nresult = client.invoke({\"query\": \"hello\"})\n```\n\n## Error Handling\n\n```python\nfrom agentcube import AgentRuntimeClient\n\ntry:\n    with AgentRuntimeClient(agent_name=\"my-agent\") as client:\n        result = client.invoke({\"query\": \"test\"})\nexcept ValueError as e:\n    print(f\"Configuration error: {e}\")\nexcept requests.RequestException as e:\n    print(f\"Network error: {e}\")\n```\n\n## Examples\n\nSee the `examples/` directory for complete usage examples:\n- `agent_runtime_basic.py` - Basic usage\n- `agent_runtime_session_reuse.py` - Session reuse\n- `agent_runtime_custom_timeout.py` - Custom timeout configuration\n```\n\n**Step 2: Update main README.md**\n\nAdd section about AgentRuntimeClient to README.md.\n\n**Step 3: Commit**\n\n```bash\ngit add README.md docs/agent_runtime_client.md\ngit commit -m \"docs(ar-028): update AgentRuntimeClient documentation\"\n```\n\n---\n\n### Task 15: Final verification and cleanup\n\n**Files:**\n- None (verification task)\n\n**Step 1: Run all tests**\n\n```bash\npython -m pytest tests/ -v --cov=agentcube\n```\n\nExpected: All tests PASS with >80% coverage\n\n**Step 2: Run linting**\n\n```bash\nruff check agentcube/\n```\n\nFix any linting issues.\n\n**Step 3: Run type checking**\n\n```bash\nmypy agentcube/\n```\n\nExpected: No type errors\n\n**Step 4: Verify package builds**\n\n```bash\npython -m build\n```\n\nExpected: Build succeeds\n\n**Step 5: Verify all examples run (optional)**\n\n```bash\npython examples/agent_runtime_basic.py\npython examples/agent_runtime_session_reuse.py\npython examples/agent_runtime_custom_timeout.py\n```\n\n**Step 6: Update CHANGE.md**\n\nAdd entry for AR-028 implementation.\n\n**Step 7: Final commit**\n\n```bash\ngit add CHANGE.md\ngit commit -m \"chore(ar-028): final verification and cleanup\"\n```\n\n---\n\n## Summary\n\nThis implementation plan breaks down AR-028 (SDK AgentRuntimeClient) into 15 atomic, independently verifiable tasks:\n\n1. **Verify AgentRuntimeClient class structure** - Ensure all required methods and attributes exist\n2. **Verify AgentRuntimeClient initialization** - Test all constructor parameters and defaults\n3. **Verify context manager support** - Test `__enter__`/`__exit__` behavior\n4. **Verify invoke method** - Test invocation with various payloads and timeouts\n5. **Verify AgentRuntimeDataPlaneClient** - Test HTTP client implementation\n6. **Verify HTTP session utilities** - Test connection pooling and retry strategy\n7. **Verify logging utilities** - Test logger creation and configuration\n8. **Verify exception hierarchy** - Test all exception classes\n9. **Run all tests with coverage** - Ensure >80% code coverage\n10. **Verify type checking** - Run mypy and fix type errors\n11. **Verify package builds** - Ensure package builds and installs correctly\n12. **Create integration tests** - Test end-to-end workflows\n13. **Create usage examples** - Provide example code\n14. **Update documentation** - Create comprehensive docs\n15. **Final verification** - Run all checks and cleanup\n\nEach task follows the verification pattern:\n- Write comprehensive tests\n- Run tests to verify behavior\n- Document findings\n- Commit changes\n\nThe implementation ensures:\n- AgentRuntimeClient provides a simple, intuitive API\n- Session management is automatic and seamless\n- Context manager support ensures proper resource cleanup\n- Error handling is clear and informative\n- Connection pooling optimizes performance\n- High test coverage and code quality\n- Comprehensive documentation and examples","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tasks.md"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260