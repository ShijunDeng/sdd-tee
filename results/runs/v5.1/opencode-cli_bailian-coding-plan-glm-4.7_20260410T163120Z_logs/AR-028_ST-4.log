o INFO.\"\"\"\n    logger = get_logger(\"test_logger_default\")\n\n    assert logger.level == logging.INFO\n\n\ndef test_get_logger_custom_level():\n    \"\"\"Test get_logger sets custom level.\"\"\"\n    logger = get_logger(\"test_logger_custom\", level=logging.DEBUG)\n\n    assert logger.level == logging.DEBUG\n\n\ndef test_get_logger_string_level():\n    \"\"\"Test get_logger accepts string level.\"\"\"\n    logger = get_logger(\"test_logger_string\", level=\"DEBUG\")\n\n    assert logger.level == logging.DEBUG\n\n\ndef test_get_logger_same_instance():\n    \"\"\"Test get_logger returns same instance for same name.\"\"\"\n    logger1 = get_logger(\"test_logger_same\")\n    logger2 = get_logger(\"test_logger_same\")\n\n    assert logger1 is logger2\n\n\ndef test_get_logger_has_handler():\n    \"\"\"Test get_logger adds stream handler.\"\"\"\n    logger = get_logger(\"test_logger_handler\")\n\n    assert len(logger.handlers) > 0\n    assert isinstance(logger.handlers[0], logging.StreamHandler)\n```\n\n**Step 2: Run test to verify it passes**\n\nRun: `python -m pytest tests/test_log_utils.py -v`\nExpected: PASS\n\n**Step 3: Commit**\n\n```bash\ngit add tests/test_log_utils.py\ngit commit -m \"test(ar-028): verify logging utilities\"\n```\n\n---\n\n### Task 8: Verify exception hierarchy\n\n**Files:**\n- Verify: `agentcube/exceptions.py`\n- Create: `tests/test_exceptions.py`\n\n**Step 1: Write the failing test**\n\n```python\n# tests/test_exceptions.py\nimport pytest\nfrom agentcube.exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    SessionError,\n    DataPlaneError,\n)\n\n\ndef test_agent_cube_error_base_exception():\n    \"\"\"Test AgentCubeError is an Exception.\"\"\"\n    assert issubclass(AgentCubeError, Exception)\n\n\ndef test_command_execution_error_inherits():\n    \"\"\"Test CommandExecutionError inherits from AgentCubeError.\"\"\"\n    assert issubclass(CommandExecutionError, AgentCubeError)\n\n\ndef test_command_execution_error_attri