{"type":"tool_use","timestamp":1775878147542,"sessionID":"ses_2856a97e0ffey48D6qOMQnb0po","part":{"id":"prt_d7a96055b001BKNcdvEYEb6yOB","messageID":"msg_d7a95d8f5001WdIu2dkvVAlL6b","sessionID":"ses_2856a97e0ffey48D6qOMQnb0po","type":"tool","tool":"read","callID":"toolu_tool-835f1ccce35e48a98c1d34e11b0277b3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_agent_runtime_client.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_agent_runtime_client.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for AgentRuntimeClient.\"\"\"\n2: \n3: import os\n4: from unittest.mock import MagicMock, patch\n5: \n6: import pytest\n7: \n8: from agentcube.agent_runtime import AgentRuntimeClient\n9: \n10: \n11: @pytest.fixture\n12: def mock_router_url():\n13:     \"\"\"Return a mock router URL.\"\"\"\n14:     return \"http://router:8080\"\n15: \n16: \n17: @pytest.fixture\n18: def agent_runtime_client(mock_router_url):\n19:     \"\"\"Return an AgentRuntimeClient instance.\"\"\"\n20:     return AgentRuntimeClient(\n21:         agent_name=\"test-agent\",\n22:         namespace=\"default\",\n23:         router_url=mock_router_url,\n24:     )\n25: \n26: \n27: def test_agent_runtime_client_init(mock_router_url):\n28:     \"\"\"Test AgentRuntimeClient initialization.\"\"\"\n29:     with patch.object(\n30:         AgentRuntimeClient, \"AgentRuntimeDataPlaneClient\", autospec=True\n31:     ) as mock_dp_class, patch.object(mock_dp_class.return_value, \"bootstrap_session_id\") as mock_bootstrap:\n32:         mock_bootstrap.return_value = \"test-session-id\"\n33:         mock_dp_class.return_value.bootstrap_session_id = mock_bootstrap\n34: \n35:         client = AgentRuntimeClient(\n36:             agent_name=\"test-agent\",\n37:             namespace=\"default\",\n38:             router_url=mock_router_url,\n39:         )\n40: \n41:         assert client.agent_name == \"test-agent\"\n42:         assert client.namespace == \"default\"\n43:         assert client.router_url == mock_router_url\n44:         assert client.session_id == \"test-session-id\"\n45:         client.close()\n46: \n47: \n48: def test_agent_runtime_client_init_from_env(mock_router_url):\n49:     \"\"\"Test AgentRuntimeClient initialization from environment variable.\"\"\"\n50:     with patch.dict(os.environ, {\"ROUTER_URL\": mock_router_url}), patch(\n51:         \"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\", autospec=True\n52:     ) as mock_dp_class:\n53:         mock_dp_instance = MagicMock()\n54:         mock_dp_instance.bootstrap_session_id.return_value = \"test-session-id\"\n55:         mock_dp_class.return_value = mock_dp_instance\n56: \n57:         client = AgentRuntimeClient(\n58:             agent_name=\"test-agent\",\n59:             namespace=\"default\",\n60:         )\n61: \n62:         assert client.router_url == mock_router_url\n63:         client.close()\n64: \n65: \n66: def test_agent_runtime_client_init_with_session_id(mock_router_url):\n67:     \"\"\"Test AgentRuntimeClient initialization with existing session_id.\"\"\"\n68:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\", autospec=True) as mock_dp_class:\n69:         mock_dp_instance = MagicMock()\n70:         mock_dp_class.return_value = mock_dp_instance\n71: \n72:         client = AgentRuntimeClient(\n73:             agent_name=\"test-agent\",\n74:             namespace=\"default\",\n75:             router_url=mock_router_url,\n76:             session_id=\"existing-session-id\",\n77:         )\n78: \n79:         assert client.session_id == \"existing-session-id\"\n80:         mock_dp_instance.bootstrap_session_id.assert_not_called()\n81:         client.close()\n82: \n83: \n84: def test_context_manager(agent_runtime_client):\n85:     \"\"\"Test AgentRuntimeClient as context manager.\"\"\"\n86:     with patch.object(agent_runtime_client, \"close\") as mock_close:\n87:         with agent_runtime_client:\n88:             pass\n89: \n90:         mock_close.assert_called_once()\n91: \n92: \n93: def test_context_manager_with_exception(agent_runtime_client):\n94:     \"\"\"Test AgentRuntimeClient context manager with exception.\"\"\"\n95:     with patch.object(agent_runtime_client, \"close\") as mock_close:\n96:         with pytest.raises(ValueError):\n97:             with agent_runtime_client:\n98:                 raise ValueError(\"Test error\")\n99: \n100:         mock_close.assert_called_once()\n101: \n102: \n103: def test_invoke_success(agent_runtime_client):\n104:     \"\"\"Test invoke method success.\"\"\"\n105:     payload = {\"key\": \"value\"}\n106:     session_id = \"test-session-id\"\n107: \n108:     with patch.object(agent_runtime_client.dp_client, \"invoke\") as mock_invoke:\n109:         mock_response = MagicMock()\n110:         mock_response.json.return_value = {\"result\": \"success\"}\n111:         mock_invoke.return_value = mock_response\n112: \n113:         result = agent_runtime_client.invoke(payload)\n114: \n115:         assert result == {\"result\": \"success\"}\n116:         mock_invoke.assert_called_once_with(session_id, payload, timeout=None)\n117: \n118: \n119: def test_invoke_with_timeout(agent_runtime_client):\n120:     \"\"\"Test invoke with custom timeout.\"\"\"\n121:     payload = {\"key\": \"value\"}\n122:     session_id = \"test-session-id\"\n123: \n124:     with patch.object(agent_runtime_client.dp_client, \"invoke\") as mock_invoke:\n125:         mock_response = MagicMock()\n126:         mock_response.json.return_value = {\"result\": \"success\"}\n127:         mock_invoke.return_value = mock_response\n128: \n129:         result = agent_runtime_client.invoke(payload, timeout=60.0)\n130: \n131:         assert result == {\"result\": \"success\"}\n132:         mock_invoke.assert_called_once_with(session_id, payload, timeout=60.0)\n133: \n134: \n135: def test_invoke_no_session_id():\n136:     \"\"\"Test invoke without session_id.\"\"\"\n137:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\", autospec=True) as mock_dp_class:\n138:         mock_dp_instance = MagicMock()\n139:         mock_dp_class.return_value = mock_dp_instance\n140: \n141:         client = AgentRuntimeClient(\n142:             agent_name=\"test-agent\",\n143:             namespace=\"default\",\n144:             router_url=\"http://router:8080\",\n145:             session_id=None,\n146:         )\n147:         client.session_id = None\n148: \n149:         with pytest.raises(ValueError, match=\"AgentRuntime session_id is not initialized\"):\n150:             client.invoke({\"key\": \"value\"})\n151: \n152:         client.close()\n153: \n154: \n155: def test_close(agent_runtime_client):\n156:     \"\"\"Test close method.\"\"\"\n157:     agent_runtime_client.close()\n158:     agent_runtime_client.close()\n159: \n160: \n161: def test_verbose_logging(mock_router_url):\n162:     \"\"\"Test verbose logging.\"\"\"\n163:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\", autospec=True) as mock_dp_class:\n164:         mock_dp_instance = MagicMock()\n165:         mock_dp_instance.bootstrap_session_id.return_value = \"test-session-id\"\n166:         mock_dp_class.return_value = mock_dp_instance\n167: \n168:         client = AgentRuntimeClient(\n169:             agent_name=\"test-agent\",\n170:             namespace=\"default\",\n171:             router_url=mock_router_url,\n172:             verbose=True,\n173:         )\n174: \n175:         assert client.verbose is True\n176:         client.close()\n177: \n178: \n179: def test_custom_timeout(mock_router_url):\n180:     \"\"\"Test custom timeout.\"\"\"\n181:     with patch(\"agentcube.agent_runtime.AgentRuntimeDataPlaneClient\", autospec=True) as mock_dp_class:\n182:         mock_dp_instance = MagicMock()\n183:         mock_dp_instance.bootstrap_session_id.