 \tengine       *gin.Engine\n1095: \tconfig       Config\n1096: \tauthManager  *AuthManager\n1097: \tstartTime    time.Time\n1098: \tworkspaceDir string\n1099: \thttpServer   *http.Server\n1100: \tlockManager  *FileLockManager // Add this field\n1101: }\n1102: \n1103: func NewServer(config Config) (*Server, error) {\n1104: \t// ... existing code ...\n1105: \n1106: \tserver := &Server{\n1107: \t\tengine:       engine,\n1108: \t\tconfig:       config,\n1109: \t\tauthManager:  authManager,\n1110: \t\tstartTime:    time.Now(),\n1111: \t\tworkspaceDir: absWorkspace,\n1112: \t\tlockManager:  NewFileLockManager(), // Initialize lock manager\n1113: \t}\n1114: \n1115: \t// ... rest of existing code ...\n1116: }\n1117: ```\n1118: \n1119: **Step 5: Apply locks in upload and delete handlers**\n1120: \n1121: ```go\n1122: // pkg/picod/handlers.go\n1123: func (s *Server) UploadFileHandler(c *gin.Context) {\n1124: \t// ... existing validation code ...\n1125: \n1126: \tsanitizedPath, err := s.sanitizePath(path)\n1127: \tif err != nil {\n1128: \t\tHandleError(c, err)\n1129: \t\treturn\n1130: \t}\n1131: \n1132: \t// Acquire write lock\n1133: \tif !s.lockManager.AcquireWriteLock(sanitizedPath) {\n1134: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n1135: \t\treturn\n1136: \t}\n1137: \tdefer s.lockManager.ReleaseWriteLock(sanitizedPath)\n1138: \n1139: \t// ... rest of handler code ...\n1140: }\n1141: \n1142: func (s *Server) DeleteFileHandler(c *gin.Context) {\n1143: \t// ... existing validation code ...\n1144: \n1145: \tsanitizedPath, err := s.sanitizePath(path)\n1146: \tif err != nil {\n1147: \t\tHandleError(c, err)\n1148: \t\treturn\n1149: \t}\n1150: \n1151: \t// Acquire write lock\n1152: \tif !s.lockManager.AcquireWriteLock(sanitizedPath) {\n1153: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n1154: \t\treturn\n1155: \t}\n1156: \tdefer s.lockManager.ReleaseWriteLock(sa