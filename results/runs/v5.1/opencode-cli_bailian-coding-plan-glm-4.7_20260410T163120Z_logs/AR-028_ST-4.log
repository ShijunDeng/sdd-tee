r(f\"{__name__}.AgentRuntimeClient\")\n39: \n40:         if verbose:\n41:             self.logger.setLevel(10)\n42: \n43:         self.router_url = router_url or os.getenv(\"ROUTER_URL\", \"\")\n44: \n45:         if not self.router_url:\n46:             self.logger.warning(\"ROUTER_URL not set\")\n47: \n48:         self.session_id = session_id\n49:         self.dp_client = AgentRuntimeDataPlaneClient(\n50:             router_url=self.router_url,\n51:             namespace=namespace,\n52:             agent_name=agent_name,\n53:             timeout=timeout,\n54:             connect_timeout=connect_timeout,\n55:         )\n56: \n57:         if not self.session_id:\n58:             self.session_id = self.dp_client.bootstrap_session_id()\n59: \n60:     def __enter__(self) -> \"AgentRuntimeClient\":\n61:         \"\"\"Enter context manager.\n62: \n63:         Returns:\n64:             Self\n65:         \"\"\"\n66:         return self\n67: \n68:     def __exit__(self, exc_type: object, exc_val: object, exc_tb: object) -> None:\n69:         \"\"\"Exit context manager and cleanup.\n70: \n71:         Args:\n72:             exc_type: Exception type\n73:             exc_val: Exception value\n74:             exc_tb: Exception traceback\n75:         \"\"\"\n76:         self.close()\n77: \n78:     def invoke(self, payload: dict[str, object], timeout: float | None = None) -> dict[str, object]:\n79:         \"\"\"Invoke the Agent Runtime with a payload.\n80: \n81:         Args:\n82:             payload: JSON payload to send\n83:             timeout: Timeout in seconds\n84: \n85:         Returns:\n86:             Response JSON\n87: \n88:         Raises:\n89:             ValueError: If session_id is not initialized\n90:         \"\"\"\n91:         if not self.session_id:\n92:             raise ValueError(\"AgentRuntime session_id is not initialized\")\n93: \n94:         response = self.dp_client.invoke(self.session_id, payload, timeout=timeout)\n95:         return response.json()\n96: \n97:     def close(self) -> None:\n98:         \"\"\"Close the underlying HTTP session.\"\"\"\n99:         self.dp_client.close()\n100:         self.logger.info(\"Closed Agent Runtime client\")\n\n(End of file - total 100 lines)\n</content>","metadata":{"preview":"\"\"\"Agent Runtime client for invoking agent workloads.\"\"\"\n\nimport os\n\nfrom .clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom .utils import get_logger\n\n\nclass AgentRuntimeClient:\n    \"\"\"Client for Agent Runtime invocation.\"\"\"\n\n    def __init__(\n        self,\n        agent_name: str,\n        namespace: str = \"default\",\n        router_url: str | None = None,\n        verbose: bool = False,\n        session_id: str | None = None,\n        timeout: int = 120,\n        connect_timeout: float = 5.0,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/agentcube/agent_runtime.py","time":{"start":1775878115159,"end":1775878115211}}}}
