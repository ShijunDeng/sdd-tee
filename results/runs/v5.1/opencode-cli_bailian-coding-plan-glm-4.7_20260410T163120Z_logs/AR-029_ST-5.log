 not provided or found in environment\n        \"\"\"\n        self.name = name\n        self.namespace = namespace\n        self.ttl = ttl\n        self.verbose = verbose\n        self.logger = get_logger(f\"{__name__}.CodeInterpreterClient\")\n\n        if verbose:\n            self.logger.setLevel(10)\n\n        self.router_url = router_url or os.getenv(\"ROUTER_URL\")\n\n        if not self.router_url:\n            raise ValueError(\n                \"Router URL must be provided via router_url argument or ROUTER_URL environment variable\"\n            )\n\n        self.session_id = session_id\n        self.cp_client = ControlPlaneClient(\n            workload_manager_url=workload_manager_url,\n            auth_token=auth_token,\n        )\n        self.dp_client: Optional[CodeInterpreterDataPlaneClient] = None\n\n        if self.session_id:\n            self.logger.info(f\"Reusing existing session: {self.session_id}\")\n            self._init_data_plane()\n        else:\n            self._create_session()\n\n    def _create_session(self) -> None:\n        \"\"\"Create a new session via control plane.\"\"\"\n        self.session_id = self.cp_client.create_session(\n            name=self.name,\n            namespace=self.namespace,\n            ttl=self.ttl,\n        )\n        self._init_data_plane()\n\n    def _init_data_plane(self) -> None:\n        \"\"\"Initialize the data plane client.\n\n        Raises:\n            Exception: If initialization fails, cleans up session\n        \"\"\"\n        try:\n            self.dp_client = CodeInterpreterDataPlaneClient(\n                session_id=self.session_id,\n                router_url=self.router_url,\n                namespace=self.namespace,\n                cr_name=self.name,\n            )\n        except Exception as e:\n            if self.session_id and self.cp_client:\n                self.logger.warning(\n                    f\"Data plane initialization failed, cleaning up session: {e}\"\n                )\n                self.cp_client.delete_session(self.session_id)\n                self.session_id = None\n            raise\n\n    def __enter__(self) -> \"CodeInterpreterClient\":\n        \"\"\"Enter context manager.\n\n        Returns:\n            Self\n        \"\"\"\n        return self\n\n    def __exit__(self, exc_type: Optional[object], exc_val: Optional[object], exc_tb: Optional[object]) -> None:\n        \"\"\"Exit context manager and cleanup.\n\n        Args:\n            exc_type: Exception type\n            exc_val: Exception value\n            exc_tb: Exception traceback\n        \"\"\"\n        self.stop()\n\n    def stop(self) -> None:\n        \"\"\"Stop the session and cleanup resources.\"\"\"\n        if self.dp_client:\n            self.dp_client.close()\n            self.dp_client = None\n\n        if self.session_id and self.cp_client:\n            self.cp_client.delete_session(self.session_id)\n            self.session_id = None\n\n        if self.cp_client:\n            self.cp_client.close()\n\n        self.logger.info(\"Stopped Code Interpreter session\")\n\n    def execute_command(self, command: str, timeout: Optional[float] = None) -> str:\n        \"\"\"Execute a command in the session.\n\n        Args:\n            command: Command to execute\n            timeout: Timeout in seconds\n\n        Returns:\n            Command output\n\n        Raises:\n            ValueError: If data plane client is not initialized\n        \"\"\"\n        if not self.dp_client:\n            raise ValueError(\"Data plane client not initialized\")\n\n        return self.dp_client.execute_command(command, timeout=timeout)\n\n    def run_code(self, language: str, code: str, timeout: Optional[float] = None) -> str:\n        \"\"\"Run code in the session.\n\n        Args:\n            language: Programming language\n            code: Source code\n            timeout: Timeout in seconds\n\n        Returns:\n            Execution output\n\n        Raises:\n            ValueError: If data plane client is not initialized\n        \"\"\"\n        if not self.dp_client:\n            raise ValueError(\"Data plane client not initialized\")\n\n        return self.dp_client.run_code(language, code, timeout=timeout)\n\n    def write_file(self, content: str, remote_path: str) -> None:\n        \"\"\"Write content to a file in the session.\n\n        Args:\n            content: File content\n            remote_path: Remote file path\n\n        Raises:\n            ValueError: If data plane client is not initialized\n        \"\"\"\n        if not self.dp_client:\n            raise ValueError(\"Data plane client not initialized\")\n\n        self.dp_client.write_file(content, remote_path)\n\n    def upload_file(self, local_path: str, remote_path: str) -> None:\n        \"\"\"Upload a local file to the session.\n\n        Args:\n            local_path: Local file path\n            remote_path: Remote file path\n\n        Raises:\n            ValueError: If data plane client is not initialized\n        \"\"\"\n        if not self.dp_client:\n            raise ValueError(\"Data plane client not initialized\")\n\n        self.dp_client.upload_file(local_path, remote_path)\n\n    def download_file(self, remote_path: str, local_path: str) -> None:\n        \"\"\"Download a file from the session.\n\n        Args:\n            remote_path: Remote file path\n            local_path: Local file path\n\n        Raises:\n            ValueError: If data plane client is not initialized\n        \"\"\"\n        if not self.dp_client:\n            raise ValueError(\"Data plane client not initialized\")\n\n        self.dp_client.download_file(remote_path, local_path)\n\n    def list_files(self, path: str = \".\") -> Any:\n        \"\"\"List files in the session.\n\n        Args:\n            path: Directory path\n\n        Returns:\n            File listing\n\n        Raises:\n            ValueError: If data plane client is not initialized\n       