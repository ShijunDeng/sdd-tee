_data_plane\"\n    ) as mock_init_dp:\n        mock_create_session.return_value = \"test-session-id\"\n\n        client = CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"default\",\n            router_url=mock_router_url,\n            workload_manager_url=mock_workload_manager_url,\n        )\n\n        yield client\n\n        client.stop()\n\n\ndef test_code_interpreter_client_init(mock_router_url, mock_workload_manager_url):\n    \"\"\"Test CodeInterpreterClient initialization.\"\"\"\n    with patch.object(CodeInterpreterClient, \"_create_session\") as mock_create_session:\n        client = CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"default\",\n            router_url=mock_router_url,\n            workload_manager_url=mock_workload_manager_url,\n        )\n\n        assert client.name == \"test-interpreter\"\n        assert client.namespace == \"default\"\n        assert client.router_url == mock_router_url\n        assert client.session_id is not None\n        mock_create_session.assert_called_once()\n        client.stop()\n\n\ndef test_code_interpreter_client_init_from_env(mock_router_url):\n    \"\"\"Test CodeInterpreterClient initialization from environment variable.\"\"\"\n    with patch.dict(os.environ, {\"ROUTER_URL\": mock_router_url}), patch.object(\n        CodeInterpreterClient, \"_create_session\"\n    ):\n        client = CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"default\",\n        )\n\n        assert client.router_url == mock_router_url\n        client.stop()\n\n\ndef test_code_interpreter_client_init_no_router_url():\n    \"\"\"Test CodeInterpreterClient initialization without router URL.\"\"\"\n    with pytest.raises(ValueError, match=\"Router URL must be provided\"):\n        CodeInterpreterClient(name=\"test-interpreter\", namespace=\"default\")\n\n\ndef test_code_interpreter_client_init_with_session_id(mock_router_url, mock_workload_manager_url):\n    \"\"\"Test CodeInterpreterClient initialization with existing session_id.\"\"\"\n    with patch.object(CodeInterpreterClient, \"_init_data_plane\") as mock_init_dp:\n        client = CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"default\",\n            router_url=mock_router_url,\n            workload_manager_url=mock_workload_manager_url,\n            session_id=\"existing-session-id\",\n        )\n\n        assert client.session_id == \"existing-session-id\"\n        mock_init_dp.assert_called_once()\n        client.stop()\n\n\ndef test_create_session(code_interpreter_client):\n    \"\"\"Test _create_session method.\"\"\"\n    with patch.object(code_interpreter_client.cp_client, \"create_session\") as mock_create, patch.object(\n        code_interpreter_client, \"_init_data_plane\"\n    ) as mock_init_dp:\n        mock_create.return_value = \"new-session-id\"\n\n        code_interpreter_client._create_session()\n\n        assert code_interpreter_client.session_id == \"new-session-id\"\n        mock_create.assert_called_once()\n        mock_init_dp.assert_called_once()\n\n\ndef test_init_data_plane_success(code_interpreter_client):\n    \"\"\"Test _init_data_plane success.\"\"\"\n    code_interpreter_client.session_id = \"test-session-id\"\n    code_interpreter_client._init_data_plane()\n\n    assert code_interpreter_client.dp_client is not None\n    assert code_interpreter_client.dp_client.session_id == \"test-session-id\"\n\n\ndef test_init_data_plane_failure(code_interpreter_client):\n    \"\"\"Test _init_data_plane failure.\"\"\"\n    code_interpreter_client.session_id = \"test-session-id\"\n\n    with patch(\n        \"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\",\n        side_effect=Exception(\"Init failed\"),\n    ) as mock_dp_class, patch.object(code_interpreter_client.cp_client, \"delete_session\") as mock_delete:\n        mock_dp_class.__name__ = \"CodeInterpreterDataPlaneClient\"\n\n        with pytest.raises(Exception, match=\"Init failed\"):\n            code_interpreter_client._init_data_plane()\n\n        mock_delete.assert_called_once_with(\"test-session-id\")\n        assert code_interpreter_client.session_id is None\n\n\ndef test_context_manager(code_interpreter_client):\n    \"\"\"Test CodeInterpreterClient as context manager.\"\"\"\n    with patch.object(code_interpreter_client, \"stop\") as mock_stop:\n        with code_interpreter_client:\n            pass\n\n        mock_stop.assert_called_once()\n\n\ndef test_context_manager_with_exception(code_interpreter_client):\n    \"\"\"Test CodeInterpreterClient context manager with exception.\"\"\"\n    with patch.object(code_interpreter_client, \"stop\") as mock_stop:\n        with pytest.raises(ValueError):\n            with code_interpreter_client:\n                raise ValueError(\"Test error\")\n\n        mock_stop.assert_called_once()\n\n\ndef test_stop(code_interpreter_client):\n    \"\"\"Test stop method.\"\"\"\n    code_interpreter_client.session_id = \"test-session-id\"\n    code_interpreter_client.dp_client = MagicMock()\n    code_interpreter_client.cp_client = MagicMock()\n\n    code_interpreter_client.stop()\n\n    code_interpreter_client.dp_client.close.assert_called_once()\n    code_interpreter_client.cp_client.delete_session.assert_called_once_with(\"test-session-id\")\n    code_interpreter_client.cp_client.close.assert_called_once()\n    assert code_interpreter_client.dp_client is None\n    assert code_interpreter_client.session_id is None\n\n\ndef test_stop_without_session(code_interpreter_client):\n    \"\"\"Test stop without session.\"\"\"\n    code_interpreter_client.session_id = None\n    code_interpreter_client.dp_client = None\n    code_interpreter_client.cp_client = MagicMock()\n\n    code_interpreter_client.stop()\n\n    code_interpreter_client.cp_client.close.assert_called_once()\n\n\ndef test_execute_command(code_interpreter_client):\n    \