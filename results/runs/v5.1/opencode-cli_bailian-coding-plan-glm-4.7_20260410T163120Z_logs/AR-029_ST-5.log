_args = mock_post.call_args\n84:         assert call_args[0][0] == agent_runtime_client.base_url\n85:         assert call_args[1][\"json\"] == payload\n86:         assert call_args[1][\"headers\"][\"x-agentcube-session-id\"] == session_id\n87:         assert call_args[1][\"headers\"][\"Content-Type\"] == \"application/json\"\n88: \n89: \n90: def test_invoke_with_timeout(agent_runtime_client):\n91:     \"\"\"Test invoke with custom timeout.\"\"\"\n92:     payload = {\"key\": \"value\"}\n93:     session_id = \"test-session-id\"\n94: \n95:     with patch.object(agent_runtime_client.session, \"post\") as mock_post:\n96:         mock_response = MagicMock()\n97:         mock_response.json.return_value = {\"result\": \"success\"}\n98:         mock_post.return_value = mock_response\n99: \n100:         agent_runtime_client.invoke(session_id, payload, timeout=60.0)\n101: \n102:         call_args = mock_post.call_args\n103:         assert call_args[1][\"timeout\"] == (5.0, 60.0)\n104: \n105: \n106: def test_close(agent_runtime_client):\n107:     \"\"\"Test close method.\"\"\"\n108:     agent_runtime_client.close()\n109:     agent_runtime_client.close()\n110: \n111: \n112: def test_custom_timeout(mock_router_url):\n113:     \"\"\"Test AgentRuntimeDataPlaneClient with custom timeout.\"\"\"\n114:     client = AgentRuntimeDataPlaneClient(\n115:         router_url=mock_router_url,\n116:         namespace=\"default\",\n117:         agent_name=\"test-agent\",\n118:         timeout=60,\n119:         connect_timeout=2.0,\n120:     )\n121:     assert client.timeout == 60\n122:     assert client.connect_timeout == 2.0\n123:     client.close()\n124: \n125: \n126: def test_session_header_constant():\n127:     \"\"\"Test SESSION_HEADER constant.\"\"\"\n128:     assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n\n(End of file - total 128 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for AgentRuntimeDataPlaneClient.\"\"\"\n\nfrom unittest.mock import Ma