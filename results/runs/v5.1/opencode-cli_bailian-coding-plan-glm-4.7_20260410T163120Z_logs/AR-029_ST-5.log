     \"\"\"Test get_logger with custom level.\"\"\"\n46:     import logging\n47: \n48:     logger = get_logger(\"test_logger_level\", level=logging.DEBUG)\n49:     assert logger is not None\n50:     assert logger.level == logging.DEBUG\n51: \n52: \n53: def test_logger_same_instance():\n54:     \"\"\"Test that get_logger returns the same instance for same name.\"\"\"\n55:     logger1 = get_logger(\"same_logger\")\n56:     logger2 = get_logger(\"same_logger\")\n57:     assert logger1 is logger2\n\n(End of file - total 57 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for agentcube utilities.\"\"\"\n\nimport os\nimport tempfile\n\nimport pytest\n\nfrom agentcube.utils import create_session, get_logger, read_token_from_file\n\n\ndef test_create_session():\n    \"\"\"Test create_session function.\"\"\"\n    session = create_session(pool_connections=5, pool_maxsize=5)\n    assert session is not None\n    session.close()\n\n\ndef test_read_token_from_file():\n    \"\"\"Test read_token_from_file function.\"\"\"\n    with tempfile.NamedTemporaryFile(mode=\"w\", delete=False, suffix=\".txt\") as f:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_utils.py","time":{"start":1775880002805,"end":1775880002851}}}}
