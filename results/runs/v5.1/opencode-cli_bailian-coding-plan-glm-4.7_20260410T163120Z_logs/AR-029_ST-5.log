D to reuse\n36: \n37:         Raises:\n38:             ValueError: If router_url is not provided or found in environment\n39:         \"\"\"\n40:         self.name = name\n41:         self.namespace = namespace\n42:         self.ttl = ttl\n43:         self.verbose = verbose\n44:         self.logger = get_logger(f\"{__name__}.CodeInterpreterClient\")\n45: \n46:         if verbose:\n47:             self.logger.setLevel(10)\n48: \n49:         self.router_url = router_url or os.getenv(\"ROUTER_URL\")\n50: \n51:         if not self.router_url:\n52:             raise ValueError(\n53:                 \"Router URL must be provided via router_url argument or ROUTER_URL environment variable\"\n54:             )\n55: \n56:         self.session_id = session_id\n57:         self.cp_client = ControlPlaneClient(\n58:             workload_manager_url=workload_manager_url,\n59:             auth_token=auth_token,\n60:         )\n61:         self.dp_client: CodeInterpreterDataPlaneClient | None = None\n62: \n63:         if self.session_id:\n64:             self.logger.info(f\"Reusing existing session: {self.session_id}\")\n65:             self._init_data_plane()\n66:         else:\n67:             self._create_session()\n68: \n69:     def _create_session(self) -> None:\n70:         \"\"\"Create a new session via control plane.\"\"\"\n71:         self.session_id = self.cp_client.create_session(\n72:             name=self.name,\n73:             namespace=self.namespace,\n74:             ttl=self.ttl,\n75:         )\n76:         self._init_data_plane()\n77: \n78:     def _init_data_plane(self) -> None:\n79:         \"\"\"Initialize the data plane client.\n80: \n81:         Raises:\n82:             Exception: If initialization fails, cleans up session\n83:         \"\"\"\n84:         try:\n85:             self.dp_client = CodeInterpreterDataPlaneClient(\n86:                 session_id=self.session_id,\n87:                 router_url=self.router_url,\n88:                 namespace=self.namespace,\n89:                 cr_name=self.name,\n90:             )\n91:         except Exception as e:\n92:             if self.session_id and self.cp_client:\n93:                 self.logger.warning(\n94:                     f\"Data plane initialization failed, cleaning up session: {e}\"\n95:                 )\n96:                 self.cp_client.delete_session(self.session_id)\n97:                 self.session_id = None\n98:             raise\n99: \n100:     def __enter__(self) -> \"CodeInterpreterClient\":\n101:         \"\"\"Enter context manager.\n102: \n103:         Returns:\n104:             Self\n105:         \"\"\"\n106:         return self\n107: \n108:     def __exit__(self, exc_type: Optional[object], exc_val: Optional[object], exc_tb: Optional[object]) -> None:\n109:         \"\"\"Exit context manager and cleanup.\n110: \n111:         Args:\n112:             exc_type: Exception type\n113:             exc_val: Exception value\n114:             exc_tb: Exception traceback\n115:         \"\"\"\n116:         self.stop()\n117: \n118:     def stop(self) -> None:\n119:         \"\"\"Stop the session and cleanup resources.\"\"\"\n120:         if self.dp_client:\n121:             self.dp_client.close()\n122:             self.dp_client = None\n123: \n124:         if self.session_id and self.cp_client:\n125:             self.cp_client.delete_session(self.session_id)\n126:             self.session_id = None\n127: \n128:         if self.cp_client:\n129:             self.cp_client.close()\n130: \n131:         self.logger.info(\"Stopped Code Interpreter session\")\n132: \n133:     def execute_command(self, command: str, timeout: Optional[float] = None) -> str:\n134:         \"\"\"Execute a command in the session.\n135: \n136:         Args:\n137:             command: Command to execute\n138:             timeout: Timeout in seconds\n139: \n140:         Returns:\n141:             Command output\n142: \n143:         Raises:\n144:             ValueError: If data plane client is not initialized\n145:         \"\"\"\n146:         if not self.dp_client:\n147:             raise ValueError(\"Data plane client not initialized\")\n148: \n149:         return self.dp_client.execute_command(command, timeout=timeout)\n150: \n151:     def run_code(self, language: str, code: str, timeout: Optional[float] = None) -> str:\n152:         \"\"\"Run code in the session.\n153: \n154:         Args:\n155:             language: Programming language\n156:             code: Source code\n157:             timeout: Timeout in seconds\n158: \n159:         Returns:\n160:             Execution output\n161: \n162:         Raises:\n163:             ValueError: If data plane client is not initialized\n164:         \"\"\"\n165:         if not self.dp_client:\n166:             raise ValueError(\"Data plane client not initialized\")\n167: \n168:         return self.dp_client.run_code(language, code, timeout=timeout)\n169: \n170:     def write_file(self, content: str, remote_path: str) -> None:\n171:         \"\"\"Write content to a file in the session.\n172: \n173:         Args:\n174:             content: File content\n175:             remote_path: Remote file path\n176: \n177:         Raises:\n178:             ValueError: If data plane client is not initialized\n179:         \"\"\"\n180:         if not self.dp_client:\n181:             raise ValueError(\"Data plane client not initialized\")\n182: \n183:         self.dp_client.write_file(content, remote_path)\n184: \n185:     def upload_file(self, local_path: str, remote_path: str) -> None:\n186:         \"\"\"Upload a local file to the session.\n187: \n188:         Args:\n189:             local_path: Local file path\n190:             remote_path: Remote file path\n191: \n192:         Raises:\n193:             ValueError: If data plane client is not initialized\n194:         \"\"\"\n195:         if not self.dp_client:\n196:             raise ValueError(\"Data plane client not initialized\")\n197: \n198:         self.dp_client.upload_file(local_path, remote_path)\n199: \n200:     def download_file(self, remote_path: str, local_path: str) -> None:\n201:         \"\"\"Download a file from the session.\n202: \n203:         Args:\n204:             remote_path: Remote file path\n205:             local_path: Local file path\n206: \n207:         Raises:\n208:             ValueError: If data plane client is not initialized\n209:         \"\"\"\n210:         if not self.dp_client:\n211:             raise ValueError(\"Data plane client not initialized\")\n212: \n213:         self.dp_client.download_file(remote_path, local_path)\n214: \n215:     def list_files(self, path: str = \".\") -> Any:\n216:         \"\"\"List files in the session.\n217: \n218:         Args:\n219:             path: Directory path\n220: \n221:         Returns:\n222:             File listing\n223: \n224:         Raises:\n225:             ValueError: If data plane client is not initialized\n226:         \"\"\"\n227:         if not self.dp_client:\n228:             raise ValueError(\"Data plane client not initialized\")\n229: \n230:         return self.dp_client.list_files(path)\n\n(End of file - total 230 lines)\n</content>","metadata":{"preview":"\"\"\"Code Interpreter client for managing interpreter sessions.\"\"\"\n\nimport os\nfrom typing import Any, Optional\n\nfrom .clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom .clients.control_plane import ControlPlaneClient\nfrom .utils import get_logger\n\n\nclass CodeInterpreterClient:\n    \"\"\"Main client for Code Interpreter session management and operations.\"\"\"\n\n    def __init__(\n        self,\n        name: str = \"my-interpreter\",\n        namespace: str = \"default\",\n        ttl: int = 3600,\n        workload_manager_url: Optional[str] = None,\n        router_url: Optional[str] = None,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/agentcube/code_interpreter.py","