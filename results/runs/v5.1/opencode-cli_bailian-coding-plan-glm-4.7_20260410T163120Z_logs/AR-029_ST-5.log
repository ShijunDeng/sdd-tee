ace = namespace\n        self.timeout = timeout\n        self.connect_timeout = connect_timeout\n        self.verbose = verbose\n        self.logger = get_logger(f\"{__name__}.AgentRuntimeClient\")\n\n        if verbose:\n            self.logger.setLevel(10)\n\n        self.router_url = router_url or os.getenv(\"ROUTER_URL\", \"\")\n\n        if not self.router_url:\n            self.logger.warning(\"ROUTER_URL not set\")\n\n        self.session_id = session_id\n        self.dp_client = AgentRuntimeDataPlaneClient(\n            router_url=self.router_url,\n            namespace=namespace,\n            agent_name=agent_name,\n            timeout=timeout,\n            connect_timeout=connect_timeout,\n        )\n\n        if not self.session_id:\n            self.session_id = self.dp_client.bootstrap_session_id()\n\n    def __enter__(self) -> \"AgentRuntimeClient\":\n        \"\"\"Enter context manager.\n\n        Returns:\n            Self\n        \"\"\"\n        return self\n\n    def __exit__(self, exc_type: Optional[object], exc_val: Optional[object], exc_tb: Optional[object]) -> None:\n        \"\"\"Exit context manager and cleanup.\n\n        Args:\n            exc_type: Exception type\n            exc_val: Exception value\n            exc_tb: Exception traceback\n        \"\"\"\n        self.close()\n\n    def invoke(self, payload: dict[str, Any], timeout: Optional[float] = None) -> dict[str, Any]:\n        \"\"\"Invoke the Agent Runtime with a payload.\n\n        Args:\n            payload: JSON payload to send\n            timeout: Timeout in seconds\n\n        Returns:\n            Response JSON\n\n        Raises:\n            ValueError: If session_id is not initialized\n        \"\"\"\n        if not self.session_id:\n            raise ValueError(\"AgentRuntime session_id is not initialized\")\n\n        response = self.dp_client.invoke(self.session_id, payload, timeout=timeout)\n        return response.json()\n\n    def close(self) -> None:\n        \"\"