on failed\"\n37: \n38: \n39: def test_data_plane_error():\n40:     \"\"\"Test DataPlaneError.\"\"\"\n41:     error = DataPlaneError(\"Data plane error\")\n42:     assert isinstance(error, AgentCubeError)\n43:     assert str(error) == \"Data plane error\"\n\n(End of file - total 43 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for agentcube exceptions.\"\"\"\n\nimport pytest\n\nfrom agentcube.exceptions import AgentCubeError, CommandExecutionError, DataPlaneError, SessionError\n\n\ndef test_agent_cube_error():\n    \"\"\"Test base AgentCubeError.\"\"\"\n    error = AgentCubeError(\"Test error\")\n    assert str(error) == \"Test error\"\n\n\ndef test_command_execution_error():\n    \"\"\"Test CommandExecutionError.\"\"\"\n    error = CommandExecutionError(exit_code=1, stderr=\"error output\", command=\"ls /invalid\")\n    assert error.exit_code == 1\n    assert error.stderr == \"error output\"\n    assert error.command == \"ls /invalid\"\n    assert \"exit 1\" in str(error)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_exceptions.py","time":{"start":1775880002801,"end":1775880002843}}}}
{"type":"tool_use","timestamp":1775880002850,"sessionID":"ses_2854e7c0bffe5w0RmAD0fpq7ai","part":{"id":"prt_d7ab25cd000115ntugHFhoQb0s","messageID":"msg_d7ab24efb001r25BvIv8S730hc","sessionID":"ses_2854e7c0bffe5w0RmAD0fpq7ai","type":"tool","tool":"read","callID":"toolu_tool-c42bfb86fb51491c83729b04a0b4e8bf","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_control_plane_client.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_control_plane_client.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for ControlPlaneClient.\"\"\"\n2: \n3: import os\n4: from unittest.mock import MagicMock, patch\n5: \n6: import pytest\n7: import requests\n8: \n9: from agentcube.clients.control_plane import ControlPlaneClient\n10: \n11: \n12: @pytest.fixture\n13: def mock_workload_manager_url():\n14:     \"\"\"Return a mock workload manager URL.\"\"\"\n15:     return \"http://workload-manager:8080\"\n16: \n17: \n18: @pytest.fixture\n19: def control_plane_client(mock_workload_manager_url):\n20:     \"\"\"Return a ControlPlaneClient instance.\"\"\"\n21:     return ControlPlaneClient(workload_manager_url=mock_workload_manager_url)\n22: \n23: \n24: def test_control_plane_client_init(mock_workload_manager_url):\n25:     \"\"\"Test ControlPlaneClient initialization.\"\"\"\n26:     client = ControlPlaneClient(workload_manager_url=mock_workload_manager_url)\n27:     assert client.base_url == mock_workload_manager_url\n28:     assert client.timeout == 120\n29:     assert client.connect_timeout == 5.0\n30:     client.close()\n31: \n32: \n33: def test_control_plane_client_init_from_env():\n34:     \"\"\"Test ControlPlaneClient initialization from environment variable.\"\"\"\n35:     with patch.dict(os.environ, {\"WORKLOAD_MANAGER_URL\": \"http://env-url:8080\"}):\n36:         client = ControlPlaneClient()\n37:         assert client.base_url == \"http://env-url:8080\"\n38:         client.close()\n39: \n40: \n41: def test_control_plane_client_init_no_url():\n42:     \"\"\"Test ControlPlaneClient initialization without URL.\"\"\"\n43:     client = ControlPlaneClient()\n44:     assert client.base_url == \"\"\n45:     client.close()\n46: \n47: \n48: def test_control_plane_client_with_auth_token(mock_workload_manager_url):\n49:     \"\"\"Test ControlPlaneClient with auth token.\"\"\"\n50:     client = ControlPlaneClient(workload_manager_url=mock_workload_manager_url, auth_token=\"test-token\")\n51:     assert client.session.headers.get(\"Authorization\") == \"Bearer test-token\"\n52:     client.close()\n53: \n54: \n55: @patch(\"agentcube.clients.control_plane.read_token_from_file\")\n56: def test_control_plane_client_with_sa_token(mock_read_token, mock_workload_manager_url):\n57:     \"\"\"Test ControlPlaneClient with service account token.\"\"\"\n58:     mock_read_token.return_value = \"sa-token\"\n59:     client = ControlPlaneClient(workload_manager_url=mock_workload_manager_url)\n60:     assert client.session.headers.get(\"Authorization\") == \"Bearer sa-token\"\n61:     client.close()\n62: \n63: \n64: def test_create_session(control_plane_client, mock_workload_manager_url):\n65:     \"\"\"Test create_session method.\"\"\"\n66:     session_id = \"test-session-id\"\n67: \n68:     with patch.object(control_plane_client.session, \"post\") as mock_post:\n69:         mock_response = MagicMock()\n70:         mock_response.json.return_value = {\"sessionId\": session_id}\n71:         mock_post.return_value = mock_response\n72: \n73:         result = control_plane_client.create_session(name=\"test\", namespace=\"default\")\n74: \n75:         assert result == session_id\n76:         mock_post.assert_called_once()\n77:         call_args = mock_post.call_args\n78:         assert call_args[0][0] == f\"{mock_workload_manager_url}/v1/code-interpreter\"\n79:         assert call_args[1][\"json\"][\"name\"] == \"test\"\n80:         assert call_args[1][\"json\"][\"namespace\"] == \"default\"\n81: \n82: \n83: def test_create_session_with_metadata(control_plane_client):\n84:     \"\"\"Test create_session with metadata.\"\"\"\n85:     session_id = \"test-session-id\"\n86:     metadata = {\"key\": \"value\"}\n87: \n88:     with patch.object(control_plane_client.session, \"post\") as mock_post:\n89:         mock_response = MagicMock()\n90:         mock_response.json.return_value = {\"sessionId\": session_id}\n91:         mock_post.return_value = mock_response\n92: \n93:         result = control_plane_client.create_session(\n94:             name=\"test\",\n95:             namespace=\"default\",\n96:             metadata=metadata,\n97:         )\n98: \n99:         assert result == session_id\n100:         assert mock_post.call_args[1][\"json\"][\"metadata\"] == metadata\n101: \n102: \n103: def test_create_session_missing_session_id(control_plane_client):\n104:     \"\"\"Test create_session with missing sessionId in response.\"\"\"\n105:     with patch.object(control_plane_client.session, \"post\") as mock_post:\n106:         mock_response = MagicMock()\n107:         mock_response.json.return_value = {}\n108:         mock_post.return_value = mock_response\n109: \n110:         with pytest.raises(ValueError, match=\"Missing sessionId\"):\n111:             control_plane_client.create_session(name=\"test\", namespace=\"default\")\n112: \n113: \n114: def test_create_session_no_url():\n115:     \"\"\"Test create_session without base URL.\"\"\"\n116:     client = ControlPlaneClient(workload_manager_url=None)\n117: \n118:     with pytest.raises(ValueError, match=\"Workload Manager URL not configured\"):\n119:         client.create_session(name=\"test\", namespace=\"default\")\n120: \n121:     client.close()\n122: \n123: \n124: def test_delete_session_success(control_plane_client, mock_workload_manager_url):\n125:     \"\"\"Test delete_session success.\"\"\"\n126:     with patch.object(control_plane_client.session, \"delete\") as mock_delete:\n127:         mock_response = MagicMock()\n128:         mock_response.status_code = 200\n129:         mock_delete.return_value = mock_response\n130: \n131:         result = control_plane_client.delete_session(\"test-session-id\")\n132: \n133:         assert result is True\n134:         mock_delete.assert_called_once()\n135:         assert mock_delete.call_args[0][0] == f\"{mock_workload_manager_url}/v1/code-interpreter/sessions/test-session-id\"\n136: \n137: \n138: def test_delete_session_404(control_plane_client, mock_workload_manager_url):\n139:     \"\"\"Test delete_session with 404 response.\"\"\"\n140:     with patch.object(control_plane_client.session, \"delete\") as mock_delete:\n141:         mock_response = MagicMock()\n142:         mock_response.status_code = 404\n143:         mock_delete.return_value = mock_response\n144: \n145:         result = control_plane_client.delete_session(\"test-session-id\")\n146: \n147:         assert result is True\n148: \n149: \n150: def test_delete_session_failure(control_plane_client):\n151:     \"\"\"Test delete_session with failure.\"\"\"\n152:     with patch.object(control_plane_client.session, \"delete\") as mock_delete:\n153:         mock_delete.side_effect = requests.RequestException(\"Network error\")\n154: \n155:         result = control_plane_client.delete_session(\"test-session-id\")\n156: \n157:         assert result is False\n158: \n159: \n160: def test_delete_session_no_url():\n161:     \"\"\"Test delete_session without base URL.\"\"\"\n162:     client = ControlPlaneClient(workload_manager_url=None)\n163:     result = client.delete_session(\"test-session-id\")\n164:     assert result is False\n165:     client.close()\n166: \n167: \n168: def test_close(control_plane_client):\n169:     \"\"\"Test close method.\"\"\"\n170:     control_plane_client.close()\n171:     control_plane_client.close()\n172: \n173: \n174: def test_custom_timeout(mock_workload_manager_url):\n175:     \"\"\"Test ControlPlaneClient with custom timeout.\"\"\"\n176:     client = ControlPlaneClient(\n177:         workload_manager_url=mock_workload_manager_url,\n178:         timeout=60,\n179:         connect_timeout=2.0,\n180:     )\n181:     assert client.timeout == 60\n182:     assert client.connect_timeout == 2.0\n183:     client.close()\n\n(End of file - total 183 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for ControlPlaneClient.\"\"\"\n\nimport os\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\nimport requests\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\n\n\n@pytest.fixture\ndef mock_workload_manager_url():\n    \"\"\"Return a mock workload manager URL.\"\"\"\n    return \"http://workload-manager:8080\"\n\n\n@pytest.fixture\ndef control_plane_client(mock_workload_manager_url):\n    \"\"\"Return a ControlPlaneClient instance.\"\"\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_control_plane_client.py","time":{"start":1775880002809,"end":1775880002848}}}}
