{"type":"tool_use","timestamp":1775880006647,"sessionID":"ses_2854e7c0bffe5w0RmAD0fpq7ai","part":{"id":"prt_d7ab269110013NRTxGvXURBV3X","messageID":"msg_d7ab25d5f001E4UMmJyReOZ8Fw","sessionID":"ses_2854e7c0bffe5w0RmAD0fpq7ai","type":"tool","tool":"read","callID":"toolu_tool-8761f8d0d61e4818bc00399ff00dd736","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_code_interpreter_data_plane_client.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_code_interpreter_data_plane_client.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n2: \n3: from unittest.mock import MagicMock, mock_open, patch\n4: \n5: import pytest\n6: import requests\n7: \n8: from agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n9: from agentcube.exceptions import CommandExecutionError\n10: \n11: \n12: @pytest.fixture\n13: def mock_base_url():\n14:     \"\"\"Return a mock base URL.\"\"\"\n15:     return \"http://router:8080/v1/namespaces/default/code-interpreters/test/invocations/\"\n16: \n17: \n18: @pytest.fixture\n19: def data_plane_client(mock_base_url):\n20:     \"\"\"Return a CodeInterpreterDataPlaneClient instance.\"\"\"\n21:     return CodeInterpreterDataPlaneClient(\n22:         session_id=\"test-session-id\",\n23:         base_url=mock_base_url,\n24:     )\n25: \n26: \n27: def test_data_plane_client_init_with_base_url(mock_base_url):\n28:     \"\"\"Test CodeInterpreterDataPlaneClient initialization with base_url.\"\"\"\n29:     client = CodeInterpreterDataPlaneClient(\n30:         session_id=\"test-session-id\",\n31:         base_url=mock_base_url,\n32:     )\n33:     assert client.session_id == \"test-session-id\"\n34:     assert client.base_url == mock_base_url\n35:     assert \"x-agentcube-session-id\" in client.session.headers\n36:     assert client.session.headers[\"x-agentcube-session-id\"] == \"test-session-id\"\n37:     client.close()\n38: \n39: \n40: def test_data_plane_client_init_with_router_url():\n41:     \"\"\"Test CodeInterpreterDataPlaneClient initialization with router_url.\"\"\"\n42:     client = CodeInterpreterDataPlaneClient(\n43:         session_id=\"test-session-id\",\n44:         router_url=\"http://router:8080\",\n45:         namespace=\"default\",\n46:         cr_name=\"test\",\n47:     )\n48:     assert client.base_url == \"http://router:8080/v1/namespaces/default/code-interpreters/test/invocations/\"\n49:     client.close()\n50: \n51: \n52: def test_data_plane_client_init_missing_params():\n53:     \"\"\"Test CodeInterpreterDataPlaneClient initialization with missing parameters.\"\"\"\n54:     with pytest.raises(ValueError, match=\"Either base_url or\"):\n55:         CodeInterpreterDataPlaneClient(session_id=\"test-session-id\")\n56: \n57: \n58: def test_execute_command_success(data_plane_client, mock_base_url):\n59:     \"\"\"Test execute_command success.\"\"\"\n60:     with patch.object(data_plane_client.session, \"post\") as mock_post:\n61:         mock_response = MagicMock()\n62:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\", \"stderr\": \"\"}\n63:         mock_post.return_value = mock_response\n64: \n65:         result = data_plane_client.execute_command(\"ls\")\n66: \n67:         assert result == \"output\"\n68:         mock_post.assert_called_once()\n69:         call_args = mock_post.call_args\n70:         assert call_args[0][0] == f\"{mock_base_url}api/execute\"\n71:         assert \"x-agentcube-session-id\" in call_args[1][\"headers\"]\n72: \n73: \n74: def test_execute_command_list(data_plane_client):\n75:     \"\"\"Test execute_command with list of arguments.\"\"\"\n76:     with patch.object(data_plane_client.session, \"post\") as mock_post:\n77:         mock_response = MagicMock()\n78:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\", \"stderr\": \"\"}\n79:         mock_post.return_value = mock_response\n80: \n81:         result = data_plane_client.execute_command([\"ls\", \"-la\"])\n82: \n83:         assert result == \"output\"\n84: \n85: \n86: def test_execute_command_failure(data_plane_client, mock_base_url):\n87:     \"\"\"Test execute_command with non-zero exit code.\"\"\"\n88:     with patch.object(data_plane_client.session, \"post\") as mock_post:\n89:         mock_response = MagicMock()\n90:         mock_response.json.return_value = {\"exit_code\": 1, \"stdout\": \"\", \"stderr\": \"error message\"}\n91:         mock_post.return_value = mock_response\n92: \n93:         with pytest.raises(CommandExecutionError) as exc_info:\n94:             data_plane_client.execute_command(\"ls /invalid\")\n95: \n96:         assert exc_info.value.exit_code == 1\n97:         assert exc_info.value.stderr == \"error message\"\n98:         assert exc_info.value.command == \"ls /invalid\"\n99: \n100: \n101: def test_execute_command_with_timeout(data_plane_client):\n102:     \"\"\"Test execute_command with custom timeout.\"\"\"\n103:     with patch.object(data_plane_client.session, \"post\") as mock_post:\n104:         mock_response = MagicMock()\n105:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\", \"stderr\": \"\"}\n106:         mock_post.return_value = mock_response\n107: \n108:         data_plane_client.execute_command(\"sleep 1\", timeout=30.0)\n109: \n110:         call_args = mock_post.call_args\n111:         assert call_args[1][\"timeout\"] == (5.0, 32.0)\n112: \n113: \n114: def test_run_code_python(data_plane_client):\n115:     \"\"\"Test run_code with Python.\"\"\"\n116:     with patch.object(data_plane_client, \"write_file\") as mock_write, patch.object(\n117:         data_plane_client, \"execute_command\"\n118:     ) as mock_execute:\n119:         mock_execute.return_value = \"output\"\n120: \n121:         result = data_plane_client.run_code(\"python\", \"print('hello')\")\n122: \n123:         assert result == \"output\"\n124:         mock_write.assert_called_once()\n125:         assert mock_execute.call_args[0][0].startswith(\"python3 code_\")\n126:         assert mock_execute.call_args[0][0].endswith(\".py\")\n127: \n128: \n129: def test_run_code_python3(data_plane_client):\n130:     \"\"\"Test run_code with python3.\"\"\"\n131:     with patch.object(data_plane_client, \"write_file\") as mock_write, patch.object(\n132:         data_plane_client, \"execute_command\"\n133:     ) as mock_execute:\n134:         mock_execute.return_value = \"output\"\n135: \n136:         result = data_plane_client.run_code(\"python3\", \"print('hello')\")\n137: \n138:         assert result == \"output\"\n139: \n140: \n141: def test_run_code_py(data_plane_client):\n142:     \"\"\"Test run_code with py.\"\"\"\n143:     with patch.object(data_plane_client, \"write_file\") as mock_write, patch.object(\n144:         data_plane_client, \"execute_command\"\n145:     ) as mock_execute:\n146:         mock_execute.return_value = \"output\"\n147: \n148:         result = data_plane_client.run_code(\"py\", \"print('hello')\")\n149: \n150:         assert result == \"output\"\n151: \n152: \n153: def test_run_code_unsupported_language(data_plane_client):\n154:     \"\"\"Test run_code with unsupported language.\"\"\"\n155:     with pytest.raises(ValueError, match=\"Unsupported language\"):\n156:         data_plane_client.run_code(\"javascript\", \"console.log('hello')\")\n157: \n158: \n159: def test_write_file(data_plane_client, mock_base_url):\n160:     \"\"\"Test write_file.\"\"\"\n161:     with patch.object(data_plane_client, \"_request\") as mock_request:\n162:         data_plane_client.write_file(\"test content\", \"/test/file.txt\")\n163: \n164:         mock_request.assert_called_once()\n165:         call_args = mock_request.call_args\n166:         assert call_args[0][0] == \"POST\"\n167:         assert call_args[0][1] == \"api/files\"\n168: \n169: \n170: def test_upload_file(data_plane_client, mock_base_url):\n171:     \"\"\"Test upload_file.\"\"\"\n172:     with patch.object(data_plane_client.session, \"post\") as mock_post, patch(\"builtins.open\", mock_open(read_data=b\"file content\")):\n173:         mock_response = MagicMock()\n174:         mock_post.return_value = mock_response\n175: \n176:         data_plane_client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n177: \n178:         mock_post.assert_called_once()\n179:         call_args = mock_post.call_args\n180:         assert call_args[0][0] == f\"{mock_base_url}api/files\"\n181:         assert \"files\" in call_args[1]\n182:         assert \"x-agentcube-session-id\" in call_args[1][\"headers\"]\n183: \n184: \n185: def test_download_file(data_plane_client, mock_base_url):\n186:     \"\"\"Test download_file.\"\"\"\n187:     with patch.object(data_plane_client.session, \"get\") as mock_get, patch(\"builtins.open\", mock_open()) as mock_file:\n188:         mock_response = MagicMock()\n189:         mock_response.iter_content.return_value = [b\"chunk1\", b\"chunk2\"]\n190:         mock_response.raise_for_status = MagicMock()\n191:         mock_get.return_value = mock_response\n192: \n193:         data_plane_client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n194: \n195:         mock_get.assert_called_once()\n196:         call_args = mock_get.call_args\n197:         assert call_args[0][0] == f\"{mock_base_url}api/files/remote/file.txt\"\n198:         assert call_args[1][\"stream\"] is True\n199: \n200: \n201: def test_download_file_with_leading_slash(data_plane_client):\n202:     \"\"\"Test download_file with leading slash in path.\"\"\"\n203:     with patch.object(data_plane_client.session, \"get\") as mock_get, patch(\"builtins.open\", mock_open()):\n204:         mock_response = MagicMock()\n205:         mock_response.iter_content.return_value = [b\"chunk\"]\n206:         mock_response.raise_for_status = MagicMock()\n207:         mock_get.return_value = mock_response\n208: \n209:         data_plane_client.download_file(\"/path/to/file.txt\", \"/local/file.txt\")\n210: \n211:         call_args = mock_get.call_args\n212:         assert call_args[0][0].endswith(\"api/files/path/to/file.txt\")\n213: \n214: \n215: def test_list_files(data_plane_client, mock_base_url):\n216:     \"\"\"Test list_files.\"\"\"\n217:     with patch.object(data_plane_client.session, \"get\") as mock_get:\n218:         mock_response = MagicMock()\n219:         mock_response.json.return_value = {\"files\": [\"file1.txt\", \"file2.txt\"]}\n220:         mock_get.return_value = mock_response\n221: \n222:         result = data_plane_client.list_files(\".\")\n223: \n224:         assert result == {\"files\": [\"file1.txt\", \"file2.txt\"]}\n225:         mock_get.assert_called_once()\n226:         call_args = mock_get.call_args\n227:         assert call_args[0][0] == f\"{mock_base_url}api/files\"\n228:         assert call_args[1][\"params\"][\"path\"] == \".\"\n229: \n230: \n231: def test_close(data_plane_client):\n232:     \"\"\"Test close method.\"\"\"\n233:     data_plane_client.close()\n234:     data_plane_client.close()\n235: \n236: \n237: def test_custom_timeout(mock_base_url):\n238:     \"\"\"Test CodeInterpreterDataPlaneClient with custom timeout.\"\"\"\n239:     client = CodeInterpreterDataPlaneClient(\n240:         session_id=\"test-session-id\",\n241:         base_url=mock_base_url,\n242:         timeout=60,\n243:         connect_timeout=2.0,\n244:     )\n245:     assert client.timeout == 60\n246:     assert client.connect_timeout == 2.0\n247:     client.close()\n\n(End of file - total 247 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nfrom unittest.mock import MagicMock, mock_open, patch\n\nimport pytest\nimport requests\n\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcub