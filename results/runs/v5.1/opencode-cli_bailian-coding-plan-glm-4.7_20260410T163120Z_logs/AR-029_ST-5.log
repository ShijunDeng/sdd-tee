ute_command with timeout.\"\"\"\n    code_interpreter_client.dp_client = MagicMock()\n    code_interpreter_client.dp_client.execute_command.return_value = \"output\"\n\n    result = code_interpreter_client.execute_command(\"ls\", timeout=30.0)\n\n    assert result == \"output\"\n    code_interpreter_client.dp_client.execute_command.assert_called_once_with(\"ls\", timeout=30.0)\n\n\ndef test_execute_command_no_dp_client(code_interpreter_client):\n    \"\"\"Test execute_command without data plane client.\"\"\"\n    code_interpreter_client.dp_client = None\n\n    with pytest.raises(ValueError, match=\"Data plane client not initialized\"):\n        code_interpreter_client.execute_command(\"ls\")\n\n\ndef test_run_code(code_interpreter_client):\n    \"\"\"Test run_code method.\"\"\"\n    code_interpreter_client.dp_client = MagicMock()\n    code_interpreter_client.dp_client.run_code.return_value = \"output\"\n\n    result = code_interpreter_client.run_code(\"python\", \"print('hello')\")\n\n    assert result == \"output\"\n    code_interpreter_client.dp_client.run_code.assert_called_once()\n\n\ndef test_write_file(code_interpreter_client):\n    \"\"\"Test write_file method.\"\"\"\n    code_interpreter_client.dp_client = MagicMock()\n\n    code_interpreter_client.write_file(\"content\", \"/file.txt\")\n\n    code_interpreter_client.dp_client.write_file.assert_called_once_with(\"content\", \"/file.txt\")\n\n\ndef test_upload_file(code_interpreter_client):\n    \"\"\"Test upload_file method.\"\"\"\n    code_interpreter_client.dp_client = MagicMock()\n\n    code_interpreter_client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n\n    code_interpreter_client.dp_client.upload_file.assert_called_once()\n\n\ndef test_download_file(code_interpreter_client):\n    \"\"\"Test download_file method.\"\"\"\n    code_interpreter_client.dp_client = MagicMock()\n\n    code_interpreter_client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n\n    code_interpreter_client.dp_client.download_file.assert_called_once()\n\n\ndef test_list_files(code_interpreter_client):\n    \"\"\"Test list_files method.\"\"\"\n    code_interpreter_client.dp_client = MagicMock()\n    code_interpreter_client.dp_client.list_files.return_value = {\"files\": [\"file.txt\"]}\n\n    result = code_interpreter_client.list_files(\".\")\n\n    assert result == {\"files\": [\"file.txt\"]}\n    code_interpreter_client.dp_client.list_files.assert_called_once_with(\".\")\n\n\ndef test_verbose_logging(mock_router_url, mock_workload_manager_url):\n    \"\"\"Test verbose logging.\"\"\"\n    with patch.object(CodeInterpreterClient, \"_create_session\"):\n        client = CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"default\",\n            router_url=mock_router_url,\n            workload_manager_url=mock_workload_manager_url,\n            verbose=True,\n        )\n\n        assert client.verbose is True\n        client.stop()\n\n\ndef test_custom_ttl(mock_router_url, mock_workload_manager_url):\n    \"\"\"Test custom TTL.\"\"\"\n    with patch.object(CodeInterpreterClient, \"_create_session\") as mock_create:\n        client = CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"default\",\n            router_url=mock_router_url,\n            workload_manager_url=mock_workload_manager_url,\n            ttl=7200,\n        )\n\n        assert client.ttl == 7200\n        client.stop()\n\n\ndef test_custom_namespace(mock_router_url, mock_workload_manager_url):\n    \"\"\"Test custom namespace.\"\"\"\n    with patch.object(CodeInterpreterClient, \"_create_session\"):\n        client = CodeInterpreterClient(\n            name=\"test-interpreter\",\n            namespace=\"custom-namespace\",\n            router_url=mock_router_url,\n            workload_manager_url=mock_workload_manager_url,\n        )\n\n        assert client.namespace == \"custom-namespace\"\n        client.stop()","additions":4,"delet