      self.namespace = namespace\n40:         self.agent_name = agent_name\n41:         self.timeout = timeout\n42:         self.connect_timeout = connect_timeout\n43:         self.logger = get_logger(f\"{__name__}.AgentRuntimeDataPlaneClient\")\n44:         self.session = create_session(pool_connections=pool_connections, pool_maxsize=pool_maxsize)\n45: \n46:         base_path = f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n47:         self.base_url = urljoin(router_url, base_path)\n48: \n49:         self.logger.debug(f\"Initialized agent runtime client with base_url: {self.base_url}\")\n50: \n51:     def bootstrap_session_id(self) -> str:\n52:         \"\"\"Bootstrap session ID from the Agent Runtime invocation endpoint.\n53: \n54:         Returns:\n55:             Session ID from response header\n56: \n57:         Raises:\n58:             ValueError: If session header is missing in response\n59:             requests.RequestException: If the request fails\n60:         \"\"\"\n61:         self.logger.debug(\"Bootstrapping session ID\")\n62: \n63:         response = self.session.get(\n64:             self.base_url,\n65:             timeout=(self.connect_timeout, self.timeout),\n66:         )\n67: \n68:         response.raise_for_status()\n69: \n70:         session_id = response.headers.get(self.SESSION_HEADER)\n71: \n72:         if not session_id:\n73:             raise ValueError(f\"Missing required response header: {self.SESSION_HEADER}\")\n74: \n75:         self.logger.info(f\"Bootstrapped session ID: {session_id}\")\n76:         return session_id\n77: \n78:     def invoke(\n79:         self,\n80:         session_id: str,\n81:         payload: dict[str, Any],\n82:         timeout: Optional[float] = None,\n83:     ) -> requests.Response:\n84:         \"\"\"Invoke the Agent Runtime with a payload.\n85: \n86:         Args:\n87:             session_id: Session ID\n88:             payload: JSON payload to send\n89:             timeout: Timeout in seconds (uses instance default if None)\n90: \n91:         Returns:\n92:             Response object\n93: \n94:         Raises:\n95:             requests.RequestException: If the request fails\n96:         \"\"\"\n97:         read_timeout = timeout if timeout is not None else self.timeout\n98: \n99:         self.logger.debug(f\"Invoking agent runtime with session: {session_id}\")\n100: \n101:         response = self.session.post(\n102:             self.base_url,\n103:             json=payload,\n104:             headers={\n105:                 self.SESSION_HEADER: session_id,\n106:                 \"Content-Type\": \"application/json\",\n107:             },\n108:             timeout=(self.connect_timeout, read_timeout),\n109:         )\n110: \n111:         response.raise_for_status()\n112:         return response\n113: \n114:     def close(self) -> None:\n115:         \"\"\"Close the HTTP session.\"\"\"\n116:         self.session.close()\n117:         self.logger.debug(\"Closed agent runtime data plane session\")\n\n(End of file - total 117 lines)\n</content>","metadata":{"preview":"\"\"\"Data plane client for Agent Runtime operations.\"\"\"\n\nimport logging\nfrom typing import Any, Optional\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom ..utils import create_session, get_logger\n\n\nclass AgentRuntimeDataPlaneClient:\n    \"\"\"Client for Agent Runtime data plane operations via Router.\"\"\"\n\n    SESSION_HEADER = \"x-agentcube-session-id\"\n\n    def __init__(\n        self,\n        router_url: str,\n        namespace: str,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/agentcube/clients/agent_runtime_data_plane.py","time":{"start":1775879990936,"end":1775879990950}}}}
