{\n\t// Type is the type of seccomp profile.\n\t// +required\n\tType string `json:\"type\"`\n\n\t// LocalhostProfile references a local profile.\n\t// +optional\n\tLocalhostProfile string `json:\"localhostProfile,omitempty\"`\n}\n\n// SandboxAffinity defines pod scheduling constraints.\ntype SandboxAffinity struct {\n\t// NodeAffinity defines node affinity.\n\t// +optional\n\tNodeAffinity *SandboxNodeAffinity `json:\"nodeAffinity,omitempty\"`\n\n\t// PodAffinity defines pod affinity.\n\t// +optional\n\tPodAffinity *SandboxPodAffinity `json:\"podAffinity,omitempty\"`\n\n\t// PodAntiAffinity defines pod anti-affinity.\n\t// +optional\n\tPodAntiAffinity *SandboxPodAffinity `json:\"podAntiAffinity,omitempty\"`\n}\n\n// SandboxNodeAffinity defines node affinity.\ntype SandboxNodeAffinity struct {\n\t// RequiredDuringSchedulingIgnoredDuringExecution defines required node selectors.\n\t// +optional\n\tRequiredDuringSchedulingIgnoredDuringExecution *SandboxNodeSelector `json:\"requiredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n\n\t// PreferredDuringSchedulingIgnoredDuringExecution defines preferred node selectors.\n\t// +optional\n\tPreferredDuringSchedulingIgnoredDuringExecution []SandboxPreferredSchedulingTerm `json:\"preferredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n}\n\n// SandboxNodeSelector defines a node selector.\ntype SandboxNodeSelector struct {\n\t// NodeSelectorTerms is the list of node selector terms.\n\t// +required\n\t// +kubebuilder:validation:MinItems=1\n\tNodeSelectorTerms []SandboxNodeSelectorTerm `json:\"nodeSelectorTerms\"`\n}\n\n// SandboxNodeSelectorTerm defines a node selector term.\ntype SandboxNodeSelectorTerm struct {\n\t// MatchExpressions is a list of node selector requirements.\n\t// +optional\n\tMatchExpressions []SandboxNodeSelectorRequirement `json:\"matchExpressions,omitempty\"`\n\n\t// MatchFields is a list of node selector field requirements.\n\t// +optional\n\tMatchFields []SandboxNodeSelectorRequirement `json:\"matchFields,omitempty\"`\n}\n\n// SandboxNodeSelectorRequirement defines a node selector requirement.\ntype SandboxNodeSelectorRequirement struct {\n\t// Key is the label key.\n\t// +required\n\tKey string `json:\"key\"`\n\n\t// Operator is the operator.\n\t// +required\n\tOperator string `json:\"operator\"`\n\n\t// Values is the values.\n\t// +optional\n\tValues []string `json:\"values,omitempty\"`\n}\n\n// SandboxPreferredSchedulingTerm defines a preferred scheduling term.\ntype SandboxPreferredSchedulingTerm struct {\n\t// Weight is the weight.\n\t// +required\n\t// +kubebuilder:validation:Minimum=1\n\t// +kubebuilder:validation:Maximum=100\n\tWeight int32 `json:\"weight\"`\n\n\t// Preference is the preference.\n\t// +required\n\tPreference SandboxNodeSelectorTerm `json:\"preference\"`\n}\n\n// SandboxPodAffinity defines pod affinity.\ntype SandboxPodAffinity struct {\n\t// RequiredDuringSchedulingIgnoredDuringExecution defines required pod selectors.\n\t// +optional\n\tRequiredDuringSchedulingIgnoredDuringExecution []SandboxPodAffinityTerm `json:\"requiredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n\n\t// PreferredDuringSchedulingIgnoredDuringExecution defines preferred pod selectors.\n\t// +optional\n\tPreferredDuringSchedulingIgnoredDuringExecution []SandboxWeightedPodAffinityTerm `json:\"preferredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n}\n\n// SandboxPodAffinityTerm defines a pod affinity term.\ntype SandboxPodAffinityTerm struct {\n\t// LabelSelector defines the label selector.\n\t// +optional\n\tLabelSelector *SandboxLabelSelector `json:\"labelSelector,omitempty\"`\n\n\t// Namespaces specifies the namespaces.\n\t// +optional\n\tNamespaces []string `json:\"namespaces,omitempty\"`\n\n\t// TopologyKey is the topology key.\n\t// +required\n\tTopologyKey string `json:\"topologyKey\"`\n\n\t// NamespaceSelector defines the namespace selector.\n\t// +optional\n\tNamespaceSelector *SandboxLabelSelector `json:\"namespaceSelector,omitempty\"`\n}\n\n