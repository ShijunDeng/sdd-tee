\"\n)\n\n// +genclient\n// +genclient:nonNamespaced\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +k8s:openapi-gen=true\n// +kubebuilder:resource:shortName=ar;agentruntime\n// +kubebuilder:subresource:status\n// +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n\n// AgentRuntime defines a custom resource for managing agent runtime configurations.\n// It represents a sandbox orchestration runtime that manages the lifecycle of agent pods.\ntype AgentRuntime struct {\n\tmetav1.TypeMeta   `json:\",inline\"`\n\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n\n\tSpec   AgentRuntimeSpec   `json:\"spec,omitempty\"`\n\tStatus AgentRuntimeStatus `json:\"status,omitempty\"`\n}\n\n// AgentRuntimeSpec defines the desired state of an AgentRuntime.\ntype AgentRuntimeSpec struct {\n\t// PodTemplate defines the template for creating sandbox pods.\n\t// +required\n\tPodTemplate *SandboxTemplate `json:\"podTemplate\"`\n\n\t// SessionTimeout defines the timeout for idle sessions before cleanup.\n\t// +kubebuilder:default=\"15m\"\n\t// +kubebuilder:validation:Type=string\n\t// +kubebuilder:validation:Format=duration\n\t// +optional\n\tSessionTimeout *metav1.Duration `json:\"sessionTimeout,omitempty\"`\n\n\t// MaxSessionDuration defines the maximum allowed duration for a session.\n\t// +kubebuilder:default=\"8h\"\n\t// +kubebuilder:validation:Type=string\n\t// +kubebuilder:validation:Format=duration\n\t// +optional\n\tMaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\"`\n}\n\n// SandboxTemplate defines the template for creating sandbox pods.\ntype SandboxTemplate struct {\n\t// Metadata defines labels and annotations for the pod.\n\t// +optional\n\tMetadata *SandboxMetadata `json:\"metadata,omitempty\"`\n\n\t// Spec defines the pod specification.\n\tSpec SandboxPodSpec `json:\"spec\"`\n}\n\n// SandboxMetadata defines metadata for sandbox pods.\ntype SandboxMetadata struct {\n\t// Labels are