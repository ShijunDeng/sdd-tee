es a pod affinity term.\ntype SandboxPodAffinityTerm struct {\n\t// LabelSelector defines the label selector.\n\t// +optional\n\tLabelSelector *SandboxLabelSelector `json:\"labelSelector,omitempty\"`\n\n\t// Namespaces specifies the namespaces.\n\t// +optional\n\tNamespaces []string `json:\"namespaces,omitempty\"`\n\n\t// TopologyKey is the topology key.\n\t// +required\n\tTopologyKey string `json:\"topologyKey\"`\n\n\t// NamespaceSelector defines the namespace selector.\n\t// +optional\n\tNamespaceSelector *SandboxLabelSelector `json:\"namespaceSelector,omitempty\"`\n}\n\n// SandboxLabelSelector defines a label selector.\ntype SandboxLabelSelector struct {\n\t// MatchLabels is a map of label keys and values.\n\t// +optional\n\tMatchLabels map[string]string `json:\"matchLabels,omitempty\"`\n\n\t// MatchExpressions is a list of label selector requirements.\n\t// +optional\n\tMatchExpressions []SandboxLabelSelectorRequirement `json:\"matchExpressions,omitempty\"`\n}\n\n// SandboxLabelSelectorRequirement defines a label selector requirement.\ntype SandboxLabelSelectorRequirement struct {\n\t// Key is the label key.\n\t// +required\n\tKey string `json:\"key\"`\n\n\t// Operator is the operator.\n\t// +required\n\tOperator string `json:\"operator\"`\n\n\t// Values is the values.\n\t// +optional\n\tValues []string `json:\"values,omitempty\"`\n}\n\n// SandboxWeightedPodAffinityTerm defines a weighted pod affinity term.\ntype SandboxWeightedPodAffinityTerm struct {\n\t// Weight is the weight.\n\t// +required\n\t// +kubebuilder:validation:Minimum=1\n\t// +kubebuilder:validation:Maximum=100\n\tWeight int32 `json:\"weight\"`\n\n\t// PodAffinityTerm is the pod affinity term.\n\t// +required\n\tPodAffinityTerm SandboxPodAffinityTerm `json:\"podAffinityTerm\"`\n}\n\n// SandboxToleration defines a pod toleration.\ntype SandboxToleration struct {\n\t// Key is the toleration key.\n\t// +optional\n\tKey string `json:\"key,omitempty\"`\n\n\t// Operator is the toleration operator.\n\t//