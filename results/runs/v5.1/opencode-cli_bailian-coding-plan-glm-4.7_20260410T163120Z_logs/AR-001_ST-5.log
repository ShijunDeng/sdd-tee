ype=string\n\t// +kubebuilder:validation:Format=duration\n\t// +optional\n\tMaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\"`\n}\n\n// SandboxTemplate defines the template for creating sandbox pods.\ntype SandboxTemplate struct {\n\t// Metadata defines labels and annotations for the pod.\n\t// +optional\n\tMetadata *SandboxMetadata `json:\"metadata,omitempty\"`\n\n\t// Spec defines the pod specification.\n\tSpec SandboxPodSpec `json:\"spec\"`\n}\n\n// SandboxMetadata defines metadata for sandbox pods.\ntype SandboxMetadata struct {\n\t// Labels are key-value pairs attached to the pod.\n\t// +optional\n\tLabels map[string]string `json:\"labels,omitempty\"`\n\n\t// Annotations are unstructured key-value pairs stored with the pod.\n\t// +optional\n\tAnnotations map[string]string `json:\"annotations,omitempty\"`\n}\n\n// SandboxPodSpec defines the specification for sandbox pods.\ntype SandboxPodSpec struct {\n\t// Containers represents the list of containers in the pod.\n\t// +kubebuilder:validation:MinItems=1\n\tContainers []SandboxContainer `json:\"containers\"`\n\n\t// NodeSelector specifies node selection constraints.\n\t// +optional\n\tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n\n\t// Affinity defines pod scheduling constraints.\n\t// +optional\n\tAffinity *SandboxAffinity `json:\"affinity,omitempty\"`\n\n\t// Tolerations defines pod tolerations.\n\t// +optional\n\tTolerations []SandboxToleration `json:\"tolerations,omitempty\"`\n\n\t// ResourceRequirements defines resource requirements for the pod.\n\t// +optional\n\tResourceRequirements *SandboxResources `json:\"resources,omitempty\"`\n\n\t// Volumes defines pod volumes.\n\t// +optional\n\tVolumes []SandboxVolume `json:\"volumes,omitempty\"`\n}\n\n// SandboxContainer defines a container in a sandbox pod.\ntype SandboxContainer struct {\n\t// Name is the name of the container.\n\t// +required\n\t// +kubebuilder:validation:MinLength=1\n\tName string `json:\"name\"`\n