root  4096 Mar 21 15:58 integrations\n-rw-r--r--  1 root root  1674 Mar 21 15:53 project.md\n-rw-r--r--  1 root root  6258 Apr 11 00:32 proposal.md\ndrwxr-xr-x  2 root root  4096 Mar 21 15:56 python-sdk\ndrwxr-xr-x  3 root root  4096 Apr 10 18:18 sandbox-orchestration\n-rw-r--r--  1 root root 10078 Apr 11 00:33 .sdd_prompt.md\ndrwxr-xr-x  2 root root  4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root  4096 Mar 21 15:56 session-store\ndrwxr-xr-x  2 root root  4096 Mar 25 09:51 testing\n-rw-r--r--  1 root root  1983 Mar 25 09:36 test_spec.md\n","exit":0,"description":"List root directory contents","truncated":false},"title":"List root directory contents","time":{"start":1775839154871,"end":1775839154896}}}}
