rts,omitempty\"`\n\n\t// Env represents environment variables.\n\t// +optional\n\tEnv []SandboxEnvVar `json:\"env,omitempty\"`\n\n\t// Resources defines compute resource requirements.\n\t// +optional\n\tResources *SandboxContainerResources `json:\"resources,omitempty\"`\n\n\t// VolumeMounts specifies volume mounts.\n\t// +optional\n\tVolumeMounts []SandboxVolumeMount `json:\"volumeMounts,omitempty\"`\n\n\t// LivenessProbe defines the liveness probe.\n\t// +optional\n\tLivenessProbe *SandboxProbe `json:\"livenessProbe,omitempty\"`\n\n\t// ReadinessProbe defines the readiness probe.\n\t// +optional\n\tReadinessProbe *SandboxProbe `json:\"readinessProbe,omitempty\"`\n\n\t// SecurityContext defines security settings.\n\t// +optional\n\tSecurityContext *SandboxSecurityContext `json:\"securityContext,omitempty\"`\n}\n\n// SandboxContainerPort defines a network port in a container.\ntype SandboxContainerPort struct {\n\t// Name is the name of the port.\n\t// +optional\n\tName string `json:\"name,omitempty\"`\n\n\t// ContainerPort is the port number on the container.\n\t// +required\n\t// +kubebuilder:validation:Minimum=1\n\t// +kubebuilder:validation:Maximum=65535\n\tContainerPort int32 `json:\"containerPort\"`\n\n\t// Protocol is the protocol for the port.\n\t// +optional\n\t// +kubebuilder:default=TCP\n\tProtocol string `json:\"protocol,omitempty\"`\n\n\t// HostPort is the port number on the host.\n\t// +optional\n\t// +kubebuilder:validation:Minimum=1\n\t// +kubebuilder:validation:Maximum=65535\n\tHostPort int32 `json:\"hostPort,omitempty\"`\n}\n\n// SandboxEnvVar defines an environment variable.\ntype SandboxEnvVar struct {\n\t// Name is the name of the environment variable.\n\t// +required\n\tName string `json:\"name\"`\n\n\t// Value is the literal value of the environment variable.\n\t// +optional\n\tValue string `json:\"value,omitempty\"`\n\n\t// ValueFrom specifies a source for the value.\n\t// +optional\n\tValueFrom *SandboxEnvVarSource `json:\"valueFrom,omitempty\"`\n}\n\n// SandboxEnvVarSource defines a source for environment variable values.\ntype SandboxEnvVarSource struct {\n\t// FieldRef selects a field from the pod.\n\t// +optional\n\tFieldRef *SandboxFieldRef `json:\"fieldRef,omitempty\"`\n\n\t// ConfigMapKeyRef selects a key from a ConfigMap.\n\t// +optional\n\tConfigMapKeyRef *SandboxConfigMapKeyRef `json:\"configMapKeyRef,omitempty\"`\n\n\t// SecretKeyRef selects a key from a Secret.\n\t// +optional\n\tSecretKeyRef *SandboxSecretKeyRef `json:\"secretKeyRef,omitempty\"`\n}\n\n// SandboxFieldRef selects a field from a pod.\ntype SandboxFieldRef struct {\n\t// FieldPath is the path of the field.\n\t// +required\n\tFieldPath string `json:\"fieldPath\"`\n}\n\n// SandboxConfigMapKeyRef selects a key from a ConfigMap.\ntype SandboxConfigMapKeyRef struct {\n\t// Name is the name of the ConfigMap.\n\t// +required\n\tName string `json:\"name\"`\n\n\t// Key is the key to select.\n\t// +required\n\tKey string `json:\"key\"`\n\n\t// Optional specifies whether the ConfigMap must exist.\n\t// +optional\n\tOptional *bool `json:\"optional,omitempty\"`\n}\n\n// SandboxSecretKeyRef selects a key from a Secret.\ntype SandboxSecretKeyRef struct {\n\t// Name is the name of the Secret.\n\t// +required\n\tName string `json:\"name\"`\n\n\t// Key is the key to select.\n\t// +required\n\tKey string `json:\"key\"`\n\n\t// Optional specifies whether the Secret must exist.\n\t// +optional\n\tOptional *bool `json:\"optional,omitempty\"`\n}\n\n// SandboxContainerResources defines resource requirements for a container.\ntype SandboxContainerResources struct {\n\t// Limits defines the resource limits.\n\t// +optional\n\tLimits SandboxResourceList `json:\"limits,omitempty\"`\n\n\t// Requests defines the resource requests.\n\t// +optional\n\tRequests SandboxResourceList `json:\"requests,omitempty\"`\n}\n\n// SandboxResourceList defines a list of resources.\ntype SandboxResourceList struct {\n\t// CPU defines CPU resources.\n\t// +optional\n\tCPU string `json:\"cpu,omitempty\"`\n\n\t// Memory defines memory resources.\n\t// +optional\n\tMemory string `json:\"memory,omitempty\"`\n\n\t// EphemeralStorage defines ephemeral storage resources.\n\t// +optional\n\tEphemeralStorage string `json:\"ephemeralStorage,omitempty\"`\n}\n\n// SandboxResources defines resource requirements for the pod.\ntype SandboxResources struct {\n\t// Limits defines the resource limits.\n\t// +optional\n\tLimits SandboxResourceList `json:\"limits,omitempty\"`\n\n\t// Requests defines the resource requests.\n\t// +optional\n\tRequests SandboxResourceList `json:\"requests,omitempty\"`\n}\n\n// SandboxVolumeMount defines a volume mount.\ntype SandboxVolumeMount struct {\n\t// Name is the name of the volume.\n\t// +required\n\tName string `json:\"name\"`\n\n\t// MountPath is the path within the container.\n\t// +required\n\tMountPath string `json:\"mountPath\"`\n\n\t// SubPath is the sub-path within the volume.\n\t// +optional\n\tSubPath string `json:\"subPath,omitempty\"`\n\n\t// ReadOnly specifies whether the volume is read-only.\n\t// +optional\n\tReadOnly bool `json:\"readOnly,omitempty\"`\n}\n\n// SandboxVolume defines a volume.\ntype SandboxVolume struct {\n\t// Name is the name of the volume.\n\t// +required\n\tName string `json:\"name\"`\n\n\t// EmptyDir defines an empty directory volume.\n\t// +optional\n\tEmptyDir *SandboxEmptyDirVolumeSource `json:\"emptyDir,omitempty\"`\n\n\t// ConfigMap defines a ConfigMap volume.\n\t// +optional\n\tConfigMap *SandboxConfigMapVolumeSource `json:\"configMap,omitempty\"`\n\n\t// Secret defines a Secret volume.\n\t// +optional\n\tSecret *SandboxSecretVolumeSource `json:\"secret,omitempty\"`\n\n\t// PersistentVolumeClaim defines a PVC volume.\n\t// +optional\n\tPersistentVolumeClaim *SandboxPersistentVolumeClaimVolumeSource `json:\"persistentVolumeClaim,omitempty\"`\n}\n\n// SandboxEmptyDirVolumeSource defines an empty directory volume.\ntype SandboxEmptyDirVolumeSource struct {\n\t// SizeLimit is the limit on the size of the volume.\n\t// +optional\n\tSizeLimit string `json:\"sizeLimit,omitempty\"`\n}\n\n// SandboxConfigMapVolumeSource defines a ConfigMap volume.\ntype SandboxConfigMapVolumeSource struct {\n\t// Name is the name of the ConfigMap.\n\t// +required\n\tName string `json:\"name\"`\n\n\t// Optional specifies whether the ConfigMap must exist.\n\t// +optional\n\tOptional *bool `json:\"optional,omitempty\"`\n\n\t// Items specifies keys to use and the path to mount them at.\n\t// +optional\n\tItems []SandboxKeyToPath `json:\"items,omitempty\"`\n}\n\n// SandboxSecretVolumeSource defines a Secret volume.\ntype SandboxSecretVolumeSource struct {\n\t// SecretName is the name of the Secret.\n\t// +required\n\tSecretName string `json:\"secretName\"`\n\n\t// Optional specifies whether the Secret must exist.\n\t// +optional\n\tOptional *bool `json:\"optional,omitempty\"`\n\n\t// Items specifies keys to use and the path to mount them at.\n\t// +optional\n\tItems []SandboxKeyToPath `json:\"items,omitempty\"`\n}\n\n// SandboxPersistentVolumeClaimVolumeSource defines a PVC volume.\ntype SandboxPersistentVolumeClaimVolumeSource struct {\n\t// ClaimName is the name of the PVC.\n\t// +required\n\tClaimName string `json:\"claimName\"`\n\n\t// ReadOnly specifies whether the volume is read-only.\n\t// +optional\n\tReadOnly bool `json:\"readOnly,omitempty\"`\n}\n\n// SandboxKeyToPath maps a key to a path.\ntype SandboxKeyToPath struct {\n\t// Key is the key to reference.\n\t// +required\n\tKey string `json:\"key\"`\n\n\t// Path is the relative path within the mount point.\n\t// +required\n\tPath string `json:\"path\"`\n\n\t// Mode is the octal permission bits.\n\t// +optional\n\tMode *int32 `json:\"mode,omitempty\"`\n}\n\n// SandboxProbe defines a probe.\ntype SandboxProbe struct {\n\t// ProbeHandler defines the probe handler.\n\tSandboxProbeHandler `json:\",inline\"`\n\n\t// InitialDelaySeconds is the delay before the first probe.\n\t// +optional\n\t// +kubebuilder:defaul