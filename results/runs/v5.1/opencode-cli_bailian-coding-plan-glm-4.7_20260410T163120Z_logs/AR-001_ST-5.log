ge: \"Runtime is ready\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif ar.Name != \"test-runtime\" {\n\t\tt.Errorf(\"Expected name test-runtime, got %s\", ar.Name)\n\t}\n\n\tif ar.Spec.PodTemplate == nil {\n\t\tt.Error(\"PodTemplate should not be nil\")\n\t}\n\n\tif len(ar.Spec.PodTemplate.Spec.Containers) != 1 {\n\t\tt.Errorf(\"Expected 1 container, got %d\", len(ar.Spec.PodTemplate.Spec.Containers))\n\t}\n\n\tif len(ar.Spec.PodTemplate.Spec.Volumes) != 1 {\n\t\tt.Errorf(\"Expected 1 volume, got %d\", len(ar.Spec.PodTemplate.Spec.Volumes))\n\t}\n}\n\nfunc TestSchemeContainsTypes(t *testing.T) {\n\tif Scheme == nil {\n\t\tt.Fatal(\"Scheme should not be nil\")\n\t}\n\n\tgvks, _, _ := Scheme.ObjectKinds(&AgentRuntime{})\n\tif len(gvks) == 0 {\n\t\tt.Error(\"AgentRuntime should be registered in scheme\")\n\t}\n\n\tgvks, _, _ = Scheme.ObjectKinds(&AgentRuntimeList{})\n\tif len(gvks) == 0 {\n\t\tt.Error(\"AgentRuntimeList should be registered in scheme\")\n\t}\n}\n\nfunc TestAgentRuntimeListTypeMeta(t *testing.T) {\n\tlist := &AgentRuntimeList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: SchemeGroupVersion.String(),\n\t\t\tKind:       \"AgentRuntimeList\",\n\t\t},\n\t}\n\n\tif list.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n\t\tt.Errorf(\"Expected APIVersion runtime.agentcube.volcano.sh/v1alpha1, got %s\", list.APIVersion)\n\t}\n\n\tif list.Kind != \"AgentRuntimeList\" {\n\t\tt.Errorf(\"Expected Kind AgentRuntimeList, got %s\", list.Kind)\n\t}\n}\n","additions":12,"deletions":4},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types_test.go","time":{"start":1775839548988,"end":1775839549189}}}}
