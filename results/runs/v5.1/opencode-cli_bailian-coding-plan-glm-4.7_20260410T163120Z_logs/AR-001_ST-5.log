 TestAgentRuntimeSpecDefaults(t *testing.T) {\n\tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n\tduration8h := metav1.Duration{Duration: 8 * time.Hour}\n\n\tspec := &AgentRuntimeSpec{\n\t\tPodTemplate: &SandboxTemplate{\n\t\t\tSpec: SandboxPodSpec{\n\t\t\t\tContainers: []SandboxContainer{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:  \"test\",\n\t\t\t\t\t\tImage: \"test:latest\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif spec.PodTemplate == nil {\n\t\tt.Error(\"PodTemplate should not be nil\")\n\t}\n\n\tif spec.SessionTimeout == nil || spec.SessionTimeout.Duration != duration15m.Duration {\n\t\tt.Logf(\"Note: SessionTimeout default value will be applied by API server\")\n\t}\n\n\tif spec.MaxSessionDuration == nil || spec.MaxSessionDuration.Duration != duration8h.Duration {\n\t\tt.Logf(\"Note: MaxSessionDuration default value will be applied by API server\")\n\t}\n}\n\nfunc TestAgentRuntimeStatusConditions(t *testing.T) {\n\tnow := metav1.Now()\n\tar := &AgentRuntime{\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:               \"Ready\",\n\t\t\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\t\t\tLastTransitionTime: now,\n\t\t\t\t\tReason:             \"Available\",\n\t\t\t\t\tMessage:            \"Runtime is ready\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tObservedGeneration: 1,\n\t\t},\n\t}\n\n\tif len(ar.Status.Conditions) != 1 {\n\t\tt.Errorf(\"Expected 1 condition, got %d\", len(ar.Status.Conditions))\n\t}\n\n\tif ar.Status.Conditions[0].Type != \"Ready\" {\n\t\tt.Errorf(\"Expected condition type Ready, got %s\", ar.Status.Conditions[0].Type)\n\t}\n\n\tif ar.Status.ObservedGeneration != 1 {\n\t\tt.Errorf(\"Expected ObservedGeneration 1, got %d\", ar.Status.ObservedGeneration)\n\t}\n}\n\nfunc TestAgentRuntimeList(t *testing.T) {\n\tlist := &AgentRuntimeList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: SchemeGroupVersion.String(),\n\t\t\tKind:       \"AgentRuntimeList\",\n\t\t},\n\t\tItems: []AgentRuntime{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"runtime-1\",\n\t\t\t\t},\n\t\t\t},\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"runtime-2\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(list.Items) != 2 {\n\t\tt.Errorf(\"Expected 2 items, got %d\", len(list.Items))\n\t}\n\n\tif list.Items[0].Name != \"runtime-1\" {\n\t\tt.Errorf(\"Expected runtime-1, got %s\", list.Items[0].Name)\n\t}\n}\n\nfunc TestSandboxTemplate(t *testing.T) {\n\ttemplate := &SandboxTemplate{\n\t\tMetadata: &SandboxMetadata{\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"agent\",\n\t\t\t},\n\t\t\tAnnotations: map[string]string{\n\t\t\t\t\"description\": \"Test agent runtime\",\n\t\t\t},\n\t\t},\n\t\tSpec: SandboxPodSpec{\n\t\t\tContainers: []SandboxContainer{\n\t\t\t\t{\n\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\tImage: \"agent:latest\",\n\t\t\t\t\tPorts: []SandboxContainerPort{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tContainerPort: 8080,\n\t\t\t\t\t\t\tProtocol:      \"TCP\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif template.Metadata == nil {\n\t\tt.Error(\"Metadata should not be nil\")\n\t}\n\n\tif len(template.Metadata.Labels) != 1 {\n\t\tt.Errorf(\"Expected 1 label, got %d\", len(template.Metadata.Labels))\n\t}\n\n\tif len(template.Spec.Containers) != 1 {\n\t\tt.Errorf(\"Expected 1 container, got %d\", len(template.Spec.Containers))\n\t}\n}\n\nfunc TestSandboxContainer(t *testing.T) {\n\tcontainer := SandboxContainer{\n\t\tName:  \"agent\",\n\t\tImage: \"agent:latest\",\n\t\tCommand: []string{\n\t\t\t\"/bin/agent\",\n\t\t},\n\t\tArgs: []string{\n\t\t\t\"--debug\",\n\t\t},\n\t\tWorkingDir: \"/workspace\",\n\t\tPorts: []SandboxContainerPort{\n\t\t\t{\n\t\t\t\tName:          \"http\",\n\t\t\t\tContainerPort: 8080,\n\t\t\t\tProtocol:      \"TCP\",\n\t\t\t},\n\t\t},\n\t\tEnv: []SandboxEnvVar{\n\t\t\t{\n\t\t\t\tName:  \"DEBUG\",\n\t\t\t\tValue: \"true\",\n\t\t\t},\n\t\t},\n\t\tResources: &SandboxContainerResources{\n\t\t\tLimits: SandboxResourceList{\n\t\t\t\tCPU:    \"1\",\n\t\t\t\tMemory: \"1Gi\",\n\t\t\t},\n\t\t\tRequests: SandboxResourceList{\n\t\t\t\tCPU:    \"500m\",\n\t\t\t\tMemory: \"512Mi\",\n\t\t\t},\n\t\t},\n\t}\n\n\tif container.Name != \"agent\" {\n\t\tt.Errorf(\"Expected name agent, got %s\", container.Name)\n\t}\n\n\tif len(container.Command) != 1 {\n\t\tt.Errorf(\"Expected 1 command, got %d\", len(container.Command))\n\t}\n\n\tif len(container.Ports) != 1 {\n\t\tt.Errorf(\"Expected 1 port, got %d\", len(container.Ports))\n\t}\n\n\tif container.Resources == nil {\n\t\tt.Error(\"Resources should not be nil\")\n\t}\n}\n\nfunc TestSandboxEnvVarSources(t *testing.T) {\n\ttests := []struct {\n\t\tname      string\n\t\tenvVar    SandboxEnvVar\n\t\thasValue  bool\n\t\thasField  bool\n\t\thasCM     bool\n\t\thasSecret bool\n\t}{\n\t\t{\n\t\t\tname: \"literal value\",\n\t\t\tenvVar: SandboxEnvVar{\n\t\t\t\tName:  \"DEBUG\",\n\t\t\t\tValue: \"true\",\n\t\t\t},\n\t\t\thasValue: true,\n\t\t},\n\t\t{\n\t\t\tname: \"field ref\",\n\t\t\tenvVar: SandboxEnvVar{\n\t\t\t\tName: \"POD_NAME\",\n\t\t\t\tValueFrom: &SandboxEnvVarSource{\n\t\t\t\t\tFieldRef: &SandboxFieldRef{\n\t\t\t\t\t\tFieldPath: \"metadata.name\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\thasField: true,\n\t\t},\n\t\t{\n\t\t\tname: \"configmap ref\",\n\t\t\tenvVar: SandboxEnvVar{\n\t\t\t\tName: \"CONFIG\",\n\t\t\t\tValueFrom: &SandboxEnvVarSource{\n\t\t\t\t\tConfigMapKeyRef: &SandboxConfigMapKeyRef{\n\t\t\t\t\t\tName: \"config\",\n\t\t\t\t\t\tKey:  \"key\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\thasCM: true,\n\t\t},\n\t\t{\n\t\t\tname: \"secret ref\",\n\t\t\tenvVar: SandboxEnvVar{\n\t\t\t\tName: \"SECRET\",\n\t\t\t\tValueFrom: &SandboxEnvVarSource{\n\t\t\t\t\tSecretKeyRef: &SandboxSecretKeyRef{\n\t\t\t\t\t\tName: \"secret\",\n\t\t\t\t\t\tKey:  \"key\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\thasSecret: true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.hasValue && tt.envVar.Value == \"\" {\n\t\t\t\tt.Error(\"Expected value to be set\")\n\t\t\t}\n\t\t\tif tt.hasField && tt.envVar.ValueFrom == nil {\n\t\t\t\tt.Error(\"Expected ValueFrom to be set\")\n\t\t\t}\n\t\t\tif tt.hasCM && tt.envVar.ValueFrom.ConfigMapKeyRef == nil {\n\t\t\t\tt.Error(\"Expected ConfigMapKeyRef to be set\")\n\t\t\t}\n\t\t\tif tt.hasSecret && tt.envVar.ValueFrom.SecretKeyRef == nil {\n\t\t\t\tt.Error(\"Expected SecretKeyRef to be set\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestSandboxProbe(t *testing.T) {\n\tprobe := &SandboxProbe{\n\t\tSandboxProbeHandler: SandboxProbeHandler{\n\t\t\tHTTPGet: &SandboxHTTPGetAction{\n\t\t\t\tPort: k8sutil.FromInt(8080),\n\t\t\t\tPath: \"/healthz\",\n\t\t\t},\n\t\t},\n\t\tInitialDelaySeconds: 5,\n\t\tTimeoutSeconds:      1,\n\t\tPeriodSeconds:       10,\n\t\tSuccessThreshold:    1,\n\t\tFailureThreshold:    3,\n\t}\n\n\tif probe.HTTPGet == nil {\n\t\tt.Error(\"HTTPGet should not be nil\")\n\t}\n\n\tif probe.InitialDelaySeconds != 5 {\n\t\tt.Errorf(\"Expected InitialDelaySeconds 5, got %d\", probe.InitialDelaySeconds)\n\t}\n}\n\nfunc TestSandboxAffinity(t *testing.T) {\n\taffinity := &SandboxAffinity{\n\t\tNodeAffinity: &SandboxNodeAffinity{\n\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &SandboxNodeSelector{\n\t\t\t\tNodeSelectorTerms: []SandboxNodeSelectorTerm{\n\t\t\t\t\t{\n\t\t\t\t\t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tKey:      \"node-role.kubernetes.io/agent\",\n\t\t\t\t\t\t\t\tOperator: \"In\",\n\t\t\t\t\t\t\t\tValues:   []string{\"true\"},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tPodAffinity: &SandboxPodAffinity{\n\t\t\tPreferredDuringSchedulingIgnoredDuringExecution: []SandboxWeightedPodAffinityTerm{\n\t\t\t\t{\n\t\t\t\t\tWeight: 100,\n\t\t\t\t\tPodAffinityTerm: SandboxPodAffinityTerm{\n\t\t\t\t\t\tTopologyKey: \"kubernetes.io/hostname\",\n\t\t\t\t\t\tLabelSelector: &SandboxLabelSelector{\n\t\t\t\t\t\t\tMatchLabels: map[string]string{\n\t\t\t\t\t\t\t\t\"app\": \"agent\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif affinity.NodeAffinity == nil {\n\t\tt.Error(\"NodeAffinity should not be nil\")\n\t}\n\n\tif affinity.PodAffinity == nil {\n\t\tt.Error(\"PodAffinity should not be nil\")\n\t}\n\n\tif len(affinity.PodAffinity.PreferredDuringSchedulingIgnoredDuringExecution) != 1 {\n\t\tt.Errorf(\"Expected 1 preferred term, got %d\", len(affinity.PodAffinity.PreferredDuringSchedulingIgnoredDuringExecution))\n\t}\n}\n\nfunc TestSandboxTolerations(t *testing.T) {\n\ttoleration := SandboxToleration{\n\t\tKey:      \"node-role.kubernetes.io/agent\",\n\t\tOperator: \"Equal\",\n\t\tValue:    \"true\",\n\t\tEffect:   \"NoSchedule\",\n\t\tTolerationSeconds: func() *int64 {\n\t\t\tv := int64(300)\n\t\t\treturn &v\n\t\t}(),\n\t}\n\n\tif toleration.Key != \"node-role.kubernetes.io/agent\" {\n\t\tt.Errorf(\"Expected key node-role.kubernetes.io/agent, got %s\", toleration.Key)\n\t}\n\n\tif toleration.TolerationSeconds == nil {\n\t\tt.Error(\"TolerationSeconds should not be nil\")\n\t}\n}\n\nfunc TestSandboxSecurityContext(t *testing.T) {\n\tuid := int64(1000)\n\tgid := int64(1000)\n\ttrueVal := true\n\n\tsecurityContext := &SandboxSecurityContext{\n\t\tRunAsUser:                &uid,\n\t\tRunAsGroup:               &gid,\n\t\tRunAsNonRoot:             &trueVal,\n\t\tReadOnlyRootFilesystem:   &trueVal,\n\t\tAllowPrivilegeEscalation: &trueVal,\n\t\tCapabilities: &SandboxCapabilities{\n\t\t\tAdd:  []string{\"NET_ADMIN\", \"SYS_ADMIN\"},\n\t\t\tDrop: []string{\"ALL\"},\n\t\t},\n\t\tSeccompProfile: &SandboxSeccompProfile{\n\t\t\tType: \"RuntimeDefault\",\n\t\t},\n\t}\n\n\tif securityContext.RunAsUser == nil {\n\t\tt.Error(\"RunAsUser should not be nil\")\n\t}\n\n\tif *securityContext.RunAsUser != 1000 {\n\t\tt.Errorf(\"Expected RunAsUser 1000, got %d\", *securityContext.RunAsUser)\n\t}\n\n\tif securityContext.Capabilities == nil {\n\t\tt.Error(\"Capabilities should not be nil\")\n\t}\n\n\tif len(securityContext.Capabilities.Add) != 2 {\n\t\tt.Errorf(\"Expected 2 capabilities to add, got %d\", len(securityContext.Capabilities.Add))\n\t}\n}\n\nfunc TestSandboxVolumes(t *testing.T) {\n\tmode := int32(0644)\n\ttrueVal := true\n\n\tvolumes := []SandboxVolume{\n\t\t{\n\t\t\tName: \"config-volume\",\n\t\t\tConfigMap: &SandboxConfigMapVolumeSource{\n\t\t\t\tName:     \"config\",\n\t\t\t\tOptional: &trueVal,\n\t\t\t\tItems: []SandboxKeyToPath{\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:  \"config.yaml\",\n\t\t\t\t\t\tPath: \"config.yaml\",\n\t\t\t\t\t\tMode: &mode,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tName: \"secret-volume\",\n\t\t\tSecret: &SandboxSecretVolumeSource{\n\t\t\t\tSecretName: \"secret\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tName: \"data-volume\",\n\t\t\tEmptyDir: &SandboxEmptyDirVolumeSource{\n\t\t\t\tSizeLimit: \"1Gi\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tName: \"pvc-volume\",\n\t\t\tPersistentVolumeClaim: &SandboxPersistentVolumeClaimVolumeSource{\n\t\t\t\tClaimName: \"data-claim\",\n\t\t\t\tReadOnly:  true,\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(volumes) != 4 {\n\t\tt.Errorf(\"Expected 4 volumes, got %d\", len(volumes))\n\t}\n\n\tif volumes[0].ConfigMap == nil {\n\t\tt.Error(\"ConfigMap should not be nil for config-volume\")\n\t}\n\n\tif volumes[1].Secret == nil {\n\t\tt.Error(\"Secret should not be nil for secret-volume\")\n\t}\n\n\tif volumes[2].EmptyDir == nil {\n\t\tt.Error(\"EmptyDir should not be nil for data-volume\")\n\t}\n\n\tif volumes[3].PersistentVolumeClaim == nil {\n\t\tt.Error(\"PersistentVolumeClaim should not be nil for pvc-volume\")\n\t}\n}\n\nfunc TestJSONSerialization(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tPodTemplate: &SandboxTemplate{\n\t\t\t\tSpec: SandboxPodSpec{\n\t\t\t\t\tContainers: []SandboxContainer{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\t\t\tImage: \"agent:latest\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tdata, err := json.Marshal(ar)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to marshal AgentRuntime: %v\", err)\n\t}\n\n\tvar unmarshaled AgentRuntime\n\tif err := json.Unmarshal(data, &unmarshaled); err != nil {\n\t\tt.Fatalf(\"Failed to unmarshal AgentRuntime: %v\", err)\n\t}\n\n\tif unmarshaled.Name != \"test-runtime\" {\n\t\tt.Errorf(\"Expected name test-runtime, got %s\", unmarshaled.Name)\n\t}\n\n\tif unmarshaled.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n\t\tt.Errorf(\"Expected APIVersion runtime.agentcube.volcano.sh/v1alpha1, got %s\", unmarshaled.APIVersion)\n\t}\n}\n\nfunc TestSchemeRegistration(t *testing.T) {\n\tif Scheme == nil {\n\t\tt.Fatal(\"Scheme should not be nil\")\n\t}\n\n\tgvk := schema.GroupVersionKind{\n\t\tGroup:   \"runtime.agentcube.volcano.sh\",\n\t\tVersion: \"v1alpha1\",\n\t\tKind:    \"AgentRuntime\",\n\t}\n\n\tobj, err := Scheme.New(gvk)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create object from scheme: %v\", err)\n\t}\n\n\tar, ok := obj.(*AgentRuntime)\n\tif !ok {\n\t\tt.Fatalf(\"Expected *AgentRuntime, got %T\", obj)\n\t}\n\n\tif ar.APIVersion != gvk.GroupVersion().String() {\n\t\tt.Errorf(\"Expected APIVersion %s, got %s\", gvk.GroupVersion().String(), ar.APIVersion)\n\t}\n\n\tif ar.Kind != gvk.Kind {\n\t\tt.Errorf(\"Expected Kind %s, got %s\", gvk.Kind, ar.Kind)\n\t}\n}\n\nfunc TestAgentRuntimeObjectMeta(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:              \"test-runtime\",\n\t\t\tNamespace:         \"default\",\n\t\t\tUID:               \"12345\",\n\t\t\tResourceVersion:   \"1\",\n\t\t\tGeneration:        1,\n\t\t\tCreationTimestamp: metav1.Now(),\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"agent\",\n\t\t\t},\n\t\t\tAnnotations: map[string]string{\n\t\t\t\t\"description\": \"Test agent runtime\",\n\t\t\t},\n\t\t},\n\t}\n\n\tif ar.Name != \"test-runtime\" {\n\t\tt.Errorf(\"Expected name test-runtime, got %s\", ar.Name)\n\t}\n\n\tif ar.Namespace != \"default\" {\n\t\tt.Errorf(\"Expected namespace default, got %s\", ar.Namespace)\n\t}\n\n\tif len(ar.Labels) != 1 {\n\t\tt.Errorf(\"Expected 1 label, got %d\", len(ar.Labels))\n\t}\n\n\tif len(ar.Annotations) != 1 {\n\t\tt.Errorf(\"Expected 1 annotation, got %d\", len(ar.Annotations))\n\t}\n}\n\nfunc TestSandboxContainerPort(t *testing.T) {\n\tport := SandboxContainerPort{\n\t\tName:          \"http\",\n\t\tContainerPort: 8080,\n\t\tProtocol:      \"TCP\",\n\t\tHostPort:      30080,\n\t}\n\n\tif port.Name != \"http\" {\n\t\tt.Errorf(\"Expected name http, got %s\", port.Name)\n\t}\n\n\tif port.ContainerPort != 8080 {\n\t\tt.Errorf(\"Expected ContainerPort 8080, got %d\", port.ContainerPort)\n\t}\n\n\tif port.Protocol != \"TCP\" {\n\t\tt.Errorf(\"Expected Protocol TCP, got %s\", port.Protocol)\n\t}\n\n\tif port.HostPort != 30080 {\n\t\tt.Errorf(\"Expected HostPort 30080, got %d\", port.HostPort)\n\t}\n}\n\nfunc TestDurationFields(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tduration string\n\t\texpected time.Duration\n\t}{\n\t\t{\n\t\t\tname:     \"15 minutes\",\n\t\t\tduration: \"15m\",\n\t\t\texpected: 15 * time.Minute,\n\t\t},\n\t\t{\n\t\t\tname:     \"8 hours\",\n\t\t\tduration: \"8h\",\n\t\t\texpected: 8 * time.Hour,\n\t\t},\n\t\t{\n\t\t\tname:     \"1 hour 30 minutes\",\n\t\t\tduration: \"1h30m\",\n\t\t\texpected: 1*time.Hour + 30*time.Minute,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tdur, err := time.ParseDuration(tt.duration)\n\t\t\tif err != nil {\n\t\t\t\tt.Fatalf(\"Failed to parse duration %s: %v\", tt.duration, err)\n\t\t\t}\n\n\t\t\tif dur != tt.expected {\n\t\t\t\tt.Errorf(\"Expected duration %v, got %v\", tt.expected, dur)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestSandboxResources(t *testing.T) {\n\tresources := &SandboxResources{\n\t\tLimits: SandboxResourceList{\n\t\t\tCPU:              \"2\",\n\t\t\tMemory:           \"4Gi\",\n\t\t\tEphemeralStorage: \"10Gi\",\n\t\t},\n\t\tRequests: SandboxResourceList{\n\t\t\tCPU:              \"1\",\n\t\t\tMemory:           \"2Gi\",\n\t\t\tEphemeralStorage: \"5Gi\",\n\t\t},\n\t}\n\n\tif resources.Limits.CPU != \"2\" {\n\t\tt.Errorf(\"Expected CPU limit 2, got %s\", resources.Limits.CPU)\n\t}\n\n\tif resources.Requests.Memory != \"2Gi\" {\n\t\tt.Errorf(\"Expected Memory request 2Gi, got %s\", resources.Requests.Memory)\n\t}\n\n\tif resources.Limits.EphemeralStorage != \"10Gi\" {\n\t\tt.Errorf(\"Expected EphemeralStorage limit 10Gi, got %s\", resources.Limits.EphemeralStorage)\n\t}\n}\n\nfunc TestSandboxVolumeMount(t *testing.T) {\n\tmount := SandboxVolumeMount{\n\t\tName:      \"config-volume\",\n\t\tMountPath: \"/etc/config\",\n\t\tSubPath:   \"config.yaml\",\n\t\tReadOnly:  true,\n\t}\n\n\tif mount.Name != \"config-volume\" {\n\t\tt.Errorf(\"Expected name config-volume, got %s\", mount.Name)\n\t}\n\n\tif mount.MountPath != \"/etc/config\" {\n\t\tt.Errorf(\"Expected MountPath /etc/config, got %s\", mount.MountPath)\n\t}\n\n\tif mount.SubPath != \"config.yaml\" {\n\t\tt.Errorf(\"Expected SubPath config.yaml, got %s\", mount.SubPath)\n\t}\n\n\tif !mount.ReadOnly {\n\t\tt.Error(\"Expected ReadOnly to be true\")\n\t}\n}\n\nfunc TestSandboxHTTPHeader(t *testing.T) {\n\theader := SandboxHTTPHeader{\n\t\tName:  \"Authorization\",\n\t\tValue: \"Bearer token\",\n\t}\n\n\tif header.Name != \"Authorization\" {\n\t\tt.Errorf(\"Expected name Authorization, got %s\", header.Name)\n\t}\n\n\tif header.Value != \"Bearer token\" {\n\t\tt.Errorf(\"Expected value Bearer token, got %s\", header.Value)\n\t}\n}\n\nfunc TestSandboxExecAction(t *testing.T) {\n\taction := &SandboxExecAction{\n\t\tCommand: []string{\n\t\t\t\"/bin/sh\",\n\t\t\t\"-c\",\n\t\t\t\"cat /tmp/health\",\n\t\t},\n\t}\n\n\tif len(action.Command) != 3 {\n\t\tt.Errorf(\"Expected 3 commands, got %d\", len(action.Command))\n\t}\n\n\tif action.Command[0] != \"/bin/sh\" {\n\t\tt.Errorf(\"Expected first command /bin/sh, got %s\", action.Command[0])\n\t}\n}\n\nfunc TestSandboxLabelSelector(t *testing.T) {\n\tselector := &SandboxLabelSelector{\n\t\tMatchLabels: map[string]string{\n\t\t\t\"app\":     \"agent\",\n\t\t\t\"version\": \"v1\",\n\t\t},\n\t\tMatchExpressions: []SandboxLabelSelectorRequirement{\n\t\t\t{\n\t\t\t\tKey:      \"tier\",\n\t\t\t\tOperator: \"In\",\n\t\t\t\tValues:   []string{\"frontend\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(selector.MatchLabels) != 2 {\n\t\tt.Errorf(\"Expected 2 match labels, got %d\", len(selector.MatchLabels))\n\t}\n\n\tif len(selector.MatchExpressions) != 1 {\n\t\tt.Errorf(\"Expected 1 match expression, got %d\", len(selector.MatchExpressions))\n\t}\n}\n\nfunc TestAgentRuntimeStatus(t *testing.T) {\n\tnow := metav1.Now()\n\tstatus := AgentRuntimeStatus{\n\t\tConditions: []metav1.Condition{\n\t\t\t{\n\t\t\t\tType:               \"Ready\",\n\t\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\t\tLastTransitionTime: now,\n\t\t\t\tReason:             \"Available\",\n\t\t\t\tMessage:            \"Runtime is ready\",\n\t\t\t},\n\t\t\t{\n\t\t\t\tType:               \"Initializing\",\n\t\t\t\tStatus:             metav1.ConditionFalse,\n\t\t\t\tLastTransitionTime: now,\n\t\t\t\tReason:             \"Completed\",\n\t\t\t\tMessage:            \"Initialization completed\",\n\t\t\t},\n\t\t},\n\t\tObservedGeneration: 2,\n\t}\n\n\tif len(status.Conditions) != 2 {\n\t\tt.Errorf(\"Expected 2 conditions, got %d\", len(status.Conditions))\n\t}\n\n\tif status.Conditions[0].Status != metav1.ConditionTrue {\n\t\tt.Errorf(\"Expected first condition status True, got %v\", status.Conditions[0].Status)\n\t}\n\n\tif status.ObservedGeneration != 2 {\n\t\tt.Errorf(\"Expected ObservedGeneration 2, got %d\", status.ObservedGeneration)\n\t}\n}\n\nfunc TestSandboxNodeSelectorTerm(t *testing.T) {\n\tterm := SandboxNodeSelectorTerm{\n\t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n\t\t\t{\n\t\t\t\tKey:      \"node-role.kubernetes.io/agent\",\n\t\t\t\tOperator: \"In\",\n\t\t\t\tValues:   []string{\"true\"},\n\t\t\t},\n\t\t},\n\t\tMatchFields: []SandboxNodeSelectorRequirement{\n\t\t\t{\n\t\t\t\tKey:      \"metadata.name\",\n\t\t\t\tOperator: \"In\",\n\t\t\t\tValues:   []string{\"agent-node-1\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(term.MatchExpressions) != 1 {\n\t\tt.Errorf(\"Expected 1 match expression, got %d\", len(term.MatchExpressions))\n\t}\n\n\tif len(term.MatchFields) != 1 {\n\t\tt.Errorf(\"Expected 1 match field, got %d\", len(term.MatchFields))\n\t}\n}\n\nfunc TestSandboxPreferredSchedulingTerm(t *testing.T) {\n\tterm := SandboxPreferredSchedulingTerm{\n\t\tWeight: 100,\n\t\tPreference: SandboxNodeSelectorTerm{\n\t\t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n\t\t\t\t{\n\t\t\t\t\tKey:      \"zone\",\n\t\t\t\t\tOperator: \"In\",\n\t\t\t\t\tValues:   []string{\"us-west-1\"},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif term.Weight != 100 {\n\t\tt.Errorf(\"Expected weight 100, got %d\", term.Weight)\n\t}\n\n\tif len(term.Preference.MatchExpressions) != 1 {\n\t\tt.Errorf(\"Expected 1 match expression, got %d\", len(term.Preference.MatchExpressions))\n\t}\n}\n\nfunc TestSandboxKeyToPath(t *testing.T) {\n\tmode := int32(0644)\n\tktp := SandboxKeyToPath{\n\t\tKey:  \"config.yaml\",\n\t\tPath: \"config/config.yaml\",\n\t\tMode: &mode,\n\t}\n\n\tif ktp.Key != \"config.yaml\" {\n\t\tt.Errorf(\"Expected key config.yaml, got %s\", ktp.Key)\n\t}\n\n\tif ktp.Path != \"config/config.yaml\" {\n\t\tt.Errorf(\"Expected path config/config.yaml, got %s\", ktp.Path)\n\t}\n\n\tif ktp.Mode == nil {\n\t\tt.Error(\"Mode should not be nil\")\n\t}\n\n\tif *ktp.Mode != 0644 {\n\t\tt.Errorf(\"Expected mode 0644, got %d\", *ktp.Mode)\n\t}\n}\n\nfunc TestFullAgentRuntime(t *testing.T) {\n\tuid := int64(1000)\n\ttrueVal := true\n\tmode := int32(0644)\n\n\tar := &AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"agent\",\n\t\t\t},\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tPodTemplate: &SandboxTemplate{\n\t\t\t\tMetadata: &SandboxMetadata{\n\t\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\t\"runtime\": \"test\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tSpec: SandboxPodSpec{\n\t\t\t\t\tContainers: []SandboxContainer{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:       \"agent\",\n\t\t\t\t\t\t\tImage:      \"agent:latest\",\n\t\t\t\t\t\t\tWorkingDir: \"/workspace\",\n\t\t\t\t\t\t\tPorts: []SandboxContainerPort{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:          \"http\",\n\t\t\t\t\t\t\t\t\tContainerPort: 8080,\n\t\t\t\t\t\t\t\t\tProtocol:      \"TCP\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tEnv: []SandboxEnvVar{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"DEBUG\",\n\t\t\t\t\t\t\t\t\tValue: \"true\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tResources: &SandboxContainerResources{\n\t\t\t\t\t\t\t\tRequests: SandboxResourceList{\n\t\t\t\t\t\t\t\t\tCPU:    \"500m\",\n\t\t\t\t\t\t\t\t\tMemory: \"512Mi\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\tLimits: SandboxResourceList{\n\t\t\t\t\t\t\t\t\tCPU:    \"1\",\n\t\t\t\t\t\t\t\t\tMemory: \"1Gi\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tSecurityContext: &SandboxSecurityContext{\n\t\t\t\t\t\t\t\tRunAsUser:    &uid,\n\t\t\t\t\t\t\t\tRunAsNonRoot: &trueVal,\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tNodeSelector: map[string]string{\n\t\t\t\t\t\t\"node-role.kubernetes.io/agent\": \"true\",\n\t\t\t\t\t},\n\t\t\t\t\tAffinity: &SandboxAffinity{\n\t\t\t\t\t\tNodeAffinity: &SandboxNodeAffinity{\n\t\t\t\t\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &SandboxNodeSelector{\n\t\t\t\t\t\t\t\tNodeSelectorTerms: []SandboxNodeSelectorTerm{\n\t\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n\t\t\t\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\t\t\tKey:      \"node-role.kubernetes.io/agent\",\n\t\t\t\t\t\t\t\t\t\t\t\tOperator: \"In\",\n\t\t\t\t\t\t\t\t\t\t\t\tValues:   []string{\"true\"},\n\t\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tTolerations: []SandboxToleration{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tKey:      \"node-role.kubernetes.io/agent\",\n\t\t\t\t\t\t\tOperator: \"Equal\",\n\t\t\t\t\t\t\tValue:    \"true\",\n\t\t\t\t\t\t\tEffect:   \"NoSchedule\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tVolumes: []SandboxVolume{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName: \"config\",\n\t\t\t\t\t\t\tConfigMap: &SandboxConfigMapVolumeSource{\n\t\t\t\t\t\t\t\tName: \"agent-config\",\n\t\t\t\t\t\t\t\tItems: []SandboxKeyToPath{\n\t\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\tKey:  \"config.yaml\",\n\t\t\t\t\t\t\t\t\t\tPath: \"config.yaml\",\n\t\t\t\t\t\t\t\t\t\tMode: &mode,\n\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:    \"Ready\",\n\t\t\t\t\tStatus:  metav1.ConditionTrue,\n\t\t\t\t\tReason:  \"Available\",\n\t\t\t\t\tMessage: \"Runtime is ready\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif ar.Name != \"test-runtime\" {\n\t\tt.Errorf(\"Expected name test-runtime, got %s\", ar.Name)\n\t}\n\n\tif ar.Spec.PodTemplate == nil {\n\t\tt.Error(\"PodTemplate should not be nil\")\n\t}\n\n\tif len(ar.Spec.PodTemplate.Spec.Containers) != 1 {\n\t\tt.Errorf(\"Expected 1 container, got %d\", len(ar.Spec.PodTemplate.Spec.Containers))\n\t}\n\n\tif len(ar.Spec.PodTemplate.Spec.Volumes) != 1 {\n\t\tt.Errorf(\"Expected 1 volume, got %d\", len(ar.Spec.PodTemplate.Spec.Volumes))\n\t}\n}\n\nfunc TestSchemeContainsTypes(t *testing.T) {\n\tif Scheme == nil {\n\t\tt.Fatal(\"Scheme should not be nil\")\n\t}\n\n\tgvks, _, _ := Scheme.ObjectKinds(&AgentRuntime{})\n\tif len(gvks) == 0 {\n\t\tt.Error(\"AgentRuntime should be registered in scheme\")\n\t}\n\n\tgvks, _, _ = Scheme.ObjectKinds(&AgentRuntimeList{})\n\tif len(gvks) == 0 {\n\t\tt.Error(\"AgentRuntimeList should be registered in scheme\")\n\t}\n}\n\nfunc TestAgentRuntimeListTypeMeta(t *testing.T) {\n\tlist := &AgentRuntimeList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: SchemeGroupVersion.String(),\n\t\t\tKind:       \"AgentRuntimeList\",\n\t\t},\n\t}\n\n\tif list.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n\t\tt.Errorf(\"Expected APIVersion runtime.agentcube.volcano.sh/v1alpha1, got %s\", list.APIVersion)\n\t}\n\n\tif list.Kind != \"AgentRuntimeList\" {\n\t\tt.Errorf(\"Expected Kind AgentRuntimeList, got %s\", list.Kind)\n\t}\n}\n","after":"package v1alpha1\n\nimport (\n\t\"encoding/json\"\n\t\"testing\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\tk8sutil \"k8s.io/apimachinery/pkg/util/intstr\"\n)\n\nfunc TestAgentRuntimeTypeMeta(t *testing.T) {\n\tar := &AgentRuntime{}\n\n\tif ar.APIVersion != \"\" {\n\t\tt.Errorf(\"Expected empty APIVersion, got %s\", ar.APIVersion)\n\t}\n\tif ar.Kind != \"\" {\n\t\tt.Errorf(\"Expected empty Kind, got %s\", ar.Kind)\n\t}\n}\n\nfunc TestAgentRuntimeSchemeGroupVersion(t *testing.T) {\n\texpectedGV := schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"}\n\tif SchemeGroupVersion != expectedGV {\n\t\tt.Errorf(\"Expected SchemeGroupVersion %v, got %v\", expectedGV, SchemeGroupVersion)\n\t}\n}\n\nfunc TestResource(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tresource string\n\t\texpected schema.GroupResource\n\t}{\n\t\t{\n\t\t\tname:     \"agentruntime\",\n\t\t\tresource: \"agentruntime\",\n\t\t\texpected: SchemeGroupVersion.WithResource(\"agentruntime\").GroupResource(),\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tresult := Resource(tt.resource)\n\t\t\tif result != tt.expected {\n\t\t\t\tt.Errorf(\"Expected %v, got %v\", tt.expected, result)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAgentRuntimeSpecDefaults(t *testing.T) {\n\tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n\tduration8h := metav1.Duration{Duration: 8 * time.Hour}\n\n\tspec := &AgentRuntimeSpec{\n\t\tPodTemplate: &SandboxTemplate{\n\t\t\tSpec: SandboxPodSpec{\n\t\t\t\tContainers: []SandboxContainer{\n\t\t\t\t\t{\n\t\t\t\t\t\tName:  \"test\",\n\t\t\t\t\t\tImage: \"test:latest\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif spec.PodTemplate == nil {\n\t\tt.Error(\"PodTemplate should not be nil\")\n\t}\n\n\tif spec.SessionTimeout == nil || spec.SessionTimeout.Duration != duration15m.Duration {\n\t\tt.Logf(\"Note: SessionTimeout default value will be applied by API server\")\n\t}\n\n\tif spec.MaxSessionDuration == nil || spec.MaxSessionDuration.Duration != duration8h.Duration {\n\t\tt.Logf(\"Note: MaxSessionDuration default value will be applied by API server\")\n\t}\n}\n\nfunc TestAgentRuntimeStatusConditions(t *testing.T) {\n\tnow := metav1.Now()\n\tar := &AgentRuntime{\n\t\tStatus: AgentRuntimeStatus{\n\t\t\tConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:               \"Ready\",\n\t\t\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\t\t\tLastTransitionTime: now,\n\t\t\t\t\tReason:             \"Available\",\n\t\t\t\t\tMessage:            \"Runtime is ready\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tObservedGeneration: 1,\n\t\t},\n\t}\n\n\tif len(ar.Status.Conditions) != 1 {\n\t\tt.Errorf(\"Expected 1 condition, got %d\", len(ar.Status.Conditions))\n\t}\n\n\tif ar.Status.Conditions[0].Type != \"Ready\" {\n\t\tt.Errorf(\"Expected condition type Ready, got %s\", ar.Status.Conditions[0].Type)\n\t}\n\n\tif ar.Status.ObservedGeneration != 1 {\n\t\tt.Errorf(\"Expected ObservedGeneration 1, got %d\", ar.Status.ObservedGeneration)\n\t}\n}\n\nfunc TestAgentRuntimeList(t *testing.T) {\n\tlist := &AgentRuntimeList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: SchemeGroupVersion.String(),\n\t\t\tKind:       \"AgentRuntimeList\",\n\t\t},\n\t\tItems: []AgentRuntime{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"runtime-1\",\n\t\t\t\t},\n\t\t\t},\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"runtime-2\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(list.Items) != 2 {\n\t\tt.Errorf(\"Expected 2 items, got %d\", len(list.Items))\n\t}\n\n\tif list.Items[0].Name != \"runtime-1\" {\n\t\tt.Errorf(\"Expected runtime-1, got %s\", list.Items[0].Name)\n\t}\n}\n\nfunc TestSandboxTemplate(t *testing.T) {\n\ttemplate := &SandboxTemplate{\n\t\tMetadata: &SandboxMetadata{\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"agent\",\n\t\t\t},\n\t\t\tAnnotations: map[string]string{\n\t\t\t\t\"description\": \"Test agent runtime\",\n\t\t\t},\n\t\t},\n\t\tSpec: SandboxPodSpec{\n\t\t\tContainers: []SandboxContainer{\n\t\t\t\t{\n\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\tImage: \"agent:latest\",\n\t\t\t\t\tPorts: []SandboxContainerPort{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tContainerPort: 8080,\n\t\t\t\t\t\t\tProtocol:      \"TCP\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif template.Metadata == nil {\n\t\tt.Error(\"Metadata should not be nil\")\n\t}\n\n\tif len(template.Metadata.Labels) != 1 {\n\t\tt.Errorf(\"Expected 1 label, got %d\", len(template.Metadata.Labels))\n\t}\n\n\tif len(template.Spec.Containers) != 1 {\n\t\tt.Errorf(\"Expected 1 container, got %d\", len(template.Spec.Containers))\n\t}\n}\n\nfunc TestSandboxContainer(t *testing.T) {\n\tcontainer := SandboxContainer{\n\t\tName:  \"agent\",\n\t\tImage: \"agent:latest\",\n\t\tCommand: []string{\n\t\t\t\"/bin/agent\",\n\t\t},\n\t\tArgs: []string{\n\t\t\t\"--debug\",\n\t\t},\n\t\tWorkingDir: \"/workspace\",\n\t\tPorts: []SandboxContainerPort{\n\t\t\t{\n\t\t\t\tName:          \"http\",\n\t\t\t\tContainerPort: 8080,\n\t\t\t\tProtocol:      \"TCP\",\n\t\t\t},\n\t\t},\n\t\tEnv: []SandboxEnvVar{\n\t\t\t{\n\t\t\t\tName:  \"DEBUG\",\n\t\t\t\tValue: \"true\",\n\t\t\t},\n\t\t},\n\t\tResources: &SandboxContainerResources{\n\t\t\tLimits: SandboxResourceList{\n\t\t\t\tCPU:    \"1\",\n\t\t\t\tMemory: \"1Gi\",\n\t\t\t},\n\t\t\tRequests: SandboxResourceList{\n\t\t\t\tCPU:    \"500m\",\n\t\t\t\tMemory: \"512Mi\",\n\t\t\t},\n\t\t},\n\t}\n\n\tif container.Name != \"agent\" {\n\t\tt.Errorf(\"Expected name agent, got %s\", container.Name)\n\t}\n\n\tif len(container.Command) != 1 {\n\t\tt.Errorf(\"Expected 1 command, got %d\", len(container.Command))\n\t}\n\n\tif len(container.Ports) != 1 {\n\t\tt.Errorf(\"Expected 1 port, got %d\", len(container.Ports))\n\t}\n\n\tif container.Resources == nil {\n\t\tt.Error(\"Resources should not be nil\")\n\t}\n}\n\nfunc TestSandboxEnvVarSources(t *testing.T) {\n\ttests := []struct {\n\t\tname      string\n\t\tenvVar    SandboxEnvVar\n\t\thasValue  bool\n\t\thasField  bool\n\t\thasCM     bool\n\t\thasSecret bool\n\t}{\n\t\t{\n\t\t\tname: \"literal value\",\n\t\t\tenvVar: SandboxEnvVar{\n\t\t\t\tName:  \"DEBUG\",\n\t\t\t\tValue: \"true\",\n\t\t\t},\n\t\t\thasValue: true,\n\t\t},\n\t\t{\n\t\t\tname: \"field ref\",\n\t\t\tenvVar: SandboxEnvVar{\n\t\t\t\tName: \"POD_NAME\",\n\t\t\t\tValueFrom: &SandboxEnvVarSource{\n\t\t\t\t\tFieldRef: &SandboxFieldRef{\n\t\t\t\t\t\tFieldPath: \"metadata.name\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\thasField: true,\n\t\t},\n\t\t{\n\t\t\tname: \"configmap ref\",\n\t\t\tenvVar: SandboxEnvVar{\n\t\t\t\tName: \"CONFIG\",\n\t\t\t\tValueFrom: &SandboxEnvVarSource{\n\t\t\t\t\tConfigMapKeyRef: &SandboxConfigMapKeyRef{\n\t\t\t\t\t\tName: \"config\",\n\t\t\t\t\t\tKey:  \"key\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\thasCM: true,\n\t\t},\n\t\t{\n\t\t\tname: \"secret ref\",\n\t\t\tenvVar: SandboxEnvVar{\n\t\t\t\tName: \"SECRET\",\n\t\t\t\tValueFrom: &SandboxEnvVarSource{\n\t\t\t\t\tSecretKeyRef: &SandboxSecretKeyRef{\n\t\t\t\t\t\tName: \"secret\",\n\t\t\t\t\t\tKey:  \"key\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\thasSecret: true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.hasValue && tt.envVar.Value == \"\" {\n\t\t\t\tt.Error(\"Expected value to be set\")\n\t\t\t}\n\t\t\tif tt.hasField && tt.envVar.ValueFrom == nil {\n\t\t\t\tt.Error(\"Expected ValueFrom to be set\")\n\t\t\t}\n\t\t\tif tt.hasCM && tt.envVar.ValueFrom.ConfigMapKeyRef == nil {\n\t\t\t\tt.Error(\"Expected ConfigMapKeyRef to be set\")\n\t\t\t}\n\t\t\tif tt.hasSecret && tt.envVar.ValueFrom.SecretKeyRef == nil {\n\t\t\t\tt.Error(\"Expected SecretKeyRef to be set\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestSandboxProbe(t *testing.T) {\n\tprobe := &SandboxProbe{\n\t\tSandboxProbeHandler: SandboxProbeHandler{\n\t\t\tHTTPGet: &SandboxHTTPGetAction{\n\t\t\t\tPort: k8sutil.FromInt(8080),\n\t\t\t\tPath: \"/healthz\",\n\t\t\t},\n\t\t},\n\t\tInitialDelaySeconds: 5,\n\t\tTimeoutSeconds:      1,\n\t\tPeriodSeconds:       10,\n\t\tSuccessThreshold:    1,\n\t\tFailureThreshold:    3,\n\t}\n\n\tif probe.HTTPGet == nil {\n\t\tt.Error(\"HTTPGet should not be nil\")\n\t}\n\n\tif probe.InitialDelaySeconds != 5 {\n\t\tt.Errorf(\"Expected InitialDelaySeconds 5, got %d\", probe.InitialDelaySeconds)\n\t}\n}\n\nfunc TestSandboxAffinity(t *testing.T) {\n\taffinity := &SandboxAffinity{\n\t\tNodeAffinity: &SandboxNodeAffinity{\n\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &SandboxNodeSelector{\n\t\t\t\tNodeSelectorTerms: []SandboxNodeSelectorTerm{\n\t\t\t\t\t{\n\t\t\t\t\t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tKey:      \"node-role.kubernetes.io/agent\",\n\t\t\t\t\t\t\t\tOperator: \"In\",\n\t\t\t\t\t\t\t\tValues:   []string{\"true\"},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tPodAffinity: &SandboxPodAffinity{\n\t\t\tPreferredDuringSchedulingIgnoredDuringExecution: []SandboxWeightedPodAffinityTerm{\n\t\t\t\t{\n\t\t\t\t\tWeight: 100,\n\t\t\t\t\tPodAffinityTerm: SandboxPodAffinityTerm{\n\t\t\t\t\t\tTopologyKey: \"kubernetes.io/hostname\",\n\t\t\t\t\t\tLabelSelector: &SandboxLabelSelector{\n\t\t\t\t\t\t\tMatchLabels: map[string]string{\n\t\t\t\t\t\t\t\t\"app\": \"agent\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif affinity.NodeAffinity == nil {\n\t\tt.Error(\"NodeAffinity should not be nil\")\n\t}\n\n\tif affinity.PodAffinity == nil {\n\t\tt.Error(\"PodAffinity should not be nil\")\n\t}\n\n\tif len(affinity.PodAffinity.PreferredDuringSchedulingIgnoredDuringExecution) != 1 {\n\t\tt.Errorf(\"Expected 1 preferred term, got %d\", len(affinity.PodAffinity.PreferredDuringSchedulingIgnoredDuringExecution))\n\t}\n}\n\nfunc TestSandboxTolerations(t *testing.T) {\n\ttoleration := SandboxToleration{\n\t\tKey:      \"node-role.kubernetes.io/agent\",\n\t\tOperator: \"Equal\",\n\t\tValue:    \"true\",\n\t\tEffect:   \"NoSchedule\",\n\t\tTolerationSeconds: func() *int64 {\n\t\t\tv := int64(300)\n\t\t\treturn &v\n\t\t}(),\n\t}\n\n\tif toleration.Key != \"node-role.kubernetes.io/agent\" {\n\t\tt.Errorf(\"Expected key node-role.kubernetes.io/agent, got %s\", toleration.Key)\n\t}\n\n\tif toleration.TolerationSeconds == nil {\n\t\tt.Error(\"TolerationSeconds should not be nil\")\n\t}\n}\n\nfunc TestSandboxSecurityContext(t *testing.T) {\n\tuid := int64(1000)\n\tgid := int64(1000)\n\ttrueVal := true\n\n\tsecurityContext := &SandboxSecurityContext{\n\t\tRunAsUser:                &uid,\n\t\tRunAsGroup:               &gid,\n\t\tRunAsNonRoot:             &trueVal,\n\t\tReadOnlyRootFilesystem:   &trueVal,\n\t\tAllowPrivilegeEscalation: &trueVal,\n\t\tCapabilities: &SandboxCapabilities{\n\t\t\tAdd:  []string{\"NET_ADMIN\", \"SYS_ADMIN\"},\n\t\t\tDrop: []string{\"ALL\"},\n\t\t},\n\t\tSeccompProfile: &SandboxSeccompProfile{\n\t\t\tType: \"RuntimeDefault\",\n\t\t},\n\t}\n\n\tif securityContext.RunAsUser == nil {\n\t\tt.Error(\"RunAsUser should not be nil\")\n\t}\n\n\tif *securityContext.RunAsUser != 1000 {\n\t\tt.Errorf(\"Expected RunAsUser 1000, got %d\", *securityContext.RunAsUser)\n\t}\n\n\tif securityContext.Capabilities == nil {\n\t\tt.Error(\"Capabilities should not be nil\")\n\t}\n\n\tif len(securityContext.Capabilities.Add) != 2 {\n\t\tt.Errorf(\"Expected 2 capabilities to add, got %d\", len(securityContext.Capabilities.Add))\n\t}\n}\n\nfunc TestSandboxVolumes(t *testing.T) {\n\tmode := int32(0644)\n\ttrueVal := true\n\n\tvolumes := []SandboxVolume{\n\t\t{\n\t\t\tName: \"config-volume\",\n\t\t\tConfigMap: &SandboxConfigMapVolumeSource{\n\t\t\t\tName:     \"config\",\n\t\t\t\tOptional: &trueVal,\n\t\t\t\tItems: []SandboxKeyToPath{\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:  \"config.yaml\",\n\t\t\t\t\t\tPath: \"config.yaml\",\n\t\t\t\t\t\tMode: &mode,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tName: \"secret-volume\",\n\t\t\tSecret: &SandboxSecretVolumeSource{\n\t\t\t\tSecretName: \"secret\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tName: \"data-volume\",\n\t\t\tEmptyDir: &SandboxEmptyDirVolumeSource{\n\t\t\t\tSizeLimit: \"1Gi\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tName: \"pvc-volume\",\n\t\t\tPersistentVolumeClaim: &SandboxPersistentVolumeClaimVolumeSource{\n\t\t\t\tClaimName: \"data-claim\",\n\t\t\t\tReadOnly:  true,\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(volumes) != 4 {\n\t\tt.Errorf(\"Expected 4 volumes, got %d\", len(volumes))\n\t}\n\n\tif volumes[0].ConfigMap == nil {\n\t\tt.Error(\"ConfigMap should not be nil for config-volume\")\n\t}\n\n\tif volumes[1].Secret == nil {\n\t\tt.Error(\"Secret should not be nil for secret-volume\")\n\t}\n\n\tif volumes[2].EmptyDir == nil {\n\t\tt.Error(\"EmptyDir should not be nil for data-volume\")\n\t}\n\n\tif volumes[3].PersistentVolumeClaim == nil {\n\t\tt.Error(\"PersistentVolumeClaim should not be nil for pvc-volume\")\n\t}\n}\n\nfunc TestJSONSerialization(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tPodTemplate: &SandboxTemplate{\n\t\t\t\tSpec: SandboxPodSpec{\n\t\t\t\t\tContainers: []SandboxContainer{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\t\t\tImage: \"agent:latest\",\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tdata, err := json.Marshal(ar)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to marshal AgentRuntime: %v\", err)\n\t}\n\n\tvar unmarshaled AgentRuntime\n\tif err := json.Unmarshal(data, &unmarshaled); err != nil {\n\t\tt.Fatalf(\"Failed to unmarshal AgentRuntime: %v\", err)\n\t}\n\n\tif unmarshaled.Name != \"test-runtime\" {\n\t\tt.Errorf(\"Expected name test-runtime, got %s\", unmarshaled.Name)\n\t}\n\n\tif unmarshaled.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n\t\tt.Errorf(\"Expected APIVersion runtime.agentcube.volcano.sh/v1alpha1, got %s\", unmarshaled.APIVersion)\n\t}\n}\n\nfunc TestSchemeRegistration(t *testing.T) {\n\tif Scheme == nil {\n\t\tt.Fatal(\"Scheme should not be nil\")\n\t}\n\n\tgvk := schema.GroupVersionKind{\n\t\tGroup:   \"runtime.agentcube.volcano.sh\",\n\t\tVersion: \"v1alpha1\",\n\t\tKind:    \"AgentRuntime\",\n\t}\n\n\tobj, err := Scheme.New(gvk)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create object from scheme: %v\", err)\n\t}\n\n\tar, ok := obj.(*AgentRuntime)\n\tif !ok {\n\t\tt.Fatalf(\"Expected *AgentRuntime, got %T\", obj)\n\t}\n\n\t// Note: Scheme.New() creates an empty instance without setting TypeMeta\n\t// TypeMeta is set when unmarshaling from YAML/JSON or manually\n\tif ar.Kind != \"\" {\n\t\tt.Logf(\"Note: Kind is not automatically set by Scheme.New()\")\n\t}\n\n\t// Verify the GVK is correct by checking the known types\n\tgvks, _, _ := Scheme.ObjectKinds(obj)\n\tif len(gvks) == 0 {\n\t\tt.Error(\"AgentRuntime should have a known GVK\")\n\t}\n\n\tif gvks[0] != gvk {\n\t\tt.Errorf(\"Expected GVK %v, got %v\", gvk, gvks[0])\n\t}\n}\n\nfunc TestAgentRuntimeObjectMeta(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:              \"test-runtime\",\n\t\t\tNamespace:         \"default\",\n\t\t\tUID:               \"12345\",\n\t\t\tResourceVersion:   \"1\",\n\t\t\tGeneration:        1,\n\t\t\tCreationTimestamp: metav1.Now(),\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"agent\",\n\t\t\t},\n\t\t\tAnnotations: map[string]string{\n\t\t\t\t\"description\": \"Test agent runtime\",\n\t\t\t},\n\t\t},\n\t}\n\n\tif ar.Name != \"test-runtime\" {\n\t\tt.Errorf(\"Expected name test-runtime, got %s\", ar.Name)\n\t}\n\n\tif ar.Namespace != \"default\" {\n\t\tt.Errorf(\"Expected namespace default, got %s\", ar.Namespace)\n\t}\n\n\tif len(ar.Labels) != 1 {\n\t\tt.Errorf(\"Expected 1 label, got %d\", len(ar.Labels))\n\t}\n\n\tif len(ar.Annotations) != 1 {\n\t\tt.Errorf(\"Expected 1 annotation, got %d\", len(ar.Annotations))\n\t}\n}\n\nfunc TestSandboxContainerPort(t *testing.T) {\n\tport := SandboxContainerPort{\n\t\tName:          \"http\",\n\t\tContainerPort: 8080,\n\t\tProtocol:      \"TCP\",\n\t\tHostPort:      30080,\n\t}\n\n\tif port.Name != \"http\" {\n\t\tt.Errorf(\"Expected name http, got %s\", port.Name)\n\t}\n\n\tif port.ContainerPort != 8080 {\n\t\tt.Errorf(\"Expected ContainerPort 8080, got %d\", port.ContainerPort)\n\t}\n\n\tif port.Protocol != \"TCP\" {\n\t\tt.Errorf(\"Expected Protocol TCP, got %s\", port.Protocol)\n\t}\n\n\tif port.HostPort != 30080 {\n\t\tt.Errorf(\"Expected HostPort 30080, got %d\", port.HostPort)\n\t}\n}\n\nfunc TestDurationFields(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tduration string\n\t\texpected time.Duration\n\t}{\n\t\t{\n\t\t\tname:     \"15 minutes\",\n\t\t\tduration: \"15m\",\n\t\t\texpected: 15 * time.Minute,\n\t\t},\n\t\t{\n\t\t\tname:     \"8 hours\",\n\t\t\tduration: \"8h\",\n\t\t\texpected: 8 * time.Hour,\n\t\t},\n\t\t{\n\t\t\tname:     \"1 hour 30 minutes\",\n\t\t\tduration: \"1h30m\",\n\t\t\texpected: 1*time.Hour + 30*time.Minute,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tdur, err := time.ParseDuration(tt.duration)\n\t\t\tif err != nil {\n\t\t\t\tt.Fatalf(\"Failed to parse duration %s: %v\", tt.duration, err)\n\t\t\t}\n\n\t\t\tif dur != tt.expected {\n\t\t\t\tt.Errorf(\"Expected duration %v, got %v\", tt.expected, dur)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestSandboxResources(t *testing.T) {\n\tresources := &SandboxResources{\n\t\tLimits: SandboxResourceList{\n\t\t\tCPU:              \"2\",\n\t\t\tMemory:           \"4Gi\",\n\t\t\tEphemeralStorage: \"10Gi\",\n\t\t},\n\t\tRequests: SandboxResourceList{\n\t\t\tCPU:              \"1\",\n\t\t\tMemory:           \"2Gi\",\n\t\t\tEphemeralStorage: \"5Gi\",\n\t\t},\n\t}\n\n\tif resources.Limits.CPU != \"2\" {\n\t\tt.Errorf(\"Expected CPU limit 2, got %s\", resources.Limits.CPU)\n\t}\n\n\tif resources.Requests.Memory != \"2Gi\" {\n\t\tt.Errorf(\"Expected Memory request 2Gi, got %s\", resources.Requests.Memory)\n\t}\n\n\tif resources.Limits.EphemeralStorage != \"10Gi\" {\n\t\tt.Errorf(\"Expected EphemeralStorage limit 10Gi, got %s\", resources.Limits.EphemeralStorage)\n\t}\n}\n\nfunc TestSandboxVolumeMount(t *testing.T) {\n\tmount := SandboxVolumeMount{\n\t\tName:      \"config-volume\",\n\t\tMountPath: \"/etc/config\",\n\t\tSubPath:   \"config.yaml\",\n\t\tReadOnly:  true,\n\t}\n\n\tif mount.Name != \"config-volume\" {\n\t\tt.Errorf(\"Expected name config-volume, got %s\", mount.Name)\n\t}\n\n\tif mount.MountPath != \"/etc/config\" {\n\t\tt.Errorf(\"Expected MountPath /etc/config, got %s\", mount.MountPath)\n\t}\n\n\tif mount.SubPath != \"config.yaml\" {\n\t\tt.Errorf(\"Expected SubPath config.yaml, got %s\", mount.SubPath)\n\t}\n\n\tif !mount.ReadOnly {\n\t\tt.Error(\"Expected ReadOnly to be true\")\n\t}\n}\n\nfunc TestSandboxHTTPHeader(t *testing.T) {\n\theader := SandboxHTTPHeader{\n\t\tName:  \"Authorization\",\n\t\tValue: \"Bearer token\",\n\t}\n\n\tif header.Name != \"Authorization\" {\n\t\tt.Errorf(\"Expected name Authorization, got %s\", header.Name)\n\t}\n\n\tif header.Value != \"Bearer token\" {\n\t\tt.Errorf(\"Expected value Bearer token, got %s\", header.Value)\n\t}\n}\n\nfunc TestSandboxExecAction(t *testing.T) {\n\taction := &SandboxExecAction{\n\t\tCommand: []string{\n\t\t\t\"/bin/sh\",\n\t\t\t\"-c\",\n\t\t\t\"cat /tmp/health\",\n\t\t},\n\t}\n\n\tif len(action.Command) != 3 {\n\t\tt.Errorf(\"Expected 3 commands, got %d\", len(action.Command))\n\t}\n\n\tif action.Command[0] != \"/bin/sh\" {\n\t\tt.Errorf(\"Expected first command /bin/sh, got %s\", action.Command[0])\n\t}\n}\n\nfunc TestSandboxLabelSelector(t *testing.T) {\n\tselector := &SandboxLabelSelector{\n\t\tMatchLabels: map[string]string{\n\t\t\t\"app\":     \"agent\",\n\t\t\t\"version\": \"v1\",\n\t\t},\n\t\tMatchExpressions: []SandboxLabelSelectorRequirement{\n\t\t\t{\n\t\t\t\tKey:      \"tier\",\n\t\t\t\tOperator: \"In\",\n\t\t\t\tValues:   []string{\"frontend\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(selector.MatchLabels) != 2 {\n\t\tt.Errorf(\"Expected 2 match labels, got %d\", len(selector.MatchLabels))\n\t}\n\n\tif len(selector.MatchExpressions) != 1 {\n\t\tt.Errorf(\"Expected 1 match expression, got %d\", len(selector.MatchExpressions))\n\t}\n}\n\nfunc TestAgentRuntimeStatus(t *testing.T) {\n\tnow := metav1.Now()\n\tstatus := AgentRuntimeStatus{\n\t\tConditions: []metav1.Condition{\n\t\t\t{\n\t\t\t\tType:               \"Ready\",\n\t\t\t\tStatus:             metav1.ConditionTrue,\n\t\t\t\tLastTransitionTime: now,\n\t\t\t\tReason:             \"Available\",\n\t\t\t\tMessage:            \"Runtime is ready\",\n\t\t\t},\n\t\t\t{\n\t\t\t\tType:               \"Initializing\",\n\t\t\t\tStatus:             metav1.ConditionFalse,\n\t\t\t\tLastTransitionTime: now,\n\t\t\t\tReason:             \"Completed\",\n\t\t\t\tMessage:            \"Initialization completed\",\n\t\t\t},\n\t\t},\n\t\tObservedGeneration: 2,\n\t}\n\n\tif len(status.Conditions) != 2 {\n\t\tt.Errorf(\"Expected 2 conditions, got %d\", len(status.Conditions))\n\t}\n\n\tif status.Conditions[0].Status != metav1.ConditionTrue {\n\t\tt.Errorf(\"Expected first condition status True, got %v\", status.Conditions[0].Status)\n\t}\n\n\tif status.ObservedGeneration != 2 {\n\t\tt.Errorf(\"Expected ObservedGeneration 2, got %d\", status.ObservedGeneration)\n\t}\n}\n\nfunc TestSandboxNodeSelectorTerm(t *testing.T) {\n\tterm := SandboxNodeSelectorTerm{\n\t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n\t\t\t{\n\t\t\t\tKey:      \"node-role.kubernetes.io/agent\",\n\t\t\t\tOperator: \"In\",\n\t\t\t\tValues:   []string{\"true\"},\n\t\t\t},\n\t\t},\n\t\tMatchFields: []SandboxNodeSelectorRequirement{\n\t\t\t{\n\t\t\t\tKey:      \"metadata.name\",\n\t\t\t\tOperator: \"In\",\n\t\t\t\tValues:   []string{\"agent-node-1\"},\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(term.MatchExpressions) != 1 {\n\t\tt.Errorf(\"Expected 1 match expression, got %d\", len(term.MatchExpressions))\n\t}\n\n\tif len(term.MatchFields) != 1 {\n\t\tt.Errorf(\"Expected 1 match field, got %d\", len(term.MatchFields))\n\t}\n}\n\nfunc TestSandboxPreferredSchedulingTerm(t *testing.T) {\n\tterm := SandboxPreferredSchedulingTerm{\n\t\tWeight: 100,\n\t\tPreference: SandboxNodeSelectorTerm{\n\t\t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n\t\t\t\t{\n\t\t\t\t\tKey:      \"zone\",\n\t\t\t\t\tOperator: \"In\",\n\t\t\t\t\tValues:   []string{\"us-west-1\"},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif term.Weight != 100 {\n\t\tt.Errorf(\"Expected weight 100, got %d\", term.Weight)\n\t}\n\n\tif len(term.Preference.MatchExpressions) != 1 {\n\t\tt.Errorf(\"Expected 1 match expression, got %d\", len(term.Preference.MatchExpressions))\n\t}\n}\n\nfunc TestSandboxKeyToPath(t *testing.T) {\n\tmode := int32(0644)\n\tktp := SandboxKeyToPath{\n\t\tKey:  \"config.yaml\",\n\t\tPath: \"config/config.yaml\",\n\t\tMode: &mode,\n\t}\n\n\tif ktp.Key != \"config.yaml\" {\n\t\tt.Errorf(\"Expected key config.yaml, got %s\", ktp.Key)\n\t}\n\n\tif ktp.Path != \"config/config.yaml\" {\n\t\tt.Errorf(\"Expected path config/config.yaml, got %s\", ktp.Path)\n\t}\n\n\tif ktp.Mode == nil {\n\t\tt.Error(\"Mode should not be nil\")\n\t}\n\n\tif *ktp.Mode != 0644 {\n\t\tt.Errorf(\"Expected mode 0644, got %d\", *ktp.Mode)\n\t}\n}\n\nfunc TestFullAgentRuntime(t *testing.T) {\n\tuid := int64(1000)\n\ttrueVal := true\n\tmode := int32(0644)\n\n\tar := &AgentRuntime{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\tKind:       \"AgentRuntime\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t\tLabels: map[string]string{\n\t\t\t\t\"app\": \"agent\",\n\t\t\t},\n\t\t},\n\t\tSpec: AgentRuntimeSpec{\n\t\t\tPodTemplate: &SandboxTemplate{\n\t\t\t\tMetadata: &SandboxMetadata{\n\t\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\t\"runtime\": \"test\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tSpec: SandboxPodSpec{\n\t\t\t\t\tContainers: []SandboxContainer{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tName:       \"agent\",\n\t\t\t\t\t\t\tImage:      \"agent:latest\",\n\t\t\t\t\t\t\tWorkingDir: \"/workspace\",\n\t\t\t\t\t\t\tPorts: []SandboxContainerPort{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:          \"http\",\n\t\t\t\t\t\t\t\t\tContainerPort: 8080,\n\t\t\t\t\t\t\t\t\tProtocol:      \"TCP\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tEnv: []SandboxEnvVar{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"DEBUG\",\n\t\t\t\t\t\t\t\t\tValue: \"true\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tResources: &SandboxContainerResources{\n\t\t\t\t\t\t\t\tRequests: SandboxResourceList{\n\t\t\t\t\t\t\t\t\tCPU:    \"500m\",\n\t\t\t\t\t\t\t\t\tMemory: \"512Mi\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\tLimits: SandboxResourceList{\n\t\t\t\t\t\t\t\t\tCPU:    \"