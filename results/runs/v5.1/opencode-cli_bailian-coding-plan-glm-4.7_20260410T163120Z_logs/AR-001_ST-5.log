on struct {\n\t// Port is the port number or name.\n\t// +required\n\tPort intstr.IntOrString `json:\"port\"`\n\n\t// Host is the host to connect to.\n\t// +optional\n\tHost string `json:\"host,omitempty\"`\n\n\t// Path is the path to request.\n\t// +optional\n\tPath string `json:\"path,omitempty\"`\n\n\t// Scheme is the URI scheme.\n\t// +optional\n\t// +kubebuilder:default=HTTP\n\tScheme string `json:\"scheme,omitempty\"`\n\n\t// HTTPHeaders specifies custom headers.\n\t// +optional\n\tHTTPHeaders []SandboxHTTPHeader `json:\"httpHeaders,omitempty\"`\n}\n\n// SandboxHTTPHeader defines an HTTP header.\ntype SandboxHTTPHeader struct {\n\t// Name is the header name.\n\t// +required\n\tName string `json:\"name\"`\n\n\t// Value is the header value.\n\t// +required\n\tValue string `json:\"value\"`\n}\n\n// SandboxSecurityContext defines security settings.\ntype SandboxSecurityContext struct {\n\t// RunAsUser is the UID to run the entrypoint of the container.\n\t// +optional\n\tRunAsUser *int64 `json:\"runAsUser,omitempty\"`\n\n\t// RunAsGroup is the GID to run the entrypoint of the container.\n\t// +optional\n\tRunAsGroup *int64 `json:\"runAsGroup,omitempty\"`\n\n\t// RunAsNonRoot specifies whether the container must run as non-root.\n\t// +optional\n\tRunAsNonRoot *bool `json:\"runAsNonRoot,omitempty\"`\n\n\t// ReadOnlyRootFilesystem specifies whether the root filesystem is read-only.\n\t// +optional\n\tReadOnlyRootFilesystem *bool `json:\"readOnlyRootFilesystem,omitempty\"`\n\n\t// AllowPrivilegeEscalation specifies whether a process can gain privileges.\n\t// +optional\n\tAllowPrivilegeEscalation *bool `json:\"allowPrivilegeEscalation,omitempty\"`\n\n\t// Capabilities defines Linux capabilities.\n\t// +optional\n\tCapabilities *SandboxCapabilities `json:\"capabilities,omitempty\"`\n\n\t// SeccompProfile defines the seccomp profile.\n\t// +optional\n\tSeccompProfile *SandboxSeccompProfile `json:\"seccompProfile,omitempty\"`\n\n\t// Privileged specifies whether to run i