oat64(sandboxStore.ExpiresAt.Unix()), sandboxStore.SessionID).Build(),\n+\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().ScoreMember(float64(time.Now().Unix()), sandboxStore.SessionID).Build(),\n }\n \n for _, cmd := range commands {\n \tif err := s.cli.Do(ctx, cmd).Error(); err != nil {\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey.go","before":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc newValkeyStore(addr string, password string, db int) (Store, error) {\n\tdialer := net.Dialer{\n\t\tTimeout:   5 * time.Second,\n\t\tKeepAlive: 30 * time.Second,\n\t}\n\n\toptions := valkey.ClientOption{\n\t\tInitAddress:       []string{addr},\n\t\tPassword:          password,\n\t\tSelectDB:          db,\n\t\tDisableCache:      os.Getenv(\"VALKEY_DISABLE_CACHE\") == \"true\",\n\t\tForceSingleClient: os.Getenv(\"VALKEY_FORCE_SINGLE\") == \"true\",\n\t\tDialer:            dialer,\n\t}\n\n\tcli, err := valkey.NewClient(options)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n\t}\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\n\tresult, err := cli.Do(ctx, cli.B().Ping().Build()).ToString()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to ping valkey: %w\", err)\n\t}\n\tif result != \"PONG\" {\n\t\treturn nil, fmt.Errorf(\"unexpected ping response: %s\", result)\n\t}\n\n\treturn &valkeyStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        \"session:\",\n\t\texpiryIndexKey:       \"session:expiry\",\n\t\tlastActivityIndexKey: \"session:last_activity\",\n\t}, nil\n}\n\nfunc (s *valkeyStore) Ping(ctx context.Context) error {\n\tresult, err := s.cli.Do(ctx, s.cli.B().Ping().Build()).ToString()\n\tif err != nil {\n\t\treturn err\n\t}\n\tif result != \"PONG\" {\n\t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n\t}\n\treturn nil\n}\n\nfunc (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\tkey := s.sessionPrefix + sessionID\n\tdata := s.cli.Do(ctx, s.cli.B().Get().Key(key).Build())\n\n\tif valkey.IsValkeyNil(data.Error()) {\n\t\treturn nil, ErrNotFound\n\t}\n\n\tif data.Error() != nil {\n\t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", data.Error())\n\t}\n\n\tbytes, err := data.AsBytes()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n\t}\n\n\tinfo := &types.SandboxInfo{}\n\tif err := unmarshalSandboxInfo(string(bytes), info); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n\t}\n\n\treturn info, nil\n}\n\nfunc (s *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n\tif sandboxStore == nil {\n\t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n\t}\n\tif sandboxStore.SessionID == \"\" {\n\t\treturn fmt.Errorf(\"session ID cannot be empty\")\n\t}\n\tif sandboxStore.ExpiresAt.IsZero() {\n\t\treturn fmt.Errorf(\"expires at cannot be zero\")\n\t}\n\n\tkey := s.sessionPrefix + sandboxStore.SessionID\n\tdata, err := marshalSandboxInfo(sandboxStore)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n\t}\n\n\tcommands := []valkey.Completed{\n\t\ts.cli.B().Set().Key(key).Value(data).Nx().Build(),\n\t\ts.cli.B().Zadd().Key(s.expiryIndexKey).Score(float64(sandboxStore.ExpiresAt.Unix())).Member(sandboxStore.SessionID).Build(),\n\t\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).Score(float64(time.Now().Unix())).Member(sandboxStore.SessionID).Build(),\n\t}\n\n\tfor _, cmd := range commands {