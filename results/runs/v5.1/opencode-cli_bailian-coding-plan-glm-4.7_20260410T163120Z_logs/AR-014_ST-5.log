{"type":"tool_use","timestamp":1775857422966,"sessionID":"ses_286a9a530ffepWXr051e2RyH2C","part":{"id":"prt_d7959d247001sYmqU8AXDhiOjQ","messageID":"msg_d7959aab8001h2nCqa7M77fKEk","sessionID":"ses_286a9a530ffepWXr051e2RyH2C","type":"tool","tool":"read","callID":"toolu_tool-283abeb84c0b454db43c3834b996d234","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net\"\n7: \t\"os\"\n8: \t\"strings\"\n9: \t\"time\"\n10: \n11: \t\"github.com/valkey-io/valkey-go\"\n12: \t\"k8s.io/klog/v2\"\n13: \n14: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n15: )\n16: \n17: type valkeyStore struct {\n18: \tcli                  valkey.Client\n19: \tsessionPrefix        string\n20: \texpiryIndexKey       string\n21: \tlastActivityIndexKey string\n22: }\n23: \n24: func newValkeyStore(addr string, password string, db int) (Store, error) {\n25: \tdialer := net.Dialer{\n26: \t\tTimeout:   5 * time.Second,\n27: \t\tKeepAlive: 30 * time.Second,\n28: \t}\n29: \n30: \toptions := valkey.ClientOption{\n31: \t\tInitAddress:       strings.Split(addr, \",\"),\n32: \t\tPassword:          password,\n33: \t\tSelectDB:          db,\n34: \t\tDisableCache:      os.Getenv(\"VALKEY_DISABLE_CACHE\") == \"true\",\n35: \t\tForceSingleClient: os.Getenv(\"VALKEY_FORCE_SINGLE\") == \"true\",\n36: \t\tDialer:            dialer,\n37: \t}\n38: \n39: \tcli, err := valkey.NewClient(options)\n40: \tif err != nil {\n41: \t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n42: \t}\n43: \n44: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n45: \tdefer cancel()\n46: \n47: \tresult, err := cli.Do(ctx, cli.B().Ping().Build()).ToString()\n48: \tif err != nil {\n49: \t\treturn nil, fmt.Errorf(\"failed to ping valkey: %w\", err)\n50: \t}\n51: \tif result != \"PONG\" {\n52: \t\treturn nil, fmt.Errorf(\"unexpected ping response: %s\", result)\n53: \t}\n54: \n55: \treturn &valkeyStore{\n56: \t\tcli:                  cli,\n57: \t\tsessionPrefix:        \"session:\",\n58: \t\texpiryIndexKey:       \"session:expiry\",\n59: \t\tlastActivityIndexKey: \"session:last_activity\",\n60: \t}, nil\n61: }\n62: \n63: func (s *valkeyStore) Ping(ctx context.Context) error {\n64: \tresult, err := s.cli.Do(ctx, s.cli.B().Ping().Build()).ToString()\n65: \tif err != nil {\n66: \t\treturn err\n67: \t}\n68: \tif result != \"PONG\" {\n69: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n70: \t}\n71: \treturn nil\n72: }\n73: \n74: func (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n75: \tkey := s.sessionPrefix + sessionID\n76: \tdata := s.cli.Do(ctx, s.cli.B().Get().Key(key).Build())\n77: \n78: \tif valkey.IsValkeyNil(data.Error()) {\n79: \t\treturn nil, ErrNotFound\n80: \t}\n81: \n82: \tif data.Error() != nil {\n83: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", data.Error())\n84: \t}\n85: \n86: \tbytes, err := data.AsBytes()\n87: \tif err != nil {\n88: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n89: \t}\n90: \n91: \tinfo := &types.SandboxInfo{}\n92: \tif err := unmarshalSandboxInfo(string(bytes), info); err != nil {\n93: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n94: \t}\n95: \n96: \treturn info, nil\n97: }\n98: \n99: func (s *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n100: \tif sandboxStore == nil {\n101: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n102: \t}\n103: \tif sandboxStore.SessionID == \"\" {\n104: \t\treturn fmt.Errorf(\"session ID cannot be empty\")\n105: \t}\n106: \tif sandboxStore.ExpiresAt.IsZero() {\n107: \t\treturn fmt.Errorf(\"expires at cannot be zero\")\n108: \t}\n109: \n110: \tkey := s.sessionPrefix + sandboxStore.SessionID\n111: \tdata, err := marshalSandboxInfo(sandboxStore)\n112: \tif err != nil {\n113: \t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n114: \t}\n115: \n116: \tcommands := []valkey.Completed{\n117: \t\ts.cli.B().Set().Key(key).Value(data).Nx().Build(),\n118: \t\ts.cli.B().Zadd().Key(s.expiryIndexKey).ScoreMember().ScoreMember(float64(sandboxStore.ExpiresAt.Unix()), sandboxStore.SessionID).Build(),\n119: \t\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().ScoreMember(float64(time.Now().Unix()), sandboxStore.SessionID).Build(),\n120: \t}\n121: \n122: \tfor _, cmd := range commands {\n123: \t\tif err := s.cli.Do(ctx, cmd).Error(); err != nil {\n124: \t\t\treturn fmt.Errorf(\"failed to store sandbox: %w\", err)\n125: \t\t}\n126: \t}\n127: \n128: \treturn nil\n129: }\n130: \n131: func (s *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n132: \tif sandboxStore == nil {\n133: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n134: \t}\n135: \tif sandboxStore.SessionID == \"\" {\n136: \t\treturn fmt.Errorf(\"session ID cannot be empty\")\n137: \t}\n138: \n139: \tkey := s.sessionPrefix + sandboxStore.SessionID\n140: \tdata, err := marshalSandboxInfo(sandboxStore)\n141: \tif err != nil {\n142: \t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n143: \t}\n144: \n145: \tresult, err := s.cli.Do(ctx, s.cli.B().Set().Key(key).Value(data).Xx().Build()).ToString()\n146: \tif err != nil {\n147: \t\treturn fmt.Errorf(\"failed to update sandbox: %w\", err)\n148: \t}\n149: \tif result != \"OK\" {\n150: \t\treturn ErrNotFound\n151: \t}\n152: \n153: \treturn nil\n154: }\n155: \n156: func (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n157: \tkey := s.sessionPrefix + sessionID\n158: \n159: \tcommands := []valkey.Completed{\n160: \t\ts.cli.B().Del().Key(key).Build(),\n161: \t\ts.cli.B().Zrem().Key(s.expiryIndexKey).Member(sessionID).Build(),\n162: \t\ts.cli.B().Zrem().Key(s.lastActivityIndexKey).Member(sessionID).Build(),\n163: \t}\n164: \n165: \tfor _, cmd := range commands {\n166: \t\tif err := s.cli.Do(ctx, cmd).Error(); err != nil {\n167: \t\t\treturn fmt.Errorf(\"failed to delete sandbox: %w\", err)\n168: \t\t}\n169: \t}\n170: \n171: \treturn nil\n172: }\n173: \n174: func (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n175: \tmessages, err := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.expiryIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()).ToArray()\n176: \tif err != nil {\n177: \t\treturn nil, fmt.Errorf(\"failed to list expired sandboxes: %w\", err)\n178: \t}\n179: \n180: \tsessionIDs := make([]string, len(messages))\n181: \tfor i, msg := range messages {\n182: \t\tsessionIDs[i], err = msg.ToString()\n183: \t\tif err != nil {\n184: \t\t\treturn nil, fmt.Errorf(\"failed to convert session ID: %w\", err)\n185: \t\t}\n186: \t}\n187: \n188: \treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n189: }\n190: \n191: func (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n192: \tmessages, err := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.lastActivityIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()).ToArray()\n193: \tif err != nil {\n194: \t\treturn nil, fmt.Errorf(\"failed to list inactive sandboxes: %w\", err)\n195: \t}\n196: \n197: \tsessionIDs := make([]string, len(messages))\n198: \tfor i, msg := range messages {\n199: \t\tsessionIDs[i], err = msg.ToString()\n200: \t\tif err != nil {\n201: \t\t\treturn nil, fmt.Errorf(\"failed to convert session ID: %w\", err)\n202: \t\t}\n203: \t}\n204: \n205: \treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n206: }\n207: \n208: func (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n209: \tkey := s.sessionPrefix + sessionID\n210: \n211: \texists, err := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build()).ToInt64()\n212: \tif err != nil {\n213: \t\treturn fmt.Errorf(\"failed to check session existence: %w\", err)\n214: \t}\n215: \tif exists != 1 {\n216: \t\treturn ErrNotFound\n217: \t}\n218: \n219: \tif err := s.cli.Do(ctx, s.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().ScoreMember(float64(at.Unix()), sessionID).Build()).Error(); err != nil {\n220: \t\treturn fmt.Errorf(\"failed to update last activity: %w\", err)\n221: \t}\n222: \n223: \treturn nil\n224: }\n225: \n226: func (s *valkeyStore) Close() error {\n227: \ts.cli.Close()\n228: \treturn nil\n229: }\n230: \n231: func (s *valkeyStore) getSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n232: \tif len(sessionIDs) == 0 {\n233: \t\treturn []*types.SandboxInfo{}, nil\n234: \t}\n235: \n236: \tkeys := make([]string, len(sessionIDs))\n237: \tfor i, sessionID := range sessionIDs {\n238: \t\tkeys[i] = s.sessionPrefix + sessionID\n239: \t}\n240: \n241: \tvalues, err := s.cli.Do(ctx, s.cli.B().Mget().Key(keys...).Build()).ToArray()\n242: \tif err != nil {\n243: \t\treturn nil, fmt.Errorf(\"failed to get sandbox data: %w\", err)\n244: \t}\n245: \n246: \tresult := make([]*types.SandboxInfo, 0, len(sessionIDs))\n247: \tfor _, value := range values {\n248: \t\tif valkey.IsValkeyNil(value.Error()) {\n249: \t\t\tcontinue\n250: \t\t}\n251: \n252: \t\tif value.Error() != nil {\n253: \t\t\tklog.Warningf(\"Failed to get value: %v\", value.Error())\n254: \t\t\tcontinue\n255: \t\t}\n256: \n257: \t\tbytes, err := value.AsBytes()\n258: \t\tif err != nil {\n259: \t\t\tklog.Warningf(\"Failed to convert value to bytes: %v\", err)\n260: \t\t\tcontinue\n261: \t\t}\n262: \n263: \t\tinfo := &types.SandboxInfo{}\n264: \t\tif err := unmarshalSandboxInfo(string(bytes), info); err != nil {\n265: \t\t\tklog.Warningf(\"Failed to unmarshal sandbox info: %v\", err)\n266: \t\t\tcontinue\n267: \t\t}\n268: \n269: \t\tresult = append(result, info)\n270: \t}\n271: \n272: \treturn result, nil\n273: }\n\n(End of file - total 273 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey.go","time":{"start":1775857422945,"end":1775857422963}}}}
