:             type: string\n38:           metadata:\n39:             type: object\n40:           spec:\n41:             description: AgentRuntimeSpec defines the desired state of an AgentRuntime.\n42:             type: object\n43:             properties:\n44:               maxSessionDuration:\n45:                 default: 8h\n46:                 description: MaxSessionDuration defines the maximum allowed duration for a session.\n47:                 type: string\n48:               podTemplate:\n49:                 description: PodTemplate defines the template for creating sandbox pods.\n50:                 type: object\n51:                 properties:\n52:                   metadata:\n53:                     description: Metadata defines labels and annotations for the pod.\n54:                     type: object\n55:                     properties:\n56:                       annotations:\n57:                         additionalProperties:\n58:                           type: string\n59:                         type: object\n60:                       labels:\n61:                         additionalProperties:\n62:                           type: string\n63:                         type: object\n64:                   spec:\n65:                     description: Spec defines the pod specification.\n66:                     type: object\n67:                     x-kubernetes-preserve-unknown-fields: true\n68:           status:\n69:             description: AgentRuntimeStatus defines the observed state of an AgentRuntime.\n70:             type: object\n71:             properties:\n72:               conditions:\n73:                 description: Conditions represent the latest available observations of an AgentRuntime's current state.\n74:                 type: array\n75:                 items:\n76:                   type: object\n77:                   properties:\n78:                     lastTransitionTime:\n79:                       format: date-time\n80:                       type: string\n81:                     message:\n82:                       type: string\n83:                     reason:\n84:                       type: string\n85:                     status:\n86:                       type: string\n87:                     type:\n88:                       type: string\n89:                     observedGeneration:\n90:                       format: int64\n91:                       type: integer\n92:               observedGeneration:\n93:                 format: int64\n94:                 type: integer\n95:     subresources:\n96:       status: {}\n97:     additionalPrinterColumns:\n98:     - name: Age\n99:       type: date\n100:       jsonPath: .metadata.creationTimestamp\n101: {{- end }}\n\n(End of file - total 101 lines)\n</content>","metadata":{"preview":"{{- if .Values.controllerManager.enabled }}\napiVersion: apiextensions.k8s.io/v1\nkind: CustomResourceDefinition\nmetadata:\n  name: agentruntimes.runtime.agentcube.volcano.sh\n  annotations:\n    helm.sh/hook: crd-install\n    helm.sh/hook-weight: \"-5\"\n    helm.sh/hook-delete-policy: before-hook-creation\n  labels:\n    {{- include \"agentcube.labels\" . | nindent 4 }}\nspec:\n  group: runtime.agentcube.volcano.sh\n  names:\n    kind: AgentRuntime\n    listKind: AgentRuntimeList\n    plural: agentruntimes\n    shortNames:\n    - ar\n    - agentruntime","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/manifests/charts/agentcube/templates/crds/agentruntime.yaml","time":{"start":1775899762683,"end":1775899762695}}}}
