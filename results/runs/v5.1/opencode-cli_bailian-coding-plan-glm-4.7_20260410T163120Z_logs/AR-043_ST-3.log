 = namespace\n39:         self.agent_name = agent_name\n40:         self.timeout = timeout\n41:         self.connect_timeout = connect_timeout\n42:         self.logger = get_logger(f\"{__name__}.AgentRuntimeDataPlaneClient\")\n43:         self.session = create_session(pool_connections=pool_connections, pool_maxsize=pool_maxsize)\n44: \n45:         base_path = f\"/v1/namespaces/{namespace}/agent-runtimes/{agent_name}/invocations/\"\n46:         self.base_url = urljoin(router_url, base_path)\n47: \n48:         self.logger.debug(f\"Initialized agent runtime client with base_url: {self.base_url}\")\n49: \n50:     def bootstrap_session_id(self) -> str:\n51:         \"\"\"Bootstrap session ID from the Agent Runtime invocation endpoint.\n52: \n53:         Returns:\n54:             Session ID from response header\n55: \n56:         Raises:\n57:             ValueError: If session header is missing in response\n58:             requests.RequestException: If the request fails\n59:         \"\"\"\n60:         self.logger.debug(\"Bootstrapping session ID\")\n61: \n62:         response = self.session.get(\n63:             self.base_url,\n64:             timeout=(self.connect_timeout, self.timeout),\n65:         )\n66: \n67:         response.raise_for_status()\n68: \n69:         session_id = response.headers.get(self.SESSION_HEADER)\n70: \n71:         if not session_id:\n72:             raise ValueError(f\"Missing required response header: {self.SESSION_HEADER}\")\n73: \n74:         self.logger.info(f\"Bootstrapped session ID: {session_id}\")\n75:         return session_id\n76: \n77:     def invoke(\n78:         self,\n79:         session_id: str,\n80:         payload: dict[str, Any],\n81:         timeout: Optional[float] = None,\n82:     ) -> requests.Response:\n83:         \"\"\"Invoke the Agent Runtime with a payload.\n84: \n85:         Args:\n86:             session_id: Session ID\n87:             payload: JSON payload to send\n88:             timeout: Timeout in seconds (uses instance default if None)\n89: \n90:         Returns:\n91:             Response object\n92: \n93:         Raises:\n94:             requests.RequestException: If the request fails\n95:         \"\"\"\n96:         read_timeout = timeout if timeout is not None else self.timeout\n97: \n98:         self.logger.debug(f\"Invoking agent runtime with session: {session_id}\")\n99: \n100:         response = self.session.post(\n101:             self.base_url,\n102:             json=payload,\n103:             headers={\n104:                 self.SESSION_HEADER: session_id,\n105:                 \"Content-Type\": \"application/json\",\n106:             },\n107:             timeout=(self.connect_timeout, read_timeout),\n108:         )\n109: \n110:         response.raise_for_status()\n111:         return response\n112: \n113:     def close(self) -> None:\n114:         \"\"\"Close the HTTP session.\"\"\"\n115:         self.session.close()\n116:         self.logger.debug(\"Closed agent runtime data plane session\")\n\n(End of file - total 116 lines)\n</content>","metadata":{"preview":"\"\"\"Data plane client for Agent Runtime operations.\"\"\"\n\nfrom typing import Any, Optional\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom ..utils import create_session, get_logger\n\n\nclass AgentRuntimeDataPlaneClient:\n    \"\"\"Client for Agent Runtime data plane operations via Router.\"\"\"\n\n    SESSION_HEADER = \"x-agentcube-session-id\"\n\n    def __init__(\n        self,\n        router_url: str,\n        namespace: str,\n        agent_name: str,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/agentcube/clients/agent_runtime_data_plane.py","time":{"start":1775899746000,"end":1775899746011}}}}
