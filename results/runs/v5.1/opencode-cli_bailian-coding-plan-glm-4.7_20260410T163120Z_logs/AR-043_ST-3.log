{"type":"tool_use","timestamp":1775899766935,"sessionID":"ses_28420c30cffepE7vemUlRXG8Kj","part":{"id":"prt_d7bdfeaab001Kay14YxOXNuArc","messageID":"msg_d7bdfe040001vdJYUXCfywK4oB","sessionID":"ses_28420c30cffepE7vemUlRXG8Kj","type":"tool","tool":"read","callID":"toolu_tool-eb05772f2ca04e88901f4752574354a0","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/providers/k8s_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/providers/k8s_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Refactored Kubernetes provider with unified interface.\"\"\"\n2: \n3: import logging\n4: import time\n5: from typing import Any, Dict, List, Optional\n6: \n7: from agentcube.providers.base import BaseProvider, DeploymentResult, AgentStatus, ProviderStatus\n8: from agentcube.providers.exceptions import ProviderTimeoutError\n9: from agentcube.providers.retry import retry_on_exception\n10: \n11: \n12: try:\n13:     from kubernetes import client\n14:     from kubernetes.client.rest import ApiException\n15:     KUBERNETES_AVAILABLE = True\n16: except ImportError:\n17:     KUBERNETES_AVAILABLE = False\n18:     client = None\n19:     ApiException = Exception\n20: \n21: \n22: logger = logging.getLogger(__name__)\n23: \n24: \n25: class KubernetesProvider(BaseProvider):\n26:     \"\"\"Provider for deploying agents to standard Kubernetes.\"\"\"\n27: \n28:     def __init__(\n29:         self,\n30:         namespace: str = \"default\",\n31:         verbose: bool = False,\n32:         kubeconfig: Optional[str] = None,\n33:         timeout: int = 120,\n34:     ) -> None:\n35:         \"\"\"Initialize the Kubernetes provider.\n36: \n37:         Args:\n38:             namespace: Kubernetes namespace\n39:             verbose: Enable verbose logging\n40:             kubeconfig: Path to kubeconfig file\n41:             timeout: Operation timeout in seconds\n42:         \"\"\"\n43:         super().__init__(namespace, verbose, kubeconfig, timeout)\n44: \n45:         if not KUBERNETES_AVAILABLE:\n46:             raise RuntimeError(\n47:                 \"Kubernetes Python client is not installed. \"\n48:                 \"Install it with: pip install kubernetes\"\n49:             )\n50: \n51:         self._load_kubernetes_config()\n52:         self._core_v1 = client.CoreV1Api()\n53:         self._apps_v1 = client.AppsV1Api()\n54: \n55:     def get_provider_type(self) -> str:\n56:         \"\"\"Get the provider type.\"\"\"\n57:         return \"k8s\"\n58: \n59:     def deploy(\n60:         self,\n61:         agent_name: str,\n62:         image_url: str,\n63:         port: int,\n64:         **kwargs: Any,\n65:     ) -> DeploymentResult:\n66:         \"\"\"Deploy an agent to Kubernetes.\n67: \n68:         Args:\n69:             agent_name: Name of the agent\n70:             image_url: Container image URL\n71:             port: Container port\n72:             **kwargs: Additional parameters (replicas, node_port, env_vars, entrypoint)\n73: \n74:         Returns:\n75:             DeploymentResult: Result of the deployment\n76:         \"\"\"\n77:         try:\n78:             self._ensure_namespace()\n79: \n80:             sanitized_name = self._sanitize_name(agent_name)\n81: \n82:             replicas = kwargs.get(\"replicas\", 1)\n83:             node_port = kwargs.get(\"node_port\")\n84:             env_vars = kwargs.get(\"env_vars\")\n85: \n86:             config_errors = self.validate_config(replicas=replicas, node_port=node_port)\n87:             if config_errors:\n88:                 return DeploymentResult(\n89:                     status=ProviderStatus.ERROR,\n90:                     agent_name=agent_name,\n91:                     namespace=self.namespace,\n92:                     error=f\"Configuration validation failed: {'; '.join(config_errors)}\",\n93:                 )\n94: \n95:             self._create_deployment(\n96:                 sanitized_name, image_url, port, kwargs.get(\"entrypoint\"), replicas, env_vars\n97:             )\n98: \n99:             service = self._create_service(sanitized_name, port, node_port)\n100: \n101:             self._wait_for_ready(sanitized_name, self.timeout)\n102: \n103:             resource_url = f\"http://localhost:{service.spec.ports[0].node_port}\"\n104: \n105:             return DeploymentResult(\n106:                 status=ProviderStatus.RUNNING,\n107:                 agent_name=agent_name,\n108:                 namespace=self.namespace,\n109:                 resource_url=resource_url,\n110:                 metadata={\n111:                     \"deployment_name\": sanitized_name,\n112:                     \"service_name\": sanitized_name,\n113:                     \"replicas\": replicas,\n114:                     \"node_port\": service.spec.ports[0].node_port,\n115:                     \"container_port\": port,\n116:                 },\n117:             )\n118: \n119:         except Exception as e:\n120:             logger.error(f\"Failed to deploy agent {agent_name}: {e}\")\n121:             return DeploymentResult(\n122:                 status=ProviderStatus.FAILED,\n123:                 agent_name=agent_name,\n124:                 namespace=self.namespace,\n125:                 error=str(e),\n126:             )\n127: \n128:     def get_status(self, agent_name: str) -> AgentStatus:\n129:         \"\"\"Get the status of an agent deployment.\n130: \n131:         Args:\n132:             agent_name: Name of the agent\n133: \n134:         Returns:\n135:             AgentStatus: Current status of the agent\n136:         \"\"\"\n137:         sanitized_name = self._sanitize_name(agent_name)\n138: \n139:         try:\n140:             deployment = self._apps_v1.read_namespaced_deployment(\n141:                 sanitized_name, self.namespace\n142:             )\n143: \n144:             return AgentStatus(\n145:                 status=ProviderStatus.RUNNING,\n146:                 agent_name=agent_name,\n147:                 namespace=self.namespace,\n148:                 resource_type=\"Deployment\",\n149:                 replicas=deployment.spec.replicas,\n150:                 ready_replicas=deployment.status.ready_replicas or 0,\n151:                 available_replicas=deployment.status.available_replicas or 0,\n152:             )\n153: \n154:         except ApiException as e:\n155:             if e.status == 404:\n156:                 return AgentStatus(\n157:                     status=ProviderStatus.NOT_FOUND,\n158:                     agent_name=agent_name,\n159:                     namespace=self.namespace,\n160:                 )\n161:             return AgentStatus(\n162:                 status=ProviderStatus.ERROR,\n163:                 agent_name=agent_name,\n164:                 namespace=self.namespace,\n165:                 error=str(e),\n166:             )\n167: \n168:     def delete(self, agent_name: str) -> Dict[str, Any]:\n169:         \"\"\"Delete an agent deployment.\n170: \n171:         Args:\n172:             agent_name: Name of the agent\n173: \n174:         Returns:\n175:             Dict[str, Any]: Result of the deletion\n176:         \"\"\"\n177:         sanitized_name = self._sanitize_name(agent_name)\n178: \n179:         results: Dict[str, Any] = {}\n180: \n181:         try:\n182:             self._apps_v1.delete_namespaced_deployment(sanitized_name, self.namespace)\n183:             results[\"deployment\"] = \"deleted\"\n184:             logger.info(f\"Deleted deployment {sanitized_name}\")\n185:         except ApiException as e:\n186:             if e.status != 404:\n187:                 logger.warning(f\"Failed to delete deployment: {e}\")\n188:                 results[\"deployment\"] = f\"failed: {e}\"\n189: \n190:         try:\n191:             self._core_v1.delete_namespaced_service(sanitized_name, self.namespace)\n192:             results[\"service\"] = \"deleted\"\n193:             logger.info(f\"Deleted service {sanitized_name}\")\n194:         except ApiException as e:\n195:             if e.status != 404:\n196:                 logger.warning(f\"Failed to delete service: {e}\")\n197:                 results[\"service\"] = f\"failed: {e}\"\n198: \n199:         return {\n200:             \"status\": \"deleted\" if \"deployment\" in results and \"service\" in results else \"partial\",\n201:             \"agent_name\": agent_name,\n202:             \"namespace\": self.namespace,\n203:             \"details\": results,\n204:         }\n205: \n206:     def validate_config(self, **kwargs: Any) -> List[str]:\n207:         \"\"\"Validate provider configuration parameters.\n208: \n209:         Args:\n210:             **kwargs: Configuration parameters (replicas, node_port)\n211: \n212:         Returns:\n213:             List[str]: List of error messages (empty if valid)\n214:         \"\"\"\n215:         errors: List[str] = []\n216: \n217:         replicas = kwargs.get(\"replicas\", 1)\n218:         if not isinstance(replicas, int) or replicas < 0:\n219:             errors.append(\"replicas must be a non-negative integer\")\n220: \n221:         node_port = kwargs.get(\"node_port\")\n222:         if node_port is not None:\n223:             if not isinstance(node_port, int) or not (30000 <= node_port <= 32767):\n224:                 errors.append(\"node_port must be between 30000 and 32767\")\n225: \n226:         return errors\n227: \n228:     def _create_deployment(\n229:         self,\n230:         name: str,\n231:         image_url: str,\n232:         port: int,\n233:         entrypoint: Optional[str],\n234:         replicas: int,\n235:         env_vars: Optional[Dict[str, str]],\n236:     ) -> Dict[str, Any]:\n237:         \"\"\"Create a Kubernetes deployment.\n238: \n239:         Args:\n240:             name: Deployment name\n241:             image_url: Container image URL\n242:             port: Container port\n243:             entrypoint: Container entrypoint command\n244:             replicas: Number of replicas\n245:             env_vars: Environment variables\n246: \n247:         Returns:\n248:             Dict[str, Any]: Deployment manifest\n249:         \"\"\"\n250:         env_list = [\n251:             client.V1EnvVar(name=k, value=v) for k, v in (env_vars or {}).items()\n252:         ]\n253: \n254:         container = client.V1Container(\n255:             name=name,\n256:             image=image_url,\n257:             ports=[client.V1ContainerPort(container_port=port)],\n258:             env=env_list,\n259:         )\n260: \n261:         template = client.V1PodTemplateSpec(\n262:             metadata=client.V1ObjectMeta(labels={\"app\": name}),\n263:             spec=client.V1PodSpec(containers=[container]),\n264:         )\n265: \n266:         spec = client.V1DeploymentSpec(\n267:             replicas=replicas,\n268:             template=template,\n269:             selector=client.V1LabelSelector(match_labels={\"app\": name}),\n270:         )\n271: \n272:         deployment = client.V1Deployment(\n273:             api_version=\"apps/v1\",\n274:             kind=\"Deployment\",\n275:             metadata=client.V1ObjectMeta(name=name, namespace=self.namespace),\n276:             spec=spec,\n277:         )\n278: \n279:         try:\n280:             self._apps_v1.create_namespaced_deployment(self.namespace, deployment)\n281:             logger.info(f\"Created deployment {name}\")\n282:         except ApiException as e:\n283:             if e.status == 409:\n284:                 self._apps_v1.replace_namespaced_deployment(name, self.namespace, deployment)\n285:                 logger.info(f\"Updated deployment {name}\")\n286:             else:\n287:                 raise\n288: \n289:         return deployment.to_dict()\n290: \n291:     def _create_service(\n292:         self,\n293:         name: str,\n294:         port: int,\n295:         node_port: Optional[int],\n296:     ) -> client.V1Service:\n297:         \"\"\"Create a Kubernetes NodePort service.\n298: \n299:         Args:\n300:             name: Service name\n301:             port: Service port\n302:             node_port: NodePort value\n303: \n304:         Returns:\n305:             client.V1Service: Created service\n306:         \"\"\"\n307:         service = client.V1Service(\n308:             api_version=\"v1\",\n309:             kind=\"Service\",\n310:             metadata=client.V1ObjectMeta(name=name, namespace=self.namespace),\n311:             spec=client.V1ServiceSpec(\n312:                 type=\"NodePort\",\n313:                 selector={\"app\": name},\n314:                 ports=[\n315:                     client.V1ServicePort(\n316:                         port=port,\n317:                         target_port=port,\n318:                         node_port=node_port,\n319:                     )\n320:                 ],\n321:             ),\n322:         )\n323: \n324:         try:\n325:             created = self._core_v1.create_namespaced_service(self.namespace, service)\n326:             logger.info(f\"Created service {name}\")\n327:         except ApiException as e:\n328:             if e.status == 409:\n329:                 created = self._core_v1.replace_namespaced_service(name, self.namespace, service)\n330:                 logger.info(f\"Updated service {name}\")\n331:             else:\n332:                 raise\n333: \n334:         return created\n335: \n336:     @retry_on_exception(max_attempts=3, delay=2.0, exceptions=(ApiException,))\n337:     def _wait_for_ready(self, name: str, timeout: int) -> None:\n338:         \"\"\"Wait for a deployment to be ready.\n339: \n340:         Args:\n341:             name: Deployment name\n342:             timeout: Timeout in seconds\n343: \n344:         Raises:\n345:             ProviderTimeoutError: If deployment does not become ready\n346:         \"\"\"\n347:         start_time = time.time()\n348: \n349:         while time.time() - start_time < timeout:\n350:             try:\n351:                 deployment = self._apps_v1.read_namespaced_deployment(name, self.namespace)\n352:                 if (\n353:                     deployment.status.ready_replicas is not None\n354:                     and deployment.status.ready_replicas >= deployment.spec.replicas\n355:                 ):\n356:                     logger.info(f\"Deployment {name} is ready\")\n357:                     return\n358:             except ApiException as e:\n359:                 logger.warning(f\"Error checking deployment status: {e}\")\n360: \n361:             time.sleep(2)\n362: \n363:         raise ProviderTimeoutError(\n364:             f\"Deployment {name} did not become ready within {timeout} seconds\"\n365:         )\n\n(End of file - total 365 lines)\n</content>","metadata":{"preview":"\"\"\"Refactored Kubernetes provider with unified interface.\"\"\"\n\nimport logging\nimport time\nfrom typing import Any, Dict, List, Optional\n\nfrom agentcube.providers.base import BaseProvider, DeploymentResult, AgentStatus, ProviderStatus\nfrom agentcube.providers.exceptions import ProviderTimeoutError\nfrom agentcube.providers.retry import retry_on_exception\n\n\ntry:\n    from kubernetes import client\n    from kubernetes.client.rest import ApiException\n    KUBERNETES_AVAILABLE = True\nexcept ImportError:\n    KUBERNETES_AVAILABLE = False\n    client = None\n    ApiException = Exception\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/providers/k8s_provider.py","time":{"start":1775899766916,"end":1775899766933}}}}
