  \"\"\"\n198:         if not self.dp_client:\n199:             raise ValueError(\"Data plane client not initialized\")\n200: \n201:         self.dp_client.upload_file(local_path, remote_path)\n202: \n203:     def download_file(self, remote_path: str, local_path: str) -> None:\n204:         \"\"\"Download a file from the session.\n205: \n206:         Args:\n207:             remote_path: Remote file path\n208:             local_path: Local file path\n209: \n210:         Raises:\n211:             ValueError: If data plane client is not initialized\n212:         \"\"\"\n213:         if not self.dp_client:\n214:             raise ValueError(\"Data plane client not initialized\")\n215: \n216:         self.dp_client.download_file(remote_path, local_path)\n217: \n218:     def list_files(self, path: str = \".\") -> Any:\n219:         \"\"\"List files in the session.\n220: \n221:         Args:\n222:             path: Directory path\n223: \n224:         Returns:\n225:             File listing\n226: \n227:         Raises:\n228:             ValueError: If data plane client is not initialized\n229:         \"\"\"\n230:         if not self.dp_client:\n231:             raise ValueError(\"Data plane client not initialized\")\n232: \n233:         return self.dp_client.list_files(path)\n\n(End of file - total 233 lines)\n</content>","metadata":{"preview":"\"\"\"Code Interpreter client for managing interpreter sessions.\"\"\"\n\nimport os\nfrom typing import Any, Optional\n\nfrom .clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom .clients.control_plane import ControlPlaneClient\nfrom .utils import get_logger\n\n\nclass CodeInterpreterClient:\n    \"\"\"Main client for Code Interpreter session management and operations.\"\"\"\n\n    def __init__(\n        self,\n        name: str = \"my-interpreter\",\n        namespace: str = \"default\",\n        ttl: int = 3600,\n        workload_manager_url: Optional[str] = None,\n        router_url: Optional[str] = No