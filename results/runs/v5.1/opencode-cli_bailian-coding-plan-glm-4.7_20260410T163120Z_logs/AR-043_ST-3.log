)\n35: \n36:         try:\n37:             if metadata.build_mode == \"local\":\n38:                 result = self._build_local(workspace_path, metadata, options)\n39:             else:\n40:                 result = self._build_cloud(workspace_path, metadata, options)\n41: \n42:             self._update_build_metadata(workspace_path, metadata, result)\n43:             return result\n44: \n45:         except Exception as e:\n46:             if original_version != metadata.version:\n47:                 logger.warning(f\"Build failed, reverting version from {metadata.version} to {original_version}\")\n48:                 metadata.version = original_version\n49:                 self.metadata_service.save_metadata(workspace_path, metadata)\n50:             raise\n51: \n52:     def _increment_version(self, workspace_path: Path, metadata: AgentMetadata) -> str:\n53:         \"\"\"Increment the version for the build.\"\"\"\n54:         if metadata.version:\n55:             version_parts = re.match(r\"(\\d+)\\.(\\d+)\\.(\\d+)(?:-(.+))?\", metadata.version)\n56:             if version_parts:\n57:                 major = int(version_parts.group(1))\n58:                 minor = int(version_parts.group(2))\n59:                 patch = int(version_parts.group(3))\n60:                 prerelease = version_parts.group(4)\n61: \n62:                 if prerelease:\n63:                     prerelease_parts = re.match(r\"([^.]+)\\.(\\d+)(?:\\..+)?\", prerelease)\n64:                     if prerelease_parts:\n65:                         prefix = prerelease_parts.group(1)\n66:                         build_num = int(prerelease_parts.group(2)) + 1\n67:                         suffix_match = re.match(r\"[^.]+\\.\\d+\\.(.+)\", prerelease)\n68:                         suffix = f\".{suffix_match.group(1)}\" if suffix_match else \"\"\n69:                         metadata.version = f\"{major}.{minor}.{patch}-{prefix}.{build_num}{suffix}\"\n70:                     else:\n71:                         metadata.version = f\"{major}.{minor}.{patch}-{prerelease}.1\"\n72:                 else:\n73:                     patch += 1\n74:                     metadata.version = f\"{major}.{minor}.{patch}\"\n75:             else:\n76:                 metadata.version = f\"{metadata.version}-1\"\n77:         else:\n78:             metadata.version = \"0.1.0\"\n79: \n80:         self.metadata_service.save_metadata(workspace_path, metadata)\n81:         logger.info(f\"Incremented version to: {metadata.version}\")\n82:         return metadata.version\n83: \n84:     def _validate_build_prerequisites(self, workspace_path: Path) -> None:\n85:         \"\"\"Validate that build prerequisites are met.\"\"\"\n86:         dockerfile_path = workspace_path / \"Dockerfile\"\n87:         if not dockerfile_path.exists():\n88:             raise ValueError(\"Dockerfile not found in workspace. Run 'pack' first.\")\n89: \n90:         if not self.docker_service.check_docker_available():\n91:             raise RuntimeError(\"Docker is not available or not running\")\n92: \n93:     def _build_local(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> Dict[str, Any]:\n94:         \"\"\"Build the image locally using Docker.\"\"\"\n95:         dockerfile_path = workspace_path / \"Dockerfile\"\n96:         image_name = f\"{metadata.agent_name}:{metadata.version or 'latest'}\"\n97: \n98:         build_args: Dict[str, str] = {}\n99:         proxy = options.get(\"proxy\")\n100:         if proxy:\n101:             build_args[\"HTTP_PROXY\"] = proxy\n102:             build_args[\"HTTPS_PROXY\"] = proxy\n103: \n104:         result = self.docker_service.build_image(\n105:             dockerfile_path=dockerfile_path,\n106:             context_path=workspace_path,\n107:             image_name=metadata.agent_name,\n108:             tag=metadata.version or \"latest\",\n109:             build_args=build_args if build_args else None,\n110:         )\n111: \n112:         result[\"image_name\"] = image_name\n113:         return result\n114: \n115:     def _build_cloud(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> Dict[str, Any]:\n116:         \"\"\"Build the image in the cloud.\"\"\"\n117:         cloud_provider = options.get(\"cloud_provider\", \"huawei\")\n118: \n119:         logger.info(f\"Building in cloud with provider: {cloud_provider}\")\n120: \n121:         return {\n122:             \"image_name\": f\"{cloud_provider}/{metadata.agent_name}:{metadata.version or 'latest'}\",\n123:             \"image_id\": \"cloud-build-id\",\n124:             \"image_size\": \"Unknown\",\n125:             \"build_time\": \"cloud-build-time\",\n126:         }\n127: \n128:     def _update_build_metadata(self, workspace_path: Path, metadata: AgentMetadata, build_result: Dict[str, str], tag: str = \"latest\") -> None:\n129:         \"\"\"Update metadata with build information.\"\"\"\n130:         metadata.image = metadata.image or {}\n131:         metadata.image.update(build_result)\n132: \n133:         self.metadata_service.save_metadata(workspace_path, metadata)\n\n(End of file - total 133 lines)\n</content>","metadata":{"preview":"\"\"\"Runtime for the build command.\"\"\"\n\nimport logging\nimport re\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.docker_service import DockerService\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass BuildRuntime:\n    \"\"\"Runtime for building agent images.\"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        \"\"\"Initialize the build runtime.\"\"\"\n        self.verbose = verbose","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/build_runtime.py","time":{"start":1775899766919,"end":1775899766935}}}}
