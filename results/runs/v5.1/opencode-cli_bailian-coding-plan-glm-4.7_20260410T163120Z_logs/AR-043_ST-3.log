      self.base_url = workload_manager_url or os.getenv(\"WORKLOAD_MANAGER_URL\", \"\")\n36:         self.timeout = timeout\n37:         self.connect_timeout = connect_timeout\n38:         self.logger = get_logger(f\"{__name__}.ControlPlaneClient\")\n39:         self.session = create_session(pool_connections=pool_connections, pool_maxsize=pool_maxsize)\n40: \n41:         if not self.base_url:\n42:             self.logger.warning(\"WORKLOAD_MANAGER_URL not set\")\n43: \n44:         token = auth_token or read_token_from_file(\"/var/run/secrets/kubernetes.io/serviceaccount/token\")\n45:         if token:\n46:             self.session.headers.update({\"Authorization\": f\"Bearer {token}\"})\n47:             self.logger.debug(\"Set authorization header from token\")\n48: \n49:     def create_session(\n50:         self,\n51:         name: str = \"my-interpreter\",\n52:         namespace: str = \"default\",\n53:         metadata: Optional[dict[str, object]] = None,\n54:         ttl: int = 3600,\n55:     ) -> str:\n56:         \"\"\"Create a new Code Interpreter session.\n57: \n58:         Args:\n59:             name: Session name\n60:             namespace: Kubernetes namespace\n61:             metadata: Optional metadata dictionary\n62:             ttl: Time-to-live in seconds\n63: \n64:         Returns:\n65:             Session ID\n66: \n67:         Raises:\n68:             ValueError: If base_url is not set or sessionId is missing from response\n69:             requests.RequestException: If the request fails\n70:         \"\"\"\n71:         if not self.base_url:\n72:             raise ValueError(\"Workload Manager URL not configured\")\n73: \n74:         url = f\"{self.base_url}/v1/code-interpreter\"\n75:         body = {\"name\": name, \"namespace\": namespace, \"ttl\": ttl}\n76: \n77:         if metadata is not None:\n78:             body[\"metadata\"] = metadata\n79: \n80:         self.logger.debug(f\"Creating session: {name} in namespace {namespace}\")\n81: \n82:         response = self.session.post(\n83:             url,\n84:             json=body,\n85:             timeout=(self.connect_timeout, self.timeout),\n86:         )\n87:         response.raise_for_status()\n88: \n89:         data = response.json()\n90:         session_id = data.get(\"sessionId\")\n91: \n92:         if not session_id:\n93:             raise ValueError(\"Missing sessionId in response\")\n94: \n95:         self.logger.info(f\"Created session {session_id}\")\n96:         return session_id\n97: \n98:     def delete_session(self, session_id: str) -> bool:\n99:         \"\"\"Delete a Code Interpreter session.\n100: \n101:         Args:\n102:             session_id: Session ID to delete\n103: \n104:         Returns:\n105:             True if deletion succeeded (404 is treated as success), False otherwise\n106:         \"\"\"\n107:         if not self.base_url:\n108:             self.logger.warning(\"Workload Manager URL not configured, cannot delete session\")\n109:             return False\n110: \n111:         url = f\"{self.base_url}/v1/code-interpreter/sessions/{session_id}\"\n112: \n113:         try:\n114:             self.logger.debug(f\"Deleting session {session_id}\")\n115:             response = self.session.delete(\n116:                 url,\n117:                 timeout=(self.connect_timeout, self.timeout),\n118:             )\n119: \n120:             if response.status_code == 404:\n121:                 self.logger.info(f\"Session {session_id} not found (already deleted)\")\n122:                 return True\n123: \n124:             response.raise_for_status()\n125:             self.logger.info(f\"Deleted session {session_id}\")\n126:             return True\n127: \n128:         except requests.RequestException as e:\n129:             self.logger.error(f\"Failed to delete session {session_id}: {e}\")\n130:             return False\n131: \n132:     def close(self) -> None:\n133:         \"\"\"Close the HTTP session.\"\"\"\n134:         self.session.close()\n135:         self.logger.debug(\"Closed control plane session\")\n\n(End of file - total 135 lines)\n</content>","metadata":{"preview":"\"\"\"Control plane client for Workload Manager interactions.\"\"\"\n\nimport os\nfrom typing import Optional\n\nimport requests\n\nfrom ..utils import create_session, get_logger, read_token_from_file\n\n\nclass ControlPlaneClient:\n    \"\"\"Client for Workload Manager control plane operations.\"\"\"\n\n    def __init__(\n        self,\n        workload_manager_url: Optional[str] = None,\n        auth_token: Optional[str] = None,\n        timeout: int = 120,\n        connect_timeout: float = 5.0,\n        pool_connections: int = 10,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/agentcube/clients/control_plane.py","time":{"start":1775899745998,"end":1775899746009}}}}
