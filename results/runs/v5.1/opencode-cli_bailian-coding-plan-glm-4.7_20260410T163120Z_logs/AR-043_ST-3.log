)[0]\n37:             endpoint = (\n38:                 f\"{base_url}/v1/namespaces/{namespace}/agent-runtimes/\"\n39:                 f\"{metadata.agent_name}/invocations/\"\n40:             )\n41: \n42:         headers = headers or {}\n43:         if metadata.session_id:\n44:             headers[\"X-Agentcube-Session-Id\"] = metadata.session_id\n45: \n46:         try:\n47:             result = asyncio.run(self._invoke_agent_via_agentcube(\n48:                 agent_id=metadata.agent_id or metadata.agent_name,\n49:                 payload=payload,\n50:                 headers=headers,\n51:                 endpoint=endpoint,\n52:                 workspace_path=workspace_path,\n53:             ))\n54:             return result\n55:         except Exception:\n56:             if endpoint.startswith(\"http\"):\n57:                 return asyncio.run(self._direct_http_invocation(\n58:                     endpoint=endpoint,\n59:                     payload=payload,\n60:                     headers=headers,\n61:                     workspace_path=workspace_path,\n62:                 ))\n63:             else:\n64:                 return {\"error\": \"Invalid endpoint format\", \"endpoint\": endpoint}\n65: \n66:     def _validate_invoke_prerequisites(self, workspace_path: Path) -> tuple:\n67:         \"\"\"Validate that invocation prerequisites are met.\"\"\"\n68:         from agentcube.services.metadata_service import MetadataService\n69: \n70:         metadata_service = MetadataService(verbose=self.verbose)\n71:         metadata = metadata_service.load_metadata(workspace_path)\n72: \n73:         if not metadata.agent_id and not metadata.agent_endpoint:\n74:             raise ValueError(\n75:                 \"Agent has not been published. Please run 'agentcube publish' first.\"\n76:             )\n77: \n78:         endpoint = metadata.agent_endpoint or (\n79:             metadata.k8s_deployment.get(\"service_url\") if metadata.k8s_deployment else None\n80:         )\n81: \n82:         if not endpoint:\n83:             raise ValueError(\"No endpoint found in metadata. Please publish the agent first.\")\n84: \n85:         namespace = (\n86:             metadata.k8s_deployment.get(\"namespace\") if metadata.k8s_deployment else \"default\"\n87:         )\n88: \n89:         return metadata, endpoint, namespace\n90: \n91:     async def _invoke_agent_via_agentcube(\n92:         self,\n93:         agent_id: str,\n94:         payload: Dict[str, Any],\n95:         headers: Optional[Dict[str, str]],\n96:         endpoint: str,\n97:         workspace_path: Path,\n98:     ) -> Any:\n99:         \"\"\"Invoke agent via AgentCube provider.\"\"\"\n100:         if endpoint.startswith(\"http\"):\n101:             async with httpx.AsyncClient(timeout=60.0) as client:\n102:                 response = await client.post(\n103:                     endpoint,\n104:                     json=payload,\n105:                     headers=headers,\n106:                 )\n107:                 response.raise_for_status()\n108:                 return response.json()\n109:         return {\"error\": \"Invalid endpoint format\", \"endpoint\": endpoint}\n110: \n111:     async def _direct_http_invocation(\n112:         self,\n113:         endpoint: str,\n114:         payload: Dict[str, Any],\n115:         headers: Optional[Dict[str, str]],\n116:         workspace_path: Path,\n117:     ) -> Dict[str, Any]:\n118:         \"\"\"Invoke agent via direct HTTP.\"\"\"\n119:         async with httpx.AsyncClient(timeout=60.0) as client:\n120:             response = await client.post(\n121:                 endpoint,\n122:                 json=payload,\n123:                 headers=headers,\n124:             )\n125:             response.raise_for_status()\n126:             return response.json()\n\n(End of file - total 126 lines)\n</content>","metadata":{"preview":"\"\"\"Runtime for the invoke command.\"\"\"\n\nimport asyncio\nimport logging\nfrom pathlib import Path\nfrom typing imp