        decode=True\n376:                 )\n377: \n378:     def test_push_image_with_authentication(self, docker_service):\n379:         \"\"\"Test pushing image with authentication.\"\"\"\n380:         mock_client = MagicMock()\n381:         mock_images = MagicMock()\n382: \n383:         push_logs = [\n384:             {\"status\": \"Pushing\"},\n385:             {\"status\": \"Pushed\"},\n386:         ]\n387:         mock_images.push.return_value = push_logs\n388:         mock_client.images = mock_images\n389: \n390:         docker_service._client = mock_client\n391: \n392:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n393:             with patch.object(docker_service, \"_docker_login_sdk\") as mock_login:\n394:                 result = docker_service.push_image(\n395:                     \"test:1.0.0\",\n396:                     registry_url=\"registry.example.com\",\n397:                     username=\"user\",\n398:                     password=\"pass\"\n399:                 )\n400: \n401:                 assert \"pushed_image\" in result\n402:                 mock_login.assert_called_once_with(\"registry.example.com\", \"user\", \"pass\")\n403: \n404:     def test_push_image_failure(self, docker_service):\n405:         \"\"\"Test pushing image when push fails.\"\"\"\n406:         mock_client = MagicMock()\n407:         mock_images = MagicMock()\n408: \n409:         push_logs = [\n410:             {\"error\": \"Authentication failed\"},\n411:         ]\n412:         mock_images.push.return_value = push_logs\n413:         mock_client.images = mock_images\n414: \n415:         docker_service._client = mock_client\n416: \n417:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n418:             with pytest.raises(RuntimeError, match=\"Failed to push image\"):\n419:                 docker_service.push_image(\"test:1.0.0\")\n420: \n421:     def test_push_image_docker_unavailable(self, docker_service):\n422:         \"\"\"Test pushing image when Docker is unavailable.\"\"\"\n423:         with patch.object(docker_service, \"check_docker_available\", return_value=False):\n424:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n425:                 docker_service.push_image(\"test:1.0.0\")\n426: \n427:     def test_docker_login_success(self, docker_service):\n428:         \"\"\"Test successful Docker registry login.\"\"\"\n429:         mock_client = MagicMock()\n430:         mock_client.login.return_value = {}\n431:         docker_service._client = mock_client\n432: \n433:         docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n434: \n435:         mock_client.login.assert_called_once_with(\n436:             username=\"user\",\n437:             password=\"pass\",\n438:             registry=\"registry.example.com\"\n439:         )\n440: \n441:     def test_docker_login_default_registry(self, docker_service):\n442:         \"\"\"Test Docker login to default registry.\"\"\"\n443:         mock_client = MagicMock()\n444:         mock_client.login.return_value = {}\n445:         docker_service._client = mock_client\n446: \n447:         docker_service._docker_login_sdk(None, \"user\", \"pass\")\n448: \n449:         mock_client.login.assert_called_once_with(\n450:             username=\"user\",\n451:             password=\"pass\",\n452:             registry=None\n453:         )\n454: \n455:     def test_docker_login_failure(self, docker_service):\n456:         \"\"\"Test Docker login failure.\"\"\"\n457:         mock_client = MagicMock()\n458:         mock_client.login.side_effect = DockerException(\"Authentication failed\")\n459:         docker_service._client = mock_client\n460: \n461:         with pytest.raises(RuntimeError, match=\"Failed to log in to Docker registry\"):\n462:             docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n463: \n464:     def test_tag_image_success(self, docker_service):\n465:         \"\"\"Test successful image tagging.\"\"\"\n466:         mock_client = MagicMock()\n467:         mock_images = MagicMock()\n468:         mock_image = MagicMock()\n469:         mock_images.get.return_value = mock_image\n470:         mock_client.images = mock_images\n471: \n472:         docker_service._client = mock_client\n473: \n474:         docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n475: \n476:         mock_images.get.assert_called_once_with(\"test:1.0.0\")\n477:         mock_image.tag.assert_called_once_with(\"registry.example.com/test:1.0.0\", force=True)\n478: \n479:     def test_tag_image_failure(self, docker_service):\n480:         \"\"\"Test image tagging failure.\"\"\"\n481:         mock_client = MagicMock()\n482:         mock_images = MagicMock()\n483:         mock_images.get.side_effect = DockerException(\"Image not found\")\n484:         mock_client.images = mock_images\n485: \n486:         docker_service._client = mock_client\n487: \n488:         with pytest.raises(RuntimeError, match=\"Failed to tag Docker image\"):\n489:             docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n490: \n491:     def test_remove_image_success(self, docker_service):\n492:         \"\"\"Test successful image removal.\"\"\"\n493:         mock_client = MagicMock()\n494:         mock_images = MagicMock()\n495:         mock_images.remove.return_value = None\n496:         mock_client.images = mock_images\n497: \n498:         docker_service._client = mock_client\n499: \n500:         result = docker_service.remove_image(\"test:1.0.0\")\n501: \n502:         assert result is True\n503:         mock_images.remove.assert_called_once_with(\"test:1.0.0\", force=True)\n504: \n505:     def test_remove_image_failure(self, docker_service):\n506:         \"\"\"Test image removal failure.\"\"\"\n507:         mock_client = MagicMock()\n508:         mock_images =