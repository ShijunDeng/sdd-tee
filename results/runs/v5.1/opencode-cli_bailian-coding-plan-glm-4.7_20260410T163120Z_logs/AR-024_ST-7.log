{"type":"tool_use","timestamp":1775871621739,"sessionID":"ses_285cdb4ddffem8xdXe9Ez0Bk8K","part":{"id":"prt_d7a327a3b001eEP7F2JgF4037X","messageID":"msg_d7a325eb5001NuNT00FZ17ad27","sessionID":"ses_285cdb4ddffem8xdXe9Ez0Bk8K","type":"tool","tool":"read","callID":"toolu_tool-612ae0312431444f972128ab29b77f33","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for the Docker service.\"\"\"\n2: \n3: import pytest\n4: import time\n5: from pathlib import Path\n6: from unittest.mock import MagicMock, patch, PropertyMock\n7: from docker.errors import DockerException\n8: \n9: from agentcube.services.docker_service import DockerService\n10: \n11: \n12: class TestDockerService:\n13:     \"\"\"Test cases for DockerService.\"\"\"\n14: \n15:     @pytest.fixture\n16:     def mock_docker_client(self):\n17:         \"\"\"Create a mock Docker client.\"\"\"\n18:         client = MagicMock()\n19:         client.ping.return_value = True\n20:         return client\n21: \n22:     @pytest.fixture\n23:     def mock_docker_image(self):\n24:         \"\"\"Create a mock Docker image.\"\"\"\n25:         image = MagicMock()\n26:         image.attrs = {\n27:             \"Id\": \"sha256:abc123def4567890123456789012345678901234567890123456789012345678\",\n28:             \"Size\": 536870912,\n29:         }\n30:         return image\n31: \n32:     @pytest.fixture\n33:     def docker_service(self):\n34:         \"\"\"Create a DockerService instance.\"\"\"\n35:         return DockerService(verbose=False)\n36: \n37:     def test_check_docker_available_success(self, docker_service):\n38:         \"\"\"Test Docker availability check when available.\"\"\"\n39:         mock_client = MagicMock()\n40:         mock_client.ping.return_value = True\n41:         docker_service._client = mock_client\n42: \n43:         result = docker_service.check_docker_available()\n44: \n45:         assert result is True\n46:         mock_client.ping.assert_called_once()\n47: \n48:     def test_check_docker_available_failure(self, docker_service):\n49:         \"\"\"Test Docker availability check when unavailable.\"\"\"\n50:         mock_client = MagicMock()\n51:         mock_client.ping.side_effect = DockerException(\"Docker daemon not running\")\n52:         docker_service._client = mock_client\n53: \n54:         result = docker_service.check_docker_available()\n55: \n56:         assert result is False\n57: \n58:     def test_build_image_success(self, docker_service, mock_docker_image, tmp_path):\n59:         \"\"\"Test successful image build.\"\"\"\n60:         dockerfile_path = tmp_path / \"Dockerfile\"\n61:         dockerfile_path.write_text(\"FROM python:3.10\")\n62: \n63:         mock_client = MagicMock()\n64:         mock_images = MagicMock()\n65:         mock_images.build.return_value = (mock_docker_image, [])\n66:         mock_client.images = mock_images\n67: \n68:         docker_service._client = mock_client\n69: \n70:         with patch.object(docker_service, \"get_image_info\", return_value={\n71:             \"image_name\": \"test:1.0.0\",\n72:             \"image_id\": \"abc123def456\",\n73:             \"image_size\": \"512.34 MB\",\n74:             \"size_bytes\": 536870912,\n75:         }):\n76:             result = docker_service.build_image(\n77:                 dockerfile_path=dockerfile_path,\n78:                 context_path=tmp_path,\n79:                 image_name=\"test\",\n80:                 tag=\"1.0.0\"\n81:             )\n82: \n83:             assert result[\"image_name\"] == \"test:1.0.0\"\n84:             assert result[\"image_id\"] == \"abc123def456\"\n85:             assert result[\"image_size\"] == \"512.34 MB\"\n86:             mock_images.build.assert_called_once()\n87: \n88:     def test_build_image_with_custom_tag(self, docker_service, mock_docker_image, tmp_path):\n89:         \"\"\"Test building image with custom tag.\"\"\"\n90:         dockerfile_path = tmp_path / \"Dockerfile\"\n91:         dockerfile_path.write_text(\"FROM python:3.10\")\n92: \n93:         mock_client = MagicMock()\n94:         mock_images = MagicMock()\n95:         mock_images.build.return_value = (mock_docker_image, [])\n96:         mock_client.images = mock_images\n97: \n98:         docker_service._client = mock_client\n99: \n100:         with patch.object(docker_service, \"get_image_info\", return_value={\n101:             \"image_name\": \"test:v1.0.0\",\n102:             \"image_id\": \"abc123def456\",\n103:             \"image_size\": \"512.34 MB\",\n104:             \"size_bytes\": 536870912,\n105:         }):\n106:             result = docker_service.build_image(\n107:                 dockerfile_path=dockerfile_path,\n108:                 context_path=tmp_path,\n109:                 image_name=\"test\",\n110:                 tag=\"v1.0.0\"\n111:             )\n112: \n113:             assert result[\"image_name\"] == \"test:v1.0.0\"\n114:             call_args = mock_images.build.call_args\n115:             assert call_args.kwargs[\"tag\"] == \"test:v1.0.0\"\n116: \n117:     def test_build_image_with_build_args(self, docker_service, mock_docker_image, tmp_path):\n118:         \"\"\"Test building image with build arguments.\"\"\"\n119:         dockerfile_path = tmp_path / \"Dockerfile\"\n120:         dockerfile_path.write_text(\"FROM python:3.10\")\n121: \n122:         mock_client = MagicMock()\n123:         mock_images = MagicMock()\n124:         mock_images.build.return_value = (mock_docker_image, [])\n125:         mock_client.images = mock_images\n126: \n127:         docker_service._client = mock_client\n128: \n129:         with patch.object(docker_service, \"get_image_info\", return_value={\n130:             \"image_name\": \"test:1.0.0\",\n131:             \"image_id\": \"abc123def456\",\n132:             \"image_size\": \"512.34 MB\",\n133:             \"size_bytes\": 536870912,\n134:         }):\n135:             build_args = {\n136:                 \"HTTP_PROXY\": \"http://proxy.example.com:8080\",\n137:                 \"HTTPS_PROXY\": \"http://proxy.example.com:8080\"\n138:             }\n139: \n140:             result = docker_service.build_image(\n141:                 dockerfile_path=dockerfile_path,\n142:                 context_path=tmp_path,\n143:                 image_name=\"test\",\n144:                 tag=\"1.0.0\",\n145:                 build_args=build_args\n146:             )\n147: \n148:             assert result[\"image_name\"] == \"test:1.0.0\"\n149:             call_args = mock_images.build.call_args\n150:             assert call_args.kwargs[\"buildargs\"] == build_args\n151: \n152:     def test_build_image_docker_unavailable(self, docker_service, tmp_path):\n153:         \"\"\"Test building image when Docker is unavailable.\"\"\"\n154:         dockerfile_path = tmp_path / \"Dockerfile\"\n155:         dockerfile_path.write_text(\"FROM python:3.10\")\n156: \n157:         with patch.object(docker_service, \"check_docker_available\", return_value=False):\n158:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n159:                 docker_service.build_image(\n160:                     dockerfile_path=dockerfile_path,\n161:                     context_path=tmp_path,\n162:                     image_name=\"test\"\n163:                 )\n164: \n165:     def test_build_image_docker_exception(self, docker_service, tmp_path):\n166:         \"\"\"Test building image when Docker build fails.\"\"\"\n167:         dockerfile_path = tmp_path / \"Dockerfile\"\n168:         dockerfile_path.write_text(\"FROM python:3.10\")\n169: \n170:         mock_client = MagicMock()\n171:         mock_images = MagicMock()\n172:         mock_images.build.side_effect = DockerException(\"Build failed\")\n173:         mock_client.images = mock_images\n174: \n175:         docker_service._client = mock_client\n176: \n177:         with pytest.raises(RuntimeError, match=\"Failed to build Docker image\"):\n178:             docker_service.build_image(\n179:                 dockerfile_path=dockerfile_path,\n180:                 context_path=tmp_path,\n181:                 image_name=\"test\"\n182:             )\n183: \n184:     def test_build_image_invalid_dockerfile_path(self, docker_service, tmp_path):\n185:         \"\"\"Test building image with non-existent Dockerfile.\"\"\"\n186:         non_existent_path = tmp_path / \"nonexistent\" / \"Dockerfile\"\n187: \n188:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n189:             with pytest.raises(FileNotFoundError, match=\"Dockerfile not found\"):\n190:                 docker_service.build_image(\n191:                     dockerfile_path=non_existent_path,\n192:                     context_path=tmp_path,\n193:                     image_name=\"test\"\n194:                 )\n195: \n196:     def test_build_image_invalid_context_path(self, docker_service, tmp_path):\n197:         \"\"\"Test building image with non-existent context path.\"\"\"\n198:         dockerfile_path = tmp_path / \"Dockerfile\"\n199:         dockerfile_path.write_text(\"FROM python:3.10\")\n200:         non_existent_context = tmp_path / \"nonexistent\"\n201: \n202:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n203:             with pytest.raises(FileNotFoundError, match=\"Build context not found\"):\n204:                 docker_service.build_image(\n205:                     dockerfile_path=dockerfile_path,\n206:                     context_path=non_existent_context,\n207:                     image_name=\"test\"\n208:                 )\n209: \n210:     def test_build_image_dockerfile_is_directory(self, docker_service, tmp_path):\n211:         \"\"\"Test building image when Dockerfile path is a directory.\"\"\"\n212:         dockerfile_path = tmp_path / \"Dockerfile\"\n213:         dockerfile_path.mkdir()\n214: \n215:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n216:             with pytest.raises(ValueError, match=\"Dockerfile path is not a file\"):\n217:                 docker_service.build_image(\n218:                     dockerfile_path=dockerfile_path,\n219:                     context_path=tmp_path,\n220:                     image_name=\"test\"\n221:                 )\n222: \n223:     def test_build_image_context_is_file(self, docker_service, tmp_path):\n224:         \"\"\"Test building image when context path is a file.\"\"\"\n225:         dockerfile_path = tmp_path / \"Dockerfile\"\n226:         dockerfile_path.write_text(\"FROM python:3.10\")\n227:         context_path = tmp_path / \"file.txt\"\n228:         context_path.write_text(\"content\")\n229: \n230:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n231:             with pytest.raises(ValueError, match=\"Build context path is not a directory\"):\n232:                 docker_service.build_image(\n233:                     dockerfile_path=dockerfile_path,\n234:                     context_path=context_path,\n235:                     image_name=\"test\"\n236:                 )\n237: \n238:     def test_build_image_invalid_image_name(self, docker_service, tmp_path):\n239:         \"\"\"Test building image with invalid image name.\"\"\"\n240:         dockerfile_path = tmp_path / \"Dockerfile\"\n241:         dockerfile_path.write_text(\"FROM python:3.10\")\n242: \n243:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n244:             with pytest.raises(ValueError, match=\"Invalid image_name\"):\n245:                 docker_service.build_image(\n246:                     dockerfile_path=dockerfile_path,\n247:                     context_path=tmp_path,\n248:                     image_name=\"\"\n249:                 )\n250: \n251:     def test_get_image_info_success(self, docker_service, mock_docker_image):\n252:         \"\"\"Test getting image info successfully.\"\"\"\n253:         mock_client = MagicMock()\n254:         mock_images = MagicMock()\n255:         mock_images.get.return_value = mock_docker_image\n256:         mock_client.images = mock_images\n257: \n258:         docker_service._client = mock_client\n259: \n260:         result = docker_service.get_image_info(\"test:1.0.0\")\n261: \n262:         assert result[\"image_name\"] == \"test:1.0.0\"\n263:         assert result[\"image_id\"] == \"abc123def456\"\n264:         assert result[\"size_bytes\"] == 536870912\n265:         assert result[\"image_size\"] == \"512.00 MB\"\n266: \n267:     def test_get_image_info_not_found(self, docker_service):\n268:         \"\"\"Test getting image info when image not found.\"\"\"\n269:         mock_client = MagicMock()\n270:         mock_images = MagicMock()\n271:         mock_images.get.side_effect = DockerException(\"Image not found\")\n272:         mock_client.images = mock_images\n273: \n274:         docker_service._client = mock_client\n275: \n276:         result = docker_service.get_image_info(\"test:1.0.0\")\n277: \n278:         assert result == {}\n279: \n280:     def test_format_size_bytes(self, docker_service):\n281:         \"\"\"Test formatting size in bytes.\"\"\"\n282:         result = docker_service._format_size(512)\n283:         assert result == \"512.00 B\"\n284: \n285:     def test_format_size_kb(self, docker_service):\n286:         \"\"\"Test formatting size in kilobytes.\"\"\"\n287:         result = docker_service._format_size(2048)\n288:         assert result == \"2.00 KB\"\n289: \n290:     def test_format_size_mb(self, docker_service):\n291:         \"\"\"Test formatting size in megabytes.\"\"\"\n292:         result = docker_service._format_size(1048576)\n293:         assert result == \"1.00 MB\"\n294: \n295:     def test_format_size_gb(self, docker_service):\n296:         \"\"\"Test formatting size in gigabytes.\"\"\"\n297:         result = docker_service._format_size(1073741824)\n298:         assert result == \"1.00 GB\"\n299: \n300:     def test_format_size_tb(self, docker_service):\n301:         \"\"\"Test formatting size in terabytes.\"\"\"\n302:         result = docker_service._format_size(1099511627776)\n303:         assert result == \"1.00 TB\"\n304: \n305:     def test_format_size_zero(self, docker_service):\n306:         \"\"\"Test formatting zero size.\"\"\"\n307:         result = docker_service._format_size(0)\n308:         assert result == \"0.00 B\"\n309: \n310:     def test_format_size_small_values(self, docker_service):\n311:         \"\"\"Test formatting small byte values.\"\"\"\n312:         assert docker_service._format_size(1) == \"1.00 B\"\n313:         assert docker_service._format_size(100) == \"100.00 B\"\n314:         assert docker_service._format_size(999) == \"999.00 B\"\n315: \n316:     def test_format_size_boundary_values(self, docker_service):\n317:         \"\"\"Test formatting size at unit boundaries.\"\"\"\n318:         assert docker_service._format_size(1023) == \"1023.00 B\"\n319:         assert docker_service._format_size(1024) == \"1.00 KB\"\n320:         assert docker_service._format_size(1048575) == \"1024.00 KB\"\n321:         assert docker_service._format_size(1048576) == \"1.00 MB\"\n322:         assert docker_service._format_size(1073741823) == \"1024.00 MB\"\n323:         assert docker_service._format_size(1073741824) == \"1.00 GB\"\n324: \n325:     def test_push_image_to_default_registry(self, docker_service):\n326:         \"\"\"Test pushing image to default registry.\"\"\"\n327:         mock_client = MagicMock()\n328:         mock_images = MagicMock()\n329: \n330:         push_logs = [\n331:             {\"status\": \"Pushing\"},\n332:        