toreClient == nil {\n40: \t\treturn nil, fmt.Errorf(\"store client is required\")\n41: \t}\n42: \n43: \tif workloadMgrAddr == \"\" {\n44: \t\treturn nil, fmt.Errorf(\"workload manager address is required\")\n45: \t}\n46: \n47: \treturn &manager{\n48: \t\tstoreClient:     storeClient,\n49: \t\tworkloadMgrAddr: workloadMgrAddr,\n50: \t\thttpClient:      &http.Client{Timeout: 30 * time.Second},\n51: \t\tresourceCache:   NewResourceCache(),\n52: \t}, nil\n53: }\n54: \n55: func (m *manager) InitializeInformers(clientset kubernetes.Interface, namespace string, resyncPeriod time.Duration) error {\n56: \tif clientset == nil {\n57: \t\tklog.Info(\"Kubernetes clientset not provided, informers not initialized\")\n58: \t\treturn nil\n59: \t}\n60: \n61: \tinformerManager, err := NewInformerManager(clientset, namespace, resyncPeriod)\n62: \tif err != nil {\n63: \t\treturn fmt.Errorf(\"failed to create informer manager: %w\", err)\n64: \t}\n65: \n66: \tm.informerManager = informerManager\n67: \tm.resourceCache = informerManager.GetResourceCache()\n68: \n69: \tklog.Infof(\"Informers initialized for namespace: %s\", namespace)\n70: \treturn nil\n71: }\n72: \n73: func (m *manager) StartInformers() {\n74: \tif m.informerManager != nil {\n75: \t\tm.informerManager.Start()\n76: \t}\n77: }\n78: \n79: func (m *manager) StopInformers() {\n80: \tif m.informerManager != nil {\n81: \t\tm.informerManager.Stop()\n82: \t}\n83: }\n84: \n85: func (m *manager) WaitForCacheSync(ctx context.Context) bool {\n86: \tif m.informerManager == nil {\n87: \t\treturn true\n88: \t}\n89: \n90: \treturn m.informerManager.WaitForCacheSync(ctx.Done())\n91: }\n92: \n93: func (m *manager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n94: \tsandboxInfo, err := m.storeClient.GetSandboxBySessionID(ctx, sessionID)\n95: \tif err == nil {\n96: \t\tklog.V(4).Infof(\"Cache hit for session: %s\", sessionID)\n97: \n98: \t\tif m.isResourceActive(namespace, name, kind) {\n99: \t\t\treturn sandboxInfo, nil\n100: \t\t}\n101: \n102: \t\tklog.V(4).Infof(\"Resource not active, removing from cache: %s\", sessionID)\n103: \t\tm.storeClient.DeleteSandboxBySessionID(ctx, sessionID)\n104: \n105: \t\tklog.V(4).Infof(\"Cache miss for session: %s, querying workload manager\", sessionID)\n106: \t\treturn m.getSandboxFromWorkloadManager(ctx, sessionID)\n107: \t}\n108: \n109: \tif err != store.ErrNotFound {\n110: \t\tklog.Warningf(\"Failed to get sandbox from store: %v\", err)\n111: \t}\n112: \n113: \tklog.V(4).Infof(\"Cache miss for session: %s, querying workload manager\", sessionID)\n114: \treturn m.getSandboxFromWorkloadManager(ctx, sessionID)\n115: }\n116: \n117: func (m *manager) CreateSession(ctx context.Context, name string, namespace string, kind string) (string, *types.SandboxInfo, error) {\n118: \tif err := validateKind(kind); err != nil {\n119: \t\treturn \"\", nil, err\n120: \t}\n121: \n122: \tif !isValidNamespace(namespace) {\n123: \t\treturn \"\", nil, &ValidationError{Field: \"namespace\", Message: \"invalid namespace format\"}\n124: \t}\n125: \n126: \tif !isValidResourceName(name) {\n127: \t\treturn \"\", nil, &ValidationError{Field: \"name\", Message: \"invalid resource name format\"}\n128: \t}\n129: \n130: \tcreateReq := &WorkloadManagerCreateRequest{\n131: \t\tKind:      kind,\n132: \t\tName:      name,\n133: \t\tNamespace: namespace,\n134: \t}\n135: \n136: \treqBody, err := json.Marshal(createReq)\n137: \tif err != nil {\n138: \t\treturn \"\", nil, fmt.Errorf(\"failed to marshal create request: %w\", err)\n139: \t}\n140: \n141: \tvar endpoint string\n142: \tif kind == types.AgentRuntimeKind {\n143: \t\tendpoint = fmt.Sprintf(\"%s/v1/agent-runtime\", m.workloadMgrAddr)\n144: \t} else {\n145: \t\tendpoint = fmt.Sprintf(\"%s/v1/code-interpreter\", m.workloadMgrAddr)\n146: \t}\n147: \n148: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(reqBody))\n149: \tif err != nil {\n150: \t\treturn \"\", nil, fmt.Errorf(\"failed to create request: %w\", err)\n151: \t}\n152: \n153: \treq.Header.Set(\"Content-Type\", \"application/json\")\n154: \n155: \tresp, err := m.httpClient.Do(req)\n156: \tif err != nil {\n157: \t\treturn \"\", nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusServiceUnavailable}\n158: \t}\n159: \tdefer resp.Body.Close()\n160: \n161: \tbody, err := io.ReadAll(resp.Body)\n162: \tif err != nil {\n163: \t\treturn \"\", nil, fmt.Errorf(\"failed to read response body: %w\", err)\n164: \t}\n165: \n166: \tif resp.StatusCode != http.StatusOK {\n167: \t\treturn \"\", nil, &WorkloadManagerError{\n168: \t\t\tMessage: string(body),\n169: \t\t\tCode:    resp.StatusCode,\n170: \t\t}\n171: \t}\n172: \n173: \tvar createResp WorkloadManagerCreateResponse\n174: \tif err := json.Unmarshal(body, &createResp); err != nil {\n175: \t\treturn \"\", nil, fmt.Errorf(\"failed to unmarshal create response: %w\", err)\n176: \t}\n177: \n178: \tsessionID := createResp.SessionID\n179: \n180: \tgetSandboxResp, err := m.getSandboxFromWorkloadManager(ctx, sessionID)\n181: \tif err != nil {\n182: \t\treturn \"\", nil, fmt.Errorf(\"created session but failed to get sandbox info: %w\", err)\n183: \t}\n184: \n185: \treturn sessionID, getSandboxResp, nil\n186: }\n187: \n188: func (m *manager) ListSessions(ctx context.Context) ([]*types.SandboxInfo, error) {\n189: \tbefore := time.Now()\n190: \tsandboxes, err := m.storeClient.ListExpiredSandboxes(ctx, before, 1000)\n191: \tif err != nil {\n192: \t\treturn nil, fmt.Errorf(\"failed to list sessions from store: %w\", err)\n193: \t}\n194: \n195: \tresult := make([]*types.SandboxInfo, 0, len(sandboxes))\n196: \tfor _, sandbox := range sandboxes {\n197: \t\tresult = append(result, sandbox)\n198: \t}\n199: \n200: \treturn result, nil\n201: }\n202: \n203: func (m *manager) getSandboxFromWorkloadManager(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n204: \tendpoint := fmt.Sprintf(\"%s/v1/session/%s\", m.workloadMgrAddr, sessionID)\n205: \n206: \treq, err := http.NewRequestWithContext(ctx, http.MethodGet, endpoint, nil)\n207: \tif err != nil {\n208: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n209: \t}\n210: \n211: \tresp, err := m.httpClient.Do(req)\n212: \tif err != nil {\n213: \t\treturn nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusServiceUnavailable}\n214: \t}\n215: \tdefer resp.Body.Close()\n216: \n217: \tbody, err := io.ReadAll(resp.Body)\n218: \tif err != nil {\n219: \t\treturn nil, fmt.Errorf(\"failed to read response body: %w\", err)\n220: \t}\n221: \n222: \tif resp.StatusCode == http.StatusNotFound {\n223: \t\treturn nil, &SandboxNotFoundError{SessionID: sessionID}\n224: \t}\n225: \n226: \tif resp.StatusCode != http.StatusOK {\n227: \t\treturn nil, &WorkloadManagerError{\n228: \t\t\tMessage: string(body),\n229: \t\t\tCode:    resp.StatusCode,\n230: \t\t}\n231: \t}\n232: \n233: \tvar getSessionResp WorkloadManagerGetSessionResponse\n234: \tif err := json.Unmarshal(body, &getSessionResp); err != nil {\n235: \t\treturn nil, fmt.Errorf(\"failed to unmarshal get session response: %w\", err)\n236: \t}\n237: \n238: \tsandboxInfo := SandboxInfoFromWorkloadManager(&getSessionResp, sessionID)\n239: \n240: \tif err := m.storeClient.StoreSandbox(ctx, sandboxInfo); err != nil {\n241: \t\tklog.Warningf(\"Failed to cache sandbox info: %v\", err)\n242: \t}\n243: \n244: \treturn sandboxInfo, nil\n245: }\n246: \n247: func (m *manager) isResourceActive(namespace string, name string, kind string) bool {\n248: \tif m.resourceCache == nil {\n249: \t\treturn true\n250: \t}\n251: \n252: \tif kind == types.AgentRuntimeKind {\n253: \t\tar, err := m.resourceCache.GetAgentRuntime(namespace, name)\n254: \t\tif err != nil || ar == nil {\n255: \t\t\treturn true\n256: \t\t}\n257: \n258: \t\tif !isResourceReady(ar.Status.Conditions) {\n259: \t\t\treturn false\n260: \t\t}\n261: \n262: \t\tif isResourceBeingDeleted(ar) {\n263: \t\t\treturn false\n264: \t\t}\n265: \n266: \t\treturn true\n267: \t} else if kind == types.CodeInterpreterKind {\n268: \t\tci, err := m.resourceCache.GetCodeInterpreter(namespace, name)\n269: \t\tif err != nil || ci == nil {\n270: \t\t\treturn true\n271: \t\t}\n272: \n273: \t\tif !ci.Status.Ready {\n274: \t\t\treturn false\n275: \t\t}\n276: \n277: \t\tif isResourceBeingDeleted(ci) {\n278: \t\t\treturn false\n279: \t\t}\n280: \n281: \t\treturn true\n282: \t}\n283: \n284: \treturn true\n285: }\n286: \n287: func isResourceReady(conditions []metav1.Condition) bool {\n288: \tif len(conditions) == 0 {\n289: \t\treturn false\n290: \t}\n291: \n292: \tfor _, cond := range conditions {\n293: \t\tif cond.Type == \"Ready\" && cond.Status == metav1.ConditionTrue {\n294: \t\t\treturn true\n295: \t\t}\n296: \t}\n297: \n298: \treturn false\n299: }\n300: \n301: func isResourceBeingDeleted(obj metav1.Object) bool {\n302: \treturn !obj.GetDeletionTimestamp().IsZero()\n303: }\n304: \n305: func conditionsChanged(oldConditions, newConditions []metav1.Condition) bool {\n306: \tif len(oldConditions) != len(newConditions) {\n307: \t\treturn true\n308: \t}\n309: \n310: \tfor i := range oldConditions {\n311: \t\tif oldConditions[i].Type != newConditions[i].Type ||\n312: \t\t\toldConditions[i].Status != newConditions[i].Status ||\n313: \t\t\toldConditions[i].Reason != newConditions[i].Reason {\n314: \t\t\treturn true\n315: \t\t}\n316: \t}\n317: \n318: \treturn false\n319: }\n320: \n321: func GetResourceStatus(conditions []metav1.Condition) string {\n322: \tif len(conditions) == 0 {\n323: \t\treturn \"Unknown\"\n324: \t}\n325: \n326: \tfor _, cond := range conditions {\n327: \t\tif cond.Type == \"Ready\" {\n328: \t\t\tif cond.Status == metav1.ConditionTrue {\n329: \t\t\t\treturn \"Ready\"\n330: \t\t\t}\n331: \t\t\treturn cond.Reason\n332: \t\t}\n333: \t}\n334: \n335: \treturn conditions[0].Type\n336: }\n\n(End of file - total 336 lines)\n</content>","metadata":{"preview":"package rout