{"type":"tool_use","timestamp":1775900726625,"sessionID":"ses_284125adbffefzbkmrn4NDE8fS","part":{"id":"prt_d7bee929a001g03mjXzXKU8J7M","messageID":"msg_d7bee88ad001ta1YzsSVPZhW63","sessionID":"ses_284125adbffefzbkmrn4NDE8fS","type":"tool","tool":"read","callID":"toolu_tool-60094631040e455dbc08e3cfa8b9b7d6","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/pem\"\n9: \t\"fmt\"\n10: \t\"strings\"\n11: \t\"time\"\n12: \n13: \t\"github.com/golang-jwt/jwt/v5\"\n14: \tcorev1 \"k8s.io/api/core/v1\"\n15: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n16: \t\"k8s.io/client-go/kubernetes\"\n17: \t\"k8s.io/klog/v2\"\n18: )\n19: \n20: const (\n21: \tprivateKeyPEMType  = \"RSA PRIVATE KEY\"\n22: \tpublicKeyPEMType   = \"PUBLIC KEY\"\n23: \tjwtTokenExpiration = 5 * time.Minute\n24: \tjwtSecretName      = \"agentcube-jwt-keys\"\n25: )\n26: \n27: type JWTManager struct {\n28: \tprivateKey *rsa.PrivateKey\n29: \tpublicKey  *rsa.PublicKey\n30: \tclientset  kubernetes.Interface\n31: \tnamespace  string\n32: }\n33: \n34: func NewJWTManager(clientset kubernetes.Interface, namespace string) (*JWTManager, error) {\n35: \tif clientset == nil {\n36: \t\treturn nil, fmt.Errorf(\"kubernetes clientset is required\")\n37: \t}\n38: \n39: \tif namespace == \"\" {\n40: \t\tnamespace = defaultNamespace\n41: \t}\n42: \n43: \tjwtMgr := &JWTManager{\n44: \t\tclientset: clientset,\n45: \t\tnamespace: namespace,\n46: \t}\n47: \n48: \tif err := jwtMgr.tryStoreOrLoadJWTKeySecret(); err != nil {\n49: \t\tklog.Warningf(\"Failed to load or store JWT key secret: %v. Generating in-memory keys only.\", err)\n50: \t\tprivateKey, publicKey, err := generateRSAKeyPair()\n51: \t\tif err != nil {\n52: \t\t\treturn nil, fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n53: \t\t}\n54: \t\tjwtMgr.privateKey = privateKey\n55: \t\tjwtMgr.publicKey = publicKey\n56: \t}\n57: \n58: \treturn jwtMgr, nil\n59: }\n60: \n61: func (j *JWTManager) GenerateToken(sessionID string) (string, error) {\n62: \tif j.privateKey == nil {\n63: \t\treturn \"\", fmt.Errorf(\"JWT manager not initialized with private key\")\n64: \t}\n65: \n66: \tnow := time.Now()\n67: \tclaims := &JWTClaims{\n68: \t\tSessionID: sessionID,\n69: \t\tRegisteredClaims: jwt.RegisteredClaims{\n70: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n71: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(jwtTokenExpiration)),\n72: \t\t\tNotBefore: jwt.NewNumericDate(now),\n73: \t\t},\n74: \t}\n75: \n76: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n77: \ttokenString, err := token.SignedString(j.privateKey)\n78: \tif err != nil {\n79: \t\treturn \"\", fmt.Errorf(\"failed to sign JWT token: %w\", err)\n80: \t}\n81: \n82: \treturn tokenString, nil\n83: }\n84: \n85: func (j *JWTManager) ValidateToken(tokenString string) (*JWTClaims, error) {\n86: \tif j.publicKey == nil {\n87: \t\treturn nil, fmt.Errorf(\"JWT manager not initialized with public key\")\n88: \t}\n89: \n90: \ttoken, err := jwt.ParseWithClaims(tokenString, &JWTClaims{}, func(token *jwt.Token) (interface{}, error) {\n91: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n92: \t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n93: \t\t}\n94: \t\treturn j.publicKey, nil\n95: \t})\n96: \n97: \tif err != nil {\n98: \t\treturn nil, fmt.Errorf(\"failed to parse JWT token: %w\", err)\n99: \t}\n100: \n101: \tclaims, ok := token.Claims.(*JWTClaims)\n102: \tif !ok || !token.Valid {\n103: \t\treturn nil, fmt.Errorf(\"invalid JWT token claims\")\n104: \t}\n105: \n106: \tif time.Now().After(claims.ExpiresAt.Time) {\n107: \t\treturn nil, fmt.Errorf(\"JWT token has expired\")\n108: \t}\n109: \n110: \treturn claims, nil\n111: }\n112: \n113: func (j *JWTManager) tryStoreOrLoadJWTKeySecret() error {\n114: \tsecret, err := j.clientset.CoreV1().Secrets(j.namespace).Get(j.context(), jwtSecretName, metav1.GetOptions{})\n115: \tif err == nil {\n116: \t\treturn j.loadKeysFromSecret(secret)\n117: \t}\n118: \n119: \tif err != nil && !isNotFoundError(err) {\n120: \t\treturn fmt.Errorf(\"failed to check for existing JWT secret: %w\", err)\n121: \t}\n122: \n123: \treturn j.storeJWTKeySecret()\n124: }\n125: \n126: func (j *JWTManager) loadKeysFromSecret(secret *corev1.Secret) error {\n127: \tprivateKeyPEM, ok := secret.Data[\"private.pem\"]\n128: \tif !ok {\n129: \t\treturn fmt.Errorf(\"secret does not contain private.pem\")\n130: \t}\n131: \n132: \tpublicKeyPEM, ok := secret.Data[\"public.pem\"]\n133: \tif !ok {\n134: \t\treturn fmt.Errorf(\"secret does not contain public.pem\")\n135: \t}\n136: \n137: \tprivateKey, err := parsePrivateKeyPEM(privateKeyPEM)\n138: \tif err != nil {\n139: \t\treturn fmt.Errorf(\"failed to parse private key: %w\", err)\n140: \t}\n141: \n142: \tpublicKey, err := parsePublicKeyPEM(publicKeyPEM)\n143: \tif err != nil {\n144: \t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n145: \t}\n146: \n147: \tj.privateKey = privateKey\n148: \tj.publicKey = publicKey\n149: \n150: \tklog.Infof(\"Successfully loaded JWT keys from secret: %s\", jwtSecretName)\n151: \treturn nil\n152: }\n153: \n154: func (j *JWTManager) storeJWTKeySecret() error {\n155: \tprivateKey, publicKey, err := generateRSAKeyPair()\n156: \tif err != nil {\n157: \t\treturn fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n158: \t}\n159: \n160: \tprivateKeyPEM := pem.EncodeToMemory(&pem.Block{\n161: \t\tType:  privateKeyPEMType,\n162: \t\tBytes: x509.MarshalPKCS1PrivateKey(privateKey),\n163: \t})\n164: \n165: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n166: \tif err != nil {\n167: \t\treturn fmt.Errorf(\"failed to marshal public key: %w\", err)\n168: \t}\n169: \n170: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n171: \t\tType:  publicKeyPEMType,\n172: \t\tBytes: publicKeyBytes,\n173: \t})\n174: \n175: \tsecret := &corev1.Secret{\n176: \t\tObjectMeta: metav1.ObjectMeta{\n177: \t\t\tName:      jwtSecretName,\n178: \t\t\tNamespace: j.namespace,\n179: \t\t},\n180: \t\tData: map[string][]byte{\n181: \t\t\t\"private.pem\": privateKeyPEM,\n182: \t\t\t\"public.pem\":  publicKeyPEM,\n183: \t\t},\n184: \t}\n185: \n186: \t_, err = j.clientset.CoreV1().Secrets(j.namespace).Create(j.context(), secret, metav1.CreateOptions{})\n187: \tif err != nil {\n188: \t\treturn fmt.Errorf(\"failed to create JWT key secret: %w\", err)\n189: \t}\n190: \n191: \tj.privateKey = privateKey\n192: \tj.publicKey = publicKey\n193: \n194: \tklog.Infof(\"Successfully created JWT key secret: %s\", jwtSecretName)\n195: \treturn nil\n196: }\n197: \n198: func (j *JWTManager) context() context.Context {\n199: \treturn context.Background()\n200: }\n201: \n202: func generateRSAKeyPair() (*rsa.PrivateKey, *rsa.PublicKey, error) {\n203: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n204: \tif err != nil {\n205: \t\treturn nil, nil, fmt.Errorf(\"failed to generate RSA key: %w\", err)\n206: \t}\n207: \n208: \treturn privateKey, &privateKey.PublicKey, nil\n209: }\n210: \n211: func parsePrivateKeyPEM(privateKeyPEM []byte) (*rsa.PrivateKey, error) {\n212: \tblock, _ := pem.Decode(privateKeyPEM)\n213: \tif block == nil {\n214: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n215: \t}\n216: \n217: \tif block.Type != privateKeyPEMType {\n218: \t\treturn nil, fmt.Errorf(\"invalid PEM block type: %s\", block.Type)\n219: \t}\n220: \n221: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n222: \tif err != nil {\n223: \t\treturn nil, fmt.Errorf(\"failed to parse private key: %w\", err)\n224: \t}\n225: \n226: \treturn privateKey, nil\n227: }\n228: \n229: func parsePublicKeyPEM(publicKeyPEM []byte) (*rsa.PublicKey, error) {\n230: \tblock, _ := pem.Decode(publicKeyPEM)\n231: \tif block == nil {\n232: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n233: \t}\n234: \n235: \tif block.Type != publicKeyPEMType {\n236: \t\treturn nil, fmt.Errorf(\"invalid PEM block type: %s\", block.Type)\n237: \t}\n238: \n239: \tpublicKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n240: \tif err != nil {\n241: \t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n242: \t}\n243: \n244: \trsaPublicKey, ok := publicKey.(*rsa.PublicKey)\n245: \tif !ok {\n246: \t\treturn nil, fmt.Errorf(\"not an RSA public key\")\n247: \t}\n248: \n249: \treturn rsaPublicKey, nil\n250: }\n251: \n252: func isNotFoundError(err error) bool {\n253: \tif err == nil {\n254: \t\treturn false\n255: \t}\n256: \treturn strings.Contains(err.Error(), \"not found\") ||\n257: \t\tstrings.Contains(err.Error(), \"404\")\n258: }\n\n(End of file - total 258 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go","time":{"start":1775900726615,"end":1775900726624}}}}
