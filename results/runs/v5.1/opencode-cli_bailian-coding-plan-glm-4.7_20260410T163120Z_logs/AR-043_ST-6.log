\t\tcorrelationID := c.GetHeader(\"X-Request-ID\")\n59: \t\tif correlationID == \"\" {\n60: \t\t\tcorrelationID = uuid.New().String()\n61: \t\t\tc.Header(\"X-Request-ID\", correlationID)\n62: \t\t}\n63: \t\tc.Set(\"correlationID\", correlationID)\n64: \n65: \t\tklog.V(4).Infof(\"[%s] %s %s\", correlationID, c.Request.Method, c.Request.URL.Path)\n66: \n67: \t\tc.Next()\n68: \n69: \t\tduration := time.Since(start)\n70: \t\tklog.V(4).Infof(\"[%s] %s %s - Status: %d - Duration: %v\",\n71: \t\t\tcorrelationID,\n72: \t\t\tc.Request.Method,\n73: \t\t\tc.Request.URL.Path,\n74: \t\t\tc.Writer.Status(),\n75: \t\t\tduration,\n76: \t\t)\n77: \t}\n78: }\n79: \n80: func recoveryMiddleware() gin.HandlerFunc {\n81: \treturn func(c *gin.Context) {\n82: \t\tdefer func() {\n83: \t\t\tif err := recover(); err != nil {\n84: \t\t\t\tcorrelationID, _ := c.Get(\"correlationID\")\n85: \t\t\t\tklog.Errorf(\"[%v] Panic recovered: %v\", correlationID, err)\n86: \n87: \t\t\t\tc.JSON(http.StatusInternalServerError, NewErrorResponse(\n88: \t\t\t\t\t\"internal server error\",\n89: \t\t\t\t\t\"\",\n90: \t\t\t\t))\n91: \t\t\t\tc.Abort()\n92: \t\t\t}\n93: \t\t}()\n94: \n95: \t\tc.Next()\n96: \t}\n97: }\n98: \n99: func correlationIDMiddleware() gin.HandlerFunc {\n100: \treturn func(c *gin.Context) {\n101: \t\tcorrelationID := c.GetHeader(\"X-Request-ID\")\n102: \t\tif correlationID == \"\" {\n103: \t\t\tcorrelationID = uuid.New().String()\n104: \t\t}\n105: \n106: \t\tc.Set(\"correlationID\", correlationID)\n107: \t\tc.Header(\"X-Request-ID\", correlationID)\n108: \n109: \t\tc.Next()\n110: \t}\n111: }\n112: \n113: type Metrics struct {\n114: \trequestCount      map[string]int64\n115: \tresponseTime      map[string][]time.Duration\n116: \tactiveConnections int\n117: \tmu                sync.RWMutex\n118: }\n119: \n120: func NewMetrics() *Metrics {\n121: \treturn &Metrics{\n122: \t\trequestCount: make(map[string]int64),\n123: \t\tresponseTime: make(map[string][]time.Duration),\n124: \t}\n125: }\n126: \n127: func (m *Metrics) RecordRequest(method, path string, duration time.Duration) {\n128: \tm.mu.Lock()\n129: \tdefer m.mu.Unlock()\n130: \n131: \tkey := fmt.Sprintf(\"%s %s\", method, path)\n132: \tm.requestCount[key]++\n133: \tm.responseTime[key] = append(m.responseTime[key], duration)\n134: \n135: \tif len(m.responseTime[key]) > 1000 {\n136: \t\tm.responseTime[key] = m.responseTime[key][1:]\n137: \t}\n138: }\n139: \n140: func (m *Metrics) IncrementActiveConnections() {\n141: \tm.mu.Lock()\n142: \tdefer m.mu.Unlock()\n143: \tm.activeConnections++\n144: }\n145: \n146: func (m *Metrics) DecrementActiveConnections() {\n147: \tm.mu.Lock()\n148: \tdefer m.mu.Unlock()\n149: \tm.activeConnections--\n150: }\n151: \n152: func (m *Metrics) GetActiveConnections() int {\n153: \tm.mu.RLock()\n154: \tdefer m.mu.RUnlock()\n155: \treturn m.activeConnections\n156: }\n157: \n158: func metricsMiddleware(metrics *Metrics) gin.HandlerFunc {\n159: \treturn func(c *gin.Context) {\n160: \t\tstart := time.Now()\n161: \n162: \t\tmetrics.IncrementActiveConnections()\n163: \t\tdefer metrics.DecrementActiveConnections()\n164: \n165: \t\tc.Next()\n166: \n167: \t\tduration := time.Since(start)\n168: \t\tmetrics.RecordRequest(c.Request.Method, c.FullPath(), duration)\n169: \t}\n170: }\n171: \n172: func jwtAuthMiddleware(jwtManager *JWTManager) gin.HandlerFunc {\n173: \treturn func(c *gin.Context) {\n174: \t\tif jwtManager == nil {\n175: \t\t\tc.JSON(http.StatusUnauthorized, NewErrorResponse(\n176: \t\t\t\t\"authentication service unavailable\",\n177: \t\t\t\t\"AUTH_UNAVAILABLE\",\n178: \t\t\t))\n179: \t\t\tc.Abort()\n180: \t\t\treturn\n181: \t\t}\n182: \n183: \t\tauthHeader := c.GetHeader(\"Authorization\")\n184: \t\tif authHeader == \"\" {\n185: \t\t\tc.JSON(http.StatusUnauthorized, NewErrorResponse(\n186: \t\t\t\t\"missing authorization header\",\n187: \t\t\t\t\"MISSING_TOKEN\",\n188: \t\t\t))\n189: \t\t\tc.Abort()\n190: \t\t\treturn\n191: \t\t}\n192: \n193: \t\tconst bearerPrefix = \"Bearer \"\n194: \t\tif !strings.HasPrefix(authHeader, bearerPrefix) {\n195: \t\t\tc.JSON(http.StatusUnauthorized, NewErrorResponse(\n196: \t\t\t\t\"invalid authorization header format\",\n197: \t\t\t\t\"INVALID_TOKEN_FORMAT\",\n198: \t\t\t))\n199: \t\t\tc.Abort()\n200: \t\t\treturn\n201: \t\t}\n202: \n203: \t\ttokenString := strings.TrimPrefix(authHeader, bearerPrefix)\n204: \t\tclaims, err := jwtManager.ValidateToken(tokenString)\n205: \t\tif err != nil {\n206: \t\t\tcorrelationID, _ := c.Get(\"correlationID\")\n207: \t\t\tklog.Warningf(\"[%v] JWT validation failed: %v\", correlationID, err)\n208: \n209: \t\t\terrorCode := \"INVALID_TOKEN\"\n210: \t\t\tif strings.Contains(err.Error(), \"expired\") {\n211: \t\t\t\terrorCode = \"TOKEN_EXPIRED\"\n212: \t\t\t}\n213: \n214: \t\t\tc.JSON(http.StatusUnauthorized, NewErrorResponse(\n215: \t\t\t\t\"invalid or expired token\",\n216: \t\t\t\terrorCode,\n217: \t\t\t))\n218: \t\t\tc.Abort()\n219: \t\t\treturn\n220: \t\t}\n221: \n222: \t\tc.Set(\"sessionID\", claims.SessionID)\n223: \t\tc.Next()\n224: \t}\n225: }\n\n(End of file - total 225 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype ConcurrencyLimiter struct {\n\tsemaphore chan struct{}\n}\n\nfunc NewConcurrencyLimiter(maxConcurrent int) *ConcurrencyLimiter {\n\treturn &ConcurrencyLimiter{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/middleware.go","time":{"start":1775900726618,"end":1775900726626}}}}
