' $(MAKEFILE_LIST) .makefiles/*.mk 2>/dev/null | grep -E \"lint|format|Lint|Format\"\n\t@echo \"\"\n\t@echo \"$(GREEN)Docker Targets:$(NC)\"\n--\n\t@echo \"  $(YELLOW)BUILD_DIR$(NC)       Build directory: $(BUILD_DIR)\"\n\t@echo \"  $(YELLOW)IMAGE_TAG$(NC)       Docker image tag: $(IMAGE_TAG)\"\n\t@echo \"\"\n\t@echo \"$(BLUE)Examples:$(NC)\"\n\t@echo \"  make build                    Build all components\"\n\t@echo \"  make test                     Run all tests\"\n\t@echo \"  make lint                     Run all linting checks\"\n\t@echo \"  make clean                    Clean build artifacts\"\n\t@echo \"  BUILD_MODE=release make build Build in release mode\"\n\t@echo \"  make docker-build             Build Docker images\"\n\t@echo \"\"\n\n.PHONY: all\nall: build test lint ## Build, test, and lint everything\n\n.PHONY: build\nbuild: build-go build-python ## Build all Go and Python components\n\n.PHONY: test\ntest: test-go test-python ## Run all tests\n\n.PHONY: lint\nlint: lint-go lint-python ## Run all linting checks\n\n.PHONY: format\nformat: format-go format-python ## Format all code\n\n.PHONY: check\ncheck: lint test ## Run all checks (lint and test)\n\n.PHONY: clean\nclean: clean-go clean-python clean-docker clean-coverage ## Clean all build artifacts\n\n.PHONY: deps\ndeps: deps-go deps-python ## Download all dependencies\n\n.PHONY: verify\nverify: test lint format-check ## Verify code quality (test, lint, format check)\n\n.PHONY: ci\nci: ci-build ci-test ci-lint ## Run CI pipeline\n\n.PHONY: dev-setup\ndev-setup: deps install-dev-tools ## Set up development environment\n\n.PHONY: version\n","exit":0,"description":"Check Makefile for test commands","truncated":false},"title":"Check Makefile for test commands","time":{"start":1775900740508,"end":1775900740630}}}}
