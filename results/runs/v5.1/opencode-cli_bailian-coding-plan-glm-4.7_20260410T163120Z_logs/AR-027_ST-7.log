:             timeout: Request timeout in seconds\n40:             connect_timeout: Connection timeout in seconds\n41:             pool_connections: Number of connection pools to cache\n42:             pool_maxsize: Maximum number of connections in pool\n43:         \"\"\"\n44:         self.session_id = session_id\n45:         self.timeout = timeout\n46:         self.connect_timeout = connect_timeout\n47:         self.logger = get_logger(f\"{__name__}.CodeInterpreterDataPlaneClient\")\n48:         self.session = create_session(pool_connections=pool_connections, pool_maxsize=pool_maxsize)\n49: \n50:         if base_url:\n51:             self.base_url = base_url\n52:         elif router_url and namespace and cr_name:\n53:             base_path = f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\"\n54:             self.base_url = urljoin(router_url, base_path)\n55:         else:\n56:             raise ValueError(\"Either base_url or (router_url, namespace, cr_name) must be provided\")\n57: \n58:         self.session.headers.update({\"x-agentcube-session-id\": session_id})\n59:         self.logger.debug(f\"Initialized data plane client with base_url: {self.base_url}\")\n60: \n61:     def _request(\n62:         self,\n63:         method: str,\n64:         endpoint: str,\n65:         body: bytes | None = None,\n66:     ) -> requests.Response:\n67:         \"\"\"Make a request to the data plane.\n68: \n69:         Args:\n70:             method: HTTP method\n71:             endpoint: API endpoint relative to base_url\n72:             body: Request body as bytes\n73: \n74:         Returns:\n75:             Response object\n76: \n77:         Raises:\n78:             requests.RequestException: If the request fails\n79:         \"\"\"\n80:         url = f\"{self.base_url}{endpoint}\"\n81:         headers: dict[str, str] = {}\n82: \n83:         if body is not None:\n84:             headers[\"Content-Type\"] = \"application/json\"\n85: \n86:         response = self.session.request(\n87:             method,\n88:             url,\n89:             data=body,\n90:             headers=headers,\n91:             timeout=(self.connect_timeout, self.timeout),\n92:         )\n93: \n94:         response.raise_for_status()\n95:         return response\n96: \n97:     def execute_command(\n98:         self,\n99:         command: str | list[str],\n100:         timeout: float | None = None,\n101:     ) -> str:\n102:         \"\"\"Execute a command in the Code Interpreter session.\n103: \n104:         Args:\n105:             command: Command string or list of arguments\n106:             timeout: Timeout in seconds (uses instance default if None)\n107: \n108:         Returns:\n109:             Command output\n110: \n111:         Raises:\n112:             CommandExecutionError: If command exits with non-zero code\n113:             requests.RequestException: If the request fails\n114:         \"\"\"\n115:         if isinstance(command, str):\n116:             command_list = [command]\n117:         else:\n118:             command_list = command\n119: \n120:         timeout_value = timeout if timeout is not None else self.timeout\n121:         timeout_str = f\"{timeout_value}s\"\n122: \n123:         body = {\"command\": command_list, \"timeout\": timeout_str}\n124:         body_bytes = json.dumps(body).encode(\"utf-8\")\n125: \n126:         read_timeout = timeout_value + 2.0\n127: \n128:         self.logger.debug(f\"Executing command: {' '.join(command_list)}\")\n129: \n130:         response = self.session.post(\n131:             f\"{self.base_url}api/execute\",\n132:             data=body_bytes,\n133:             headers={\"Content-Type\": \"application/json\", \"x-agentcube-session-id\": self.session_id},\n134:             timeout=(self.connect_timeout, read_timeout),\n135:         )\n136: \n137:         response.raise_for_status()\n138:         data = response.json()\n139: \n140:         exit_code = data.get(\"exit_code\", 0)\n141: \n142:         if exit_code != 0:\n143:             stderr = data.get(\"stderr\", \"\")\n144:             cmd_str = \" \".join(command_list)\n145:             self.logger.error(f\"Command failed with exit code {exit_code}: {stderr}\")\n146:             raise CommandExecutionError(exit_code=exit_code, stderr=stderr, command=cmd_str)\n147: \n148:         stdout = data.get(\"stdout\", \"\")\n149:         return stdout\n150: \n151:     def run_code(\n152:         self,\n153:         language: str,\n154:         code: str,\n155:         timeout: float | None = None,\n156:     ) -> str:\n157:         \"\"\"Run code in the specified language.\n158: \n159:         Args:\n160:             language: Programming language (python, py, python3 supported)\n161:             code: Source code to execute\n162:             timeout: Timeout in seconds\n163: \n164:         Returns:\n165:             Execution output\n166: \n167:         Raises:\n168:             ValueError: If language is not supported\n169:         \"\"\"\n170:         language_lower = language.lower()\n171: \n172:         if language_lower not in (\"python\", \"py\", \"python3\"):\n173:             raise ValueError(f\"Unsupported language: {language}\")\n174: \n175:         timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S_%f\")\n176:         file_name = f\"code_{timestamp}.py\"\n177: \n178:         self.write_file(code, file_name)\n179: \n180:         command = f\"python3 {file_name}\"\n181:         return self.execute_command(command, timeout=timeout)\n182: \n183:     def write_file(self, content: str, remote_path: str) -> None:\n184:         \"\"\"Write content to a file in the session.\n185: \n186:         Args:\n187:             content: File content as string\n188:             remote_path: Remote file path\n189: \n190:         Raises:\n191:             requests.RequestException: If the request fails\n192:         \"\"\"\n193:         content_b64 = base64.b64encode(content.encode(\"utf-8\")).decode(\"utf-8\")\n194: \n195:         body = {\"path\": remote_path, \"content\": content_b64, \"mode\": \"0644\"}\n196:         body_bytes = json.dumps(body).encode(\"utf-8\")\n197: \n198:         self.logger.debug(f\"Writing file: {remote_path}\")\n199: \n200:         self._request(\"POST\", \"api/files\", body=body_bytes)\n201: \n202:     def upload_file(self, local_path: str, remote_path: str) -> None:\n203:         \"\"\"Upload a local file to the session.\n204: \n205:         Args:\n206:             local_path: Local file path\n207:             remote_path: Remote file path\n208: \n209:         Raises:\n210:             requests.RequestException: If the request fails\n211:         \"\"\"\n212:         self.logger.debug(f\"Uploading file: {local_path} -> {remote_path}\")\n213: \n214:         with open(local_path, \"rb\") as f:\n215:             files = {\"file\": f}\n216:             data = {\"path\": remote_path, \"mode\": \"0644\"}\n217: \n218:             response = self.session.post(\n219:                 f\"{self.base_url}api/files\",\n220:                 files=files,\n221:                 data=data,\n222:                 headers={\"x-agentcube-session-id\": self.session_id},\n223:                 timeout=(self.connect_timeout, self.timeout),\n224:             )\n225: \n226:             response.raise_for_status()\n227: \n228:     def download_file(self, remote_path: str, local_path: str) -> None:\n229:         \"\"\"Download a file from the session.\n230: \n231:         Args:\n232:             remote_path: Remote file path\n233:             local_path: Local file path\n234: \n235:         Raises:\n236:             requests.RequestException: If the request fails\n237:         \"\"\"\n238:         clean_path = remote_path.lstrip(\"/\")\n239: \n240:         self.logger.debug(f\"Downloading file: {remote_path} -> {local_path}\")\n241: \n242:         response = self.session.get(\n243:             f\"{self.base_url}api/files/{clean_path}\",\n244:             headers={\"x-agentcube-session-id\": self.session_id},\n245:             timeout=(self.connect_timeout, self.timeout),\n246:             stream=True,\n247:         )\n248: \n249:         response.raise_for_status()\n250: \n251:         with open(local_path, \"wb\") as f:\n252:             for chunk in response.iter_content(chunk_size=8192):\n253:                 f.write(chunk)\n254: \n255:     def list_files(self, path: str = \".\") -> Any:\n256:         \"\"\"List files in the session.\n257: \n258:         Args:\n259:             path: Directory path to list\n260: \n261:         Returns:\n262:             JSON response with file listing\n263: \n264:         Raises:\n265:             requests.RequestException: If the request fails\n266:         \"\"\"\n267:         self.logger.debug(f\"Listing files: {path}\")\n268: \n269:         response = self.session.get(\n270:             f\"{self.base_url}api/files\",\n271:             headers={\"x-agentcube-session-id\": self.session_id},\n272:             params={\"path\": path},\n273:             timeout=(self.connect_timeout, self.timeout),\n274:         )\n275: \n276:         response.raise_for_status()\n277:         return response.json()\n278: \n279:     def close(self) -> None:\n280:         \"\"\"Close the HTTP session.\"\"\"\n281:         self.session.close()\n282:         self.logger.debug(\"Closed code interpreter data plane session\")\n\n(End of file - total 282 lines)\n</content>","metadata":{"preview":"\"\"\"Data plane client for Code Interpreter operations.\"\"\"\n\nimport base64\nimport json\nimport logging\nfrom datetime import datetime\nfrom typing import Any\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom ..exceptions import CommandExecutionError\nfrom ..utils import create_session, get_logger\n\n\nclass CodeInterpreterDataPlaneClient:\n    \"\"\"Client for Code Interpreter data plane operations via Router.\"\"\"\n\n    def __init__(\n        self,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_