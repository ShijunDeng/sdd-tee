  self.command = command\n        super().__init__(f\"Command failed (exit {exit_code}): {stderr}\")\n\n\nclass SessionError(AgentCubeError):","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/agentcube/exceptions.py","time":{"start":1775877702357,"end":1775877702383}}}}
