40:             router_url=mock_router_url,\n41:             workload_manager_url=mock_workload_manager_url,\n42:         )\n43: \n44:         assert client.name == \"test-interpreter\"\n45:         assert client.namespace == \"default\"\n46:         assert client.router_url == mock_router_url\n47:         assert client.session_id is not None\n48:         mock_create_session.assert_called_once()\n49:         client.stop()\n50: \n51: \n52: def test_code_interpreter_client_init_from_env(mock_router_url):\n53:     \"\"\"Test CodeInterpreterClient initialization from environment variable.\"\"\"\n54:     with patch.dict(os.environ, {\"ROUTER_URL\": mock_router_url}), patch.object(\n55:         CodeInterpreterClient, \"_create_session\"\n56:     ):\n57:         client = CodeInterpreterClient(\n58:             name=\"test-interpreter\",\n59:             namespace=\"default\",\n60:         )\n61: \n62:         assert client.router_url == mock_router_url\n63:         client.stop()\n64: \n65: \n66: def test_code_interpreter_client_init_no_router_url():\n67:     \"\"\"Test CodeInterpreterClient initialization without router URL.\"\"\"\n68:     with pytest.raises(ValueError, match=\"Router URL must be provided\"):\n69:         CodeInterpreterClient(name=\"test-interpreter\", namespace=\"default\")\n70: \n71: \n72: def test_code_interpreter_client_init_with_session_id(mock_router_url, mock_workload_manager_url):\n73:     \"\"\"Test CodeInterpreterClient initialization with existing session_id.\"\"\"\n74:     with patch.object(CodeInterpreterClient, \"_init_data_plane\") as mock_init_dp:\n75:         client = CodeInterpreterClient(\n76:             name=\"test-interpreter\",\n77:             namespace=\"default\",\n78:             router_url=mock_router_url,\n79:             workload_manager_url=mock_workload_manager_url,\n80:             session_id=\"existing-session-id\",\n81:         )\n82: \n83:         assert client.session_id == \"existing-session-id\"\n84:         mock_init_dp.assert_called_once()\n85:         client.stop()\n86: \n87: \n88: def test_create_session(code_interpreter_client):\n89:     \"\"\"Test _create_session method.\"\"\"\n90:     with patch.object(code_interpreter_client.cp_client, \"create_session\") as mock_create, patch.object(\n91:         code_interpreter_client, \"_init_data_plane\"\n92:     ) as mock_init_dp:\n93:         mock_create.return_value = \"new-session-id\"\n94: \n95:         code_interpreter_client._create_session()\n96: \n97:         assert code_interpreter_client.session_id == \"new-session-id\"\n98:         mock_create.assert_called_once()\n99:         mock_init_dp.assert_called_once()\n100: \n101: \n102: def test_init_data_plane_success(code_interpreter_client):\n103:     \"\"\"Test _init_data_plane success.\"\"\"\n104:     code_interpreter_client.session_id = \"test-session-id\"\n105:     code_interpreter_client._init_data_plane()\n106: \n107:     assert code_interpreter_client.dp_client is not None\n108:     assert code_interpreter_client.dp_client.session_id == \"test-session-id\"\n109: \n110: \n111: def test_init_data_plane_failure(code_interpreter_client):\n112:     \"\"\"Test _init_data_plane failure.\"\"\"\n113:     code_interpreter_client.session_id = \"test-session-id\"\n114: \n115:     with patch(\n116:         \"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\",\n117:         side_effect=Exception(\"Init failed\"),\n118:     ) as mock_dp_class, patch.object(code_interpreter_client.cp_client, \"delete_session\") as mock_delete:\n119:         mock_dp_class.__name__ = \"CodeInterpreterDataPlaneClient\"\n120: \n121:         with pytest.raises(Exception, match=\"Init failed\"):\n122:             code_interpreter_client._init_data_plane()\n123: \n124:         mock_delete.assert_called_once_with(\"test-session-id\")\n125:         assert code_interpreter_client.session_id is None\n126: \n127: \n128: def test_context_manager(code_interpreter_client):\n129:     \"\"\"Test CodeInterpreterClient as context manager.\"\"\"\n130:     with patch.object(code_interpreter_client, \"stop\") as mock_stop:\n131:         with code_interpreter_client:\n132:             pass\n133: \n134:         mock_stop.assert_called_once()\n135: \n136: \n137: def test_context_manager_with_exception(code_interpreter_client):\n138:     \"\"\"Test CodeInterpreterClient context manager with exception.\"\"\"\n139:     with patch.object(code_interpreter_client, \"stop\") as mock_stop:\n140:         with pytest.raises(ValueError):\n141:             with code_interpreter_client:\n142:                 raise ValueError(\"Test error\")\n143: \n144:         mock_stop.assert_called_once()\n145: \n146: \n147: def test_stop(code_interpreter_client):\n148:     \"\"\"Test stop method.\"\"\"\n149:     code_interpreter_client.session_id = \"test-session-id\"\n150:     code_interpreter_client.dp_client = MagicMock()\n151:     code_interpreter_client.cp_client = MagicMock()\n152: \n153:     code_interpreter_client.stop()\n154: \n155:     code_interpreter_client.dp_client.close.assert_called_once()\n156:     code_interpreter_client.cp_client.delete_session.assert_called_once_with(\"test-session-id\")\n157:     code_interpreter_client.cp_client.close.assert_called_once()\n158:     assert code_interpreter_client.dp_client is None\n159:     assert code_interpreter_client.session_id is None\n160: \n161: \n162: def test_stop_without_session(code_interpreter_client):\n163:     \"\"\"Test stop without session.\"\"\"\n164:     code_interpreter_client.session_id = None\n165:     code_interpreter_client.dp_client = None\n166:     code_interpreter_client.cp_client = MagicMock()\n167: \n168:     code_interpreter_client.stop()\n169: \n170:     code_interpreter_client.cp_client.close.assert_called_once()\n171: \n172: \n173: def test_execute_command(code_interpreter_client):\n174:     \"\"\"Test execute_command method.\"\"\"\n175:     code_interpreter_client.dp_client = MagicMock()\n176:     code_interpreter_client.dp_client.execute_command.return_value = \"output\"\n177: \n178:     result = code_interpreter_client.execute_command(\"ls\")\n179: \n180:     assert result == \"output\"\n181:     code_interpreter_client.dp_client.execute_command.assert_called_once_with(\"ls\", timeout=None)\n182: \n183: \n184: def test_execute_command_with_timeout(code_interpreter_client):\n185:     \"\"\"Test execute_command with timeout.\"\"\"\n186:     code_interpreter_client.dp_client = MagicMock()\n187:     code_interpreter_client.dp_client.execute_command.return_value = \"output\"\n188: \n189:     result = code_interpreter_client.execute_command(\"ls\", timeout=30.0)\n190: \n191:     assert result == \"output\"\n192:     code_interpreter_client.dp_client.execute_command.assert_called_once_with(\"ls\", timeout=30.0)\n193: \n194: \n195: def test_execute_command_no_dp_client(code_interpreter_client):\n196:     \"\"\"Test execute_command without data plane client.\"\"\"\n197:     code_interpreter_client.dp_client = None\n198: \n199:     with pytest.raises(ValueError, match=\"Data plane client not initialized\"):\n200:         code_interpreter_client.execute_command(\"ls\")\n201: \n202: \n203: def test_run_code(code_interpreter_client):\n204:     \"\"\"Test run_code method.\"\"\"\n205:     code_interpreter_client.dp_client = MagicMock()\n206:     code_interpreter_client.dp_client.run_code.return_value = \"output\"\n207: \n208:     result = code_interpreter_client.run_code(\"python\", \"print('hello')\")\n209: \n210:     assert result == \"output\"\n211:     code_interpreter_client.dp_client.run_code.assert_called_once()\n212: \n213: \n214: def test_write_file(code_interpreter_client):\n215:     \"\"\"Test write_file method.\"\"\"\n216:     code_interpreter_client.dp_client = MagicMock()\n217: \n218:     code_interpreter_client.write_file(\"content\", \"/file.txt\")\n219: \n220:     code_interpreter_client.dp_client.write_file.assert_called_once_with(\"content\", \"/file.txt\")\n221: \n222: \n223: def test_upload_file(code_interpreter_client):\n224:     \"\"\"Test upload_file method.\"\"\"\n225:     code_interpreter_client.dp_client = MagicMock()\n226: \n227:     code_interpreter_client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n228: \n229:     code_interpreter_client.dp_client.upload_file.assert_called_once()\n230: \n231: \n232: def test_download_file(code_interpreter_client):\n233:     \"\"\"Test download_file method.\"\"\"\n234:     code_interpreter_client.dp_client = MagicMock()\n235: \n236:     code_interpreter_client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n237: \n238:     code_interpreter_client.dp_client.download_file.assert_called_once()\n239: \n240: \n241: def test_list_files(code_interpreter_client):\n242:     \"\"\"Test list_files method.\"\"\"\n243:     code_interpreter_client.dp_client = MagicMock()\n244:     code_interpreter_client.dp_client.list_files.return_value = {\"files\": [\"file.txt\"]}\n245: \n246:     result = code_interpreter_client.list_files(\".\")\n247: \n248:     assert result == {\"files\": [\"file.txt\"]}\n249:     code_interpreter_client.dp_client.list_files.assert_called_once_with(\".\")\n250: \n251: \n252: def test_verbose_logging(mock_router_url, mock_workload_manager_url):\n253:     \"\"\"Test verbose logging.\"\"\"\n254:     with patch.object(CodeInterpreterClient, \"_create_session\"):\n255:         client = CodeInterpreterClient(\n256:             name=\"test-interpreter\",\n257:             namespace=\"default\",\n258:             router_url=mock_router_url,\n259:             workload_manager_url=mock_workload_manager_url,\n260:             verbose=True,\n261:         )\n262: \n263:         assert client.verbose is True\n264:         client.stop()\n265: \n266: \n267: def test_custom_ttl(mock_router_url, mock_workload_manager_url):\n268:     \"\"\"Test custom TTL.\"\"\"\n269:     with patch.object(CodeInterpreterClient, \"_create_session\") as mock_create:\n270:         client = CodeInterpreterClient(\n271:             name=\"test-interpreter\",\n272:             namespace=\"default\",\n273:             router_url=mock_router_url,\n274:             workload_manager_url=mock_workload_manager_url,\n275:             ttl=7200,\n276:         )\n277: \n278:         assert client.ttl == 7200\n279:         client.stop()\n280: \n281: \n282: def test_custom_namespace(mock_router_url, mock_workload_manager_url):\n283:     \"\"\"Test custom namespace.\"\"\"\n284:     with patch.object(CodeInterpreterClient, \"_create_session\"):\n285:         client = CodeInterpreterClient(\n286:             name=\"test-interpreter\",\n287:             namespace=\"custom-namespace\",\n288:             router_url=mock_router_url,\n289:             workload_manager_url=mock_workload_manager_url,\n290:         )\n291: \n292:         assert client.namespace == \"custom-namespace\"\n293:         client.stop()\n\n(End of file - total 293 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterClient.\"\"\"\n\nimport os\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom agentcube.code_interpreter import CodeInterpreterClient\n\n\n@pytest.fixture\ndef mock_router_url():\n    \"\"\"Return a mock router URL.\"\"\"\n    return \"http://router:8080\"\n\n\n@pytest.fixture\ndef mock_workload_manager_url():\n    \"\"\"Return a mock workload manager URL.\"\"\"\n    return \"http://workload-manager:8080\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_code_interpreter_client.py","time":{"start":1775877706949,"end":1775877706975}}}}
{"type":"tool_use","timestamp":1775877706980,"sessionID":"ses_2857184e3ffe6rSn7qG9kyr1b5","part":{"id":"prt_d7a8f54ab0019S8TI690IJomx2","messageID":"msg_d7a8f4326001AZZcPHKmayOARb","sessionID":"ses_2857184e3ffe6rSn7qG9kyr1b5","type":"tool","tool":"read","callID":"toolu_tool-53f54a440e6742f7b5bd821735075129","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_code_interpreter_data_plane_client.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/test_code_interpreter_data_plane_client.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n2: \n3: from unittest.mock import MagicMock, mock_open, patch\n4: \n5: import pytest\n6: import requests\n7: \n8: from agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n9: from agentcube.exceptions import CommandExecutionError\n10: \n11: \n12: @pytest.fixture\n13: def mock_base_url():\n14:     \"\"\"Return a mock base URL.\"\"\"\n15:     return \"http://router:8080/v1/namespaces/default/code-interpreters/test/invocations/\"\n16: \n17: \n18: @pytest.fixture\n19: def data_plane_client(mock_base_url):\n20:     \"\"\"Return a CodeInterpreterDataPlaneClient instance.\"\"\"\n21:     return CodeInterpreterDataPlaneClient(\n22:         session_id=\"test-session-id\",\n23:         base_url=mock_base_url,\n24:     )\n25: \n26: \n27: def test_data_plane_client_init_with_base_url(mock_base_url):\n28:     \"\"\"Test CodeInterpreterDataPlaneClient initialization with base_url.\"\"\"\n29:     client = CodeInterpreterDataPlaneClient(\n30:         session_id=\"test-session-id\",\n31:         base_url=mock_base_url,\n32:     )\n33:     assert client.session_id == \"test-session-id\"\n34:     assert client.base_url == mock_base_url\n35:     assert \"x-agentcube-session-id\" in client.session.headers\n36:     assert client.session.headers[\"x-agentcube-session-id\"] == \"test-session-id\"\n37:     client.close()\n38: \n39: \n40: def test_data_plane_client_init_with_router_url():\n41:     \"\"\"Test CodeInterpreterDataPlaneClient initialization with router_url.\"\"\"\n42:     client = CodeInterpreterDataPlaneClient(\n43:         session_id=\"test-session-id\",\n44:         router_url=\"http://router:8080\",\n45:         namespace=\"default\",\n46:         cr_name=\"test\",\n47:     )\n48:     assert client.base_url == \"http://router:8080/v1/namespaces/default/code-interpreters/test/invocations/\"\n49:     client.close()\n50: \n51: \n52: def test_data_plane_client_init_missing_params():\n53:     \"\"\"Test CodeInterpreterDataPlaneClient initialization with missing parameters.\"\"\"\n54:     with pytest.raises(ValueError, match=\"Either base_url or\"):\n55:         CodeInterpreterDataPlaneClient(session_id=\"test-session-id\")\n56: \n57: \n58: def test_execute_command_success(data_plane_client, mock_base_url):\n59:     \"\"\"Test execute_command success.\"\"\"\n60:     with patch.object(data_plane_client.session, \"post\") as mock_post:\n61:         mock_response = MagicMock()\n62:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\", \"stderr\": \"\"}\n63:         mock_post.return_value = mock_response\n64: \n65:         result = data_plane_client.execute_command(\"ls\")\n66: \n67:         assert result == \"output\"\n68:         mock_post.assert_called_once()\n69:         call_args = mock_post.call_args\n70:         assert call_args[0][0] == f\"{mock_base_url}api/execute\"\n71:         assert \"x-agentcube-session-id\" in call_args[1][\"headers\"]\n72: \n73: \n74: def test_execute_command_list(data_plane_client):\n75:     \"\"\"Test execute_command with list of arguments.\"\"\"\n76:     with patch.object(data_plane_client.session, \"post\") as mock_post:\n77:         mock_response = MagicMock()\n78:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\", \"stderr\": \"\"}\n79:         mock_post.return_value = mock_response\n80: \n81:         result = data_plane_client.execute_command([\"ls\", \"-la\"])\n82: \n83:         assert result == \"output\"\n84: \n85: \n86: def test_execute_command_failure(data_plane_client, mock_base_url):\n87:     \"\"\"Test execute_command with non-zero exit code.\"\"\"\n88:     with patch.object(data_plane_client.session, \"post\") as mock_post:\n89:         mock_response = MagicMock()\n90:         mock_response.json.return_value = {\"exit_code\": 1, \"stdout\": \"\", \"stderr\": \"error message\"}\n91:         mock_post.return_value = mock_response\n92: \n93:         with pytest.raises(CommandExecutionError) as exc_info:\n94:             data_plane_client.execute_command(\"ls /invalid\")\n95: \n96:         assert exc_info.value.exit_code == 1\n97:         assert exc_info.value.stderr == \"error message\"\n98:         assert exc_info.value.command == \"ls /invalid\"\n99: \n100: \n101: def test_execute_command_with_timeout(data_plane_client):\n102:     \"\"\"Test execute_command with custom timeout.\"\"\"\n103:     with patch.object(data_plane_client.session, \"post\") as mock_post:\n104:         mock_response = MagicMock()\n105:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\", \"stderr\": \"\"}\n106:         mock_post.return_value = mock_response\n107: \n108:         data_plane_client.execute_command(\"sleep 1\", timeout=30.0)\n109: \n110:         call_args = mock_post.call_args\n111:         assert call_args[1][\"timeout\"] == (5.0, 32.0)\n112: \n113: \n114: def test_run_code_python(data_plane_client):\n115:     \"\"\"Test run_code with Python.\"\"\"\n116:     with patch.object(data_plane_client, \"write_file\") as mock_write, patch.object(\n117:         data_plane_client, \"execute_command\"\n118:     ) as mock_execute:\n119:         mock_execute.return_value = \"output\"\n120: \n121:         result = data_plane_client.run_code(\"python\", \"print('hello')\")\n122: \n123:         assert result == \"output\"\n124:         mock_write.assert_called_once()\n125:         assert mock_execute.call_args[0][0].startswith(\"python3 code_\")\n126:         assert mock_execute.call_args[0][0].endswith(\".py\")\n127: \n128: \n129: def test_run_code_python3(data_plane_client):\n130:     \"\"\"Test run_code with python3.\"\"\"\n131:     with patch.object(data_plane_client, \"write_file\") as mock_write, patch.object(\n132:         data_plane_client, \"execute_command\"\n133:     ) as mock_execute:\n134:         mock_execute.return_value = \"output\"\n135: \n136:         result = data_plane_client.run_code(\"python3\", \"print('hello')\")\n137: \n138:         assert result == \"output\"\n139: \n140: \n141: def test_run_code_py(data_plane_client):\n142:     \"\"\"Test run_code with py.\"\"\"\n143:     with patch.object(data_plane_client, \"write_file\") as mock_write, patch.object(\n144:         data_plane_client, \"execute_command\"\n145:     ) as mock_execute:\n146:         mock_execute.return_value = \"output\"\n147: \n148:         result = data_plane_client.run_code(\"py\", \"print('hello')\")\n149: \n150:         assert result == \"output\"\n151: \n152: \n153: def test_run_code_unsupported_language(data_plane_client):\n154:     \"\"\"Test run_code with unsupported language.\"\"\"\n155:     with pytest.raises(ValueError, match=\"Unsupported language\"):\n156:         data_plane_client.run_code(\"javascript\", \"console.log('hello')\")\n157: \n158: \n159: def test_write_file(data_plane_client, mock_base_url):\n160:     \"\"\"Test write_file.\"\"\"\n161:     with patch.object(data_plane_client, \"_request\") as mock_request:\n162:         data_plane_client.write_file(\"test content\", \"/test/file.txt\")\n163: \n164:         mock_request.assert_called_once()\n165:         call_args = mock_request.call_args\n166:         assert call_args[0][0] == \"POST\"\n167:         assert call_args[0][1] == \"api/files\"\n168: \n169: \n170: def test_upload_file(data_plane_client, mock_base_url):\n171:     \"\"\"Test upload_file.\"\"\"\n172:     with patch.object(data_plane_client.session, \"post\") as mock_post, patch(\"builtins.open\", mock_open(read_data=b\"file content\")):\n173:         mock_response = MagicMock()\n174:         mock_post.return_value = mock_response\n175: \n176:         data_plane_client.upload_file(\"/local/file.txt\", \"/remote/file.txt\")\n177: \n178:         mock_post.assert_called_once()\n179:         call_args = mock_post.call_args\n180:         assert call_args[0][0] == f\"{mock_base_url}api/files\"\n181:         assert \"files\" in call_args[1]\n182:         assert \"x-agentcube-session-id\" in call_args[1][\"headers\"]\n183: \n184: \n185: def test_download_file(data_plane_client, mock_base_url):\n186:     \"\"\"Test download_file.\"\"\"\n187:     with patch.object(data_plane_client.session, \"get\") as mock_get, patch(\"builtins.open\", mock_open()) as mock_file:\n188:         mock_response = MagicMock()\n189:         mock_response.iter_content.return_value = [b\"chunk1\", b\"chunk2\"]\n190:         mock_response.raise_for_status = MagicMock()\n191:         mock_get.return_value = mock_response\n192: \n193:         data_plane_client.download_file(\"/remote/file.txt\", \"/local/file.txt\")\n194: \n195:         mock_get.assert_called_once()\n196:         call_args = mock_get.call_args\n197:         assert call_args[0][0] == f\"{mock_base_url}api/files/remote/file.txt\"\n198:         assert call_args[1][\"stream\"] is True\n199: \n200: \n201: def test_download_file_with_leading_slash(data_plane_client):\n202:     \"\"\"Test download_file with leading slash in path.\"\"\"\n203:     with patch.object(data_plane_client.session, \"get\") as mock_get, patch(\"builtins.open\", mock_open()):\n204:         mock_response = MagicMock()\n205:         mock_response.iter_content.return_value = [b\"chunk\"]\n206:         mock_response.raise_for_status = MagicMock()\n207:         mock_get.return_value = mock_response\n208: \n209:         data_plane_client.download_file(\"/path/to/file.txt\", \"/local/file.txt\")\n210: \n211:         call_args = mock_get.call_args\n212:         assert \"path/to/file.txt\" in call_args[0][0]\n213:         assert \"/path/to/file.txt\" not in call_args[0][0]\n214: \n215: \n216: def test_list_files(data_plane_client, mock_base_url):\n217:     \"\"\"Test list_files.\"\"\"\n218:     with patch.object(data_plane_client.session, \"get\") as mock_get:\n219:         mock_response = MagicMock()\n220:         mock_response.json.return_value = {\"files\": [\"file1.txt\", \"file2.txt\"]}\n221:         mock_get.return_value = mock_response\n222: \n223:         result = data_plane_client.list_files(\".\")\n224: \n225:         assert result == {\"files\": [\"file1.txt\", \"file2.txt\"]}\n226:         mock_get.assert_called_once()\n227:         call_args = mock_get.call_args\n228:         assert call_args[0][0] == f\"{mock_base_url}api/files\"\n229:         assert call_args[1][\"params\"][\"path\"] == \".\"\n230: \n231: \n232: def test_close(data_plane_client):\n233:     \"\"\"Test close method.\"\"\"\n234:     data_plane_client.close()\n235:     data_plane_client.close()\n236: \n237: \n238: def test_custom_timeout(mock_base_url):\n239:     \"\"\"Test CodeInterpreterDataPlaneClient with custom timeout.\"\"\"\n240:     client = CodeInterpreterDataPlaneClient(\n241:         session_id=\"test-session-id\",\n242:         base_url=mock_base_url,\n243:         timeout=60,\n244:         connect_timeout=2.0,\n245:     )\n246:     assert client.timeout == 60\n247:     assert client.connect_timeout == 2.0\n248:     client.close()\n\n(End of file - total 248 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for CodeInterpreterDataPlaneClient.\"\"\"\n\nfrom unittest.mock import MagicMock, mock_open, patch\n\nimport pytest\nimport requests\n\nfrom agentcube.clients.code_interpreter_data_plane imp