am, err := NewAuthManager()\n\trequire.NoError(t, err)\n\treturn am\n}\n\nfunc createTestTokenWithPrivateKey(t *testing.T, privateKey *rsa.PrivateKey) string {\n\tclaims := AuthClaims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now()),\n\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),\n\t\t},\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, err := token.SignedString(privateKey)\n\trequire.NoError(t, err)\n\n\treturn tokenString\n}\n\nfunc createTestToken(t *testing.T, am *AuthManager) string {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\treturn createTestTokenWithPrivateKey(t, privateKey)\n}"},"output":"Edit applied successfully.\n\nLSP errors detected in this file, please fix:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/middleware_test.go\">\nERROR [58:6] TestAuthMiddleware redeclared in this block (this error: other declaration of TestAuthMiddleware)\nERROR [121:5] declared and not used: am\nERROR [124:14] undefined: createTestTokenWithPrivateKey\nERROR [155:5] declared and not used: am\nERROR [181:14] undefined: createTestTokenWithPrivateKey\nERROR [260:11] undefined: createTestTokenWithPrivateKey\nERROR [306:11] undefined: createTestTokenWithPrivateKey\n</diagnostics>","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/auth.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/middleware.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/session_manager_test.go":[{"range":{"start":{"line":20,"character":36},"end":{"line":20,"cha