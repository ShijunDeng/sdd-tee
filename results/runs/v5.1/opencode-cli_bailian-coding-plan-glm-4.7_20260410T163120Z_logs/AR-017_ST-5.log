s{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now()),\n\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),\n\t\t},\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, err := token.SignedString(privateKey)\n\trequire.NoError(t, err)\n\n\treturn tokenString\n}\n\nfunc TestAuthMiddleware_ErrorCases(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\tam := setupTestAuthManager(t)\n\n\tmiddleware := AuthMiddleware(am)\n\n\ttests := []struct {\n\t\tname           string\n\t\tsetupRequest   func(*http.Request)\n\t\texpectedStatus int\n\t\texpectedError  string\n\t\tshouldSetClaim bool\n\t}{\n\t\t{\n\t\t\tname: \"missing authorization header\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Missing Authorization header\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format - Basic\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Basic dGVzdDp0ZXN0\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Use Bearer\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format - Token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Token abc123\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Use Bearer\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format - no prefix\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"abc123\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Use Bearer\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid token format\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"B