us: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Use Bearer <token> format\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format - Token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Token abc123\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Use Bearer <token> format\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format - no prefix\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"abc123\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Use Bearer <token> format\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"valid authorization header with valid token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n\t\t\t\t\tType:  \"PUBLIC KEY\",\n\t\t\t\t\tBytes: publicKeyBytes,\n\t\t\t\t})\n\n\t\t\t\tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n\t\t\t\tam, err := NewAuthManager()\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\ttoken := createTestTokenForMiddleware(t, privateKey)\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+token)\n\t\t\t},\n\t\t\texpectedStatus: http.StatusOK,\n\t\t\texpectedError:  \"\",\n\t\t\tshouldSetClaim: true,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid token format\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer invalid.token.format\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Invalid token\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"expired token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\