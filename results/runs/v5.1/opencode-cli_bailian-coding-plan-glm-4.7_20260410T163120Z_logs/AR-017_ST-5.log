n tokenString\n}\n\nfunc TestAuthMiddleware_ErrorCases(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\tam := setupTestAuthManager(t)\n\n\tmiddleware := AuthMiddleware(am)\n\n\ttests := []struct {\n\t\tname           string\n\t\tsetupRequest   func(*http.Request)\n\t\texpectedStatus int\n\t\texpectedError  string\n\t\tshouldSetClaim bool\n\t}{\n\t\t{\n\t\t\tname: \"missing authorization header\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Missing Authorization header\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format - Basic\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Basic dGVzdDp0ZXN0\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Use Bearer <token> format\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format - Token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Token abc123\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Use Bearer <token> format\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid authorization format - no prefix\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"abc123\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Use Bearer <token> format\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"valid authorization header with valid token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n\t\t\t\t\tType:  \"PUBLIC KEY\",\n\t\t\t\t\tBytes: publicKeyBytes,\n\t\t\t\t})\n\n\t\t\t\tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n\t\t\t\t_, err = NewAuthManager()\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\ttoken := createTestTokenForMiddleware(t, privateKey)\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+token)\n\t\t\t},\n\t\t\texpectedStatus: http.StatusOK,\n\t\t\texpectedError:  \"\",\n\t\t\tshouldSetClaim: true,\n\t\t},\n\t\t{\n\t\t\tname: \"invalid token format\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer invalid.token.format\")\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Invalid token\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"expired token\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n\t\t\t\t\tType:  \"PUBLIC KEY\",\n\t\t\t\t\tBytes: publicKeyBytes,\n\t\t\t\t})\n\n\t\t\t\tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n\t\t\t\t_, err = NewAuthManager()\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\tclaims := AuthClaims{\n\t\t\t\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\t\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now().Add(-2 * time.Hour)),\n\t\t\t\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(-1 * time.Hour)),\n\t\t\t\t\t},\n\t\t\t\t}\n\n\t\t\t\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\t\t\t\ttokenString, err := token.SignedString(privateKey)\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+tokenString)\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Invalid token\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"token with wrong signature\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\twrongKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\ttoken := createTestTokenForMiddleware(t, wrongKey)\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+token)\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Invalid token\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t\t{\n\t\t\tname: \"token with wrong signing algorithm (HS256)\",\n\t\t\tsetupRequest: func(req *http.Request) {\n\t\t\t\tclaims := AuthClaims{\n\t\t\t\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\t\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now()),\n\t\t\t\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),\n\t\t\t\t\t},\n\t\t\t\t}\n\n\t\t\t\ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n\t\t\t\tsecret := []byte(\"test-secret\")\n\t\t\t\ttokenString, err := token.SignedString(secret)\n\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+tokenString)\n\t\t\t},\n\t\t\texpectedStatus: http.StatusUnauthorized,\n\t\t\texpectedError:  \"Invalid token\",\n\t\t\tshouldSetClaim: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\trouter := gin.New()\n\t\t\trouter.Use(middleware)\n\t\t\trouter.GET(\"/test\", func(c *gin.Context) {\n\t\t\t\tclaims, exists := c.Get(\"claims\")\n\t\t\t\tif tt.shouldSetClaim {\n\t\t\t\t\trequire.True(t, exists)\n\t\t\t\t\trequire.NotNil(t, claims)\n\t\t\t\t}\n\t\t\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n\t\t\t})\n\n\t\t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n\t\t\ttt.setupRequest(req)\n\n\t\t\tw := httptest.NewRecorder()\n\t\t\trouter.ServeHTTP(w, req)\n\n\t\t\tassert.Equal(t, tt.expectedStatus, w.Code)\n\t\t\tbody := w.Body.String()\n\t\t\tif tt.expectedError != \"\" {\n\t\t\t\tassert.Contains(t, body, tt.expectedError)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAuthMiddleware_ClaimsInContext(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\tam := setupTestAuthManager(t)\n\n\tmiddleware := AuthMiddleware(am)\n\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: publicKeyBytes,\n\t})\n\n\tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n\tam, err = NewAuthManager()\n\trequire.NoError(t, err)\n\n\ttoken := createTestTokenForMiddleware(t, privateKey)\n\n\trouter := gin.New()\n\trouter.Use(middleware)\n\trouter.GET(\"/test\", func(c *gin.Context) {\n\t\tclaims, exists := c.Get(\"claims\")\n\t\trequire.True(t, exists)\n\t\trequire.NotNil(t, claims)\n\n\t\tauthClaims, ok := claims.(*AuthClaims)\n\t\trequire.True(t, ok)\n\t\trequire.NotNil(t, authClaims)\n\n\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n\t})\n\n\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n\treq.Header.Set(HeaderAuthorization, \"Bearer \"+token)\n\n\tw := httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n}\n\nfunc TestAuthMiddleware_BodySizeLimit(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\tam := setupTestAuthManager(t)\n\n\tmiddleware := AuthMiddleware(am)\n\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: publicKeyBytes,\n\t})\n\n\tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n\tam, err = NewAuthManager()\n\trequire.NoError(t, err)\n\n\ttoken := createTestTokenWithPrivateKey(t, privateKey)\n\n\trouter := gin.New()\n\trouter.Use(middleware)\n\trouter.POST(\"/test\", func(c *gin.Context) {\n\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n\t})\n\n\tlargeBody := strings.Repeat(\"x\", MaxBodySize+1)\n\treq := httptest.NewRequest(http.MethodPost, \"/test\", strings.NewReader(largeBody))\n\treq.Header.Set(HeaderAuthorization, \"Bearer \"+token)\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\n\tw := httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusRequestEntityTooLarge, w.Code)\n}\n\nfunc TestAuthMiddleware_ClockSkewTolerance(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: publicKeyBytes,\n\t})\n\n\tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n\tam, err := NewAuthManager()\n\trequire.NoError(t, err)\n\n\tclaims := AuthClaims{\n\t\tRegisteredClaims: jwt.RegisteredClaims{\n\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now().Add(-59 * time.Second)),\n\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Second)),\n\t\t},\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, err := token.SignedString(privateKey)\n\trequire.NoError(t, err)\n\n\tmiddleware := AuthMiddleware(am)\n\n\trouter := gin.New()\n\trouter.Use(middleware)\n\trouter.GET(\"/test\", func(c *gin.Context) {\n\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n\t})\n\n\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n\treq.Header.Set(HeaderAuthorization, \"Bearer \"+tokenString)\n\n\tw := httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n}\n\nfunc TestAuthMiddleware_RequestAbortedOnError(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\tam := setupTestAuthManager(t)\n\n\tmiddleware := AuthMiddleware(am)\n\n\thandlerCalled := false\n\trouter := gin.New()\n\trouter.Use(middleware)\n\trouter.GET(\"/test\", func(c *gin.Context) {\n\t\thandlerCalled = true\n\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n\t})\n\n\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n\n\tw := httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusUnauthorized, w.Code)\n\tassert.False(t, handlerCalled)\n\tassert.Contains(t, w.Body.String(), \"Missing Authorization header\")\n}\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/middleware_test.go","time":{"start":1775861216029,"end":1775861216223}}}}
