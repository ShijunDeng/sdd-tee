)\n</content>","metadata":{"preview":"{{- if and .Values.controllerManager.enabled .Values.controllerManager.rbac.create }}\napiVersion: rbac.authorization.k8s.io/v1\nkind: Role\nmetadata:\n  name: {{ include \"agentcube.fullname\" . }}\n  namespace: {{ include \"agentcube.namespace\" . }}\n  labels:\n    {{- include \"agentcube.labels\" . | nindent 4 }}\n    app.kubernetes.io/component: controller-manager\nrules:\n{{- if .Values.controllerManager.rbac.rules }}\n{{- toYaml .Values.controllerManager.rbac.rules | nindent 2 }}\n{{- else }}\n  []\n{{- end }}\n---\napiVersion: rbac.authorization.k8s.io/v1\nkind: RoleBinding\nmetadata:\n  name: {{ include \"agentcube.fullname\" . }}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/manifests/charts/agentcube/templates/controller-manager/rbac.yaml","time":{"start":1775882215226,"end":1775882215248}}}}
