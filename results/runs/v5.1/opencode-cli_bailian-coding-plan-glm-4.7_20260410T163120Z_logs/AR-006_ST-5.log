ndboxBySessionID\", mock.Anything, \"missing-session\")\n}\n\nfunc TestGarbageCollector_StartStop(t *testing.T) {\n\tmockStore := &mockStoreForGC{}\n\tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n\tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n\n\tscheme := runtime.NewScheme()\n\tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n\tgc := NewGarbageCollector(fakeDynamicClient, mockStore, 100*time.Millisecond)\n\n\tgc.Start()\n\n\ttime.Sleep(250 * time.Millisecond)\n\n\tgc.Stop()\n\n\ttime.Sleep(50 * time.Millisecond)\n\tassert.True(t, true, \"GC stopped without panic\")\n}\n\nfunc TestGarbageCollector_Tick_ListInactiveError(t *testing.T) {\n\tmockStore := &mockStoreForGC{}\n\tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n\tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n\n\tscheme := runtime.NewScheme()\n\tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n\tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n\n\tgc.tick()\n\n\tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n\tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n}\n\nfunc TestGarbageCollector_Tick_ListExpiredError(t *testing.T) {\n\tmockStore := &mockStoreForGC{}\n\tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n\tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n\n\tscheme := runtime.NewScheme()\n\tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n\tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n\n\tgc.tick()\n\n\tmockStore.AssertCalled(t, \"ListInactiveSandboxes\",