tore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n44: \targs := m.Called(ctx, sessionID, info)\n45: \treturn args.Error(0)\n46: }\n47: \n48: func (m *mockStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n49: \targs := m.Called(ctx, sessionID, info)\n50: \treturn args.Error(0)\n51: }\n52: \n53: func (m *mockStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n54: \targs := m.Called(ctx, sessionID)\n55: \treturn args.Error(0)\n56: }\n57: \n58: func (m *mockStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n59: \targs := m.Called(ctx)\n60: \treturn args.Get(0).(map[string]*types.SandboxInfo), args.Error(1)\n61: }\n62: \n63: func (m *mockStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n64: \targs := m.Called(ctx, sessionID, at)\n65: \treturn args.Error(0)\n66: }\n67: \n68: func (m *mockStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n69: \targs := m.Called(ctx, before, limit)\n70: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n71: }\n72: \n73: func (m *mockStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n74: \targs := m.Called(ctx, before, limit)\n75: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n76: }\n77: \n78: func (m *mockStore) Close() error {\n79: \targs := m.Called()\n80: \treturn args.Error(0)\n81: }\n82: \n83: func buildUnstructuredSandbox(name, namespace string) *unstructured.Unstructured {\n84: \treturn &unstructured.Unstructured{\n85: \t\tObject: map[string]interface{}{\n86: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n87: \t\t\t\"kind\":       \"Sandbox\",\n88: \t\t\t\"metadata\": map[string]interface{}{\n89: \t\t\t\t\"name\":      name,\n90: \t\t\t\t\"namespace\": namespace,\n91: \t\t\t\t\"labels\": map[string]interface{}{\n92: \t\t\t\t\t\"runtime.agentcube.io/session-id\": \"test-session\",\n93: \t\t\t\t},\n94: \t\t\t},\n95: \t\t},\n96: \t}\n97: }\n98: \n99: func buildUnstructuredSandboxClaim(name, namespace string) *unstructured.Unstructured {\n100: \treturn &unstructured.Unstructured{\n101: \t\tObject: map[string]interface{}{\n102: \t\t\t\"apiVersion\": \"extensions.agents.x-k8s.io/v1alpha1\",\n103: \t\t\t\"kind\":       \"SandboxClaim\",\n104: \t\t\t\"metadata\": map[string]interface{}{\n105: \t\t\t\t\"name\":      name,\n106: \t\t\t\t\"namespace\": namespace,\n107: \t\t\t},\n108: \t\t},\n109: \t}\n110: }\n111: \n112: func TestHandleDeleteSandbox_Success(t *testing.T) {\n113: \tgin.SetMode(gin.TestMode)\n114: \n115: \tsessionID := \"test-session-123\"\n116: \tsandboxInfo := &types.SandboxInfo{\n117: \t\tSessionID:        sessionID,\n118: \t\tSandboxID:        \"test-sandbox-abc\",\n119: \t\tSandboxName:      \"test-sandbox\",\n120: \t\tSandboxNamespace: \"default\",\n121: \t\tKind:             \"Sandbox\",\n122: \t}\n123: \n124: \tmockStore := &mockStore{}\n125: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n126: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n127: \n128: \tscheme := runtime.NewScheme()\n129: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n130: \n131: \tsandboxObj := buildUnstructuredSandbox(sandboxInfo.SandboxID, sandboxInfo.SandboxNamespace)\n132: \tfakeDynamicClient.Resource(schema.GroupVersionResource{\n133: \t\tGroup:    \"agents.x-k8s.io\",\n134: \t\tVersion:  \"v1alpha1\",\n135: \t\tResource: \"sandboxes\",\n136: \t}).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n137: \n138: \thandler := NewSandboxHandler(fakeDynamicClient, mockStore)\n139: \n140: \tw := httptest.NewRecorder()\n141: \tc, _ := gin.CreateTestContext(w)\n142: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\"+sessionID, nil)\n143: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n144: \n145: \thandler.HandleDeleteSandbox(c)\n146: \n147: \tassert.Equal(t, http.StatusOK, w.Code)\n148: \tvar resp wmTypes.DeleteSandboxResponse\n149: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n150: \tassert.Equal(t, \"Sandbox deleted successfully\", resp.Message)\n151: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, sessionID)\n152: }\n153: \n154: func TestHandleDeleteSandbox_NotFound(t *testing.T) {\n155: \tgin.SetMode(gin.TestMode)\n156: \n157: \tsessionID := \"non-existent-session\"\n158: \tmockStore := &mockStore{}\n159: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(nil, store.ErrNotFound)\n160: \n161: \thandler := NewSandboxHandler(nil, mockStore)\n162: \n163: \tw := httptest.NewRecorder()\n164: \tc, _ := gin.CreateTestContext(w)\n165: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\"+sessionID, nil)\n166: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n167: \n168: \thandler.HandleDeleteSandbox(c)\n169: \n170: \tassert.Equal(t, http.StatusNotFound, w.Code)\n171: \tvar resp map[string]interface{}\n172: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n173: \tassert.Contains(t, resp[\"error\"], sessionID)\n174: \tassert.Contains(t, resp[\"error\"], \"not found\")\n175: }\n176: \n177: func TestHandleDeleteSandbox_EmptySessionID(t *testing.T) {\n178: \tgin.SetMode(gin.TestMode)\n179: \n180: \tmockStore := &mockStore{}\n181: \thandler := NewSandboxHandler(nil, mockStore)\n182: \n183: \tw := httptest.NewRecorder()\n184: \tc, _ := gin.CreateTestContext(w)\n185: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\", nil)\n186: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: \"\"}}\n187: \n188: \thandler.HandleDeleteSandbox(c)\n189: \n190: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n191: \tvar resp map[string]interface{}\n192: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n193: \tassert.Contains(t, resp[\"error\"], \"sessionId is required\")\n194: }\n195: \n196: func TestHandleDeleteSandbox_SandboxClaim(t *testing.T) {\n197: \tgin.SetMode(gin.TestMode)\n198: \n199: \tsessionID := \"test-session-claim\"\n200: \tsandboxInfo := &types.SandboxInfo{\n201: \t\tSessionID:        sessionID,\n202: \t\tSandboxID:        \"test-claim-abc\",\n203: \t\tSandboxName:      \"test-claim\",\n204: \t\tSandboxNamespace: \"default\",\n205: \t\tKind:             \"SandboxClaim\",\n206: \t}\n207: \n208: \tmockStore := &mockStore{}\n209: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n210: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n211: \n212: \tscheme := runtime.NewScheme()\n213: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n214: \n215: \tclaimObj := buildUnstructuredSandboxClaim(sandboxInfo.SandboxID, sandboxInfo.SandboxNamespace)\n216: \tfakeDynamicClient.Resource(schema.GroupVersionResource{\n217: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n218: \t\tVersion:  \"v1alpha1\",\n219: \t\tResource: \"sandboxclaims\",\n220: \t}).Namespace(\"default\").Create(context.Background(), claimObj, metav1.CreateOptions{})\n221: \n222: \thandler := NewSandboxHandler(fakeDynamicClient, mockStore)\n223: \n224: \tw := httptest.NewRecorder()\n225: \tc, _ := gin.CreateTestContext(w)\n226: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/code-interpreter/sessions/\"+sessionID, nil)\n227: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n228: \n229: \thandler.HandleDeleteSandbox(c)\n230: \n231: \tassert.Equal(t, http.StatusOK, w.Code)\n232: \t_, err := fakeDynamicClient.Resource(schema.GroupVersionResource{\n233: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n234: \t\tVersion:  \"v1alpha1\",\n235: \t\tResource: \"sandboxclaims\",\n236: \t}).Namespace(\"default\").Get(context.Background(), sandboxInfo.SandboxID, metav1.GetOptions{})\n237: \tassert.True(t, apierrors.IsNotFound(err))\n238: }\n239: \n240: func TestHandleDeleteSandbox_StoreError(t *testing.T) {\n241: \tgin.SetMode(gin.TestMode)\n242: \n243: \tsessionID := \"test-session\"\n244: \tmockStore := &mockStore{}\n245: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(nil, assert.AnError)\n246: \n247: \thandler := NewSandboxHandler(nil, mockStore)\n248: \n249: \tw := httptest.NewRecorder()\n250: \tc, _ := gin.CreateTestContext(w)\n251: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\"+sessionID, nil)\n252: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n253: \n254: \thandler.HandleDeleteSandbox(c)\n255: \n256: \tassert.Equal(t, http.StatusInternalServerError, w.Code)\n257: \tvar resp map[string]interface{}\n258: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n259: \tassert.Contains(t, resp[\"error\"], \"internal server error\")\n260: }\n\n(End of file - total 260 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic/fake\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/handler/sandbox_test.go","time":{"start":1775845275046,"end":1775845275072}}}}
