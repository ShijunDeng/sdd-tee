 (m *mockStoreForGC) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n\targs := m.Called(ctx, before, limit)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n}\n\nfunc (m *mockStoreForGC) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n\targs := m.Called(ctx, before, limit)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n}\n\nfunc (m *mockStoreForGC) Close() error {\n\targs := m.Called()\n\treturn args.Error(0)\n}\n\nfunc buildUnstructuredSandboxForGC(name, namespace string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n\t\t\t\"kind\":       \"Sandbox\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      name,\n\t\t\t\t\"namespace\": namespace,\n\t\t\t\t\"labels\": map[string]interface{}{\n\t\t\t\t\t\"runtime.agentcube.io/session-id\": \"test-session\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc TestGarbageCollector_Tick_IdleSandboxes(t *testing.T) {\n\tmockStore := &mockStoreForGC{}\n\tidleSandboxes := []*types.SandboxInfo{\n\t\t{\n\t\t\tSessionID:        \"idle-session-1\",\n\t\t\tSandboxID:        \"idle-sandbox-1\",\n\t\t\tSandboxNamespace: \"default\",\n\t\t\tKind:             \"Sandbox\",\n\t\t},\n\t}\n\tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return(idleSandboxes, nil)\n\tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\").Return(nil)\n\n\tscheme := runtime.NewScheme()\n\tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n\tsandboxObj := buildUnstructuredSandboxForGC(\"idle-sandbox-1\", \"default\")\n\tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n\n\tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n\n\tgc.tick()\n\n\tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n\tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\")\n}\n\nfunc TestGarbageCollector_Tick_ExpiredSandboxes(t *testing.T) {\n\tmockStore := &mockStoreForGC{}\n\texpiredSandboxes := []*types.SandboxInfo{\n\t\t{\n\t\t\tSessionID:        \"expired-session-1\",\n\t\t\tSandboxID:        \"expired-sandbox-1\",\n\t\t\tSandboxNamespace: \"default\",\n\t\t\tKind:             \"Sandbox\",\n\t\t},\n\t}\n\tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return(expiredSandboxes, nil)\n\tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\").Return(nil)\n\n\tscheme := runtime.NewScheme()\n\tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n\tsandboxObj := buildUnstructuredSandboxForGC(\"expired-sandbox-1\", \"default\")\n\tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n\n\tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n\n\tgc.tick()\n\n\tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n\tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\")\n}\n\nfunc TestGarbageCollector_Tick_KubernetesNotFound(t *testing.T) {\n\tmockStore := &mockStoreForGC{}\n\tsandboxInfo := &types.SandboxInfo{\n\t\tSessionID:        \"missing-session\",\n\t\tSandboxID:        \"missing-sandbox\",\n\t\tSandboxNamespace: \"default\",\n\t\tKind:             \"Sandbox\",\n\t}\n\tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{sandboxInfo}, nil)\n\tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\").Return(nil)\n\n\tscheme := runtime.NewScheme()\n\tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n\tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n\n\tgc.tick()\n\n\tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\")\n}\n\nfunc TestGarbageCollector_StartStop(t *testing.T) {\n\tmockStore := &mockStoreForGC{}\n\tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n\tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n\n\tscheme := runtime.NewScheme()\n\tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n\tgc := NewGarbageCollector(fakeDynamicClient, mockStore, 100*time.Millisecond)\n\n\tgc.Start()\n\n\ttime.Sleep(250 * time.Millisecond)\n\n\tgc.Stop()\n\n\ttime.Sleep(50 * time.Millisecond)\n\tassert.True(t, true, \"GC stopped without panic\")\n}\n\nfunc TestGarbageCollector_Tick_ListInactiveError(t *testing.T) {\n\tmockStore := &mockStoreForGC{}\n\tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n\tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n\n\tscheme := runtime.NewScheme()\n\tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n\tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n\n\tgc.tick()\n\n\tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n\tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n}\n\nfunc TestGarbageCollector_Tick_ListExpiredError(t *testing.T) {\n\tmockStore := &mockStoreForGC{}\n\tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n\tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n\n\tscheme := runtime.NewScheme()\n\tfakeDynamicClient := fa