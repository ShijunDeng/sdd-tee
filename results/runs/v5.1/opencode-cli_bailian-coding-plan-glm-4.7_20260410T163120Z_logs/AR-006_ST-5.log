ror, http.StatusInternalServerError, err.Error())\n44: \t\treturn\n45: \t}\n46: \n47: \tapi.JSON(c, http.StatusOK, resp)\n48: }\n49: \n50: func (h *Handler) CreateCodeInterpreterSandbox(c *gin.Context) {\n51: \tvar req api.CreateSandboxRequest\n52: \tif err := c.ShouldBindJSON(&req); err != nil {\n53: \t\tapi.Error(c, http.StatusBadRequest, http.StatusBadRequest, \"Invalid request body\")\n54: \t\treturn\n55: \t}\n56: \n57: \treq.Kind = types.CodeInterpreterKind\n58: \n59: \tif err := (&types.CreateSandboxRequest{\n60: \t\tKind:      req.Kind,\n61: \t\tName:      req.Name,\n62: \t\tNamespace: req.Namespace,\n63: \t}).Validate(); err != nil {\n64: \t\tapi.Error(c, http.StatusBadRequest, http.StatusBadRequest, err.Error())\n65: \t\treturn\n66: \t}\n67: \n68: \tresp, err := h.controller.CreateCodeInterpreterSandbox(c.Request.Context(), &req)\n69: \tif err != nil {\n70: \t\tapi.Error(c, http.StatusInternalServerError, http.StatusInternalServerError, err.Error())\n71: \t\treturn\n72: \t}\n73: \n74: \tapi.JSON(c, http.StatusOK, resp)\n75: }\n76: \n77: func (h *Handler) GetSession(c *gin.Context) {\n78: \tsessionID := c.Param(\"sessionId\")\n79: \n80: \tresp, err := h.controller.GetSession(c.Request.Context(), sessionID)\n81: \tif err != nil {\n82: \t\tapi.Error(c, http.StatusNotFound, http.StatusNotFound, err.Error())\n83: \t\treturn\n84: \t}\n85: \n86: \tapi.JSON(c, http.StatusOK, resp)\n87: }\n88: \n89: func (h *Handler) DeleteSession(c *gin.Context) {\n90: \tsessionID := c.Param(\"sessionId\")\n91: \n92: \tresp, err := h.controller.DeleteSession(c.Request.Context(), sessionID)\n93: \tif err != nil {\n94: \t\tapi.Error(c, http.StatusNotFound, http.StatusNotFound, err.Error())\n95: \t\treturn\n96: \t}\n97: \n98: \tapi.JSON(c, http.StatusOK, resp)\n99: }\n100: \n101: func (h *Handler) Health(c *gin.Context) {\n102: \tc.JSON(http.StatusOK, gin.H{\n103: \t\t\"status\": \"healthy\",\n104: \t})\n105: }\n\n(End of file - total 105 lines)\n</content>","metadata":{"preview":"pac