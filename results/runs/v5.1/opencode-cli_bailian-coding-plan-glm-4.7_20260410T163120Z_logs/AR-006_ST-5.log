{"type":"tool_use","timestamp":1775845297781,"sessionID":"ses_287604f96ffeaki2IdoYVkEile","part":{"id":"prt_d78a0ce3a0011GxH1PDdQZpuRb","messageID":"msg_d78a09f21001t9C4Hf9o1OIXhh","sessionID":"ses_287604f96ffeaki2IdoYVkEile","type":"tool","tool":"read","callID":"toolu_tool-0a5fc508ef614ed9a6029a192f8ec42a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go</path>\n<type>file</type>\n<content>\n1: package server\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"sync\"\n8: \t\"time\"\n9: \n10: \t\"github.com/gin-gonic/gin\"\n11: \t\"k8s.io/client-go/rest\"\n12: \t\"k8s.io/klog/v2\"\n13: \n14: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n15: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n16: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/client\"\n17: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/config\"\n18: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/controller\"\n19: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n20: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/middleware\"\n21: )\n22: \n23: type Server struct {\n24: \tconfig           *config.Config\n25: \trouter           *gin.Engine\n26: \tserver           *http.Server\n27: \tk8sClient        *client.K8sClient\n28: \tstore            store.Store\n29: \tcontroller       *controller.SandboxController\n30: \tgarbageCollector *workloadmanager.GarbageCollector\n31: \twg               sync.WaitGroup\n32: \tctx              context.Context\n33: \tcancel           context.CancelFunc\n34: }\n35: \n36: func NewServer(cfg *config.Config) (*Server, error) {\n37: \tk8sConfig, err := rest.InClusterConfig()\n38: \tif err != nil {\n39: \t\treturn nil, fmt.Errorf(\"failed to get in-cluster config: %w\", err)\n40: \t}\n41: \n42: \tk8sConfig.QPS = float32(cfg.K8s.QPS)\n43: \tk8sConfig.Burst = cfg.K8s.Burst\n44: \n45: \tk8sClient, err := client.NewK8sClient(k8sConfig)\n46: \tif err != nil {\n47: \t\treturn nil, fmt.Errorf(\"failed to create k8s client: %w\", err)\n48: \t}\n49: \n50: \tredisStore, err := store.NewValkeyStore(cfg.Redis.Addr, cfg.Redis.Password, cfg.Redis.DB)\n51: \tif err != nil {\n52: \t\treturn nil, fmt.Errorf(\"failed to create redis store: %w\", err)\n53: \t}\n54: \n55: \tsandboxController := controller.NewSandboxController(k8sClient, redisStore)\n56: \n57: \th := handler.NewHandler(sandboxController)\n58: \tsandboxHandler := handler.NewSandboxHandler(k8sClient.GetDynamicClient(), redisStore)\n59: \n60: \tgin.SetMode(gin.ReleaseMode)\n61: \trouter := gin.New()\n62: \n63: \trouter.Use(middleware.RecoveryMiddleware())\n64: \trouter.Use(middleware.LoggingMiddleware())\n65: \trouter.Use(middleware.CORSMiddleware())\n66: \n67: \tapiGroup := router.Group(\"/v1\")\n68: \t{\n69: \t\tapiGroup.POST(\"/agent-runtime\", h.CreateAgentRuntimeSandbox)\n70: \t\tapiGroup.POST(\"/code-interpreter\", h.CreateCodeInterpreterSandbox)\n71: \t\tapiGroup.GET(\"/sessions/:sessionId\", h.GetSession)\n72: \t\tapiGroup.DELETE(\"/agent-runtime/sessions/:sessionId\", sandboxHandler.HandleDeleteSandbox)\n73: \t\tapiGroup.DELETE(\"/code-interpreter/sessions/:sessionId\", sandboxHandler.HandleDeleteSandbox)\n74: \t}\n75: \n76: \trouter.GET(\"/health\", h.Health)\n77: \n78: \tctx, cancel := context.WithCancel(context.Background())\n79: \n80: \tdynamicClient := k8sClient.GetDynamicClient()\n81: \tgc := workloadmanager.NewGarbageCollector(dynamicClient, redisStore, workloadmanager.GCInterval)\n82: \n83: \tsrv := &http.Server{\n84: \t\tAddr:         fmt.Sprintf(\"%s:%s\", cfg.Server.Host, cfg.Server.Port),\n85: \t\tHandler:      router,\n86: \t\tReadTimeout:  cfg.Server.ReadTimeout,\n87: \t\tWriteTimeout: cfg.Server.WriteTimeout,\n88: \t\tIdleTimeout:  cfg.Server.IdleTimeout,\n89: \t}\n90: \n91: \treturn &Server{\n92: \t\tconfig:           cfg,\n93: \t\trouter:           router,\n94: \t\tserver:           srv,\n95: \t\tk8sClient:        k8sClient,\n96: \t\tstore:            redisStore,\n97: \t\tcontroller:       sandboxController,\n98: \t\tgarbageCollector: gc,\n99: \t\tctx:              ctx,\n100: \t\tcancel:           cancel,\n101: \t}, nil\n102: }\n103: \n104: func (s *Server) Start() error {\n105: \ts.garbageCollector.Start()\n106: \n107: \ts.wg.Add(1)\n108: \tgo func() {\n109: \t\tdefer s.wg.Done()\n110: \t\tklog.Infof(\"Starting server on %s\", s.server.Addr)\n111: \t\tif err := s.server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n112: \t\t\tklog.Errorf(\"Server error: %v\", err)\n113: \t\t}\n114: \t}()\n115: \n116: \treturn nil\n117: }\n118: \n119: func (s *Server) Stop() error {\n120: \tklog.Info(\"Shutting down server...\")\n121: \n122: \tif err := s.server.Shutdown(s.ctx); err != nil {\n123: \t\tklog.Errorf(\"Server shutdown error: %v\", err)\n124: \t}\n125: \n126: \ts.garbageCollector.Stop()\n127: \ts.cancel()\n128: \ts.wg.Wait()\n129: \n130: \tif err := s.store.Close(); err != nil {\n131: \t\tklog.Errorf(\"Store close error: %v\", err)\n132: \t}\n133: \n134: \tklog.Info(\"Server stopped\")\n135: \treturn nil\n136: }\n137: \n138: func (s *Server) runGarbageCollector() {\n139: \tticker := time.NewTicker(s.config.Session.CleanupInterval)\n140: \tdefer ticker.Stop()\n141: \n142: \tfor {\n143: \t\tselect {\n144: \t\tcase <-s.ctx.Done():\n145: \t\t\treturn\n146: \t\tcase <-ticker.C:\n147: \t\t\ts.cleanupExpiredSessions()\n148: \t\t\ts.cleanupInactiveSessions()\n149: \t\t}\n150: \t}\n151: }\n152: \n153: func (s *Server) cleanupExpiredSessions() {\n154: \tctx, cancel := context.WithTimeout(s.ctx, 2*time.Minute)\n155: \tdefer cancel()\n156: \n157: \tsandboxes, err := s.store.ListExpiredSandboxes(ctx, time.Now(), 16)\n158: \tif err != nil {\n159: \t\tklog.Errorf(\"Failed to list expired sessions: %v\", err)\n160: \t\treturn\n161: \t}\n162: \n163: \tfor _, sb := range sandboxes {\n164: \t\tklog.Infof(\"Cleaning up expired session %s\", sb.SessionID)\n165: \t\ts.k8sClient.DeleteSandbox(ctx, sb.Namespace, sb.SandboxName)\n166: \t\ts.store.DeleteSandboxBySessionID(ctx, sb.SessionID)\n167: \t}\n168: }\n169: \n170: func (s *Server) cleanupInactiveSessions() {\n171: \tctx, cancel := context.WithTimeout(s.ctx, 2*time.Minute)\n172: \tdefer cancel()\n173: \n174: \tinactiveThreshold := time.Now().Add(-15 * time.Minute)\n175: \tsandboxes, err := s.store.ListInactiveSandboxes(ctx, inactiveThreshold, 16)\n176: \tif err != nil {\n177: \t\tklog.Errorf(\"Failed to list inactive sessions: %v\", err)\n178: \t\treturn\n179: \t}\n180: \n181: \tfor _, sb := range sandboxes {\n182: \t\tklog.Infof(\"Cleaning up inactive session %s\", sb.SessionID)\n183: \t\ts.k8sClient.DeleteSandbox(ctx, sb.Namespace, sb.SandboxName)\n184: \t\ts.store.DeleteSandboxBySessionID(ctx, sb.SessionID)\n185: \t}\n186: }\n187: \n188: func (s *Server) GetRouter() *gin.Engine {\n189: \treturn s.router\n190: }\n\n(End of file - total 190 lines)\n</content>","metadata":{"preview":"package server\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/client\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/config\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/controller\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/middleware\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go","time":{"start":1775845297755,"end":1775