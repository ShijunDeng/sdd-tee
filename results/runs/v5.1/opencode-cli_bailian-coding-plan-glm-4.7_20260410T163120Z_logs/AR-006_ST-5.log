andbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n43: \targs := m.Called(ctx, sessionID, info)\n44: \treturn args.Error(0)\n45: }\n46: \n47: func (m *mockStoreForGC) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n48: \targs := m.Called(ctx, sessionID)\n49: \treturn args.Error(0)\n50: }\n51: \n52: func (m *mockStoreForGC) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n53: \targs := m.Called(ctx)\n54: \treturn args.Get(0).(map[string]*types.SandboxInfo), args.Error(1)\n55: }\n56: \n57: func (m *mockStoreForGC) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n58: \targs := m.Called(ctx, sessionID, at)\n59: \treturn args.Error(0)\n60: }\n61: \n62: func (m *mockStoreForGC) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n63: \targs := m.Called(ctx, before, limit)\n64: \tif args.Get(0) == nil {\n65: \t\treturn nil, args.Error(1)\n66: \t}\n67: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n68: }\n69: \n70: func (m *mockStoreForGC) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n71: \targs := m.Called(ctx, before, limit)\n72: \tif args.Get(0) == nil {\n73: \t\treturn nil, args.Error(1)\n74: \t}\n75: \treturn args.Get(0).([]*types.SandboxInfo), args.Error(1)\n76: }\n77: \n78: func (m *mockStoreForGC) Close() error {\n79: \targs := m.Called()\n80: \treturn args.Error(0)\n81: }\n82: \n83: func buildUnstructuredSandboxForGC(name, namespace string) *runtime.Unstructured {\n84: \treturn &runtime.Unstructured{\n85: \t\tObject: map[string]interface{}{\n86: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n87: \t\t\t\"kind\":       \"Sandbox\",\n88: \t\t\t\"metadata\": map[string]interface{}{\n89: \t\t\t\t\"name\":      name,\n90: \t\t\t\t\"namespace\": namespace,\n91: \t\t\t\t\"labels\": map[string]interface{}{\n92: \t\t\t\t\t\"runtime.agentcube.io/session-id\": \"test-session\",\n93: \t\t\t\t},\n94: \t\t\t},\n95: \t\t},\n96: \t}\n97: }\n98: \n99: func TestGarbageCollector_Tick_IdleSandboxes(t *testing.T) {\n100: \tmockStore := &mockStoreForGC{}\n101: \tidleSandboxes := []*types.SandboxInfo{\n102: \t\t{\n103: \t\t\tSessionID:        \"idle-session-1\",\n104: \t\t\tSandboxID:        \"idle-sandbox-1\",\n105: \t\t\tSandboxNamespace: \"default\",\n106: \t\t\tKind:             \"Sandbox\",\n107: \t\t},\n108: \t}\n109: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return(idleSandboxes, nil)\n110: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\").Return(nil)\n111: \n112: \tscheme := runtime.NewScheme()\n113: \tscheme.AddKnownTypeWithName(schema.GroupVersionKind{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\", Kind: \"Sandbox\"}, &runtime.Unstructured{})\n114: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n115: \n116: \tsandboxObj := buildUnstructuredSandboxForGC(\"idle-sandbox-1\", \"default\")\n117: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n118: \n119: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n120: \n121: \tgc.tick()\n122: \n123: \tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n124: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\")\n125: }\n126: \n127: func TestGarbageCollector_Tick_ExpiredSandboxes(t *testing.T) {\n128: \tmockStore := &mockStoreForGC{}\n129: \texpiredSandboxes := []*types.SandboxInfo{\n130: \t\t{\n131: \t\t\tSessionID:        \"expired-session-1\",\n132: \t\t\tSandboxID:        \"expired-sandbox-1\",\n133: \t\t\tSandboxNamespace: \"default\",\n134: \t\t\tKind:             \"Sandbox\",\n135: \t\t},\n136: \t}\n137: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return(expiredSandboxes, nil)\n138: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\").Return(nil)\n139: \n140: \tscheme := runtime.NewScheme()\n141: \tscheme.AddKnownTypeWithName(schema.GroupVersionKind{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\", Kind: \"Sandbox\"}, &runtime.Unstructured{})\n142: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n143: \n144: \tsandboxObj := buildUnstructuredSandboxForGC(\"expired-sandbox-1\", \"default\")\n145: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n146: \n147: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n148: \n149: \tgc.tick()\n150: \n151: \tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n152: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\")\n153: }\n154: \n155: func TestGarbageCollector_Tick_KubernetesNotFound(t *testing.T) {\n156: \tmockStore := &mockStoreForGC{}\n157: \tsandboxInfo := &types.SandboxInfo{\n158: \t\tSessionID:        \"missing-session\",\n159: \t\tSandboxID:        \"missing-sandbox\",\n160: \t\tSandboxNamespace: \"default\",\n161: \t\tKind:             \"Sandbox\",\n162: \t}\n163: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{sandboxInfo}, nil)\n164: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\").Return(nil)\n165: \n166: \tscheme := runtime.NewScheme()\n167: \tscheme.AddKnownTypeWithName(schema.GroupVersionKind{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\", Kind: \"Sandbox\"}, &runtime.Unstructured{})\n168: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n169: \n170: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n171: \n172: \tgc.tick()\n173: \n174: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\")\n175: }\n176: \n177: func TestGarbageCollector_StartStop(t *testing.T) {\n178: \tmockStore := &mockStoreForGC{}\n179: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n180: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n181: \n182: \tscheme := runtime.NewScheme()\n183: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n184: \n185: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, 100*time.Millisecond)\n186: \n187: \tgc.Start()\n188: \n189: \ttime.Sleep(250 * time.Millisecond)\n190: \n191: \tgc.Stop()\n192: \n193: \ttime.Sleep(50 * time.Millisecond)\n194: \tassert.True(t, true, \"GC stopped without panic\")\n195: }\n196: \n197: func TestGarbageCollector_Tick_ListInactiveError(t *testing.T) {\n198: \tmockStore := &mockStoreForGC{}\n199: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n200: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n201: \n202: \tscheme := runtime.NewScheme()\n203: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n204: \n205: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n206: \n207: \tgc.tick()\n208: \n209: \tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n210: \tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n211: }\n212: \n213: func TestGarbageCollector_Tick_ListExpiredError(t *testing.T) {\n214: \tmockStore := &mockStoreForGC{}\n215: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n216: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n217: \n218: \tscheme := runtime.NewScheme()\n219: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n220: \n221: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n222: \n223: \tgc.tick()\n224: \n225: \tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n226: \tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n227: }\n228: \n229: func TestGarbageCollector_Tick_BothLists(t *testing.T) {\n230: \tmockStore := &mockStoreForGC{}\n231: \tidleSandboxes := []*types.SandboxInfo{\n232: \t\t{\n233: \t\t\tSessionID:        \"idle-session-1\",\n234: \t\t\tSandboxID:        \"idle-sandbox-1\",\n235: \t\t\tSandboxNamespace: \"default\",\n236: \t\t\tKind:             \"Sandbox\",\n237: \t\t},\n238: \t}\n239: \texpiredSandboxes := []*types.SandboxInfo{\n240: \t\t{\n241: \t\t\tSessionID:        \"expired-session-1\",\n242: \t\t\tSandboxID:        \"expired-sandbox-1\",\n243: \t\t\tSandboxNamespace: \"default\",\n244: \t\t\tKind:             \"Sandbox\",\n245: \t\t},\n246: \t}\n247: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return(idleSandboxes, nil)\n248: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\").Return(nil)\n249: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return(expiredSandboxes, nil)\n250: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\").Return(nil)\n251: \n252: \tscheme := runtime.NewScheme()\n253: \tscheme.AddKnownTypeWithName(schema.GroupVersionKind{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\", Kind: \"Sandbox\"}, &runtime.Unstructured{})\n254: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n255: \n256: \tidleObj := buildUnstructuredSandboxForGC(\"idle-sandbox-1\", \"default\")\n257: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), idleObj, metav1.CreateOptions{})\n258: \n259: \texpiredObj := buildUnstructuredSandboxForGC(\"expired-sandbox-1\", \"default\")\n260: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), expiredObj, metav1.CreateOptions{})\n261: \n262: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n263: \n264: \tgc.tick()\n265: \n266: \tmockStore.AssertNumberOfCalls(t, \"DeleteSandboxBySessionID\", 2)\n267: }\n\n(End of file - total 267 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/apimachinery/pkg/runtime/serializer\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype mockStoreForGC struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/garbage_collector_test.go","time":{"start":1775845275048,"end":1775845275067}}}}
