itempty\"`\n33: \tLastActivityAt   time.Time           `json:\"lastActivityAt,omitempty\"`\n34: }\n35: \n36: type SandboxEntryPoint struct {\n37: \tPath     string `json:\"path\"`\n38: \tProtocol string `json:\"protocol\"`\n39: \tEndpoint string `json:\"endpoint\"`\n40: }\n41: \n42: type CreateSandboxRequest struct {\n43: \tKind      string `json:\"kind\"`\n44: \tName      string `json:\"name\"`\n45: \tNamespace string `json:\"namespace\"`\n46: }\n47: \n48: func (car *CreateSandboxRequest) Validate() error {\n49: \tif car.Kind != AgentRuntimeKind && car.Kind != CodeInterpreterKind {\n50: \t\treturn ErrInvalidKind\n51: \t}\n52: \tif car.Name == \"\" {\n53: \t\treturn ErrNameRequired\n54: \t}\n55: \tif car.Namespace == \"\" {\n56: \t\treturn ErrNamespaceRequired\n57: \t}\n58: \treturn nil\n59: }\n60: \n61: type CreateSandboxResponse struct {\n62: \tSessionID   string              `json:\"sessionId\"`\n63: \tSandboxID   string              `json:\"sandboxId\"`\n64: \tSandboxName string              `json:\"sandboxName\"`\n65: \tEntryPoints []SandboxEntryPoint `json:\"entryPoints\"`\n66: }\n67: \n68: type GetSessionRequest struct {\n69: \tSessionID string `uri:\"sessionId\" binding:\"required\"`\n70: }\n71: \n72: type GetSessionResponse struct {\n73: \tSessionID    string              `json:\"sessionId\"`\n74: \tSandboxID    string              `json:\"sandboxId\"`\n75: \tSandboxName  string              `json:\"sandboxName\"`\n76: \tKind         string              `json:\"kind\"`\n77: \tNamespace    string              `json:\"namespace\"`\n78: \tName         string              `json:\"name\"`\n79: \tEntryPoints  []SandboxEntryPoint `json:\"entryPoints\"`\n80: \tLastActivity string              `json:\"lastActivity\"`\n81: \tCreatedAt    string              `json:\"createdAt\"`\n82: \tExpiresAt    string              `json:\"expiresAt\"`\n83: \tPodIP        string              `json:\"podIp,omitempty\"`\n84: }\n85: \n86: type DeleteSessionRequest struct {\n87: \tSessionID string `uri:\"sessionId\" binding:\"required\"`\n88: }\n89: \n90: type DeleteSessionResponse struct {\n91: \tSessionID string `json:\"sessionId\"`\n92: \tDeletedAt string `json:\"deletedAt\"`\n93: }\n94: \n95: type ErrorResponse struct {\n96: \tError string `json:\"error\"`\n97: \tCode  string `json:\"code,omitempty\"`\n98: }\n\n(End of file - total 98 lines)\n</content>","metadata":{"preview":"package types\n\nimport (\n\t\"errors\"\n\t\"time\"\n)\n\nconst (\n\tAgentRuntimeKind    = \"AgentRuntime\"\n\tCodeInterpreterKind = \"CodeInterpreter\"\n)\n\nvar (\n\tErrInvalidKind       = errors.New(\"invalid kind: must be AgentRuntime or CodeInterpreter\")\n\tErrNameRequired      = errors.New(\"name is required\")\n\tErrNamespaceRequired = errors.New(\"namespace is required\")\n)\n\ntype SandboxInfo struct {\n\tKind             string              `json:\"kind\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/common/types/types.go","time":{"start":1775845281930,"end":1775845281963}}}}
