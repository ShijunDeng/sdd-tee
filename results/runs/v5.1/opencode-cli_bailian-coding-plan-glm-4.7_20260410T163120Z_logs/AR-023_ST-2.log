08:59 .sdd_prompt.md\ndrwxr-xr-x  2 root root     4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 session-store\n-rw-r--r--  1 root root    44595 Apr 11 06:21 tasks.md\ndrwxr-xr-x  2 root root     4096 Mar 25 09:51 testing\n-rw-r--r--  1 root root     1983 Mar 25 09:36 test_spec.md\n","metadata":{"output":"total 73768\ndrwxr-xr-x 20 root root     4096 Apr 11 08:24 .\ndrwxr-xr-x 15 root root     4096 Apr 11 05:41 ..\n-rwxr-xr-x  1 root root 43812248 Apr 11 07:12 agentd\ndrwxr-xr-x 25 root root     4096 Apr 11 08:57 changes\ndrwxr-xr-x  2 root root     4096 Mar 21 15:58 ci-cd\ndrwxr-xr-x  2 root root     4096 Mar 21 15:55 cli-toolkit\ndrwxr-xr-x  9 root root     4096 Apr 11 07:55 cmd\ndrwxr-xr-x  2 root root     4096 Mar 21 15:55 code-execution\ndrwxr-xr-x  4 root root     4096 Apr 11 00:47 config\n-rw-r--r--  1 root root    27328 Apr 11 07:48 delta-spec.md\ndrwxr-xr-x  2 root root     4096 Apr 11 00:59 deployment\n-rw-r--r--  1 root root    18533 Apr 11 07:51 design.md\ndrwxr-xr-x  2 root root     4096 Apr 11 01:03 examples\n-rw-r--r--  1 root root     5084 Apr 11 07:33 go.mod\n-rw-r--r--  1 root root    26886 Apr 11 07:33 go.sum\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 idle-cleanup\ndrwxr-xr-x  2 root root     4096 Mar 21 15:58 integrations\n-rwxr-xr-x  1 root root 31422336 Apr 11 06:07 picod\ndrwxr-xr-x 10 root root     4096 Apr 11 07:27 pkg\n-rw-r--r--  1 root root     1674 Mar 21 15:53 project.md\n-rw-r--r--  1 root root     8044 Apr 11 08:59 proposal.md\ndrwxr-xr-x  3 root root     4096 Apr 11 08:01 .pytest_cache\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 python-sdk\ndrwxr-xr-x  3 root root     4096 Apr 11 08:24 .ruff_cache\ndrwxr-xr-x  3 root root     4096 Apr 10 18:18 sandbox-orchestration\n-rw-r--r--  1 root root    59757 Apr 11 08:59 .sdd_prompt.md\ndrwxr-xr-x  2 root root     4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 session-store\n-rw-r--r--  1 root root    44595 Apr 11 06:21 tasks.md\ndrwxr-xr-x  2 root root     4096 Mar 25 09:51 testing\n-rw-r--r--  1 root root     1983 Mar 25 09:36 test_spec.md\n","exit":0,"description":"List directory contents to verify location","truncated":false},"title":"List directory contents to verify location","time":{"start":1775869271244,"end":1775869271333}}}}
