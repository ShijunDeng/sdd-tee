eTestContext(w)\n41: \n42: \t\tdata := map[string]string{\"key\": \"value\"}\n43: \t\tJSON(c, http.StatusOK, data)\n44: \n45: \t\tassert.Equal(t, http.StatusOK, w.Code)\n46: \t\tvar resp map[string]string\n47: \t\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n48: \t\tassert.Equal(t, \"value\", resp[\"key\"])\n49: \t})\n50: }\n\n(End of file - total 50 lines)\n</content>","metadata":{"preview":"package api\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestErrorResponse(t *testing.T) {\n\tt.Run(\"Error\", func(t *testing.T) {\n\t\tw := httptest.NewRecorder()\n\t\tc, _ := gin.CreateTestContext(w)\n\n\t\tError(c, http.StatusBadRequest, http.StatusBadRequest, \"bad request\")\n\n\t\tassert.Equal(t, http.StatusBadRequest, w.Code)\n\t\tvar resp ErrorResponse","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/api/response_test.go","time":{"start":1775842972711,"end":1775842972752}}}}
