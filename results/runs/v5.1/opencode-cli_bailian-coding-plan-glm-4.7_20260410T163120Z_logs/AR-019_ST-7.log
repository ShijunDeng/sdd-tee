preter Kubernetes resources\",\n\t\tLong:    `Command-line tool for managing CodeInterpreter custom resources in Kubernetes.`,\n\t\tVersion: \"0.1.0\",\n\t}\n\n\trootCmd.PersistentFlags().StringVar(&kubeconfig, \"kubeconfig\", \"\", \"Path to the kubeconfig file\")\n\trootCmd.PersistentFlags().StringVarP(&namespace, \"namespace\", \"n\", \"\", \"Namespace scope\")\n\trootCmd.PersistentFlags().StringVarP(&outputFormat, \"output\", \"o\", \"\", \"Output format (json, yaml)\")\n\n\trootCmd.AddCommand(listCmd())\n\trootCmd.AddCommand(getCmd())\n\trootCmd.AddCommand(createCmd())\n\trootCmd.AddCommand(updateCmd())\n\trootCmd.AddCommand(deleteCmd())\n\trootCmd.AddCommand(watchCmd())\n\n\tif err := rootCmd.Execute(); err != nil {\n\t\tcli.HandleError(err)\n\t}\n}\n\nfunc listCmd() *cobra.Command {\n\tvar allNamespaces bool\n\tvar labelSelector string\n\tvar runtimeFilter string\n\n\tcmd := &cobra.Command{\n\t\tUse:     \"list\",\n\t\tAliases: []string{\"ls\"},\n\t\tShort:   \"List CodeInterpreter resources\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\topts := metav1.ListOptions{}\n\t\t\tif labelSelector != \"\" {\n\t\t\t\topts.LabelSelector = labelSelector\n\t\t\t}\n\n\t\t\tlist, err := interpreterClient.List(cmd.Context(), opts)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tfilteredList := list.Items\n\t\t\tif runtimeFilter != \"\" {\n\t\t\t\tfilteredList = make([]runtimev1alpha1.CodeInterpreter, 0)\n\t\t\t\tfor _, item := range list.Items {\n\t\t\t\t\tif item.Spec.Runtime == runtimeFilter {\n\t\t\t\t\t\tfilteredList = append(filteredList, item)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tswitch outputFormat {\n\t\t\tcase cli.OutputFormatJSON, cli.OutputFormatYAML:\n\t\t\t\tfilteredListObj := &runtimev1alpha1.CodeInterpreterList{\n\t\t\t\t\tTypeMeta: list.TypeMeta,\n\t\t\t\t\tListMeta: list.ListMeta,\n\t\t\t\t\tItems:    filteredList,\n\t\t\t\t}\n\t\t\t\tprinter := &cli.PrintOptions{\n\t\t\t\t\tFormat: outputFormat,\n\t\t\t\t\tOutput: os.Stdout,\n\t\t\t\t}\n\t\t\t\tif err := cli.Print(filteredListObj, printer); err != nil {\n\t\t\t\t\tcli.HandleError(err)\n\t\t\t\t}\n\t\t\tdefault:\n\t\t\t\tcli.PrintCodeInterpreterTable(filteredList, os.Stdout)\n\t\t\t}\n\t\t},\n\t}\n\n\tcmd.Flags().BoolVarP(&allNamespaces, \"all-namespaces\", \"A\", false, \"List resources across all namespaces\")\n\tcmd.Flags().StringVarP(&labelSelector, \"selector\", \"l\", \"\", \"Selector (label query) to filter on\")\n\tcmd.Flags().StringVar(&runtimeFilter, \"runtime\", \"\", \"Filter by runtime type\")\n\n\treturn cmd\n}\n\nfunc getCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"get NAME\",\n\t\tShort: \"Get a specific CodeInterpreter resource\",\n\t\tArgs:  cobra.ExactArgs(1),\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreter, err := interpreterClient.Get(cmd.Context(), args[0], metav1.GetOptions{})\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tif outputFormat != \"\" {\n\t\t\t\tprinter := &cli.PrintOptions{\n\t\t\t\t\tFormat: outputFormat,\n\t\t\t\t\tOutput: os.Stdout,\n\t\t\t\t}\n\t\t\t\tif err := cli.Print(interpreter, printer); err != nil {\n\t\t\t\t\tcli.HandleError(err)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tprinter := &cli.PrintOptions{\n\t\t\t\t\tFormat: cli.OutputFormatYAML,\n\t\t\t\t\tOutput: os.Stdout,\n\t\t\t\t}\n\t\t\t\tif err := cli.Print(interpreter, printer); err != nil {\n\t\t\t\t\tcli.HandleError(err)\n\t\t\t\t}\n\t\t\t}\n\t\t},\n\t}\n\n\treturn cmd\n}\n\nfunc createCmd() *cobra.Command {\n\tvar fileName string\n\n\tcmd := &cobra.Command{\n\t\tUse:   \"create -f FILENAME\",\n\t\tShort: \"Create a CodeInterpreter resource from a file\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tif fileName == \"\" {\n\t\t\t\tcmd.Help()\n\t\t\t\tos.Exit(cli.ExitCodeFailure)\n\t\t\t}\n\n\t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tdata, err := os.ReadFile(fileName)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreter := &runtimev1alpha1.CodeInterpreter{}\n\t\t\tif err := yaml.Unmarshal(data, interpreter); err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tcreated, err := interpreterClient.Create(cmd.Context(), interpreter, metav1.CreateOptions{})\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tprinter := &cli.PrintOptions{\n\t\t\t\tFormat: cli.OutputFormatYAML,\n\t\t\t\tOutput: os.Stdout,\n\t\t\t}\n\t\t\tif err := cli.Print(created, printer); err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\t\t},\n\t}\n\n\tcmd.Flags().StringVarP(&fileName, \"filename\", \"f\", \"\", \"Filename to use to create the resource\")\n\n\treturn cmd\n}\n\nfunc updateCmd() *cobra.Command {\n\tvar fileName string\n\n\tcmd := &cobra.Command{\n\t\tUse:   \"update -f FILENAME\",\n\t\tShort: \"Update a CodeInterpreter resource from a file\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tif fileName == \"\" {\n\t\t\t\tcmd.Help()\n\t\t\t\tos.Exit(cli.ExitCodeFailure)\n\t\t\t}\n\n\t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tdata, err := os.ReadFile(fileName)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreter := &runtimev1alpha1.CodeInterpreter{}\n\t\t\tif err := yaml.Unmarshal(data, interpreter); err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tupdated, err := interpreterClient.Update(cmd.Context(), interpreter, metav1.UpdateOptions{})\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tprinter := &cli.PrintOptions{\n\t\t\t\tFormat: cli.OutputFormatYAML,\n\t\t\t\tOutput: os.Stdout,\n\t\t\t}\n\t\t\tif err := cli.Print(updated, printer); err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\t\t},\n\t}\n\n\tcmd.Flags().StringVarP(&fileName, \"filename\", \"f\", \"\", \"Filename to use to update the resource\")\n\n\treturn cmd\n}\n\nfunc deleteCmd() *cobra.Command {\n\tvar force bool\n\n\tcmd := &cobra.Command{\n\t\tUse:   \"delete NAME\",\n\t\tShort: \"Delete a CodeInterpreter resource\",\n\t\tArgs:  cobra.ExactArgs(1),\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tif !force {\n\t\t\t\tif !cli.Confirm(fmt.Sprintf(\"Are you sure you want to delete CodeInterpreter %q?\", args[0])) {\n\t\t\t\t\tfmt.Println(\"Deletion cancelled\")\n\t\t\t\t\tos.Exit(cli.ExitCodeSuccess)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tif err := interpreterClient.Delete(cmd.Context(), args[0], metav1.DeleteOptions{}); err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tfmt.Printf(\"CodeInterpreter %q deleted\\n\", args[0])\n\t\t},\n\t}\n\n\tcmd.Flags().BoolVarP(&force, \"force\", \"\", false, \"Delete without confirmation\")\n\n\treturn cmd\n}\n\nfunc watchCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"watch\",\n\t\tShort: \"Watch CodeInterpreter resources for changes\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\twatcher, err := interpreterClient.Watch(cmd.Context(), metav1.ListOptions{})\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\t\t\tdefer watcher.Stop()\n\n\t\t\tfor event := range watcher.ResultChan() {\n\t\t\t\tinterpreter, ok := event.Object.(*runtimev1alpha1.CodeInterpreter)\n\t\t\t\tif !ok {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tswitch event.Type {\n\t\t\t\tcase watch.Added:\n\t\t\t\t\tfmt.Printf(\"ADDED\\t%s\\n\", interpreter.Name)\n\t\t\t\tcase watch.Modified:\n\t\t\t\t\tfmt.Printf(\"MODIFIED\\t%s\\n\", interpreter.Name)\n\t\t\t\tcase watch.Deleted:\n\t\t\t\t\tfmt.Printf(\"DELETED\\t%s\\n\", interpreter.Name)\n\t\t\t\tcase watch.Error:\n\t\t\t\t\tfmt.Printf(\"ERROR\\t%v\\n\", event.Object)\n\t\t\t\t}\n\t\t\t}\n\t\t},\n\t}\n\n\treturn cmd\n}\n","after":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\n\t\"github.com/spf13/cobra\"\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/cli\"\n\t\"gopkg.in/yaml.v3\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/watch\"\n)\n\nvar (\n\tkubeconfig   string\n\tnamespace    string\n\toutputFormat string\n)\n\nfunc main() {\n\trootCmd := &cobra.Command{\n\t\tUse:     \"code-interpreter\",\n\t\tShort:   \"Manage CodeInterpreter Kubernetes resources\",\n\t\tLong:    `Command-line tool for managing CodeInterpreter custom resources in Kubernetes.`,\n\t\tVersion: \"0.1.0\",\n\t}\n\n\trootCmd.PersistentFlags().StringVar(&kubeconfig, \"kubeconfig\", \"\", \"Path to the kubeconfig file\")\n\trootCmd.PersistentFlags().StringVarP(&namespace, \"namespace\", \"n\", \"\", \"Namespace scope\")\n\trootCmd.PersistentFlags(