atch.Added:\n661: \t\t\t\t\tfmt.Printf(\"ADDED\\t%s\\n\", interpreter.Name)\n662: \t\t\t\tcase watch.Modified:\n663: \t\t\t\t\tfmt.Printf(\"MODIFIED\\t%s\\n\", interpreter.Name)\n664: \t\t\t\tcase watch.Deleted:\n665: \t\t\t\t\tfmt.Printf(\"DELETED\\t%s\\n\", interpreter.Name)\n666: \t\t\t\tcase watch.Error:\n667: \t\t\t\t\tfmt.Printf(\"ERROR\\t%v\\n\", event.Object)\n668: \t\t\t\t}\n669: \t\t\t}\n670: \t\t},\n671: \t}\n672: \n673: \treturn cmd\n674: }\n675: \n676: func completionBashCmd() *cobra.Command {\n677: \tcmd := &cobra.Command{\n678: \t\tUse:   \"bash\",\n679: \t\tShort: \"Generate bash completion script\",\n680: \t\tRun: func(cmd *cobra.Command, args []string) {\n681: \t\t\tcmd.Root().GenBashCompletion(os.Stdout)\n682: \t\t},\n683: \t}\n684: \n685: \treturn cmd\n686: }\n687: \n688: func completionZshCmd() *cobra.Command {\n689: \tcmd := &cobra.Command{\n690: \t\tUse:   \"zsh\",\n691: \t\tShort: \"Generate zsh completion script\",\n692: \t\tRun: func(cmd *cobra.Command, args []string) {\n693: \t\t\tcmd.Root().GenZshCompletion(os.Stdout)\n694: \t\t},\n695: \t}\n696: \n697: \treturn cmd\n698: }\n699: \n700: func completionFishCmd() *cobra.Command {\n701: \tcmd := &cobra.Command{\n702: \t\tUse:   \"fish\",\n703: \t\tShort: \"Generate fish completion script\",\n704: \t\tRun: func(cmd *cobra.Command, args []string) {\n705: \t\t\tcmd.Root().GenFishCompletion(os.Stdout, true)\n706: \t\t},\n707: \t}\n708: \n709: \treturn cmd\n710: }\n711: \n712: func completionPowerShellCmd() *cobra.Command {\n713: \tcmd := &cobra.Command{\n714: \t\tUse:   \"powershell\",\n715: \t\tShort: \"Generate PowerShell completion script\",\n716: \t\tRun: func(cmd *cobra.Command, args []string) {\n717: \t\t\tcmd.Root().GenPowerShellCompletionWithDesc(os.Stdout)\n718: \t\t},\n719: \t}\n720: \n721: \treturn cmd\n722: }\n\n(End of file - total 722 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\n\t\"github.com/spf13/cobra\"\n\truntimev1alpha1 \"github.