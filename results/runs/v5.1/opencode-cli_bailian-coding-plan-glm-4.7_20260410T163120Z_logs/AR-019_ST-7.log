andleError(err)\n\t\t\t}\n\n\t\t\tdata, err := os.ReadFile(fileName)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\truntime := &runtimev1alpha1.AgentRuntime{}\n\t\t\tif err := yaml.Unmarshal(data, runtime); err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tupdated, err := runtimeClient.Update(cmd.Context(), runtime, metav1.UpdateOptions{})\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tprinter := &cli.PrintOptions{\n\t\t\t\tFormat: cli.OutputFormatYAML,\n\t\t\t\tOutput: os.Stdout,\n\t\t\t}\n\t\t\tif err := cli.Print(updated, printer); err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\t\t},\n\t}\n\n\tcmd.Flags().StringVarP(&fileName, \"filename\", \"f\", \"\", \"Filename to use to update the resource\")\n\n\treturn cmd\n}\n\nfunc deleteCmd() *cobra.Command {\n\tvar force bool\n\n\tcmd := &cobra.Command{\n\t\tUse:   \"delete NAME\",\n\t\tShort: \"Delete an AgentRuntime resource\",\n\t\tArgs:  cobra.ExactArgs(1),\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tif !force {\n\t\t\t\tif !cli.Confirm(fmt.Sprintf(\"Are you sure you want to delete AgentRuntime %q?\", args[0])) {\n\t\t\t\t\tfmt.Println(\"Deletion cancelled\")\n\t\t\t\t\tos.Exit(cli.ExitCodeSuccess)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\truntimeClient, err := cli.NewAgentRuntimeClient(client)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tif err := runtimeClient.Delete(cmd.Context(), args[0], metav1.DeleteOptions{}); err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tfmt.Printf(\"AgentRuntime %q deleted\\n\", args[0])\n\t\t},\n\t}\n\n\tcmd.Flags().BoolVarP(&force, \"force\", \"\", false, \"Delete without confirmation\")\n\n\treturn cmd\n}\n\nfunc watchCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"watch\",\n\t\tShort: \"Watch AgentRuntime resources for changes\",\n\t\tRun: func