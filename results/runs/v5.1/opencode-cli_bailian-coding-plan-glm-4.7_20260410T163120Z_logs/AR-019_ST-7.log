eleted\\n\", args[0])\n\t\t},\n\t}\n\n\tcmd.Flags().BoolVarP(&force, \"force\", \"\", false, \"Delete without confirmation\")\n\n\treturn cmd\n}\n\nfunc runtimeWatchCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"watch\",\n\t\tShort: \"Watch AgentRuntime resources for changes\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\truntimeClient, err := cli.NewAgentRuntimeClient(client)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\twatcher, err := runtimeClient.Watch(cmd.Context(), metav1.ListOptions{})\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\t\t\tdefer watcher.Stop()\n\n\t\t\tfor event := range watcher.ResultChan() {\n\t\t\t\truntime, ok := event.Object.(*runtimev1alpha1.AgentRuntime)\n\t\t\t\tif !ok {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tswitch event.Type {\n\t\t\t\tcase watch.Added:\n\t\t\t\t\tfmt.Printf(\"ADDED\\t%s\\n\", runtime.Name)\n\t\t\t\tcase watch.Modified:\n\t\t\t\t\tfmt.Printf(\"MODIFIED\\t%s\\n\", runtime.Name)\n\t\t\t\tcase watch.Deleted:\n\t\t\t\t\tfmt.Printf(\"DELETED\\t%s\\n\", runtime.Name)\n\t\t\t\tcase watch.Error:\n\t\t\t\t\tfmt.Printf(\"ERROR\\t%v\\n\", event.Object)\n\t\t\t\t}\n\t\t\t}\n\t\t},\n\t}\n\n\treturn cmd\n}\n\nfunc interpreterListCmd() *cobra.Command {\n\tvar allNamespaces bool\n\tvar labelSelector string\n\tvar runtimeFilter string\n\n\tcmd := &cobra.Command{\n\t\tUse:     \"list\",\n\t\tAliases: []string{\"ls\"},\n\t\tShort:   \"List CodeInterpreter resources\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n\t\t\tif err != nil {\n\t\t\t\tcli.HandleError(err)\n\t\t\t}\n\n\t\t\topts := metav1.ListOptions{}\n\t\t\tif labelSelector != \"\" {\n\