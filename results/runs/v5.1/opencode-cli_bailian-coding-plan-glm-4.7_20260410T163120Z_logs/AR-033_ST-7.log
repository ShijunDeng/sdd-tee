agentcube\n27: docker-build-agentcube: ## Build agentcube Docker image\n28: \t@echo \"$(BLUE)Building agentcube Docker image...$(NC)\"\n29: \t$(DOCKER) build -t $(DOCKER_REGISTRY)$(IMAGE_NAME):$(IMAGE_TAG) \\\n30: \t\t--build-arg VERSION=$(VERSION) \\\n31: \t\t--build-arg GIT_COMMIT=$(GIT_COMMIT) \\\n32: \t\t--build-arg BUILD_TIME=$(BUILD_TIME) \\\n33: \t\t-f cmd/agentcube/Dockerfile .\n34: \t@$(DOCKER) tag $(DOCKER_REGISTRY)$(IMAGE_NAME):$(IMAGE_TAG) $(DOCKER_REGISTRY)$(IMAGE_NAME):latest\n35: \t@echo \"$(GREEN)âœ“ agentcube Docker image built$(NC)\"\n36: \n37: .PHONY: docker-build-runtime\n38: docker-build-runtime: ## Build agent-runtime Docker image\n39: \t@echo \"$(BLUE)Building agent-runtime Docker image...$(NC)\"\n40: \t$(DOCKER) build -t $(DOCKER_REGISTRY)$(IMAGE_NAME)-runtime:$(IMAGE_TAG) \\\n41: \t\t--build-arg VERSION=$(VERSION) \\\n42: \t\t--build-arg GIT_COMMIT=$(GIT_COMMIT) \\\n43: \t\t--build-arg BUILD_TIME=$(BUILD_TIME) \\\n44: \t\t-f cmd/agent-runtime/Dockerfile .\n45: \t@$(DOCKER) tag $(DOCKER_REGISTRY)$(IMAGE_NAME)-runtime:$(IMAGE_TAG) $(DOCKER_REGISTRY)$(IMAGE_NAME)-runtime:latest\n46: \t@echo \"$(GREEN)âœ“ agent-runtime Docker image built$(NC)\"\n47: \n48: .PHONY: docker-build-builder\n49: docker-build-builder: ## Build builder Docker image\n50: \t@echo \"$(BLUE)Building builder Docker image...$(NC)\"\n51: \t$(DOCKER) build -t $(DOCKER_REGISTRY)$(IMAGE_NAME)-builder:$(IMAGE_TAG) \\\n52: \t\t--build-arg VERSION=$(VERSION) \\\n53: \t\t--build-arg GIT_COMMIT=$(GIT_COMMIT) \\\n54: \t\t--build-arg BUILD_TIME=$(BUILD_TIME) \\\n55: \t\t-f Dockerfile.builder .\n56: \t@$(DOCKER) tag $(DOCKER_REGISTRY)$(IMAGE_NAME)-builder:$(IMAGE_TAG) $(DOCKER_REGISTRY)$(IMAGE_NAME)-builder:latest\n57: \t@echo \"$(GREEN)âœ“ builder Docker image built$(NC)\"\n58: \n59: .PHONY: docker-build-multiarch\n60: docker-build-multiarch: ## Build multi-architecture Docker images\n61: \t@echo \"$(BLUE)Building multi-architecture Docker images...$(NC)\"\n62: \t$(DOCKER) buildx create 