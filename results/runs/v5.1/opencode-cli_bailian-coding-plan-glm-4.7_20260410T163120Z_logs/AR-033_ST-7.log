 tests with verbose output...$(NC)\"\n32: \t@$(GO) test -v -timeout $(TEST_TIMEOUT) ./...\n33: \t@echo \"$(GREEN)âœ“ Go tests passed$(NC)\"\n34: \n35: .PHONY: test-go-cover\n36: test-go-cover: test-go ## Run Go tests and generate coverage report\n37: \t@echo \"$(BLUE)Generating Go coverage report...$(NC)\"\n38: \t@$(GO) tool cover -html=$(GO_TEST_COVERAGE) -o $(GO_TEST_COVERAGE_HTML)\n39: \t@$(GO) tool cover -func=$(GO_TEST_COVERAGE) | tail -n 1\n40: \t@echo \"$(GREEN)âœ“ Coverage report generated at $(GO_TEST_COVERAGE_HTML)$(NC)\"\n41: \n42: .PHONY: test-go-cover-func\n43: test-go-cover-func: ## Show Go test coverage by function\n44: \t@echo \"$(BLUE)Go test coverage by function:$(NC)\"\n45: \t@$(GO) test -coverprofile=$(GO_TEST_COVERAGE) ./...\n46: \t@$(GO) tool cover -func=$(GO_TEST_COVERAGE)\n47: \n48: .PHONY: test-go-bench\n49: test-go-bench: ## Run Go benchmarks\n50: \t@echo \"$(BLUE)Running Go benchmarks...$(NC)\"\n51: \t@$(GO) test -bench=. -benchmem ./...\n52: \t@echo \"$(GREEN)âœ“ Go benchmarks completed$(NC)\"\n53: \n54: .PHONY: test-agentd\n55: test-agentd: ## Run tests for agentd\n56: \t@echo \"$(BLUE)Running agentd tests...$(NC)\"\n57: \t@$(GO) test $(TEST_FLAGS) -timeout $(TEST_TIMEOUT) ./pkg/agentd/...\n58: \t@echo \"$(GREEN)âœ“ agentd tests passed$(NC)\"\n59: \n60: .PHONY: test-picod\n61: test-picod: ## Run tests for picod\n62: \t@echo \"$(BLUE)Running picod tests...$(NC)\"\n63: \t@$(GO) test $(TEST_FLAGS) -timeout $(TEST_TIMEOUT) ./pkg/picod/...\n64: \t@echo \"$(GREEN)âœ“ picod tests passed$(NC)\"\n65: \n66: .PHONY: test-router\n67: test-router: ## Run tests for router\n68: \t@echo \"$(BLUE)Running router tests...$(NC)\"\n69: \t@$(GO) test $(TEST_FLAGS) -timeout $(TEST_TIMEOUT) ./pkg/router/...\n70: \t@echo \"$(GREEN)âœ“ router tests passed$(NC)\"\n71: \n72: .PHONY: test-store\n73: test-store: ## Run tests for store\n74: \t@echo \"$(BLUE)Running store tests...$(NC)\"\n75: \t@$(GO) test $(TEST_FLAGS) -timeout $(TEST_TIMEOUT) ./pkg/store/...\n76: \t@echo \"$(GREEN)âœ“ store tests passed$(NC)\"\n77: \n78: .PHONY: test-cli\n79: test-cli: ## Run tests for CLI\n80: \t@echo \"$(BLUE)Running CLI tests...$(NC)\"\n81: \t@$(GO) test $(TEST_FLAGS) -timeout $(TEST_TIMEOUT) ./pkg/cli/...\n82: \t@echo \"$(GREEN)âœ“ CLI tests passed$(NC)\"\n83: \n84: .PHONY: test-python\n85: test-python: ## Run all Python tests\n86: \t@echo \"$(BLUE)Running Python tests...$(NC)\"\n87: \t@$(PYTHON) -m pytest -v\n88: \t@echo \"$(GREEN)âœ“ Python tests passed$(NC)\"\n89: \n90: .PHONY: test-python-unit\n91: test-python-unit: ## Run Python unit tests only\n92: \t@echo \"$(BLUE)Running Python unit tests...$(NC)\"\n93: \t@$(PYTHON) -m pytest -v -m \"not integration\"\n94: \t@echo \"$(GREEN)âœ“ Python unit tests passed$(NC)\"\n95: \n96: .PHONY: test-python-integration\n97: test-python-integration: ## Run Python integration tests only\n98: \t@echo \"$(BLUE)Running Python integration tests...$(NC)\"\n99: \t@$(PYTHON) -m pytest -v -m \"integration\"\n100: \t@echo \"$(GREEN)âœ“ Python integration tests passed$(NC)\"\n101: \n102: .PHONY: test-python-cover\n103: test-python-cover: ## Run Python tests with coverage report\n104: \t@echo \"$(BLUE)Running Python tests with coverage...$(NC)\"\n105: \t@$(PYTHON) -m pytest --cov=agentcube --cov-report=html --cov-report=term\n106: \t@echo \"$(GREEN)âœ“ Python tests with coverage passed$(NC)\"\n107: \n108: .PHONY: test-python-verbose\n109: test-python-verbose: ## Run Python tests with verbose output\n110: \t@echo \"$(BLUE)Running Python tests with verbose output...$(NC)\"\n111: \t@$(PYTHON) -m pytest -vv\n112: \t@echo \"$(GREEN)âœ“ Python tests passed$(NC)\"\n113: \n114: .PHONY: test-sdk\n115: test-sdk: ## Run Python SDK tests\n116: \t@echo \"$(BLUE)Running Python SDK tests...$(NC)\"\n117: \t@$(PYTHON) -m pytest -v tests/\n118: \t@echo \"$(GREEN)âœ“ Python SDK tests passed$(NC)\"\n119: \n120: .PHONY: test-cli-python\n121: test-cli-python: ## Run CLI Python tests\n122: \t@echo \"$(BLUE)Running CLI Python tests...$(NC)\"\n123: \t@$(PYTHON) -m pytest -v cmd/cli/tests/\n124: \t@echo \"$(GREEN)âœ“ CLI Python tests passed$(NC)\"\n125: \n126: .PHONY: test-integration\n127: test-integration: ## Run all integration tests\n128: \t@echo \"$(BLUE)Running all integration tests...$(NC)\"\n129: \t@$(MAKE) test-go-integration\n130: \t@$(MAKE) test-python-integration\n131: \t@echo \"$(GREEN)âœ“ All integration tests passed$(NC)\"\n132: \n133: .PHONY: test-e2e\n134: test-e2e: ## Run end-to-end tests\n135: \t@echo \"$(BLUE)Running end-to-end tests...$(NC)\"\n136: \t@$(GO) test $(TEST_FLAGS) -run E2E -timeout $(TEST_TIMEOUT) ./...\n137: \t@$(PYTHON) -m pytest -v -m \"e2e\"\n138: \t@echo \"$(GREEN)âœ“ End-to-end tests passed$(NC)\"\n139: \n140: .PHONY: test-report\n141: test-report: ## Generate all test reports\n142: \t@echo \"$(BLUE)Generating test reports...$(NC)\"\n143: \t@mkdir -p $(REPORT_DIR)\n144: \t@$(MAKE) test-go-cover\n145: \t@$(MAKE) test-python-cover\n146: \t@echo \"$(GREEN)âœ“ Test reports generated$(NC)\"\n147: \n148: .PHONY: test-watch\n149: test-watch: ## Watch for changes and run tests automatically\n150: \t@echo \"$(BLUE)Watching for changes and running tests...$(NC)\"\n151: \t@while true; do \\\n152: \t\tfind . -name \"*.go\" -o -name \"*.py\" | entr -d make test; \\\n153: \tdone\n154: \n155: .PHONY: benchmark\n156: benchmark: ## Run all benchmarks\n157: \t@echo \"$(BLUE)Running all benchmarks...$(NC)\"\n158: \t@$(MAKE) test-go-bench\n159: \t@echo \"$(GREEN)âœ“ Benchmarks completed$(NC)\"\n160: \n161: .PHONY: benchmark-go\n162: benchmark-go: ## Run Go benchmarks\n163: \t@echo \"$(BLUE)Running Go benchmarks...$(NC)\"\n164: \t@$(GO) test -bench=. -benchmem -run=^$$ ./...\n165: \t@echo \"$(GREEN)âœ“ Go benchmarks completed$(NC)\"\n166: \n167: .PHONY: benchmark-python\n168: benchmark-python: ## Run Python benchmarks\n169: \t@echo \"$(BLUE)Running Python benchmarks...$(NC)\"\n170: \t@$(PYTHON) -m pytest --benchmark-only\n171: \t@echo \"$(GREEN)âœ“ Python benchmarks completed$(NC)\"\n172: \n173: .PHONY: clean-coverage\n174: clean-coverage: ## Clean test coverage reports\n175: \t@echo \"$(BLUE)Cleaning coverage reports...$(NC)\"\n176: \t@rm -rf $(COVERAGE_DIR)\n177: \t@rm -f $(COVERAGE_DIR)/*.out $(COVERAGE_DIR)/*.html\n178: \t@rm -f .coverage coverage.xml\n179: \t@find . -type d -name htmlcov -exec rm -rf {} + 2>/dev/null || true\n180: \t@echo \"$(GREEN)âœ“ Coverage reports cleaned$(NC)\"\n181: \n182: .PHONY: clean-test\n183: clean-test: clean-coverage ## Clean test artifacts\n184: \t@echo \"$(BLUE)Cleaning test artifacts...$(NC)\"\n185: \t@rm -rf $(REPORT_DIR)\n186: \t@find . -type d -name .pytest_cache -exec rm -rf {} + 2>/dev/null || true\n187: \t@find . -type d -name \".test\" -exec rm -rf {} + 2>/dev/null || true\n188: \t@echo \"$(GREEN)âœ“ Test artifacts cleaned$(NC)\"\n\n(End of file - total 188 lines)\n</content>","metadata":{"preview":".PHONY: test\ntest: test-go test-python ## Run all tests (Go and Python)\n\n.PHONY: test-go\ntest-go: ## Run all Go tests\n\t@echo \"$(BLUE)Running Go tests...$(NC)\"\n\t@mkdir -p $(COVERAGE_DIR)\n\t@$(GO) test $(TEST_FLAGS) -timeout $(TEST_TIMEOUT) -coverprofile=$(GO_TEST_COVERAGE) -covermode=atomic ./...\n\t@echo \"$(GREEN)âœ“ Go tests passed$(NC)\"\n\n.PHONY: test-go-unit\ntest-go-unit: ## Run Go unit tests only\n\t@echo \"$(BLUE)Running Go unit tests...$(NC)\"\n\t@$(GO) test $(TEST_FLAGS) -short -timeout $(TEST_TIMEOUT) ./...\n\t@echo \"$(GREEN)âœ“ Go unit tests passed$(NC)\"\n\n.PHONY: test-go-integration\ntest-go-integration: ## Run Go integration tests only\n\t@echo \"$(BLUE)Running Go integration tests...$(NC)\"\n\t@$(GO) test $(TEST_FLAGS) -run Integration -timeout $(TEST_TIMEOUT) ./...","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/.makefiles/test.mk","time":{"start":1775885085965,"end":1775885086005}}}}
