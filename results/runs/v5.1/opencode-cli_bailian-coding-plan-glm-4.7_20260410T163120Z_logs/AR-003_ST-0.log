ions) (*v1alpha1.CodeInterpreter, error)\n531:     List(ctx context.Context, opts metav1.ListOptions) (*v1alpha1.CodeInterpreterList, error)\n532:     Watch(ctx context.Context, opts metav1.ListOptions) (watch.Interface, error)\n533:     Patch(ctx context.Context, name string, pt types.PatchType, data []byte, opts metav1.PatchOptions, subresources ...string) (*v1alpha1.CodeInterpreter, error)\n534:     CodeInterpreterExpansion\n535: }\n536: ```\n537: \n538: ## Error Handling\n539: \n540: ### Validation Errors\n541: \n542: CRD validation errors enforced by Kubernetes API server:\n543: \n544: 1. **Missing required fields**: `spec.image` is required\n545: 2. **Invalid enum values**: `spec.runtime` must be one of `python`, `javascript`, `typescript`, or `go`\n546: 3. **Invalid duration format**: `spec.timeout` must be a valid duration string (e.g., `\"5m\"`, `\"1h30m\"`)\n547: 4. **Invalid package names**: `spec.enabledPackages` entries must follow package naming conventions and not contain malicious patterns (path traversal, etc.)\n548: \n549: ### Package Name Validation\n550: \n551: Package names must:\n552: - Be alphanumeric with hyphens and underscores allowed\n553: - Not contain path traversal sequences (`../`, `..\\\\`, etc.)\n554: - Not start with `.` or `-`\n555: - Be at least 1 character and at most 255 characters\n556: \n557: ```go\n558: // Example webhook validation logic\n559: func validatePackageName(name string) error {\n560:     if strings.Contains(name, \"../\") || strings.Contains(name, \"..\\\\\") {\n561:         return fmt.Errorf(\"package name contains path traversal: %s\", name)\n562:     }\n563:     if strings.HasPrefix(name, \".\") || strings.HasPrefix(name, \"-\") {\n564:         return fmt.Errorf(\"package name cannot start with . or -: %s\", name)\n565:     }\n566:     if len(name) == 0 || len(name) > 255 {\n567:         return fmt.Errorf(\"package name must be 1-255 characters: %s\", name)\n568:     }\n569:     matched, _ := regexp.MatchString(`^[a-zA-Z0-9_-]+$`, name)\n570:     if !matched {\n571:         return fmt.Errorf(\"package name contains invalid characters: %s\", name)\n572:     }\n573:     return nil\n574: }\n575: ```\n576: \n577: ### Client-Go Error Handling\n578: \n579: ```go\n580: // Common error patterns\n581: err := client.CodeInterpreters(namespace).Create(ctx, &codeInterpreter, opts)\n582: if errors.IsAlreadyExists(err) {\n583:     // Handle conflict\n584: } else if errors.IsNotFound(err) {\n585:     // Handle not found\n586: } else if errors.IsInvalid(err) {\n587:     // Handle validation error (missing required fields, invalid enum, etc.)\n588: } else if errors.IsForbidden(err) {\n589:     // Handle RBAC error\n590: } else if err != nil {\n591:     // Handle other errors\n592: }\n593: ```\n594: \n595: ### Status Update Error Handling\n596: \n597: ```go\n598: // Update status without affecting spec\n599: ci, err := client.CodeInterpreters(namespace).Get(ctx, name, metav1.GetOptions{})\n600: if err != nil {\n601:     return err\n602: }\n603: \n604: ci.Status.Ready = true\n605: ci.Status.ObservedGeneration = ci.Generation\n606: \n607: _, err = client.CodeInterpreters(namespace).UpdateStatus(ctx, ci, metav1.UpdateOptions{})\n608: if err != nil {\n609:     return fmt.Errorf(\"failed to update status: %w\", err)\n610: }\n611: ```\n612: \n613: ## Testing Strategy\n614: \n615: ### Unit Tests\n616: \n617: **File**: `pkg/apis/runtime/v1alpha1/types_test.go`\n618: \n619: ```go\n620: package v1alpha1_test\n621: \n622: import (\n623:     \"testing\"\n624:     \"time\"\n625: \n626:     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n627:     \"k8s.io/apimachinery/pkg/runtime/schema\"\n628: \n629:     runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n630: )\n631: \n632: func TestCodeInterpreterTypeMeta(t *testing.T) {\n633:     ci := &runtimev1alpha1.CodeInterpreter{}\n634: \n635:     if ci.APIVersion != \"\" {\n636:         t.Errorf(\"Expected empty APIVersion, got %s\", ci.APIVersion)\n637:     }\n638:     if ci.Kind != \"\" {\n639:         t.Errorf(\"Expected empty Kind, got %s\", ci.Kind)\n640:     }\n641: }\n642: \n643: func TestCodeInterpreterSpecDefaults(t *testing.T) {\n644:     duration5m := metav1.Duration{Duration: 5 * time.Minute}\n645: \n646:     spec := &runtimev1alpha1.CodeInterpreterSpec{\n647:         Image: \"python:3.11-slim\",\n648:     }\n649: \n650:     if spec.Image != \"python:3.11-slim\" {\n651:         t.Errorf(\"Expected image python:3.11-slim, got %s\", spec.Image)\n652:     }\n653: \n654:     if spec.Runtime == \"\" {\n655:         spec.Runtime = \"python\" // Default applied by controller-gen\n656:     }\n657: \n658:     if spec.Timeout == nil || spec.Timeout.Duration != duration5m.Duration {\n659:         t.Logf(\"Note: Timeout default value will be applied by API server\")\n660:     }\n661: }\n662: \n663: func TestCodeInterpreterStatus(t *testing.T) {\n664:     now := metav1.Now()\n665:     ci := &runtimev1alpha1.CodeInterpreter{\n666:         Status: runtimev1alpha1.CodeInterpreterStatus{\n667:             Ready: true,\n668:             Conditions: []metav1.Condition{\n669:                 {\n670:                     Type:               \"Ready\",\n671:                     Status:             metav1.ConditionTrue,\n672:                     LastTransitionTime: now,\n673:                     Reason:             \"Available\",\n674:                     Message:            \"Interpreter is ready\",\n675:                 },\n676:             },\n677:             ObservedGeneration: 1,\n678:         },\n679:     }\n680: \n681:     if !ci.Status.Ready {\n682:         t.Error(\"Expected Ready to be true\")\n683:     }\n684: \n685:     if len(ci.Status.Conditions) != 1 {\n686:         t.Errorf(\"Expected 1 condition, got %d\", len(ci.Status.Conditions))\n687:     }\n688: \n689:     if ci.Status.ObservedGeneration != 1 {\n690:         t.Errorf(\"Expected ObservedGeneration 1, got %d\", ci.Status.ObservedGeneration)\n691:     }\n692: }\n693: \n694: func TestCodeInterpreterList(t *testing.T) {\n695:     list := &runtimev1alpha1.CodeInterpreterList{\n696:         TypeMeta: metav1.TypeMeta{\n697:             APIVersion: runtimev1alpha1.SchemeGroupVersion.String(),\n698:             Kind:       \"CodeInterpreterList\",\n699:         },\n700:         Items: []runtimev1alpha1.CodeInterpreter{\n701:             {\n702:                 ObjectMeta: metav1.ObjectMeta{\n703:                     Name: \"python-interpreter\",\n704:                 },\n705:             },\n706:             {\n707:                 ObjectMeta: metav1.ObjectMeta{\n708:                     Name: \"javascript-interpreter\",\n709:                 },\n710:             },\n711:         },\n712:     }\n713: \n714:     if len(list.Items) != 2 {\n715:         t.Errorf(\"Expected 2 items, got %d\", len(list.Items))\n716:     }\n717: }\n718: \n719: func TestCodeInterpreterResources(t *testing.T) {\n720:     resources := &runtimev1alpha1.SandboxContainerResources{\n721:         Limits: runtimev1alpha1.SandboxResourceList{\n722:             CPU:              \"1\",\n723:             Memory:           \"1Gi\",\n724:             EphemeralStorage: \"5Gi\",\n725:         },\n726:         Requests: runtimev1alpha1.SandboxResourceList{\n727:             CPU:    \"500m\",\n728:             Memory: \"512Mi\",\n729:         },\n730:     }\n731: \n732:     if resources.Limits.CPU != \"1\" {\n733:         t.Errorf(\"Expected CPU limit 1, got %s\", resources.Limits.CPU)\n734:     }\n735: \n736:     if resources.Requests.Memory != \"512Mi\" {\n737:         t.Errorf(\"Expected Memory request 512Mi, got %s\", resources.Requests.Memory)\n738:     }\n739: }\n740: \n741: func TestCodeInterpreterEnvVar(t *testing.T) {\n742:     env := []runtimev1alpha1.SandboxEnvVar{\n743:         {\n744:             Name:  \"PYTHONPATH\",\n745:             Value: \"/usr/local/lib/python3.11/site-packages\",\n746:         },\n747:         {\n748:             Name: \"API_KEY\",\n749:             ValueFrom: &runtimev1alpha1.SandboxEnvVarSource{\n750:                 SecretKeyRef: &runtimev1alpha1.SandboxSecretKeyRef{\n751:                     Name: \"api-secret\",\n752:                     Key:  \"key\",\n753:                 },\n754:             },\n755:         },\n756:     }\n757: \n758:     if len(env) != 2 {\n759:         t.Errorf(\"Expected 2 environment variables, got %d\", len(env))\n760:     }\n761: \n762:     if env[0].Name != \"PYTHONPATH\" {\n763:         t.Errorf(\"Expected PYTHONPATH, got %s\", env[0].Name)\n764:     }\n765: \n766:     if env[1].ValueFrom == nil {\n767:         t.Error(\"Expected ValueFrom to be set for second env var\")\n768:     }\n769: }\n770: \n771: func TestCodeInterpreterRuntimeEnum(t *testing.T) {\n772:     validRuntimes := []string{\"python\", \"javascript\", \"typescript\", \"go\"}\n773: \n774:     for _, runtime := range validRuntimes {\n775:         ci := &runtimev1alpha1.CodeInterpreter{\n776:             Spec: runtimev1alpha1.CodeInterpreterSpec{\n777:                 Image:   \"test:latest\",\n778:                 Runtime: runtime,\n779:             },\n780:         }\n781: \n782:         if ci.Spec.Runtime != runtime {\n783:             t.Errorf(\"Expected runtime %s, got %s\", runtime, ci.Spec.Runtime)\n784:         }\n785:     }\n786: }\n787: \n788: func TestEnabledPackages(t *testing.T) {\n789:     ci := &runtimev1alpha1.CodeInterpreter{\n790:         Spec: runtimev1alpha1.CodeInterpreterSpec{\n791:             Image:           \"python:3.11-slim\",\n792:             EnabledPackages: []string{\"numpy\", \"pandas\", \"scikit-learn\"},\n793:         },\n794:     }\n795: \n796:     if len(ci.Spec.EnabledPackages) != 3 {\n797:         t.Errorf(\"Expected 3 enabled packages, got %d\", len(ci.Spec.EnabledPackages))\n798:     }\n799: \n800:     if ci.Spec.EnabledPackages[0] != \"numpy\" {\n801:         t.Errorf(\"Expected numpy, got %s\", ci.Spec.EnabledPackages[0])\n802:     }\n803: }\n804: \n805: func TestCodeInterpreterSchemeRegistration(t *testing.T) {\n806:     gvk := schema.GroupVersionKind{\n807:         Group:   \"runtime.agentcube.volcano.sh\",\n808:         Version: \"v1alpha1\",\n809:         Kind:    \"CodeInterpreter\",\n810:     }\n811: \n812:     obj, err := runtimev1alpha1.Scheme.New(gvk)\n813:     if err != nil {\n814:         t.Fatalf(\"Failed to create object from scheme: %v\", err)\n815:     }\n816: \n817:     ci, ok := obj.(*runtimev1alpha1.CodeInterpreter)\n818:     if !ok {\n819:         t.Fatalf(\"Expected *CodeInterpreter, got %T\", obj)\n820:     }\n821: \n822:     gvks, _, _ := runtimev1alpha1.Scheme.ObjectKinds(obj)\n823:     if len(gvks) == 0 {\n824:         t.Error(\"CodeInterpreter should have a known GVK\")\n825:     }\n826: \n827:     if gvks[0] != gvk {\n828:         t.Errorf(\"Expected GVK %v, got %v\", gvk, gvks[0])\n829:     }\n830: }\n831: ```\n832: \n833: ### Integration Tests\n834: \n835: **File**: `pkg/apis/runtime/v1alpha1/client_integration_test.go`\n836: \n837: ```go\n838: package v1alpha1_test\n839: \n840: import (\n841:     \"context\"\n842:     \"testing\"\n843:     \"time\"\n844: \n845:     . \"github.com/onsi/ginkgo/v2\"\n846:     . \"github.com/onsi/gomega\"\n847:     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n848:     \"k8s.io/client-go/kubernetes/scheme\"\n849:     \"sigs.k8s.io/controller-runtime/pkg/client\"\n850:     \"sigs.k8s.io/controller-runtime/pkg/envtest\"\n851: \n852:     runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n853: )\n854: \n855: var (\n856:     envTest *envtest.Environment\n857:     k8sClient client.Client\n858: )\n859: \n860: var _ = BeforeSuite(func() {\n861:     err := runtimev1alpha1.AddToScheme(scheme.Scheme)\n862:     Expect(err).NotTo(HaveOccurred())\n863: \n864:     envTest = &envtest.Environment{\n865:         CRDDirectoryPaths: []string{\"../../../manifests/charts/base/crds\"},\n866:     }\n867: \n868:     cfg, err := envTest.Start()\n869:     Expect(err).NotTo(HaveOccurred())\n870: \n871:     k8sClient, err = client.New(cfg, client.Options{Scheme: scheme.Scheme})\n872:     Expect(err).NotTo(HaveOccurred())\n873: })\n874: \n875: var _ = AfterSuite(func() {\n876:     err := envTest.Stop()\n877:     Expect(err).NotTo(HaveOccurred())\n878: })\n879: \n880: var _ = Describe(\"CodeInterpreter CRD\", func() {\n881:     Context(\"Create with defaults\", func() {\n882:         It(\"should create CodeInterpreter and apply defaults\", func(ctx SpecContext) {\n883:             ci := &runtimev1alpha1.CodeInterpreter{\n884:                 ObjectMeta: metav1.ObjectMeta{\n885:                     Name:      \"test-ci\",\n886:                     Namespace: \"default\",\n887:                 },\n888:                 Spec: runtimev1alpha1.CodeInterpreterSpec{\n889:                     Image: \"python:3.11-slim\",\n890:                 },\n891:             }\n892: \n893:             err := k8sClient.Create(ctx, ci)\n894:             Expect(err).NotTo(HaveOccurred())\n895: \n896:             var fetchedCi runtimev1alpha1.CodeInterpreter\n897:             err = k8sClient.Get(ctx, client.ObjectKeyFromObject(ci), &fetchedCi)\n898:             Expect(err).NotTo(HaveOccurred())\n899: \n900:             Expect(fetchedCi.Spec.Image).To(Equal(\"python:3.11-slim\"))\n901:             Expect(fetchedCi.Spec.Runtime).To(Equal(\"python\"))\n902:         }, SpecTimeout(5*time.Second))\n903:     })\n904: \n905:     Context(\"Status updates\", func() {\n906:         It(\"should update status independently from spec\", func(ctx SpecContext) {\n907:             ci := &runtimev1alpha1.CodeInterpreter{\n908:                 ObjectMeta: metav1.ObjectMeta{\n909:                     Name:      \"test-ci-status\",\n910:                     Namespace: \"default\",\n911:                 },\n912:                 Spec: runtimev1alpha1.CodeInterpreterSpec{\n913:                     Image: \"python:3.11-slim\",\n914:                 },\n915:             }\n916: \n917:             err := k8sClient.Create(ctx, ci)\n918:             Expect(err).NotTo(HaveOccurred())\n919: \n920:             ci.Status.Ready = true\n921:             ci.Status.ObservedGeneration = ci.Generation\n922:             err = k8sClient.Status().Update(ctx, ci)\n923:             Expect(err).NotTo(HaveOccurred())\n924: \n925:             var fetchedCi runtimev1alpha1.CodeInterpreter\n926:             err = k8sClient.Get(ctx, client.ObjectKeyFromObject(ci), &fetchedCi)\n927:             Expect(err).NotTo(HaveOccurred())\n928: \n929:             Expect(fetchedCi.Status.Ready).To(BeTrue())\n930:         }, SpecTimeout(5*time.Second))\n931:     })\n932: })\n933: ```\n934: \n935: ### E2E Tests\n936: \n937: **File**: `test/e2e/codeinterpreter_test.go`\n938: \n939: ```go\n940: package e2e\n941: \n942: import (\n943:     \"context\"\n944:     \"testing\"\n945:     \"time\"\n946: \n947:     . \"github.com/onsi/ginkgo/v2\"\n948:     . \"github.com/onsi/gomega\"\n949:     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n950: \n951:     runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n952:     \"github.com/volcano-sh/agentcube/test/e2e/framework\"\n953: )\n954: \n955: var _ = Describe(\"CodeInterpreter E2E\", func() {\n956:     f := framework.NewDefaultFramework(\"codeinterpreter\")\n957: \n958:     Context(\"Create and validate CodeInterpreter\", func() {\n959:         It(\"should create CodeInterpreter with custom configuration\", func() {\n960:             ctx := context.Background()\n961: \n962:             ci := &runtimev1alpha1.CodeInterpreter{\n963:                 ObjectMeta: metav1.ObjectMeta{\n964:                     Name:      \"e2e-ci\",\n965:                     Namespace: f.Namespace.Name,\n966:                 },\n967:                 Spec: runtimev1alpha1.CodeInterpreterSpec{\n968:                     Image: \"python:3.11-slim\",\n969:                     Runtime: \"python\",\n970:                     Timeout: &metav1.Duration{Duration: 10 * time.Minute},\n971:                     Resources: &runtimev1alpha1.SandboxContainerResources{\n972:                         Limits: runtimev1alpha1.SandboxResourceList{\n973:                             CPU:    \"2\",\n974:                             Memory: \"2Gi\",\n975:                         },\n976:                         Requests: runtimev1alpha1.SandboxResourceList{\n977:                             CPU:    \"500m\",\n978:                             Memory: \"512Mi\",\n979:                         },\n980:                     },\n981:                     EnabledPackages: []string{\"numpy\", \"pandas\"},\n982:                     Env: []runtimev1alpha1.SandboxEnvVar{\n983:                         {\n984:                             Name:  \"PYTHON_VERSION\",\n985:                             Value: \"3.11\",\n986:                         },\n987:                     },\n988:                 },\n989:             }\n990: \n991:             err := f.Client.Create(ctx, ci)\n992:             Expect(err).NotTo(HaveOccurred())\n993: \n994:             Eventually(func() bool {\n995:                 var fetchedCi runtimev1alpha1.CodeInterpreter\n996:                 err := f.Client.Get(ctx, client.ObjectKeyFromObject(ci), &fetchedCi)\n997:                 return err == nil\n998:             }, 10*time.Second, time.Second).Should(BeTrue())\n999:         })\n1000:     })\n1001: })\n1002: ```\n1003: \n1004: ## Code Generation\n1005: \n1006: ### CRD Generation\n1007: \n1008: **Command**: `make gen-crd`\n1009: \n1010: ```bash\n1011: controller-gen crd paths=\"./pkg/apis/runtime/v1alpha1/...\" output:crd:dir=manifests/charts/base/crds\n1012: ```\n1013: \n1014: This generates:\n1015: - `manifests/charts/base/crds/runtime.agentcube.volcano.sh_agentruntimes.yaml`\n1016: - `manifests/charts/base/crds/runtime.agentcube.volcano.sh_codeinterpreters.yaml`\n1017: \n1018: ### Client-Go Generation\n1019: \n1020: **Command**: `make gen-client`\n1021: \n1022: ```bash\n1023: bash hack/update-codegen.sh\n1024: ```\n1025: \n1026: This generates:\n1027: - Typed clients in `client-go/clientset/versioned/typed/runtime/v1alpha1/`\n1028: - Informers in `client-go/informers/externalversions/runtime/v1alpha1/`\n1029: - Listers in `client-go/listers/runtime/v1alpha1/`\n1030: \n1031: ### DeepCopy Generation\n1032: \n1033: **Command**: `make generate`\n1034: \n1035: ```bash\n1036: controller-gen object paths=\"./pkg/apis/runtime/v1alpha1/...\"\n1037: ```\n1038: \n1039: This generates:\n1040: - `pkg/apis/runtime/v1alpha1/zz_generated.deepcopy.go`\n1041: \n1042: ## Integration Points\n1043: \n1044: ### With PicoD Daemon\n1045: \n1046: The CodeInterpreter CRD is used by the session creation processor to:\n1047: 1. Look up the CodeInterpreter configuration for a given session\n1048: 2. Determine the container image and runtime type\n1049: 3. Apply resource limits and environment variables\n1050: 4. Enforce package restrictions\n1051: \n1052: ### With Session Store\n1053: \n1054: The session store uses CodeInterpreter metadata to:\n1055: 1. Associate sessions with their interpreter configuration\n1056: 2. Track which interpreter is handling which sessions\n1057: 3. Apply timeout limits from the CodeInterpreter spec\n1058: \n1059: ### With Router\n1060: \n1061: The router uses CodeInterpreter information to:\n1062: 1. Route execution requests to the appropriate interpreter pods\n1063: 2. Apply timeout limits to requests\n1064: 3. Track interpreter availability via Ready status\n1065: \n1066: ### RBAC Requirements\n1067: \n1068: ```yaml\n1069: apiGroups:\n1070: - runtime.agentcube.volcano.sh\n1071: resources:\n1072: - codeinterpreters\n1073: verbs:\n1074: - get\n1075: - list\n1076: - watch\n1077: \n1078: apiGroups:\n1079: - runtime.agentcube.volcano.sh\n1080: resources:\n1081: - codeinterpreters/status\n1082: verbs:\n1083: - get\n1084: - update\n1085: - patch\n1086: \n1087: apiGroups:\n1088: - runtime.agentcube.volcano.sh\n1089: resources:\n1090: - codeinterpreters/finalizers\n1091: verbs:\n1092: - update\n1093: ```\n1094: \n1095: ## Dependencies\n1096: \n1097: ### Go Dependencies\n1098: \n1099: ```go\n1100: import (\n1101:     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n1102:     \"k8s.io/apimachinery/pkg/runtime\"\n1103:     \"k8s.io/apimachinery/pkg/runtime/schema\"\n1104: )\n1105: ```\n1106: \n1107: ### Build Tools\n1108: \n1109: - `controller-gen`: v0.17.2 (for CRD and deepcopy generation)\n1110: - `k8s.io/code-generator`: v0.34.1 (for client-go generation)\n1111: \n1112: ### Makefile Targets\n1113: \n1114: | Target | Description |\n1115: |--------|-------------|\n1116: | `gen-crd` | Generate CRD manifests |\n1117: | `gen-client` | Generate client-go library |\n1118: | `generate` | Generate all code (CRD + deepcopy + go mod tidy) |\n1119: | `gen-all` | `generate` + `gen-client` |\n1120: | `gen-check` | Verify generated code is up-to-date |\n1121: \n1122: ## Documentation\n1123: \n1124: ### Example CodeInterpreter Resource\n1125: \n1126: **File**: `examples/codeinterpreter.yaml`\n1127: \n1128: ```yaml\n1129: apiVersion: runtime.agentcube.volcano.sh/v1alpha1\n1130: kind: CodeInterpreter\n1131: metadata:\n1132:   name: python-interpreter\n1133:   namespace: agentcube\n1134: spec:\n1135:   image: ghcr.io/volcano-sh/python-interpreter:3.11-slim\n1136:   runtime: python\n1137:   timeout: 5m\n1138:   resources:\n1139:     limits:\n1140:       cpu: \"1\"\n1141:       memory: \"1Gi\"\n1142:     requests:\n1143:       cpu: \"250m\"\n1144:       memory: \"256Mi\"\n1145:   enabledPackages:\n1146:   - numpy\n1147:   - pandas\n1148:   - scikit-learn\n1149:   env:\n1150:   - name: PYTHON_VERSION\n1151:     value: \"3.11\"\n1152:   - name: API_KEY\n1153:     valueFrom:\n1154:       secretKeyRef:\n1155:         name: api-secret\n1156:         key: key\n1157: ```\n1158: \n1159: ### Minimal CodeInterpreter Resource\n1160: \n1161: ```yaml\n1162: apiVersion: runtime.agentcube.volcano.sh/v1alpha1\n1163: kind: CodeInterpreter\n1164: metadata:\n1165:   name: python-interpreter\n1166:   namespace: agentcube\n1167: spec:\n1168:   image: python:3.11-slim\n1169: ```\n1170: \n1171: This minimal configuration will have:\n1172: - Runtime defaults to `python`\n1173: - Timeout defaults to `5m`\n1174: - No resource limits\n1175: - No package restrictions\n1176: - No custom environment variables\n1177: \n1178: ### Usage Examples\n1179: \n1180: **Creating a CodeInterpreter**:\n1181: \n1182: ```go\n1183: ci := &runtimev1alpha1.CodeInterpreter{\n1184:     ObjectMeta: metav1.ObjectMeta{\n1185:         Name:      \"python-interpreter\",\n1186:         Namespace: \"default\",\n1187:     },\n1188:     Spec: runtimev1alpha1.CodeInterpreterSpec{\n1189:         Image: \"python:3.11-slim\",\n1190:         Runtime: \"python\",\n1191:         EnabledPackages: []string{\"numpy\", \"pandas\"},\n1192:     },\n1193: }\n1194: \n1195: createdCi, err := client.CodeInterpreters(\"default\").Create(ctx, ci, metav1.CreateOptions{})\n1196: ```\n1197: \n1198: **Watching for changes**:\n1199: \n1200: ```go\n1201: informer := factory.Runtime().V1alpha1().CodeInterpreters().Informer()\n1202: \n1203: informer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n1204:     AddFunc: func(obj interface{}) {\n1205:         ci := obj.(*runtimev1alpha1.CodeInterpreter)\n1206:         log.Infof(\"CodeInterpreter %s added\", ci.Name)\n1207:     },\n1208:     UpdateFunc: func(oldObj, newObj interface{}) {\n1209:         oldCi := oldObj.(*runtimev1alpha1.CodeInterpreter)\n1210:         newCi := newObj.(*runtimev1alpha1.CodeInterpreter)\n1211:         if oldCi.Generation != newCi.Generation {\n1212:             log.Infof(\"CodeInterpreter %s generation changed\", newCi.Name)\n1213:         }\n1214:     },\n1215:     DeleteFunc: func(obj interface{}) {\n1216:         ci := obj.(*runtimev1alpha1.CodeInterpreter)\n1217:         log.Infof(\"CodeInterpreter %s deleted\", ci.Name)\n1218:     },\n1219: })\n1220: ```\n1221: \n1222: ## Security Considerations\n1223: \n1224: ### Package Name Validation\n1225: \n1226: Package names must be validated to prevent:\n1227: - Path traversal attacks (`../`, `..\\\\`)\n1228: - Arbitrary file system access\n1229: - Package namespace pollution\n1230: - Injection attacks via malicious package names\n1231: \n1232: ### Resource Limits\n1233: \n1234: CodeInterpreter resources should be:\n1235: - Configured with appropriate CPU and memory limits\n1236: - Monitored for resource usage\n1237: - Prevented from consuming cluster resources\n1238: \n1239: ### Timeout Enforcement\n1240: \n1241: Execution timeouts should be:\n1242: - Enforced by the PicoD daemon\n1243: - Configurable per CodeInterpreter\n1244: - Applied to all code execution requests\n1245: \n1246: ### Environment Variable Security\n1247: \n1248: Environment variables from Secrets should:\n1249: - Be encrypted at rest\n1250: - Only be accessible to authorized service accounts\n1251: - Be rotated regularly\n1252: \n1253: ## Future Enhancements\n1254: \n1255: ### Potential Extensions\n1256: \n1257: 1. **Version Pinning**: Support for pinning specific library versions\n1258: 2. **Pre-installed Packages**: Allow specifying packages to pre-install in the image\n1259: 3. **Network Policies**: Configure network access per interpreter\n1260: 4. **Storage Options**: Persistent storage options for workspace data\n1261: 5. **Multi-language Support**: Support for additional languages (R, Java, etc.)\n1262: 6. **Custom Runtimes**: Support for custom runtime configurations\n1263: \n1264: ### Version Migration Path\n1265: \n1266: Future migration from v1alpha1 to v1beta1/v1:\n1267: 1. Create new version package `pkg/apis/runtime/v1beta1/`\n1268: 2. Implement conversion functions between v1alpha1 and v1beta1\n1269: 3. Update CRD to serve both versions\n1270: 4. Set v1beta1 as storage version\n1271: 5. Update controllers and clients to use v1beta1\n1272: 6. Deprecate v1alpha1 after migration period\n\n(End of file - total 1272 lines)\n</content>","metadata":{"preview":"# CodeInterpreter CRD Type Definition Design\n\n## AR-002 — CRD CodeInterpreter 类型定义\n\n**Module**: `pkg/apis`  \n**Language**: Go  \n**Size**: S  \n**Purpose**: Define Kubernetes CRD type definitions for CodeInterpreter resources, enable client-go code generation, and provide type-safe API access for code execution environment management.\n\n## Architecture\n\n### Package Structure\n\n```\npkg/apis/\n└── runtime/\n    └── v1alpha1/\n        ├── types.go                   # Core type definitions (AgentRuntime + Sandbox types)\n        ├── register.go                # Scheme registration\n        ├── doc.go                     # Package documentation","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-002/design.md","time":{"start":1775840847475,"end":1775840847497}}}}
