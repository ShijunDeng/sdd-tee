 Placeholder implementation\n\treturn nil\n}\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `go test ./pkg/workloadmanager/controller/reconciler/ -run TestAgentRuntimeReconcile_FullFlow -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add pkg/workloadmanager/controller/reconciler/agentruntime.go pkg/workloadmanager/controller/reconciler/agentruntime_test.go\ngit commit -m \"feat(ar-007): update AgentRuntime Reconcile method to call reconcileSandbox\"\n```\n\n### Task 17: Add SetupWithManager methods for both reconcilers\n\n**Files:**\n- Modify: `pkg/workloadmanager/controller/reconciler/agentruntime.go`\n- Modify: `pkg/workloadmanager/controller/reconciler/codeinterpreter.go`\n\n**Step 1: Write the failing test**\n\n```go\n// pkg/workloadmanager/controller/reconciler/agentruntime_test.go\nfunc TestAgentRuntimeReconciler_SetupWithManager(t *testing.T) {\n\tg := NewGomegaWithT(t)\n\n\tscheme := runtime.NewScheme()\n\tmgr, err := ctrl.NewManager(cfg, ctrl.Options{Scheme: scheme})\n\tg.Expect(err).NotTo(HaveOccurred())\n\n\treconciler := &AgentRuntimeReconciler{\n\t\tClient:       mgr.GetClient(),\n\t\tScheme:       scheme,\n\t\tRequeueAfter: 10 * time.Second,\n\t}\n\n\terr = reconciler.SetupWithManager(mgr)\n\tg.Expect(err).NotTo(HaveOccurred())\n}\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `go test ./pkg/workloadmanager/controller/reconciler/ -run TestAgentRuntimeReconciler_SetupWithManager -v`\nExpected: FAIL with \"undefined: method SetupWithManager\"\n\n**Step 3: Write minimal implementation**\n\nAdd to agentruntime.go:\n\n```go\n// SetupWithManager sets up the controller with the manager\nfunc (r *AgentRuntimeReconciler) SetupWithManager(mgr ctrl.Manager) error {\n\treturn ctrl.NewControllerManagedBy(mgr).\n\t\tFor(&runtimev1alpha1.AgentRuntime{}).\n\t\tWithEventFilter(&ResourceGenerationChangedPredicate{}).\n\t\tComplete(r)\n}\n```\n\nAdd to codeinterpreter.go:\n\n```go\n// SetupWithManager sets up the controller with the manager\nfunc (r *CodeInterpreterReconciler) SetupWithManager(mgr ctrl.Manager) error {\n\treturn ctrl.NewControllerManagedBy(mgr).\n\t\tFor(&runtimev1alpha1.CodeInterpreter{}).\n\t\tWithEventFilter(&ResourceGenerationChangedPredicate{}).\n\t\tComplete(r)\n}\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `go test ./pkg/workloadmanager/controller/reconciler/ -run TestAgentRuntimeReconciler_SetupWithManager -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add pkg/workloadmanager/controller/reconciler/agentruntime.go pkg/workloadmanager/controller/reconciler/codeinterpreter.go\ngit commit -m \"feat(ar-007): add SetupWithManager methods for both reconcilers\"\n```\n\n### Task 18: Run all reconciler unit tests\n\n**Files:**\n- Test: `pkg/workloadmanager/controller/reconciler/`\n\n**Step 1: Run all unit tests**\n\n```bash\ngo test ./pkg/workloadmanager/controller/reconciler/ -v -cover\n```\n\n**Step 2: Verify all tests pass**\n\nExpected: All tests pass with coverage > 80%\n\n**Step 3: Run linting**\n\n```bash\ngolangci-lint run ./pkg/workloadmanager/controller/reconciler/\n```\n\nExpected: No linting errors\n\n**Step 4: Commit**\n\n```bash\ngit add .\ngit commit -m \"feat(ar-007): all reconciler unit tests passing\"\n```\n\n### Task 19: Create RBAC manifests for reconciler\n\n**Files:**\n- Create: `manifests/rbac/reconciler-role.yaml`\n\n**Step 1: Create ClusterRole manifest**\n\n```yaml\napiVersion: rbac.authorization.k8s.io/v1\nkind: ClusterRole\nmetadata:\n  name: agentcube-reconciler\nrules:\n  # AgentRuntime and CodeInterpreter CRDs\n  - apiGroups: [\"runtime.agentcube.volcano.sh\"]\n    resources: [\"agentruntimes\", \"agentruntimes/status\", \"agentruntimes/finalizers\"]\n    verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"]\n\n  - apiGroups: [\"runtime.agentcube.volcano.sh\"]\n    resources: [\"codeinterpreters\", \"codeinterpreters/status\", \"codeinterpreters/finalizers\"]\n    verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"]\n\n  # Sandbox resources\n  - apiGroups: [\"agents.x-k8s.io\"]\n    resources: [\"sandboxes\"]\n    verbs: [\"get\", \"list\", \"watch\", \"create\", \"update\", \"delete\"]\n\n  # Events\n  - apiGroups: [\"\"]\n    resources: [\"events\"]\n    verbs: [\"create\", \"patch\"]\n\n  # ConfigMaps (for configuration)\n  - apiGroups: [\"\"]\n    resources: [\"configmaps\"]\n    verbs: [\"get\", \"list\", \"watch\"]\n```\n\n**Step 2: Verify manifest is valid**\n\nRun: `kubectl apply --dry-run=client -f manifests/rbac/reconciler-role.yaml`\nExpected: No validation errors\n\n**Step 3: Commit**\n\n```bash\ngit add manifests/rbac/reconciler-role.yaml\ngit commit -m \"feat(ar-007): create RBAC manifests for reconciler\"\n```\n\n### Task 20: Create example AgentRuntime CRD manifest\n\n**Files:**\n- Create: `examples/agentruntime-reconciler.yaml`\n\n**Step 1: Create example manifest**\n\n```yaml\napiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: AgentRuntime\nmetadata:\n  name: python-agent\n  namespace: agentcube\nspec:\n  sessionTimeout: \"15m\"\n  maxSessionDuration: \"8h\"\n  podTemplate:\n    metadata:\n      labels:\n        app: python-agent\n    spec:\n      containers:\n      - name: agent\n        image: ghcr.io/volcano-sh/python-agent:latest\n        ports:\n        - containerPort: 8080\n          protocol: TCP\n        resources:\n          limits:\n            cpu: \"500m\"\n            memory: \"512Mi\"\n          requests:\n            cpu: \"100m\"\n            memory: \"128Mi\"\n```\n\n**Step 2: Verify manifest is valid**\n\nRun: `kubectl apply --dry-run=client -f examples/agentruntime-reconciler.yaml`\nExpected: No validation errors (may fail if CRD not installed)\n\n**Step 3: Commit**\n\n```bash\ngit add examples/agentruntime-reconciler.yaml\ngit commit -m \"feat(ar-007): create example AgentRuntime CRD manifest\"\n```\n\n### Task 21: Create example CodeInterpreter CRD manifest\n\n**Files:**\n- Create: `examples/codeinterpreter-reconciler.yaml`\n\n**Step 1: Create example manifest**\n\n```yaml\napiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: CodeInterpreter\nmetadata:\n  name: python-interpreter\n  namespace: agentcube\nspec:\n  sessionTimeout: \"15m\"\n  maxSessionDuration: \"8h\"\n  template:\n    image: python:3.11-slim\n    ports:\n    - port: 8080\n      protocol: HTTP\n```\n\n**Step 2: Verify manifest is valid**\n\nRun: `kubectl apply --dry-run=client -f examples/codeinterpreter-reconciler.yaml`\nExpected: No validation errors (may fail if CRD not installed)\n\n**Step 3: Commit**\n\n```bash\ngit add examples/codeinterpreter-reconciler.yaml\ngit commit -m \"feat(ar-007): create example CodeInterpreter CRD manifest\"\n```\n\n### Task 22: Update documentation with reconciler configuration\n\n**Files:**\n- Modify: `docs/configuration.md`\n\n**Step 1: Add reconciler configuration section**\n\n```markdown\n## Reconciler Configuration\n\nThe reconciler-based controllers can be configured with the following options:\n\n```yaml\n# Controller configuration\ncontroller:\n  # Requeue interval for reconciliation\n  requeueAfter: 10s\n\n  # Maximum number of concurrent reconciles per controller\n  maxConcurrentReconciles: 2\n\n  # Full resync period (optional)\n  syncPeriod: 10m\n\n  # Leader election\n  enableLeaderElection: true\n  leaderElectionID: \"agentcube-reconciler\"\n  leaderElectionNamespace: \"agentcube-system\"\n\n  # Metrics\n  metricsAddr: \":8080\"\n  enableProfiling: true\n\n  # Health probes\n  probeAddr: \":8081\"\n```\n\n### Metrics\n\nThe reconciler exposes the following Prometheus metrics:\n\n- `workloadmanager_reconcile_total`: Total number of reconciliation operations\n- `workloadmanager_reconcile_errors_total`: Total number of reconciliation errors\n- `workloadmanager_reconcile_duration_seconds`: Reconciliation duration histogram\n- `workloadmanager_resources_ready`: Number of ready resources\n- `workloadmanager_sandbox_creations_total`: Total number of sandbox creations\n- `workloadmanager_sandbox_deletions_total`: Total number of sandbox deletions\n```\n\n**Step 2: Verify documentation is valid**\n\nRun: Check for markdown syntax errors\n\n**Step 3: Commit**\n\n```bash\ngit add docs/configuration.md\ngit commit -m \"feat(ar-007): update documentation with reconciler configuration\"\n```\n\n### Task 23: Create integration tests\n\n**Files:**\n- Create: `pkg/workloadmanager/controller/reconciler/integration_test.go`\n\n**Step 1: Write integration test structure**\n\n```go\n// +build integration\n\npackage reconciler_test\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes/scheme\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/envtest\"\n\t\"sigs.k8s.io/controller-runtime/pkg/manager\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/controller/reconciler\"\n)\n\nvar (\n\tenvTest   *envtest.Environment\n\tk8sClient client.Client\n\tmgr       manager.Manager\n)\n\nvar _ = BeforeSuite(func() {\n\terr := runtimev1alpha1.AddToScheme(scheme.Scheme)\n\tExpect(err).NotTo(HaveOccurred())\n\n\tenvTest = &envtest.Environment{\n\t\tCRDDirectoryPaths: []string{\n\t\t\t\"../../../manifests/charts/base/crds\",\n\t\t},\n\t}\n\n\tcfg, err := envTest.Start()\n\tExpect(err).NotTo(HaveOccurred())\n\n\tk8sClient, err = client.New(cfg, client.Options{Scheme: scheme.Scheme})\n\tExpect(err).NotTo(HaveOccurred())\n\n\tmgr, err = manager.New(cfg, manager.Options{\n\t\tScheme: scheme.Scheme,\n\t})\n\tExpect(err).NotTo(HaveOccurred())\n\n\tcontrollerCfg := &reconciler.ControllerConfig{\n\t\tRequeueAfter:           10 * time.Second,\n\t\tMaxConcurrentReconciles: 2,\n\t}\n\n\terr = reconciler.SetupWithManager(mgr, nil, controllerCfg)\n\tExpect(err).NotTo(HaveOccurred())\n\n\tgo func() {\n\t\terr = mgr.Start(context.Background())\n\t\tExpect(err).NotTo(HaveOccurred())\n\t}()\n})\n\nvar _ = AfterSuite(func() {\n\terr := envTest.Stop()\n\tExpect(err).NotTo(HaveOccurred())\n})\n\nvar _ = Describe(\"AgentRuntime Reconciler Integration\", func() {\n\tContext(\"Full lifecycle\", func() {\n\t\tIt(\"should create, update, and delete AgentRuntime with sandbox\", func(ctx SpecContext) {\n\t\t\tnamespace := \"default\"\n\n\t\t\t// Create AgentRuntime\n\t\t\tagentRuntime := &runtimev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"integration-test-runtime\",\n\t\t\t\t\tNamespace: namespace,\n\t\t\t\t},\n\t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n\t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n\t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n\t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\t\t\t\t\tImage: \"python:3.11-slim\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\n\t\t\terr := k8sClient.Create(ctx, agentRuntime)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\t\t// Wait for AgentRuntime to be ready\n\t\t\tEventually(func() bool {\n\t\t\t\tupdated := &runtimev1alpha1.AgentRuntime{}\n\t\t\t\terr := k8sClient.Get(ctx, client.ObjectKey{\n\t\t\t\t\tNamespace: namespace,\n\t\t\t\t\tName:      \"integration-test-runtime\",\n\t\t\t\t}, updated)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn false\n\t\t\t\t}\n\t\t\t\treturn reconciler.IsReady(updated.Status.Conditions)\n\t\t\t}, 30*time.Second, 2*time.Second).Should(BeTrue())\n\n\t\t\t// Delete AgentRuntime\n\t\t\terr = k8sClient.Delete(ctx, agentRuntime)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t}, SpecTimeout(2*time.Minute))\n\t})\n})\n```\n\n**Step 