)\n\nconst (\n\t// Reconciler metrics\n\tmetricReconcileTotal = \"workloadmanager_reconcile_total\"\n\tmetricReconcileErrors = \"workloadmanager_reconcile_errors_total\"\n\tmetricReconcileDuration = \"workloadmanager_reconcile_duration_seconds\"\n\tmetricReconcileRequeues = \"workloadmanager_reconcile_requeues_total\"\n\n\t// Resource metrics\n\tmetricResourcesReady = \"workloadmanager_resources_ready\"\n\tmetricResourcesPending = \"workloadmanager_resources_pending\"\n\tmetricResourcesError = \"workloadmanager_resources_error\"\n\n\t// Sandbox metrics\n\tmetricSandboxCreations = \"workloadmanager_sandbox_creations_total\"\n\tmetricSandboxDeletions = \"workloadmanager_sandbox_deletions_total\"\n\tmetricSandboxUpdateDuration = \"workloadmanager_sandbox_update_duration_seconds\"\n)\n\nvar (\n\treconcileTotal = prometheus.NewCounterVec(\n\t\tprometheus.CounterOpts{\n\t\t\tName: metricReconcileTotal,\n\t\t\tHelp: \"Total number of reconciliation operations\",\n\t\t},\n\t\t[]string{\"controller\", \"namespace\", \"name\"},\n\t)\n\n\treconcileErrors = prometheus.NewCounterVec(\n\t\tprometheus.CounterOpts{\n\t\t\tName: metricReconcileErrors,\n\t\t\tHelp: \"Total number of reconciliation errors\",\n\t\t},\n\t\t[]string{\"controller\", \"namespace\", \"name\"},\n\t)\n\n\treconcileDuration = prometheus.NewHistogramVec(\n\t\tprometheus.HistogramOpts{\n\t\t\tName:    metricReconcileDuration,\n\t\t\tHelp:    \"Reconciliation duration in seconds\",\n\t\t\tBuckets: prometheus.DefBuckets,\n\t\t},\n\t\t[]string{\"controller\", \"result\"},\n\t)\n\n\tsandboxCreations = prometheus.NewCounterVec(\n\t\tprometheus.CounterOpts{\n\t\t\tName: metricSandboxCreations,\n\t\t\tHelp: \"Total number of sandbox creations\",\n\t\t},\n\t\t[]string{\"namespace\", \"name\"},\n\t)\n\n\tsandboxDeletions = prometheus.NewCounterVec(\n\t\tprometheus.CounterOpts{\n\t\t\tName: metricSandboxDeletions,\n\t\t\tHelp: \"Total number of sandbox deletions\",\n\t\t},\n\t\t[]string{\"namespace\", \"name\"},\n\t)\n\n\tresourcesReady = prometheus.NewGaugeVec(\n\t\tprometheus.GaugeOpts{\n\t\t\tName: metricResourcesReady,\n\t\t\tHelp: \"Number of ready resources\",\n\t\t},\n\t\t[]string{\"controller\", \"namespace\"},\n\t)\n)\n\nfunc init() {\n\tprometheus.MustRegister(\n\t\treconcileTotal,\n\t\treconcileErrors,\n\t\treconcileDuration,\n\t\tsandboxCreations,\n\t\tsandboxDeletions,\n\t\tresourcesReady,\n\t)\n}\n\n// RecordReconciliation records a reconciliation operation\nfunc RecordReconciliation(controller, namespace, name string, duration float64, result string) {\n\treconcileTotal.WithLabelValues(controller, namespace, name).Inc()\n\treconcileDuration.WithLabelValues(controller, result).Observe(duration)\n\n\tif result == \"error\" {\n\t\treconcileErrors.WithLabelValues(controller, namespace, name).Inc()\n\t}\n}\n\n// RecordSandboxOperation records a sandbox operation\nfunc RecordSandboxOperation(operation, namespace, name string, duration float64, err error) {\n\tif operation == \"create\" {\n\t\tsandboxCreations.WithLabelValues(namespace, name).Inc()\n\t} else if operation == \"delete\" {\n\t\tsandboxDeletions.WithLabelValues(namespace, name).Inc()\n\t}\n}\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `go test ./pkg/workloadmanager/controller/reconciler/ -run TestRecordReconciliation -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add pkg/workloadmanager/controller/reconciler/metrics.go pkg/workloadmanager/controller/reconciler/metrics_test.go\ngit commit -m \"feat(ar-007): define metrics structure\"\n```\n\n### Task 8: Implement error handling types\n\n**Files:**\n- Create: `pkg/workloadmanager/controller/reconciler/errors.go`\n\n**Step 1: Write the failing test**\n\n```go\n// pkg/workloadmanager/controller/reconciler/errors_test.go\npackage reconciler\n\nimport (\n\t\"errors\"\n\t\"testing\"\n\n\t. \"github.com/onsi/gomega\"\n)\n\nfunc TestReconcilerError(t *testing.T) {\n\tg := NewGomegaWithT(t)\n\n\toriginalErr := errors.New(\"original error\")\n\treco