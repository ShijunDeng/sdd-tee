escribe(\"AgentRuntime E2E\", func() {\n962:     f := framework.NewDefaultFramework(\"agentruntime\")\n963: \n964:     Context(\"Create and validate AgentRuntime\", func() {\n965:         It(\"should create AgentRuntime and verify defaults\", func() {\n966:             ctx := context.Background()\n967:             \n968:             art := &runtimev1alpha1.AgentRuntime{\n969:                 ObjectMeta: metav1.ObjectMeta{\n970:                     Name:      \"e2e-art\",\n971:                     Namespace: f.Namespace.Name,\n972:                 },\n973:                 Spec: runtimev1alpha1.AgentRuntimeSpec{\n974:                     MaxSessionDuration: \"1h\",\n975:                     SessionTimeout:     \"5m\",\n976:                     TargetPort: []runtimev1alpha1.TargetPort{\n977:                         {\n978:                             Port:     8080,\n979:                             Protocol: \"HTTP\",\n980:                         },\n981:                     },\n982:                     PodTemplate: runtimev1alpha1.PodTemplateSpec{\n983:                         Spec: runtimev1alpha1.PodSpec{\n984:                             Containers: []runtimev1alpha1.Container{\n985:                                 {\n986:                                     Name:  \"agent\",\n987:                                     Image: \"nginx:latest\",\n988:                                 },\n989:                             },\n990:                         },\n991:                     },\n992:                 },\n993:             }\n994: \n995:             err := f.Client.Create(ctx, art)\n996:             Expect(err).NotTo(HaveOccurred())\n997: \n998:             // Verify creation\n999:             Eventually(func() bool {\n1000:                 var fetchedArt runtimev1alpha1.AgentRuntime\n1001:                 err := f.Client.Get(ctx, client.ObjectKeyFromObject(art), &fetchedArt)\n1002:                 return err == nil\n1003:             }, 10*time.Second, time.Second