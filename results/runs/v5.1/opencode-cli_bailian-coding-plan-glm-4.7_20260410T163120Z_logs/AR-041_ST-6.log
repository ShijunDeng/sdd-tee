load,\n146: \t\tHeaders: headers,\n147: \t})\n148: \tif err != nil {\n149: \t\treturn nil, fmt.Errorf(\"failed to marshal request: %w\", err)\n150: \t}\n151: \n152: \thttpReq, err := http.NewRequestWithContext(ctx, http.MethodPost, url, bytes.NewReader(reqBody))\n153: \tif err != nil {\n154: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n155: \t}\n156: \n157: \thttpReq.Header.Set(\"Content-Type\", \"application/json\")\n158: \tfor k, v := range headers {\n159: \t\thttpReq.Header.Set(k, v)\n160: \t}\n161: \n162: \tresp, err := h.framework.HTTPClient().Do(httpReq)\n163: \tif err != nil {\n164: \t\treturn nil, fmt.Errorf(\"failed to send request: %w\", err)\n165: \t}\n166: \tdefer resp.Body.Close()\n167: \n168: \tbody, err := io.ReadAll(resp.Body)\n169: \tif err != nil {\n170: \t\treturn nil, fmt.Errorf(\"failed to read response: %w\", err)\n171: \t}\n172: \n173: \tresponseHeaders := make(map[string]string)\n174: \tfor k, v := range resp.Header {\n175: \t\tif len(v) > 0 {\n176: \t\t\tresponseHeaders[k] = v[0]\n177: \t\t}\n178: \t}\n179: \n180: \treturn &InvokeResponse{\n181: \t\tStatusCode: resp.StatusCode,\n182: \t\tHeaders:    responseHeaders,\n183: \t\tBody:       body,\n184: \t}, nil\n185: }\n186: \n187: func (h *AgentRuntimeHelper) DeleteSession(ctx context.Context, sessionID string) error {\n188: \turl := fmt.Sprintf(\"http://agentcube-workload-manager.%s/v1/sessions/%s\", h.framework.Namespace(), sessionID)\n189: \n190: \thttpReq, err := http.NewRequestWithContext(ctx, http.MethodDelete, url, nil)\n191: \tif err != nil {\n192: \t\treturn fmt.Errorf(\"failed to create request: %w\", err)\n193: \t}\n194: \n195: \tresp, err := h.framework.HTTPClient().Do(httpReq)\n196: \tif err != nil {\n197: \t\treturn fmt.Errorf(\"failed to send request: %w\", err)\n198: \t}\n199: \tdefer resp.Body.Close()\n200: \n201: \tif resp.StatusCode != http.StatusOK && resp.StatusCode != http.StatusNotFound {\n202: \t\treturn fmt.Errorf(\"unexpected status code: %d\", r