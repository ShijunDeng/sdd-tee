config := *c\n\tif err := setConfigDefaults(&config); err != nil {\n\t\treturn nil, err\n\t}\n\tclient, err := rest.RESTClientFor(&config)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn &RuntimeV1alpha1Client{client}, nil\n}\n\nfunc NewForConfigAndClient(c *rest.Config, httpClient *rest.HttpClient) (*RuntimeV1alpha1Client, error) {\n\tconfig := *c\n\tif err := setConfigDefaults(&config); err != nil {\n\t\treturn nil, err\n\t}\n\tclient, err := rest.RESTClientForConfigAndClient(&config, httpClient)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn &RuntimeV1alpha1Client{client}, nil\n}\n\nfunc NewForConfigOrDie(c *rest.Config) *RuntimeV1alpha1Client {\n\tclient, err := NewForConfig(c)\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\treturn client\n}\n\nfunc New(c rest.Interface) *RuntimeV1alpha1Client {\n\treturn &RuntimeV1alpha1Client{c}\n}\n\nfunc setConfigDefaults(config *rest.Config) error {\n\tgv := schema.GroupVersion{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\"}\n\tconfig.GroupVersion = &gv\n\tconfig.APIPath = \"/apis\"\n\tconfig.NegotiatedSerializer = scheme.Codecs.WithoutConversion()\n\tif config.UserAgent == \"\" {\n\t\tconfig.UserAgent = rest.DefaultKubernetesUserAgent()\n\t}\n\treturn nil\n}\n\nfunc (c *RuntimeV1alpha1Client) RESTClient() rest.Interface {\n\tif c == nil {\n\t\treturn nil\n\t}\n\treturn c.restClient\n}\n\nfunc (c *RuntimeV1alpha1Client) AgentRuntimes() AgentRuntimeInterface {\n\treturn newAgentRuntimes(c)\n}\n\nfunc (c *RuntimeV1alpha1Client) CodeInterpreters() CodeInterpreterInterface {\n\treturn newCodeInterpreters(c)\n}\n","after":"/*\nCopyright 2024 The AgentCube Authors.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on