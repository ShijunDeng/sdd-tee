Prefix is the URL path prefix for this port\n124:     PathPrefix string `json:\"pathPrefix,omitempty\"`\n125: }\n126: \n127: // PodTemplateSpec defines the pod template specification\n128: type PodTemplateSpec struct {\n129:     // Metadata for the pod\n130:     Metadata metav1.ObjectMeta `json:\"metadata,omitempty\"`\n131:     \n132:     // Spec for the pod\n133:     Spec PodSpec `json:\"spec,omitempty\"`\n134: }\n135: \n136: // AgentRuntime is the Schema for the agentruntimes API\n137: // +kubebuilder:object:root=true\n138: // +kubebuilder:subresource:status\n139: // +kubebuilder:resource:shortName=art\n140: // +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n141: type AgentRuntime struct {\n142:     metav1.TypeMeta   `json:\",inline\"`\n143:     metav1.ObjectMeta `json:\"metadata,omitempty\"`\n144:     \n145:     Spec   AgentRuntimeSpec   `json:\"spec,omitempty\"`\n146:     Status AgentRuntimeStatus `json:\"status,omitempty\"`\n147: }\n148: \n149: // AgentRuntimeList contains a list of AgentRuntime\n150: // +kubebuilder:object:root=true\n151: type AgentRuntimeList struct {\n152:     metav1.TypeMeta `json:\",inline\"`\n153:     metav1.ListMeta `json:\"metadata,omitempty\"`\n154:     \n155:     Items []AgentRuntime `json:\"items\"`\n156: }\n157: ```\n158: \n159: ### CodeInterpreter\n160: \n161: **File**: `pkg/apis/runtime/v1alpha1/codeinterpreter_types.go`\n162: \n163: ```go\n164: // CodeInterpreterSpec defines the desired state of CodeInterpreter\n165: type CodeInterpreterSpec struct {\n166:     // AuthMode specifies the authentication mode\n167:     // +kubebuilder:default=\"picod\"\n168:     // +kubebuilder:validation:Enum=picod;none\n169:     AuthMode string `json:\"authMode\"`\n170:     \n171:     // MaxSessionDuration is the maximum duration for any session\n172:     // +kubebuilder:default=\"8h\"\n173:     MaxSessionDuration string `json:\"maxSessionDuration\"`\n174:     \n175:     // SessionTimeout is the idle ti