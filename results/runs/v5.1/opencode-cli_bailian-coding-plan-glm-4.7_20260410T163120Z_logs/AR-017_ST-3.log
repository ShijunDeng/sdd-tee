\n47: \tauthManager, err := NewAuthManager()\n48: \tif err != nil {\n49: \t\treturn nil, err\n50: \t}\n51: \n52: \tgin.SetMode(gin.ReleaseMode)\n53: \tengine := gin.New()\n54: \n55: \tengine.Use(gin.Recovery())\n56: \tengine.Use(gin.Logger())\n57: \n58: \tserver := &Server{\n59: \t\tengine:       engine,\n60: \t\tconfig:       config,\n61: \t\tauthManager:  authManager,\n62: \t\tstartTime:    time.Now(),\n63: \t\tworkspaceDir: absWorkspace,\n64: \t}\n65: \n66: \tserver.registerRoutes()\n67: \n68: \tif config.K8sConfig != nil {\n69: \t\tk8sClient, err := NewK8sClient(*config.K8sConfig)\n70: \t\tif err != nil {\n71: \t\t\tklog.Warningf(\"Failed to create Kubernetes client: %v\", err)\n72: \t\t} else {\n73: \t\t\tserver.k8sClient = k8sClient\n74: \t\t\tklog.Infof(\"Kubernetes client initialized for namespace: %s\", k8sClient.GetNamespace())\n75: \n76: \t\t\tworkspaceManager, err := NewWorkspaceManager(absWorkspace, k8sClient)\n77: \t\t\tif err != nil {\n78: \t\t\t\tklog.Warningf(\"Failed to create workspace manager: %v\", err)\n79: \t\t\t} else {\n80: \t\t\t\tserver.workspaceManager = workspaceManager\n81: \t\t\t\tklog.Infof(\"Workspace manager initialized at: %s\", absWorkspace)\n82: \n83: \t\t\t\tif k8sClient.GetAgentRuntimeName() != \"\" {\n84: \t\t\t\t\tstatusReporter := NewStatusReporter(k8sClient, workspaceManager, k8sClient.GetAgentRuntimeName(), time.Minute)\n85: \t\t\t\t\tserver.statusReporter = statusReporter\n86: \t\t\t\t\tgo statusReporter.Start()\n87: \t\t\t\t\tklog.Infof(\"Status reporter started for AgentRuntime: %s\", k8sClient.GetAgentRuntimeName())\n88: \n89: \t\t\t\t\tinformerManager := NewInformerManager(k8sClient, server, workspaceManager, statusReporter)\n90: \t\t\t\t\tserver.informerManager = informerManager\n91: \n92: \t\t\t\t\tif err := informerManager.SetupAgentRuntimeInformer(); err != nil {\n93: \t\t\t\t\t\tklog.Errorf(\"Failed to setup AgentRuntime informer: %v\", err)\n94: \t\t\t\t\t} else {\n95: \t\t\t\t\t\tklog.Info(\"AgentRuntime informer setup completed\")\n96: \t\t\t\t\t}\n97: \n98: \t\t\t\t\tif err := informerManager.SetupCodeInterpreterInformer(); err != nil {\n99: \t\t\t\t\t\tklog.Errorf(\"Failed to setup CodeInterpreter informer: %v\", err)\n100: \t\t\t\t\t} else {\n101: \t\t\t\t\t\tklog.Info(\"CodeInterpreter informer setup completed\")\n102: \t\t\t\t\t}\n103: \n104: \t\t\t\t\tk8sClient.StartInformers()\n105: \t\t\t\t\tsynced := k8sClient.WaitForCacheSync()\n106: \t\t\t\t\tklog.Infof(\"Informer cache sync: %v\", synced)\n107: \t\t\t\t}\n108: \t\t\t}\n109: \t\t}\n110: \t}\n111: \n112: \treturn server, nil\n113: }\n114: \n115: func (s *Server) registerRoutes() {\n116: \tapi := s.engine.Group(\"/api\")\n117: \tapi.Use(AuthMiddleware(s.authManager))\n118: \t{\n119: \t\tapi.POST(\"/execute\", s.ExecuteHandler)\n120: \t\tapi.POST(\"/files\", s.UploadFileHandler)\n121: \t\tapi.GET(\"/files\", s.ListFilesHandler)\n122: \t\tapi.GET(\"/files/*path\", s.DownloadFileHandler)\n123: \t}\n124: \n125: \ts.engine.GET(\"/health\", s.HealthCheckHandler)\n126: }\n127: \n128: func (s *Server) Run() error {\n129: \taddr := fmt.Sprintf(\":%d\", s.config.Port)\n130: \ts.httpServer = &http.Server{\n131: \t\tAddr:              addr,\n132: \t\tHandler:           s.engine,\n133: \t\tReadHeaderTimeout: ReadHeaderTimeout,\n134: \t}\n135: \n136: \tklog.Infof(\"Starting %s server on port %d\", ServiceName, s.config.Port)\n137: \tklog.Infof(\"Workspace directory: %s\", s.workspaceDir)\n138: \tklog.Infof(\"Server version: %s\", Version)\n139: \n140: \tif s.k8sClient != nil {\n141: \t\tklog.Infof(\"Kubernetes integration enabled for AgentRuntime: %s\", s.k8sClient.GetAgentRuntimeName())\n142: \t}\n143: \n144: \tif err := s.httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n145: \t\treturn err\n146: \t}\n147: \n148: \treturn nil\n149: }\n150: \n151: func (s *Server) Shutdown(ctx context.Context) error {\n152: \tklog.Info(\"Shutting down server...\")\n153: \n154: \tif s.statusReporter != nil {\n155: \t\ts.statusReporter.Stop()\n156: \t\tklog.Info(\"Status reporter stopped\")\n157: \t}\n158: \n159: \tif s.k8sClient != nil {\n160: \t\ts.k8sClient.Stop()\n161: \t\tklog.Info(\"Kubernetes client stopped\")\n162: \t}\n163: \n164: \tif err := s.httpServer.Shutdown(ctx); err != nil {\n165: \t\treturn err\n166: \t}\n167: \n168: \tklog.Info(\"Server shutdown complete\")\n169: \treturn nil\n170: }\n171: \n172: func (s *Server) GetWorkspaceManager() *WorkspaceManager {\n173: \treturn s.workspaceManager\n174: }\n175: \n176: func (s *Server) GetK8sClient() *K8sClient {\n177: \treturn s.k8sClient\n178: }\n\n(End of file - total 178 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tengine           *gin.Engine\n\tconfig           Config\n\tauthManager      *AuthManager\n\tstartTime        time.Time\n\tworkspaceDir     string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server.go","time":{"start":1775860774468,"end":1775860774487}}}}
