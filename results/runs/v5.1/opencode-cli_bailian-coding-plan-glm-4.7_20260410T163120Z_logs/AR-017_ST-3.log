c AuthMiddleware(authManager *AuthManager) gin.HandlerFunc {\n\treturn func(c *gin.Context) {\n\t\tauthHeader := c.GetHeader(HeaderAuthorization)\n\t\tif authHeader == \"\" {\n\t\t\tHandleError(c, NewError(ErrMissingAuthHeader, ErrMsgMissingAuthHeader, \"\", nil))\n\t\t\tc.Abort()\n\t\t\treturn\n\t\t}\n\n\t\tif !strings.HasPrefix(authHeader, \"Bearer \") {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/middleware.go","time":{"start":1775860771671,"end":1775860771684}}}}
