 .Values.imagePullSecrets }}\n1015:       imagePullSecrets:\n1016:         {{- toYaml . | nindent 8 }}\n1017:       {{- end }}\n1018:       serviceAccountName: {{ include \"agentcube.workloadManager.serviceAccountName\" . }}\n1019:       securityContext:\n1020:         {{- toYaml .Values.workloadManager.securityContext | nindent 8 }}\n1021:       {{- with .Values.workloadManager.nodeSelector }}\n1022:       nodeSelector:\n1023:         {{- toYaml . | nindent 8 }}\n1024:       {{- end }}\n1025:       {{- with .Values.workloadManager.affinity }}\n1026:       affinity:\n1027:         {{- toYaml . | nindent 8 }}\n1028:       {{- end }}\n1029:       {{- with .Values.workloadManager.tolerations }}\n1030:       tolerations:\n1031:         {{- toYaml . | nindent 8 }}\n1032:       {{- end }}\n1033:       {{- if .Values.priorityClassName }}\n1034:       priorityClassName: {{ .Values.priorityClassName }}\n1035:       {{- end }}\n1036:       containers:\n1037:       - name: workload-manager\n1038:         securityContext:\n1039:           {{- toYaml .Values.workloadManager.containerSecurityContext | nindent 10 }}\n1040:         image: \"{{ include \"agentcube.image\" (dict \"registry\" .Values.global.imageRegistry \"repository\" .Values.workloadManager.image.repository \"tag\" .Values.workloadManager.image.tag) }}\"\n1041:         imagePullPolicy: {{ .Values.workloadManager.image.pullPolicy }}\n1042:         args:\n1043:         - --leader-elect\n1044:         - --health-probe-bind-address=:8080\n1045:         - --metrics-bind-address=:9090\n1046:         ports:\n1047:         - name: http\n1048:           containerPort: 8080\n1049:           protocol: TCP\n1050:         - name: metrics\n1051:           containerPort: 9090\n1052:           protocol: TCP\n1053:         {{- with .Values.workloadManager.livenessProbe }}\n1054:         livenessProbe:\n1055:           {{- toYaml . | nindent 10 }}\n1056:         {{- end }}\n1057:         {{- with .Values.workloadManager.readinessProbe }}\n1058:         readinessProbe:\n1059:           {{- toYaml . | nindent 10 }}\n1060:         {{- end }}\n1061:         resources:\n1062:           {{- toYaml .Values.workloadManager.resources | nindent 10 }}\n1063:         {{- with .Values.workloadManager.env }}\n1064:         env:\n1065:           {{- toYaml . | nindent 10 }}\n1066:         {{- end }}\n1067:         {{- with .Values.workloadManager.envFrom }}\n1068:         envFrom:\n1069:           {{- toYaml . | nindent 10 }}\n1070:         {{- end }}\n1071:         {{- with .Values.workloadManager.extraVolumeMounts }}\n1072:         volumeMounts:\n1073:           {{- toYaml . | nindent 10 }}\n1074:         {{- end }}\n1075:       {{- with .Values.workloadManager.extraVolumes }}\n1076:       volumes:\n1077:         {{- toYaml . | nindent 6 }}\n1078:       {{- end }}\n1079: {{- end }}\n1080: ```\n1081: \n1082: ### Template: Router Deployment\n1083: \n1084: **File:** `templates/router/deployment.yaml`\n1085: \n1086: ```yaml\n1087: {{- if .Values.router.enabled }}\n1088: apiVersion: apps/v1\n1089: kind: Deployment\n1090: metadata:\n1091:   name: {{ printf \"%s-router\" (include \"agentcube.fullname\" .) }}\n1092:   namespace: {{ include \"agentcube.namespace\" . }}\n1093:   labels:\n1094:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1095:     app.kubernetes.io/component: router\n1096: spec:\n1097:   replicas: {{ .Values.router.replicaCount }}\n1098:   selector:\n1099:     matchLabels:\n1100:       {{- include \"agentcube.selectorLabels\" . | nindent 6 }}\n1101:       app.kubernetes.io/component: router\n1102:   template:\n1103:     metadata:\n1104:       annotations:\n1105:         checksum/config: {{ include (print $.Template.BasePath \"/configmaps/config.yaml\") . | sha256sum }}\n1106:         {{- with .Values.router.podAnnotations }}\n1107:         {{- toYaml . | nindent 8 }}\n1108:         {{- end }}\n1109:       labels:\n1110:         {{- include \"agentcube.selectorLabels\" . | nindent 8 }}\n1111:         app.kubernetes.io/component: router\n1112:         {{- with .Values.router.podLabels }}\n1113:         {{- toYaml . | nindent 8 }}\n1114:         {{- end }}\n1115:     spec:\n1116:       {{- with .Values.imagePullSecrets }}\n1117:       imagePullSecrets:\n1118:         {{- toYaml . | nindent 8 }}\n1119:       {{- end }}\n1120:       serviceAccountName: {{ include \"agentcube.router.serviceAccountName\" . }}\n1121:       securityContext:\n1122:         {{- toYaml .Values.router.securityContext | nindent 8 }}\n1123:       {{- with .Values.router.nodeSelector }}\n1124:       nodeSelector:\n1125:         {{- toYaml . | nindent 8 }}\n1126:       {{- end }}\n1127:       {{- with .Values.router.affinity }}\n1128:       affinity:\n1129:         {{- toYaml . | nindent 8 }}\n1130:       {{- end }}\n1131:       {{- with .Values.router.tolerations }}\n1132:       tolerations:\n1133:         {{- toYaml . | nindent 8 }}\n1134:       {{- end }}\n1135:       {{- if .Values.priorityClassName }}\n1136:       priorityClassName: {{ .Values.priorityClassName }}\n1137:       {{- end }}\n1138:       containers:\n1139:       - name: router\n1140:         securityContext:\n1141:           {{- toYaml .Values.router.containerSecurityContext | nindent 10 }}\n1142:         image: \"{{ include \"agentcube.image\" (dict \"registry\" .Values.global.imageRegistry \"repository\" .Values.router.image.repository \"tag\" .Values.router.image.tag) }}\"\n1143:         imagePullPolicy: {{ .Values.router.image.pullPolicy }}\n1144:         args:\n1145:         - --leader-elect\n1146:         - --health-probe-bind-address=:8080\n1147:         - --metrics-bind-address=:9090\n1148:         ports:\n1149:         - name: http\n1150:           containerPort: 8080\n1151:           protocol: TCP\n1152:         - name: metrics\n1153:           containerPort: 9090\n1154:           protocol: TCP\n1155:         {{- with .Values.router.livenessProbe }}\n1156:         livenessProbe:\n1157:           {{- toYaml . | nindent 10 }}\n1158:         {{- end }}\n1159:         {{- with .Values.router.readinessProbe }}\n1160:         readinessProbe:\n1161:           {{- toYaml . | nindent 10 }}\n1162:         {{- end }}\n1163:         resources:\n1164:           {{- toYaml .Values.router.resources | nindent 10 }}\n1165:         {{- with .Values.router.env }}\n1166:         env:\n1167:           {{- toYaml . | nindent 10 }}\n1168:         {{- end }}\n1169:         {{- with .Values.router.envFrom }}\n1170:         envFrom:\n1171:           {{- toYaml . | nindent 10 }}\n1172:         {{- end }}\n1173:         {{- with .Values.router.extraVolumeMounts }}\n1174:         volumeMounts:\n1175:           {{- toYaml . | nindent 10 }}\n1176:         {{- end }}\n1177:       {{- with .Values.router.extraVolumes }}\n1178:       volumes:\n1179:         {{- toYaml . | nindent 6 }}\n1180:       {{- end }}\n1181: {{- end }}\n1182: ```\n1183: \n1184: ### Template: ServiceMonitor\n1185: \n1186: **File:** `templates/monitoring/servicemonitor.yaml`\n1187: \n1188: ```yaml\n1189: {{- if and .Values.monitoring.enabled .Values.monitoring.serviceMonitor.enabled }}\n1190: apiVersion: monitoring.coreos.com/v1\n1191: kind: ServiceMonitor\n1192: metadata:\n1193:   name: {{ include \"agentcube.fullname\" . }}\n1194:   namespace: {{ include \"agentcube.namespace\" . }}\n1195:   labels:\n1196:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1197:     {{- with .Values.monitoring.serviceMonitor.labels }}\n1198:     {{- toYaml . | nindent 4 }}\n1199:     {{- end }}\n1200:   {{- with .Values.monitoring.serviceMonitor.annotations }}\n1201:   annotations:\n1202:     {{- toYaml . | nindent 4 }}\n1203:   {{- end }}\n1204: spec:\n1205:   selector:\n1206:     matchLabels:\n1207:       {{- include \"agentcube.selectorLabels\" . | nindent 6 }}\n1208:   namespaceSelector:\n1209:     matchNames:\n1210:       - {{ include \"agentcube.namespace\" . }}\n1211:   endpoints:\n1212:   - port: metrics\n1213:     interval: {{ .Values.monitoring.serviceMonitor.interval }}\n1214:     scrapeTimeout: {{ .Values.monitoring.serviceMonitor.scrapeTimeout }}\n1215:     path: /metrics\n1216:     {{- with .Values.monitoring.serviceMonitor.metricRelabelings }}\n1217:     metricRelabelings:\n1218:       {{- toYaml . | nindent 4 }}\n1219:     {{- end }}\n1220:     {{- with .Values.monitoring.serviceMonitor.relabelings }}\n1221:     relabelings:\n1222:       {{- toYaml . | nindent 4 }}\n1223:     {{- end }}\n1224: {{- end }}\n1225: ```\n1226: \n1227: ### Template: PodDisruptionBudget\n1228: \n1229: **File:** `templates/poddisruptionbudgets/controller-manager.yaml`\n1230: \n1231: ```yaml\n1232: {{- if and .Values.controllerManager.enabled .Values.controllerManager.podDisruptionBudget.enabled }}\n1233: apiVersion: policy/v1\n1234: kind: PodDisruptionBudget\n1235: metadata:\n1236:   name: {{ include \"agentcube.fullname\" . }}\n1237:   namespace: {{ include \"agentcube.namespace\" . }}\n1238:   labels:\n1239:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1240:     app.kubernetes.io/component: controller-manager\n1241: spec:\n1242:   minAvailable: {{ .Values.controllerManager.podDisruptionBudget.minAvailable }}\n1243:   selector:\n1244:     matchLabels:\n1245:       {{- include \"agentcube.selectorLabels\" . | nindent 6 }}\n1246:       app.kubernetes.io/component: controller-manager\n1247: {{- end }}\n1248: ```\n1249: \n1250: ### Template: Ingress\n1251: \n1252: **File:** `templates/ingress.yaml`\n1253: \n1254: ```yaml\n1255: {{- if .Values.ingress.enabled }}\n1256: apiVersion: networking.k8s.io/v1\n1257: kind: Ingress\n1258: metadata:\n1259:   name: {{ include \"agentcube.fullname\" . }}\n1260:   namespace: {{ include \"agentcube.namespace\" . }}\n1261:   labels:\n1262:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1263:   {{- with .Values.ingress.annotations }}\n1264:   annotations:\n1265:     {{- toYaml . | nindent 4 }}\n1266:   {{- end }}\n1267: spec:\n1268:   ingressClassName: {{ .Values.ingress.className }}\n1269:   {{- if .Values.ingress.tls }}\n1270:   tls:\n1271:     {{- range .Values.ingress.tls }}\n1272:     - hosts:\n1273:         {{- range .hosts }}\n1274:         - {{ . | quote }}\n1275:         {{- end }}\n1276:       secretName: {{ .secretName }}\n1277:     {{- end }}\n1278:   {{- end }}\n1279:   rules:\n1280:     {{- range .Values.ingress.hosts }}\n1281:     - host: {{ .host | quote }}\n1282:       http:\n1283:         paths:\n1284:           {{- range .paths }}\n1285:           - path: {{ .path }}\n1286:             pathType: {{ .pathType }}\n1287:             backend:\n1288:               service:\n1289:                 name: {{ .backend.service.name | default (printf \"%s-router\" (include \"agentcube.fullname\" $)) }}\n1290:                 port:\n1291:                   number: {{ .backend.service.port.number | default 8080 }}\n1292:           {{- end }}\n1293:     {{- end }}\n1294: {{- end }}\n1295: ```\n1296: \n1297: ### Template: NetworkPolicy\n1298: \n1299: **File:** `templates/networkpolicies/networkpolicy.yaml`\n1300: \n1301: ```yaml\n1302: {{- if .Values.networkPolicies.enabled }}\n1303: apiVersion: networking.k8s.io/v1\n1304: kind: NetworkPolicy\n1305: metadata:\n1306:   name: {{ include \"agentcube.fullname\" . }}\n1307:   namespace: {{ include \"agentcube.namespace\" . }}\n1308:   labels:\n1309:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1310: spec:\n1311:   podSelector: {}\n1312:   {{- if .Values.networkPolicies.defaultDeny }}\n1313:   policyTypes:\n1314:   - Ingress\n1315:   - Egress\n1316:   {{- end }}\n1317:   ingress:\n1318:   {{- range .Values.networkPolicies.rules.controllerManager.ingress }}\n1319:   - from:\n1320:     {{- range .from }}\n1321:     {{- toYaml . | nindent 6 }}\n1322:     {{- end }}\n1323:     ports:\n1324:     {{- range .ports }}\n1325:     - {{ toYaml . | nindent 8 }}\n1326:     {{- end }}\n1327:   {{- end }}\n1328:   egress:\n1329:   {{- range .Values.networkPolicies.rules.controllerManager.egress }}\n1330:   - to:\n1331:     {{- range .to }}\n1332:     {{- toYaml . | nindent 6 }}\n1333:     {{- end }}\n1334:     ports:\n1335:     {{- range .ports }}\n1336:     - {{ toYaml . | nindent 8 }}\n1337:     {{- end }}\n1338:   {{- end }}\n1339: {{- end }}\n1340: ```\n1341: \n1342: ### Template: ConfigMap\n1343: \n1344: **File:** `templates/configmaps/config.yaml`\n1345: \n1346: ```yaml\n1347: {{- if .Values.configMaps.agentcubeConfig.create }}\n1348: apiVersion: v1\n1349: kind: ConfigMap\n1350: metadata:\n1351:   name: {{ include \"agentcube.fullname\" . }}-config\n1352:   namespace: {{ include \"agentcube.namespace\" . }}\n1353:   labels:\n1354:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1355: data:\n1356:   {{- toYaml .Values.configMaps.agentcubeConfig.data | nindent 2 }}\n1357: {{- end }}\n1358: ```\n1359: \n1360: ### Template: Secret\n1361: \n1362: **File:** `templates/secrets/secret.yaml`\n1363: \n1364: ```yaml\n1365: {{- if .Values.secrets.create }}\n1366: apiVersion: v1\n1367: kind: Secret\n1368: metadata:\n1369:   name: {{ .Values.secrets.name | default (printf \"%s-secrets\" (include \"agentcube.fullname\" .)) }}\n1370:   namespace: {{ include \"agentcube.namespace\" . }}\n1371:   labels:\n1372:     {{- include \"agentcube.labels\" . | nindent 4 }}\n1373: type: Opaque\n1374: data:\n1375:   {{- range $key, $value := .Values.secrets.data }}\n1376:   {{ $key }}: {{ $value | b64enc }}\n1377:   {{- end }}\n1378: {{- end }}\n1379: ```\n1380: \n1381: ### Template: NOTES.txt\n1382: \n1383: **File:** `templates/NOTES.txt`\n1384: \n1385: ```yaml\n1386: Thank you for installing {{ .Chart.Name }}!\n1387: \n1388: Your release is named {{ .Release.Name }}.\n1389: \n1390: To learn more about the release, try:\n1391: \n1392:   $ helm status {{ .Release.Name }}\n1393:   $ helm get all {{ .Release.Name }}\n1394: \n1395: {{- if .Values.ingress.enabled }}\n1396: To access the AgentCube Router:\n1397: \n1398:   {{- range .Values.ingress.hosts }}\n1399:   http{{ if $.Values.ingress.tls }}s{{ end }}://{{ .host }}\n1400:   {{- end }}\n1401: \n1402: {{- else if contains \"NodePort\" .Values.router.service.type }}\n1403: \n1404: Get the Router URL by running these commands:\n1405: \n1406:   export NODE_PORT=$(kubectl get --namespace {{ include \"agentcube.namespace\" . }} -o jsonpath=\"{.spec.ports[0].nodePort}\" services {{ printf \"%s-router\" (include \"agentcube.fullname\" .) }})\n1407:   export NODE_IP=$(kubectl get nodes --namespace {{ include \"agentcube.namespace\" . }} -o jsonpath=\"{.items[0].status.addresses[0].address}\")\n1408: \n1409:   echo http://$NODE_IP:$NODE_PORT\n1410: \n1411: {{- else if contains \"LoadBalancer\" .Values.router.service.type }}\n1412: \n1413: Get the Router URL by running these commands:\n1414: \n1415:   NOTE: It may take a few minutes for the LoadBalancer IP to be available.\n1416:         You can watch the status by running 'kubectl get svc --namespace {{ include \"agentcube.namespace\" . }} -w {{ printf \"%s-router\" (include \"agentcube.fullname\" .) }}'\n1417: \n1418:   export SERVICE_IP=$(kubectl get svc --namespace {{ include \"agentcube.namespace\" . }} {{ printf \"%s-router\" (include \"agentcube.fullname\" .) }} -o jsonpath='{.status.loadBalancer.ingress[0].ip}')\n1419: \n1420:   echo http://$SERVICE_IP:{{ .Values.router.service.port }}\n1421: \n1422: {{- else if contains \"ClusterIP\" .Values.router.service.type }}\n1423: \n1424: Get the Router URL by running these commands:\n1425: \n1426:   export POD_NAME=$(kubectl get pods --namespace {{ include \"agentcube.namespace\" . }} -l \"app.kubernetes.io/name={{ include \"agentcube.name\" . }},app.kubernetes.io/instance={{ .Release.Name }},app.kubernetes.io/component=router\" -o jsonpath=\"{.items[0].metadata.name}\")\n1427: \n1428:   kubectl port-forward --namespace {{ include \"agentcube.namespace\" . }} $POD_NAME 8080:8080\n1429: \n1430:   echo \"Visit http://127.0.0.1:8080 to use the AgentCube Router\"\n1431: \n1432: {{- end }}\n1433: \n1434: {{- if .Values.monitoring.enabled }}\n1435: \n1436: Monitoring is enabled. ServiceMonitor {{ include \"agentcube.fullname\" . }} has been created.\n1437: \n1438: To verify Prometheus is scraping metrics:\n1439: \n1440:   $ kubectl get servicemonitor {{ include \"agentcube.fullname\" . }} -n {{ include \"agentcube.namespace\" . }}\n1441: \n1442: {{- end }}\n1443: \n1444: For more information, visit:\n1445:   https://github.com/volcano-sh/agentcube\n1446: ```\n1447: \n1448: ## Error Handling\n1449: \n1450: ### Helm Template Validation\n1451: \n1452: **Linting:**\n1453: ```bash\n1454: helm lint ./agentcube\n1455: ```\n1456: \n1457: **Template rendering validation:**\n1458: ```bash\n1459: helm template agentcube ./agentcube --debug\n1460: ```\n1461: \n1462: **Values validation:**\n1463: ```bash\n1464: helm show values ./agentcube > values.yaml\n1465: # Validate values.yaml manually or with schema validation tool\n1466: ```\n1467: \n1468: ### Common Template Errors\n1469: \n1470: | Error Type | Cause | Resolution |\n1471: |------------|-------|------------|\n1472: | `variable not defined` | Reference to undefined template variable | Ensure variable is defined in _helpers.tpl or passed as parameter |\n1473: | `invalid type for index` | Trying to index non-map/slice type | Check value type before indexing |\n1474: | `nil pointer dereference` | Accessing field of nil value | Use `with` or `if` to check for nil |\n1475: | `unexpected end` | Unclosed template block | Check for matching `{{-` and `}}` |\n1476: | `redefinition` | Duplicate template definition | Ensure each template has unique name |\n1477: | `unknown identifier` | Reference to unknown Go template function | Use available Helm template functions only |\n1478: \n1479: ### Values Validation Errors\n1480: \n1481: | Error | Condition | Message |\n1482: |-------|-----------|---------|\n1483: | Invalid port | Port outside 1-65535 range | \"Port must be between 1 and 65535\" |\n1484: | Invalid replica count | Replica count < 0 | \"Replica count must be non-negative\" |\n1485: | Missing required value | Required field not set | \"Required value 'X' not set\" |\n1486: | Invalid image tag | Empty image tag with tag required | \"Image tag cannot be empty\" |\n1487: | Invalid resource request | CPU/memory request > limit | \"Resource request cannot exceed limit\" |\n1488: \n1489: ### Installation/Upgrade Errors\n1490: \n1491: ```bash\n1492: # Error: CRD already exists with different schema\n1493: Solution: helm upgrade --install --force or manually delete CRD\n1494: \n1495: # Error: Namespace does not exist\n1496: Solution: kubectl create namespace <namespace>\n1497: \n1498: # Error: Image pull failure\n1499: Solution: Check imagePullSecrets and image registry access\n1500: \n1501: # Error: Insufficient resources\n1502: Solution: Adjust resource requests/limits in values.yaml\n1503: \n1504: # Error: RBAC permissions denied\n1505: Solution: Ensure cluster-admin role or create necessary RBAC\n1506: ```\n1507: \n1508: ### Rollback Strategy\n1509: \n1510: ```bash\n1511: # View revision history\n1512: helm history <release-name>\n1513: \n1514: # Rollback to previous version\n1515: helm rollback <release-name> <revision>\n1516: \n1517: # Rollback with specific values\n1518: helm rollback <release-name> <revision> --reuse-values\n1519: \n1520: # Rollback and reconfigure\n1521: helm rollback <release-name> <revision> -f values.yaml\n1522: ```\n1523: \n1524: ### Error Reporting\n1525: \n1526: **Custom error messages in templates:**\n1527: ```yaml\n1528: {{- if not .Values.controllerManager.enabled }}\n1529: {{- fail \"Controller Manager must be enabled for AgentCube to function\" }}\n1530: {{- end }}\n1531: \n1532: {{- if lt .Values.router.replicaCount 1 }}\n1533: {{- fail \"Router replica count must be at least 1\" }}\n1534: {{- end }}\n1535: \n1536: {{- if not (hasKey .Values.controllerManager.image \"tag\") }}\n1537: {{- fail \"Controller Manager image tag is required\" }}\n1538: {{- end }}\n1539: ```\n1540: \n1541: ## Testing Strategy\n1542: \n1543: ### Unit Tests\n1544: \n1545: **Template Testing:**\n1546: \n1547: ```yaml\n1548: # tests/controller-manager_test.yaml\n1549: suite: controller manager deployment test\n1550: templates:\n1551:   - templates/controller-manager/deployment.yaml\n1552: tests:\n1553:   - it: should render deployment\n1554:     asserts:\n1555:       - isKind:\n1556:           of: Deployment\n1557:       - equal:\n1558:           path: metadata.name\n1559:           value: agentcube\n1560:   - it: should set correct replicas\n1561:     asserts:\n1562:       - equal:\n1563:           path: spec.replicas\n1564:           value: 2\n1565:   - it: should set correct image\n1566:     asserts:\n1567:       - equal:\n1568:           path: spec.template.spec.containers[0].image\n1569:           value: agentcube/controller-manager:v1.0.0\n1570:   - it: should set correct resource limits\n1571:     asserts:\n1572:       - equal:\n1573:           path: spec.template.spec.containers[0].resources.limits.cpu\n1574:           value: 500m\n1575:       - equal:\n1576:           path: spec.template.spec.containers[0].resources.limits.memory\n1577:           value: 512Mi\n1578:   - it: should set security context\n1579:     asserts:\n1580:       - equal:\n1581:           path: spec.template.spec.securityContext.runAsNonRoot\n1582:           value: true\n1583:   - it: should disable deployment when disabled\n1584:     set:\n1585:       controllerManager.enabled: false\n1586:     asserts:\n1587:       - hasDocuments:\n1588:           count: 0\n1589: ```\n1590: \n1591: **Values Testing:**\n1592: \n1593: ```yaml\n1594: # tests/values_test.yaml\n1595: suite: values validation\n1596: tests:\n1597:   - it: should require valid replica count\n1598:     set:\n1599:       controllerManager.replicaCount: -1\n1600:     asserts:\n1601:       - failedTemplate:\n1602:           errorMessage: \"Replica count must be non-negative\"\n1603:   - it: should require valid port\n1604:     set:\n1605:       controllerManager.service.port: 70000\n1606:     asserts:\n1607:       - failedTemplate:\n1608:           errorMessage: \"Port must be between 1 and 65535\"\n1609: ```\n1610: \n1611: **Helper Template Testing:**\n1612: \n1613: ```yaml\n1614: # tests/helpers_test.yaml\n1615: suite: helper templates\n1616: templates:\n1617:   - templates/_helpers.tpl\n1618: tests:\n1619:   - it: should generate correct full name\n1620:     asserts:\n1621:       - matchRegex:\n1622:           path: agentcube.fullname\n1623:           pattern: \"^agentcube-.*\"\n1624:   - it: should generate correct labels\n1625:     asserts:\n1626:       - contains:\n1627:           path: agentcube.labels\n1628:           content: app.kubernetes.io/name\n1629:       - contains:\n1630:           path: agentcube.labels\n1631:           content: helm.sh/chart\n1632: ```\n1633: \n1634: ### Integration Tests\n1635: \n1636: **Installation Test:**\n1637: \n1638: ```bash\n1639: #!/bin/bash\n1640: # test/integration/install_test.sh\n1641: \n1642: set -e\n1643: \n1644: echo \"Testing Helm Chart Installation...\"\n1645: \n1646: # Create namespace\n1647: kubectl create namespace agentcube-test --dry-run=client -o yaml | kubectl apply -f -\n1648: \n1649: # Install chart\n1650: helm install agentcube-test ./agentcube \\\n1651:   --namespace agentcube-test \\\n1652:   --values values-test.yaml \\\n1653:   --wait --timeout 5m\n1654: \n1655: # Verify deployments\n1656: kubectl rollout status deployment/agentcube-test -n agentcube-test\n1657: kubectl rollout status deployment/agentcube-test-workload-manager -n agentcube-test\n1658: kubectl rollout status deployment/agentcube-test-router -n agentcube-test\n1659: \n1660: # Verify services\n1661: kubectl get svc -n agentcube-test\n1662: kubectl get endpoints -n agentcube-test\n1663: \n1664: # Verify pods are running\n1665: kubectl get pods -n agentcube-test -l app.kubernetes.io/name=agentcube\n1666: \n1667: echo \"Installation test passed!\"\n1668: ```\n1669: \n1670: **Upgrade Test:**\n1671: \n1672: ```bash\n1673: #!/bin/bash\n1674: # test/integration/upgrade_test.sh\n1675: \n1676: set -e\n1677: \n1678: echo \"Testing Helm Chart Upgrade...\"\n1679: \n1680: # Initial installation\n1681: helm install agentcube-upgrade ./agentcube \\\n1682:   --namespace agentcube-upgrade \\\n1683:   --values values-test.yaml \\\n1684:   --set controllerManager.replicaCount=2\n1685: \n1686: # Upgrade with new values\n1687: helm upgrade agentcube-upgrade ./agentcube \\\n1688:   --namespace agentcube-upgrade \\\n1689:   --values values-test.yaml \\\n1690:   --set controllerManager.replicaCount=3 \\\n1691:   --reuse-values\n1692: \n1693: # Verify upgrade\n1694: kubectl rollout status deployment/agentcube-upgrade -n agentcube-upgrade\n1695: \n1696: # Check replica count\n1697: REPLICAS=$(kubectl get deployment agentcube-upgrade -n agentcube-upgrade -o jsonpath='{.spec.replicas}')\n1698: if [ \"$REPLICAS\" != \"3\" ]; then\n1699:   echo \"Upgrade test failed: expected 3 replicas, got $REPLICAS\"\n1700:   exit 1\n1701: fi\n1702: \n1703: echo \"Upgrade test passed!\"\n1704: ```\n1705: \n1706: **Rollback Test:**\n1707: \n1708: ```bash\n1709: #!/bin/bash\n1710: # test/integration/rollback_test.sh\n1711: \n1712: set -e\n1713: \n1714: echo \"Testing Helm Chart Rollback...\"\n1715: \n1716: # Install and upgrade\n1717: helm install agentcube-rollback ./agentcube \\\n1718:   --namespace agentcube-rollback \\\n1719:   --values values-test.yaml \\\n1720:   --set controllerManager.replicaCount=2\n1721: \n1722: helm upgrade agentcube-rollback ./agentcube \\\n1723:   --namespace agentcube-rollback \\\n1724:   --values values-test.yaml \\\n1725:   --set controllerManager.replicaCount=3 \\\n1726:   --reuse-values\n1727: \n1728: # Rollback\n1729: helm rollback agentcube-rollback 0 -n agentcube-rollback\n1730: \n1731: # Verify rollback\n1732: REPLICAS=$(kubectl get deployment agentcube-rollback -n agentcube-rollback -o jsonpath='{.spec.replicas}')\n1733: if [ \"$REPLICAS\" != \"2\" ]; then\n1734:   echo \"Rollback test failed: expected 2 replicas, got $REPLICAS\"\n1735:   exit 1\n1736: fi\n1737: \n1738: echo \"Rollback test passed!\"\n1739: ```\n1740: \n1741: ### E2E Tests\n1742: \n1743: **Functional Test:**\n1744: \n1745: ```bash\n1746: #!/bin/bash\n1747: # test/e2e/functional_test.sh\n1748: \n1749: set -e\n1750: \n1751: echo \"Running E2E Functional Tests...\"\n1752: \n1753: # Install chart\n1754: helm install agentcube-e2e ./agentcube \\\n1755:   --namespace agentcube-e2e \\\n1756:   --values values-test.yaml \\\n1757:   --wait\n1758: \n1759: # Test CRD creation\n1760: kubectl apply -f ../config/samples/runtime_v1alpha1_agentruntime.yaml\n1761: \n1762: # Wait for resource reconciliation\n1763: sleep 10\n1764: \n1765: # Verify AgentRuntime status\n1766: STATUS=$(kubectl get agentruntime example-runtime -n default -o jsonpath='{.status.conditions[0].status}')\n1767: if [ \"$STATUS\" != \"True\" ]; then\n1768:   echo \"Functional test failed: AgentRuntime not ready\"\n1769:   exit 1\n1770: fi\n1771: \n1772: # Test endpoint connectivity\n1773: SERVICE_IP=$(kubectl get svc agentcube-e2e-router -n agentcube-e2e -o jsonpath='{.spec.clusterIP}')\n1774: curl -f http://$SERVICE_IP:8080/healthz || exit 1\n1775: \n1776: echo \"E2E Functional test passed!\"\n1777: ```\n1778: \n1779: **Environment Test:**\n1780: \n1781: ```bash\n1782: #!/bin/bash\n1783: # test/e2e/environment_test.sh\n1784: \n\n(Output capped at 50 KB. Showing lines 1-1784. Use offset=1785 to continue.)\n</content>","metadata":{"preview":"# AR-030: Helm Chart 模板与 Values — Design\n\n## Overview\n\nHelm Chart for AgentCube platform provides a standardized, configurable, and reusable Kubernetes deployment solution. The chart encapsulates all necessary Kubernetes resources (CRDs, Deployments, Services, ConfigMaps, RBAC) and enables flexible configuration through Values files, simplifying deployment across multiple environments.\n\n**Module:** `manifests`  \n**Language:** YAML + Go Templates  \n**Source Root:** `manifests/charts/agentcube/`  \n**Size:** L\n\n## Architecture\n\n### Chart Structure\n\n```\nagentcube/\n├── Chart.yaml                          # Chart metadata\n├── values.yaml                         # Default configuration\n├── values-dev.yaml                     # Development environment overrides","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-030/design.md","time":{"start":1775881083359,"end":1775881083376}}}}
