y=None\n-        )\n+    mock_client.login.assert_called_once_with(\n+        username=\"user\",\n+        password=\"pass\",\n+        registry=None\n+    )\n \n def test_docker_login_failure(self, docker_service):\n     \"\"\"Test Docker login failure.\"\"\"\n     mock_client = MagicMock()\n     mock_client.login.side_effect = DockerException(\"Authentication failed\")\n+    docker_service._client = mock_client\n \n-    with patch.object(docker_service, \"client\", mock_client):\n-        with pytest.raises(RuntimeError, match=\"Failed to log in to Docker registry\"):\n-            docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n+    with pytest.raises(RuntimeError, match=\"Failed to log in to Docker registry\"):\n+        docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n \n def test_tag_image_success(self, docker_service):\n     \"\"\"Test successful image tagging.\"\"\"\n     mock_client = MagicMock()\n@@ -385,50 +385,54 @@\n     mock_image = MagicMock()\n     mock_images.get.return_value = mock_image\n     mock_client.images = mock_images\n \n-    with patch.object(docker_service, \"client\", mock_client):\n-        docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n+    docker_service._client = mock_client\n \n-        mock_images.get.assert_called_once_with(\"test:1.0.0\")\n-        mock_image.tag.assert_called_once_with(\"registry.example.com/test:1.0.0\", force=True)\n+    docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n \n+    mock_images.get.assert_called_once_with(\"test:1.0.0\")\n+    mock_image.tag.assert_called_once_with(\"registry.example.com/test:1.0.0\", force=True)\n+\n def test_tag_image_failure(self, docker_service):\n     \"\"\"Test image tagging failure.\"\"\"\n     mock_client = MagicMock()\n     mock_images = MagicMock()\n     mock_images.get.side_effect = DockerException(\"Image not found\")\n     mock_client.images = mock_images\n \n-    with patch.object(docker_service, \"client\", mock_client):\n-        with pytest.raises(RuntimeError, match=\"Failed to tag Docker image\"):\n-            docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n+    docker_service._client = mock_client\n \n+    with pytest.raises(RuntimeError, match=\"Failed to tag Docker image\"):\n+        docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n+\n def test_remove_image_success(self, docker_service):\n     \"\"\"Test successful image removal.\"\"\"\n     mock_client = MagicMock()\n     mock_images = MagicMock()\n     mock_images.remove.return_value = None\n     mock_client.images = mock_images\n \n-    with patch.object(docker_service, \"client\", mock_client):\n-        result = docker_service.remove_image(\"test:1.0.0\")\n+    docker_service._client = mock_client\n \n-        assert result is True\n-        mock_images.remove.assert_called_once_with(\"test:1.0.0\", force=True)\n+    result = docker_service.remove_image(\"test:1.0.0\")\n \n+    assert result is True\n+    mock_images.remove.assert_called_once_with(\"test:1.0.0\", force=True)\n+\n def test_remove_image_failure(self, docker_service):\n     \"\"\"Test image removal failure.\"\"\"\n     mock_client = MagicMock()\n     mock_images = MagicMock()\n     mock_images.remove.side_effect = DockerException(\"No such image\")\n     mock_client.images = mock_images\n \n-    with patch.object(docker_service, \"client\", mock_client):\n-        result = docker_service.remove_image(\"test:1.0.0\")\n+    docker_service._client = mock_client\n \n-        assert result is False\n+    result = docker_service.remove_image(\"test:1.0.0\")\n \n+    assert result is False\n+\n def test_client_property_lazy_initialization(self, docker_service):\n     \"\"\"Test that Docker client is lazily initialized.\"\"\"\n     assert docker_service._client is None\n \n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_docker_service.py","before":"\"\"\"Tests for the Docker service.\"\"\"\n\nimport pytest\nimport time\nfrom unittest.mock import MagicMock, patch, PropertyMock\nfrom docker.errors import DockerException\n\nfrom agentcube.services.docker_service import DockerService\n\n\nclass TestDockerService:\n    \"\"\"Test cases for DockerService.\"\"\"\n\n    @pytest.fixture\n    def mock_docker_client(self):\n        \"\"\"Create a mock Docker client.\"\"\"\n        client = MagicMock()\n        client.ping.return_value = True\n        return client\n\n    @pytest.fixture\n    def mock_docker_image(self):\n        \"\"\"Create a mock Docker image.\"\"\"\n        image = MagicMock()\n        image.attrs = {\n            \"Id\": \"sha256:abc123def4567890123456789012345678901234567890123456789012345678\",\n            \"Size\": 536870912,\n        }\n        return image\n\n    @pytest.fixture\n    def docker_service(self):\n        \"\"\"Create a DockerService instance.\"\"\"\n        return DockerService(verbose=False)\n\n    def test_check_docker_available_success(self, docker_service):\n        \"\"\"Test Docker availability check when available.\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        docker_service._client = mock_client\n\n        result = docker_service.check_docker_available()\n\n        assert result is True\n        mock_client.ping.assert_called_once()\n\n    def test_check_docker_available_failure(self, docker_service):\n        \"\"\"Test Docker availability check when unavailable.\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.side_effect = DockerException(\"Docker daemon not running\")\n        docker_service._client = mock_client\n\n        result = docker_service.check_docker_available()\n\n        assert result is False\n\n    def test_build_image_success(self, docker_service, mock_docker_image, tmp_path):\n        \"\"\"Test successful image build.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.build.return_value = (mock_docker_image, [])\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"get_image_info\", return_value={\n            \"image_name\": \"test:1.0.0\",\n            \"image_id\": \"abc123def456\",\n            \"image_size\": \"512.34 MB\",\n            \"size_bytes\": 536870912,\n        }):\n            result = docker_service.build_image(\n                dockerfile_path=dockerfile_path,\n                context_path=tmp_path,\n                image_name=\"test\",\n                tag=\"1.0.0\"\n            )\n\n            assert result[\"image_name\"] == \"test:1.0.0\"\n            assert result[\"image_id\"] == \"abc123def456\"\n            assert result[\"image_size\"] == \"512.34 MB\"\n            mock_images.build.assert_called_once()\n\n    def test_build_image_with_custom_tag(self, docker_service, mock_docker_image, tmp_path):\n        \"\"\"Test building image with custom tag.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.build.return_value = (mock_docker_image, [])\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"get_image_info\", return_value={\n            \"image_name\": \"test:v1.0.0\",\n            \"image_id\": \"abc123def456\",\n            \"image_size\": \"512.34 MB\",\n            \"size_bytes\": 536870912,\n        }):\n            result = docker_service.build_image(\n                dockerfile_path=dockerfile_path,\n                context_path=tmp_path,\n                image_name=\"test\",\n                tag=\"v1.0.0\"\n            )\n\n            assert result[\"image_name\"] == \"test:v1.0.0\"\n            call_args = mock_images.build.call_args\n            assert call_args.kwargs[\"tag\"] == \"test:v1.0.0\"\n\n    def test_build_image_with_build_args(self, docker_service, mock_docker_image, tmp_path):\n        \"\"\"Test building image with build arguments.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.build.return_value = (mock_docker_image, [])\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"get_image_info\", return_value={\n            \"image_name\": \"test:1.0.0\",\n            \"image_id\": \"abc123def456\",\n            \"image_size\": \"512.34 MB\",\n            \"size_bytes\": 536870912,\n        }):\n            build_args = {\n                \"HTTP_PROXY\": \"http://proxy.example.com:8080\",\n                \"HTTPS_PROXY\": \"http://proxy.example.com:8080\"\n            }\n\n            result = docker_service.build_image(\n                dockerfile_path=dockerfile_path,\n                context_path=tmp_path,\n                image_name=\"test\",\n                tag=\"1.0.0\",\n                build_args=build_args\n            )\n\n            assert result[\"image_name\"] == \"test:1.0.0\"\n            call_args = mock_images.build.call_args\n            assert call_args.kwargs[\"buildargs\"] == build_args\n\n    def test_build_image_docker_unavailable(self, docker_service, tmp_path):\n        \"\"\"Test building image when Docker is unavailable.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=False):\n            with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n                docker_service.build_image(\n                    dockerfile_path=dockerfile_path,\n                    context_path=tmp_path,\n                    image_name=\"test\"\n                )\n\n    def test_build_image_docker_exception(self, docker_service, tmp_path):\n        \"\"\"Test building image when Docker build fails.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.build.side_effect = DockerException(\"Build failed\")\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with pytest.raises(RuntimeError, match=\"Failed to build Docker image\"):\n            docker_service.build_image(\n                dockerfile_path=dockerfile_path,\n                context_path=tmp_path,\n                image_name=\"test\"\n            )\n\n    def test_get_image_info_success(self, docker_service, mock_docker_image):\n        \"\"\"Test getting image info successfully.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.get.return_value = mock_docker_image\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        result = docker_service.get_image_info(\"test:1.0.0\")\n\n        assert result[\"image_name\"] == \"test:1.0.0\"\n        assert result[\"image_id\"] == \"abc123def456\"\n        assert result[\"size_bytes\"] == 536870912\n        assert result[\"image_size\"] == \"512.00 MB\"\n\n    def test_get_image_info_not_found(self, docker_service):\n        \"\"\"Test getting image info when image not found.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.get.side_effect = DockerException(\"Image not found\")\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        result = docker_service.get_image_info(\"test:1.0.0\")\n\n        assert result == {}\n\n    def test_format_size_bytes(self, docker_service):\n        \"\"\"Test formatting size in bytes.\"\"\"\n        result = docker_service._format_size(512)\n        assert result == \"512.00 B\"\n\n    def test_format_size_kb(self, docker_service):\n        \"\"\"Test formatting size in kilobytes.\"\"\"\n        result = docker_service._format_size(2048)\n        assert result == \"2.00 KB\"\n\n    def test_format_size_mb(self, docker_service):\n        \"\"\"Test formatting size in megabytes.\"\"\"\n        result = docker_service._format_size(1048576)\n        assert result == \"1.00 MB\"\n\n    def test_format_size_gb(self, docker_service):\n        \"\"\"Test formatting size in gigabytes.\"\"\"\n        result = docker_service._format_size(1073741824)\n        assert result == \"1.00 GB\"\n\n    def test_format_size_tb(self, docker_service):\n        \"\"\"Test formatting size in terabytes.\"\"\"\n        result = docker_service._format_size(1099511627776)\n        assert result == \"1.00 TB\"\n\n    def test_format_size_zero(self, docker_service):\n        \"\"\"Test formatting zero size.\"\"\"\n        result = docker_service._format_size(0)\n        assert result == \"0.00 B\"\n\n    def test_push_image_to_default_registry(self, docker_service):\n        \"\"\"Test pushing image to default registry.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n\n        push_logs = [\n            {\"status\": \"Pushing\"},\n            {\"status\": \"Pushed\"},\n        ]\n        mock_images.push.return_value = push_logs\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=True):\n            result = docker_service.push_image(\"test:1.0.0\")\n\n            assert result[\"pushed_image\"] == \"test:1.0.0\"\n            assert \"push_time\" in result\n            mock_images.push.assert_called_once_with(\"test:1.0.0\", stream=True, decode=True)\n\n    def test_push_image_to_custom_registry(self, docker_service):\n        \"\"\"Test pushing image to custom registry.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n\n        push_logs = [\n            {\"status\": \"Pushing\"},\n            {\"status\": \"Pushed\"},\n        ]\n        mock_images.push.return_value = push_logs\n        mock_client.images = mock_images\n\n        mock_image = MagicMock()\n        mock_images.get.return_value = mock_image\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=True):\n            with patch.object(docker_service, \"_tag_image_sdk\") as mock_tag:\n                result = docker_service.push_image(\n                    \"test:1.0.0\",\n                    registry_url=\"registry.example.com\"\n                )\n\n                assert result[\"pushed_image\"] == \"registry.example.com/test:1.0.0\"\n                mock_tag.assert_called_once_with(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n                mock_images.push.assert_called_once_with(\n                    \"registry.example.com/test:1.0.0\",\n                    stream=True,\n                    decode=True\n                )\n\n    def test_push_image_with_authentication(self, docker_service):\n        \"\"\"Test pushing image with authentication.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n\n        push_logs = [\n            {\"status\": \"Pushing\"},\n            {\"status\": \"Pushed\"},\n        ]\n        mock_images.push.return_value = push_logs\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=True):\n            with patch.object(docker_service, \"_docker_login_sdk\") as mock_login:\n                result = docker_service.push_image(\n                    \"test:1.0.0\",\n                    registry_url=\"registry.example.com\",\n                    username=\"user\",\n                    password=\"pass\"\n                )\n\n                assert \"pushed_image\" in result\n                mock_login.assert_called_once_with(\"registry.example.com\", \"user\", \"pass\")\n\n    def test_push_image_failure(self, docker_service):\n        \"\"\"Test pushing image when push fails.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n\n        push_logs = [\n            {\"error\": \"Authentication failed\"},\n        ]\n        mock_images.push.return_value = push_logs\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=True):\n            with pytest.raises(RuntimeError, match=\"Failed to push image\"):\n                docker_service.push_image(\"test:1.0.0\")\n\n    def test_push_image_docker_unavailable(self, docker_service):\n        \"\"\"Test pushing image when Docker is unavailable.\"\"\"\n        with patch.object(docker_service, \"check_docker_available\", return_value=False):\n            with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n                docker_service.push_image(\"test:1.0.0\")\n\n    def test_docker_login_success(self, docker_service):\n        \"\"\"Test successful Docker registry login.\"\"\"\n        mock_client = MagicMock()\n        mock_client.login.return_value = {}\n\n        with patch.object(docker_service, \"client\", mock_client):\n            docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n\n            mock_client.login.assert_called_once_with(\n                username=\"user\",\n                password=\"pass\",\n                registry=\"registry.example.com\"\n            )\n\n    def test_docker_login_default_registry(self, docker_service):\n        \"\"\"Test Docker login to default registry.\"\"\"\n        mock_client = MagicMock()\n        mock_client.login.return_value = {}\n\n        with patch.object(docker_service, \"client\", mock_client):\n            docker_service._docker_login_sdk(None, \"user\", \"pass\")\n\n            mock_client.login.assert_called_once_with(\n                username=\"user\",\n                password=\"pass\",\n                registry=None\n            )\n\n    def test_docker_login_failure(self, docker_service):\n        \"\"\"Test Docker login failure.\"\"\"\n        mock_client = MagicMock()\n        mock_client.login.side_effect = DockerException(\"Authentication failed\")\n\n        with patch.object(docker_service, \"client\", mock_client):\n            with pytest.raises(RuntimeError, match=\"Failed to log in to Docker registry\"):\n                docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n\n    def test_tag_image_success(self, docker_service):\n        \"\"\"Test successful image tagging.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_image = MagicMock()\n        mock_images.get.return_value = mock_image\n        mock_client.images = mock_images\n\n        with patch.object(docker_service, \"client\", mock_client):\n            docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n\n            mock_images.get.assert_called_once_with(\"test:1.0.0\")\n            mock_image.tag.assert_called_once_with(\"registry.example.com/test:1.0.0\", force=True)\n\n    def test_tag_image_failure(self, docker_service):\n        \"\"\"Test image tagging failure.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.get.side_effect = DockerException(\"Image not found\")\n        mock_client.images = mock_images\n\n        with patch.object(docker_service, \"client\", mock_client):\n            with pytest.raises(RuntimeError, match=\"Failed to tag Docker image\"):\n                docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n\n    def test_remove_image_success(self, docker_service):\n        \"\"\"Test successful image removal.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.remove.return_value = None\n        mock_client.images = mock_images\n\n        with patch.object(docker_service, \"client\", mock_client):\n            result = docker_service.remove_image(\"test:1.0.0\")\n\n            assert result is True\n            mock_images.remove.assert_called_once_with(\"test:1.0.0\", force=True)\n\n    def test_remove_image_failure(self, docker_service):\n        \"\"\"Test image removal failure.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.remove.side_effect = DockerException(\"No such image\")\n        mock_client.images = mock_images\n\n        with patch.object(docker_service, \"client\", mock_client):\n            result = docker_service.remove_image(\"test:1.0.0\")\n\n            assert result is False\n\n    def test_client_property_lazy_initialization(self, docker_service):\n        \"\"\"Test that Docker client is lazily initialized.\"\"\"\n        assert docker_service._client is None\n\n        with patch(\"agentcube.services.docker_service.docker\") as mock_docker_module:\n            mock_docker_module.from_env.return_value = MagicMock()\n\n            client = docker_service.client\n\n            assert docker_service._client is not None\n            assert client is docker_service.client\n\n    def test_verbose_mode_sets_logging(self):\n        \"\"\"Test verbose mode sets logging level.\"\"\"\n        import logging\n\n        service = DockerService(verbose=True)\n        assert service.verbose is True\n\n    def test_non_verbose_mode(self):\n        \"\"\"Test non-verbose mode.\"\"\"\n        service = DockerService(verbose=False)\n        assert service.verbose is False\n\n    def test_get_image_info_truncates_id(self, docker_service, mock_docker_image):\n        \"\"\"Test that image ID is truncated to 12 characters.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.get.return_value = mock_docker_image\n        mock_client.images = mock_images\n\n        with patch.object(docker_service, \"client\", mock_client):\n            result = docker_service.get_image_info(\"test:1.0.0\")\n\n            assert len(result[\"image_id\"]) == 12\n            assert result[\"image_id\"] == \"abc123def456\"\n\n    def test_build_image_adds_build_time(self, docker_service, mock_docker_image, tmp_path):\n        \"\"\"Test that build_image adds build_time to result.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.build.return_value = (mock_docker_image, [])\n        mock_client.images = mock_images\n\n        with patch.object(docker_service, \"client\", mock_client):\n            with patch.object(docker_service, \"get_image_info\", return_value={\n                \"image_name\": \"test:1.0.0\",\n                \"image_id\": \"abc123def456\",\n                \"image_size\": \"512.34 MB\",\n                \"size_bytes\": 536870912,\n            }):\n                with patch(\"time.time\", return_value=1234567890.0):\n                    result = docker_service.build_image(\n                        dockerfile_path=dockerfile_path,\n                        context_path=tmp_path,\n                        image_name=\"test\",\n                        tag=\"1.0.0\"\n                    )\n\n                    assert result[\"build_time\"] == 1234567890.0\n\n    @pytest.mark.integration\n    def test_e2e_build_real_image(self):\n        \"\"\"Test end-to-end building a real Docker image (integration test).\"\"\"\n        pytest.skip(\"Integration test - requires Docker daemon\")\n\n    @pytest.mark.integration\n    def test_e2e_push_real_image(self):\n        \"\"\"Test end-to-end pushing a real Docker image (integration test).\"\"\"\n        pytest.skip(\"Integration test - requires Docker daemon and registry\")","after":"\"\"\"Tests for the Docker service.\"\"\"\n\nimport pytest\nimport time\nfrom unittest.mock import MagicMock, patch, PropertyMock\nfrom docker.errors import DockerException\n\nfrom agentcube.services.docker_service import DockerService\n\n\nclass TestDockerService:\n    \"\"\"Test cases for DockerService.\"\"\"\n\n    @pytest.fixture\n    def mock_docker_client(self):\n        \"\"\"Create a mock Docker client.\"\"\"\n        client = MagicMock()\n        client.ping.return_value = True\n        return client\n\n    @pytest.fixture\n    def mock_docker_image(self):\n        \"\"\"Create a mock Docker image.\"\"\"\n        image = MagicMock()\n        image.attrs = {\n            \"Id\": \"sha256:abc123def4567890123456789012345678901234567890123456789012345678\",\n            \"Size\": 536870912,\n        }\n        return image\n\n    @pytest.fixture\n    def docker_service(self):\n        \"\"\"Create a DockerService instance.\"\"\"\n        return DockerService(verbose=False)\n\n    def test_check_docker_available_success(self, docker_service):\n        \"\"\"Test Docker availability check when available.\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.return_value = True\n        docker_service._client = mock_client\n\n        result = docker_service.check_docker_available()\n\n        assert result is True\n        mock_client.ping.assert_called_once()\n\n    def test_check_docker_available_failure(self, docker_service):\n        \"\"\"Test Docker availability check when unavailable.\"\"\"\n        mock_client = MagicMock()\n        mock_client.ping.side_effect = DockerException(\"Docker daemon not running\")\n        docker_service._client = mock_client\n\n        result = docker_service.check_docker_available()\n\n        assert result is False\n\n    def test_build_image_success(self, docker_service, mock_docker_image, tmp_path):\n        \"\"\"Test successful image build.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.build.return_value = (mock_docker_image, [])\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"get_image_info\", return_value={\n            \"image_name\": \"test:1.0.0\",\n            \"image_id\": \"abc123def456\",\n            \"image_size\": \"512.34 MB\",\n            \"size_bytes\": 536870912,\n        }):\n            result = docker_service.build_image(\n                dockerfile_path=dockerfile_path,\n                context_path=tmp_path,\n                image_name=\"test\",\n                tag=\"1.0.0\"\n            )\n\n            assert result[\"image_name\"] == \"test:1.0.0\"\n            assert result[\"image_id\"] == \"abc123def456\"\n            assert result[\"image_size\"] == \"512.34 MB\"\n            mock_images.build.assert_called_once()\n\n    def test_build_image_with_custom_tag(self, docker_service, mock_docker_image, tmp_path):\n        \"\"\"Test building image with custom tag.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.build.return_value = (mock_docker_image, [])\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"get_image_info\", return_value={\n            \"image_name\": \"test:v1.0.0\",\n            \"image_id\": \"abc123def456\",\n            \"image_size\": \"512.34 MB\",\n            \"size_bytes\": 536870912,\n        }):\n            result = docker_service.build_image(\n                dockerfile_path=dockerfile_path,\n                context_path=tmp_path,\n                image_name=\"test\",\n                tag=\"v1.0.0\"\n            )\n\n            assert result[\"image_name\"] == \"test:v1.0.0\"\n            call_args = mock_images.build.call_args\n            assert call_args.kwargs[\"tag\"] == \"test:v1.0.0\"\n\n    def test_build_image_with_build_args(self, docker_service, mock_docker_image, tmp_path):\n        \"\"\"Test building image with build arguments.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.build.return_value = (mock_docker_image, [])\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"get_image_info\", return_value={\n            \"image_name\": \"test:1.0.0\",\n            \"image_id\": \"abc123def456\",\n            \"image_size\": \"512.34 MB\",\n            \"size_bytes\": 536870912,\n        }):\n            build_args = {\n                \"HTTP_PROXY\": \"http://proxy.example.com:8080\",\n                \"HTTPS_PROXY\": \"http://proxy.example.com:8080\"\n            }\n\n            result = docker_service.build_image(\n                dockerfile_path=dockerfile_path,\n                context_path=tmp_path,\n                image_name=\"test\",\n                tag=\"1.0.0\",\n                build_args=build_args\n            )\n\n            assert result[\"image_name\"] == \"test:1.0.0\"\n            call_args = mock_images.build.call_args\n            assert call_args.kwargs[\"buildargs\"] == build_args\n\n    def test_build_image_docker_unavailable(self, docker_service, tmp_path):\n        \"\"\"Test building image when Docker is unavailable.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=False):\n            with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n                docker_service.build_image(\n                    dockerfile_path=dockerfile_path,\n                    context_path=tmp_path,\n                    image_name=\"test\"\n                )\n\n    def test_build_image_docker_exception(self, docker_service, tmp_path):\n        \"\"\"Test building image when Docker build fails.\"\"\"\n        dockerfile_path = tmp_path / \"Dockerfile\"\n        dockerfile_path.write_text(\"FROM python:3.10\")\n\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.build.side_effect = DockerException(\"Build failed\")\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with pytest.raises(RuntimeError, match=\"Failed to build Docker image\"):\n            docker_service.build_image(\n                dockerfile_path=dockerfile_path,\n                context_path=tmp_path,\n                image_name=\"test\"\n            )\n\n    def test_get_image_info_success(self, docker_service, mock_docker_image):\n        \"\"\"Test getting image info successfully.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.get.return_value = mock_docker_image\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        result = docker_service.get_image_info(\"test:1.0.0\")\n\n        assert result[\"image_name\"] == \"test:1.0.0\"\n        assert result[\"image_id\"] == \"abc123def456\"\n        assert result[\"size_bytes\"] == 536870912\n        assert result[\"image_size\"] == \"512.00 MB\"\n\n    def test_get_image_info_not_found(self, docker_service):\n        \"\"\"Test getting image info when image not found.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_images.get.side_effect = DockerException(\"Image not found\")\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        result = docker_service.get_image_info(\"test:1.0.0\")\n\n        assert result == {}\n\n    def test_format_size_bytes(self, docker_service):\n        \"\"\"Test formatting size in bytes.\"\"\"\n        result = docker_service._format_size(512)\n        assert result == \"512.00 B\"\n\n    def test_format_size_kb(self, docker_service):\n        \"\"\"Test formatting size in kilobytes.\"\"\"\n        result = docker_service._format_size(2048)\n        assert result == \"2.00 KB\"\n\n    def test_format_size_mb(self, docker_service):\n        \"\"\"Test formatting size in megabytes.\"\"\"\n        result = docker_service._format_size(1048576)\n        assert result == \"1.00 MB\"\n\n    def test_format_size_gb(self, docker_service):\n        \"\"\"Test formatting size in gigabytes.\"\"\"\n        result = docker_service._format_size(1073741824)\n        assert result == \"1.00 GB\"\n\n    def test_format_size_tb(self, docker_service):\n        \"\"\"Test formatting size in terabytes.\"\"\"\n        result = docker_service._format_size(1099511627776)\n        assert result == \"1.00 TB\"\n\n    def test_format_size_zero(self, docker_service):\n        \"\"\"Test formatting zero size.\"\"\"\n        result = docker_service._format_size(0)\n        assert result == \"0.00 B\"\n\n    def test_push_image_to_default_registry(self, docker_service):\n        \"\"\"Test pushing image to default registry.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n\n        push_logs = [\n            {\"status\": \"Pushing\"},\n            {\"status\": \"Pushed\"},\n        ]\n        mock_images.push.return_value = push_logs\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=True):\n            result = docker_service.push_image(\"test:1.0.0\")\n\n            assert result[\"pushed_image\"] == \"test:1.0.0\"\n            assert \"push_time\" in result\n            mock_images.push.assert_called_once_with(\"test:1.0.0\", stream=True, decode=True)\n\n    def test_push_image_to_custom_registry(self, docker_service):\n        \"\"\"Test pushing image to custom registry.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n\n        push_logs = [\n            {\"status\": \"Pushing\"},\n            {\"status\": \"Pushed\"},\n        ]\n        mock_images.push.return_value = push_logs\n        mock_client.images = mock_images\n\n        mock_image = MagicMock()\n        mock_images.get.return_value = mock_image\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=True):\n            with patch.object(docker_service, \"_tag_image_sdk\") as mock_tag:\n                result = docker_service.push_image(\n                    \"test:1.0.0\",\n                    registry_url=\"registry.example.com\"\n                )\n\n                assert result[\"pushed_image\"] == \"registry.example.com/test:1.0.0\"\n                mock_tag.assert_called_once_with(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n                mock_images.push.assert_called_once_with(\n                    \"registry.example.com/test:1.0.0\",\n                    stream=True,\n                    decode=True\n                )\n\n    def test_push_image_with_authentication(self, docker_service):\n        \"\"\"Test pushing image with authentication.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n\n        push_logs = [\n            {\"status\": \"Pushing\"},\n            {\"status\": \"Pushed\"},\n        ]\n        mock_images.push.return_value = push_logs\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=True):\n            with patch.object(docker_service, \"_docker_login_sdk\") as mock_login:\n                result = docker_service.push_image(\n                    \"test:1.0.0\",\n                    registry_url=\"registry.example.com\",\n                    username=\"user\",\n                    password=\"pass\"\n                )\n\n                assert \"pushed_image\" in result\n                mock_login.assert_called_once_with(\"registry.example.com\", \"user\", \"pass\")\n\n    def test_push_image_failure(self, docker_service):\n        \"\"\"Test pushing image when push fails.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n\n        push_logs = [\n            {\"error\": \"Authentication failed\"},\n        ]\n        mock_images.push.return_value = push_logs\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        with patch.object(docker_service, \"check_docker_available\", return_value=True):\n            with pytest.raises(RuntimeError, match=\"Failed to push image\"):\n                docker_service.push_image(\"test:1.0.0\")\n\n    def test_push_image_docker_unavailable(self, docker_service):\n        \"\"\"Test pushing image when Docker is unavailable.\"\"\"\n        with patch.object(docker_service, \"check_docker_available\", return_value=False):\n            with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n                docker_service.push_image(\"test:1.0.0\")\n\n    def test_docker_login_success(self, docker_service):\n        \"\"\"Test successful Docker registry login.\"\"\"\n        mock_client = MagicMock()\n        mock_client.login.return_value = {}\n        docker_service._client = mock_client\n\n        docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n\n        mock_client.login.assert_called_once_with(\n            username=\"user\",\n            password=\"pass\",\n            registry=\"registry.example.com\"\n        )\n\n    def test_docker_login_default_registry(self, docker_service):\n        \"\"\"Test Docker login to default registry.\"\"\"\n        mock_client = MagicMock()\n        mock_client.login.return_value = {}\n        docker_service._client = mock_client\n\n        docker_service._docker_login_sdk(None, \"user\", \"pass\")\n\n        mock_client.login.assert_called_once_with(\n            username=\"user\",\n            password=\"pass\",\n            registry=None\n        )\n\n    def test_docker_login_failure(self, docker_service):\n        \"\"\"Test Docker login failure.\"\"\"\n        mock_client = MagicMock()\n        mock_client.login.side_effect = DockerException(\"Authentication failed\")\n        docker_service._client = mock_client\n\n        with pytest.raises(RuntimeError, match=\"Failed to log in to Docker registry\"):\n            docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n\n    def test_tag_image_success(self, docker_service):\n        \"\"\"Test successful image tagging.\"\"\"\n        mock_client = MagicMock()\n        mock_images = MagicMock()\n        mock_image = MagicMock()\n        mock_images.get.return_value = mock_image\n        mock_client.images = mock_images\n\n        docker_service._client = mock_client\n\n        docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n\n        mock_images.get.assert_called_once_with(\"test:1.0.0\")\n        mock_image.tag.assert_called_once_with(\"registry.example.com/test:1.0.0\", f