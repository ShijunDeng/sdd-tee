      self._client = docker.from_env()\n        return self._client\n\n    def check_docker_available(self) -> bool:\n        \"\"\"Check if Docker is available and running.\"\"\"\n        try:\n            self.client.ping()\n            return True\n        except DockerException as e:\n            logger.warning(f\"Docker not available: {e}\")\n            return False\n\n    def build_image(\n        self,\n        dockerfile_path: Path,\n        context_path: Path,\n        image_name: str,\n        tag: str = \"latest\",\n        build_args: Optional[Dict[str, str]] = None,\n    ) -> Dict[str, str]:\n        \"\"\"Build a Docker image.\"\"\"\n        if not self.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n        logger.info(f\"Building image {image_name}:{tag} from {dockerfile_path}\")\n        full_image_name = f\"{image_name}:{tag}\"\n\n        try:\n            image, build_logs = self.client.images.build(\n                path=str(context_path),\n                dockerfile=str(dockerfile_path),\n                tag=full_image_name,\n                buildargs=build_args,\n                rm=True,\n                forcerm=True,\n            )\n\n            image_info = self.get_image_info(full_image_name)\n            image_info[\"build_time\"] = time.time()\n\n            return image_info\n\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to build Docker image: {e}\") from e\n\n    def get_image_info(self, image_name: str) -> Dict[str, str]:\n        \"\"\"Get information about a Docker image.\"\"\"\n        try:\n            image = self.client.images.get(image_name)\n            attrs = image.attrs\n\n            image_id = attrs[\"Id\"].split(\":\")[-1][:12]\n            size_bytes = attrs.get(\"Size\", 0)\n\n            return {\n                \"image_name\": image_name,\n                \"image_id\": image_id,\n                \"image_size\": self._format_size(size_bytes),\n                \"size_bytes\": size_bytes,\n            }\n\n        except DockerException as e:\n            logger.warning(f\"Failed to get image info for {image_name}: {e}\")\n            return {}\n\n    def _format_size(self, size_bytes: int) -> str:\n        \"\"\"Format size in human-readable format.\"\"\"\n        for unit in [\"B\", \"KB\", \"MB\", \"GB\"]:\n            if size_bytes < 1024:\n                return f\"{size_bytes:.2f} {unit}\"\n            size_bytes /= 1024\n        return f\"{size_bytes:.2f} TB\"\n\n    def push_image(\n        self,\n        image_name: str,\n        registry_url: Optional[str] = None,\n        username: Optional[str] = None,\n        password: Optional[str] = None,\n    ) -> Dict[str, str]:\n        \"\"\"Push a Docker image to a registry.\"\"\"\n        if not self.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n        target_image = image_name\n        if registry_url:\n            target_image = f\"{registry_url}/{image_name}\"\n            self._tag_image_sdk(image_name, target_image)\n\n        if username and password:\n            self._docker_login_sdk(registry_url, username, password)\n\n        logger.info(f\"Pushing image {target_image}\")\n\n        try:\n            push_logs = self.client.images.push(target_image, stream=True, decode=True)\n\n            for line in push_logs:\n                if \"error\" in line:\n                    raise RuntimeError(f\"Failed to push image: {line['error']}\")\n                if self.verbose:\n                    logger.debug(f\"Push log: {line}\")\n\n            return {\n                \"pushed_image\": target_image,\n                \"push_time\": str(time.time()),\n            }\n\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to push Docker image: {e}\") from e\n\n    def _docker_login_sdk(self, registry: Optional[str], username: str, password: str) -> None:\n        \"\"\"Log in to Docker registry.\"\"\"\n        try:\n            self.client.login(username=username, password=password, registry=registry)\n            logger.info(f\"Successfully logged in to registry: {registry or 'default'}\")\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to log in to Docker registry: {e}\") from e\n\n    def _tag_image_sdk(self, source_image: str, target_image: str) -> None:\n        \"\"\"Tag a Docker image.\"\"\"\n        try:\n            image = self.client.images.get(source_image)\n            image.tag(target_image, force=True)\n            logger.info(f\"Tagged {source_image} as {target_image}\")\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to tag Docker image: {e}\") from e\n\n    def remove_image(self, image_name: str) -> bool:\n        \"\"\"Remove a Docker image.\"\"\"\n        try:\n            self.client.images.remove(image_name, force=True)\n            logger.info(f\"Removed image {image_name}\")\n            return True\n        except DockerException as e:\n            logger.warning(f\"Failed to remove image {image_name}: {e}\")\n            return False","after":"\"\"\"Service for Docker operations.\"\"\"\n\nimport logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport docker\nfrom docker.errors import DockerException\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass DockerService:\n    \"\"\"Service for Docker operations.\"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        \"\"\"Initialize the Docker service.\"\"\"\n        self.verbose = verbose\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        self._client: Optional[docker.DockerClient] = None\n\n    @property\n    def client(self) -> docker.DockerClient:\n        \"\"\"Get or create Docker client.\"\"\"\n        if self._client is None:\n            self._client = docker.from_env()\n        return self._client\n\n    def check_docker_available(self) -> bool:\n        \"\"\"Check if Docker is available and running.\"\"\"\n        try:\n            self.client.ping()\n            return True\n        except DockerException as e:\n            logger.warning(f\"Docker not available: {e}\")\n            return False\n\n    def build_image(\n        self,\n        dockerfile_path: Path,\n        context_path: Path,\n        image_name: str,\n        tag: str = \"latest\",\n        build_args: Optional[Dict[str, str]] = None,\n    ) -> Dict[str, Any]:\n        \"\"\"Build a Docker image.\"\"\"\n        if not self.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n        logger.info(f\"Building image {image_name}:{tag} from {dockerfile_path}\")\n        full_image_name = f\"{image_name}:{tag}\"\n\n        try:\n            image, build_logs = self.client.images.build(\n                path=str(context_path),\n                dockerfile=str(dockerfile_path),\n                tag=full_image_name,\n                buildargs=build_args,\n                rm=True,\n                forcerm=True,\n            )\n\n            image_info = self.get_image_info(full_image_name)\n            image_info[\"build_time\"] = time.time()\n\n            return image_info\n\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to build Docker image: {e}\") from e\n\n    def get_image_info(self, image_name: str) -> Dict[str, Any]:\n        \"\"\"Get information about a Docker image.\"\"\"\n        try:\n            image = self.client.images.get(image_name)\n            attrs = image.attrs\n\n            image_id = attrs[\"Id\"].split(\":\")[-1][:12]\n            size_bytes = attrs.get(\"Size\", 0)\n\n            return {\n                \"image_name\": image_name,\n                \"image_id\": image_id,\n                \"image_size\": self._format_size(size_bytes),\n                \"size_bytes\": size_bytes,\n            }\n\n        except DockerException as e:\n            logger.warning(f\"Failed to get image info for {image_name}: {e}\")\n            return {}\n\n    def _format_size(self, size_bytes: int) -> str:\n        \"\"\"Format size in human-readable format.\"\"\"\n        size = float(size_bytes)\n        for unit in [\"B\", \"KB\", \"MB\", \"GB\"]:\n            if size < 1024:\n                return f\"{size:.2f} {unit}\"\n            size /= 1024\n        return f\"{size:.2f} TB\"\n\n    def push_image(\n        self,\n        image_name: str,\n        registry_url: Optional[str] = None,\n        username: Optional[str] = None,\n        password: Optional[str] = None,\n    ) -> Dict[str, Any]:\n        \"\"\"Push a Docker image to a registry.\"\"\"\n        if not self.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n        target_image = image_name\n        if registry_url:\n            target_image = f\"{registry_url}/{image_name}\"\n            self._tag_image_sdk(image_name, target_image)\n\n        if username and password:\n            self._docker_login_sdk(registry_url, username, password)\n\n        logger.info(f\"Pushing image {target_image}\")\n\n        try:\n            push_logs = self.client.images.push(target_image, stream=True, decode=True)\n\n            for line in push_logs:\n                if \"error\" in line:\n                    raise RuntimeError(f\"Failed to push image: {line['error']}\")\n                if self.verbose:\n                    logger.debug(f\"Push log: {line}\")\n\n            return {\n                \"pushed_image\": target_image,\n                \"push_time\": str(time.time()),\n            }\n\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to push Docker image: {e}\") from e\n\n    def _docker_login_sdk(self, registry: Optional[str], username: str, password: str) -> None:\n        \"\"\"Log in to Docker registry.\"\"\"\n        try:\n            self.client.login(username=username, password=password, registry=registry)\n            logger.info(f\"Successfully logged in to registry: {registry or 'default'}\")\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to log in to Docker registry: {e}\") from e\n\n    def _tag_image_sdk(self, source_image: str, target_image: str) -> None:\n        \"\"\"Tag a Docker image.\"\"\"\n        try:\n            image = self.client.images.get(source_image)\n            image.tag(target_image, force=True)\n            logger.info(f\"Tagged {source_image} as {target_image}\")\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to tag Docker image: {e}\") from e\n\n    def remove_image(self, image_name: str) -> bool:\n        \"\"\"Remove a Docker image.\"\"\"\n        try:\n            self.client.images.remove(image_name, force=True)\n            logger.info(f\"Removed image {image_name}\")\n            return True\n        except DockerException as e:\n            logger.warning(f\"Failed to remove image {image_name}: {e}\")\n            return False","additions":8,"deletions":7},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/docker_service.py","time":{"start":1775866774850,"end":1775866775568}}}}
