lan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/build_runtime.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/build_runtime.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/build_runtime.py\n@@ -59,13 +59,15 @@\n patch = int(version_parts.group(3))\n prerelease = version_parts.group(4)\n \n if prerelease:\n-    prerelease_parts = re.match(r\"(\\d+)(?:\\.(.+))?\", prerelease)\n+    prerelease_parts = re.match(r\"([^.]+)\\.(\\d+)(?:\\..+)?\", prerelease)\n     if prerelease_parts:\n-        build_num = int(prerelease_parts.group(1)) + 1\n-        suffix = prerelease_parts.group(2) or \"\"\n-        metadata.version = f\"{major}.{minor}.{patch}-{build_num}.{suffix}\"\n+        prefix = prerelease_parts.group(1)\n+        build_num = int(prerelease_parts.group(2)) + 1\n+        suffix_match = re.match(r\"[^.]+\\.\\d+\\.(.+)\", prerelease)\n+        suffix = f\".{suffix_match.group(1)}\" if suffix_match else \"\"\n+        metadata.version = f\"{major}.{minor}.{patch}-{prefix}.{build_num}{suffix}\"\n     else:\n         metadata.version = f\"{major}.{minor}.{patch}-{prerelease}.1\"\n else:\n     patch += 1\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/build_runtime.py","before":"\"\"\"Runtime for the build command.\"\"\"\n\nimport logging\nimport re\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.docker_service import DockerService\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass BuildRuntime:\n    \"\"\"Runtime for building agent images.\"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        \"\"\"Initialize the build runtime.\"\"\"\n        self.verbose = verbose\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        self.metadata_service = MetadataService(verbose=verbose)\n        self.docker_service = DockerService(verbose=verbose)\n\n    def build(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n        \"\"\"Build a Docker image for the agent.\"\"\"\n        logger.info(f\"Building workspace: {workspace_path}\")\n\n        metadata = self.metadata_service.load_metadata(workspace_path)\n        self._validate_build_prerequisites(workspace_path)\n\n        original_version = metadata.version\n        self._increment_version(workspace_path, metadata)\n\n        try:\n            if metadata.build_mode == \"local\":\n                result = self._build_local(workspace_path, metadata, options)\n            else:\n                result = self._build_cloud(workspace_path, metadata, options)\n\n            self._update_build_metadata(workspace_path, metadata, result)\n            return result\n\n        except Exception as e:\n            if original_version != metadata.version:\n                logger.warning(f\"Build failed, reverting version from {metadata.version} to {original_version}\")\n                metadata.version = original_version\n                self.metadata_service.save_metadata(workspace_path, metadata)\n            raise\n\n    def _increment_version(self, workspace_path: Path, metadata: AgentMetadata) -> str:\n        \"\"\"Increment the version for the build.\"\"\"\n        if metadata.version:\n            version_parts = re.match(r\"(\\d+)\\.(\\d+)\\.(\\d+)(?:-(.+))?\", metadata.version)\n            if version_parts:\n                major = int(version_parts.group(1))\n                minor = int(version_parts.group(2))\n                patch = int(version_parts.group(3))\n                prerelease = version_parts.group(4)\n\n                if prerelease:\n                    prerelease_parts = re.match(r\"(\\d+)(?:\\.(.+))?\", prerelease)\n                    if prerelease_parts:\n                        build_num = int(prerelease_parts.group(1)) + 1\n                        suffix = prerelease_parts.group(2) or \"\"\n                        metadata.version = f\"{major}.{minor}.{patch}-{build_num}.{suffix}\"\n                    else:\n                        metadata.version = f\"{major}.{minor}.{patch}-{prerelease}.1\"\n                else:\n                    patch += 1\n                    metadata.version = f\"{major}.{minor}.{patch}\"\n            else:\n                metadata.version = f\"{metadata.version}-1\"\n        else:\n            metadata.version = \"0.1.0\"\n\n        self.metadata_service.save_metadata(workspace_path, metadata)\n        logger.info(f\"Incremented version to: {metadata.version}\")\n        return metadata.version\n\n    def _validate_build_prerequisites(self, workspace_path: Path) -> None:\n        \"\"\"Validate that build prerequisites are met.\"\"\"\n        dockerfile_path = workspace_path / \"Dockerfile\"\n        if not dockerfile_path.exists():\n            raise ValueError(\"Dockerfile not found in workspace. Run 'pack' first.\")\n\n        if not self.docker_service.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n    def _build_local(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> Dict[str, Any]:\n        \"\"\"Build the image locally using Docker.\"\"\"\n        dockerfile_path = workspace_path / \"Dockerfile\"\n        image_name = f\"{metadata.agent_name}:{metadata.version or 'latest'}\"\n\n        build_args: Dict[str, str] = {}\n        proxy = options.get(\"proxy\")\n        if proxy:\n            build_args[\"HTTP_PROXY\"] = proxy\n            build_args[\"HTTPS_PROXY\"] = proxy\n\n        result = self.docker_service.build_image(\n            dockerfile_path=dockerfile_path,\n            context_path=workspace_path,\n            image_name=metadata.agent_name,\n            tag=metadata.version or \"latest\",\n            build_args=build_args if build_args else None,\n        )\n\n        result[\"image_name\"] = image_name\n        return result\n\n    def _build_cloud(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> Dict[str, Any]:\n        \"\"\"Build the image in the cloud.\"\"\"\n        cloud_provider = options.get(\"cloud_provider\", \"huawei\")\n\n        logger.info(f\"Building in cloud with provider: {cloud_provider}\")\n\n        return {\n            \"image_name\": f\"{cloud_provider}/{metadata.agent_name}:{metadata.version or 'latest'}\",\n            \"image_id\": \"cloud-build-id\",\n            \"image_size\": \"Unknown\",\n            \"build_time\": \"cloud-build-time\",\n        }\n\n    def _update_build_metadata(self, workspace_path: Path, metadata: AgentMetadata, build_result: Dict[str, str], tag: str = \"latest\") -> None:\n        \"\"\"Update metadata with build information.\"\"\"\n        metadata.image = metadata.image or {}\n        metadata.image.update(build_result)\n\n        self.metadata_service.save_metadata(workspace_path, metadata)","after":"\"\"\"Runtime for the build command.\"\"\"\n\nimport logging\nimport re\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.docker_service import DockerService\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass BuildRuntime:\n    \"\"\"Runtime for building agent images.\"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        \"\"\"Initialize the build runtime.\"\"\"\n        self.verbose = verbose\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        self.metadata_service = MetadataService(verbose=verbose)\n        self.docker_service = DockerService(verbose=verbose)\n\n    def build(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n        \"\"\"Build a Docker image for the agent.\"\"\"\n        logger.info(f\"Building workspace: {workspace_path}\")\n\n        metadata = self.metadata_service.load_metadata(workspace_path)\n        self._validate_build_prerequisites(workspace_path)\n\n        original_version = metadata.version\n        self._increment_version(workspace_path, metadata)\n\n        try:\n            if metadata.build_mode == \"local\":\n                result = self._build_local(workspace_path, metadata, options)\n            else:\n                result = self._build_cloud(workspace_path, metadata, options)\n\n            self._update_build_metadata(workspace_path, metadata, result)\n            return result\n\n        except Exception as e:\n            if original_version != metadata.version:\n                logger.warning(f\"Build failed, reverting version from {metadata.version} to {original_version}\")\n                metadata.version = original_version\n                self.metadata_service.save_metadata(workspace_path, metadata)\n            raise\n\n    def _increment_version(self, workspace_path: Path, metadata: AgentMetadata) -> str:\n        \"\"\"Increment the version for the build.\"\"\"\n        if metadata.version:\n            version_parts = re.match(r\"(\\d+)\\.(\\d+)\\.(\\d+)(?:-(.+))?\", metadata.version)\n            if version_parts:\n                major = int(version_parts.group(1))\n                minor = int(version_parts.group(2))\n                patch = int(version_parts.group(3))\n                prerelease = version_parts.group(4)\n\n                if prerelease:\n                    prerelease_parts = re.match(r\"([^.]+)\\.(\\d+)(?:\\..+)?\", prerelease)\n                    if prerelease_parts:\n                        prefix = prerelease_parts.group(1)\n                        build_num = int(prerelease_parts.group(2)) + 1\n                        suffix_match = re.match(r\"[^.]+\\.\\d+\\.(.+)\", prerelease)\n                        suffix = f\".{suffix_match.group(1)}\" if suffix_match else \"\"\n                        metadata.version = f\"{major}.{minor}.{patch}-{prefix}.{build_num}{suffix}\"\n                    else:\n                        metadata.version = f\"{major}.{minor}.{patch}-{prerelease}.1\"\n                else:\n                    patch += 1\n                    metadata.version = f\"{major}.{minor}.{patch}\"\n            else:\n                metadata.version = f\"{metadata.version}-1\"\n        else:\n            metadata.version = \"0.1.0\"\n\n        self.metadata_service.save_metadata(workspace_path, metadata)\n        logger.info(f\"Incremented version to: {metadata.version}\")\n        return metadata.version\n\n    def _validate_build_prerequisites(self, workspace_path: Path) -> None:\n        \"\"\"Validate that build prerequisites are met.\"\"\"\n        dockerfile_path = workspace_path / \"Dockerfile\"\n        if not dockerfile_path.exists():\n            raise ValueError(\"Dockerfile not found in workspace. Run 'pack' first.\")\n\n        if not self.docker_service.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n    def _build_local(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> Dict[str, Any]:\n        \"\"\"Build the image locally using Docker.\"\"\"\n        dockerfile_path = workspace_path / \"Dockerfile\"\n        image_name = f\"{metadata.agent_name}:{metadata.version or 'latest'}\"\n\n        build_args: Dict[str, str] = {}\n        proxy = options.get(\"proxy\")\n        if proxy:\n            build_args[\"HTTP_PROXY\"] = proxy\n            build_args[\"HTTPS_PROXY\"] = proxy\n\n        result = self.docker_service.build_image(\n            dockerfile_path=dockerfile_path,\n            context_path=workspace_path,\n            image_name=metadata.agent_name,\n            tag=metadata.version or \"latest\",\n            build_args=build_args if build_args else None,\n        )\n\n        result[\"image_name\"] = image_name\n        return result\n\n    def _build_cloud(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> Dict[str, Any]:\n        \"\"\"Build the image in the cloud.\"\"\"\n        cloud_provider = options.get(\"cloud_provider\", \"huawei\")\n\n        logger.info(f\"Building in cloud with provider: {cloud_provider}\")\n\n        return {\n            \"image_name\": f\"{cloud_provider}/{metadata.agent_name}:{metadata.version or 'latest'}\",\n            \"image_id\": \"cloud-build-id\",\n            \"image_size\": \"Unknown\",\n            \"build_time\": \"cloud-build-time\",\n        }\n\n    def _update_build_metadata(self, workspace_path: Path, metadata: AgentMetadata, build_result: Dict[str, str], tag: str = \"latest\") -> None:\n        \"\"\"Update metadata with build information.\"\"\"\n        metadata.image = metadata.image or {}\n        metadata.image.update(build_result)\n\n        self.metadata_service.save_metadata(workspace_path, metadata)","additions":6,"deletions":4},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/build_runtime.py","time":{"start":1775866836248,"end":1775866836926}}}}
