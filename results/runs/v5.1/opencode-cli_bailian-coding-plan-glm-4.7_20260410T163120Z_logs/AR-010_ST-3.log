{"type":"tool_use","timestamp":1775850006634,"sessionID":"ses_287179656ffezx7f2tbbaM7DVN","part":{"id":"prt_d78e8a25d001qjAd5ycbaK5G15","messageID":"msg_d78e89658001uFSF6QUgvhi7yN","sessionID":"ses_287179656ffezx7f2tbbaM7DVN","type":"tool","tool":"read","callID":"toolu_tool-2004dc696b124fc380ebb7a39b962098","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/session_manager.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/session_manager.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"encoding/json\"\n7: \t\"fmt\"\n8: \t\"io\"\n9: \t\"net/http\"\n10: \t\"time\"\n11: \n12: \t\"k8s.io/klog/v2\"\n13: \n14: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n15: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n16: )\n17: \n18: type SessionManager interface {\n19: \tGetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)\n20: \tCreateSession(ctx context.Context, name string, namespace string, kind string) (string, *types.SandboxInfo, error)\n21: }\n22: \n23: type manager struct {\n24: \tstoreClient     store.Store\n25: \tworkloadMgrAddr string\n26: \thttpClient      *http.Client\n27: }\n28: \n29: func NewSessionManager(storeClient store.Store, workloadMgrAddr string) (SessionManager, error) {\n30: \tif storeClient == nil {\n31: \t\treturn nil, fmt.Errorf(\"store client is required\")\n32: \t}\n33: \n34: \tif workloadMgrAddr == \"\" {\n35: \t\treturn nil, fmt.Errorf(\"workload manager address is required\")\n36: \t}\n37: \n38: \treturn &manager{\n39: \t\tstoreClient:     storeClient,\n40: \t\tworkloadMgrAddr: workloadMgrAddr,\n41: \t\thttpClient:      &http.Client{Timeout: 30 * time.Second},\n42: \t}, nil\n43: }\n44: \n45: func (m *manager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n46: \tsandboxInfo, err := m.storeClient.GetSandbox(ctx, sessionID)\n47: \tif err == nil {\n48: \t\tklog.V(4).Infof(\"Cache hit for session: %s\", sessionID)\n49: \t\treturn sandboxInfo, nil\n50: \t}\n51: \n52: \tif err != store.ErrNotFound {\n53: \t\tklog.Warningf(\"Failed to get sandbox from store: %v\", err)\n54: \t}\n55: \n56: \tklog.V(4).Infof(\"Cache miss for session: %s, querying workload manager\", sessionID)\n57: \treturn m.getSandboxFromWorkloadManager(ctx, sessionID)\n58: }\n59: \n60: func (m *manager) CreateSession(ctx context.Context, name string, namespace string, kind string) (string, *types.SandboxInfo, error) {\n61: \tif err := validateKind(kind); err != nil {\n62: \t\treturn \"\", nil, err\n63: \t}\n64: \n65: \tif !isValidNamespace(namespace) {\n66: \t\treturn \"\", nil, &ValidationError{Field: \"namespace\", Message: \"invalid namespace format\"}\n67: \t}\n68: \n69: \tif !isValidResourceName(name) {\n70: \t\treturn \"\", nil, &ValidationError{Field: \"name\", Message: \"invalid resource name format\"}\n71: \t}\n72: \n73: \tcreateReq := &WorkloadManagerCreateRequest{\n74: \t\tKind:      kind,\n75: \t\tName:      name,\n76: \t\tNamespace: namespace,\n77: \t}\n78: \n79: \treqBody, err := json.Marshal(createReq)\n80: \tif err != nil {\n81: \t\treturn \"\", nil, fmt.Errorf(\"failed to marshal create request: %w\", err)\n82: \t}\n83: \n84: \tvar endpoint string\n85: \tif kind == types.AgentRuntimeKind {\n86: \t\tendpoint = fmt.Sprintf(\"%s/v1/agent-runtime\", m.workloadMgrAddr)\n87: \t} else {\n88: \t\tendpoint = fmt.Sprintf(\"%s/v1/code-interpreter\", m.workloadMgrAddr)\n89: \t}\n90: \n91: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(reqBody))\n92: \tif err != nil {\n93: \t\treturn \"\", nil, fmt.Errorf(\"failed to create request: %w\", err)\n94: \t}\n95: \n96: \treq.Header.Set(\"Content-Type\", \"application/json\")\n97: \n98: \tresp, err := m.httpClient.Do(req)\n99: \tif err != nil {\n100: \t\treturn \"\", nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusServiceUnavailable}\n101: \t}\n102: \tdefer resp.Body.Close()\n103: \n104: \tbody, err := io.ReadAll(resp.Body)\n105: \tif err != nil {\n106: \t\treturn \"\", nil, fmt.Errorf(\"failed to read response body: %w\", err)\n107: \t}\n108: \n109: \tif resp.StatusCode != http.StatusOK {\n110: \t\treturn \"\", nil, &WorkloadManagerError{\n111: \t\t\tMessage: string(body),\n112: \t\t\tCode:    resp.StatusCode,\n113: \t\t}\n114: \t}\n115: \n116: \tvar createResp WorkloadManagerCreateResponse\n117: \tif err := json.Unmarshal(body, &createResp); err != nil {\n118: \t\treturn \"\", nil, fmt.Errorf(\"failed to unmarshal create response: %w\", err)\n119: \t}\n120: \n121: \tsessionID := createResp.SessionID\n122: \n123: \tgetSandboxResp, err := m.getSandboxFromWorkloadManager(ctx, sessionID)\n124: \tif err != nil {\n125: \t\treturn \"\", nil, fmt.Errorf(\"created session but failed to get sandbox info: %w\", err)\n126: \t}\n127: \n128: \treturn sessionID, getSandboxResp, nil\n129: }\n130: \n131: func (m *manager) getSandboxFromWorkloadManager(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n132: \tendpoint := fmt.Sprintf(\"%s/v1/session/%s\", m.workloadMgrAddr, sessionID)\n133: \n134: \treq, err := http.NewRequestWithContext(ctx, http.MethodGet, endpoint, nil)\n135: \tif err != nil {\n136: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n137: \t}\n138: \n139: \tresp, err := m.httpClient.Do(req)\n140: \tif err != nil {\n141: \t\treturn nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusServiceUnavailable}\n142: \t}\n143: \tdefer resp.Body.Close()\n144: \n145: \tbody, err := io.ReadAll(resp.Body)\n146: \tif err != nil {\n147: \t\treturn nil, fmt.Errorf(\"failed to read response body: %w\", err)\n148: \t}\n149: \n150: \tif resp.StatusCode == http.StatusNotFound {\n151: \t\treturn nil, &SandboxNotFoundError{SessionID: sessionID}\n152: \t}\n153: \n154: \tif resp.StatusCode != http.StatusOK {\n155: \t\treturn nil, &WorkloadManagerError{\n156: \t\t\tMessage: string(body),\n157: \t\t\tCode:    resp.StatusCode,\n158: \t\t}\n159: \t}\n160: \n161: \tvar getSessionResp WorkloadManagerGetSessionResponse\n162: \tif err := json.Unmarshal(body, &getSessionResp); err != nil {\n163: \t\treturn nil, fmt.Errorf(\"failed to unmarshal get session response: %w\", err)\n164: \t}\n165: \n166: \tsandboxInfo := SandboxInfoFromWorkloadManager(&getSessionResp, sessionID)\n167: \n168: \tif err := m.storeClient.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n169: \t\tklog.Warningf(\"Failed to cache sandbox info: %v\", err)\n170: \t}\n171: \n172: \treturn sandboxInfo, nil\n173: }\n\n(End of file - total 173 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\ntype SessionManager interface {\n\tGetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)\n\tCreateSession(ctx context.Context, name string, namespace string, kind string) (string, *types.SandboxInfo, error)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/session_manager.go","time":{"start":1775850006613,"end":1775850006633}}}}
