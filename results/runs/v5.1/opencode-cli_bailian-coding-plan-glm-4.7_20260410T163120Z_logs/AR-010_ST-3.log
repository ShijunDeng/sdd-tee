r:default=\"15m\"\n34: \t// +kubebuilder:validation:Type=string\n35: \t// +kubebuilder:validation:Format=duration\n36: \t// +optional\n37: \tSessionTimeout *metav1.Duration `json:\"sessionTimeout,omitempty\"`\n38: \n39: \t// MaxSessionDuration defines the maximum allowed duration for a session.\n40: \t// +kubebuilder:default=\"8h\"\n41: \t// +kubebuilder:validation:Type=string\n42: \t// +kubebuilder:validation:Format=duration\n43: \t// +optional\n44: \tMaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\"`\n45: }\n46: \n47: // SandboxTemplate defines the template for creating sandbox pods.\n48: type SandboxTemplate struct {\n49: \t// Metadata defines labels and annotations for the pod.\n50: \t// +optional\n51: \tMetadata *SandboxMetadata `json:\"metadata,omitempty\"`\n52: \n53: \t// Spec defines the pod specification.\n54: \tSpec SandboxPodSpec `json:\"spec\"`\n55: }\n56: \n57: // SandboxMetadata defines metadata for sandbox pods.\n58: type SandboxMetadata struct {\n59: \t// Labels are key-value pairs attached to the pod.\n60: \t// +optional\n61: \tLabels map[string]string `json:\"labels,omitempty\"`\n62: \n63: \t// Annotations are unstructured key-value pairs stored with the pod.\n64: \t// +optional\n65: \tAnnotations map[string]string `json:\"annotations,omitempty\"`\n66: }\n67: \n68: // SandboxPodSpec defines the specification for sandbox pods.\n69: type SandboxPodSpec struct {\n70: \t// Containers represents the list of containers in the pod.\n71: \t// +kubebuilder:validation:MinItems=1\n72: \tContainers []SandboxContainer `json:\"containers\"`\n73: \n74: \t// NodeSelector specifies node selection constraints.\n75: \t// +optional\n76: \tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n77: \n78: \t// Affinity defines pod scheduling constraints.\n79: \t// +optional\n80: \tAffinity *SandboxAffinity `json:\"affinity,omitempty\"`\n81: \n82: \t// Tolerations defines pod tolerations.\n83: \t// +optional\n84: \tTolerations []SandboxToleration `json:\"tolerations,omitempty\"`\n85: \n86: \t// ResourceRequirements defines resource requirements for the pod.\n87: \t// +optional\n88: \tResourceRequirements *SandboxResources `json:\"resources,omitempty\"`\n89: \n90: \t// Volumes defines pod volumes.\n91: \t// +optional\n92: \tVolumes []SandboxVolume `json:\"volumes,omitempty\"`\n93: }\n94: \n95: // SandboxContainer defines a container in a sandbox pod.\n96: type SandboxContainer struct {\n97: \t// Name is the name of the container.\n98: \t// +required\n99: \t// +kubebuilder:validation:MinLength=1\n100: \tName string `json:\"name\"`\n101: \n102: \t// Image is the container image.\n103: \t// +required\n104: \tImage string `json:\"image\"`\n105: \n106: \t// Command specifies the entrypoint array for the container.\n107: \t// +optional\n108: \tCommand []string `json:\"command,omitempty\"`\n109: \n110: \t// Args specifies the arguments to the entrypoint.\n111: \t// +optional\n112: \tArgs []string `json:\"args,omitempty\"`\n113: \n114: \t// WorkingDir specifies the working directory.\n115: \t// +optional\n116: \tWorkingDir string `json:\"workingDir,omitempty\"`\n117: \n118: \t// Ports represents the network ports exposed by the container.\n119: \t// +optional\n120: \tPorts []SandboxContainerPort `json:\"ports,omitempty\"`\n121: \n122: \t// Env represents environment variables.\n123: \t// +optional\n124: \tEnv []SandboxEnvVar `json:\"env,omitempty\"`\n125: \n126: \t// Resources defines compute resource requirements.\n127: \t// +optional\n128: \tResources *SandboxContainerResources `json:\"resources,omitempty\"`\n129: \n130: \t// VolumeMounts specifies volume mounts.\n131: \t// +optional\n132: \tVolumeMounts []SandboxVolumeMount `json:\"volumeMounts,omitempty\"`\n133: \n134: \t// LivenessProbe defines the liveness probe.\n135: \t// +optional\n136: \tLivenessProbe *SandboxProbe `json:\"livenessProbe,omitempty\"`\n137: \n138: \t// ReadinessProbe defines the readiness probe.\n139: \t// +optional\n140: \tReadinessProbe *SandboxProbe `json:\"readinessProbe,omitempty\"`\n141: \n142: \t// SecurityContext defines security settings.\n143: \t// +optional\n144: \tSecurityContext *SandboxSecurityContext `json:\"securityContext,omitempty\"`\n145: }\n146: \n147: // SandboxContainerPort defines a network port in a container.\n148: type SandboxContainerPort struct {\n149: \t// Name is the name of the port.\n150: \t// +optional\n151: \tName string `json:\"name,omitempty\"`\n152: \n153: \t// ContainerPort is the port number on the container.\n154: \t// +required\n155: \t// +kubebuilder:validation:Minimum=1\n156: \t// +kubebuilder:validation:Maximum=65535\n157: \tContainerPort int32 `json:\"containerPort\"`\n158: \n159: \t// Protocol is the protocol for the port.\n160: \t// +optional\n161: \t// +kubebuilder:default=TCP\n162: \tProtocol string `json:\"protocol,omitempty\"`\n163: \n164: \t// HostPort is the port number on the host.\n165: \t// +optional\n166: \t// +kubebuilder:validation:Minimum=1\n167: \t// +kubebuilder:validation:Maximum=65535\n168: \tHostPort int32 `json:\"hostPort,omitempty\"`\n169: }\n170: \n171: // SandboxEnvVar defines an environment variable.\n172: type SandboxEnvVar struct {\n173: \t// Name is the name of the environment variable.\n174: \t// +required\n175: \tName string `json:\"name\"`\n176: \n177: \t// Value is the literal value of the environment variable.\n178: \t// +optional\n179: \tValue string `json:\"value,omitempty\"`\n180: \n181: \t// ValueFrom specifies a source for the value.\n182: \t// +optional\n183: \tValueFrom *SandboxEnvVarSource `json:\"valueFrom,omitempty\"`\n184: }\n185: \n186: // SandboxEnvVarSource defines a source for environment variable values.\n187: type SandboxEnvVarSource struct {\n188: \t// FieldRef selects a field from the pod.\n189: \t// +optional\n190: \tFieldRef *SandboxFieldRef `json:\"fieldRef,omitempty\"`\n191: \n192: \t// ConfigMapKeyRef selects a key from a ConfigMap.\n193: \t// +optional\n194: \tConfigMapKeyRef *SandboxConfigMapKeyRef `json:\"configMapKeyRef,omitempty\"`\n195: \n196: \t// SecretKeyRef selects a key from a Secret.\n197: \t// +optional\n198: \tSecretKeyRef *SandboxSecretKeyRef `json:\"secretKeyRef,omitempty\"`\n199: }\n200: \n201: // SandboxFieldRef selects a field from a pod.\n202: type SandboxFieldRef struct {\n203: \t// FieldPath is the path of the field.\n204: \t// +required\n205: \tFieldPath string `json:\"fieldPath\"`\n206: }\n207: \n208: // SandboxConfigMapKeyRef selects a key from a ConfigMap.\n209: type SandboxConfigMapKeyRef struct {\n210: \t// Name is the name of the ConfigMap.\n211: \t// +required\n212: \tName string `json:\"name\"`\n213: \n214: \t// Key is the key to select.\n215: \t// +required\n216: \tKey string `json:\"key\"`\n217: \n218: \t// Optional specifies whether the ConfigMap must exist.\n219: \t// +optional\n220: \tOptional *bool `json:\"optional,omitempty\"`\n221: }\n222: \n223: // SandboxSecretKeyRef selects a key from a Secret.\n224: type SandboxSecretKeyRef struct {\n225: \t// Name is the name of the Secret.\n226: \t// +required\n227: \tName string `json:\"name\"`\n228: \n229: \t// Key is the key to select.\n230: \t// +required\n231: \tKey string `json:\"key\"`\n232: \n233: \t// Optional specifies whether the Secret must exist.\n234: \t// +optional\n235: \tOptional *bool `json:\"optional,omitempty\"`\n236: }\n237: \n238: // SandboxContainerResources defines resource requirements for a container.\n239: type SandboxContainerResources struct {\n240: \t// Limits defines the resource limits.\n241: \t// +optional\n242: \tLimits SandboxResourceList `json:\"limits,omitempty\"`\n243: \n244: \t// Requests defines the resource requests.\n245: \t// +optional\n246: \tRequests SandboxResourceList `json:\"requests,omitempty\"`\n247: }\n248: \n249: // SandboxResourceList defines a list of resources.\n250: type SandboxResourceList struct {\n251: \t// CPU defines CPU resources.\n252: \t// +optional\n253: \tCPU string `json:\"cpu,omitempty\"`\n254: \n255: \t// Memory defines memory resources.\n256: \t// +optional\n257: \tMemory string `json:\"memory,omitempty\"`\n258: \n259: \t// EphemeralStorage defines ephemeral storage resources.\n260: \t// +optional\n261: \tEphemeralStorage string `json:\"ephemeralStorage,omitempty\"`\n262: }\n263: \n264: // SandboxResources defines resource requirements for the pod.\n265: type SandboxResources struct {\n266: \t// Limits defines the resource limits.\n267: \t// +optional\n268: \tLimits SandboxResourceList `json:\"limits,omitempty\"`\n269: \n270: \t// Requests defines the resource requests.\n271: \t// +optional\n272: \tRequests SandboxResourceList `json:\"requests,omitempty\"`\n273: }\n274: \n275: // SandboxVolumeMount defines a volume mount.\n276: type SandboxVolumeMount struct {\n277: \t// Name is the name of the volume.\n278: \t// +required\n279: \tName string `json:\"name\"`\n280: \n281: \t// MountPath is the path within the container.\n282: \t// +required\n283: \tMountPath string `json:\"mountPath\"`\n284: \n285: \t// SubPath is the sub-path within the volume.\n286: \t// +optional\n287: \tSubPath string `json:\"subPath,omitempty\"`\n288: \n289: \t// ReadOnly specifies whether the volume is read-only.\n290: \t// +optional\n291: \tReadOnly bool `json:\"readOnly,omitempty\"`\n292: }\n293: \n294: // SandboxVolume defines a volume.\n295: type SandboxVolume struct {\n296: \t// Name is the name of the volume.\n297: \t// +required\n298: \tName string `json:\"name\"`\n299: \n300: \t// EmptyDir defines an empty directory volume.\n301: \t// +optional\n302: \tEmptyDir *SandboxEmptyDirVolumeSource `json:\"emptyDir,omitempty\"`\n303: \n304: \t// ConfigMap defines a ConfigMap volume.\n305: \t// +optional\n306: \tConfigMap *SandboxConfigMapVolumeSource `json:\"configMap,omitempty\"`\n307: \n308: \t// Secret defines a Secret volume.\n309: \t// +optional\n310: \tSecret *SandboxSecretVolumeSource `json:\"secret,omitempty\"`\n311: \n312: \t// PersistentVolumeClaim defines a PVC volume.\n313: \t// +optional\n314: \tPersistentVolumeClaim *SandboxPersistentVolumeClaimVolumeSource `json:\"persistentVolumeClaim,omitempty\"`\n315: }\n316: \n317: // SandboxEmptyDirVolumeSource defines an empty directory volume.\n318: type SandboxEmptyDirVolumeSource struct {\n319: \t// SizeLimit is the limit on the size of the volume.\n320: \t// +optional\n321: \tSizeLimit string `json:\"sizeLimit,omitempty\"`\n322: }\n323: \n324: // SandboxConfigMapVolumeSource defines a ConfigMap volume.\n325: type SandboxConfigMapVolumeSource struct {\n326: \t// Name is the name of the ConfigMap.\n327: \t// +required\n328: \tName string `json:\"name\"`\n329: \n330: \t// Optional specifies whether the ConfigMap must exist.\n331: \t// +optional\n332: \tOptional *bool `json:\"optional,omitempty\"`\n333: \n334: \t// Items specifies keys to use and the path to mount them at.\n335: \t// +optional\n336: \tItems []SandboxKeyToPath `json:\"items,omitempty\"`\n337: }\n338: \n339: // SandboxSecretVolumeSource defines a Secret volume.\n340: type SandboxSecretVolumeSource struct {\n341: \t// SecretName is the name of the Secret.\n342: \t// +required\n343: \tSecretName string `json:\"secretName\"`\n344: \n345: \t// Optional specifies whether the Secret must exist.\n346: \t// +optional\n347: \tOptional *bool `json:\"optional,omitempty\"`\n348: \n349: \t// Items specifies keys to use and the path to mount them at.\n350: \t// +optional\n351: \tItems []SandboxKeyToPath `json:\"items,omitempty\"`\n352: }\n353: \n354: // SandboxPersistentVolumeClaimVolumeSource defines a PVC volume.\n355: type SandboxPersistentVolumeClaimVolumeSource struct {\n356: \t// ClaimName is the name of the PVC.\n357: \t// +required\n358: \tClaimName string `json:\"claimName\"`\n359: \n360: \t// ReadOnly specifies whether the volume is read-only.\n361: \t// +optional\n362: \tReadOnly bool `json:\"readOnly,omitempty\"`\n363: }\n364: \n365: // SandboxKeyToPath maps a key to a path.\n366: type SandboxKeyToPath struct {\n367: \t// Key is the key to reference.\n368: \t// +required\n369: \tKey string `json:\"key\"`\n370: \n371: \t// Path is the relative path within the mount point.\n372: \t// +required\n373: \tPath string `json:\"path\"`\n374: \n375: \t// Mode is the octal permission bits.\n376: \t// +optional\n377: \tMode *int32 `json:\"mode,omitempty\"`\n378: }\n379: \n380: // SandboxProbe defines a probe.\n381: type SandboxProbe struct {\n382: \t// ProbeHandler defines the probe handler.\n383: \tSandboxProbeHandler `json:\",inline\"`\n384: \n385: \t// InitialDelaySeconds is the delay before the first probe.\n386: \t// +optional\n387: \t// +kubebuilder:default=0\n388: \t// +kubebuilder:validation:Minimum=0\n389: \tInitialDelaySeconds int32 `json:\"initialDelaySeconds,omitempty\"`\n390: \n391: \t// TimeoutSeconds is the timeout for the probe.\n392: \t// +optional\n393: \t// +kubebuilder:default=1\n394: \t// +kubebuilder:validation:Minimum=1\n395: \tTimeoutSeconds int32 `json:\"timeoutSeconds,omitempty\"`\n396: \n397: \t// PeriodSeconds is the period between probes.\n398: \t// +optional\n399: \t// +kubebuilder:default=10\n400: \t// +kubebuilder:validation:Minimum=1\n401: \tPeriodSeconds int32 `json:\"periodSeconds,omitempty\"`\n402: \n403: \t// SuccessThreshold is the number of successes to consider successful.\n404: \t// +optional\n405: \t// +kubebuilder:default=1\n406: \t// +kubebuilder:validation:Minimum=1\n407: \tSuccessThreshold int32 `json:\"successThreshold,omitempty\"`\n408: \n409: \t// FailureThreshold is the number of failures to consider failed.\n410: \t// +optional\n411: \t// +kubebuilder:default=3\n412: \t// +kubebuilder:validation:Minimum=1\n413: \tFailureThreshold int32 `json:\"failureThreshold,omitempty\"`\n414: }\n415: \n416: // SandboxProbeHandler defines the probe handler.\n417: type SandboxProbeHandler struct {\n418: \t// ExecAction specifies an action to execute in the container.\n419: \t// +optional\n420: \tExec *SandboxExecAction `json:\"exec,omitempty\"`\n421: \n422: \t// TCPSocketAction specifies a TCP socket check.\n423: \t// +optional\n424: \tTCPSocket *SandboxTCPSocketAction `json:\"tcpSocket,omitempty\"`\n425: \n426: \t// HTTPGetAction specifies an HTTP GET check.\n427: \t// +optional\n428: \tHTTPGet *SandboxHTTPGetAction `json:\"httpGet,omitempty\"`\n429: }\n430: \n431: // SandboxExecAction defines an exec action.\n432: type SandboxExecAction struct {\n433: \t// Command is the command to execute.\n434: \t// +required\n435: \tCommand []string `json:\"command\"`\n436: }\n437: \n438: // SandboxTCPSocketAction defines a TCP socket check.\n439: type SandboxTCPSocketAction struct {\n440: \t// Port is the port number or name.\n441: \t// +required\n442: \tPort intstr.IntOrString `json:\"port\"`\n443: \n444: \t// Host is the host to connect to.\n445: \t// +optional\n446: \tHost string `json:\"host,omitempty\"`\n447: }\n448: \n449: // SandboxHTTPGetAction defines an HTTP GET check.\n450: type SandboxHTTPGetAction struct {\n451: \t// Port is the port number or name.\n452: \t// +required\n453: \tPort intstr.IntOrString `json:\"port\"`\n454: \n455: \t// Host is the host to connect to.\n456: \t// +optional\n457: \tHost string `json:\"host,omitempty\"`\n458: \n459: \t// Path is the path to request.\n460: \t// +optional\n461: \tPath string `json:\"path,omitempty\"`\n462: \n463: \t// Scheme is the URI scheme.\n464: \t// +optional\n465: \t// +kubebuilder:default=HTTP\n466: \tScheme string `json:\"scheme,omitempty\"`\n467: \n468: \t// HTTPHeaders specifies custom headers.\n469: \t// +optional\n470: \tHTTPHeaders []SandboxHTTPHeader `json:\"httpHeaders,omitempty\"`\n471: }\n472: \n473: // SandboxHTTPHeader defines an HTTP header.\n474: type SandboxHTTPHeader struct {\n475: \t// Name is the header name.\n476: \t// +required\n477: \tName string `json:\"name\"`\n478: \n479: \t// Value is the header value.\n480: \t// +required\n481: \tValue string `json:\"value\"`\n482: }\n483: \n484: // SandboxSecurityContext defines security settings.\n485: type SandboxSecurityContext struct {\n486: \t// RunAsUser is the UID to run the entrypoint of the container.\n487: \t// +optional\n488: \tRunAsUser *int64 `json:\"runAsUser,omitempty\"`\n489: \n490: \t// RunAsGroup is the GID to run the entrypoint of the container.\n491: \t// +optional\n492: \tRunAsGroup *int64 `json:\"runAsGroup,omitempty\"`\n493: \n494: \t// RunAsNonRoot specifies whether the container must run as non-root.\n495: \t// +optional\n496: \tRunAsNonRoot *bool `json:\"runAsNonRoot,omitempty\"`\n497: \n498: \t// ReadOnlyRootFilesystem specifies whether the root filesystem is read-only.\n499: \t// +optional\n500: \tReadOnlyRootFilesystem *bool `json:\"readOnlyRootFilesystem,omitempty\"`\n501: \n502: \t// AllowPrivilegeEscalation specifies whether a process can gain privileges.\n503: \t// +optional\n504: \tAllowPrivilegeEscalation *bool `json:\"allowPrivilegeEscalation,omitempty\"`\n505: \n506: \t// Capabilities defines Linux capabilities.\n507: \t// +optional\n508: \tCapabilities *SandboxCapabilities `json:\"capabilities,omitempty\"`\n509: \n510: \t// SeccompProfile defines the seccomp profile.\n511: \t// +optional\n512: \tSeccompProfile *SandboxSeccompProfile `json:\"seccompProfile,omitempty\"`\n513: \n514: \t// Privileged specifies whether to run in privileged mode.\n515: \t// +optional\n516: \tPrivileged *bool `json:\"privileged,omitempty\"`\n517: \n518: \t// ProcMount specifies the proc mount type.\n519: \t// +optional\n520: \tProcMount string `json:\"procMount,omitempty\"`\n521: }\n522: \n523: // SandboxCapabilities defines Linux capabilities.\n524: type SandboxCapabilities struct {\n525: \t// Add is the list of capabilities to add.\n526: \t// +optional\n527: \tAdd []string `json:\"add,omitempty\"`\n528: \n529: \t// Drop is the list of capabilities to drop.\n530: \t// +optional\n531: \tDrop []string `json:\"drop,omitempty\"`\n532: }\n533: \n534: // SandboxSeccompProfile defines the seccomp profile.\n535: type SandboxSeccompProfile struct {\n536: \t// Type is the type of seccomp profile.\n537: \t// +required\n538: \tType string `json:\"type\"`\n539: \n540: \t// LocalhostProfile references a local profile.\n541: \t// +optional\n542: \tLocalhostProfile string `json:\"localhostProfile,omitempty\"`\n543: }\n544: \n545: // SandboxAffinity defines pod scheduling constraints.\n546: type SandboxAffinity struct {\n547: \t// NodeAffinity defines node affinity.\n548: \t// +optional\n549: \tNodeAffinity *SandboxNodeAffinity `json:\"nodeAffinity,omitempty\"`\n550: \n551: \t// PodAffinity defines pod affinity.\n552: \t// +optional\n553: \tPodAffinity *SandboxPodAffinity `json:\"podAffinity,omitempty\"`\n554: \n555: \t// PodAntiAffinity defines pod anti-affinity.\n556: \t// +optional\n557: \tPodAntiAffinity *SandboxPodAffinity `json:\"podAntiAffinity,omitempty\"`\n558: }\n559: \n560: // SandboxNodeAffinity defines node affinity.\n561: type SandboxNodeAffinity struct {\n562: \t// RequiredDuringSchedulingIgnoredDuringExecution defines required node selectors.\n563: \t// +optional\n564: \tRequiredDuringSchedulingIgnoredDuringExecution *SandboxNodeSelector `json:\"requiredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n565: \n566: \t// PreferredDuringSchedulingIgnoredDuringExecution defines preferred node selectors.\n567: \t// +optional\n568: \tPreferredDuringSchedulingIgnoredDuringExecution []SandboxPreferredSchedulingTerm `json:\"preferredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n569: }\n570: \n571: // SandboxNodeSelector defines a node selector.\n572: type SandboxNodeSelector struct {\n573: \t// NodeSelectorTerms is the list of node selector terms.\n574: \t// +required\n575: \t// +kubebuilder:validation:MinItems=1\n576: \tNodeSelectorTerms []SandboxNodeSelectorTerm `json:\"nodeSelectorTerms\"`\n577: }\n578: \n579: // SandboxNodeSelectorTerm defines a node selector term.\n580: type SandboxNodeSelectorTerm struct {\n581: \t// MatchExpressions is a list of node selector requirements.\n582: \t// +optional\n583: \tMatchExpressions []SandboxNodeSelectorRequirement `json:\"matchExpressions,omitempty\"`\n584: \n585: \t// MatchFields is a list of node selector field requirements.\n586: \t// +optional\n587: \tMatchFields []SandboxNodeSelectorRequirement `json:\"matchFields,omitempty\"`\n588: }\n589: \n590: // SandboxNodeSelectorRequirement defines a node selector requirement.\n591: type SandboxNodeSelectorRequirement struct {\n592: \t// Key is the label key.\n593: \t// +required\n594: \tKey string `json:\"key\"`\n595: \n596: \t// Operator is the operator.\n597: \t// +required\n598: \tOperator string `json:\"operator\"`\n599: \n600: \t// Values is the values.\n601: \t// +optional\n602: \tValues []string `json:\"values,omitempty\"`\n603: }\n604: \n605: // SandboxPreferredSchedulingTerm defines a preferred scheduling term.\n606: type SandboxPreferredSchedulingTerm struct {\n607: \t// Weight is the weight.\n608: \t// +required\n609: \t// +kubebuilder:validation:Minimum=1\n610: \t// +kubebuilder:validation:Maximum=100\n611: \tWeight int32 `json:\"weight\"`\n612: \n613: \t// Preference is the preference.\n614: \t// +required\n615: \tPreference SandboxNodeSelectorTerm `json:\"preference\"`\n616: }\n617: \n618: // SandboxPodAffinity defines pod affinity.\n619: type SandboxPodAffinity struct {\n620: \t// RequiredDuringSchedulingIgnoredDuringExecution defines required pod selectors.\n621: \t// +optional\n622: \tRequiredDuringSchedulingIgnoredDuringExecution []SandboxPodAffinityTerm `json:\"requiredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n623: \n624: \t// PreferredDuringSchedulingIgnoredDuringExecution defines preferred pod selectors.\n625: \t// +optional\n626: \tPreferredDuringSchedulingIgnoredDuringExecution []SandboxWeightedPodAffinityTerm `json:\"preferredDuringSchedulingIgnoredDuringExecution,omitempty\"`\n627: }\n628: \n629: // SandboxPodAffinityTerm defines a pod affinity term.\n630: type SandboxPodAffinityTerm struct {\n631: \t// LabelSelector defines the label selector.\n632: \t// +optional\n633: \tLabelSelector *SandboxLabelSelector `json:\"labelSelector,omitempty\"`\n634: \n635: \t// Namespaces specifies the namespaces.\n636: \t// +optional\n637: \tNamespaces []string `json:\"namespaces,omitempty\"`\n638: \n639: \t// TopologyKey is the topology key.\n640: \t// +required\n641: \tTopologyKey string `json:\"topologyKey\"`\n642: \n643: \t// NamespaceSelector defines the namespace selector.\n644: \t// +optional\n645: \tNamespaceSelector *SandboxLabelSelector `json:\"namespaceSelector,omitempty\"`\n646: }\n647: \n648: // SandboxLabelSelector defines a label selector.\n649: type SandboxLabelSelector struct {\n650: \t// MatchLabels is a map of label keys and values.\n651: \t// +optional\n652: \tMatchLabels map[string]string `json:\"matchLabels,omitempty\"`\n653: \n654: \t// MatchExpressions is a list of label selector requirements.\n655: \t// +optional\n656: \tMatchExpressions []SandboxLabelSelectorRequirement `json:\"matchExpressions,omitempty\"`\n657: }\n658: \n659: // SandboxLabelSelectorRequirement defines a label selector requirement.\n660: type SandboxLabelSelectorRequirement struct {\n661: \t// Key is the label key.\n662: \t// +required\n663: \tKey string `json:\"key\"`\n664: \n665: \t// Operator is the operator.\n666: \t// +required\n667: \tOperator string `json:\"operator\"`\n668: \n669: \t// Values is the values.\n670: \t// +optional\n671: \tValues []string `json:\"values,omitempty\"`\n672: }\n673: \n674: // SandboxWeightedPodAffinityTerm defines a weighted pod affinity term.\n675: type SandboxWeightedPodAffinityTerm struct {\n676: \t// Weight is the weight.\n677: \t// +required\n678: \t// +kubebuilder:validation:Minimum=1\n679: \t// +kubebuilder:validation:Maximum=100\n680: \tWeight int32 `json:\"weight\"`\n681: \n682: \t// PodAffinityTerm is the pod affinity term.\n683: \t// +required\n684: \tPodAffinityTerm SandboxPodAffinityTerm `json:\"podAffinityTerm\"`\n685: }\n686: \n687: // SandboxToleration defines a pod toleration.\n688: type SandboxToleration struct {\n689: \t// Key is the toleration key.\n690: \t// +optional\n691: \tKey string `json:\"key,omitempty\"`\n692: \n693: \t// Operator is the toleration operator.\n694: \t// +optional\n695: \tOperator string `json:\"operator,omitempty\"`\n696: \n697: \t// Value is the toleration value.\n698: \t// +optional\n699: \tValue string `json:\"value,omitempty\"`\n700: \n701: \t// Effect is the toleration effect.\n702: \t// +optional\n703: \tEffect string `json:\"effect,omitempty\"`\n704: \n705: \t// TolerationSeconds is the toleration duration.\n706: \t// +optional\n707: \tTolerationSeconds *int64 `json:\"tolerationSeconds,omitempty\"`\n708: }\n709: \n710: // AgentRuntimeStatus defines the observed state of an AgentRuntime.\n711: type AgentRuntimeStatus struct {\n712: \t// Conditions represent the latest available observations of the AgentRuntime's current state.\n713: \t// +optional\n714: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n715: \n716: \t// ObservedGeneration is the most recent generation observed by the controller.\n717: \t// +optional\n718: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n719: }\n720: \n721: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n722: \n723: // AgentRuntimeList contains a list of AgentRuntime objects.\n724: type AgentRuntimeList struct {\n725: \tmetav1.TypeMeta `json:\",inline\"`\n726: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n727: \n728: \tItems []AgentRuntime `json:\"items\"`\n729: }\n730: \n731: // +genclient\n732: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n733: // +k8s:openapi-gen=true\n734: // +kubebuilder:resource:shortName=ci;codeinterpreter\n735: // +kubebuilder:subresource:status\n736: // +kubebuilder:printcolumn:name=\"Ready\",type=\"boolean\",JSONPath=\".status.ready\"\n737: // +kubebuilder:printcolumn:name=\"Runtime\",type=\"string\",JSONPath=\".spec.runtime\"\n738: // +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n739: \n740: // CodeInterpreter defines a custom resource for managing code execution environments.\n741: // It represents a code interpreter sandbox that executes user code in a secure environment.\n742: type CodeInterpreter struct {\n743: \tmetav1.TypeMeta   `json:\",inline\"`\n744: \tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n745: \n746: \tSpec   CodeInterpreterSpec   `json:\"spec,omitempty\"`\n747: \tStatus CodeInterpreterStatus `json:\"status,omitempty\"`\n748: }\n749: \n750: // CodeInterpreterSpec defines the desired state of a CodeInterpreter.\n751: type CodeInterpreterSpec struct {\n752: \t// Image is the container image for the interpreter (e.g., \"python:3.11-slim\").\n753: \t// +required\n754: \tImage string `json:\"image\"`\n755: \n756: \t// Runtime specifies the execution environment type.\n757: \t// +kubebuilder:default=\"python\"\n758: \t// +kubebuilder:validation:Enum=python;javascript;typescript;go\n759: \t// +optional\n760: \tRuntime string `json:\"runtime,omitempty\"`\n761: \n762: \t// Timeout defines the maximum execution time for code snippets.\n763: \t// +kubebuilder:default=\"5m\"\n764: \t// +kubebuilder:validation:Type=string\n765: \t// +kubebuilder:validation:Format=duration\n766: \t// +optional\n767: \tTimeout *metav1.Duration `json:\"timeout,omitempty\"`\n768: \n769: \t// Resources defines compute resource requirements for the interpreter container.\n770: \t// +optional\n771: \tResources *SandboxContainerResources `json:\"resources,omitempty\"`\n772: \n773: \t// Env defines environment variables to inject into the interpreter container.\n774: \t// +optional\n775: \tEnv []SandboxEnvVar `json:\"env,omitempty\"`\n776: \n777: \t// EnabledPackages specifies allowed packages for the interpreter.\n778: \t// Only packages listed here can be imported/required. Empty list allows all.\n779: \t// +optional\n780: \tEnabledPackages []string `json:\"enabledPackages,omitempty\"`\n781: }\n782: \n783: // CodeInterpreterStatus defines the observed state of a CodeInterpreter.\n784: type CodeInterpreterStatus struct {\n785: \t// Ready indicates whether the interpreter is ready to execute code.\n786: \t// +optional\n787: \tReady bool `json:\"ready,omitempty\"`\n788: \n789: \t// Conditions represent the latest available observations of the CodeInterpreter's current state.\n790: \t// +optional\n791: \tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n792: \n793: \t// ObservedGeneration is the most recent generation observed by the controller.\n794: \t// +optional\n795: \tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n796: }\n797: \n798: // +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n799: \n800: // CodeInterpreterList contains a list of CodeInterpreter objects.\n801: type CodeInterpreterList struct {\n802: \tmetav1.TypeMeta `json:\",inline\"`\n803: \tmetav1.ListMeta `json:\"metadata,omitempty\"`\n804: \n805: \tItems []CodeInterpreter `json:\"items\"`\n806: }\n\n(End of file - total 806 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/util/intstr\"\n)\n\n// +genclient\n// +genclient:nonNamespaced\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +k8s:openapi-gen=true\n// +kubebuilder:resource:shortName=ar;agentruntime\n// +kubebuilder:subresource:status\n// +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n\n// AgentRuntime defines a custom resource for managing agent runtime configurations.\n// It represents a sandbox orchestration runtime that manages the lifecycle of agent pods.\ntype AgentRuntime struct {\n\tmetav1.TypeMeta   `json:\",inline\"`\n\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types.go","time":{"start":1775850006620,"end":1775850006654}}}}
{"type":"step_finish","timestamp":1775850006685,"sessionID":"ses_287179656ffezx7f2tbbaM7DVN","part":{"id":"prt_d78e8a881001rHGe4MSNfMddx9","reason":"tool-calls","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","messageID":"msg_d78e89658001uFSF6QUgvhi7yN","sessionID":"ses_287179656ffezx7f2tbbaM7DVN","type":"step-finish","tokens":{"total":24032,"input":5007,"output":210,"reasoning":0,"cache":{"write":0,"read":18815}},"cost":0}}
{"type":"step_start","timestamp":1775850011946,"sessionID":"ses_287179656ffezx7f2tbbaM7DVN","part":{"id":"prt_d78e8bd28001k8VzxRnhNYM1cF","messageID":"msg_d78e8a8ba001P1OsP7AcL0DXeP","sessionID":"ses_287179656ffezx7f2tbbaM7DVN","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","type":"step-start"}}
{"type":"tool_use","timestamp":1775850013810,"sessionID":"ses_287179656ffezx7f2tbbaM7DVN","part":{"id":"prt_d78e8c107001y52sYOQYz86eqo","messageID":"msg_d78e8a8ba001P1OsP7AcL0DXeP","sessionID":"ses_287179656ffezx7f2tbbaM7DVN","type":"tool","tool":"read","callID":"toolu_tool-65ce9320a0914bdfa87bf96b0cb78983","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-009/design.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-009/design.md</path>\n<type>file</type>\n<content>\n1: # AR-009 Design - Router HTTP Reverse Proxy Core\n2: \n3: ## Overview\n4: \n5: The Router module provides HTTP reverse proxy capabilities for routing client requests to sandbox instances (AgentRuntime and CodeInterpreter). It acts as the entry point for all external traffic, managing session-based routing, authentication, and request forwarding.\n6: \n7: ## Architecture\n8: \n9: ### Component Diagram\n10: \n11: ```\n12: ┌─────────────────┐\n13: │  Client Request │\n14: └────────┬────────┘\n15:          │\n16:          ▼\n17: ┌─────────────────────────────────────┐\n18: │  HTTP Server (Gin)                  │\n19: │  - Request Validation               │\n20: │  - Concurrency Limiting             │\n21: │  - Logging/Recovery                 │\n22: └────────┬────────────────────────────┘\n23:          │\n24:          ▼\n25: ┌─────────────────────────────────────┐\n26: │  Router Handler                     │\n27: │  - Session Extraction               │\n28: │  - JWT Generation/Validation        │\n29: │  - Sandbox Lookup                   │\n30: └────────┬────────────────────────────┘\n31:          │\n32:          ▼\n33: ┌─────────────────────────────────────┐\n34: │  Session Manager                    │\n35: │  - Cache Lookup                     │\n36: │  - Workload Manager Call            │\n37: │  - Session Creation/Retrieval       │\n38: └────────┬────────────────────────────┘\n39:          │\n40:          ▼\n41: ┌─────────────────────────────────────┐\n42: │  Reverse Proxy                      │\n43: │  - Request Forwarding               │\n44: │  - Response Modification            │\n45: │  - Header Management                │\n46: └────────┬────────────────────────────┘\n47:          │\n48:          ▼\n49: ┌─────────────────┐\n50: │  Sandbox Pod    │\n51: └─────────────────┘\n52: ```\n53: \n54: ### Layered Architecture\n55: \n56: 1. **HTTP Layer**: Gin-based HTTP server with middleware\n57: 2. **Routing Layer**: Request routing and session management\n58: 3. **Proxy Layer**: HTTP reverse proxy with transport configuration\n59: 4. **Integration Layer**: Store, JWT, and workload manager clients\n60: \n61: ### Key Components\n62: \n63: #### Server (`server.go`)\n64: \n65: ```go\n66: type Server struct {\n67:     config         *Config\n68:     engine         *gin.Engine\n69:     httpServer     *http.Server\n70:     sessionManager SessionManager\n71:     storeClient    store.Store\n72:     httpTransport  *http.Transport\n73:     jwtManager     *JWTManager\n74: }\n75: ```\n76: \n77: **Responsibilities:**\n78: - HTTP server lifecycle management\n79: - Route registration and middleware setup\n80: - Graceful shutdown handling\n81: - Health check endpoints\n82: \n83: #### Session Manager (`session_manager.go`)\n84: \n85: ```go\n86: type SessionManager interface {\n87:     GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)\n88: }\n89: \n90: type manager struct {\n91:     storeClient     store.Store\n92:     workloadMgrAddr string\n93:     httpClient      *http.Client\n94: }\n95: ```\n96: \n97: **Responsibilities:**\n98: - Session-based sandbox lookup\n99: - Cache integration for performance\n100: - Workload manager communication\n101: - Session validation\n102: \n103: #### JWT Manager (`jwt.go`)\n104: \n105: ```go\n106: type JWTManager struct {\n107:     privateKey *rsa.PrivateKey\n108:     publicKey  *rsa.PublicKey\n109:     clientset  kubernetes.Interface\n110: }\n111: ```\n112: \n113: **Responsibilities:**\n114: - JWT token generation for sandbox authentication\n115: - RSA key pair generation and persistence\n116: - Kubernetes secret management for key storage\n117: - Token-based authentication for sandbox requests\n118: \n119: ## Data Structures\n120: \n121: ### Configuration\n122: \n123: ```go\n124: type Config struct {\n125:     Port                  string\n126:     Debug                 bool\n127:     EnableTLS             bool\n128:     TLSCert               string\n129:     TLSKey                string\n130:     MaxConcurrentRequests int\n131: }\n132: ```\n133: \n134: **Default Values:**\n135: - Port: \"8080\"\n136: - Debug: false\n137: - EnableTLS: false\n138: - TLSCert: \"\"\n139: - TLSKey: \"\"\n140: - MaxConcurrentRequests: 1000\n141: \n142: ### Session Data\n143: \n144: ```go\n145: type SandboxInfo struct {\n146:     Kind             string              // \"AgentRuntime\" or \"CodeInterpreter\"\n147:     SandboxID        string              // Unique sandbox identifier\n148:     SandboxName      string              // Pod name\n149:     SandboxNamespace string              // Pod namespace\n150:     Name             string              // Resource name\n151:     EntryPoints      []SandboxEntryPoint // Available service endpoints\n152:     SessionID        string              // Session identifier\n153:     CreatedAt        time.Time           // Session creation time\n154:     ExpiresAt        time.Time           // Session expiration time\n155:     Status           string              // Sandbox status\n156:     PodIP            string              // Pod IP address\n157:     WorkloadName     string              // Workload name\n158:     Namespace        string              // Resource namespace\n159:     LastActivityAt   time.Time           // Last activity timestamp\n160: }\n161: ```\n162: \n163: ### Entry Point\n164: \n165: ```go\n166: type SandboxEntryPoint struct {\n167:     Path     string // URL path prefix\n168:     Protocol string // \"http\" or \"https\"\n169:     Endpoint string // Target URL endpoint\n170: }\n171: ```\n172: \n173: ### JWT Claims\n174: \n175: ```go\n176: type JWTClaims struct {\n177:     SessionID string `json:\"session_id\"`\n178:     jwt.RegisteredClaims\n179: }\n180: ```\n181: \n182: ## API Contracts\n183: \n184: ### HTTP Endpoints\n185: \n186: #### Health Checks\n187: \n188: **GET `/health/live`**\n189: - Purpose: Liveness probe for Kubernetes\n190: - Response: `{\"status\":\"alive\"}`\n191: - No authentication required\n192: \n193: **GET `/health/ready`**\n194: - Purpose: Readiness probe for Kubernetes\n195: - Response: `{\"status\":\"ready\"}` or `{\"status\":\"not ready\",\"error\":\"...\"}`\n196: - Checks session manager availability\n197: \n198: #### Agent Runtime Invocation\n199: \n200: **GET/POST `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path`**\n201: \n202: **Middleware:**\n203: 1. `gin.Logger()` - Request logging\n204: 2. `gin.Recovery()` - Panic recovery\n205: 3. `concurrencyLimitMiddleware` - Concurrency control\n206: \n207: **Path Parameters:**\n208: - `namespace`: Kubernetes namespace\n209: - `name`: AgentRuntime resource name\n210: - `path`: Request path to forward to sandbox\n211: \n212: **Flow:**\n213: 1. Extract or generate session ID from request\n214: 2. Validate session and retrieve sandbox info\n215: 3. Generate JWT token for authentication\n216: 4. Reverse proxy request to sandbox endpoint\n217: 5. Add `x-agentcube-session-id` header to response\n218: \n219: **Success Response:** Proxied sandbox response\n220: \n221: **Error Responses:**\n222: - 400: Invalid request parameters\n223: - 404: Sandbox not found\n224: - 429: Concurrency limit exceeded\n225: - 500: Internal server error\n226: \n227: #### Code Interpreter Invocation\n228: \n229: **GET/POST `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path`**\n230: \n231: Same flow and error handling as Agent Runtime invocation.\n232: \n233: ### Workload Manager API\n234: \n235: **Create Sandbox**\n236: - Method: POST\n237: - Endpoint: `{WORKLOAD_MANAGER_URL}/v1/agent-runtime` or `/v1/code-interpreter`\n238: - Request Body: `CreateSandboxRequest`\n239: - Response Body: `CreateSandboxResponse`\n240: \n241: **Get Session**\n242: - Method: GET\n243: - Endpoint: `{WORKLOAD_MANAGER_URL}/v1/session/{sessionID}`\n244: - Response Body: `GetSessionResponse`\n245: \n246: ### Store Interface\n247: \n248: The router uses the `store.Store` interface for caching session data:\n249: \n250: ```go\n251: type Store interface {\n252:     Get(ctx context.Context, key string) ([]byte, error)\n253:     Set(ctx context.Context, key string, value []byte, ttl time.Duration) error\n254:     Delete(ctx context.Context, key string) error\n255: }\n256: ```\n257: \n258: ## Error Handling\n259: \n260: ### Error Types\n261: \n262: 1. **Validation Errors** (400)\n263:    - Invalid resource kind\n264:    - Missing required parameters\n265:    - Invalid session ID format\n266: \n267: 2. **Not Found Errors** (404)\n268:    - AgentRuntime or CodeInterpreter resource not found\n269:    - Session not found\n270:    - Sandbox pod not available\n271: \n272: 3. **Concurrency Limit Errors** (429)\n273:    - Maximum concurrent requests exceeded\n274:    - Server under heavy load\n275: \n276: 4. **Internal Server Errors** (500)\n277:    - Workload manager communication failures\n278:    - Store access failures\n279:    - Proxy transport errors\n280:    - JWT generation failures\n281: \n282: ### Error Response Format\n283: \n284: ```go\n285: type ErrorResponse struct {\n286:     Error string `json:\"error\"`\n287:     Code  string `json:\"code,omitempty\"`\n288: }\n289: ```\n290: \n291: **Example:**\n292: ```json\n293: {\n294:   \"error\": \"sandbox not found\",\n295:   \"code\": \"SANDBOX_NOT_FOUND\"\n296: }\n297: ```\n298: \n299: ### Error Handling Strategy\n300: \n301: 1. **Graceful Degradation**\n302:    - Return cached sandbox info if workload manager is temporarily unavailable\n303:    - Continue serving requests during partial failures\n304: \n305: 2. **Circuit Breaker Pattern**\n306:    - Limit retries to workload manager\n307:    - Fail fast after consecutive failures\n308:    - Automatic recovery after timeout\n309: \n310: 3. **Context Cancellation**\n311:    - Propagate context timeouts to downstream calls\n312:    - Clean up resources on cancellation\n313:    - Respect client deadlines\n314: \n315: 4. **Logging**\n316:    - Log all errors with structured fields\n317:    - Include request correlation IDs\n318:    - Aggregate error metrics\n319: \n320: ## Testing Strategy\n321: \n322: ### Unit Tests\n323: \n324: #### Server Tests\n325: \n326: ```go\n327: func TestNewServer(t *testing.T)\n328: func TestServer_Start(t *testing.T)\n329: func TestServer_Shutdown(t *testing.T)\n330: ```\n331: \n332: **Coverage:**\n333: - Server initialization\n334: - Graceful shutdown\n335: - Configuration validation\n336: \n337: #### Session Manager Tests\n338: \n339: ```go\n340: func TestSessionManager_GetSandboxBySession(t *testing.T)\n341: func TestSessionManager_cacheHit(t *testing.T)\n342: func TestSessionManager_cacheMiss(t *testing.T)\n343: func TestSessionManager_workloadManagerCall(t *testing.T)\n344: ```\n345: \n346: **Coverage:**\n347: - Cache hit scenarios\n348: - Cache miss scenarios\n349: - Workload manager communication\n350: - Error handling\n351: \n352: #### JWT Manager Tests\n353: \n354: ```go\n355: func TestJWTManager_GenerateToken(t *testing.T)\n356: func TestJWTManager_TryStoreOrLoadJWTKeySecret(t *testing.T)\n357: func TestJWTManager_keyRotation(t *testing.T)\n358: ```\n359: \n360: **Coverage:**\n361: - Token generation and validation\n362: - RSA key generation\n363: - Secret persistence\n364: - Key rotation scenarios\n365: \n366: #### Handler Tests\n367: \n368: ```go\n369: func TestHandleHealthLive(t *testing.T)\n370: func TestHandleHealthReady(t *testing.T)\n371: func TestHandleAgentInvoke(t *testing.T)\n372: func TestHandleCodeInterpreterInvoke(t *testing.T)\n373: ```\n374: \n375: **Coverage:**\n376: - Request handling\n377: - Parameter extraction\n378: - Response formatting\n379: - Error cases\n380: \n381: #### Middleware Tests\n382: \n383: ```go\n384: func TestConcurrencyLimitMiddleware(t *testing.T)\n385: func TestConcurrencyLimitMiddleware_exceeded(t *testing.T)\n386: ```\n387: \n388: **Coverage:**\n389: - Concurrency control\n390: - Rate limiting\n391: - Headers and status codes\n392: \n393: #### Proxy Tests\n394: \n395: ```go\n396: func TestReverseProxy_Forwarding(t *testing.T)\n397: func TestReverseProxy_HeaderModification(t *testing.T)\n398: func TestReverseProxy_Transport(t *testing.T)\n399: ```\n400: \n401: **Coverage:**\n402: - Request forwarding\n403: - Header manipulation\n404: - Response modification\n405: - Transport configuration\n406: \n407: ### Integration Tests\n408: \n409: #### End-to-End Tests\n410: \n411: ```go\n412: func TestE2E_AgentRuntimeInvocation(t *testing.T)\n413: func TestE2E_CodeInterpreterInvocation(t *testing.T)\n414: func TestE2E_SessionLifecycle(t *testing.T)\n415: func TestE2E_ErrorScenarios(t *testing.T)\n416: ```\n417: \n418: **Setup:**\n419: - Mock workload manager server\n420: - In-memory store\n421: - Test AgentRuntime/CodeInterpreter resources\n422: \n423: **Coverage:**\n424: - Complete request flow\n425: - Session creation and reuse\n426: - Error propagation\n427: - Performance characteristics\n428: \n429: #### Store Integration Tests\n430: \n431: ```go\n432: func TestStoreIntegration_SessionCaching(t *testing.T)\n433: func TestStoreIntegration_TTLExpiration(t *testing.T)\n434: ```\n435: \n436: **Coverage:**\n437: - Store operations\n438: - TTL behavior\n439: - Concurrent access\n440: \n441: ### Performance Tests\n442: \n443: ```go\n444: func BenchmarkHandleAgentInvoke(b *testing.B)\n445: func BenchmarkHandleCodeInterpreterInvoke(b *testing.B)\n446: func BenchmarkConcurrencyLimitMiddleware(b *testing.B)\n447: func BenchmarkReverseProxy(b *testing.B)\n448: ```\n449: \n450: **Metrics:**\n451: - Request throughput\n452: - Latency percentiles\n453: - Memory usage\n454: - Goroutine count\n455: \n456: ### Load Tests\n457: \n458: ```go\n459: func TestLoad_ConcurrentRequests(t *testing.T)\n460: func TestLoad_LongRunningRequests(t *testing.T)\n461: func TestLoad_MixedWorkload(t *testing.T)\n462: ```\n463: \n464: **Scenarios:**\n465: - Concurrent request handling\n466: - Memory pressure\n467: - Connection pooling\n468: - Backlog management\n469: \n470: ### Security Tests\n471: \n472: ```go\n473: func TestSecurity_JWTValidation(t *testing.T)\n474: func TestSecurity_PathTraversal(t *testing.T)\n475: func TestSecurity_HeaderInjection(t *testing.T)\n476: func TestSecurity_TLSConfiguration(t *testing.T)\n477: ```\n478: \n479: **Coverage:**\n480: - Authentication bypass attempts\n481: - Input validation\n482: - Header manipulation\n483: - TLS certificate handling\n484: \n485: ## Security Considerations\n486: \n487: ### Authentication\n488: \n489: 1. **JWT-based Authentication**\n490:    - RSA 2048-bit keys\n491:    - RS256 signing algorithm\n492:    - 5-minute token expiration\n493:    - Key rotation support\n494: \n495: 2. **Secret Management**\n496:    - Kubernetes secrets for key storage\n497:    - In-cluster service account tokens\n498:    - Secure key generation\n499: \n500: ### Authorization\n501: \n502: 1. **Namespace Isolation**\n503:    - Requests scoped to specific namespace\n504:    - Cross-namespace access prevention\n505: \n506: 2. **Resource Access Control**\n507:    - Resource name validation\n508:    - Kind-based routing\n509: \n510: ### Transport Security\n511: \n512: 1. **TLS Support**\n513:    - Optional TLS termination\n514:    - Certificate validation\n515:    - Secure cipher suites\n516: \n517: 2. **HTTP/2 Support**\n518:    - HTTP/2 transport configuration\n519:    - Connection pooling\n520:    - Multiplexing\n521: \n522: ### Input Validation\n523: \n524: 1. **Path Sanitization**\n525:    - Path traversal prevention\n526:    - URL normalization\n527:    - Reserved path handling\n528: \n529: 2. **Parameter Validation**\n530:    - Namespace validation\n531:    - Resource name validation\n532:    - Session ID validation\n533: \n534: ### Rate Limiting\n535: \n536: 1. **Concurrency Control**\n537:    - Configurable concurrency limits\n538:    - 429 responses on limit exceeded\n539:    - Backpressure management\n540: \n541: ## Performance Optimizations\n542: \n543: ### Caching\n544: \n545: 1. **Session Caching**\n546:    - Store-based cache\n547:    - Configurable TTL\n548:    - Cache invalidation\n549: \n550: 2. **Connection Pooling**\n551:    - HTTP/2 transport\n552:    - Keep-alive connections\n553:    - Connection reuse\n554: \n555: ### Request Processing\n556: \n557: 1. **Streaming**\n558:    - Response streaming\n559:    - Chunked encoding\n560:    - No buffering\n561: \n562: 2. **Zero-Copy**\n563:    - Efficient proxy forwarding\n564:    - Minimal request modification\n565:    - Low overhead\n566: \n567: ### Resource Management\n568: \n569: 1. **Goroutine Pooling**\n570:    - Bounded concurrency\n571:    - Worker pool pattern\n572:    - Context cancellation\n573: \n574: 2. **Memory Management**\n575:    - Buffer pooling\n576:    - Memory reuse\n577:    - Garbage collection optimization\n578: \n579: ## Monitoring and Observability\n580: \n581: ### Metrics\n582: \n583: 1. **HTTP Metrics**\n584:    - Request count\n585:    - Response time\n586:    - Error rate\n587:    - Active connections\n588: \n589: 2. **Proxy Metrics**\n590:    - Proxy requests\n591:    - Backend latency\n592:    - Proxy errors\n593: \n594: 3. **Session Metrics**\n595:    - Active sessions\n596:    - Cache hits/misses\n597:    - Session creation rate\n598: \n599: ### Logging\n600: \n601: 1. **Structured Logging**\n602:    - Request correlation IDs\n603:    - Session IDs\n604:    - Error stack traces\n605:    - Performance data\n606: \n607: 2. **Log Levels**\n608:    - Debug: Detailed request/response\n609:    - Info: Key events and errors\n610:    - Error: Failure conditions\n611:    - Fatal: Critical failures\n612: \n613: ### Tracing\n614: \n615: 1. **Distributed Tracing**\n616:    - Request tracing\n617:    - Span propagation\n618:    - Performance profiling\n619: \n620: ### Health Checks\n621: \n622: 1. **Liveness Probe**\n623:    - HTTP endpoint `/health/live`\n624:    - Basic server health\n625: \n626: 2. **Readiness Probe**\n627:    - HTTP endpoint `/health/ready`\n628:    - Dependency health checks\n629: \n630: ## Deployment\n631: \n632: ### Configuration\n633: \n634: **Environment Variables:**\n635: - `WORKLOAD_MANAGER_URL`: Workload manager endpoint (required)\n636: - `AGENTCUBE_NAMESPACE`: Router namespace (default: `default`)\n637: \n638: **CLI Flags:**\n639: - `-port`: Server port (default: 8080)\n640: - `-enable-tls`: Enable TLS (default: false)\n641: - `-tls-cert`: TLS certificate path\n642: - `-tls-key`: TLS key path\n643: - `-debug`: Debug mode (default: false)\n644: - `-max-concurrent-requests`: Max concurrent requests (default: 1000)\n645: \n646: ### Kubernetes Deployment\n647: \n648: **Deployment Manifest:**\n649: ```yaml\n650: apiVersion: apps/v1\n651: kind: Deployment\n652: metadata:\n653:   name: agentcube-router\n654: spec:\n655:   replicas: 3\n656:   selector:\n657:     matchLabels:\n658:       app: agentcube-router\n659:   template:\n660:     metadata:\n661:       labels:\n662:         app: agentcube-router\n663:     spec:\n664:       containers:\n665:       - name: router\n666:         image: volcano-sh/agentcube-router:latest\n667:         ports:\n668:         - containerPort: 8080\n669:         env:\n670:         - name: WORKLOAD_MANAGER_URL\n671:           value: \"http://agentcube-workload-manager:8081\"\n672:         - name: AGENTCUBE_NAMESPACE\n673:           value: \"default\"\n674:         livenessProbe:\n675:           httpGet:\n676:             path: /health/live\n677:             port: 8080\n678:         readinessProbe:\n679:           httpGet:\n680:             path: /health/ready\n681:             port: 8080\n682: ```\n683: \n684: **Service Manifest:**\n685: ```yaml\n686: apiVersion: v1\n687: kind: Service\n688: metadata:\n689:   name: agentcube-router\n690: spec:\n691:   selector:\n692:     app: agentcube-router\n693:   ports:\n694:   - port: 80\n695:     targetPort: 8080\n696:   type: LoadBalancer\n697: ```\n698: \n699: ### Scalability\n700: \n701: 1. **Horizontal Scaling**\n702:    - Stateless design\n703:    - Shared session store\n704:    - Load balancer distribution\n705: \n706: 2. **Vertical Scaling**\n707:    - Configurable concurrency limits\n708:    - Resource requests/limits\n709:    - Performance tuning\n710: \n711: ## Future Enhancements\n712: \n713: 1. **WebSocket Support**\n714:    - Real-time communication\n715:    - Connection upgrades\n716:    - Session management\n717: \n718: 2. **Advanced Routing**\n719:    - Weight-based routing\n720:    - A/B testing\n721:    - Canary deployments\n722: \n723: 3. **Security Enhancements**\n724:    - Mutual TLS\n725:    - IP whitelisting\n726:    - Rate limiting per client\n727: \n728: 4. **Performance Improvements**\n729:    - HTTP/3 support\n730:    - QUIC protocol\n731:    - Compression\n732: \n733: 5. **Observability**\n734:    - Prometheus metrics\n735:    - Grafana dashboards\n736:    - Alerting rules\n737: \n738: ## Dependencies\n739: \n740: ### Runtime Dependencies\n741: \n742: - `github.com/gin-gonic/gin`: HTTP framework\n743: - `github.com/golang-jwt/jwt/v5`: JWT library\n744: - `golang.org/x/net/http2`: HTTP/2 support\n745: - `k8s.io/client-go`: Kubernetes client\n746: - `k8s.io/klog/v2`: Logging\n747: \n748: ### Internal Dependencies\n749: \n750: - `github.com/volcano-sh/agentcube/pkg/store`: Store interface\n751: - `github.com/volcano-sh/agentcube/pkg/common/types`: Common types\n752: - `github.com/volcano-sh/agentcube/pkg/api`: API types\n753: \n754: ## References\n755: \n756: - [Gin Framework Documentation](https://gin-gonic.com/docs/)\n757: - [Kubernetes API Conventions](https://github.com/kubernetes/community/blob/master/contributors/devel/sig-architecture/api-conventions.md)\n758: - [HTTP Reverse Proxy Design](https://github.com/golang/go/tree/master/src/net/http/httputil)\n759: - [JWT Best Practices](https://tools.ietf.org/html/rfc8725)\n\n(End of file - total 759 lines)\n</content>","metadata":{"preview":"# AR-009 Design - Router HTTP Reverse Proxy Core\n\n## Overview\n\nThe Router module provides HTTP reverse proxy capabilities for routing client requests to sandbox instances (AgentRuntime and CodeInterpreter). It acts as the entry point for all external traffic, managing session-based routing, authentication, and request forwarding.\n\n## Architecture\n\n### Component Diagram\n\n```\n┌─────────────────┐\n│  Client Request │\n└────────┬────────┘\n         │\n         ▼\n┌─────────────────────────────────────┐\n│  HTTP Server (Gin)                  │\n│  - Request Validation               │\n│  - Concurrency Limiting             │","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-009/design.md","time":{"start":1775850013786,"end":1775850013808}}}}
{"type":"tool_use","timestamp":1775850013812,"sessionID":"ses_287179656ffezx7f2tbbaM7DVN","part":{"id":"prt_d78e8c441001k8lDz0jnqvwBZn","messageID":"msg_d78e8a8ba001P1OsP7AcL0DXeP","sessionID":"ses_287179656ffezx7f2tbbaM7DVN","type":"tool","tool":"read","callID":"toolu_tool-a49db54aa98b47d79bebf09d25e7a4eb","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/errors.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"net/http\"\n6: )\n7: \n8: var (\n9: \tErrSandboxNotFound        = &SandboxNotFoundError{}\n10: \tErrSessionExpired         = &SessionExpiredError{}\n11: \tErrWorkloadManagerError   = &WorkloadManagerError{}\n12: \tErrValidationError        = &ValidationError{}\n13: \tErrJWTSigningFailed       = \"JWT_SIGNING_FAILED\"\n14: \tErrSandboxUnreachable     = \"SANDBOX_UNREACHABLE\"\n15: \tErrServerOverloaded       = \"SERVER_OVERLOADED\"\n16: \tErrSessionManagerNotReady = \"SESSION_MANAGER_NOT_READY\"\n17: )\n18: \n19: type SandboxNotFoundError struct {\n20: \tSessionID string\n21: \tName      string\n22: \tNamespace string\n23: \tKind      string\n24: }\n25: \n26: func (e *SandboxNotFoundError) Error() string {\n27: \tif e.SessionID != \"\" {\n28: \t\treturn fmt.Sprintf(\"sandbox not found for session: %s\", e.SessionID)\n29: \t}\n30: \treturn fmt.Sprintf(\"sandbox not found: %s/%s/%s\", e.Kind, e.Namespace, e.Name)\n31: }\n32: \n33: func (e *SandboxNotFoundError) HTTPStatusCode() int {\n34: \treturn http.StatusNotFound\n35: }\n36: \n37: func (e *SandboxNotFoundError) ErrorCode() string {\n38: \treturn \"SANDBOX_NOT_FOUND\"\n39: }\n40: \n41: type SessionExpiredError struct {\n42: \tSessionID string\n43: }\n44: \n45: func (e *SessionExpiredError) Error() string {\n46: \treturn fmt.Sprintf(\"session expired: %s\", e.SessionID)\n47: }\n48: \n49: func (e *SessionExpiredError) HTTPStatusCode() int {\n50: \treturn http.StatusNotFound\n51: }\n52: \n53: func (e *SessionExpiredError) ErrorCode() string {\n54: \treturn \"SESSION_EXPIRED\"\n55: }\n56: \n57: type WorkloadManagerError struct {\n58: \tMessage string\n59: \tCode    int\n60: }\n61: \n62: func (e *WorkloadManagerError) Error() string {\n63: \treturn fmt.Sprintf(\"workload manager error: %s (code: %d)\", e.Message, e.Code)\n64: }\n65: \n66: func (e *WorkloadManagerError) HTTPStatusCode() int {\n67: \treturn e.Code\n68: }\n69: \n70: func (e *WorkloadManagerError) ErrorCode() string {\n71: \treturn \"WORKLOAD_MANAGER_ERROR\"\n72: }\n73: \n74: type ValidationError struct {\n75: \tField   string\n76: \tMessage string\n77: }\n78: \n79: func (e *ValidationError) Error() string {\n80: \treturn fmt.Sprintf(\"validation error: %s - %s\", e.Field, e.Message)\n81: }\n82: \n83: func (e *ValidationError) HTTPStatusCode() int {\n84: \treturn http.StatusBadRequest\n85: }\n86: \n87: func (e *ValidationError) ErrorCode() string {\n88: \treturn \"VALIDATION_ERROR\"\n89: }\n90: \n91: type HTTPError interface {\n92: \tError() string\n93: \tHTTPStatusCode() int\n94: \tErrorCode() string\n95: }\n96: \n97: func GetHTTPStatusCode(err error) int {\n98: \tif httpErr, ok := err.(HTTPError); ok {\n99: \t\treturn httpErr.HTTPStatusCode()\n100: \t}\n101: \treturn http.StatusInternalServerError\n102: }\n103: \n104: func GetErrorCode(err error) string {\n105: \tif httpErr, ok := err.(HTTPError); ok {\n106: \t\treturn httpErr.ErrorCode()\n107: \t}\n108: \treturn \"\"\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n)\n\nvar (\n\tErrSandboxNotFound        = &SandboxNotFoundError{}\n\tErrSessionExpired         = &SessionExpiredError{}\n\tErrWorkloadManagerError   = &WorkloadManagerError{}\n\tErrValidationError        = &ValidationError{}\n\tErr