r)\n1662: \t}\n1663: \tsandbox.Object[\"spec\"] = spec\n1664: \n1665: \t// Create sandbox\n1666: \tif err := r.Create(ctx, sandbox); err != nil {\n1667: \t\tlog.Error(err, \"Failed to create sandbox\")\n1668: \t\tRecordSandboxOperation(\"create\", agentRuntime.Namespace, sandboxName,\n1669: \t\t\ttime.Since(startTime).Seconds(), err)\n1670: \t\treturn nil, err\n1671: \t}\n1672: \n1673: \tlog.Info(\"Sandbox created successfully\")\n1674: \tRecordSandboxOperation(\"create\", agentRuntime.Namespace, sandboxName,\n1675: \t\ttime.Since(startTime).Seconds(), nil)\n1676: \n1677: \treturn &SandboxResult{Created: true}, nil\n1678: }\n1679: \n1680: // updateSandbox updates an existing sandbox resource\n1681: func (r *AgentRuntimeReconciler) updateSandbox(ctx context.Context, agentRuntime *runtimev1alpha1.AgentRuntime, existing *unstructured.Unstructured, sandboxName string) (*SandboxResult, error) {\n1682: \tlog := log.FromContext(ctx)\n1683: \tlog.Info(\"Updating sandbox\", \"name\", sandboxName)\n1684: \n1685: \tstartTime := time.Now()\n1686: \n1687: \t// Build desired spec\n1688: \tdesiredSpec, err := r.buildSandboxSpec(agentRuntime)\n1689: \tif err != nil {\n1690: \t\treturn nil, fmt.Errorf(\"failed to build sandbox spec: %w\", err)\n1691: \t}\n1692: \n1693: \t// Check if update is needed\n1694: \texistingSpec, _, _ := unstructured.NestedMap(existing.Object, \"spec\")\n1695: \tif reflect.DeepEqual(desiredSpec, existingSpec) {\n1696: \t\tlog.Info(\"Sandbox spec unchanged, skipping update\")\n1697: \t\treturn &SandboxResult{Created: false}, nil\n1698: \t}\n1699: \n1700: \t// Update sandbox\n1701: \texisting.Object[\"spec\"] = desiredSpec\n1702: \tif err := r.Update(ctx, existing); err != nil {\n1703: \t\tlog.Error(err, \"Failed to update sandbox\")\n1704: \t\tRecordSandboxOperation(\"update\", agentRuntime.Namespace, sandboxName,\n1705: \t\t\ttime.Since(startTime).Seconds(), err)\n1706: \t\treturn nil, err\n1707: \t}\n1708: \n1709: \tlog.Info(\"Sandbox updated successfully\")\n1710: \tRecordSandboxOperation(\"update\", agentRuntime.Namespace, sandboxName,\n1711: \t\ttime.Since(startTime).Seconds(), nil)\n1712: \n1713: \treturn &SandboxResult{Created: false}, nil\n1714: }\n1715: \n1716: // buildSandboxSpec builds sandbox spec from AgentRuntime spec\n1717: func (r *AgentRuntimeReconciler) buildSandboxSpec(agentRuntime *runtimev1alpha1.AgentRuntime) (map[string]interface{}, error) {\n1718: \tspec := map[string]interface{}{\n1719: \t\t\"replicas\": int64(1),\n1720: \t}\n1721: \n1722: \t// Add pod template from spec\n1723: \tif agentRuntime.Spec.PodTemplate != nil {\n1724: \t\t// Convert pod template to map - placeholder\n1725: \t\tspec[\"podTemplate\"] = map[string]interface{}{}\n1726: \t}\n1727: \n1728: \treturn spec, nil\n1729: }\n1730: ```\n1731: \n1732: **Step 4: Run test to verify it passes**\n1733: \n1734: Run: `go test ./pkg/workloadmanager/controller/reconciler/ -run TestAgentRuntimeReconcileSandbox -v`\n1735: Expected: PASS\n1736: \n1737: **Step 5: Commit**\n1738: \n1739: ```bash\n1740: git add pkg/workloadmanager/controller/reconciler/agentruntime.go pkg/workloadmanager/controller/reconciler/agentruntime_test.go\n1741: git commit -m \"feat(ar-007): implement sandbox reconciliation for AgentRuntime\"\n1742: ```\n1743: \n1744: ### Task 16: Update AgentRuntime Reconcile method to call reconcileSandbox\n1745: \n1746: **Files:**\n1747: - Modify: `pkg/workloadmanager/controller/reconciler/agentruntime.go`\n1748: \n1749: **Step 1: Write the failing test**\n1750: \n1751: ```go\n1752: // pkg/workloadmanager/controller/reconciler/agentruntime_test.go\n1753: func TestAgentRuntimeReconcile_FullFlow(t *testing.T) {\n1754: \tg := NewGomegaWithT(t)\n1755: \n1756: \tctx := context.Background()\n1757: \tscheme := runtime.NewScheme()\n1758: \n1759: \tagentRuntime := &runtimev1alpha1.AgentRuntime{\n1760: \t\tObjectMeta: metav1.ObjectMeta{\n1761: \t\t\tName:      \"test-runtime\",\n1762: \t\t\tNamespace: \"default\",\n1763: \t\t},\n1764: \t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n1765: \t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n1766: \t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n1767: \t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{\n1768: \t\t\t\t\t\t{Name: \"agent\", Image: \"python:3.11-slim\"},\n1769: \t\t\t\t\t},\n1770: \t\t\t\t},\n1771: \t\t\t},\n1772: \t\t},\n1773: \t}\n1774: \n1775: \tfakeClient := fake.NewClientBuilder().WithScheme(scheme).WithObjects(agentRuntime).Build()\n1776: \n1777: \treconciler := &AgentRuntimeReconciler{\n1778: \t\tClient:       fakeClient,\n1779: \t\tScheme:       scheme,\n1780: \t\tRecorder:     &record.FakeRecorder{},\n1781: \t\tRequeueAfter: 10 * time.Second,\n1782: \t}\n1783: \n1784: \treq := ctrl.Request{\n1785: \t\tNamespacedName: types.NamespacedName{\n1786: \t\t\tNamespace: \"default\",\n1787: \t\t\tName:      \"test-runtime\",\n1788: \t\t},\n1789: \t}\n1790: \n\n(Output capped at 50 KB. Showing lines 1-1790. Use offset=1791 to continue.)\n</content>","metadata":{"preview":"# AR-007 Implementation Plan\n\n**Feature:** AR-007 — K8s Reconciler 控制器\n**Goal:** Implement Kubernetes-native reconciler controllers for AgentRuntime and CodeInterpreter CRDs using controller-runtime to provide automated lifecycle management for sandbox resources with proper event handling and status reporting.\n**Acceptance Criteria:**\n- AgentRuntimeReconciler successfully creates and manages sandbox resources\n- CodeInterpreterReconciler successfully creates and manages sandbox resources\n- Status conditions are accurately updated during reconciliation (Ready, Error, Progressing, etc.)\n- Finalizers are properly handled for resource deletion\n- Events are recorded for all significant operations\n- Metrics are exposed and can be scraped by Prometheus\n- Unit tests cover all major code paths\n- Integration tests validate end-to-end reconciliation\n- Error handling is robust and provides clear feedback\n- Reconciler can handle spec changes gracefully\n- Leader election works correctly in HA deployments\n**Architecture:** Controller-runtime based reconciler pattern with separate reconcilers for AgentRuntime and CodeInterpreter CRDs, coexisting with existing HTTP-based controller, using agent-sandbox API for sandbox lifecycle management.\n**Tech Stack:** Go, controller-runtime, client-go, agent-sandbox API, Prometheus metrics, Ginkgo/Gomega testing\n**前端验证:** No\n","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tasks.md","time":{"start":1775850135214,"end":1775850135238}}}}
