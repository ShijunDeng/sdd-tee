string = \"redis\"\n\tvalkeyStoreType string = \"valkey\"\n)\n\ntype Store interface {\n\tPing(ctx context.Context) error\n\tGetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store.go","time":{"start":1775857503622,"end":1775857503679}}}}
{"type":"tool_use","timestamp":1775857503682,"sessionID":"ses_286a51886ffeGR53YcPZsYH1NX","part":{"id":"prt_d795b08b3001xkHjyB4ZYlI067","messageID":"msg_d795afc640011di0VK9fjPlT8l","sessionID":"ses_286a51886ffeGR53YcPZsYH1NX","type":"tool","tool":"read","callID":"toolu_tool-a9be8ea4574842b8b87b359415c0a28e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net\"\n7: \t\"os\"\n8: \t\"strings\"\n9: \t\"time\"\n10: \n11: \t\"github.com/valkey-io/valkey-go\"\n12: \t\"k8s.io/klog/v2\"\n13: \n14: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n15: )\n16: \n17: type valkeyStore struct {\n18: \tcli                  valkey.Client\n19: \tsessionPrefix        string\n20: \texpiryIndexKey       string\n21: \tlastActivityIndexKey string\n22: }\n23: \n24: func newValkeyStore(addr string, password string, db int) (Store, error) {\n25: \tdialer := net.Dialer{\n26: \t\tTimeout:   5 * time.Second,\n27: \t\tKeepAlive: 30 * time.Second,\n28: \t}\n29: \n30: \toptions := valkey.ClientOption{\n31: \t\tInitAddress:       strings.Split(addr, \",\"),\n32: \t\tPassword:          password,\n33: \t\tSelectDB:          db,\n34: \t\tDisableCache:      os.Getenv(\"VALKEY_DISABLE_CACHE\") == \"true\",\n35: \t\tForceSingleClient: os.Getenv(\"VALKEY_FORCE_SINGLE\") == \"true\",\n36: \t\tDialer:            dialer,\n37: \t}\n38: \n39: \tcli, err := valkey.NewClient(options)\n40: \tif err != nil {\n41: \t\treturn nil, fmt.Errorf(\"failed to create valkey client: %w\", err)\n42: \t}\n43: \n44: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n45: \tdefer cancel()\n46: \n47: \tresult, err := cli.Do(ctx, cli.B().Ping().Build()).ToString()\n48: \tif err != nil {\n49: \t\treturn nil, fmt.Errorf(\"failed to ping valkey: %w\", err)\n50: \t}\n51: \tif result != \"PONG\" {\n52: \t\treturn nil, fmt.Errorf(\"unexpected ping response: %s\", result)\n53: \t}\n54: \n55: \treturn &valkeyStore{\n56: \t\tcli:                  cli,\n57: \t\tsessionPrefix:        \"session:\",\n58: \t\texpiryIndexKey:       \"session:expiry\",\n59: \t\tlastActivityIndexKey: \"session:last_activity\",\n60: \t}, nil\n61: }\n62: \n63: func (s *valkeyStore) Ping(ctx context.Context) error {\n64: \tresult, err := s.cli.Do(ctx, s.cli.B().Ping().Build()).ToString()\n65: \tif err != nil {\n66: \t\treturn err\n67: \t}\n68: \tif result != \"PONG\" {\n69: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n70: \t}\n71: \treturn nil\n72: }\n73: \n74: func (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n75: \tkey := s.sessionPrefix + sessionID\n76: \tdata := s.cli.Do(ctx, s.cli.B().Get().Key(key).Build())\n77: \n78: \tif valkey.IsValkeyNil(data.Error()) {\n79: \t\treturn nil, ErrNotFound\n80: \t}\n81: \n82: \tif data.Error() != nil {\n83: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", data.Error())\n84: \t}\n85: \n86: \tbytes, err := data.AsBytes()\n87: \tif err != nil {\n88: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n89: \t}\n90: \n91: \tinfo := &types.SandboxInfo{}\n92: \tif err := unmarshalSandboxInfo(string(bytes), info); err != nil {\n93: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n94: \t}\n95: \n96: \treturn info, nil\n97: }\n98: \n99: func (s *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n100: \tif sandboxStore == nil {\n101: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n102: \t}\n103: \tif sandboxStore.SessionID == \"\" {\n104: \t\treturn fmt.Errorf(\"session ID cannot be empty\")\n105: \t}\n106: \tif sandboxStore.ExpiresAt.IsZero() {\n107: \t\treturn fmt.Errorf(\"expires at cannot be zero\")\n108: \t}\n109: \n110: \tkey := s.sessionPrefix + sandboxStore.SessionID\n111: \tdata, err := marshalSandboxInfo(sandboxStore)\n112: \tif err != nil {\n113: \t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n114: \t}\n115: \n116: \tcommands := []valkey.Completed{\n117: \t\ts.cli.B().Set().Key(key).Value(data).Nx().Build(),\n118: \t\ts.cli.B().Zadd().Key(s.expiryIndexKey).ScoreMember().ScoreMember(float64(sandboxStore.ExpiresAt.Unix()), sandboxStore.SessionID).Build(),\n119: \t\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().ScoreMember(float64(time.Now().Unix()), sandboxStore.SessionID).Build(),\n120: \t}\n121: \n122: \tfor _, cmd := range commands {\n123: \t\tif err := s.cli.Do(ctx, cmd).Error(); err != nil {\n124: \t\t\treturn fmt.Errorf(\"failed to store sandbox: %w\", err)\n125: \t\t}\n126: \t}\n127: \n128: \treturn nil\n129: }\n130: \n131: func (s *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n132: \tif sandboxStore == nil {\n133: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n134: \t}\n135: \tif sandboxStore.SessionID == \"\" {\n136: \t\treturn fmt.Errorf(\"session ID cannot be empty\")\n137: \t}\n138: \n139: \tkey := s.sessionPrefix + sandboxStore.SessionID\n140: \tdata, err := marshalSandboxInfo(sandboxStore)\n141: \tif err != nil {\n142: \t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n143: \t}\n144: \n145: \tresult, err := s.cli.Do(ctx, s.cli.B().Set().Key(key).Value(data).Xx().Build()).ToString()\n146: \tif err != nil {\n147: \t\treturn fmt.Errorf(\"failed to update sandbox: %w\", err)\n148: \t}\n149: \tif result != \"OK\" {\n150: \t\treturn ErrNotFound\n151: \t}\n152: \n153: \treturn nil\n154: }\n155: \n156: func (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n157: \tkey := s.sessionPrefix + sessionID\n158: \n159: \tcommands := []valkey.Completed{\n160: \t\ts.cli.B().Del().Key(key).Build(),\n161: \t\ts.cli.B().Zrem().Key(s.expiryIndexKey).Member(sessionID).Build(),\n162: \t\ts.cli.B().Zrem().Key(s.lastActivityIndexKey).Member(sessionID).Build(),\n163: \t}\n164: \n165: \tfor _, cmd := range commands {\n166: \t\tif err := s.cli.Do(ctx, cmd).Error(); err != nil {\n167: \t\t\treturn fmt.Errorf(\"failed to delete sandbox: %w\", err)\n168: \t\t}\n169: \t}\n170: \n171: \treturn nil\n172: }\n173: \n174: func (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n175: \tmessages, err := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.expiryIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()).ToArray()\n176: \tif err != nil {\n177: \t\treturn nil, fmt.Errorf(\"failed to list expired sandboxes: %w\", err)\n178: \t}\n179: \n180: \tsessionIDs := make([]string, len(messages))\n181: \tfor i, msg := range messages {\n182: \t\tsessionIDs[i], err = msg.ToString()\n183: \t\tif err != nil {\n184: \t\t\treturn nil, fmt.Errorf(\"failed to convert session ID: %w\", err)\n185: \t\t}\n186: \t}\n187: \n188: \treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n189: }\n190: \n191: func (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n192: \tmessages, err := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.lastActivityIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()).ToArray()\n193: \tif err != nil {\n194: \t\treturn nil, fmt.Errorf(\"failed to list inactive sandboxes: %w\", err)\n195: \t}\n196: \n197: \tsessionIDs := make([]string, len(messages))\n198: \tfor i, msg := range messages {\n199: \t\tsessionIDs[i], err = msg.ToString()\n200: \t\tif err != nil {\n201: \t\t\treturn nil, fmt.Errorf(\"failed to convert session ID: %w\", err)\n202: \t\t}\n203: \t}\n204: \n205: \treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n206: }\n207: \n208: func (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n209: \tkey := s.sessionPrefix + sessionID\n210: \n211: \texists, err := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build()).ToInt64()\n212: \tif err != nil {\n213: \t\treturn fmt.Errorf(\"failed to check session existence: %w\", err)\n214: \t}\n215: \tif exists != 1 {\n216: \t\treturn ErrNotFound\n217: \t}\n218: \n219: \tif err := s.cli.Do(ctx, s.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().ScoreMember(float64(at.Unix()), sessionID).Build()).Error(); err != nil {\n220: \t\treturn fmt.Errorf(\"failed to update last activity: %w\", err)\n221: \t}\n222: \n223: \treturn nil\n224: }\n225: \n226: func (s *valkeyStore) Close() error {\n227: \ts.cli.Close()\n228: \treturn nil\n229: }\n230: \n231: func (s *valkeyStore) getSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n232: \t// MGET requires all keys to be in the same slot for cluster deployments.\n233: \t// For single-node deployments or when using hash tags, this is not a concern.\n234: \tif len(sessionIDs) == 0 {\n235: \t\treturn []*types.SandboxInfo{}, nil\n236: \t}\n237: \n238: \tkeys := make([]string, len(sessionIDs))\n239: \tfor i, sessionID := range sessionIDs {\n240: \t\tkeys[i] = s.sessionPrefix + sessionID\n241: \t}\n242: \n243: \tvalues, err := s.cli.Do(ctx, s.cli.B().Mget().Key(keys...).Build()).ToArray()\n244: \tif err != nil {\n245: \t\treturn nil, fmt.Errorf(\"failed to get sandbox data: %w\", err)\n246: \t}\n247: \n248: \tresult := make([]*types.SandboxInfo, 0, len(sessionIDs))\n249: \tfor _, value := range values {\n250: \t\tif valkey.IsValkeyNil(value.Error()) {\n251: \t\t\tcontinue\n252: \t\t}\n253: \n254: \t\tif value.Error() != nil {\n255: \t\t\tklog.Warningf(\"Failed to get value: %v\", value.Error())\n256: \t\t\tcontinue\n257: \t\t}\n258: \n259: \t\tbytes, err := value.AsBytes()\n260: \t\tif err != nil {\n261: \t\t\tklog.Warningf(\"Failed to convert value to bytes: %v\", err)\n262: \t\t\tcontinue\n263: \t\t}\n264: \n265: \t\tinfo := &types.SandboxInfo{}\n266: \t\tif err := unmarshalSandboxInfo(string(bytes), info); err != nil {\n267: \t\t\tklog.Warningf(\"Failed to unmarshal sandbox info: %v\", err)\n268: \t\t\tcontinue\n269: \t\t}\n270: \n271: \t\tresult = append(result, info)\n272: \t}\n273: \n274: \treturn result, nil\n275: }\n\n(End of file - total 275 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey.go","time":{"start":1775857503625,"end":1775857503681}}}}
{"type":"tool_use","timestamp":1775857503685,"sessionID":"ses_286a51886ffeGR53YcPZsYH1NX","part":{"id":"prt_d795b0ac4001kc8A7PpdmKWlls","messageID":"msg_d795afc640011di0VK9fjPlT8l","sessionID":"ses_286a51886ffeGR53YcPZsYH1NX","type":"tool","tool":"read","callID":"toolu_tool-b83121d096724852a3bd865d290ac2a2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey_test.go</path>\n<type>file</type>\n<content>\n1: package store\n2: \n3: import (\n4: \t\"context\"\n5: \t\"os\"\n6: \t\"testing\"\n7: \t\"time\"\n8: \n9: \t\"github.com/stretchr/testify/assert\"\n10: \t\"github.com/stretchr/testify/require\"\n11: \n12: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n13: )\n14: \n15: func TestValkeyStore(t *testing.T) {\n16: \tvalkeyAddr := os.Getenv(\"VALKEY_TEST_ADDR\")\n17: \tif valkeyAddr == \"\" {\n18: \t\tt.Skip(\"Skipping Valkey tests: VALKEY_TEST_ADDR not set\")\n19: \t}\n20: \n21: \tvalkeyPassword := os.Getenv(\"VALKEY_TEST_PASSWORD\")\n22: \n23: \tstore, err := newValkeyStore(valkeyAddr, valkeyPassword, 0)\n24: \trequire.NoError(t, err)\n25: \trequire.NotNil(t, store)\n26: \n27: \tdefer store.Close()\n28: \n29: \tctx := context.Background()\n30: \n31: \tt.Run(\"Ping\", func(t *testing.T) {\n32: \t\terr := store.Ping(ctx)\n33: \t\tassert.NoError(t, err)\n34: \t})\n35: \n36: \tt.Run(\"Store and Get Sandbox\", func(t *testing.T) {\n37: \t\tsessionID := \"valkey-test-session-1\"\n38: \t\tinfo := &types.SandboxInfo{\n39: \t\t\tSessionID:    sessionID,\n40: \t\t\tSandboxName:  \"test-sandbox\",\n41: \t\t\tWorkloadName: \"test-workload\",\n42: \t\t\tNamespace:    \"default\",\n43: \t\t\tKind:         \"AgentRuntime\",\n44: \t\t\tStatus:       \"running\",\n45: \t\t\tCreatedAt:    time.Now(),\n46: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n47: \t\t\tPodIP:        \"10.0.0.1\",\n48: \t\t}\n49: \n50: \t\terr := store.StoreSandbox(ctx, info)\n51: \t\trequire.NoError(t, err)\n52: \n53: \t\tretrieved, err := store.GetSandboxBySessionID(ctx, sessionID)\n54: \t\trequire.NoError(t, err)\n55: \t\tassert.Equal(t, sessionID, retrieved.SessionID)\n56: \t\tassert.Equal(t, \"test-sandbox\", retrieved.SandboxName)\n57: \t\tassert.Equal(t, \"AgentRuntime\", retrieved.Kind)\n58: \t})\n59: \n60: \tt.Run(\"Store Sandbox Nil\", func(t *testing.T) {\n61: \t\terr := store.StoreSandbox(ctx, nil)\n62: \t\tassert.Error(t, err)\n63: \t\tassert.Contains(t, err.Error(), \"cannot be nil\")\n64: \t})\n65: \n66: \tt.Run(\"Store Sandbox Empty SessionID\", func(t *testing.T) {\n67: \t\tinfo := &types.SandboxInfo{\n68: \t\t\tSandboxName: \"test-sandbox\",\n69: \t\t\tCreatedAt:   time.Now(),\n70: \t\t\tExpiresAt:   time.Now().Add(8 * time.Hour),\n71: \t\t}\n72: \n73: \t\terr := store.StoreSandbox(ctx, info)\n74: \t\tassert.Error(t, err)\n75: \t\tassert.Contains(t, err.Error(), \"session ID cannot be empty\")\n76: \t})\n77: \n78: \tt.Run(\"Store Sandbox Zero ExpiresAt\", func(t *testing.T) {\n79: \t\tinfo := &types.SandboxInfo{\n80: \t\t\tSessionID:   \"test-session\",\n81: \t\t\tSandboxName: \"test-sandbox\",\n82: \t\t\tCreatedAt:   time.Now(),\n83: \t\t}\n84: \n85: \t\terr := store.StoreSandbox(ctx, info)\n86: \t\tassert.Error(t, err)\n87: \t\tassert.Contains(t, err.Error(), \"expires at cannot be zero\")\n88: \t})\n89: \n90: \tt.Run(\"Get Non-Existent Sandbox\", func(t *testing.T) {\n91: \t\t_, err := store.GetSandboxBySessionID(ctx, \"valkey-non-existent\")\n92: \t\tassert.Error(t, err)\n93: \t\tassert.Equal(t, ErrNotFound, err)\n94: \t})\n95: \n96: \tt.Run(\"Update Sandbox\", func(t *testing.T) {\n97: \t\tsessionID := \"valkey-test-session-2\"\n98: \t\tinfo := &types.SandboxInfo{\n99: \t\t\tSessionID:    sessionID,\n100: \t\t\tSandboxName:  \"test-sandbox-2\",\n101: \t\t\tWorkloadName: \"test-workload\",\n102: \t\t\tNamespace:    \"default\",\n103: \t\t\tKind:         \"CodeInterpreter\",\n104: \t\t\tStatus:       \"pending\",\n105: \t\t\tCreatedAt:    time.Now(),\n106: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n107: \t\t}\n108: \n109: \t\terr := store.StoreSandbox(ctx, info)\n110: \t\trequire.NoError(t, err)\n111: \n112: \t\tinfo.Status = \"running\"\n113: \t\tinfo.PodIP = \"10.0.0.2\"\n114: \n115: \t\terr = store.UpdateSandbox(ctx, info)\n116: \t\trequire.NoError(t, err)\n117: \n118: \t\tretrieved, err := store.GetSandboxBySessionID(ctx, sessionID)\n119: \t\trequire.NoError(t, err)\n120: \t\tassert.Equal(t, \"running\", retrieved.Status)\n121: \t\tassert.Equal(t, \"10.0.0.2\", retrieved.PodIP)\n122: \t})\n123: \n124: \tt.Run(\"Update Non-Existent Sandbox\", func(t *testing.T) {\n125: \t\tinfo := &types.SandboxInfo{\n126: \t\t\tSessionID:   \"valkey-non-existent\",\n127: \t\t\tSandboxName: \"test-sandbox\",\n128: \t\t\tCreatedAt:   time.Now(),\n129: \t\t\tExpiresAt:   time.Now().Add(8 * time.Hour),\n130: \t\t}\n131: \n132: \t\terr := store.UpdateSandbox(ctx, info)\n133: \t\tassert.Error(t, err)\n134: \t\tassert.Equal(t, ErrNotFound, err)\n135: \t})\n136: \n137: \tt.Run(\"Update Sandbox Nil\", func(t *testing.T) {\n138: \t\terr := store.UpdateSandbox(ctx, nil)\n139: \t\tassert.Error(t, err)\n140: \t\tassert.Contains(t, err.Error(), \"cannot be nil\")\n141: \t})\n142: \n143: \tt.Run(\"Update Sandbox Empty SessionID\", func(t *testing.T) {\n144: \t\tinfo := &types.SandboxInfo{\n145: \t\t\tSandboxName: \"test-sandbox\",\n146: \t\t\tCreatedAt:   time.Now(),\n147: \t\t\tExpiresAt:   time.Now().Add(8 * time.Hour),\n148: \t\t}\n149: \n150: \t\terr := store.UpdateSandbox(ctx, info)\n151: \t\tassert.Error(t, err)\n152: \t\tassert.Contains(t, err.Error(), \"session ID cannot be empty\")\n153: \t})\n154: \n155: \tt.Run(\"Delete Sandbox\", func(t *testing.T) {\n156: \t\tsessionID := \"valkey-test-session-3\"\n157: \t\tinfo := &types.SandboxInfo{\n158: \t\t\tSessionID:    sessionID,\n159: \t\t\tSandboxName:  \"test-sandbox-3\",\n160: \t\t\tWorkloadName: \"test-workload\",\n161: \t\t\tNamespace:    \"default\",\n162: \t\t\tKind:         \"AgentRuntime\",\n163: \t\t\tStatus:       \"running\",\n164: \t\t\tCreatedAt:    time.Now(),\n165: \t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n166: \t\t}\n167: \n168: \t\terr := store.StoreSandbox(ctx, info)\n169: \t\trequire.NoError(t, err)\n170: \n171: \t\terr = store.DeleteSandboxBySessionID(ctx, sessionID)\n172: \t\trequire.NoError(t, err)\n173: \n174: \t\t_, err = store.GetSandboxBySessionID(ctx, sessionID)\n175: \t\tassert.Error(t, err)\n176: \t\tassert.Equal(t, ErrNotFound, err)\n177: \t})\n178: \n179: \tt.Run(\"Update Session Last Activity\", func(t *testing.T) {\n180: \t\tsessionID := \"valkey-test-session-4\"\n181: \t\tinfo := &types.SandboxInfo{\n182: \t\t\tSessionID:    sessionID,\n183: \t\t\tSandboxName:  \"test-sandbox-4\",\n184: \t\t\tWorkloadName: \"test-workload\",\n185: \t\t\tNamespace:    \"default\",\n186: \t\t\tKind:         \"AgentRuntime\",\n187: \t\t\tStatus:       \"running\",\n188: \t\t\tCreatedAt:    time.Now().Add(-1 * time.Hour),\n189: \t\t\tExpiresAt:    time.Now().Add(7 * time.Hour),\n190: \t\t}\n191: \n192: \t\terr := store.StoreSandbox(ctx, info)\n193: \t\trequire.NoError(t, err)\n194: \n195: \t\tnewActivityTime := time.Now()\n196: \t\terr = store.UpdateSessionLastActivity(ctx, sessionID, newActivityTime)\n197: \t\trequire.NoError(t, err)\n198: \n199: \t\tretrieved, err := store.GetSandboxBySessionID(ctx, sessionID)\n200: \t\trequire.NoError(t, err)\n201: \t\tassert.WithinDuration(t, newActivityTime, retrieved.LastActivityAt, time.Second)\n202: \t})\n203: \n204: \tt.Run(\"Update Session Last Activity Non-Existent\", func(t *testing.T) {\n205: \t\terr := store.UpdateSessionLastActivity(ctx, \"valkey-non-existent\", time.Now())\n206: \t\tassert.Error(t, err)\n207: \t\tassert.Equal(t, ErrNotFound, err)\n208: \t})\n209: \n210: \tt.Run(\"List Expired Sandboxes\", func(t *testing.T) {\n211: \t\tsessionID1 := \"valkey-expired-session-1\"\n212: \t\tsessionID2 := \"valkey-expired-session-2\"\n213: \t\tsessionID3 := \"valkey-active-session\"\n214: \n215: \t\tnow := time.Now()\n216: \n217: \t\texpiredInfo1 := &types.SandboxInfo{\n218: \t\t\tSessionID:    sessionID1,\n219: \t\t\tSandboxName:  \"expired-1\",\n220: \t\t\tWorkloadName: \"test\",\n221: \t\t\tNamespace:    \"default\",\n222: \t\t\tKind:         \"AgentRuntime\",\n223: \t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n224: \t\t\tExpiresAt:    now.Add(-1 * time.Hour),\n225: \t\t}\n226: \n227: \t\texpiredInfo2 := &types.SandboxInfo{\n228: \t\t\tSessionID:    sessionID2,\n229: \t\t\tSandboxName:  \"expired-2\",\n230: \t\t\tWorkloadName: \"test\",\n231: \t\t\tNamespace:    \"default\",\n232: \t\t\tKind:         \"AgentRuntime\",\n233: \t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n234: \t\t\tExpiresAt:    now.Add(-30 * time.Minute),\n235: \t\t}\n236: \n237: \t\tactiveInfo := &types.SandboxInfo{\n238: \t\t\tSessionID:    sessionID3,\n239: \t\t\tSandboxName:  \"active\",\n240: \t\t\tWorkloadName: \"test\",\n241: \t\t\tNamespace:    \"default\",\n242: \t\t\tKind:         \"AgentRuntime\",\n243: \t\t\tCreatedAt:    now,\n244: \t\t\tExpiresAt:    now.Add(8 * time.Hour),\n245: \t\t}\n246: \n247: \t\trequire.NoError(t, store.StoreSandbox(ctx, expiredInfo1))\n248: \t\trequire.NoError(t, store.StoreSandbox(ctx, expiredInfo2))\n249: \t\trequire.NoError(t, store.StoreSandbox(ctx, activeInfo))\n250: \n251: \t\texpired, err := store.ListExpiredSandboxes(ctx, now, 10)\n252: \t\trequire.NoError(t, err)\n253: \t\tassert.Len(t, expired, 2)\n254: \n255: \t\tsessionIDs := make([]string, 0, len(expired))\n256: \t\tfor _, sb := range expired {\n257: \t\t\tsessionIDs = append(sessionIDs, sb.SessionID)\n258: \t\t}\n259: \t\tassert.Contains(t, sessionIDs, sessionID1)\n260: \t\tassert.Contains(t, sessionIDs, sessionID2)\n261: \t\tassert.NotContains(t, sessionIDs, sessionID3)\n262: \t})\n263: \n264: \tt.Run(\"List Inactive Sandboxes\", func(t *testing.T) {\n265: \t\tsessionID1 := \"valkey-inactive-session-1\"\n266: \t\tsessionID2 := \"valkey-inactive-session-2\"\n267: \t\tsessionID3 := \"valkey-recent-session\"\n268: \n269: \t\tnow := time.Now()\n270: \t\tinactiveThreshold := now.Add(-15 * time.Minute)\n271: \n272: \t\tinactiveInfo1 := &types.SandboxInfo{\n273: \t\t\tSessionID:      sessionID1,\n274: \t\t\tSandboxName:    \"inactive-1\",\n275: \t\t\tWorkloadName:   \"test\",\n276: \t\t\tNamespace:      \"default\",\n277: \t\t\tKind:           \"AgentRuntime\",\n278: \t\t\tCreatedAt:      now.Add(-1 * time.Hour),\n279: \t\t\tExpiresAt:      now.Add(7 * time.Hour),\n280: \t\t\tLastActivityAt: now.Add(-20 * time.Minute),\n281: \t\t}\n282: \n283: \t\tinactiveInfo2 := &types.SandboxInfo{\n284: \t\t\tSessionID:      sessionID2,\n285: \t\t\tSandboxName:    \"inactive-2\",\n286: \t\t\tWorkloadName:   \"test\",\n287: \t\t\tNamespace:      \"default\",\n288: \t\t\tKind:           \"AgentRuntime\",\n289: \t\t\tCreatedAt:      now.Add(-1 * time.Hour),\n290: \t\t\tExpiresAt:      now.Add(7 * time.Hour),\n291: \t\t\tLastActivityAt: now.Add(-30 * time.Minute),\n292: \t\t}\n293: \n294: \t\trecentInfo := &types.SandboxInfo{\n295: \t\t\tSessionID:      sessionID3,\n296: \t\t\tSandboxName:    \"recent\",\n297: \t\t\tWorkloadName:   \"test\",\n298: \t\t\tNamespace:      \"default\",\n299: \t\t\tKind:           \"AgentRuntime\",\n300: \t\t\tCreatedAt:      now,\n301: \t\t\tExpiresAt:      now.Add(8 * time.Hour),\n302: \t\t\tLastActivityAt: now,\n303: \t\t}\n304: \n305: \t\trequire.NoError(t, store.StoreSandbox(ctx, inactiveInfo1))\n306: \t\trequire.NoError(t, store.StoreSandbox(ctx, inactiveInfo2))\n307: \t\trequire.NoError(t, store.StoreSandbox(ctx, recentInfo))\n308: \n309: \t\tinactive, err := store.ListInactiveSandboxes(ctx, inactiveThreshold, 10)\n310: \t\trequire.NoError(t, err)\n311: \n312: \t\tinactiveSessionIDs := make([]string, 0)\n313: \t\tfor _, sb := range inactive {\n314: \t\t\tif sb.SessionID == sessionID1 || sb.SessionID == sessionID2 {\n315: \t\t\t\tinactiveSessionIDs = append(inactiveSessionIDs, sb.SessionID)\n316: \t\t\t}\n317: \t\t}\n318: \n319: \t\tassert.Contains(t, inactiveSessionIDs, sessionID1)\n320: \t\tassert.Contains(t, inactiveSessionIDs, sessionID2)\n321: \t})\n322: }\n\n(End of file - total 322 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestValkeyStore(t *testing.T) {\n\tvalkeyAddr := os.Getenv(\"VALKEY_TEST_ADDR\")\n\tif valkeyAddr == \"\" {\n\t\tt.Skip(\"Skipping Valkey tests: VALKEY_TEST_ADDR not set\")\n\t}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_valkey_test.go","time":{"start":1775857503627,"end":1775857503684}}}}
