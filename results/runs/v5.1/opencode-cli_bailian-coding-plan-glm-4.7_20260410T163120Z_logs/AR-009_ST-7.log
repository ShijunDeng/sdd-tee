{"type":"tool_use","timestamp":1775849657726,"sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","part":{"id":"prt_d78e3553d001Fn9cPBTJ9B422x","messageID":"msg_d78e347a5001FpIYWoO7xDuVst","sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","type":"tool","tool":"read","callID":"toolu_tool-33bd7633fff64618afcb57d16f550301","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/config_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/config_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"os\"\n5: \t\"testing\"\n6: )\n7: \n8: func TestDefaultConfig(t *testing.T) {\n9: \tcfg := DefaultConfig()\n10: \n11: \tif cfg.Port != defaultPort {\n12: \t\tt.Errorf(\"Expected default port %s, got %s\", defaultPort, cfg.Port)\n13: \t}\n14: \n15: \tif cfg.Debug != false {\n16: \t\tt.Errorf(\"Expected default debug false, got %v\", cfg.Debug)\n17: \t}\n18: \n19: \tif cfg.EnableTLS != false {\n20: \t\tt.Errorf(\"Expected default EnableTLS false, got %v\", cfg.EnableTLS)\n21: \t}\n22: \n23: \tif cfg.MaxConcurrentRequests != defaultMaxConcurrentRequests {\n24: \t\tt.Errorf(\"Expected default MaxConcurrentRequests %d, got %d\", defaultMaxConcurrentRequests, cfg.MaxConcurrentRequests)\n25: \t}\n26: \n27: \tif cfg.AgentcubeNamespace != defaultNamespace {\n28: \t\tt.Errorf(\"Expected default namespace %s, got %s\", defaultNamespace, cfg.AgentcubeNamespace)\n29: \t}\n30: }\n31: \n32: func TestLoadConfig(t *testing.T) {\n33: \tos.Setenv(\"ROUTER_PORT\", \"9090\")\n34: \tos.Setenv(\"ROUTER_DEBUG\", \"true\")\n35: \tos.Setenv(\"ROUTER_ENABLE_TLS\", \"true\")\n36: \tos.Setenv(\"ROUTER_TLS_CERT\", \"/path/to/cert.pem\")\n37: \tos.Setenv(\"ROUTER_TLS_KEY\", \"/path/to/key.pem\")\n38: \tos.Setenv(\"ROUTER_MAX_CONCURRENT_REQUESTS\", \"500\")\n39: \tos.Setenv(\"WORKLOAD_MANAGER_URL\", \"http://workload-manager:8080\")\n40: \tos.Setenv(\"AGENTCUBE_NAMESPACE\", \"test-namespace\")\n41: \tdefer func() {\n42: \t\tos.Unsetenv(\"ROUTER_PORT\")\n43: \t\tos.Unsetenv(\"ROUTER_DEBUG\")\n44: \t\tos.Unsetenv(\"ROUTER_ENABLE_TLS\")\n45: \t\tos.Unsetenv(\"ROUTER_TLS_CERT\")\n46: \t\tos.Unsetenv(\"ROUTER_TLS_KEY\")\n47: \t\tos.Unsetenv(\"ROUTER_MAX_CONCURRENT_REQUESTS\")\n48: \t\tos.Unsetenv(\"WORKLOAD_MANAGER_URL\")\n49: \t\tos.Unsetenv(\"AGENTCUBE_NAMESPACE\")\n50: \t}()\n51: \n52: \tcfg, err := LoadConfig()\n53: \tif err != nil {\n54: \t\tt.Fatalf(\"Failed to load config: %v\", err)\n55: \t}\n56: \n57: \tif cfg.Port != \"9090\" {\n58: \t\tt.Errorf(\"Expected port 9090, got %s\", cfg.Port)\n59: \t}\n60: \n61: \tif cfg.Debug != true {\n62: \t\tt.Errorf(\"Expected debug true, got %v\", cfg.Debug)\n63: \t}\n64: \n65: \tif cfg.EnableTLS != true {\n66: \t\tt.Errorf(\"Expected EnableTLS true, got %v\", cfg.EnableTLS)\n67: \t}\n68: \n69: \tif cfg.TLSCert != \"/path/to/cert.pem\" {\n70: \t\tt.Errorf(\"Expected TLSCert /path/to/cert.pem, got %s\", cfg.TLSCert)\n71: \t}\n72: \n73: \tif cfg.TLSKey != \"/path/to/key.pem\" {\n74: \t\tt.Errorf(\"Expected TLSKey /path/to/key.pem, got %s\", cfg.TLSKey)\n75: \t}\n76: \n77: \tif cfg.MaxConcurrentRequests != 500 {\n78: \t\tt.Errorf(\"Expected MaxConcurrentRequests 500, got %d\", cfg.MaxConcurrentRequests)\n79: \t}\n80: \n81: \tif cfg.WorkloadManagerURL != \"http://workload-manager:8080\" {\n82: \t\tt.Errorf(\"Expected WorkloadManagerURL http://workload-manager:8080, got %s\", cfg.WorkloadManagerURL)\n83: \t}\n84: \n85: \tif cfg.AgentcubeNamespace != \"test-namespace\" {\n86: \t\tt.Errorf(\"Expected namespace test-namespace, got %s\", cfg.AgentcubeNamespace)\n87: \t}\n88: }\n89: \n90: func TestConfigValidation(t *testing.T) {\n91: \ttests := []struct {\n92: \t\tname    string\n93: \t\tcfg     *Config\n94: \t\twantErr bool\n95: \t}{\n96: \t\t{\n97: \t\t\tname: \"valid config\",\n98: \t\t\tcfg: &Config{\n99: \t\t\t\tPort:                  \"8080\",\n100: \t\t\t\tMaxConcurrentRequests: 1000,\n101: \t\t\t\tWorkloadManagerURL:    \"http://workload-manager:8080\",\n102: \t\t\t},\n103: \t\t\twantErr: false,\n104: \t\t},\n105: \t\t{\n106: \t\t\tname: \"missing port\",\n107: \t\t\tcfg: &Config{\n108: \t\t\t\tPort:                  \"\",\n109: \t\t\t\tMaxConcurrentRequests: 1000,\n110: \t\t\t\tWorkloadManagerURL:    \"http://workload-manager:8080\",\n111: \t\t\t},\n112: \t\t\twantErr: true,\n113: \t\t},\n114: \t\t{\n115: \t\t\tname: \"invalid port number\",\n116: \t\t\tcfg: &Config{\n117: \t\t\t\tPort:                  \"-1\",\n118: \t\t\t\tMaxConcurrentRequests: 1000,\n119: \t\t\t\tWorkloadManagerURL:    \"http://workload-manager:8080\",\n120: \t\t\t},\n121: \t\t\twantErr: true,\n122: \t\t},\n123: \t\t{\n124: \t\t\tname: \"port out of range\",\n125: \t\t\tcfg: &Config{\n126: \t\t\t\tPort:                  \"99999\",\n127: \t\t\t\tMaxConcurrentRequests: 1000,\n128: \t\t\t\tWorkloadManagerURL:    \"http://workload-manager:8080\",\n129: \t\t\t},\n130: \t\t\twantErr: true,\n131: \t\t},\n132: \t\t{\n133: \t\t\tname: \"TLS enabled but missing cert\",\n134: \t\t\tcfg: &Config{\n135: \t\t\t\tPort:                  \"8080\",\n136: \t\t\t\tEnableTLS:             true,\n137: \t\t\t\tTLSCert:               \"\",\n138: \t\t\t\tMaxConcurrentRequests: 1000,\n139: \t\t\t\tWorkloadManagerURL:    \"http://workload-manager:8080\",\n140: \t\t\t},\n141: \t\t\twantErr: true,\n142: \t\t},\n143: \t\t{\n144: \t\t\tname: \"TLS enabled but missing key\",\n145: \t\t\tcfg: &Config{\n146: \t\t\t\tPort:                  \"8080\",\n147: \t\t\t\tEnableTLS:             true,\n148: \t\t\t\tTLSCert:               \"/cert.pem\",\n149: \t\t\t\tTLSKey:                \"\",\n150: \t\t\t\tMaxConcurrentRequests: 1000,\n151: \t\t\t\tWorkloadManagerURL:    \"http://workload-manager:8080\",\n152: \t\t\t},\n153: \t\t\twantErr: true,\n154: \t\t},\n155: \t\t{\n156: \t\t\tname: \"missing workload manager URL\",\n157: \t\t\tcfg: &Config{\n158: \t\t\t\tPort:                  \"8080\",\n159: \t\t\t\tMaxConcurrentRequests: 1000,\n160: \t\t\t\tWorkloadManagerURL:    \"\",\n161: \t\t\t},\n162: \t\t\twantErr: true,\n163: \t\t},\n164: \t\t{\n165: \t\t\tname: \"zero max concurrent requests gets default\",\n166: \t\t\tcfg: &Config{\n167: \t\t\t\tPort:                  \"8080\",\n168: \t\t\t\tMaxConcurrentRequests: 0,\n169: \t\t\t\tWorkloadManagerURL:    \"http://workload-manager:8080\",\n170: \t\t\t},\n171: \t\t\twantErr: false,\n172: \t\t},\n173: \t}\n174: \n175: \tfor _, tt := range tests {\n176: \t\tt.Run(tt.name, func(t *testing.T) {\n177: \t\t\terr := tt.cfg.Validate()\n178: \t\t\tif (err != nil) != tt.wantErr {\n179: \t\t\t\tt.Errorf(\"Validate() error = %v, wantErr %v\", err, tt.wantErr)\n180: \t\t\t}\n181: \t\t\tif !tt.wantErr && tt.cfg.MaxConcurrentRequests == 0 {\n182: \t\t\t\tif tt.cfg.MaxConcurrentRequests != defaultMaxConcurrentRequests {\n183: \t\t\t\t\tt.Errorf(\"Expected MaxConcurrentRequests to be set to default %d, got %d\", defaultMaxConcurrentRequests, tt.cfg.MaxConcurrentRequests)\n184: \t\t\t\t}\n185: \t\t\t}\n186: \t\t})\n187: \t}\n188: }\n\n(End of file - total 188 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"os\"\n\t\"testing\"\n)\n\nfunc TestDefaultConfig(t *testing.T) {\n\tcfg := DefaultConfig()\n\n\tif cfg.Port != defaultPort {\n\t\tt.Errorf(\"Expected default port %s, got %s\", defaultPort, cfg.Port)\n\t}\n\n\tif cfg.Debug != false {\n\t\tt.Errorf(\"Expected default debug false, got %v\", cfg.Debug)\n\t}\n\n\tif cfg.EnableTLS != false {\n\t\tt.Errorf(\"Expected default EnableTLS false, got %v\", cfg.EnableTLS)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/config_test.go","time":{"start":1775849657697,"end":1775849657723}}}}
