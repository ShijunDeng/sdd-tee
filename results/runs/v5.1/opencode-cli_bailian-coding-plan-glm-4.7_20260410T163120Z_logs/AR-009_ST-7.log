{"type":"tool_use","timestamp":1775849633727,"sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","part":{"id":"prt_d78e2f1f5001v9s2n4MSAjDK7k","messageID":"msg_d78e2dcb3001hYKxUi3eRHkkf7","sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","type":"tool","tool":"read","callID":"toolu_tool-16bad33830f54088b29a087b82e7e9f8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net\"\n7: \t\"net/http\"\n8: \t\"sync\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"k8s.io/client-go/kubernetes\"\n13: \t\"k8s.io/klog/v2\"\n14: \n15: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n16: )\n17: \n18: type Server struct {\n19: \tconfig         *Config\n20: \tengine         *gin.Engine\n21: \thttpServer     *http.Server\n22: \tsessionManager SessionManager\n23: \tstoreClient    store.Store\n24: \thttpTransport  *http.Transport\n25: \tjwtManager     *JWTManager\n26: \thandler        *Handler\n27: \tlimiter        *ConcurrencyLimiter\n28: \tmetrics        *Metrics\n29: \tmu             sync.RWMutex\n30: }\n31: \n32: func NewServer(cfg *Config, storeClient store.Store, clientset kubernetes.Interface) (*Server, error) {\n33: \tif err := cfg.Validate(); err != nil {\n34: \t\treturn nil, fmt.Errorf(\"invalid configuration: %w\", err)\n35: \t}\n36: \n37: \tif cfg.Debug {\n38: \t\tgin.SetMode(gin.DebugMode)\n39: \t} else {\n40: \t\tgin.SetMode(gin.ReleaseMode)\n41: \t}\n42: \n43: \ts := &Server{\n44: \t\tconfig:        cfg,\n45: \t\tstoreClient:   storeClient,\n46: \t\thttpTransport: configureHTTPTransport(),\n47: \t\tlimiter:       NewConcurrencyLimiter(cfg.MaxConcurrentRequests),\n48: \t\tmetrics:       NewMetrics(),\n49: \t}\n50: \n51: \tif err := s.initializeSessionManager(); err != nil {\n52: \t\treturn nil, fmt.Errorf(\"failed to initialize session manager: %w\", err)\n53: \t}\n54: \n55: \tif err := s.initializeJWTManager(clientset); err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to initialize JWT manager: %w\", err)\n57: \t}\n58: \n59: \ts.handler = NewHandler(s.sessionManager, s.jwtManager, NewReverseProxy(s.jwtManager))\n60: \n61: \ts.engine = gin.New()\n62: \n63: \ts.applyMiddleware()\n64: \n65: \ts.setupRoutes()\n66: \n67: \ts.httpServer = &http.Server{\n68: \t\tAddr:         \":\" + s.config.Port,\n69: \t\tHandler:      s.engine,\n70: \t\tReadTimeout:  time.Duration(s.config.ReadTimeout) * time.Second,\n71: \t\tWriteTimeout: time.Duration(s.config.WriteTimeout) * time.Second,\n72: \t\tIdleTimeout:  time.Duration(s.config.IdleTimeout) * time.Second,\n73: \t}\n74: \n75: \treturn s, nil\n76: }\n77: \n78: func (s *Server) initializeSessionManager() error {\n79: \tsessionManager, err := NewSessionManager(s.storeClient, s.config.WorkloadManagerURL)\n80: \tif err != nil {\n81: \t\treturn err\n82: \t}\n83: \n84: \ts.sessionManager = sessionManager\n85: \treturn nil\n86: }\n87: \n88: func (s *Server) initializeJWTManager(clientset kubernetes.Interface) error {\n89: \tif clientset == nil {\n90: \t\tklog.Warning(\"Kubernetes clientset not provided, JWT manager will not be fully functional\")\n91: \t\ts.jwtManager = &JWTManager{}\n92: \t\treturn nil\n93: \t}\n94: \n95: \tjwtManager, err := NewJWTManager(clientset, s.config.AgentcubeNamespace)\n96: \tif err != nil {\n97: \t\treturn err\n98: \t}\n99: \n100: \ts.jwtManager = jwtManager\n101: \treturn nil\n102: }\n103: \n104: func (s *Server) applyMiddleware() {\n105: \ts.engine.Use(recoveryMiddleware())\n106: \ts.engine.Use(loggingMiddleware())\n107: \ts.engine.Use(correlationIDMiddleware())\n108: \ts.engine.Use(concurrencyLimitMiddleware(s.limiter))\n109: \ts.engine.Use(metricsMiddleware(s.metrics))\n110: }\n111: \n112: func (s *Server) setupRoutes() {\n113: \ts.engine.GET(\"/health/live\", s.handler.handleHealthLive)\n114: \ts.engine.GET(\"/health/ready\", s.handler.handleHealthReady)\n115: \n116: \tv1 := s.engine.Group(\"/v1\")\n117: \t{\n118: \t\tnamespaces := v1.Group(\"/namespaces/:namespace\")\n119: \t\t{\n120: \t\t\tagentRuntimes := namespaces.Group(\"/agent-runtimes/:name\")\n121: \t\t\t{\n122: \t\t\t\tagentRuntimes.Any(\"/invocations/*path\", s.handler.handleAgentInvoke)\n123: \t\t\t}\n124: \n125: \t\t\tcodeInterpreters := namespaces.Group(\"/code-interpreters/:name\")\n126: \t\t\t{\n127: \t\t\t\tcodeInterpreters.Any(\"/invocations/*path\", s.handler.handleCodeInterpreterInvoke)\n128: \t\t\t}\n129: \t\t}\n130: \t}\n131: }\n132: \n133: func (s *Server) Start(ctx context.Context) error {\n134: \tlistener, err := net.Listen(\"tcp\", s.httpServer.Addr)\n135: \tif err != nil {\n136: \t\treturn fmt.Errorf(\"failed to listen on %s: %w\", s.httpServer.Addr, err)\n137: \t}\n138: \n139: \tklog.Infof(\"Starting HTTP server on %s\", s.httpServer.Addr)\n140: \tklog.Infof(\"TLS enabled: %v\", s.config.EnableTLS)\n141: \tklog.Infof(\"Max concurrent requests: %d\", s.config.MaxConcurrentRequests)\n142: \n143: \terrChan := make(chan error, 1)\n144: \n145: \tgo func() {\n146: \t\tif s.config.EnableTLS {\n147: \t\t\terrChan <- s.httpServer.ServeTLS(listener, s.config.TLSCert, s.config.TLSKey)\n148: \t\t} else {\n149: \t\t\terrChan <- s.httpServer.Serve(listener)\n150: \t\t}\n151: \t}()\n152: \n153: \tselect {\n154: \tcase err := <-errChan:\n155: \t\tif err != nil && err != http.ErrServerClosed {\n156: \t\t\treturn fmt.Errorf(\"server error: %w\", err)\n157: \t\t}\n158: \t\treturn err\n159: \tcase <-ctx.Done():\n160: \t\treturn s.Shutdown(ctx)\n161: \t}\n162: }\n163: \n164: func (s *Server) Shutdown(ctx context.Context) error {\n165: \tklog.Info(\"Shutting down HTTP server...\")\n166: \n167: \tshutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n168: \tdefer cancel()\n169: \n170: \tif err := s.httpServer.Shutdown(shutdownCtx); err != nil {\n171: \t\tklog.Warningf(\"Error during server shutdown: %v\", err)\n172: \t\treturn err\n173: \t}\n174: \n175: \tklog.Info(\"HTTP server stopped\")\n176: \n177: \treturn nil\n178: }\n179: \n180: func (s *Server) GetMetrics() *Metrics {\n181: \treturn s.metrics\n182: }\n183: \n184: func (s *Server) GetActiveConnections() int {\n185: \treturn s.limiter.semaphoreLen()\n186: }\n187: \n188: func (l *ConcurrencyLimiter) semaphoreLen() int {\n189: \treturn len(l.semaphore)\n190: }\n\n(End of file - total 190 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/server.go","time":{"start":1775849633712,"end":1775849633726}}}}
{"type":"tool_use","timestamp":1775849633729,"sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","part":{"id":"prt_d78e2f4e1001wfg8yM13yNg3E8","messageID":"msg_d78e2dcb3001hYKxUi3eRHkkf7","sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","type":"tool","tool":"read","callID":"toolu_tool-a1d26a16bbb449c699c73a0f9420c295","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/proxy.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/proxy.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"io\"\n7: \t\"net/http\"\n8: \t\"net/http/httputil\"\n9: \t\"net/url\"\n10: \t\"strings\"\n11: \t\"time\"\n12: \n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: \t\"k8s.io/klog/v2\"\n15: )\n16: \n17: type ReverseProxy struct {\n18: \thttpTransport *http.Transport\n19: \tjwtManager    *JWTManager\n20: }\n21: \n22: func NewReverseProxy(jwtManager *JWTManager) *ReverseProxy {\n23: \treturn &ReverseProxy{\n24: \t\thttpTransport: configureHTTPTransport(),\n25: \t\tjwtManager:    jwtManager,\n26: \t}\n27: }\n28: \n29: func configureHTTPTransport() *http.Transport {\n30: \treturn &http.Transport{\n31: \t\tMaxIdleConns:        100,\n32: \t\tIdleConnTimeout:     90 * time.Second,\n33: \t\tDisableCompression:  false,\n34: \t\tForceAttemptHTTP2:   true,\n35: \t\tTLSHandshakeTimeout: 10 * time.Second,\n36: \t}\n37: }\n38: \n39: func (p *ReverseProxy) ProxyRequest(ctx context.Context, sandboxInfo *types.SandboxInfo, originalReq *http.Request) (*http.Response, error) {\n40: \tentryPoint := findMatchingEntryPoint(originalReq.URL.Path, sandboxInfo.EntryPoints)\n41: \tif entryPoint == nil {\n42: \t\treturn nil, fmt.Errorf(\"no matching entry point for path: %s\", originalReq.URL.Path)\n43: \t}\n44: \n45: \tupstreamURL := constructUpstreamURL(entryPoint.Protocol, entryPoint.Endpoint)\n46: \tupstreamURLParsed, err := url.Parse(upstreamURL)\n47: \tif err != nil {\n48: \t\treturn nil, fmt.Errorf(\"failed to parse upstream URL: %w\", err)\n49: \t}\n50: \n51: \ttargetPath := originalReq.URL.Path\n52: \tif originalReq.URL.RawQuery != \"\" {\n53: \t\ttargetPath = targetPath + \"?\" + originalReq.URL.RawQuery\n54: \t}\n55: \n56: \tproxyReq, err := http.NewRequestWithContext(ctx, originalReq.Method, upstreamURLParsed.String()+targetPath, originalReq.Body)\n57: \tif err != nil {\n58: \t\treturn nil, fmt.Errorf(\"failed to create proxy request: %w\", err)\n59: \t}\n60: \n61: \tp.modifyRequestHeaders(proxyReq, originalReq, sandboxInfo)\n62: \n63: \ttoken, err := p.jwtManager.GenerateToken(sandboxInfo.SessionID)\n64: \tif err != nil {\n65: \t\treturn nil, fmt.Errorf(\"failed to sign request: %w\", err)\n66: \t}\n67: \tproxyReq.Header.Set(\"Authorization\", \"Bearer \"+token)\n68: \n69: \tclient := &http.Client{\n70: \t\tTransport: p.httpTransport,\n71: \t\tTimeout:   60 * time.Second,\n72: \t}\n73: \n74: \tresp, err := client.Do(proxyReq)\n75: \tif err != nil {\n76: \t\treturn nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusBadGateway}\n77: \t}\n78: \n79: \treturn resp, nil\n80: }\n81: \n82: func (p *ReverseProxy) modifyRequestHeaders(proxyReq, originalReq *http.Request, sandboxInfo *types.SandboxInfo) {\n83: \tfor name, values := range originalReq.Header {\n84: \t\tif isHopByHopHeader(name) {\n85: \t\t\tcontinue\n86: \t\t}\n87: \n88: \t\tif strings.EqualFold(name, \"Authorization\") {\n89: \t\t\tcontinue\n90: \t\t}\n91: \n92: \t\tfor _, value := range values {\n93: \t\t\tproxyReq.Header.Add(name, value)\n94: \t\t}\n95: \t}\n96: \n97: \tproxyReq.Header.Set(\"X-Forwarded-Host\", originalReq.Host)\n98: \n99: \tif originalReq.TLS != nil {\n100: \t\tproxyReq.Header.Set(\"X-Forwarded-Proto\", \"https\")\n101: \t} else {\n102: \t\tproxyReq.Header.Set(\"X-Forwarded-Proto\", \"http\")\n103: \t}\n104: \n105: \tclientIP := originalReq.RemoteAddr\n106: \tif xff := originalReq.Header.Get(\"X-Forwarded-For\"); xff != \"\" {\n107: \t\tclientIP = xff + \", \" + clientIP\n108: \t}\n109: \tproxyReq.Header.Set(\"X-Forwarded-For\", clientIP)\n110: \n111: \tproxyReq.Header.Set(\"X-Agentcube-Session-ID\", sandboxInfo.SessionID)\n112: }\n113: \n114: func (p *ReverseProxy) CopyResponse(resp *http.Response, w http.ResponseWriter, sessionID string) {\n115: \tfor name, values := range resp.Header {\n116: \t\tif isHopByHopHeader(name) {\n117: \t\t\tcontinue\n118: \t\t}\n119: \n120: \t\tfor _, value := range values {\n121: \t\t\tw.Header().Add(name, value)\n122: \t\t}\n123: \t}\n124: \n125: \tw.Header().Set(\"X-Agentcube-Session-ID\", sessionID)\n126: \n127: \tw.WriteHeader(resp.StatusCode)\n128: \n129: \tif resp.Body != nil {\n130: \t\tdefer resp.Body.Close()\n131: \t\tif _, err := io.Copy(w, resp.Body); err != nil {\n132: \t\t\tklog.Warningf(\"Failed to copy response body: %v\", err)\n133: \t\t}\n134: \t}\n135: }\n136: \n137: func (p *ReverseProxy) ServeHTTP(w http.ResponseWriter, r *http.Request, sandboxInfo *types.SandboxInfo) {\n138: \tentryPoint := findMatchingEntryPoint(r.URL.Path, sandboxInfo.EntryPoints)\n139: \tif entryPoint == nil {\n140: \t\thttp.Error(w, \"no matching entry point\", http.StatusNotFound)\n141: \t\treturn\n142: \t}\n143: \n144: \tupstreamURL := constructUpstreamURL(entryPoint.Protocol, entryPoint.Endpoint)\n145: \tupstreamURLParsed, err := url.Parse(upstreamURL)\n146: \tif err != nil {\n147: \t\thttp.Error(w, fmt.Sprintf(\"invalid upstream URL: %v\", err), http.StatusInternalServerError)\n148: \t\treturn\n149: \t}\n150: \n151: \tdirector := func(req *http.Request) {\n152: \t\treq.URL.Scheme = upstreamURLParsed.Scheme\n153: \t\treq.URL.Host = upstreamURLParsed.Host\n154: \t\treq.URL.Path = singleJoiningSlash(upstreamURLParsed.Path, req.URL.Path)\n155: \n156: \t\tp.modifyRequestHeaders(req, r, sandboxInfo)\n157: \n158: \t\ttoken, err := p.jwtManager.GenerateToken(sandboxInfo.SessionID)\n159: \t\tif err != nil {\n160: \t\t\tklog.Warningf(\"Failed to generate JWT token: %v\", err)\n161: \t\t} else {\n162: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n163: \t\t}\n164: \t}\n165: \n166: \tproxy := &httputil.ReverseProxy{\n167: \t\tDirector:       director,\n168: \t\tTransport:      p.httpTransport,\n169: \t\tErrorHandler:   p.errorHandler,\n170: \t\tModifyResponse: p.modifyResponse,\n171: \t}\n172: \n173: \tproxy.ServeHTTP(w, r)\n174: }\n175: \n176: func (p *ReverseProxy) errorHandler(w http.ResponseWriter, r *http.Request, err error) {\n177: \tklog.Warningf(\"Proxy error: %v\", err)\n178: \n179: \tif err == context.DeadlineExceeded {\n180: \t\thttp.Error(w, \"sandbox timeout\", http.StatusGatewayTimeout)\n181: \t\treturn\n182: \t}\n183: \n184: \thttp.Error(w, \"sandbox unreachable\", http.StatusBadGateway)\n185: }\n186: \n187: func (p *ReverseProxy) modifyResponse(resp *http.Response) error {\n188: \tfor name, values := range resp.Header {\n189: \t\tif isHopByHopHeader(name) {\n190: \t\t\tresp.Header.Del(name)\n191: \t\t} else {\n192: \t\t\tfor _, value := range values {\n193: \t\t\t\tresp.Header.Set(name, value)\n194: \t\t\t}\n195: \t\t}\n196: \t}\n197: \n198: \treturn nil\n199: }\n200: \n201: func singleJoiningSlash(a, b string) string {\n202: \taslash := strings.HasSuffix(a, \"/\")\n203: \tbslash := strings.HasPrefix(b, \"/\")\n204: \tswitch {\n205: \tcase aslash && bslash:\n206: \t\treturn a + b[1:]\n207: \tcase !aslash && !bslash:\n208: \t\treturn a + \"/\" + b\n209: \t}\n210: \treturn a + b\n211: }\n\n(End of file - total 211 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype ReverseProxy struct {\n\thttpTransport *http.Transport\n\tjwtManager    *JWTManager\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/proxy.go","time":{"start":1775849633715,"end":1775849633727}}}}
