{"type":"tool_use","timestamp":1775849642713,"sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","part":{"id":"prt_d78e3187a001QlM2DjL8BBzu32","messageID":"msg_d78e2f80b001im37GmU3pCxwjb","sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","type":"tool","tool":"read","callID":"toolu_tool-d523f6b0cdcf4951b8a2f77954fef8ef","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"net/http\"\n5: \n6: \t\"github.com/gin-gonic/gin\"\n7: \t\"github.com/google/uuid\"\n8: \t\"k8s.io/klog/v2\"\n9: \n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: type Handler struct {\n14: \tsessionManager SessionManager\n15: \tjwtManager     *JWTManager\n16: \treverseProxy   *ReverseProxy\n17: }\n18: \n19: func NewHandler(sessionManager SessionManager, jwtManager *JWTManager, reverseProxy *ReverseProxy) *Handler {\n20: \treturn &Handler{\n21: \t\tsessionManager: sessionManager,\n22: \t\tjwtManager:     jwtManager,\n23: \t\treverseProxy:   reverseProxy,\n24: \t}\n25: }\n26: \n27: func (h *Handler) handleHealthLive(c *gin.Context) {\n28: \tc.JSON(http.StatusOK, gin.H{\n29: \t\t\"status\": \"alive\",\n30: \t})\n31: }\n32: \n33: func (h *Handler) handleHealthReady(c *gin.Context) {\n34: \tif h.sessionManager == nil {\n35: \t\tc.JSON(http.StatusServiceUnavailable, NewErrorResponse(\n36: \t\t\t\"session manager not available\",\n37: \t\t\tErrSessionManagerNotReady,\n38: \t\t))\n39: \t\treturn\n40: \t}\n41: \n42: \tif h.jwtManager == nil {\n43: \t\tc.JSON(http.StatusServiceUnavailable, NewErrorResponse(\n44: \t\t\t\"JWT manager not available\",\n45: \t\t\t\"JWT_MANAGER_NOT_READY\",\n46: \t\t))\n47: \t\treturn\n48: \t}\n49: \n50: \tc.JSON(http.StatusOK, gin.H{\n51: \t\t\"status\": \"ready\",\n52: \t})\n53: }\n54: \n55: func (h *Handler) handleAgentInvoke(c *gin.Context) {\n56: \th.handleInvocation(c, types.AgentRuntimeKind)\n57: }\n58: \n59: func (h *Handler) handleCodeInterpreterInvoke(c *gin.Context) {\n60: \th.handleInvocation(c, types.CodeInterpreterKind)\n61: }\n62: \n63: func (h *Handler) handleInvocation(c *gin.Context, kind string) {\n64: \tnamespace := c.Param(\"namespace\")\n65: \tname := c.Param(\"name\")\n66: \tpath := c.Param(\"path\")\n67: \n68: \tif !isValidNamespace(namespace) {\n69: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n70: \t\t\t\"invalid namespace format\",\n71: \t\t\tGetErrorCode(&ValidationError{Field: \"namespace\"}),\n72: \t\t))\n73: \t\treturn\n74: \t}\n75: \n76: \tif !isValidResourceName(name) {\n77: \t\tc.JSON(http.StatusBadRequest, NewErrorResponse(\n78: \t\t\t\"invalid resource name format\",\n79: \t\t\tGetErrorCode(&ValidationError{Field: \"name\"}),\n80: \t\t))\n81: \t\treturn\n82: \t}\n83: \n84: \tsessionID := h.extractSessionID(c)\n85: \n86: \tsandboxInfo, err := h.sessionManager.GetSandboxBySession(c.Request.Context(), sessionID, namespace, name, kind)\n87: \tif err != nil {\n88: \t\tif _, ok := err.(*SandboxNotFoundError); ok {\n89: \t\t\tsessionID, sandboxInfo, err = h.sessionManager.CreateSession(c.Request.Context(), name, namespace, kind)\n90: \t\t\tif err != nil {\n91: \t\t\t\tklog.Warningf(\"Failed to create session: %v\", err)\n92: \t\t\t\tc.JSON(GetHTTPStatusCode(err), NewErrorResponse(err.Error(), GetErrorCode(err)))\n93: \t\t\t\treturn\n94: \t\t\t}\n95: \t\t} else {\n96: \t\t\tklog.Warningf(\"Failed to get sandbox: %v\", err)\n97: \t\t\tc.JSON(GetHTTPStatusCode(err), NewErrorResponse(err.Error(), GetErrorCode(err)))\n98: \t\t\treturn\n99: \t\t}\n100: \t}\n101: \n102: \tif path != \"\" {\n103: \t\tc.Request.URL.Path = \"/\" + path\n104: \t}\n105: \n106: \tc.Header(\"X-Agentcube-Session-ID\", sessionID)\n107: \tc.Request.URL.Path = sanitizePath(c.Request.URL.Path)\n108: \n109: \th.reverseProxy.ServeHTTP(c.Writer, c.Request, sandboxInfo)\n110: }\n111: \n112: func (h *Handler) extractSessionID(c *gin.Context) string {\n113: \tsessionID := c.GetHeader(\"X-Agentcube-Session-ID\")\n114: \tif sessionID != \"\" {\n115: \t\tif err := parseSessionID(sessionID); err == nil {\n116: \t\t\treturn sessionID\n117: \t\t}\n118: \t}\n119: \n120: \treturn uuid.New().String()\n121: }\n122: \n123: func (h *Handler) generateSessionID() string {\n124: \treturn uuid.New().String()\n125: }\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/google/uuid\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype Handler struct {\n\tsessionManager SessionManager\n\tjwtManager     *JWTManager\n\treverseProxy   *ReverseProxy\n}\n\nfunc NewHandler(sessionManager SessionManager, jwtManager *JWTManager, reverseProxy *ReverseProxy) *Handler {\n\treturn &Handler{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/handlers.go","time":{"start":1775849642690,"end":1775849642712}}}}
{"type":"tool_use","timestamp":1775849642715,"sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","part":{"id":"prt_d78e31a99001ZKekkCK65Z2O6C","messageID":"msg_d78e2f80b001im37GmU3pCxwjb","sessionID":"ses_2871d40a1ffeI2RsyVHtcrKM38","type":"tool","tool":"read","callID":"toolu_tool-d05eb501fd3e4fdc85f848790733032a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rsa\"\n6: \t\"crypto/x509\"\n7: \t\"encoding/pem\"\n8: \t\"fmt\"\n9: \t\"time\"\n10: \n11: \t\"github.com/golang-jwt/jwt/v5\"\n12: \tcorev1 \"k8s.io/api/core/v1\"\n13: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n14: \t\"k8s.io/client-go/kubernetes\"\n15: \t\"k8s.io/klog/v2\"\n16: )\n17: \n18: const (\n19: \tprivateKeyPEMType  = \"RSA PRIVATE KEY\"\n20: \tpublicKeyPEMType   = \"PUBLIC KEY\"\n21: \tjwtTokenExpiration = 5 * time.Minute\n22: )\n23: \n24: type JWTManager struct {\n25: \tprivateKey *rsa.PrivateKey\n26: \tpublicKey  *rsa.PublicKey\n27: \tclientset  kubernetes.Interface\n28: \tnamespace  string\n29: }\n30: \n31: func NewJWTManager(clientset kubernetes.Interface, namespace string) (*JWTManager, error) {\n32: \tif clientset == nil {\n33: \t\treturn nil, fmt.Errorf(\"kubernetes clientset is required\")\n34: \t}\n35: \n36: \tif namespace == \"\" {\n37: \t\tnamespace = defaultNamespace\n38: \t}\n39: \n40: \tjwtMgr := &JWTManager{\n41: \t\tclientset: clientset,\n42: \t\tnamespace: namespace,\n43: \t}\n44: \n45: \tif err := jwtMgr.tryStoreOrLoadJWTKeySecret(); err != nil {\n46: \t\tklog.Warningf(\"Failed to load or store JWT key secret: %v. Generating in-memory keys only.\", err)\n47: \t\tprivateKey, publicKey, err := generateRSAKeyPair()\n48: \t\tif err != nil {\n49: \t\t\treturn nil, fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n50: \t\t}\n51: \t\tjwtMgr.privateKey = privateKey\n52: \t\tjwtMgr.publicKey = publicKey\n53: \t}\n54: \n55: \treturn jwtMgr, nil\n56: }\n57: \n58: func (j *JWTManager) GenerateToken(sessionID string) (string, error) {\n59: \tif j.privateKey == nil {\n60: \t\treturn \"\", fmt.Errorf(\"JWT manager not initialized with private key\")\n61: \t}\n62: \n63: \tnow := time.Now()\n64: \tclaims := &JWTClaims{\n65: \t\tSessionID: sessionID,\n66: \t\tRegisteredClaims: jwt.RegisteredClaims{\n67: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n68: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(jwtTokenExpiration)),\n69: \t\t\tNotBefore: jwt.NewNumericDate(now),\n70: \t\t},\n71: \t}\n72: \n73: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n74: \ttokenString, err := token.SignedString(j.privateKey)\n75: \tif err != nil {\n76: \t\treturn \"\", fmt.Errorf(\"failed to sign JWT token: %w\", err)\n77: \t}\n78: \n79: \treturn tokenString, nil\n80: }\n81: \n82: func (j *JWTManager) ValidateToken(tokenString string) (*JWTClaims, error) {\n83: \tif j.publicKey == nil {\n84: \t\treturn nil, fmt.Errorf(\"JWT manager not initialized with public key\")\n85: \t}\n86: \n87: \ttoken, err := jwt.ParseWithClaims(tokenString, &JWTClaims{}, func(token *jwt.Token) (interface{}, error) {\n88: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n89: \t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n90: \t\t}\n91: \t\treturn j.publicKey, nil\n92: \t})\n93: \n94: \tif err != nil {\n95: \t\treturn nil, fmt.Errorf(\"failed to parse JWT token: %w\", err)\n96: \t}\n97: \n98: \tclaims, ok := token.Claims.(*JWTClaims)\n99: \tif !ok || !token.Valid {\n100: \t\treturn nil, fmt.Errorf(\"invalid JWT token claims\")\n101: \t}\n102: \n103: \tif time.Now().After(claims.ExpiresAt.Time) {\n104: \t\treturn nil, fmt.Errorf(\"JWT token has expired\")\n105: \t}\n106: \n107: \treturn claims, nil\n108: }\n109: \n110: func (j *JWTManager) tryStoreOrLoadJWTKeySecret() error {\n111: \tsecret, err := j.clientset.CoreV1().Secrets(j.namespace).Get(j.context(), secretName, metav1.GetOptions{})\n112: \tif err == nil {\n113: \t\treturn j.loadKeysFromSecret(secret)\n114: \t}\n115: \n116: \tif err != nil && !isNotFoundError(err) {\n117: \t\treturn fmt.Errorf(\"failed to check for existing JWT secret: %w\", err)\n118: \t}\n119: \n120: \treturn j.storeJWTKeySecret()\n121: }\n122: \n123: func (j *JWTManager) loadKeysFromSecret(secret *corev1.Secret) error {\n124: \tprivateKeyPEM, ok := secret.Data[\"private.pem\"]\n125: \tif !ok {\n126: \t\treturn fmt.Errorf(\"secret does not contain private.pem\")\n127: \t}\n128: \n129: \tpublicKeyPEM, ok := secret.Data[\"public.pem\"]\n130: \tif !ok {\n131: \t\treturn fmt.Errorf(\"secret does not contain public.pem\")\n132: \t}\n133: \n134: \tprivateKey, err := parsePrivateKeyPEM(privateKeyPEM)\n135: \tif err != nil {\n136: \t\treturn fmt.Errorf(\"failed to parse private key: %w\", err)\n137: \t}\n138: \n139: \tpublicKey, err := parsePublicKeyPEM(publicKeyPEM)\n140: \tif err != nil {\n141: \t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n142: \t}\n143: \n144: \tj.privateKey = privateKey\n145: \tj.publicKey = publicKey\n146: \n147: \tklog.Infof(\"Successfully loaded JWT keys from secret: %s\", secretName)\n148: \treturn nil\n149: }\n150: \n151: func (j *JWTManager) storeJWTKeySecret() error {\n152: \tprivateKey, publicKey, err := generateRSAKeyPair()\n153: \tif err != nil {\n154: \t\treturn fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n155: \t}\n156: \n157: \tprivateKeyPEM := pem.EncodeToMemory(&pem.Block{\n158: \t\tType:  privateKeyPEMType,\n159: \t\tBytes: x509.MarshalPKCS1PrivateKey(privateKey),\n160: \t})\n161: \n162: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n163: \tif err != nil {\n164: \t\treturn fmt.Errorf(\"failed to marshal public key: %w\", err)\n165: \t}\n166: \n167: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n168: \t\tType:  publicKeyPEMType,\n169: \t\tBytes: publicKeyBytes,\n170: \t})\n171: \n172: \tsecret := &corev1.Secret{\n173: \t\tObjectMeta: metav1.ObjectMeta{\n174: \t\t\tName:      secretName,\n175: \t\t\tNamespace: j.namespace,\n176: \t\t},\n177: \t\tData: map[string][]byte{\n178: \t\t\t\"private.pem\": privateKeyPEM,\n179: \t\t\t\"public.pem\":  publicKeyPEM,\n180: \t\t},\n181: \t}\n182: \n183: \t_, err = j.clientset.CoreV1().Secrets(j.namespace).Create(j.context(), secret, metav1.CreateOptions{})\n184: \tif err != nil {\n185: \t\treturn fmt.Errorf(\"failed to create JWT key secret: %w\", err)\n186: \t}\n187: \n188: \tj.privateKey = privateKey\n189: \tj.publicKey = publicKey\n190: \n191: \tklog.Infof(\"Successfully created JWT key secret: %s\", secretName)\n192: \treturn nil\n193: }\n194: \n195: func (j *JWTManager) context() context.Context {\n196: \treturn context.Background()\n197: }\n198: \n199: func generateRSAKeyPair() (*rsa.PrivateKey, *rsa.PublicKey, error) {\n200: \tprivateKey, err := rsa.GenerateKey(nil, 2048)\n201: \tif err != nil {\n202: \t\treturn nil, nil, fmt.Errorf(\"failed to generate RSA key: %w\", err)\n203: \t}\n204: \n205: \treturn privateKey, &privateKey.PublicKey, nil\n206: }\n207: \n208: func parsePrivateKeyPEM(privateKeyPEM []byte) (*rsa.PrivateKey, error) {\n209: \tblock, _ := pem.Decode(privateKeyPEM)\n210: \tif block == nil {\n211: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n212: \t}\n213: \n214: \tif block.Type != privateKeyPEMType {\n215: \t\treturn nil, fmt.Errorf(\"invalid PEM block type: %s\", block.Type)\n216: \t}\n217: \n218: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n219: \tif err != nil {\n220: \t\treturn nil, fmt.Errorf(\"failed to parse private key: %w\", err)\n221: \t}\n222: \n223: \treturn privateKey, nil\n224: }\n225: \n226: func parsePublicKeyPEM(publicKeyPEM []byte) (*rsa.PublicKey, error) {\n227: \tblock, _ := pem.Decode(publicKeyPEM)\n228: \tif block == nil {\n229: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n230: \t}\n231: \n232: \tif block.Type != publicKeyPEMType {\n233: \t\treturn nil, fmt.Errorf(\"invalid PEM block type: %s\", block.Type)\n234: \t}\n235: \n236: \tpublicKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n237: \tif err != nil {\n238: \t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n239: \t}\n240: \n241: \trsaPublicKey, ok := publicKey.(*rsa.PublicKey)\n242: \tif !ok {\n243: \t\treturn nil, fmt.Errorf(\"not an RSA public key\")\n244: \t}\n245: \n246: \treturn rsaPublicKey, nil\n247: }\n248: \n249: func isNotFoundError(err error) bool {\n250: \treturn false\n251: }\n\n(End of file - total 251 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (\n\tprivateKeyPEMType  = \"RSA PRIVATE KEY\"\n\tpublicKeyPEMType   = \"PUBLIC KEY\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go","time":{"start":1775849642692,"end":1775849642714}}}}
