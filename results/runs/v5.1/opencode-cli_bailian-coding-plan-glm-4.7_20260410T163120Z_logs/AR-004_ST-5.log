/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: gin"},{"range":{"start":{"line":42,"character":2},"end":{"line":42,"character":6}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: JSON"},{"range":{"start":{"line":46,"character":21},"end":{"line":46,"character":25}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: json"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_test.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go\n@@ -34,16 +34,9 @@\n \n func NewServer(cfg *config.Config) (*Server, error) {\n \tk8sConfig, err := rest.InClusterConfig()\n \tif err != nil {\n-\t\tif !cfg.K8s.InClusterConfig {\n-\t\t\tk8sConfig, err = clientcmd.BuildConfigFromFlags(\"\", cfg.K8s.Kubeconfig)\n-\t\t\tif err != nil {\n-\t\t\t\treturn nil, fmt.Errorf(\"failed to build kubeconfig: %w\", err)\n-\t\t\t}\n-\t\t} else {\n-\t\t\treturn nil, fmt.Errorf(\"failed to get in-cluster config: %w\", err)\n-\t\t}\n+\t\treturn nil, fmt.Errorf(\"failed to get in-cluster config: %w\", err)\n \t}\n \n \tk8sConfig.QPS = float32(cfg.K8s.QPS)\n \tk8sConfig.Burst = cfg.K8s.Burst\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go","before":"package server\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/client-go/clientcmd\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/client\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/config\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/controller\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/handler\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/middleware\"\n)\n\ntype Server struct {\n\tconfig     *config.Config\n\trouter     *gin.Engine\n\tserver     *http.Server\n\tk8sClient  *client.K8sClient\n\tstore      store.Store\n\tcontroller *controller.SandboxController\n\twg         sync.WaitGroup\n\tctx        context.Context\n\tcancel     context.CancelFunc\n}\n\nfunc NewServer(cfg *config.Config) (*Server, error) {\n\tk8sConfig, err := rest.InClusterConfig()\n\tif err != nil {\n\t\tif !cfg.K8s.InClusterConfig {\n\t\t\tk8sConfig, err = clientcmd.BuildConfigFromFlags(\"\", cfg.K8s.Kubeconfig)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"failed to build kubeconfig: %w\", err)\n\t\t\t}\n\t\t} else {\n\t\t\treturn nil, fmt.Errorf(\"failed to get in-cluster config: %w\", err)\n\t\t}\n\t}\n\n\tk8sConfig.QPS = float32(cfg.K8s.QPS)\n\tk8sConfig.Burst = cfg.K8s.Burst\n\n\tk8sClient, err := client.NewK8sClient(k8sConfig)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to create k8s client: %w\", err)\n\t}\n\n\tredisStore, err := store.NewValkeyStore(cfg.Redis.Addr, cfg.Redis.Password, cfg.Redis.DB)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to create redis store: %w\", err)\n\t}\n\n\tsandboxController := controller.NewSandboxController(k8sClient, redisStore)\n\n\th := handler.NewHandler(sandboxController)\n\n\tgin.SetMode(gin.ReleaseMode)\n\trouter := gin.New()\n\n\trouter.Use(middleware.RecoveryMiddleware())\n\trouter.Use(middleware.LoggingMiddleware())\n\trouter.Use(middleware.CORSMiddleware())\n\n\tapiGroup := router.Group(\"/v1\")\n\t{\n\t\tapiGroup.POST(\"/agent-runtime\", h.CreateAgentRuntimeSandbox)\n\t\tapiGroup.POST(\"/code-interpreter\", h.CreateCodeInterpreterSandbox)\n\t\tapiGroup.GET(\"/sessions/:sessionId\", h.GetSession)\n\t\tapiGroup.DELETE(\"/sessions/:sessionId\", h.DeleteSession)\n\t}\n\n\trouter.GET(\"/health\", h.Health)\n\n\tctx, cancel := context.WithCancel(context.Background())\n\n\tsrv := &http.Server{\n\t\tAddr:         fmt.Sprintf(\"%s:%s\", cfg.Server.Host, cfg.Server.Port),\n\t\tHandler:      router,\n\t\tReadTimeout:  cfg.Server.ReadTimeout,\n\t\tWriteTimeout: cfg.Server.WriteTimeout,\n\t\tIdleTimeout:  cfg.Server.IdleTimeout,\n\t}\n\n\treturn &Server{\n\t\tconfig:     cfg,\n\t\trouter:     router,\n\t\tserver:     srv,\n\t\tk8sClient:  k8sClient,\n\t\tstore:      redisStore,\n\t\tcontroller: sandboxController,\n\t\tctx:        ctx,\n\t\tcancel:     cancel,\n\t}, nil\n}\n\nfunc (s *Server) Start() error {\n\ts.wg.Add(1)\n\tgo func() {\n\t\tdefer s.wg.Done()\n\t\tklog.Infof(\"Starting server on %s\", s.server.Addr)\n\t\tif err := s.server.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n\t\t\tklog.Errorf(\"Server error: %v\", err)\n\t\t}\n\t}()\n\n\ts.wg.Add(1)\n\tgo func() {\n\t\tdefer s.wg.Done()\n\t\ts.runGarbageCollector()\n\t}()\n\n\treturn nil\n}\n\nfunc (s *Server) Stop() error {\n\tklog.Info(\"Shutting down server...\")\n\n\tctx, cancel := context.WithTimeout(context.Background(), s.config.Server.ShutdownTimeout)\n\tdefer cancel()\n\n\tif err := s.server.Shutdown(ctx); err != nil {\n\t\tklog.Errorf(\"Server shutdown error: %v\", err)\n\t}\n\n\ts.cancel()\n\ts.wg.Wait()\n\n\tif err := s.store.Close(); err != nil {\n\t\tklog.Errorf(\"Store close error: %v\", err)\n\t}\n\n\tklog.Info(\"Server stopped\")\n\treturn nil\n}\n\nfunc (s *Server) runGarbageCollector() {\n\tticker := time.NewTicker(s.conf