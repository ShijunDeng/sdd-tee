ommon/types\")"},{"range":{"start":{"line":15,"character":6},"end":{"line":15,"character":15}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: miniredis"},{"range":{"start":{"line":17,"character":15},"end":{"line":17,"character":29}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: NewValkeyStore"},{"range":{"start":{"line":57,"character":18},"end":{"line":57,"character":29}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: ErrNotFound"},{"range":{"start":{"line":109,"character":18},"end":{"line":109,"character":29}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: ErrNotFound"}]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go\n@@ -13,8 +13,9 @@\n \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n \t\"k8s.io/client-go/dynamic\"\n \t\"k8s.io/client-go/kubernetes\"\n \t\"k8s.io/client-go/rest\"\n+\t\"k8s.io/klog/v2\"\n \n \t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n )\n \n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go","before":"package client\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n)\n\ntype K8sClient struct {\n\tclientset  kubernetes.Interface\n\tdynamic    dynamic.Interface\n\tconfig     *rest.Config\n\tgvrSandbox schema.GroupVersionResource\n\tgvrAgent   schema.GroupVersionResource\n\tgvrCode    schema.GroupVersionResource\n}\n\nfunc NewK8sClient(config *rest.Config) (*K8sClient, error) {\n\tclientset, err := kubernetes.NewForConfig(config)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to create kubernetes clientset: %w\", err)\n\t}\n\n\tdynamicClient, err := dynamic.NewForConfig(config)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n\t}\n\n\treturn &K8sClient{\n\t\tclientset: clientset,\n\t\tdynamic:   dynamicClient,\n\t\tconfig:    config,\n\t\tgvrSandbox: schema.GroupVersionResource{\n\t\t\tGroup:    \"agents.x-k8s.io\",\n\t\t\tVersion:  \"v1alpha1\",\n\t\t\tResource: \"sandboxes\",\n\t\t},\n\t\tgvrAgent: schema.GroupVersionResource{\n\t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n\t\t\tVersion:  \"v1alpha1\",\n\t\t\tResource: \"agentruntimes\",\n\t\t},\n\t\tgvrCode: schema.GroupVersionResource{\n\t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n\t\t\tVersion:  \"v1alpha1\",\n\t\t\tResource: \"codeinterpreters\",\n\t\t},\n\t}, nil\n}\n\nfunc (c *K8sClient) GetAgentRuntime(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\treturn c.dynamic.Resource(c.gvrAgent).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n}\n\nfunc (c *K8sClient) GetCodeInterpreter(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\treturn c.dynamic.Resource(c.gvrCode).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n}\n\nfunc (c *K8sClient) CreateSandbox(ctx context.Context, namespace string, sandbox *unstructured.Unstructured) (*unstructured.Unstructured, error) {\n\treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Create(ctx, sandbox, metav1.CreateOptions{})\n}\n\nfunc (c *K8sClient) GetSandbox(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n}\n\nfunc (c *K8sClient) DeleteSandbox(ctx context.Context, namespace, name string) error {\n\treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Delete(ctx, name, metav1.DeleteOptions{})\n}\n\nfunc (c *K8sClient) GetPodIP(ctx context.Context, sandboxName, namespace string, sandbox *unstructured.Unstructured) (string, error) {\n\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n\tif err == nil && pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n\t\treturn pod.Status.PodIP, nil\n\t}\n\n\tannotations := sandbox.GetAnnotations()\n\tconst podNameAnnotation = \"agents.x-k8s.io/sandbox-pod-name\"\n\tif podName, ok := annotations[podNameAnnotation]; ok && podName != \"\" {\n\t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, podName, metav1.GetOptions{})\n\t\tif err == nil {\n\t\t\tif pod.Status.Phase != corev1.PodRunning {\n\t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n\t\t\t}\n\t\t\tif pod.Status.PodIP == \"\" {\n\t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n\t\t\t}\n\t\t\treturn pod.Status.PodIP, nil\n\t\t}\n\t}\n\n\tpods, err := c.clientset.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n\t\tLabelSelector: labels.SelectorFromSet(labels.Set{\n\t\t\tconstants.LabelSandboxName: sandboxName,\n\t\t}).String(),\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to list pods: %w\", err)\n\t}\n\n\tfor _, p := range pods.Items {\n\t\tfor _, ownerRef := range p.OwnerReferences {\n\t\t\tif ownerRef.Kind == \"Sandbox\" && ownerRef.Name == sandboxName {\n\t\t\t\tif p.Status.Phase != corev1.PodRunning {\n\t\t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n\t\t\t\t}\n\t\t\t\tif p.Status.PodIP == \"\" {\n\t\t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n\t\t\t\t}\n\t\t\t\treturn p.Status.PodIP, nil\n\t\t\t}\n\t\t}\n\t}\n\n\treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n}\n\nfunc (c *K8sClient) WatchPods(ctx context.Context, namespace string, sandboxName string) (<-chan string, error) {\n\tpodCh := make(chan string, 1)\n\n\tgo func() {\n\t\tdefer close(podCh)\n\n\t\tticker := time.NewTicker(2 * time.Second)\n\t\tdefer ticker.Stop()\n\n\t\tfor {\n\t\t\tselect {\n\t\t\tcase <-ctx.Done():\n\t\t\t\treturn\n\t\t\tcase <-ticker.C:\n\t\t\t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n\t\t\t\tif err != nil {\n\t\t\t\t\tif apierrors.IsNotFound(err) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t\tklog.Errorf(\"Failed to get pod: %v\", err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n\t\t\t\t\tselect {\n\t\t\t\t\tcase podCh <- pod.Status.PodIP:\n\t\t\t\t\tdefault:\n\t\t\t\t\t}\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}()\n\n\treturn podCh, nil\n}\n\nfunc (c *K8sClient) GetSecret(ctx context.Context, namespace, name string) (*corev1.Secret, error) {\n\treturn c.clientset.CoreV1().Secrets(namespace).Get(ctx, name, metav1.GetOptions{})\n}\n","after":"package client\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/api