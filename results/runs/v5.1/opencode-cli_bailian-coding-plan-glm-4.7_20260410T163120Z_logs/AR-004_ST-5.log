oreSandbox(ctx, sessionID3, recentInfo))\n\n\t\tinactive, err := store.ListInactiveSandboxes(ctx, inactiveThreshold, 10)\n\t\trequire.NoError(t, err)\n\t\t\n\t\tinactiveSessionIDs := make([]string, 0)\n\t\tfor _, sb := range inactive {\n\t\t\tif sb.SessionID == sessionID1 || sb.SessionID == sessionID2 {\n\t\t\t\tinactiveSessionIDs = append(inactiveSessionIDs, sb.SessionID)\n\t\t\t}\n\t\t}\n\t\t\n\t\tassert.Contains(t, inactiveSessionIDs, sessionID1)\n\t\tassert.Contains(t, inactiveSessionIDs, sessionID2)\n\t})","oldString":"t.Run(\"List Inactive Sandboxes\", func(t *testing.T) {\n\t\tsessionID1 := \"inactive-session-1\"\n\t\tsessionID2 := \"inactive-session-2\"\n\t\tsessionID3 := \"recent-session\"\n\n\t\tnow := time.Now()\n\t\tinactiveThreshold := now.Add(-15 * time.Minute)\n\n\t\tinactiveInfo1 := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID1,\n\t\t\tSandboxName:  \"inactive-1\",\n\t\t\tWorkloadName: \"test\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tCreatedAt:    now.Add(-1 * time.Hour),\n\t\t\tExpiresAt:    now.Add(7 * time.Hour),\n\t\t\tLastActivityAt: now.Add(-20 * time.Minute),\n\t\t}\n\n\t\tinactiveInfo2 := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID2,\n\t\t\tSandboxName:  \"inactive-2\",\n\t\t\tWorkloadName: \"test\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tCreatedAt:    now.Add(-1 * time.Hour),\n\t\t\tExpiresAt:    now.Add(7 * time.Hour),\n\t\t\tLastActivityAt: now.Add(-30 * time.Minute),\n\t\t}\n\n\t\trecentInfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID3,\n\t\t\tSandboxName:  \"recent\",\n\t\t\tWorkloadName: \"test\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tCreatedAt:    now,\n\t\t\tExpiresAt:    now.Add(8 * time.Hour),\n\t\t\tLastActivityAt: now,\n\t\t}\n\n\t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID1, inactiveInfo1))\n\t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID2, inactiveInfo2))\n\t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID3, recentInfo))\n\n\t\tinactive, err := store.ListInactiveSandboxes(ctx, inactiveThreshold, 10)\n\t\trequire.NoError(t, err)\n\t\tassert.Len(t, inactive, 2)\n\n\t\tsessionIDs := make([]string, 0, len(inactive))\n\t\tfor _, sb := range inactive {\n\t\t\tsessionIDs = append(sessionIDs, sb.SessionID)\n\t\t}\n\t\tassert.Contains(t, sessionIDs, sessionID1)\n\t\tassert.Contains(t, sessionIDs, sessionID2)\n\t\tassert.NotContains(t, sessionIDs, sessionID3)\n\t})"},"output":"Edit applied successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z/pkg/workloadmanager/handler/models.go":[{"range":{"start":{"line":0,"character":8},"end":{"line":0,"character":15}},"severity":2,"source":"go list","message":"This file is within module \"../opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z\", which is not included in your workspace.\nTo fix this problem, you can add a go.work file that uses this directory.\nSee the documentation for more information on setting up your workspace:\nhttps://github.com/golang/tools/blob/master/gopls/doc/workspace.md.","data":{"Actions":[{"title":"Add a go.work file using this module","kind":"quickfix","command":{"title":"Run `go work init && go work use`","command":"gopls.run_go_work_command","arguments":[{"ViewID":"1","InitFirst":true,"Args":["use","../opencode-cli_alibaba-cn-qwen3.6-plus_20260410T073331Z"]}]}}]}},{"range":{"start":{"line":27,"character":14},"end":{"line":27,"character":30}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","message":"undefined: AgentRuntimeKind"},{"range":{"start":{"line":27,"character":44},"end":{"line":27,"character":63}},"severity":1,"code":"UndeclaredName","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UndeclaredName"},"source":"compiler","