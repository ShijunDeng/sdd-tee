\"inactive-session-1\"\n-\t\tsessionID2 := \"inactive-session-2\"\n-\t\tsessionID3 := \"recent-session\"\n+\t\tsessionID1 := \"inactive-session-test-1\"\n+\t\tsessionID2 := \"inactive-session-test-2\"\n+\t\tsessionID3 := \"recent-session-test\"\n \n \t\tnow := time.Now()\n \t\tinactiveThreshold := now.Add(-15 * time.Minute)\n \n@@ -235,15 +235,16 @@\n \t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID3, recentInfo))\n \n \t\tinactive, err := store.ListInactiveSandboxes(ctx, inactiveThreshold, 10)\n \t\trequire.NoError(t, err)\n-\t\tassert.Len(t, inactive, 2)\n \n-\t\tsessionIDs := make([]string, 0, len(inactive))\n+\t\tinactiveSessionIDs := make([]string, 0)\n \t\tfor _, sb := range inactive {\n-\t\t\tsessionIDs = append(sessionIDs, sb.SessionID)\n+\t\t\tif sb.SessionID == sessionID1 || sb.SessionID == sessionID2 {\n+\t\t\t\tinactiveSessionIDs = append(inactiveSessionIDs, sb.SessionID)\n+\t\t\t}\n \t\t}\n-\t\tassert.Contains(t, sessionIDs, sessionID1)\n-\t\tassert.Contains(t, sessionIDs, sessionID2)\n-\t\tassert.NotContains(t, sessionIDs, sessionID3)\n+\n+\t\tassert.Contains(t, inactiveSessionIDs, sessionID1)\n+\t\tassert.Contains(t, inactiveSessionIDs, sessionID2)\n \t})\n }\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/store/store_test.go","before":"package store\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestRedisStore(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tstore, err := NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, store)\n\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\tt.Run(\"Ping\", func(t *testing.T) {\n\t\terr := store.Ping(ctx)\n\t\tassert.NoError(t, err)\n\t})\n\n\tt.Run(\"Store and Get Sandbox\", func(t *testing.T) {\n\t\tsessionID := \"test-session-1\"\n\t\tinfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxName:  \"test-sandbox\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t\tPodIP:        \"10.0.0.1\",\n\t\t}\n\n\t\terr := store.StoreSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\tretrieved, err := store.GetSandbox(ctx, sessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, sessionID, retrieved.SessionID)\n\t\tassert.Equal(t, \"test-sandbox\", retrieved.SandboxName)\n\t\tassert.Equal(t, \"AgentRuntime\", retrieved.Kind)\n\t})\n\n\tt.Run(\"Get Non-Existent Sandbox\", func(t *testing.T) {\n\t\t_, err := store.GetSandbox(ctx, \"non-existent\")\n\t\tassert.Error(t, err)\n\t\tassert.Equal(t, ErrNotFound, err)\n\t})\n\n\tt.Run(\"Update Sandbox\", func(t *testing.T) {\n\t\tsessionID := \"test-session-2\"\n\t\tinfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxName:  \"test-sandbox-2\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"CodeInterpreter\",\n\t\t\tStatus:       \"pending\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t}\n\n\t\terr := store.StoreSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\tinfo.Status = \"running\"\n\t\tinfo.PodIP = \"10.0.0.2\"\n\n\t\terr = store.UpdateSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\tretrieved, err := store.GetSandbox(ctx, sessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"running\", retrieved.Status)\n\t\tassert.Equal(t, \"10.0.0.2\", retrieved.PodIP)\n\t})\n\n\tt.Run(\"Delete Sandbox\", func(t *testing.T) {\n\t\tsessionID := \"test-session-3\"\n\t\tinfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxName:  \"test-sandbox-3\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t}\n\n\t\terr := store.StoreSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\terr = store.DeleteSandboxBySessionID(ctx, sessionID)\n\t\trequire.NoError(t, err)\n\n\t\t_, err = store.GetSandbox(ctx, sessionID)\n\t\tassert.Error(t, err)\n\t\tassert.Equal(t, ErrNotFound, err)\n\t})\n\n\tt.Run(\"Update Session Last Activity\", func(t *testing.T) {\n\t\tsessionID := \"test-session-4\"\n\t\tinfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxName:  \"test-sandbox-4\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now().Add(-1 * time.Hour),\n\t\t\tExpiresAt:    time.Now().Add(7 * time.Hour),\n\t\t}\n\n\t\terr := store.StoreSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\tnewActivityTime := time.Now()\n\t\terr = store.UpdateSessionLastActivity(ctx, sessionID, newActivityTime)\n\t\trequire.NoError(t, err)\n\n\t\tretrieved, err := store.GetSandbox(ctx, sessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.WithinDuration(t, newActivityTime, retrieved.LastActivityAt, time.Second)\n\t})\n\n\tt.Run(\"List Expired Sandboxes\", func(t *testing.T) {\n\t\tsessionID1 := \"expired-session-1\"\n\t\tsessionID2 := \"expired-session-2\"\n\t\tsessionID3 := \"active-session\"\n\n\t\tnow := time.Now()\n\n\t\texpiredInfo1 := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID1,\n\t\t\tSandboxName:  \"expired-1\",\n\t\t\tWorkloadName: \"test\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n\t\t\tExpiresAt:    now.Add(-1 * time.Hour),\n\t\t}\n\n\t\texpiredInfo2 := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID2,\n\t\t\tSandboxName:  \"expired-2\",\n\t\t\tWorkloadName: \"test\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n\t\t\tExpiresAt:    now.Add(-30 * time.Minute),\n\t\t}\n\n\t\tactiveInfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID3,\n\t\t\tSandboxName:  \"active\",\n\t\t\tWorkloadName: \"test\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tCreatedAt:    now,\n\t\t\tExpiresAt:    now.Add(8 * time.Hour),\n\t\t}\n\n\t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID1, expiredInfo1))\n\t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID2, expiredInfo2))\n\t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID3, activeInfo))\n\n\t\texpired, err := store.ListExpiredSandboxes(ctx, now, 10)\n\t\trequire.NoError(t, err)\n\t\tassert.Len(t, expired, 2)\n\n\t\tsessionIDs := make([]string, 0, len(expired))\n\t\tfor _, sb := range expired {\n\t\t\tsessionIDs = append(sessionIDs, sb.SessionID)\n\t\t}\n\t\tassert.Contains(t, sessionIDs, sessionID1)\n\t\tassert.Contains(t, sessionIDs, sessionID2)\n\t\tassert.NotContains(t, sessionIDs, sessionID3)\n\t})\n\n\tt.Run(\"List Inactive Sandboxes\", func(t *testing.T) {\n\t\tsessionID1 := \"inactive-session-1\"\n\t\tsessionID2 := \"inactive-session-2\"\n\t\tsessionID3 := \"recent-session\"\n\n\t\tnow := time.Now()\n\t\tinactiveThreshold := now.Add(-15 * time.Minute)\n\n\t\tinactiveInfo1 := &types.SandboxInfo{\n\t\t\tSessionID:      sessionID1,\n\t\t\tSandboxName:    \"inactive-1\",\n\t\t\tWorkloadName:   \"test\",\n\t\t\tNamespace:      \"default\",\n\t\t\tKind:           \"AgentRuntime\",\n\t\t\tCreatedAt:      now.Add(-1 * time.Hour),\n\t\t\tExpiresAt:      now.Add(7 * time.Hour),\n\t\t\tLastActivityAt: now.Add(-20 * time.Minute),\n\t\t}\n\n\t\tinactiveInfo2 := &types.SandboxInfo{\n\t\t\tSessionID:      sessionID2,\n\t\t\tSandboxName:    \"inactive-2\",\n\t\t\tWorkloadName:   \"test\",\n\t\t\tNamespace:      \"default\",\n\t\t\tKind:           \"AgentRuntime\",\n\t\t\tCreatedAt:      now.Add(-1 * time.Hour),\n\t\t\tExpiresAt:      now.Add(7 * time.Hour),\n\t\t\tLastActivityAt: now.Add(-30 * time.Minute),\n\t\t}\n\n\t\trecentInfo := &types.SandboxInfo{\n\t\t\tSessionID:      sessionID3,\n\t\t\tSandboxName:    \"recent\",\n\t\t\tWorkloadName:   \"test\",\n\t\t\tNamespace:      \"default\",\n\t\t\tKind:           \"AgentRuntime\",\n\t\t\tCreatedAt:      now,\n\t\t\tExpiresAt:      now.Add(8 * time.Hour),\n\t\t\tLastActivityAt: now,\n\t\t}\n\n\t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID1, inactiveInfo1))\n\t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID2, inactiveInfo2))\n\t\trequire.NoError(t, store.StoreSandbox(ctx, sessionID3, recentInfo))\n\n\t\tinactive, err := store.ListInactiveSandboxes(ctx, inactiveThreshold, 10)\n\t\trequire.NoError(t, err)\n\t\tassert.Len(t, inactive, 2)\n\n\t\tsessionIDs := make([]string, 0, len(inactive))\n\t\tfor _, sb := range inactive {\n\t\t\tsessionIDs = append(sessionIDs, sb.SessionID)\n\t\t}\n\t\tassert.Contains(t, sessionIDs, sessionID1)\n\t\tassert.Contains(t, sessionIDs, sessionID2)\n\t\tassert.NotContains(t, sessionIDs, sessionID3)\n\t})\n}\n","after":"package store\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestRedisStore(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tstore, err := NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\trequire.NotNil(t, store)\n\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\tt.Run(\"Ping\", func(t *testing.T) {\n\t\terr := store.Ping(ctx)\n\t\tassert.NoError(t, err)\n\t})\n\n\tt.Run(\"Store and Get Sandbox\", func(t *testing.T) {\n\t\tsessionID := \"test-session-1\"\n\t\tinfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxName:  \"test-sandbox\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t\tPodIP:        \"10.0.0.1\",\n\t\t}\n\n\t\terr := store.StoreSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\tretrieved, err := store.GetSandbox(ctx, sessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, sessionID, retrieved.SessionID)\n\t\tassert.Equal(t, \"test-sandbox\", retrieved.SandboxName)\n\t\tassert.Equal(t, \"AgentRuntime\", retrieved.Kind)\n\t})\n\n\tt.Run(\"Get Non-Existent Sandbox\", func(t *testing.T) {\n\t\t_, err := store.GetSandbox(ctx, \"non-existent\")\n\t\tassert.Error(t, err)\n\t\tassert.Equal(t, ErrNotFound, err)\n\t})\n\n\tt.Run(\"Update Sandbox\", func(t *testing.T) {\n\t\tsessionID := \"test-session-2\"\n\t\tinfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxName:  \"test-sandbox-2\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"CodeInterpreter\",\n\t\t\tStatus:       \"pending\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t}\n\n\t\terr := store.StoreSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\tinfo.Status = \"running\"\n\t\tinfo.PodIP = \"10.0.0.2\"\n\n\t\terr = store.UpdateSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\tretrieved, err := store.GetSandbox(ctx, sessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"running\", retrieved.Status)\n\t\tassert.Equal(t, \"10.0.0.2\", retrieved.PodIP)\n\t})\n\n\tt.Run(\"Delete Sandbox\", func(t *testing.T) {\n\t\tsessionID := \"test-session-3\"\n\t\tinfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxName:  \"test-sandbox-3\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t}\n\n\t\terr := store.StoreSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\terr = store.DeleteSandboxBySessionID(ctx, sessionID)\n\t\trequire.NoError(t, err)\n\n\t\t_, err = store.GetSandbox(ctx, sessionID)\n\t\tassert.Error(t, err)\n\t\tassert.Equal(t, ErrNotFound, err)\n\t})\n\n\tt.Run(\"Update Session Last Activity\", func(t *testing.T) {\n\t\tsessionID := \"test-session-4\"\n\t\tinfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxName:  \"test-sandbox-4\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now().Add(-1 * time.Hour),\n\t\t\tExpiresAt:    time.Now().Add(7 * time.Hour),\n\t\t}\n\n\t\terr := store.StoreSandbox(ctx, sessionID, info)\n\t\trequire.NoError(t, err)\n\n\t\tnewActivityTime := time.Now()\n\t\terr = store.UpdateSessionLastActivity(ctx, sessionID, newActivityTime)\n\t\trequire.NoError(t, err)\n\n\t\tretrieved, err := store.GetSandbox(ctx, sessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.WithinDuration(t, newActivityTime, retrieved.LastActivityAt, time.Second)\n\t})\n\n\tt.Run(\"List Expired Sandboxes\", func(t *testing.T) {\n\t\tsessionID1 := \"expired-session-1\"\n\t\tsessionID2 := \"expired-session-2\"\n\t\tsessionID3 := \"active-session\"\n\n\t\tnow := time.Now()\n\n\t\texpiredInfo1 := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID1,\n\t\t\tSandboxName:  \"expired-1\",\n\t\t\tWorkloadName: \"test\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tCreatedAt:    now.Add(-10 * time.Hour),\n\t\t\tExpiresAt:    now.Add(-1 * time.Hour),\n\t\t}\n\n\t\texpiredInfo2 := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID2,\n\t\t\tSandboxName:  \"expired-2\",\n\t\t\tWorkloadName: \"test\",\n\t\t\tNamespace:    \"default\",\