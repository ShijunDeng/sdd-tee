Obj interface{}) {\n41: \t\t\toldAgentRuntime := &runtimev1alpha1.AgentRuntime{}\n42: \t\t\tnewAgentRuntime := &runtimev1alpha1.AgentRuntime{}\n43: \n44: \t\t\tif err := im.k8sClient.GetScheme().Convert(oldObj, oldAgentRuntime, nil); err != nil {\n45: \t\t\t\tklog.Errorf(\"Failed to convert old AgentRuntime: %v\", err)\n46: \t\t\t\treturn\n47: \t\t\t}\n48: \t\t\tif err := im.k8sClient.GetScheme().Convert(newObj, newAgentRuntime, nil); err != nil {\n49: \t\t\t\tklog.Errorf(\"Failed to convert new AgentRuntime: %v\", err)\n50: \t\t\t\treturn\n51: \t\t\t}\n52: \n53: \t\t\tif !im.specsEqual(oldAgentRuntime.Spec, newAgentRuntime.Spec) {\n54: \t\t\t\tklog.Infof(\"AgentRuntime %s spec updated\", newAgentRuntime.Name)\n55: \t\t\t\tim.handleSpecUpdate(newAgentRuntime)\n56: \t\t\t}\n57: \t\t},\n58: \t\tDeleteFunc: func(obj interface{}) {\n59: \t\t\tagentRuntime := &runtimev1alpha1.AgentRuntime{}\n60: \t\t\tif err := im.k8sClient.GetScheme().Convert(obj, agentRuntime, nil); err != nil {\n61: \t\t\t\tklog.Errorf(\"Failed to convert AgentRuntime: %v\", err)\n62: \t\t\t\treturn\n63: \t\t\t}\n64: \t\t\tklog.Infof(\"AgentRuntime %s deleted, initiating shutdown\", agentRuntime.Name)\n65: \t\t\tim.handleAgentRuntimeDeletion(agentRuntime)\n66: \t\t},\n67: \t}\n68: \n69: \treturn im.k8sClient.SetupAgentRuntimeInformer(handler)\n70: }\n71: \n72: func (im *InformerManager) SetupCodeInterpreterInformer() error {\n73: \thandler := cache.ResourceEventHandlerFuncs{\n74: \t\tAddFunc: func(obj interface{}) {\n75: \t\t\tcodeInterpreter := &runtimev1alpha1.CodeInterpreter{}\n76: \t\t\tif err := im.k8sClient.GetScheme().Convert(obj, codeInterpreter, nil); err != nil {\n77: \t\t\t\tklog.Errorf(\"Failed to convert CodeInterpreter: %v\", err)\n78: \t\t\t\treturn\n79: \t\t\t}\n80: \t\t\tklog.Infof(\"CodeInterpreter %s added\", codeInterpreter.Name)\n81: \t\t},\n82: \t\tUpdateFunc: func(oldObj, newObj interface{}) {\n83: \t\t\toldCodeInterpreter := &runtimev1alpha1.CodeInterpreter{}\n84: \t\t\tnewCodeInterpreter := &runtimev1alpha1.CodeInterpreter{}\n85: \n86: \t\t\tif err := im.k8sClient.GetScheme().Convert(oldObj, oldCodeInterpreter, nil); err != nil {\n87: \t\t\t\tklog.Errorf(\"Failed to convert old CodeInterpreter: %v\", err)\n88: \t\t\t\treturn\n89: \t\t\t}\n90: \t\t\tif err := im.k8sClient.GetScheme().Convert(newObj, newCodeInterpreter, nil); err != nil {\n91: \t\t\t\tklog.Errorf(\"Failed to convert new CodeInterpreter: %v\", err)\n92: \t\t\t\treturn\n93: \t\t\t}\n94: \n95: \t\t\tif !im.specsEqual(oldCodeInterpreter.Spec, newCodeInterpreter.Spec) {\n96: \t\t\t\tklog.Infof(\"CodeInterpreter %s spec updated\", newCodeInterpreter.Name)\n97: \t\t\t\tim.handleCodeInterpreterUpdate(newCodeInterpreter)\n98: \t\t\t}\n99: \t\t},\n100: \t\tDeleteFunc: func(obj interface{}) {\n101: \t\t\tcodeInterpreter := &runtimev1alpha1.CodeInterpreter{}\n102: \t\t\tif err := im.k8sClient.GetScheme().Convert(obj, codeInterpreter, nil); err != nil {\n103: \t\t\t\tklog.Errorf(\"Failed to convert CodeInterpreter: %v\", err)\n104: \t\t\t\treturn\n105: \t\t\t}\n106: \t\t\tklog.Infof(\"CodeInterpreter %s deleted\", codeInterpreter.Name)\n107: \t\t},\n108: \t}\n109: \n110: \treturn im.k8sClient.SetupCodeInterpreterInformer(handler)\n111: }\n112: \n113: func (im *InformerManager) handleSpecUpdate(agentRuntime *runtimev1alpha1.AgentRuntime) {\n114: \tif agentRuntime.Spec.SessionTimeout != nil {\n115: \t\tklog.Infof(\"Session timeout updated to %v for AgentRuntime %s\", agentRuntime.Spec.SessionTimeout, agentRuntime.Name)\n116: \t}\n117: \n118: \tif agentRuntime.Spec.MaxSessionDuration != nil {\n119: \t\tklog.Infof(\"Max session duration updated to %v for AgentRuntime %s\", agentRuntime.Spec.MaxSessionDuration, agentRuntime.Name)\n120: \t}\n121: }\n122: \n123: func (im *InformerManager) handleAgentRuntimeDeletion(agentRuntime *runtimev1alpha1.AgentRuntime) {\n124: \tif agentRuntime.Name == im.k8sClient.GetAgentRuntimeName() {\n125: \t\tklog.Info(\"This PicoD instance's AgentRuntime was deleted, initiating graceful shutdown\")\n126: \n127: \t\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n128: \t\tdefer cancel()\n129: \n130: \t\tif im.workspaceManager != nil {\n131: \t\t\tif err := im.workspaceManager.CleanupWorkspace(); err != nil {\n132: \t\t\t\tklog.Errorf(\"Failed to cleanup workspace: %v\", err)\n133: \t\t\t}\n134: \t\t}\n135: \n136: \t\tif im.server != nil {\n137: \t\t\tif err := im.server.Shutdown(ctx); err != nil {\n138: \t\t\t\tklog.Errorf(\"Failed to shutdown server: %v\", err)\n139: \t\t\t}\n140: \t\t}\n141: \n142: \t\tos.Exit(0)\n143: \t}\n144: }\n145: \n146: func (im *InformerManager) handleCodeInterpreterUpdate(codeInterpreter *runtimev1alpha1.CodeInterpreter) {\n147: \tklog.Infof(\"CodeInterpreter %s updated: image=%s, runtime=%s\",\n148: \t\tcodeInterpreter.Name, codeInterpreter.Spec.Image, codeInterpreter.Spec.Runtime)\n149: }\n150: \n151: func (im *InformerManager) specsEqual(spec1, spec2 interface{}) bool {\n152: \treturn im.deepEqual(spec1, spec2)\n153: }\n154: \n155: func (im *InformerManager) deepEqual(a, b interface{}) bool {\n156: \tswitch a := a.(type) {\n157: \tcase runtimev1alpha1.AgentRuntimeSpec:\n158: \t\tbSpec, ok := b.(runtimev1alpha1.AgentRuntimeSpec)\n159: \t\tif !ok {\n160: \t\t\treturn false\n161: \t\t}\n162: \t\tif a.SessionTimeout != nil && bSpec.SessionTimeout != nil {\n163: \t\t\tif a.SessionTimeout.Duration != bSpec.SessionTimeout.Duration {\n164: \t\t\t\treturn false\n165: \t\t\t}\n166: \t\t} else if (a.SessionTimeout == nil) != (bSpec.SessionTimeout == nil) {\n167: \t\t\treturn false\n168: \t\t}\n169: \t\tif a.MaxSessionDuration != nil && bSpec.MaxSessionDuration != nil {\n170: \t\t\tif a.MaxSessionDuration.Duration != bSpec.MaxSessionDuration.Duration {\n171: \t\t\t\treturn false\n172: \t\t\t}\n173: \t\t} else if (a.MaxSessionDuration == nil) != (bSpec.MaxSessionDuration == nil) {\n174: \t\t\treturn false\n175: \t\t}\n176: \t\treturn true\n177: \tcase runtimev1alpha1.CodeInterpreterSpec:\n178: \t\tbSpec, ok := b.(runtimev1alpha1.CodeInterpreterSpec)\n179: \t\tif !ok {\n180: \t\t\treturn false\n181: \t\t}\n182: \t\tif a.Image != bSpec.Image || a.Runtime != bSpec.Runtime {\n183: \t\t\treturn false\n184: \t\t}\n185: \t\tif a.Timeout != nil && bSpec.Timeout != nil {\n186: \t\t\tif a.Timeout.Duration != bSpec.Timeout.Duration {\n187: \t\t\t\treturn false\n188: \t\t\t}\n189: \t\t} else if (a.Timeout == nil) != (bSpec.Timeout == nil) {\n190: \t\t\treturn false\n191: \t\t}\n192: \t\treturn true\n193: \tdefault:\n194: \t\treturn a == b\n195: \t}\n196: }\n\n(End of file - total 196 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"time\"\n\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/klog/v2\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\ntype InformerManager struct {\n\tk8sClient        *K8sClient\n\tserver           *Server\n\tworkspaceManager *WorkspaceManager\n\tstatusReporter   *StatusReporter\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/informer.go","time":{"start":1775893297500,"end":1775893297516}}}}
