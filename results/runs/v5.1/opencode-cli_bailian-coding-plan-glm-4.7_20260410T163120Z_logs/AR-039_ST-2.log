: \t\tcase <-sr.stopCh:\n45: \t\t\tklog.Info(\"Status reporter stopped\")\n46: \t\t\treturn\n47: \t\t}\n48: \t}\n49: }\n50: \n51: func (sr *StatusReporter) Stop() {\n52: \tclose(sr.stopCh)\n53: }\n54: \n55: func (sr *StatusReporter) reportStatus() error {\n56: \tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n57: \tdefer cancel()\n58: \n59: \tagentRuntime, err := sr.k8sClient.GetAgentRuntime(ctx, sr.agentRuntimeName)\n60: \tif err != nil {\n61: \t\treturn fmt.Errorf(\"failed to get AgentRuntime: %w\", err)\n62: \t}\n63: \n64: \tif err := sr.workspaceManager.UpdateMetrics(); err != nil {\n65: \t\tklog.Warningf(\"Failed to update workspace metrics: %v\", err)\n66: \t}\n67: \n68: \tmetrics := sr.workspaceManager.GetMetrics()\n69: \n70: \tnow := metav1.NewTime(time.Now())\n71: \tagentRuntime.Status.ObservedGeneration = agentRuntime.Generation\n72: \n73: \treadyCondition := metav1.Condition{\n74: \t\tType:               \"Ready\",\n75: \t\tStatus:             metav1.ConditionTrue,\n76: \t\tLastTransitionTime: now,\n77: \t\tReason:             \"WorkspaceReady\",\n78: \t\tMessage:            \"Workspace initialized and ready\",\n79: \t}\n80: \n81: \tagentRuntime.Status.Conditions = appendCondition(agentRuntime.Status.Conditions, readyCondition)\n82: \n83: \tklog.V(2).Infof(\"Reporting status for AgentRuntime %s: files=%d, dirs=%d, size=%d\",\n84: \t\tsr.agentRuntimeName, metrics.FileCount, metrics.DirectoryCount, metrics.TotalSize)\n85: \n86: \t_, err = sr.k8sClient.UpdateAgentRuntimeStatus(ctx, agentRuntime)\n87: \tif err != nil {\n88: \t\treturn fmt.Errorf(\"failed to update AgentRuntime status: %w\", err)\n89: \t}\n90: \n91: \tklog.V(2).Infof(\"Successfully reported status for AgentRuntime %s\", sr.agentRuntimeName)\n92: \treturn nil\n93: }\n94: \n95: func appendCondition(conditions []metav1.Condition, newCondition metav1.Condition) []metav1.Condition {\n96: \tnow := metav1.NewTime(time.Now())\n97: \n98: \tfor i := range conditions {\n99: \t\tif conditions[i].Type == newCondition.Type {\n100: \t\t\tif conditions[i].Status != newCondition.Status {\n101: \t\t\t\tconditions[i].Status = newCondition.Status\n102: \t\t\t\tconditions[i].LastTransitionTime = now\n103: \t\t\t\tconditions[i].Reason = newCondition.Reason\n104: \t\t\t\tconditions[i].Message = newCondition.Message\n105: \t\t\t}\n106: \t\t\treturn conditions\n107: \t\t}\n108: \t}\n109: \n110: \tnewCondition.LastTransitionTime = now\n111: \treturn append(conditions, newCondition)\n112: }\n113: \n114: func (sr *StatusReporter) ReportOnce() error {\n115: \treturn sr.reportStatus()\n116: }\n\n(End of file - total 116 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype StatusReporter struct {\n\tk8sClient        *K8sClient\n\tworkspaceManager *WorkspaceManager\n\tagentRuntimeName string\n\tinterval         time.Duration\n\tstopCh           chan struct{}\n}\n\nfunc NewStatusReporter(k8sClient *K8sClient, workspaceManager *WorkspaceManager, agentRuntimeName string, interval time.Duration) *StatusReporter {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/status_reporter.go","time":{"start":1775893246718,"end":1775893246735}}}}
