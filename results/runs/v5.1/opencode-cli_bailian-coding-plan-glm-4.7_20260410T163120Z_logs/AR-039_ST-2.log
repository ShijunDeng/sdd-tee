rpreters[key]\n43: \tif !exists {\n44: \t\treturn nil, nil\n45: \t}\n46: \n47: \treturn ci, nil\n48: }\n49: \n50: func (rc *ResourceCache) UpdateAgentRuntime(ar *agentcubev1alpha1.AgentRuntime) {\n51: \trc.mu.Lock()\n52: \tdefer rc.mu.Unlock()\n53: \n54: \tkey := rc.agentRuntimeKey(ar.Namespace, ar.Name)\n55: \trc.agentRuntimes[key] = ar\n56: \trc.resourceVersions[key] = ar.ResourceVersion\n57: }\n58: \n59: func (rc *ResourceCache) UpdateCodeInterpreter(ci *agentcubev1alpha1.CodeInterpreter) {\n60: \trc.mu.Lock()\n61: \tdefer rc.mu.Unlock()\n62: \n63: \tkey := rc.codeInterpreterKey(ci.Namespace, ci.Name)\n64: \trc.codeInterpreters[key] = ci\n65: \trc.resourceVersions[key] = ci.ResourceVersion\n66: }\n67: \n68: func (rc *ResourceCache) DeleteAgentRuntime(namespace, name string) {\n69: \trc.mu.Lock()\n70: \tdefer rc.mu.Unlock()\n71: \n72: \tkey := rc.agentRuntimeKey(namespace, name)\n73: \tdelete(rc.agentRuntimes, key)\n74: \tdelete(rc.resourceVersions, key)\n75: }\n76: \n77: func (rc *ResourceCache) DeleteCodeInterpreter(namespace, name string) {\n78: \trc.mu.Lock()\n79: \tdefer rc.mu.Unlock()\n80: \n81: \tkey := rc.codeInterpreterKey(namespace, name)\n82: \tdelete(rc.codeInterpreters, key)\n83: \tdelete(rc.resourceVersions, key)\n84: }\n85: \n86: func (rc *ResourceCache) HasResourceChanged(namespace, name, kind, resourceVersion string) bool {\n87: \trc.mu.RLock()\n88: \tdefer rc.mu.RUnlock()\n89: \n90: \tvar key string\n91: \tif kind == \"AgentRuntime\" {\n92: \t\tkey = rc.agentRuntimeKey(namespace, name)\n93: \t} else if kind == \"CodeInterpreter\" {\n94: \t\tkey = rc.codeInterpreterKey(namespace, name)\n95: \t} else {\n96: \t\treturn true\n97: \t}\n98: \n99: \tstoredVersion, exists := rc.resourceVersions[key]\n100: \tif !exists {\n101: \t\treturn true\n102: \t}\n103: \n104: \treturn storedVersion != resourceVersion\n105: }\n106: \n107: func (rc *ResourceCache) ListAgentRuntimes() []*agentcubev1alpha1.AgentRuntime {\n108: \trc.mu.RLock()\n109: \tdefer rc.mu.RUnlock()\n110: \n111: \tresult := make([]*agentcubev1alpha1.AgentRuntime, 0, len(rc.agentRuntimes))\n112: \tfor _, ar := range rc.agentRuntimes {\n113: \t\tresult = append(result, ar)\n114: \t}\n115: \n116: \treturn result\n117: }\n118: \n119: func (rc *ResourceCache) ListCodeInterpreters() []*agentcubev1alpha1.CodeInterpreter {\n120: \trc.mu.RLock()\n121: \tdefer rc.mu.RUnlock()\n122: \n123: \tresult := make([]*agentcubev1alpha1.CodeInterpreter, 0, len(rc.codeInterpreters))\n124: \tfor _, ci := range rc.codeInterpreters {\n125: \t\tresult = append(result, ci)\n126: \t}\n127: \n128: \treturn result\n129: }\n130: \n131: func (rc *ResourceCache) agentRuntimeKey(namespace, name string) string {\n132: \treturn \"agentruntime:\" + namespace + \":\" + name\n133: }\n134: \n135: func (rc *ResourceCache) codeInterpreterKey(namespace, name string) string {\n136: \treturn \"codeinterpreter:\" + namespace + \":\" + name\n137: }\n\n(End of file - total 137 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"sync\"\n\n\tagentcubev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\ntype ResourceCache struct {\n\tmu               sync.RWMutex\n\tagentRuntimes    map[string]*agentcubev1alpha1.AgentRuntime\n\tcodeInterpreters map[string]*agentcubev1alpha1.CodeInterpreter\n\tresourceVersions map[string]string\n}\n\nfunc NewResourceCache() *ResourceCache {\n\treturn &ResourceCache{\n\t\tagentRuntimes:    make(map[string]*agentcubev1alpha1.AgentRuntime),\n\t\tcodeInterpreters: make(map[string]*agentcubev1alpha1.CodeInterpreter),\n\t\tresourceVersions: make(map[string]string),","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/resource_cache.go","time":{"start":1775893280244,"end":1775893280254}}}}
