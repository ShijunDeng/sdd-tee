ext.WithTimeout(context.Background(), timeout)\n53: \tdefer cancel()\n54: \n55: \tcmd := exec.CommandContext(ctx, req.Command[0], req.Command[1:]...)\n56: \tcmd.Dir = workingDir\n57: \n58: \tenv := os.Environ()\n59: \tfor k, v := range req.Env {\n60: \t\tenv = append(env, fmt.Sprintf(\"%s=%s\", k, v))\n61: \t}\n62: \tcmd.Env = env\n63: \n64: \tstartTime := time.Now()\n65: \tstdout, err := cmd.CombinedOutput()\n66: \tendTime := time.Now()\n67: \tduration := endTime.Sub(startTime)\n68: \n69: \texitCode := 0\n70: \tif err != nil {\n71: \t\tif ctx.Err() == context.DeadlineExceeded {\n72: \t\t\texitCode = TimeoutExitCode\n73: \t\t} else {\n74: \t\t\tif exitError, ok := err.(*exec.ExitError); ok {\n75: \t\t\t\texitCode = exitError.ExitCode()\n76: \t\t\t} else {\n77: \t\t\t\texitCode = 1\n78: \t\t\t}\n79: \t\t}\n80: \t}\n81: \n82: \tresponse := ExecuteResponse{\n83: \t\tStdout:    string(stdout),\n84: \t\tStderr:    \"\",\n85: \t\tExitCode:  exitCode,\n86: \t\tDuration:  duration.Seconds(),\n87: \t\tStartTime: startTime.UTC(),\n88: \t\tEndTime:   endTime.UTC(),\n89: \t}\n90: \n91: \tc.JSON(http.StatusOK, response)\n92: }\n93: \n94: func (s *Server) UploadFileHandler(c *gin.Context) {\n95: \tcontentType := c.GetHeader(HeaderContentType)\n96: \n97: \tif strings.HasPrefix(contentType, MIMEMultipart) {\n98: \t\tif err := c.Request.ParseMultipartForm(32 << 20); err != nil {\n99: \t\t\tHandleError(c, NewError(ErrInvalidCommand, \"failed to parse multipart form\", err.Error(), err))\n100: \t\t\treturn\n101: \t\t}\n102: \n103: \t\tpath := c.PostForm(\"path\")\n104: \t\tfile, header, err := c.Request.FormFile(\"file\")\n105: \t\tif err != nil {\n106: \t\t\tHandleError(c, NewError(ErrMissingPath, \"path or file form field missing\", \"\", err))\n107: \t\t\treturn\n108: \t\t}\n109: \t\tdefer file.Close()\n110: \n111: \t\tif path == \"\" {\n112: \t\t\tHandleError(c, NewError(ErrMissingPath, \"path form field missing\", \"\", nil))\n113: \t\t\treturn\n114: \t\t}\n115: \n116: \t\tmodeSt