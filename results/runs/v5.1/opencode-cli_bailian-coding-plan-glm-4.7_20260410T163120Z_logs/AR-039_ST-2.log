rror) {\n55: \tif workspaceDir == \"\" {\n56: \t\treturn \"\", NewError(ErrWorkspaceNotInit, ErrMsgWorkspaceNotInit, \"\", nil)\n57: \t}\n58: \n59: \tif len(path) > MaxPathLength {\n60: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgPathTooLong, \"\", nil)\n61: \t}\n62: \n63: \tresolvedWorkspace, err := filepath.EvalSymlinks(workspaceDir)\n64: \tif err != nil {\n65: \t\tresolvedWorkspace = filepath.Clean(workspaceDir)\n66: \t}\n67: \tresolvedWorkspace = filepath.Clean(resolvedWorkspace)\n68: \n69: \tcleanPath := filepath.Clean(path)\n70: \n71: \tif cleanPath == \"\" || cleanPath == \".\" {\n72: \t\treturn resolvedWorkspace, nil\n73: \t}\n74: \n75: \tif filepath.IsAbs(cleanPath) {\n76: \t\tcleanPath = strings.TrimPrefix(cleanPath, string(os.PathSeparator))\n77: \t}\n78: \n79: \tfullPath := filepath.Clean(filepath.Join(resolvedWorkspace, cleanPath))\n80: \n81: \trelPath, err := filepath.Rel(resolvedWorkspace, fullPath)\n82: \tif err != nil {\n83: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, err.Error(), err)\n84: \t}\n85: \n86: \tif strings.HasPrefix(relPath, \"..\"+string(os.PathSeparator)) || relPath == \"..\" {\n87: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"\", nil)\n88: \t}\n89: \n90: \tresolvedPath, err := filepath.EvalSymlinks(fullPath)\n91: \tif err == nil {\n92: \t\tresolvedRelPath, err := filepath.Rel(resolvedWorkspace, resolvedPath)\n93: \t\tif err != nil || strings.HasPrefix(resolvedRelPath, \"..\"+string(os.PathSeparator)) {\n94: \t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"\", nil)\n95: \t\t}\n96: \t\treturn resolvedPath, nil\n97: \t}\n98: \n99: \treturn fullPath, nil\n100: }\n101: \n102: func (s *Server) sanitizePath(path string) (string, error) {\n103: \treturn sanitizePath(s.workspaceDir, path)\n104: }\n105: \n106: func (s *Server) getFileInfo(path string) (FileInfo, error) {\n107: \tinfo, err := os.Stat(path)\n108: \tif err != nil {\n109: \t\tif os.IsNotExist(err) {\n110: \t\t\treturn FileInfo{}, NewError(ErrFileNotFound, ErrMsgFileNotFound, \"\", err)\n111: \t\t}\n112: \t\treturn FileInfo{}, NewError(ErrServerInternal, \"failed to get file info\", err.Error(), err)\n113: \t}\n114: \n115: \treturn FileInfo{\n116: \t\tPath:     path,\n117: \t\tSize:     info.Size(),\n118: \t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n119: \t\tModified: info.ModTime(),\n120: \t}, nil\n121: }\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n)\n\ntype FileInfo struct {\n\tPath     string    `json:\"path\"`\n\tSize     int64     `json:\"size\"`\n\tMode     string    `json:\"mode\"`\n\tModified time.Time `json:\"modified\"`\n}\n\ntype UploadFileRequest struct {\n\tPath    string `json:\"path\" binding:\"required\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/files.go","time":{"start":1775893264262,"end":1775893264284}}}}
