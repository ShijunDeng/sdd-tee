ewError(ErrServerInternal, \"failed to create directory\", err.Error(), err))\n172: \t\t\treturn\n173: \t\t}\n174: \n175: \t\tmode := parseFileMode(req.Mode)\n176: \t\tif err := os.WriteFile(sanitizedPath, content, mode); err != nil {\n177: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to write file\", err.Error(), err))\n178: \t\t\treturn\n179: \t\t}\n180: \n181: \t\tklog.Infof(\"Uploaded file: %s (size: %d)\", sanitizedPath, len(content))\n182: \n183: \t\tfileInfo, err := s.getFileInfo(sanitizedPath)\n184: \t\tif err != nil {\n185: \t\t\tHandleError(c, err)\n186: \t\t\treturn\n187: \t\t}\n188: \n189: \t\tc.JSON(http.StatusOK, fileInfo)\n190: \t}\n191: }\n192: \n193: func (s *Server) ListFilesHandler(c *gin.Context) {\n194: \tpath := c.Query(\"path\")\n195: \tif path == \"\" {\n196: \t\tHandleError(c, NewError(ErrMissingPath, ErrMsgMissingPathParam, \"\", nil))\n197: \t\treturn\n198: \t}\n199: \n200: \tsanitizedPath, err := s.sanitizePath(path)\n201: \tif err != nil {\n202: \t\tHandleError(c, err)\n203: \t\treturn\n204: \t}\n205: \n206: \tentries, err := os.ReadDir(sanitizedPath)\n207: \tif err != nil {\n208: \t\tif os.IsNotExist(err) {\n209: \t\t\tHandleError(c, NewError(ErrDirectoryNotFound, ErrMsgDirectoryNotFound, \"\", err))\n210: \t\t} else {\n211: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to read directory\", err.Error(), err))\n212: \t\t}\n213: \t\treturn\n214: \t}\n215: \n216: \tvar files []FileEntry\n217: \tfor _, entry := range entries {\n218: \t\tinfo, err := entry.Info()\n219: \t\tif err != nil {\n220: \t\t\tklog.Warningf(\"Failed to get info for %s: %v\", entry.Name(), err)\n221: \t\t\tcontinue\n222: \t\t}\n223: \n224: \t\tfiles = append(files, FileEntry{\n225: \t\t\tName:     entry.Name(),\n226: \t\t\tSize:     info.Size(),\n227: \t\t\tModified: info.ModTime(),\n228: \t\t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n229: \t\t\tIsDir:    entry.IsDir(),\n230: \t\t})\n231: \t}\n232: \n233: \tresponse := ListFilesResponse{\n234: \t\tFiles: files,\n235: \t}\n236: \n237: \tc.JSON(http.StatusOK, response)\n238: }\n239: \n240: func (s *Server) DownloadFileHandler(c *gin.Context) {\n241: \tpath := c.Param(\"path\")\n242: \tif path == \"\" {\n243: \t\tHandleError(c, NewError(ErrMissingPath, ErrMsgMissingPathParam, \"\", nil))\n244: \t\treturn\n245: \t}\n246: \n247: \tpath = strings.TrimPrefix(path, \"/\")\n248: \n249: \tsanitizedPath, err := s.sanitizePath(path)\n250: \tif err != nil {\n251: \t\tHandleError(c, err)\n252: \t\treturn\n253: \t}\n254: \n255: \tinfo, err := os.Stat(sanitizedPath)\n256: \tif err != nil {\n257: \t\tif os.IsNotExist(err) {\n258: \t\t\tHandleError(c, NewError(ErrFileNotFound, ErrMsgFileNotFound, \"\", err))\n259: \t\t} else {\n260: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to get file info\", err.Error(), err))\n261: \t\t}\n262: \t\treturn\n263: \t}\n264: \n265: \tif info.IsDir() {\n266: \t\tHandleError(c, NewError(ErrPathIsDirectory, ErrMsgPathIsDirectory, \"\", nil))\n267: \t\treturn\n268: \t}\n269: \n270: \tcontent, err := os.ReadFile(sanitizedPath)\n271: \tif err != nil {\n272: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to read file\", err.Error(), err))\n273: \t\treturn\n274: \t}\n275: \n276: \tc.Header(HeaderContentDescription, \"File Transfer\")\n277: \tc.Header(HeaderContentEncoding, \"binary\")\n278: \tc.Header(HeaderContentDisposition, fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filepath.Base(sanitizedPath)))\n279: \n280: \tmimeType := mime.TypeByExtension(filepath.Ext(sanitizedPath))\n281: \tif mimeType == \"\" {\n282: \t\tmimeType = MIMEOctetStream\n283: \t}\n284: \tc.Header(HeaderContentType, mimeType)\n285: \n286: \tc.Data(http.StatusOK, mimeType, content)\n287: }\n288: \n289: func (s *Server) HealthCheckHandler(c *gin.Context) {\n290: \tuptime := time.Since(s.startTime)\n291: \n292: \tc.JSON(http.StatusOK, gin.H{\n293: \t\t\"status\":  \"ok\",\n294: \t\t\"service\": ServiceName,\n295: \t\t\"version\": Version,\