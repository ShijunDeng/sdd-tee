toreClient == nil {\n40: \t\treturn nil, fmt.Errorf(\"store client is required\")\n41: \t}\n42: \n43: \tif workloadMgrAddr == \"\" {\n44: \t\treturn nil, fmt.Errorf(\"workload manager address is required\")\n45: \t}\n46: \n47: \treturn &manager{\n48: \t\tstoreClient:     storeClient,\n49: \t\tworkloadMgrAddr: workloadMgrAddr,\n50: \t\thttpClient:      &http.Client{Timeout: 30 * time.Second},\n51: \t\tresourceCache:   NewResourceCache(),\n52: \t}, nil\n53: }\n54: \n55: func (m *manager) InitializeInformers(clientset kubernetes.Interface, namespace string, resyncPeriod time.Duration) error {\n56: \tif clientset == nil {\n57: \t\tklog.Info(\"Kubernetes clientset not provided, informers not initialized\")\n58: \t\treturn nil\n59: \t}\n60: \n61: \tinformerManager, err := NewInformerManager(clientset, namespace, resyncPeriod)\n62: \tif err != nil {\n63: \t\treturn fmt.Errorf(\"failed to create informer manager: %w\", err)\n64: \t}\n65: \n66: \tm.informerManager = informerManager\n67: \tm.resourceCache = informerManager.GetResourceCache()\n68: \n69: \tklog.Infof(\"Informers initialized for namespace: %s\", namespace)\n70: \treturn nil\n71: }\n72: \n73: func (m *manager) StartInformers() {\n74: \tif m.informerManager != nil {\n75: \t\tm.informerManager.Start()\n76: \t}\n77: }\n78: \n79: func (m *manager) StopInformers() {\n80: \tif m.informerManager != nil {\n81: \t\tm.informerManager.Stop()\n82: \t}\n83: }\n84: \n85: func (m *manager) WaitForCacheSync(ctx context.Context) bool {\n86: \tif m.informerManager == nil {\n87: \t\treturn true\n88: \t}\n89: \n90: \treturn m.informerManager.WaitForCacheSync(ctx.Done())\n91: }\n92: \n93: func (m *manager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n94: \tsandboxInfo, err := m.storeClient.GetSandbox(ctx, sessionID)\n95: \tif err == nil {\n96: \t\tklog.V(4).Infof(\"Cache hit for session: %s\", sessionID)\n97: \n98: \t\tif m.isResourceActive(namespace, name, kind) {\n99: \t\t\treturn sandboxInfo, nil\n100: \t\t}\n101: \n102: \t\tklog.V(4).Infof(\"Resource not active, removing from cache: %s\", sessionID)\n103: \t\tm.storeClient.DeleteSandboxBySessionID(ctx, sessionID)\n104: \n105: \t\tklog.V(4).Infof(\"Cache miss for session: %s, querying workload manager\", sessionID)\n106: \t\treturn m.getSandboxFromWorkloadManager(ctx, sessionID)\n107: \t}\n108: \n109: \tif err != store.ErrNotFound {\n110: \t\tklog.Warningf(\"Failed to get sandbox from store: %v\", err)\n111: \t}\n112: \n113: \tklog.V(4).Infof(\"Cache miss for session: %s, querying workload manager\", sessionID)\n114: \treturn m.getSandboxFromWorkloadManager(ctx, sessionID)\n115: }\n116: \n117: func (m *manager) CreateSession(ctx context.Context, name string, namespace string, kind string) (string, *types.SandboxInfo, error) {\n118: \tif err := validateKind(kind); err != nil {\n119: \t\treturn \"\", nil, err\n120: \t}\n121: \n122: \tif !isValidNamespace(namespace) {\n123: \t\treturn \"\", nil, &ValidationError{Field: \"namespace\", Message: \"invalid namespace format\"}\n124: \t}\n125: \n126: \tif !isValidResourceName(name) {\n127: \t\treturn \"\", nil, &ValidationError{Field: \"name\", Message: \"invalid resource name format\"}\n128: \t}\n129: \n130: \tcreateReq := &WorkloadManagerCreateRequest{\n131: \t\tKind:      kind,\n132: \t\tName:      name,\n133: \t\tNamespace: namespace,\n134: \t}\n135: \n136: \treqBody, err := json.Marshal(createReq)\n137: \tif err != nil {\n138: \t\treturn \"\", nil, fmt.Errorf(\"failed to marshal create request: %w\", err)\n139: \t}\n140: \n141: \tvar endpoint string\n142: \tif kind == types.AgentRuntimeKind {\n143: \t\tendpoint = fmt.Sprintf(\"%s/v1/agent-runtime\", m.workloadMgrAddr)\n144: \t} else {\n145: \t\tendpoint = fmt.Sprintf(\"%s/v1/code-interpreter\", m.workloadMgrAddr)\n146: \t}\n147: \n148: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(reqBody))\n149: \tif err != nil {\n150: \t\treturn \"\", nil, fmt.Errorf(\"failed to create request: %w\", err)\n151: \t}\n152: \n153: \treq.Header.Set(\"Content-Type\", \"application/json\")\n154: \n155: \tresp, err := m.httpClient.Do(req)\n156: \tif err != nil {\n157: \t\treturn \"\", nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusServiceUnavailable}\n158: \t}\n159: \tdefer resp.Body.Close()\n160: \n161: \tbody, err := io.ReadAll(resp.Body)\n162: \tif err != nil {\n163: \t\treturn \"\", nil, fmt.Errorf(\"failed to read response body: %w\", err)\n164: \t}\n165: \n166: \tif resp.StatusCode != http.StatusOK {\n167: \t\treturn \"\", nil, &WorkloadManagerError{\n168: \t\t\tMessage: string(body),\n169: \t\t\tCode:    resp.StatusCode,\n170: \t\t}\n171: \t}\n172: \n173: \tvar createResp WorkloadManagerCreateResponse\n174: \tif err := json.Unmarshal(body, &createResp); err != nil {\n175: \t\treturn \"\", nil, fmt.Errorf(\"failed to unmarshal create response: %w\", err)\n176: \t}\n177: \n178: \tsessionID := createResp.SessionID\n179: \n180: \tgetSandboxResp, err := m.getSandboxFromWorkloadManager(ctx, sessionID)\n181: \tif err != nil {\n182: \t\treturn \"\", nil, fmt.Errorf(\"created session but failed to get sandbox info: %w\", err)\n183: \t}\n184: \n185: \treturn sessionID, getSandboxResp, nil\n186: }\n187: \n188: func (m *manager) ListSessions(ctx context.Context) ([]*types.SandboxInfo, error) {\n189: \tsandboxes, err := m.storeClient.ListSandboxes(ctx)\n190: \tif err != nil {\n191: \t\treturn nil, fmt.Errorf(\"failed to list sessions from store: %w\", err)\n192: \t}\n193: \n194: \tresult := make([]*types.SandboxInfo, 0, len(sandboxes))\n195: \tfor _, sandbox := range sandboxes {\n196: \t\tresult = append(result, sandbox)\n197: \t}\n198: \n199: \treturn result, nil\n200: }\n201: \n202: func (m *manager) getSandboxFromWorkloadManager(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n203: \tendpoint := fmt.Sprintf(\"%s/v1/session/%s\", m.workloadMgrAddr, sessionID)\n204: \n205: \treq, err := http.NewRequestWithContext(ctx, http.MethodGet, endpoint, nil)\n206: \tif err != nil {\n207: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n208: \t}\n209: \n210: \tresp, err := m.httpClient.Do(req)\n211: \tif err != nil {\n212: \t\treturn nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusServiceUnavailable}\n213: \t}\n214: \tdefer resp.Body.Close()\n215: \n216: \tbody, err := io.ReadAll(resp.Body)\n217: \tif err != nil {\n218: \t\treturn nil, fmt.Errorf(\"failed to read response body: %w\", err)\n219: \t}\n220: \n221: \tif resp.StatusCode == http.StatusNotFound {\n222: \t\treturn nil, &SandboxNotFoundError{SessionID: sessionID}\n223: \t}\n224: \n225: \tif resp.StatusCode != http.StatusOK {\n226: \t\treturn nil, &WorkloadManagerError{\n227: \t\t\tMessage: string(body),\n228: \t\t\tCode:    resp.StatusCode,\n229: \t\t}\n230: \t}\n231: \n232: \tvar getSessionResp WorkloadManagerGetSessionResponse\n233: \tif err := json.Unmarshal(body, &getSessionResp); err != nil {\n234: \t\treturn nil, fmt.Errorf(\"failed to unmarshal get session response: %w\", err)\n235: \t}\n236: \n237: \tsandboxInfo := SandboxInfoFromWorkloadManager(&getSessionResp, sessionID)\n238: \n239: \tif err := m.storeClient.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n240: \t\tklog.Warningf(\"Failed to cache sandbox info: %v\", err)\n241: \t}\n242: \n243: \treturn sandboxInfo, nil\n244: }\n245: \n246: func (m *manager) isResourceActive(namespace string, name string, kind string) bool {\n247: \tif m.resourceCache == nil {\n248: \t\treturn true\n249: \t}\n250: \n251: \tif kind == types.AgentRuntimeKind {\n252: \t\tar, err := m.resourceCache.GetAgentRuntime(namespace, name)\n253: \t\tif err != nil || ar == nil {\n254: \t\t\treturn true\n255: \t\t}\n256: \n257: \t\tif !isResourceReady(ar.Status.Conditions) {\n258: \t\t\treturn false\n259: \t\t}\n260: \n261: \t\tif isResourceBeingDeleted(ar) {\n262: \t\t\treturn false\n263: \t\t}\n264: \n265: \t\treturn true\n266: \t} else if kind == types.CodeInterpreterKind {\n267: \t\tci, err := m.resourceCache.GetCodeInterpreter(namespace, name)\n268: \t\tif err != nil || ci == nil {\n269: \t\t\treturn true\n270: \t\t}\n271: \n272: \t\tif !ci.Status.Ready {\n273: \t\t\treturn false\n274: \t\t}\n275: \n276: \t\tif isResourceBeingDeleted(ci) {\n277: \t\t\treturn false\n278: \t\t}\n279: \n280: \t\treturn true\n281: \t}\n282: \n283: \treturn true\n284: }\n285: \n286: func isResourceReady(conditions []metav1.Condition) bool {\n287: \tif len(conditions) == 0 {\n288: \t\treturn false\n289: \t}\n290: \n291: \tfor _, cond := range conditions {\n292: \t\tif cond.Type == \"Ready\" && cond.Status == metav1.ConditionTrue {\n293: \t\t\treturn true\n294: \t\t}\n295: \t}\n296: \n297: \treturn false\n298: }\n299: \n300: func isResourceBeingDeleted(obj metav1.Object) bool {\n301: \treturn !obj.GetDeletionTimestamp().IsZero()\n302: }\n303: \n304: func conditionsChanged(oldConditions, newConditions []metav1.Condition) bool {\n305: \tif len(oldConditions) != len(newConditions) {\n306: \t\treturn true\n307: \t}\n308: \n309: \tfor i := range oldConditions {\n310: \t\tif oldConditions[i].Type != newConditions[i].Type ||\n311: \t\t\toldConditions[i].Status != newConditions[i].Status ||\n312: \t\t\toldConditions[i].Reason != newConditions[i].Reason {\n313: \t\t\treturn true\n314: \t\t}\n315: \t}\n316: \n317: \treturn false\n318: }\n319: \n320: func GetResourceStatus(conditions []metav1.Condition) string {\n321: \tif len(conditions) == 0 {\n322: \t\treturn \"Unknown\"\n323: \t}\n324: \n325: \tfor _, cond := range conditions {\n326: \t\tif cond.Type == \"Ready\" {\n327: \t\t\tif cond.Status == metav1.ConditionTrue {\n328: \t\t\t\treturn \"Ready\"\n329: \t\t\t}\n330: \t\t\treturn cond.Reason\n331: \t\t}\n332: \t}\n333: \n334: \treturn conditions[0].Type\n335: }\n\n(End of file - total 335 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\ntype SessionManager interface {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/session_manager.go","time":{"start":1775893246712,"end":1775893246730}}}}
{"type":"tool_use","timestamp":1775893246733,"sessionID":"ses_284842a70ffeQCCyWUKDRhFriu","part":{"id":"prt_d7b7c6d4e001R3KeiwqzJ6CIhz","messageID":"msg_d7b7c5e31001UdW5uavTV5KgPW","sessionID":"ses_284842a70ffeQCCyWUKDRhFriu","type":"tool","tool":"read","callID":"toolu_tool-5db1859ae10e4285b7221300b50216ca","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/pem\"\n9: \t\"fmt\"\n10: \t\"strings\"\n11: \t\"time\"\n12: \n13: \t\"github.com/golang-jwt/jwt/v5\"\n14: \tcorev1 \"k8s.io/api/core/v1\"\n15: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n16: \t\"k8s.io/client-go/kubernetes\"\n17: \t\"k8s.io/klog/v2\"\n18: )\n19: \n20: const (\n21: \tprivateKeyPEMType  = \"RSA PRIVATE KEY\"\n22: \tpublicKeyPEMType   = \"PUBLIC KEY\"\n23: \tjwtTokenExpiration = 5 * time.Minute\n24: \tjwtSecretName      = \"agentcube-jwt-keys\"\n25: )\n26: \n27: type JWTManager struct {\n28: \tprivateKey *rsa.PrivateKey\n29: \tpublicKey  *rsa.PublicKey\n30: \tclientset  kubernetes.Interface\n31: \tnamespace  string\n32: }\n33: \n34: func NewJWTManager(clientset kubernetes.Interface, namespace string) (*JWTManager, error) {\n35: \tif clientset == nil {\n36: \t\treturn nil, fmt.Errorf(\"kubernetes clientset is required\")\n37: \t}\n38: \n39: \tif namespace == \"\" {\n40: \t\tnamespace = defaultNamespace\n41: \t}\n42: \n43: \tjwtMgr := &JWTManager{\n44: \t\tclientset: clientset,\n45: \t\tnamespace: namespace,\n46: \t}\n47: \n48: \tif err := jwtMgr.tryStoreOrLoadJWTKeySecret(); err != nil {\n49: \t\tklog.Warningf(\"Failed to load or store JWT key secret: %v. Generating in-memory keys only.\", err)\n50: \t\tprivateKey, publicKey, err := generateRSAKeyPair()\n51: \t\tif err != nil {\n52: \t\t\treturn nil, fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n53: \t\t}\n54: \t\tjwtMgr.privateKey = privateKey\n55: \t\tjwtMgr.publicKey = publicKey\n56: \t}\n57: \n58: \treturn jwtMgr, nil\n59: }\n60: \n61: func (j *JWTManager) GenerateToken(sessionID string) (string, error) {\n62: \tif j.privateKey == nil {\n63: \t\treturn \"\", fmt.Errorf(\"JWT manager not initialized with private key\")\n64: \t}\n65: \n66: \tnow := time.Now()\n67: \tclaims := &JWTClaims{\n68: \t\tSessionID: sessionID,\n69: \t\tRegisteredClaims: jwt.RegisteredClaims{\n70: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n71: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(jwtTokenExpiration)),\n72: \t\t\tNotBefore: jwt.NewNumericDate(now),\n73: \t\t},\n74: \t}\n75: \n76: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n77: \ttokenString, err := token.SignedString(j.privateKey)\n78: \tif err != nil {\n79: \t\treturn \"\", fmt.Errorf(\"failed to sign JWT token: %w\", err)\n80: \t}\n81: \n82: \treturn tokenString, nil\n83: }\n84: \n85: func (j *JWTManager) ValidateToken(tokenString string) (*JWTClaims, error) {\n86: \tif j.publicKey == nil {\n87: \t\treturn nil, fmt.Errorf(\"JWT manager not initialized with public key\")\n88: \t}\n89: \n90: \ttoken, err := jwt.ParseWithClaims(tokenString, &JWTClaims{}, func(token *jwt.Token) (interface{}, error) {\n91: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n92: \t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n93: \t\t}\n94: \t\treturn j.publicKey, nil\n95: \t})\n96: \n97: \tif err != nil {\n98: \t\treturn nil, fmt.Errorf(\"failed to parse JWT token: %w\", err)\n99: \t}\n100: \n101: \tclaims, ok := token.Claims.(*JWTClaims)\n102: \tif !ok || !token.Valid {\n103: \t\treturn nil, fmt.Errorf(\"invalid JWT token claims\")\n104: \t}\n105: \n106: \tif time.Now().After(claims.ExpiresAt.Time) {\n107: \t\treturn nil, fmt.Errorf(\"JWT token has expired\")\n108: \t}\n109: \n110: \treturn claims, nil\n111: }\n112: \n113: func (j *JWTManager) tryStoreOrLoadJWTKeySecret() error {\n114: \tsecret, err := j.clientset.CoreV1().Secrets(j.namespace).Get(j.context(), jwtSecretName, metav1.GetOptions{})\n115: \tif err == nil {\n116: \t\treturn j.loadKeysFromSecret(secret)\n117: \t}\n118: \n119: \tif err != nil && !isNotFoundError(err) {\n120: \t\treturn fmt.Errorf(\"failed to check for existing JWT secret: %w\", err)\n121: \t}\n122: \n123: \treturn j.storeJWTKeySecret()\n124: }\n125: \n126: func (j *JWTManager) loadKeysFromSecret(secret *corev1.Secret) error {\n127: \tprivateKeyPEM, ok := secret.Data[\"private.pem\"]\n128: \tif !ok {\n129: \t\treturn fmt.Errorf(\"secret does not contain private.pem\")\n130: \t}\n131: \n132: \tpublicKeyPEM, ok := secret.Data[\"public.pem\"]\n133: \tif !ok {\n134: \t\treturn fmt.Errorf(\"secret does not contain public.pem\")\n135: \t}\n136: \n137: \tprivateKey, err := parsePrivateKeyPEM(privateKeyPEM)\n138: \tif err != nil {\n139: \t\treturn fmt.Errorf(\"failed to parse private key: %w\", err)\n140: \t}\n141: \n142: \tpublicKey, err := parsePublicKeyPEM(publicKeyPEM)\n143: \tif err != nil {\n144: \t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n145: \t}\n146: \n147: \tj.privateKey = privateKey\n148: \tj.publicKey = publicKey\n149: \n150: \tklog.Infof(\"Successfully loaded JWT keys from secret: %s\", jwtSecretName)\n151: \treturn nil\n152: }\n153: \n154: func (j *JWTManager) storeJWTKeySecret() error {\n155: \tprivateKey, publicKey, err := generateRSAKeyPair()\n156: \tif err != nil {\n157: \t\treturn fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n158: \t}\n159: \n160: \tprivateKeyPEM := pem.EncodeToMemory(&pem.Block{\n161: \t\tType:  privateKeyPEMType,\n162: \t\tBytes: x509.MarshalPKCS1PrivateKey(privateKey),\n163: \t})\n164: \n165: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n166: \tif err != nil {\n167: \t\treturn fmt.Errorf(\"failed to marshal public key: %w\", err)\n168: \t}\n169: \n170: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n171: \t\tType:  publicKeyPEMType,\n172: \t\tBytes: publicKeyBytes,\n173: \t})\n174: \n175: \tsecret := &corev1.Secret{\n176: \t\tObjectMeta: metav1.ObjectMeta{\n177: \t\t\tName:      jwtSecretName,\n178: \t\t\tNamespace: j.namespace,\n179: \t\t},\n180: \t\tData: map[string][]byte{\n181: \t\t\t\"private.pem\": privateKeyPEM,\n182: \t\t\t\"public.pem\":  publicKeyPEM,\n183: \t\t},\n184: \t}\n185: \n186: \t_, err = j.clientset.CoreV1().Secrets(j.namespace).Create(j.context(), secret, metav1.CreateOptions{})\n187: \tif err != nil {\n188: \t\treturn fmt.Errorf(\"failed to create JWT key secret: %w\", err)\n189: \t}\n190: \n191: \tj.privateKey = privateKey\n192: \tj.publicKey = publicKey\n193: \n194: \tklog.Infof(\"Successfully created JWT key secret: %s\", jwtSecretName)\n195: \treturn nil\n196: }\n197: \n198: func (j *JWTManager) context() context.Context {\n199: \treturn context.Background()\n200: }\n201: \n202: func generateRSAKeyPair() (*rsa.PrivateKey, *rsa.PublicKey, error) {\n203: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n204: \tif err != nil {\n205: \t\treturn nil, nil, fmt.Errorf(\"failed to generate RSA key: %w\", err)\n206: \t}\n207: \n208: \treturn privateKey, &privateKey.PublicKey, nil\n209: }\n210: \n211: func parsePrivateKeyPEM(privateKeyPEM []byte) (*rsa.PrivateKey, error) {\n212: \tblock, _ := pem.Decode(privateKeyPEM)\n213: \tif block == nil {\n214: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n215: \t}\n216: \n217: \tif block.Type != privateKeyPEMType {\n218: \t\treturn nil, fmt.Errorf(\"invalid PEM block type: %s\", block.Type)\n219: \t}\n220: \n221: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n222: \tif err != nil {\n223: \t\treturn nil, fmt.Errorf(\"failed to parse private key: %w\", err)\n224: \t}\n225: \n226: \treturn privateKey, nil\n227: }\n228: \n229: func parsePublicKeyPEM(publicKeyPEM []byte) (*rsa.PublicKey, error) {\n230: \tblock, _ := pem.Decode(publicKeyPEM)\n231: \tif block == nil {\n232: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n233: \t}\n234: \n235: \tif block.Type != publicKeyPEMType {\n236: \t\treturn nil, fmt.Errorf(\"invalid PEM block type: %s\", block.Type)\n237: \t}\n238: \n239: \tpublicKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n240: \tif err != nil {\n241: \t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n242: \t}\n243: \n244: \trsaPublicKey, ok := publicKey.(*rsa.PublicKey)\n245: \tif !ok {\n246: \t\treturn nil, fmt.Errorf(\"not an RSA public key\")\n247: \t}\n248: \n249: \treturn rsaPublicKey, nil\n250: }\n251: \n252: func isNotFoundError(err error) bool {\n253: \tif err == nil {\n254: \t\treturn false\n255: \t}\n256: \treturn strings.Contains(err.Error(), \"not found\") ||\n257: \t\tstrings.Contains(err.Error(), \"404\")\n258: }\n\n(End of file - total 258 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go","time":{"start":1775893246715,"end":1775893246731}}}}
{"type":"tool_use","timestamp":1775893246734,"sessionID":"ses_284842a70ffeQCCyWUKDRhFriu","part":{"id":"prt_d7b7c6ff30016cFkMua0nGq5JJ","messageID":"msg_d7b7c5e31001UdW5uavTV5KgPW","sessionID":"ses_284842a70ffeQCCyWUKDRhFriu","type":"tool","tool":"read","callID":"toolu_tool-dfaac6ba2ad940c2b535b611f3207546","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/proxy.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/proxy.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"io\"\n7: \t\"net/http\"\n8: \t\"net/http/httputil\"\n9: \t\"net/url\"\n10: \t\"strings\"\n11: \t\"time\"\n12: \n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: \t\"k8s.io/klog/v2\"\n15: )\n16: \n17: type ReverseProxy struct {\n18: \thttpTransport *http.Transport\n19: \tjwtManager    *JWTManager\n20: }\n21: \n22: func NewReverseProxy(jwtManager *JWTManager) *ReverseProxy {\n23: \treturn &ReverseProxy{\n24: \t\thttpTransport: configureHTTPTransport(),\n25: \t\tjwtManager:    jwtManager,\n26: \t}\n27: }\n28: \n29: func configureHTTPTransport() *http.Transport {\n30: \treturn &http.Transport{\n31: \t\tMaxIdleConns:        100,\n32: \t\tIdleConnTimeout:     90 * time.Second,\n33: \t\tDisableCompression:  false,\n34: \t\tForceAttemptHTTP2:   true,\n35: \t\tTLSHandshakeTimeout: 10 * time.Second,\n36: \t}\n37: }\n38: \n39: func (p *ReverseProxy) ProxyRequest(ctx context.Context, sandboxInfo *types.SandboxInfo, originalReq *http.Request) (*http.Response, error) {\n40: \tentryPoint := findMatchingEntryPoint(originalReq.URL.Path, sandboxInfo.EntryPoints)\n41: \tif entryPoint == nil {\n42: \t\treturn nil, fmt.Errorf(\"no matching entry point for path: %s\", originalReq.URL.Path)\n43: \t}\n44: \n45: \tupstreamURL := constructUpstreamURL(entryPoint.Protocol, entryPoint.Endpoint)\n46: \tupstreamURLParsed, err := url.Parse(upstreamURL)\n47: \tif err != nil {\n48: \t\treturn nil, fmt.Errorf(\"failed to parse upstream URL: %w\", err)\n49: \t}\n50: \n51: \ttargetPath := originalReq.URL.Path\n52: \tif originalReq.URL.RawQuery != \"\" {\n53: \t\ttargetPath = targetPath + \"?\" + originalReq.URL.RawQuery\n54: \t}\n55: \n56: \tproxyReq, err := http.NewRequestWithContext(ctx, originalReq.Method, upstreamURLParsed.String()+targetPath, originalReq.Body)\n57: \tif err != nil {\n58: \t\treturn nil, fmt.Errorf(\"failed to create proxy request: %w\", err)\n59: \t}\n60: \n61: \tp.modifyRequestHeaders(proxyReq, originalReq, sandboxInfo)\n62: \n63: \ttoken, err := p.jwtManager.GenerateToken(sandboxInfo.SessionID)\n64: \tif err != nil {\n65: \t\treturn nil, fmt.Errorf(\"failed to sign request: %w\", err)\n66: \t}\n67: \tproxyReq.Header.Set(\"Authorization\", \"Bearer \"+token)\n68: \n69: \tclient := &http.Client{\n70: \t\tTransport: p.httpTransport,\n71: \t\tTimeout:   60 * time.Second,\n72: \t}\n73: \n74: \tresp, err := client.Do(proxyReq)\n75: \tif err != nil {\n76: \t\treturn nil, &WorkloadManagerError{Message: err.Error(), Code: http.StatusBadGateway}\n77: \t}\n78: \n79: \treturn resp, nil\n80: }\n81: \n82: func (p *ReverseProxy) modifyRequestHeaders(proxyReq, originalReq *http.Request, sandboxInfo *types.SandboxInfo) {\n83: \tfor name, values := range originalReq.Header {\n84: \t\tif isHopByHopHeader(name) {\n85: \t\t\tcontinue\n86: \t\t}\n87: \n88: \t\tif strings.EqualFold(name, \"Authorization\") {\n89: \t\t\tcontinue\n90: \t\t}\n91: \n92: \t\tfor _, value := range values {\n93: \t\t\tproxyReq.Header.Add(name, value)\n94: \t\t}\n95: \t}\n96: \n97: \tproxyReq.Header.Set(\"X-Forwarded-Host\", originalReq.Host)\n98: \n99: \tif originalReq.TLS != nil {\n100: \t\tproxyReq.Header.Set(\"X-Forwarded-Proto\", \"https\")\n101: \t} else {\n102: \t\tproxyReq.Header.Set(\"X-Forwarded-Proto\", \"http\")\n103: \t}\n104: \n105: \tclientIP := originalReq.RemoteAddr\n106: \tif xff := originalReq.Header.Get(\"X-Forwarded-For\"); xff != \"\" {\n107: \t\tclientIP = xff + \", \" + clientIP\n108: \t}\n109: \tproxyReq.Header.Set(\"X-Forwarded-For\", clientIP)\n110: \n111: \tproxyReq.Header.Set(\"X-Agentcube-Session-ID\", sandboxInfo.SessionID)\n112: }\n113: \n114: func (p *ReverseProxy) CopyResponse(resp *http.Response, w http.ResponseWriter, sessionID string) {\n115: \tfor name, values := range resp.Header {\n116: \t\tif isHopByHopHeader(name) {\n117: \t\t\tcontinue\n118: \t\t}\n119: \n120: \t\tfor _, value := range values {\n121: \t\t\tw.Header().Add(name, value)\n122: \t\t}\n123: \t}\n124: \n125: \tw.Header().Set(\"X-Agentcube-Session-ID\", sessionID)\n126: \n127: \tw.WriteHeader(resp.StatusCode)\n128: \n129: \tif resp.Body != nil {\n130: \t\tdefer resp.Body.Close()\n131: \t\tif _, err := io.Copy(w, resp.Body); err != nil {\n132: \t\t\tklog.Warningf(\"Failed to copy response body: %v\", err)\n133: \t\t}\n134: \t}\n135: }\n136: \n137: func (p *ReverseProxy) ServeHTTP(w http.ResponseWriter, r *http.Request, sandboxInfo *types.SandboxInfo) {\n138: \tentryPoint := findMatchingEntryPoint(r.URL.Path, sandboxInfo.EntryPoints)\n139: \tif entryPoint == nil {\n140: \t\thttp.Error(w, \"no matching entry point\", http.StatusNotFound)\n141: \t\treturn\n142: \t}\n143: \n144: \tupstreamURL := constructUpstreamURL(entryPoint.Protocol, entryPoint.Endpoint)\n145: \tupstreamURLParsed, err := url.Parse(upstreamURL)\n146: \tif err != nil {\n147: \t\thttp.Error(w, fmt.Sprintf(\"invalid upstream URL: %v\", err), http.StatusInternalServerError)\n148: \t\treturn\n149: \t}\n150: \n151: \tdirector := func(req *http.Request) {\n152: \t\treq.URL.Scheme = upstreamURLParsed.Scheme\n153: \t\treq.URL.Host = upstreamURLParsed.Host\n154: \t\treq.URL.Path = singleJoiningSlash(upstreamURLParsed.Path, req.URL.Path)\n155: \n156: \t\tp.modifyRequestHeaders(req, r, sandboxInfo)\n157: \n158: \t\ttoken, err := p.jwtManager.GenerateToken(sandboxInfo.SessionID)\n159: \t\tif err != nil {\n160: \t\t\tklog.Warningf(\"Failed to generate JWT token: %v\", err)\n161: \t\t} else {\n162: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n163: \t\t}\n164: \t}\n165: \n166: \tproxy := &httputil.ReverseProxy{\n167: \t\tDirector:       director,\n168: \t\tTransport:      p.httpTransport,\n169: \t\tErrorHandler:   p.errorHandler,\n170: \t\tModifyResponse: p.modifyResponse,\n171: \t}\n172: \n173: \tproxy.ServeHTTP(w, r)\n174: }\n175: \n176: func (p *ReverseProxy) errorHandler(w http.ResponseWriter, r *http.Request, err error) {\n177: \tklog.Warningf(\"Proxy error: %v\", err)\n178: \n179: \tif err == context.DeadlineExceeded {\n180: \t\thttp.Error(w, \"sandbox timeout\", http.StatusGatewayTimeout)\n181: \t\treturn\n182: \t}\n183: \n184: \thttp.Error(w, \"sandbox unreachable\", http.StatusBadGateway)\n185: }\n186: \n187: func (p *ReverseProxy) modifyResponse(resp *http.Response) error {\n188: \tfor name, values := range resp.Header {\n189: \t\tif isHopByHopHeader(name) {\n190: \t\t\tresp.Header.Del(name)\n191: \t\t} else {\n192: \t\t\tfor _, value := range values {\n193: \t\t\t\tresp.Header.Set(name, value)\n194: \t\t\t}\n195: \t\t}\n196: \t}\n197: \n198: \treturn nil\n199: }\n200: \n201: func singleJoiningSlash(a, b string) string {\n202: \taslash := strings.HasSuffix(a, \"/\")\n203: \tbslash := strings.HasPrefix(b, \"/\")\n204: \tswitch {\n205: \tcase aslash && bslash:\n206: \t\treturn a + b[1:]\n207: \tcase !aslash && !bslash:\n208: \t\treturn a + \"/\" + b\n209: \t}\n210: \treturn a + b\n211: }\n\n(End of file - total 211 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"net/url\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype ReverseProxy struct {\n\thttpTransport *http.Transport\n\tjwtManager    *JWTManager\n}","truncated":false,"loaded":[]},"title":"