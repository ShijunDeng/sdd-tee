tscheme             *runtime.Scheme\n44: }\n45: \n46: func NewK8sClient(config K8sConfig) (*K8sClient, error) {\n47: \tvar kubeConfig *rest.Config\n48: \tvar err error\n49: \n50: \tif config.InCluster {\n51: \t\tkubeConfig, err = rest.InClusterConfig()\n52: \t} else if config.KubeconfigPath != \"\" {\n53: \t\tkubeConfig, err = clientcmd.BuildConfigFromFlags(\"\", config.KubeconfigPath)\n54: \t} else {\n55: \t\treturn nil, NewError(ErrK8sConfigInvalid, \"invalid kubernetes configuration\", \"either in-cluster or kubeconfig path must be specified\", nil)\n56: \t}\n57: \n58: \tif err != nil {\n59: \t\treturn nil, NewError(ErrK8sConnectionFailed, \"failed to build kubeconfig\", err.Error(), err)\n60: \t}\n61: \n62: \tdynamicClient, err := dynamic.NewForConfig(kubeConfig)\n63: \tif err != nil {\n64: \t\treturn nil, NewError(ErrK8sConnectionFailed, \"failed to create dynamic client\", err.Error(), err)\n65: \t}\n66: \n67: \tnamespace := config.Namespace\n68: \tif namespace == \"\" {\n69: \t\tif config.InCluster {\n70: \t\t\tnamespaceBytes, err := os.ReadFile(\"/var/run/secrets/kubernetes.io/serviceaccount/namespace\")\n71: \t\t\tif err != nil {\n72: \t\t\t\treturn nil, NewError(ErrK8sConfigInvalid, \"failed to read namespace from service account\", err.Error(), err)\n73: \t\t\t}\n74: \t\t\tnamespace = string(namespaceBytes)\n75: \t\t} else {\n76: \t\t\tnamespace = \"default\"\n77: \t\t}\n78: \t}\n79: \n80: \tinformerFactory := dynamicinformer.NewDynamicSharedInformerFactory(dynamicClient, time.Minute*10)\n81: \n82: \treturn &K8sClient{\n83: \t\tdynamicClient:      dynamicClient,\n84: \t\tnamespace:          namespace,\n85: \t\tagentRuntimeName:   config.AgentRuntimeName,\n86: \t\tstopCh:             make(chan struct{}),\n87: \t\tinformerFactory:    informerFactory,\n88: \t\tagentRuntimeGVR:    schema.GroupVersionResource{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\", Resource: \"agentruntimes\"},\n89: \t\tcodeInterpreterGVR: schema.GroupVersionResource{Group: \"runtime.agentcube.volcano.sh\", Version: \"v1alpha1\", Resource: \"codeinterpreters\"},\n90: \t\tscheme:             runtimeScheme,\n91: \t}, nil\n92: }\n93: \n94: func (k *K8sClient) GetAgentRuntime(ctx context.Context, name string) (*runtimev1alpha1.AgentRuntime, error) {\n95: \tobj, err := k.dynamicClient.Resource(k.agentRuntimeGVR).Namespace(k.namespace).Get(ctx, name, metav1.GetOptions{})\n96: \tif err != nil {\n97: \t\tif errors.IsNotFound(err) {\n98: \t\t\treturn nil, NewError(ErrK8sResourceNotFound, \"AgentRuntime not found\", fmt.Sprintf(\"AgentRuntime %s not found\", name), err)\n99: \t\t}\n100: \t\treturn nil, NewError(ErrK8sConnectionFailed, \"failed to get AgentRuntime\", err.Error(), err)\n101: \t}\n102: \n103: \tagentRuntime := &runtimev1alpha1.AgentRuntime{}\n104: \tif err := runtimeScheme.Convert(obj, agentRuntime, nil); err != nil {\n105: \t\treturn nil, NewError(ErrServerInternal, \"failed to convert AgentRuntime\", err.Error(), err)\n106: \t}\n107: \n108: \treturn agentRuntime, nil\n109: }\n110: \n111: func (k *K8sClient) UpdateAgentRuntimeStatus(ctx context.Context, agentRuntime *runtimev1alpha1.AgentRuntime) (*runtimev1alpha1.AgentRuntime, error) {\n112: \tunstructuredObj, err := runtime.DefaultUnstructuredConverter.ToUnstructured(agentRuntime)\n113: \tif err != nil {\n114: \t\treturn nil, NewError(ErrServerInternal, \"failed to convert to unstructured\", err.Error(), err)\n115: \t}\n116: \n117: \tupdatedObj, err := k.dynamicClient.Resource(k.agentRuntimeGVR).Namespace(k.namespace).UpdateStatus(ctx, &unstructured.Unstructured{Object: unstructuredObj}, metav1.UpdateOptions{})\n118: \tif err != nil {\n119: \t\treturn nil, NewError(ErrK8sUpdateFailed, \"failed to update AgentRuntime status\", err.Error(), err)\n120: \t}\n121: \n122: \tupdatedAgentRuntime := &runtimev1alpha1.AgentRuntime{}\n123: \tif err := runtimeScheme.Convert(updatedObj, updatedAgentRuntime, nil); err != nil {\n124: \t\treturn nil, NewError(ErrServerInternal, \"failed to convert updated AgentRuntime\", err.Error(), err)\n125: \t}\n126: \n127: \treturn updatedAgentRuntime, nil\n128: }\n129: \n130: func (k *K8sClient) GetCodeInterpreter(ctx context.Context, name string) (*runtimev1alpha1.CodeInterpreter, error) {\n131: \tobj, err := k.dynamicClient.Resource(k.codeInterpreterGVR).Namespace(k.namespace).Get(ctx, name, metav1.GetOptions{})\n132: \tif err != nil {\n133: \t\tif errors.IsNotFound(err) {\n134: \t\t\treturn nil, NewError(ErrK8sResourceNotFound, \"CodeInterpreter not found\", fmt.Sprintf(\"CodeInterpreter %s not found\", name), err)\n135: \t\t}\n136: \t\treturn nil, NewError(ErrK8sConnectionFailed, \"failed to get CodeInterpreter\", err.Error(), err)\n137: \t}\n138: \n139: \tcodeInterpreter := &runtimev1alpha1.CodeInterpreter{}\n140: \tif err := runtimeScheme.Convert(obj, codeInterpreter, nil); err != nil {\n141: \t\treturn nil, NewError(ErrServerInternal, \"failed to convert CodeInterpreter\", err.Error(), err)\n142: \t}\n143: \n144: \treturn codeInterpreter, nil\n145: }\n146: \n147: func (k *K8sClient) UpdateCodeInterpreterStatus(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter) (*runtimev1alpha1.CodeInterpreter, error) {\n148: \tunstructuredObj, err := runtime.DefaultUnstructuredConverter.ToUnstructured(codeInterpreter)\n149: \tif err != nil {\n150: \t\treturn nil, NewError(ErrServerInternal, \"failed to convert to unstructured\", err.Error(), err)\n151: \t}\n152: \n153: \tupdatedObj, err := k.dynamicClient.Resource(k.codeInterpreterGVR).Namespace(k.namespace).UpdateStatus(ctx, &unstructured.Unstructured{Object: unstructuredObj}, metav1.UpdateOptions{})\n154: \tif err != nil {\n155: \t\treturn nil, NewError(ErrK8sUpdateFailed, \"failed to update CodeInterpreter status\", err.Error(), err)\n156: \t}\n157: \n158: \tupdatedCodeInterpreter := &runtimev1alpha1.CodeInterpreter{}\n159: \tif err := runtimeScheme.Convert(updatedObj, updatedCodeInterpreter, nil); err != nil {\n160: \t\treturn nil, NewError(ErrServerInternal, \"failed to convert updated CodeInterpreter\", err.Error(), err)\n161: \t}\n162: \n163: \treturn updatedCodeInterpreter, nil\n164: }\n165: \n166: func (k *K8sClient) WatchAgentRuntimes(ctx context.Context) (watch.Interface, error) {\n167: \treturn k.dynamicClient.Resource(k.agentRuntimeGVR).Namespace(k.namespace).Watch(ctx, metav1.ListOptions{})\n168: }\n169: \n170: func (k *K8sClient) WatchCodeInterpreters(ctx context.Context) (watch.Interface, error) {\n171: \treturn k.dynamicClient.Resource(k.codeInterpreterGVR).Namespace(k.namespace).Watch(ctx, metav1.ListOptions{})\n172: }\n173: \n174: func (k *K8sClient) StartInformers() {\n175: \tk.informerFactory.Start(k.stopCh)\n176: }\n177: \n178: func (k *K8sClient) WaitForCacheSync() map[schema.GroupVersionResource]bool {\n179: \treturn k.informerFactory.WaitForCacheSync(k.stopCh)\n180: }\n181: \n182: func (k *K8sClient) Stop() {\n183: \tclose(k.stopCh)\n184: }\n185: \n186: func (k *K8sClient) GetNamespace() string {\n187: \treturn k.namespace\n188: }\n189: \n190: func (k *K8sClient) GetAgentRuntimeName() string {\n191: \treturn k.agentRuntimeName\n192: }\n193: \n194: func (k *K8sClient) SetupAgentRuntimeInformer(handler cache.ResourceEventHandler) error {\n195: \tgvr := schema.GroupVersionResource{\n196: \t\tGroup:    \"runtime.agentcube.volcano.sh\",\n197: \t\tVersion:  \"v1alpha1\",\n198: \t\tResource: \"agentruntimes\",\n199: \t}\n200: \tinformer := k.informerFactory.ForResource(gvr).Informer()\n201: \tinformer.AddEventHandler(handler)\n202: \tklog.Infof(\"AgentRuntime informer set up for namespace: %s\", k.namespace)\n203: \treturn nil\n204: }\n205: \n206: func (k *K8sClient) SetupCodeInterpreterInformer(handler cache.ResourceEventHandler) error {\n207: \tgvr := schema.GroupVersionResource{\n208: \t\tGroup:    \"runtime.agentcube.volcano.sh\",\n209: \t\tVersion:  \"v1alpha1\",\n210: \t\tResource: \"codeinterpreters\",\n211: \t}\n212: \tinformer := k.informerFactory.ForResource(gvr).Informer()\n213: \tinformer.AddEventHandler(handler)\n214: \tklog.Infof(\"CodeInterpreter informer set up for namespace: %s\", k.namespace)\n215: \treturn nil\n216: }\n217: \n218: func (k *K8sClient) GetScheme() *runtime.Scheme {\n219: \treturn k.scheme\n220: }\n\n(End of file - total 220 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"time\"\n\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/apimachinery/pkg/watch\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/dynamic/dynamicinformer\"\n\t\"k8s.io/client-go/kubernetes/scheme\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/client-go/tools/cache\"\n\t\"k8s.io/client-go/tools/clientcmd\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/k8s_integration.go","time":{"start":1775893297501,"end":1775893297517}}}}
