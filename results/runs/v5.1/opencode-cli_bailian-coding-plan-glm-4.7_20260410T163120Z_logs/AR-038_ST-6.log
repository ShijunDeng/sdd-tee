ace {\n36: \tDiscovery() discovery.DiscoveryInterface\n37: \tRuntimeV1alpha1() runtimev1alpha1.RuntimeV1alpha1Interface\n38: }\n39: \n40: type Clientset struct {\n41: \t*discovery.DiscoveryClient\n42: \truntimeV1alpha1 *runtimev1alpha1.RuntimeV1alpha1Client\n43: }\n44: \n45: func New(c *rest.Config) (*Clientset, error) {\n46: \tconfigShallowCopy := *c\n47: \tif configShallowCopy.UserAgent == \"\" {\n48: \t\tconfigShallowCopy.UserAgent = rest.DefaultKubernetesUserAgent()\n49: \t}\n50: \n51: \tdiscoveryClient, err := discovery.NewDiscoveryClientForConfig(&configShallowCopy)\n52: \tif err != nil {\n53: \t\treturn nil, err\n54: \t}\n55: \n56: \tvar cs Clientset\n57: \tcs.runtimeV1alpha1, err = runtimev1alpha1.NewForConfig(&configShallowCopy)\n58: \tif err != nil {\n59: \t\treturn nil, err\n60: \t}\n61: \n62: \tcs.DiscoveryClient = discoveryClient\n63: \treturn &cs, nil\n64: }\n65: \n66: func NewForConfig(c *rest.Config) (*Clientset, error) {\n67: \tconfigShallowCopy := *c\n68: \tif configShallowCopy.RateLimiter == nil && configShallowCopy.QPS > 0 {\n69: \t\tif configShallowCopy.Burst <= 0 {\n70: \t\t\treturn nil, fmt.Errorf(\"burst is required to be greater than 0 when RateLimiter is not set and QPS is set to greater than 0\")\n71: \t\t}\n72: \t\tconfigShallowCopy.RateLimiter = createDefaultRateLimiter(configShallowCopy.QPS, configShallowCopy.Burst)\n73: \t}\n74: \n75: \tvar cs Clientset\n76: \tvar err error\n77: \tcs.runtimeV1alpha1, err = runtimev1alpha1.NewForConfig(&configShallowCopy)\n78: \tif err != nil {\n79: \t\treturn nil, err\n80: \t}\n81: \tcs.DiscoveryClient, err = discovery.NewDiscoveryClientForConfig(&configShallowCopy)\n82: \tif err != nil {\n83: \t\treturn nil, err\n84: \t}\n85: \treturn &cs, nil\n86: }\n87: \n88: func NewForConfigAndClient(c *rest.Config, httpClient *rest.HttpClient) (*Clientset, error) {\n89: \tconfigShallowCopy := *c\n90: \tif configShallowCopy.RateLimiter == nil && configShallowCopy.QPS > 0 {\n91: \t\tif configShallowCopy.Burst <= 0 