 }\n47: \n48: func (p *LabelChangedPredicate) Update(e event.UpdateEvent) bool {\n49: \tif e.ObjectOld == nil || e.ObjectNew == nil {\n50: \t\treturn false\n51: \t}\n52: \n53: \toldLabels := e.ObjectOld.GetLabels()\n54: \tnewLabels := e.ObjectNew.GetLabels()\n55: \n56: \tif len(oldLabels) != len(newLabels) {\n57: \t\treturn true\n58: \t}\n59: \n60: \tfor k, v := range oldLabels {\n61: \t\tif newLabels[k] != v {\n62: \t\t\treturn true\n63: \t\t}\n64: \t}\n65: \n66: \treturn false\n67: }\n68: \n69: type AnnotationChangedPredicate struct {\n70: \tpredicate.Funcs\n71: }\n72: \n73: func (p *AnnotationChangedPredicate) Update(e event.UpdateEvent) bool {\n74: \tif e.ObjectOld == nil || e.ObjectNew == nil {\n75: \t\treturn false\n76: \t}\n77: \n78: \toldAnnotations := e.ObjectOld.GetAnnotations()\n79: \tnewAnnotations := e.ObjectNew.GetAnnotations()\n80: \n81: \tif len(oldAnnotations) != len(newAnnotations) {\n82: \t\treturn true\n83: \t}\n84: \n85: \tfor k, v := range oldAnnotations {\n86: \t\tif newAnnotations[k] != v {\n87: \t\t\treturn true\n88: \t\t}\n89: \t}\n90: \n91: \treturn false\n92: }\n93: \n94: type PauseAnnotationPredicate struct {\n95: \tpredicate.Funcs\n96: }\n97: \n98: func (p *PauseAnnotationPredicate) Update(e event.UpdateEvent) bool {\n99: \tif e.ObjectNew == nil {\n100: \t\treturn false\n101: \t}\n102: \n103: \treturn !p.isPaused(e.ObjectNew.GetAnnotations())\n104: }\n105: \n106: func (p *PauseAnnotationPredicate) Create(e event.CreateEvent) bool {\n107: \tif e.Object == nil {\n108: \t\treturn false\n109: \t}\n110: \n111: \treturn !p.isPaused(e.Object.GetAnnotations())\n112: }\n113: \n114: func (p *PauseAnnotationPredicate) Delete(e event.DeleteEvent) bool {\n115: \treturn true\n116: }\n117: \n118: func (p *PauseAnnotationPredicate) isPaused(annotations map[string]string) bool {\n119: \tif annotations == nil {\n120: \t\treturn false\n121: \t}\n122: \n123: \tval, ok := annotations[\"agentcube.volcano.sh/paused\"]\n124: \treturn ok && val == \"true\"\n125