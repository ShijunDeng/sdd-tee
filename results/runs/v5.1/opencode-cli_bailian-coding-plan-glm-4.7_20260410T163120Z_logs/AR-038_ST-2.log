&ReconcilerError{\n44: \t\tCode:      ErrCodeValidationFailed,\n45: \t\tMessage:   message,\n46: \t\tErr:       err,\n47: \t\tRetryable: false,\n48: \t}\n49: }\n50: \n51: func NewSandboxCreateFailedError(message string, err error) *ReconcilerError {\n52: \treturn &ReconcilerError{\n53: \t\tCode:      ErrCodeSandboxCreateFailed,\n54: \t\tMessage:   message,\n55: \t\tErr:       err,\n56: \t\tRetryable: true,\n57: \t}\n58: }\n59: \n60: func NewSandboxUpdateFailedError(message string, err error) *ReconcilerError {\n61: \treturn &ReconcilerError{\n62: \t\tCode:      ErrCodeSandboxUpdateFailed,\n63: \t\tMessage:   message,\n64: \t\tErr:       err,\n65: \t\tRetryable: true,\n66: \t}\n67: }\n68: \n69: func NewSandboxDeleteFailedError(message string, err error) *ReconcilerError {\n70: \treturn &ReconcilerError{\n71: \t\tCode:      ErrCodeSandboxDeleteFailed,\n72: \t\tMessage:   message,\n73: \t\tErr:       err,\n74: \t\tRetryable: true,\n75: \t}\n76: }\n77: \n78: func NewStatusUpdateFailedError(message string, err error) *ReconcilerError {\n79: \treturn &ReconcilerError{\n80: \t\tCode:      ErrCodeStatusUpdateFailed,\n81: \t\tMessage:   message,\n82: \t\tErr:       err,\n83: \t\tRetryable: true,\n84: \t}\n85: }\n86: \n87: func NewFinalizerFailedError(message string, err error) *ReconcilerError {\n88: \treturn &ReconcilerError{\n89: \t\tCode:      ErrCodeFinalizerFailed,\n90: \t\tMessage:   message,\n91: \t\tErr:       err,\n92: \t\tRetryable: true,\n93: \t}\n94: }\n\n(End of file - total 94 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport \"fmt\"\n\ntype ReconcilerError struct {\n\tCode      string\n\tMessage   string\n\tErr       error\n\tRetryable bool\n}\n\nfunc (e *ReconcilerError) Error() string {\n\tif e.Err != nil {\n\t\treturn fmt.Sprintf(\"%s: %s (caused by: %v)\", e.Code, e.Message, e.Err)\n\t}\n\treturn fmt.Sprintf(\"%s: %s\", e.Code, e.Message)\n}\n\nfunc (e *ReconcilerError) Unwrap() error {\n\treturn e.Err","truncated":false,"loaded":[]},