eAfter:            defaultRequeue,\n43: \t\tMaxConcurrentReconciles: 2,\n44: \t\tSyncPeriod:              nil,\n45: \t\tEnableLeaderElection:    true,\n46: \t\tLeaderElectionID:        \"agentcube-reconciler\",\n47: \t\tLeaderElectionNamespace: \"agentcube-system\",\n48: \t\tMetricsAddr:             \":8080\",\n49: \t\tEnableProfiling:         true,\n50: \t\tProbeAddr:               \":8081\",\n51: \t}\n52: }\n53: \n54: func NewControllerManager(cfg *rest.Config, controllerCfg *ControllerConfig) (ctrl.Manager, error) {\n55: \topts := ctrl.Options{\n56: \t\tScheme:                  scheme,\n57: \t\tMetricsBindAddress:      controllerCfg.MetricsAddr,\n58: \t\tPort:                    9443,\n59: \t\tLeaderElection:          controllerCfg.EnableLeaderElection,\n60: \t\tLeaderElectionID:        controllerCfg.LeaderElectionID,\n61: \t\tLeaderElectionNamespace: controllerCfg.LeaderElectionNamespace,\n62: \t\tSyncPeriod:              controllerCfg.SyncPeriod,\n63: \t}\n64: \n65: \tmgr, err := ctrl.NewManager(cfg, opts)\n66: \tif err != nil {\n67: \t\treturn nil, fmt.Errorf(\"unable to start manager: %w\", err)\n68: \t}\n69: \n70: \treturn mgr, nil\n71: }\n72: \n73: type SetupFunc func(mgr ctrl.Manager, cli client.Client, cfg *ControllerConfig) error\n74: \n75: func SetupWithManager(mgr ctrl.Manager, cli client.Client, cfg *ControllerConfig) error {\n76: \tif err := setupAgentRuntimeReconciler(mgr, cli, cfg); err != nil {\n77: \t\treturn fmt.Errorf(\"failed to setup AgentRuntime reconciler: %w\", err)\n78: \t}\n79: \n80: \tif err := setupCodeInterpreterReconciler(mgr, cli, cfg); err != nil {\n81: \t\treturn fmt.Errorf(\"failed to setup CodeInterpreter reconciler: %w\", err)\n82: \t}\n83: \n84: \treturn nil\n85: }\n86: \n87: func setupAgentRuntimeReconciler(mgr ctrl.Manager, cli client.Client, cfg *ControllerConfig) error {\n88: \treconciler := &AgentRuntimeReconciler{\n89: \t\tClient:       cli,\n90: \t\tScheme:       mgr.GetScheme(),\n91: \t\tRecorder:     mgr.GetEventRecorderFor(\"agentruntime-reconciler\"),\n92: \t\tRequeueAfter: cfg.RequeueAfter,\n93: \t}\n94: \n95: \tbuilder := ctrl.NewControllerManagedBy(mgr).\n96: \t\tFor(&runtimev1alpha1.AgentRuntime{}).\n97: \t\tWithEventFilter(&ResourceGenerationChangedPredicate{}).\n98: \t\tWithOptions(ctrl.Options{MaxConcurrentReconciles: cfg.MaxConcurrentReconciles})\n99: \n100: \tif err := builder.Complete(reconciler); err != nil {\n101: \t\treturn err\n102: \t}\n103: \n104: \treturn nil\n105: }\n106: \n107: func setupCodeInterpreterReconciler(mgr ctrl.Manager, cli client.Client, cfg *ControllerConfig) error {\n108: \treconciler := &CodeInterpreterReconciler{\n109: \t\tClient:       cli,\n110: \t\tScheme:       mgr.GetScheme(),\n111: \t\tRecorder:     mgr.GetEventRecorderFor(\"codeinterpreter-reconciler\"),\n112: \t\tRequeueAfter: cfg.RequeueAfter,\n113: \t}\n114: \n115: \tbuilder := ctrl.NewControllerManagedBy(mgr).\n116: \t\tFor(&runtimev1alpha1.CodeInterpreter{}).\n117: \t\tWithEventFilter(&ResourceGenerationChangedPredicate{}).\n118: \t\tWithOptions(ctrl.Options{MaxConcurrentReconciles: cfg.MaxConcurrentReconciles})\n119: \n120: \tif err := builder.Complete(reconciler); err != nil {\n121: \t\treturn err\n122: \t}\n123: \n124: \treturn nil\n125: }\n126: \n127: func StartManager(mgr manager.Manager) error {\n128: \tctx := ctrl.SetupSignalHandler()\n129: \n130: \tlogger := mgr.GetLogger()\n131: \tlogger.Info(\"starting manager\")\n132: \n133: \tif err := mgr.Start(ctx); err != nil {\n134: \t\treturn fmt.Errorf(\"problem running manager: %w\", err)\n135: \t}\n136: \n137: \treturn nil\n138: }\n139: \n140: type SandboxResult struct {\n141: \tCreated bool\n142: \tUpdated bool\n143: }\n144: \n145: func GetSandboxName(workloadName string) string {\n146: \treturn fmt.Sprintf(\"%s-sandbox\", workloadName)\n147: }\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"package reconciler\n\nimport (\n\t\"fmt\"\n\t\"time\"\n\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tutilruntime \"k8