views().Create(ctx, tokenReview, metav1.CreateOptions{})\n52: \tif err != nil {\n53: \t\treturn nil, fmt.Errorf(\"token review failed: %w\", err)\n54: \t}\n55: \n56: \tif !resp.Status.Authenticated {\n57: \t\treturn nil, fmt.Errorf(\"token authentication failed\")\n58: \t}\n59: \n60: \treturn &AuthenticationInfo{\n61: \t\tUsername: resp.Status.User.Username,\n62: \t\tUID:      resp.Status.User.UID,\n63: \t\tGroups:   resp.Status.User.Groups,\n64: \t}, nil\n65: }\n66: \n67: func NewTokenCache(ttl time.Duration) *TokenCache {\n68: \treturn &TokenCache{\n69: \t\tcache: make(map[string]*cacheEntry),\n70: \t\tttl:   ttl,\n71: \t}\n72: }\n73: \n74: func (c *TokenCache) Get(token string) (*AuthenticationInfo, bool) {\n75: \tc.mu.RLock()\n76: \tdefer c.mu.RUnlock()\n77: \n78: \tentry, exists := c.cache[token]\n79: \tif !exists {\n80: \t\treturn nil, false\n81: \t}\n82: \n83: \tif time.Now().After(entry.expiresAt) {\n84: \t\treturn nil, false\n85: \t}\n86: \n87: \treturn entry.info, true\n88: }\n89: \n90: func (c *TokenCache) Put(token string, info *AuthenticationInfo) {\n91: \tc.mu.Lock()\n92: \tdefer c.mu.Unlock()\n93: \n94: \tc.cache[token] = &cacheEntry{\n95: \t\tinfo:      info,\n96: \t\texpiresAt: time.Now().Add(c.ttl),\n97: \t}\n98: }\n99: \n100: func (c *TokenCache) Delete(token string) {\n101: \tc.mu.Lock()\n102: \tdefer c.mu.Unlock()\n103: \n104: \tdelete(c.cache, token)\n105: }\n106: \n107: func (c *TokenCache) Cleanup() {\n108: \tc.mu.Lock()\n109: \tdefer c.mu.Unlock()\n110: \n111: \tnow := time.Now()\n112: \tfor token, entry := range c.cache {\n113: \t\tif now.After(entry.expiresAt) {\n114: \t\t\tdelete(c.cache, token)\n115: \t\t}\n116: \t}\n117: }\n\n(End of file - total 117 lines)\n</content>","metadata":{"preview":"package auth\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"time\"\n\n\tauthenticationv1 \"k8s.io/api/authentication/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n)\n\ntype K8sAuthenticator stru