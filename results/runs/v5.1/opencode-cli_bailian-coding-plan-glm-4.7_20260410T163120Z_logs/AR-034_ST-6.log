agged$(NC)\"\n97: \n98: .PHONY: docker-run-agentd\n99: docker-run-agentd: docker-build-agentd ## Build and run agentd container\n100: \t@echo \"$(BLUE)Running agentd container...$(NC)\"\n101: \t$(DOCKER) run --rm -it $(DOCKER_REGISTRY)$(IMAGE_NAME)-agentd:latest\n102: \n103: .PHONY: docker-run-picod\n104: docker-run-picod: docker-build-picod ## Build and run picod container\n105: \t@echo \"$(BLUE)Running picod container...$(NC)\"\n106: \t$(DOCKER) run --rm -it $(DOCKER_REGISTRY)$(IMAGE_NAME)-picod:latest\n107: \n108: .PHONY: docker-run-agentcube\n109: docker-run-agentcube: docker-build-agentcube ## Build and run agentcube container\n110: \t@echo \"$(BLUE)Running agentcube container...$(NC)\"\n111: \t$(DOCKER) run --rm -it $(DOCKER_REGISTRY)$(IMAGE_NAME):latest\n112: \n113: .PHONY: docker-clean\n114: docker-clean: ## Clean Docker images and containers\n115: \t@echo \"$(BLUE)Cleaning Docker resources...$(NC)\"\n116: \t@$(DOCKER) system prune -f\n117: \t@$(DOCKER) image prune -f\n118: \t@echo \"$(GREEN)✓ Docker resources cleaned$(NC)\"\n119: \n120: .PHONY: docker-clean-all\n121: docker-clean-all: ## Clean all Docker resources including volumes\n122: \t@echo \"$(BLUE)Cleaning all Docker resources...$(NC)\"\n123: \t@$(DOCKER) system prune -af --volumes\n124: \t@echo \"$(GREEN)✓ All Docker resources cleaned$(NC)\"\n125: \n126: .PHONY: docker-login\n127: docker-login: ## Login to Docker registry\n128: \t@echo \"$(BLUE)Logging in to Docker registry...$(NC)\"\n129: \t$(DOCKER) login $(DOCKER_REGISTRY)\n130: \t@echo \"$(GREEN)✓ Logged in$(NC)\"\n131: \n132: .PHONY: docker-logout\n133: docker-logout: ## Logout from Docker registry\n134: \t@echo \"$(BLUE)Logging out from Docker registry...$(NC)\"\n135: \t$(DOCKER) logout $(DOCKER_REGISTRY)\n136: \t@echo \"$(GREEN)✓ Logged out$(NC)\"\n137: \n138: .PHONY: docker-images\n139: docker-images: ## List all AgentCube Docker images\n140: \t@echo \"$(BLUE)AgentCube Docker Images:$(NC)\"\n141: \t@$(DOCKER) images | grep agentcube || echo 