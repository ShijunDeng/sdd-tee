st Copyright workflow verifies headers.\"\"\"\n223:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"copyright.yml\"\n224:     with open(workflow_file, 'r') as f:\n225:         content = yaml.safe_load(f)\n226: \n227:     job = content['jobs']['copyright-check']\n228:     steps = job['steps']\n229: \n230:     assert any('make gen-copyright' in str(step) for step in steps)\n231:     assert any('git diff --exit-code' in str(step) for step in steps)\n232: \n233: \n234: def test_release_workflow_builds_multiarch():\n235:     \"\"\"Test Release workflow builds multi-architecture images.\"\"\"\n236:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n237:     with open(workflow_file, 'r') as f:\n238:         content = yaml.safe_load(f)\n239: \n240:     job = content['jobs']['release']\n241:     steps = job['steps']\n242: \n243:     assert any('docker-buildx-push' in str(step) for step in steps)\n244:     assert any('docker-buildx-push-router' in str(step) for step in steps)\n245:     assert any('docker-buildx-push-picod' in str(step) for step in steps)\n246: \n247: \n248: def test_release_workflow_triggers_on_main_and_tags():\n249:     \"\"\"Test Release workflow triggers on main and tags.\"\"\"\n250:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n251:     with open(workflow_file, 'r') as f:\n252:         content = yaml.safe_load(f)\n253: \n254:     # Get triggers (handle YAML 'on' keyword)\n255:     triggers = content.get('on', content.get(True, {}))\n256:     assert 'push' in triggers\n257:     assert 'main' in triggers['push']['branches']\n258:     assert 'v*.*.*' in triggers['push']['tags']\n259: \n260: \n261: def test_release_workflow_uses_ghcr():\n262:     \"\"\"Test Release workflow uses GitHub Container Registry.\"\"\"\n263:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"r