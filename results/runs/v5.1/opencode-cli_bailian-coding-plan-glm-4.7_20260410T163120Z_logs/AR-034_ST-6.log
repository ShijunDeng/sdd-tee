agentcube-util\n30: \t@echo \"$(GREEN)✓ agentcube-util built successfully$(NC)\"\n31: \n32: .PHONY: build-code-interpreter\n33: build-code-interpreter: ## Build code-interpreter binary\n34: \t@echo \"$(BLUE)Building code-interpreter...$(NC)\"\n35: \t@mkdir -p $(BUILD_DIR)/$(PLATFORM)\n36: \t$(GO) build $(GOFLAGS) $(GO_BUILD_FLAGS) -o $(CODE_INTERPRETER_BIN) ./cmd/code-interpreter\n37: \t@echo \"$(GREEN)✓ code-interpreter built successfully$(NC)\"\n38: \n39: .PHONY: build-agent-runtime\n40: build-agent-runtime: ## Build agent-runtime binary\n41: \t@echo \"$(BLUE)Building agent-runtime...$(NC)\"\n42: \t@mkdir -p $(BUILD_DIR)/$(PLATFORM)\n43: \t$(GO) build $(GOFLAGS) $(GO_BUILD_FLAGS) -o $(AGENT_RUNTIME_BIN) ./cmd/agent-runtime\n44: \t@echo \"$(GREEN)✓ agent-runtime built successfully$(NC)\"\n45: \n46: .PHONY: build-go-race\n47: build-go-race: ## Build all Go binaries with race detector\n48: \t@$(MAKE) BUILD_MODE=race build-go\n49: \n50: .PHONY: build-go-debug\n51: build-go-debug: ## Build all Go binaries with debug symbols\n52: \t@$(MAKE) GO_BUILD_FLAGS=\"-gcflags='all=-N -l'\" build-go\n53: \n54: .PHONY: build-go-release\n55: build-go-release: ## Build all Go binaries in release mode\n56: \t@$(MAKE) BUILD_MODE=release build-go\n57: \n58: .PHONY: build-go-fast\n59: build-go-fast: ## Build all Go binaries quickly (skip non-essential checks)\n60: \t@$(MAKE) GO_BUILD_FLAGS=\"\" build-go\n61: \n62: .PHONY: build-matrix-go\n63: build-matrix-go: ## Build Go binaries for all supported platforms\n64: \t@echo \"$(BLUE)Building Go binaries for all platforms...$(NC)\"\n65: \t@$(MAKE) GOOS=linux GOARCH=amd64 build-go\n66: \t@$(MAKE) GOOS=linux GOARCH=arm64 build-go\n67: \t@$(MAKE) GOOS=darwin GOARCH=amd64 build-go\n68: \t@$(MAKE) GOOS=darwin GOARCH=arm64 build-go\n69: \t@echo \"$(GREEN)✓ All platform builds completed$(NC)\"\n70: \n71: .PHONY: install-go\n72: install-go: build-go ## Install Go binaries to GOPATH/bin\n73: \t@echo \"$(BLUE)Installing Go binaries...$(NC)\"\n74: \t@cp $(BUILD_DIR)/$(PLATFORM)/agentd $$($(GO) env GOPATH)/bin/\n75: \t@cp $(BUILD_DIR)/$(PLATFORM)/picod $$($(GO) env GOPATH)/bin/\n76: \t@cp $(BUILD_DIR)/$(PLATFORM)/agentcube $$($(GO) env GOPATH)/bin/\n77: \t@cp $(BUILD_DIR)/$(PLATFORM)/agentcube-util $$($(GO) env GOPATH)/bin/\n78: \t@cp $(BUILD_DIR)/$(PLATFORM)/code-interpreter $$($(GO) env GOPATH)/bin/\n79: \t@cp $(BUILD_DIR)/$(PLATFORM)/agent-runtime $$($(GO) env GOPATH)/bin/\n80: \t@echo \"$(GREEN)✓ Go binaries installed$(NC)\"\n81: \n82: .PHONY: run-agentd\n83: run-agentd: build-agentd ## Build and run agentd\n84: \t@echo \"$(BLUE)Running agentd...$(NC)\"\n85: \t@$(AGENTD_BIN)\n86: \n87: .PHONY: run-picod\n88: run-picod: build-picod ## Build and run picod\n89: \t@echo \"$(BLUE)Running picod...$(NC)\"\n90: \t@$(PICOD_BIN)\n91: \n92: .PHONY: run-agentcube\n93: run-agentcube: build-agentcube ## Build and run agentcube CLI\n94: \t@echo \"$(BLUE)Running agentcube CLI...$(NC)\"\n95: \t@$(AGENTCUBE_CLI_BIN) $(ARGS)\n96: \n97: .PHONY: go-version\n98: go-version: ## Show Go version\n99: \t@$(GO) version\n100: \n101: .PHONY: go-mod-tidy\n102: go-mod-tidy: ## Tidy Go module dependencies\n103: \t@echo \"$(BLUE)Tidying Go modules...$(NC)\"\n104: \t@$(GO) mod tidy\n105: \t@echo \"$(GREEN)✓ Go modules tidied$(NC)\"\n106: \n107: .PHONY: go-mod-verify\n108: go-mod-verify: ## Verify Go module dependencies\n109: \t@echo \"$(BLUE)Verifying Go modules...$(NC)\"\n110: \t@$(GO) mod verify\n111: \t@echo \"$(GREEN)✓ Go modules verified$(NC)\"\n112: \n113: .PHONY: go-mod-download\n114: go-mod-download: ## Download Go module dependencies\n115: \t@echo \"$(BLUE)Downloading Go modules...$(NC)\"\n116: \t@$(GO) mod download\n117: \t@echo \"$(GREEN)✓ Go modules downloaded$(NC)\"\n118: \n119: .PHONY: go-mod-graph\n120: go-mod-graph: ## Show Go module dependency graph\n121: \t@$(GO) mod graph\n122: \n123: .PHONY: go-mod-why\n124: go-mod-why: ## Explain why a package is needed (usage: make go-mod-why PACKAGE=github.com/some/package)\n125: \t@$(GO) mod why $(PACKAGE)\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":".PHONY: build-go\nbuild-go: build-agentd build-picod build-agentcube build-agentcube-util build-code-interpreter build-agent-runtime ## Build all Go binaries\n\n.PHONY: build-agentd\nbuild-agentd: ## Build agentd binary\n\t@echo \"$(BLUE)Building agentd...$(NC)\"\n\t@mkdir -p $(BUILD_DIR)/$(PLATFORM)\n\t$(GO) build $(GOFLAGS) $(GO_BUILD_FLAGS) -o $(AGENTD_BIN) ./cmd/agentd\n\t@echo \"$(GREEN)✓ agentd built successfully$(NC)\"\n\n.PHONY: build-picod\nbuild-picod: ## Build picod binary\n\t@echo \"$(BLUE)Building picod...$(NC)\"\n\t@mkdir -p $(BUILD_DIR)/$(PLATFORM)\n\t$(GO) build $(GOFLAGS) $(GO_BUILD_FLAGS) -o $(PICOD_BIN) ./cmd/picod\n\t@echo \"$(GREEN)✓ picod built successfully$(NC)\"\n\n.PHONY: build-agentcube\nbuild-agentcube: ## Build agentcube CLI binary\n\t@echo \"$(BLUE)Building agentcube CLI...$(NC)\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/.makefiles/go.mk","time":{"start":1775886416653,"end":1775886416669}}}}
