{"type":"tool_use","timestamp":1775886384332,"sessionID":"ses_284ed1db4ffef84KWPn8fGNBw4","part":{"id":"prt_d7b13bab1001UuvUByAsf55N5s","messageID":"msg_d7b13b24d001N7Lr1TpHH115fD","sessionID":"ses_284ed1db4ffef84KWPn8fGNBw4","type":"tool","tool":"read","callID":"toolu_tool-a48fe51c5dc741a88a5c0c62bf3940b7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/github/test_workflows.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/github/test_workflows.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Unit tests for GitHub Actions workflows.\"\"\"\n2: import os\n3: import yaml\n4: import pytest\n5: from pathlib import Path\n6: \n7: \n8: def get_workflow_files():\n9:     \"\"\"Get all workflow YAML files.\"\"\"\n10:     workflows_dir = Path(__file__).parent.parent.parent / \".github\" / \"workflows\"\n11:     return list(workflows_dir.glob(\"*.yml\"))\n12: \n13: \n14: def test_all_workflows_have_valid_yaml():\n15:     \"\"\"Test that all workflow files have valid YAML syntax.\"\"\"\n16:     for workflow_file in get_workflow_files():\n17:         with open(workflow_file, 'r') as f:\n18:             try:\n19:                 yaml.safe_load(f)\n20:             except yaml.YAMLError as e:\n21:                 pytest.fail(f\"Invalid YAML in {workflow_file}: {e}\")\n22: \n23: \n24: def test_all_workflows_have_required_fields():\n25:     \"\"\"Test that all workflows have required top-level fields.\"\"\"\n26:     for workflow_file in get_workflow_files():\n27:         with open(workflow_file, 'r') as f:\n28:             content = yaml.safe_load(f)\n29: \n30:         assert 'name' in content, f\"{workflow_file} missing 'name' field\"\n31:         # 'on' is a boolean keyword in YAML, so check both 'on' and True\n32:         assert 'on' in content or True in content, f\"{workflow_file} missing 'on' field\"\n33:         assert 'permissions' in content, f\"{workflow_file} missing 'permissions' field\"\n34:         assert 'jobs' in content, f\"{workflow_file} missing 'jobs' field\"\n35: \n36: \n37: def test_ci_workflow_triggers():\n38:     \"\"\"Test CI workflow triggers on correct branches.\"\"\"\n39:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"ci.yml\"\n40:     with open(workflow_file, 'r') as f:\n41:         content = yaml.safe_load(f)\n42: \n43:     # Get triggers (handle YAML 'on' keyword)\n44:     triggers = content.get('on', content.get(True, {}))\n45:     assert 'pull_request' in triggers\n46:     assert 'main' in triggers['pull_request']['branches']\n47:     assert 'release-*' in triggers['pull_request']['branches']\n48: \n49: \n50: def test_ci_workflow_builds_docker():\n51:     \"\"\"Test CI workflow includes Docker build step.\"\"\"\n52:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"ci.yml\"\n53:     with open(workflow_file, 'r') as f:\n54:         content = yaml.safe_load(f)\n55: \n56:     job = content['jobs']['docker-build']\n57:     steps = [step['name'] if 'name' in step else list(step.keys())[0] for step in job['steps']]\n58: \n59:     assert 'Build Docker image' in steps\n60:     assert any('make docker-build' in str(step) for step in job['steps'])\n61: \n62: \n63: def test_lint_workflow_path_filtering():\n64:     \"\"\"Test Lint workflow has correct path filtering.\"\"\"\n65:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"lint.yml\"\n66:     with open(workflow_file, 'r') as f:\n67:         content = yaml.safe_load(f)\n68: \n69:     # Get triggers (handle YAML 'on' keyword)\n70:     triggers = content.get('on', content.get(True, {}))\n71:     assert 'pull_request' in triggers\n72:     paths = triggers['pull_request']['paths']\n73: \n74:     assert '**/*.go' in paths\n75:     assert 'go.mod' in paths\n76:     assert 'go.sum' in paths\n77: \n78: \n79: def test_lint_workflow_runs_golangci_lint():\n80:     \"\"\"Test Lint workflow runs golangci-lint.\"\"\"\n81:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"lint.yml\"\n82:     with open(workflow_file, 'r') as f:\n83:         content = yaml.safe_load(f)\n84: \n85:     job = content['jobs']['golangci-lint']\n86:     steps = job['steps']\n87: \n88:     assert any('make lint' in str(step) for step in steps)\n89: \n90: \n91: def test_codegen_workflow_checks_drift():\n92:     \"\"\"Test Codegen Check workflow verifies no drift.\"\"\"\n93:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"codegen-check.yml\"\n94:     with open(workflow_file, 'r') as f:\n95:         content = yaml.safe_load(f)\n96: \n97:     job = content['jobs']['codegen-check']\n98:     steps = job['steps']\n99: \n100:     assert any('make gen-check' in str(step) for step in steps)\n101:     assert any('git diff --exit-code' in str(step) for step in steps)\n102: \n103: \n104: def test_coverage_workflow_race_detection():\n105:     \"\"\"Test Coverage workflow runs with race detection.\"\"\"\n106:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"coverage.yml\"\n107:     with open(workflow_file, 'r') as f:\n108:         content = yaml.safe_load(f)\n109: \n110:     job = content['jobs']['coverage']\n111:     steps = job['steps']\n112: \n113:     assert any('-race' in str(step) and 'go test' in str(step) for step in steps)\n114: \n115: \n116: def test_coverage_workflow_uploads_artifact():\n117:     \"\"\"Test Coverage workflow uploads coverage artifact.\"\"\"\n118:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"coverage.yml\"\n119:     with open(workflow_file, 'r') as f:\n120:         content = yaml.safe_load(f)\n121: \n122:     job = content['jobs']['coverage']\n123:     steps = job['steps']\n124: \n125:     assert any('upload-artifact' in str(step) for step in steps)\n126: \n127: \n128: def test_e2e_workflow_uses_kind():\n129:     \"\"\"Test E2E workflow uses Kind cluster.\"\"\"\n130:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"e2e.yml\"\n131:     with open(workflow_file, 'r') as f:\n132:         content = yaml.safe_load(f)\n133: \n134:     job = content['jobs']['e2e']\n135:     steps = job['steps']\n136: \n137:     assert any('kind-action' in str(step) for step in steps)\n138:     assert any('make e2e' in str(step) for step in steps)\n139: \n140: \n141: def test_e2e_workflow_captures_logs_on_failure():\n142:     \"\"\"Test E2E workflow captures logs on failure.\"\"\"\n143:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"e2e.yml\"\n144:     with open(workflow_file, 'r') as f:\n145:         content = yaml.safe_load(f)\n146: \n147:     job = content['jobs']['e2e']\n148:     steps = job['steps']\n149: \n150:     # Check for failure condition in step\n151:     has_failure_condition = False\n152:     for step in steps:\n153:         if isinstance(step, dict):\n154:             if 'if' in step and 'failure()' in step['if']:\n155:                 has_failure_condition = True\n156:                 break\n157: \n158:     assert has_failure_condition, \"E2E workflow missing failure condition\"\n159: \n160: \n161: def test_e2e_workflow_cleanup_always_runs():\n162:     \"\"\"Test E2E workflow cleanup always runs.\"\"\"\n163:     workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"e2e.yml\"\n164:     with open(workflow_file, 'r') as f:\n165:         content = yaml.safe_load(f)\n166: \n167:     job = content['jobs']['e2e']\n168:     steps = job['steps']\n169: \n170:     # Check for always condition and cleanup step\n171:     has_cleanup = False\n172:     for step in steps:\n173:         if isinstance(step, dict):\n174:             if 'if' in step and 'always()' in step['if']: