itionTime: now,\n\t\t\t\t\tReason:             \"Available\",\n\t\t\t\t\tMessage:            \"Interpreter is ready\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tObservedGeneration: 1,\n\t\t},\n\t}\n\n\tif !ci.Status.Ready {\n\t\tt.Error(\"Expected Ready to be true\")\n\t}\n\n\tif len(ci.Status.Conditions) != 1 {\n\t\tt.Errorf(\"Expected 1 condition, got %d\", len(ci.Status.Conditions))\n\t}\n\n\tif ci.Status.ObservedGeneration != 1 {\n\t\tt.Errorf(\"Expected ObservedGeneration 1, got %d\", ci.Status.ObservedGeneration)\n\t}\n}\n\nfunc TestCodeInterpreterList(t *testing.T) {\n\tlist := &CodeInterpreterList{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: SchemeGroupVersion.String(),\n\t\t\tKind:       \"CodeInterpreterList\",\n\t\t},\n\t\tItems: []CodeInterpreter{\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"python-interpreter\",\n\t\t\t\t},\n\t\t\t},\n\t\t\t{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName: \"javascript-interpreter\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tif len(list.Items) != 2 {\n\t\tt.Errorf(\"Expected 2 items, got %d\", len(list.Items))\n\t}\n}\n\nfunc TestCodeInterpreterResources(t *testing.T) {\n\tresources := &SandboxContainerResources{\n\t\tLimits: SandboxResourceList{\n\t\t\tCPU:              \"1\",\n\t\t\tMemory:           \"1Gi\",\n\t\t\tEphemeralStorage: \"5Gi\",\n\t\t},\n\t\tRequests: SandboxResourceList{\n\t\t\tCPU:    \"500m\",\n\t\t\tMemory: \"512Mi\",\n\t\t},\n\t}\n\n\tif resources.Limits.CPU != \"1\" {\n\t\tt.Errorf(\"Expected CPU limit 1, got %s\", resources.Limits.CPU)\n\t}\n\n\tif resources.Requests.Memory != \"512Mi\" {\n\t\tt.Errorf(\"Expected Memory request 512Mi, got %s\", resources.Requests.Memory)\n\t}\n}\n\nfunc TestCodeInterpreterEnvVar(t *testing.T) {\n\tenv := []SandboxEnvVar{\n\t\t{\n\t\t\tName:  \"PYTHONPATH\",\n\t\t\tValue: \"/usr/local/lib/python3.11/site-packages\",\n\t\t},\n\t\t{\n\t\t\tName: \"API_KEY\",\n\t\t\tValueFrom: &SandboxEnvVarSource{\n\t\t\t\tSecretKeyRef: &SandboxSecretKeyRef{\n