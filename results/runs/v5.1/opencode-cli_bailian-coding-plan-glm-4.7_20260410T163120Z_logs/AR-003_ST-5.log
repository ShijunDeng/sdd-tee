[runtime] = true\n\t\tcount++\n\t}\n\n\texpectedCount := 4\n\tif count != expectedCount {\n\t\tt.Errorf(\"Expected %d unique runtime types, got %d\", expectedCount, count)\n\t}\n}\n\nfunc TestProtocolTypes(t *testing.T) {\n\tprotocols := []string{\n\t\tv1alpha1.ProtocolTCP,\n\t\tv1alpha1.ProtocolUDP,\n\t\tv1alpha1.ProtocolSCTP,\n\t}\n\n\tfor _, protocol := range protocols {\n\t\tif protocol == \"\" {\n\t\t\tt.Errorf(\"Protocol type should not be empty\")\n\t\t}\n\t}\n}\n\nfunc TestProtocolTypesUnique(t *testing.T) {\n\tprotocols := map[string]bool{\n\t\tv1alpha1.ProtocolTCP:  false,\n\t\tv1alpha1.ProtocolUDP:  false,\n\t\tv1alpha1.ProtocolSCTP: false,\n\t}\n\n\tcount := 0\n\tfor protocol := range protocols {\n\t\tif protocols[protocol] {\n\t\t\tt.Errorf(\"Duplicate protocol type found: %s\", protocol)\n\t\t}\n\t\tprotocols[protocol] = true\n\t\tcount++\n\t}\n\n\texpectedCount := 3\n\tif count != expectedCount {\n\t\tt.Errorf(\"Expected %d unique protocol types, got %d\", expectedCount, count)\n\t}\n}\n\nfunc TestDefaultCPULimit(t *testing.T) {\n\texpected := \"1\"\n\tif v1alpha1.DefaultCPULimit != expected {\n\t\tt.Errorf(\"Expected CPU limit %s, got %s\", expected, v1alpha1.DefaultCPULimit)\n\t}\n}\n\nfunc TestDefaultMemoryLimit(t *testing.T) {\n\texpected := \"1Gi\"\n\tif v1alpha1.DefaultMemoryLimit != expected {\n\t\tt.Errorf(\"Expected memory limit %s, got %s\", expected, v1alpha1.DefaultMemoryLimit)\n\t}\n}\n\nfunc TestDefaultCPURequest(t *testing.T) {\n\texpected := \"100m\"\n\tif v1alpha1.DefaultCPURequest != expected {\n\t\tt.Errorf(\"Expected CPU request %s, got %s\", expected, v1alpha1.DefaultCPURequest)\n\t}\n}\n\nfunc TestDefaultMemoryRequest(t *testing.T) {\n\texpected := \"128Mi\"\n\tif v1alpha1.DefaultMemoryRequest != expected {\n\t\tt.Errorf(\"Expected memory request %s, got %s\", expected, v1alpha1.DefaultMemoryRequest)\n\t}\n}\n\nfunc TestSeccompProfileTypes(t *testing.T) {\n\tprofiles := []string{\n\t\tv1alpha1.SeccompProfileTypeRuntimeDefault,\n\t\tv1alpha1.SeccompProfileTypeUnconfined,\n\t\tv1alpha1.SeccompProfileTypeLocalhost,\n\t}\n\n\tfor _, profile := range profiles {\n\t\tif profile == \"\" {\n\t\t\tt.Errorf(\"Seccomp profile type should not be empty\")\n\t\t}\n\t}\n}\n\nfunc TestSeccompProfileTypesUnique(t *testing.T) {\n\tprofiles := map[string]bool{\n\t\tv1alpha1.SeccompProfileTypeRuntimeDefault: false,\n\t\tv1alpha1.SeccompProfileTypeUnconfined:     false,\n\t\tv1alpha1.SeccompProfileTypeLocalhost:      false,\n\t}\n\n\tcount := 0\n\tfor profile := range profiles {\n\t\tif profiles[profile] {\n\t\t\tt.Errorf(\"Duplicate seccomp profile type found: %s\", profile)\n\t\t}\n\t\tprofiles[profile] = true\n\t\tcount++\n\t}\n\n\texpectedCount := 3\n\tif count != expectedCount {\n\t\tt.Errorf(\"Expected %d unique seccomp profile types, got %d\", expectedCount, count)\n\t}\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/constants_test.go"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/deepcopy.go":[{"range":{"start":{"line":22,"character":1},"end":{"line":22,"character":7}},"severity":2,"code":"default","codeDescription":{"href":"https://staticcheck.dev/docs/checks/#S1023"},"source":"S1023","message":"redundant return statement"},{"range":{"start":{"line":52,"character":1},"end":{"line":52,"character":7}},"severity":2,"code":"default","codeDescription":{"href":"https://staticcheck.dev/docs/checks/#S1023"},"source":"S1023","message":"redundant return statement"},{"range":{"start":{"line":88,"character":1},"end":{"line":88,"character":7}},"severity":2,"code":"default","codeDescription":{"href":"https://staticcheck.dev/docs/checks/#S1023"},"source":"S1023",