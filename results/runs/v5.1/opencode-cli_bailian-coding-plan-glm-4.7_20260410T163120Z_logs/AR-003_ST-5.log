.Errorf(\"Expected CPU limit %s, got %s\", DefaultCPULimit, container.Resources.Limits.CPU)\n+\t}\n+\n+\tif container.Env[0].Name != \"TEST_VAR\" {\n+\t\tt.Errorf(\"Expected env var name TEST_VAR, got %s\", container.Env[0].Name)\n+\t}\n+}\n+\n+func TestAllRuntimeTypes(t *testing.T) {\n+\truntimes := []string{\n+\t\tRuntimeTypePython,\n+\t\tRuntimeTypeJavaScript,\n+\t\tRuntimeTypeTypeScript,\n+\t\tRuntimeTypeGo,\n+\t}\n+\n+\tfor _, runtime := range runtimes {\n+\t\tci := &CodeInterpreter{\n+\t\t\tSpec: CodeInterpreterSpec{\n+\t\t\t\tImage:   \"image:latest\",\n+\t\t\t\tRuntime: runtime,\n+\t\t\t},\n+\t\t}\n+\n+\t\tif ci.Spec.Runtime != runtime {\n+\t\t\tt.Errorf(\"Expected runtime %s, got %s\", runtime, ci.Spec.Runtime)\n+\t\t}\n+\n+\t\terr := ValidateRuntimeType(ci.Spec.Runtime)\n+\t\tif err != nil {\n+\t\t\tt.Errorf(\"Runtime type %s should be valid, got error: %v\", runtime, err)\n+\t\t}\n+\t}\n+}\n+\n+func TestAllProtocolTypes(t *testing.T) {\n+\tprotocols := []string{\n+\t\tProtocolTCP,\n+\t\tProtocolUDP,\n+\t\tProtocolSCTP,\n+\t}\n+\n+\tfor _, protocol := range protocols {\n+\t\tport := SandboxContainerPort{\n+\t\t\tContainerPort: 8080,\n+\t\t\tProtocol:      protocol,\n+\t\t}\n+\n+\t\tif port.Protocol != protocol {\n+\t\t\tt.Errorf(\"Expected protocol %s, got %s\", protocol, port.Protocol)\n+\t\t}\n+\n+\t\terr := ValidateProtocol(port.Protocol)\n+\t\tif err != nil {\n+\t\t\tt.Errorf(\"Protocol %s should be valid, got error: %v\", protocol, err)\n+\t\t}\n+\t}\n+}\n+\n+func TestAllSeccompProfileTypes(t *testing.T) {\n+\tprofiles := []string{\n+\t\tSeccompProfileTypeRuntimeDefault,\n+\t\tSeccompProfileTypeUnconfined,\n+\t\tSeccompProfileTypeLocalhost,\n+\t}\n+\n+\tfor _, profile := range profiles {\n+\t\tseccompProfile := &SandboxSeccompProfile{\n+\t\t\tType: profile,\n+\t\t}\n+\n+\t\tif seccompProfile.Type != profile {\n+\t\t\tt.Errorf(\"Expected seccomp profile type %s, got %s\", profile, seccompProfile.Type)\n+\t\t}\n+\n+\t\terr := ValidateSeccompProfileType(