 NodeAffinity defines node affinity.\n73:                             properties:\n74:                               preferredDuringSchedulingIgnoredDuringExecution:\n75:                                 description: PreferredDuringSchedulingIgnoredDuringExecution\n76:                                   defines preferred node selectors.\n77:                                 items:\n78:                                   description: SandboxPreferredSchedulingTerm defines\n79:                                     a preferred scheduling term.\n80:                                   properties:\n81:                                     preference:\n82:                                       description: Preference is the preference.\n83:                                       properties:\n84:                                         matchExpressions:\n85:                                           description: MatchExpressions is a list of\n86:                                             node selector requirements.\n87:                                           items:\n88:                                             description: SandboxNodeSelectorRequirement\n89:                                               defines a node selector requirement.\n90:                                             properties:\n91:                                               key:\n92:                                                 description: Key is the label key.\n93:                                                 type: string\n94:                                               operator:\n95:                                                 description: Operator is the operator.\n96:                                                 type: string\n97:                                               values:\n98:                                                 description: Values is the values.\n99:                                                 items:\n100:                                              