is ready\",\n1107: \t\t\t\t},\n1108: \t\t\t},\n1109: \t\t\tObservedGeneration: 1,\n1110: \t\t},\n1111: \t}\n1112: \n1113: \tif !ci.Status.Ready {\n1114: \t\tt.Error(\"Expected Ready to be true\")\n1115: \t}\n1116: \n1117: \tif len(ci.Status.Conditions) != 1 {\n1118: \t\tt.Errorf(\"Expected 1 condition, got %d\", len(ci.Status.Conditions))\n1119: \t}\n1120: \n1121: \tif ci.Status.ObservedGeneration != 1 {\n1122: \t\tt.Errorf(\"Expected ObservedGeneration 1, got %d\", ci.Status.ObservedGeneration)\n1123: \t}\n1124: }\n1125: \n1126: func TestCodeInterpreterList(t *testing.T) {\n1127: \tlist := &CodeInterpreterList{\n1128: \t\tTypeMeta: metav1.TypeMeta{\n1129: \t\t\tAPIVersion: SchemeGroupVersion.String(),\n1130: \t\t\tKind:       \"CodeInterpreterList\",\n1131: \t\t},\n1132: \t\tItems: []CodeInterpreter{\n1133: \t\t\t{\n1134: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n1135: \t\t\t\t\tName: \"python-interpreter\",\n1136: \t\t\t\t},\n1137: \t\t\t},\n1138: \t\t\t{\n1139: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n1140: \t\t\t\t\tName: \"javascript-interpreter\",\n1141: \t\t\t\t},\n1142: \t\t\t},\n1143: \t\t},\n1144: \t}\n1145: \n1146: \tif len(list.Items) != 2 {\n1147: \t\tt.Errorf(\"Expected 2 items, got %d\", len(list.Items))\n1148: \t}\n1149: }\n1150: \n1151: func TestCodeInterpreterResources(t *testing.T) {\n1152: \tresources := &SandboxContainerResources{\n1153: \t\tLimits: SandboxResourceList{\n1154: \t\t\tCPU:              \"1\",\n1155: \t\t\tMemory:           \"1Gi\",\n1156: \t\t\tEphemeralStorage: \"5Gi\",\n1157: \t\t},\n1158: \t\tRequests: SandboxResourceList{\n1159: \t\t\tCPU:    \"500m\",\n1160: \t\t\tMemory: \"512Mi\",\n1161: \t\t},\n1162: \t}\n1163: \n1164: \tif resources.Limits.CPU != \"1\" {\n1165: \t\tt.Errorf(\"Expected CPU limit 1, got %s\", resources.Limits.CPU)\n1166: \t}\n1167: \n1168: \tif resources.Requests.Memory != \"512Mi\" {\n1169: \t\tt.Errorf(\"Expected Memory request 512Mi, got %s\", resources.Requests.Memory)\n1170: \t}\n1171: }\n1172: \n1173: func TestCodeInterpreterEnvVar(t *testing.T) {\n1174: \tenv := []SandboxEnvVar{\n1175: \t\t{\n1176: \t\t\tName:  \"PYTHONPATH\",\n1177: \t\t\tValue: \"/usr/local/lib/python3.11/site-packages\",\n1178: \t\t},\n1179: \t\t{\n1180: \t\t\tName: \"API_KEY\",\n1181: \t\t\tValueFrom: &SandboxEnvVarSource{\n1182: \t\t\t\tSecretKeyRef: &SandboxSecretKeyRef{\n1183: \t\t\t\t\tName: \"api-secret\",\n1184: \t\t\t\t\tKey:  \"key\",\n1185: \t\t\t\t},\n1186: \t\t\t},\n1187: \t\t},\n1188: \t}\n1189: \n1190: \tif len(env) != 2 {\n1191: \t\tt.Errorf(\"Expected 2 environment variables, got %d\", len(env))\n1192: \t}\n1193: \n1194: \tif env[0].Name != \"PYTHONPATH\" {\n1195: \t\tt.Errorf(\"Expected PYTHONPATH, got %s\", env[0].Name)\n1196: \t}\n1197: \n1198: \tif env[1].ValueFrom == nil {\n1199: \t\tt.Error(\"Expected ValueFrom to be set for second env var\")\n1200: \t}\n1201: }\n1202: \n1203: func TestCodeInterpreterRuntimeEnum(t *testing.T) {\n1204: \tvalidRuntimes := []string{\"python\", \"javascript\", \"typescript\", \"go\"}\n1205: \n1206: \tfor _, runtime := range validRuntimes {\n1207: \t\tci := &CodeInterpreter{\n1208: \t\t\tSpec: CodeInterpreterSpec{\n1209: \t\t\t\tImage:   \"test:latest\",\n1210: \t\t\t\tRuntime: runtime,\n1211: \t\t\t},\n1212: \t\t}\n1213: \n1214: \t\tif ci.Spec.Runtime != runtime {\n1215: \t\t\tt.Errorf(\"Expected runtime %s, got %s\", runtime, ci.Spec.Runtime)\n1216: \t\t}\n1217: \t}\n1218: }\n1219: \n1220: func TestEnabledPackages(t *testing.T) {\n1221: \tci := &CodeInterpreter{\n1222: \t\tSpec: CodeInterpreterSpec{\n1223: \t\t\tImage:           \"python:3.11-slim\",\n1224: \t\t\tEnabledPackages: []string{\"numpy\", \"pandas\", \"scikit-learn\"},\n1225: \t\t},\n1226: \t}\n1227: \n1228: \tif len(ci.Spec.EnabledPackages) != 3 {\n1229: \t\tt.Errorf(\"Expected 3 enabled packages, got %d\", len(ci.Spec.EnabledPackages))\n1230: \t}\n1231: \n1232: \tif ci.Spec.EnabledPackages[0] != \"numpy\" {\n1233: \t\tt.Errorf(\"Expected numpy, got %s\", ci.Spec.EnabledPackages[0])\n1234: \t}\n1235: }\n1236: \n1237: func TestCodeInterpreterSchemeRegistration(t *testing.T) {\n1238: \tgvk := schema.GroupVersionKind{\n1239: \t\tGroup:   \"runtime.agentcube.volcano.sh\",\n1240: \t\tVersion: \"v1alpha1\",\n1241: \t\tKind:    \"CodeInterpreter\",\n1242: \t}\n1243: \n1244: \tobj, err := Scheme.New(gvk)\n1245: \tif err != nil {\n1246: \t\tt.Fatalf(\"Failed to create object from scheme: %v\", err)\n1247: \t}\n1248: \n1249: \tci, ok := obj.(*CodeInterpreter)\n1250: \tif !ok {\n1251: \t\tt.Fatalf(\"Expected *CodeInterpreter, got %T\", obj)\n1252: \t}\n1253: \n1254: \tgvks, _, _ := Scheme.ObjectKinds(obj)\n1255: \tif len(gvks) == 0 {\n1256: \t\tt.Error(\"CodeInterpreter should have a known GVK\")\n1257: \t}\n1258: \n1259: \tif gvks[0] != gvk {\n1260: \t\tt.Errorf(\"Expected GVK %v, got %v\", gvk, gvks[0])\n1261: \t}\n1262: \n1263: \t_ = ci\n1264: }\n1265: \n1266: func TestFullCodeInterpreter(t *testing.T) {\n1267: \tduration10m := metav1.Duration{Duration: 10 * time.Minute}\n1268: \n1269: \tci := &CodeInterpreter{\n1270: \t\tTypeMeta: metav1.TypeMeta{\n1271: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n1272: \t\t\tKind:       \"CodeInterpreter\",\n1273: \t\t},\n1274: \t\tObjectMeta: metav1.ObjectMeta{\n1275: \t\t\tName:      \"python-interpreter\",\n1276: \t\t\tNamespace: \"default\",\n1277: \t\t\tLabels: map[string]string{\n1278: \t\t\t\t\"app\": \"codeinterpreter\",\n1279: \t\t\t},\n1280: \t\t},\n1281: \t\tSpec: CodeInterpreterSpec{\n1282: \t\t\tImage:   \"python:3.11-slim\",\n1283: \t\t\tRuntime: \"python\",\n1284: \t\t\tTimeout: &duration10m,\n1285: \t\t\tResources: &SandboxContainerResources{\n1286: \t\t\t\tLimits: SandboxResourceList{\n1287: \t\t\t\t\tCPU:    \"2\",\n1288: \t\t\t\t\tMemory: \"2Gi\",\n1289: \t\t\t\t},\n1290: \t\t\t\tRequests: SandboxResourceList{\n1291: \t\t\t\t\tCPU:    \"500m\",\n1292: \t\t\t\t\tMemory: \"512Mi\",\n1293: \t\t\t\t},\n1294: \t\t\t},\n1295: \t\t\tEnv: []SandboxEnvVar{\n1296: \t\t\t\t{\n1297: \t\t\t\t\tName:  \"PYTHON_VERSION\",\n1298: \t\t\t\t\tValue: \"3.11\",\n1299: \t\t\t\t},\n1300: \t\t\t},\n1301: \t\t\tEnabledPackages: []string{\"numpy\", \"pandas\", \"scikit-learn\"},\n1302: \t\t},\n1303: \t\tStatus: CodeInterpreterStatus{\n1304: \t\t\tReady: true,\n1305: \t\t\tConditions: []metav1.Condition{\n1306: \t\t\t\t{\n1307: \t\t\t\t\tType:    \"Ready\",\n1308: \t\t\t\t\tStatus:  metav1.ConditionTrue,\n1309: \t\t\t\t\tReason:  \"Available\",\n1310: \t\t\t\t\tMessage: \"Interpreter is ready\",\n1311: \t\t\t\t},\n1312: \t\t\t},\n1313: \t\t\tObservedGeneration: 1,\n1314: \t\t},\n1315: \t}\n1316: \n1317: \tif ci.Name != \"python-interpreter\" {\n1318: \t\tt.Errorf(\"Expected name python-interpreter, got %s\", ci.Name)\n1319: \t}\n1320: \n1321: \tif ci.Spec.Image != \"python:3.11-slim\" {\n1322: \t\tt.Errorf(\"Expected image python:3.11-slim, got %s\", ci.Spec.Image)\n1323: \t}\n1324: \n1325: \tif ci.Spec.Runtime != \"python\" {\n1326: \t\tt.Errorf(\"Expected runtime python, got %s\", ci.Spec.Runtime)\n1327: \t}\n1328: \n1329: \tif len(ci.Spec.EnabledPackages) != 3 {\n1330: \t\tt.Errorf(\"Expected 3 enabled packages, got %d\", len(ci.Spec.EnabledPackages))\n1331: \t}\n1332: \n1333: \tif !ci.Status.Ready {\n1334: \t\tt.Error(\"Expected Ready to be true\")\n1335: \t}\n1336: }\n1337: \n1338: func TestCodeInterpreterJSONSerialization(t *testing.T) {\n1339: \tci := &CodeInterpreter{\n1340: \t\tTypeMeta: metav1.TypeMeta{\n1341: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n1342: \t\t\tKind:       \"CodeInterpreter\",\n1343: \t\t},\n1344: \t\tObjectMeta: metav1.ObjectMeta{\n1345: \t\t\tName:      \"test-ci\",\n1346: \t\t\tNamespace: \"default\",\n1347: \t\t},\n1348: \t\tSpec: CodeInterpreterSpec{\n1349: \t\t\tImage:   \"python:3.11-slim\",\n1350: \t\t\tRuntime: \"python\",\n1351: \t\t},\n1352: \t}\n1353: \n1354: \tdata, err := json.Marshal(ci)\n1355: \tif err != nil {\n1356: \t\tt.Fatalf(\"Failed to marshal CodeInterpreter: %v\", err)\n1357: \t}\n1358: \n1359: \tvar unmarshaled CodeInterpreter\n1360: \tif err := json.Unmarshal(data, &unmarshaled); err != nil {\n1361: \t\tt.Fatalf(\"Failed to unmarshal CodeInterpreter: %v\", err)\n1362: \t}\n1363: \n1364: \tif unmarshaled.Name != \"test-ci\" {\n1365: \t\tt.Errorf(\"Expected name test-ci, got %s\", unmarshaled.Name)\n1366: \t}\n1367: \n1368: \tif unmarshaled.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n1369: \t\tt.Errorf(\"Expected APIVersion runtime.agentcube.volcano.sh/v1alpha1, got %s\", unmarshaled.APIVersion)\n1370: \t}\n1371: }\n1372: \n1373: func TestCodeInterpreterListTypeMeta(t *testing.T) {\n1374: \tlist := &CodeInterpreterList{\n1375: \t\tTypeMeta: metav1.TypeMeta{\n1376: \t\t\tAPIVersion: SchemeGroupVersion.String(),\n1377: \t\t\tKind:       \"CodeInterpreterList\",\n1378: \t\t},\n1379: \t}\n1380: \n1381: \tif list.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n1382: \t\tt.Errorf(\"Expected APIVersion runtime.agentcube.volcano.sh/v1alpha1, got %s\", list.APIVersion)\n1383: \t}\n1384: \n1385: \tif list.Kind != \"CodeInterpreterList\" {\n1386: \t\tt.Errorf(\"Expected Kind CodeInterpreterList, got %s\", list.Kind)\n1387: \t}\n1388: }\n1389: \n1390: func TestCodeInterpreterDeepCopy(t *testing.T) {\n1391: \toriginal := &CodeInterpreter{\n1392: \t\tObjectMeta: metav1.ObjectMeta{\n1393: \t\t\tName:      \"test-ci\",\n1394: \t\t\tNamespace: \"default\",\n1395: \t\t},\n1396: \t\tSpec: CodeInterpreterSpec{\n1397: \t\t\tImage:           \"python:3.11-slim\",\n1398: \t\t\tRuntime:         \"python\",\n1399: \t\t\tEnabledPackages: []string{\"numpy\", \"pandas\"},\n1400: \t\t\tEnv: []SandboxEnvVar{\n1401: \t\t\t\t{\n1402: \t\t\t\t\tName:  \"DEBUG\",\n1403: \t\t\t\t\tValue: \"true\",\n1404: \t\t\t\t},\n1405: \t\t\t},\n1406: \t\t},\n1407: \t\tStatus: CodeInterpreterStatus{\n1408: \t\t\tReady: true,\n1409: \t\t},\n1410: \t}\n1411: \n1412: \tcopied := original.DeepCopy()\n1413: \n1414: \tif copied.Name != original.Name {\n1415: \t\tt.Errorf(\"Expected name %s, got %s\", original.Name, copied.Name)\n1416: \t}\n1417: \n1418: \tif copied.Spec.Image != original.Spec.Image {\n1419: \t\tt.Errorf(\"Expected image %s, got %s\", original.Spec.Image, copied.Spec.Image)\n1420: \t}\n1421: \n1422: \tif len(copied.Spec.EnabledPackages) != len(original.Spec.EnabledPackages) {\n1423: \t\tt.Errorf(\"Expected %d packages, got %d\", len(original.Spec.EnabledPackages), len(copied.Spec.EnabledPackages))\n1424: \t}\n1425: \n1426: \tcopied.Name = \"modified-ci\"\n1427: \tcopied.Spec.EnabledPackages = append(copied.Spec.EnabledPackages, \"scikit-learn\")\n1428: \n1429: \tif original.Name == \"modified-ci\" {\n1430: \t\tt.Error(\"Deep copy should not modify original\")\n1431: \t}\n1432: \n1433: \tif len(original.Spec.EnabledPackages) != 2 {\n1434: \t\tt.Error(\"Deep copy should not share slices with original\")\n1435: \t}\n1436: }\n1437: \n1438: func TestCodeInterpreterListDeepCopy(t *testing.T) {\n1439: \toriginal := &CodeInterpreterList{\n1440: \t\tItems: []CodeInterpreter{\n1441: \t\t\t{\n1442: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n1443: \t\t\t\t\tName: \"ci-1\",\n1444: \t\t\t\t},\n1445: \t\t\t},\n1446: \t\t\t{\n1447: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n1448: \t\t\t\t\tName: \"ci-2\",\n1449: \t\t\t\t},\n1450: \t\t\t},\n1451: \t\t},\n1452: \t}\n1453: \n1454: \tcopied := original.DeepCopy()\n1455: \n1456: \tif len(copied.Items) != len(original.Items) {\n1457: \t\tt.Errorf(\"Expected %d items, got %d\", len(original.Items), len(copied.Items))\n1458: \t}\n1459: \n1460: \tcopied.Items[0].Name = \"modified-ci\"\n1461: \n1462: \tif original.Items[0].Name == \"modified-ci\" {\n1463: \t\tt.Error(\"Deep copy should not modify original\")\n1464: \t}\n1465: }\n1466: \n1467: func TestCodeInterpreterSpecDeepCopy(t *testing.T) {\n1468: \tduration5m := metav1.Duration{Duration: 5 * time.Minute}\n1469: \n1470: \toriginal := &CodeInterpreterSpec{\n1471: \t\tImage:   \"python:3.11-slim\",\n1472: \t\tRuntime: \"python\",\n1473: \t\tTimeout: &duration5m,\n1474: \t\tResources: &SandboxContainerResources{\n1475: \t\t\tLimits: SandboxResourceList{\n1476: \t\t\t\tCPU:    \"1\",\n1477: \t\t\t\tMemory: \"1Gi\",\n1478: \t\t\t},\n1479: \t\t},\n1480: \t\tEnabledPackages: []string{\"numpy\"},\n1481: \t}\n1482: \n1483: \tcopied := original.DeepCopy()\n1484: \n1485: \tif copied.Image != original.Image {\n1486: \t\tt.Errorf(\"Expected image %s, got %s\", original.Image, copied.Image)\n1487: \t}\n1488: \n1489: \tif copied.Timeout == nil || copied.Timeout.Duration != original.Timeout.Duration {\n1490: \t\tt.Error(\"Deep copy should preserve timeout\")\n1491: \t}\n1492: \n1493: \tcopied.EnabledPackages = append(copied.EnabledPackages, \"pandas\")\n1494: \n1495: \tif len(original.EnabledPackages) != 1 {\n1496: \t\tt.Error(\"Deep copy should not share slices with original\")\n1497: \t}\n1498: }\n1499: \n1500: func TestCodeInterpreterStatusDeepCopy(t *testing.T) {\n1501: \toriginal := &CodeInterpreterStatus{\n1502: \t\tReady: true,\n1503: \t\tConditions: []metav1.Condition{\n1504: \t\t\t{\n1505: \t\t\t\tType:    \"Ready\",\n1506: \t\t\t\tStatus:  metav1.ConditionTrue,\n1507: \t\t\t\tReason:  \"Available\",\n1508: \t\t\t\tMessage: \"Interpreter is ready\",\n1509: \t\t\t},\n1510: \t\t},\n1511: \t\tObservedGeneration: 1,\n1512: \t}\n1513: \n1514: \tcopied := original.DeepCopy()\n1515: \n1516: \tif copied.Ready != original.Ready {\n1517: \t\tt.Errorf(\"Expected Ready %v, got %v\", original.Ready, copied.Ready)\n1518: \t}\n1519: \n1520: \tif len(copied.Conditions) != len(original.Conditions) {\n1521: \t\tt.Errorf(\"Expected %d conditions, got %d\", len(original.Conditions), len(copied.Conditions))\n1522: \t}\n1523: \n1524: \tcopied.Conditions = append(copied.Conditions, metav1.Condition{\n1525: \t\tType:    \"Initializing\",\n1526: \t\tStatus:  metav1.ConditionFalse,\n1527: \t\tReason:  \"Completed\",\n1528: \t\tMessage: \"Initialization completed\",\n1529: \t})\n1530: \n1531: \tif len(original.Conditions) != 1 {\n1532: \t\tt.Error(\"Deep copy should not share slices with original\")\n1533: \t}\n1534: }\n1535: \n1536: func TestCodeInterpreterWithNilOptionalFields(t *testing.T) {\n1537: \tci := &CodeInterpreter{\n1538: \t\tSpec: CodeInterpreterSpec{\n1539: \t\t\tImage: \"python:3.11-slim\",\n1540: \t\t},\n1541: \t\tStatus: CodeInterpreterStatus{},\n1542: \t}\n1543: \n1544: \tif ci.Spec.Timeout != nil {\n1545: \t\tt.Error(\"Timeout should be nil\")\n1546: \t}\n1547: \n1548: \tif ci.Spec.Resources != nil {\n1549: \t\tt.Error(\"Resources should be nil\")\n1550: \t}\n1551: \n1552: \tif ci.Spec.Env != nil {\n1553: \t\tt.Error(\"Env should be nil\")\n1554: \t}\n1555: \n1556: \tif ci.Spec.EnabledPackages != nil {\n1557: \t\tt.Error(\"EnabledPackages should be nil\")\n1558: \t}\n1559: \n1560: \tif ci.Status.Conditions != nil {\n1561: \t\tt.Error(\"Conditions should be nil\")\n1562: \t}\n1563: }\n1564: \n1565: func TestCodeInterpreterTimeout(t *testing.T) {\n1566: \ttests := []struct {\n1567: \t\tname     string\n1568: \t\tduration string\n1569: \t\texpected time.Duration\n1570: \t}{\n1571: \t\t{\n1572: \t\t\tname:     \"5 minutes\",\n1573: \t\t\tduration: \"5m\",\n1574: \t\t\texpected: 5 * time.Minute,\n1575: \t\t},\n1576: \t\t{\n1577: \t\t\tname:     \"1 hour\",\n1578: \t\t\tduration: \"1h\",\n1579: \t\t\texpected: 1 * time.Hour,\n1580: \t\t},\n1581: \t\t{\n1582: \t\t\tname:     \"30 seconds\",\n1583: \t\t\tduration: \"30s\",\n1584: \t\t\texpected: 30 * time.Second,\n1585: \t\t},\n1586: \t}\n1587: \n1588: \tfor _, tt := range tests {\n1589: \t\tt.Run(tt.name, func(t *testing.T) {\n1590: \t\t\tdur, err := time.ParseDuration(tt.duration)\n1591: \t\t\tif err != nil {\n1592: \t\t\t\tt.Fatalf(\"Failed to parse duration %s: %v\", tt.duration, err)\n1593: \t\t\t}\n1594: \n1595: \t\t\tif dur != tt.expected {\n1596: \t\t\t\tt.Errorf(\"Expected duration %v, got %v\", tt.expected, dur)\n1597: \t\t\t}\n1598: \t\t})\n1599: \t}\n1600: }\n\n(End of file - total 1600 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\t\"encoding/json\"\n\t\"testing\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\tk8sutil \"k8s.io/apimachinery/pkg/util/intstr\"\n)\n\nfunc TestAgentRuntimeTypeMeta(t *testing.T) {\n\tar := &AgentRuntime{}\n\n\tif ar.APIVersion != \"\" {\n\t\tt.Errorf(\"Expected empty APIVersion, got %s\", ar.APIVersion)\n\t}\n\tif ar.Kind != \"\" {\n\t\tt.Errorf(\"Expected empty Kind, got %s\", ar.Kind)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types_test.go","time":{"start":1775841066054,"end":1775841066086}}}}
