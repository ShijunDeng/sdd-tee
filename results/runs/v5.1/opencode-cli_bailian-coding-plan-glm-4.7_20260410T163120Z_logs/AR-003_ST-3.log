 \t\tt.Run(tt.name, func(t *testing.T) {\n46: \t\t\tresult := Resource(tt.resource)\n47: \t\t\tif result != tt.expected {\n48: \t\t\t\tt.Errorf(\"Expected %v, got %v\", tt.expected, result)\n49: \t\t\t}\n50: \t\t})\n51: \t}\n52: }\n53: \n54: func TestAgentRuntimeSpecDefaults(t *testing.T) {\n55: \tduration15m := metav1.Duration{Duration: 15 * time.Minute}\n56: \tduration8h := metav1.Duration{Duration: 8 * time.Hour}\n57: \n58: \tspec := &AgentRuntimeSpec{\n59: \t\tPodTemplate: &SandboxTemplate{\n60: \t\t\tSpec: SandboxPodSpec{\n61: \t\t\t\tContainers: []SandboxContainer{\n62: \t\t\t\t\t{\n63: \t\t\t\t\t\tName:  \"test\",\n64: \t\t\t\t\t\tImage: \"test:latest\",\n65: \t\t\t\t\t},\n66: \t\t\t\t},\n67: \t\t\t},\n68: \t\t},\n69: \t}\n70: \n71: \tif spec.PodTemplate == nil {\n72: \t\tt.Error(\"PodTemplate should not be nil\")\n73: \t}\n74: \n75: \tif spec.SessionTimeout == nil || spec.SessionTimeout.Duration != duration15m.Duration {\n76: \t\tt.Logf(\"Note: SessionTimeout default value will be applied by API server\")\n77: \t}\n78: \n79: \tif spec.MaxSessionDuration == nil || spec.MaxSessionDuration.Duration != duration8h.Duration {\n80: \t\tt.Logf(\"Note: MaxSessionDuration default value will be applied by API server\")\n81: \t}\n82: }\n83: \n84: func TestAgentRuntimeStatusConditions(t *testing.T) {\n85: \tnow := metav1.Now()\n86: \tar := &AgentRuntime{\n87: \t\tStatus: AgentRuntimeStatus{\n88: \t\t\tConditions: []metav1.Condition{\n89: \t\t\t\t{\n90: \t\t\t\t\tType:               \"Ready\",\n91: \t\t\t\t\tStatus:             metav1.ConditionTrue,\n92: \t\t\t\t\tLastTransitionTime: now,\n93: \t\t\t\t\tReason:             \"Available\",\n94: \t\t\t\t\tMessage:            \"Runtime is ready\",\n95: \t\t\t\t},\n96: \t\t\t},\n97: \t\t\tObservedGeneration: 1,\n98: \t\t},\n99: \t}\n100: \n101: \tif len(ar.Status.Conditions) != 1 {\n102: \t\tt.Errorf(\"Expected 1 condition, got %d\", len(ar.Status.Conditions))\n103: \t}\n104: \n105: \tif ar.Status.Conditions[0].Type != \"Ready\" {\n106: \t\tt.Errorf(\"Expected condition type Ready, got %s\", ar.Status.Conditions[0].Type)\n107: \t}\n108: \n109: \tif ar.Status.ObservedGeneration != 1 {\n110: \t\tt.Errorf(\"Expected ObservedGeneration 1, got %d\", ar.Status.ObservedGeneration)\n111: \t}\n112: }\n113: \n114: func TestAgentRuntimeList(t *testing.T) {\n115: \tlist := &AgentRuntimeList{\n116: \t\tTypeMeta: metav1.TypeMeta{\n117: \t\t\tAPIVersion: SchemeGroupVersion.String(),\n118: \t\t\tKind:       \"AgentRuntimeList\",\n119: \t\t},\n120: \t\tItems: []AgentRuntime{\n121: \t\t\t{\n122: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n123: \t\t\t\t\tName: \"runtime-1\",\n124: \t\t\t\t},\n125: \t\t\t},\n126: \t\t\t{\n127: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n128: \t\t\t\t\tName: \"runtime-2\",\n129: \t\t\t\t},\n130: \t\t\t},\n131: \t\t},\n132: \t}\n133: \n134: \tif len(list.Items) != 2 {\n135: \t\tt.Errorf(\"Expected 2 items, got %d\", len(list.Items))\n136: \t}\n137: \n138: \tif list.Items[0].Name != \"runtime-1\" {\n139: \t\tt.Errorf(\"Expected runtime-1, got %s\", list.Items[0].Name)\n140: \t}\n141: }\n142: \n143: func TestSandboxTemplate(t *testing.T) {\n144: \ttemplate := &SandboxTemplate{\n145: \t\tMetadata: &SandboxMetadata{\n146: \t\t\tLabels: map[string]string{\n147: \t\t\t\t\"app\": \"agent\",\n148: \t\t\t},\n149: \t\t\tAnnotations: map[string]string{\n150: \t\t\t\t\"description\": \"Test agent runtime\",\n151: \t\t\t},\n152: \t\t},\n153: \t\tSpec: SandboxPodSpec{\n154: \t\t\tContainers: []SandboxContainer{\n155: \t\t\t\t{\n156: \t\t\t\t\tName:  \"agent\",\n157: \t\t\t\t\tImage: \"agent:latest\",\n158: \t\t\t\t\tPorts: []SandboxContainerPort{\n159: \t\t\t\t\t\t{\n160: \t\t\t\t\t\t\tContainerPort: 8080,\n161: \t\t\t\t\t\t\tProtocol:      \"TCP\",\n162: \t\t\t\t\t\t},\n163: \t\t\t\t\t},\n164: \t\t\t\t},\n165: \t\t\t},\n166: \t\t},\n167: \t}\n168: \n169: \tif template.Metadata == nil {\n170: \t\tt.Error(\"Metadata should not be nil\")\n171: \t}\n172: \n173: \tif len(template.Metadata.Labels) != 1 {\n174: \t\tt.Errorf(\"Expected 1 label, got %d\", len(template.Metadata.Labels))\n175: \t}\n176: \n177: \tif len(template.Spec.Containers) != 1 {\n178: \t\tt.Errorf(\"Expected 1 container, got %d\", len(template.Spec.Containers))\n179: \t}\n180: }\n181: \n182: func TestSandboxContainer(t *testing.T) {\n183: \tcontainer := SandboxContainer{\n184: \t\tName:  \"agent\",\n185: \t\tImage: \"agent:latest\",\n186: \t\tCommand: []string{\n187: \t\t\t\"/bin/agent\",\n188: \t\t},\n189: \t\tArgs: []string{\n190: \t\t\t\"--debug\",\n191: \t\t},\n192: \t\tWorkingDir: \"/workspace\",\n193: \t\tPorts: []SandboxContainerPort{\n194: \t\t\t{\n195: \t\t\t\tName:          \"http\",\n196: \t\t\t\tContainerPort: 8080,\n197: \t\t\t\tProtocol:      \"TCP\",\n198: \t\t\t},\n199: \t\t},\n200: \t\tEnv: []SandboxEnvVar{\n201: \t\t\t{\n202: \t\t\t\tName:  \"DEBUG\",\n203: \t\t\t\tValue: \"true\",\n204: \t\t\t},\n205: \t\t},\n206: \t\tResources: &SandboxContainerResources{\n207: \t\t\tLimits: SandboxResourceList{\n208: \t\t\t\tCPU:    \"1\",\n209: \t\t\t\tMemory: \"1Gi\",\n210: \t\t\t},\n211: \t\t\tRequests: SandboxResourceList{\n212: \t\t\t\tCPU:    \"500m\",\n213: \t\t\t\tMemory: \"512Mi\",\n214: \t\t\t},\n215: \t\t},\n216: \t}\n217: \n218: \tif container.Name != \"agent\" {\n219: \t\tt.Errorf(\"Expected name agent, got %s\", container.Name)\n220: \t}\n221: \n222: \tif len(container.Command) != 1 {\n223: \t\tt.Errorf(\"Expected 1 command, got %d\", len(container.Command))\n224: \t}\n225: \n226: \tif len(container.Ports) != 1 {\n227: \t\tt.Errorf(\"Expected 1 port, got %d\", len(container.Ports))\n228: \t}\n229: \n230: \tif container.Resources == nil {\n231: \t\tt.Error(\"Resources should not be nil\")\n232: \t}\n233: }\n234: \n235: func TestSandboxEnvVarSources(t *testing.T) {\n236: \ttests := []struct {\n237: \t\tname      string\n238: \t\tenvVar    SandboxEnvVar\n239: \t\thasValue  bool\n240: \t\thasField  bool\n241: \t\thasCM     bool\n242: \t\thasSecret bool\n243: \t}{\n244: \t\t{\n245: \t\t\tname: \"literal value\",\n246: \t\t\tenvVar: SandboxEnvVar{\n247: \t\t\t\tName:  \"DEBUG\",\n248: \t\t\t\tValue: \"true\",\n249: \t\t\t},\n250: \t\t\thasValue: true,\n251: \t\t},\n252: \t\t{\n253: \t\t\tname: \"field ref\",\n254: \t\t\tenvVar: SandboxEnvVar{\n255: \t\t\t\tName: \"POD_NAME\",\n256: \t\t\t\tValueFrom: &SandboxEnvVarSource{\n257: \t\t\t\t\tFieldRef: &SandboxFieldRef{\n258: \t\t\t\t\t\tFieldPath: \"metadata.name\",\n259: \t\t\t\t\t},\n260: \t\t\t\t},\n261: \t\t\t},\n262: \t\t\thasField: true,\n263: \t\t},\n264: \t\t{\n265: \t\t\tname: \"configmap ref\",\n266: \t\t\tenvVar: SandboxEnvVar{\n267: \t\t\t\tName: \"CONFIG\",\n268: \t\t\t\tValueFrom: &SandboxEnvVarSource{\n269: \t\t\t\t\tConfigMapKeyRef: &SandboxConfigMapKeyRef{\n270: \t\t\t\t\t\tName: \"config\",\n271: \t\t\t\t\t\tKey:  \"key\",\n272: \t\t\t\t\t},\n273: \t\t\t\t},\n274: \t\t\t},\n275: \t\t\thasCM: true,\n276: \t\t},\n277: \t\t{\n278: \t\t\tname: \"secret ref\",\n279: \t\t\tenvVar: SandboxEnvVar{\n280: \t\t\t\tName: \"SECRET\",\n281: \t\t\t\tValueFrom: &SandboxEnvVarSource{\n282: \t\t\t\t\tSecretKeyRef: &SandboxSecretKeyRef{\n283: \t\t\t\t\t\tName: \"secret\",\n284: \t\t\t\t\t\tKey:  \"key\",\n285: \t\t\t\t\t},\n286: \t\t\t\t},\n287: \t\t\t},\n288: \t\t\thasSecret: true,\n289: \t\t},\n290: \t}\n291: \n292: \tfor _, tt := range tests {\n293: \t\tt.Run(tt.name, func(t *testing.T) {\n294: \t\t\tif tt.hasValue && tt.envVar.Value == \"\" {\n295: \t\t\t\tt.Error(\"Expected value to be set\")\n296: \t\t\t}\n297: \t\t\tif tt.hasField && tt.envVar.ValueFrom == nil {\n298: \t\t\t\tt.Error(\"Expected ValueFrom to be set\")\n299: \t\t\t}\n300: \t\t\tif tt.hasCM && tt.envVar.ValueFrom.ConfigMapKeyRef == nil {\n301: \t\t\t\tt.Error(\"Expected ConfigMapKeyRef to be set\")\n302: \t\t\t}\n303: \t\t\tif tt.hasSecret && tt.envVar.ValueFrom.SecretKeyRef == nil {\n304: \t\t\t\tt.Error(\"Expected SecretKeyRef to be set\")\n305: \t\t\t}\n306: \t\t})\n307: \t}\n308: }\n309: \n310: func TestSandboxProbe(t *testing.T) {\n311: \tprobe := &SandboxProbe{\n312: \t\tSandboxProbeHandler: SandboxProbeHandler{\n313: \t\t\tHTTPGet: &SandboxHTTPGetAction{\n314: \t\t\t\tPort: k8sutil.FromInt(8080),\n315: \t\t\t\tPath: \"/healthz\",\n316: \t\t\t},\n317: \t\t},\n318: \t\tInitialDelaySeconds: 5,\n319: \t\tTimeoutSeconds:      1,\n320: \t\tPeriodSeconds:       10,\n321: \t\tSuccessThreshold:    1,\n322: \t\tFailureThreshold:    3,\n323: \t}\n324: \n325: \tif probe.HTTPGet == nil {\n326: \t\tt.Error(\"HTTPGet should not be nil\")\n327: \t}\n328: \n329: \tif probe.InitialDelaySeconds != 5 {\n330: \t\tt.Errorf(\"Expected InitialDelaySeconds 5, got %d\", probe.InitialDelaySeconds)\n331: \t}\n332: }\n333: \n334: func TestSandboxAffinity(t *testing.T) {\n335: \taffinity := &SandboxAffinity{\n336: \t\tNodeAffinity: &SandboxNodeAffinity{\n337: \t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &SandboxNodeSelector{\n338: \t\t\t\tNodeSelectorTerms: []SandboxNodeSelectorTerm{\n339: \t\t\t\t\t{\n340: \t\t\t\t\t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n341: \t\t\t\t\t\t\t{\n342: \t\t\t\t\t\t\t\tKey:      \"node-role.kubernetes.io/agent\",\n343: \t\t\t\t\t\t\t\tOperator: \"In\",\n344: \t\t\t\t\t\t\t\tValues:   []string{\"true\"},\n345: \t\t\t\t\t\t\t},\n346: \t\t\t\t\t\t},\n347: \t\t\t\t\t},\n348: \t\t\t\t},\n349: \t\t\t},\n350: \t\t},\n351: \t\tPodAffinity: &SandboxPodAffinity{\n352: \t\t\tPreferredDuringSchedulingIgnoredDuringExecution: []SandboxWeightedPodAffinityTerm{\n353: \t\t\t\t{\n354: \t\t\t\t\tWeight: 100,\n355: \t\t\t\t\tPodAffinityTerm: SandboxPodAffinityTerm{\n356: \t\t\t\t\t\tTopologyKey: \"kubernetes.io/hostname\",\n357: \t\t\t\t\t\tLabelSelector: &SandboxLabelSelector{\n358: \t\t\t\t\t\t\tMatchLabels: map[string]string{\n359: \t\t\t\t\t\t\t\t\"app\": \"agent\",\n360: \t\t\t\t\t\t\t},\n361: \t\t\t\t\t\t},\n362: \t\t\t\t\t},\n363: \t\t\t\t},\n364: \t\t\t},\n365: \t\t},\n366: \t}\n367: \n368: \tif affinity.NodeAffinity == nil {\n369: \t\tt.Error(\"NodeAffinity should not be nil\")\n370: \t}\n371: \n372: \tif affinity.PodAffinity == nil {\n373: \t\tt.Error(\"PodAffinity should not be nil\")\n374: \t}\n375: \n376: \tif len(affinity.PodAffinity.PreferredDuringSchedulingIgnoredDuringExecution) != 1 {\n377: \t\tt.Errorf(\"Expected 1 preferred term, got %d\", len(affinity.PodAffinity.PreferredDuringSchedulingIgnoredDuringExecution))\n378: \t}\n379: }\n380: \n381: func TestSandboxTolerations(t *testing.T) {\n382: \ttoleration := SandboxToleration{\n383: \t\tKey:      \"node-role.kubernetes.io/agent\",\n384: \t\tOperator: \"Equal\",\n385: \t\tValue:    \"true\",\n386: \t\tEffect:   \"NoSchedule\",\n387: \t\tTolerationSeconds: func() *int64 {\n388: \t\t\tv := int64(300)\n389: \t\t\treturn &v\n390: \t\t}(),\n391: \t}\n392: \n393: \tif toleration.Key != \"node-role.kubernetes.io/agent\" {\n394: \t\tt.Errorf(\"Expected key node-role.kubernetes.io/agent, got %s\", toleration.Key)\n395: \t}\n396: \n397: \tif toleration.TolerationSeconds == nil {\n398: \t\tt.Error(\"TolerationSeconds should not be nil\")\n399: \t}\n400: }\n401: \n402: func TestSandboxSecurityContext(t *testing.T) {\n403: \tuid := int64(1000)\n404: \tgid := int64(1000)\n405: \ttrueVal := true\n406: \n407: \tsecurityContext := &SandboxSecurityContext{\n408: \t\tRunAsUser:                &uid,\n409: \t\tRunAsGroup:               &gid,\n410: \t\tRunAsNonRoot:             &trueVal,\n411: \t\tReadOnlyRootFilesystem:   &trueVal,\n412: \t\tAllowPrivilegeEscalation: &trueVal,\n413: \t\tCapabilities: &SandboxCapabilities{\n414: \t\t\tAdd:  []string{\"NET_ADMIN\", \"SYS_ADMIN\"},\n415: \t\t\tDrop: []string{\"ALL\"},\n416: \t\t},\n417: \t\tSeccompProfile: &SandboxSeccompProfile{\n418: \t\t\tType: \"RuntimeDefault\",\n419: \t\t},\n420: \t}\n421: \n422: \tif securityContext.RunAsUser == nil {\n423: \t\tt.Error(\"RunAsUser should not be nil\")\n424: \t}\n425: \n426: \tif *securityContext.RunAsUser != 1000 {\n427: \t\tt.Errorf(\"Expected RunAsUser 1000, got %d\", *securityContext.RunAsUser)\n428: \t}\n429: \n430: \tif securityContext.Capabilities == nil {\n431: \t\tt.Error(\"Capabilities should not be nil\")\n432: \t}\n433: \n434: \tif len(securityContext.Capabilities.Add) != 2 {\n435: \t\tt.Errorf(\"Expected 2 capabilities to add, got %d\", len(securityContext.Capabilities.Add))\n436: \t}\n437: }\n438: \n439: func TestSandboxVolumes(t *testing.T) {\n440: \tmode := int32(0644)\n441: \ttrueVal := true\n442: \n443: \tvolumes := []SandboxVolume{\n444: \t\t{\n445: \t\t\tName: \"config-volume\",\n446: \t\t\tConfigMap: &SandboxConfigMapVolumeSource{\n447: \t\t\t\tName:     \"config\",\n448: \t\t\t\tOptional: &trueVal,\n449: \t\t\t\tItems: []SandboxKeyToPath{\n450: \t\t\t\t\t{\n451: \t\t\t\t\t\tKey:  \"config.yaml\",\n452: \t\t\t\t\t\tPath: \"config.yaml\",\n453: \t\t\t\t\t\tMode: &mode,\n454: \t\t\t\t\t},\n455: \t\t\t\t},\n456: \t\t\t},\n457: \t\t},\n458: \t\t{\n459: \t\t\tName: \"secret-volume\",\n460: \t\t\tSecret: &SandboxSecretVolumeSource{\n461: \t\t\t\tSecretName: \"secret\",\n462: \t\t\t},\n463: \t\t},\n464: \t\t{\n465: \t\t\tName: \"data-volume\",\n466: \t\t\tEmptyDir: &SandboxEmptyDirVolumeSource{\n467: \t\t\t\tSizeLimit: \"1Gi\",\n468: \t\t\t},\n469: \t\t},\n470: \t\t{\n471: \t\t\tName: \"pvc-volume\",\n472: \t\t\tPersistentVolumeClaim: &SandboxPersistentVolumeClaimVolumeSource{\n473: \t\t\t\tClaimName: \"data-claim\",\n474: \t\t\t\tReadOnly:  true,\n475: \t\t\t},\n476: \t\t},\n477: \t}\n478: \n479: \tif len(volumes) != 4 {\n480: \t\tt.Errorf(\"Expected 4 volumes, got %d\", len(volumes))\n481: \t}\n482: \n483: \tif volumes[0].ConfigMap == nil {\n484: \t\tt.Error(\"ConfigMap should not be nil for config-volume\")\n485: \t}\n486: \n487: \tif volumes[1].Secret == nil {\n488: \t\tt.Error(\"Secret should not be nil for secret-volume\")\n489: \t}\n490: \n491: \tif volumes[2].EmptyDir == nil {\n492: \t\tt.Error(\"EmptyDir should not be nil for data-volume\")\n493: \t}\n494: \n495: \tif volumes[3].PersistentVolumeClaim == nil {\n496: \t\tt.Error(\"PersistentVolumeClaim should not be nil for pvc-volume\")\n497: \t}\n498: }\n499: \n500: func TestJSONSerialization(t *testing.T) {\n501: \tar := &AgentRuntime{\n502: \t\tTypeMeta: metav1.TypeMeta{\n503: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n504: \t\t\tKind:       \"AgentRuntime\",\n505: \t\t},\n506: \t\tObjectMeta: metav1.ObjectMeta{\n507: \t\t\tName:      \"test-runtime\",\n508: \t\t\tNamespace: \"default\",\n509: \t\t},\n510: \t\tSpec: AgentRuntimeSpec{\n511: \t\t\tPodTemplate: &SandboxTemplate{\n512: \t\t\t\tSpec: SandboxPodSpec{\n513: \t\t\t\t\tContainers: []SandboxContainer{\n514: \t\t\t\t\t\t{\n515: \t\t\t\t\t\t\tName:  \"agent\",\n516: \t\t\t\t\t\t\tImage: \"agent:latest\",\n517: \t\t\t\t\t\t},\n518: \t\t\t\t\t},\n519: \t\t\t\t},\n520: \t\t\t},\n521: \t\t},\n522: \t}\n523: \n524: \tdata, err := json.Marshal(ar)\n525: \tif err != nil {\n526: \t\tt.Fatalf(\"Failed to marshal AgentRuntime: %v\", err)\n527: \t}\n528: \n529: \tvar unmarshaled AgentRuntime\n530: \tif err := json.Unmarshal(data, &unmarshaled); err != nil {\n531: \t\tt.Fatalf(\"Failed to unmarshal AgentRuntime: %v\", err)\n532: \t}\n533: \n534: \tif unmarshaled.Name != \"test-runtime\" {\n535: \t\tt.Errorf(\"Expected name test-runtime, got %s\", unmarshaled.Name)\n536: \t}\n537: \n538: \tif unmarshaled.APIVersion != \"runtime.agentcube.volcano.sh/v1alpha1\" {\n539: \t\tt.Errorf(\"Expected APIVersion runtime.agentcube.volcano.sh/v1alpha1, got %s\", unmarshaled.APIVersion)\n540: \t}\n541: }\n542: \n543: func TestSchemeRegistration(t *testing.T) {\n544: \tif Scheme == nil {\n545: \t\tt.Fatal(\"Scheme should not be nil\")\n546: \t}\n547: \n548: \tgvk := schema.GroupVersionKind{\n549: \t\tGroup:   \"runtime.agentcube.volcano.sh\",\n550: \t\tVersion: \"v1alpha1\",\n551: \t\tKind:    \"AgentRuntime\",\n552: \t}\n553: \n554: \tobj, err := Scheme.New(gvk)\n555: \tif err != nil {\n556: \t\tt.Fatalf(\"Failed to create object from scheme: %v\", err)\n557: \t}\n558: \n559: \tar, ok := obj.(*AgentRuntime)\n560: \tif !ok {\n561: \t\tt.Fatalf(\"Expected *AgentRuntime, got %T\", obj)\n562: \t}\n563: \n564: \t// Note: Scheme.New() creates an empty instance without setting TypeMeta\n565: \t// TypeMeta is set when unmarshaling from YAML/JSON or manually\n566: \tif ar.Kind != \"\" {\n567: \t\tt.Logf(\"Note: Kind is not automatically set by Scheme.New()\")\n568: \t}\n569: \n570: \t// Verify the GVK is correct by checking the known types\n571: \tgvks, _, _ := Scheme.ObjectKinds(obj)\n572: \tif len(gvks) == 0 {\n573: \t\tt.Error(\"AgentRuntime should have a known GVK\")\n574: \t}\n575: \n576: \tif gvks[0] != gvk {\n577: \t\tt.Errorf(\"Expected GVK %v, got %v\", gvk, gvks[0])\n578: \t}\n579: }\n580: \n581: func TestAgentRuntimeObjectMeta(t *testing.T) {\n582: \tar := &AgentRuntime{\n583: \t\tObjectMeta: metav1.ObjectMeta{\n584: \t\t\tName:              \"test-runtime\",\n585: \t\t\tNamespace:         \"default\",\n586: \t\t\tUID:               \"12345\",\n587: \t\t\tResourceVersion:   \"1\",\n588: \t\t\tGeneration:        1,\n589: \t\t\tCreationTimestamp: metav1.Now(),\n590: \t\t\tLabels: map[string]string{\n591: \t\t\t\t\"app\": \"agent\",\n592: \t\t\t},\n593: \t\t\tAnnotations: map[string]string{\n594: \t\t\t\t\"description\": \"Test agent runtime\",\n595: \t\t\t},\n596: \t\t},\n597: \t}\n598: \n599: \tif ar.Name != \"test-runtime\" {\n600: \t\tt.Errorf(\"Expected name test-runtime, got %s\", ar.Name)\n601: \t}\n602: \n603: \tif ar.Namespace != \"default\" {\n604: \t\tt.Errorf(\"Expected namespace default, got %s\", ar.Namespace)\n605: \t}\n606: \n607: \tif len(ar.Labels) != 1 {\n608: \t\tt.Errorf(\"Expected 1 label, got %d\", len(ar.Labels))\n609: \t}\n610: \n611: \tif len(ar.Annotations) != 1 {\n612: \t\tt.Errorf(\"Expected 1 annotation, got %d\", len(ar.Annotations))\n613: \t}\n614: }\n615: \n616: func TestSandboxContainerPort(t *testing.T) {\n617: \tport := SandboxContainerPort{\n618: \t\tName:          \"http\",\n619: \t\tContainerPort: 8080,\n620: \t\tProtocol:      \"TCP\",\n621: \t\tHostPort:      30080,\n622: \t}\n623: \n624: \tif port.Name != \"http\" {\n625: \t\tt.Errorf(\"Expected name http, got %s\", port.Name)\n626: \t}\n627: \n628: \tif port.ContainerPort != 8080 {\n629: \t\tt.Errorf(\"Expected ContainerPort 8080, got %d\", port.ContainerPort)\n630: \t}\n631: \n632: \tif port.Protocol != \"TCP\" {\n633: \t\tt.Errorf(\"Expected Protocol TCP, got %s\", port.Protocol)\n634: \t}\n635: \n636: \tif port.HostPort != 30080 {\n637: \t\tt.Errorf(\"Expected HostPort 30080, got %d\", port.HostPort)\n638: \t}\n639: }\n640: \n641: func TestDurationFields(t *testing.T) {\n642: \ttests := []struct {\n643: \t\tname     string\n644: \t\tduration string\n645: \t\texpected time.Duration\n646: \t}{\n647: \t\t{\n648: \t\t\tname:     \"15 minutes\",\n649: \t\t\tduration: \"15m\",\n650: \t\t\texpected: 15 * time.Minute,\n651: \t\t},\n652: \t\t{\n653: \t\t\tname:     \"8 hours\",\n654: \t\t\tduration: \"8h\",\n655: \t\t\texpected: 8 * time.Hour,\n656: \t\t},\n657: \t\t{\n658: \t\t\tname:     \"1 hour 30 minutes\",\n659: \t\t\tduration: \"1h30m\",\n660: \t\t\texpected: 1*time.Hour + 30*time.Minute,\n661: \t\t},\n662: \t}\n663: \n664: \tfor _, tt := range tests {\n665: \t\tt.Run(tt.name, func(t *testing.T) {\n666: \t\t\tdur, err := time.ParseDuration(tt.duration)\n667: \t\t\tif err != nil {\n668: \t\t\t\tt.Fatalf(\"Failed to parse duration %s: %v\", tt.duration, err)\n669: \t\t\t}\n670: \n671: \t\t\tif dur != tt.expected {\n672: \t\t\t\tt.Errorf(\"Expected duration %v, got %v\", tt.expected, dur)\n673: \t\t\t}\n674: \t\t})\n675: \t}\n676: }\n677: \n678: func TestSandboxResources(t *testing.T) {\n679: \tresources := &SandboxResources{\n680: \t\tLimits: SandboxResourceList{\n681: \t\t\tCPU:              \"2\",\n682: \t\t\tMemory:           \"4Gi\",\n683: \t\t\tEphemeralStorage: \"10Gi\",\n684: \t\t},\n685: \t\tRequests: SandboxResourceList{\n686: \t\t\tCPU:              \"1\",\n687: \t\t\tMemory:           \"2Gi\",\n688: \t\t\tEphemeralStorage: \"5Gi\",\n689: \t\t},\n690: \t}\n691: \n692: \tif resources.Limits.CPU != \"2\" {\n693: \t\tt.Errorf(\"Expected CPU limit 2, got %s\", resources.Limits.CPU)\n694: \t}\n695: \n696: \tif resources.Requests.Memory != \"2Gi\" {\n697: \t\tt.Errorf(\"Expected Memory request 2Gi, got %s\", resources.Requests.Memory)\n698: \t}\n699: \n700: \tif resources.Limits.EphemeralStorage != \"10Gi\" {\n701: \t\tt.Errorf(\"Expected EphemeralStorage limit 10Gi, got %s\", resources.Limits.EphemeralStorage)\n702: \t}\n703: }\n704: \n705: func TestSandboxVolumeMount(t *testing.T) {\n706: \tmount := SandboxVolumeMount{\n707: \t\tName:      \"config-volume\",\n708: \t\tMountPath: \"/etc/config\",\n709: \t\tSubPath:   \"config.yaml\",\n710: \t\tReadOnly:  true,\n711: \t}\n712: \n713: \tif mount.Name != \"config-volume\" {\n714: \t\tt.Errorf(\"Expected name config-volume, got %s\", mount.Name)\n715: \t}\n716: \n717: \tif mount.MountPath != \"/etc/config\" {\n718: \t\tt.Errorf(\"Expected MountPath /etc/config, got %s\", mount.MountPath)\n719: \t}\n720: \n721: \tif mount.SubPath != \"config.yaml\" {\n722: \t\tt.Errorf(\"Expected SubPath config.yaml, got %s\", mount.SubPath)\n723: \t}\n724: \n725: \tif !mount.ReadOnly {\n726: \t\tt.Error(\"Expected ReadOnly to be true\")\n727: \t}\n728: }\n729: \n730: func TestSandboxHTTPHeader(t *testing.T) {\n731: \theader := SandboxHTTPHeader{\n732: \t\tName:  \"Authorization\",\n733: \t\tValue: \"Bearer token\",\n734: \t}\n735: \n736: \tif header.Name != \"Authorization\" {\n737: \t\tt.Errorf(\"Expected name Authorization, got %s\", header.Name)\n738: \t}\n739: \n740: \tif header.Value != \"Bearer token\" {\n741: \t\tt.Errorf(\"Expected value Bearer token, got %s\", header.Value)\n742: \t}\n743: }\n744: \n745: func TestSandboxExecAction(t *testing.T) {\n746: \taction := &SandboxExecAction{\n747: \t\tCommand: []string{\n748: \t\t\t\"/bin/sh\",\n749: \t\t\t\"-c\",\n750: \t\t\t\"cat /tmp/health\",\n751: \t\t},\n752: \t}\n753: \n754: \tif len(action.Command) != 3 {\n755: \t\tt.Errorf(\"Expected 3 commands, got %d\", len(action.Command))\n756: \t}\n757: \n758: \tif action.Command[0] != \"/bin/sh\" {\n759: \t\tt.Errorf(\"Expected first command /bin/sh, got %s\", action.Command[0])\n760: \t}\n761: }\n762: \n763: func TestSandboxLabelSelector(t *testing.T) {\n764: \tselector := &SandboxLabelSelector{\n765: \t\tMatchLabels: map[string]string{\n766: \t\t\t\"app\":     \"agent\",\n767: \t\t\t\"version\": \"v1\",\n768: \t\t},\n769: \t\tMatchExpressions: []SandboxLabelSelectorRequirement{\n770: \t\t\t{\n771: \t\t\t\tKey:      \"tier\",\n772: \t\t\t\tOperator: \"In\",\n773: \t\t\t\tValues:   []string{\"frontend\"},\n774: \t\t\t},\n775: \t\t},\n776: \t}\n777: \n778: \tif len(selector.MatchLabels) != 2 {\n779: \t\tt.Errorf(\"Expected 2 match labels, got %d\", len(selector.MatchLabels))\n780: \t}\n781: \n782: \tif len(selector.MatchExpressions) != 1 {\n783: \t\tt.Errorf(\"Expected 1 match expression, got %d\", len(selector.MatchExpressions))\n784: \t}\n785: }\n786: \n787: func TestAgentRuntimeStatus(t *testing.T) {\n788: \tnow := metav1.Now()\n789: \tstatus := AgentRuntimeStatus{\n790: \t\tConditions: []metav1.Condition{\n791: \t\t\t{\n792: \t\t\t\tType:               \"Ready\",\n793: \t\t\t\tStatus:             metav1.ConditionTrue,\n794: \t\t\t\tLastTransitionTime: now,\n795: \t\t\t\tReason:             \"Available\",\n796: \t\t\t\tMessage:            \"Runtime is ready\",\n797: \t\t\t},\n798: \t\t\t{\n799: \t\t\t\tType:               \"Initializing\",\n800: \t\t\t\tStatus:             metav1.ConditionFalse,\n801: \t\t\t\tLastTransitionTime: now,\n802: \t\t\t\tReason:             \"Completed\",\n803: \t\t\t\tMessage:            \"Initialization completed\",\n804: \t\t\t},\n805: \t\t},\n806: \t\tObservedGeneration: 2,\n807: \t}\n808: \n809: \tif len(status.Conditions) != 2 {\n810: \t\tt.Errorf(\"Expected 2 conditions, got %d\", len(status.Conditions))\n811: \t}\n812: \n813: \tif status.Conditions[0].Status != metav1.ConditionTrue {\n814: \t\tt.Errorf(\"Expected first condition status True, got %v\", status.Conditions[0].Status)\n815: \t}\n816: \n817: \tif status.ObservedGeneration != 2 {\n818: \t\tt.Errorf(\"Expected ObservedGeneration 2, got %d\", status.ObservedGeneration)\n819: \t}\n820: }\n821: \n822: func TestSandboxNodeSelectorTerm(t *testing.T) {\n823: \tterm := SandboxNodeSelectorTerm{\n824: \t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n825: \t\t\t{\n826: \t\t\t\tKey:      \"node-role.kubernetes.io/agent\",\n827: \t\t\t\tOperator: \"In\",\n828: \t\t\t\tValues:   []string{\"true\"},\n829: \t\t\t},\n830: \t\t},\n831: \t\tMatchFields: []SandboxNodeSelectorRequirement{\n832: \t\t\t{\n833: \t\t\t\tKey:      \"metadata.name\",\n834: \t\t\t\tOperator: \"In\",\n835: \t\t\t\tValues:   []string{\"agent-node-1\"},\n836: \t\t\t},\n837: \t\t},\n838: \t}\n839: \n840: \tif len(term.MatchExpressions) != 1 {\n841: \t\tt.Errorf(\"Expected 1 match expression, got %d\", len(term.MatchExpressions))\n842: \t}\n843: \n844: \tif len(term.MatchFields) != 1 {\n845: \t\tt.Errorf(\"Expected 1 match field, got %d\", len(term.MatchFields))\n846: \t}\n847: }\n848: \n849: func TestSandboxPreferredSchedulingTerm(t *testing.T) {\n850: \tterm := SandboxPreferredSchedulingTerm{\n851: \t\tWeight: 100,\n852: \t\tPreference: SandboxNodeSelectorTerm{\n853: \t\t\tMatchExpressions: []SandboxNodeSelectorRequirement{\n854: \t\t\t\t{\n855: \t\t\t\t\tKey:      \"zone\",\n856: \t\t\t\t\tOperator: \"In\",\n857: \t\t\t\t\tValues:   []string{\"us-west-1\"},\n858: \t\t\t\t},\n859: \t\t\t},\n860: \t\t},\n861: \t}\n862: \n863: \tif term.Weight != 100 {\n864: \t\tt.Errorf(\"Expected weight 100, got %d\", term.Weight)\n865: \t}\n866: \n867: \tif len(term.Preference.MatchExpressions) != 1 {\n868: \t\tt.Errorf(\"Expected 1 match expression, got %d\", len(term.Preference.MatchExpressions))\n869: \t}\n870: }\n871: \n872: func TestSandboxKeyToPath(t *testing.T) {\n873: \tmode := int32(0644)\n874: \tktp := SandboxKeyToPath{\n875: \t\tKey:  \"config.yaml\",\n876: \t\tPath: \"config/config.yaml\",\n877: \t\tMode: &mode,\n878: \t}\n879: \n880: \tif ktp.Key != \"config.yaml\" {\n881: \t\tt.Errorf(\"Expected key config.yaml, got %s\", ktp.Key)\n882: \t}\n883: \n884: \tif ktp.Path != \"config/config.yaml\" {\n885: \t\tt.Errorf(\"Expected path config/config.yaml, got %s\", ktp.Path)\n886: \t}\n887: \n888: \tif ktp.Mode == nil {\n889: \t\tt.Error(\"Mode should not be nil\")\n890: \t}\n891: \n892: \tif *ktp.Mode != 0644 {\n893: \t\tt.Errorf(\"Expected mode 0644, got %d\", *ktp.Mode)\n894: \t}\n895: }\n896: \n897: func TestFullAgentRuntime(t *testing.T) {\n898: \tuid := int64(1000)\n899: \ttrueVal := true\n900: \tmode := int32(0644)\n901: \n902: \tar := &AgentRuntime{\n903: \t\tTypeMeta: metav1.TypeMeta{\n904: \t\t\tAPIVersion: \"runtime.agentcube.volcano.sh/v1alpha1\",\n905: \t\t\tKind:       \"AgentRuntime\",\n906: \t\t},\n907: \t\tObjectMeta: metav1.ObjectMeta{\n908: \t\t\tName:      \"test-runtime\",\n909: \t\t\tNamespace: \"default\",\n910: \t\t\tLabels: map[string]string{\n911: \t\t\t\t\"app\": \"agent\",\n912: \t\t\t},\n913: \t\t},\n914: \t\tSpec: AgentRuntimeSpec{\n915: \t\t\tPodTemplate: &SandboxTemplate{\n916: \t\t\t\tMetadata: &SandboxMetadata{\n917: \t\t\t\t\tLabels: map[string]string{\n918: \t\t\t\t\t\t\"runtime\": \"test\",\n919: \t\t\t\t\t},\n920: \t\t\t\t},\n921: \t\t\t\tSpec: SandboxPodSpec{\n922: \t\t\t\t\tContainers: []SandboxContainer{\n923: \t\t\t\t\t\t{\n924: \t\t\t\t\t\t\tName:       \"agent\",\n925: \t\t\t\t\t\t\tImage:      \"agent:latest\",\n926: \t\t\t\t\t\t\tWorkingDir: \"/workspace\",\n927: \t\t\t\t\t\t\tPorts: []SandboxContainerPort{\n928: \t\t\t\t\t\t\t\t{\n929: \t\t\t\t\t\t\t\t\tName:          \"http\",\n930: \t\t\t\t\t\t\t\t\tContainerPort: 8080,\n931: \t\t\t\t\t\t\t\t\tProtocol:      \"TCP\",\n932: \t\t\t\t\t\t\t\t},\n933: \t\t\t\t\t\t\t},\n934: \t\t\t\t\t\t\tEnv: []SandboxEnvVar{\n935: \t\t\t\t\t\t\t\t{\n936: \t\t\t\t\t\t\t\t\tName:  \"DEBUG\",\n937: \t\t\t\t\t\t\t\t\tValue: