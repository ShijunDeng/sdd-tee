     type: string\n189:                                               values:\n190:                                                 description: Values is the values.\n191:                                                 items:\n192:                                                   type: string\n193:                                                 type: array\n194:                                             required:\n195:                                             - key\n196:                                             - operator\n197:                                             type: object\n198:                                           type: array\n199:                                       type: object\n200:                                     minItems: 1\n201:                                     type: array\n202:                                 required:\n203:                                 - nodeSelectorTerms\n204:                                 type: object\n205:                             type: object\n206:                           podAffinity:\n207:                             description: PodAffinity defines pod affinity.\n208:                             properties:\n209:                               preferredDuringSchedulingIgnoredDuringExecution:\n210:                                 description: PreferredDuringSchedulingIgnoredDuringExecution\n211:                                   defines preferred pod selectors.\n212:                                 items:\n213:                                   description: SandboxWeightedPodAffinityTerm defines\n214:                                     a weighted pod affinity term.\n215:                                   properties:\n216:                                     podAffinityTerm:\n217:                                       description: PodAffinityTerm is the pod affinity\n218:                                         term.\n219:                                       properties:\n220:                                         labelSelector:\n221:                                           description: LabelSelector defines the label\n222:                                             selector.\n223:                                           properties:\n224:                                             matchExpressions:\n225:                                               description: MatchExpressions is a list\n226:                                                 of label selector requirements.\n227:                                               items:\n228:                                                 description: SandboxLabelSelectorRequirement\n229:                                                   defines a label selector requirement.\n230:                                                 properties:\n231:                                                   key:\n232:                                                     description: Key is the label key.\n233:                                                     type: string\n234:                                                   operator:\n235:                                                     description: Operator is the operator.\n236:                                                     type: string\n237:                                                   values:\n238:                                                     description: Values is the values.\n239:                                                     items:\n240:                                                       type: string\n241:                                                     type: array\n242:                                                 required:\n243:                                                 - key\n244:                                                 - operator\n245:                                                 type: object\n246:                                               type: array\n247:                               