oadManagerURL:    \"\",\n45: \t\tAgentcubeNamespace:    defaultNamespace,\n46: \t}\n47: }\n48: \n49: func LoadConfig() (*Config, error) {\n50: \tcfg := DefaultConfig()\n51: \n52: \tif port := os.Getenv(\"ROUTER_PORT\"); port != \"\" {\n53: \t\tcfg.Port = port\n54: \t}\n55: \n56: \tif debug := os.Getenv(\"ROUTER_DEBUG\"); debug != \"\" {\n57: \t\tcfg.Debug = debug == \"true\" || debug == \"1\"\n58: \t}\n59: \n60: \tif enableTLS := os.Getenv(\"ROUTER_ENABLE_TLS\"); enableTLS != \"\" {\n61: \t\tcfg.EnableTLS = enableTLS == \"true\" || enableTLS == \"1\"\n62: \t}\n63: \n64: \tif tlsCert := os.Getenv(\"ROUTER_TLS_CERT\"); tlsCert != \"\" {\n65: \t\tcfg.TLSCert = tlsCert\n66: \t}\n67: \n68: \tif tlsKey := os.Getenv(\"ROUTER_TLS_KEY\"); tlsKey != \"\" {\n69: \t\tcfg.TLSKey = tlsKey\n70: \t}\n71: \n72: \tif readTimeout := os.Getenv(\"ROUTER_READ_TIMEOUT\"); readTimeout != \"\" {\n73: \t\tif val, err := strconv.Atoi(readTimeout); err == nil {\n74: \t\t\tcfg.ReadTimeout = val\n75: \t\t}\n76: \t}\n77: \n78: \tif writeTimeout := os.Getenv(\"ROUTER_WRITE_TIMEOUT\"); writeTimeout != \"\" {\n79: \t\tif val, err := strconv.Atoi(writeTimeout); err == nil {\n80: \t\t\tcfg.WriteTimeout = val\n81: \t\t}\n82: \t}\n83: \n84: \tif idleTimeout := os.Getenv(\"ROUTER_IDLE_TIMEOUT\"); idleTimeout != \"\" {\n85: \t\tif val, err := strconv.Atoi(idleTimeout); err == nil {\n86: \t\t\tcfg.IdleTimeout = val\n87: \t\t}\n88: \t}\n89: \n90: \tif maxConcurrent := os.Getenv(\"ROUTER_MAX_CONCURRENT_REQUESTS\"); maxConcurrent != \"\" {\n91: \t\tif val, err := strconv.Atoi(maxConcurrent); err == nil {\n92: \t\t\tcfg.MaxConcurrentRequests = val\n93: \t\t}\n94: \t}\n95: \n96: \tif workloadMgrURL := os.Getenv(\"WORKLOAD_MANAGER_URL\"); workloadMgrURL != \"\" {\n97: \t\tcfg.WorkloadManagerURL = workloadMgrURL\n98: \t}\n99: \n100: \tif namespace := os.Getenv(\"AGENTCUBE_NAMESPACE\"); namespace != \"\" {\n101: \t\tcfg.AgentcubeNamespace = namespace\n102: \t}\n103: \n104: \tif err := cfg.Validate(); err != nil {\