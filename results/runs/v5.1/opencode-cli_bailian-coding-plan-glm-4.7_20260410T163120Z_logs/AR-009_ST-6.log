{"type":"tool_use","timestamp":1775849560240,"sessionID":"ses_2871ec0bbffeG75S7Y1zWrjj42","part":{"id":"prt_d78e1d456001kY50QbKns1AjDb","messageID":"msg_d78e1c4f1001svVP0G3e6NeqZY","sessionID":"ses_2871ec0bbffeG75S7Y1zWrjj42","type":"tool","tool":"read","callID":"toolu_tool-528c3a68055f4408bd5f4779d74ad601","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rsa\"\n6: \t\"crypto/x509\"\n7: \t\"encoding/pem\"\n8: \t\"fmt\"\n9: \t\"time\"\n10: \n11: \t\"github.com/golang-jwt/jwt/v5\"\n12: \tcorev1 \"k8s.io/api/core/v1\"\n13: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n14: \t\"k8s.io/client-go/kubernetes\"\n15: \t\"k8s.io/klog/v2\"\n16: )\n17: \n18: const (\n19: \tprivateKeyPEMType  = \"RSA PRIVATE KEY\"\n20: \tpublicKeyPEMType   = \"PUBLIC KEY\"\n21: \tjwtTokenExpiration = 5 * time.Minute\n22: )\n23: \n24: type JWTManager struct {\n25: \tprivateKey *rsa.PrivateKey\n26: \tpublicKey  *rsa.PublicKey\n27: \tclientset  kubernetes.Interface\n28: \tnamespace  string\n29: }\n30: \n31: func NewJWTManager(clientset kubernetes.Interface, namespace string) (*JWTManager, error) {\n32: \tif clientset == nil {\n33: \t\treturn nil, fmt.Errorf(\"kubernetes clientset is required\")\n34: \t}\n35: \n36: \tif namespace == \"\" {\n37: \t\tnamespace = defaultNamespace\n38: \t}\n39: \n40: \tjwtMgr := &JWTManager{\n41: \t\tclientset: clientset,\n42: \t\tnamespace: namespace,\n43: \t}\n44: \n45: \tif err := jwtMgr.tryStoreOrLoadJWTKeySecret(); err != nil {\n46: \t\tklog.Warningf(\"Failed to load or store JWT key secret: %v. Generating in-memory keys only.\", err)\n47: \t\tprivateKey, publicKey, err := generateRSAKeyPair()\n48: \t\tif err != nil {\n49: \t\t\treturn nil, fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n50: \t\t}\n51: \t\tjwtMgr.privateKey = privateKey\n52: \t\tjwtMgr.publicKey = publicKey\n53: \t}\n54: \n55: \treturn jwtMgr, nil\n56: }\n57: \n58: func (j *JWTManager) GenerateToken(sessionID string) (string, error) {\n59: \tif j.privateKey == nil {\n60: \t\treturn \"\", fmt.Errorf(\"JWT manager not initialized with private key\")\n61: \t}\n62: \n63: \tnow := time.Now()\n64: \tclaims := &JWTClaims{\n65: \t\tSessionID: sessionID,\n66: \t\tRegisteredClaims: jwt.RegisteredClaims{\n67: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n68: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(jwtTokenExpiration)),\n69: \t\t\tNotBefore: jwt.NewNumericDate(now),\n70: \t\t},\n71: \t}\n72: \n73: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n74: \ttokenString, err := token.SignedString(j.privateKey)\n75: \tif err != nil {\n76: \t\treturn \"\", fmt.Errorf(\"failed to sign JWT token: %w\", err)\n77: \t}\n78: \n79: \treturn tokenString, nil\n80: }\n81: \n82: func (j *JWTManager) ValidateToken(tokenString string) (*JWTClaims, error) {\n83: \tif j.publicKey == nil {\n84: \t\treturn nil, fmt.Errorf(\"JWT manager not initialized with public key\")\n85: \t}\n86: \n87: \ttoken, err := jwt.ParseWithClaims(tokenString, &JWTClaims{}, func(token *jwt.Token) (interface{}, error) {\n88: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n89: \t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])\n90: \t\t}\n91: \t\treturn j.publicKey, nil\n92: \t})\n93: \n94: \tif err != nil {\n95: \t\treturn nil, fmt.Errorf(\"failed to parse JWT token: %w\", err)\n96: \t}\n97: \n98: \tclaims, ok := token.Claims.(*JWTClaims)\n99: \tif !ok || !token.Valid {\n100: \t\treturn nil, fmt.Errorf(\"invalid JWT token claims\")\n101: \t}\n102: \n103: \tif time.Now().After(claims.ExpiresAt.Time) {\n104: \t\treturn nil, fmt.Errorf(\"JWT token has expired\")\n105: \t}\n106: \n107: \treturn claims, nil\n108: }\n109: \n110: func (j *JWTManager) tryStoreOrLoadJWTKeySecret() error {\n111: \tsecret, err := j.clientset.CoreV1().Secrets(j.namespace).Get(j.context(), secretName, metav1.GetOptions{})\n112: \tif err == nil {\n113: \t\treturn j.loadKeysFromSecret(secret)\n114: \t}\n115: \n116: \tif err != nil && !isNotFoundError(err) {\n117: \t\treturn fmt.Errorf(\"failed to check for existing JWT secret: %w\", err)\n118: \t}\n119: \n120: \treturn j.storeJWTKeySecret()\n121: }\n122: \n123: func (j *JWTManager) loadKeysFromSecret(secret *corev1.Secret) error {\n124: \tprivateKeyPEM, ok := secret.Data[\"private.pem\"]\n125: \tif !ok {\n126: \t\treturn fmt.Errorf(\"secret does not contain private.pem\")\n127: \t}\n128: \n129: \tpublicKeyPEM, ok := secret.Data[\"public.pem\"]\n130: \tif !ok {\n131: \t\treturn fmt.Errorf(\"secret does not contain public.pem\")\n132: \t}\n133: \n134: \tprivateKey, err := parsePrivateKeyPEM(privateKeyPEM)\n135: \tif err != nil {\n136: \t\treturn fmt.Errorf(\"failed to parse private key: %w\", err)\n137: \t}\n138: \n139: \tpublicKey, err := parsePublicKeyPEM(publicKeyPEM)\n140: \tif err != nil {\n141: \t\treturn fmt.Errorf(\"failed to parse public key: %w\", err)\n142: \t}\n143: \n144: \tj.privateKey = privateKey\n145: \tj.publicKey = publicKey\n146: \n147: \tklog.Infof(\"Successfully loaded JWT keys from secret: %s\", secretName)\n148: \treturn nil\n149: }\n150: \n151: func (j *JWTManager) storeJWTKeySecret() error {\n152: \tprivateKey, publicKey, err := generateRSAKeyPair()\n153: \tif err != nil {\n154: \t\treturn fmt.Errorf(\"failed to generate RSA key pair: %w\", err)\n155: \t}\n156: \n157: \tprivateKeyPEM := pem.EncodeToMemory(&pem.Block{\n158: \t\tType:  privateKeyPEMType,\n159: \t\tBytes: x509.MarshalPKCS1PrivateKey(privateKey),\n160: \t})\n161: \n162: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(publicKey)\n163: \tif err != nil {\n164: \t\treturn fmt.Errorf(\"failed to marshal public key: %w\", err)\n165: \t}\n166: \n167: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n168: \t\tType:  publicKeyPEMType,\n169: \t\tBytes: publicKeyBytes,\n170: \t})\n171: \n172: \tsecret := &corev1.Secret{\n173: \t\tObjectMeta: metav1.ObjectMeta{\n174: \t\t\tName:      secretName,\n175: \t\t\tNamespace: j.namespace,\n176: \t\t},\n177: \t\tData: map[string][]byte{\n178: \t\t\t\"private.pem\": privateKeyPEM,\n179: \t\t\t\"public.pem\":  publicKeyPEM,\n180: \t\t},\n181: \t}\n182: \n183: \t_, err = j.clientset.CoreV1().Secrets(j.namespace).Create(j.context(), secret, metav1.CreateOptions{})\n184: \tif err != nil {\n185: \t\treturn fmt.Errorf(\"failed to create JWT key secret: %w\", err)\n186: \t}\n187: \n188: \tj.privateKey = privateKey\n189: \tj.publicKey = publicKey\n190: \n191: \tklog.Infof(\"Successfully created JWT key secret: %s\", secretName)\n192: \treturn nil\n193: }\n194: \n195: func (j *JWTManager) context() context.Context {\n196: \treturn context.Background()\n197: }\n198: \n199: func generateRSAKeyPair() (*rsa.PrivateKey, *rsa.PublicKey, error) {\n200: \tprivateKey, err := rsa.GenerateKey(nil, 2048)\n201: \tif err != nil {\n202: \t\treturn nil, nil, fmt.Errorf(\"failed to generate RSA key: %w\", err)\n203: \t}\n204: \n205: \treturn privateKey, &privateKey.PublicKey, nil\n206: }\n207: \n208: func parsePrivateKeyPEM(privateKeyPEM []byte) (*rsa.PrivateKey, error) {\n209: \tblock, _ := pem.Decode(privateKeyPEM)\n210: \tif block == nil {\n211: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n212: \t}\n213: \n214: \tif block.Type != privateKeyPEMType {\n215: \t\treturn nil, fmt.Errorf(\"invalid PEM block type: %s\", block.Type)\n216: \t}\n217: \n218: \tprivateKey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n219: \tif err != nil {\n220: \t\treturn nil, fmt.Errorf(\"failed to parse private key: %w\", err)\n221: \t}\n222: \n223: \treturn privateKey, nil\n224: }\n225: \n226: func parsePublicKeyPEM(publicKeyPEM []byte) (*rsa.PublicKey, error) {\n227: \tblock, _ := pem.Decode(publicKeyPEM)\n228: \tif block == nil {\n229: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n230: \t}\n231: \n232: \tif block.Type != publicKeyPEMType {\n233: \t\treturn nil, fmt.Errorf(\"invalid PEM block type: %s\", block.Type)\n234: \t}\n235: \n236: \tpublicKey, err := x509.ParsePKIXPublicKey(block.Bytes)\n237: \tif err != nil {\n238: \t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n239: \t}\n240: \n241: \trsaPublicKey, ok := publicKey.(*rsa.PublicKey)\n242: \tif !ok {\n243: \t\treturn nil, fmt.Errorf(\"not an RSA public key\")\n244: \t}\n245: \n246: \treturn rsaPublicKey, nil\n247: }\n248: \n249: func isNotFoundError(err error) bool {\n250: \treturn false\n251: }\n\n(End of file - total 251 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (\n\tprivateKeyPEMType  = \"RSA PRIVATE KEY\"\n\tpublicKeyPEMType   = \"PUBLIC KEY\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/jwt.go","time":{"start":1775849560225,"end":1775849560238}}}}
{"type":"tool_use","timestamp":1775849560241,"sessionID":"ses_2871ec0bbffeG75S7Y1zWrjj42","part":{"id":"prt_d78e1d65e001om8er5qQ861XjN","messageID":"msg_d78e1c4f1001svVP0G3e6NeqZY","sessionID":"ses_2871ec0bbffeG75S7Y1zWrjj42","type":"tool","tool":"read","callID":"toolu_tool-5d166e0ce81c4ce18c3ed86782986543","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/utils.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/utils.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"net/url\"\n6: \t\"regexp\"\n7: \t\"strings\"\n8: \t\"time\"\n9: \n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: \t\"k8s.io/apimachinery/pkg/util/validation\"\n12: )\n13: \n14: const (\n15: \tsessionTTL = 5 * time.Minute\n16: )\n17: \n18: var (\n19: \tnamespaceRegex    = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)\n20: \tresourceNameRegex = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)\n21: \tsessionIDRegex    = regexp.MustCompile(`^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$`)\n22: )\n23: \n24: func isValidNamespace(namespace string) bool {\n25: \tif namespace == \"\" {\n26: \t\treturn false\n27: \t}\n28: \tif len(namespace) > 63 {\n29: \t\treturn false\n30: \t}\n31: \treturn namespaceRegex.MatchString(namespace)\n32: }\n33: \n34: func isValidResourceName(name string) bool {\n35: \tif name == \"\" {\n36: \t\treturn false\n37: \t}\n38: \tif len(name) > 253 {\n39: \t\treturn false\n40: \t}\n41: \treturn resourceNameRegex.MatchString(name)\n42: }\n43: \n44: func sanitizePath(path string) string {\n45: \tcleanPath := strings.TrimSpace(path)\n46: \tcleanPath = strings.ReplaceAll(cleanPath, \"..\", \"\")\n47: \tcleanPath = strings.ReplaceAll(cleanPath, \"\\\\\", \"\")\n48: \n49: \tif !strings.HasPrefix(cleanPath, \"/\") {\n50: \t\tcleanPath = \"/\" + cleanPath\n51: \t}\n52: \n53: \treturn cleanPath\n54: }\n55: \n56: func normalizeURL(rawURL string) (string, error) {\n57: \tparsed, err := url.Parse(rawURL)\n58: \tif err != nil {\n59: \t\treturn \"\", err\n60: \t}\n61: \n62: \tparsed.Path = sanitizePath(parsed.Path)\n63: \n64: \treturn parsed.String(), nil\n65: }\n66: \n67: func parseSessionID(sessionID string) error {\n68: \tif sessionID == \"\" {\n69: \t\treturn fmt.Errorf(\"session ID is required\")\n70: \t}\n71: \n72: \tif !sessionIDRegex.MatchString(sessionID) {\n73: \t\treturn fmt.Errorf(\"invalid session ID format\")\n74: \t}\n75: \n76: \treturn nil\n77: }\n78: \n79: func validateKind(kind string) error {\n80: \tif kind != types.AgentRuntimeKind && kind != types.CodeInterpreterKind {\n81: \t\treturn fmt.Errorf(\"invalid kind: %s, must be %s or %s\", kind, types.AgentRuntimeKind, types.CodeInterpreterKind)\n82: \t}\n83: \treturn nil\n84: }\n85: \n86: func generateCacheKey(sessionID, namespace, name, kind string) string {\n87: \treturn fmt.Sprintf(\"session:%s:%s:%s:%s\", namespace, kind, name, sessionID)\n88: }\n89: \n90: func isHopByHopHeader(header string) bool {\n91: \thopByHopHeaders := []string{\n92: \t\t\"Connection\",\n93: \t\t\"Keep-Alive\",\n94: \t\t\"Proxy-Authenticate\",\n95: \t\t\"Proxy-Authorization\",\n96: \t\t\"Te\",\n97: \t\t\"Trailers\",\n98: \t\t\"Transfer-Encoding\",\n99: \t\t\"Upgrade\",\n100: \t}\n101: \n102: \tfor _, h := range hopByHopHeaders {\n103: \t\tif strings.EqualFold(header, h) {\n104: \t\t\treturn true\n105: \t\t}\n106: \t}\n107: \treturn false\n108: }\n109: \n110: func constructUpstreamURL(protocol, endpoint string) string {\n111: \tif strings.Contains(endpoint, \"://\") {\n112: \t\treturn endpoint\n113: \t}\n114: \n115: \tif protocol == \"\" {\n116: \t\tprotocol = \"http\"\n117: \t}\n118: \n119: \tif !strings.HasPrefix(endpoint, \"http://\") && !strings.HasPrefix(endpoint, \"https://\") {\n120: \t\tendpoint = fmt.Sprintf(\"%s://%s\", protocol, endpoint)\n121: \t}\n122: \n123: \treturn endpoint\n124: }\n125: \n126: func findMatchingEntryPoint(requestPath string, entryPoints []types.SandboxEntryPoint) *types.SandboxEntryPoint {\n127: \tif len(entryPoints) == 0 {\n128: \t\treturn nil\n129: \t}\n130: \n131: \tfor _, ep := range entryPoints {\n132: \t\tif strings.HasPrefix(requestPath, ep.Path) {\n133: \t\t\treturn &ep\n134: \t\t}\n135: \t}\n136: \n137: \tfor _, ep := range entryPoints {\n138: \t\tif ep.Path == \"/\" || ep.Path == \"\" {\n139: \t\t\treturn &ep\n140: \t\t}\n141: \t}\n142: \n143: \treturn &entryPoints[0]\n144: }\n145: \n146: func getK8sValidation(field string) bool {\n147: \terrs := validation.IsDNS1123Label(field)\n148: \treturn len(errs) == 0\n149: }\n\n(End of file - total 149 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"net/url\"\n\t\"regexp\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/apimachinery/pkg/util/validation\"\n)\n\nconst (\n\tsessionTTL = 5 * time.Minute\n)\n\nvar (\n\tnamespaceRegex    = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)\n\tresourceNameRegex = regexp.MustCompile(`^[a-z0-9]([-a-z0-9]*[a-z0-9])?$`)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/utils.go","time":{"start":1775849560228,"end":1775849560240}}}}
