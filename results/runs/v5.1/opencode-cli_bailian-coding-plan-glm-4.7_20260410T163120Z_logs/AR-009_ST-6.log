lt\",\n44: \t\tName:         \"test-agent\",\n45: \t\tEntryPoints:  []types.SandboxEntryPoint{{Path: \"/api\", Protocol: \"http\", Endpoint: \"api:8080\"}},\n46: \t\tLastActivity: now.Format(time.RFC3339),\n47: \t\tCreatedAt:    now.Format(time.RFC3339),\n48: \t\tExpiresAt:    expiry.Format(time.RFC3339),\n49: \t\tPodIP:        \"10.0.0.1\",\n50: \t}\n51: \n52: \tsandboxInfo := SandboxInfoFromWorkloadManager(resp, \"test-session-id\")\n53: \n54: \tif sandboxInfo.Kind != types.AgentRuntimeKind {\n55: \t\tt.Errorf(\"Expected kind %s, got %s\", types.AgentRuntimeKind, sandboxInfo.Kind)\n56: \t}\n57: \n58: \tif sandboxInfo.SandboxID != \"test-sandbox-id\" {\n59: \t\tt.Errorf(\"Expected sandbox ID 'test-sandbox-id', got '%s'\", sandboxInfo.SandboxID)\n60: \t}\n61: \n62: \tif sandboxInfo.SandboxName != \"test-sandbox\" {\n63: \t\tt.Errorf(\"Expected sandbox name 'test-sandbox', got '%s'\", sandboxInfo.SandboxName)\n64: \t}\n65: \n66: \tif sandboxInfo.SessionID != \"test-session-id\" {\n67: \t\tt.Errorf(\"Expected session ID 'test-session-id', got '%s'\", sandboxInfo.SessionID)\n68: \t}\n69: \n70: \tif len(sandboxInfo.EntryPoints) != 1 {\n71: \t\tt.Errorf(\"Expected 1 entry point, got %d\", len(sandboxInfo.EntryPoints))\n72: \t}\n73: \n74: \tif sandboxInfo.PodIP != \"10.0.0.1\" {\n75: \t\tt.Errorf(\"Expected pod IP '10.0.0.1', got '%s'\", sandboxInfo.PodIP)\n76: \t}\n77: }\n78: \n79: func TestSandboxNotFoundError(t *testing.T) {\n80: \terr := &SandboxNotFoundError{\n81: \t\tSessionID: \"test-session\",\n82: \t\tName:      \"test-agent\",\n83: \t\tNamespace: \"default\",\n84: \t\tKind:      types.AgentRuntimeKind,\n85: \t}\n86: \n87: \tif err.Error() == \"\" {\n88: \t\tt.Error(\"Expected non-empty error message\")\n89: \t}\n90: \n91: \tif err.HTTPStatusCode() != http.StatusNotFound {\n92: \t\tt.Errorf(\"Expected status code 404, got %d\", err.HTTPStatusCode())\n93: \t}\n94: \n95: \tif err.ErrorCode() != \"SANDBOX_NOT_FOUND\" {\n96: \t\tt.Errorf(\"Expected error code 'SANDBOX_NOT_FOUND', got '%s'\", err.ErrorCode())\n97: \t}\n98: }\n99: \n100: func TestSessionExpiredError(t *testing.T) {\n101: \terr := &SessionExpiredError{SessionID: \"test-session\"}\n102: \n103: \tif err.Error() == \"\" {\n104: \t\tt.Error(\"Expected non-empty error message\")\n105: \t}\n106: \n107: \tif err.HTTPStatusCode() != http.StatusNotFound {\n108: \t\tt.Errorf(\"Expected status code 404, got %d\", err.HTTPStatusCode())\n109: \t}\n110: \n111: \tif err.ErrorCode() != \"SESSION_EXPIRED\" {\n112: \t\tt.Errorf(\"Expected error code 'SESSION_EXPIRED', got '%s'\", err.ErrorCode())\n113: \t}\n114: }\n115: \n116: func TestWorkloadManagerError(t *testing.T) {\n117: \terr := &WorkloadManagerError{\n118: \t\tMessage: \"workload manager unavailable\",\n119: \t\tCode:    http.StatusServiceUnavailable,\n120: \t}\n121: \n122: \tif err.Error() == \"\" {\n123: \t\tt.Error(\"Expected non-empty error message\")\n124: \t}\n125: \n126: \tstatusCode := err.HTTPStatusCode()\n127: \tif statusCode != http.StatusServiceUnavailable {\n128: \t\tt.Errorf(\"Expected status code 503, got %d\", statusCode)\n129: \t}\n130: \n131: \tif err.ErrorCode() != \"WORKLOAD_MANAGER_ERROR\" {\n132: \t\tt.Errorf(\"Expected error code 'WORKLOAD_MANAGER_ERROR', got '%s'\", err.ErrorCode())\n133: \t}\n134: }\n135: \n136: func TestValidationError(t *testing.T) {\n137: \terr := &ValidationError{\n138: \t\tField:   \"namespace\",\n139: \t\tMessage: \"invalid format\",\n140: \t}\n141: \n142: \tif err.Error() == \"\" {\n143: \t\tt.Error(\"Expected non-empty error message\")\n144: \t}\n145: \n146: \tif err.HTTPStatusCode() != http.StatusBadRequest {\n147: \t\tt.Errorf(\"Expected status code 400, got %d\", err.HTTPStatusCode())\n148: \t}\n149: \n150: \tif err.ErrorCode() != \"VALIDATION_ERROR\" {\n151: \t\tt.Errorf(\"Expected error code 'VALIDATION_ERROR', got '%s'\", err.ErrorCode())\n152: \t}\n153: }\n154: \n155: func TestGetHTTPStatusCode(t *testing.T) {\n156: \ttests := []struct {\n157: \t\tdesc     string\n158: \t\terr      error\n159: \t\texpected int\n160: \t}{\n161: \t\t{\"sandbox not found\", &SandboxNotFoundError{}, http.StatusNotFound},\n162: \t\t{\"session expired\", &SessionExpiredError{}, http.StatusNotFound},\n163: \t\t{\"workload manager error\", &WorkloadManagerError{Code: http.StatusServiceUnavailable}, http.StatusServiceUnavailable},\n164: \t\t{\"validation error\", &ValidationError{}, http.StatusBadRequest},\n165: \t\t{\"generic error\", &someError{}, http.StatusInternalServerError},\n166: \t}\n167: \n168: \tfor _, tt := range tests {\n169: \t\tt.Run(tt.desc, func(t *testing.T) {\n170: \t\t\tstatusCode := GetHTTPStatusCode(tt.err)\n171: \t\t\tif statusCode != tt.expected {\n172: \t\t\t\tt.Errorf(\"Expected status code %d, got %d\", tt.expected, statusCode)\n173: \t\t\t}\n174: \t\t})\n175: \t}\n176: }\n177: \n178: func TestGetErrorCode(t *testing.T) {\n179: \ttests := []struct {\n180: \t\tdesc     string\n181: \t\terr      error\n182: \t\texpected string\n183: \t}{\n184: \t\t{\"sandbox not found\", &SandboxNotFoundError{}, \"SANDBOX_NOT_FOUND\"},\n185: \t\t{\"session expired\", &SessionExpiredError{}, \"SESSION_EXPIRED\"},\n186: \t\t{\"workload manager error\", &WorkloadManagerError{}, \"WORKLOAD_MANAGER_ERROR\"},\n187: \t\t{\"validation error\", &ValidationError{}, \"VALIDATION_ERROR\"},\n188: \t\t{\"generic error\", &someError{}, \"\"},\n189: \t}\n190: \n191: \tfor _, tt := range tests {\n192: \t\tt.Run(tt.desc, func(t *testing.T) {\n193: \t\t\terrorCode := GetErrorCode(tt.err)\n194: \t\t\tif errorCode != tt.expected {\n195: \t\t\t\tt.Errorf(\"Expected error code '%s', got '%s'\", tt.expected, errorCode)\n196: \t\t\t}\n197: \t\t})\n198: \t}\n199: }\n200: \n201: type someError struct{}\n202: \n203: func (e *someError) Error() string {\n204: \treturn \"some error\"\n205: }\n\n(End of file - total 205 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/volcan