imeError(\n44:                 \"Kubernetes Python client is not installed. \"\n45:                 \"Install it with: pip install kubernetes\"\n46:             )\n47: \n48:         if verbose:\n49:             logging.basicConfig(level=logging.DEBUG)\n50: \n51:         self._load_config()\n52:         self._custom_api = CustomObjectsApi()\n53: \n54:     def _load_config(self) -> None:\n55:         \"\"\"Load Kubernetes configuration.\"\"\"\n56:         try:\n57:             if self.kubeconfig:\n58:                 config.load_kube_config(config_file=self.kubeconfig)\n59:             else:\n60:                 config.load_kube_config()\n61:         except config.ConfigException:\n62:             try:\n63:                 config.load_incluster_config()\n64:             except config.ConfigException as e:\n65:                 raise RuntimeError(\n66:                     \"Failed to load Kubernetes configuration. \"\n67:                     \"Please provide a kubeconfig file or run in a Kubernetes cluster.\"\n68:                 ) from e\n69: \n70:     def _ensure_namespace(self) -> None:\n71:         \"\"\"Ensure the namespace exists.\"\"\"\n72:         try:\n73:             core_v1 = client.CoreV1Api()\n74:             core_v1.read_namespace(self.namespace)\n75:         except ApiException as e:\n76:             if e.status == 404:\n77:                 core_v1 = client.CoreV1Api()\n78:                 namespace = client.V1Namespace(\n79:                     metadata=client.V1ObjectMeta(name=self.namespace)\n80:                 )\n81:                 core_v1.create_namespace(namespace)\n82:                 logger.info(f\"Created namespace: {self.namespace}\")\n83:             else:\n84:                 raise\n85: \n86:     def deploy_agent_runtime(\n87:         self,\n88:         agent_name: str,\n89:         image_url: str,\n90:         port: int,\n91:         entrypoint: Optional[str] = None,\n92:         env_vars: Optional[Dict[str, str]] = None,\n93:         workload_manager_url: Optional[str] = None,\n94:         router_url: Optional[str] = None,\n95:         readiness_probe_path: Optional[str] = None,\n96:         readiness_probe_port: Optional[int] = None,\n97:     ) -> Dict[str, Any]:\n98:         \"\"\"Deploy an agent using AgentRuntime custom resource.\"\"\"\n99:         self._ensure_namespace()\n100: \n101:         sanitized_name = self._sanitize_name(agent_name)\n102: \n103:         workload_manager = workload_manager_url or os.getenv(\"WORKLOAD_MANAGER_URL\")\n104:         router = router_url or os.getenv(\"ROUTER_URL\")\n105: \n106:         if not workload_manager:\n107:             raise ValueError(\n108:                 \"workload_manager_url is required. \"\n109:                 \"Provide it as a parameter or set WORKLOAD_MANAGER_URL environment variable.\"\n110:             )\n111: \n112:         if not router:\n113:             raise ValueError(\n114:                 \"router_url is required. \"\n115:                 \"Provide it as a parameter or set ROUTER_URL environment variable.\"\n116:             )\n117: \n118:         env_list = [\n119:             client.V1EnvVar(name=k, value=v) for k, v in (env_vars or {}).items()\n120:         ]\n121: \n122:         cr = {\n123:             \"apiVersion\": f\"{CR_GROUP}/{CR_VERSION}\",\n124:             \"kind\": \"AgentRuntime\",\n125:             \"metadata\": {\n126:                 \"name\": sanitized_name,\n127:                 \"namespace\": self.namespace,\n128:             },\n129:             \"spec\": {\n130:                 \"image\": image_url,\n131:                 \"port\": port,\n132:                 \"entrypoint\": entrypoint or \"\",\n133:                 \"env\": env_list,\n134:                 \"workloadManagerURL\": workload_manager,\n135:                 \"routerURL\": router,\n136:                 \"sessionTimeout\": \"15m\",\n137:                 \"maxSessionDuration\": \"8h\",\n138:                 \"readinessProbe\": {\n139:                     \"path\": readiness_probe_path or \"/health\",\n140:                     \"port\": readiness_probe_port or port,\n141:                 },\n142:                 \"imagePullSecrets\": [{\"name\": \"default-secret\"}],\n143:             },\n144:         }\n145: \n146:         try:\n147:             self._custom_api.create_namespaced_custom_object(\n148:                 group=CR_GROUP,\n149:                 version=CR_VERSION,\n150:                 namespace=self.namespace,\n151:                 plural=CR_PLURAL,\n152:                 body=cr,\n153:             )\n154:             logger.info(f\"Created AgentRuntime {sanitized_name}\")\n155:         except ApiException as e:\n156:             if e.status == 409:\n157:                 self._custom_api.replace_namespaced_custom_object(\n158:                     group=CR_GROUP,\n159:                     version=CR_VERSION,\n160:                     namespace=self.namespace,\n161:                     plural=CR_PLURAL,\n162:                     name=sanitized_name,\n163:                     body=cr,\n164:                 )\n165:                 logger.info(f\"Updated AgentRuntime {sanitized_name}\")\n166:             else:\n167:                 raise\n168: \n169:         return {\n170:             \"status\": \"created\",\n171:             \"agent_name\": sanitized_name,\n172:             \"namespace\": self.namespace,\n173:         }\n174: \n175:     def get_agent_runtime(self, name: str, namespace: str) -> Optional[Dict[str, Any]]:\n176:         \"\"\"Get an AgentRuntime custom resource.\"\"\"\n177:         try:\n178:             cr = self._custom_api.get_namespaced_custom_object(\n179:                 group=CR_GROUP,\n180:                 version=CR_VERSION,\n181:                 namespace=namespace,\n182:                 plural=CR_PLURAL,\n183:                 name=name,\n184:             )\n185:             return cr\n186:         except ApiException as e:\n187:             if e.status == 404:\n188:                 return None\n189:             raise\n190: \n191:     def _sanitize_name(self, name: str) -> str:\n192:         \"\"\"Sanitize a name for Kubernetes.\"\"\"\n193:         sanitized = re.sub(r\"[^a-z0-9-]\", \"-\", name.lower())\n194:         sanitized = re.sub(r\"-+\", \"-\", sanitized)\n195:         sanitized = sanitized.strip(\"-\")\n196:         if len(sanitized) > 63:\n197:             sanitized = sanitized[:63].rstrip(\"-\")\n198:         return sanitized or \"agent\"\n\n(End of file - total 198 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube provider service for AgentRuntime CR.\"\"\"\n\nimport logging\nimport os\nimport re\nfrom typing import Any, Dict, List, Optional\n\ntry:\n    from kubernetes import client, config\n    from kubernetes.client.rest import ApiException\n    from kubernetes.client import CustomObjectsApi\n    KUBERNETES_AVAILABLE = True\nexcept ImportError:\n    KUBERNETES_AVAILABLE = False\n    client = None\n    config = None\n    ApiException = Exception\n    CustomObjectsApi = None\n\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/agentcube_provider.py","time":{"start":1775867829087,"end":1775867829121}}}}
{"type":"tool_use","timestamp":1775867829124,"sessionID":"ses_28607dc6fffe0RHK34NP7uECaP","part":{"id":"prt_d79f89b3c001SoPow43mlJT6H0","messageID":"msg_d79f857aa001mcy42MYo0n32GC","sessionID":"ses_28607dc6fffe0RHK34NP7uECaP","type":"tool","tool":"read","callID":"toolu_tool-633ed0328f55462e9d2b2f37c9e6d4db","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Service for managing agent metadata.\"\"\"\n2: \n3: import logging\n4: import os\n5: from pathlib import Path\n6: from typing import Any, Dict, List, Optional\n7: \n8: import yaml\n9: from pydantic import BaseModel, field_validator, ConfigDict\n10: \n11: \n12: logger = logging.getLogger(__name__)\n13: \n14: \n15: class AgentMetadata(BaseModel):\n16:     \"\"\"Agent metadata model.\"\"\"\n17: \n18:     model_config = ConfigDict(extra=\"allow\", validate_assignment=True)\n19: \n20:     agent_name: str\n21:     description: Optional[str] = None\n22:     language: str = \"python\"\n23:     entrypoint: str\n24:     port: int = 8080\n25:     build_mode: str = \"local\"\n26:     region: Optional[str] = None\n27:     version: Optional[str] = None\n28:     image: Optional[Dict[str, Any]] = None\n29:     auth: Optional[Dict[str, Any]] = None\n30:     requirements_file: Optional[str] = \"requirements.txt\"\n31:     registry_url: Optional[str] = \"\"\n32:     registry_username: Optional[str] = \"\"\n33:     registry_password: Optional[str] = \"\"\n34:     agent_endpoint: Optional[str] = None\n35:     workload_manager_url: Optional[str] = None\n36:     router_url: Optional[str] = None\n37:     readiness_probe_path: Optional[str] = None\n38:     readiness_probe_port: Optional[int] = None\n39:     agent_id: Optional[str] = None\n40:     session_id: Optional[str] = None\n41:     k8s_deployment: Optional[Dict[str, Any]] = None\n42: \n43:     @field_validator(\"language\")\n44:     @classmethod\n45:     def validate_language(cls, v: str) -> str:\n46:         \"\"\"Validate language is supported.\"\"\"\n47:         if v.lower() not in (\"python\", \"java\"):\n48:             raise ValueError(f\"Language must be 'python' or 'java', got '{v}'\")\n49:         return v.lower()\n50: \n51:     @field_validator(\"build_mode\")\n52:     @classmethod\n53:     def validate_build_mode(cls, v: str) -> str:\n54:         \"\"\"Validate build mode is supported.\"\"\"\n55:         if v.lower() not in (\"local\", \"cloud\"):\n56:             raise ValueError(f\"Build mode must be 'local' or 'cloud', got '{v}'\")\n57:         return v.lower()\n58: \n59:     @field_validator(\"port\")\n60:     @classmethod\n61:     def validate_port(cls, v: int) -> int:\n62:         \"\"\"Validate port is in valid range.\"\"\"\n63:         if not 1 <= v <= 65535:\n64:             raise ValueError(f\"Port must be between 1 and 65535, got {v}\")\n65:         return v\n66: \n67: \n68: class MetadataService:\n69:     \"\"\"Service for managing agent metadata files.\"\"\"\n70: \n71:     def __init__(self, verbose: bool = False) -> None:\n72:         \"\"\"Initialize the metadata service.\"\"\"\n73:         self.verbose = verbose\n74:         if verbose:\n75:             logging.basicConfig(level=logging.DEBUG)\n76: \n77:     def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n78:         \"\"\"Load metadata from workspace directory.\"\"\"\n79:         metadata_file = self._find_metadata_file(workspace_path)\n80:         if not metadata_file or not metadata_file.exists():\n81:             raise FileNotFoundError(\n82:                 f\"No metadata file found in {workspace_path}. \"\n83:                 \"Expected one of: agent_metadata.yaml, agent.yaml, metadata.yaml\"\n84:             )\n85: \n86:         logger.debug(f\"Loading metadata from {metadata_file}\")\n87:         with open(metadata_file, \"r\") as f:\n88:             data = yaml.safe_load(f) or {}\n89: \n90:         return AgentMetadata(**data)\n91: \n92:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n93:         \"\"\"Save metadata to workspace directory.\"\"\"\n94:         metadata_file = workspace_path / \"agent_metadata.yaml\"\n95:         logger.debug(f\"Saving metadata to {metadata_file}\")\n96: \n97:         with open(metadata_file, \"w\") as f:\n98:             yaml.dump(\n99:                 metadata.model_dump(exclude_none=True),\n100:                 f,\n101:                 default_flow_style=False,\n102:                 indent=2,\n103:                 sort_keys=False,\n104:             )\n105: \n106:     def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n107:         \"\"\"Update metadata with new values.\"\"\"\n108:         metadata = self.load_metadata(workspace_path)\n109:         for key, value in updates.items():\n110:             if value is not None:\n111:                 setattr(metadata, key, value)\n112:         self.save_metadata(workspace_path, metadata)\n113:         return metadata\n114: \n115:     def validate_workspace(self, workspace_path: Path) -> bool:\n116:         \"\"\"Validate workspace structure.\"\"\"\n117:         if not workspace_path.exists():\n118:             raise FileNotFoundError(f\"Workspace directory does not exist: {workspace_path}\")\n119: \n120:         if not workspace_path.is_dir():\n121:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n122: \n123:         return True\n124: \n125:     def _find_metadata_file(self, workspace_path: Path) -> Optional[Path]:\n126:         \"\"\"Find metadata file in workspace directory.\"\"\"\n127:         for filename in (\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"):\n128:             metadata_file = workspace_path / filename\n129:             if metadata_file.exists():\n130:                 return metadata_file\n131:         return None\n132: \n133:     def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n134:         \"\"\"Validate Python workspace structure.\"\"\"\n135:         py_files = list(workspace_path.glob(\"*.py\"))\n136:         if not py_files:\n137:             raise ValueError(\"No Python files found in workspace\")\n138: \n139:     def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n140:         \"\"\"Validate Java workspace structure.\"\"\"\n141:         pom_file = workspace_path / \"pom.xml\"\n142:         if not pom_file.exists():\n143:             raise ValueError(\"Java workspace requires pom.xml file\")\n\n(End of file - total 143 lines)\n</content>","metadata":{"preview":"\"\"\"Service for managing agent metadata.\"\"\"\n\nimport logging\nimport os\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport yaml\nfrom pydantic import BaseModel, field_validator, ConfigDict\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Agent metadata model.\"\"\"\n\n    model_config = ConfigDict(extra=\"allow\", validate_assignment=True)\n\n    agent_name: str","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775867829091,"end":1775867829123}}}}
