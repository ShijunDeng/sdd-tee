{"type":"tool_use","timestamp":1775867829120,"sessionID":"ses_28607dc6fffe0RHK34NP7uECaP","part":{"id":"prt_d79f895cd001LlgnTDvk8xEh8o","messageID":"msg_d79f857aa001mcy42MYo0n32GC","sessionID":"ses_28607dc6fffe0RHK34NP7uECaP","type":"tool","tool":"read","callID":"toolu_tool-00a2dd42ae864f459d28f427f4909c2f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/k8s_provider.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/k8s_provider.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Kubernetes provider service.\"\"\"\n2: \n3: import logging\n4: import re\n5: import time\n6: from typing import Any, Dict, List, Optional\n7: \n8: try:\n9:     from kubernetes import client, config\n10:     from kubernetes.client.rest import ApiException\n11:     KUBERNETES_AVAILABLE = True\n12: except ImportError:\n13:     KUBERNETES_AVAILABLE = False\n14:     client = None\n15:     config = None\n16:     ApiException = Exception\n17: \n18: \n19: logger = logging.getLogger(__name__)\n20: \n21: \n22: class KubernetesProvider:\n23:     \"\"\"Provider for deploying agents to standard Kubernetes.\"\"\"\n24: \n25:     def __init__(\n26:         self,\n27:         namespace: str = \"default\",\n28:         verbose: bool = False,\n29:         kubeconfig: Optional[str] = None,\n30:     ) -> None:\n31:         \"\"\"Initialize the Kubernetes provider.\"\"\"\n32:         self.namespace = namespace\n33:         self.verbose = verbose\n34:         self.kubeconfig = kubeconfig\n35: \n36:         if not KUBERNETES_AVAILABLE:\n37:             raise RuntimeError(\n38:                 \"Kubernetes Python client is not installed. \"\n39:                 \"Install it with: pip install kubernetes\"\n40:             )\n41: \n42:         if verbose:\n43:             logging.basicConfig(level=logging.DEBUG)\n44: \n45:         self._load_config()\n46:         self._core_v1 = client.CoreV1Api()\n47:         self._apps_v1 = client.AppsV1Api()\n48: \n49:     def _load_config(self) -> None:\n50:         \"\"\"Load Kubernetes configuration.\"\"\"\n51:         try:\n52:             if self.kubeconfig:\n53:                 config.load_kube_config(config_file=self.kubeconfig)\n54:             else:\n55:                 config.load_kube_config()\n56:         except config.ConfigException:\n57:             try:\n58:                 config.load_incluster_config()\n59:             except config.ConfigException as e:\n60:                 raise RuntimeError(\n61:                     \"Failed to load Kubernetes configuration. \"\n62:                     \"Please provide a kubeconfig file or run in a Kubernetes cluster.\"\n63:                 ) from e\n64: \n65:     def _ensure_namespace(self) -> None:\n66:         \"\"\"Ensure the namespace exists.\"\"\"\n67:         try:\n68:             self._core_v1.read_namespace(self.namespace)\n69:         except ApiException as e:\n70:             if e.status == 404:\n71:                 namespace = client.V1Namespace(\n72:                     metadata=client.V1ObjectMeta(name=self.namespace)\n73:                 )\n74:                 self._core_v1.create_namespace(namespace)\n75:                 logger.info(f\"Created namespace: {self.namespace}\")\n76:             else:\n77:                 raise\n78: \n79:     def deploy_agent(\n80:         self,\n81:         agent_name: str,\n82:         image_url: str,\n83:         port: int,\n84:         entrypoint: Optional[str] = None,\n85:         replicas: int = 1,\n86:         node_port: Optional[int] = None,\n87:         env_vars: Optional[Dict[str, str]] = None,\n88:     ) -> Dict[str, Any]:\n89:         \"\"\"Deploy an agent to Kubernetes.\"\"\"\n90:         self._ensure_namespace()\n91: \n92:         sanitized_name = self._sanitize_name(agent_name)\n93: \n94:         env_list = [\n95:             client.V1EnvVar(name=k, value=v) for k, v in (env_vars or {}).items()\n96:         ]\n97: \n98:         container = client.V1Container(\n99:             name=sanitized_name,\n100:             image=image_url,\n101:             ports=[client.V1ContainerPort(container_port=port)],\n102:             env=env_list,\n103:         )\n104: \n105:         deployment = self._create_deployment(\n106:             sanitized_name, image_url, port, entrypoint, replicas, env_vars\n107:         )\n108: \n109:         service = self._create_service(sanitized_name, port, node_port)\n110: \n111:         self.wait_for_deployment_ready(sanitized_name, timeout=120)\n112: \n113:         result = {\n114:             \"deployment_name\": sanitized_name,\n115:             \"service_name\": sanitized_name,\n116:             \"namespace\": self.namespace,\n117:             \"replicas\": replicas,\n118:             \"container_port\": port,\n119:             \"node_port\": service.spec.ports[0].node_port,\n120:             \"service_url\": f\"http://localhost:{service.spec.ports[0].node_port}\",\n121:         }\n122: \n123:         logger.info(f\"Successfully deployed agent {sanitized_name}\")\n124:         return result\n125: \n126:     def _create_deployment(\n127:         self,\n128:         name: str,\n129:         image_url: str,\n130:         port: int,\n131:         entrypoint: Optional[str],\n132:         replicas: int,\n133:         env_vars: Optional[Dict[str, str]],\n134:     ) -> Dict[str, Any]:\n135:         \"\"\"Create a Kubernetes deployment.\"\"\"\n136:         env_list = [\n137:             client.V1EnvVar(name=k, value=v) for k, v in (env_vars or {}).items()\n138:         ]\n139: \n140:         container = client.V1Container(\n141:             name=name,\n142:             image=image_url,\n143:             ports=[client.V1ContainerPort(container_port=port)],\n144:             env=env_list,\n145:         )\n146: \n147:         template = client.V1PodTemplateSpec(\n148:             metadata=client.V1ObjectMeta(labels={\"app\": name}),\n149:             spec=client.V1PodSpec(containers=[container]),\n150:         )\n151: \n152:         spec = client.V1DeploymentSpec(\n153:             replicas=replicas,\n154:             template=template,\n155:             selector=client.V1LabelSelector(match_labels={\"app\": name}),\n156:         )\n157: \n158:         deployment = client.V1Deployment(\n159:             api_version=\"apps/v1\",\n160:             kind=\"Deployment\",\n161:             metadata=client.V1ObjectMeta(name=name, namespace=self.namespace),\n162:             spec=spec,\n163:         )\n164: \n165:         try:\n166:             self._apps_v1.create_namespaced_deployment(self.namespace, deployment)\n167:             logger.info(f\"Created deployment {name}\")\n168:         except ApiException as e:\n169:             if e.status == 409:\n170:                 self._apps_v1.replace_namespaced_deployment(name, self.namespace, deployment)\n171:                 logger.info(f\"Updated deployment {name}\")\n172:             else:\n173:                 raise\n174: \n175:         return deployment.to_dict()\n176: \n177:     def _create_service(\n178:         self,\n179:         name: str,\n180:         port: int,\n181:         node_port: Optional[int],\n182:     ) -> client.V1Service:\n183:         \"\"\"Create a Kubernetes NodePort service.\"\"\"\n184:         service = client.V1Service(\n185:             api_version=\"v1\",\n186:             kind=\"Service\",\n187:             metadata=client.V1ObjectMeta(name=name, namespace=self.namespace),\n188:             spec=client.V1ServiceSpec(\n189:                 type=\"NodePort\",\n190:                 selector={\"app\": name},\n191:                 ports=[\n192:                     client.V1ServicePort(\n193:                         port=port,\n194:                         target_port=port,\n195:                         node_port=node_port,\n196:                     )\n197:                 ],\n198:             ),\n199:         )\n200: \n201:         try:\n202:             created = self._core_v1.create_namespaced_service(self.namespace, service)\n203:             logger.info(f\"Created service {name}\")\n204:         except ApiException as e:\n205:             if e.status == 409:\n206:                 created = self._core_v1.replace_namespaced_service(name, self.namespace, service)\n207:                 logger.info(f\"Updated service {name}\")\n208:             else:\n209:                 raise\n210: \n211:         return created\n212: \n213:     def wait_for_deployment_ready(self, name: str, timeout: int = 120) -> None:\n214:         \"\"\"Wait for a deployment to be ready.\"\"\"\n215:         start_time = time.time()\n216: \n217:         while time.time() - start_time < timeout:\n218:             try:\n219:                 deployment = self._apps_v1.read_namespaced_deployment(name, self.namespace)\n220:                 if (\n221:                     deployment.status.ready_replicas is not None\n222:                     and deployment.status.ready_replicas >= deployment.spec.replicas\n223:                 ):\n224:                     logger.info(f\"Deployment {name} is ready\")\n225:                     return\n226:             except ApiException as e:\n227:                 logger.warning(f\"Error checking deployment status: {e}\")\n228: \n229:             time.sleep(2)\n230: \n231:         raise TimeoutError(f\"Deployment {name} did not become ready within {timeout} seconds\")\n232: \n233:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n234:         \"\"\"Get the status of an agent deployment.\"\"\"\n235:         sanitized_name = self._sanitize_name(agent_name)\n236: \n237:         try:\n238:             deployment = self._apps_v1.read_namespaced_deployment(sanitized_name, self.namespace)\n239:             return {\n240:                 \"status\": \"running\",\n241:                 \"replicas\": deployment.spec.replicas,\n242:                 \"ready_replicas\": deployment.status.ready_replicas or 0,\n243:                 \"available_replicas\": deployment.status.available_replicas or 0,\n244:             }\n245:         except ApiException as e:\n246:             if e.status == 404:\n247:                 return {\"status\": \"not_found\"}\n248:             raise\n249: \n250:     def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n251:         \"\"\"Delete an agent deployment.\"\"\"\n252:         sanitized_name = self._sanitize_name(agent_name)\n253: \n254:         try:\n255:             self._apps_v1.delete_namespaced_deployment(sanitized_name, self.namespace)\n256:             logger.info(f\"Deleted deployment {sanitized_name}\")\n257:         except ApiException as e:\n258:             if e.status != 404:\n259:                 logger.warning(f\"Failed to delete deployment: {e}\")\n260: \n261:         try:\n262:             self._core_v1.delete_namespaced_service(sanitized_name, self.namespace)\n263:             logger.info(f\"Deleted service {sanitized_name}\")\n264:         except ApiException as e:\n265:             if e.status != 404:\n266:                 logger.warning(f\"Failed to delete service: {e}\")\n267: \n268:         return {\n269:             \"status\": \"deleted\",\n270:             \"deployment_name\": sanitized_name,\n271:             \"namespace\": self.namespace,\n272:         }\n273: \n274:     def _sanitize_name(self, name: str) -> str:\n275:         \"\"\"Sanitize a name for Kubernetes.\"\"\"\n276:         sanitized = re.sub(r\"[^a-z0-9-]\", \"-\", name.lower())\n277:         sanitized = re.sub(r\"-+\", \"-\", sanitized)\n278:         sanitized = sanitized.strip(\"-\")\n279:         if len(sanitized) > 63:\n280:             sanitized = sanitized[:63].rstrip(\"-\")\n281:         return sanitized or \"agent\"\n\n(End of file - total 281 lines)\n</content>","metadata":{"preview":"\"\"\"Kubernetes provider service.\"\"\"\n\nimport logging\nimport re\nimport time\nfrom typing import Any, Dict, List, Optional\n\ntry:\n    from kubernetes import client, config\n    from kubernetes.client.rest import ApiException\n    KUBERNETES_AVAILABLE = True\nexcept ImportError:\n    KUBERNETES_AVAILABLE = False\n    client = None\n    config = None\n    ApiException = Exception\n\n\nlogger = logging.getLogger(__name__)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/k8s_provider.py","time":{"start":1775867829089,"end":1775867829118}}}}
