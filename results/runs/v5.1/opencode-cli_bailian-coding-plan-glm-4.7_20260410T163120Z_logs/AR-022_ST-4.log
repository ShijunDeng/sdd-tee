{"type":"tool_use","timestamp":1775867811650,"sessionID":"ses_28607dc6fffe0RHK34NP7uECaP","part":{"id":"prt_d79f853aa0011f5JwYbMbF56RA","messageID":"msg_d79f8346f001qrxVhPzvFQ8EoH","sessionID":"ses_28607dc6fffe0RHK34NP7uECaP","type":"tool","tool":"read","callID":"toolu_tool-8d9704a9082841709ae80367508e997f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Runtime for the publish command.\"\"\"\n2: \n3: import logging\n4: import secrets\n5: import string\n6: from pathlib import Path\n7: from typing import Any, Dict, Optional\n8: \n9: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n10: from agentcube.services.docker_service import DockerService\n11: from agentcube.services.k8s_provider import KubernetesProvider\n12: from agentcube.services.agentcube_provider import AgentCubeProvider\n13: \n14: \n15: logger = logging.getLogger(__name__)\n16: \n17: \n18: class PublishRuntime:\n19:     \"\"\"Runtime for publishing agents.\"\"\"\n20: \n21:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n22:         \"\"\"Initialize the publish runtime.\"\"\"\n23:         self.verbose = verbose\n24:         self.provider = provider\n25:         if verbose:\n26:             logging.basicConfig(level=logging.DEBUG)\n27:         self.metadata_service = MetadataService(verbose=verbose)\n28:         self.docker_service = DockerService(verbose=verbose)\n29: \n30:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n31:         \"\"\"Publish an agent to the specified provider.\"\"\"\n32:         logger.info(f\"Publishing workspace: {workspace_path} to provider: {self.provider}\")\n33: \n34:         metadata = self.metadata_service.load_metadata(workspace_path)\n35: \n36:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n37: \n38:         agent_info: Dict[str, Any] = {}\n39: \n40:         if self.provider == \"agentcube\":\n41:             agent_info = self._publish_cr_to_k8s(workspace_path, metadata, **options)\n42:         elif self.provider == \"k8s\":\n43:             agent_info = self._publish_k8s(workspace_path, metadata, image_url, **options)\n44:         else:\n45:             raise ValueError(f\"Unsupported provider: {self.provider}\")\n46: \n47:         self._update_publish_metadata(workspace_path, agent_info)\n48:         return agent_info\n49: \n50:     def _prepare_image_for_publishing(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> str:\n51:         \"\"\"Prepare the image for publishing.\"\"\"\n52:         if metadata.build_mode == \"local\":\n53:             return self._prepare_local_image(workspace_path, metadata, options)\n54:         else:\n55:             return self._prepare_cloud_image(workspace_path, metadata, options)\n56: \n57:     def _prepare_local_image(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> str:\n58:         \"\"\"Prepare a locally built image for publishing.\"\"\"\n59:         image_url = options.get(\"image_url\") or metadata.image.get(\"image_name\") if metadata.image else None\n60: \n61:         if not image_url:\n62:             raise ValueError(\n63:                 \"image_url is required for local build mode. \"\n64:                 \"Provide it via --image-url option or build the image first.\"\n65:             )\n66: \n67:         if metadata.image and \"image_name\" in metadata.image:\n68:             local_image = metadata.image[\"image_name\"]\n69:             registry_url = options.get(\"image_url\", \"\").rsplit(\":\", 1)[0]\n70: \n71:             username = options.get(\"image_username\") or metadata.registry_username\n72:             password = options.get(\"image_password\") or metadata.registry_password\n73: \n74:             if username and password:\n75:                 self.docker_service.push_image(\n76:                     image_name=local_image,\n77:                     registry_url=registry_url,\n78:                     username=username,\n79:                     password=password,\n80:                 )\n81: \n82:         return image_url\n83: \n84:     def _prepare_cloud_image(self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]) -> str:\n85:         \"\"\"Prepare a cloud-built image for publishing.\"\"\"\n86:         if metadata.image and \"image_name\" in metadata.image:\n87:             return metadata.image[\"image_name\"]\n88: \n89:         cloud_provider = options.get(\"cloud_provider\", \"huawei\")\n90:         version = options.get(\"version\") or metadata.version or \"latest\"\n91: \n92:         return f\"{cloud_provider}/{metadata.agent_name}:{version}\"\n93: \n94:     def _publish_cr_to_k8s(self, workspace_path: Path, metadata: AgentMetadata, **options: Any) -> Dict[str, Any]:\n95:         \"\"\"Publish using AgentCube AgentRuntime custom resource.\"\"\"\n96:         namespace = options.get(\"namespace\") or \"default\"\n97: \n98:         if not metadata.workload_manager_url or not metadata.router_url:\n99:             raise ValueError(\n100:                 \"Both workload_manager_url and router_url are required for agentcube provider. \"\n101:                 \"Please set them in agent_metadata.yaml.\"\n102:             )\n103: \n104:         provider = AgentCubeProvider(namespace=namespace, verbose=self.verbose)\n105:         image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n106: \n107:         result = provider.deploy_agent_runtime(\n108:             agent_name=metadata.agent_name,\n109:             image_url=image_url,\n110:             port=metadata.port,\n111:             entrypoint=metadata.entrypoint,\n112:             env_vars=None,\n113:             workload_manager_url=metadata.workload_manager_url,\n114:             router_url=metadata.router_url,\n115:             readiness_probe_path=metadata.readiness_probe_path,\n116:             readiness_probe_port=metadata.readiness_probe_port,\n117:         )\n118: \n119:         session_id = self._generate_session_id()\n120:         agent_id = result.get(\"agent_name\", metadata.agent_name)\n121: \n122:         result.update({\n123:             \"agent_id\": agent_id,\n124:             \"session_id\": session_id,\n125:             \"namespace\": namespace,\n126:             \"image_url\": image_url,\n127:             \"provider\": \"agentcube\",\n128:         })\n129: \n130:         return result\n131: \n132:     def _publish_k8s(self, workspace_path: Path, metadata: AgentMetadata, image_url: str, **options: Any) -> Dict[str, Any]:\n133:         \"\"\"Publish using standard Kubernetes Deployment and Service.\"\"\"\n134:         namespace = options.get(\"namespace\") or \"default\"\n135:         replicas = options.get(\"replicas\", 1)\n136:         node_port = options.get(\"node_port\")\n137: \n138:         if node_port and not (30000 <= node_port <= 32767):\n139:             raise ValueError(f\"NodePort must be between 30000 and 32767, got {node_port}\")\n140: \n141:         provider = KubernetesProvider(namespace=namespace, verbose=self.verbose)\n142: \n143:         result = provider.deploy_agent(\n144:             agent_name=metadata.agent_name,\n145:             image_url=image_url,\n146:             port=metadata.port,\n147:             entrypoint=metadata.entrypoint,\n148:             replicas=replicas,\n149:             node_port=node_port,\n150:             env_vars=None,\n151:         )\n152: \n153:         session_id = self._generate_session_id()\n154: \n155:         result.update({\n156:             \"agent_id\": result.get(\"deployment_name\", metadata.agent_name),\n157:             \"session_id\": session_id,\n158:             \"namespace\": namespace,\n159:             \"image_url\": image_url,\n160:             \"provider\": \"k8s\",\n161:         })\n162: \n163:         return result\n164: \n165:     def _update_publish_metadata(self, workspace_path: Path, agent_info: Dict[str, Any]) -> None:\n166:         \"\"\"Update metadata with publish information.\"\"\"\n167:         metadata = self.metadata_service.load_metadata(workspace_path)\n168: \n169:         if \"agent_id\" in agent_info:\n170:             metadata.agent_id = agent_info[\"agent_id\"]\n171:         if \"session_id\" in agent_info:\n172:             metadata.session_id = agent_info[\"session_id\"]\n173:         if \"k8s_deployment\" in agent_info:\n174:             metadata.k8s_deployment = agent_info[\"k8s_deployment\"]\n175:         if \"agent_endpoint\" in agent_info:\n176:             metadata.agent_endpoint = agent_info[\"agent_endpoint\"]\n177: \n178:         self.metadata_service.save_metadata(workspace_path, metadata)\n179: \n180:     def _generate_session_id(self) -> str:\n181:         \"\"\"Generate a unique session ID.\"\"\"\n182:         alphabet = string.ascii_letters + string.digits\n183:         return \"\".join(secrets.choice(alphabet) for _ in range(32))\n\n(End of file - total 183 lines)\n</content>","metadata":{"preview":"\"\"\"Runtime for the publish command.\"\"\"\n\nimport logging\nimport secrets\nimport string\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.k8s_provider import KubernetesProvider\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass PublishRuntime:\n    \"\"\"Runtime for publishing agents.\"\"\"\n","truncated":false,"loaded":[]},"title":"workspaces/v