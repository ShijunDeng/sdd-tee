n47: \tif err != nil {\n48: \t\treturn nil, fmt.Errorf(\"failed to ping valkey: %w\", err)\n49: \t}\n50: \tif result != \"PONG\" {\n51: \t\treturn nil, fmt.Errorf(\"unexpected ping response: %s\", result)\n52: \t}\n53: \n54: \treturn &valkeyStore{\n55: \t\tcli:                  cli,\n56: \t\tsessionPrefix:        \"session:\",\n57: \t\texpiryIndexKey:       \"session:expiry\",\n58: \t\tlastActivityIndexKey: \"session:last_activity\",\n59: \t}, nil\n60: }\n61: \n62: func (s *valkeyStore) Ping(ctx context.Context) error {\n63: \tresult, err := s.cli.Do(ctx, s.cli.B().Ping().Build()).ToString()\n64: \tif err != nil {\n65: \t\treturn err\n66: \t}\n67: \tif result != \"PONG\" {\n68: \t\treturn fmt.Errorf(\"unexpected ping response: %s\", result)\n69: \t}\n70: \treturn nil\n71: }\n72: \n73: func (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n74: \tkey := s.sessionPrefix + sessionID\n75: \tdata := s.cli.Do(ctx, s.cli.B().Get().Key(key).Build())\n76: \n77: \tif valkey.IsValkeyNil(data.Error()) {\n78: \t\treturn nil, ErrNotFound\n79: \t}\n80: \n81: \tif data.Error() != nil {\n82: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", data.Error())\n83: \t}\n84: \n85: \tbytes, err := data.AsBytes()\n86: \tif err != nil {\n87: \t\treturn nil, fmt.Errorf(\"failed to get sandbox: %w\", err)\n88: \t}\n89: \n90: \tinfo := &types.SandboxInfo{}\n91: \tif err := unmarshalSandboxInfo(string(bytes), info); err != nil {\n92: \t\treturn nil, fmt.Errorf(\"failed to unmarshal sandbox info: %w\", err)\n93: \t}\n94: \n95: \treturn info, nil\n96: }\n97: \n98: func (s *valkeyStore) StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n99: \tif sandboxStore == nil {\n100: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n101: \t}\n102: \tif sandboxStore.SessionID == \"\" {\n103: \t\treturn fmt.Errorf(\"session ID cannot be empty\")\n104: \t}\n105: \tif sandboxStore.ExpiresAt.IsZero() {\n106: \t\treturn fmt.Errorf(\"expires at cannot be zero\")\n107: \t}\n108: \n109: \tkey := s.sessionPrefix + sandboxStore.SessionID\n110: \tdata, err := marshalSandboxInfo(sandboxStore)\n111: \tif err != nil {\n112: \t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n113: \t}\n114: \n115: \tcommands := []valkey.Completed{\n116: \t\ts.cli.B().Set().Key(key).Value(data).Nx().Build(),\n117: \t\ts.cli.B().Zadd().Key(s.expiryIndexKey).Member().Member(sandboxStore.SessionID).Score(float64(sandboxStore.ExpiresAt.Unix())).Build(),\n118: \t\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).Member().Member(sandboxStore.SessionID).Score(float64(time.Now().Unix())).Build(),\n119: \t}\n120: \n121: \tfor _, cmd := range commands {\n122: \t\tif err := s.cli.Do(ctx, cmd).Error(); err != nil {\n123: \t\t\treturn fmt.Errorf(\"failed to store sandbox: %w\", err)\n124: \t\t}\n125: \t}\n126: \n127: \treturn nil\n128: }\n129: \n130: func (s *valkeyStore) UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error {\n131: \tif sandboxStore == nil {\n132: \t\treturn fmt.Errorf(\"sandbox cannot be nil\")\n133: \t}\n134: \tif sandboxStore.SessionID == \"\" {\n135: \t\treturn fmt.Errorf(\"session ID cannot be empty\")\n136: \t}\n137: \n138: \tkey := s.sessionPrefix + sandboxStore.SessionID\n139: \tdata, err := marshalSandboxInfo(sandboxStore)\n140: \tif err != nil {\n141: \t\treturn fmt.Errorf(\"failed to marshal sandbox info: %w\", err)\n142: \t}\n143: \n144: \tresult, err := s.cli.Do(ctx, s.cli.B().Set().Key(key).Value(data).Xx().Build()).ToString()\n145: \tif err != nil {\n146: \t\treturn fmt.Errorf(\"failed to update sandbox: %w\", err)\n147: \t}\n148: \tif result != \"OK\" {\n149: \t\treturn ErrNotFound\n150: \t}\n151: \n152: \treturn nil\n153: }\n154: \n155: func (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n156: \tkey := s.sessionPrefix + sessionID\n157: \n158: \tcommands := []valkey.Completed{\n159: \t\ts.cli.B().Del().Key(key).Build(),\n160: \t\ts.cli.B().Zrem().Key(s.expiryIndexKey).Member(sessionID).Build(),\n161: \t\ts.cli.B().Zrem().Key(s.lastActivityIndexKey).Member(sessionID).Build(),\n162: \t}\n163: \n164: \tfor _, cmd := range commands {\n165: \t\tif err := s.cli.Do(ctx, cmd).Error(); err != nil {\n166: \t\t\treturn fmt.Errorf(\"failed to delete sandbox: %w\", err)\n167: \t\t}\n168: \t}\n169: \n170: \treturn nil\n171: }\n172: \n173: func (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n174: \tsessionIDs, err := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.expiryIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()).ToArray()\n175: \tif err != nil {\n176: \t\treturn nil, fmt.Errorf(\"failed to list expired sandboxes: %w\", err)\n177: \t}\n178: \n179: \treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n180: }\n181: \n182: func (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n183: \tsessionIDs, err := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.lastActivityIndexKey).Min(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).Limit(0, limit).Build()).ToArray()\n184: \tif err != nil {\n185: \t\treturn nil, fmt.Errorf(\"failed to list inactive sandboxes: %w\", err)\n186: \t}\n187: \n188: \treturn s.getSandboxesBySessionIDs(ctx, sessionIDs)\n189: }\n190: \n191: func (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n192: \tkey := s.sessionPrefix + sessionID\n193: \n194: \texists, err := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build()).ToInt64()\n195: \tif err != nil {\n196: \t\treturn fmt.Errorf(\"failed to check session existence: %w\", err)\n197: \t}\n198: \tif exists != 1 {\n199: \t\treturn ErrNotFound\n200: \t}\n201: \n202: \tif err := s.cli.Do(ctx, s.cli.B().Zadd().Key(s.lastActivityIndexKey).Member().Member(sessionID).Score(float64(at.Unix())).Build()).Error(); err != nil {\n203: \t\treturn fmt.Errorf(\"failed to update last activity: %w\", err)\n204: \t}\n205: \n206: \treturn nil\n207: }\n208: \n209: func (s *valkeyStore) Close() error {\n210: \ts.cli.Close()\n211: \treturn nil\n212: }\n213: \n214: func (s *valkeyStore) getSandboxesBySessionIDs(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n215: \tif len(sessionIDs) == 0 {\n216: \t\treturn []*types.SandboxInfo{}, nil\n217: \t}\n218: \n219: \tkeys := make([]string, len(sessionIDs))\n220: \tfor i, sessionID := range sessionIDs {\n221: \t\tkeys[i] = s.sessionPrefix + sessionID\n222: \t}\n223: \n224: \tvalues, err := s.cli.Do(ctx, s.cli.B().Mget().Key(keys...).Build()).ToArray()\n225: \tif err != nil {\n226: \t\treturn nil, fmt.Errorf(\"failed to get sandbox data: %w\", err)\n227: \t}\n228: \n229: \tresult := make([]*types.SandboxInfo, 0, len(sessionIDs))\n230: \tfor _, value := range values {\n231: \t\tif valkey.IsValkeyNil(value.Error()) {\n232: \t\t\tcontinue\n233: \t\t}\n234: \n235: \t\tif value.Error() != nil {\n236: \t\t\tklog.Warningf(\"Failed to get value: %v\", value.Error())\n237: \t\t\tcontinue\n238: \t\t}\n239: \n240: \t\tbytes, err := value.AsBytes()\n241: \t\tif err != nil {\n242: \t\t\tklog.Warningf(\"Failed to convert value to bytes: %v\", err)\n243: \t\t\tcontinue\n244: \t\t}\n245: \n246: \t\tinfo := &types.SandboxInfo{}\n247: \t\tif err := unmarshalSandboxInfo(string(bytes), info); err != nil {\n248: \t\t\tklog.Warningf(\"Failed to unmarshal sandbox info: %v\", err)\n249: \t\t\tcontinue\n250: \t\t}\n251: \n252: \t\tresult = append(result, info)\n253: \t}\n254: \n255: \treturn result, nil\n256: }\n\n(End of file - total 256 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype valkeyStore struct {\n\tcli                  valke