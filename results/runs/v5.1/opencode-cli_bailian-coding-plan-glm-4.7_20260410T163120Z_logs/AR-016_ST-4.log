ings\"\n)\n\nfunc detectMimeType(path string) string {\n\text := strings.ToLower(filepath.Ext(path))\n\tif mimeType := mime.TypeByExtension(ext); mimeType != \"\" {\n\t\treturn mimeType\n\t}\n\n\t// Add additional MIME type mappings\n\tswitch ext {\n\tcase \".json\":\n\t\treturn \"application/json\"\n\tcase \".yaml\", \".yml\":\n\t\treturn \"application/x-yaml\"\n\tcase \".md\":\n\t\treturn \"text/markdown\"\n\tcase \".log\":\n\t\treturn \"text/plain\"\n\tcase \".sh\":\n\t\treturn \"application/x-sh\"\n\tcase \".py\":\n\t\treturn \"text/x-python\"\n\tcase \".js\":\n\t\treturn \"text/javascript\"\n\tcase \".ts\":\n\t\treturn \"text/typescript\"\n\tcase \".html\":\n\t\treturn \"text/html\"\n\tcase \".css\":\n\t\treturn \"text/css\"\n\tcase \".xml\":\n\t\treturn \"application/xml\"\n\tdefault:\n\t\treturn MIMEOctetStream\n\t}\n}\n\n// pkg/picod/files.go\ntype FileMetadata struct {\n\tPath     string    `json:\"path\"`\n\tSize     int64     `json:\"size\"`\n\tMode     string    `json:\"mode\"`\n\tModified time.Time `json:\"modified\"`\n\tCreated  time.Time `json:\"created\"`\n\tIsDir    bool      `json:\"is_dir\"`\n\tMimeType string    `json:\"mime_type\"`\n}\n\nfunc (s *Server) getFileMetadata(path string) (FileMetadata, error) {\n\tinfo, err := os.Stat(path)\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\treturn FileMetadata{}, NewError(ErrFileNotFound, ErrMsgFileNotFound, \"\", err)\n\t\t}\n\t\treturn FileMetadata{}, NewError(ErrServerInternal, \"failed to get file info\", err.Error(), err)\n\t}\n\n\tvar created time.Time\n\tif sys, ok := info.Sys().(*syscall.Stat_t); ok {\n\t\tcreated = time.Unix(int64(sys.Ctim.Sec), int64(sys.Ctim.Nsec))\n\t} else {\n\t\tcreated = info.ModTime() // Fallback to mod time\n\t}\n\n\tmimeType := MIMEOctetStream\n\tif !info.IsDir() {\n\t\tmimeType = detectMimeType(path)\n\t}\n\n\treturn FileMetadata{\n\t\tPath:     path,\n\t\tSize:     info.Size(),\n\t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n\t\tModified: info.ModTime(),\n\t\tCreated:  created,\n\t\tIsDir:    info.IsDir(),\n\t\tMimeType: mimeType,\n\t}, nil\n}\n\n// pkg/picod/handlers.go\nfunc (s *Server) DownloadFileHandler(c *gin.Context) {\n\tpath := c.Param(\"path\")\n\tif path == \"\" {\n\t\tHandleError(c, NewError(ErrMissingPath, ErrMsgMissingPathParam, \"\", nil))\n\t\treturn\n\t}\n\n\tpath = strings.TrimPrefix(path, \"/\")\n\n\tsanitizedPath, err := s.sanitizePath(path)\n\tif err != nil {\n\t\tHandleError(c, err)\n\t\treturn\n\t}\n\n\t// Check for metadata query parameter\n\tif c.Query(\"metadata\") == \"true\" {\n\t\tmetadata, err := s.getFileMetadata(sanitizedPath)\n\t\tif err != nil {\n\t\t\tHandleError(c, err)\n\t\t\treturn\n\t\t}\n\t\tc.JSON(http.StatusOK, metadata)\n\t\treturn\n\t}\n\n\tinfo, err := os.Stat(sanitizedPath)\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\tHandleError(c, NewError(ErrFileNotFound, ErrMsgFileNotFound, \"\", err))\n\t\t} else {\n\t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to get file info\", err.Error(), err))\n\t\t}\n\t\treturn\n\t}\n\n\tif info.IsDir() {\n\t\tHandleError(c, NewError(ErrPathIsDirectory, ErrMsgPathIsDirectory, \"\", nil))\n\t\treturn\n\t}\n\n\tcontent, err := os.ReadFile(sanitizedPath)\n\tif err != nil {\n\t\tHandleError(c, NewError(ErrServerInternal, \"failed to read file\", err.Error(), err))\n\t\treturn\n\t}\n\n\tc.Header(HeaderContentDescription, \"File Transfer\")\n\tc.Header(HeaderContentEncoding, \"binary\")\n\tc.Header(HeaderContentDisposition, fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filepath.Base(sanitizedPath)))\n\n\tmimeType := detectMimeType(sanitizedPath)\n\tc.Header(HeaderContentType, mimeType)\n\n\tc.Data(http.StatusOK, mimeType, content)\n}\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `go test ./pkg/picod/ -run TestDownloadFileHandlerWithMetadata -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add pkg/picod/handlers.go pkg/picod/files.go pkg/picod/mime.go pkg/picod/handlers_test.go\ngit commit -m \"feat