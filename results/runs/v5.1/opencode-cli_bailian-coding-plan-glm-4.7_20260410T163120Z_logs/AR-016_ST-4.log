\tmetricReconcileDuration = \"workloadmanager_reconcile_duration_seconds\"\n736: \tmetricReconcileRequeues = \"workloadmanager_reconcile_requeues_total\"\n737: \n738: \t// Resource metrics\n739: \tmetricResourcesReady = \"workloadmanager_resources_ready\"\n740: \tmetricResourcesPending = \"workloadmanager_resources_pending\"\n741: \tmetricResourcesError = \"workloadmanager_resources_error\"\n742: \n743: \t// Sandbox metrics\n744: \tmetricSandboxCreations = \"workloadmanager_sandbox_creations_total\"\n745: \tmetricSandboxDeletions = \"workloadmanager_sandbox_deletions_total\"\n746: \tmetricSandboxUpdateDuration = \"workloadmanager_sandbox_update_duration_seconds\"\n747: )\n748: \n749: var (\n750: \treconcileTotal = prometheus.NewCounterVec(\n751: \t\tprometheus.CounterOpts{\n752: \t\t\tName: metricReconcileTotal,\n753: \t\t\tHelp: \"Total number of reconciliation operations\",\n754: \t\t},\n755: \t\t[]string{\"controller\", \"namespace\", \"name\"},\n756: \t)\n757: \n758: \treconcileErrors = prometheus.NewCounterVec(\n759: \t\tprometheus.CounterOpts{\n760: \t\t\tName: metricReconcileErrors,\n761: \t\t\tHelp: \"Total number of reconciliation errors\",\n762: \t\t},\n763: \t\t[]string{\"controller\", \"namespace\", \"name\"},\n764: \t)\n765: \n766: \treconcileDuration = prometheus.NewHistogramVec(\n767: \t\tprometheus.HistogramOpts{\n768: \t\t\tName:    metricReconcileDuration,\n769: \t\t\tHelp:    \"Reconciliation duration in seconds\",\n770: \t\t\tBuckets: prometheus.DefBuckets,\n771: \t\t},\n772: \t\t[]string{\"controller\", \"result\"},\n773: \t)\n774: \n775: \tsandboxCreations = prometheus.NewCounterVec(\n776: \t\tprometheus.CounterOpts{\n777: \t\t\tName: metricSandboxCreations,\n778: \t\t\tHelp: \"Total number of sandbox creations\",\n779: \t\t},\n780: \t\t[]string{\"namespace\", \"name\"},\n781: \t)\n782: \n783: \tsandboxDeletions = prometheus.NewCounterVec(\n784: \t\tprometheus.CounterOpts{\n785: \t\t\tName: metricSandboxDeletions,\n786: \t\t\tHelp: \"Total number of sandbox deletions\",\n787: \t\t},\n788: \t\t[]string{\"namespace\", \"name\"},\n789: \t)\n790: \n791: \tresourcesReady = prometheus.NewGaugeVec(\n792: \t\tprometheus.GaugeOpts{\n793: \t\t\tName: metricResourcesReady,\n794: \t\t\tHelp: \"Number of ready resources\",\n795: \t\t},\n796: \t\t[]string{\"controller\", \"namespace\"},\n797: \t)\n798: )\n799: \n800: func init() {\n801: \tprometheus.MustRegister(\n802: \t\treconcileTotal,\n803: \t\treconcileErrors,\n804: \t\treconcileDuration,\n805: \t\tsandboxCreations,\n806: \t\tsandboxDeletions,\n807: \t\tresourcesReady,\n808: \t)\n809: }\n810: \n811: // RecordReconciliation records a reconciliation operation\n812: func RecordReconciliation(controller, namespace, name string, duration float64, result string) {\n813: \treconcileTotal.WithLabelValues(controller, namespace, name).Inc()\n814: \treconcileDuration.WithLabelValues(controller, result).Observe(duration)\n815: \n816: \tif result == \"error\" {\n817: \t\treconcileErrors.WithLabelValues(controller, namespace, name).Inc()\n818: \t}\n819: }\n820: \n821: // RecordSandboxOperation records a sandbox operation\n822: func RecordSandboxOperation(operation, namespace, name string, duration float64, err error) {\n823: \tif operation == \"create\" {\n824: \t\tsandboxCreations.WithLabelValues(namespace, name).Inc()\n825: \t} else if operation == \"delete\" {\n826: \t\tsandboxDeletions.WithLabelValues(namespace, name).Inc()\n827: \t}\n828: }\n829: ```\n830: \n831: **Step 4: Run test to verify it passes**\n832: \n833: Run: `go test ./pkg/workloadmanager/controller/reconciler/ -run TestRecordReconciliation -v`\n834: Expected: PASS\n835: \n836: **Step 5: Commit**\n837: \n838: ```bash\n839: git add pkg/workloadmanager/controller/reconciler/metrics.go pkg/workloadmanager/controller/reconciler/metrics_test.go\n840: git commit -m \"feat(ar-007): define metrics structure\"\n841: ```\n842: \n843: ### Task 8: Implement error handling types\n844: \n845: **Files:**\n846: - Create: `pkg