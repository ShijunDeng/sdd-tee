\t\t\t}\n\t\t}()\n\t}\n\n\twg.Wait()\n\tg.Expect(acquiredCount).To(Equal(10))\n\n\t// Test read locks allow multiple readers\n\treadPath := filepath.Join(tempDir, \"readtest.txt\")\n\tfor i := 0; i < 5; i++ {\n\t\twg.Add(1)\n\t\tgo func() {\n\t\t\tdefer wg.Done()\n\t\t\tlockManager.AcquireReadLock(readPath)\n\t\t\ttime.Sleep(10 * time.Millisecond)\n\t\t\tlockManager.ReleaseReadLock(readPath)\n\t\t}()\n\t}\n\n\twg.Wait()\n\t// All read locks should be acquired successfully\n}\n\nfunc TestWriteLockPreventsReadLocks(t *testing.T) {\n\tg := NewGomegaWithT(t)\n\n\ttempDir := t.TempDir()\n\tlockManager := NewFileLockManager()\n\n\ttestPath := filepath.Join(tempDir, \"test.txt\")\n\n\t// Acquire write lock\n\tlockManager.AcquireWriteLock(testPath)\n\n\t// Try to acquire read lock - should fail immediately or timeout\n\tdone := make(chan bool)\n\tgo func() {\n\t\tlockManager.AcquireReadLock(testPath)\n\t\tclose(done)\n\t}()\n\n\tselect {\n\tcase <-done:\n\t\tg.Expect(false).To(BeTrue(), \"Read lock should not be acquired while write lock is held\")\n\tcase <-time.After(100 * time.Millisecond):\n\t\t// Expected - read lock should block or fail\n\t}\n\n\tlockManager.ReleaseWriteLock(testPath)\n}\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `go test ./pkg/picod/ -run TestFileLocks -v`\nExpected: FAIL with \"undefined: NewFileLockManager\"\n\n**Step 3: Write minimal implementation**\n\n```go\n// pkg/picod/locks.go\npackage picod\n\nimport (\n\t\"path/filepath\"\n\t\"sync\"\n\t\"time\"\n)\n\nconst (\n\tFileLockTimeout = 30 * time.Second\n)\n\ntype FileLockManager struct {\n\tlocks map[string]*fileLock\n\tmu    sync.RWMutex\n}\n\ntype fileLock struct {\n\twriteLockCount int\n\treadLockCount  int\n\twriteCond      *sync.Cond\n\treadCond       *sync.Cond\n\tmu             sync.Mutex\n}\n\nfunc NewFileLockManager() *FileLockManager {\n\treturn &FileLockManager{\n\t\tlocks: make(map[string]*fileLock),\n\t}\n}\n\nfunc (fm *FileLockManager) getLock(path string) *fileLock {\n\tfm.mu.Lock()\n\tdefer fm.mu.Unlock()\n\n\tlock, exists := fm.locks[path]\n\tif !exists {\n\t\tlock = &fileLock{}\n\t\tlock.writeCond = sync.NewCond(&lock.mu)\n\t\tlock.readCond = sync.NewCond(&lock.mu)\n\t\tfm.locks[path] = lock\n\t}\n\n\treturn lock\n}\n\nfunc (fm *FileLockManager) cleanupLock(path string) {\n\tfm.mu.Lock()\n\tdefer fm.mu.Unlock()\n\n\tif lock, exists := fm.locks[path]; exists {\n\t\tlock.mu.Lock()\n\t\tif lock.writeLockCount == 0 && lock.readLockCount == 0 {\n\t\t\tdelete(fm.locks, path)\n\t\t}\n\t\tlock.mu.Unlock()\n\t}\n}\n\nfunc (fm *FileLockManager) AcquireWriteLock(path string) bool {\n\tabsPath := filepath.Clean(path)\n\tlock := fm.getLock(absPath)\n\n\tlock.mu.Lock()\n\tdefer lock.mu.Unlock()\n\n\ttimeout := time.After(FileLockTimeout)\n\n\tfor lock.writeLockCount > 0 || lock.readLockCount > 0 {\n\t\tselect {\n\t\tcase <-timeout:\n\t\t\treturn false\n\t\tdefault:\n\t\t\tlock.writeCond.Wait()\n\t\t}\n\t}\n\n\tlock.writeLockCount++\n\treturn true\n}\n\nfunc (fm *FileLockManager) ReleaseWriteLock(path string) {\n\tabsPath := filepath.Clean(path)\n\n\tfm.mu.RLock()\n\tlock, exists := fm.locks[absPath]\n\tfm.mu.RUnlock()\n\n\tif !exists {\n\t\treturn\n\t}\n\n\tlock.mu.Lock()\n\tlock.writeLockCount--\n\tif lock.writeLockCount == 0 {\n\t\tlock.writeCond.Broadcast()\n\t\tlock.readCond.Broadcast()\n\t}\n\tlock.mu.Unlock()\n\n\tfm.cleanupLock(absPath)\n}\n\nfunc (fm *FileLockManager) AcquireReadLock(path string) bool {\n\tabsPath := filepath.Clean(path)\n\tlock := fm.getLock(absPath)\n\n\tlock.mu.Lock()\n\tdefer lock.mu.Unlock()\n\n\ttimeout := time.After(FileLockTimeout)\n\n\tfor lock.writeLockCount > 0 {\n\t\tselect {\n\t\tcase <-timeout:\n\t\t\treturn false\n\t\tdefault:\n\t\t\tlock.readCond.Wait()\n\t\t}\n\t}\n\n\tlock.readLockCount++\n\treturn true\n}\n\nfunc (fm *FileLockManager) ReleaseReadLock(path string) {\n\tabsPath := filepath.Clean(path)\n\n\tfm.mu.RLock()\n\tlock, exists := fm.locks[absPath]\n\tfm.mu.RUnlock()\n\n\tif !exists {\n\t\treturn\n\t}\n\n\tlock.mu.Lock()\n\tlock.readLockCount--\n\tif lock.readLockCount == 0 {\n\t\tlock.writeCond.Broadcast()\n\t}\n\tlock.mu.Unlock()\n\n\tfm.cleanupLock(absPath)\n}\n```\n\n**Step 4: Integrate locks into handlers**\n\n```go\n// pkg/picod/server.go\ntype Server struct {\n\tengine       *gin.Engine\n\tconfig       Config\n\tauthManager  *AuthManager\n\tstartTime    time.Time\n\tworkspaceDir string\n\thttpServer   *http.Server\n\tlockManager  *FileLockManager // Add this field\n}\n\nfunc NewServer(config Config) (*Server, error) {\n\t// ... existing code ...\n\n\tserver := &Server{\n\t\tengine:       engine,\n\t\tconfig:       config,\n\t\tauthManager:  authManager,\n\t\tstartTime:    time.Now(),\n\t\tworkspaceDir: absWorkspace,\n\t\tlockManager:  NewFileLockManager(), // Initialize lock manager\n\t}\n\n\t// ... rest of existing code ...\n}\n```\n\n**Step 5: Apply locks in upload and delete handlers**\n\n```go\n// pkg/picod/handlers.go\nfunc (s *Server) UploadFileHandler(c *gin.Context) {\n\t// ... existing validation code ...\n\n\tsanitizedPath, err := s.sanitizePath(path)\n\tif err != nil {\n\t\tHandleError(c, err)\n\t\treturn\n\t}\n\n\t// Acquire write lock\n\tif !s.lockManager.AcquireWriteLock(sanitizedPath) {\n\t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n\t\treturn\n\t}\n\tdefer s.lockManager.ReleaseWriteLock(sanitizedPath)\n\n\t// ... rest of handler code ...\n}\n\nfunc (s *Server) DeleteFileHandler(c *gin.Context) {\n\t// ... existing validation code ...\n\n\tsanitizedPath, err := s.sanitizePath(path)\n\tif err != nil {\n\t\tHandleError(c, err)\n\t\treturn\n\t}\n\n\t// Acquire write lock\n\tif !s.lockManager.AcquireWriteLock(sanitizedPath) {\n\t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n\t\treturn\n\t}\n\tdefer s.lockManager.ReleaseWriteLock(sanitizedPath)\n\n\t// ... rest of handler code ...\n}\n\nfunc (s *Server) DownloadFileHandler(c *gin.Context) {\n\t// ... existing validation code ...\n\n\tsanitizedPath, err := s.sanitizePath(path)\n\tif err != nil {\n\t\tHandleError(c, err)\n\t\treturn\n\t}\n\n\t// Acquire read lock\n\tif !s.lockManager.AcquireReadLock(sanitizedPath) {\n\t\tHandleError(c, NewError(ErrServerInternal, \"failed to acquire file lock\", \"lock timeout\", nil))\n\t\treturn\n\t}\n\tdefer s.lockManager.ReleaseReadLock(sanitizedPath)\n\n\t// ... rest of handler code ...\n}\n```\n\n**Step 6: Run test to verify it passes**\n\nRun: `go test ./pkg/picod/ -run TestFileLocks -v`\nExpected: PASS\n\n**Step 7: Commit**\n\n```bash\ngit add pkg/picod/locks.go pkg/picod/server.go pkg/picod/handlers.go pkg/picod/locks_test.go\ngit commit -m \"feat(ar-016): add file operation locks for concurrency control\"\n```\n\n---\n\n### Task 6: Enhance path security with symlink resolution\n\n**Files:**\n- Modify: `pkg/picod/files.go`\n\n**Step 1: Write the failing test**\n\n```go\n// pkg/picod/files_test.go\npackage picod\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t. \"github.com/onsi/gomega\"\n)\n\nfunc TestSanitizePathWithSymlinks(t *testing.T) {\n\tg := NewGomegaWithT(t)\n\n\ttempDir := t.TempDir()\n\tserver := &Server{\n\t\tworkspaceDir: tempDir,\n\t\tauthManager:  nil,\n\t}\n\n\t// Create a file outside workspace\n\toutsideFile := filepath.Join(filepath.Dir(tempDir), \"outside.txt\")\n\tif err := os.WriteFile(outsideFile, []byte(\"outside content\"), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create outside file: %v\", err)\n\t}\n\n\t// Create a symlink inside workspace pointing outside\n\tsymlinkPath := filepath.Join(tempDir, \"escape_link\")\n\tif err := os.Symlink(outsideFile, symlinkPath); err != nil {\n\t\tt.Fatalf(\"Failed to create symlink: %v\", err)\n\t}\n\n\t// Test that symlink escaping is blocked\n\tsanitized, err := server.sanitizePath(\"escape_link\")\n\tg.Expect(err).To(HaveOccurred())\n\tg.Expect(err).To(MatchError(ContainSubstring(ErrAccessDenied)))\n\n\t// Test valid symlink within workspace\n\tinsideFile := filepath.Join(tempDir, \"inside.txt\")\n\tos.WriteFile(insideFile, []byte(\"inside content\"), 0644)\n\n\tvalidSymlink := filepath.Join(tempDir, \"valid_link\")\n\tos.Symlink(\"inside.txt\", validSymlink)\n\n\tsanitized, err = server.sanitizePath(\"valid_link\")\n\tg.Expect(err).NotTo(HaveOccurred())\n\tg.Expect(sanitized).To(Equal(validSymlink))\n\n\t// Test symlink chain\n\tchain1 := filepath.Join(tempDir, \"chain1\")\n\tchain2 := filepath.Join(tempDir, \"chain2\")\n\tos.Symlink(\"chain2\", chain1)\n\tos.Symlink(\"inside.txt\", chain2)\n\n\tsanitized, err = server.sanitizePath(\"chain1\")\n\tg.Expect(err).NotTo(HaveOccurred())\n}\n\nfunc TestSanitizePathPreventsEscape(t *testing.T) {\n\tg := NewGomegaWithT(t)\n\n\ttempDir := t.TempDir()\n\tserver := &Server{\n\t\tworkspaceDir: tempDir,\n\t\tauthManager:  nil,\n\t}\n\n\tescapeAttempts := []string{\n\t\t\"../etc/passwd\",\n\t\t\"../../etc/passwd\",\n\t\t\"../../../etc/passwd\",\n\t\t\"/etc/passwd\",\n\t\t\"..\",\n\t\t\"../..\",\n\t}\n\n\tfor _, attempt := range escapeAttempts {\n\t\t_, err := server.sanitizePath(attempt)\n\t\tg.Expect(err).To(HaveOccurred(), \"Should reject escape attempt: %s\", attempt)\n\t\tg.Expect(err).To(MatchError(ContainSubstring(ErrAccessDenied)))\n\t}\n}\n```\n\n**Step 2: Run test to verify it fails**\n\nRun: `go test ./pkg/picod/ -run TestSanitizePathWithSymlinks -v`\nExpected: FAIL with existing sanitizePath not handling all symlink cases\n\n**Step 3: Write enhanced implementation**\n\n```go\n// pkg/picod/files.go\nfunc (s *Server) sanitizePath(path string) (string, error) {\n\tif s.workspaceDir == \"\" {\n\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, ErrMsgWorkspaceNotInit, nil)\n\t}\n\n\t// Resolve workspace path fully\n\tresolvedWorkspace, err := filepath.EvalSymlinks(s.workspaceDir)\n\tif err != nil {\n\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"failed to resolve workspace: \"+err.Error(), err)\n\t}\n\tresolvedWorkspace = filepath.Clean(resolvedWorkspace)\n\n\t// Clean the input path\n\tcleanPath := filepath.Clean(path)\n\n\t// Remove leading slash if present to make it relative\n\tif filepath.IsAbs(cleanPath) {\n\t\tcleanPath = strings.TrimPrefix(cleanPath, string(os.PathSeparator))\n\t\tcleanPath = strings.TrimPrefix(cleanPath, \"/\")\n\t}\n\n\t// Check for obvious escape attempts\n\tif strings.Contains(cleanPath, \"..\") {\n\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"path contains parent directory references\", nil)\n\t}\n\n\t// Join with workspace and clean\n\tfullPath := filepath.Clean(filepath.Join(resolvedWorkspace, cleanPath))\n\n\t// Resolve symlinks in the full path\n\tresolvedPath, err := filepath.EvalSymlinks(fullPath)\n\tif err != nil && !os.IsNotExist(err) {\n\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"failed to resolve path: \"+err.Error(), err)\n\t}\n\n\t// If the path doesn't exist yet, use the unresolved path\n\tfinalPath := resolvedPath\n\tif os.IsNotExist(err) {\n\t\t// For paths that don't exist, check each parent component\n\t\tfinalPath = fullPath\n\t\tparentPath := filepath.Dir(fullPath)\n\t\tfor parentPath != resolvedWorkspace && parentPath != \".\" {\n\t\t\tresolvedParent, err := filepath.EvalSymlinks(parentPath)\n\t\t\tif err != nil && !os.IsNotExist(err) {\n\t\t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"failed to resolve parent path: \"+err.Error(), err)\n\t\t\t}\n\t\t\tif !os.IsNotExist(err) {\n\t\t\t\trelParent, err := filepath.Rel(resolvedWorkspace, resolvedParent)\n\t\t\t\tif err != nil || strings.HasPrefix(relParent, \"..\"+string(os.PathSeparator)) {\n\t\t\t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"parent path escapes workspace\", nil)\n\t\t\t\t}\n\t\t\t}\n\t\t\tparentPath = filepath.Dir(parentPath)\n\t\t}\n\t} else {\n\t\t// Verify the resolved path is still within workspace\n\t\trelPath, err := filepath.Rel(resolvedWorkspace, resolvedPath)\n\t\tif err != nil {\n\t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"failed to compute relative path: \"+err.Error(), err)\n\t\t}\n\n\t\tif strings.HasPrefix(relPath, \"..\"+string(os.PathSeparator)) || relPath == \"..\" {\n\t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"resolved path escapes workspace\", nil)\n\t\t}\n\t\tfinalPath = resolvedPath\n\t}\n\n\t// Final verification\n\trelPath, err := filepath.Rel(resolvedWorkspace, finalPath)\n\tif err != nil {\n\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"final verification failed\", err)\n\t}\n\n\tif strings.HasPrefix(relPath, \"..\"+string(os.PathSeparator)) || relPath == \"..\" {\n\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"path escapes workspace\", nil)\n\t}\n\n\treturn finalPath, nil\n}\n```\n\n**Step 4: Run test to verify it passes**\n\nRun: `go test ./pkg/picod/ -run TestSanitizePathWithSymlinks -v`\nExpected: PASS\n\n**Step 5: Commit**\n\n```bash\ngit add pkg/picod/files.go pkg/picod/files_test.go\ngit commit -m \"feat(ar-016): enhance path security with symlink resolution\"\n```\n\n---\n\n### Task 7: Add comprehensive integration tests\n\n**Files:**\n- Create: `pkg/picod/integration_test.go`\n\n**Step 1: Write integration tests**\n\n```go\n// pkg/picod/integration_test.go\n//go:build integration\n// +build integration\n\npackage picod\n\nimport (\n\t\"bytes\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t. \"github.com/onsi/gomega\"\n)\n\nfunc TestFullFileManagementWorkflow(t *testing.T) {\n\tg := NewGomegaWithT(t)\n\n\tgin.SetMode(gin.TestMode)\n\ttempDir := t.TempDir()\n\n\tconfig := Config{\n\t\tWorkspace: tempDir,\n\t\tPort:      0, // Use random port\n\t}\n\n\t// Create server without auth for testing\n\tserver := &Server{\n\t\tworkspaceDir: tempDir,\n\t\tauthManager:  nil,\n\t\tlockManager:  NewFileLockManager(),\n\t}\n\n\trouter := gin.New()\n\trouter.Use(func(c *gin.Context) {\n\t\t// Mock auth middleware\n\t\tc.Next()\n\t})\n\n\tapi := router.Group(\"/api\")\n\tapi.POST(\"/files\", server.UploadFileHandler)\n\tapi.GET(\"/files\", server.ListFilesHandler)\n\tapi.GET(\"/files/*path\", server.DownloadFileHandler)\n\tapi.PUT(\"/files/*path\", server.CreateDirectoryHandler)\n\tapi.DELETE(\"/files/*path\", server.DeleteFileHandler)\n\n\t// Step 1: Create directory structure\n\treq, _ := http.NewRequest(\"PUT\", \"/api/files/workdir\", nil)\n\tw := httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\n\treq, _ = http.NewRequest(\"PUT\", \"/api/files/workdir/subdir\", nil)\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\n\t// Step 2: Upload files via multipart\n\tbody := &bytes.Buffer{}\n\twriter := multipart.NewWriter(body)\n\twriter.WriteField(\"path\", \"workdir/file1.txt\")\n\tpart, _ := writer.CreateFormFile(\"file\", \"file1.txt\")\n\tio.WriteString(part, \"content of file 1\")\n\twriter.WriteField(\"mode\", \"0644\")\n\twriter.Close()\n\n\treq, _ = http.NewRequest(\"POST\", \"/api/files\", body)\n\treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\n\t// Step 3: Upload file via JSON Base64\n\tuploadReq := UploadFileRequest{\n\t\tPath:    \"workdir/subdir/file2.txt\",\n\t\tContent: base64.StdEncoding.EncodeToString([]byte(\"content of file 2\")),\n\t\tMode:    \"0644\",\n\t}\n\treqBody, _ := json.Marshal(uploadReq)\n\treq, _ = http.NewRequest(\"POST\", \"/api/files\", bytes.NewReader(reqBody))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\n\t// Step 4: List files (non-recursive)\n\treq, _ = http.NewRequest(\"GET\", \"/api/files?path=workdir&recursive=false\", nil)\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\n\tvar listResp ListFilesResponse\n\tjson.Unmarshal(w.Body.Bytes(), &listResp)\n\tg.Expect(len(listResp.Files)).To(BeNumerically(\">=\", 2))\n\n\t// Step 5: List files (recursive)\n\treq, _ = http.NewRequest(\"GET\", \"/api/files?path=workdir&recursive=true\", nil)\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\n\tjson.Unmarshal(w.Body.Bytes(), &listResp)\n\tg.Expect(len(listResp.Files)).To(BeNumerically(\">=\", 3))\n\n\t// Step 6: Get file metadata\n\treq, _ = http.NewRequest(\"GET\", \"/api/files/workdir/file1.txt?metadata=true\", nil)\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\n\tvar metadata FileMetadata\n\tjson.Unmarshal(w.Body.Bytes(), &metadata)\n\tg.Expect(metadata.Path).To(ContainSubstring(\"workdir/file1.txt\"))\n\tg.Expect(metadata.Size).To(Equal(int64(14)))\n\tg.Expect(metadata.IsDir).To(BeFalse())\n\n\t// Step 7: Download file\n\treq, _ = http.NewRequest(\"GET\", \"/api/files/workdir/file1.txt\", nil)\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\tg.Expect(w.Body.String()).To(Equal(\"content of file 1\"))\n\n\t// Step 8: Delete single file\n\treq, _ = http.NewRequest(\"DELETE\", \"/api/files/workdir/file1.txt\", nil)\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\n\t// Verify deletion\n\treq, _ = http.NewRequest(\"GET\", \"/api/files/workdir/file1.txt\", nil)\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusNotFound))\n\n\t// Step 9: Delete directory recursively\n\treq, _ = http.NewRequest(\"DELETE\", \"/api/files/workdir?recursive=true\", nil)\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\n\t// Verify deletion\n\treq, _ = http.NewRequest(\"GET\", \"/api/files?path=workdir\", nil)\n\tw = httptest.NewRecorder()\n\trouter.ServeHTTP(w, req)\n\tg.Expect(w.Code).To(Equal(http.StatusNotFound))\n}\n\nfunc TestConcurrentFileOperations(t *testing.T) {\n\tg := NewGomegaWithT(t)\n\n\tgin.SetMode(gin.TestMode)\n\ttempDir := t.TempDir()\n\n\tserver := &Server{\n\t\tworkspaceDir: tempDir,\n\t\tauthManager:  nil,\n\t\tlockManager:  NewFileLockManager(),\n\t}\n\n\trouter := gin.New()\n\tapi := router.Group(\"/api\")\n\tapi.POST(\"/files\", server.UploadFileHandler)\n\tapi.GET(\"/files/*path\", server.DownloadFileHandler)\n\n\t// Create multiple goroutines to upload to the same file\n\tdone := make(chan bool, 10)\n\tfor i := 0; i < 10; i++ {\n\t\tgo func(idx int) {\n\t\t\tdefer func() { done <- true }()\n\n\t\t\tuploadReq := UploadFileRequest{\n\t\t\t\tPath:    fmt.Sprintf(\"concurrent.txt\"),\n\t\t\t\tContent: base64.StdEncoding.EncodeToString([]byte(fmt.Sprintf(\"content %d\", idx))),\n\t\t\t\tMode:    \"0644\",\n\t\t\t}\n\t\t\treqBody, _ := json.Marshal(uploadReq)\n\t\t\treq, _ := http.NewRequest(\"POST\", \"/api/files\", bytes.NewReader(reqBody))\n\t\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\t\t\tw := httptest.NewRecorder()\n\t\t\trouter.ServeHTTP(w, req)\n\t\t}(i)\n\t}\n\n\t// Wait for all operations to complete\n\tfor i := 0; i < 10; i++ {\n\t\t<-done\n\t}\n\n\t// Verify the file exists and is valid\n\tfilePath := filepath.Join(tempDir, \"concurrent.txt\")\n\tcontent, err := os.ReadFile(filePath)\n\tg.Expect(err).NotTo(HaveOccurred())\n\tg.Expect(len(content)).To(BeNumerically(\">\", 0))\n}\n\nfunc TestSecurityEscalationPrevention(t *testing.T) {\n\tg := NewGomegaWithT(t)\n\n\tgin.SetMode(gin.TestMode)\n\ttempDir := t.TempDir()\n\n\tserver := &Server{\n\t\tworkspaceDir: tempDir,\n\t\tauthManager:  nil,\n\t\tlockManager:  NewFileLockManager(),\n\t}\n\n\trouter := gin.New()\n\tapi := router.Group(\"/api\")\n\tapi.POST(\"/files\", server.UploadFileHandler)\n\tapi.GET(\"/files/*path\", server.DownloadFileHandler)\n\n\t// Test path escape attempts\n\tescapeAttempts := []string{\n\t\t\"../../../etc/passwd\",\n\t\t\"../../etc/passwd\",\n\t\t\"../test.txt\",\n\t\t\"/etc/passwd\",\n\t}\n\n\tfor _, attempt := range escapeAttempts {\n\t\tuploadReq := UploadFileRequest{\n\t\t\tPath:    attempt,\n\t\t\tContent: base64.StdEncoding.EncodeToString([]byte(\"malicious\")),\n\t\t}\n\t\treqBody, _ := json.Marshal(uploadReq)\n\t\treq, _ := http.NewRequest(\"POST\", \"/api/files\", bytes.NewReader(reqBody))\n\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\t\tw := httptest.NewRecorder()\n\t\trouter.ServeHTTP(w, req)\n\t\tg.Expect(w.Code).To(Equal(http.StatusBadRequest), \"Should reject escape attempt: %s\", attempt)\n\t}\n}\n\nfunc TestLargeFileUpload(t *testing.T) {\n\tg := NewGomegaWithT(t)\n\n\tgin.SetMode(gin.TestMode)\n\ttempDir := t.TempDir()\n\n\tserver := &Server{\n\t\tworkspaceDir: tempDir,\n\t\tauthManager:  nil,\n\t\tlockManager:  NewFileLockManager(),\n\t}\n\n\trouter := gin.New()\n\tapi := router.Group(\"/api\")\n\tapi.POST(\"/files\", server.UploadFileHandler)\n\n\t// Create a moderately large file (1MB)\n\tlargeContent := make([]byte, 1<<20) // 1MB\n\tfor i := range largeContent {\n\t\tlargeContent[i] = byte(i % 256)\n\t}\n\n\tuploadReq := UploadFileRequest{\n\t\tPath:    \"largefile.bin\",\n\t\tContent: base64.StdEncoding.EncodeToString(largeContent),\n\t\tMode:    \"0644\",\n\t}\n\treqBody, _ := json.Marshal(uploadReq)\n\treq, _ := http.NewRequest(\"POST\", \"/api/files\", bytes.NewReader(reqBody))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tw := httptest.NewRecorder()\n\n\tstart := time.Now()\n\trouter.ServeHTTP(w, req)\n\tduration := time.Since(start)\n\n\tg.Expect(w.Code).To(Equal(http.StatusOK))\n\tg.Expect(duration).To(BeNumerically(\"<\", 5*time.Second), \"Large file upload should complete quickly\")\n\n\t// Verify file content\n\tdownloaded, err := os.ReadFile(filepath.Join(tempDir, \"largefile.bin\"))\n\tg.Expect(err).NotTo(HaveOccurred())\n\tg.Expect(len(downloaded)).To(Equal(len(largeContent)))\n}\n```\n\n**Step 2: Run integration tests**\n\nRun: `go test ./pkg/picod/ -tags=integration -v`\nExpected: PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/picod/integration_test.go\ngit commit -m \"feat(ar-016): add comprehensive integration tests\"\n```\n\n---\n\n### Task 8: Run all tests and verify coverage\n\n**Files:**\n- None (verification task)\n\n**Step 1: Run all tests**\n\n```bash\ngo test ./pkg/picod/ -v -coverprofile=coverage.out\n```\n\n**Step 2: Check coverage**\n\n```bash\ngo tool cover -func=coverage.out | grep total\n```\n\nExpected: Coverage >90%\n\n**Step 3: Generate coverage report**\n\n```bash\ngo tool cover -html=coverage.out -o coverage.html\n```\n\n**Step 4: Fix any coverage gaps if below 90%**\n\nIdentify uncovered code paths and add tests as needed.\n\n**Step 5: Run linter**\n\n```bash\ngolangci-lint run ./pkg/picod/\n```\n\nFix any linting issues.\n\n**Step 6: Verify package builds**\n\n```bash\ngo build ./pkg/picod/\n```\n\n**Step 7: Update documentation**\n\nUpdate README.md and API documentation to reflect new endpoints.\n\n**Step 8: Final commit**\n\n```bash\ngit add README.md docs/api.md\ngit commit -m \"docs(ar-016): update documentation for file management API\"\n```\n\n---\n\n## Summary\n\nThis implementation plan breaks down AR-016 (PicoD 文件管理 API) into 8 atomic, independently verifiable tasks:\n\n1. **DELETE handler** - File and directory deletion with recursive support\n2. **PUT handler** - Directory creation with recursive support\n3. **Metadata query parameter** - Detailed file metadata retrieval\n4. **Recursive directory listing** - Recursive query parameter for GET /api/files\n5. **File operation locks** - Concurrency control for file operations\n6. **Enhanced path security** - Symlink resolution and escape prevention\n7. **Integration tests** - Comprehensive end-to-end testing\n8. **Final verification** - Coverage, linting, and documentation\n\nEach task follows the TDD pattern:\n- Write failing test\n- Run test to verify failure\n- Write minimal implementation\n- Run test to verify success\n- Commit changes\n\nThe implementation ensures:\n- All file operations are protected by JWT authentication\n- Strict path security prevents workspace escape\n- Concurrent operations are properly synchronized\n- Error handling is consistent and secure\n- High test coverage and reliability","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tasks.md"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/server/server.go\">\nERROR [50:27] undefined: store.NewValkeyStore\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/collector_test.go\">\nERROR [127:15] expected 1 expression\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/controller.go\">\nERROR [57:3] unknown field MetricsBindAddress in struct literal of type controllerruntime.Options\nERROR [58:3] unknown field Port in struct literal of type controllerruntime.Options\nERROR [62:3] unknown field SyncPeriod in struct literal of type controllerruntime.Options\nERROR [88:17] undefined: AgentRuntimeReconciler\nERROR [98:15] cannot use ctrl.Options{…} (value of struct type controllerruntime.Options) as \"sigs.k8s.io/controller-runtime/pkg/controller\".TypedOptions[reconcile.Request] value in argument to ctrl.NewControllerManagedBy(mgr).For(&runtimev1alpha1.AgentRuntime{}