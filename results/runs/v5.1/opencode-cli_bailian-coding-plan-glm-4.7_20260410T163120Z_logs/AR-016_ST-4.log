{"type":"tool_use","timestamp":1775859569514,"sessionID":"ses_286863106ffeo6VSneMB4AUo03","part":{"id":"prt_d797a9339001KvRIVXgEbHmmGw","messageID":"msg_d797a3b8f001HgubMEp2CqGL73","sessionID":"ses_286863106ffeo6VSneMB4AUo03","type":"tool","tool":"read","callID":"toolu_tool-21e6d1ee8daa4426ad06d90ca664b21d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/errors.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"net/http\"\n6: \n7: \t\"github.com/gin-gonic/gin\"\n8: )\n9: \n10: const (\n11: \tErrInvalidCommand    = \"InvalidCommand\"\n12: \tErrEmptyCommand      = \"EmptyCommand\"\n13: \tErrInvalidTimeout    = \"InvalidTimeout\"\n14: \tErrInvalidWorkingDir = \"InvalidWorkingDir\"\n15: \tErrInvalidBase64     = \"InvalidBase64\"\n16: \tErrMissingPath       = \"MissingPath\"\n17: \tErrFileNotFound      = \"FileNotFound\"\n18: \tErrDirectoryNotFound = \"DirectoryNotFound\"\n19: \tErrPathIsDirectory   = \"PathIsDirectory\"\n20: \tErrAccessDenied      = \"AccessDenied\"\n21: \tErrMissingAuthHeader = \"MissingAuthHeader\"\n22: \tErrInvalidAuthFormat = \"InvalidAuthFormat\"\n23: \tErrInvalidToken      = \"InvalidToken\"\n24: \tErrInvalidSignature  = \"InvalidSignature\"\n25: \tErrTokenExpired      = \"TokenExpired\"\n26: \tErrInvalidPublicKey  = \"InvalidPublicKey\"\n27: \tErrServerInternal    = \"ServerInternal\"\n28: \tErrWorkspaceNotInit  = \"WorkspaceNotInit\"\n29: )\n30: \n31: const (\n32: \tErrorCodeBadRequest    = \"BadRequest\"\n33: \tErrorCodeUnauthorized  = \"Unauthorized\"\n34: \tErrorCodeNotFound      = \"NotFound\"\n35: \tErrorCodeInternalError = \"InternalError\"\n36: )\n37: \n38: var statusCodeMap = map[string]int{\n39: \tErrInvalidCommand:    http.StatusBadRequest,\n40: \tErrEmptyCommand:      http.StatusBadRequest,\n41: \tErrInvalidTimeout:    http.StatusBadRequest,\n42: \tErrInvalidWorkingDir: http.StatusBadRequest,\n43: \tErrInvalidBase64:     http.StatusBadRequest,\n44: \tErrMissingPath:       http.StatusBadRequest,\n45: \tErrFileNotFound:      http.StatusNotFound,\n46: \tErrDirectoryNotFound: http.StatusNotFound,\n47: \tErrPathIsDirectory:   http.StatusBadRequest,\n48: \tErrAccessDenied:      http.StatusBadRequest,\n49: \tErrMissingAuthHeader: http.StatusUnauthorized,\n50: \tErrInvalidAuthFormat: http.StatusUnauthorized,\n51: \tErrInvalidToken:      http.StatusUnauthorized,\n52: \tErrInvalidSignature:  http.StatusUnauthorized,\n53: \tErrTokenExpired:      http.StatusUnauthorized,\n54: \tErrInvalidPublicKey:  http.StatusInternalServerError,\n55: \tErrServerInternal:    http.StatusInternalServerError,\n56: \tErrWorkspaceNotInit:  http.StatusInternalServerError,\n57: }\n58: \n59: type ErrorResponse struct {\n60: \tError  string `json:\"error\"`\n61: \tCode   int    `json:\"code\"`\n62: \tDetail string `json:\"detail,omitempty\"`\n63: }\n64: \n65: type PicoDError struct {\n66: \tCode    string\n67: \tMessage string\n68: \tDetail  string\n69: \tErr     error\n70: }\n71: \n72: func (e *PicoDError) Error() string {\n73: \tif e.Err != nil {\n74: \t\treturn fmt.Sprintf(\"%s: %s (caused by: %v)\", e.Code, e.Message, e.Err)\n75: \t}\n76: \treturn fmt.Sprintf(\"%s: %s\", e.Code, e.Message)\n77: }\n78: \n79: func (e *PicoDError) Unwrap() error {\n80: \treturn e.Err\n81: }\n82: \n83: func NewError(code, message, detail string, err error) *PicoDError {\n84: \treturn &PicoDError{\n85: \t\tCode:    code,\n86: \t\tMessage: message,\n87: \t\tDetail:  detail,\n88: \t\tErr:     err,\n89: \t}\n90: }\n91: \n92: func HandleError(c *gin.Context, err error) {\n93: \tstatus := http.StatusInternalServerError\n94: \tcode := ErrorCodeInternalError\n95: \tmessage := err.Error()\n96: \tdetail := \"\"\n97: \n98: \tif picoDErr, ok := err.(*PicoDError); ok {\n99: \t\tcode = picoDErr.Code\n100: \t\tmessage = picoDErr.Message\n101: \t\tdetail = picoDErr.Detail\n102: \t\tif mappedStatus, exists := statusCodeMap[code]; exists {\n103: \t\t\tstatus = mappedStatus\n104: \t\t}\n105: \t}\n106: \n107: \tc.JSON(status, ErrorResponse{\n108: \t\tError:  message,\n109: \t\tCode:   status,\n110: \t\tDetail: detail,\n111: \t})\n112: }\n\n(End of file - total 112 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nconst (\n\tErrInvalidCommand    = \"InvalidCommand\"\n\tErrEmptyCommand      = \"EmptyCommand\"\n\tErrInvalidTimeout    = \"InvalidTimeout\"\n\tErrInvalidWorkingDir = \"InvalidWorkingDir\"\n\tErrInvalidBase64     = \"InvalidBase64\"\n\tErrMissingPath       = \"MissingPath\"\n\tErrFileNotFound      = \"FileNotFound\"\n\tErrDirectoryNotFound = \"DirectoryNotFound\"\n\tErrPathIsDirectory   = \"PathIsDirectory\"\n\tErrAccessDenied      = \"AccessDenied\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/errors.go","time":{"start":1775859569498,"end":1775859569512}}}}
