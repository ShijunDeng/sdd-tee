os.Getenv(\\\"VALKEY_TEST_ADDR\\\")\\n17: \\tif valkeyAddr == \\\"\\\" {\\n18: \\t\\tt.Skip(\\\"Skipping Valkey tests: VALKEY_TEST_ADDR not set\\\")\\n19: \\t}\\n20: \\n21: \\tvalkeyPassword := os.Getenv(\\\"VALKEY_TEST_PASSWORD\\\")\\n22: \\n23: \\tstore, err := newValkeyStore(valkeyAddr, valkeyPassword, 0)\\n24: \\trequire.NoError(t, err)\\n25: \\trequire.NotNil(t, store)\\n26: \\n27: \\tdefer store.Close()\\n28: \\n29: \\tctx := context.Background()\\n30: \\n31: \\tt.Run(\\\"Ping\\\", func(t *testing.T) {\\n32: \\t\\terr := store.Ping(ctx)\\n33: \\t\\tassert.NoError(t, err)\\n34: \\t})\\n35: \\n36: \\tt.Run(\\\"Store and Get Sandbox\\\", func(t *testing.T) {\\n37: \\t\\tsessionID := \\\"valkey-test-session-1\\\"\\n38: \\t\\tinfo := &types.SandboxInfo{\\n39: \\t\\t\\tSessionID:    sessionID,\\n40: \\t\\t\\tSandboxName:  \\\"test-sandbox\\\",\\n41: \\t\\t\\tWorkloadName: \\\"test-workload\\\",\\n42: \\t\\t\\tNamespace:    \\\"default\\\",\\n43: \\t\\t\\tKind:         \\\"AgentRuntime\\\",\\n44: \\t\\t\\tStatus:       \\\"running\\\",\\n45: \\t\\t\\tCreatedAt:    time.Now(),\\n46: \\t\\t\\tExpiresAt:    time.Now().Add(8 * time.Hour),\\n47: \\t\\t\\tPodIP:        \\\"10.0.0.1\\\",\\n48: \\t\\t}\\n49: \\n50: \\t\\terr := store.StoreSandbox(ctx, info)\\n51: \\t\\trequire.NoError(t, err)\\n52: \\n53: \\t\\tretrieved, err := store.GetSandboxBySessionID(ctx, sessionID)\\n54: \\t\\trequire.NoError(t, err)\\n55: \\t\\tassert.Equal(t, sessionID, retrieved.SessionID)\\n56: \\t\\tassert.Equal(t, \\\"test-sandbox\\\", retrieved.SandboxName)\\n57: \\t\\tassert.Equal(t, \\\"AgentRuntime\\\", retrieved.Kind)\\n58: \\t})\\n59: \\n60: \\tt.Run(\\\"Store Sandbox Nil\\\", func(t *testing.T) {\\n61: \\t\\terr := store.StoreSandbox(ctx, nil)\\n62: \\t\\tassert.Error(t, err)\\n63: \\t\\tassert.Contains(t, err.Error(), \\\"cannot be nil\\\")\\n64: \\t})\\n65: \\n66: \\tt.Run(\\\"Store Sandbox Empty SessionID\\\", func(t *testing.T) {\\n67: \\t\\tinfo := &types.SandboxInfo{\\n68: \\t\\t\\t