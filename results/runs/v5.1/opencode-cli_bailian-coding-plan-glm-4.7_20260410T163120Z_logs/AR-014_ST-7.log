Context) error\\n    GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\\n    StoreSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\\n    UpdateSandbox(ctx context.Context, sandboxStore *types.SandboxInfo) error\\n    DeleteSandboxBySessionID(ctx context.Context, sessionID string) error\\n    ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\\n    ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error)\\n    UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\\n    Close() error\\n}\\n```\\n\\n### SandboxInfo 结构体\\n\\n存储的 JSON 文档反序列化到 `pkg/common/types.SandboxInfo`:\\n\\n```go\\ntype SandboxInfo st...\n  Line 16: {\"type\":\"text\",\"timestamp\":1775857093684,\"sessionID\":\"ses_286ac03a4ffevNHKrolkCJN1ax\",\"part\":{\"id\":\"prt_d7954cb19001JsO2VxyVTeHMQF\",\"messageID\":\"msg_d7954bf23001KFyO3T7c5pm8hH\",\"sessionID\":\"ses_286ac03a4ffevNHKrolkCJN1ax\",\"type\":\"text\",\"text\":\"已更新 `pkg/store/design.md`，包含 AR-014 Valkey 存储实现的技术实现细节。\",\"time\":{\"start\":1775857093683,\"end\":1775857093683}}}\n\n/home/dsj/benchmark/results/runs/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z_logs/AR-014_ST-2.log:\n  Line 4: {\"type\":\"tool_use\",\"timestamp\":1775856922594,\"sessionID\":\"ses_286ade9b8ffe345JXsiaQtvma3\",\"part\":{\"id\":\"prt_d79522fa9001VspyY8A7Ja23Qd\",\"messageID\":\"msg_d7952173a001lY5hpWQ1wGwEmZ\",\"sessionID\":\"ses_286ade9b8ffe345JXsiaQtvma3\",\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"toolu_tool-85dc19f0515d4f968d0610ff0fc3e134\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/.sdd_prompt.md\"},\"output\":\"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/.sdd_prompt.md</path>\\n<type>fi