uild artifacts\"\n116: \t@echo \"  BUILD_MODE=release make build Build in release mode\"\n117: \t@echo \"  make docker-build             Build Docker images\"\n118: \t@echo \"\"\n119: \n120: .PHONY: all\n121: all: build test lint ## Build, test, and lint everything\n122: \n123: .PHONY: build\n124: build: build-go build-python ## Build all Go and Python components\n125: \n126: .PHONY: test\n127: test: test-go test-python ## Run all tests\n128: \n129: .PHONY: lint\n130: lint: lint-go lint-python ## Run all linting checks\n131: \n132: .PHONY: format\n133: format: format-go format-python ## Format all code\n134: \n135: .PHONY: check\n136: check: lint test ## Run all checks (lint and test)\n137: \n138: .PHONY: clean\n139: clean: clean-go clean-python clean-docker clean-coverage ## Clean all build artifacts\n140: \n141: .PHONY: deps\n142: deps: deps-go deps-python ## Download all dependencies\n143: \n144: .PHONY: verify\n145: verify: test lint format-check ## Verify code quality (test, lint, format check)\n146: \n147: .PHONY: ci\n148: ci: ci-build ci-test ci-lint ## Run CI pipeline\n149: \n150: .PHONY: dev-setup\n151: dev-setup: deps install-dev-tools ## Set up development environment\n152: \n153: .PHONY: version\n154: version: ## Display version information\n155: \t@echo \"$(BLUE)Version Information:$(NC)\"\n156: \t@echo \"  Version:        $(VERSION)\"\n157: \t@echo \"  Git Commit:     $(GIT_COMMIT)\"\n158: \t@echo \"  Git Branch:     $(GIT_BRANCH)\"\n159: \t@echo \"  Build Time:     $(BUILD_TIME)\"\n160: \t@echo \"  Go Version:     $(GO_VERSION)\"\n161: \t@echo \"  Python Version: $(PYTHON_VERSION)\"\n162: \t@echo \"\"\n163: \n164: .PHONY: vars\n165: vars: ## Display all Makefile variables\n166: \t@echo \"$(BLUE)Makefile Variables:$(NC)\"\n167: \t@echo \"  VERSION=$(VERSION)\"\n168: \t@echo \"  GIT_COMMIT=$(GIT_COMMIT)\"\n169: \t@echo \"  GIT_BRANCH=$(GIT_BRANCH)\"\n170: \t@echo \"  BUILD_TIME=$(BUILD_TIME)\"\n171: \t@echo \"  GO=$(GO)\"\n172: \t@echo \"  GO_VERSION=$(GO_VERSION)\"\n173: \t@echo \"  GOFLAGS=$(GOFLAGS)\"\n174: \t@echo \"  BUILD_DIR=$(BUILD_DIR)\"\n175: \t@echo \"  DIST_DIR=$(DIST_DIR)\"\n176: \t@echo \"  BUILD_MODE=$(BUILD_MODE)\"\n177: \t@echo \"  GOOS=$(GOOS)\"\n178: \t@echo \"  GOARCH=$(GOARCH)\"\n179: \t@echo \"  PLATFORM=$(PLATFORM)\"\n180: \t@echo \"  PYTHON=$(PYTHON)\"\n181: \t@echo \"  PIP=$(PIP)\"\n182: \t@echo \"  PYTHON_VERSION=$(PYTHON_VERSION)\"\n183: \t@echo \"  DOCKER=$(DOCKER)\"\n184: \t@echo \"  DOCKER_REGISTRY=$(DOCKER_REGISTRY)\"\n185: \t@echo \"  IMAGE_NAME=$(IMAGE_NAME)\"\n186: \t@echo \"  IMAGE_TAG=$(IMAGE_TAG)\"\n187: \t@echo \"\"\n188: \n189: .PHONY: list-targets\n190: list-targets: ## List all available targets\n191: \t@awk 'BEGIN {FS = \":.*?## \"} /^[a-zA-Z_-]+:.*?## / {printf \"%s\\n\", $$1}' $(MAKEFILE_LIST) .makefiles/*.mk 2>/dev/null | sort -u\n192: \n193: .PHONY: show-target\n194: show-target: ## Show a specific target's commands (usage: make show-target TARGET=build-go)\n195: ifndef TARGET\n196: \t@echo \"$(RED)Error: TARGET variable is required$(NC)\"\n197: \t@echo \"Usage: make show-target TARGET=<target-name>\"\n198: \t@exit 1\n199: endif\n200: \t@echo \"$(BLUE)Target: $(TARGET)$(NC)\"\n201: \t@awk \"/^$(TARGET):/,/^[a-zA-Z_-]+:/ {print}\" $(MAKEFILE_LIST) .makefiles/*.mk 2>/dev/null | head -n -1\n\n(End of file - total 201 lines)\n</content>","metadata":{"preview":".PHONY: help\n.DEFAULT_GOAL := help\n\n# Define colors for output\nBLUE := \\033[0;34m\nGREEN := \\033[0;32m\nYELLOW := \\033[1;33m\nRED := \\033[0;31m\nNC := \\033[0m\n\n# Define version information\nVERSION := $(shell cat VERSION 2>/dev/null || echo \"0.1.0\")\nGIT_COMMIT := $(shell git rev-parse --short HEAD 2>/dev/null || echo \"unknown\")\nGIT_BRANCH := $(shell git rev-parse --abbrev-ref HEAD 2>/dev/null || echo \"unknown\")\nBUILD_TIME := $(shell date -u +%Y-%m-%dT%H:%M:%SZ)\n\n# Go related variables\nGO := go\nGO_VERSION := 1.25\nGOFLAGS :=","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_