6: GOOS ?= $(shell go env GOOS)\n47: GOARCH ?= $(shell go env GOARCH)\n48: PLATFORM := $(GOOS)_$(GOARCH)\n49: \n50: # Test flags\n51: TEST_FLAGS := -v\n52: TEST_TIMEOUT := 30m\n53: GO_TEST_COVERAGE := $(COVERAGE_DIR)/go_coverage.out\n54: GO_TEST_COVERAGE_HTML := $(COVERAGE_DIR)/go_coverage.html\n55: PYTHON_TEST_COVERAGE := $(COVERAGE_DIR)/python_coverage\n56: \n57: # Binary names\n58: AGENTD_BIN := $(BUILD_DIR)/$(PLATFORM)/agentd\n59: PICOD_BIN := $(BUILD_DIR)/$(PLATFORM)/picod\n60: AGENTCUBE_CLI_BIN := $(BUILD_DIR)/$(PLATFORM)/agentcube\n61: AGENTCUBE_UTIL_BIN := $(BUILD_DIR)/$(PLATFORM)/agentcube-util\n62: CODE_INTERPRETER_BIN := $(BUILD_DIR)/$(PLATFORM)/code-interpreter\n63: AGENT_RUNTIME_BIN := $(BUILD_DIR)/$(PLATFORM)/agent-runtime\n64: \n65: # Include sub-Makefiles\n66: -include .makefiles/go.mk\n67: -include .makefiles/python.mk\n68: -include .makefiles/docker.mk\n69: -include .makefiles/test.mk\n70: -include .makefiles/lint.mk\n71: -include .makefiles/docs.mk\n72: -include .makefiles/clean.mk\n73: -include .makefiles/deps.mk\n74: -include .makefiles/release.mk\n75: -include .makefiles/utils.mk\n76: \n77: help: ## Show this help message\n78: \t@echo \"$(BLUE)AgentCube Build System$(NC)\"\n79: \t@echo \"$(BLUE)=====================$(NC)\"\n80: \t@echo \"\"\n81: \t@echo \"$(GREEN)Build Targets:$(NC)\"\n82: \t@awk 'BEGIN {FS = \":.*?## \"} /^[a-zA-Z_-]+:.*?## / {printf \"  $(YELLOW)%-30s$(NC) %s\\n\", $$1, $$2}' $(MAKEFILE_LIST) .makefiles/*.mk 2>/dev/null | grep -E \"build|Build\"\n83: \t@echo \"\"\n84: \t@echo \"$(GREEN)Test Targets:$(NC)\"\n85: \t@awk 'BEGIN {FS = \":.*?## \"} /^[a-zA-Z_-]+:.*?## / {printf \"  $(YELLOW)%-30s$(NC) %s\\n\", $$1, $$2}' $(MAKEFILE_LIST) .makefiles/*.mk 2>/dev/null | grep -E \"test|Test\"\n86: \t@echo \"\"\n87: \t@echo \"$(GREEN)Lint & Format Targets:$(NC)\"\n88: \t@awk 'BEGIN {FS = \":.*?## \"} /^[a-zA-Z_-]+:.*?## / {printf \"  $(YELLOW)%-30s$(NC) %s\\n\", $$1, $$2}' $(MAKEFILE_LIST) .makefiles/*.mk 2>/dev/null | grep -E \"lint|f