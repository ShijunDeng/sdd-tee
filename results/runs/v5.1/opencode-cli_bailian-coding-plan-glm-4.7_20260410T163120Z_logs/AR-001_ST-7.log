     memory: \"1Gi\"\n49:         livenessProbe:\n50:           httpGet:\n51:             port: 8080\n52:             path: /healthz\n53:           initialDelaySeconds: 10\n54:           periodSeconds: 10\n55:         readinessProbe:\n56:           httpGet:\n57:             port: 8080\n58:             path: /readyz\n59:           initialDelaySeconds: 5\n60:           periodSeconds: 5\n61:         securityContext:\n62:           runAsNonRoot: true\n63:           runAsUser: 1000\n64:           readOnlyRootFilesystem: true\n65:           allowPrivilegeEscalation: false\n66:           capabilities:\n67:             drop:\n68:             - ALL\n69:         volumeMounts:\n70:         - name: workspace\n71:           mountPath: /workspace\n72:         - name: config\n73:           mountPath: /etc/config\n74:           readOnly: true\n75:       nodeSelector:\n76:         node-role.kubernetes.io/agent: \"true\"\n77:       affinity:\n78:         nodeAffinity:\n79:           requiredDuringSchedulingIgnoredDuringExecution:\n80:             nodeSelectorTerms:\n81:             - matchExpressions:\n82:               - key: node-role.kubernetes.io/agent\n83:                 operator: In\n84:                 values:\n85:                 - \"true\"\n86:         podAntiAffinity:\n87:           preferredDuringSchedulingIgnoredDuringExecution:\n88:           - weight: 100\n89:             podAffinityTerm:\n90:               labelSelector:\n91:                 matchLabels:\n92:                   runtime: example\n93:               topologyKey: kubernetes.io/hostname\n94:       tolerations:\n95:       - key: node-role.kubernetes.io/agent\n96:         operator: Equal\n97:         value: \"true\"\n98:         effect: NoSchedule\n99:       volumes:\n100:       - name: workspace\n101:         emptyDir:\n102:           sizeLimit: 1Gi\n103:       - name: config\n104:         configMap:\n105:           name: agent-config\n106:           optional: true\n107:           items:\n108:           - key: config.yaml\n109:             path: config.yaml\n110:   sessionTimeout: 15m\n111:   maxSessionDuration: 8h\n\n(End of file - total 111 lines)\n</content>","metadata":{"preview":"apiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: AgentRuntime\nmetadata:\n  name: example-runtime\n  namespace: default\n  labels:\n    app: agentcube\n    component: runtime\nspec:\n  podTemplate:\n    metadata:\n      labels:\n        app: agent\n        runtime: example\n      annotations:\n        description: \"Example agent runtime\"\n    spec:\n      containers:\n      - name: agent\n        image: agent:latest","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/config/samples/runtime_v1alpha1_agentruntime.yaml","time":{"start":1775839810200,"end":1775839810208}}}}
