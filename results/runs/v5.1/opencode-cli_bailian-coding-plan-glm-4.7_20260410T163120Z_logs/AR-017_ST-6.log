{"type":"tool_use","timestamp":1775861430599,"sessionID":"ses_286695f8affeXqgpjksmL4xzeM","part":{"id":"prt_d7996f435001aklBYFDTzW8JWK","messageID":"msg_d7996da93001S2p67TTvgo51IW","sessionID":"ses_286695f8affeXqgpjksmL4xzeM","type":"tool","tool":"read","callID":"toolu_tool-f1a51cce30e64f2fb1ed8e3631fa8dd4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/middleware_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/middleware_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"crypto/rand\"\n5: \t\"crypto/rsa\"\n6: \t\"crypto/x509\"\n7: \t\"encoding/pem\"\n8: \t\"net/http\"\n9: \t\"net/http/httptest\"\n10: \t\"os\"\n11: \t\"strings\"\n12: \t\"testing\"\n13: \t\"time\"\n14: \n15: \t\"github.com/gin-gonic/gin\"\n16: \t\"github.com/golang-jwt/jwt/v5\"\n17: \t\"github.com/stretchr/testify/assert\"\n18: \t\"github.com/stretchr/testify/require\"\n19: )\n20: \n21: func setupTestAuthManager(t *testing.T) *AuthManager {\n22: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n23: \trequire.NoError(t, err)\n24: \n25: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n26: \trequire.NoError(t, err)\n27: \n28: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n29: \t\tType:  \"PUBLIC KEY\",\n30: \t\tBytes: publicKeyBytes,\n31: \t})\n32: \n33: \tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n34: \tt.Cleanup(func() {\n35: \t\tos.Unsetenv(PublicKeyEnvVar)\n36: \t})\n37: \n38: \tam, err := NewAuthManager()\n39: \trequire.NoError(t, err)\n40: \treturn am\n41: }\n42: \n43: func createTestTokenForMiddleware(t *testing.T, privateKey *rsa.PrivateKey) string {\n44: \tclaims := AuthClaims{\n45: \t\tRegisteredClaims: jwt.RegisteredClaims{\n46: \t\t\tIssuedAt:  jwt.NewNumericDate(time.Now()),\n47: \t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),\n48: \t\t},\n49: \t}\n50: \n51: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n52: \ttokenString, err := token.SignedString(privateKey)\n53: \trequire.NoError(t, err)\n54: \n55: \treturn tokenString\n56: }\n57: \n58: func TestAuthMiddleware_ErrorCases(t *testing.T) {\n59: \tgin.SetMode(gin.TestMode)\n60: \tam := setupTestAuthManager(t)\n61: \n62: \tmiddleware := AuthMiddleware(am)\n63: \n64: \ttests := []struct {\n65: \t\tname           string\n66: \t\tsetupRequest   func(*http.Request)\n67: \t\texpectedStatus int\n68: \t\texpectedError  string\n69: \t\tshouldSetClaim bool\n70: \t}{\n71: \t\t{\n72: \t\t\tname: \"missing authorization header\",\n73: \t\t\tsetupRequest: func(req *http.Request) {\n74: \t\t\t},\n75: \t\t\texpectedStatus: http.StatusUnauthorized,\n76: \t\t\texpectedError:  \"Missing Authorization header\",\n77: \t\t\tshouldSetClaim: false,\n78: \t\t},\n79: \t\t{\n80: \t\t\tname: \"invalid authorization format - Basic\",\n81: \t\t\tsetupRequest: func(req *http.Request) {\n82: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Basic dGVzdDp0ZXN0\")\n83: \t\t\t},\n84: \t\t\texpectedStatus: http.StatusUnauthorized,\n85: \t\t\texpectedError:  \"Use Bearer\",\n86: \t\t\tshouldSetClaim: false,\n87: \t\t},\n88: \t\t{\n89: \t\t\tname: \"invalid authorization format - Token\",\n90: \t\t\tsetupRequest: func(req *http.Request) {\n91: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Token abc123\")\n92: \t\t\t},\n93: \t\t\texpectedStatus: http.StatusUnauthorized,\n94: \t\t\texpectedError:  \"Use Bearer\",\n95: \t\t\tshouldSetClaim: false,\n96: \t\t},\n97: \t\t{\n98: \t\t\tname: \"invalid authorization format - no prefix\",\n99: \t\t\tsetupRequest: func(req *http.Request) {\n100: \t\t\t\treq.Header.Set(HeaderAuthorization, \"abc123\")\n101: \t\t\t},\n102: \t\t\texpectedStatus: http.StatusUnauthorized,\n103: \t\t\texpectedError:  \"Use Bearer\",\n104: \t\t\tshouldSetClaim: false,\n105: \t\t},\n106: \t\t{\n107: \t\t\tname: \"invalid token format\",\n108: \t\t\tsetupRequest: func(req *http.Request) {\n109: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer invalid.token.format\")\n110: \t\t\t},\n111: \t\t\texpectedStatus: http.StatusUnauthorized,\n112: \t\t\texpectedError:  \"invalid token\",\n113: \t\t\tshouldSetClaim: false,\n114: \t\t},\n115: \t\t{\n116: \t\t\tname: \"expired token\",\n117: \t\t\tsetupRequest: func(req *http.Request) {\n118: \t\t\t\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n119: \t\t\t\trequire.NoError(t, err)\n120: \n121: \t\t\t\tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n122: \t\t\t\trequire.NoError(t, err)\n123: \n124: \t\t\t\tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n125: \t\t\t\t\tType:  \"PUBLIC KEY\",\n126: \t\t\t\t\tBytes: publicKeyBytes,\n127: \t\t\t\t})\n128: \n129: \t\t\t\tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n130: \t\t\t\t_, err = NewAuthManager()\n131: \t\t\t\trequire.NoError(t, err)\n132: \n133: \t\t\t\tclaims := AuthClaims{\n134: \t\t\t\t\tRegisteredClaims: jwt.RegisteredClaims{\n135: \t\t\t\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now().Add(-2 * time.Hour)),\n136: \t\t\t\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(-1 * time.Hour)),\n137: \t\t\t\t\t},\n138: \t\t\t\t}\n139: \n140: \t\t\t\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n141: \t\t\t\ttokenString, err := token.SignedString(privateKey)\n142: \t\t\t\trequire.NoError(t, err)\n143: \n144: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+tokenString)\n145: \t\t\t},\n146: \t\t\texpectedStatus: http.StatusUnauthorized,\n147: \t\t\texpectedError:  \"invalid token\",\n148: \t\t\tshouldSetClaim: false,\n149: \t\t},\n150: \t\t{\n151: \t\t\tname: \"token with wrong signature\",\n152: \t\t\tsetupRequest: func(req *http.Request) {\n153: \t\t\t\twrongKey, err := rsa.GenerateKey(rand.Reader, 2048)\n154: \t\t\t\trequire.NoError(t, err)\n155: \n156: \t\t\t\ttoken := createTestTokenForMiddleware(t, wrongKey)\n157: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+token)\n158: \t\t\t},\n159: \t\t\texpectedStatus: http.StatusUnauthorized,\n160: \t\t\texpectedError:  \"invalid token\",\n161: \t\t\tshouldSetClaim: false,\n162: \t\t},\n163: \t\t{\n164: \t\t\tname: \"token with wrong signing algorithm (HS256)\",\n165: \t\t\tsetupRequest: func(req *http.Request) {\n166: \t\t\t\tclaims := AuthClaims{\n167: \t\t\t\t\tRegisteredClaims: jwt.RegisteredClaims{\n168: \t\t\t\t\t\tIssuedAt:  jwt.NewNumericDate(time.Now()),\n169: \t\t\t\t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),\n170: \t\t\t\t\t},\n171: \t\t\t\t}\n172: \n173: \t\t\t\ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n174: \t\t\t\tsecret := []byte(\"test-secret\")\n175: \t\t\t\ttokenString, err := token.SignedString(secret)\n176: \t\t\t\trequire.NoError(t, err)\n177: \n178: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+tokenString)\n179: \t\t\t},\n180: \t\t\texpectedStatus: http.StatusUnauthorized,\n181: \t\t\texpectedError:  \"invalid token\",\n182: \t\t\tshouldSetClaim: false,\n183: \t\t},\n184: \t}\n185: \n186: \tfor _, tt := range tests {\n187: \t\tt.Run(tt.name, func(t *testing.T) {\n188: \t\t\trouter := gin.New()\n189: \t\t\trouter.Use(middleware)\n190: \t\t\trouter.GET(\"/test\", func(c *gin.Context) {\n191: \t\t\t\tclaims, exists := c.Get(\"claims\")\n192: \t\t\t\tif tt.shouldSetClaim {\n193: \t\t\t\t\trequire.True(t, exists)\n194: \t\t\t\t\trequire.NotNil(t, claims)\n195: \t\t\t\t}\n196: \t\t\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n197: \t\t\t})\n198: \n199: \t\t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n200: \t\t\ttt.setupRequest(req)\n201: \n202: \t\t\tw := httptest.NewRecorder()\n203: \t\t\trouter.ServeHTTP(w, req)\n204: \n205: \t\t\tassert.Equal(t, tt.expectedStatus, w.Code)\n206: \t\t\tbody := w.Body.String()\n207: \t\t\tif tt.expectedError != \"\" {\n208: \t\t\t\tassert.Contains(t, body, tt.expectedError)\n209: \t\t\t}\n210: \t\t})\n211: \t}\n212: }\n213: \n214: func TestAuthMiddleware_ValidToken(t *testing.T) {\n215: \tgin.SetMode(gin.TestMode)\n216: \n217: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n218: \trequire.NoError(t, err)\n219: \n220: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n221: \trequire.NoError(t, err)\n222: \n223: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n224: \t\tType:  \"PUBLIC KEY\",\n225: \t\tBytes: publicKeyBytes,\n226: \t})\n227: \n228: \tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n229: \tt.Cleanup(func() {\n230: \t\tos.Unsetenv(PublicKeyEnvVar)\n231: \t})\n232: \n233: \tam, err := NewAuthManager()\n234: \trequire.NoError(t, err)\n235: \n236: \tmiddleware := AuthMiddleware(am)\n237: \ttoken := createTestTokenForMiddleware(t, privateKey)\n238: \n239: \trouter := gin.New()\n240: \trouter.Use(middleware)\n241: \trouter.GET(\"/test\", func(c *gin.Context) {\n242: \t\tclaims, exists := c.Get(\"claims\")\n243: \t\trequire.True(t, exists)\n244: \t\trequire.NotNil(t, claims)\n245: \n246: \t\tauthClaims, ok := claims.(*AuthClaims)\n247: \t\trequire.True(t, ok)\n248: \t\trequire.NotNil(t, authClaims)\n249: \n250: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n251: \t})\n252: \n253: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n254: \treq.Header.Set(HeaderAuthorization, \"Bearer \"+token)\n255: \n256: \tw := httptest.NewRecorder()\n257: \trouter.ServeHTTP(w, req)\n258: \n259: \tassert.Equal(t, http.StatusOK, w.Code)\n260: }\n261: \n262: func TestAuthMiddleware_BodySizeWrapped(t *testing.T) {\n263: \tgin.SetMode(gin.TestMode)\n264: \n265: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n266: \trequire.NoError(t, err)\n267: \n268: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n269: \trequire.NoError(t, err)\n270: \n271: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n272: \t\tType:  \"PUBLIC KEY\",\n273: \t\tBytes: publicKeyBytes,\n274: \t})\n275: \n276: \tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n277: \tt.Cleanup(func() {\n278: \t\tos.Unsetenv(PublicKeyEnvVar)\n279: \t})\n280: \n281: \tam, err := NewAuthManager()\n282: \trequire.NoError(t, err)\n283: \n284: \tmiddleware := AuthMiddleware(am)\n285: \ttoken := createTestTokenForMiddleware(t, privateKey)\n286: \n287: \tbodyWrapped := false\n288: \trouter := gin.New()\n289: \trouter.Use(middleware)\n290: \trouter.POST(\"/test\", func(c *gin.Context) {\n291: \t\tbodyWrapped = (c.Request.Body != nil)\n292: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n293: \t})\n294: \n295: \treq := httptest.NewRequest(http.MethodPost, \"/test\", strings.NewReader(\"test body\"))\n296: \treq.Header.Set(HeaderAuthorization, \"Bearer \"+token)\n297: \treq.Header.Set(\"Content-Type\", \"application/json\")\n298: \n299: \tw := httptest.NewRecorder()\n300: \trouter.ServeHTTP(w, req)\n301: \n302: \tassert.Equal(t, http.StatusOK, w.Code)\n303: \tassert.True(t, bodyWrapped, \"Request body should be wrapped\")\n304: }\n305: \n306: func TestAuthMiddleware_ClockSkewTolerance(t *testing.T) {\n307: \tgin.SetMode(gin.TestMode)\n308: \n309: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n310: \trequire.NoError(t, err)\n311: \n312: \tpublicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n313: \trequire.NoError(t, err)\n314: \n315: \tpublicKeyPEM := pem.EncodeToMemory(&pem.Block{\n316: \t\tType:  \"PUBLIC KEY\",\n317: \t\tBytes: publicKeyBytes,\n318: \t})\n319: \n320: \tos.Setenv(PublicKeyEnvVar, string(publicKeyPEM))\n321: \tt.Cleanup(func() {\n322: \t\tos.Unsetenv(PublicKeyEnvVar)\n323: \t})\n324: \n325: \tam, err := NewAuthManager()\n326: \trequire.NoError(t, err)\n327: \n328: \tclaims := AuthClaims{\n329: \t\tRegisteredClaims: jwt.RegisteredClaims{\n330: \t\t\tIssuedAt:  jwt.NewNumericDate(time.Now().Add(-59 * time.Second)),\n331: \t\t\tExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Second)),\n332: \t\t},\n333: \t}\n334: \n335: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n336: \ttokenString, err := token.SignedString(privateKey)\n337: \trequire.NoError(t, err)\n338: \n339: \tmiddleware := AuthMiddleware(am)\n340: \n341: \trouter := gin.New()\n342: \trouter.Use(middleware)\n343: \trouter.GET(\"/test\", func(c *gin.Context) {\n344: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n345: \t})\n346: \n347: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n348: \treq.Header.Set(HeaderAuthorization, \"Bearer \"+tokenString)\n349: \n350: \tw := httptest.NewRecorder()\n351: \trouter.ServeHTTP(w, req)\n352: \n353: \tassert.Equal(t, http.StatusOK, w.Code)\n354: }\n355: \n356: func TestAuthMiddleware_RequestAbortedOnError(t *testing.T) {\n357: \tgin.SetMode(gin.TestMode)\n358: \tam := setupTestAuthManager(t)\n359: \n360: \tmiddleware := AuthMiddleware(am)\n361: \n362: \thandlerCalled := false\n363: \trouter := gin.New()\n364: \trouter.Use(middleware)\n365: \trouter.GET(\"/test\", func(c *gin.Context) {\n366: \t\thandlerCalled = true\n367: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n368: \t})\n369: \n370: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n371: \n372: \tw := httptest.NewRecorder()\n373: \trouter.ServeHTTP(w, req)\n374: \n375: \tassert.Equal(t, http.StatusUnauthorized, w.Code)\n376: \tassert.False(t, handlerCalled)\n377: \tassert.Contains(t, w.Body.String(), \"Missing Authorization header\")\n378: }\n\n(End of file - total 378 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/middleware_test.go","time":{"start":1775861430580,"en