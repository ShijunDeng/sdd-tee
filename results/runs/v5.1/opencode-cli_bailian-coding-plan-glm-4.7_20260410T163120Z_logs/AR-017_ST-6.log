= \"WorkspaceProvisionFailed\"\n36: \tErrWorkspaceCleanupFailed   = \"WorkspaceCleanupFailed\"\n37: \tErrWorkspaceMetricsFailed   = \"WorkspaceMetricsFailed\"\n38: )\n39: \n40: const (\n41: \tErrorCodeBadRequest    = \"BadRequest\"\n42: \tErrorCodeUnauthorized  = \"Unauthorized\"\n43: \tErrorCodeNotFound      = \"NotFound\"\n44: \tErrorCodeInternalError = \"InternalError\"\n45: )\n46: \n47: var statusCodeMap = map[string]int{\n48: \tErrInvalidCommand:           http.StatusBadRequest,\n49: \tErrEmptyCommand:             http.StatusBadRequest,\n50: \tErrInvalidTimeout:           http.StatusBadRequest,\n51: \tErrInvalidWorkingDir:        http.StatusBadRequest,\n52: \tErrInvalidBase64:            http.StatusBadRequest,\n53: \tErrMissingPath:              http.StatusBadRequest,\n54: \tErrFileNotFound:             http.StatusNotFound,\n55: \tErrDirectoryNotFound:        http.StatusNotFound,\n56: \tErrPathIsDirectory:          http.StatusBadRequest,\n57: \tErrAccessDenied:             http.StatusBadRequest,\n58: \tErrMissingAuthHeader:        http.StatusUnauthorized,\n59: \tErrInvalidAuthFormat:        http.StatusUnauthorized,\n60: \tErrInvalidToken:             http.StatusUnauthorized,\n61: \tErrInvalidSignature:         http.StatusUnauthorized,\n62: \tErrTokenExpired:             http.StatusUnauthorized,\n63: \tErrInvalidPublicKey:         http.StatusInternalServerError,\n64: \tErrServerInternal:           http.StatusInternalServerError,\n65: \tErrWorkspaceNotInit:         http.StatusInternalServerError,\n66: \tErrK8sConnectionFailed:      http.StatusServiceUnavailable,\n67: \tErrK8sResourceNotFound:      http.StatusNotFound,\n68: \tErrK8sUpdateFailed:          http.StatusInternalServerError,\n69: \tErrK8sInformerFailed:        http.StatusInternalServerError,\n70: \tErrK8sConfigInvalid:         http.StatusBadRequest,\n71: \tErrWorkspaceProvisionFailed: http.StatusInternalServerError,\n72: \tErrWorkspaceCleanupFailed:   http.StatusInternalServerError,\n73: \tErrWorkspaceMetricsFailed:   http.StatusInternalServerError,\n74: }\n75: \n76: type ErrorResponse struct {\n77: \tError  string `json:\"error\"`\n78: \tCode   int    `json:\"code\"`\n79: \tDetail string `json:\"detail,omitempty\"`\n80: }\n81: \n82: type PicoDError struct {\n83: \tCode    string\n84: \tMessage string\n85: \tDetail  string\n86: \tErr     error\n87: }\n88: \n89: func (e *PicoDError) Error() string {\n90: \tif e.Err != nil {\n91: \t\treturn fmt.Sprintf(\"%s: %s (caused by: %v)\", e.Code, e.Message, e.Err)\n92: \t}\n93: \treturn fmt.Sprintf(\"%s: %s\", e.Code, e.Message)\n94: }\n95: \n96: func (e *PicoDError) Unwrap() error {\n97: \treturn e.Err\n98: }\n99: \n100: func NewError(code, message, detail string, err error) *PicoDError {\n101: \treturn &PicoDError{\n102: \t\tCode:    code,\n103: \t\tMessage: message,\n104: \t\tDetail:  detail,\n105: \t\tErr:     err,\n106: \t}\n107: }\n108: \n109: func HandleError(c *gin.Context, err error) {\n110: \tstatus := http.StatusInternalServerError\n111: \tcode := ErrorCodeInternalError\n112: \tmessage := err.Error()\n113: \tdetail := \"\"\n114: \n115: \tif picoDErr, ok := err.(*PicoDError); ok {\n116: \t\tcode = picoDErr.Code\n117: \t\tmessage = picoDErr.Message\n118: \t\tdetail = picoDErr.Detail\n119: \t\tif mappedStatus, exists := statusCodeMap[code]; exists {\n120: \t\t\tstatus = mappedStatus\n121: \t\t}\n122: \t}\n123: \n124: \tc.JSON(status, ErrorResponse{\n125: \t\tError:  message,\n126: \t\tCode:   status,\n127: \t\tDetail: detail,\n128: \t})\n129: }\n\n(End of file - total 129 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nconst (\n\tErrInvalidCommand    = \"InvalidCommand\"\n\tErrEmptyCommand      = \"EmptyCommand\"\n\tErrInvalidTimeout    = \"InvalidTimeout\"\n\tErrInvalidWorkingDir = \"InvalidWorkingDir\"\n\tErrInvalidBase64     = \"InvalidBase64\"\n\tErrMissingPath       = \"MissingPath\"\n\tErrFileNotFound      = \"FileNotFound\"