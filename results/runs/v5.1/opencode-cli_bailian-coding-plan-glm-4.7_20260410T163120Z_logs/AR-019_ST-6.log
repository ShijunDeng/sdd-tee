E\",\n46: \t\tShort: \"Validate AgentRuntime or CodeInterpreter manifests locally\",\n47: \t\tRun: func(cmd *cobra.Command, args []string) {\n48: \t\t\tif filePath == \"\" {\n49: \t\t\t\tcmd.Help()\n50: \t\t\t\tos.Exit(cli.ExitCodeFailure)\n51: \t\t\t}\n52: \n53: \t\t\tinfo, err := os.Stat(filePath)\n54: \t\t\tif err != nil {\n55: \t\t\t\tcli.HandleError(err)\n56: \t\t\t}\n57: \n58: \t\t\tvar files []string\n59: \t\t\tif info.IsDir() {\n60: \t\t\t\terr = filepath.Walk(filePath, func(path string, info os.FileInfo, err error) error {\n61: \t\t\t\t\tif err != nil {\n62: \t\t\t\t\t\treturn err\n63: \t\t\t\t\t}\n64: \t\t\t\t\tif !info.IsDir() && (filepath.Ext(path) == \".yaml\" || filepath.Ext(path) == \".yml\") {\n65: \t\t\t\t\t\tfiles = append(files, path)\n66: \t\t\t\t\t}\n67: \t\t\t\t\treturn nil\n68: \t\t\t\t})\n69: \t\t\t\tif err != nil {\n70: \t\t\t\t\tcli.HandleError(err)\n71: \t\t\t\t}\n72: \t\t\t} else {\n73: \t\t\t\tfiles = append(files, filePath)\n74: \t\t\t}\n75: \n76: \t\t\tallValid := true\n77: \t\t\tfor _, file := range files {\n78: \t\t\t\tvalid := validateFile(file)\n79: \t\t\t\tif !valid {\n80: \t\t\t\t\tallValid = false\n81: \t\t\t\t}\n82: \t\t\t}\n83: \n84: \t\t\tif !allValid {\n85: \t\t\t\tos.Exit(cli.ExitCodeFailure)\n86: \t\t\t}\n87: \n88: \t\t\tfmt.Println(\"All manifests are valid\")\n89: \t\t},\n90: \t}\n91: \n92: \tcmd.Flags().StringVarP(&filePath, \"filename\", \"f\", \"\", \"Path to file or directory to validate\")\n93: \n94: \treturn cmd\n95: }\n96: \n97: func dryRunCmd() *cobra.Command {\n98: \tvar filePath string\n99: \n100: \tcmd := &cobra.Command{\n101: \t\tUse:   \"dry-run -f FILE\",\n102: \t\tShort: \"Simulate resource creation without modifying the cluster\",\n103: \t\tRun: func(cmd *cobra.Command, args []string) {\n104: \t\t\tif filePath == \"\" {\n105: \t\t\t\tcmd.Help()\n106: \t\t\t\tos.Exit(cli.ExitCodeFailure)\n107: \t\t\t}\n108: \n109: \t\t\tdata, err := os.ReadFile(filePath)\n110: \t\t\tif err != nil {\n111: \t\t\t\tcli.HandleError(err)\n112: \t\t\t}\n113: \n114: \t\t\t_, err = detectResourceType(data)\n115: \t\t\tif err != nil {\n116: \t\t\t\tcli.HandleError(err)\n117: \t\t\t}\n118: \n119: \t\t\tfmt.Printf(\"Dry run: Would create resource from %s\\n\", filePath)\n120: \t\t\tfmt.Println(\"Validation: PASSED\")\n121: \t\t},\n122: \t}\n123: \n124: \tcmd.Flags().StringVarP(&filePath, \"filename\", \"f\", \"\", \"Path to manifest file\")\n125: \n126: \treturn cmd\n127: }\n128: \n129: func diagnoseCmd() *cobra.Command {\n130: \tcmd := &cobra.Command{\n131: \t\tUse:   \"diagnose\",\n132: \t\tShort: \"Run diagnostics on cluster connectivity\",\n133: \t\tRun: func(cmd *cobra.Command, args []string) {\n134: \t\t\tfmt.Println(\"Running AgentCube diagnostics...\")\n135: \n136: \t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n137: \t\t\tif err != nil {\n138: \t\t\t\tfmt.Printf(\"✗ Kubernetes client creation failed: %v\\n\", err)\n139: \t\t\t\tos.Exit(cli.ExitCodeFailure)\n140: \t\t\t}\n141: \t\t\tfmt.Println(\"✓ Kubernetes client created successfully\")\n142: \n143: \t\t\t_, err = cli.NewAgentRuntimeClient(client)\n144: \t\t\tif err != nil {\n145: \t\t\t\tfmt.Printf(\"✗ AgentRuntime client creation failed: %v\\n\", err)\n146: \t\t\t} else {\n147: \t\t\t\tfmt.Println(\"✓ AgentRuntime client available\")\n148: \t\t\t}\n149: \n150: \t\t\t_, err = cli.NewCodeInterpreterClient(client)\n151: \t\t\tif err != nil {\n152: \t\t\t\tfmt.Printf(\"✗ CodeInterpreter client creation failed: %v\\n\", err)\n153: \t\t\t} else {\n154: \t\t\t\tfmt.Println(\"✓ CodeInterpreter client available\")\n155: \t\t\t}\n156: \n157: \t\t\tfmt.Println(\"\\nDiagnostics complete\")\n158: \t\t},\n159: \t}\n160: \n161: \treturn cmd\n162: }\n163: \n164: func crdInfoCmd() *cobra.Command {\n165: \tcmd := &cobra.Command{\n166: \t\tUse:   \"crd-info\",\n167: \t\tShort: \"Display CRD information\",\n168: \t\tRun: func(cmd *cobra.Command, args []string) {\n169: \t\t\tfmt.Println(\"AgentCube CRD Information:\")\n170: \t\t\tfmt.Println(\"\\nAgentRuntime:\")\n171: \t\t\tfmt.Println(\"  Group: runtime.agentcube.volcano.sh\")\n172: \t\t\tfmt.Println(\"  Version: v1alpha1\")\n173: \t\t\tfmt.Println(\"  Resource: agentruntimes\")\n174: \t\t\tfmt.Println(\"  Short Names: ar, agentruntime\")\n175: \t\t\tfmt.Println(\"\\nCodeInterpreter:\")\n176: \t\t\tfmt.Println(\"  Group: runtime.agentcube.volcano.sh\")\n177: \t\t\tfmt.Println(\"  Version: v1alpha1\")\n178: \t\t\tfmt.Println(\"  Resource: codeinterpreters\")\n179: \t\t\tfmt.Println(\"  Short Names: ci, codeinterpreter\")\n180: \t\t},\n181: \t}\n182: \n183: \treturn cmd\n184: }\n185: \n186: func completionCmd() *cobra.Command {\n187: \tcmd := &cobra.Command{\n188: \t\tUse:   \"completion\",\n189: \t\tShort: \"Generate shell completion scripts\",\n190: \t}\n191: \n192: \tcmd.AddCommand(completionBashCmd())\n193: \tcmd.AddCommand(completionZshCmd())\n194: \tcmd.AddCommand(completionFishCmd())\n195: \tcmd.AddCommand(completionPowerShellCmd())\n196: \n197: \treturn cmd\n198: }\n199: \n200: func completionBashCmd() *cobra.Command {\n201: \tcmd := &cobra.Command{\n202: \t\tUse:   \"bash\",\n203: \t\tShort: \"Generate bash completion script\",\n204: \t\tRun: func(cmd *cobra.Command, args []string) {\n205: \t\t\tcmd.Root().GenBashCompletion(os.Stdout)\n206: \t\t},\n207: \t}\n208: \n209: \treturn cmd\n210: }\n211: \n212: func completionZshCmd() *cobra.Command {\n213: \tcmd := &cobra.Command{\n214: \t\tUse:   \"zsh\",\n215: \t\tShort: \"Generate zsh completion script\",\n216: \t\tRun: func(cmd *cobra.Command, args []string) {\n217: \t\t\tcmd.Root().GenZshCompletion(os.Stdout)\n218: \t\t},\n219: \t}\n220: \n221: \treturn cmd\n222: }\n223: \n224: func completionFishCmd() *cobra.Command {\n225: \tcmd := &cobra.Command{\n226: \t\tUse:   \"fish\",\n227: \t\tShort: \"Generate fish completion script\",\n228: \t\tRun: func(cmd *cobra.Command, args []string) {\n229: \t\t\tcmd.Root().GenFishCompletion(os.Stdout, true)\n230: \t\t},\n231: \t}\n232: \n233: \treturn cmd\n234: }\n235: \n236: func completionPowerShellCmd() *cobra.Command {\n237: \tcmd := &cobra.Command{\n238: \t\tUse:   \"powershell\",\n239: \t\tShort: \"Generate PowerShell completion script\",\n240: \t\tRun: func(cmd *cobra.Command, args []string) {\n241: \t\t\tcmd.Root().GenPowerShellCompletionWithDesc(os.Stdout)\n242: \t\t},\n243: \t}\n244: \n245: \treturn cmd\n246: }\n247: \n248: func validateFile(filePath string) bool {\n249: \tdata, err := os.ReadFile(filePath)\n250: \tif err != nil {\n251: \t\tfmt.Printf(\"✗ Error reading %s: %v\\n\", filePath, err)\n252: \t\treturn false\n253: \t}\n254: \n255: \tresourceType, err := detectResourceType(data)\n256: \tif err != nil {\n257: \t\tfmt.Printf(\"✗ %s: %v\\n\", filePath, err)\n258: \t\treturn false\n259: \t}\n260: \n261: \tswitch resourceType {\n262: \tcase \"AgentRuntime\":\n263: \t\truntime := &runtimev1alpha1.AgentRuntime{}\n264: \t\tif err := yaml.Unmarshal(data, runtime); err != nil {\n265: \t\t\tfmt.Printf(\"✗ %s: Invalid AgentRuntime manifest: %v\\n\", filePath, err)\n266: \t\t\treturn false\n267: \t\t}\n268: \t\tfmt.Printf(\"✓ %s: Valid AgentRuntime manifest\\n\", filePath)\n269: \tcase \"CodeInterpreter\":\n270: \t\tinterpreter := &runtimev1alpha1.CodeInterpreter{}\n271: \t\tif err := yaml.Unmarshal(data, interpreter); err != nil {\n272: \t\t\tfmt.Printf(\"✗ %s: Invalid CodeInterpreter manifest: %v\\n\", filePath, err)\n273: \t\t\treturn false\n274: \t\t}\n275: \t\tfmt.Printf(\"✓ %s: Valid CodeInterpreter manifest\\n\", filePath)\n276: \tdefault:\n277: \t\tfmt.Printf(\"✗ %s: Unknown resource type\\n\", filePath)\n278: \t\treturn false\n279: \t}\n280: \n281: \treturn true\n282: }\n283: \n284: func detectResourceType(data []byte) (string, error) {\n285: \tvar manifest map[string]interface{}\n286: \tif err := yaml.Unmarshal(data, &manifest); err != nil {\n287: \t\treturn \"\", fmt.Errorf(\"failed to parse YAML: %w\", err)\n288: \t}\n289: \n290: \tkind, ok := manifest[\"kind\"].(string)\n291: \tif !ok {\n292: \t\treturn \"\", fmt.Errorf(\"missing or invalid 'kind' field\")\n293: \t}\n294: \n295: \tswitch kind {\n296: \tcase \"AgentRuntime\":\n297: \t\treturn \"AgentRuntime\", nil\n298: \tcase \"CodeInterpreter\":\n299: \t\treturn \"CodeInterpreter\", nil\n300: \tdefault:\n301: \t\treturn \"\", fmt.Errorf(\"unsupported resource kind: %s\", kind)\n302: \t}\n303: }\n\n(End of file - total 303 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\n\t\"github.com/spf13/cobra\"\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/pkg/cli\"\n\t\"gopkg.in/yaml.v3\"\n)\n\nvar (\n\tkubeconfig string\n\tnamespace  string\n)\n\nfunc main() {\n\trootCmd := &cobra.Command{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/agentcube-util/main.go","time":{"start":1775864289189,"end":1775864289205}}}}
