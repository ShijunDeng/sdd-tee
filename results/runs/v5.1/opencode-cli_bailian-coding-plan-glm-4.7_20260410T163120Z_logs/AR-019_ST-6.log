dleError(err)\n223: \t\t\t}\n224: \n225: \t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n226: \t\t\tif err != nil {\n227: \t\t\t\tcli.HandleError(err)\n228: \t\t\t}\n229: \n230: \t\t\tdata, err := os.ReadFile(fileName)\n231: \t\t\tif err != nil {\n232: \t\t\t\tcli.HandleError(err)\n233: \t\t\t}\n234: \n235: \t\t\tinterpreter := &runtimev1alpha1.CodeInterpreter{}\n236: \t\t\tif err := yaml.Unmarshal(data, interpreter); err != nil {\n237: \t\t\t\tcli.HandleError(err)\n238: \t\t\t}\n239: \n240: \t\t\tupdated, err := interpreterClient.Update(cmd.Context(), interpreter, metav1.UpdateOptions{})\n241: \t\t\tif err != nil {\n242: \t\t\t\tcli.HandleError(err)\n243: \t\t\t}\n244: \n245: \t\t\tprinter := &cli.PrintOptions{\n246: \t\t\t\tFormat: cli.OutputFormatYAML,\n247: \t\t\t\tOutput: os.Stdout,\n248: \t\t\t}\n249: \t\t\tif err := cli.Print(updated, printer); err != nil {\n250: \t\t\t\tcli.HandleError(err)\n251: \t\t\t}\n252: \t\t},\n253: \t}\n254: \n255: \tcmd.Flags().StringVarP(&fileName, \"filename\", \"f\", \"\", \"Filename to use to update the resource\")\n256: \n257: \treturn cmd\n258: }\n259: \n260: func deleteCmd() *cobra.Command {\n261: \tvar force bool\n262: \n263: \tcmd := &cobra.Command{\n264: \t\tUse:   \"delete NAME\",\n265: \t\tShort: \"Delete a CodeInterpreter resource\",\n266: \t\tArgs:  cobra.ExactArgs(1),\n267: \t\tRun: func(cmd *cobra.Command, args []string) {\n268: \t\t\tif !force {\n269: \t\t\t\tif !cli.Confirm(fmt.Sprintf(\"Are you sure you want to delete CodeInterpreter %q?\", args[0])) {\n270: \t\t\t\t\tfmt.Println(\"Deletion cancelled\")\n271: \t\t\t\t\tos.Exit(cli.ExitCodeSuccess)\n272: \t\t\t\t}\n273: \t\t\t}\n274: \n275: \t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n276: \t\t\tif err != nil {\n277: \t\t\t\tcli.HandleError(err)\n278: \t\t\t}\n279: \n280: \t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n281: \t\t\tif err != nil {\n282: \t\t\t\tcli.HandleError(err)\n283: \t\t\t}\n284: \n285: \t\t\tif err := interpreterClient.Delete(cmd.Context(), args[0], metav1.DeleteOptions{}); err != nil {\n286: \t\t\t\tcli.HandleError(err)\n287: \t\t\t}\n288: \n289: \t\t\tfmt.Printf(\"CodeInterpreter %q deleted\\n\", args[0])\n290: \t\t},\n291: \t}\n292: \n293: \tcmd.Flags().BoolVarP(&force, \"force\", \"\", false, \"Delete without confirmation\")\n294: \n295: \treturn cmd\n296: }\n297: \n298: func watchCmd() *cobra.Command {\n299: \tcmd := &cobra.Command{\n300: \t\tUse:   \"watch\",\n301: \t\tShort: \"Watch CodeInterpreter resources for changes\",\n302: \t\tRun: func(cmd *cobra.Command, args []string) {\n303: \t\t\tclient, err := cli.NewClient(kubeconfig, namespace)\n304: \t\t\tif err != nil {\n305: \t\t\t\tcli.HandleError(err)\n306: \t\t\t}\n307: \n308: \t\t\tinterpreterClient, err := cli.NewCodeInterpreterClient(client)\n309: \t\t\tif err != nil {\n310: \t\t\t\tcli.HandleError(err)\n311: \t\t\t}\n312: \n313: \t\t\twatcher, err := interpreterClient.Watch(cmd.Context(), metav1.ListOptions{})\n314: \t\t\tif err != nil {\n315: \t\t\t\tcli.HandleError(err)\n316: \t\t\t}\n317: \t\t\tdefer watcher.Stop()\n318: \n319: \t\t\tfor event := range watcher.ResultChan() {\n320: \t\t\t\tinterpreter, ok := event.Object.(*runtimev1alpha1.CodeInterpreter)\n321: \t\t\t\tif !ok {\n322: \t\t\t\t\tcontinue\n323: \t\t\t\t}\n324: \n325: \t\t\t\tswitch event.Type {\n326: \t\t\t\tcase watch.Added:\n327: \t\t\t\t\tfmt.Printf(\"ADDED\\t%s\\n\", interpreter.Name)\n328: \t\t\t\tcase watch.Modified:\n329: \t\t\t\t\tfmt.Printf(\"MODIFIED\\t%s\\n\", interpreter.Name)\n330: \t\t\t\tcase watch.Deleted:\n331: \t\t\t\t\tfmt.Printf(\"DELETED\\t%s\\n\", interpreter.Name)\n332: \t\t\t\tcase watch.Error:\n333: \t\t\t\t\tfmt.Printf(\"ERROR\\t%v\\n\", event.Object)\n334: \t\t\t\t}\n335: \t\t\t}\n336: \t\t},\n337: \t}\n338: \n339: \treturn cmd\n340: }\n\n(End of file - total 340 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\n\t\"github.com/spf13/cobra\"\n\truntime