.logger = get_logger(__name__, logging.DEBUG if verbose else logging.INFO)\n43:         self.agent_name = agent_name\n44:         self.namespace = namespace\n45:         self.timeout = timeout\n46:         self.connect_timeout = connect_timeout\n47:         self.session_id = session_id\n48: \n49:         self.router_url = router_url or os.getenv(\"ROUTER_URL\")\n50:         if not self.router_url:\n51:             raise ValueError(\n52:                 \"Router URL must be provided via argument or ROUTER_URL environment variable\"\n53:             )\n54: \n55:         self.dp_client = AgentRuntimeDataPlaneClient(\n56:             router_url=self.router_url,\n57:             namespace=self.namespace,\n58:             agent_name=self.agent_name,\n59:             timeout=self.timeout,\n60:             connect_timeout=self.connect_timeout,\n61:         )\n62: \n63:         if not self.session_id:\n64:             self.session_id = self.dp_client.bootstrap_session_id()\n65:             self.logger.info(f\"Bootstrapped session: {self.session_id}\")\n66: \n67:     def __enter__(self):\n68:         \"\"\"Context manager entry.\"\"\"\n69:         return self\n70: \n71:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n72:         \"\"\"Context manager exit - cleanup resources.\"\"\"\n73:         self.close()\n74: \n75:     def invoke(\n76:         self,\n77:         payload: Dict[str, Any],\n78:         timeout: Optional[float] = None,\n79:     ) -> Any:\n80:         \"\"\"Invoke the agent runtime with a payload.\n81: \n82:         Args:\n83:             payload: JSON payload to send.\n84:             timeout: Optional timeout override.\n85: \n86:         Returns:\n87:             The response data.\n88: \n89:         Raises:\n90:             ValueError: If session_id is not initialized.\n91:         \"\"\"\n92:         if not self.session_id:\n93:             raise ValueError(\"AgentRuntime session_id is not initialized\")\n94: \n95:         response = self.dp_client.invoke(\n96:             session_id=self.session_id,\n97:             payload=payload,\n98:             timeout=timeout,\n99:         )\n100:         return response.json()\n101: \n102:     def close(self) -> None:\n103:         \"\"\"Close the underlying HTTP session.\"\"\"\n104:         self.dp_client.close()\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"\"\"\"Agent Runtime Client for AgentCube SDK.\"\"\"\n\nimport logging\nimport os\nfrom typing import Any, Dict, Optional\n\nfrom .clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom .utils.log import get_logger\n\n\nclass AgentRuntimeClient:\n    \"\"\"High-level client for Agent Runtime operations.\n\n    This client manages session lifecycle and provides a convenient interface\n    for invoking agent runtimes.\n    \"\"\"\n\n    def __init__(\n        self,\n        agent_name: str,","truncated":false,"loaded":[]},"title":"sdk-python/agentcube/agent_runtime.py","time":{"start":1775895857049,"end":1775895857067}}}}
