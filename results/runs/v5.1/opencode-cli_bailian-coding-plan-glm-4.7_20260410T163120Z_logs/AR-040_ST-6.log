        pool_connections: Number of connections to pool.\n40:             pool_maxsize: Maximum number of connections in the pool.\n41:         \"\"\"\n42:         self.logger = get_logger(__name__)\n43:         self.session_id = session_id\n44:         self.timeout = timeout\n45:         self.connect_timeout = connect_timeout\n46: \n47:         if base_url:\n48:             self.base_url = base_url\n49:         else:\n50:             if not router_url:\n51:                 raise ValueError(\"router_url must be provided if base_url is not set\")\n52:             base_path = f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\"\n53:             self.base_url = urljoin(router_url, base_path)\n54: \n55:         self.session = create_session(\n56:             pool_connections=pool_connections,\n57:             pool_maxsize=pool_maxsize,\n58:         )\n59:         self.session.headers[\"x-agentcube-session-id\"] = session_id\n60: \n61:     def _request(\n62:         self,\n63:         method: str,\n64:         endpoint: str,\n65:         body: Optional[bytes] = None,\n66:         **kwargs,\n67:     ) -> requests.Response:\n68:         \"\"\"Make an HTTP request to the data plane.\n69: \n70:         Args:\n71:             method: HTTP method.\n72:             endpoint: Relative endpoint path.\n73:             body: Optional request body bytes.\n74:             **kwargs: Additional arguments passed to requests.\n75: \n76:         Returns:\n77:             The HTTP response.\n78:         \"\"\"\n79:         url = urljoin(self.base_url, endpoint)\n80:         headers = kwargs.pop(\"headers\", {})\n81:         kwargs.pop(\"timeout\", None)\n82: \n83:         if body:\n84:             headers[\"Content-Type\"] = \"application/json\"\n85:             response = self.session.request(\n86:                 method,\n87:                 url,\n88:                 data=body,\n89:                 headers=headers,\n90:                 timeout=(self.connect_timeout, self.timeout),\n91:                 **kwargs,\n92:             )\n93:         else:\n94:             response = self.session.request(\n95:                 method,\n96:                 url,\n97:                 headers=headers,\n98:                 timeout=(self.connect_timeout, self.timeout),\n99:                 **kwargs,\n100:             )\n101: \n102:         return response\n103: \n104:     def execute_command(\n105:         self,\n106:         command: Union[str, List[str]],\n107:         timeout: Optional[float] = None,\n108:     ) -> str:\n109:         \"\"\"Execute a command in the code interpreter.\n110: \n111:         Args:\n112:             command: Command string or list of command parts.\n113:             timeout: Timeout in seconds. Defaults to self.timeout.\n114: \n115:         Returns:\n116:             The command output (stdout).\n117: \n118:         Raises:\n119:             CommandExecutionError: If the command returns non-zero exit code.\n120:         \"\"\"\n121:         effective_timeout = timeout if timeout is not None else self.timeout\n122: \n123:         if isinstance(command, str):\n124:             cmd_list = [command]\n125:         else:\n126:             cmd_list = command\n127: \n128:         timeout_str = f\"{int(effective_timeout)}s\"\n129:         payload = {\n130:             \"command\": cmd_list,\n131:             \"timeout\": timeout_str,\n132:         }\n133: \n134:         import json\n135:         body = json.dumps(payload).encode(\"utf-8\")\n136: \n137:         read_timeout = effective_timeout + 2.0\n138: \n139:         response = self._request(\n140:             \"POST\",\n141:             \"api/execute\",\n142:             body=body,\n143:             timeout=(self.connect_timeout, read_timeout),\n144:         )\n145:         response.raise_for_status()\n146: \n147:         data = response.json()\n148:         exit_code = data.get(\"exit_code\", 0)\n149:         stderr = data.get(\"stderr\", \"\")\n150:         stdout = data.get(\"stdout\", \"\")\n151: \n152:         if exit_code != 0:\n153:             from ..exceptions import CommandExecutionError\n154:             raise CommandExecutionError(\n155:                 exit_code=exit_code,\n156:                 stderr=stderr,\n157:                 command=cmd_list,\n158:             )\n159: \n160:         return stdout\n161: \n162:     def run_code(\n163:         self,\n164:         language: str,\n165:         code: str,\n166:         timeout: Optional[float] = None,\n167:     ) -> str:\n168:         \"\"\"Run code in the specified language.\n169: \n170:         Args:\n171:             language: Programming language (python, py, python3, etc.).\n172:             code: Code to execute.\n173:             timeout: Timeout in seconds.\n174: \n175:         Returns:\n176:             The code output.\n177:         \"\"\"\n178:         if language in (\"python\", \"py\", \"python3\"):\n179:             import time\n180:             timestamp = int(time.time() * 1000)\n181:             remote_path = f\"/tmp/code_{timestamp}.py\"\n182:             self.write_file(code, remote_path)\n183:             command = f\"python3 {remote_path}\"\n184:             return self.execute_command(command, timeout)\n185:         else:\n186:             raise ValueError(f\"Unsupported language: {language}\")\n187: \n188:     def write_file(self, content: str, remote_path: str) -> None:\n189:         \"\"\"Write content to a file in the remote environment.\n190: \n191:         Args:\n192:             content: File content.\n193:             remote_path: Remote file path.\n194:         \"\"\"\n195:         import json\n196: \n197:         content_b64 = base64.b64encode(content.encode(\"utf-8\")).decode(\"utf-8\")\n198:         payload = {\n199:             \"path\": remote_path,\n200:             \"content\": content_b64,\n201:             \"mode\": \"0644\",\n202:         }\n203: \n204:         body = json.dumps(payload).encode(\"utf-8\")\n205:         response = self._request(\"POST\", \"api/files\", body=body)\n206:         response.raise_for_status()\n207: \n208:     def upload_file(self, local_path: str, remote_path: str) -> None:\n209:         \"\"\"Upload a local file to the remote environment.\n210: \n211:         Args:\n212:             local_path: Path to local file.\n213:             remote_path: Remote file path.\n214:         \"\"\"\n215:         url = urljoin(self.base_url, \"api/files\")\n216: \n217:         with open(local_path, \"rb\") as f:\n218:             files = {\"file\": f}\n219:             data = {\n220:                 \"path\": remote_path,\n221:                 \"mode\": \"0644\",\n222:             }\n223:             headers = {\n224:                 \"x-agentcube-session-id\": self.session_id,\n225:             }\n226: \n227:             response = self.session.post(\n228:                 url,\n229:                 files=files,\n230:                 data=data,\n231:                 headers=headers,\n232:                 timeout=(self.connect_timeout, self.timeout),\n233:             )\n234:             response.raise_for_status()\n235: \n236:     def download_file(self, remote_path: str, local_path: str) -> None:\n237:         \"\"\"Download a file from the remote environment.\n238: \n239:         Args:\n240:             remote_path: Remote file path.\n241:             local_path: Local file path to save to.\n242:         \"\"\"\n243:         clean_path = remote_path.lstrip(\"/\")\n244:         endpoint = f\"api/files/{clean_path}\"\n245: \n246:         response = self._request(\n247:             \"GET\",\n248:             endpoint,\n249:             stream=True,\n250:         )\n251:         response.raise_for_status()\n252: \n253:         with open(local_path, \"wb\") as f:\n254:             for chunk in response.iter_content(chunk_size=8192):\n255:                 f.write(chunk)\n256: \n257:     def list_files(self, path: str = \".\") -> Any:\n258:         \"\"\"List files in the remote environment.\n259: \n260:         Args:\n261:             path: Path to list.\n262: \n263:         Returns:\n264:             The file listing response data.\n265:         \"\"\"\n266:         params = {\"path\": path}\n267: \n268:         response = self._request(\n269:             \"GET\",\n270:             \"api/files\",\n271:             params=params,\n272:         )\n273:         response.raise_for_status()\n274:         return response.json()\n275: \n276:     def close(self) -> None:\n277:         \"\"\"Close the underlying HTTP session.\"\"\"\n278:         self.session.close()\n\n(End of file - total 278 lines)\n</content>","metadata":{"preview":"\"\"\"Code Interpreter Data Plane client for AgentCube SDK.\"\"\"\n\nimport base64\nimport logging\nfrom typing import Any, Dict, List, Optional, Union\nfrom urllib.parse import urljoin\n\nimport requests\n\nfrom ..utils.http import create_session\nfrom ..utils.log import get_logger\n\n\nclass CodeInterpreterDataPlaneClient:\n    \"\"\"Client for interacting with the Code Interpreter data plane (Router).\"\"\"\n\n    def __init__(\n        self,\n        session_id: str,\n        router_url: Optional[str] = None,","truncated":false,"loaded":[]},"title":"sdk-python/agentcube/clients/code_interpreter_data_plane.py","time":{"start":1775895857052,"end":1775895857069}}}}
