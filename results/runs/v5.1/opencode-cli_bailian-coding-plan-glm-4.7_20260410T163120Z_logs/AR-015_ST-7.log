ext.WithTimeout(context.Background(), timeout)\n53: \tdefer cancel()\n54: \n55: \tcmd := exec.CommandContext(ctx, req.Command[0], req.Command[1:]...)\n56: \tcmd.Dir = workingDir\n57: \n58: \tenv := os.Environ()\n59: \tfor k, v := range req.Env {\n60: \t\tenv = append(env, fmt.Sprintf(\"%s=%s\", k, v))\n61: \t}\n62: \tcmd.Env = env\n63: \n64: \tstartTime := time.Now()\n65: \tstdout, err := cmd.CombinedOutput()\n66: \tendTime := time.Now()\n67: \tduration := endTime.Sub(startTime)\n68: \n69: \texitCode := 0\n70: \tif err != nil {\n71: \t\tif ctx.Err() == context.DeadlineExceeded {\n72: \t\t\texitCode = TimeoutExitCode\n73: \t\t} else {\n74: \t\t\tif exitError, ok := err.(*exec.ExitError); ok {\n75: \t\t\t\texitCode = exitError.ExitCode()\n76: \t\t\t} else {\n77: \t\t\t\texitCode = 1\n78: \t\t\t}\n79: \t\t}\n80: \t}\n81: \n82: \tresponse := ExecuteResponse{\n83: \t\tStdout:    string(stdout),\n84: \t\tStderr:    \"\",\n85: \t\tExitCode:  exitCode,\n86: \t\tDuration:  duration.Seconds(),\n87: \t\tStartTime: startTime.UTC(),\n88: \t\tEndTime:   endTime.UTC(),\n89: \t}\n90: \n91: \tc.JSON(http.StatusOK, response)\n92: }\n93: \n94: func (s *Server) UploadFileHandler(c *gin.Context) {\n95: \tcontentType := c.GetHeader(HeaderContentType)\n96: \n97: \tif strings.HasPrefix(contentType, MIMEMultipart) {\n98: \t\tif err := c.Request.ParseMultipartForm(32 << 20); err != nil {\n99: \t\t\tHandleError(c, NewError(ErrInvalidCommand, \"failed to parse multipart form\", err.Error(), err))\n100: \t\t\treturn\n101: \t\t}\n102: \n103: \t\tpath := c.PostForm(\"path\")\n104: \t\tfile, header, err := c.Request.FormFile(\"file\")\n105: \t\tif err != nil {\n106: \t\t\tHandleError(c, NewError(ErrMissingPath, \"path or file form field missing\", \"\", err))\n107: \t\t\treturn\n108: \t\t}\n109: \t\tdefer file.Close()\n110: \n111: \t\tif path == \"\" {\n112: \t\t\tHandleError(c, NewError(ErrMissingPath, \"path form field missing\", \"\", nil))\n113: \t\t\treturn\n114: \t\t}\n115: \n116: \t\tmodeStr := c.PostForm(\"mode\")\n117: \t\tmode := parseFileMode(modeStr)\n118: \n119: \t\tsanitizedPath, err := s.sanitizePath(path)\n120: \t\tif err != nil {\n121: \t\t\tHandleError(c, err)\n122: \t\t\treturn\n123: \t\t}\n124: \n125: \t\tif err := os.MkdirAll(filepath.Dir(sanitizedPath), DefaultDirMode); err != nil {\n126: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to create directory\", err.Error(), err))\n127: \t\t\treturn\n128: \t\t}\n129: \n130: \t\tdst, err := os.OpenFile(sanitizedPath, os.O_WRONLY|os.O_CREATE|os.O_TRUNC, mode)\n131: \t\tif err != nil {\n132: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to create file\", err.Error(), err))\n133: \t\t\treturn\n134: \t\t}\n135: \t\tdefer dst.Close()\n136: \n137: \t\tif _, err := io.Copy(dst, file); err != nil {\n138: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to write file\", err.Error(), err))\n139: \t\t\treturn\n140: \t\t}\n141: \n142: \t\tklog.Infof(\"Uploaded file: %s (size: %d, original: %s)\", sanitizedPath, header.Size, header.Filename)\n143: \n144: \t\tfileInfo, err := s.getFileInfo(sanitizedPath)\n145: \t\tif err != nil {\n146: \t\t\tHandleError(c, err)\n147: \t\t\treturn\n148: \t\t}\n149: \n150: \t\tc.JSON(http.StatusOK, fileInfo)\n151: \t} else {\n152: \t\tvar req UploadFileRequest\n153: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n154: \t\t\tHandleError(c, NewError(ErrInvalidCommand, \"invalid request body\", err.Error(), err))\n155: \t\t\treturn\n156: \t\t}\n157: \n158: \t\tcontent, err := base64.StdEncoding.DecodeString(req.Content)\n159: \t\tif err != nil {\n160: \t\t\tHandleError(c, NewError(ErrInvalidBase64, ErrMsgInvalidBase64, err.Error(), err))\n161: \t\t\treturn\n162: \t\t}\n163: \n164: \t\tsanitizedPath, err := s.sanitizePath(req.Path)\n165: \t\tif err != nil {\n166: \t\t\tHandleError(c, err)\n167: \t\t\treturn\n168: \t\t}\n169: \n170: \t\tif err := os.MkdirAll(filepath.Dir(sanitizedPath), DefaultDirMode); err != nil {\n171: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to create directory\", err.Error(), err))\n172: \t\t\treturn\n173: \t\t}\n174: \n175: \t\tmode := parseFileMode(req.Mode)\n176: \t\tif err := os.WriteFile(sanitizedPath, content, mode); err != nil {\n177: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to write file\", err.Error(), err))\n178: \t\t\treturn\n179: \t\t}\n180: \n181: \t\tklog.Infof(\"Uploaded file: %s (size: %d)\", sanitizedPath, len(content))\n182: \n183: \t\tfileInfo, err := s.getFileInfo(sanitizedPath)\n184: \t\tif err != nil {\n185: \t\t\tHandleError(c, err)\n186: \t\t\treturn\n187: \t\t}\n188: \n189: \t\tc.JSON(http.StatusOK, fileInfo)\n190: \t}\n191: }\n192: \n193: func (s *Server) ListFilesHandler(c *gin.Context) {\n194: \tpath := c.Query(\"path\")\n195: \tif path == \"\" {\n196: \t\tHandleError(c, NewError(ErrMissingPath, ErrMsgMissingPathParam, \"\", nil))\n197: \t\treturn\n198: \t}\n199: \n200: \tsanitizedPath, err := s.sanitizePath(path)\n201: \tif err != nil {\n202: \t\tHandleError(c, err)\n203: \t\treturn\n204: \t}\n205: \n206: \tentries, err := os.ReadDir(sanitizedPath)\n207: \tif err != nil {\n208: \t\tif os.IsNotExist(err) {\n209: \t\t\tHandleError(c, NewError(ErrDirectoryNotFound, ErrMsgDirectoryNotFound, \"\", err))\n210: \t\t} else {\n211: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to read directory\", err.Error(), err))\n212: \t\t}\n213: \t\treturn\n214: \t}\n215: \n216: \tvar files []FileEntry\n217: \tfor _, entry := range entries {\n218: \t\tinfo, err := entry.Info()\n219: \t\tif err != nil {\n220: \t\t\tklog.Warningf(\"Failed to get info for %s: %v\", entry.Name(), err)\n221: \t\t\tcontinue\n222: \t\t}\n223: \n224: \t\tfiles = append(files, FileEntry{\n225: \t\t\tName:     entry.Name(),\n226: \t\t\tSize:     info.Size(),\n227: \t\t\tModified: info.ModTime(),\n228: \t\t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n229: \t\t\tIsDir:    entry.IsDir(),\n230: \t\t})\n231: \t}\n232: \n233: \tresponse := ListFilesResponse{\n234: \t\tFiles: files,\n235: \t}\n236: \n237: \tc.JSON(http.StatusOK, response)\n238: }\n239: \n240: func (s *Server) DownloadFileHandler(c *gin.Context) {\n241: \tpath := c.Param(\"path\")\n242: \tif path == \"\" {\n243: \t\tHandleError(c, NewError(ErrMissingPath, ErrMsgMissingPathParam, \"\", nil))\n244: \t\treturn\n245: \t}\n246: \n247: \tpath = strings.TrimPrefix(path, \"/\")\n248: \n249: \tsanitizedPath, err := s.sanitizePath(path)\n250: \tif err != nil {\n251: \t\tHandleError(c, err)\n252: \t\treturn\n253: \t}\n254: \n255: \tinfo, err := os.Stat(sanitizedPath)\n256: \tif err != nil {\n257: \t\tif os.IsNotExist(err) {\n258: \t\t\tHandleError(c, NewError(ErrFileNotFound, ErrMsgFileNotFound, \"\", err))\n259: \t\t} else {\n260: \t\t\tHandleError(c, NewError(ErrServerInternal, \"failed to get file info\", err.Error(), err))\n261: \t\t}\n262: \t\treturn\n263: \t}\n264: \n265: \tif info.IsDir() {\n266: \t\tHandleError(c, NewError(ErrPathIsDirectory, ErrMsgPathIsDirectory, \"\", nil))\n267: \t\treturn\n268: \t}\n269: \n270: \tcontent, err := os.ReadFile(sanitizedPath)\n271: \tif err != nil {\n272: \t\tHandleError(c, NewError(ErrServerInternal, \"failed to read file\", err.Error(), err))\n273: \t\treturn\n274: \t}\n275: \n276: \tc.Header(HeaderContentDescription, \"File Transfer\")\n277: \tc.Header(HeaderContentEncoding, \"binary\")\n278: \tc.Header(HeaderContentDisposition, fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filepath.Base(sanitizedPath)))\n279: \n280: \tmimeType := mime.TypeByExtension(filepath.Ext(sanitizedPath))\n281: \tif mimeType == \"\" {\n282: \t\tmimeType = MIMEOctetStream\n283: \t}\n284: \tc.Header(HeaderContentType, mimeType)\n285: \n286: \tc.Data(http.StatusOK, mimeType, content)\n287: }\n288: \n289: func (s *Server) HealthCheckHandler(c *gin.Context) {\n290: \tuptime := time.Since(s.startTime)\n291: \n292: \tc.JSON(http.StatusOK, gin.H{\n293: \t\t\"status\":  \"ok\",\n294: \t\t\"service\": ServiceName,\n295: \t\t\"version\": Version,\n296: \t\t\"uptime\":  uptime.String(),\n297: \t})\n298: }\n\n(End of file - total 298 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\nfunc (s *Server) ExecuteHandler(c *gin.Context) {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/handlers.go","time":{"start":1775858920993,"end":1775858921019}}}}
{"type":"tool_use","timestamp":1775858921025,"sessionID":"ses_2868f8df7ffeRyXTi6MhEkYhzE","part":{"id":"prt_d7970ae07001LMLTsXDjBxr0Vc","messageID":"msg_d7970a4860018Mivf1EVJ4nT6a","sessionID":"ses_2868f8df7ffeRyXTi6MhEkYhzE","type":"tool","tool":"read","callID":"toolu_tool-ef28c3902a8a472584b992330bdb59f1","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"net/http/httptest\"\n6: \t\"os\"\n7: \t\"testing\"\n8: \t\"time\"\n9: \n10: \t\"github.com/gin-gonic/gin\"\n11: \t\"github.com/stretchr/testify/assert\"\n12: \t\"github.com/stretchr/testify/require\"\n13: )\n14: \n15: func setupTestServer(t *testing.T) *Server {\n16: \tworkspace := t.TempDir()\n17: \n18: \t_, publicKey := generateTestKeyPair(t)\n19: \tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n20: \n21: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n22: \tdefer os.Unsetenv(PublicKeyEnvVar)\n23: \n24: \tconfig := Config{\n25: \t\tPort:      0,\n26: \t\tWorkspace: workspace,\n27: \t}\n28: \n29: \tserver, err := NewServer(config)\n30: \trequire.NoError(t, err)\n31: \n32: \tgin.SetMode(gin.TestMode)\n33: \n34: \treturn server\n35: }\n36: \n37: func cleanupTestServer(t *testing.T, server *Server) {\n38: \tos.Unsetenv(PublicKeyEnvVar)\n39: }\n40: \n41: func TestSanitizePath(t *testing.T) {\n42: \tserver := setupTestServer(t)\n43: \tdefer cleanupTestServer(t, server)\n44: \n45: \ttests := []struct {\n46: \t\tname        string\n47: \t\tpath        string\n48: \t\twantErr     bool\n49: \t\terrContains string\n50: \t}{\n51: \t\t{\n52: \t\t\tname:    \"valid relative path\",\n53: \t\t\tpath:    \"test/file.txt\",\n54: \t\t\twantErr: false,\n55: \t\t},\n56: \t\t{\n57: \t\t\tname:    \"valid absolute path\",\n58: \t\t\tpath:    \"/test/file.txt\",\n59: \t\t\twantErr: false,\n60: \t\t},\n61: \t\t{\n62: \t\t\tname:        \"path traversal attempt\",\n63: \t\t\tpath:        \"../../etc/passwd\",\n64: \t\t\twantErr:     true,\n65: \t\t\terrContains: \"Access denied\",\n66: \t\t},\n67: \t\t{\n68: \t\t\tname:    \"empty path\",\n69: \t\t\tpath:    \"\",\n70: \t\t\twantErr: false,\n71: \t\t},\n72: \t\t{\n73: \t\t\tname:    \"single dot\",\n74: \t\t\tpath:    \".\",\n75: \t\t\twantErr: false,\n76: \t\t},\n77: \t\t{\n78: \t\t\tname:        \"double dot at root\",\n79: \t\t\tpath:        \"..\",\n80: \t\t\twantErr:     true,\n81: \t\t\terrContains: \"Access denied\",\n82: \t\t},\n83: \t}\n84: \n85: \tfor _, tt := range tests {\n86: \t\tt.Run(tt.name, func(t *testing.T) {\n87: \t\t\tresult, err := server.sanitizePath(tt.path)\n88: \n89: \t\t\tif tt.wantErr {\n90: \t\t\t\tassert.Error(t, err)\n91: \t\t\t\tif tt.errContains != \"\" {\n92: \t\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n93: \t\t\t\t}\n94: \t\t\t} else {\n95: \t\t\t\tassert.NoError(t, err)\n96: \t\t\t\tassert.NotEmpty(t, result)\n97: \t\t\t}\n98: \t\t})\n99: \t}\n100: }\n101: \n102: func TestParseFileMode(t *testing.T) {\n103: \ttests := []struct {\n104: \t\tname     string\n105: \t\tmodeStr  string\n106: \t\texpected int\n107: \t}{\n108: \t\t{\n109: \t\t\tname:     \"default mode\",\n110: \t\t\tmodeStr:  \"\",\n111: \t\t\texpected: 0644,\n112: \t\t},\n113: \t\t{\n114: \t\t\tname:     \"valid octal mode\",\n115: \t\t\tmodeStr:  \"0644\",\n116: \t\t\texpected: 0644,\n117: \t\t},\n118: \t\t{\n119: \t\t\tname:     \"valid octal mode 0755\",\n120: \t\t\tmodeStr:  \"0755\",\n121: \t\t\texpected: 0755,\n122: \t\t},\n123: \t\t{\n124: \t\t\tname:     \"invalid format\",\n125: \t\t\tmodeStr:  \"invalid\",\n126: \t\t\texpected: 0644,\n127: \t\t},\n128: \t\t{\n129: \t\t\tname:     \"exceeds max\",\n130: \t\t\tmodeStr:  \"10000\",\n131: \t\t\texpected: 0644,\n132: \t\t},\n133: \t}\n134: \n135: \tfor _, tt := range tests {\n136: \t\tt.Run(tt.name, func(t *testing.T) {\n137: \t\t\tresult := parseFileMode(tt.modeStr)\n138: \t\t\tassert.Equal(t, int(result), tt.expected)\n139: \t\t})\n140: \t}\n141: }\n142: \n143: func TestAuthMiddleware(t *testing.T) {\n144: \tserver := setupTestServer(t)\n145: \tdefer cleanupTestServer(t, server)\n146: \n147: \tprivateKey, publicKey := generateTestKeyPair(t)\n148: \tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n149: \n150: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n151: \tdefer os.Unsetenv(PublicKeyEnvVar)\n152: \n153: \tserver, err := NewServer(Config{\n154: \t\tPort:      0,\n155: \t\tWorkspace: t.TempDir(),\n156: \t})\n157: \trequire.NoError(t, err)\n158: \n159: \tvalidToken := createTestToken(t, privateKey)\n160: \n161: \ttests := []struct {\n162: \t\tname           string\n163: \t\tsetupRequest   func(*http.Request)\n164: \t\twantStatusCode int\n165: \t\twantError      string\n166: \t}{\n167: \t\t{\n168: \t\t\tname: \"valid token\",\n169: \t\t\tsetupRequest: func(req *http.Request) {\n170: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer \"+validToken)\n171: \t\t\t},\n172: \t\t\twantStatusCode: http.StatusOK,\n173: \t\t},\n174: \t\t{\n175: \t\t\tname: \"missing authorization header\",\n176: \t\t\tsetupRequest: func(req *http.Request) {\n177: \t\t\t},\n178: \t\t\twantStatusCode: http.StatusUnauthorized,\n179: \t\t\twantError:      ErrMsgMissingAuthHeader,\n180: \t\t},\n181: \t\t{\n182: \t\t\tname: \"invalid authorization format\",\n183: \t\t\tsetupRequest: func(req *http.Request) {\n184: \t\t\t\treq.Header.Set(HeaderAuthorization, \"InvalidFormat token\")\n185: \t\t\t},\n186: \t\t\twantStatusCode: http.StatusUnauthorized,\n187: \t\t\twantError:      \"Use Bearer\",\n188: \t\t},\n189: \t\t{\n190: \t\t\tname: \"invalid token\",\n191: \t\t\tsetupRequest: func(req *http.Request) {\n192: \t\t\t\treq.Header.Set(HeaderAuthorization, \"Bearer invalid.token.here\")\n193: \t\t\t},\n194: \t\t\twantStatusCode: http.StatusUnauthorized,\n195: \t\t},\n196: \t}\n197: \n198: \tfor _, tt := range tests {\n199: \t\tt.Run(tt.name, func(t *testing.T) {\n200: \t\t\trouter := gin.New()\n201: \t\t\trouter.Use(AuthMiddleware(server.authManager))\n202: \t\t\trouter.GET(\"/test\", func(c *gin.Context) {\n203: \t\t\t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n204: \t\t\t})\n205: \n206: \t\t\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n207: \t\t\ttt.setupRequest(req)\n208: \t\t\tw := httptest.NewRecorder()\n209: \n210: \t\t\trouter.ServeHTTP(w, req)\n211: \n212: \t\t\tassert.Equal(t, tt.wantStatusCode, w.Code)\n213: \t\t\tif tt.wantError != \"\" {\n214: \t\t\t\tassert.Contains(t, w.Body.String(), tt.wantError)\n215: \t\t\t}\n216: \t\t})\n217: \t}\n218: }\n219: \n220: func TestHealthCheckHandler(t *testing.T) {\n221: \tserver := setupTestServer(t)\n222: \tdefer cleanupTestServer(t, server)\n223: \n224: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n225: \tw := httptest.NewRecorder()\n226: \n227: \tserver.engine.ServeHTTP(w, req)\n228: \n229: \tassert.Equal(t, http.StatusOK, w.Code)\n230: \tassert.Contains(t, w.Body.String(), `\"status\":\"ok\"`)\n231: \tassert.Contains(t, w.Body.String(), `\"service\":\"PicoD\"`)\n232: \tassert.Contains(t, w.Body.String(), `\"version\":\"0.0.1\"`)\n233: \tassert.Contains(t, w.Body.String(), `\"uptime\"`)\n234: }\n235: \n236: func TestNewServer(t *testing.T) {\n237: \t_, publicKey := generateTestKeyPair(t)\n238: \tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n239: \n240: \ttests := []struct {\n241: \t\tname     string\n242: \t\tconfig   Config\n243: \t\tsetupEnv func()\n244: \t\tcleanup  func()\n245: \t\twantErr  bool\n246: \t\terrMsg   string\n247: \t}{\n248: \t\t{\n249: \t\t\tname: \"success with default workspace\",\n250: \t\t\tconfig: Config{\n251: \t\t\t\tPort: DefaultPort,\n252: \t\t\t},\n253: \t\t\tsetupEnv: func() {\n254: \t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n255: \t\t\t},\n256: \t\t\tcleanup: func() {\n257: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n258: \t\t\t},\n259: \t\t\twantErr: false,\n260: \t\t},\n261: \t\t{\n262: \t\t\tname: \"success with custom workspace\",\n263: \t\t\tconfig: Config{\n264: \t\t\t\tPort:      9090,\n265: \t\t\t\tWorkspace: t.TempDir(),\n266: \t\t\t},\n267: \t\t\tsetupEnv: func() {\n268: \t\t\t\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n269: \t\t\t},\n270: \t\t\tcleanup: func() {\n271: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n272: \t\t\t},\n273: \t\t\twantErr: false,\n274: \t\t},\n275: \t\t{\n276: \t\t\tname: \"error without public key\",\n277: \t\t\tconfig: Config{\n278: \t\t\t\tPort: DefaultPort,\n279: \t\t\t},\n280: \t\t\tsetupEnv: func() {\n281: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n282: \t\t\t},\n283: \t\t\tcleanup: func() {\n284: \t\t\t\tos.Unsetenv(PublicKeyEnvVar)\n285: \t\t\t},\n286: \t\t\twantErr: true,\n287: \t\t\terrMsg:  \"public key not found\",\n288: \t\t},\n289: \t}\n290: \n291: \tfor _, tt := range tests {\n292: \t\tt.Run(tt.name, func(t *testing.T) {\n293: \t\t\ttt.setupEnv()\n294: \t\t\tdefer tt.cleanup()\n295: \n296: \t\t\tserver, err := NewServer(tt.config)\n297: \n298: \t\t\tif tt.wantErr {\n299: \t\t\t\tassert.Error(t, err)\n300: \t\t\t\tassert.Nil(t, server)\n301: \t\t\t\tif tt.errMsg != \"\" {\n302: \t\t\t\t\tassert.Contains(t, err.Error(), tt.errMsg)\n303: \t\t\t\t}\n304: \t\t\t} else {\n305: \t\t\t\tassert.NoError(t, err)\n306: \t\t\t\tassert.NotNil(t, server)\n307: \t\t\t\tassert.Equal(t, tt.config.Port, server.config.Port)\n308: \t\t\t\tassert.NotEmpty(t, server.workspaceDir)\n309: \t\t\t\tassert.NotNil(t, server.authManager)\n310: \t\t\t\tassert.True(t, time.Since(server.startTime) < time.Second)\n311: \t\t\t}\n312: \t\t})\n313: \t}\n314: }\n315: \n316: func TestDefaultConfig(t *testing.T) {\n317: \tconfig := DefaultConfig()\n318: \n319: \tassert.Equal(t, DefaultPort, config.Port)\n320: \tassert.Empty(t, config.Workspace)\n321: }\n322: \n323: func TestPicoDError(t *testing.T) {\n324: \ttests := []struct {\n325: \t\tname    string\n326: \t\terr     *PicoDError\n327: \t\twantMsg string\n328: \t}{\n329: \t\t{\n330: \t\t\tname: \"error without underlying error\",\n331: \t\t\terr: &PicoDError{\n332: \t\t\t\tCode:    \"TestCode\",\n333: \t\t\t\tMessage: \"Test message\",\n334: \t\t\t\tDetail:  \"Test detail\",\n335: \t\t\t},\n336: \t\t\twantMsg: \"TestCode: Test message\",\n337: \t\t},\n338: \t\t{\n339: \t\t\tname: \"error with underlying error\",\n340: \t\t\terr: &PicoDError{\n341: \t\t\t\tCode:    \"TestCode\",\n342: \t\t\t\tMessage: \"Test message\",\n343: \t\t\t\tDetail:  \"Test detail\",\n344: \t\t\t\tErr:     assert.AnError,\n345: \t\t\t},\n346: \t\t\twantMsg: \"TestCode: Test message (caused by: \",\n347: \t\t},\n348: \t}\n349: \n350: \tfor _, tt := range tests {\n351: \t\tt.Run(tt.name, func(t *testing.T) {\n352: \t\t\terrMsg := tt.err.Error()\n353: \t\t\tassert.Contains(t, errMsg, tt.wantMsg)\n354: \n355: \t\t\tif tt.err.Err != nil {\n356: \t\t\t\tassert.Equal(t, tt.err.Err, tt.err.Unwrap())\n357: \t\t\t}\n358: \t\t})\n359: \t}\n360: }\n361: \n362: func TestNewError(t *testing.T) {\n363: \terr := NewError(\"TestCode\", \"Test message\", \"Test detail\", nil)\n364: \n365: \tassert.Equal(t, \"TestCode\", err.Code)\n366: \tassert.Equal(t, \"Test message\", err.Message)\n367: \tassert.Equal(t, \"Test detail\", err.Detail)\n368: \tassert.Nil(t, err.Err)\n369: }\n370: \n371: func TestStatusCodeMap(t *testing.T) {\n372: \ttests := []struct {\n373: \t\tname           string\n374: \t\tcode           string\n375: \t\texpectedStatus int\n376: \t}{\n377: \t\t{\n378: \t\t\tname:           \"bad request\",\n379: \t\t\tcode:           ErrInvalidCommand,\n380: \t\t\texpectedStatus: http.StatusBadRequest,\n381: \t\t},\n382: \t\t{\n383: \t\t\tname:           \"unauthorized\",\n384: \t\t\tcode:           ErrMissingAuthHeader,\n385: \t\t\texpectedStatus: http.StatusUnauthorized,\n386: \t\t},\n387: \t\t{\n388: \t\t\tname:           \"not found\",\n389: \t\t\tcode:           ErrFileNotFound,\n390: \t\t\texpectedStatus: http.StatusNotFound,\n391: \t\t},\n392: \t\t{\n393: \t\t\tname:           \"internal error\",\n394: \t\t\tcode:           ErrServerInternal,\n395: \t\t\texpectedStatus: http.StatusInternalServerError,\n396: \t\t},\n397: \t}\n398: \n399: \tfor _, tt := range tests {\n400: \t\tt.Run(tt.name, func(t *testing.T) {\n401: \t\t\tstatus, exists := statusCodeMap[tt.code]\n402: \t\t\tassert.True(t, exists)\n403: \t\t\tassert.Equal(t, tt.expectedStatus, status)\n404: \t\t})\n405: \t}\n406: }\n407: \n408: func TestHandleError(t *testing.T) {\n409: \tgin.SetMode(gin.TestMode)\n410: \n411: \ttests := []struct {\n412: \t\tname           string\n413: \t\terr            error\n414: \t\texpectedStatus int\n415: \t\tcontains       string\n416: \t}{\n417: \t\t{\n418: \t\t\tname:           \"picoD error\",\n419: \t\t\terr:            NewError(ErrInvalidCommand, \"Test message\", \"\", nil),\n420: \t\t\texpectedStatus: http.StatusBadRequest,\n421: \t\t\tcontains:       \"Test message\",\n422: \t\t},\n423: \t\t{\n424: \t\t\tname:           \"generic error\",\n425: \t\t\terr:            assert.AnError,\n426: \t\t\texpectedStatus: http.StatusInternalServerError,\n427: \t\t\tcontains:       \"Error\",\n428: \t\t},\n429: \t}\n430: \n431: \tfor _, tt := range tests {\n432: \t\tt.Run(tt.name, func(t *testing.T) {\n433: \t\t\tw := httptest.NewRecorder()\n434: \t\t\tc, _ := gin.CreateTestContext(w)\n435: \n436: \t\t\tHandleError(c, tt.err)\n437: \n438: \t\t\tassert.Equal(t, tt.expectedStatus, w.Code)\n439: \t\t\tassert.Contains(t, w.Body.String(), tt.contains)\n440: \t\t})\n441: \t}\n442: }\n\n(End of file - total 442 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc setupTestServer(t *testing.T) *Server {\n\tworkspace := t.TempDir()\n\n\t_, publicKey := generateTestKeyPair(t)\n\tpublicKeyPEM := publicKeyToPEM(t, publicKey)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server_test.go","time":{"start":1775858921000,"end":1775858921022}}}}
