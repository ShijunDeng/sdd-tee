{"type":"tool_use","timestamp":1775871279162,"sessionID":"ses_285d35baeffenWjdb48dAJwLcJ","part":{"id":"prt_d7a2d4014001IlzdGWO1w1UOuJ","messageID":"msg_d7a2d3530001qRYTBm1GTZMpar","sessionID":"ses_285d35baeffenWjdb48dAJwLcJ","type":"tool","tool":"read","callID":"toolu_tool-616f5dd72827421c91a1bd71fe641b4f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_docker_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_docker_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for the Docker service.\"\"\"\n2: \n3: import pytest\n4: import time\n5: from unittest.mock import MagicMock, patch, PropertyMock\n6: from docker.errors import DockerException\n7: \n8: from agentcube.services.docker_service import DockerService\n9: \n10: \n11: class TestDockerService:\n12:     \"\"\"Test cases for DockerService.\"\"\"\n13: \n14:     @pytest.fixture\n15:     def mock_docker_client(self):\n16:         \"\"\"Create a mock Docker client.\"\"\"\n17:         client = MagicMock()\n18:         client.ping.return_value = True\n19:         return client\n20: \n21:     @pytest.fixture\n22:     def mock_docker_image(self):\n23:         \"\"\"Create a mock Docker image.\"\"\"\n24:         image = MagicMock()\n25:         image.attrs = {\n26:             \"Id\": \"sha256:abc123def4567890123456789012345678901234567890123456789012345678\",\n27:             \"Size\": 536870912,\n28:         }\n29:         return image\n30: \n31:     @pytest.fixture\n32:     def docker_service(self):\n33:         \"\"\"Create a DockerService instance.\"\"\"\n34:         return DockerService(verbose=False)\n35: \n36:     def test_check_docker_available_success(self, docker_service):\n37:         \"\"\"Test Docker availability check when available.\"\"\"\n38:         mock_client = MagicMock()\n39:         mock_client.ping.return_value = True\n40:         docker_service._client = mock_client\n41: \n42:         result = docker_service.check_docker_available()\n43: \n44:         assert result is True\n45:         mock_client.ping.assert_called_once()\n46: \n47:     def test_check_docker_available_failure(self, docker_service):\n48:         \"\"\"Test Docker availability check when unavailable.\"\"\"\n49:         mock_client = MagicMock()\n50:         mock_client.ping.side_effect = DockerException(\"Docker daemon not running\")\n51:         docker_service._client = mock_client\n52: \n53:         result = docker_service.check_docker_available()\n54: \n55:         assert result is False\n56: \n57:     def test_build_image_success(self, docker_service, mock_docker_image, tmp_path):\n58:         \"\"\"Test successful image build.\"\"\"\n59:         dockerfile_path = tmp_path / \"Dockerfile\"\n60:         dockerfile_path.write_text(\"FROM python:3.10\")\n61: \n62:         mock_client = MagicMock()\n63:         mock_images = MagicMock()\n64:         mock_images.build.return_value = (mock_docker_image, [])\n65:         mock_client.images = mock_images\n66: \n67:         docker_service._client = mock_client\n68: \n69:         with patch.object(docker_service, \"get_image_info\", return_value={\n70:             \"image_name\": \"test:1.0.0\",\n71:             \"image_id\": \"abc123def456\",\n72:             \"image_size\": \"512.34 MB\",\n73:             \"size_bytes\": 536870912,\n74:         }):\n75:             result = docker_service.build_image(\n76:                 dockerfile_path=dockerfile_path,\n77:                 context_path=tmp_path,\n78:                 image_name=\"test\",\n79:                 tag=\"1.0.0\"\n80:             )\n81: \n82:             assert result[\"image_name\"] == \"test:1.0.0\"\n83:             assert result[\"image_id\"] == \"abc123def456\"\n84:             assert result[\"image_size\"] == \"512.34 MB\"\n85:             mock_images.build.assert_called_once()\n86: \n87:     def test_build_image_with_custom_tag(self, docker_service, mock_docker_image, tmp_path):\n88:         \"\"\"Test building image with custom tag.\"\"\"\n89:         dockerfile_path = tmp_path / \"Dockerfile\"\n90:         dockerfile_path.write_text(\"FROM python:3.10\")\n91: \n92:         mock_client = MagicMock()\n93:         mock_images = MagicMock()\n94:         mock_images.build.return_value = (mock_docker_image, [])\n95:         mock_client.images = mock_images\n96: \n97:         docker_service._client = mock_client\n98: \n99:         with patch.object(docker_service, \"get_image_info\", return_value={\n100:             \"image_name\": \"test:v1.0.0\",\n101:             \"image_id\": \"abc123def456\",\n102:             \"image_size\": \"512.34 MB\",\n103:             \"size_bytes\": 536870912,\n104:         }):\n105:             result = docker_service.build_image(\n106:                 dockerfile_path=dockerfile_path,\n107:                 context_path=tmp_path,\n108:                 image_name=\"test\",\n109:                 tag=\"v1.0.0\"\n110:             )\n111: \n112:             assert result[\"image_name\"] == \"test:v1.0.0\"\n113:             call_args = mock_images.build.call_args\n114:             assert call_args.kwargs[\"tag\"] == \"test:v1.0.0\"\n115: \n116:     def test_build_image_with_build_args(self, docker_service, mock_docker_image, tmp_path):\n117:         \"\"\"Test building image with build arguments.\"\"\"\n118:         dockerfile_path = tmp_path / \"Dockerfile\"\n119:         dockerfile_path.write_text(\"FROM python:3.10\")\n120: \n121:         mock_client = MagicMock()\n122:         mock_images = MagicMock()\n123:         mock_images.build.return_value = (mock_docker_image, [])\n124:         mock_client.images = mock_images\n125: \n126:         docker_service._client = mock_client\n127: \n128:         with patch.object(docker_service, \"get_image_info\", return_value={\n129:             \"image_name\": \"test:1.0.0\",\n130:             \"image_id\": \"abc123def456\",\n131:             \"image_size\": \"512.34 MB\",\n132:             \"size_bytes\": 536870912,\n133:         }):\n134:             build_args = {\n135:                 \"HTTP_PROXY\": \"http://proxy.example.com:8080\",\n136:                 \"HTTPS_PROXY\": \"http://proxy.example.com:8080\"\n137:             }\n138: \n139:             result = docker_service.build_image(\n140:                 dockerfile_path=dockerfile_path,\n141:                 context_path=tmp_path,\n142:                 image_name=\"test\",\n143:                 tag=\"1.0.0\",\n144:                 build_args=build_args\n145:             )\n146: \n147:             assert result[\"image_name\"] == \"test:1.0.0\"\n148:             call_args = mock_images.build.call_args\n149:             assert call_args.kwargs[\"buildargs\"] == build_args\n150: \n151:     def test_build_image_docker_unavailable(self, docker_service, tmp_path):\n152:         \"\"\"Test building image when Docker is unavailable.\"\"\"\n153:         dockerfile_path = tmp_path / \"Dockerfile\"\n154:         dockerfile_path.write_text(\"FROM python:3.10\")\n155: \n156:         with patch.object(docker_service, \"check_docker_available\", return_value=False):\n157:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n158:                 docker_service.build_image(\n159:                     dockerfile_path=dockerfile_path,\n160:                     context_path=tmp_path,\n161:                     image_name=\"test\"\n162:                 )\n163: \n164:     def test_build_image_docker_exception(self, docker_service, tmp_path):\n165:         \"\"\"Test building image when Docker build fails.\"\"\"\n166:         dockerfile_path = tmp_path / \"Dockerfile\"\n167:         dockerfile_path.write_text(\"FROM python:3.10\")\n168: \n169:         mock_client = MagicMock()\n170:         mock_images = MagicMock()\n171:         mock_images.build.side_effect = DockerException(\"Build failed\")\n172:         mock_client.images = mock_images\n173: \n174:         docker_service._client = mock_client\n175: \n176:         with pytest.raises(RuntimeError, match=\"Failed to build Docker image\"):\n177:             docker_service.build_image(\n178:                 dockerfile_path=dockerfile_path,\n179:                 context_path=tmp_path,\n180:                 image_name=\"test\"\n181:             )\n182: \n183:     def test_get_image_info_success(self, docker_service, mock_docker_image):\n184:         \"\"\"Test getting image info successfully.\"\"\"\n185:         mock_client = MagicMock()\n186:         mock_images = MagicMock()\n187:         mock_images.get.return_value = mock_docker_image\n188:         mock_client.images = mock_images\n189: \n190:         docker_service._client = mock_client\n191: \n192:         result = docker_service.get_image_info(\"test:1.0.0\")\n193: \n194:         assert result[\"image_name\"] == \"test:1.0.0\"\n195:         assert result[\"image_id\"] == \"abc123def456\"\n196:         assert result[\"size_bytes\"] == 536870912\n197:         assert result[\"image_size\"] == \"512.00 MB\"\n198: \n199:     def test_get_image_info_not_found(self, docker_service):\n200:         \"\"\"Test getting image info when image not found.\"\"\"\n201:         mock_client = MagicMock()\n202:         mock_images = MagicMock()\n203:         mock_images.get.side_effect = DockerException(\"Image not found\")\n204:         mock_client.images = mock_images\n205: \n206:         docker_service._client = mock_client\n207: \n208:         result = docker_service.get_image_info(\"test:1.0.0\")\n209: \n210:         assert result == {}\n211: \n212:     def test_format_size_bytes(self, docker_service):\n213:         \"\"\"Test formatting size in bytes.\"\"\"\n214:         result = docker_service._format_size(512)\n215:         assert result == \"512.00 B\"\n216: \n217:     def test_format_size_kb(self, docker_service):\n218:         \"\"\"Test formatting size in kilobytes.\"\"\"\n219:         result = docker_service._format_size(2048)\n220:         assert result == \"2.00 KB\"\n221: \n222:     def test_format_size_mb(self, docker_service):\n223:         \"\"\"Test formatting size in megabytes.\"\"\"\n224:         result = docker_service._format_size(1048576)\n225:         assert result == \"1.00 MB\"\n226: \n227:     def test_format_size_gb(self, docker_service):\n228:         \"\"\"Test formatting size in gigabytes.\"\"\"\n229:         result = docker_service._format_size(1073741824)\n230:         assert result == \"1.00 GB\"\n231: \n232:     def test_format_size_tb(self, docker_service):\n233:         \"\"\"Test formatting size in terabytes.\"\"\"\n234:         result = docker_service._format_size(1099511627776)\n235:         assert result == \"1.00 TB\"\n236: \n237:     def test_format_size_zero(self, docker_service):\n238:         \"\"\"Test formatting zero size.\"\"\"\n239:         result = docker_service._format_size(0)\n240:         assert result == \"0.00 B\"\n241: \n242:     def test_push_image_to_default_registry(self, docker_service):\n243:         \"\"\"Test pushing image to default registry.\"\"\"\n244:         mock_client = MagicMock()\n245:         mock_images = MagicMock()\n246: \n247:         push_logs = [\n248:             {\"status\": \"Pushing\"},\n249:             {\"status\": \"Pushed\"},\n250:         ]\n251:         mock_images.push.return_value = push_logs\n252:         mock_client.images = mock_images\n253: \n254:         docker_service._client = mock_client\n255: \n256:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n257:             result = docker_service.push_image(\"test:1.0.0\")\n258: \n259:             assert result[\"pushed_image\"] == \"test:1.0.0\"\n260:             assert \"push_time\" in result\n261:             mock_images.push.assert_called_once_with(\"test:1.0.0\", stream=True, decode=True)\n262: \n263:     def test_push_image_to_custom_registry(self, docker_service):\n264:         \"\"\"Test pushing image to custom registry.\"\"\"\n265:         mock_client = MagicMock()\n266:         mock_images = MagicMock()\n267: \n268:         push_logs = [\n269:             {\"status\": \"Pushing\"},\n270:             {\"status\": \"Pushed\"},\n271:         ]\n272:         mock_images.push.return_value = push_logs\n273:         mock_client.images = mock_images\n274: \n275:         mock_image = MagicMock()\n276:         mock_images.get.return_value = mock_image\n277: \n278:         docker_service._client = mock_client\n279: \n280:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n281:             with patch.object(docker_service, \"_tag_image_sdk\") as mock_tag:\n282:                 result = docker_service.push_image(\n283:                     \"test:1.0.0\",\n284:                     registry_url=\"registry.example.com\"\n285:                 )\n286: \n287:                 assert result[\"pushed_image\"] == \"registry.example.com/test:1.0.0\"\n288:                 mock_tag.assert_called_once_with(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n289:                 mock_images.push.assert_called_once_with(\n290:                     \"registry.example.com/test:1.0.0\",\n291:                     stream=True,\n292:                     decode=True\n293:                 )\n294: \n295:     def test_push_image_with_authentication(self, docker_service):\n296:         \"\"\"Test pushing image with authentication.\"\"\"\n297:         mock_client = MagicMock()\n298:         mock_images = MagicMock()\n299: \n300:         push_logs = [\n301:             {\"status\": \"Pushing\"},\n302:             {\"status\": \"Pushed\"},\n303:         ]\n304:         mock_images.push.return_value = push_logs\n305:         mock_client.images = mock_images\n306: \n307:         docker_service._client = mock_client\n308: \n309:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n310:             with patch.object(docker_service, \"_docker_login_sdk\") as mock_login:\n311:                 result = docker_service.push_image(\n312:                     \"test:1.0.0\",\n313:                     registry_url=\"registry.example.com\",\n314:                     username=\"user\",\n315:                     password=\"pass\"\n316:                 )\n317: \n318:                 assert \"pushed_image\" in result\n319:                 mock_login.assert_called_once_with(\"registry.example.com\", \"user\", \"pass\")\n320: \n321:     def test_push_image_failure(self, docker_service):\n322:         \"\"\"Test pushing image when push fails.\"\"\"\n323:         mock_client = MagicMock()\n324:         mock_images = MagicMock()\n325: \n326:         push_logs = [\n327:             {\"error\": \"Authentication failed\"},\n328:         ]\n329:         mock_images.push.return_value = push_logs\n330:         mock_client.images = mock_images\n331: \n332:         docker_service._client = mock_client\n333: \n334:         with patch.object(docker_service, \"check_docker_available\", return_value=True):\n335:             with pytest.raises(RuntimeError, match=\"Failed to push image\"):\n336:                 docker_service.push_image(\"test:1.0.0\")\n337: \n338:     def test_push_image_docker_unavailable(self, docker_service):\n339:         \"\"\"Test pushing image when Docker is unavailable.\"\"\"\n340:         with patch.object(docker_service, \"check_docker_available\", return_value=False):\n341:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n342:                 docker_service.push_image(\"test:1.0.0\")\n343: \n344:     def test_docker_login_success(self, docker_service):\n345:         \"\"\"Test successful Docker registry login.\"\"\"\n346:         mock_client = MagicMock()\n347:         mock_client.login.return_value = {}\n348:         docker_service._client = mock_client\n349: \n350:         docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n351: \n352:         mock_client.login.assert_called_once_with(\n353:             username=\"user\",\n354:             password=\"pass\",\n355:             registry=\"registry.example.com\"\n356:         )\n357: \n358:     def test_docker_login_default_registry(self, docker_service):\n359:         \"\"\"Test Docker login to default registry.\"\"\"\n360:         mock_client = MagicMock()\n361:         mock_client.login.return_value = {}\n362:         docker_service._client = mock_client\n363: \n364:         docker_service._docker_login_sdk(None, \"user\", \"pass\")\n365: \n366:         mock_client.login.assert_called_once_with(\n367:             username=\"user\",\n368:             password=\"pass\",\n369:             registry=None\n370:         )\n371: \n372:     def test_docker_login_failure(self, docker_service):\n373:         \"\"\"Test Docker login failure.\"\"\"\n374:         mock_client = MagicMock()\n375:         mock_client.login.side_effect = DockerException(\"Authentication failed\")\n376:         docker_service._client = mock_client\n377: \n378:         with pytest.raises(RuntimeError, match=\"Failed to log in to Docker registry\"):\n379:             docker_service._docker_login_sdk(\"registry.example.com\", \"user\", \"pass\")\n380: \n381:     def test_tag_image_success(self, docker_service):\n382:         \"\"\"Test successful image tagging.\"\"\"\n383:         mock_client = MagicMock()\n384:         mock_images = MagicMock()\n385:         mock_image = MagicMock()\n386:         mock_images.get.return_value = mock_image\n387:         mock_client.images = mock_images\n388: \n389:         docker_service._client = mock_client\n390: \n391:         docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n392: \n393:         mock_images.get.assert_called_once_with(\"test:1.0.0\")\n394:         mock_image.tag.assert_called_once_with(\"registry.example.com/test:1.0.0\", force=True)\n395: \n396:     def test_tag_image_failure(self, docker_service):\n397:         \"\"\"Test image tagging failure.\"\"\"\n398:         mock_client = MagicMock()\n399:         mock_images = MagicMock()\n400:         mock_images.get.side_effect = DockerException(\"Image not found\")\n401:         mock_client.images = mock_images\n402: \n403:         docker_service._client = mock_client\n404: \n405:         with pytest.raises(RuntimeError, match=\"Failed to tag Docker image\"):\n406:             docker_service._tag_image_sdk(\"test:1.0.0\", \"registry.example.com/test:1.0.0\")\n407: \n408:     def test_remove_image_success(self, docker_service):\n409:         \"\"\"Test successful image removal.\"\"\"\n410:         mock_client = MagicMock()\n411:         mock_images = MagicMock()\n412:         mock_images.remove.return_value = None\n413:         mock_client.images = mock_images\n414: \n415:         docker_service._client = mock_client\n416: \n417:         result = docker_service.remove_image(\"test:1.0.0\")\n418: \n419:         assert result is True\n420:         mock_images.remove.assert_called_once_with(\"test:1.0.0\", force=True)\n421: \n422:     def test_remove_image_failure(self, docker_service):\n423:         \"\"\"Test image removal failure.\"\"\"\n424:         mock_client = MagicMock()\n425:         mock_images = MagicMock()\n426:         mock_images.remove.side_effect = DockerException(\"No such image\")\n427:         mock_client.images = mock_images\n428: \n429:         docker_service._client = mock_client\n430: \n431:         result = docker_service.remove_image(\"test:1.0.0\")\n432: \n433:         assert result is False\n434: \n435:     def test_client_property_lazy_initialization(self, docker_service):\n436:         \"\"\"Test that Docker client is lazily initialized.\"\"\"\n437:         assert docker_service._client is None\n438: \n439:         with patch(\"agentcube.services.docker_service.docker\") as mock_docker_module:\n440:             mock_docker_module.from_env.return_value = MagicMock()\n441: \n442:             client = docker_service.client\n443: \n444:             assert docker_service._client is not None\n445:             assert client is docker_service.client\n446: \n447:     def test_verbose_mode_sets_logging(self):\n448:         \"\"\"Test verbose mode sets logging level.\"\"\"\n449:         import logging\n450: \n451:         service = DockerService(verbose=True)\n452:         assert service.verbose is True\n453: \n454:     def test_non_verbose_mode(self):\n455:         \"\"\"Test non-verbose mode.\"\"\"\n456:         service = DockerService(verbose=False)\n457:         assert service.verbose is False\n458: \n459:     def test_get_image_info_truncates_id(self, docker_service, mock_docker_image):\n460:         \"\"\"Test that image ID is truncated to 12 characters.\"\"\"\n461:         mock_client = MagicMock()\n462:         mock_images = MagicMock()\n463:         mock_images.get.return_value = mock_docker_image\n464:         mock_client.images = mock_images\n465: \n466:         docker_service._client = mock_client\n467: \n468:         result = docker_service.get_image_info(\"test:1.0.0\")\n469: \n470:         assert len(result[\"image_id\"]) == 12\n471:         assert result[\"image_id\"] == \"abc123def456\"\n472: \n473:     def test_build_image_adds_build_time(self, docker_service, mock_docker_image, tmp_path):\n474:         \"\"\"Test that build_image adds build_time to result.\"\"\"\n475:         dockerfile_path = tmp_path / \"Dockerfile\"\n476:         dockerfile_path.write_text(\"FROM python:3.10\")\n477: \n478:         mock_client = MagicMock()\n479:         mock_images = MagicMock()\n480:         mock_images.build.return_value = (mock_docker_image, [])\n481:         mock_client.images = mock_images\n482: \n483:         docker_service._client = mock_client\n484: \n485:         with patch.object(docker_service, \"get_image_info\", return_value={\n486:             \"image_name\": \"test:1.0.0\",\n487:             \"image_id\": \"abc123def456\",\n488:             \"image_size\": \"512.34 MB\",\n489:             \"size_bytes\": 536870912,\n490:         }):\n491:             with patch(\"time.time\", return_value=1234567890.0):\n492:                 result = docker_service.build_image(\n493:                     dockerfile_path=dockerfile_path,\n494:                     context_path=tmp_path,\n495:                     image_name=\"test\",\n496:                     tag=\"1.0.0\"\n497:                 )\n498: \n499:                 assert result[\"build_time\"] == 1234567890.0\n500: \n501:     @pytest.mark.integration\n502:     def test_e2e_build_real_image(self):\n503:         \"\"\"Test end-to-end building a real Docker image (integration test).\"\"\"\n504:         pytest.skip(\"Integration test - requires Docker daemon\")\n505: \n506:     @pytest.mark.integration\n507:     def test_e2e_push_real_image(self):\n508:         \"\"\"Test end-to-end pushing a real Docker image (integration test).\"\"\"\n509:         pytest.skip(\"Integration test - requires Docker daemon and registry\")\n\n(End of file - total 509 lines)\n</content>","metadata":{"preview":"\"\"\"Tests for the Docker service.\"\"\"\n\nimport pytest\nimport time\nfrom unittest.mock import MagicMock, patch, PropertyMock\nfrom docker.errors import DockerException\n\nfrom agentcube.services.docker_service import DockerService\n\n\nclass TestDockerService:\n    \"\"\"Test cases for DockerService.\"\"\"\n\n    @pytest.fixture\n    def mock_docker_client(self):\n        \"\"\"Create a mock Docker client.\"\"\"\n        client = MagicMock()\n        client.ping.return_value = True\n        return client\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_docker_service.py","time":{"start":1775871279149,"end":1775871279158}}}}
