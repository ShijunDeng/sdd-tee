{"type":"tool_use","timestamp":1775871322451,"sessionID":"ses_285d35baeffenWjdb48dAJwLcJ","part":{"id":"prt_d7a2de704001zqswMF2jy85fRP","messageID":"msg_d7a2d406f001SlybpvQnHFZzhI","sessionID":"ses_285d35baeffenWjdb48dAJwLcJ","type":"tool","tool":"write","callID":"toolu_tool-07fe26b886dc4f49b52e15d241f576e2","state":{"status":"completed","input":{"content":"\"\"\"Service for Docker operations.\"\"\"\n\nimport logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nimport docker\nfrom docker.errors import DockerException\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass DockerService:\n    \"\"\"Service for Docker operations.\n\n    This service provides a Pythonic abstraction layer over Docker SDK\n    operations required by the CLI's pack, build, and publish workflows.\n\n    Attributes:\n        verbose: Enable verbose logging for debugging.\n        _client: Optional Docker client instance (lazy initialization).\n    \"\"\"\n\n    def __init__(self, verbose: bool = False) -> None:\n        \"\"\"Initialize the Docker service.\n\n        Args:\n            verbose: Enable verbose logging for debugging.\n\n        Raises:\n            RuntimeError: If Docker client initialization fails.\n        \"\"\"\n        self.verbose = verbose\n        if verbose:\n            logging.basicConfig(level=logging.DEBUG)\n        self._client: Optional[docker.DockerClient] = None\n\n    @property\n    def client(self) -> docker.DockerClient:\n        \"\"\"Get or create Docker client using lazy initialization.\n\n        Returns:\n            The Docker client instance.\n\n        Raises:\n            DockerException: If Docker daemon is not available.\n        \"\"\"\n        if self._client is None:\n            self._client = docker.from_env()\n        return self._client\n\n    def check_docker_available(self) -> bool:\n        \"\"\"Check if Docker daemon is available and running.\n\n        Returns:\n            True if Docker is available, False otherwise.\n\n        Note:\n            This method does not raise exceptions on failure, making it\n            suitable for availability checks before operations.\n        \"\"\"\n        try:\n            self.client.ping()\n            return True\n        except DockerException as e:\n            logger.warning(f\"Docker not available: {e}\")\n            return False\n\n    def build_image(\n        self,\n        dockerfile_path: Path,\n        context_path: Path,\n        image_name: str,\n        tag: str = \"latest\",\n        build_args: Optional[Dict[str, str]] = None,\n    ) -> Dict[str, Any]:\n        \"\"\"Build a Docker image from a Dockerfile.\n\n        Args:\n            dockerfile_path: Path to the Dockerfile.\n            context_path: Path to the build context directory.\n            image_name: Name for the resulting image.\n            tag: Tag for the image (default: \"latest\").\n            build_args: Optional build arguments for proxy configuration.\n\n        Returns:\n            Dict containing:\n                - image_name: Full image name with tag.\n                - image_id: SHA256 hash of the image.\n                - image_size: Human-readable size string.\n                - size_bytes: Size in bytes.\n                - build_time: Timestamp of the build.\n\n        Raises:\n            FileNotFoundError: If dockerfile_path or context_path does not exist.\n            ValueError: If image_name is invalid.\n            RuntimeError: If Docker is not available or build fails.\n        \"\"\"\n        if not self.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n        self._validate_build_paths(dockerfile_path, context_path)\n\n        if not image_name or not isinstance(image_name, str):\n            raise ValueError(f\"Invalid image_name: {image_name}\")\n\n        logger.info(f\"Building image {image_name}:{tag} from {dockerfile_path}\")\n        full_image_name = f\"{image_name}:{tag}\"\n\n        try:\n            image, build_logs = self.client.images.build(\n                path=str(context_path),\n                dockerfile=str(dockerfile_path),\n                tag=full_image_name,\n                buildargs=build_args,\n                rm=True,\n                forcerm=True,\n            )\n\n            image_info = self.get_image_info(full_image_name)\n            image_info[\"build_time\"] = time.time()\n\n            return image_info\n\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to build Docker image: {e}\") from e\n\n    def _validate_build_paths(self, dockerfile_path: Path, context_path: Path) -> None:\n        \"\"\"Validate file paths before Docker operations.\n\n        Security Measures:\n            1. Resolves absolute paths to prevent directory traversal.\n            2. Validates paths exist before operations.\n            3. Validates context_path is a directory.\n            4. Validates dockerfile_path is a file.\n\n        Args:\n            dockerfile_path: Path to the Dockerfile.\n            context_path: Path to the build context directory.\n\n        Raises:\n            FileNotFoundError: If paths do not exist.\n            ValueError: If paths have invalid types.\n        \"\"\"\n        dockerfile_path = dockerfile_path.resolve()\n        context_path = context_path.resolve()\n\n        if not dockerfile_path.exists():\n            raise FileNotFoundError(f\"Dockerfile not found: {dockerfile_path}\")\n        if not dockerfile_path.is_file():\n            raise ValueError(f\"Dockerfile path is not a file: {dockerfile_path}\")\n\n        if not context_path.exists():\n            raise FileNotFoundError(f\"Build context not found: {context_path}\")\n        if not context_path.is_dir():\n            raise ValueError(f\"Build context path is not a directory: {context_path}\")\n\n    def get_image_info(self, image_name: str) -> Dict[str, Any]:\n        \"\"\"Get detailed information about a Docker image.\n\n        Args:\n            image_name: Name of the image (with or without tag).\n\n        Returns:\n            Dict containing:\n                - image_name: The image name.\n                - image_id: SHA256 hash (first 12 characters).\n                - image_size: Human-readable size string.\n                - size_bytes: Size in bytes.\n\n        Note:\n            Returns empty dict if image is not found.\n        \"\"\"\n        try:\n            image = self.client.images.get(image_name)\n            attrs = image.attrs\n\n            image_id = attrs[\"Id\"].split(\":\")[-1][:12]\n            size_bytes = attrs.get(\"Size\", 0)\n\n            return {\n                \"image_name\": image_name,\n                \"image_id\": image_id,\n                \"image_size\": self._format_size(size_bytes),\n                \"size_bytes\": size_bytes,\n            }\n\n        except DockerException as e:\n            logger.warning(f\"Failed to get image info for {image_name}: {e}\")\n            return {}\n\n    def _format_size(self, size_bytes: int) -> str:\n        \"\"\"Format byte size into human-readable format.\n\n        Args:\n            size_bytes: Size in bytes.\n\n        Returns:\n            Human-readable size string (e.g., \"2.00 GB\").\n\n        Example:\n            >>> service._format_size(2147483648)\n            \"2.00 GB\"\n        \"\"\"\n        size = float(size_bytes)\n        for unit in [\"B\", \"KB\", \"MB\", \"GB\"]:\n            if size < 1024:\n                return f\"{size:.2f} {unit}\"\n            size /= 1024\n        return f\"{size:.2f} TB\"\n\n    def push_image(\n        self,\n        image_name: str,\n        registry_url: Optional[str] = None,\n        username: Optional[str] = None,\n        password: Optional[str] = None,\n    ) -> Dict[str, Any]:\n        \"\"\"Push a Docker image to a container registry.\n\n        Args:\n            image_name: Local image name to push.\n            registry_url: Optional registry URL (e.g., \"registry.example.com/username\").\n            username: Optional username for private registry authentication.\n            password: Optional password for private registry authentication.\n\n        Returns:\n            Dict containing:\n                - pushed_image: Full name of the pushed image.\n                - push_time: Timestamp of the push operation.\n\n        Raises:\n            RuntimeError: If Docker is not available, authentication fails,\n                         or push operation fails.\n            ValueError: If image does not exist locally.\n\n        Security Note:\n            Passwords are never logged or stored in instance variables.\n        \"\"\"\n        if not self.check_docker_available():\n            raise RuntimeError(\"Docker is not available or not running\")\n\n        target_image = image_name\n        if registry_url:\n            target_image = f\"{registry_url}/{image_name}\"\n            self._tag_image_sdk(image_name, target_image)\n\n        if username and password:\n            self._docker_login_sdk(registry_url, username, password)\n\n        logger.info(f\"Pushing image {target_image}\")\n\n        try:\n            push_logs = self.client.images.push(target_image, stream=True, decode=True)\n\n            for line in push_logs:\n                if \"error\" in line:\n                    raise RuntimeError(f\"Failed to push image: {line['error']}\")\n                if self.verbose:\n                    logger.debug(f\"Push log: {line}\")\n\n            return {\n                \"pushed_image\": target_image,\n                \"push_time\": str(time.time()),\n            }\n\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to push Docker image: {e}\") from e\n\n    def _docker_login_sdk(self, registry: Optional[str], username: str, password: str) -> None:\n        \"\"\"Log in to a Docker registry.\n\n        Args:\n            registry: Registry URL or None for Docker Hub.\n            username: Username for authentication.\n            password: Password for authentication.\n\n        Raises:\n            RuntimeError: If authentication fails.\n\n        Security Note:\n            Password is never logged. Authentication is handled\n            securely through Docker SDK.\n        \"\"\"\n        try:\n            self.client.login(username=username, password=password, registry=registry)\n            logger.info(f\"Successfully logged in to registry: {registry or 'default'}\")\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to log in to Docker registry: {e}\") from e\n\n    def _tag_image_sdk(self, source_image: str, target_image: str) -> None:\n        \"\"\"Tag a Docker image with a new name.\n\n        Args:\n            source_image: Existing image name.\n            target_image: New image name/tag.\n\n        Raises:\n            RuntimeError: If tagging fails.\n        \"\"\"\n        try:\n            image = self.client.images.get(source_image)\n            image.tag(target_image, force=True)\n            logger.info(f\"Tagged {source_image} as {target_image}\")\n        except DockerException as e:\n            raise RuntimeError(f\"Failed to tag Docker image: {e}\") from e\n\n    def remove_image(self, image_name: str, force: bool = True) -> bool:\n        \"\"\"Remove a Docker image from the local daemon.\n\n        Args:\n            image_name: Name of the image to remove.\n            force: Force removal even if image is in use (default: True).\n\n        Returns:\n            True if removal succeeded, False otherwise.\n\n        Note:\n            This method does not raise exceptions for non-existent images,\n            making it safe for cleanup operations.\n        \"\"\"\n        try:\n            self.client.images.remove(image_name, force=force)\n            logger.info(f\"Removed image {image_name}\")\n            return True\n        except DockerException as e:\n            logger.warning(f\"Failed to remove image {image_name}: {e}\")\n            return False","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/docker_service.py"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/docker_service.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/__init__.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_docker_service.py":[]},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/docker_service.py","exists":true,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/docker_service.py","time":{"start":1775871321878,"end":1775871322448}}}}
