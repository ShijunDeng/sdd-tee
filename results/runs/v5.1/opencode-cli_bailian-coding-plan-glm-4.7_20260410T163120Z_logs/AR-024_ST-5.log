v = [\n43:     \"pytest>=7.4.0\",\n44:     \"pytest-asyncio>=0.21.0\",\n45:     \"pytest-cov>=4.1.0\",\n46:     \"ruff>=0.1.0\",\n47:     \"mypy>=1.5.0\",\n48:     \"pre-commit>=3.3.0\",\n49:     \"kubernetes>=28.0.0\",\n50: ]\n51: test = [\n52:     \"pytest>=7.4.0\",\n53:     \"pytest-asyncio>=0.21.0\",\n54:     \"pytest-cov>=4.1.0\",\n55:     \"pytest-mock>=3.11.0\",\n56:     \"httpx-mock>=0.10.0\",\n57: ]\n58: \n59: [project.scripts]\n60: kubectl-agentcube = \"agentcube.cli.main:app\"\n61: \n62: [project.urls]\n63: Homepage = \"https://github.com/volcano-sh/agentcube\"\n64: Documentation = \"https://agentcube.volcano.sh\"\n65: Repository = \"https://github.com/volcano-sh/agentcube\"\n66: \n67: [tool.setuptools]\n68: packages = [\n69:     \"agentcube\",\n70:     \"agentcube.cli\",\n71:     \"agentcube.models\",\n72:     \"agentcube.runtime\",\n73:     \"agentcube.operations\",\n74:     \"agentcube.services\",\n75: ]\n76: \n77: [tool.setuptools.package-data]\n78: agentcube = [\"py.typed\"]\n79: \n80: [tool.ruff]\n81: line-length = 100\n82: target-version = \"py310\"\n83: \n84: [tool.ruff.lint]\n85: select = [\"E\", \"F\", \"W\", \"I\", \"N\", \"UP\", \"B\", \"C4\", \"SIM\"]\n86: ignore = []\n87: \n88: [tool.mypy]\n89: python_version = \"3.10\"\n90: warn_return_any = true\n91: warn_unused_configs = true\n92: disallow_untyped_defs = true\n93: disallow_incomplete_defs = true\n94: check_untyped_defs = true\n95: no_implicit_optional = true\n96: warn_redundant_casts = true\n97: warn_unused_ignores = true\n98: warn_no_return = true\n99: strict_equality = true\n100: \n101: [tool.pytest.ini_options]\n102: testpaths = [\"tests\"]\n103: python_files = [\"test_*.py\"]\n104: python_classes = [\"Test*\"]\n105: python_functions = [\"test_*\"]\n106: addopts = \"-v --cov=agentcube --cov-report=term-missing\"\n107: markers = [\n108:     \"integration: marks tests as integration tests (deselect with '-m \\\"not integration\\\"')\"\n109: ]\n\n(End of file - total 109 lines)\n</content