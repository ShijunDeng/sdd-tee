oadManagerURL:    \"\",\n45: \t\tAgentcubeNamespace:    defaultNamespace,\n46: \t}\n47: }\n48: \n49: func LoadConfig() (*Config, error) {\n50: \tcfg := DefaultConfig()\n51: \n52: \tif port := os.Getenv(\"ROUTER_PORT\"); port != \"\" {\n53: \t\tcfg.Port = port\n54: \t}\n55: \n56: \tif debug := os.Getenv(\"ROUTER_DEBUG\"); debug != \"\" {\n57: \t\tcfg.Debug = debug == \"true\" || debug == \"1\"\n58: \t}\n59: \n60: \tif enableTLS := os.Getenv(\"ROUTER_ENABLE_TLS\"); enableTLS != \"\" {\n61: \t\tcfg.EnableTLS = enableTLS == \"true\" || enableTLS == \"1\"\n62: \t}\n63: \n64: \tif tlsCert := os.Getenv(\"ROUTER_TLS_CERT\"); tlsCert != \"\" {\n65: \t\tcfg.TLSCert = tlsCert\n66: \t}\n67: \n68: \tif tlsKey := os.Getenv(\"ROUTER_TLS_KEY\"); tlsKey != \"\" {\n69: \t\tcfg.TLSKey = tlsKey\n70: \t}\n71: \n72: \tif readTimeout := os.Getenv(\"ROUTER_READ_TIMEOUT\"); readTimeout != \"\" {\n73: \t\tif val, err := strconv.Atoi(readTimeout); err == nil {\n74: \t\t\tcfg.ReadTimeout = val\n75: \t\t}\n76: \t}\n77: \n78: \tif writeTimeout := os.Getenv(\"ROUTER_WRITE_TIMEOUT\"); writeTimeout != \"\" {\n79: \t\tif val, err := strconv.Atoi(writeTimeout); err == nil {\n80: \t\t\tcfg.WriteTimeout = val\n81: \t\t}\n82: \t}\n83: \n84: \tif idleTimeout := os.Getenv(\"ROUTER_IDLE_TIMEOUT\"); idleTimeout != \"\" {\n85: \t\tif val, err := strconv.Atoi(idleTimeout); err == nil {\n86: \t\t\tcfg.IdleTimeout = val\n87: \t\t}\n88: \t}\n89: \n90: \tif maxConcurrent := os.Getenv(\"ROUTER_MAX_CONCURRENT_REQUESTS\"); maxConcurrent != \"\" {\n91: \t\tif val, err := strconv.Atoi(maxConcurrent); err == nil {\n92: \t\t\tcfg.MaxConcurrentRequests = val\n93: \t\t}\n94: \t}\n95: \n96: \tif workloadMgrURL := os.Getenv(\"WORKLOAD_MANAGER_URL\"); workloadMgrURL != \"\" {\n97: \t\tcfg.WorkloadManagerURL = workloadMgrURL\n98: \t}\n99: \n100: \tif namespace := os.Getenv(\"AGENTCUBE_NAMESPACE\"); namespace != \"\" {\n101: \t\tcfg.AgentcubeNamespace = namespace\n102: \t}\n103: \n104: \tif err := cfg.Validate(); err != nil {\n105: \t\treturn nil, err\n106: \t}\n107: \n108: \treturn cfg, nil\n109: }\n110: \n111: func (c *Config) Validate() error {\n112: \tif c.Port == \"\" {\n113: \t\treturn fmt.Errorf(\"port is required\")\n114: \t}\n115: \n116: \tport, err := strconv.Atoi(c.Port)\n117: \tif err != nil {\n118: \t\treturn fmt.Errorf(\"invalid port number: %w\", err)\n119: \t}\n120: \n121: \tif port < 1 || port > 65535 {\n122: \t\treturn fmt.Errorf(\"port must be between 1 and 65535, got: %d\", port)\n123: \t}\n124: \n125: \tif c.EnableTLS {\n126: \t\tif c.TLSCert == \"\" {\n127: \t\t\treturn fmt.Errorf(\"TLS certificate path is required when TLS is enabled\")\n128: \t\t}\n129: \t\tif c.TLSKey == \"\" {\n130: \t\t\treturn fmt.Errorf(\"TLS key path is required when TLS is enabled\")\n131: \t\t}\n132: \t}\n133: \n134: \tif c.WorkloadManagerURL == \"\" {\n135: \t\treturn fmt.Errorf(\"workload manager URL is required\")\n136: \t}\n137: \n138: \tif c.MaxConcurrentRequests <= 0 {\n139: \t\tc.MaxConcurrentRequests = defaultMaxConcurrentRequests\n140: \t}\n141: \n142: \tif c.ReadTimeout <= 0 {\n143: \t\tc.ReadTimeout = defaultReadTimeout\n144: \t}\n145: \n146: \tif c.WriteTimeout <= 0 {\n147: \t\tc.WriteTimeout = defaultWriteTimeout\n148: \t}\n149: \n150: \tif c.IdleTimeout <= 0 {\n151: \t\tc.IdleTimeout = defaultIdleTimeout\n152: \t}\n153: \n154: \treturn nil\n155: }\n\n(End of file - total 155 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n)\n\nconst (\n\tdefaultPort                  = \"8080\"\n\tdefaultMaxConcurrentRequests = 1000\n\tdefaultReadTimeout           = 30\n\tdefaultWriteTimeout          = 30\n\tdefaultIdleTimeout           = 90\n\tdefaultNamespace             = \"default\"\n\tsecretName                   = \"picod-router-identity\"\n)\n\ntype Config struct {\n\tPort                  string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/config.g