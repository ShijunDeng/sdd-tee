{"type":"tool_use","timestamp":1775851763858,"sessionID":"ses_286fd0597ffeUvSKPGO0JQDwqU","part":{"id":"prt_d7903734f001qW6XeohRXBk0Cy","messageID":"msg_d79035bb7001D48AKt7OZKzwUc","sessionID":"ses_286fd0597ffeUvSKPGO0JQDwqU","type":"tool","tool":"read","callID":"toolu_tool-42a975b764e04a6da25a449d38916131","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/errors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/errors.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"net/http\"\n6: )\n7: \n8: var (\n9: \tErrSandboxNotFound        = &SandboxNotFoundError{}\n10: \tErrSessionExpired         = &SessionExpiredError{}\n11: \tErrWorkloadManagerError   = &WorkloadManagerError{}\n12: \tErrValidationError        = &ValidationError{}\n13: \tErrJWTSigningFailed       = \"JWT_SIGNING_FAILED\"\n14: \tErrSandboxUnreachable     = \"SANDBOX_UNREACHABLE\"\n15: \tErrServerOverloaded       = \"SERVER_OVERLOADED\"\n16: \tErrSessionManagerNotReady = \"SESSION_MANAGER_NOT_READY\"\n17: )\n18: \n19: type SandboxNotFoundError struct {\n20: \tSessionID string\n21: \tName      string\n22: \tNamespace string\n23: \tKind      string\n24: }\n25: \n26: func (e *SandboxNotFoundError) Error() string {\n27: \tif e.SessionID != \"\" {\n28: \t\treturn fmt.Sprintf(\"sandbox not found for session: %s\", e.SessionID)\n29: \t}\n30: \treturn fmt.Sprintf(\"sandbox not found: %s/%s/%s\", e.Kind, e.Namespace, e.Name)\n31: }\n32: \n33: func (e *SandboxNotFoundError) HTTPStatusCode() int {\n34: \treturn http.StatusNotFound\n35: }\n36: \n37: func (e *SandboxNotFoundError) ErrorCode() string {\n38: \treturn \"SANDBOX_NOT_FOUND\"\n39: }\n40: \n41: type SessionExpiredError struct {\n42: \tSessionID string\n43: }\n44: \n45: func (e *SessionExpiredError) Error() string {\n46: \treturn fmt.Sprintf(\"session expired: %s\", e.SessionID)\n47: }\n48: \n49: func (e *SessionExpiredError) HTTPStatusCode() int {\n50: \treturn http.StatusNotFound\n51: }\n52: \n53: func (e *SessionExpiredError) ErrorCode() string {\n54: \treturn \"SESSION_EXPIRED\"\n55: }\n56: \n57: type WorkloadManagerError struct {\n58: \tMessage string\n59: \tCode    int\n60: }\n61: \n62: func (e *WorkloadManagerError) Error() string {\n63: \treturn fmt.Sprintf(\"workload manager error: %s (code: %d)\", e.Message, e.Code)\n64: }\n65: \n66: func (e *WorkloadManagerError) HTTPStatusCode() int {\n67: \treturn e.Code\n68: }\n69: \n70: func (e *WorkloadManagerError) ErrorCode() string {\n71: \treturn \"WORKLOAD_MANAGER_ERROR\"\n72: }\n73: \n74: type ValidationError struct {\n75: \tField   string\n76: \tMessage string\n77: }\n78: \n79: func (e *ValidationError) Error() string {\n80: \treturn fmt.Sprintf(\"validation error: %s - %s\", e.Field, e.Message)\n81: }\n82: \n83: func (e *ValidationError) HTTPStatusCode() int {\n84: \treturn http.StatusBadRequest\n85: }\n86: \n87: func (e *ValidationError) ErrorCode() string {\n88: \treturn \"VALIDATION_ERROR\"\n89: }\n90: \n91: type HTTPError interface {\n92: \tError() string\n93: \tHTTPStatusCode() int\n94: \tErrorCode() string\n95: }\n96: \n97: func GetHTTPStatusCode(err error) int {\n98: \tif httpErr, ok := err.(HTTPError); ok {\n99: \t\treturn httpErr.HTTPStatusCode()\n100: \t}\n101: \treturn http.StatusInternalServerError\n102: }\n103: \n104: func GetErrorCode(err error) string {\n105: \tif httpErr, ok := err.(HTTPError); ok {\n106: \t\treturn httpErr.ErrorCode()\n107: \t}\n108: \treturn \"\"\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"fmt\"\n\t\"net/http\"\n)\n\nvar (\n\tErrSandboxNotFound        = &SandboxNotFoundError{}\n\tErrSessionExpired         = &SessionExpiredError{}\n\tErrWorkloadManagerError   = &WorkloadManagerError{}\n\tErrValidationError        = &ValidationError{}\n\tErrJWTSigningFailed       = \"JWT_SIGNING_FAILED\"\n\tErrSandboxUnreachable     = \"SANDBOX_UNREACHABLE\"\n\tErrServerOverloaded       = \"SERVER_OVERLOADED\"\n\tErrSessionManagerNotReady = \"SESSION_MANAGER_NOT_READY\"\n)\n\ntype SandboxNotFoundError struct {\n\tSessionID string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/errors.go","time":{"start":1775851763836,"end":1775851763856}}}}
