on can be used to manipulate options of a SharedInformerFactory instance.\n485: type SharedInformerOption func(*sharedInformerFactory) *sharedInformerFactory\n486: \n487: type sharedInformerFactory struct {\n488:     client           versioned.Interface\n489:     namespace        string\n490:     defaultResync    time.Duration\n491:     informers        map[reflect.Type]cache.SharedIndexInformer\n492:     startedInformers map[reflect.Type]bool\n493:     customResync     map[reflect.Type]time.Duration\n494:     lock             sync.Mutex\n495: }\n496: \n497: // Start initializes all requested informers.\n498: func (f *sharedInformerFactory) Start(stopCh <-chan struct{}) {\n499:     f.lock.Lock()\n500:     defer f.lock.Unlock()\n501: \n502:     for informerType, informer := range f.informers {\n503:         if !f.startedInformers[informerType] {\n504:             go informer.Run(stopCh)\n505:             f.startedInformers[informerType] = true\n506:         }\n507:     }\n508: }\n509: \n510: // WaitForCacheSync waits for all started informers' cache were synced.\n511: func (f *sharedInformerFactory) WaitForCacheSync(stopCh <-chan struct{}) map[reflect.Type]bool {\n512:     informers := func() []cache.SharedIndexInformer {\n513:         f.lock.Lock()\n514:         defer f.lock.Unlock()\n515: \n516:         informers := make([]cache.SharedIndexInformer, 0, len(f.informers))\n517:         for _, informer := range f.informers {\n518:             if f.startedInformers[informer.Type()] {\n519:                 informers = append(informers, informer)\n520:             }\n521:         }\n522:         return informers\n523:     }()\n524: \n525:     res := map[reflect.Type]bool{}\n526:     for _, informer := range informers {\n527:         res[informer.Type()] = cache.WaitForCacheSync(stopCh, informer.HasSynced)\n528:     }\n529:     return res\n530: }\n531: \n532: // Runtime provides access to runtime shared informers.\n533: func (f *sharedInformerFactory) Runtime() externalve