{"type":"tool_use","timestamp":1775867030623,"sessionID":"ses_286140efbffe4OwA8bBtYwNWa0","part":{"id":"prt_d79ec6c240011eMXJcaY1pYnJP","messageID":"msg_d79ec62040018cvStWlUooJR0j","sessionID":"ses_286140efbffe4OwA8bBtYwNWa0","type":"tool","tool":"read","callID":"toolu_tool-e0c9a257de404882b134a06de6959889","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_build_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/tests/test_build_runtime.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Tests for the build runtime.\"\"\"\n2: \n3: import pytest\n4: from pathlib import Path\n5: import tempfile\n6: import yaml\n7: from unittest.mock import MagicMock, patch, PropertyMock\n8: \n9: from agentcube.runtime.build_runtime import BuildRuntime\n10: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n11: from agentcube.services.docker_service import DockerService\n12: \n13: \n14: class TestBuildRuntime:\n15:     \"\"\"Test cases for BuildRuntime.\"\"\"\n16: \n17:     @pytest.fixture\n18:     def mock_docker_service(self):\n19:         \"\"\"Create a mock DockerService.\"\"\"\n20:         service = MagicMock(spec=DockerService)\n21:         service.check_docker_available.return_value = True\n22:         service.build_image.return_value = {\n23:             \"image_name\": \"test:1.0.1\",\n24:             \"image_id\": \"abc123def456\",\n25:             \"image_size\": \"512.34 MB\",\n26:             \"size_bytes\": 536870912,\n27:             \"build_time\": 1234567890.0,\n28:         }\n29:         return service\n30: \n31:     @pytest.fixture\n32:     def mock_metadata_service(self):\n33:         \"\"\"Create a mock MetadataService.\"\"\"\n34:         service = MagicMock(spec=MetadataService)\n35: \n36:         def load_side_effect(path):\n37:             return AgentMetadata(\n38:                 agent_name=\"test\",\n39:                 entrypoint=\"python main.py\",\n40:                 version=\"1.0.0\",\n41:                 build_mode=\"local\"\n42:             )\n43: \n44:         service.load_metadata.side_effect = load_side_effect\n45:         service.save_metadata = MagicMock()\n46:         return service\n47: \n48:     @pytest.fixture\n49:     def workspace_with_dockerfile(self):\n50:         \"\"\"Create a temporary workspace with Dockerfile.\"\"\"\n51:         with tempfile.TemporaryDirectory() as tmpdir:\n52:             workspace = Path(tmpdir)\n53:             (workspace / \"main.py\").write_text(\"print('hello')\")\n54:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10-slim\")\n55:             metadata = AgentMetadata(\n56:                 agent_name=\"test-agent\",\n57:                 entrypoint=\"python main.py\",\n58:                 version=\"1.0.0\",\n59:                 build_mode=\"local\"\n60:             )\n61:             metadata_service = MetadataService()\n62:             metadata_service.save_metadata(workspace, metadata)\n63:             yield workspace\n64: \n65:     def test_increment_semantic_version(self, workspace_with_dockerfile):\n66:         \"\"\"Test incrementing semantic version patch.\"\"\"\n67:         metadata = AgentMetadata(\n68:             agent_name=\"test\",\n69:             entrypoint=\"python main.py\",\n70:             version=\"1.0.0\"\n71:         )\n72:         runtime = BuildRuntime()\n73:         runtime.metadata_service = MagicMock(spec=MetadataService)\n74:         runtime.metadata_service.save_metadata = MagicMock()\n75: \n76:         new_version = runtime._increment_version(workspace_with_dockerfile, metadata)\n77: \n78:         assert new_version == \"1.0.1\"\n79:         assert metadata.version == \"1.0.1\"\n80:         runtime.metadata_service.save_metadata.assert_called_once()\n81: \n82:     def test_increment_prerelease_version(self):\n83:         \"\"\"Test incrementing prerelease version.\"\"\"\n84:         metadata = AgentMetadata(\n85:             agent_name=\"test\",\n86:             entrypoint=\"python main.py\",\n87:             version=\"1.0.0-alpha.1\"\n88:         )\n89:         runtime = BuildRuntime()\n90:         runtime.metadata_service = MagicMock(spec=MetadataService)\n91:         runtime.metadata_service.save_metadata = MagicMock()\n92: \n93:         with tempfile.TemporaryDirectory() as tmpdir:\n94:             workspace = Path(tmpdir)\n95:             new_version = runtime._increment_version(workspace, metadata)\n96: \n97:             assert new_version == \"1.0.0-alpha.2\"\n98:             assert metadata.version == \"1.0.0-alpha.2\"\n99: \n100:     def test_increment_prerelease_with_suffix(self):\n101:         \"\"\"Test incrementing prerelease version with suffix.\"\"\"\n102:         metadata = AgentMetadata(\n103:             agent_name=\"test\",\n104:             entrypoint=\"python main.py\",\n105:             version=\"1.0.0-beta.1.rc1\"\n106:         )\n107:         runtime = BuildRuntime()\n108:         runtime.metadata_service = MagicMock(spec=MetadataService)\n109:         runtime.metadata_service.save_metadata = MagicMock()\n110: \n111:         with tempfile.TemporaryDirectory() as tmpdir:\n112:             workspace = Path(tmpdir)\n113:             new_version = runtime._increment_version(workspace, metadata)\n114: \n115:             assert new_version == \"1.0.0-beta.2.rc1\"\n116:             assert metadata.version == \"1.0.0-beta.2.rc1\"\n117: \n118:     def test_increment_custom_version(self):\n119:         \"\"\"Test incrementing custom version with suffix.\"\"\"\n120:         metadata = AgentMetadata(\n121:             agent_name=\"test\",\n122:             entrypoint=\"python main.py\",\n123:             version=\"custom-version\"\n124:         )\n125:         runtime = BuildRuntime()\n126:         runtime.metadata_service = MagicMock(spec=MetadataService)\n127:         runtime.metadata_service.save_metadata = MagicMock()\n128: \n129:         with tempfile.TemporaryDirectory() as tmpdir:\n130:             workspace = Path(tmpdir)\n131:             new_version = runtime._increment_version(workspace, metadata)\n132: \n133:             assert new_version == \"custom-version-1\"\n134:             assert metadata.version == \"custom-version-1\"\n135: \n136:     def test_increment_no_version(self):\n137:         \"\"\"Test incrementing when no version exists.\"\"\"\n138:         metadata = AgentMetadata(\n139:             agent_name=\"test\",\n140:             entrypoint=\"python main.py\"\n141:         )\n142:         runtime = BuildRuntime()\n143:         runtime.metadata_service = MagicMock(spec=MetadataService)\n144:         runtime.metadata_service.save_metadata = MagicMock()\n145: \n146:         with tempfile.TemporaryDirectory() as tmpdir:\n147:             workspace = Path(tmpdir)\n148:             new_version = runtime._increment_version(workspace, metadata)\n149: \n150:             assert new_version == \"0.1.0\"\n151:             assert metadata.version == \"0.1.0\"\n152: \n153:     def test_validate_missing_dockerfile(self):\n154:         \"\"\"Test validation when Dockerfile is missing.\"\"\"\n155:         with tempfile.TemporaryDirectory() as tmpdir:\n156:             workspace = Path(tmpdir)\n157:             runtime = BuildRuntime()\n158:             runtime.docker_service = MagicMock(spec=DockerService)\n159:             runtime.docker_service.check_docker_available.return_value = True\n160: \n161:             with pytest.raises(ValueError, match=\"Dockerfile not found\"):\n162:                 runtime._validate_build_prerequisites(workspace)\n163: \n164:     def test_validate_docker_unavailable(self):\n165:         \"\"\"Test validation when Docker is unavailable.\"\"\"\n166:         with tempfile.TemporaryDirectory() as tmpdir:\n167:             workspace = Path(tmpdir)\n168:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n169: \n170:             runtime = BuildRuntime()\n171:             runtime.docker_service = MagicMock(spec=DockerService)\n172:             runtime.docker_service.check_docker_available.return_value = False\n173: \n174:             with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n175:                 runtime._validate_build_prerequisites(workspace)\n176: \n177:     def test_validate_valid_workspace(self):\n178:         \"\"\"Test validation with valid workspace.\"\"\"\n179:         with tempfile.TemporaryDirectory() as tmpdir:\n180:             workspace = Path(tmpdir)\n181:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n182: \n183:             runtime = BuildRuntime()\n184:             runtime.docker_service = MagicMock(spec=DockerService)\n185:             runtime.docker_service.check_docker_available.return_value = True\n186: \n187:             runtime._validate_build_prerequisites(workspace)\n188:             runtime.docker_service.check_docker_available.assert_called_once()\n189: \n190:     def test_build_local_basic(self, mock_docker_service, mock_metadata_service):\n191:         \"\"\"Test basic local build.\"\"\"\n192:         with tempfile.TemporaryDirectory() as tmpdir:\n193:             workspace = Path(tmpdir)\n194:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n195: \n196:             metadata = AgentMetadata(\n197:                 agent_name=\"test-agent\",\n198:                 entrypoint=\"python main.py\",\n199:                 version=\"1.0.1\"\n200:             )\n201: \n202:             runtime = BuildRuntime()\n203:             runtime.docker_service = mock_docker_service\n204:             runtime.metadata_service = mock_metadata_service\n205: \n206:             result = runtime._build_local(workspace, metadata, {})\n207: \n208:             assert result[\"image_name\"] == \"test-agent:1.0.1\"\n209:             assert \"image_id\" in result\n210:             mock_docker_service.build_image.assert_called_once()\n211: \n212:     def test_build_local_with_proxy(self, mock_docker_service, mock_metadata_service):\n213:         \"\"\"Test local build with proxy.\"\"\"\n214:         with tempfile.TemporaryDirectory() as tmpdir:\n215:             workspace = Path(tmpdir)\n216:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n217: \n218:             metadata = AgentMetadata(\n219:                 agent_name=\"test-agent\",\n220:                 entrypoint=\"python main.py\",\n221:                 version=\"1.0.1\"\n222:             )\n223: \n224:             runtime = BuildRuntime()\n225:             runtime.docker_service = mock_docker_service\n226:             runtime.metadata_service = mock_metadata_service\n227: \n228:             options = {\"proxy\": \"http://proxy.example.com:8080\"}\n229:             result = runtime._build_local(workspace, metadata, options)\n230: \n231:             assert result[\"image_name\"] == \"test-agent:1.0.1\"\n232:             call_kwargs = mock_docker_service.build_image.call_args.kwargs\n233:             assert call_kwargs[\"build_args\"][\"HTTP_PROXY\"] == \"http://proxy.example.com:8080\"\n234:             assert call_kwargs[\"build_args\"][\"HTTPS_PROXY\"] == \"http://proxy.example.com:8080\"\n235: \n236:     def test_build_local_without_version(self, mock_docker_service, mock_metadata_service):\n237:         \"\"\"Test local build without version uses latest tag.\"\"\"\n238:         with tempfile.TemporaryDirectory() as tmpdir:\n239:             workspace = Path(tmpdir)\n240:             (workspace / \"Dockerfile\").write_text(\"FROM python:3.10\")\n241: \n242:             metadata = AgentMetadata(\n243:                 agent_name=\"test-agent\",\n244:                 entrypoint=\"python main.py\",\n245:                 version=None\n246:             )\n247: \n248:             runtime = BuildRuntime()\n249:             runtime