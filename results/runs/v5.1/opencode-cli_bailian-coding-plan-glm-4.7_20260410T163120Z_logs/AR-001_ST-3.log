sionTimeout`, `spec.targetPort` (AgentRuntime)\n2. **Invalid enum values**: `protocol` must be `HTTP` or `HTTPS`\n3. **Port range violations**: `port` must be between 1 and 65535\n4. **Array minimum**: `targetPort` must have at least one element\n\n### Client-Go Error Handling\n\n```go\n// Common error patterns\nerr := client.AgentRuntimes(namespace).Create(ctx, &agentRuntime, opts)\nif errors.IsAlreadyExists(err) {\n    // Handle conflict\n} else if errors.IsNotFound(err) {\n    // Handle not found\n} else if errors.IsInvalid(err) {\n    // Handle validation error\n} else if errors.IsForbidden(err) {\n    // Handle RBAC error\n} else if err != nil {\n    // Handle other errors\n}\n```\n\n### Informer Error Handling\n\n```go\ninformer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n    AddFunc: func(obj interface{}) {\n        if runtimeObj, ok := obj.(metav1.Object); ok {\n            klog.Infof(\"AgentRuntime %s added\", runtimeObj.GetName())\n        }\n    },\n    UpdateFunc: func(oldObj, newObj interface{}) {\n        oldRuntime := oldObj.(*v1alpha1.AgentRuntime)\n        newRuntime := newObj.(*v1alpha1.AgentRuntime)\n        if oldRuntime.Generation != newRuntime.Generation {\n            klog.Infof(\"AgentRuntime %s generation changed\", newRuntime.Name)\n        }\n    },\n    DeleteFunc: func(obj interface{}) {\n        if runtimeObj, ok := obj.(metav1.Object); ok {\n            klog.Infof(\"AgentRuntime %s deleted\", runtimeObj.GetName())\n        }\n    },\n})\n```\n\n## Testing Strategy\n\n### Unit Tests\n\n**File**: `pkg/apis/runtime/v1alpha1/agentruntime_types_test.go`\n\n```go\npackage v1alpha1_test\n\nimport (\n    . \"github.com/onsi/ginkgo/v2\"\n    . \"github.com/onsi/gomega\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n    \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nvar _ = Describe(\"AgentRuntime\", func() {\n    Describe(\"Spec defaults\", func() {\n        It(\"should default maxSessionDuration to 8h\", func() {\n            art := &v1alpha1.AgentRuntime{\n                Spec: v1alpha1.AgentRuntimeSpec{},\n            }\n            // Controller-gen sets defaults; verify after defaulting\n            Expect(art.Spec.MaxSessionDuration).To(Equal(\"8h\"))\n        })\n    })\n\n    Describe(\"TargetPort validation\", func() {\n        It(\"should reject invalid protocol\", func() {\n            art := &v1alpha1.AgentRuntime{\n                Spec: v1alpha1.AgentRuntimeSpec{\n                    TargetPort: []v1alpha1.TargetPort{\n                        {\n                            Port:     8080,\n                            Protocol: \"TCP\", // Invalid: must be HTTP or HTTPS\n                        },\n                    },\n                },\n            }\n            // Validation will fail at API server level\n        })\n    })\n\n    Describe(\"DeepCopy\", func() {\n        It(\"should create independent copies\", func() {\n            original := &v1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name: \"test\",\n                },\n                Spec: v1alpha1.AgentRuntimeSpec{\n                    MaxSessionDuration: \"8h\",\n                },\n            }\n            copy := original.DeepCopy()\n            \n            Expect(copy).NotTo(BeIdenticalTo(original))\n            Expect(copy.Name).To(Equal(original.Name))\n            Expect(copy.Spec.MaxSessionDuration).To(Equal(original.Spec.MaxSessionDuration))\n        })\n    })\n})\n```\n\n### Client-Go Integration Tests\n\n**File**: `pkg/apis/runtime/v1alpha1/client_test.go`\n\n```go\npackage v1alpha1_test\n\nimport (\n    \"context\"\n    \"testing\"\n    \"time\"\n\n    . \"github.com/onsi/ginkgo/v2\"\n    . \"github.com/onsi/gomega\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n    \"k8s.io/client-go/kubernetes/scheme\"\n    \"sigs.k8s.io/controller-runtime/pkg/client\"\n    \"sigs.k8s.io/controller-runtime/pkg/envtest\"\n\n    runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n)\n\nvar (\n    envTest *envtest.Environment\n    k8sClient client.Client\n)\n\nvar _ = BeforeSuite(func() {\n    err := runtimev1alpha1.AddToScheme(scheme.Scheme)\n    Expect(err).NotTo(HaveOccurred())\n\n    envTest = &envtest.Environment{\n        CRDDirectoryPaths: []string{\"../../../manifests/charts/base/crds\"},\n    }\n\n    cfg, err := envTest.Start()\n    Expect(err).NotTo(HaveOccurred())\n\n    k8sClient, err = client.New(cfg, client.Options{Scheme: scheme.Scheme})\n    Expect(err).NotTo(HaveOccurred())\n})\n\nvar _ = AfterSuite(func() {\n    err := envTest.Stop()\n    Expect(err).NotTo(HaveOccurred())\n})\n\nvar _ = Describe(\"AgentRuntime CRD\", func() {\n    Context(\"Create\", func() {\n        It(\"should create AgentRuntime successfully\", func(ctx SpecContext) {\n            art := &runtimev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"test-art\",\n                    Namespace: \"default\",\n                },\n                Spec: runtimev1alpha1.AgentRuntimeSpec{\n                    MaxSessionDuration: \"8h\",\n                    SessionTimeout:     \"15m\",\n                    TargetPort: []runtimev1alpha1.TargetPort{\n                        {\n                            Port:     8080,\n                            Protocol: \"HTTP\",\n                        },\n                    },\n                    PodTemplate: runtimev1alpha1.PodTemplateSpec{\n                        Spec: runtimev1alpha1.PodSpec{\n                            Containers: []runtimev1alpha1.Container{\n                                {\n                                    Name:  \"agent\",\n                                    Image: \"nginx:latest\",\n                                },\n                            },\n                        },\n                    },\n                },\n            }\n\n            err := k8sClient.Create(ctx, art)\n            Expect(err).NotTo(HaveOccurred())\n        }, SpecTimeout(5*time.Second))\n    })\n\n    Context(\"Get\", func() {\n        It(\"should get AgentRuntime\", func(ctx SpecContext) {\n            var art runtimev1alpha1.AgentRuntime\n            err := k8sClient.Get(ctx, client.ObjectKey{\n                Name:      \"test-art\",\n                Namespace: \"default\",\n            }, &art)\n            Expect(err).NotTo(HaveOccurred())\n            Expect(art.Spec.MaxSessionDuration).To(Equal(\"8h\"))\n        }, SpecTimeout(5*time.Second))\n    })\n})\n```\n\n### E2E Tests\n\n**File**: `test/e2e/agentruntime_test.go`\n\n```go\npackage e2e\n\nimport (\n    \"context\"\n    \"testing\"\n    \"time\"\n\n    . \"github.com/onsi/ginkgo/v2\"\n    . \"github.com/onsi/gomega\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\n    runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n    \"github.com/volcano-sh/agentcube/test/e2e/framework\"\n)\n\nvar _ = Describe(\"AgentRuntime E2E\", func() {\n    f := framework.NewDefaultFramework(\"agentruntime\")\n\n    Context(\"Create and validate AgentRuntime\", func() {\n        It(\"should create AgentRuntime and verify defaults\", func() {\n            ctx := context.Background()\n            \n            art := &runtimev1alpha1.AgentRuntime{\n                ObjectMeta: metav1.ObjectMeta{\n                    Name:      \"e2e-art\",\n                    Namespace: f.Namespace.Name,\n                },\n                Spec: runtimev1alpha1.AgentRuntimeSpec{\n                    MaxSessionDuration: \"1h\",\n                    SessionTimeout:     \"5m\",\n                    TargetPort: []runtimev1alpha1.TargetPort{\n                        {\n                            Port:     8080,\n                            Protocol: \"HTTP\",\n                        },\n                    },\n                    PodTemplate: runtimev1alpha1.PodTemplateSpec{\n                        Spec: runtimev1alpha1.PodSpec{\n                            Containers: []runtimev1alpha1.Container{\n                                {\n                                    Name:  \"agent\",\n                                    Image: \"nginx:latest\",\n                                },\n                            },\n                        },\n                    },\n                },\n            }\n\n            err := f.Client.Create(ctx, art)\n            Expect(err).NotTo(HaveOccurred())\n\n            // Verify creation\n            Eventually(func() bool {\n                var fetchedArt runtimev1alpha1.AgentRuntime\n                err := f.Client.Get(ctx, client.ObjectKeyFromObject(art), &fetchedArt)\n                return err == nil\n            }, 10*time.Second, time.Second).Should(BeTrue())\n        })\n    })\n})\n```\n\n## Code Generation\n\n### CRD Generation\n\n**Command**: `make gen-crd`\n\n```bash\ncontroller-gen crd paths=\"./pkg/apis/runtime/v1alpha1/...\" output:crd:dir=manifests/charts/base/crds\n```\n\nThis generates:\n- `manifests/charts/base/crds/runtime.agentcube.volcano.sh_agentruntimes.yaml`\n- `manifests/charts/base/crds/runtime.agentcube.volcano.sh_codeinterpreters.yaml`\n\n### Client-Go Generation\n\n**Command**: `make gen-client`\n\n```bash\nbash hack/update-codegen.sh\n```\n\nThis generates:\n- Typed clients in `client-go/clientset/versioned/typed/runtime/v1alpha1/`\n- Informers in `client-go/informers/externalversions/runtime/v1alpha1/`\n- Listers in `client-go/listers/runtime/v1alpha1/`\n\n### DeepCopy Generation\n\n**Command**: `make generate`\n\n```bash\ncontroller-gen object paths=\"./pkg/apis/runtime/v1alpha1/...\"\n```\n\nThis generates:\n- `pkg/apis/runtime/v1alpha1/zz_generated.deepcopy.go`\n\n## Integration Points\n\n### With Workload Manager\n\nThe Workload Manager uses the generated client-go to:\n1. Watch AgentRuntime CRDs for changes\n2. Create and manage sandbox pods based on AgentRuntime spec\n3. Update AgentRuntime status with observed state\n4. Handle session lifecycle (creation, expiry, idle cleanup)\n\n### With Router\n\nThe Router uses the generated client-go to:\n1. Watch CodeInterpreter CRDs for target ports\n2. Configure routing rules based on port and pathPrefix\n3. Update session metadata in Redis\n\n### With RBAC\n\nRequired RBAC permissions (from `deployment/design.md`):\n\n```yaml\napiGroups:\n- runtime.agentcube.volcano.sh\nresources:\n- agentruntimes\n- codeinterpreters\nverbs:\n- get\n- list\n- watch\n- create\n- update\n- patch\n- delete\n\napiGroups:\n- runtime.agentcube.volcano.sh\nresources:\n- agentruntimes/status\n- codeinterpreters/status\nverbs:\n- get\n- update\n- patch\n\napiGroups:\n- runtime.agentcube.volcano.sh\nresources:\n- codeinterpreters/finalizers\nverbs:\n- update\n```\n\n## Version Migration Strategy\n\nFuture migration path from v1alpha1 to v1beta1/v1:\n\n1. Create new version package `pkg/apis/runtime/v1beta1/`\n2. Implement conversion functions between v1alpha1 and v1beta1\n3. Update CRD to serve both versions (v1alpha1 and v1beta1)\n4. Set v1beta1 as storage version\n5. Update controllers and clients to use v1beta1\n6. Deprecate v1alpha1 after migration period\n\n```go\n// pkg/apis/runtime/conversion.go\npackage runtime\n\nimport (\n    \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n    \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1beta1\"\n    \"sigs.k8s.io/controller-runtime/pkg/conversion\"\n)\n\nfunc (src *v1alpha1.AgentRuntime) ConvertTo(dstRaw conversion.Hub) error {\n    dst := dstRaw.(*v1beta1.AgentRuntime)\n    // Conversion logic\n    return nil\n}\n\nfunc (dst *v1beta1.AgentRuntime) ConvertFrom(srcRaw conversion.Hub) error {\n    src := srcRaw.(*v1alpha1.AgentRuntime)\n    // Conversion logic\n    return nil\n}\n```\n\n## Dependencies\n\n### Go Dependencies\n\n```go\nimport (\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n    \"k8s.io/apimachinery/pkg/runtime\"\n    \"k8s.io/apimachinery/pkg/runtime/schema\"\n    \"k8s.io/apimachinery/pkg/util/intstr\"\n)\n```\n\n### Build Tools\n\n- `controller-gen`: v0.17.2 (for CRD and deepcopy generation)\n- `k8s.io/code-generator`: v0.34.1 (for client-go generation)\n\n### Makefile Targets\n\n| Target | Description |\n|--------|-------------|\n| `gen-crd` | Generate CRD manifests |\n| `gen-client` | Generate client-go library |\n| `generate` | Generate all code (CRD + deepcopy + go mod tidy) |\n| `gen-all` | `generate` + `gen-client` |\n| `gen-check` | Verify generated code is up-to-date |\n\n## Documentation\n\n### API Reference\n\nAuto-generated from CRD OpenAPIV3Schema:\n- `AgentRuntime` spec and status fields\n- `CodeInterpreter` spec and status fields\n- Validation rules and constraints\n\n### Client-Go Documentation\n\nAuto-generated from source code:\n- Interface definitions\n- Method signatures\n- Usage examples\n\n### Examples\n\n**AgentRuntime example** (`examples/agentruntime.yaml`):\n\n```yaml\napiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: AgentRuntime\nmetadata:\n  name: python-agent\n  namespace: agentcube\nspec:\n  maxSessionDuration: \"8h\"\n  sessionTimeout: \"15m\"\n  targetPort:\n  - port: 8080\n    protocol: \"HTTP\"\n    pathPrefix: \"/api\"\n  podTemplate:\n    metadata:\n      labels:\n        app: python-agent\n    spec:\n      containers:\n      - name: agent\n        image: ghcr.io/volcano-sh/python-agent:latest\n        resources:\n          limits:\n            cpu: \"500m\"\n            memory: \"512Mi\"\n          requests:\n            cpu: \"100m\"\n            memory: \"128Mi\"\n```\n\n**CodeInterpreter example** (`examples/codeinterpreter.yaml`):\n\n```yaml\napiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: CodeInterpreter\nmetadata:\n  name: python-interpreter\n  namespace: agentcube\nspec:\n  authMode: \"picod\"\n  maxSessionDuration: \"8h\"\n  sessionTimeout: \"15m\"\n  ports:\n  - port: 8080\n    protocol: \"HTTP\"\n  template:\n    spec:\n      containers:\n      - name: interpreter\n        image: ghcr.io/volcano-sh/python-interpreter:latest\n        resources:\n          limits:\n            cpu: \"1\"\n            memory: \"1Gi\"\n          requests:\n            cpu: \"250m\"\n            memory: \"256Mi\"\n    warmPoolSize: 2\n```","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/deployment/design.md"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/deployment/design.md","exists":true,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/deployment/design.md","time":{"start":1775838990016,"end":1775838990213}}}}
