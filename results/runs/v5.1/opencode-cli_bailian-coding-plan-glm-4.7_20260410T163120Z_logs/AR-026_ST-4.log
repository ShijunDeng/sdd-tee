imeError(\n44:                 \"Kubernetes Python client is not installed. \"\n45:                 \"Install it with: pip install kubernetes\"\n46:             )\n47: \n48:         if verbose:\n49:             logging.basicConfig(level=logging.DEBUG)\n50: \n51:         self._load_config()\n52:         self._custom_api = CustomObjectsApi()\n53: \n54:     def _load_config(self) -> None:\n55:         \"\"\"Load Kubernetes configuration.\"\"\"\n56:         try:\n57:             if self.kubeconfig:\n58:                 config.load_kube_config(config_file=self.kubeconfig)\n59:             else:\n60:                 config.load_kube_config()\n61:         except config.ConfigException:\n62:             try:\n63:                 config.load_incluster_config()\n64:             except config.ConfigException as e:\n65:                 raise RuntimeError(\n66:                     \"Failed to load Kubernetes configuration. \"\n67:                     \"Please provide a kubeconfig file or run in a Kubernetes cluster.\"\n68:                 ) from e\n69: \n70:     def _ensure_namespace(self) -> None:\n71:         \"\"\"Ensure the namespace exists.\"\"\"\n72:         try:\n73:             core_v1 = client.CoreV1Api()\n74:             core_v1.read_namespace(self.namespace)\n75:         except ApiException as e:\n76:             if e.status == 404:\n77:                 core_v1 = client.CoreV1Api()\n78:                 namespace = client.V1Namespace(\n79:                     metadata=client.V1ObjectMeta(name=self.namespace)\n80:                 )\n81:                 core_v1.create_namespace(namespace)\n82:                 logger.info(f\"Created namespace: {self.namespace}\")\n83:             else:\n84:                 raise\n85: \n86:     def deploy_agent_runtime(\n87:         self,\n88:         agent_name: str,\n89:         image_url: str,\n90:         port: int,\n91:         entrypoint: Optional[str] = None,\n92:         env_vars: Optional[Dict[str, str]] = None,\n93:         workload_manager_url: Optional[str] = None,\n94:         router_url: Optional[str] = None,\n95:         readiness_probe_path: Optional[str] = None,\n96:         readiness_probe_port: Optional[int] = None,\n97:     ) -> Dict[str, Any]:\n98:         \"\"\"Deploy an agent using AgentRuntime custom resource.\"\"\"\n99:         self._ensure_namespace()\n100: \n101:         sanitized_name = self._sanitize_name(agent_name)\n102: \n103:         workload_manager = workload_manager_url or os.getenv(\"WORKLOAD_MANAGER_URL\")\n104:         router = router_url or os.getenv(\"ROUTER_URL\")\n105: \n106:         if not workload_manager:\n107:             raise ValueError(\n108:                 \"workload_manager_url is required. \"\n109:                 \"Provide it as a parameter or set WORKLOAD_MANAGER_URL environment variable.\"\n110:             )\n111: \n112:         if not router:\n113:             raise ValueError(\n114:                 \"router_url is required. \"\n115:                 \"Provide it as a parameter or set ROUTER_URL environment variable.\"\n116:             )\n117: \n118:         env_list = [\n119:             client.V1EnvVar(name=k, value=v) for k, v in (env_vars or {}).items()\n120:         ]\n121: \n122:         cr = {\n123:             \"apiVersion\": f\"{CR_GROUP}/{CR_VERSION}\",\n124:             \"kind\": \"AgentRuntime\",\n125:             \"metadata\": {\n126:                 \"name\": sanitized_name,\n127:                 \"namespace\": self.namespace,\n128:             },\n129:             \"spec\": {\n130:                 \"image\": image_url,\n131:                 \"port\": port,\n132:                 \"entrypoint\": entrypoint or \"\",\n133:                 \"env\": env_list,\n134:                 \"workloadManagerURL\": workload_manager,\n135:                 \"routerURL\": router,\n136:                 \"sessionTimeout\": \"15m\",\n137:                 \"maxSessionDuration\": \"8h\",\n138:                 \"readinessProbe\": {\n139:                     \"path\": readiness_probe_path or \"/health\",\n140:                     \"port\": readiness_probe_port or port,\n141:                 },\n142:                 \"imagePullSecrets\": [{\"name\": \"default-secret\"}],\n143:             },\n144:         }\n145: \n146:         try:\n147:             self._custom_api.create_namespaced_custom_object(\n148:                 group=CR_GROUP,\n149:                 version=CR_VERSION,\n150:                 namespace=self.namespace,\n151:                 plural=CR_PLURAL,\n152:                 body=cr,\n153:             )\n154:             logger.info(f\"Created AgentRuntime {sanitized_name}\")\n155:         except ApiException as e:\n156:             if e.status == 409:\n157:                 self._custom_api.replace_namespaced_custom_object(\n158:                     group=CR_GROUP,\n159:                     version=CR_VERSION,\n160:                     namespace=self.namespace,\n161:                     plural=CR_PLURAL,\n162:                     name=sanitized_name,\n163:                     body=cr,\n164:                 )\n165:                 logger.info(f\"Updated AgentRuntime {sanitized_name}\")\n166:             else:\n167:                 raise\n168: \n169:         return {\n170:             \"status\": \"created\",\n171:             \"agent_name\": sanitized_name,\n172:             \"namespace\": self.namespace,\n173:         }\n174: \n175:     def get_agent_runtime(self, name: str, namespace: str) -> Optional[Dict[str, Any]]:\n176:         \"\"\"Get an AgentRuntime custom resource.\"\"\"\n177:         try:\n178:             cr = self._custom_api.get_namespaced_custom_object(\n179:                 group=CR_GROUP,\n180:                 version=CR_VERSION,\n181:                 namespace=namespace,\n182:                 plural=CR_PLURAL,\n183:                 name=name,\n184:             )\n185:             return cr\n186:         except ApiException as e:\n187:             if e.status == 404:\n188:                 return None\n189:             raise\n190: \n191:     def _sanitize_name(self, name: str) -> str:\n192:         \"\"\"Sanitize a name for Kubernetes.\"\"\"\n193:         sanitized = re.sub(r\"[^a-z0-9-]\", \"-\", name.lower())\n194:         sanitized = re.sub(r\"-+\", \"-\", sanitized)\n195:         sanitized = sanitized.strip(\"-\")\n196:         if len(sanitized) > 63:\n197:             sanitized = sanitized[:63].rstrip(\"-\")\n198:         return sanitized or \"agent\"\n\n(End of file - total 198 lines)\n</content>","metadata":{"preview":"\"\"\"AgentCube provider service for AgentRuntime CR.\"\"\"\n\nimport logging\nimport os\nimport re\nfrom typing import Any, Dict, List, Optional\n\ntry:\n    from kubernetes import client, config\n    from kubernetes.client.rest import ApiException\n    from kubernetes.client import CustomObjectsApi\n    KUBERNETES_AVAILABLE = True\nexcept ImportError:\n    KUBERNETES_AVAILABLE = False\n    client = None\n    config = None\n    ApiException = Exception\n    CustomObjectsApi = None\n\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/agentcube_provider.py","time":{"start":1775875603702,"end":1775875603719}}}}
