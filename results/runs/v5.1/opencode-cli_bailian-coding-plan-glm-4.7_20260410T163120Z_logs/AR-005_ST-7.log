ionID string `uri:\"sessionId\" binding:\"required\"`\n88: }\n89: \n90: type DeleteSessionResponse struct {\n91: \tSessionID string `json:\"sessionId\"`\n92: \tDeletedAt string `json:\"deletedAt\"`\n93: }\n94: \n95: type ErrorResponse struct {\n96: \tError string `json:\"error\"`\n97: \tCode  string `json:\"code,omitempty\"`\n98: }\n\n(End of file - total 98 lines)\n</content>","metadata":{"preview":"package types\n\nimport (\n\t\"errors\"\n\t\"time\"\n)\n\nconst (\n\tAgentRuntimeKind    = \"AgentRuntime\"\n\tCodeInterpreterKind = \"CodeInterpreter\"\n)\n\nvar (\n\tErrInvalidKind       = errors.New(\"invalid kind: must be AgentRuntime or CodeInterpreter\")\n\tErrNameRequired      = errors.New(\"name is required\")\n\tErrNamespaceRequired = errors.New(\"namespace is required\")\n)\n\ntype SandboxInfo struct {\n\tKind             string              `json:\"kind\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/common/types/types.go","time":{"start":1775844590638,"end":1775844590646}}}}
