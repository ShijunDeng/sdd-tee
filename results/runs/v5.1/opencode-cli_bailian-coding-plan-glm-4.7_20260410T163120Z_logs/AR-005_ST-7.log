ionID+\" not found, maybe already deleted\")\n41: \t\t\treturn\n42: \t\t}\n43: \t\tklog.Errorf(\"Failed to get sandbox by session ID %s: %v\", sessionID, err)\n44: \t\tapi.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n45: \t\treturn\n46: \t}\n47: \n48: \tgvr := workloadmanager.SandboxGVR\n49: \tif sandboxInfo.Kind == \"SandboxClaim\" {\n50: \t\tgvr = workloadmanager.SandboxClaimGVR\n51: \t}\n52: \n53: \tdeleteCtx, cancel := context.WithTimeout(c.Request.Context(), workloadmanager.DeleteTimeout)\n54: \tdefer cancel()\n55: \n56: \terr = h.dynamicClient.Resource(gvr).\n57: \t\tNamespace(sandboxInfo.SandboxNamespace).\n58: \t\tDelete(deleteCtx, sandboxInfo.SandboxID, metav1.DeleteOptions{})\n59: \n60: \tif err != nil && !apierrors.IsNotFound(err) {\n61: \t\tklog.Errorf(\"Failed to delete sandbox %s/%s: %v\", sandboxInfo.SandboxNamespace, sandboxInfo.SandboxID, err)\n62: \t\tapi.Error(c, http.StatusInternalServerError, 50002, \"internal server error\")\n63: \t\treturn\n64: \t}\n65: \n66: \tif err := h.storeClient.DeleteSandboxBySessionID(c.Request.Context(), sessionID); err != nil {\n67: \t\tklog.Warningf(\"Failed to delete sandbox %s from store: %v\", sessionID, err)\n68: \t}\n69: \n70: \tapi.JSON(c, http.StatusOK, wmTypes.DeleteSandboxResponse{\n71: \t\tMessage: \"Sandbox deleted successfully\",\n72: \t})\n73: }\n\n(End of file - total 73 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n\ntype SandboxHandler struct {\n\tdynamicClient dynamic.Interface\n\tstoreClient   store.Store","truncated":false,"loaded":[]},"titl