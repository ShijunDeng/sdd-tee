argeContent {\n198: \t\t\t\tlargeContent[i] = byte(i % 256)\n199: \t\t\t}\n200: \n201: \t\t\terr := helper.UploadFile(ctx, sessionID, \"large.bin\", largeContent, \"base64\")\n202: \t\t\tExpect(err).NotTo(HaveOccurred())\n203: \n204: \t\t\tdownloaded, err := helper.DownloadFile(ctx, sessionID, \"large.bin\")\n205: \t\t\tExpect(err).NotTo(HaveOccurred())\n206: \t\t\tExpect(len(downloaded)).To(Equal(len(largeContent)))\n207: \t\t})\n208: \t})\n209: \n210: \tContext(\"CodeInterpreter Error Handling\", func() {\n211: \t\tIt(\"should reject invalid spec\", func() {\n212: \t\t\tci := &runtimev1alpha1.CodeInterpreter{\n213: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n214: \t\t\t\t\tName:      \"test-invalid-spec\",\n215: \t\t\t\t\tNamespace: f.Namespace(),\n216: \t\t\t\t},\n217: \t\t\t\tSpec: runtimev1alpha1.CodeInterpreterSpec{},\n218: \t\t\t}\n219: \n220: \t\t\t_, err := helper.CreateCodeInterpreter(ctx, ci)\n221: \t\t\tExpect(err).To(HaveOccurred())\n222: \t\t})\n223: \n224: \t\tIt(\"should reject non-existent session invocation\", func() {\n225: \t\t\t_, err := helper.ExecuteCode(ctx, \"non-existent-session\", `print(\"test\")`, \"\")\n226: \t\t\tExpect(err).To(HaveOccurred())\n227: \t\t})\n228: \n229: \t\tIt(\"should handle malformed code\", func() {\n230: \t\t\tci := framework.NewTestPythonCodeInterpreter(\"test-malformed\")\n231: \t\t\tci.Namespace = f.Namespace()\n232: \n233: \t\t\t_, err := helper.CreateCodeInterpreter(ctx, ci)\n234: \t\t\tExpect(err).NotTo(HaveOccurred())\n235: \n236: \t\t\terr = helper.WaitForCodeInterpreterReady(ctx, ci.Name, 5*time.Minute)\n237: \t\t\tExpect(err).NotTo(HaveOccurred())\n238: \n239: \t\t\treq := framework.NewTestSessionRequest(\"CodeInterpreter\", ci.Name, f.Namespace())\n240: \t\t\tresp, err := helper.CreateSession(ctx, req)\n241: \t\t\tExpect(err).NotTo(HaveOccurred())\n242: \t\t\tsessionID := resp.SessionID\n243: \n244: \t\t\texecResp, err := helper.ExecuteCode(ctx, sessionID, \"invalid code\", \"\")\n245: \t\t\tExpect(err).NotTo(HaveOccurred())\n246: \t\t\tExpect(execResp.ExitCode).NotTo(Equal(0))\n247: \t\t})\n248: \t})\n249: \n250: \tContext(\"CodeInterpreter Concurrent Access\", func() {\n251: \t\tIt(\"should handle concurrent code executions\", func() {\n252: \t\t\tci := framework.NewTestPythonCodeInterpreter(\"test-concurrent-exec\")\n253: \t\t\tci.Namespace = f.Namespace()\n254: \n255: \t\t\t_, err := helper.CreateCodeInterpreter(ctx, ci)\n256: \t\t\tExpect(err).NotTo(HaveOccurred())\n257: \n258: \t\t\terr = helper.WaitForCodeInterpreterReady(ctx, ci.Name, 5*time.Minute)\n259: \t\t\tExpect(err).NotTo(HaveOccurred())\n260: \n261: \t\t\treq := framework.NewTestSessionRequest(\"CodeInterpreter\", ci.Name, f.Namespace())\n262: \t\t\tresp, err := helper.CreateSession(ctx, req)\n263: \t\t\tExpect(err).NotTo(HaveOccurred())\n264: \t\t\tsessionID := resp.SessionID\n265: \n266: \t\t\terrors := make(chan error, 10)\n267: \t\t\tfor i := 0; i < 10; i++ {\n268: \t\t\t\tgo func(id int) {\n269: \t\t\t\t\t_, err := helper.ExecuteCode(ctx, sessionID, `print(\"test\")`, \"\")\n270: \t\t\t\t\terrors <- err\n271: \t\t\t\t}(i)\n272: \t\t\t}\n273: \n274: \t\t\tfor i := 0; i < 10; i++ {\n275: \t\t\t\terr := <-errors\n276: \t\t\t\tExpect(err).NotTo(HaveOccurred())\n277: \t\t\t}\n278: \t\t})\n279: \t})\n280: })\n\n(End of file - total 280 lines)\n</content>","metadata":{"preview":"package e2e\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/test/e2e/framework\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nvar _ = Describe(\"CodeInterpreter E2E\", func() {\n\tvar (\n\t\tf      *framework.TestFramework\n\t\thelper *framework.CodeInterpreterHelper\n\t\tctx    context.Context","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/codeinterpreter