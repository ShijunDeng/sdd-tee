{"type":"tool_use","timestamp":1775897286769,"sessionID":"ses_28446533dffeWNSknzWye520EF","part":{"id":"prt_d7bba1223001i7dz2A9fi64DT2","messageID":"msg_d7bb9fbb0001ZCUI0LKXky4zS5","sessionID":"ses_28446533dffeWNSknzWye520EF","type":"tool","tool":"read","callID":"toolu_tool-977cfd3306a340908e5813178c94b16e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/agentruntime/agentruntime_suite_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/agentruntime/agentruntime_suite_test.go</path>\n<type>file</type>\n<content>\n1: package e2e\n2: \n3: import (\n4: \t\"context\"\n5: \t\"sync\"\n6: \t\"time\"\n7: \n8: \t. \"github.com/onsi/ginkgo/v2\"\n9: \t. \"github.com/onsi/gomega\"\n10: \n11: \truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n12: \t\"github.com/volcano-sh/agentcube/test/e2e/framework\"\n13: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n14: )\n15: \n16: var _ = Describe(\"AgentRuntime E2E\", func() {\n17: \tvar (\n18: \t\tf      *framework.TestFramework\n19: \t\thelper *framework.AgentRuntimeHelper\n20: \t\tctx    context.Context\n21: \t\tcancel context.CancelFunc\n22: \t)\n23: \n24: \tBeforeSuite(func() {\n25: \t\tf = framework.NewDefaultFramework(\"agentruntime-e2e\")\n26: \t\tctx, cancel = context.WithTimeout(context.Background(), 15*time.Minute)\n27: \t\tdefer cancel()\n28: \n29: \t\tExpect(f.Setup(ctx)).To(Succeed())\n30: \t\tEventually(func() bool {\n31: \t\t\treturn f.AgentCubeReady()\n32: \t\t}, 10*time.Minute, 10*time.Second).Should(BeTrue())\n33: \n34: \t\thelper = framework.NewAgentRuntimeHelper(f)\n35: \t})\n36: \n37: \tAfterSuite(func() {\n38: \t\tif f != nil && !f.Options().SkipCleanup {\n39: \t\t\tExpect(f.Cleanup()).To(Succeed())\n40: \t\t}\n41: \t})\n42: \n43: \tBeforeEach(func() {\n44: \t\tctx, cancel = context.WithTimeout(context.Background(), 5*time.Minute)\n45: \t})\n46: \n47: \tAfterEach(func() {\n48: \t\tcancel()\n49: \t})\n50: \n51: \tContext(\"AgentRuntime Creation\", func() {\n52: \t\tIt(\"should create AgentRuntime successfully\", func() {\n53: \t\t\tart := framework.NewTestAgentRuntime(\"test-creation\")\n54: \t\t\tart.Namespace = f.Namespace()\n55: \n56: \t\t\tcreated, err := helper.CreateAgentRuntime(ctx, art)\n57: \t\t\tExpect(err).NotTo(HaveOccurred())\n58: \t\t\tExpect(created).NotTo(BeNil())\n59: \t\t\tExpect(created.Name).To(Equal(art.Name))\n60: \t\t\tExpect(created.Namespace).To(Equal(f.Namespace()))\n61: \t\t})\n62: \n63: \t\tIt(\"should apply default values\", func() {\n64: \t\t\tart := &runtimev1alpha1.AgentRuntime{\n65: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n66: \t\t\t\t\tName:      \"test-defaults\",\n67: \t\t\t\t\tNamespace: f.Namespace(),\n68: \t\t\t\t},\n69: \t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n70: \t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n71: \t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n72: \t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{\n73: \t\t\t\t\t\t\t\t{\n74: \t\t\t\t\t\t\t\t\tName:  \"agent\",\n75: \t\t\t\t\t\t\t\t\tImage: \"nginx:latest\",\n76: \t\t\t\t\t\t\t\t},\n77: \t\t\t\t\t\t\t},\n78: \t\t\t\t\t\t},\n79: \t\t\t\t\t},\n80: \t\t\t\t},\n81: \t\t\t}\n82: \n83: \t\t\tcreated, err := helper.CreateAgentRuntime(ctx, art)\n84: \t\t\tExpect(err).NotTo(HaveOccurred())\n85: \n86: \t\t\tExpect(created.Spec.SessionTimeout).NotTo(BeNil())\n87: \t\t\tExpect(created.Spec.SessionTimeout.Duration).To(Equal(15 * time.Minute))\n88: \t\t\tExpect(created.Spec.MaxSessionDuration).NotTo(BeNil())\n89: \t\t\tExpect(created.Spec.MaxSessionDuration.Duration).To(Equal(8 * time.Hour))\n90: \t\t})\n91: \n92: \t\tIt(\"should become ready\", func() {\n93: \t\t\tart := framework.NewTestAgentRuntime(\"test-ready\")\n94: \t\t\tart.Namespace = f.Namespace()\n95: \n96: \t\t\t_, err := helper.CreateAgentRuntime(ctx, art)\n97: \t\t\tExpect(err).NotTo(HaveOccurred())\n98: \n99: \t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n100: \t\t\tExpect(err).NotTo(HaveOccurred())\n101: \n102: \t\t\tfetched, err := helper.GetAgentRuntime(ctx, art.Name)\n103: \t\t\tExpect(err).NotTo(HaveOccurred())\n104: \n105: \t\t\tfor _, condition := range fetched.Status.Conditions {\n106: \t\t\t\tif condition.Type == \"Ready\" {\n107: \t\t\t\t\tExpect(condition.Status).To(Equal(metav1.ConditionTrue))\n108: \t\t\t\t}\n109: \t\t\t}\n110: \t\t})\n111: \t})\n112: \n113: \tContext(\"AgentRuntime Invocation\", func() {\n114: \t\tvar (\n115: \t\t\tart       *runtimev1alpha1.AgentRuntime\n116: \t\t\tsessionID string\n117: \t\t)\n118: \n119: \t\tBeforeEach(func() {\n120: \t\t\tart = framework.NewTestAgentRuntime(\"test-invocation\")\n121: \t\t\tart.Namespace = f.Namespace()\n122: \n123: \t\t\tvar err error\n124: \t\t\tart, err = helper.CreateAgentRuntime(ctx, art)\n125: \t\t\tExpect(err).NotTo(HaveOccurred())\n126: \n127: \t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n128: \t\t\tExpect(err).NotTo(HaveOccurred())\n129: \t\t})\n130: \n131: \t\tIt(\"should create session successfully\", func() {\n132: \t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n133: \n134: \t\t\tresp, err := helper.CreateSession(ctx, req)\n135: \t\t\tExpect(err).NotTo(HaveOccurred())\n136: \t\t\tExpect(resp).NotTo(BeNil())\n137: \t\t\tExpect(resp.SessionID).NotTo(BeEmpty())\n138: \t\t\tExpect(resp.SandboxID).NotTo(BeEmpty())\n139: \n140: \t\t\tsessionID = resp.SessionID\n141: \t\t})\n142: \n143: \t\tIt(\"should invoke session successfully\", func() {\n144: \t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n145: \t\t\tresp, err := helper.CreateSession(ctx, req)\n146: \t\t\tExpect(err).NotTo(HaveOccurred())\n147: \t\t\tsessionID = resp.SessionID\n148: \n149: \t\t\tpayload := framework.NewTestInvokePayloadWithString(\"hello\")\n150: \t\t\tinvokeResp, err := helper.InvokeSession(ctx, sessionID, payload, nil)\n151: \t\t\tExpect(err).NotTo(HaveOccurred())\n152: \t\t\tExpect(invokeResp).NotTo(BeNil())\n153: \t\t\tExpect(invokeResp.StatusCode).To(Equal(200))\n154: \t\t})\n155: \n156: \t\tIt(\"should handle concurrent invocations\", func() {\n157: \t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n158: \t\t\tresp, err := helper.CreateSession(ctx, req)\n159: \t\t\tExpect(err).NotTo(HaveOccurred())\n160: \t\t\tsessionID = resp.SessionID\n161: \n162: \t\t\terrors := make(chan error, 10)\n163: \t\t\tfor i := 0; i < 10; i++ {\n164: \t\t\t\tgo func(id int) {\n165: \t\t\t\t\tpayload := framework.NewTestInvokePayloadWithID(id)\n166: \t\t\t\t\t_, err := helper.InvokeSession(ctx, sessionID, payload, nil)\n167: \t\t\t\t\terrors <- err\n168: \t\t\t\t}(i)\n169: \t\t\t}\n170: \n171: \t\t\tfor i := 0; i < 10; i++ {\n172: \t\t\t\terr := <-errors\n173: \t\t\t\tExpect(err).NotTo(HaveOccurred())\n174: \t\t\t}\n175: \t\t})\n176: \t})\n177: \n178: \tContext(\"AgentRuntime Lifecycle\", func() {\n179: \t\tIt(\"should handle session expiration\", func() {\n180: \t\t\tart := framework.NewTestAgentRuntimeWithShortTimeout(\"test-expiration\")\n181: \t\t\tart.Namespace = f.Namespace()\n182: \n183: \t\t\t_, err := helper.CreateAgentRuntime(ctx, art)\n184: \t\t\tExpect(err).NotTo(HaveOccurred())\n185: \n186: \t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n187: \t\t\tExpect(err).NotTo(HaveOccurred())\n188: \n189: \t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n190: \t\t\tresp, err := helper.CreateSession(ctx, req)\n191: \t\t\tExpect(err).NotTo(HaveOccurred())\n192: \t\t\tsessionID := resp.SessionID\n193: \n194: \t\t\ttime.Sleep(35 * time.Second)\n195: \n196: \t\t\t_, err = helper.InvokeSession(ctx, sessionID, []byte(\"{}\"), nil)\n197: \t\t\tExpect(err).To(HaveOccurred())\n198: \t\t})\n199: \n200: \t\tIt(\"should delete session successfully\", func() {\n201: \t\t\tart := framework.NewTestAgentRuntime(\"test-deletion\")\n202: \t\t\tart.Namespace = f.Namespace()\n203: \n204: \t\t\t_, err := helper.CreateAgentRuntime(ctx, art)\n205: \t\t\tExpect(err).NotTo(HaveOccurred())\n206: \n207: \t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n208: \t\t\tExpect(err).NotTo(HaveOccurred())\n209: \n210: \t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n211: \t\t\tresp, err := helper.CreateSession(ctx, req)\n212: \t\t\tExpect(err).NotTo(HaveOccurred())\n213: \t\t\tsessionID := resp.SessionID\n214: \n215: \t\t\terr = helper.DeleteSession(ctx, sessionID)\n216: \t\t\tExpect(err).NotTo(HaveOccurred())\n217: \n218: \t\t\t_, err = helper.InvokeSession(ctx, sessionID, []byte(\"{}\"), nil)\n219: \t\t\tExpect(err).To(HaveOccurred())\n220: \t\t})\n221: \t})\n222: \n223: \tContext(\"AgentRuntime Error Handling\", func() {\n224: \t\tIt(\"should reject invalid spec\", func() {\n225: \t\t\tart := &runtimev1alpha1.AgentRuntime{\n226: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n227: \t\t\t\t\tName:      \"test-invalid-spec\",\n228: \t\t\t\t\tNamespace: f.Namespace(),\n229: \t\t\t\t},\n230: \t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n231: \t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n232: \t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n233: \t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{},\n234: \t\t\t\t\t\t},\n235: \t\t\t\t\t},\n236: \t\t\t\t},\n237: \t\t\t}\n238: \n239: \t\t\t_, err := helper.CreateAgentRuntime(ctx, art)\n240: \t\t\tExpect(err).To(HaveOccurred())\n241: \t\t})\n242: \n243: \t\tIt(\"should reject non-existent session invocation\", func() {\n244: \t\t\t_, err := helper.InvokeSession(ctx, \"non-existent-session\", []byte(\"{}\"), nil)\n245: \t\t\tExpect(err).To(HaveOccurred())\n246: \t\t})\n247: \n248: \t\tIt(\"should handle malformed payload\", func() {\n249: \t\t\tart := framework.NewTestAgentRuntime(\"test-malformed\")\n250: \t\t\tart.Namespace = f.Namespace()\n251: \n252: \t\t\t_, err := helper.CreateAgentRuntime(ctx, art)\n253: \t\t\tExpect(err).NotTo(HaveOccurred())\n254: \n255: \t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n256: \t\t\tExpect(err).NotTo(HaveOccurred())\n257: \n258: \t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n259: \t\t\tresp, err := helper.CreateSession(ctx, req)\n260: \t\t\tExpect(err).NotTo(HaveOccurred())\n261: \t\t\tsessionID := resp.SessionID\n262: \n263: \t\t\tinvokeResp, err := helper.InvokeSession(ctx, sessionID, []byte(\"invalid\"), nil)\n264: \t\t\tExpect(err).NotTo(HaveOccurred())\n265: \t\t\tExpect(invokeResp.StatusCode).NotTo(Equal(200))\n266: \t\t})\n267: \t})\n268: \n269: \tContext(\"AgentRuntime Concurrent Access\", func() {\n270: \t\tIt(\"should handle concurrent session creations\", func() {\n271: \t\t\tart := framework.NewTestAgentRuntime(\"test-concurrent-creation\")\n272: \t\t\tart.Namespace = f.Namespace()\n273: \n274: \t\t\t_, err := helper.CreateAgentRuntime(ctx, art)\n275: \t\t\tExpect(err).NotTo(HaveOccurred())\n276: \n277: \t\t\terr = helper.WaitForAgentRuntimeReady(ctx, art.Name, 5*time.Minute)\n278: \t\t\tExpect(err).NotTo(HaveOccurred())\n279: \n280: \t\t\terrors := make(chan error, 20)\n281: \t\t\tfor i := 0; i < 20; i++ {\n282: \t\t\t\tgo func() {\n283: \t\t\t\t\treq := framework.NewTestSessionRequest(\"AgentRuntime\", art.Name, f.Namespace())\n284: \t\t\t\t\t_, err := helper.CreateSession(ctx, req)\n285: \t\t\t\t\terrors <- err\n286: \t\t\t\t}()\n287: \t\t\t}\n288: \n289: \t\t\tfor i := 0; i < 20; i++ {\n290: \t\t\t\terr := <-errors\n291: \t\t\t\tExpect(err).NotTo(HaveOccurred())\n292: \t\t\t}\n293: \t\t})\n294: \t})\n295: })\n\n(End of file - total 295 lines)\n</content>","metadata":{"preview":"package e2e\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\n\truntimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n\t\"github.com/volcano-sh/agentcube/test/e2e/framework\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nvar _ = Describe(\"AgentRuntime E2E\", func() {\n\tvar (\n\t\tf      *framework.TestFramework\n\t\thelper *framework.AgentRuntimeHelper\n\t\tctx    context.Context","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/agentruntime/agentruntime_suite_test.go","time":{"start":1775897286751,"end":1775897286768}}}}
{"type":"tool_use","timestamp":1775897286771,"sessionID":"ses_28446533dffeWNSknzWye520EF","part":{"id":"prt_d7bba14a200151sxpRkTtryz0e","messageID":"msg_d7bb9fbb0001ZCUI0LKXky4zS5","sessionID":"ses_28446533dffeWNSknzWye520EF","type":"tool","tool":"read","callID":"toolu_tool-41c9d88ff3e74ff9814b372bb9711189","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/framework.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/framework.go</path>\n<type>file</type>\n<content>\n1: package framework\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"math/rand\"\n7: \t\"net/http\"\n8: \t\"sync\"\n9: \t\"time\"\n10: \n11: \tagentclient \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n12: \tcorev1 \"k8s.io/api/core/v1\"\n13: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n14: \t\"k8s.io/client-go/kubernetes\"\n15: \t\"k8s.io/client-go/rest\"\n16: \t\"k8s.io/client-go/tools/clientcmd\"\n17: )\n18: \n19: const (\n20: \tdefaultTimeout       = 5 * time.Minute\n21: \tdefaultPollInterval  = 1 * time.Second\n22: \tagentcubeNamespace   = \"agentcube-system\"\n23: \tagentcubeDeployment  = \"agentcube-controller-manager\"\n24: \tdefaultReadyTimeout  = 10 * time.Minute\n25: \tagentcubeService     = \"agentcube-webhook-service\"\n26: \tagentcubeWebhookPort = 9443\n27: )\n28: \n29: var (\n30: \tletters = []rune(\"abcdefghijklmnopqrstuvwxyz0123456789\")\n31: )\n32: \n33: type TestFramework struct {\n34: \tconfig      *rest.Config\n35: \tclientset   *kubernetes.Clientset\n36: \tagentClient *agentclient.Clientset\n37: \thttpClient  *http.Client\n38: \tnamespace   string\n39: \tclusterName string\n40: \tcleanup     []func() error\n41: \toptions     FrameworkOptions\n42: \tmu          sync.RWMutex\n43: \tinitialized bool\n44: }\n45: \n46: type FrameworkOptions struct {\n47: \tNamespace    string\n48: \tClusterName  string\n49: \tTimeout      time.Duration\n50: \tPollInterval time.Duration\n51: \tSkipCleanup  bool\n52: }\n53: \n54: func NewDefaultFramework(name string) *TestFramework {\n55: \treturn NewFramework(name, FrameworkOptions{})\n56: }\n57: \n58: func NewFramework(name string, opts FrameworkOptions) *TestFramework {\n59: \tif opts.Timeout == 0 {\n60: \t\topts.Timeout = defaultTimeout\n61: \t}\n62: \tif opts.PollInterval == 0 {\n63: \t\topts.PollInterval = defaultPollInterval\n64: \t}\n65: \tif opts.Namespace == \"\" {\n66: \t\topts.Namespace = fmt.Sprintf(\"e2e-test-%s-%s\", name, randomString(8))\n67: \t}\n68: \n69: \treturn &TestFramework{\n70: \t\tnamespace:   opts.Namespace,\n71: \t\tclusterName: opts.ClusterName,\n72: \t\toptions:     opts,\n73: \t\tcleanup:     make([]func() error, 0),\n74: \t\thttpClient: &http.Client{\n75: \t\t\tTimeout: opts.Timeout,\n76: \t\t},\n77: \t}\n78: }\n79: \n80: func (f *TestFramework) Setup(ctx context.Context) error {\n81: \tf.mu.Lock()\n82: \tdefer f.mu.Unlock()\n83: \n84: \tif f.initialized {\n85: \t\treturn nil\n86: \t}\n87: \n88: \tconfig, err := rest.InClusterConfig()\n89: \tif err != nil {\n90: \t\tkubeconfig := clientcmd.NewDefaultClientConfigLoadingRules().GetDefaultFilename()\n91: \t\tconfig, err = clientcmd.BuildConfigFromFlags(\"\", kubeconfig)\n92: \t\tif err != nil {\n93: \t\t\treturn fmt.Errorf(\"failed to build kubeconfig: %w\", err)\n94: \t\t}\n95: \t}\n96: \n97: \tf.config = config\n98: \n99: \tclientset, err := kubernetes.NewForConfig(config)\n100: \tif err != nil {\n101: \t\treturn fmt.Errorf(\"failed to create kubernetes clientset: %w\", err)\n102: \t}\n103: \tf.clientset = clientset\n104: \n105: \tagentClient, err := agentclient.NewForConfig(config)\n106: \tif err != nil {\n107: \t\treturn fmt.Errorf(\"failed to create agentcube clientset: %w\", err)\n108: \t}\n109: \tf.agentClient = agentClient\n110: \n111: \tns := &corev1.Namespace{\n112: \t\tObjectMeta: metav1.ObjectMeta{\n113: \t\t\tName: f.namespace,\n114: \t\t\tLabels: map[string]string{\n115: \t\t\t\t\"test\": \"e2e\",\n116: \t\t\t},\n117: \t\t},\n118: \t}\n119: \n120: \t_, err = f.clientset.CoreV1().Namespaces().Create(ctx, ns, metav1.CreateOptions{})\n121: \tif err != nil {\n122: \t\treturn fmt.Errorf(\"failed to create namespace %s: %w\", f.namespace, err)\n123: \t}\n124: \n125: \tf.registerCleanup(func() error {\n126: \t\treturn f.clientset.CoreV1().Namespaces().Delete(context.Background(), f.namespace, metav1.DeleteOptions{})\n127: \t})\n128: \n129: \tf.initialized = true\n130: \treturn nil\n131: }\n132: \n133: func (f *TestFramework) Cleanup() error {\n134: \tif f.options.SkipCleanup {\n135: \t\treturn nil\n136: \t}\n137: \n138: \tvar errors []error\n139: \n140: \tfor i := len(f.cleanup) - 1; i >= 0; i-- {\n141: \t\tif err := f.cleanup[i](); err != nil {\n142: \t\t\terrors = append(errors, err)\n143: \t\t}\n144: \t}\n145: \n146: \tif len(errors) > 0 {\n147: \t\treturn fmt.Errorf(\"cleanup failed with %d errors\", len(errors))\n148: \t}\n149: \n150: \treturn nil\n151: }\n152: \n153: func (f *TestFramework) registerCleanup(cleanup func() error) {\n154: \tf.cleanup = append(f.cleanup, cleanup)\n155: }\n156: \n157: func (f *TestFramework) Namespace() string {\n158: \treturn f.namespace\n159: }\n160: \n161: func (f *TestFramework) Clientset() *kubernetes.Clientset {\n162: \tf.mu.RLock()\n163: \tdefer f.mu.RUnlock()\n164: \treturn f.clientset\n165: }\n166: \n167: func (f *TestFramework) AgentClient() *agentclient.Clientset {\n168: \tf.mu.RLock()\n169: \tdefer f.mu.RUnlock()\n170: \treturn f.agentClient\n171: }\n172: \n173: func (f *TestFramework) HTTPClient() *http.Client {\n174: \treturn f.httpClient\n175: }\n176: \n177: func (f *TestFramework) Options() FrameworkOptions {\n178: \treturn f.options\n179: }\n180: \n181: func (f *TestFramework) AgentCubeReady() bool {\n182: \tctx, cancel := context.WithTimeout(context.Background(), defaultReadyTimeout)\n183: \tdefer cancel()\n184: \n185: \tdeployments := f.clientset.AppsV1().Deployments(agentcubeNamespace)\n186: \n187: \tfor {\n188: \t\tselect {\n189: \t\tcase <-ctx.Done():\n190: \t\t\treturn false\n191: \t\tdefault:\n192: \t\t\tdeploy, err := deployments.Get(context.Background(), agentcubeDeployment, metav1.GetOptions{})\n193: \t\t\tif err != nil {\n194: \t\t\t\ttime.Sleep(2 * time.Second)\n195: \t\t\t\tcontinue\n196: \t\t\t}\n197: \n198: \t\t\tif deploy.Status.ReadyReplicas == *deploy.Spec.Replicas {\n199: \t\t\t\treturn true\n200: \t\t\t}\n201: \n202: \t\t\ttime.Sleep(2 * time.Second)\n203: \t\t}\n204: \t}\n205: }\n206: \n207: func (f *TestFramework) WaitForAgentCubeReady(ctx context.Context) error {\n208: \tdeployments := f.clientset.AppsV1().Deployments(agentcubeNamespace)\n209: \n210: \tfor {\n211: \t\tselect {\n212: \t\tcase <-ctx.Done():\n213: \t\t\treturn fmt.Errorf(\"timeout waiting for AgentCube to be ready\")\n214: \t\tdefault:\n215: \t\t\tdeploy, err := deployments.Get(ctx, agentcubeDeployment, metav1.GetOptions{})\n216: \t\t\tif err != nil {\n217: \t\t\t\ttime.Sleep(2 * time.Second)\n218: \t\t\t\tcontinue\n219: \t\t\t}\n220: \n221: \t\t\tif deploy.Status.ReadyReplicas == *deploy.Spec.Replicas {\n222: \t\t\t\treturn nil\n223: \t\t\t}\n224: \n225: \t\t\ttime.Sleep(2 * time.Second)\n226: \t\t}\n227: \t}\n228: }\n229: \n230: func (f *TestFramework) WaitForPodReady(ctx context.Context, namespace, podName string) error {\n231: \tpods := f.clientset.CoreV1().Pods(namespace)\n232: \n233: \tfor {\n234: \t\tselect {\n235: \t\tcase <-ctx.Done():\n236: \t\t\treturn fmt.Errorf(\"timeout waiting for pod %s/%s to be ready\", namespace, podName)\n237: \t\tdefault:\n238: \t\t\tpod, err := pods.Get(ctx, podName, metav1.GetOptions{})\n239: \t\t\tif err != nil {\n240: \t\t\t\ttime.Sleep(f.options.PollInterval)\n241: \t\t\t\tcontinue\n242: \t\t\t}\n243: \n244: \t\t\tif pod.Status.Phase == corev1.PodRunning {\n245: \t\t\t\tfor _, containerStatus := range pod.Status.ContainerStatuses {\n246: \t\t\t\t\tif !containerStatus.Ready {\n247: \t\t\t\t\t\ttime.Sleep(f.options.PollInterval)\n248: \t\t\t\t\t\tcontinue\n249: \t\t\t\t\t}\n250: \t\t\t\t}\n251: \t\t\t\treturn nil\n252: \t\t\t}\n253: \n254: \t\t\ttime.Sleep(f.options.PollInterval)\n255: \t\t}\n256: \t}\n257: }\n258: \n259: func (f *TestFramework) WaitForServiceReady(ctx context.Context, namespace, serviceName string) error {\n260: \tservices := f.clientset.CoreV1().Services(namespace)\n261: \n262: \tfor {\n263: \t\tselect {\n264: \t\tcase <-ctx.Done():\n265: \t\t\treturn fmt.Errorf(\"timeout waiting for service %s/%s to be ready\", namespace, serviceName)\n266: \t\tdefault:\n267: \t\t\tsvc, err := services.Get(ctx, serviceName, metav1.GetOptions{})\n268: \t\t\tif err != nil {\n269: \t\t\t\ttime.Sleep(f.options.PollInterval)\n270: \t\t\t\tcontinue\n271: \t\t\t}\n272: \n273: \t\t\tif svc.Spec.Type == corev1.ServiceTypeLoadBalancer {\n274: \t\t\t\tif len(svc.Status.LoadBalancer.Ingress) > 0 {\n275: \t\t\t\t\treturn nil\n276: \t\t\t\t}\n277: \t\t\t} else if svc.Spec.Type == corev1.ServiceTypeNodePort {\n278: \t\t\t\treturn nil\n279: \t\t\t} else if svc.Spec.Type == corev1.ServiceTypeClusterIP {\n280: \t\t\t\treturn nil\n281: \t\t\t}\n282: \n283: \t\t\ttime.Sleep(f.options.PollInterval)\n284: \t\t}\n285: \t}\n286: }\n287: \n288: func randomString(n int) string {\n289: \tb := make([]rune, n)\n290: \tfor i := range b {\n291: \t\tb[i] = letters[rand.Intn(len(letters))]\n292: \t}\n293: \treturn string(b)\n294: }\n295: \n296: func init() {\n297: \trand.Seed(time.Now().UnixNano())\n298: }\n\n(End of file - total 298 lines)\n</content>","metadata":{"preview":"package framework\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"math/rand\"\n\t\"net/http\"\n\t\"sync\"\n\t\"time\"\n\n\tagentclient \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/client-go/to