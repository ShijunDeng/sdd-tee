st/e2e/framework/retry.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/assertions.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/timeout.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/helpers.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/framework.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/failure_handler.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/framework/fixtures.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/codeinterpreter/codeinterpreter_suite_test.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/integration/integration_suite_test.go\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/test/e2e/agentruntime/agentruntime_suite_test.go\n","exit":0,"description":"List Go test files in e2e directory","truncated":false},"title":"List Go test files in e2e directory","time":{"start":1775897279264,"end":1775897279356}}}}
