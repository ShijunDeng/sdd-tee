        raise CommandExecutionError(exit_code=1, stderr=error_msg)\n38: \n39:     def setup_pyshark(self) -> None:\n40:         \"\"\"Install pyshark library.\n41: \n42:         Raises:\n43:             CommandExecutionError: If installation fails.\n44:         \"\"\"\n45:         self.logger.info(\"Installing pyshark...\")\n46:         try:\n47:             self.client.execute_command(\"pip install pyshark>=0.6\", timeout=300)\n48:             self.logger.info(\"pyshark installed successfully\")\n49:         except Exception as e:\n50:             error_msg = f\"Failed to install pyshark: {e}\"\n51:             self.logger.error(error_msg)\n52:             raise CommandExecutionError(exit_code=1, stderr=error_msg)\n53: \n54:     def setup_visualization_libs(self) -> None:\n55:         \"\"\"Install matplotlib and pandas for visualization.\n56: \n57:         Raises:\n58:             CommandExecutionError: If installation fails.\n59:         \"\"\"\n60:         self.logger.info(\"Installing visualization libraries (matplotlib, pandas)...\")\n61:         try:\n62:             self.client.execute_command(\n63:                 \"pip install matplotlib>=3.7.0 pandas>=2.0.0\", timeout=300\n64:             )\n65:             self.logger.info(\"Visualization libraries installed successfully\")\n66:         except Exception as e:\n67:             error_msg = f\"Failed to install visualization libraries: {e}\"\n68:             self.logger.error(error_msg)\n69:             raise CommandExecutionError(exit_code=1, stderr=error_msg)\n70: \n71:     def verify_installation(self) -> bool:\n72:         \"\"\"Verify that all required libraries are installed.\n73: \n74:         Returns:\n75:             True if all libraries are installed, False otherwise.\n76:         \"\"\"\n77:         self.logger.info(\"Verifying library installations...\")\n78:         try:\n79:             verify_code = \"\"\"\n80: import sys\n81: try:\n82:     import scapy\n83:     import pyshark\n84:     import matplotlib\n85:     import pandas\n86:     print(\"All libraries installed successfully\")\n87:     sys.exit(0)\n88: except ImportError as e:\n89:     print(f\"Missing library: {e}\")\n90:     sys.exit(1)\n91: \"\"\"\n92:             output = self.client.run_code(\"python\", verify_code, timeout=60)\n93:             if \"All libraries installed successfully\" in output:\n94:                 self.logger.info(\"All libraries verified successfully\")\n95:                 return True\n96:             else:\n97:                 self.logger.warning(f\"Library verification failed: {output}\")\n98:                 return False\n99:         except Exception as e:\n100:             self.logger.error(f\"Error verifying installations: {e}\")\n101:             return False\n102: \n103:     def setup_all(self) -> bool:\n104:         \"\"\"Install all required libraries.\n105: \n106:         Returns:\n107:             True if all installations succeed, False otherwise.\n108: \n109:         Raises:\n110:             CommandExecutionError: If any installation fails.\n111:         \"\"\"\n112:         self.logger.info(\"Starting environment setup for PCAP analysis...\")\n113:         try:\n114:             self.setup_scapy()\n115:             self.setup_pyshark()\n116:             self.setup_visualization_libs()\n117:             return self.verify_installation()\n118:         except CommandExecutionError:\n119:             raise\n120:         except Exception as e:\n121:             error_msg = f\"Unexpected error during environment setup: {e}\"\n122:             self.logger.error(error_msg)\n123:             raise CommandExecutionError(exit_code=1, stderr=error_msg)\n\n(End of file - total 123 lines)\n</content>","metadata":{"preview":"\"\"\"Environment setup module for PCAP analysis libraries.\"\"\"\n\nimport logging\nfrom typing import TYPE_CHECKING\n\nif TYPE_CHECKING:\n    from agentcube import CodeInterpreterClient\n\nfrom agentcube.exceptions import CommandExecutionError\n\n\nclass EnvironmentSetup:\n    \"\"\"Handles installation and verification of PCAP analysis libraries.\"\"\"\n\n    def __init__(self, client: \"CodeInterpreterClient\") -> None:\n        \"\"\"Initialize environment setup.\n\n        Args:\n            client: CodeInterpreterClient instance.\n        \"\"\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/examples/pcap-analyzer/src/environment_setup.py","time":{"start":1775890903318,"end":1775890903333}}}}
{"type":"tool_use","timestamp":1775890903336,"sessionID":"ses_284a83a8fffe4tt8aAyvzY88X6","part":{"id":"prt_d7b58af6f00125h4AK5l84ufqz","messageID":"msg_d7b589251001CqGeW9P5xpMgLP","sessionID":"ses_284a83a8fffe4tt8aAyvzY88X6","type":"tool","tool":"read","callID":"toolu_tool-927b4ef987874b8f93589b78fc47cbf1","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/examples/pcap-analyzer/src/packet_statistics.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/examples/pcap-analyzer/src/packet_statistics.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Packet statistics module for PCAP analysis.\"\"\"\n2: \n3: import json\n4: import logging\n5: from typing import TYPE_CHECKING, Dict, List, Tuple\n6: \n7: if TYPE_CHECKING:\n8:     from agentcube import CodeInterpreterClient\n9: \n10: \n11: class PacketStatistics:\n12:     \"\"\"Analyzes basic packet statistics from PCAP files.\"\"\"\n13: \n14:     def __init__(self, client: \"CodeInterpreterClient\") -> None:\n15:         \"\"\"Initialize packet statistics analyzer.\n16: \n17:         Args:\n18:             client: CodeInterpreterClient instance.\n19:         \"\"\"\n20:         self.client = client\n21:         self.logger = logging.getLogger(__name__)\n22: \n23:     def analyze_packet_count(self, remote_path: str) -> int:\n24:         \"\"\"Count total packets in PCAP file.\n25: \n26:         Args:\n27:             remote_path: Path to the remote PCAP file.\n28: \n29:         Returns:\n30:             Total number of packets.\n31: \n32:         Raises:\n33:             Exception: If analysis fails.\n34:         \"\"\"\n35:         self.logger.info(f\"Analyzing packet count for: {remote_path}\")\n36: \n37:         code = f\"\"\"\n38: import sys\n39: from scapy.all import rdpcap\n40: \n41: try:\n42:     packets = rdpcap('{remote_path}')\n43:     packet_count = len(packets)\n44:     print(packet_count)\n45: except Exception as e:\n46:     print(f\"Error: {{e}}\", file=sys.stderr)\n47:     sys.exit(1)\n48: \"\"\"\n49: \n50:         try:\n51:             output = self.client.run_code(\"python\", code, timeout=300)\n52:             packet_count = int(output.strip())\n53:             self.logger.info(f\"Total packets: {packet_count}\")\n54:             return packet_count\n55:         except Exception as e:\n56:             error_msg = f\"Failed to analyze packet count: {e}\"\n57:             self.logger.error(error_msg)\n58:             raise Exception(error_msg)\n59: \n60:     def analyze_protocols(self, remote_path: str) -> Dict[str, Dict[str, int]]:\n61:         \"\"\"Identify and count protocols in PCAP file.\n62: \n63:         Args:\n64:             remote_path: Path to the remote PCAP file.\n65: \n66:         Returns:\n67:             Dictionary mapping protocol names to counts and percentages.\n68: \n69:         Raises:\n70:             Exception: If analysis fails.\n71:         \"\"\"\n72:         self.logger.info(f\"Analyzing protocols for: {remote_path}\")\n73: \n74:         code = f\"\"\"\n75: import json\n76: import sys\n77: from scapy.all import rdpcap\n78: \n79: try:\n80:     packets = rdpcap('{remote_path}')\n81:     protocol_counts = {{}}\n82: \n83:     for packet in packets:\n84:         if packet.haslayer('IP'):\n85:             proto = packet['IP'].proto\n86:             if proto == 6:\n87:                 protocol = 'TCP'\n88:             elif proto == 17:\n89:                 protocol = 'UDP'\n90:             elif proto == 1:\n91:                 protocol = 'ICMP'\n92:             else:\n93:                 protocol = f'Other ({proto})'\n94:         elif packet.haslayer('IPv6'):\n95:             protocol = 'IPv6'\n96:         elif packet.haslayer('ARP'):\n97:             protocol = 'ARP'\n98:         else:\n99:             protocol = 'Other'\n100: \n101:         protocol_counts[protocol] = protocol_counts.get(protocol, 0) + 1\n102: \n103:     total = sum(protocol_counts.values())\n104:     result = {{\n105:         'protocols': protocol_counts,\n106:         'distribution': {{\n107:             proto: round((count / total) * 100, 2)\n108:             for proto, count in protocol_counts.items()\n109:         }}\n110:     }}\n111: \n112:     print(json.dumps(result))\n113: except Exception as e:\n114:     print(f\"Error: {{e}}\", file=sys.stderr)\n115:     sys.exit(1)\n116: \"\"\"\n117: \n118:         try:\n119:             output = self.client.run_code(\"python\", code, timeout=300)\n120:             result = json.loads(output.strip())\n121:             self.logger.info(f\"Protocols analyzed: {result['protocols']}\")\n122:             return result\n123:         except Exception as e:\n124:             error_msg = f\"Failed to analyze protocols: {e}\"\n125:             self.logger.error(error_msg)\n126:             raise Exception(error_msg)\n127: \n128:     def analyze_time_range(self, remote_path: str) -> Tuple[float, float, float]:\n129:         \"\"\"Calculate time range of packets in PCAP file.\n130: \n131:         Args:\n132:             remote_path: Path to the remote PCAP file.\n133: \n134:         Returns:\n135:             Tuple of (start_timestamp, end_timestamp, duration_seconds).\n136: \n137:         Raises:\n138:             Exception: If analysis fails.\n139:         \"\"\"\n140:         self.logger.info(f\"Analyzing time range for: {remote_path}\")\n141: \n142:         code = f\"\"\"\n143: import json\n144: import sys\n145: from scapy.all import rdpcap\n146: \n147: try:\n148:     packets = rdpcap('{remote_path}')\n149: \n150:     if not packets:\n151:         print(json.dumps({{'error': 'No packets found'}}))\n152:         sys.exit(1)\n153: \n154:     start_time = float(packets[0].time)\n155:     end_time = float(packets[-1].time)\n156:     duration = end_time - start_time\n157: \n158:     result = {{\n159:         'start_timestamp': start_time,\n160:         'end_timestamp': end_time,\n161:         'duration_seconds': duration\n162:     }}\n163: \n164:     print(json.dumps(result))\n165: except Exception as e:\n166:     print(f\"Error: {{e}}\", file=sys.stderr)\n167:     sys.exit(1)\n168: \"\"\"\n169: \n170:         try:\n171:             output = self.client.run_code(\"python\", code, timeout=300)\n172:             result = json.loads(output.strip())\n173: \n174:             if \"error\" in result:\n175:                 raise Exception(result[\"error\"])\n176: \n177:             time_range = (\n178:                 result[\"start_timestamp\"],\n179:                 result[\"end_timestamp\"],\n180:                 result[\"duration_seconds\"],\n181:             )\n182: \n183:             self.logger.info(\n184:                 f\"Time range: {time_range[0]} to {time_range[1]} \"\n185:                 f\"({time_range[2]:.2f} seconds)\"\n186:             )\n187:             return time_range\n188:         except Exception as e:\n189:             error_msg = f\"Failed to analyze time range: {e}\"\n190:             self.logger.error(error_msg)\n191:             raise Exception(error_msg)\n192: \n193:     def calculate_protocol_distribution(\n194:         self, protocol_counts: Dict[str, int]\n195:     ) -> Dict[str, float]:\n196:         \"\"\"Calculate percentage distribution for protocols.\n197: \n198:         Args:\n199:             protocol_counts: Dictionary mapping protocols to counts.\n200: \n201:         Returns:\n202:             Dictionary mapping protocols to percentages.\n203:         \"\"\"\n204:         self.logger.info(\"Calculating protocol distribution\")\n205: \n206:         total = sum(protocol_counts.values())\n207:         if total == 0:\n208:             return {}\n209: \n210:         distribution = {\n211:             proto: round((count / total) * 100, 2)\n212:             for proto, count in protocol_counts.items()\n213:         }\n214: \n215:         self.logger.info(f\"Protocol distribution: {distribution}\")\n216:         return distribution\n\n(End of file - total 216 lines)\n</content>","metadata":{"preview":"\"\"\"Packet statistics module for PCAP analysis.\"\"\"\n\nimport json\nimport logging\nfrom typing import TYPE_CHECKING, Dict, List, Tuple\n\nif TYPE_CHECKING:\n    from agentcube import CodeInterpreterClient\n\n\nclass PacketStatistics:\n    \"\"\"Analyzes basic packet statistics from PCAP files.\"\"\"\n\n    def __init__(self, client: \"CodeInterpreterClient\") -> None:\n        \"\"\"Initialize packet statistics analyzer.\n\n        Args:\n            client: CodeInterpreterClient instance.\n        \"\"\"\n        self.client = client","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/examples/pcap-analyzer/src/packet_statistics.py","time":{"start":1775890903321,"end":1775890903335}}}}
{"type":"tool_use","timestamp":1775890903339,"sessionID":"ses_284a83a8fffe4tt8aAyvzY88X6","part":{"id":"prt_d7b58b0fb001VZD6YPJk1xqas0","messageID":"msg_d7b589251001CqGeW9P5xpMgLP","sessionID":"ses_284a83a8fffe4tt8aAyvzY88X6","type":"tool","tool":"read","callID":"toolu_tool-0a0e6d6f3b1240bc938c87c222554dd8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/examples/pcap-analyzer/src/report_generator.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/examples/pcap-analyzer/src/report_generator.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Report generation module for PCAP analysis results.\"\"\"\n2: \n3: import logging\n4: import time\n5: from datetime import datetime\n6: from typing import TYPE_CHECKING, Any, Dict, List\n7: \n8: if TYPE_CHECKING:\n9:     from agentcube import CodeInterpreterClient\n10: \n11: \n12: class ReportGenerator:\n13:     \"\"\"Generates comprehensive reports from PCAP analysis results.\"\"\"\n14: \n15:     def __init__(self, client: \"CodeInterpreterClient\") -> None:\n16:         \"\"\"Initialize report generator.\n17: \n18:         Args:\n19:             client: CodeInterpreterClient instance.\n20:         \"\"\"\n21:         self.client = client\n22:         self.logger = logging.getLogger(__name__)\n23: \n24:     def generate_report(\n25:         self,\n26:         analysis_results: Dict[str, Any],\n27:         output_path: str,\n28:         format: str = \"markdown\",\n29:     ) -> str:\n30:         \"\"\"Generate a report in the specified format.\n31: \n32:         Args:\n33:             analysis_results: Dictionary containing all analysis results.\n34:             output_path: Remote path to save the report.\n35:             format: Report format, either \"markdown\" or \"html\".\n36: \n37:         Returns:\n38:             Remote path to the generated report.\n39: \n40:         Raises:\n41:             ValueError: If format is not supported.\n42:             Exception: If report generation fails.\n43:         \"\"\"\n44:         self.logger.info(f\"Generating {format} report: {output_path}\")\n45: \n46:         if format == \"markdown\":\n47:             return self.generate_markdown_report(analysis_results, output_path)\n48:         elif format == \"html\":\n49:             return self.generate_html_report(analysis_results, output_path)\n50:         else:\n51:             raise ValueError(f\"Unsupported report format: {format}\")\n52: \n53:     def generate_markdown_report(\n54:         self, analysis_results: Dict[str, Any], output_path: str\n55:     ) -> str:\n56:         \"\"\"Generate a markdown report.\n57: \n58:         Args:\n59:             analysis_results: Dictionary containing all analysis results.\n60:             output_path: Remote path to save the report.\n61: \n62:         Returns:\n63:             Remote path to the generated report.\n64: \n65:         Raises:\n66:             Exception: If report generation fails.\n67:         \"\"\"\n68:         report_lines = []\n69: \n70:         metadata = analysis_results.get(\"metadata\", {})\n71:         report_lines.append(\"# PCAP Analysis Report\")\n72:         report_lines.append(\"\")\n73: \n74:         if metadata:\n75:             report_lines.append(\"## Metadata\")\n76:             report_lines.append(\"\")\n77:             for key, value in metadata.items():\n78:                 report_lines.append(f\"- **{key}**: {value}\")\n79:             report_lines.append(\"\")\n80: \n81:         if \"basic_stats\" in analysis_results:\n82:             report_lines.append(\"## Basic Statistics\")\n83:             report_lines.append(\"\")\n84:             stats = analysis_results[\"basic_stats\"]\n85:             if \"packet_count\" in stats:\n86:                 report_lines.append(f\"- **Total Packets**: {stats['packet_count']}\")\n87:             if \"time_range\" in stats:\n88:                 start, end, duration = stats[\"time_range\"]\n89:                 report_lines.append(f\"- **Time Range**: {start} to {end}\")\n90:                 report_lines.append(f\"- **Duration**: {duration:.2f} seconds\")\n91:             if \"protocols\" in stats:\n92:                 report_lines.append(\"- **Protocol Distribution**:\")\n93:                 for proto, count in stats[\"protocols\"].items():\n94:                     pct = stats.get(\"distribution\", {}).get(proto, 0)\n95:                     report_lines.append(f\"  - {proto}: {count} ({pct}%)\")\n96:             report_lines.append(\"\")\n97: \n98:         if \"top_talkers\" in analysis_results:\n99:             report_lines.append(\"## Top Talkers\")\n100:             report_lines.append(\"\")\n101:             talkers = analysis_results[\"top_talkers\"]\n102:             if \"top_source_ips\" in talkers:\n103:                 report_lines.append(\"### Top Source IPs (by packet count)\")\n104:                 report_lines.append(\"\")\n105:                 for ip, count in talkers[\"top_source_ips\"][:10]:\n106:                     report_lines.append(f\"- {ip}: {count} packets\")\n107:                 report_lines.append(\"\")\n108:             if \"top_destination_ips\" in talkers:\n109:                 report_lines.append(\"### Top Destination IPs (by packet count)\")\n110:                 report_lines.append(\"\")\n111:                 for ip, count in talkers[\"top_destination_ips\"][:10]:\n112:                     report_lines.append(f\"- {ip}: {count} packets\")\n113:                 report_lines.append(\"\")\n114: \n115:         if \"port_analysis\" in analysis_results:\n116:             report_lines.append(\"## Port Analysis\")\n117:             report_lines.append(\"\")\n118:             ports = analysis_results[\"port_analysis\"]\n119:             if \"top_dest_ports\" in ports:\n120:                 report_lines.append(\"### Top Destination Ports\")\n121:                 report_lines.append(\"\")\n122:                 for port, count in ports[\"top_dest_ports\"][:10]:\n123:                     report_lines.append(f\"- Port {port}: {count} packets\")\n124:                 report_lines.append(\"\")\n125:             if \"ports_with_services\" in ports:\n126:                 report_lines.append(\"### Ports with Services\")\n127:                 report_lines.append(\"\")\n128:                 for port, service, count in ports[\"ports_with_services\"][:10]:\n129:                     report_lines.append(f\"- Port {port} ({service}): {count} packets\")\n130:                 report_lines.append(\"\")\n131: \n132:         if \"http_analysis\" in analysis_results:\n133:             report_lines.append(\"## HTTP Analysis\")\n134:             report_lines.append(\"\")\n135:             http = analysis_results[\"http_analysis\"]\n136:             if \"status_codes\" in http:\n137:                 report_lines.append(\"### HTTP Status Codes\")\n138:                 report_lines.append(\"\")\n139:                 for code, count in http[\"status_codes\"].items():\n140:                     report_lines.append(f\"- {code}: {count}\")\n141:                 report_lines.append(\"\")\n142:             if \"top_hosts\" in http:\n143:                 report_lines.append(\"### Top HTTP Hosts\")\n144:                 report_lines.append(\"\")\n145:                 for host, count in http[\"top_hosts\"][:10]:\n146:                     report_lines.append(f\"- {host}: {count} requests\")\n147:                 report_lines.append(\"\")\n148: \n149:         if \"dns_analysis\" in analysis_results:\n150:             report_lines.append(\"## DNS Analysis\")\n151:             report_lines.append(\"\")\n152:             dns = analysis_results[\"dns_analysis\"]\n153:             if \"top_domains\" in dns:\n154:                 report_lines.append(\"### Top Queried Domains\")\n155:                 report_lines.append(\"\")\n156:                 for domain, count in dns[\"top_domains\"][:10]:\n157:                     report_lines.append(f\"- {domain}: {count} queries\")\n158:                 report_lines.append(\"\")\n159:             if \"response_types\" in dns:\n160:                 report_lines.append(\"### DNS Response Types\")\n161:                 report_lines.append(\"\")\n162:                 for rtype, count in dns[\"response_types\"].items():\n163:                     report_lines.append(f\"- {rtype}: {count}\")\n164:                 report_lines.append(\"\")\n165:             if \"failures\" in dns:\n166:                 report_lines.append(\"### DNS Failures\")\n167:                 report_lines.append(\"\")\n168:                 failures = dns[\"failures\"]\n169:                 if failures:\n170:                     for domain in failures[:10]:\n171:                         report_lines.append(f\"- {domain}\")\n172:                 else:\n173:                     report_lines.append(\"No DNS failures detected.\")\n174:                 report_lines.append(\"\")\n175: \n176:         if \"visualizations\" in analysis_results:\n177:             report_lines.append(\"## Visualizations\")\n178:             report_lines.append(\"\")\n179:             for viz_name, viz_path in analysis_results[\"visualizations\"].items():\n180:                 report_lines.append(f\"### {viz_name}\")\n181:                 report_lines.append(\"\")\n182:                 report_lines.append(f\"![{viz_name}]({viz_path})\")\n183:                 report_lines.append(\"\")\n184: \n185:         report_content = \"\\n\".join(report_lines)\n186: \n187:         try:\n188:             self.client.write_file(report_content, output_path)\n189:             self.logger.info(f\"Markdown report saved: {output_path}\")\n190:             return output_path\n191:         except Exception as e:\n192:             error_msg = f\"Failed to generate markdown report: {e}\"\n193:             self.logger.error(error_msg)\n194:             raise Exception(error_msg)\n195: \n196:     def generate_html_report(\n197:         self, analysis_results: Dict[str, Any], output_path: str\n198:     ) -> str:\n199:         \"\"\"Generate an HTML report.\n200: \n201:         Args:\n202:             analysis_results: Dictionary containing all analysis results.\n203:             output_path: Remote path to save the report.\n204: \n205:         Returns:\n206:             Remote path to the generated report.\n207: \n208:         Raises:\n209:             Exception: If report generation fails.\n210:         \"\"\"\n211:         html_parts = []\n212: \n213:         html_parts.append(\"<!DOCTYPE html>\")\n214:         html_parts.append(\"<html>\")\n215:         html_parts.append(\"<head>\")\n216:         html_parts.append(\"<meta charset='UTF-8'>\")\n217:         html_parts.append(\"<title>PCAP Analysis Report</title>\")\n218:         html_parts.append(\"<style>\")\n219:         html_parts.append(\"body { font-family: Arial, sans-serif; margin: 40px; }\")\n220:         html_parts.append(\"h1 { color: #333; }\")\n221:         html_parts.append(\"h2 { color: #666; margin-top: 30px; }\")\n222:         html_parts.append(\"table { border-collapse: collapse; width: 100%; }\")\n223:         html_parts.append(\"th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }\")\n224:         html_parts.append(\"th { background-color: #4CAF50; color: white; }\")\n225:         html_parts.append(\"tr:nth-child(even) { background-color: #f2f2f2; }\")\n226:         html_parts.append(\"img { max-width: 100%; height: auto; margin: 20px 0; }\")\n227:         html_parts.append(\"</style>\")\n228:         html_parts.append(\"</head>\")\n229:         html_parts.append(\"<body>\")\n230: \n231:         html_parts.append(\"<h1>PCAP Analysis Report</h1>\")\n232: \n233:         metadata = analysis_results.get(\"metadata\", {})\n234:         if metadata:\n235:             html_parts.append(\"<h2>Metadata</h2>\")\n236:             html_parts.append(\"<ul>\")\n237:             for key, value in metadata.items():\n238:                 html_parts.append(f\"<li><strong>{key}:</strong> {value}</li>\")\n239:             html_parts.append(\"</ul>\")\n240: \n241:         def dict_to_html_table(d: Dict[str, Any]) -> str:\n242:             rows = []\n243:             for key, value in d.items():\n244:                 if isinstance(value, (list, tuple)):\n245:                     value = str(value)\n246:                 rows.append(f\"<tr><td>{key}</td><td>{value}</td></tr>\")\n247:             return \"\\n\".join(rows)\n248: \n249:         if \"basic_stats\" in analysis_results:\n250:             stats = analysis_results[\"basic_stats\"]\n251:             html_parts.append(\"<h2>Basic Statistics</h2>\")\n252:             html_parts.append(\"<table>\")\n253:             html_parts.append(dict_to_html_table(stats))\n254:             html_parts.append(\"</table>\")\n255: \n256:         if \"top_talkers\" in analysis_results:\n257:             talkers = analysis_results[\"top_talkers\"]\n258:             html_parts.append(\"<h2>Top Talkers</h2>\")\n259:             html_parts.append(\"<table>\")\n260:             html_parts.append(dict_to_html_table(talkers))\n261:             html_parts.append(\"</table>\")\n262: \n263:         if \"port_analysis\" in analysis_results:\n264:             ports = analysis_results[\"port_analysis\"]\n265:             html_parts.append(\"<h2>Port Analysis</h2>\")\n266:             html_parts.append(\"<table>\")\n267:             html_parts.append(dict_to_html_table(ports))\n268:             html_parts.append(\"</table>\")\n269: \n270:         if \"http_analysis\" in analysis_results:\n271:             http = analysis_results[\"http_analysis\"]\n272:             html_parts.append(\"<h2>HTTP Analysis</h2>\")\n273:             html_parts.append(\"<table>\")\n274:             html_parts.append(dict_to_html_table(http))\n275:             html_parts.append(\"</table>\")\n276: \n277:         if \"dns_analysis\" in analysis_results:\n278:             dns = analysis_results[\"dns_analysis\"]\n279:             html_parts.append(\"<h2>DNS Analysis</h2>\")\n280:             html_parts.append(\"<table>\")\n281:             html_parts.append(dict_to_html_table(dns))\n282:             html_parts.append(\"</table>\")\n283: \n284:         if \"visualizations\" in analysis_results:\n285:             html_parts.append(\"<h2>Visualizations</h2>\")\n286:             for viz_name, viz_path in analysis_results[\"visualizations\"].items():\n287:                 html_parts.append(f\"<h3>{viz_name}</h3>\")\n288:                 html_parts.append(f'<img src=\"{viz_path}\" alt=\"{viz_name}\">')\n289: \n290:         html_parts.append(\"</body>\")\n291:         html_parts.append(\"</html>\")\n292: \n293:         html_content = \"\\n\".join(html_parts)\n294: \n295:         try:\n296:             self.client.write_file(html_content, output_path)\n297:             self.logger.info(f\"HTML report saved: {output_path}\")\n298:             return output_path\n299:         except Exception as e:\n300:             error_msg = f\"Failed to generate HTML report: {e}\"\n301:             self.logger.error(error_msg)\n302:             raise Exception(error_msg)\n303: \n304:     def add_metadata(\n305:         self, analysis_results: Dict[str, Any], file_name: str\n306:     ) -> Dict[str, Any]:\n307:         \"\"\"Add metadata to analysis results.\n308: \n309:         Args:\n310:             analysis_results: Dictionary containing analysis results.\n311:             file_name: Name of the analyzed PCAP file.\n312: \n313:         Returns:\n314:             Updated analysis results with metadata.\n315:         \"\"\"\n316:         metadata = {\n317:             \"file_name\": file_name,\n318:             \"timestamp\": datetime.now().isoformat(),\n319:             \"execution_time\": time.time(),\n320:         }\n321:         analysis_results[\"metadata\"] = metadata\n322:         return analysis_results\n\n(End of file - total 322 lines)\n</content>","metadata":{"preview":"\"\"\"Report generation module for PCAP analysis results.\"\"\"\n\nimport logging\nimport time\nfrom datetime import datetime\nfrom typing import TYPE_CHECKING, Any, Dict, List\n\nif TYPE_CHECKING:\n    from agentcube import CodeInterpreterClient\n\n\nclass ReportGenerator:\n    \"\"\"Generates comprehensive reports from PCAP analysis results.\"\"\"\n\n    def __init__(self, client: \"CodeInterpreterClient\") -> None:\n        \"\"\"Initialize report generator.\n\n        Args:\n            client: CodeInterpreterClient instance.\n        \"\"\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/examples/pcap-analyzer/src/report_generator.py","time":{"start":1775890903323,"end":1775890903337}}}}
