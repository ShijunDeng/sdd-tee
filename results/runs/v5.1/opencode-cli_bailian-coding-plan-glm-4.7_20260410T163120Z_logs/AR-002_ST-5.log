ailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/README.md\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/README.md\n@@ -119,12 +119,15 @@\n ```\n \n ### Using with client-go\n \n+#### Creating an AgentRuntime\n+\n ```go\n import (\n     \"context\"\n-    \n+    \"time\"\n+\n     \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n     \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n )\n@@ -147,9 +150,9 @@\n                 },\n             },\n         },\n     }\n-    \n+\n     _, err := clientset.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(\n         context.TODO(),\n         runtime,\n         metav1.CreateOptions{},\n@@ -157,8 +160,45 @@\n     return err\n }\n ```\n \n+#### Creating a CodeInterpreter\n+\n+```go\n+import (\n+    \"context\"\n+    \"time\"\n+\n+    \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n+    \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n+    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n+)\n+\n+func createCodeInterpreter(clientset *versioned.Clientset) error {\n+    timeout := &metav1.Duration{Duration: 5 * time.Minute}\n+\n+    interpreter := &v1alpha1.CodeInterpreter{\n+        ObjectMeta: metav1.ObjectMeta{\n+            Name:      \"python-interpreter\",\n+            Namespace: \"default\",\n+        },\n+        Spec: v1alpha1.CodeInterpreterSpec{\n+            Image:   \"python:3.11-slim\",\n+            Runtime: \"python\",\n+            Timeout: timeout,\n+            EnabledPackages: []string{\"numpy\", \"pandas\"},\n+        },\n+    }\n+\n+    _, err := clientset.RuntimeV1alpha1().CodeInterpreters(\"default\").Create(\n+        context.TODO(),\n+        interpreter,\n+        metav1.CreateOptions{},\n+    )\n+    return err\n+}\n+```\n+\n ## Testing\n \n Run the unit tests:\n \n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/README.md","before":"# AgentCube Runtime API\n\nThis package contains the Kubernetes API definitions for the AgentCube runtime resources.\n\n## API Group\n\n- **Group**: `runtime.agentcube.volcano.sh`\n- **Version**: `v1alpha1`\n- **Kinds**: `AgentRuntime`, `CodeInterpreter`\n\n## Types\n\n### AgentRuntime\n\n`AgentRuntime` is a Kubernetes custom resource that defines a sandbox orchestration runtime for managing the lifecycle of agent pods.\n\n#### Spec\n\nThe `AgentRuntimeSpec` defines the desired state of an AgentRuntime:\n\n- **PodTemplate** (*SandboxTemplate, required): Template for creating sandbox pods\n- **SessionTimeout** (*metav1.Duration, optional): Timeout for idle sessions before cleanup (default: 15m)\n- **MaxSessionDuration** (*metav1.Duration, optional): Maximum allowed duration for a session (default: 8h)\n\n#### Status\n\nThe `AgentRuntimeStatus` defines the observed state of an AgentRuntime:\n\n- **Conditions** ([]metav1.Condition, optional): List of conditions representing the runtime state\n- **ObservedGeneration** (int64, optional): Most recent generation observed by the controller\n\n### CodeInterpreter\n\n`CodeInterpreter` is a Kubernetes custom resource that defines a code execution environment for managing interpreter sandboxes.\n\n#### Spec\n\nThe `CodeInterpreterSpec` defines the desired state of a CodeInterpreter:\n\n- **Image** (string, required): Container image for the interpreter (e.g., \"python:3.11-slim\")\n- **Runtime** (string, optional): Execution environment type (default: \"python\")\n  - Allowed values: `python`, `javascript`, `typescript`, `go`\n- **Timeout** (*metav1.Duration, optional): Maximum execution time for code snippets (default: 5m)\n- **Resources** (*SandboxContainerResources, optional): Compute resource requirements\n- **Env** ([]SandboxEnvVar, optional): Environment variables to inject\n- **EnabledPackages** ([]string, optional): Allowed packages for the interpreter\n\n#### Status\n\nThe `CodeInterpreterStatus` defines the observed state of a CodeInterpreter:\n\n- **Ready** (bool, optional): Whether the interpreter is ready to execute code\n- **Conditions** ([]metav1.Condition, optional): List of conditions representing the interpreter state\n- **ObservedGeneration** (int64, optional): Most recent generation observed by the controller\n\n### SandboxTemplate\n\nDefines the template for creating sandbox pods:\n\n- **Metadata** (*SandboxMetadata, optional): Labels and annotations for the pod\n- **Spec** (SandboxPodSpec, required): Pod specification\n\n### SandboxPodSpec\n\nDefines the pod specification for sandbox pods:\n\n- **Containers** ([]SandboxContainer, required): List of containers in the pod\n- **NodeSelector** (map[string]string, optional): Node selection constraints\n- **Affinity** (*SandboxAffinity, optional): Pod scheduling constraints\n- **Tolerations** ([]SandboxToleration, optional): Pod tolerations\n- **ResourceRequirements** (*SandboxResources, optional): Resource requirements for the pod\n- **Volumes** ([]SandboxVolume, optional): Pod volumes\n\n## Usage\n\n### Creating an AgentRuntime\n\n```yaml\napiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: AgentRuntime\nmetadata:\n  name: example-runtime\n  namespace: default\nspec:\n  podTemplate:\n    spec:\n      containers:\n      - name: agent\n        image: agent:latest\n        ports:\n        - containerPort: 8080\n```\n\n### Creating a CodeInterpreter\n\n```yaml\napiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: CodeInterpreter\nmetadata:\n  name: python-interpreter\n  namespace: default\nspec:\n  image: python:3.11-slim\n  runtime: python\n  timeout: 5m\n  resources:\n    limits:\n      cpu: \"1\"\n      memory: \"1Gi\"\n    requests:\n      cpu: \"250m\"\n      memory: \"256Mi\"\n  enabledPackages:\n  - numpy\n  - pandas\n  env:\n  - name: PYTHON_VERSION\n    value: \"3.11\"\n```\n\n### Using with client-go\n\n```go\nimport (\n    \"context\"\n    \n    \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n    \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc createAgentRuntime(clientset *versioned.Clientset) error {\n    runtime := &v1alpha1.AgentRuntime{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"example-runtime\",\n            Namespace: \"default\",\n        },\n        Spec: v1alpha1.AgentRuntimeSpec{\n            PodTemplate: &v1alpha1.SandboxTemplate{\n                Spec: v1alpha1.SandboxPodSpec{\n                    Containers: []v1alpha1.SandboxContainer{\n                        {\n                            Name:  \"agent\",\n                            Image: \"agent:latest\",\n                        },\n                    },\n                },\n            },\n        },\n    }\n    \n    _, err := clientset.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(\n        context.TODO(),\n        runtime,\n        metav1.CreateOptions{},\n    )\n    return err\n}\n```\n\n## Testing\n\nRun the unit tests:\n\n```bash\ngo test ./pkg/apis/runtime/v1alpha1/...\n```\n\n## CRD Installation\n\nThe CRD YAML file is located at `config/crd/bases/runtime.agentcube.volcano.sh_agentruntimes.yaml`.\n\nInstall the CRD:\n\n```bash\nkubectl apply -f config/crd/bases/runtime.agentcube.volcano.sh_agentruntimes.yaml\n```\n\nVerify installation:\n\n```bash\nkubectl get crd agentruntimes.runtime.agentcube.volcano.sh\n```\n\n## Features\n\n- **Kubernetes-native**: Leverages Kubernetes CRD and controller patterns\n- **Type-safe**: Generated Go types for compile-time safety\n- **Extensible**: Supports custom pod templates, volumes, and configurations\n- **Status tracking**: Built-in conditions for runtime state management\n- **Resource management**: Support for resource limits, requests, and scheduling constraints\n- **Security**: Full support for security contexts, capabilities, and seccomp profiles\n\n## License\n\nCopyright 2024 Volcano Authors.","after":"# AgentCube Runtime API\n\nThis package contains the Kubernetes API definitions for the AgentCube runtime resources.\n\n## API Group\n\n- **Group**: `runtime.agentcube.volcano.sh`\n- **Version**: `v1alpha1`\n- **Kinds**: `AgentRuntime`, `CodeInterpreter`\n\n## Types\n\n### AgentRuntime\n\n`AgentRuntime` is a Kubernetes custom resource that defines a sandbox orchestration runtime for managing the lifecycle of agent pods.\n\n#### Spec\n\nThe `AgentRuntimeSpec` defines the desired state of an AgentRuntime:\n\n- **PodTemplate** (*SandboxTemplate, required): Template for creating sandbox pods\n- **SessionTimeout** (*metav1.Duration, optional): Timeout for idle sessions before cleanup (default: 15m)\n- **MaxSessionDuration** (*metav1.Duration, optional): Maximum allowed duration for a session (default: 8h)\n\n#### Status\n\nThe `AgentRuntimeStatus` defines the observed state of an AgentRuntime:\n\n- **Conditions** ([]metav1.Condition, optional): List of conditions representing the runtime state\n- **ObservedGeneration** (int64, optional): Most recent generation observed by the controller\n\n### CodeInterpreter\n\n`CodeInterpreter` is a Kubernetes custom resource that defines a code execution environment for managing interpreter sandboxes.\n\n#### Spec\n\nThe `CodeInterpreterSpec` defines the desired state of a CodeInterpreter:\n\n- **Image** (string, required): Container image for the interpreter (e.g., \"python:3.11-slim\")\n- **Runtime** (string, optional): Execution environment type (default: \"python\")\n  - Allowed values: `python`, `javascript`, `typescript`, `go`\n- **Timeout** (*metav1.Duration, optional): Maximum execution time for code snippets (default: 5m)\n- **Resources** (*SandboxContainerResources, optional): Compute resource requirements\n- **Env** ([]SandboxEnvVar, optional): Environment variables to inject\n- **EnabledPackages** ([]string, optional): Allowed packages for the interpreter\n\n#### Status\n\nThe `CodeInterpreterStatus` defines the observed state of a CodeInterpreter:\n\n- **Ready** (bool, optional): Whether the interpreter is ready to execute code\n- **Conditions** ([]metav1.Condition, optional): List of conditions representing the interpreter state\n- **ObservedGeneration** (int64, optional): Most recent generation observed by the controller\n\n### SandboxTemplate\n\nDefines the template for creating sandbox pods:\n\n- **Metadata** (*SandboxMetadata, optional): Labels and annotations for the pod\n- **Spec** (SandboxPodSpec, required): Pod specification\n\n### SandboxPodSpec\n\nDefines the pod specification for sandbox pods:\n\n- **Containers** ([]SandboxContainer, required): List of containers in the pod\n- **NodeSelector** (map[string]string, optional): Node selection constraints\n- **Affinity** (*SandboxAffinity, optional): Pod scheduling constraints\n- **Tolerations** ([]SandboxToleration, optional): Pod tolerations\n- **ResourceRequirements** (*SandboxResources, optional): Resource requirements for the pod\n- **Volumes** ([]SandboxVolume, optional): Pod volumes\n\n## Usage\n\n### Creating an AgentRuntime\n\n```yaml\napiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: AgentRuntime\nmetadata:\n  name: example-runtime\n  namespace: default\nspec:\n  podTemplate:\n    spec:\n      containers:\n      - name: agent\n        image: agent:latest\n        ports:\n        - containerPort: 8080\n```\n\n### Creating a CodeInterpreter\n\n```yaml\napiVersion: runtime.agentcube.volcano.sh/v1alpha1\nkind: CodeInterpreter\nmetadata:\n  name: python-interpreter\n  namespace: default\nspec:\n  image: python:3.11-slim\n  runtime: python\n  timeout: 5m\n  resources:\n    limits:\n      cpu: \"1\"\n      memory: \"1Gi\"\n    requests:\n      cpu: \"250m\"\n      memory: \"256Mi\"\n  enabledPackages:\n  - numpy\n  - pandas\n  env:\n  - name: PYTHON_VERSION\n    value: \"3.11\"\n```\n\n### Using with client-go\n\n#### Creating an AgentRuntime\n\n```go\nimport (\n    \"context\"\n    \"time\"\n\n    \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n    \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc createAgentRuntime(clientset *versioned.Clientset) error {\n    runtime := &v1alpha1.AgentRuntime{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"example-runtime\",\n            Namespace: \"default\",\n        },\n        Spec: v1alpha1.AgentRuntimeSpec{\n            PodTemplate: &v1alpha1.SandboxTemplate{\n                Spec: v1alpha1.SandboxPodSpec{\n                    Containers: []v1alpha1.SandboxContainer{\n                        {\n                            Name:  \"agent\",\n                            Image: \"agent:latest\",\n                        },\n                    },\n                },\n            },\n        },\n    }\n\n    _, err := clientset.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(\n        context.TODO(),\n        runtime,\n        metav1.CreateOptions{},\n    )\n    return err\n}\n```\n\n#### Creating a CodeInterpreter\n\n```go\nimport (\n    \"context\"\n    \"time\"\n\n    \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n    \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc createCodeInterpreter(clientset *versioned.Clientset) error {\n    timeout := &metav1.Duration{Duration: 5 * time.Minute}\n\n    interpreter := &v1alpha1.CodeInterpreter{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"python-interpreter\",\n            Namespace: \"default\",\n        },\n        Spec: v1alpha1.CodeInterpreterSpec{\n            Image:   \"python:3.11-slim\",\n            Runtime: \"python\",\n            Timeout: timeout,\n            EnabledPackages: []string{\"numpy\", \"pandas\"},\n        },\n    }\n\n    _, err := clientset.RuntimeV1alpha1().CodeInterpreters(\"default\").Create(\n        context.TODO(),\n        interpreter,\n        metav1.CreateOptions{},\n    )\n    return err\n}\n```\n\n## Testing\n\nRun the unit tests:\n\n```bash\ngo test ./pkg/apis/runtime/v1alpha1/...\n```\n\n## CRD Installation\n\nThe CRD YAML file is located at `config/crd/bases/runtime.agentcube.volcano.sh_agentruntimes.yaml`.\n\nInstall the CRD:\n\n```bash\nkubectl apply -f config/crd/bases/runtime.agentcube.volcano.sh_agentruntimes.yaml\n```\n\nVerify installation:\n\n```bash\nkubectl get crd agentruntimes.runtime.agentcube.volcano.sh\n```\n\n## Features\n\n- **Kubernetes-native**: Leverages Kubernetes CRD and controller patterns\n- **Type-safe**: Generated Go types for compile-time safety\n- **Extensible**: Supports custom pod templates, volumes, and configurations\n- **Status tracking**: Built-in conditions for runtime state management\n- **Resource management**: Support for resource limits, requests, and scheduling constraints\n- **Security**: Full support for security contexts, capabilities, and seccomp profiles\n\n## License\n\nCopyright 2024 Volcano Authors.","additions":42,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/README.md","time":{"start":1775840581701,"end":1775840581718}}}}
