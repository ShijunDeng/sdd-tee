rsioned.Clientset) error {\n    timeout := &metav1.Duration{Duration: 5 * time.Minute}\n\n    interpreter := &v1alpha1.CodeInterpreter{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"python-interpreter\",\n            Namespace: \"default\",\n        },\n        Spec: v1alpha1.CodeInterpreterSpec{\n            Image:   \"python:3.11-slim\",\n            Runtime: \"python\",\n            Timeout: timeout,\n            EnabledPackages: []string{\"numpy\", \"pandas\"},\n        },\n    }\n\n    _, err := clientset.RuntimeV1alpha1().CodeInterpreters(\"default\").Create(\n        context.TODO(),\n        interpreter,\n        metav1.CreateOptions{},\n    )\n    return err\n}\n```","oldString":"### Using with client-go\n\n```go\nimport (\n    \"context\"\n    \n    \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n    \"github.com/volcano-sh/agentcube/client-go/clientset/versioned\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc createAgentRuntime(clientset *versioned.Clientset) error {\n    runtime := &v1alpha1.AgentRuntime{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"example-runtime\",\n            Namespace: \"default\",\n        },\n        Spec: v1alpha1.AgentRuntimeSpec{\n            PodTemplate: &v1alpha1.SandboxTemplate{\n                Spec: v1alpha1.SandboxPodSpec{\n                    Containers: []v1alpha1.SandboxContainer{\n                        {\n                            Name:  \"agent\",\n                            Image: \"agent:latest\",\n                        },\n                    },\n                },\n            },\n        },\n    }\n    \n    _, err := clientset.RuntimeV1alpha1().AgentRuntimes(\"default\").Create(\n        context.TODO(),\n        runtime,\n        metav1.CreateOptions{},\n    )\n    return err\n}\n```"},"output":"Edit applied successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260