.Error(\"Conditions should be nil\")\n\t}\n}\n\nfunc TestCodeInterpreterTimeout(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tduration string\n\t\texpected time.Duration\n\t}{\n\t\t{\n\t\t\tname:     \"5 minutes\",\n\t\t\tduration: \"5m\",\n\t\t\texpected: 5 * time.Minute,\n\t\t},\n\t\t{\n\t\t\tname:     \"1 hour\",\n\t\t\tduration: \"1h\",\n\t\t\texpected: 1 * time.Hour,\n\t\t},\n\t\t{\n\t\t\tname:     \"30 seconds\",\n\t\t\tduration: \"30s\",\n\t\t\texpected: 30 * time.Second,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tdur, err := time.ParseDuration(tt.duration)\n\t\t\tif err != nil {\n\t\t\t\tt.Fatalf(\"Failed to parse duration %s: %v\", tt.duration, err)\n\t\t\t}\n\n\t\t\tif dur != tt.expected {\n\t\t\t\tt.Errorf(\"Expected duration %v, got %v\", tt.expected, dur)\n\t\t\t}\n\t\t})\n\t}\n}\n","additions":2,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/apis/runtime/v1alpha1/types_test.go","time":{"start":1775840540390,"end":1775840540600}}}}
