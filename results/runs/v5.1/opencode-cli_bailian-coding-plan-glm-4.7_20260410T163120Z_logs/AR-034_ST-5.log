tep in steps)\n    assert any('git diff --exit-code' in str(step) for step in steps)\n\n\ndef test_release_workflow_builds_multiarch():\n    \"\"\"Test Release workflow builds multi-architecture images.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['release']\n    steps = job['steps']\n\n    assert any('docker-buildx-push' in str(step) for step in steps)\n    assert any('docker-buildx-push-router' in str(step) for step in steps)\n    assert any('docker-buildx-push-picod' in str(step) for step in steps)\n\n\ndef test_release_workflow_triggers_on_main_and_tags():\n    \"\"\"Test Release workflow triggers on main and tags.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    assert 'push' in content['on']\n    assert 'main' in content['on']['push']['branches']\n    assert 'v*.*.*' in content['on']['push']['tags']\n\n\ndef test_release_workflow_uses_ghcr():\n    \"\"\"Test Release workflow uses GitHub Container Registry.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['release']\n    steps = job['steps']\n\n    assert any('ghcr.io' in str(step) for step in steps)\n    assert any('docker/login-action' in str(step) for step in steps)\n\n\ndef test_approve_workflow_uses_pull_request_target():\n    \"\"\"Test Approve workflow uses pull_request_target.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"approve.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    assert 'pull_request_target' in content['on']\n\n\ndef test_approve_workflow_approves_runs():\n    \"\"\"Test Approve workflow approves workflow runs.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"approve.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['approve']\n    steps = job['steps']\n\n    assert any('approveWorkflowRun' in str(step) for step in steps)\n\n\ndef test_dependencies_workflow_updates_go_and_python():\n    \"\"\"Test Dependencies workflow updates Go and Python dependencies.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"dependencies.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['update-dependencies']\n    steps = job['steps']\n\n    assert any('go get -u' in str(step) for step in steps)\n    assert any('go mod tidy' in str(step) for step in steps)\n    assert any('pip install --upgrade' in str(step) for step in steps)\n\n\ndef test_dependencies_workflow_scheduled():\n    \"\"\"Test Dependencies workflow runs on schedule.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"dependencies.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    assert 'schedule' in content['on']\n    assert len(content['on']['schedule']) > 0\n\n\ndef test_workflows_have_timeout():\n    \"\"\"Test that workflows have appropriate timeouts.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        for job_name, job in content['jobs'].items():\n            assert 'timeout-minutes' in job, f\"{workflow_file} job {job_name} missing timeout\"\n\n\ndef test_workflows_use_ubuntu_runner():\n    \"\"\"Test that workflows use ubuntu-latest runner.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        for job_name, job in content['jobs'].items():\n            assert 'runs-on' in job, f\"{workflow_file} job {job_name} missing runs-on\"\n            assert job['runs-on'] == 'ubuntu-latest', f\"{workflow_file} job {job_name} not using ubuntu-latest\"\n\n\ndef test_workflows_have_permissions():\n    \"\"\"Test that workflows have permissions configured.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'permissions' in content, f\"{workflow_file} missing permissions\"\n\n\ndef test_workflows_with_concurrency():\n    \"\"\"Test that appropriate workflows have concurrency control.\"\"\"\n    workflows_with_concurrency = [\n        'lint.yml',\n        'codegen-check.yml',\n        'coverage.yml',\n        'e2e.yml',\n        'python-sdk-tests.yml',\n        'python-lint.yml',\n        'spelling.yml',\n        'copyright.yml',\n        'dependencies.yml',\n    ]\n\n    for workflow_name in workflows_with_concurrency:\n        workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / workflow_name\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'concurrency' in content, f\"{workflow_file} missing concurrency\"\n\n\ndef test_workflows_use_pinned_action_versions():\n    \"\"\"Test that workflows use pinned action versions.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        for job_name, job in content['jobs'].items():\n            for step in job['steps']:\n                for key, value in step.items():\n                    if key == 'uses' and isinstance(value, str):\n                        if '@' in value:\n                            version = value.split('@')[1]\n                            assert version, f\"{workflow_file} job {job_name} step {key} has unpinned version\"\n                            assert not version.startswith('v') or version[1:].replace('.', '').isdigit(), \\\n                                f\"{workflow_file} job {job_name} step {key} uses unpinned version {version}\"\n\n\ndef test_workflow_names_are_descriptive():\n    \"\"\"Test that workflow names are descriptive.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'name' in content, f\"{workflow_file} missing name\"\n        assert len(content['name']) > 3, f\"{workflow_file} has too short name\"\n\n\nif __name__ == '__main__':\n    pytest.main([__file__, '-v'])","additions":9,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/github/test_workflows.py","time":{"start":1775886224696,"end":1775886225530}}}}
