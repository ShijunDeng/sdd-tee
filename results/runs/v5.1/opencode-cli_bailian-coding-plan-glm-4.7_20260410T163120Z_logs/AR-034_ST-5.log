ssert 'release-*' in triggers['pull_request']['branches']\n\n\ndef test_ci_workflow_builds_docker():\n    \"\"\"Test CI workflow includes Docker build step.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"ci.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['docker-build']\n    steps = [step['name'] if 'name' in step else list(step.keys())[0] for step in job['steps']]\n\n    assert 'Build Docker image' in steps\n    assert any('make docker-build' in str(step) for step in job['steps'])\n\n\ndef test_lint_workflow_path_filtering():\n    \"\"\"Test Lint workflow has correct path filtering.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"lint.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    # Get triggers (handle YAML 'on' keyword)\n    triggers = content.get('on', content.get(True, {}))\n    assert 'pull_request' in triggers\n    paths = triggers['pull_request']['paths']\n\n    assert '**/*.go' in paths\n    assert 'go.mod' in paths\n    assert 'go.sum' in paths\n\n\ndef test_lint_workflow_runs_golangci_lint():\n    \"\"\"Test Lint workflow runs golangci-lint.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"lint.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['golangci-lint']\n    steps = job['steps']\n\n    assert any('make lint' in str(step) for step in steps)\n\n\ndef test_codegen_workflow_checks_drift():\n    \"\"\"Test Codegen Check workflow verifies no drift.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"codegen-check.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['codegen-check']\n    steps = job['steps']\n\n    assert any('make gen-check' in str(step) for step in steps)\n    assert any('git diff --exit-code' in str(step) for step in steps)\n\n\ndef test_coverage_workflow_race_detection():\n    \"\"\"Test Coverage workflow runs with race detection.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"coverage.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['coverage']\n    steps = job['steps']\n\n    assert any('-race' in str(step) and 'go test' in str(step) for step in steps)\n\n\ndef test_coverage_workflow_uploads_artifact():\n    \"\"\"Test Coverage workflow uploads coverage artifact.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"coverage.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['coverage']\n    steps = job['steps']\n\n    assert any('upload-artifact' in str(step) for step in steps)\n\n\ndef test_e2e_workflow_uses_kind():\n    \"\"\"Test E2E workflow uses Kind cluster.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"e2e.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['e2e']\n    steps = job['steps']\n\n    assert any('kind-action' in str(step) for step in steps)\n    assert any('make e2e' in str(step) for step in steps)\n\n\ndef test_e2e_workflow_captures_logs_on_failure():\n    \"\"\"Test E2E workflow captures logs on failure.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"e2e.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['e2e']\n    steps = job['steps']\n\n    # Check for failure condition in step\n    has_failure_condition = False\n    for step in steps:\n        if isinstance(step, dict):\n            if 'if' in step and 'failure()' in step['if']:\n                has_failure_condition = True\n                break\n\n    assert has_failure_condition, \"E2E workflow missing failure condition\"\n\n\ndef test_e2e_workflow_cleanup_always_runs():\n    \"\"\"Test E2E workflow cleanup always runs.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"e2e.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['e2e']\n    steps = job['steps']\n\n    # Check for always condition and cleanup step\n    has_cleanup = False\n    for step in steps:\n        if isinstance(step, dict):\n            if 'if' in step and 'always()' in step['if']:\n                if 'run' in step and 'e2e-clean' in step['run']:\n                    has_cleanup = True\n                    break\n\n    assert has_cleanup, \"E2E workflow missing cleanup with always condition\"\n\n\ndef test_python_sdk_workflow_runs_pytest():\n    \"\"\"Test Python SDK workflow runs pytest.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"python-sdk-tests.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['python-sdk-tests']\n    steps = job['steps']\n\n    assert any('pytest' in str(step) for step in steps)\n\n\ndef test_python_lint_workflow_runs_ruff():\n    \"\"\"Test Python Lint workflow runs Ruff.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"python-lint.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['python-lint']\n    steps = job['steps']\n\n    assert any('ruff' in str(step) for step in steps)\n    assert any('--config pyproject.toml' in str(step) for step in steps)\n\n\ndef test_spelling_workflow_runs_codespell():\n    \"\"\"Test Spelling workflow runs codespell.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"spelling.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['codespell']\n    steps = job['steps']\n\n    assert any('codespell' in str(step) for step in steps)\n    assert any('--check-filenames' in str(step) for step in steps)\n    assert any('--ignore-words-list' in str(step) for step in steps)\n\n\ndef test_copyright_workflow_verifies_headers():\n    \"\"\"Test Copyright workflow verifies headers.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"copyright.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['copyright-check']\n    steps = job['steps']\n\n    assert any('make gen-copyright' in str(step) for step in steps)\n    assert any('git diff --exit-code' in str(step) for step in steps)\n\n\ndef test_release_workflow_builds_multiarch():\n    \"\"\"Test Release workflow builds multi-architecture images.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['release']\n    steps = job['steps']\n\n    assert any('docker-buildx-push' in str(step) for step in steps)\n    assert any('docker-buildx-push-router' in str(step) for step in steps)\n    assert any('docker-buildx-push-picod' in str(step) for step in steps)\n\n\ndef test_release_workflow_triggers_on_main_and_tags():\n    \"\"\"Test Release workflow triggers on main and tags.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    # Get triggers (handle YAML 'on' keyword)\n    triggers = content.get('on', content.get(True, {}))\n    assert 'push' in triggers\n    assert 'main' in triggers['push']['branches']\n    assert 'v*.*.*' in triggers['push']['tags']\n\n\ndef test_release_workflow_uses_ghcr():\n    \"\"\"Test Release workflow uses GitHub Container Registry.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['release']\n    steps = job['steps']\n\n    assert any('ghcr.io' in str(step) for step in steps)\n    assert any('docker/login-action' in str(step) for step in steps)\n\n\ndef test_approve_workflow_uses_pull_request_target():\n    \"\"\"Test Approve workflow uses pull_request_target.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"approve.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    # Get triggers (handle YAML 'on' keyword)\n    triggers = content.get('on', content.get(True, {}))\n    assert 'pull_request_target' in triggers\n\n\ndef test_approve_workflow_approves_runs():\n    \"\"\"Test Approve workflow approves workflow runs.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"approve.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['approve']\n    steps = job['steps']\n\n    assert any('approveWorkflowRun' in str(step) for step in steps)\n\n\ndef test_dependencies_workflow_updates_go_and_python():\n    \"\"\"Test Dependencies workflow updates Go and Python dependencies.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"dependencies.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['update-dependencies']\n    steps = job['steps']\n\n    assert any('go get -u' in str(step) for step in steps)\n    assert any('go mod tidy' in str(step) for step in steps)\n    assert any('pip install --upgrade' in str(step) for step in steps)\n\n\ndef test_dependencies_workflow_scheduled():\n    \"\"\"Test Dependencies workflow runs on schedule.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"dependencies.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    # Get triggers (handle YAML 'on' keyword)\n    triggers = content.get('on', content.get(True, {}))\n    assert 'schedule' in triggers\n    assert len(triggers['schedule']) > 0\n\n\ndef test_workflows_have_timeout():\n    \"\"\"Test that workflows have appropriate timeouts.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        for job_name, job in content['jobs'].items():\n            assert 'timeout-minutes' in job, f\"{workflow_file} job {job_name} missing timeout\"\n\n\ndef test_workflows_use_ubuntu_runner():\n    \"\"\"Test that workflows use ubuntu-latest runner.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        for job_name, job in content['jobs'].items():\n            assert 'runs-on' in job, f\"{workflow_file} job {job_name} missing runs-on\"\n            assert job['runs-on'] == 'ubuntu-latest', f\"{workflow_file} job {job_name} not using ubuntu-latest\"\n\n\ndef test_workflows_have_permissions():\n    \"\"\"Test that workflows have permissions configured.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'permissions' in content, f\"{workflow_file} missing permissions\"\n\n\ndef test_workflows_with_concurrency():\n    \"\"\"Test that appropriate workflows have concurrency control.\"\"\"\n    workflows_with_concurrency = [\n        'lint.yml',\n        'codegen-check.yml',\n        'coverage.yml',\n        'e2e.yml',\n        'python-sdk-tests.yml',\n        'python-lint.yml',\n        'spelling.yml',\n        'copyright.yml',\n        'dependencies.yml',\n    ]\n\n    for workflow_name in workflows_with_concurrency:\n        workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / workflow_name\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'concurrency' in content, f\"{workflow_file} missing concurrency\"\n\n\ndef test_workflows_use_pinned_action_versions():\n    \"\"\"Test that workflows use pinned action versions.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        for job_name, job in content['jobs'].items():\n            for step in job['steps']:\n                for key, value in step.items():\n                    if key == 'uses' and isinstance(value, str):\n                        if '@' in value:\n                            version = value.split('@')[1]\n                            assert version, f\"{workflow_file} job {job_name} step {key} has unpinned version\"\n                            assert not version.startswith('v') or version[1:].replace('.', '').isdigit(), \\\n                                f\"{workflow_file} job {job_name} step {key} uses unpinned version {version}\"\n\n\ndef test_workflow_names_are_descriptive():\n    \"\"\"Test that workflow names are descriptive.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'name' in content, f\"{workflow_file} missing name\"\n        assert len(content['name']) > 3, f\"{workflow_file} has too short name\"\n\n\nif __name__ == '__main__':\n    pytest.main([__file__, '-v'])","after":"\"\"\"Unit tests for GitHub Actions workflows.\"\"\"\nimport os\nimport yaml\nimport pytest\nfrom pathlib import Path\n\n\ndef get_workflow_files():\n    \"\"\"Get all workflow YAML files.\"\"\"\n    workflows_dir = Path(__file__).parent.parent.parent / \".github\" / \"workflows\"\n    return list(workflows_dir.glob(\"*.yml\"))\n\n\ndef test_all_workflows_have_valid_yaml():\n    \"\"\"Test that all workflow files have valid YAML syntax.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            try:\n                yaml.safe_load(f)\n            except yaml.YAMLError as e:\n                pytest.fail(f\"Invalid YAML in {workflow_file}: {e}\")\n\n\ndef test_all_workflows_have_required_fields():\n    \"\"\"Test that all workflows have required top-level fields.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'name' in content, f\"{workflow_file} missing 'name' field\"\n        # 'on' is a boolean keyword in YAML, so check both 'on' and True\n        assert 'on' in content or True in content, f\"{workflow_file} missing 'on' field\"\n        assert 'permissions' in content, f\"{workflow_file} missing 'permissions' field\"\n        assert 'jobs' in content, f\"{workflow_file} missing 'jobs' field\"\n\n\ndef test_ci_workflow_triggers():\n    \"\"\"Test CI workflow triggers on correct branches.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"ci.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    # Get triggers (handle YAML 'on' keyword)\n    triggers = content.get('on', content.get(True, {}))\n    assert 'pull_request' in triggers\n    assert 'main' in triggers['pull_request']['branches']\n    assert 'release-*' in triggers['pull_request']['branches']\n\n\ndef test_ci_workflow_builds_docker():\n    \"\"\"Test CI workflow includes Docker build step.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"ci.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['docker-build']\n    steps = [step['name'] if 'name' in step else list(step.keys())[0] for step in job['steps']]\n\n    assert 'Build Docker image' in steps\n    assert any('make docker-build' in str(step) for step in job['steps'])\n\n\ndef test_lint_workflow_path_filtering():\n    \"\"\"Test Lint workflow has correct path filtering.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"lint.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    # Get triggers (handle YAML 'on' keyword)\n    triggers = content.get('on', content.get(True, {}))\n    assert 'pull_request' in triggers\n    paths = triggers['pull_request']['paths']\n\n    assert '**/*.go' in paths\n    assert 'go.mod' in paths\n    assert 'go.sum' in paths\n\n\ndef test_lint_workflow_runs_golangci_lint():\n    \"\"\"Test Lint workflow runs golangci-lint.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"lint.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['golangci-lint']\n    steps = job['steps']\n\n    assert any('make lint' in str(step) for step in steps)\n\n\ndef test_codegen_workflow_checks_drift():\n    \"\"\"Test Codegen Check workflow verifies no drift.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"codegen-check.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['codegen-check']\n    steps = job['steps']\n\n    assert any('make gen-check' in str(step) for step in steps)\n    assert any('git diff --exit-code' in str(step) for step in steps)\n\n\ndef test_coverage_workflow_race_detection():\n    \"\"\"Test Coverage workflow runs with race detection.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"coverage.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['coverage']\n    steps = job['steps']\n\n    assert any('-race' in str(step) and 'go test' in str(step) for step in steps)\n\n\ndef test_coverage_workflow_uploads_artifact():\n    \"\"\"Test Coverage workflow uploads coverage artifact.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"coverage.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['coverage']\n    steps = job['steps']\n\n    assert any('upload-artifact' in str(step) for step in steps)\n\n\ndef test_e2e_workflow_uses_kind():\n    \"\"\"Test E2E workflow uses Kind cluster.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"e2e.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['e2e']\n    steps = job['steps']\n\n    assert any('kind-action' in str(step) for step in steps)\n    assert any('make e2e' in str(step) for step in steps)\n\n\ndef test_e2e_workflow_captures_logs_on_failure():\n    \"\"\"Test E2E workflow captures logs on failure.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"e2e.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['e2e']\n    steps = job['steps']\n\n    # Check for failure condition in step\n    has_failure_condition = False\n    for step in steps:\n        if isinstance(step, dict):\n            if 'if' in step and 'failure()' in step['if']:\n                has_failure_condition = True\n                break\n\n    assert has_failure_condition, \"E2E workflow missing failure condition\"\n\n\ndef test_e2e_workflow_cleanup_always_runs():\n    \"\"\"Test E2E workflow cleanup always runs.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"e2e.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['e2e']\n    steps = job['steps']\n\n    # Check for always condition and cleanup step\n    has_cleanup = False\n    for step in steps:\n        if isinstance(step, dict):\n            if 'if' in step and 'always()' in step['if']:\n                if 'run' in step and 'e2e-clean' in step['run']:\n                    has_cleanup = True\n                    break\n\n    assert has_cleanup, \"E2E workflow missing cleanup with always condition\"\n\n\ndef test_python_sdk_workflow_runs_pytest():\n    \"\"\"Test Python SDK workflow runs pytest.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"python-sdk-tests.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['python-sdk-tests']\n    steps = job['steps']\n\n    assert any('pytest' in str(step) for step in steps)\n\n\ndef test_python_lint_workflow_runs_ruff():\n    \"\"\"Test Python Lint workflow runs Ruff.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"python-lint.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['python-lint']\n    steps = job['steps']\n\n    assert any('ruff' in str(step) for step in steps)\n    assert any('--config pyproject.toml' in str(step) for step in steps)\n\n\ndef test_spelling_workflow_runs_codespell():\n    \"\"\"Test Spelling workflow runs codespell.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"spelling.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['codespell']\n    steps = job['steps']\n\n    assert any('codespell' in str(step) for step in steps)\n    assert any('--check-filenames' in str(step) for step in steps)\n    assert any('--ignore-words-list' in str(step) for step in steps)\n\n\ndef test_copyright_workflow_verifies_headers():\n    \"\"\"Test Copyright workflow verifies headers.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"copyright.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['copyright-check']\n    steps = job['steps']\n\n    assert any('make gen-copyright' in str(step) for step in steps)\n    assert any('git diff --exit-code' in str(step) for step in steps)\n\n\ndef test_release_workflow_builds_multiarch():\n    \"\"\"Test Release workflow builds multi-architecture images.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['release']\n    steps = job['steps']\n\n    assert any('docker-buildx-push' in str(step) for step in steps)\n    assert any('docker-buildx-push-router' in str(step) for step in steps)\n    assert any('docker-buildx-push-picod' in str(step) for step in steps)\n\n\ndef test_release_workflow_triggers_on_main_and_tags():\n    \"\"\"Test Release workflow triggers on main and tags.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    # Get triggers (handle YAML 'on' keyword)\n    triggers = content.get('on', content.get(True, {}))\n    assert 'push' in triggers\n    assert 'main' in triggers['push']['branches']\n    assert 'v*.*.*' in triggers['push']['tags']\n\n\ndef test_release_workflow_uses_ghcr():\n    \"\"\"Test Release workflow uses GitHub Container Registry.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"release.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['release']\n    steps = job['steps']\n\n    assert any('ghcr.io' in str(step) for step in steps)\n    assert any('docker/login-action' in str(step) for step in steps)\n\n\ndef test_approve_workflow_uses_pull_request_target():\n    \"\"\"Test Approve workflow uses pull_request_target.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"approve.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    # Get triggers (handle YAML 'on' keyword)\n    triggers = content.get('on', content.get(True, {}))\n    assert 'pull_request_target' in triggers\n\n\ndef test_approve_workflow_approves_runs():\n    \"\"\"Test Approve workflow approves workflow runs.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"approve.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['approve']\n    steps = job['steps']\n\n    assert any('approveWorkflowRun' in str(step) for step in steps)\n\n\ndef test_dependencies_workflow_updates_go_and_python():\n    \"\"\"Test Dependencies workflow updates Go and Python dependencies.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"dependencies.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    job = content['jobs']['update-dependencies']\n    steps = job['steps']\n\n    assert any('go get -u' in str(step) for step in steps)\n    assert any('go mod tidy' in str(step) for step in steps)\n    assert any('pip install --upgrade' in str(step) for step in steps)\n\n\ndef test_dependencies_workflow_scheduled():\n    \"\"\"Test Dependencies workflow runs on schedule.\"\"\"\n    workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / \"dependencies.yml\"\n    with open(workflow_file, 'r') as f:\n        content = yaml.safe_load(f)\n\n    # Get triggers (handle YAML 'on' keyword)\n    triggers = content.get('on', content.get(True, {}))\n    assert 'schedule' in triggers\n    assert len(triggers['schedule']) > 0\n\n\ndef test_workflows_have_timeout():\n    \"\"\"Test that workflows have appropriate timeouts.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        for job_name, job in content['jobs'].items():\n            assert 'timeout-minutes' in job, f\"{workflow_file} job {job_name} missing timeout\"\n\n\ndef test_workflows_use_ubuntu_runner():\n    \"\"\"Test that workflows use ubuntu-latest runner.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        for job_name, job in content['jobs'].items():\n            assert 'runs-on' in job, f\"{workflow_file} job {job_name} missing runs-on\"\n            assert job['runs-on'] == 'ubuntu-latest', f\"{workflow_file} job {job_name} not using ubuntu-latest\"\n\n\ndef test_workflows_have_permissions():\n    \"\"\"Test that workflows have permissions configured.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'permissions' in content, f\"{workflow_file} missing permissions\"\n\n\ndef test_workflows_with_concurrency():\n    \"\"\"Test that appropriate workflows have concurrency control.\"\"\"\n    workflows_with_concurrency = [\n        'lint.yml',\n        'codegen-check.yml',\n        'coverage.yml',\n        'e2e.yml',\n        'python-sdk-tests.yml',\n        'python-lint.yml',\n        'spelling.yml',\n        'copyright.yml',\n        'dependencies.yml',\n    ]\n\n    for workflow_name in workflows_with_concurrency:\n        workflow_file = Path(__file__).parent.parent.parent / \".github\" / \"workflows\" / workflow_name\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'concurrency' in content, f\"{workflow_file} missing concurrency\"\n\n\ndef test_workflows_use_pinned_action_versions():\n    \"\"\"Test that workflows use pinned action versions.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        for job_name, job in content['jobs'].items():\n            for step in job['steps']:\n                for key, value in step.items():\n                    if key == 'uses' and isinstance(value, str):\n                        if '@' in value:\n                            version = value.split('@')[1]\n                            assert version, f\"{workflow_file} job {job_name} step {key} has unpinned version\"\n                            assert not version.startswith('v') or version[1:].replace('.', '').isdigit(), \\\n                                f\"{workflow_file} job {job_name} step {key} uses unpinned version {version}\"\n\n\ndef test_workflow_names_are_descriptive():\n    \"\"\"Test that workflow names are descriptive.\"\"\"\n    for workflow_file in get_workflow_files():\n        with open(workflow_file, 'r') as f:\n            content = yaml.safe_load(f)\n\n        assert 'name' in content, f\"{workflow_file} missing name\"\n        assert len(content['name']) >= 2, f\"{workflow_file} has too short name\"\n\n\nif __name__ == '__main__':\n    pytest.main([__file__, '-v'])","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/tests/github/test_workflows.py","time":{"start":1775886224704,"end":1775886225541}}}}
