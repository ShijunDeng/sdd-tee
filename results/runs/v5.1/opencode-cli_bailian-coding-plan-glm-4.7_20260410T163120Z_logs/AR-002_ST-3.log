n796: )\n797: \n798: var _ = Describe(\"AgentRuntime\", func() {\n799:     Describe(\"Spec defaults\", func() {\n800:         It(\"should default maxSessionDuration to 8h\", func() {\n801:             art := &v1alpha1.AgentRuntime{\n802:                 Spec: v1alpha1.AgentRuntimeSpec{},\n803:             }\n804:             // Controller-gen sets defaults; verify after defaulting\n805:             Expect(art.Spec.MaxSessionDuration).To(Equal(\"8h\"))\n806:         })\n807:     })\n808: \n809:     Describe(\"TargetPort validation\", func() {\n810:         It(\"should reject invalid protocol\", func() {\n811:             art := &v1alpha1.AgentRuntime{\n812:                 Spec: v1alpha1.AgentRuntimeSpec{\n813:                     TargetPort: []v1alpha1.TargetPort{\n814:                         {\n815:                             Port:     8080,\n816:                             Protocol: \"TCP\", // Invalid: must be HTTP or HTTPS\n817:                         },\n818:                     },\n819:                 },\n820:             }\n821:             // Validation will fail at API server level\n822:         })\n823:     })\n824: \n825:     Describe(\"DeepCopy\", func() {\n826:         It(\"should create independent copies\", func() {\n827:             original := &v1alpha1.AgentRuntime{\n828:                 ObjectMeta: metav1.ObjectMeta{\n829:                     Name: \"test\",\n830:                 },\n831:                 Spec: v1alpha1.AgentRuntimeSpec{\n832:                     MaxSessionDuration: \"8h\",\n833:                 },\n834:             }\n835:             copy := original.DeepCopy()\n836:             \n837:             Expect(copy).NotTo(BeIdenticalTo(original))\n838:             Expect(copy.Name).To(Equal(original.Name))\n839:             Expect(copy.Spec.MaxSessionDuration).To(Equal(original.Spec.MaxSessionDuration))\n840:         })\n841:     })\n842: })\n843: ```\n844: \n845: ### Client-Go Integration Tests\n846: \n847: **File**: `pkg/apis/runtime/v1alpha1/client_test.go`\n848: \n849: ```go\n850: package v1alpha1_test\n851: \n852: import (\n853:     \"context\"\n854:     \"testing\"\n855:     \"time\"\n856: \n857:     . \"github.com/onsi/ginkgo/v2\"\n858:     . \"github.com/onsi/gomega\"\n859:     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n860:     \"k8s.io/client-go/kubernetes/scheme\"\n861:     \"sigs.k8s.io/controller-runtime/pkg/client\"\n862:     \"sigs.k8s.io/controller-runtime/pkg/envtest\"\n863: \n864:     runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n865: )\n866: \n867: var (\n868:     envTest *envtest.Environment\n869:     k8sClient client.Client\n870: )\n871: \n872: var _ = BeforeSuite(func() {\n873:     err := runtimev1alpha1.AddToScheme(scheme.Scheme)\n874:     Expect(err).NotTo(HaveOccurred())\n875: \n876:     envTest = &envtest.Environment{\n877:         CRDDirectoryPaths: []string{\"../../../manifests/charts/base/crds\"},\n878:     }\n879: \n880:     cfg, err := envTest.Start()\n881:     Expect(err).NotTo(HaveOccurred())\n882: \n883:     k8sClient, err = client.New(cfg, client.Options{Scheme: scheme.Scheme})\n884:     Expect(err).NotTo(HaveOccurred())\n885: })\n886: \n887: var _ = AfterSuite(func() {\n888:     err := envTest.Stop()\n889:     Expect(err).NotTo(HaveOccurred())\n890: })\n891: \n892: var _ = Describe(\"AgentRuntime CRD\", func() {\n893:     Context(\"Create\", func() {\n894:         It(\"should create AgentRuntime successfully\", func(ctx SpecContext) {\n895:             art := &runtimev1alpha1.AgentRuntime{\n896:                 ObjectMeta: metav1.ObjectMeta{\n897:                     Name:      \"test-art\",\n898:                     Namespace: \"default\",\n899:                 },\n900:                 Spec: runtimev1alpha1.AgentRuntimeSpec{\n901:                     MaxSessionDuration: \"8h\",\n902:                     SessionTimeout:     \"15m\",\n903:                     TargetPort: []runtimev1alpha1.TargetPort{\n904:                         {\n905:                             Port:     8080,\n906:                             Protocol: \"HTTP\",\n907:                         },\n908:                     },\n909:                     PodTemplate: runtimev1alpha1.PodTemplateSpec{\n910:                         Spec: runtimev1alpha1.PodSpec{\n911:                             Containers: []runtimev1alpha1.Container{\n912:                                 {\n913:                                     Name:  \"agent\",\n914:                                     Image: \"nginx:latest\",\n915:                                 },\n916:                             },\n917:                         },\n918:                     },\n919:                 },\n920:             }\n921: \n922:             err := k8sClient.Create(ctx, art)\n923:             Expect(err).NotTo(HaveOccurred())\n924:         }, SpecTimeout(5*time.Second))\n925:     })\n926: \n927:     Context(\"Get\", func() {\n928:         It(\"should get AgentRuntime\", func(ctx SpecContext) {\n929:             var art runtimev1alpha1.AgentRuntime\n930:             err := k8sClient.Get(ctx, client.ObjectKey{\n931:                 Name:      \"test-art\",\n932:                 Namespace: \"default\",\n933:             }, &art)\n934:             Expect(err).NotTo(HaveOccurred())\n935:             Expect(art.Spec.MaxSessionDuration).To(Equal(\"8h\"))\n936:         }, SpecTimeout(5*time.Second))\n937:     })\n938: })\n939: ```\n940: \n941: ### E2E Tests\n942: \n943: **File**: `test/e2e/agentruntime_test.go`\n944: \n945: ```go\n946: package e2e\n947: \n948: import (\n949:     \"context\"\n950:     \"testing\"\n951:     \"time\"\n952: \n953:     . \"github.com/onsi/ginkgo/v2\"\n954:     . \"github.com/onsi/gomega\"\n955:     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n956: \n957:     runtimev1alpha1 \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n958:     \"github.com/volcano-sh/agentcube/test/e2e/framework\"\n959: )\n960: \n961: var _ = Describe(\"AgentRuntime E2E\", func() {\n962:     f := framework.NewDefaultFramework(\"agentruntime\")\n963: \n964:     Context(\"Create and validate AgentRuntime\", func() {\n965:         It(\"should create AgentRuntime and verify defaults\", func() {\n966:             ctx := context.Background()\n967:             \n968:             art := &runtimev1alpha1.AgentRuntime{\n969:                 ObjectMeta: metav1.ObjectMeta{\n970:                     Name:      \"e2e-art\",\n971:                     Namespace: f.Namespace.Name,\n972:                 },\n973:                 Spec: runtimev1alpha1.AgentRuntimeSpec{\n974:                     MaxSessionDuration: \"1h\",\n975:                     SessionTimeout:     \"5m\",\n976:                     TargetPort: []runtimev1alpha1.TargetPort{\n977:                         {\n978:                             Port:     8080,\n979:                             Protocol: \"HTTP\",\n980:                         },\n981:                     },\n982:                     PodTemplate: runtimev1alpha1.PodTemplateSpec{\n983:                         Spec: runtimev1alpha1.PodSpec{\n984:                             Containers: []runtimev1alpha1.Container{\n985:                                 {\n986:                                     Name:  \"agent\",\n987:                                     Image: \"nginx:latest\",\n988:                                 },\n989:                             },\n990:                         },\n991:                     },\n992:                 },\n993:             }\n994: \n995:             err := f.Client.Create(ctx, art)\n996:             Expect(err).NotTo(HaveOccurred())\n997: \n998:             // Verify creation\n999:             Eventually(func() bool {\n1000:                 var fetchedArt runtimev1alpha1.AgentRuntime\n1001:                 err := f.Client.Get(ctx, client.ObjectKeyFromObject(art), &fetchedArt)\n1002:                 return err == nil\n1003:             }, 10*time.Second, time.Second).Should(BeTrue())\n1004:         })\n1005:     })\n1006: })\n1007: ```\n1008: \n1009: ## Code Generation\n1010: \n1011: ### CRD Generation\n1012: \n1013: **Command**: `make gen-crd`\n1014: \n1015: ```bash\n1016: controller-gen crd paths=\"./pkg/apis/runtime/v1alpha1/...\" output:crd:dir=manifests/charts/base/crds\n1017: ```\n1018: \n1019: This generates:\n1020: - `manifests/charts/base/crds/runtime.agentcube.volcano.sh_agentruntimes.yaml`\n1021: - `manifests/charts/base/crds/runtime.agentcube.volcano.sh_codeinterpreters.yaml`\n1022: \n1023: ### Client-Go Generation\n1024: \n1025: **Command**: `make gen-client`\n1026: \n1027: ```bash\n1028: bash hack/update-codegen.sh\n1029: ```\n1030: \n1031: This generates:\n1032: - Typed clients in `client-go/clientset/versioned/typed/runtime/v1alpha1/`\n1033: - Informers in `client-go/informers/externalversions/runtime/v1alpha1/`\n1034: - Listers in `client-go/listers/runtime/v1alpha1/`\n1035: \n1036: ### DeepCopy Generation\n1037: \n1038: **Command**: `make generate`\n1039: \n1040: ```bash\n1041: controller-gen object paths=\"./pkg/apis/runtime/v1alpha1/...\"\n1042: ```\n1043: \n1044: This generates:\n1045: - `pkg/apis/runtime/v1alpha1/zz_generated.deepcopy.go`\n1046: \n1047: ## Integration Points\n1048: \n1049: ### With Workload Manager\n1050: \n1051: The Workload Manager uses the generated client-go to:\n1052: 1. Watch AgentRuntime CRDs for changes\n1053: 2. Create and manage sandbox pods based on AgentRuntime spec\n1054: 3. Update AgentRuntime status with observed state\n1055: 4. Handle session lifecycle (creation, expiry, idle cleanup)\n1056: \n1057: ### With Router\n1058: \n1059: The Router uses the generated client-go to:\n1060: 1. Watch CodeInterpreter CRDs for target ports\n1061: 2. Configure routing rules based on port and pathPrefix\n1062: 3. Update session metadata in Redis\n1063: \n1064: ### With RBAC\n1065: \n1066: Required RBAC permissions (from `deployment/design.md`):\n1067: \n1068: ```yaml\n1069: apiGroups:\n1070: - runtime.agentcube.volcano.sh\n1071: resources:\n1072: - agentruntimes\n1073: - codeinterpreters\n1074: verbs:\n1075: - get\n1076: - list\n1077: - watch\n1078: - create\n1079: - update\n1080: - patch\n1081: - delete\n1082: \n1083: apiGroups:\n1084: - runtime.agentcube.volcano.sh\n1085: resources:\n1086: - agentruntimes/status\n1087: - codeinterpreters/status\n1088: verbs:\n1089: - get\n1090: - update\n1091: - patch\n1092: \n1093: apiGroups:\n1094: - runtime.agentcube.volcano.sh\n1095: resources:\n1096: - codeinterpreters/finalizers\n1097: verbs:\n1098: - update\n1099: ```\n1100: \n1101: ## Version Migration Strategy\n1102: \n1103: Future migration path from v1alpha1 to v1beta1/v1:\n1104: \n1105: 1. Create new version package `pkg/apis/runtime/v1beta1/`\n1106: 2. Implement conversion functions between v1alpha1 and v1beta1\n1107: 3. Update CRD to serve both versions (v1alpha1 and v1beta1)\n1108: 4. Set v1beta1 as storage version\n1109: 5. Update controllers and clients to use v1beta1\n1110: 6. Deprecate v1alpha1 after migration period\n1111: \n1112: ```go\n1113: // pkg/apis/runtime/conversion.go\n1114: package runtime\n1115: \n1116: import (\n1117:     \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n1118:     \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1beta1\"\n1119:     \"sigs.k8s.io/controller-runtime/pkg/conversion\"\n1120: )\n1121: \n1122: func (src *v1alpha1.AgentRuntime) ConvertTo(dstRaw conversion.Hub) error {\n1123:     dst := dstRaw.(*v1beta1.AgentRuntime)\n1124:     // Conversion logic\n1125:     return nil\n1126: }\n1127: \n1128: func (dst *v1beta1.AgentRuntime) ConvertFrom(srcRaw conversion.Hub) error {\n1129:     src := srcRaw.(*v1alpha1.AgentRuntime)\n1130:     // Conversion logic\n1131:     return nil\n1132: }\n1133: ```\n1134: \n1135: ## Dependencies\n1136: \n1137: ### Go Dependencies\n1138: \n1139: ```go\n1140: import (\n1141:     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n1142:     \"k8s.io/apimachinery/pkg/runtime\"\n1143:     \"k8s.io/apimachinery/pkg/runtime/schema\"\n1144:     \"k8s.io/apimachinery/pkg/util/intstr\"\n1145: )\n1146: ```\n1147: \n1148: ### Build Tools\n1149: \n1150: - `controller-gen`: v0.17.2 (for CRD and deepcopy generation)\n1151: - `k8s.io/code-generator`: v0.34.1 (for client-go generation)\n1152: \n1153: ### Makefile Targets\n1154: \n1155: | Target | Description |\n1156: |--------|-------------|\n1157: | `gen-crd` | Generate CRD manifests |\n1158: | `gen-client` | Generate client-go library |\n1159: | `generate` | Generate all code (CRD + deepcopy + go mod tidy) |\n1160: | `gen-all` | `generate` + `gen-client` |\n1161: | `gen-check` | Verify generated code is up-to-date |\n1162: \n1163: ## Documentation\n1164: \n1165: ### API Reference\n1166: \n1167: Auto-generated from CRD OpenAPIV3Schema:\n1168: - `AgentRuntime` spec and status fields\n1169: - `CodeInterpreter` spec and status fields\n1170: - Validation rules and constraints\n1171: \n1172: ### Client-Go Documentation\n1173: \n1174: Auto-generated from source code:\n1175: - Interface definitions\n1176: - Method signatures\n1177: - Usage examples\n1178: \n1179: ### Examples\n1180: \n1181: **AgentRuntime example** (`examples/agentruntime.yaml`):\n1182: \n1183: ```yaml\n1184: apiVersion: runtime.agentcube.volcano.sh/v1alpha1\n1185: kind: AgentRuntime\n1186: metadata:\n1187:   name: python-agent\n1188:   namespace: agentcube\n1189: spec:\n1190:   maxSessionDuration: \"8h\"\n1191:   sessionTimeout: \"15m\"\n1192:   targetPort:\n1193:   - port: 8080\n1194:     protocol: \"HTTP\"\n1195:     pathPrefix: \"/api\"\n1196:   podTemplate:\n1197:     metadata:\n1198:       labels:\n1199:         app: python-agent\n1200:     spec:\n1201:       containers:\n1202:       - name: agent\n1203:         image: ghcr.io/volcano-sh/python-agent:latest\n1204:         resources:\n1205:           limits:\n1206:             cpu: \"500m\"\n1207:             memory: \"512Mi\"\n1208:           requests:\n1209:             cpu: \"100m\"\n1210:             memory: \"128Mi\"\n1211: ```\n1212: \n1213: **CodeInterpreter example** (`examples/codeinterpreter.yaml`):\n1214: \n1215: ```yaml\n1216: apiVersion: runtime.agentcube.volcano.sh/v1alpha1\n1217: kind: CodeInterpreter\n1218: metadata:\n1219:   name: python-interpreter\n1220:   namespace: agentcube\n1221: spec:\n1222:   authMode: \"picod\"\n1223:   maxSessionDuration: \"8h\"\n1224:   sessionTimeout: \"15m\"\n1225:   ports:\n1226:   - port: 8080\n1227:     protocol: \"HTTP\"\n1228:   template:\n1229:     spec:\n1230:       containers:\n1231:       - name: interpreter\n1232:         image: ghcr.io/volcano-sh/python-interpreter:latest\n1233:         resources:\n1234:           limits:\n1235:             cpu: \"1\"\n1236:             memory: \"1Gi\"\n1237:           requests:\n1238:             cpu: \"250m\"\n1239:             memory: \"256Mi\"\n1240:     warmPoolSize: 2\n1241: ```\n\n(End of file - total 1241 lines)\n</content>","metadata":{"preview":"# pkg/apis — CRD AgentRuntime Type Definition Design\n\n## AR-001 — CRD AgentRuntime Type Definition\n\n**Module**: `pkg/apis`  \n**Language**: Go  \n**Size**: S  \n**Purpose**: Define Kubernetes CRDs for AgentRuntime and CodeInterpreter resources, enable client-go generation, and provide type-safe API access.\n\n## Architecture\n\n### Package Structure\n\n```\npkg/apis/\n├── runtime/\n│   └── v1alpha1/\n│       ├── agentruntime_types.go   # AgentRuntime spec/status\n│       ├── codeinterpreter_types.go # CodeInterpreter spec/status\n│       ├── doc.go                   # Package documentation","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/deployment/design.md","time":{"start":1775840126503,"end":1775840126512}}}}
