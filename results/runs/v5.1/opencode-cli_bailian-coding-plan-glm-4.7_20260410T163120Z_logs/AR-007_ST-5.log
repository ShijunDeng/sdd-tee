e\"\n)\n\nconst (\n\tLabelKind         = \"runtime.agentcube.volcano.sh/kind\"\n\tLabelWorkloadName = \"runtime.agentcube.volcano.sh/workload-name\"\n)\n\ntype ResourceGenerationChangedPredicate struct {\n\tpredicate.Funcs\n}\n\nfunc (p *ResourceGenerationChangedPredicate) Update(e event.UpdateEvent) bool {\n\tif e.ObjectOld == nil || e.ObjectNew == nil {\n\t\treturn false\n\t}\n\n\toldGen := e.ObjectOld.GetGeneration()\n\tnewGen := e.ObjectNew.GetGeneration()\n\n\tif oldGen == newGen {\n\t\treturn false\n\t}\n\n\treturn true\n}\n\nfunc (p *ResourceGenerationChangedPredicate) Create(e event.CreateEvent) bool {\n\treturn true\n}\n\nfunc (p *ResourceGenerationChangedPredicate) Delete(e event.DeleteEvent) bool {\n\treturn true\n}\n\ntype LabelChangedPredicate struct {\n\tpredicate.Funcs\n}\n\nfunc (p *LabelChangedPredicate) Update(e event.UpdateEvent) bool {\n\tif e.ObjectOld == nil || e.ObjectNew == nil {\n\t\treturn false\n\t}\n\n\toldLabels := e.ObjectOld.GetLabels()\n\tnewLabels := e.ObjectNew.GetLabels()\n\n\tif len(oldLabels) != len(newLabels) {\n\t\treturn true\n\t}\n\n\tfor k, v := range oldLabels {\n\t\tif newLabels[k] != v {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\ntype AnnotationChangedPredicate struct {\n\tpredicate.Funcs\n}\n\nfunc (p *AnnotationChangedPredicate) Update(e event.UpdateEvent) bool {\n\tif e.ObjectOld == nil || e.ObjectNew == nil {\n\t\treturn false\n\t}\n\n\toldAnnotations := e.ObjectOld.GetAnnotations()\n\tnewAnnotations := e.ObjectNew.GetAnnotations()\n\n\tif len(oldAnnotations) != len(newAnnotations) {\n\t\treturn true\n\t}\n\n\tfor k, v := range oldAnnotations {\n\t\tif newAnnotations[k] != v {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\ntype PauseAnnotationPredicate struct {\n\tpredicate.Funcs\n}\n\nfunc (p *PauseAnnotationPredicate) Update(e event.UpdateEvent) bool {\n\tif e.ObjectNew == nil {\n\t\treturn false\n\t}\n\n\treturn !p.isPaused(e.ObjectNew.GetAnnotations())\n}\n\nfunc (p *PauseAnnotationPredicate) Create(e event.CreateEvent) bool {\n\tif e.Object == nil {\n\t\treturn false\n\t}\n\n\treturn !p.isPaused(e.Object.GetAnnotations())\n}\n\nfunc (p *PauseAnnotationPredicate) Delete(e event.DeleteEvent) bool {\n\treturn true\n}\n\nfunc (p *PauseAnnotationPredicate) isPaused(annotations map[string]string) bool {\n\tif annotations == nil {\n\t\treturn false\n\t}\n\n\tval, ok := annotations[\"agentcube.volcano.sh/paused\"]\n\treturn ok && val == \"true\"\n}\n\nfunc IsBeingDeleted(obj client.Object) bool {\n\treturn !obj.GetDeletionTimestamp().IsZero()\n}\n\nfunc HasOwnerReference(obj client.Object, owner types.UID) bool {\n\tfor _, ref := range obj.GetOwnerReferences() {\n\t\tif ref.UID == owner {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\nfunc AddOwnerReference(obj, owner client.Object) error {\n\treturn controllerutil.SetControllerReference(owner, obj, nil)\n}\n\nfunc AddLabels(obj client.Object, labels map[string]string) {\n\texisting := obj.GetLabels()\n\tif existing == nil {\n\t\texisting = make(map[string]string)\n\t}\n\n\tfor k, v := range labels {\n\t\texisting[k] = v\n\t}\n\n\tobj.SetLabels(existing)\n}\n\nfunc AddAnnotations(obj client.Object, annotations map[string]string) {\n\texisting := obj.GetAnnotations()\n\tif existing == nil {\n\t\texisting = make(map[string]string)\n\t}\n\n\tfor k, v := range annotations {\n\t\texisting[k] = v\n\t}\n\n\tobj.SetAnnotations(existing)\n}\n\nfunc IsPodReady(pod *corev1.Pod) bool {\n\tfor _, condition := range pod.Status.Conditions {\n\t\tif condition.Type == corev1.PodReady && condition.Status == corev1.ConditionTrue {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\nfunc GetPodCondition(pod *corev1.Pod, conditionType corev1.PodConditionType) *corev1.PodCondition {\n\tfor _, condition := range pod.Status.Conditions {\n\t\tif condition.Type == conditionType {\n\t\t\treturn &condition\n\t\t}\n\t}\n\treturn nil\n}\n","after":"package reconciler\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachiner