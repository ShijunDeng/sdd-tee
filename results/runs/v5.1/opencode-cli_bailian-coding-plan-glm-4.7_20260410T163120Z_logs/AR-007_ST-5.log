n\tif probe.TCPSocket != nil {\n\t\tp.ProbeHandler.TCPSocket = &corev1.TCPSocketAction{\n\t\t\tPort:     intstr.FromString(probe.TCPSocket.Host),\n\t\t\tHost:     probe.TCPSocket.Host,\n\t\t}\n\t}\n\n\tif probe.HTTPGet != nil {\n\t\tp.ProbeHandler.HTTPGet = &corev1.HTTPGetAction{\n\t\t\tPath:        probe.HTTPGet.Path,\n\t\t\tPort:        intstr.FromString(probe.HTTPGet.Port),\n\t\t\tHost:        probe.HTTPGet.Host,\n\t\t\tScheme:      corev1.URIScheme(probe.HTTPGet.Scheme),\n\t\t}\n\t}\n\n\treturn p\n}\n\nfunc convertResources(resources *runtimev1alpha1.SandboxContainerResources) corev1.ResourceRequirements {\n\trr := corev1.ResourceRequirements{}\n\n\tif resources.Limits.CPU != \"\" || resources.Limits.Memory != \"\" || resources.Limits.EphemeralStorage != \"\" {\n\t\trr.Limits = make(corev1.ResourceList)\n\t\tif resources.Limits.CPU != \"\" {\n\t\t\trr.Limits[corev1.ResourceCPU] = parseResourceQuantity(resources.Limits.CPU)\n\t\t}\n\t\tif resources.Limits.Memory != \"\" {\n\t\t\trr.Limits[corev1.ResourceMemory] = parseResourceQuantity(resources.Limits.Memory)\n\t\t}\n\t\tif resources.Limits.EphemeralStorage != \"\" {\n\t\t\trr.Limits[corev1.ResourceEphemeralStorage] = parseResourceQuantity(resources.Limits.EphemeralStorage)\n\t\t}\n\t}\n\n\tif resources.Requests.CPU != \"\" || resources.Requests.Memory != \"\" || resources.Requests.EphemeralStorage != \"\" {\n\t\trr.Requests = make(corev1.ResourceList)\n\t\tif resources.Requests.CPU != \"\" {\n\t\t\trr.Requests[corev1.ResourceCPU] = parseResourceQuantity(resources.Requests.CPU)\n\t\t}\n\t\tif resources.Requests.Memory != \"\" {\n\t\t\trr.Requests[corev1.ResourceMemory] = parseResourceQuantity(resources.Requests.Memory)\n\t\t}\n\t\tif resources.Requests.EphemeralStorage != \"\" {\n\t\t\trr.Requests[corev1.ResourceEphemeralStorage] = parseResourceQuantity(resources.Requests.EphemeralStorage)\n\t\t}\n\t}\n\n\treturn rr\n}\n\nfunc convertResourceList(list runtimev1alpha1.SandboxResourceList) corev1.ResourceList {\n\trl := make(corev1.ResourceList)\n\tif list.CPU != \"\" {\n\t\trl[corev1.ResourceCPU] = parseResourceQuantity(list.CPU)\n\t}\n\tif list.Memory != \"\" {\n\t\trl[corev1.ResourceMemory] = parseResourceQuantity(list.Memory)\n\t}\n\tif list.EphemeralStorage != \"\" {\n\t\trl[corev1.ResourceEphemeralStorage] = parseResourceQuantity(list.EphemeralStorage)\n\t}\n\treturn rl\n}\n\nfunc convertSecurityContext(sc *runtimev1alpha1.SandboxSecurityContext) *corev1.SecurityContext {\n\tif sc == nil {\n\t\treturn nil\n\t}\n\n\tsecurityContext := &corev1.SecurityContext{\n\t\tRunAsUser:              sc.RunAsUser,\n\t\tRunAsGroup:             sc.RunAsGroup,\n\t\tRunAsNonRoot:           sc.RunAsNonRoot,\n\t\tReadOnlyRootFilesystem: sc.ReadOnlyRootFilesystem,\n\t\tAllowPrivilegeEscalation: sc.AllowPrivilegeEscalation,\n\t}\n\n\tif sc.Capabilities != nil {\n\t\tsecurityContext.Capabilities = &corev1.Capabilities{\n\t\t\tAdd:  sc.Capabilities.Add,\n\t\t\tDrop: sc.Capabilities.Drop,\n\t\t}\n\t}\n\n\treturn securityContext\n}\n\nfunc convertAffinity(affinity *runtimev1alpha1.SandboxAffinity) *corev1.Affinity {\n\tif affinity == nil {\n\t\treturn nil\n\t}\n\n\ta := &corev1.Affinity{}\n\n\tif affinity.NodeAffinity != nil {\n\t\ta.NodeAffinity = &corev1.NodeAffinity{\n\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: convertNodeSelector(affinity.NodeAffinity.RequiredDuringSchedulingIgnoredDuringExecution),\n\t\t}\n\t}\n\n\treturn a\n}\n\nfunc convertNodeSelector(selector *runtimev1alpha1.SandboxNodeSelector) *corev1.NodeSelector {\n\tif selector == nil {\n\t\treturn nil\n\t}\n\n\tns := &corev1.NodeSelector{\n\t\tNodeSelectorTerms: make([]corev1.NodeSelectorTerm, len(selector.NodeSelectorTerms)),\n\t}\n\n\tfor i, term := range selector.NodeSelectorTerms {\n\t\tns.NodeSelectorTerms[i] = corev1.NodeSelectorTerm{\n\t\t\tMatchExpressions: convertNodeSelectorRequirements(term.MatchExpressions),\n\t\t\tMatchFields:      convertNodeSelectorRequirements(term.MatchFields),\n\t\t}\n\t}\n\n\treturn n