g) (ctrl.Manager, error) {\n\topts := ctrl.Options{\n\t\tScheme:                 scheme,\n\t\tMetricsBindAddress:     controllerCfg.MetricsAddr,\n\t\tPort:                   9443,\n\t\tEnableLeaderElection:   controllerCfg.EnableLeaderElection,\n\t\tLeaderElectionID:       controllerCfg.LeaderElectionID,\n\t\tLeaderElectionNamespace: controllerCfg.LeaderElectionNamespace,\n\t\tSyncPeriod:             controllerCfg.SyncPeriod,\n\t}\n\n\tif controllerCfg.EnableProfiling {\n\t\topts.EnableDevelopment = true\n\t}\n\n\tmgr, err := ctrl.NewManager(cfg, opts)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"unable to start manager: %w\", err)\n\t}\n\n\treturn mgr, nil\n}\n\ntype SetupFunc func(mgr ctrl.Manager, cli client.Client, cfg *ControllerConfig) error\n\nfunc SetupWithManager(mgr ctrl.Manager, cli client.Client, cfg *ControllerConfig) error {\n\tif err := setupAgentRuntimeReconciler(mgr, cli, cfg); err != nil {\n\t\treturn fmt.Errorf(\"failed to setup AgentRuntime reconciler: %w\", err)\n\t}\n\n\tif err := setupCodeInterpreterReconciler(mgr, cli, cfg); err != nil {\n\t\treturn fmt.Errorf(\"failed to setup CodeInterpreter reconciler: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc setupAgentRuntimeReconciler(mgr ctrl.Manager, cli client.Client, cfg *ControllerConfig) error {\n\treconciler := &AgentRuntimeReconciler{\n\t\tClient:      cli,\n\t\tScheme:      mgr.GetScheme(),\n\t\tRecorder:    mgr.GetEventRecorderFor(\"agentruntime-reconciler\"),\n\t\tRequeueAfter: cfg.RequeueAfter,\n\t}\n\n\tbuilder := ctrl.NewControllerManagedBy(mgr).\n\t\tFor(&runtimev1alpha1.AgentRuntime{}).\n\t\tWithEventFilter(&ResourceGenerationChangedPredicate{}).\n\t\tWithOptions(controller.Options{MaxConcurrentReconciles: cfg.MaxConcurrentReconciles})\n\n\tif err := builder.Complete(reconciler); err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\nfunc setupCodeInterpreterReconciler(mgr ctrl.Manager, cli client.Client, cfg *ControllerConfig) error {\n\treconciler := &CodeInterpreterReconciler{\n\t\tClient:      cli,\n\t\tScheme:      mgr.GetScheme(),\n\t\tRecorder:    mgr.GetEventRecorderFor(\"codeinterpreter-reconciler\"),\n\t\tRequeueAfter: cfg.RequeueAfter,\n\t}\n\n\tbuilder := ctrl.NewControllerManagedBy(mgr).\n\t\tFor(&runtimev1alpha1.CodeInterpreter{}).\n\t\tWithEventFilter(&ResourceGenerationChangedPredicate{}).\n\t\tWithOptions(controller.Options{MaxConcurrentReconciles: cfg.MaxConcurrentReconciles})\n\n\tif err := builder.Complete(reconciler); err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\nfunc StartManager(mgr manager.Manager, logger *zap.Logger) error {\n\tctx := ctrl.SetupSignalHandler()\n\t\n\tlogger.Info(\"starting manager\")\n\t\n\tif err := mgr.Start(ctx); err != nil {\n\t\treturn fmt.Errorf(\"problem running manager: %w\", err)\n\t}\n\t\n\treturn nil\n}\n\ntype SandboxResult struct {\n\tCreated bool\n\tUpdated bool\n}\n\nfunc GetSandboxName(workloadName string) string {\n\treturn fmt.Sprintf(\"%s-sandbox\", workloadName)\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/controller.go"},"output":"Wrote file successfully.\n\nLSP errors detected in this file, please fix:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/controller.go\">\nERROR [4:2] \"context\" imported and not used\nERROR [14:2] error while importing sigs.k8s.io/controller-runtime/pkg/log/zap: missing go.sum entry for module providing package github.com/go-logr/zapr (imported by sigs.k8s.io/controller-runtime/pkg/log/zap); to add:\n\tgo get sigs.k8s.io/controller-runtime/pkg/log/zap@v0.19.2\nERROR [14:2] error while importing sigs.k8s.io/controller-runtime/pkg/log/zap: missing go.sum entry for module providing package go.uber.org/zap (imported by sigs.k8s.io/controller-runtime/pkg/log/zap); to add:\n\tgo get sigs.k8s.io/controller-runtime/pkg/log/zap@v0.19.2\nE