t\t\tif (*conditions)[i].Status != status {\n\t\t\t\t(*conditions)[i] = newCondition\n\t\t\t} else {\n\t\t\t\t(*conditions)[i].LastTransitionTime = newCondition.LastTransitionTime\n\t\t\t\t(*conditions)[i].Reason = reason\n\t\t\t\t(*conditions)[i].Message = message\n\t\t\t}\n\t\t\treturn\n\t\t}\n\t}\n\t\n\t*conditions = append(*conditions, newCondition)\n}\n\nfunc GetCondition(conditions []metav1.Condition, conditionType string) *metav1.Condition {\n\tfor i := range conditions {\n\t\tif conditions[i].Type == conditionType {\n\t\t\treturn &conditions[i]\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc IsReady(conditions []metav1.Condition) bool {\n\tcondition := GetCondition(conditions, ConditionTypeReady)\n\treturn condition != nil && condition.Status == metav1.ConditionTrue\n}\n\nfunc IsAvailable(conditions []metav1.Condition) bool {\n\tcondition := GetCondition(conditions, ConditionTypeAvailable)\n\treturn condition != nil && condition.Status == metav1.ConditionTrue\n}\n\nfunc IsProgressing(conditions []metav1.Condition) bool {\n\tcondition := GetCondition(conditions, ConditionTypeProgressing)\n\treturn condition != nil && condition.Status == metav1.ConditionTrue\n}\n\nfunc HasError(conditions []metav1.Condition) bool {\n\tcondition := GetCondition(conditions, ConditionTypeError)\n\treturn condition != nil && condition.Status == metav1.ConditionTrue\n}\n\nfunc SetReadyCondition(conditions *[]metav1.Condition, ready bool, reason, message string) {\n\tstatus := metav1.ConditionFalse\n\tif ready {\n\t\tstatus = metav1.ConditionTrue\n\t}\n\tSetCondition(conditions, ConditionTypeReady, status, reason, message)\n}\n\nfunc SetErrorCondition(conditions *[]metav1.Condition, err error, reason string) {\n\tmessage := \"\"\n\tif err != nil {\n\t\tmessage = err.Error()\n\t}\n\tSetCondition(conditions, ConditionTypeError, metav1.ConditionTrue, reason, message)\n}\n\nfunc ClearErrorCondition(conditions *[]metav1.Condition) {\n\tfor i := len(*conditions) - 1; i >= 0; i-- {\n\t\tif (*conditions)[i].Type == ConditionTypeError {\n\t\t\t*conditions = append((*conditions)[:i], (*conditions)[i+1:]...)\n\t\t\tbreak\n\t\t}\n\t}\n}\n\nfunc SetProgressingCondition(conditions *[]metav1.Condition, progressing bool, reason, message string) {\n\tstatus := metav1.ConditionFalse\n\tif progressing {\n\t\tstatus = metav1.ConditionTrue\n\t}\n\tSetCondition(conditions, ConditionTypeProgressing, status, reason, message)\n}\n\nfunc SetAvailableCondition(conditions *[]metav1.Condition, available bool, reason, message string) {\n\tstatus := metav1.ConditionFalse\n\tif available {\n\t\tstatus = metav1.ConditionTrue\n\t}\n\tSetCondition(conditions, ConditionTypeAvailable, status, reason, message)\n}\n\nfunc SetSandboxCreatedCondition(conditions *[]metav1.Condition, created bool, reason, message string) {\n\tstatus := metav1.ConditionFalse\n\tif created {\n\t\tstatus = metav1.ConditionTrue\n\t}\n\tSetCondition(conditions, ConditionTypeSandboxCreated, status, reason, message)\n}\n\nfunc GetConditionMessage(conditions []metav1.Condition, conditionType string) string {\n\tcondition := GetCondition(conditions, conditionType)\n\tif condition != nil {\n\t\treturn condition.Message\n\t}\n\treturn \"\"\n}\n\nfunc GetConditionReason(conditions []metav1.Condition, conditionType string) string {\n\tcondition := GetCondition(conditions, conditionType)\n\tif condition != nil {\n\t\treturn condition.Reason\n\t}\n\treturn \"\"\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/status.go"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/finalizers.go\">\nERROR [10:2] could not import sigs.k8s.io/controller-runtime/pkg/client (no required module provides package \"sigs.k8s.io/controller-runtime/pkg/client\")\nERROR [