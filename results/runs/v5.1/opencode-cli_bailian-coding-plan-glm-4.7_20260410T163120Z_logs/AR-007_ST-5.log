lpha1.SandboxPodSpec{\n\t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\t\t\t\t\tImage: \"python:3.11-slim\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tExpect(fakeClient.Create(ctx, agentRuntime)).To(Succeed())\n\n\t\t\treq := reconcile.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t\tName:      \"test-runtime\",\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tresult, err := reconciler.Reconcile(ctx, req)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(result.RequeueAfter).To(Equal(reconciler.RequeueAfter))\n\n\t\t\tpod := &corev1.Pod{}\n\t\t\tExpect(fakeClient.Get(ctx, client.ObjectKey{\n\t\t\t\tNamespace: \"default\",\n\t\t\t\tName:      \"test-runtime-sandbox\",\n\t\t\t}, pod)).To(Succeed())\n\n\t\t\tExpect(pod.Labels[constants.LabelManagedBy]).To(Equal(constants.LabelManagedByValue))\n\t\t\tExpect(pod.Labels[constants.LabelWorkloadName]).To(Equal(\"test-runtime\"))\n\t\t\tExpect(pod.Labels[LabelKind]).To(Equal(\"AgentRuntime\"))\n\t\t})\n\n\t\tIt(\"should add finalizer to new AgentRuntime\", func() {\n\t\t\tagentRuntime := &runtimev1alpha1.AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"test-runtime\",\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t},\n\t\t\t\tSpec: runtimev1alpha1.AgentRuntimeSpec{\n\t\t\t\t\tPodTemplate: &runtimev1alpha1.SandboxTemplate{\n\t\t\t\t\t\tSpec: runtimev1alpha1.SandboxPodSpec{\n\t\t\t\t\t\t\tContainers: []runtimev1alpha1.SandboxContainer{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"agent\",\n\t\t\t\t\t\t\t\t\tImage: \"python:3.11-slim\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tExpect(fakeClient.Create(ctx, agentRuntime)).To(Succeed())\n\n\t\t\treq := reconcile.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t\tName:      \