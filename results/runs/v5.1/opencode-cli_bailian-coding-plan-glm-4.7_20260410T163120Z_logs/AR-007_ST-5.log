n\t\tPeriodSeconds:       probe.PeriodSeconds,\n\t\tSuccessThreshold:    probe.SuccessThreshold,\n\t\tFailureThreshold:    probe.FailureThreshold,\n\t}\n\n\tif probe.Exec != nil {\n\t\tp.ProbeHandler.Exec = &corev1.ExecAction{\n\t\t\tCommand: probe.Exec.Command,\n\t\t}\n\t}\n\n\tif probe.TCPSocket != nil {\n\t\tport := intstr.Parse(probe.TCPSocket.Port)\n\t\tp.ProbeHandler.TCPSocket = &corev1.TCPSocketAction{\n\t\t\tPort: port,\n\t\t\tHost: probe.TCPSocket.Host,\n\t\t}\n\t}\n\n\tif probe.HTTPGet != nil {\n\t\tport := intstr.Parse(probe.HTTPGet.Port)\n\t\tp.ProbeHandler.HTTPGet = &corev1.HTTPGetAction{\n\t\t\tPath:   probe.HTTPGet.Path,\n\t\t\tPort:   port,\n\t\t\tHost:   probe.HTTPGet.Host,\n\t\t\tScheme: corev1.URIScheme(probe.HTTPGet.Scheme),\n\t\t}\n\t}\n\n\treturn p\n}\n\nfunc convertResources(resources *runtimev1alpha1.SandboxContainerResources) corev1.ResourceRequirements {\n\trr := corev1.ResourceRequirements{}\n\n\tif resources.Limits.CPU != \"\" || resources.Limits.Memory != \"\" || resources.Limits.EphemeralStorage != \"\" {\n\t\trr.Limits = make(corev1.ResourceList)\n\t\tif resources.Limits.CPU != \"\" {\n\t\t\tquantity := resource.MustParse(resources.Limits.CPU)\n\t\t\trr.Limits[corev1.ResourceCPU] = quantity\n\t\t}\n\t\tif resources.Limits.Memory != \"\" {\n\t\t\tquantity := resource.MustParse(resources.Limits.Memory)\n\t\t\trr.Limits[corev1.ResourceMemory] = quantity\n\t\t}\n\t\tif resources.Limits.EphemeralStorage != \"\" {\n\t\t\tquantity := resource.MustParse(resources.Limits.EphemeralStorage)\n\t\t\trr.Limits[corev1.ResourceEphemeralStorage] = quantity\n\t\t}\n\t}\n\n\tif resources.Requests.CPU != \"\" || resources.Requests.Memory != \"\" || resources.Requests.EphemeralStorage != \"\" {\n\t\trr.Requests = make(corev1.ResourceList)\n\t\tif resources.Requests.CPU != \"\" {\n\t\t\tquantity := resource.MustParse(resources.Requests.CPU)\n\t\t\trr.Requests[corev1.ResourceCPU] = quantity\n\t\t}\n\t\tif resources.Requests.Memory != \"\" {\n\t\t\tquantity := resource.MustParse(resources.Requests.Memory)\n\t\t\trr.Requests[corev1.ResourceMemory] = quantity\n\t\t}\n\t\tif resources.Requests.EphemeralStorage != \"\" {\n\t\t\tquantity := resource.MustParse(resources.Requests.EphemeralStorage)\n\t\t\trr.Requests[corev1.ResourceEphemeralStorage] = quantity\n\t\t}\n\t}\n\n\treturn rr\n}\n\nfunc convertResourceList(list runtimev1alpha1.SandboxResourceList) corev1.ResourceList {\n\trl := make(corev1.ResourceList)\n\tif list.CPU != \"\" {\n\t\trl[corev1.ResourceCPU] = resource.MustParse(list.CPU)\n\t}\n\tif list.Memory != \"\" {\n\t\trl[corev1.ResourceMemory] = resource.MustParse(list.Memory)\n\t}\n\tif list.EphemeralStorage != \"\" {\n\t\trl[corev1.ResourceEphemeralStorage] = resource.MustParse(list.EphemeralStorage)\n\t}\n\treturn rl\n}\n\nfunc convertSecurityContext(sc *runtimev1alpha1.SandboxSecurityContext) *corev1.SecurityContext {\n\tif sc == nil {\n\t\treturn nil\n\t}\n\n\tsecurityContext := &corev1.SecurityContext{\n\t\tRunAsUser:                sc.RunAsUser,\n\t\tRunAsGroup:               sc.RunAsGroup,\n\t\tRunAsNonRoot:             sc.RunAsNonRoot,\n\t\tReadOnlyRootFilesystem:   sc.ReadOnlyRootFilesystem,\n\t\tAllowPrivilegeEscalation: sc.AllowPrivilegeEscalation,\n\t}\n\n\tif sc.Capabilities != nil {\n\t\tcapabilities := corev1.Capabilities{}\n\t\tfor _, cap := range sc.Capabilities.Add {\n\t\t\tcapabilities.Add = append(capabilities.Add, corev1.Capability(cap))\n\t\t}\n\t\tfor _, cap := range sc.Capabilities.Drop {\n\t\t\tcapabilities.Drop = append(capabilities.Drop, corev1.Capability(cap))\n\t\t}\n\t\tsecurityContext.Capabilities = &capabilities\n\t}\n\n\treturn securityContext\n}\n\nfunc convertAffinity(affinity *runtimev1alpha1.SandboxAffinity) *corev1.Affinity {\n\tif affinity == nil {\n\t\treturn nil\n\t}\n\n\ta := &corev1.Affinity{}\n\n\tif affinity.NodeAffinity != nil {\n\t\ta.NodeAffinity = &corev1.NodeAffinity{\n\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: convertNodeSelector(affinity.NodeAffinity.RequiredDuringSchedulingIgnoredDuringExecution),\n\t\t}\n\t}\n\n\treturn a\n}\n\nfunc convertNodeSelector(selector *runtimev1alpha1.SandboxNodeSelector) *corev1.NodeSelector {\n\tif selector == nil {\n\t\treturn nil\n\t}\n\n\tns := &corev1.NodeSelector{\n\t\tNodeSelectorTerms: make([]corev1.NodeSelectorTerm, len(selector.NodeSelectorTerms)),\n\t}\n\n\tfor i, term := range selector.NodeSelectorTerms {\n\t\tns.NodeSelectorTerms[i] = corev1.NodeSelectorTerm{\n\t\t\tMatchExpressions: convertNodeSelectorRequirements(term.MatchExpressions),\n\t\t\tMatchFields:      convertNodeSelectorRequirements(term.MatchFields),\n\t\t}\n\t}\n\n\treturn ns\n}\n\nfunc convertNodeSelectorRequirements(reqs []runtimev1alpha1.SandboxNodeSelectorRequirement) []corev1.NodeSelectorRequirement {\n\trequirements := make([]corev1.NodeSelectorRequirement, len(reqs))\n\tfor i, req := range reqs {\n\t\trequirements[i] = corev1.NodeSelectorRequirement{\n\t\t\tKey:      req.Key,\n\t\t\tOperator: corev1.NodeSelectorOperator(req.Operator),\n\t\t\tValues:   req.Values,\n\t\t}\n\t}\n\treturn requirements\n}\n\nfunc convertVolume(volume runtimev1alpha1.SandboxVolume) corev1.Volume {\n\tv := corev1.Volume{\n\t\tName: volume.Name,\n\t}\n\n\tif volume.EmptyDir != nil {\n\t\tv.EmptyDir = &corev1.EmptyDirVolumeSource{}\n\t\tif volume.EmptyDir.SizeLimit != \"\" {\n\t\t\tquantity := resource.MustParse(volume.EmptyDir.SizeLimit)\n\t\t\tv.EmptyDir.SizeLimit = &quantity\n\t\t}\n\t}\n\n\tif volume.Secret != nil {\n\t\tv.Secret = &corev1.SecretVolumeSource{\n\t\t\tSecretName: volume.Secret.SecretName,\n\t\t\tOptional:   volume.Secret.Optional,\n\t\t}\n\t}\n\n\tif volume.PersistentVolumeClaim != nil {\n\t\tv.PersistentVolumeClaim = &corev1.PersistentVolumeClaimVolumeSource{\n\t\t\tClaimName: volume.PersistentVolumeClaim.ClaimName,\n\t\t\tReadOnly:  volume.PersistentVolumeClaim.ReadOnly,\n\t\t}\n\t}\n\n\treturn v\n}\n\nfunc podSpecsEqual(spec1, spec2 *corev1.PodSpec) bool {\n\tif spec1 == nil || spec2 == nil {\n\t\treturn spec1 == spec2\n\t}\n\n\tif len(spec1.Containers) != len(spec2.Containers) {\n\t\treturn false\n\t}\n\n\tfor i := range spec1.Containers {\n\t\tif spec1.Containers[i].Name != spec2.Containers[i].Name ||\n\t\t\tspec1.Containers[i].Image != spec2.Containers[i].Image {\n\t\t\treturn false\n\t\t}\n\t}\n\n\treturn true\n}\n\nfunc statusConditionsEqual(conds1, conds2 []metav1.Condition) bool {\n\tif len(conds1) != len(conds2) {\n\t\treturn false\n\t}\n\n\tfor i := range conds1 {\n\t\tif conds1[i].Type != conds2[i].Type ||\n\t\t\tconds1[i].Status != conds2[i].Status {\n\t\t\treturn false\n\t\t}\n\t}\n\n\treturn true\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli-bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/utils.go"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/reconciler/controller.go\">\nERROR [57:3] unknown field MetricsBindAddress in struct literal of type controllerruntime.Options\nERROR [58:3] unknown field Port in struct literal of type controllerruntime.Options\nERROR [62:3] unknown field SyncPeriod in struct literal of type controllerruntime.Options\nERROR [88:17] undefined: AgentRuntimeReconciler\nERROR [98:15] cannot use ctrl.Options{…} (value of struct type controllerruntime.Options) as controller.TypedOptions[reconcile.Request] value in argument to ctrl.NewControllerManagedBy(mgr).For(&runtimev1alpha1.AgentRuntime{}).WithEventFilter(&ResourceGenerationChangedPredicate{}).WithOptions\nERROR [98:28] unknown field MaxConcurrentReconciles in struct literal of type controllerruntime.Options\nERROR [118:15] cannot use ctrl.Options{…} (value of struct type controllerruntime.Options) as controller.TypedOptions[reconcile.Request] value in argument to ctrl.NewControllerManagedBy(mgr).For(&runtimev1alpha1.CodeInterpreter{}).WithEventFil