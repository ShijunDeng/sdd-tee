\tif !HasFinalizer(codeInterpreter, FinalizerCodeInterpreter) {\n\t\tif err := AddFinalizer(ctx, r.Client, codeInterpreter, FinalizerCodeInterpreter); err != nil {\n\t\t\tlogger.Error(err, \"Failed to add finalizer\")\n\t\t\treturn ctrl.Result{Requeue: true}, err\n\t\t}\n\t\treturn ctrl.Result{}, nil\n\t}\n\n\tif err := r.validateSpec(codeInterpreter); err != nil {\n\t\tlogger.Error(err, \"Spec validation failed\")\n\t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeWarning, ReasonSpecInvalid, err.Error())\n\t\toriginalStatus := codeInterpreter.Status.DeepCopy()\n\t\tSetErrorCondition(&codeInterpreter.Status.Conditions, err, ReasonSpecInvalid)\n\t\tif !statusConditionsEqual(originalStatus.Conditions, codeInterpreter.Status.Conditions) {\n\t\t\tif statusErr := r.Status().Update(ctx, codeInterpreter); statusErr != nil {\n\t\t\t\tRecordReconciliationError(\"codeinterpreter\", req.Namespace, req.Name, ErrCodeStatusUpdateFailed)\n\t\t\t\treturn ctrl.Result{}, statusErr\n\t\t\t}\n\t\t}\n\t\tRecordReconciliationError(\"codeinterpreter\", req.Namespace, req.Name, ErrCodeValidationFailed)\n\t\treturn ctrl.Result{}, nil\n\t}\n\n\tsandboxResult, err := r.reconcileSandbox(ctx, codeInterpreter)\n\tif err != nil {\n\t\tlogger.Error(err, \"Failed to reconcile sandbox\")\n\t\tRecordReconciliation(\"codeinterpreter\", req.Namespace, req.Name,\n\t\t\ttime.Since(startTime).Seconds(), \"error\")\n\t\tRecordReconciliationError(\"codeinterpreter\", req.Namespace, req.Name, ErrCodeSandboxCreateFailed)\n\t\treturn r.handleReconcileError(ctx, codeInterpreter, err)\n\t}\n\n\toriginalStatus := codeInterpreter.Status.DeepCopy()\n\n\tif sandboxResult.Created {\n\t\tSetSandboxCreatedCondition(&codeInterpreter.Status.Conditions, true, ReasonSandboxCreated, \"Sandbox resource created successfully\")\n\t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeNormal, ReasonSandboxCreated,\n\t\t\tfmt.Sprintf(\"Sandbox %s created\", GetSandboxName(codeInterpreter.Name)))\n\t\tRecordSandboxCreation(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", time.Since(startTime).Seconds())\n\t} else if sandboxResult.Updated {\n\t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeNormal, ReasonSandboxUpdated,\n\t\t\tfmt.Sprintf(\"Sandbox %s updated\", GetSandboxName(codeInterpreter.Name)))\n\t\tRecordSandboxUpdate(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", time.Since(startTime).Seconds())\n\t}\n\n\tready := r.isReady(ctx, codeInterpreter)\n\tSetReadyCondition(&codeInterpreter.Status.Conditions, ready, ReasonReconciliationComplete, \"CodeInterpreter is ready\")\n\n\tif ready {\n\t\tClearErrorCondition(&codeInterpreter.Status.Conditions)\n\t\tRecordResourceReady(\"codeinterpreter\", codeInterpreter.Namespace)\n\t} else {\n\t\tSetProgressingCondition(&codeInterpreter.Status.Conditions, true, ReasonReconciliationStarted, \"CodeInterpreter is being reconciled\")\n\t\tRecordResourcePending(\"codeinterpreter\", codeInterpreter.Namespace)\n\t}\n\n\tif !statusConditionsEqual(originalStatus.Conditions, codeInterpreter.Status.Conditions) {\n\t\tcodeInterpreter.Status.ObservedGeneration = codeInterpreter.Generation\n\t\tif err := r.Status().Update(ctx, codeInterpreter); err != nil {\n\t\t\tlogger.Error(err, \"Failed to update status\")\n\t\t\tRecordReconciliationError(\"codeinterpreter\", req.Namespace, req.Name, ErrCodeStatusUpdateFailed)\n\t\t\treturn ctrl.Result{}, err\n\t\t}\n\t}\n\n\tduration := time.Since(startTime).Seconds()\n\tresult := \"success\"\n\tif !ready {\n\t\tresult = \"requeue\"\n\t\tRecordRequeue(\"codeinterpreter\", req.Namespace, req.Name)\n\t}\n\tRecordReconciliation(\"codeinterpreter\", req.Namespace, req.Name, duration, result)\n\n\tif !ready {\n\t\tlogger.Info(\"CodeInterpreter not ready, requeuing\")\n\t\treturn ctrl.Result{RequeueAfter: r.RequeueAfter}, nil\n\t}\n\n\tlogger.Info(\"Reconciliation completed successfully\")\n\treturn ctrl.Result{RequeueAfter: r.RequeueAfter}, nil\n}\n\nfunc (r *CodeInterpreterReconciler) reconcileDelete(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter) (ctrl.Result, error) {\n\tlogger := log.FromContext(ctx)\n\tlogger.Info(\"Deleting CodeInterpreter\", \"namespace\", codeInterpreter.Namespace, \"name\", codeInterpreter.Name)\n\n\tsandboxName := GetSandboxName(codeInterpreter.Name)\n\tsandbox := &corev1.Pod{}\n\n\terr := r.Get(ctx, client.ObjectKey{\n\t\tNamespace: codeInterpreter.Namespace,\n\t\tName:      sandboxName,\n\t}, sandbox)\n\n\tif err == nil {\n\t\tif err := r.Delete(ctx, sandbox); err != nil && !apierrors.IsNotFound(err) {\n\t\t\tlogger.Error(err, \"Failed to delete sandbox pod\")\n\t\t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeWarning, ReasonSandboxDeleteFailed,\n\t\t\t\tfmt.Sprintf(\"Failed to delete sandbox pod: %v\", err))\n\t\t\tRecordSandboxDeletion(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"error\", 0)\n\t\t\treturn ctrl.Result{}, err\n\t\t}\n\t\tlogger.Info(\"Sandbox pod deleted successfully\")\n\t\tr.Recorder.Event(codeInterpreter, corev1.EventTypeNormal, ReasonSandboxDeleted,\n\t\t\tfmt.Sprintf(\"Sandbox %s deleted\", sandboxName))\n\t\tRecordSandboxDeletion(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", 0)\n\t} else if !apierrors.IsNotFound(err) {\n\t\tlogger.Error(err, \"Failed to get sandbox pod\")\n\t\treturn ctrl.Result{}, err\n\t}\n\n\tif HasFinalizer(codeInterpreter, FinalizerCodeInterpreter) {\n\t\tif err := RemoveFinalizer(ctx, r.Client, codeInterpreter, FinalizerCodeInterpreter); err != nil {\n\t\t\tlogger.Error(err, \"Failed to remove finalizer\")\n\t\t\treturn ctrl.Result{}, err\n\t\t}\n\t}\n\n\tlogger.Info(\"CodeInterpreter deleted successfully\")\n\treturn ctrl.Result{}, nil\n}\n\nfunc (r *CodeInterpreterReconciler) reconcileSandbox(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter) (*SandboxResult, error) {\n\tlogger := log.FromContext(ctx)\n\tsandboxName := GetSandboxName(codeInterpreter.Name)\n\n\texistingPod := &corev1.Pod{}\n\terr := r.Get(ctx, client.ObjectKey{\n\t\tNamespace: codeInterpreter.Namespace,\n\t\tName:      sandboxName,\n\t}, existingPod)\n\n\tif err != nil {\n\t\tif apierrors.IsNotFound(err) {\n\t\t\treturn r.createSandboxPod(ctx, codeInterpreter, sandboxName)\n\t\t}\n\t\treturn nil, fmt.Errorf(\"failed to get sandbox pod: %w\", err)\n\t}\n\n\treturn r.updateSandboxPod(ctx, codeInterpreter, existingPod, sandboxName)\n}\n\nfunc (r *CodeInterpreterReconciler) createSandboxPod(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter, sandboxName string) (*SandboxResult, error) {\n\tlogger := log.FromContext(ctx)\n\tlogger.Info(\"Creating sandbox pod\", \"name\", sandboxName)\n\n\tstartTime := time.Now()\n\n\tpod := &corev1.Pod{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      sandboxName,\n\t\t\tNamespace: codeInterpreter.Namespace,\n\t\t\tLabels: map[string]string{\n\t\t\t\tconstants.LabelManagedBy:    constants.LabelManagedByValue,\n\t\t\t\tconstants.LabelWorkloadName: codeInterpreter.Name,\n\t\t\t\tconstants.LabelSandboxName:  sandboxName,\n\t\t\t\tconstants.LabelSessionID:    codeInterpreter.Name,\n\t\t\t\tLabelKind:                   \"CodeInterpreter\",\n\t\t\t},\n\t\t\tOwnerReferences: []metav1.OwnerReference{\n\t\t\t\t{\n\t\t\t\t\tAPIVersion:         \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\t\t\tKind:               \"CodeInterpreter\",\n\t\t\t\t\tName:               codeInterpreter.Name,\n\t\t\t\t\tUID:                codeInterpreter.UID,\n\t\t\t\t\tController:         &[]bool{true}[0],\n\t\t\t\t\tBlockOwnerDeletion: &[]bool{true}[0],\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\tSpec: r.buildPodSpec(codeInterpreter),\n\t}\n\n\tif err := r.Create(ctx, pod); err != nil {\n\t\tlogger.Error(err, \"Failed to create sandbox pod\")\n\t\tRecordSandboxCreation(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"error\", time.Since(startTime).Seconds())\n\t\treturn nil, NewSandboxCreateFailedError(fmt.Sprintf(\"Failed to create sandbox pod: %v\", err), err)\n\t}\n\n\tlogger.Info(\"Sandbox pod created successfully\")\n\treturn &SandboxResult{Created: true}, nil\n}\n\nfunc (r *CodeInterpreterReconciler) updateSandboxPod(ctx context.Context, codeInterpreter *runtimev1alpha1.CodeInterpreter, existingPod *corev1.Pod, sandboxName string) (*SandboxResult, error) {\n\tlogger := log.FromContext(ctx)\n\tlogger.Info(\"Checking sandbox pod\", \"name\", sandboxName)\n\n\tif existingPod.DeletionTimestamp != nil {\n\t\treturn &SandboxResult{Created: false}, nil\n\t}\n\n\tdesiredSpec := r.buildPodSpec(codeInterpreter)\n\tif podSpecsEqual(&existingPod.Spec, &desiredSpec) {\n\t\treturn &SandboxResult{Created: false}, nil\n\t}\n\n\texistingPod.Spec = desiredSpec\n\tif err := r.Update(ctx, existingPod); err != nil {\n\t\tlogger.Error(err, \"Failed to update sandbox pod\")\n\t\tRecordSandboxUpdate(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"error\", 0)\n\t\treturn nil, NewSandboxUpdateFailedError(fmt.Sprintf(\"Failed to update sandbox pod: %v\", err), err)\n\t}\n\n\tlogger.Info(\"Sandbox pod updated successfully\")\n\tRecordSandboxUpdate(\"codeinterpreter\", codeInterpreter.Namespace, codeInterpreter.Name, \"success\", 0)\n\treturn &SandboxResult{Updated: true}, nil\n}\n\nfunc (r *CodeInterpreterReconciler) buildPodSpec(codeInterpreter *runtimev1alpha1.CodeInterpreter) corev1.PodSpec {\n\timage := codeInterpreter.Spec.Image\n\tif image == \"\" {\n\t\timage = \"python:3.11-slim\"\n\t}\n\n\tcontainer := corev1.Container{\n\t\tName:  \"code-interpreter\",\n\t\tImage: image,\n\t\tEnv:   convertEnvVars(codeInterpreter.Spec.Env),\n\t\tTerminationMessagePath:   \"/dev/termination-log\",\n\t\tTerminationMessagePolicy: corev1.TerminationMessageReadFile,\n\t\tImagePullPolicy:          corev1.PullIfNotPresent,\n\t}\n\n\tif codeInterpreter.Spec.Resources != nil {\n\t\tcontainer.Resources = convertResources(codeInterpreter.Spec.Resources)\n\t}\n\n\