\n46: \n47: func TestSessionManager_InitializeInformers(t *testing.T) {\n48: \tt.Run(\"With valid clientset\", func(t *testing.T) {\n49: \t\tfakeStore := &fakeStore{}\n50: \t\tfakeClientset := fake.NewSimpleClientset()\n51: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n52: \t\tif err != nil {\n53: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n54: \t\t}\n55: \n56: \t\terr = manager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n57: \t\tif err != nil {\n58: \t\t\tt.Errorf(\"InitializeInformers returned error: %v\", err)\n59: \t\t}\n60: \t})\n61: \n62: \tt.Run(\"With nil clientset\", func(t *testing.T) {\n63: \t\tfakeStore := &fakeStore{}\n64: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n65: \t\tif err != nil {\n66: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n67: \t\t}\n68: \n69: \t\terr = manager.InitializeInformers(nil, \"default\", 10*time.Minute)\n70: \t\tif err != nil {\n71: \t\t\tt.Errorf(\"InitializeInformers with nil clientset should not return error: %v\", err)\n72: \t\t}\n73: \t})\n74: }\n75: \n76: func TestSessionManager_StartInformers(t *testing.T) {\n77: \tfakeStore := &fakeStore{}\n78: \tfakeClientset := fake.NewSimpleClientset()\n79: \tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n80: \tif err != nil {\n81: \t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n82: \t}\n83: \n84: \tmanager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n85: \tmanager.StartInformers()\n86: \n87: \ttime.Sleep(50 * time.Millisecond)\n88: }\n89: \n90: func TestSessionManager_StopInformers(t *testing.T) {\n91: \tfakeStore := &fakeStore{}\n92: \tfakeClientset := fake.NewSimpleClientset()\n93: \tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n94: \tif err != nil {\n95: \t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n96: \t}\n97: \n98: \tmanager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n99: \tmanager.StartInformers()\n100: \ttime.Sleep(50 * time.Millisecond)\n101: \tmanager.StopInformers()\n102: }\n103: \n104: func TestSessionManager_WaitForCacheSync(t *testing.T) {\n105: \tt.Run(\"With informers\", func(t *testing.T) {\n106: \t\tfakeStore := &fakeStore{}\n107: \t\tfakeClientset := fake.NewSimpleClientset()\n108: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n109: \t\tif err != nil {\n110: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n111: \t\t}\n112: \n113: \t\tmanager.InitializeInformers(fakeClientset, \"default\", 10*time.Minute)\n114: \t\tmanager.StartInformers()\n115: \n116: \t\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n117: \t\tdefer cancel()\n118: \n119: \t\tsynced := manager.WaitForCacheSync(ctx)\n120: \t\tif !synced {\n121: \t\t\tt.Error(\"Informers should sync successfully\")\n122: \t\t}\n123: \n124: \t\tmanager.StopInformers()\n125: \t})\n126: \n127: \tt.Run(\"Without informers\", func(t *testing.T) {\n128: \t\tfakeStore := &fakeStore{}\n129: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n130: \t\tif err != nil {\n131: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n132: \t\t}\n133: \n134: \t\tsynced := manager.WaitForCacheSync(context.Background())\n135: \t\tif !synced {\n136: \t\t\tt.Error(\"WaitForCacheSync should return true when informers are not initialized\")\n137: \t\t}\n138: \t})\n139: }\n140: \n141: func TestSessionManager_CreateSession(t *testing.T) {\n142: \tt.Run(\"Valid session creation\", func(t *testing.T) {\n143: \t\tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n144: \t\t\tif r.Method == http.MethodPost && r.URL.Path == \"/v1/agent-runtime\" {\n145: \t\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n146: \t\t\t\tw.WriteHeader(http.StatusOK)\n147: \t\t\t\tw.Write([]byte(`{\n148: \t\t\t\t\t\"sessionId\": \"test-session-id\",\n149: \t\t\t\t\t\"sandboxId\": \"test-sandbox-id\",\n150: \t\t\t\t\t\"sandboxName\": \"test-sandbox\",\n151: \t\t\t\t\t\"entryPoints\": []\n152: \t\t\t\t}`))\n153: \t\t\t} else if r.Method == http.MethodGet && r.URL.Path == \"/v1/session/test-session-id\" {\n154: \t\t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n155: \t\t\t\tw.WriteHeader(http.StatusOK)\n156: \t\t\t\tw.Write([]byte(`{\n157: \t\t\t\t\t\"sessionId\": \"test-session-id\",\n158: \t\t\t\t\t\"sandboxId\": \"test-sandbox-id\",\n159: \t\t\t\t\t\"sandboxName\": \"test-sandbox\",\n160: \t\t\t\t\t\"kind\": \"AgentRuntime\",\n161: \t\t\t\t\t\"name\": \"test\",\n162: \t\t\t\t\t\"namespace\": \"default\",\n163: \t\t\t\t\t\"entryPoints\": [],\n164: \t\t\t\t\t\"lastActivity\": \"` + time.Now().Format(time.RFC3339) + `\",\n165: \t\t\t\t\t\"createdAt\": \"` + time.Now().Format(time.RFC3339) + `\",\n166: \t\t\t\t\t\"expiresAt\": \"` + time.Now().Add(8*time.Hour).Format(time.RFC3339) + `\"\n167: \t\t\t\t}`))\n168: \t\t\t} else {\n169: \t\t\t\tt.Errorf(\"Unexpected request: %s %s\", r.Method, r.URL.Path)\n170: \t\t\t\tw.WriteHeader(http.StatusNotFound)\n171: \t\t\t}\n172: \t\t}))\n173: \t\tdefer server.Close()\n174: \n175: \t\tfakeStore := &fakeStore{}\n176: \t\tmanager, err := NewSessionManager(fakeStore, server.URL)\n177: \t\tif err != nil {\n178: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n179: \t\t}\n180: \n181: \t\tsessionID, sandboxInfo, err := manager.CreateSession(context.Background(), \"test\", \"default\", types.AgentRuntimeKind)\n182: \t\tif err != nil {\n183: \t\t\tt.Errorf(\"CreateSession returned error: %v\", err)\n184: \t\t}\n185: \n186: \t\tif sessionID == \"\" {\n187: \t\t\tt.Error(\"Expected non-empty session ID\")\n188: \t\t}\n189: \n190: \t\tif sandboxInfo == nil {\n191: \t\t\tt.Error(\"Expected non-nil sandbox info\")\n192: \t\t}\n193: \t})\n194: \n195: \tt.Run(\"Invalid kind\", func(t *testing.T) {\n196: \t\tfakeStore := &fakeStore{}\n197: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n198: \t\tif err != nil {\n199: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n200: \t\t}\n201: \n202: \t\t_, _, err = manager.CreateSession(context.Background(), \"test\", \"default\", \"InvalidKind\")\n203: \t\tif err == nil {\n204: \t\t\tt.Error(\"Expected error for invalid kind\")\n205: \t\t}\n206: \t})\n207: \n208: \tt.Run(\"Invalid namespace\", func(t *testing.T) {\n209: \t\tfakeStore := &fakeStore{}\n210: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n211: \t\tif err != nil {\n212: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n213: \t\t}\n214: \n215: \t\t_, _, err = manager.CreateSession(context.Background(), \"test\", \"INVALID_NAMESPACE\", types.AgentRuntimeKind)\n216: \t\tif err == nil {\n217: \t\t\tt.Error(\"Expected error for invalid namespace\")\n218: \t\t}\n219: \t})\n220: \n221: \tt.Run(\"Invalid resource name\", func(t *testing.T) {\n222: \t\tfakeStore := &fakeStore{}\n223: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n224: \t\tif err != nil {\n225: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n226: \t\t}\n227: \n228: \t\t_, _, err = manager.CreateSession(context.Background(), \"INVALID_NAME\", \"default\", types.AgentRuntimeKind)\n229: \t\tif err == nil {\n230: \t\t\tt.Error(\"Expected error for invalid resource name\")\n231: \t\t}\n232: \t})\n233: \n234: \tt.Run(\"Workload manager error\", func(t *testing.T) {\n235: \t\tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n236: \t\t\tw.WriteHeader(http.StatusInternalServerError)\n237: \t\t\tw.Write([]byte(`{\"error\": \"internal server error\"}`))\n238: \t\t}))\n239: \t\tdefer server.Close()\n240: \n241: \t\tfakeStore := &fakeStore{}\n242: \t\tmanager, err := NewSessionManager(fakeStore, server.URL)\n243: \t\tif err != nil {\n244: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n245: \t\t}\n246: \n247: \t\t_, _, err = manager.CreateSession(context.Background(), \"test\", \"default\", types.AgentRuntimeKind)\n248: \t\tif err == nil {\n249: \t\t\tt.Error(\"Expected error from workload manager\")\n250: \t\t}\n251: \t})\n252: }\n253: \n254: func TestSessionManager_GetSandboxBySession(t *testing.T) {\n255: \tt.Run(\"Cache hit\", func(t *testing.T) {\n256: \t\texpectedSandbox := &types.SandboxInfo{\n257: \t\t\tSessionID: \"test-session-id\",\n258: \t\t\tName:      \"test\",\n259: \t\t\tNamespace: \"default\",\n260: \t\t\tKind:      types.AgentRuntimeKind,\n261: \t\t\tStatus:    \"Ready\",\n262: \t\t}\n263: \n264: \t\tfakeStore := &fakeStore{\n265: \t\t\tsandboxes: map[string]*types.SandboxInfo{\n266: \t\t\t\t\"test-session-id\": expectedSandbox,\n267: \t\t\t},\n268: \t\t}\n269: \n270: \t\tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n271: \t\tif err != nil {\n272: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n273: \t\t}\n274: \n275: \t\terr = manager.InitializeInformers(nil, \"default\", 10*time.Minute)\n276: \t\tif err != nil {\n277: \t\t\tt.Fatalf(\"InitializeInformers returned error: %v\", err)\n278: \t\t}\n279: \n280: \t\tsandboxInfo, err := manager.GetSandboxBySession(context.Background(), \"test-session-id\", \"default\", \"test\", types.AgentRuntimeKind)\n281: \t\tif err != nil {\n282: \t\t\tt.Errorf(\"GetSandboxBySession returned error: %v\", err)\n283: \t\t}\n284: \n285: \t\tif sandboxInfo == nil {\n286: \t\t\tt.Fatal(\"Expected non-nil sandbox info\")\n287: \t\t}\n288: \n289: \t\tif sandboxInfo.SessionID != expectedSandbox.SessionID {\n290: \t\t\tt.Errorf(\"Expected session ID '%s', got '%s'\", expectedSandbox.SessionID, sandboxInfo.SessionID)\n291: \t\t}\n292: \t})\n293: \n294: \tt.Run(\"Cache miss\", func(t *testing.T) {\n295: \t\tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n296: \t\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n297: \t\t\tw.WriteHeader(http.StatusOK)\n298: \t\t\tw.Write([]byte(`{\n299: \t\t\t\t\"sessionId\": \"test-session-id\",\n300: \t\t\t\t\"sandboxId\": \"test-sandbox-id\",\n301: \t\t\t\t\"sandboxName\": \"test-sandbox\",\n302: \t\t\t\t\"kind\": \"AgentRuntime\",\n303: \t\t\t\t\"name\": \"test\",\n304: \t\t\t\t\"namespace\": \"default\",\n305: \t\t\t\t\"entryPoints\": [],\n306: \t\t\t\t\"lastActivity\": \"` + time.Now().Format(time.RFC3339) + `\",\n307: \t\t\t\t\"createdAt\": \"` + time.Now().Format(time.RFC3339) + `\",\n308: \t\t\t\t\"expiresAt\": \"` + time.Now().Add(8*time.Hour).Format(time.RFC3339) + `\"\n309: \t\t\t}`))\n310: \t\t}))\n311: \t\tdefer server.Close()\n312: \n313: \t\tfakeStore := &fakeStore{}\n314: \t\tmanager, err := NewSessionManager(fakeStore, server.URL)\n315: \t\tif err != nil {\n316: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n317: \t\t}\n318: \n319: \t\tsandboxInfo, err := manager.GetSandboxBySession(context.Background(), \"test-session-id\", \"default\", \"test\", types.AgentRuntimeKind)\n320: \t\tif err != nil {\n321: \t\t\tt.Errorf(\"GetSandboxBySession returned error: %v\", err)\n322: \t\t}\n323: \n324: \t\tif sandboxInfo == nil {\n325: \t\t\tt.Fatal(\"Expected non-nil sandbox info\")\n326: \t\t}\n327: \n328: \t\tif sandboxInfo.SessionID != \"test-session-id\" {\n329: \t\t\tt.Errorf(\"Expected session ID 'test-session-id', got '%s'\", sandboxInfo.SessionID)\n330: \t\t}\n331: \t})\n332: \n333: \tt.Run(\"Session not found\", func(t *testing.T) {\n334: \t\tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n335: \t\t\tw.WriteHeader(http.StatusNotFound)\n336: \t\t\tw.Write([]byte(`{\"error\": \"session not found\"}`))\n337: \t\t}))\n338: \t\tdefer server.Close()\n339: \n340: \t\tfakeStore := &fakeStore{}\n341: \t\tmanager, err := NewSessionManager(fakeStore, server.URL)\n342: \t\tif err != nil {\n343: \t\t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n344: \t\t}\n345: \n346: \t\t_, err = manager.GetSandboxBySession(context.Background(), \"nonexistent-session\", \"default\", \"test\", types.AgentRuntimeKind)\n347: \t\tif err == nil {\n348: \t\t\tt.Error(\"Expected error for non-existent session\")\n349: \t\t}\n350: \n351: \t\tvar notFoundErr *SandboxNotFoundError\n352: \t\tif !errors.As(err, &notFoundErr) {\n353: \t\t\tt.Errorf(\"Expected SandboxNotFoundError, got %T\", err)\n354: \t\t}\n355: \t})\n356: }\n357: \n358: func TestSessionManager_ListSessions(t *testing.T) {\n359: \texpectedSandboxes := map[string]*types.SandboxInfo{\n360: \t\t\"session-1\": {\n361: \t\t\tSessionID: \"session-1\",\n362: \t\t\tName:      \"test-1\",\n363: \t\t\tNamespace: \"default\",\n364: \t\t\tKind:      types.AgentRuntimeKind,\n365: \t\t},\n366: \t\t\"session-2\": {\n367: \t\t\tSessionID: \"session-2\",\n368: \t\t\tName:      \"test-2\",\n369: \t\t\tNamespace: \"default\",\n370: \t\t\tKind:      types.CodeInterpreterKind,\n371: \t\t},\n372: \t}\n373: \n374: \tfakeStore := &fakeStore{\n375: \t\tsandboxes: expectedSandboxes,\n376: \t}\n377: \n378: \tmanager, err := NewSessionManager(fakeStore, \"http://test:8080\")\n379: \tif err != nil {\n380: \t\tt.Fatalf(\"NewSessionManager returned error: %v\", err)\n381: \t}\n382: \n383: \tsessions, err := manager.ListSessions(context.Background())\n384: \tif err != nil {\n385: \t\tt.Errorf(\"ListSessions returned error: %v\", err)\n386: \t}\n387: \n388: \tif len(sessions) != len(expectedSandboxes) {\n389: \t\tt.Errorf(\"Expected %d sessions, got %d\", len(expectedSandboxes), len(sessions))\n390: \t}\n391: }\n392: \n393: func TestIsResourceReady(t *testing.T) {\n394: \tt.Run(\"Ready condition true\", func(t *testing.T) {\n395: \t\tconditions := []metav1.Condition{\n396: \t\t\t{\n397: \t\t\t\tType:   \"Ready\",\n398: \t\t\t\tStatus: metav1.ConditionTrue,\n399: \t\t\t},\n400: \t\t}\n401: \n402: \t\tif !isResourceReady(conditions) {\n403: \t\t\tt.Error(\"Expected resource to be ready\")\n404: \t\t}\n405: \t})\n406: \n407: \tt.Run(\"Ready condition false\", func(t *testing.T) {\n408: \t\tconditions := []metav1.Condition{\n409: \t\t\t{\n410: \t\t\t\tType:   \"Ready\",\n411: \t\t\t\tStatus: metav1.ConditionFalse,\n412: \t\t\t},\n413: \t\t}\n414: \n415: \t\tif isResourceReady(conditions) {\n416: \t\t\tt.Error(\"Expected resource not to be ready\")\n417: \t\t}\n418: \t})\n419: \n420: \tt.Run(\"No conditions\", func(t *testing.T) {\n421: \t\tconditions := []metav1.Condition{}\n422: \n423: \t\tif isResourceReady(conditions) {\n424: \t\t\tt.Error(\"Expected resource not to be ready with no conditions\")\n425: \t\t}\n426: \t})\n427: \n428: \tt.Run(\"Other conditions\", func(t *testing.T) {\n429: \t\tconditions := []metav1.Condition{\n430: \t\t\t{\n431: \t\t\t\tType:   \"Other\",\n432: \t\t\t\tStatus: metav1.ConditionTrue,\n433: \t\t\t},\n434: \t\t}\n435: \n436: \t\tif isResourceReady(conditions) {\n437: \t\t\tt.Error(\"Expected resource not to be ready with other conditions\")\n438: \t\t}\n439: \t})\n440: }\n441: \n442: func TestIsResourceBeingDeleted(t *testing.T) {\n443: \tt.Run(\"Not being deleted\", func(t *testing.T) {\n444: \t\tobj := &metav1.ObjectMeta{\n445: \t\t\tName:              \"test\",\n446: \t\t\tDeletionTimestamp: nil,\n447: \t\t}\n448: \n449: \t\tif isResourceBeingDeleted(obj) {\n450: \t\t\tt.Error(\"Expected resource not to be deleted\")\n451: \t\t}\n452: \t})\n453: \n454: \tt.Run(\"Being deleted\", func(t *testing.T) {\n455: \t\tnow := metav1.Now()\n456: \t\tobj := &metav1.ObjectMeta{\n457: \t\t\tName:              \"test\",\n458: \t\t\tDeletionTimestamp: &now,\n459: \t\t}\n460: \n461: \t\tif !isResourceBeingDeleted(obj) {\n462: \t\t\tt.Error(\"Expected resource to be deleted\")\n463: \t\t}\n464: \t})\n465: }\n466: \n467: func TestConditionsChanged(t *testing.T) {\n468: \tt.Run(\"Same conditions\", func(t *testing.T) {\n469: \t\toldConditions := []metav1.Condition{\n470: \t\t\t{\n471: \t\t\t\tType:   \"Ready\",\n472: \t\t\t\tStatus: metav1.ConditionTrue,\n473: \t\t\t\tReason: \"Ready\",\n474: \t\t\t},\n475: \t\t}\n476: \n477: \t\tnewConditions := []metav1.Condition{\n478: \t\t\t{\n479: \t\t\t\tType:   \"Ready\",\n480: \t\t\t\tStatus: metav1.ConditionTrue,\n481: \t\t\t\tReason: \"Ready\",\n482: \t\t\t},\n483: \t\t}\n484: \n485: \t\tif conditionsChanged(oldConditions, newConditions) {\n486: \t\t\tt.Error(\"Expected conditions not to have changed\")\n487: \t\t}\n488: \t})\n489: \n490: \tt.Run(\"Different status\", func(t *testing.T) {\n491: \t\toldConditions := []metav1.Condition{\n492: \t\t\t{\n493: \t\t\t\tType:   \"Ready\",\n494: \t\t\t\tStatus: metav1.ConditionTrue,\n495: \t\t\t\tReason: \"Ready\",\n496: \t\t\t},\n497: \t\t}\n498: \n499: \t\tnewConditions := []metav1.Condition{\n500: \t\t\t{\n501: \t\t\t\tType:   \"Ready\",\n502: \t\t\t\tStatus: metav1.ConditionFalse,\n503: \t\t\t\tReason: \"NotReady\",\n504: \t\t\t},\n505: \t\t}\n506: \n507: \t\tif !conditionsChanged(oldConditions, newConditions) {\n508: \t\t\tt.Error(\"Expected conditions to have changed\")\n509: \t\t}\n510: \t})\n511: \n512: \tt.Run(\"Different length\", func(t *testing.T) {\n513: \t\toldConditions := []metav1.Condition{\n514: \t\t\t{\n515: \t\t\t\tType:   \"Ready\",\n516: \t\t\t\tStatus: metav1.ConditionTrue,\n517: \t\t\t},\n518: \t\t}\n519: \n520: \t\tnewConditions := []metav1.Condition{\n521: \t\t\t{\n522: \t\t\t\tType:   \"Ready\",\n523: \t\t\t\tStatus: metav1.ConditionTrue,\n524: \t\t\t},\n525: \t\t\t{\n526: \t\t\t\tType:   \"Available\",\n527: \t\t\t\tStatus: metav1.ConditionTrue,\n528: \t\t\t},\n529: \t\t}\n530: \n531: \t\tif !conditionsChanged(oldConditions, newConditions) {\n532: \t\t\tt.Error(\"Expected conditions to have changed\")\n533: \t\t}\n534: \t})\n535: }\n536: \n537: func TestGetResourceStatus(t *testing.T) {\n538: \tt.Run(\"Ready condition true\", func(t *testing.T) {\n539: \t\tconditions := []metav1.Condition{\n540: \t\t\t{\n541: \t\t\t\tType:   \"Ready\",\n542: \t\t\t\tStatus: metav1.ConditionTrue,\n543: \t\t\t},\n544: \t\t}\n545: \n546: \t\tstatus := GetResourceStatus(conditions)\n547: \t\tif status != \"Ready\" {\n548: \t\t\tt.Errorf(\"Expected status 'Ready', got '%s'\", status)\n549: \t\t}\n550: \t})\n551: \n552: \tt.Run(\"Ready condition false with reason\", func(t *testing.T) {\n553: \t\tconditions := []metav1.Condition{\n554: \t\t\t{\n555: \t\t\t\tType:   \"Ready\",\n556: \t\t\t\tStatus: metav1.ConditionFalse,\n557: \t\t\t\tReason: \"NotReady\",\n558: \t\t\t},\n559: \t\t}\n560: \n561: \t\tstatus := GetResourceStatus(conditions)\n562: \t\tif status != \"NotReady\" {\n563: \t\t\tt.Errorf(\"Expected status 'NotReady', got '%s'\", status)\n564: \t\t}\n565: \t})\n566: \n567: \tt.Run(\"No conditions\", func(t *testing.T) {\n568: \t\tconditions := []metav1.Condition{}\n569: \n570: \t\tstatus := GetResourceStatus(conditions)\n571: \t\tif status != \"Unknown\" {\n572: \t\t\tt.Errorf(\"Expected status 'Unknown', got '%s'\", status)\n573: \t\t}\n574: \t})\n575: }\n576: \n577: type fakeStore struct {\n578: \tsandboxes map[string]*types.SandboxInfo\n579: }\n580: \n581: func (fs *fakeStore) Ping(ctx context.Context) error {\n582: \treturn nil\n583: }\n584: \n585: func (fs *fakeStore) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n586: \tif fs.sandboxes == nil {\n587: \t\treturn nil, store.ErrNotFound\n588: \t}\n589: \n590: \tsandbox, exists := fs.sandboxes[sessionID]\n591: \tif !exists {\n592: \t\treturn nil, store.ErrNotFound\n593: \t}\n594: \n595: \treturn sandbox, nil\n596: }\n597: \n598: func (fs *fakeStore) StoreSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n599: \tif fs.sandboxes == nil {\n600: \t\tfs.sandboxes = make(map[string]*types.SandboxInfo)\n601: \t}\n602: \n603: \tfs.sandboxes[sessionID] = info\n604: \treturn nil\n605: }\n606: \n607: func (fs *fakeStore) UpdateSandbox(ctx context.Context, sessionID string, info *types.SandboxInfo) error {\n608: \treturn fs.StoreSandbox(ctx, sessionID, info)\n609: }\n610: \n611: func (fs *fakeStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n612: \tif fs.sandboxes == nil {\n613: \t\treturn nil\n614: \t}\n615: \n616: \tdelete(fs.sandboxes, sessionID)\n617: \treturn nil\n618: }\n619: \n620: func (fs *fakeStore) ListSandboxes(ctx context.Context) (map[string]*types.SandboxInfo, error) {\n621: \tif fs.sandboxes == nil {\n622: \t\treturn make(map[string]*types.SandboxInfo), nil\n623: \t}\n624: \n625: \treturn fs.sandboxes, nil\n626: }\n627: \n628: func (fs *fakeStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n629: \treturn nil\n630: }\n631: \n632: func (fs *fakeStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n633: \treturn nil, nil\n634: }\n635: \n636: func (fs *fakeStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n637: \treturn nil, nil\n638: }\n639: \n640: func (fs *fakeStore) Close() error {\n641: \treturn nil\n642: }\n\n(End of file - total 642 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\nfunc TestNewSessionManager(t *testing.T) {\n\tt.Run(\"Valid parameters\", func(t *testing.T) {\n\t\tfakeStore := &fakeStore{}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/router/session_manager_test.go","time":{"start":1775851072107,"end":1775851072130}}}}
