"`\n35: \tMinIdleConns int           `json:\"minIdleConns\"`\n36: \tMaxRetries   int           `json:\"maxRetries\"`\n37: \tDialTimeout  time.Duration `json:\"dialTimeout\"`\n38: \tReadTimeout  time.Duration `json:\"readTimeout\"`\n39: \tWriteTimeout time.Duration `json:\"writeTimeout\"`\n40: \tPoolTimeout  time.Duration `json:\"poolTimeout\"`\n41: \tIdleTimeout  time.Duration `json:\"idleTimeout\"`\n42: }\n43: \n44: type K8sConfig struct {\n45: \tQPS             float64       `json:\"qps\"`\n46: \tBurst           int           `json:\"burst\"`\n47: \tTimeout         time.Duration `json:\"timeout\"`\n48: \tInClusterConfig bool          `json:\"inClusterConfig\"`\n49: \tKubeconfig      string        `json:\"kubeconfig\"`\n50: }\n51: \n52: type AuthConfig struct {\n53: \tEnableAuth           bool          `json:\"enableAuth\"`\n54: \tJWTExpiration        time.Duration `json:\"jwtExpiration\"`\n55: \tEnableK8sTokenReview bool          `json:\"enableK8sTokenReview\"`\n56: \tK8sAPIAudience       string        `json:\"k8sAPIAudience\"`\n57: \tTokenCacheSize       int           `json:\"tokenCacheSize\"`\n58: \tTokenCacheTTL        time.Duration `json:\"tokenCacheTTL\"`\n59: }\n60: \n61: type SessionConfig struct {\n62: \tDefaultTimeout    time.Duration `json:\"defaultTimeout\"`\n63: \tMaxDuration       time.Duration `json:\"maxDuration\"`\n64: \tCleanupInterval   time.Duration `json:\"cleanupInterval\"`\n65: \tKeepAliveEnabled  bool          `json:\"keepAliveEnabled\"`\n66: \tKeepAliveInterval time.Duration `json:\"keepAliveInterval\"`\n67: \tRenewalWindow     time.Duration `json:\"renewalWindow\"`\n68: }\n69: \n70: func DefaultConfig() *Config {\n71: \treturn &Config{\n72: \t\tServer: ServerConfig{\n73: \t\t\tPort:            \"8080\",\n74: \t\t\tHost:            \"0.0.0.0\",\n75: \t\t\tReadTimeout:     30 * time.Second,\n76: \t\t\tWriteTimeout:    30 * time.Second,\n77: \t\t\tIdleTimeout:     60 * time.Second,\n78: \t\t\tShutdownTimeout: 15 * time.Second,\n79: \t\t\tEnableProfiling: false,\n80: \t\t\tEnablePprof:     false,\n81: \t\t\tMaxHeaderBytes:  1 << 20,\n82: \t\t\tEnableTLS:       false,\n83: \t\t},\n84: \t\tRedis: RedisConfig{\n85: \t\t\tAddr:         \"localhost:6379\",\n86: \t\t\tPassword:     \"\",\n87: \t\t\tDB:           0,\n88: \t\t\tPoolSize:     10,\n89: \t\t\tMinIdleConns: 2,\n90: \t\t\tMaxRetries:   3,\n91: \t\t\tDialTimeout:  5 * time.Second,\n92: \t\t\tReadTimeout:  3 * time.Second,\n93: \t\t\tWriteTimeout: 3 * time.Second,\n94: \t\t\tPoolTimeout:  4 * time.Second,\n95: \t\t\tIdleTimeout:  5 * time.Minute,\n96: \t\t},\n97: \t\tK8s: K8sConfig{\n98: \t\t\tQPS:             50,\n99: \t\t\tBurst:           100,\n100: \t\t\tTimeout:         30 * time.Second,\n101: \t\t\tInClusterConfig: true,\n102: \t\t\tKubeconfig:      \"\",\n103: \t\t},\n104: \t\tAuth: AuthConfig{\n105: \t\t\tEnableAuth:           false,\n106: \t\t\tJWTExpiration:        5 * time.Minute,\n107: \t\t\tEnableK8sTokenReview: false,\n108: \t\t\tK8sAPIAudience:       \"agentcube\",\n109: \t\t\tTokenCacheSize:       1000,\n110: \t\t\tTokenCacheTTL:        5 * time.Minute,\n111: \t\t},\n112: \t\tSession: SessionConfig{\n113: \t\t\tDefaultTimeout:    15 * time.Minute,\n114: \t\t\tMaxDuration:       8 * time.Hour,\n115: \t\t\tCleanupInterval:   15 * time.Second,\n116: \t\t\tKeepAliveEnabled:  true,\n117: \t\t\tKeepAliveInterval: 5 * time.Minute,\n118: \t\t\tRenewalWindow:     2 * time.Minute,\n119: \t\t},\n120: \t}\n121: }\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"package config\n\nimport (\n\t\"time\"\n)\n\ntype Config struct {\n\tServer  ServerConfig  `json:\"server\"`\n\tRedis   RedisConfig   `json:\"redis\"`\n\tK8s     K8sConfig     `json:\"k8s\"`\n\tAuth    AuthConfig    `json:\"auth\"`\n\tSession SessionConfig `json:\"session\"`\n}\n\ntype ServerConfig struct {\n\tPort            string        `json:\"port\"`\n\tHost            string        `json:\"host\"`\n\tReadTimeout     time.Duration `json:\"readTimeout\"`\n\tWriteTim