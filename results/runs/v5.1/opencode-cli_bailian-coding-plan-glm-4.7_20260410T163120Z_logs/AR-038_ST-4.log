sClient_GetPodIP_FromLabelSelector(t *testing.T) {\n    scheme := runtime.NewScheme()\n    clientset := fake.NewSimpleClientset()\n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n    pod := &corev1.Pod{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"test-pod\",\n            Namespace: \"default\",\n            Labels: map[string]string{\n                \"runtime.agentcube.io/sandbox-name\": \"test-sandbox\",\n            },\n            OwnerReferences: []metav1.OwnerReference{\n                {\n                    Kind: \"Sandbox\",\n                    Name: \"test-sandbox\",\n                },\n            },\n        },\n        Status: corev1.PodStatus{\n            Phase: corev1.PodRunning,\n            PodIP: \"10.0.0.2\",\n        },\n    }\n\n    _, err := clientset.CoreV1().Pods(\"default\").Create(context.Background(), pod, metav1.CreateOptions{})\n    assert.NoError(t, err)\n\n    k8sClient := &K8sClient{\n        clientset: clientset,\n        dynamic:   dynamicClient,\n    }\n\n    sandbox := &unstructured.Unstructured{\n        Object: map[string]interface{}{},\n    }\n\n    ip, err := k8sClient.GetPodIP(context.Background(), \"test-sandbox\", \"default\", sandbox)\n\n    assert.NoError(t, err)\n    assert.Equal(t, \"10.0.0.2\", ip)\n}\n\nfunc TestK8sClient_GetPodIP_NotRunning(t *testing.T) {\n    scheme := runtime.NewScheme()\n    clientset := fake.NewSimpleClientset()\n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n    pod := &corev1.Pod{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"test-sandbox\",\n            Namespace: \"default\",\n        },\n        Status: corev1.PodStatus{\n            Phase: corev1.PodPending,\n        },\n    }\n\n    _, err := clientset.CoreV1().Pods(\"default\").Create(context.Background(), pod, metav1.CreateOptions{})\n    assert.NoError(t, err)\n\n    k8sClient := &K8sClient{\n        clientset: clientset,\n        dynamic:   dynamicClient,\n    }\n\n    sandbox := &unstructured.Unstructured{\n        Object: map[string]interface{}{},\n    }\n\n    ip, err := k8sClient.GetPodIP(context.Background(), \"test-sandbox\", \"default\", sandbox)\n\n    assert.Error(t, err)\n    assert.Empty(t, ip)\n    assert.Contains(t, err.Error(), \"not running\")\n}\n\nfunc TestK8sClient_DeleteSandbox(t *testing.T) {\n    scheme := runtime.NewScheme()\n    scheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n        &unstructured.Unstructured{},\n    )\n    \n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n    clientset := fake.NewSimpleClientset()\n\n    sandbox := &unstructured.Unstructured{\n        Object: map[string]interface{}{\n            \"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n            \"kind\":       \"Sandbox\",\n            \"metadata\": map[string]interface{}{\n                \"name\":      \"test-sandbox\",\n                \"namespace\": \"default\",\n            },\n        },\n    }\n\n    _, err := dynamicClient.Resource(workloadmanager.SandboxGVR).\n        Namespace(\"default\").\n        Create(context.Background(), sandbox, metav1.CreateOptions{})\n    assert.NoError(t, err)\n\n    k8sClient := &K8sClient{\n        clientset: clientset,\n        dynamic:   dynamicClient,\n    }\n\n    err = k8sClient.DeleteSandbox(context.Background(), \"default\", \"test-sandbox\")\n\n    assert.NoError(t, err)\n}\n\nfunc TestK8sClient_WatchPods(t *testing.T) {\n    scheme := runtime.NewScheme()\n    clientset := fake.NewSimpleClientset()\n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n    k8sClient := &K8sClient{\n        clientset: clientset,\n        dynamic:   dynamicClient,\n    }\n\n    ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n    defer cancel()\n\n    podCh, err := k8sClient.WatchPods(ctx, \"default\", \"test-sandbox\")\n    \n    assert.NoError(t, err)\n    assert.NotNil(t, podCh)\n\n    select {\n    case <-podCh:\n        // Pod IP received\n    case <-ctx.Done():\n        // Timeout expected in fake client\n    }\n}\n\nfunc TestK8sClient_GetSecret(t *testing.T) {\n    scheme := runtime.NewScheme()\n    clientset := fake.NewSimpleClientset()\n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n\n    secret := &corev1.Secret{\n        ObjectMeta: metav1.ObjectMeta{\n            Name:      \"test-secret\",\n            Namespace: \"default\",\n        },\n        Data: map[string][]byte{\n            \"password\": []byte(\"secret123\"),\n        },\n    }\n\n    _, err := clientset.CoreV1().Secrets(\"default\").Create(context.Background(), secret, metav1.CreateOptions{})\n    assert.NoError(t, err)\n\n    k8sClient := &K8sClient{\n        clientset: clientset,\n        dynamic:   dynamicClient,\n    }\n\n    retrievedSecret, err := k8sClient.GetSecret(context.Background(), \"default\", \"test-secret\")\n\n    assert.NoError(t, err)\n    assert.Equal(t, \"test-secret\", retrievedSecret.Name)\n    assert.Equal(t, []byte(\"secret123\"), retrievedSecret.Data[\"password\"])\n}\n```\n\n**Step 2: Run tests**\n\n```bash\ngo test ./pkg/workloadmanager/client/ -v\n```\n\nExpected: All tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/workloadmanager/client/k8s_client_test.go\ngit commit -m \"test(ar-038): enhance k8s client test coverage\"\n```\n\n---\n\n### Task 9: 创建 auth/k8s_auth_test.go\n\n**Files:**\n- Create: `pkg/workloadmanager/auth/k8s_auth_test.go`\n- Verify: `pkg/workloadmanager/auth/k8s_auth.go`\n\n**Step 1: Write authentication tests**\n\n```go\n// pkg/workloadmanager/auth/k8s_auth_test.go\n\npackage auth\n\nimport (\n    \"context\"\n    \"testing\"\n    \"time\"\n\n    \"github.com/stretchr/testify/assert\"\n    authenticationv1 \"k8s.io/api/authentication/v1\"\n    metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n    \"k8s.io/client-go/kubernetes/fake\"\n)\n\nfunc TestNewK8sAuthenticator(t *testing.T) {\n    clientset := fake.NewSimpleClientset()\n    authenticator := NewK8sAuthenticator(clientset, \"test-audience\")\n\n    assert.NotNil(t, authenticator)\n    assert.Equal(t, \"test-audience\", authenticator.audience)\n}\n\nfunc TestK8sAuthenticator_Authenticate_Success(t *testing.T) {\n    clientset := fake.NewSimpleClientset()\n    authenticator := NewK8sAuthenticator(clientset, \"agentcube\")\n\n    token := \"test-token\"\n\n    info, err := authenticator.Authenticate(context.Background(), token)\n\n    assert.NoError(t, err)\n    assert.NotNil(t, info)\n    assert.NotEmpty(t, info.Username)\n    assert.NotEmpty(t, info.UID)\n    assert.NotEmpty(t, info.Groups)\n}\n\nfunc TestK8sAuthenticator_Authenticate_Failed(t *testing.T) {\n    clientset := fake.NewSimpleClientset()\n    \n    // Create a token review that fails\n    failedReview := &authenticationv1.TokenReview{\n        Status: authenticationv1.TokenReviewStatus{\n            Authenticated: false,\n        },\n    }\n\n    _, err := clientset.AuthenticationV1().TokenReviews().Create(context.Background(), failedReview, metav1.CreateOptions{})\n    if err != nil {\n        // Ignore error in fake client\n    }\n\n    authenticator := NewK8sAuthenticator(clientset, \"agentcube\")\n\n    info, err := authenticator.Authenticate(context.Background(), \"invalid-token\")\n\n    assert.Error(t, err)\n    assert.Nil(t, info)\n    assert.Contains(t, err.Error(), \"authentication failed\")\n}\n\nfunc TestNewTokenCache(t *testing.T) {\n    cache := NewTokenCache(5 * time.Minute)\n\n    assert.NotNil(t, cache)\n    assert.NotNil(t, cache.cache)\n    assert.Equal(t, 5*time.Minute, cache.ttl)\n}\n\nfunc TestTokenCache_Get_Put(t *testing.T) {\n    cache := NewTokenCache(5 * time.Minute)\n\n    info := &AuthenticationInfo{\n        Username: \"test-user\",\n        UID:      \"uid-123\",\n        Groups:   []string{\"system:authenticated\"},\n    }\n\n    cache.Put(\"token-1\", info)\n\n    retrieved, exists := cache.Get(\"token-1\")\n\n    assert.True(t, exists)\n    assert.Equal(t, info.Username, retrieved.Username)\n    assert.Equal(t, info.UID, retrieved.UID)\n    assert.Equal(t, info.Groups, retrieved.Groups)\n}\n\nfunc TestTokenCache_Get_NotFound(t *testing.T) {\n    cache := NewTokenCache(5 * time.Minute)\n\n    retrieved, exists := cache.Get(\"non-existent-token\")\n\n    assert.False(t, exists)\n    assert.Nil(t, retrieved)\n}\n\nfunc TestTokenCache_Get_Expired(t *testing.T) {\n    cache := NewTokenCache(1 * time.Millisecond)\n\n    info := &AuthenticationInfo{\n        Username: \"test-user\",\n        UID:      \"uid-123\",\n        Groups:   []string{\"system:authenticated\"},\n    }\n\n    cache.Put(\"token-1\", info)\n\n    time.Sleep(10 * time.Millisecond)\n\n    retrieved, exists := cache.Get(\"token-1\")\n\n    assert.False(t, exists)\n    assert.Nil(t, retrieved)\n}\n\nfunc TestTokenCache_Delete(t *testing.T) {\n    cache := NewTokenCache(5 * time.Minute)\n\n    info := &AuthenticationInfo{\n        Username: \"test-user\",\n    }\n\n    cache.Put(\"token-1\", info)\n    cache.Delete(\"token-1\")\n\n    retrieved, exists := cache.Get(\"token-1\")\n\n    assert.False(t, exists)\n    assert.Nil(t, retrieved)\n}\n\nfunc TestTokenCache_Cleanup(t *testing.T) {\n    cache := NewTokenCache(10 * time.Millisecond)\n\n    info1 := &AuthenticationInfo{Username: \"user1\"}\n    info2 := &AuthenticationInfo{Username: \"user2\"}\n\n    cache.Put(\"token-1\", info1)\n    cache.Put(\"token-2\", info2)\n\n    time.Sleep(20 * time.Millisecond)\n\n    cache.Cleanup()\n\n    _, exists1 := cache.Get(\"token-1\")\n    _, exists2 := cache.Get(\"token-2\")\n\n    assert.False(t, exists1)\n    assert.False(t, exists2)\n}\n\nfunc TestTokenCache_ConcurrentAccess(t *testing.T) {\n    cache := NewTokenCache(5 * time.Minute)\n\n    var wg sync.WaitGroup\n    for i := 0; i < 100; i++ {\n        wg.Add(1)\n        go func(n int) {\n            defer wg.Done()\n            token := fmt.Sprintf(\"token-%d\", n)\n            info := &AuthenticationInfo{\n                Username: fmt.Sprintf(\"user-%d\", n),\n            }\n            cache.Put(token, info)\n        }(i)\n    }\n    wg.Wait()\n\n    for i := 0; i < 100; i++ {\n        token := fmt.Sprintf(\"token-%d\", i)\n        retrieved, exists := cache.Get(token)\n        assert.True(t, exists)\n        assert.Equal(t, fmt.Sprintf(\"user-%d\", i), retrieved.Username)\n    }\n}\n```\n\n**Step 2: Run tests**\n\n```bash\ngo test ./pkg/workloadmanager/auth/ -v\n```\n\nExpected: All tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/workloadmanager/auth/k8s_auth_test.go\ngit commit -m \"test(ar-038): add k8s auth test coverage\"\n```\n\n---\n\n### Task 10: 更新 middleware/middleware_test.go\n\n**Files:**\n- Verify: `pkg/workloadmanager/middleware/middleware_test.go`\n- Verify: `pkg/workloadmanager/middleware/middleware.go`\n\n**Step 1: Enhance middleware tests**\n\n```go\n// pkg/workloadmanager/middleware/middleware_test.go\n\nfunc TestRecoveryMiddleware_Panic(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    router := gin.New()\n    router.Use(RecoveryMiddleware())\n    \n    router.GET(\"/panic\", func(c *gin.Context) {\n        panic(\"test panic\")\n    })\n\n    req, _ := http.NewRequest(\"GET\", \"/panic\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusInternalServerError, w.Code)\n    assert.Contains(t, w.Body.String(), \"internal server error\")\n}\n\nfunc TestLoggingMiddleware(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    router := gin.New()\n    router.Use(LoggingMiddleware())\n    \n    router.GET(\"/test\", func(c *gin.Context) {\n        c.JSON(http.StatusOK, gin.H{\"message\": \"ok\"})\n    })\n\n    req, _ := http.NewRequest(\"GET\", \"/test\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusOK, w.Code)\n}\n\nfunc TestCORSMiddleware_Options(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    router := gin.New()\n    router.Use(CORSMiddleware())\n    \n    router.GET(\"/test\", func(c *gin.Context) {\n        c.JSON(http.StatusOK, gin.H{})\n    })\n\n    req, _ := http.NewRequest(\"OPTIONS\", \"/test\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusNoContent, w.Code)\n    assert.Equal(t, \"*\", w.Header().Get(\"Access-Control-Allow-Origin\"))\n    assert.Equal(t, \"true\", w.Header().Get(\"Access-Control-Allow-Credentials\"))\n}\n\nfunc TestCORSMiddleware_Get(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    router := gin.New()\n    router.Use(CORSMiddleware())\n    \n    router.GET(\"/test\", func(c *gin.Context) {\n        c.JSON(http.StatusOK, gin.H{\"message\": \"ok\"})\n    })\n\n    req, _ := http.NewRequest(\"GET\", \"/test\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusOK, w.Code)\n    assert.Equal(t, \"*\", w.Header().Get(\"Access-Control-Allow-Origin\"))\n    assert.Equal(t, \"POST, OPTIONS, GET, PUT, DELETE\", w.Header().Get(\"Access-Control-Allow-Methods\"))\n}\n\nfunc TestCORSMiddleware_Post(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    router := gin.New()\n    router.Use(CORSMiddleware())\n    \n    router.POST(\"/test\", func(c *gin.Context) {\n        c.JSON(http.StatusOK, gin.H{\"message\": \"ok\"})\n    })\n\n    req, _ := http.NewRequest(\"POST\", \"/test\", strings.NewReader(\"{}\"))\n    req.Header.Set(\"Content-Type\", \"application/json\")\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusOK, w.Code)\n}\n```\n\n**Step 2: Run tests**\n\n```bash\ngo test ./pkg/workloadmanager/middleware/ -v\n```\n\nExpected: All tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/workloadmanager/middleware/middleware_test.go\ngit commit -m \"test(ar-038): enhance middleware test coverage\"\n```\n\n---\n\n### Task 11: 更新 config/config_test.go\n\n**Files:**\n- Verify: `pkg/w