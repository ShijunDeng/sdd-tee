.Equal(t, 5*time.Minute, config.Auth.TokenCacheTTL)\n\n    assert.Equal(t, 15*time.Minute, config.Session.DefaultTimeout)\n    assert.Equal(t, 8*time.Hour, config.Session.MaxDuration)\n    assert.Equal(t, 15*time.Second, config.Session.CleanupInterval)\n    assert.True(t, config.Session.KeepAliveEnabled)\n    assert.Equal(t, 5*time.Minute, config.Session.KeepAliveInterval)\n    assert.Equal(t, 2*time.Minute, config.Session.RenewalWindow)\n}\n\nfunc TestConfig_CustomValues(t *testing.T) {\n    config := &Config{\n        Server: ServerConfig{\n            Port:            \"9090\",\n            Host:            \"127.0.0.1\",\n            ReadTimeout:     60 * time.Second,\n            WriteTimeout:    60 * time.Second,\n            IdleTimeout:     120 * time.Second,\n            ShutdownTimeout: 30 * time.Second,\n            EnableTLS:       true,\n            TLSCertFile:     \"/path/to/cert.pem\",\n            TLSKeyFile:      \"/path/to/key.pem\",\n        },\n        Redis: RedisConfig{\n            Addr:     \"redis:6379\",\n            Password: \"secret\",\n            DB:       1,\n        },\n        K8s: K8sConfig{\n            QPS:             100.0,\n            Burst:           200,\n            InClusterConfig: false,\n            Kubeconfig:      \"/path/to/kubeconfig\",\n        },\n        Auth: AuthConfig{\n            EnableAuth:           true,\n            JWTExpiration:        10 * time.Minute,\n            EnableK8sTokenReview: true,\n        },\n        Session: SessionConfig{\n            DefaultTimeout: 30 * time.Minute,\n            MaxDuration:    24 * time.Hour,\n        },\n    }\n\n    assert.Equal(t, \"9090\", config.Server.Port)\n    assert.Equal(t, \"127.0.0.1\", config.Server.Host)\n    assert.Equal(t, \"redis:6379\", config.Redis.Addr)\n    assert.Equal(t, \"secret\", config.Redis.Password)\n    assert.Equal(t, float64(100), config.K8s.QPS)\n    assert.Equal(t, 200, config.K8s.Burst)\n    assert.True(t, config.Auth.EnableAuth)\n    assert.Equal(t, 10*time.Minute, config.Auth.JWTExpiration)\n    assert.Equal(t, 30*time.Minute, config.Session.DefaultTimeout)\n}\n```\n\n**Step 2: Run tests**\n\n```bash\ngo test ./pkg/workloadmanager/config/ -v\n```\n\nExpected: All tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/workloadmanager/config/config_test.go\ngit commit -m \"test(ar-038): enhance config test coverage\"\n```\n\n---\n\n### Task 12: 更新 api/response_test.go\n\n**Files:**\n- Verify: `pkg/workloadmanager/api/response_test.go`\n- Verify: `pkg/workloadmanager/api/response.go`\n\n**Step 1: Enhance API response tests**\n\n```go\n// pkg/workloadmanager/api/response_test.go\n\nfunc TestJSON(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    router := gin.New()\n    router.GET(\"/test\", func(c *gin.Context) {\n        data := gin.H{\n            \"message\": \"success\",\n            \"code\":    200,\n        }\n        JSON(c, http.StatusOK, data)\n    })\n\n    req, _ := http.NewRequest(\"GET\", \"/test\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusOK, w.Code)\n    \n    var resp map[string]interface{}\n    json.Unmarshal(w.Body.Bytes(), &resp)\n    assert.Equal(t, \"success\", resp[\"message\"])\n    assert.Equal(t, float64(200), resp[\"code\"])\n}\n\nfunc TestError_WithCode(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    router := gin.New()\n    router.GET(\"/error\", func(c *gin.Context) {\n        Error(c, http.StatusBadRequest, 40001, \"invalid request\")\n    })\n\n    req, _ := http.NewRequest(\"GET\", \"/error\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusBadRequest, w.Code)\n    \n    var resp map[string]interface{}\n    json.Unmarshal(w.Body.Bytes(), &resp)\n    assert.Equal(t, float64(40001), resp[\"code\"])\n    assert.Equal(t, \"invalid request\", resp[\"message\"])\n}\n\nfunc TestError_WithNilCode(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    router := gin.New()\n    router.GET(\"/error\", func(c *gin.Context) {\n        Error(c, http.StatusInternalServerError, 0, \"internal error\")\n    })\n\n    req, _ := http.NewRequest(\"GET\", \"/error\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusInternalServerError, w.Code)\n}\n\nfunc TestError_ContentType(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    router := gin.New()\n    router.GET(\"/error\", func(c *gin.Context) {\n        Error(c, http.StatusBadRequest, 40001, \"bad request\")\n    })\n\n    req, _ := http.NewRequest(\"GET\", \"/error\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, \"application/json; charset=utf-8\", w.Header().Get(\"Content-Type\"))\n}\n```\n\n**Step 2: Run tests**\n\n```bash\ngo test ./pkg/workloadmanager/api/ -v\n```\n\nExpected: All tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/workloadmanager/api/response_test.go\ngit commit -m \"test(ar-038): enhance api response test coverage\"\n```\n\n---\n\n### Task 13: 更新 garbage_collector_test.go\n\n**Files:**\n- Verify: `pkg/workloadmanager/garbage_collector_test.go`\n- Verify: `pkg/workloadmanager/garbage_collector.go`\n\n**Step 1: Enhance garbage collector tests**\n\n```go\n// pkg/workloadmanager/garbage_collector_test.go\n\nfunc TestNewGarbageCollector(t *testing.T) {\n    scheme := runtime.NewScheme()\n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n    mockStore := &mockStore{}\n\n    gc := NewGarbageCollector(dynamicClient, mockStore, 15*time.Second)\n\n    assert.NotNil(t, gc)\n    assert.Equal(t, dynamicClient, gc.dynamicClient)\n    assert.Equal(t, mockStore, gc.storeClient)\n    assert.Equal(t, 15*time.Second, gc.interval)\n    assert.NotNil(t, gc.ctx)\n    assert.NotNil(t, gc.cancel)\n}\n\nfunc TestGarbageCollector_StartStop(t *testing.T) {\n    scheme := runtime.NewScheme()\n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n    mockStore := &mockStore{}\n\n    gc := NewGarbageCollector(dynamicClient, mockStore, 100*time.Millisecond)\n    \n    gc.Start()\n    \n    time.Sleep(200 * time.Millisecond)\n    \n    gc.Stop()\n    \n    time.Sleep(100 * time.Millisecond)\n}\n\nfunc TestGarbageCollector_tick_IdleSandboxes(t *testing.T) {\n    scheme := runtime.NewScheme()\n    scheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n        &unstructured.Unstructured{},\n    )\n    \n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n    mockStore := &mockStore{}\n\n    idleSandbox := &types.SandboxInfo{\n        SessionID:          \"idle-session\",\n        SandboxID:          \"idle-sandbox\",\n        SandboxName:        \"idle-sandbox\",\n        SandboxNamespace:   \"default\",\n        Kind:               \"Sandbox\",\n        LastActivityAt:     time.Now().Add(-20 * time.Minute),\n    }\n\n    mockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{idleSandbox}, nil)\n    mockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n    mockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"idle-session\").Return(nil)\n\n    gc := NewGarbageCollector(dynamicClient, mockStore, 1*time.Minute)\n    gc.tick()\n\n    mockStore.AssertExpectations(t)\n}\n\nfunc TestGarbageCollector_tick_ExpiredSandboxes(t *testing.T) {\n    scheme := runtime.NewScheme()\n    scheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n        &unstructured.Unstructured{},\n    )\n    \n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n    mockStore := &mockStore{}\n\n    expiredSandbox := &types.SandboxInfo{\n        SessionID:          \"expired-session\",\n        SandboxID:          \"expired-sandbox\",\n        SandboxName:        \"expired-sandbox\",\n        SandboxNamespace:   \"default\",\n        Kind:               \"Sandbox\",\n        LastActivityAt:     time.Now(),\n        ExpiresAt:          time.Now().Add(-1 * time.Hour),\n    }\n\n    mockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n    mockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{expiredSandbox}, nil)\n    mockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"expired-session\").Return(nil)\n\n    gc := NewGarbageCollector(dynamicClient, mockStore, 1*time.Minute)\n    gc.tick()\n\n    mockStore.AssertExpectations(t)\n}\n\nfunc TestGarbageCollector_tick_ListError(t *testing.T) {\n    scheme := runtime.NewScheme()\n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n    mockStore := &mockStore{}\n\n    mockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return(nil, fmt.Errorf(\"list error\"))\n    mockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return(nil, fmt.Errorf(\"list error\"))\n\n    gc := NewGarbageCollector(dynamicClient, mockStore, 1*time.Minute)\n    \n    // Should not panic\n    gc.tick()\n\n    mockStore.AssertExpectations(t)\n}\n\nfunc TestGarbageCollector_deleteSandbox_SandboxClaim(t *testing.T) {\n    scheme := runtime.NewScheme()\n    scheme.AddKnownTypes(schema.GroupVersion{Group: \"extensions.agents.x-k8s.io\", Version: \"v1alpha1\"}, \n        &unstructured.Unstructured{},\n    )\n    \n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n    mockStore := &mockStore{}\n\n    sandboxClaim := &types.SandboxInfo{\n        SessionID:          \"claim-session\",\n        SandboxID:          \"claim-123\",\n        SandboxName:        \"claim-123\",\n        SandboxNamespace:   \"default\",\n        Kind:               \"SandboxClaim\",\n    }\n\n    mockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"claim-session\").Return(nil)\n\n    gc := NewGarbageCollector(dynamicClient, mockStore, 1*time.Minute)\n    gc.deleteSandbox(context.Background(), sandboxClaim, wmTypes.CleanupReasonExpired)\n\n    mockStore.AssertExpectations(t)\n}\n\nfunc TestGarbageCollector_recordAudit(t *testing.T) {\n    scheme := runtime.NewScheme()\n    dynamicClient := fake.NewSimpleDynamicClient(scheme)\n    mockStore := &mockStore{}\n\n    gc := NewGarbageCollector(dynamicClient, mockStore, 1*time.Minute)\n\n    auditEntry := &wmTypes.CleanupAuditEntry{\n        SessionID:    \"test-session\",\n        SandboxID:    \"sandbox-123\",\n        Namespace:    \"default\",\n        Reason:       wmTypes.CleanupReasonIdleTimeout,\n        Success:      true,\n        DeletedAt:    time.Now(),\n    }\n\n    gc.recordAudit(auditEntry)\n}\n```\n\n**Step 2: Run tests**\n\n```bash\ngo test ./pkg/workloadmanager/ -v -run TestGarbageCollector\n```\n\nExpected: All tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/workloadmanager/garbage_collector_test.go\ngit commit -m \"test(ar-038): enhance garbage collector test coverage\"\n```\n\n---\n\n### Task 14: 创建 reconciler 测试\n\n**Files:**\n- Create: `pkg/workloadmanager/controller/reconciler/controller_test.go`\n- Verify: `pkg/workloadmanager/controller/reconciler/controller.go`\n\n**Step 1: Write reconciler tests**\n\n```go\n// pkg/workloadmanager/controller/reconciler/controller_test.go\n\npackage reconciler\n\nimport (\n    \"testing\"\n    \"time\"\n\n    \"github.com/stretchr/testify/assert\"\n    \"k8s.io/client-go/rest\"\n)\n\nfunc TestDefaultControllerConfig(t *testing.T) {\n    config := DefaultControllerConfig()\n\n    assert.NotNil(t, config)\n    assert.Equal(t, 10*time.Second, config.RequeueAfter)\n    assert.Equal(t, 2, config.MaxConcurrentReconciles)\n    assert.Nil(t, config.SyncPeriod)\n    assert.True(t, config.EnableLeaderElection)\n    assert.Equal(t, \"agentcube-reconciler\", config.LeaderElectionID)\n    assert.Equal(t, \"agentcube-system\", config.LeaderElectionNamespace)\n    assert.Equal(t, \":8080\", config.MetricsAddr)\n    assert.True(t, config.EnableProfiling)\n    assert.Equal(t, \":8081\", config.ProbeAddr)\n}\n\nfunc TestControllerConfig_CustomValues(t *testing.T) {\n    requeueAfter := 30 * time.Second\n    config := &ControllerConfig{\n        RequeueAfter:            requeueAfter,\n        MaxConcurrentReconciles: 5,\n        EnableLeaderElection:    false,\n        LeaderElectionID:        \"custom-reconciler\",\n        MetricsAddr:             \":9090\",\n        EnableProfiling:         false,\n    }\n\n    assert.Equal(t, requeueAfter, config.RequeueAfter)\n    assert.Equal(t, 5, config.MaxConcurrentReconciles)\n    assert.False(t, config.EnableLeaderElection)\n    assert.Equal(t, \"custom-reconciler\", config.LeaderElectionID)\n}\n\nfunc TestGetSandboxName(t *testing.T) {\n    tests := []struct {\n        name         string\n        workloadName string\n        expected     string\n    }{\n        {\n            name:         \"simple name\",\n            workloadName: \"test-agent\",\n            expected:     \"test-agent-sandbox\",\n        },\n        {\n            name:         \"name with hyphens\",\n            workloadName: \"my-test-agent\",\n            expected:     \"my-test-agent-sandbox\",\n        },\n    }\n\n    for _, tt := range tests {\n        t.Run(tt.name, func(t *testing.T) {\n            result := GetSandboxName(tt.workloadName)\n            assert.Equal(t, tt.expected, result)\n        })\n    }\n}\n\nfunc TestSandboxResult(t *testing.T) {\n    result := SandboxResult{\n        Created: true,\n        Updated: false,\n    }\n\n    assert.True(t, result.Created)\n    assert.False(t, result.Updated)\n}\n```\n\n**Step 2: Run tests**\n\n```bash\ngo test ./pkg/workloadmanager/controller/reconciler/ -v\n```\n\nExpected: All tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/workloadmanager/controller/reconciler/controller_test.go\ngit commit -m \"test(ar-038): add reconciler test coverage\"\n```\n\n---\n\n### Task 15: 创建 types 测试\n\n**Files:**\n- Create: `pkg/workloadmanager/types/sandbox_types_test.go`\n- Verify: `pkg/workloadmanager/types/sandbox_types.go`\n\n**Step 1: Write types tests**\n\n```go\n// pkg/workloadmanager/types/sandbox_types_test.go\n\npackage types\n\nimport (\n    \"testing\"\n    \"time\"\n\n    \"github.com/stretchr/testify/assert\"\n)\n\nfunc TestSandboxCleanupReason_String(t *testing.T) {\n    tests := []struct {\n        name   string\n        reason SandboxCleanupReason\n        expect string\n    }{\n        {\n            name:   \"idle timeout\",\n            reason: CleanupReasonIdleTimeout,\n            expect: \"IdleTimeout\",\n        },\n        {\n            name:   \"expired\",\n            reason: CleanupReasonExpired,\n            expect: \"Expired\",\n        },\n        {\n            name:   \"manual\",\n            reason: CleanupReasonManual,\n            expect: \"Manual\",\n        },\n        {\n            name:   \"error\",\n            reason: CleanupReasonError,\n            expect: \"Error\",\n        },\n    }\n\n    for _, tt := range tests {\n        t.Run(tt.name, func(t *testing.T) {\n            result := tt.reason.String()\n            assert.Equal(t, tt.expect, result)\n        })\n    }\n}\n\nfunc TestSandboxInfo_IsExpired(t *testing.T) {\n    tests := []struct {\n        name      string\n        expiresAt time.Time\n        now       time.Time\n        expected  bool\n    }{\n        {\n            name:      \"not expired\",\n            expiresAt: time.Now().Add(1 * time.Hour),\n            now:       time.Now(),\n            expected:  false,\n        },\n        {\n            name:      \"expired\",\n            expiresAt: time.Now().Add(-1 * time.Hour),\n            now:       time.Now(),\n            expected:  true,\n        },\n        {\n            name:      \"exactly expired\",\n            expiresAt: time.Now(),\n            now:       time.Now(),\n            expected:  true,\n        },\n    }\n\n    for _, tt := range tests {\n        t.Run(tt.name, func(t *testing.T) {\n            info := &SandboxInfo{\n                ExpiresAt: tt.expiresAt,\n            }\n            // Use a mock time function in actual implementation\n            result := info.ExpiresAt.Before(tt.now) || info.ExpiresAt.Equal(tt.now)\n            assert.Equal(t, tt.expected, result)\n        })\n    }\n}\n\nfunc TestCleanupAuditEntry(t *testing.T) {\n    entry := &CleanupAuditEntry{\n        SessionID:    \"test-session\",\n        SandboxID:    \"sandbox-123\",\n        Namespace:    \"default\",\n        Reason:       CleanupReasonIdleTimeout,\n        Success:      true,\n        DeletedAt:    time.Now(),\n        ErrorMessage: \"\",\n    }\n\n    assert.Equal(t, \"test-session\", entry.SessionID)\n    assert.Equal(t, \"sandbox-123\", entry.SandboxID)\n    assert.Equal(t, \"default\", entry.Namespace)\n    assert.Equal(t, CleanupReasonIdleTimeout, entry.Reason)\n    assert.True(t, entry.Success)\n    assert.Empty(t, entry.ErrorMessage)\n}\n```\n\n**Step 2: Run tests**\n\n```bash\ngo test ./pkg/workloadmanager/types/ -v\n```\n\nExpected: All tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/workloadmanager/types/sandbox_types_test.go\ngit commit -m \"test(ar-038): add types test coverage\"\n```\n\n---\n\n### Task 16: 运行所有测试并检查覆盖率\n\n**Files:**\n- None (verification task)\n\n**Step 1: Run all workloadmanager tests**\n\n```bash\ngo test ./pkg/workloadmanager/... -v\n```\n\nExpected: All tests PASS\n\n**Step 2: Run tests with coverage**\n\n```bash\ngo test ./pkg/workloadmanager/... -coverprofile=coverage.out -covermode=atomic\n```\n\n**Step 3: Generate coverage report**\n\n```bash\ngo tool cover -html=coverage.out -o coverage.html\n```\n\n**Step 4: Check coverage percentage**\n\n```bash\ngo tool cover -func=coverage.out | grep total\n```\n\nExpected: Coverage >80%\n\n**Step 5: Review uncovered lines**\n\n```bash\ngo tool cover -func=coverage.out | grep \"0.0%\"\n```\n\n**Step 6: Add tests for any uncovered code*