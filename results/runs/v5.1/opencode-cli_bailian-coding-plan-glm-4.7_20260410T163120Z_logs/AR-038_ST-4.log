Controller)\n\n    mockController.On(\"GetSession\", mock.Anything, \"non-existent\").Return(nil, fmt.Errorf(\"session not found\"))\n\n    router := gin.New()\n    router.GET(\"/sessions/:sessionId\", handler.GetSession)\n\n    req, _ := http.NewRequest(\"GET\", \"/sessions/non-existent\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusNotFound, w.Code)\n\n    mockController.AssertExpectations(t)\n}\n\nfunc TestHandler_Health(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    mockController := &mockController{}\n    handler := NewHandler(mockController)\n\n    router := gin.New()\n    router.GET(\"/health\", handler.Health)\n\n    req, _ := http.NewRequest(\"GET\", \"/health\", nil)\n    w := httptest.NewRecorder()\n\n    router.ServeHTTP(w, req)\n\n    assert.Equal(t, http.StatusOK, w.Code)\n    \n    var resp map[string]string\n    json.Unmarshal(w.Body.Bytes(), &resp)\n    assert.Equal(t, \"healthy\", resp[\"status\"])\n}\n```\n\n**Step 2: Run tests**\n\n```bash\ngo test ./pkg/workloadmanager/handler/ -v\n```\n\nExpected: All tests PASS\n\n**Step 3: Commit**\n\n```bash\ngit add pkg/workloadmanager/handler/handler_test.go\ngit commit -m \"test(ar-038): enhance handler test coverage\"\n```\n\n---\n\n### Task 7: 更新 handler/sandbox_test.go\n\n**Files:**\n- Verify: `pkg/workloadmanager/handler/sandbox_test.go`\n- Verify: `pkg/workloadmanager/handler/sandbox.go`\n\n**Step 1: Add SandboxHandler tests**\n\n```go\n// pkg/workloadmanager/handler/sandbox_test.go\n\nfunc TestSandboxHandler_HandleDeleteSandbox_Success(t *testing.T) {\n    gin.SetMode(gin.TestMode)\n    \n    mockDynamicClient := fake.NewSimpleDynamicClient(runtime.NewScheme())\n    mockStore := &mockStore{}\n    handler := NewSandboxHandler(mockDynamicClient, mockStore)\n\n    sandboxInfo := &types.SandboxInfo{\n        SessionID:          \"test-session\",\n        SandboxID:          \"test-sandbox\",\n        SandboxNamespace:   \"default\",\