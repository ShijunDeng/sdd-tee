meUnstructuredObj := &unstructured.Unstructured{\n40: \t\tObject: agentRuntimeUnstructured,\n41: \t}\n42: \tagentRuntimeUnstructuredObj.SetAPIVersion(\"runtime.agentcube.volcano.sh/v1alpha1\")\n43: \tagentRuntimeUnstructuredObj.SetKind(\"AgentRuntime\")\n44: \n45: \tdynamicClient := fake.NewSimpleDynamicClient(scheme)\n46: \tgvr := schema.GroupVersionResource{\n47: \t\tGroup:    \"runtime.agentcube.volcano.sh\",\n48: \t\tVersion:  \"v1alpha1\",\n49: \t\tResource: \"agentruntimes\",\n50: \t}\n51: \n52: \t_, err = dynamicClient.Resource(gvr).Namespace(\"default\").Create(context.Background(), agentRuntimeUnstructuredObj, metav1.CreateOptions{})\n53: \trequire.NoError(t, err)\n54: \n55: \tk8sClient := &K8sClient{\n56: \t\tdynamic:  dynamicClient,\n57: \t\tgvrAgent: gvr,\n58: \t}\n59: \n60: \tt.Run(\"successfully gets agent runtime\", func(t *testing.T) {\n61: \t\tresult, err := k8sClient.GetAgentRuntime(context.Background(), \"default\", \"test-runtime\")\n62: \n63: \t\trequire.NoError(t, err)\n64: \t\trequire.NotNil(t, result)\n65: \t\tassert.Equal(t, \"test-runtime\", result.GetName())\n66: \t\tassert.Equal(t, \"default\", result.GetNamespace())\n67: \t})\n68: \n69: \tt.Run(\"agent runtime not found\", func(t *testing.T) {\n70: \t\t_, err := k8sClient.GetAgentRuntime(context.Background(), \"default\", \"nonexistent\")\n71: \n72: \t\trequire.Error(t, err)\n73: \t\tassert.True(t, apierrors.IsNotFound(err))\n74: \t})\n75: }\n76: \n77: func TestK8sClient_GetCodeInterpreter(t *testing.T) {\n78: \tscheme := runtime.NewScheme()\n79: \terr := v1alpha1.AddToScheme(scheme)\n80: \trequire.NoError(t, err)\n81: \n82: \tcodeInterpreter := &v1alpha1.CodeInterpreter{\n83: \t\tObjectMeta: metav1.ObjectMeta{\n84: \t\t\tName:      \"test-interpreter\",\n85: \t\t\tNamespace: \"default\",\n86: \t\t},\n87: \t\tSpec: v1alpha1.CodeInterpreterSpec{\n88: \t\t\tImage: \"python:3.11-slim\",\n89: \t\t},\n90: \t}\n91: \n92: \tcodeInterpreterUnstructured, err := runtime.DefaultUnstructuredConverter.ToUnstructured(codeInterpreter)\n93: \trequire.NoError(t, err)\n94: \n95: \tcodeInterpreterUnstructuredObj := &unstructured.Unstructured{\n96: \t\tObject: codeInterpreterUnstructured,\n97: \t}\n98: \tcodeInterpreterUnstructuredObj.SetAPIVersion(\"runtime.agentcube.volcano.sh/v1alpha1\")\n99: \tcodeInterpreterUnstructuredObj.SetKind(\"CodeInterpreter\")\n100: \n101: \tdynamicClient := fake.NewSimpleDynamicClient(scheme)\n102: \tgvr := schema.GroupVersionResource{\n103: \t\tGroup:    \"runtime.agentcube.volcano.sh\",\n104: \t\tVersion:  \"v1alpha1\",\n105: \t\tResource: \"codeinterpreters\",\n106: \t}\n107: \n108: \t_, err = dynamicClient.Resource(gvr).Namespace(\"default\").Create(context.Background(), codeInterpreterUnstructuredObj, metav1.CreateOptions{})\n109: \trequire.NoError(t, err)\n110: \n111: \tk8sClient := &K8sClient{\n112: \t\tdynamic: dynamicClient,\n113: \t\tgvrCode: gvr,\n114: \t}\n115: \n116: \tt.Run(\"successfully gets code interpreter\", func(t *testing.T) {\n117: \t\tresult, err := k8sClient.GetCodeInterpreter(context.Background(), \"default\", \"test-interpreter\")\n118: \n119: \t\trequire.NoError(t, err)\n120: \t\trequire.NotNil(t, result)\n121: \t\tassert.Equal(t, \"test-interpreter\", result.GetName())\n122: \t\tassert.Equal(t, \"default\", result.GetNamespace())\n123: \t})\n124: \n125: \tt.Run(\"code interpreter not found\", func(t *testing.T) {\n126: \t\t_, err := k8sClient.GetCodeInterpreter(context.Background(), \"default\", \"nonexistent\")\n127: \n128: \t\trequire.Error(t, err)\n129: \t\tassert.True(t, apierrors.IsNotFound(err))\n130: \t})\n131: }\n132: \n133: func TestK8sClient_CreateSandbox(t *testing.T) {\n134: \tscheme := runtime.NewScheme()\n135: \n136: \tsandbox := &unstructured.Unstructured{\n137: \t\tObject: map[string]interface{}{\n138: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n139: \t\t\t\"kind\":       \"Sandbox\",\n140: \t\t\t\"metadata\": map[string]interface{}{\n141: \t\t\t\t\"name\":      \"test-sandbox\",\n142: \t\t\t\t\"namespace\": \"default\",\n143: \t\t\t},\n144: \t\t\t\"spec\": map[string]interface{}{\n145: \t\t\t\t\"replicas\": int64(1),\n146: \t\t\t},\n147: \t\t},\n148: \t}\n149: \n150: \tdynamicClient := fake.NewSimpleDynamicClient(scheme)\n151: \tgvr := schema.GroupVersionResource{\n152: \t\tGroup:    \"agents.x-k8s.io\",\n153: \t\tVersion:  \"v1alpha1\",\n154: \t\tResource: \"sandboxes\",\n155: \t}\n156: \n157: \tk8sClient := &K8sClient{\n158: \t\tdynamic:    dynamicClient,\n159: \t\tgvrSandbox: gvr,\n160: \t}\n161: \n162: \tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n163: \t\tresult, err := k8sClient.CreateSandbox(context.Background(), \"default\", sandbox)\n164: \n165: \t\trequire.NoError(t, err)\n166: \t\trequire.NotNil(t, result)\n167: \t\tassert.Equal(t, \"test-sandbox\", result.GetName())\n168: \t\tassert.Equal(t, \"default\", result.GetNamespace())\n169: \t})\n170: }\n171: \n172: func TestK8sClient_GetSandbox(t *testing.T) {\n173: \tscheme := runtime.NewScheme()\n174: \n175: \tsandbox := &unstructured.Unstructured{\n176: \t\tObject: map[string]interface{}{\n177: \t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n178: \t\t\t\"kind\":       \"Sandbox\",\n179: \t\t\t\"metadata\": map[string]interface{}{\n180: \t\t\t\t\"name\":      \"test-sandbox\",\n181: \t\t\t\t\"namespace\": \"default\",\n182: \t\t\t},\n183: \t\t\t\"spec\": map[string]interface{}{\n184: \t\t\t\t\"replicas\": int64(1),\n185: \t\t\t},\n186: \t\t},\n187: \t}\n188: \n189: \tdynamicClient := fake.NewSimpleDynamicClient(scheme)\n190: \tgvr := schema.GroupVersionResource{\n191: \t\tGroup:    \"agents.x-k8s.io\",\n192: \t\tVersion:  \"v1alpha1\",\n193: \t\tResource: \"sandboxes\",\n194: \t}\n195: \n196: \t_, err := dynamicClient.Resource(gvr).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n197: \trequire.NoError(t, err)\n198: \n199: \tk8sClient := &K8sClient{\n200: \t\tdynamic:    dynamicClient,\n201: \t\tgvrSandbox: gvr,\n202: \t}\n203: \