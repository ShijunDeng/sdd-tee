{"type":"tool_use","timestamp":1775891677630,"sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","part":{"id":"prt_d7b647c6f0017cbGMolpZ5auvX","messageID":"msg_d7b646de1001QJghsS4r2scdGh","sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","type":"tool","tool":"read","callID":"toolu_tool-66b88c03d3c24a4092443e28fb6d3916","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/config/config_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/config/config_test.go</path>\n<type>file</type>\n<content>\n1: package config\n2: \n3: import (\n4: \t\"testing\"\n5: \t\"time\"\n6: \n7: \t\"github.com/stretchr/testify/assert\"\n8: )\n9: \n10: func TestDefaultConfig(t *testing.T) {\n11: \tcfg := DefaultConfig()\n12: \n13: \tassert.NotNil(t, cfg)\n14: \tassert.Equal(t, \"8080\", cfg.Server.Port)\n15: \tassert.Equal(t, \"0.0.0.0\", cfg.Server.Host)\n16: \tassert.Equal(t, 30*time.Second, cfg.Server.ReadTimeout)\n17: \tassert.Equal(t, 30*time.Second, cfg.Server.WriteTimeout)\n18: \tassert.Equal(t, 60*time.Second, cfg.Server.IdleTimeout)\n19: \tassert.Equal(t, 15*time.Second, cfg.Server.ShutdownTimeout)\n20: \tassert.False(t, cfg.Server.EnableProfiling)\n21: \tassert.False(t, cfg.Server.EnablePprof)\n22: \tassert.Equal(t, 1<<20, cfg.Server.MaxHeaderBytes)\n23: \tassert.False(t, cfg.Server.EnableTLS)\n24: \n25: \tassert.Equal(t, \"localhost:6379\", cfg.Redis.Addr)\n26: \tassert.Equal(t, \"\", cfg.Redis.Password)\n27: \tassert.Equal(t, 0, cfg.Redis.DB)\n28: \tassert.Equal(t, 10, cfg.Redis.PoolSize)\n29: \tassert.Equal(t, 2, cfg.Redis.MinIdleConns)\n30: \tassert.Equal(t, 3, cfg.Redis.MaxRetries)\n31: \tassert.Equal(t, 5*time.Second, cfg.Redis.DialTimeout)\n32: \tassert.Equal(t, 3*time.Second, cfg.Redis.ReadTimeout)\n33: \tassert.Equal(t, 3*time.Second, cfg.Redis.WriteTimeout)\n34: \tassert.Equal(t, 4*time.Second, cfg.Redis.PoolTimeout)\n35: \tassert.Equal(t, 5*time.Minute, cfg.Redis.IdleTimeout)\n36: \n37: \tassert.Equal(t, float64(50), cfg.K8s.QPS)\n38: \tassert.Equal(t, 100, cfg.K8s.Burst)\n39: \tassert.Equal(t, 30*time.Second, cfg.K8s.Timeout)\n40: \tassert.True(t, cfg.K8s.InClusterConfig)\n41: \tassert.Equal(t, \"\", cfg.K8s.Kubeconfig)\n42: \n43: \tassert.False(t, cfg.Auth.EnableAuth)\n44: \tassert.Equal(t, 5*time.Minute, cfg.Auth.JWTExpiration)\n45: \tassert.False(t, cfg.Auth.EnableK8sTokenReview)\n46: \tassert.Equal(t, \"agentcube\", cfg.Auth.K8sAPIAudience)\n47: \tassert.Equal(t, 1000, cfg.Auth.TokenCacheSize)\n48: \tassert.Equal(t, 5*time.Minute, cfg.Auth.TokenCacheTTL)\n49: \n50: \tassert.Equal(t, 15*time.Minute, cfg.Session.DefaultTimeout)\n51: \tassert.Equal(t, 8*time.Hour, cfg.Session.MaxDuration)\n52: \tassert.Equal(t, 15*time.Second, cfg.Session.CleanupInterval)\n53: \tassert.True(t, cfg.Session.KeepAliveEnabled)\n54: \tassert.Equal(t, 5*time.Minute, cfg.Session.KeepAliveInterval)\n55: \tassert.Equal(t, 2*time.Minute, cfg.Session.RenewalWindow)\n56: }\n\n(End of file - total 56 lines)\n</content>","metadata":{"preview":"package config\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestDefaultConfig(t *testing.T) {\n\tcfg := DefaultConfig()\n\n\tassert.NotNil(t, cfg)\n\tassert.Equal(t, \"8080\", cfg.Server.Port)\n\tassert.Equal(t, \"0.0.0.0\", cfg.Server.Host)\n\tassert.Equal(t, 30*time.Second, cfg.Server.ReadTimeout)\n\tassert.Equal(t, 30*time.Second, cfg.Server.WriteTimeout)\n\tassert.Equal(t, 60*time.Second, cfg.Server.IdleTimeout)\n\tassert.Equal(t, 15*time.Second, cfg.Server.ShutdownTimeout)\n\tassert.False(t, cfg.Server.EnableProfiling)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/config/config_test.go","time":{"start":1775891677617,"end":1775891677629}}}}
