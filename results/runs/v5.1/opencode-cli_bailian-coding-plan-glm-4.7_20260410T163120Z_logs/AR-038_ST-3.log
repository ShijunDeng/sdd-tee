nc TestCORSMiddleware(t *testing.T) {\n47: \tgin.SetMode(gin.TestMode)\n48: \trouter := gin.New()\n49: \trouter.Use(CORSMiddleware())\n50: \n51: \trouter.GET(\"/test\", func(c *gin.Context) {\n52: \t\tc.JSON(http.StatusOK, gin.H{\"message\": \"ok\"})\n53: \t})\n54: \n55: \tt.Run(\"sets CORS headers\", func(t *testing.T) {\n56: \t\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n57: \t\tw := httptest.NewRecorder()\n58: \n59: \t\trouter.ServeHTTP(w, req)\n60: \n61: \t\tassert.Equal(t, http.StatusOK, w.Code)\n62: \t\tassert.Equal(t, \"*\", w.Header().Get(\"Access-Control-Allow-Origin\"))\n63: \t\tassert.Equal(t, \"true\", w.Header().Get(\"Access-Control-Allow-Credentials\"))\n64: \t\tassert.Contains(t, w.Header().Get(\"Access-Control-Allow-Headers\"), \"Content-Type\")\n65: \t\tassert.Contains(t, w.Header().Get(\"Access-Control-Allow-Methods\"), \"POST\")\n66: \t\tassert.Contains(t, w.Header().Get(\"Access-Control-Allow-Methods\"), \"GET\")\n67: \t\tassert.Contains(t, w.Header().Get(\"Access-Control-Allow-Methods\"), \"PUT\")\n68: \t\tassert.Contains(t, w.Header().Get(\"Access-Control-Allow-Methods\"), \"DELETE\")\n69: \t})\n70: \n71: \tt.Run(\"handles OPTIONS request\", func(t *testing.T) {\n72: \t\treq := httptest.NewRequest(\"OPTIONS\", \"/test\", nil)\n73: \t\tw := httptest.NewRecorder()\n74: \n75: \t\trouter.ServeHTTP(w, req)\n76: \n77: \t\tassert.Equal(t, http.StatusNoContent, w.Code)\n78: \t\tassert.Equal(t, \"*\", w.Header().Get(\"Access-Control-Allow-Origin\"))\n79: \t})\n80: }\n81: \n82: func TestLoggingMiddleware(t *testing.T) {\n83: \tgin.SetMode(gin.TestMode)\n84: \trouter := gin.New()\n85: \trouter.Use(LoggingMiddleware())\n86: \n87: \trouter.GET(\"/test\", func(c *gin.Context) {\n88: \t\tc.JSON(http.StatusOK, gin.H{\"message\": \"ok\"})\n89: \t})\n90: \n91: \tt.Run(\"logs requests\", func(t *testing.T) {\n92: \t\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n93: \t\tw := httptest.NewRecorder()\n94: \n95: \t\trouter.ServeHTTP(w, req)\n96: \n97: \t\tassert.Equal(t, http.StatusOK, w.Code)\n98: \t\tassert.Contains(t, w.Body.String(), \"ok\")\n99: \t})\n100: \n101: \tt.Run(\"handles POST requests\", func(t *testing.T) {\n102: \t\trouter.POST(\"/test\", func(c *gin.Context) {\n103: \t\t\tc.JSON(http.StatusCreated, gin.H{\"message\": \"created\"})\n104: \t\t})\n105: \n106: \t\treq := httptest.NewRequest(\"POST\", \"/test\", nil)\n107: \t\tw := httptest.NewRecorder()\n108: \n109: \t\trouter.ServeHTTP(w, req)\n110: \n111: \t\tassert.Equal(t, http.StatusCreated, w.Code)\n112: \t})\n113: }\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestRecoveryMiddleware(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\trouter := gin.New()\n\trouter.Use(RecoveryMiddleware())\n\n\tt.Run(\"recovers from panic\", func(t *testing.T) {\n\t\trouter.GET(\"/panic\", func(c *gin.Context) {\n\t\t\tpanic(\"test panic\")\n\t\t})","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/middleware/middleware_test.go","time":{"start":1775891672473,"end":1775891672488}}}}
