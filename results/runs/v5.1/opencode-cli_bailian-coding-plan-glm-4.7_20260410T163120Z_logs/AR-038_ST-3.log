6: \n357: \tassert.NoError(t, err)\n358: \tassert.NotNil(t, result)\n359: \tassert.Equal(t, 1, result.Scanned)\n360: \tassert.Equal(t, 1, result.Candidates)\n361: \tassert.Equal(t, 1, result.Deleted)\n362: \tassert.Equal(t, 0, result.Errors)\n363: }\n364: \n365: func TestGCCollector_Delete_SandboxClaim(t *testing.T) {\n366: \tmockStore := &mockStore{}\n367: \tscheme := runtime.NewScheme()\n368: \t\n369: \tscheme.AddKnownTypes(schema.GroupVersion{Group: \"extensions.agents.x-k8s.io\", Version: \"v1alpha1\"}, \n370: \t\t&unstructured.Unstructured{},\n371: \t\t&unstructured.UnstructuredList{},\n372: \t)\n373: \t\n374: \tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n375: \t\tSandboxClaimGVR: \"SandboxClaimList\",\n376: \t})\n377: \n378: \tsessionID := \"test-session\"\n379: \n380: \tsandbox := &unstructured.Unstructured{\n381: \t\tObject: map[string]interface{}{\n382: \t\t\t\"apiVersion\": \"extensions.agents.x-k8s.io/v1alpha1\",\n383: \t\t\t\"kind\":       \"SandboxClaim\",\n384: \t\t\t\"metadata\": map[string]interface{}{\n385: \t\t\t\t\"name\":      \"test-claim\",\n386: \t\t\t\t\"namespace\": \"default\",\n387: \t\t\t\t\"labels\": map[string]interface{}{\n388: \t\t\t\t\tSessionIDLabelKey: sessionID,\n389: \t\t\t\t},\n390: \t\t\t},\n391: \t\t},\n392: \t}\n393: \n394: \tfakeClient.Resource(SandboxClaimGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n395: \n396: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n397: \n398: \tconfig := DefaultGCConfig()\n399: \tpolicy, _ := NewGCPolicy(config)\n400: \tmetrics := NewGCMetrics()\n401: \n402: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n403: \n404: \tctx := context.Background()\n405: \terr := collector.Delete(ctx, sandbox, wmTypes.CleanupReasonExpired)\n406: \n407: \tassert.NoError(t, err)\n408: \tmockStore.AssertExpectations(t)\n409: }\n410: \n411: func TestGCCollector_getGVRForKind(t *testing.T) {\n412: \tmockStore := &mockStore{}\n413: \tscheme := runtime.NewScheme()\n414: \tfakeClient := fake.NewSimpleDynamicClient(scheme)\n415: \n416: \tconfig := DefaultGCConfig()\n417: \tpolicy, _ := NewGCPolicy(config)\n418: \tmetrics := NewGCMetrics()\n419: \n420: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n421: \n422: \tassert.Equal(t, SandboxGVR, collector.getGVRForKind(\"Sandbox\"))\n423: \tassert.Equal(t, SandboxClaimGVR, collector.getGVRForKind(\"SandboxClaim\"))\n424: \tassert.Equal(t, SandboxGVR, collector.getGVRForKind(\"Unknown\"))\n425: }\n\n(End of file - total 425 lines)\n</content>","metadata":{"preview":"package gc\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/collector_test.go","time":{"start":1775891672468,"end":1775891672484}}}}
{"type":"tool_use","timestamp":1775891672488,"sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","part":{"id":"prt_d7b646b470014J7rIWAir9MEQv","messageID":"msg_d7b64485f001UO40F0YjieiGKK","sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","type":"tool","tool":"read","callID":"toolu_tool-394cd00386e546a5a27a22231677d2bd","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/policy_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/policy_test.go</path>\n<type>file</type>\n<content>\n1: package gc\n2: \n3: import (\n4: \t\"testing\"\n5: \t\"time\"\n6: \n7: \t\"github.com/stretchr/testify/assert\"\n8: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n9: \t\"k8s.io/apimachinery/pkg/labels\"\n10: )\n11: \n12: func TestDefaultGCConfig(t *testing.T) {\n13: \tconfig := DefaultGCConfig()\n14: \n15: \tassert.NotNil(t, config)\n16: \tassert.Equal(t, 15*time.Second, config.Interval)\n17: \tassert.Equal(t, 8*time.Hour, config.MaxAge)\n18: \tassert.Equal(t, 15*time.Minute, config.IdleTimeout)\n19: \tassert.False(t, config.DryRun)\n20: \tassert.Empty(t, config.Namespaces)\n21: \tassert.Empty(t, config.LabelSelector)\n22: }\n23: \n24: func TestNewGCPolicy(t *testing.T) {\n25: \tconfig := &GCConfig{\n26: \t\tMaxAge:        24 * time.Hour,\n27: \t\tIdleTimeout:   30 * time.Minute,\n28: \t\tNamespaces:    []string{\"default\", \"test\"},\n29: \t\tLabelSelector: \"app=test\",\n30: \t}\n31: \n32: \tpolicy, err := NewGCPolicy(config)\n33: \tassert.NoError(t, err)\n34: \tassert.NotNil(t, policy)\n35: \tassert.Equal(t, 24*time.Hour, policy.MaxAgeThreshold)\n36: \tassert.Equal(t, 30*time.Minute, policy.IdleThreshold)\n37: \tassert.Equal(t, OrphanPolicyDelete, policy.OrphanPolicy)\n38: \tassert.NotNil(t, policy.LabelSelector)\n39: \tassert.Equal(t, []string{\"default\", \"test\"}, policy.Namespaces)\n40: }\n41: \n42: func TestNewGCPolicy_EmptySelector(t *testing.T) {\n43: \tconfig := &GCConfig{\n44: \t\tMaxAge:        24 * time.Hour,\n45: \t\tIdleTimeout:   30 * time.Minute,\n46: \t\tLabelSelector: \"\",\n47: \t}\n48: \n49: \tpolicy, err := NewGCPolicy(config)\n50: \tassert.NoError(t, err)\n51: \tassert.NotNil(t, policy)\n52: \tassert.NotNil(t, policy.LabelSelector)\n53: }\n54: \n55: func TestNewGCPolicy_InvalidSelector(t *testing.T) {\n56: \tconfig := &GCConfig{\n57: \t\tLabelSelector: \"invalid[selector\",\n58: \t}\n59: \n60: \tpolicy, err := NewGCPolicy(config)\n61: \tassert.Error(t, err)\n62: \tassert.Nil(t, policy)\n63: }\n64: \n65: func TestGCPolicy_ShouldProcessNamespace_NoRestrictions(t *testing.T) {\n66: \tpolicy := &GCPolicy{\n67: \t\tNamespaces: []string{},\n68: \t}\n69: \n70: \tassert.True(t, policy.ShouldProcessNamespace(\"default\"))\n71: \tassert.True(t, policy.ShouldProcessNamespace(\"test\"))\n72: \tassert.True(t, policy.ShouldProcessNamespace(\"any\"))\n73: }\n74: \n75: func TestGCPolicy_ShouldProcessNamespace_WithRestrictions(t *testing.T) {\n76: \tpolicy := &GCPolicy{\n77: \t\tNamespaces: []string{\"default\", \"test\"},\n78: \t}\n79: \n80: \tassert.True(t, policy.ShouldProcessNamespace(\"default\"))\n81: \tassert.True(t, policy.ShouldProcessNamespace(\"test\"))\n82: \tassert.False(t, policy.ShouldProcessNamespace(\"other\"))\n83: }\n84: \n85: func TestGCPolicy_IsExpired(t *testing.T) {\n86: \tpolicy := &GCPolicy{\n87: \t\tMaxAgeThreshold: 1 * time.Hour,\n88: \t}\n89: \n90: \ttests := []struct {\n91: \t\tname     string\n92: \t\tage      time.Duration\n93: \t\texpected bool\n94: \t}{\n95: \t\t{\n96: \t\t\tname:     \"fresh sandbox\",\n97: \t\t\tage:      30 * time.Minute,\n98: \t\t\texpected: false,\n99: \t\t},\n100: \t\t{\n101: \t\t\tname:     \"at threshold\",\n102: \t\t\tage:      1 * time.Hour,\n103: \t\t\texpected: false,\n104: \t\t},\n105: \t\t{\n106: \t\t\tname:     \"expired sandbox\",\n107: \t\t\tage:      2 * time.Hour,\n108: \t\t\texpected: true,\n109: \t\t},\n110: \t}\n111: \n112: \tfor _, tt := range tests {\n113: \t\tt.Run(tt.name, func(t *testing.T) {\n114: \t\t\tsandbox := &unstructured.Unstructured{\n115: \t\t\t\tObject: map[string]interface{}{\n116: \t\t\t\t\t\"metadata\": map[string]interface{}{\n117: \t\t\t\t\t\t\"creationTimestamp\": time.Now().Add(-tt.age).Format(time.RFC3339),\n118: \t\t\t\t\t},\n119: \t\t\t\t},\n120: \t\t\t}\n121: \n122: \t\t\tresult := policy.IsExpired(sandbox)\n123: \t\t\tassert.Equal(t, tt.expected, result)\n124: \t\t})\n125: \t}\n126: }\n127: \n128: func TestGCPolicy_IsExpired_NoCreationTimestamp(t *testing.T) {\n129: \tpolicy := &GCPolicy{\n130: \t\tMaxAgeThreshold: 1 * time.Hour,\n131: \t}\n132: \n133: \tsandbox := &unstructured.Unstructured{\n134: \t\tObject: map[string]interface{}{},\n135: \t}\n136: \n137: \tassert.False(t, policy.IsExpired(sandbox))\n138: }\n139: \n140: func TestGCPolicy_IsIdle(t *testing.T) {\n141: \tpolicy := &GCPolicy{\n142: \t\tIdleThreshold: 15 * time.Minute,\n143: \t}\n144: \n145: \ttests := []struct {\n146: \t\tname     string\n147: \t\tidleTime time.Duration\n148: \t\texpected bool\n149: \t}{\n150: \t\t{\n151: \t\t\tname:     \"active sandbox\",\n152: \t\t\tidleTime: 5 * time.Minute,\n153: \t\t\texpected: false,\n154: \t\t},\n155: \t\t{\n156: \t\t\tname:     \"at threshold\",\n157: \t\t\tidleTime: 15 * time.Minute,\n158: \t\t\texpected: false,\n159: \t\t},\n160: \t\t{\n161: \t\t\tname:     \"idle sandbox\",\n162: \t\t\tidleTime: 30 * time.Minute,\n163: \t\t\texpected: true,\n164: \t\t},\n165: \t}\n166: \n167: \tfor _, tt := range tests {\n168: \t\tt.Run(tt.name, func(t *testing.T) {\n169: \t\t\tsessionInfo := &SessionInfo{\n170: \t\t\t\tLastActivityAt: time.Now().Add(-tt.idleTime),\n171: \t\t\t}\n172: \n173: \t\t\tresult := policy.IsIdle(nil, sessionInfo)\n174: \t\t\tassert.Equal(t, tt.expected, result)\n175: \t\t})\n176: \t}\n177: }\n178: \n179: func TestGCPolicy_IsIdle_NoSessionInfo(t *testing.T) {\n180: \tpolicy := &GCPolicy{\n181: \t\tIdleThreshold: 15 * time.Minute,\n182: \t}\n183: \n184: \tassert.False(t, policy.IsIdle(nil, nil))\n185: \tassert.False(t, policy.IsIdle(nil, &SessionInfo{}))\n186: }\n187: \n188: func TestGCPolicy_IsOrphaned(t *testing.T) {\n189: \ttests := []struct {\n190: \t\tname         string\n191: \t\torphanPolicy OrphanPolicy\n192: \t\tsessionInfo  *SessionInfo\n193: \t\texpected     bool\n194: \t}{\n195: \t\t{\n196: \t\t\tname:         \"active session\",\n197: \t\t\torphanPolicy: OrphanPolicyDelete,\n198: \t\t\tsessionInfo: &SessionInfo{\n199: \t\t\t\tHasActiveSession: true,\n200: \t\t\t},\n201: \t\t\texpected: false,\n202: \t\t},\n203: \t\t{\n204: \t\t\tname:         \"no session\",\n205: \t\t\torphanPolicy: OrphanPolicyDelete,\n206: \t\t\tsessionInfo:  nil,\n207: \t\t\texpected:     true,\n208: \t\t},\n209: \t\t{\n210: \t\t\tname:         \"inactive session\",\n211: \t\t\torphanPolicy: OrphanPolicyDelete,\n212: \t\t\tsessionInfo: &SessionInfo{\n213: \t\t\t\tHasActiveSession: false,\n214: \t\t\t},\n215: \t\t\texpected: true,\n216: \t\t},\n217: \t\t{\n218: \t\t\tname:         \"keep policy\",\n219: \t\t\torphanPolicy: OrphanPolicyKeep,\n220: \t\t\tsessionInfo:  nil,\n221: \t\t\texpected:     false,\n222: \t\t},\n223: \t}\n224: \n225: \tfor _, tt := range tests {\n226: \t\tt.Run(tt.name, func(t *testing.T) {\n227: \t\t\tpolicy := &GCPolicy{\n228: \t\t\t\tOrphanPolicy: tt.orphanPolicy,\n229: \t\t\t}\n230: \n231: \t\t\tresult := policy.IsOrphaned(nil, tt.sessionInfo)\n232: \t\t\tassert.Equal(t, tt.expected, result)\n233: \t\t})\n234: \t}\n235: }\n236: \n237: func TestGCPolicy_ShouldGC(t *testing.T) {\n238: \tpolicy := &GCPolicy{\n239: \t\tMaxAgeThreshold: 1 * time.Hour,\n240: \t\tIdleThreshold:   15 * time.Minute,\n241: \t\tOrphanPolicy:    OrphanPolicyDelete,\n242: \t}\n243: \n244: \ttests := []struct {\n245: \t\tname       string\n246: \t\tage        time.Duration\n247: \t\tidleTime   time.Duration\n248: \t\tisOrphaned bool\n249: \t\texpected   bool\n250: \t}{\n251: \t\t{\n252: \t\t\tname:       \"fresh sandbox\",\n253: \t\t\tage:        30 * time.Minute,\n254: \t\t\tidleTime:   5 * time.Minute,\n255: \t\t\tisOrphaned: false,\n256: \t\t\texpected:   false,\n257: \t\t},\n258: \t\t{\n259: \t\t\tname:       \"expired sandbox\",\n260: \t\t\tage:        2 * time.Hour,\n261: \t\t\tidleTime:   5 * time.Minute,\n262: \t\t\tisOrphaned: false,\n263: \t\t\texpected:   true,\n264: \t\t},\n265: \t\t{\n266: \t\t\tname:       \"idle sandbox\",\n267: \t\t\tage:        30 * time.Minute,\n268: \t\t\tidleTime:   30 * time.Minute,\n269: \t\t\tisOrphaned: false,\n270: \t\t\texpected:   true,\n271: \t\t},\n272: \t\t{\n273: \t\t\tname:       \"orphaned sandbox\",\n274: \t\t\tage:        30 * time.Minute,\n275: \t\t\tidleTime:   5 * time.Minute,\n276: \t\t\tisOrphaned: true,\n277: \t\t\texpected:   true,\n278: \t\t},\n279: \t}\n280: \n281: \tfor _, tt := range tests {\n282: \t\tt.Run(tt.name, func(t *testing.T) {\n283: \t\t\tsandbox := &unstructured.Unstructured{\n284: \t\t\t\tObject: map[string]interface{}{\n285: \t\t\t\t\t\"metadata\": map[string]interface{}{\n286: \t\t\t\t\t\t\"creationTimestamp\": time.Now().Add(-tt.age).Format(time.RFC3339),\n287: \t\t\t\t\t},\n288: \t\t\t\t},\n289: \t\t\t}\n290: \n291: \t\t\tvar sessionInfo *SessionInfo\n292: \t\t\tif !tt.isOrphaned {\n293: \t\t\t\tsessionInfo = &SessionInfo{\n294: \t\t\t\t\tLastActivityAt:   time.Now().Add(-tt.idleTime),\n295: \t\t\t\t\tHasActiveSession: true,\n296: \t\t\t\t}\n297: \t\t\t}\n298: \n299: \t\t\tresult := policy.ShouldGC(sandbox, sessionInfo)\n300: \t\t\tassert.Equal(t, tt.expected, result)\n301: \t\t})\n302: \t}\n303: }\n304: \n305: func TestGCPolicy_MatchesLabelSelector(t *testing.T) {\n306: \tselector, err := labels.Parse(\"app=test,env=prod\")\n307: \tassert.NoError(t, err)\n308: \n309: \tpolicy := &GCPolicy{\n310: \t\tLabelSelector: selector,\n311: \t}\n312: \n313: \ttests := []struct {\n314: \t\tname     string\n315: \t\tlabels   map[string]interface{}\n316: \t\texpected bool\n317: \t}{\n318: \t\t{\n319: \t\t\tname: \"matching labels\",\n320: \t\t\tlabels: map[string]interface{}{\n321: \t\t\t\t\"app\": \"test\",\n322: \t\t\t\t\"env\": \"prod\",\n323: \t\t\t},\n324: \t\t\texpected: true,\n325: \t\t},\n326: \t\t{\n327: \t\t\tname: \"partial match\",\n328: \t\t\tlabels: map[string]interface{}{\n329: \t\t\t\t\"app\": \"test\",\n330: \t\t\t},\n331: \t\t\texpected: false,\n332: \t\t},\n333: \t\t{\n334: \t\t\tname:     \"no labels\",\n335: \t\t\tlabels:   nil,\n336: \t\t\texpected: false,\n337: \t\t},\n338: \t\t{\n339: \t\t\tname: \"mismatched labels\",\n340: \t\t\tlabels: map[string]interface{}{\n341: \t\t\t\t\"app\": \"dev\",\n342: \t\t\t\t\"env\": \"prod\",\n343: \t\t\t},\n344: \t\t\texpected: false,\n345: \t\t},\n346: \t}\n347: \n348: \tfor _, tt := range tests {\n349: \t\tt.Run(tt.name, func(t *testing.T) {\n350: \t\t\tsandbox := &unstructured.Unstructured{\n351: \t\t\t\tObject: map[string]interface{}{\n352: \t\t\t\t\t\"metadata\": map[string]interface{}{\n353: \t\t\t\t\t\t\"labels\": tt.labels,\n354: \t\t\t\t\t},\n355: \t\t\t\t},\n356: \t\t\t}\n357: \n358: \t\t\tresult := policy.MatchesLabelSelector(sandbox)\n359: \t\t\tassert.Equal(t, tt.expected, result)\n360: \t\t})\n361: \t}\n362: }\n363: \n364: func TestGetSessionIDFromSandbox(t *testing.T) {\n365: \ttests := []struct {\n366: \t\tname     string\n367: \t\tlabels   map[string]string\n368: \t\texpected string\n369: \t}{\n370: \t\t{\n371: \t\t\tname: \"has session ID\",\n372: \t\t\tlabels: map[string]string{\n373: \t\t\t\tSessionIDLabelKey: \"test-session\",\n374: \t\t\t},\n375: \t\t\texpected: \"test-session\",\n376: \t\t},\n377: \t\t{\n378: \t\t\tname:     \"no labels\",\n379: \t\t\tlabels:   nil,\n380: \t\t\texpected: \"\",\n381: \t\t},\n382: \t\t{\n383: \t\t\tname: \"no session ID label\",\n384: \t\t\tlabels: map[string]string{\n385: \t\t\t\t\"app\": \"test\",\n386: \t\t\t},\n387: \t\t\texpected: \"\",\n388: \t\t},\n389: \t}\n390: \n391: \tfor _, tt := range tests {\n392: \t\tt.Run(tt.name, func(t *testing.T) {\n393: \t\t\tsandbox := &unstructured.Unstructured{}\n394: \t\t\tif tt.labels != nil {\n395: \t\t\t\tsandbox.SetLabels(tt.labels)\n396: \t\t\t}\n397: \n398: \t\t\tresult := GetSessionIDFromSandbox(sandbox)\n399: \t\t\tassert.Equal(t, tt.expected, result)\n400: \t\t})\n401: \t}\n402: }\n403: \n404: func TestGetLastActivityFromSandbox(t *testing.T) {\n405: \tnow := time.Now()\n406: \n407: \ttests := []struct {\n408: \t\tname        string\n409: \t\tannotations map[string]string\n410: \t\texpected    time.Time\n411: \t}{\n412: \t\t{\n413: \t\t\tname: \"has last activity\",\n414: \t\t\tannotations: map[string]string{\n415: \t\t\t\tLastActivityAnnotationKey: now.Format(time.RFC3339),\n416: \t\t\t},\n417: \t\t\texpected: now,\n418: \t\t},\n419: \t\t{\n420: \t\t\tname:        \"no annotations\",\n421: \t\t\tannotations: nil,\n422: \t\t\texpected:    time.Time{},\n423: \t\t},\n424: \t\t{\n425: \t\t\tname: \"no last activity annotation\",\n426: \t\t\tannotations: map[string]string{\n427: \t\t\t\t\"app\": \"test\",\n428: \t\t\t},\n429: \t\t\texpected: time.Time{},\n430: \t\t},\n431: \t\t{\n432: \t\t\tname: \"invalid timestamp\",\n433: \t\t\tannotations: map[string]string{\n434: \t\t\t\tLastActivityAnnotationKey: \"invalid\",\n435: \t\t\t},\n436: \t\t\texpected: time.Time{},\n437: \t\t},\n438: \t}\n439: \n440: \tfor _, tt := range tests {\n441: \t\tt.Run(tt.name, func(t *testing.T) {\n442: \t\t\tsandbox := &unstructured.Unstructured{}\n443: \t\t\tif tt.annotations != nil {\n444: \t\t\t\tsandbox.SetAnnotations(tt.annotations)\n445: \t\t\t}\n446: \n447: \t\t\tresult := GetLastActivityFromSandbox(sandbox)\n448: \n449: \t\t\tif tt.expected.IsZero() {\n450: \t\t\t\tassert.True(t, result.IsZero())\n451: \t\t\t} else {\n452: \t\t\t\tassert.WithinDuration(t, tt.expected, result, time.Second)\n453: \t\t\t}\n454: \t\t})\n455: \t}\n456: }\n\n(End of file - total 456 lines)\n</content>","metadata":{"preview":"package gc\n\nimport (\n\t\"testing\"\n\t