interface{}{\n92: \t\t\t\t\t\"runtime.agentcube.io/session-id\": \"test-session\",\n93: \t\t\t\t},\n94: \t\t\t},\n95: \t\t},\n96: \t}\n97: }\n98: \n99: func buildUnstructuredSandboxClaim(name, namespace string) *unstructured.Unstructured {\n100: \treturn &unstructured.Unstructured{\n101: \t\tObject: map[string]interface{}{\n102: \t\t\t\"apiVersion\": \"extensions.agents.x-k8s.io/v1alpha1\",\n103: \t\t\t\"kind\":       \"SandboxClaim\",\n104: \t\t\t\"metadata\": map[string]interface{}{\n105: \t\t\t\t\"name\":      name,\n106: \t\t\t\t\"namespace\": namespace,\n107: \t\t\t},\n108: \t\t},\n109: \t}\n110: }\n111: \n112: func TestHandleDeleteSandbox_Success(t *testing.T) {\n113: \tgin.SetMode(gin.TestMode)\n114: \n115: \tsessionID := \"test-session-123\"\n116: \tsandboxInfo := &types.SandboxInfo{\n117: \t\tSessionID:        sessionID,\n118: \t\tSandboxID:        \"test-sandbox-abc\",\n119: \t\tSandboxName:      \"test-sandbox\",\n120: \t\tSandboxNamespace: \"default\",\n121: \t\tKind:             \"Sandbox\",\n122: \t}\n123: \n124: \tmockStore := &mockStore{}\n125: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n126: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n127: \n128: \tscheme := runtime.NewScheme()\n129: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n130: \n131: \tsandboxObj := buildUnstructuredSandbox(sandboxInfo.SandboxID, sandboxInfo.SandboxNamespace)\n132: \tfakeDynamicClient.Resource(schema.GroupVersionResource{\n133: \t\tGroup:    \"agents.x-k8s.io\",\n134: \t\tVersion:  \"v1alpha1\",\n135: \t\tResource: \"sandboxes\",\n136: \t}).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n137: \n138: \thandler := NewSandboxHandler(fakeDynamicClient, mockStore)\n139: \n140: \tw := httptest.NewRecorder()\n141: \tc, _ := gin.CreateTestContext(w)\n142: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\"+sessionID, nil)\n143: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n144: \n145: \thandler.HandleDeleteSandbox(c)\n146: \n147: \tassert.Equal(t, http.StatusOK, w.Code)\n148: \tvar resp wmTypes.DeleteSandboxResponse\n149: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n150: \tassert.Equal(t, \"Sandbox deleted successfully\", resp.Message)\n151: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, sessionID)\n152: }\n153: \n154: func TestHandleDeleteSandbox_NotFound(t *testing.T) {\n155: \tgin.SetMode(gin.TestMode)\n156: \n157: \tsessionID := \"non-existent-session\"\n158: \tmockStore := &mockStore{}\n159: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(nil, store.ErrNotFound)\n160: \n161: \thandler := NewSandboxHandler(nil, mockStore)\n162: \n163: \tw := httptest.NewRecorder()\n164: \tc, _ := gin.CreateTestContext(w)\n165: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\"+sessionID, nil)\n166: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n167: \n168: \thandler.HandleDeleteSandbox(c)\n169: \n170: \tassert.Equal(t, http.StatusNotFound, w.Code)\n171: \tvar resp map[string]interface{}\n172: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n173: \tassert.Contains(t, resp[\"error\"], sessionID)\n174: \tassert.Contains(t, resp[\"error\"], \"not found\")\n175: }\n176: \n177: func TestHandleDeleteSandbox_EmptySessionID(t *testing.T) {\n178: \tgin.SetMode(gin.TestMode)\n179: \n180: \tmockStore := &mockStore{}\n181: \thandler := NewSandboxHandler(nil, mockStore)\n182: \n183: \tw := httptest.NewRecorder()\n184: \tc, _ := gin.CreateTestContext(w)\n185: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\", nil)\n186: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: \"\"}}\n187: \n188: \thandler.HandleDeleteSandbox(c)\n189: \n190: \tassert.Equal(t, http.StatusBadRequest, w.Code)\n191: \tvar resp map[string]interface{}\n192: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n193: \tassert.Contains(t, resp[\"error\"], \"sessionId is required\")\n194: }\n195: \n196: func TestHandleDeleteSandbox_SandboxClaim(t *testing.T) {\n197: \tgin.SetMode(gin.TestMode)\n198: \n199: \tsessionID := \"test-session-claim\"\n200: \tsandboxInfo := &types.SandboxInfo{\n201: \t\tSessionID:        sessionID,\n202: \t\tSandboxID:        \"test-claim-abc\",\n203: \t\tSandboxName:      \"test-claim\",\n204: \t\tSandboxNamespace: \"default\",\n205: \t\tKind:             \"SandboxClaim\",\n206: \t}\n207: \n208: \tmockStore := &mockStore{}\n209: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n210: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n211: \n212: \tscheme := runtime.NewScheme()\n213: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n214: \n215: \tclaimObj := buildUnstructuredSandboxClaim(sandboxInfo.SandboxID, sandboxInfo.SandboxNamespace)\n216: \tfakeDynamicClient.Resource(schema.GroupVersionResource{\n217: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n218: \t\tVersion:  \"v1alpha1\",\n219: \t\tResource: \"sandboxclaims\",\n220: \t}).Namespace(\"default\").Create(context.Background(), claimObj, metav1.CreateOptions{})\n221: \n222: \thandler := NewSandboxHandler(fakeDynamicClient, mockStore)\n223: \n224: \tw := httptest.NewRecorder()\n225: \tc, _ := gin.CreateTestContext(w)\n226: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/code-interpreter/sessions/\"+sessionID, nil)\n227: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n228: \n229: \thandler.HandleDeleteSandbox(c)\n230: \n231: \tassert.Equal(t, http.StatusOK, w.Code)\n232: \t_, err := fakeDynamicClient.Resource(schema.GroupVersionResource{\n233: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n234: \t\tVersion:  \"v1alpha1\",\n235: \t\tResource: \"sandboxclaims\",\n236: \t}).Namespace(\"default\").Get(context.Background(), sandboxInfo.SandboxID, metav1.GetOptions{})\n237: \tassert.True(t, apierrors.IsNotFound(err))\n238: }\n239: \n240: func TestHandleDeleteSandbox_StoreError(t *testing.T) {\n241: \tgin.SetMode(gin.TestMode)\n242: \n243: \tsessionID := \"test-session\"\n244: \tmockStore := &mockStore{}\n245: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(nil, assert.AnError)\n246: \n247: \thandler := NewSandboxHandler(nil, mockStore)\n248: \n249: \tw := httptest.NewRecorder()\n250: \tc, _ := gin.CreateTestContext(w)\n251: \tc.Request = httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\"+sessionID, nil)\n252: \tc.Params = gin.Params{gin.Param{Key: \"sessionId\", Value: sessionID}}\n253: \n254: \thandler.HandleDeleteSandbox(c)\n255: \n256: \tassert.Equal(t, http.StatusInternalServerError, w.Code)\n257: \tvar resp map[string]interface{}\n258: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n259: \tassert.Contains(t, resp[\"error\"], \"internal server error\")\n260: }\n\n(End of file - total 260 lines)\n</content>","metadata":{"preview":"package handler\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic/fake\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/handler/sandbox_test.go","time":{"start":1775891682005,"end":1775891682016}}}}
{"type":"tool_use","timestamp":1775891682019,"sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","part":{"id":"prt_d7b6492c1001DUwIuuar1nfEtr","messageID":"msg_d7b6481f5001dTDFHG4Y7cx0jT","sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","type":"tool","tool":"read","callID":"toolu_tool-2414bfe099a041bb807a2078e893b57e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/metrics.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/metrics.go</path>\n<type>file</type>\n<content>\n1: package gc\n2: \n3: import (\n4: \t\"sync\"\n5: \n6: \t\"github.com/prometheus/client_golang/prometheus\"\n7: )\n8: \n9: const (\n10: \tmetricGCRunsTotal       = \"workloadmanager_gc_runs_total\"\n11: \tmetricGCDeletedTotal    = \"workloadmanager_gc_deleted_total\"\n12: \tmetricGCScannedTotal    = \"workloadmanager_gc_scanned_total\"\n13: \tmetricGCErrorsTotal     = \"workloadmanager_gc_errors_total\"\n14: \tmetricGCRunDuration     = \"workloadmanager_gc_run_duration_seconds\"\n15: \tmetricGCCandidatesGauge = \"workloadmanager_gc_candidates\"\n16: )\n17: \n18: var (\n19: \tmetricsOnce sync.Once\n20: \tmetrics     *GCMetrics\n21: )\n22: \n23: type GCMetrics struct {\n24: \tRunsTotal    *prometheus.CounterVec\n25: \tDeletedTotal *prometheus.CounterVec\n26: \tScannedTotal prometheus.Counter\n27: \tErrorsTotal  *prometheus.CounterVec\n28: \tDuration     prometheus.Observer\n29: \tCandidates   prometheus.Gauge\n30: }\n31: \n32: func NewGCMetrics() *GCMetrics {\n33: \trunsTotal := prometheus.NewCounterVec(\n34: \t\tprometheus.CounterOpts{\n35: \t\t\tName: metricGCRunsTotal,\n36: \t\t\tHelp: \"Total number of GC runs\",\n37: \t\t},\n38: \t\t[]string{\"reason\"},\n39: \t)\n40: \n41: \tdeletedTotal := prometheus.NewCounterVec(\n42: \t\tprometheus.CounterOpts{\n43: \t\t\tName: metricGCDeletedTotal,\n44: \t\t\tHelp: \"Total number of sandboxes deleted by GC\",\n45: \t\t},\n46: \t\t[]string{\"reason\", \"kind\"},\n47: \t)\n48: \n49: \tscannedTotal := prometheus.NewCounter(\n50: \t\tprometheus.CounterOpts{\n51: \t\t\tName: metricGCScannedTotal,\n52: \t\t\tHelp: \"Total number of sandboxes scanned by GC\",\n53: \t\t},\n54: \t)\n55: \n56: \terrorsTotal := prometheus.NewCounterVec(\n57: \t\tprometheus.CounterOpts{\n58: \t\t\tName: metricGCErrorsTotal,\n59: \t\t\tHelp: \"Total number of GC errors\",\n60: \t\t},\n61: \t\t[]string{\"reason\"},\n62: \t)\n63: \n64: \tduration := prometheus.NewHistogramVec(\n65: \t\tprometheus.HistogramOpts{\n66: \t\t\tName:    metricGCRunDuration,\n67: \t\t\tHelp:    \"GC run duration in seconds\",\n68: \t\t\tBuckets: []float64{0.1, 0.5, 1, 2, 5, 10, 30, 60},\n69: \t\t},\n70: \t\t[]string{\"reason\"},\n71: \t)\n72: \n73: \tcandidates := prometheus.NewGauge(\n74: \t\tprometheus.GaugeOpts{\n75: \t\t\tName: metricGCCandidatesGauge,\n76: \t\t\tHelp: \"Number of sandboxes eligible for GC\",\n77: \t\t},\n78: \t)\n79: \n80: \treturn &GCMetrics{\n81: \t\tRunsTotal:    runsTotal,\n82: \t\tDeletedTotal: deletedTotal,\n83: \t\tScannedTotal: scannedTotal,\n84: \t\tErrorsTotal:  errorsTotal,\n85: \t\tDuration:     duration.WithLabelValues(\"scheduled\"),\n86: \t\tCandidates:   candidates,\n87: \t}\n88: }\n89: \n90: func GetDefaultMetrics() *GCMetrics {\n91: \tmetricsOnce.Do(func() {\n92: \t\tmetrics = NewGCMetrics()\n93: \t})\n94: \treturn metrics\n95: }\n96: \n97: func (m *GCMetrics) RecordRun() {\n98: \tm.RunsTotal.WithLabelValues(\"scheduled\").Inc()\n99: }\n100: \n101: func (m *GCMetrics) RecordDeleted(reason string, kind string) {\n102: \tm.DeletedTotal.WithLabelValues(reason, kind).Inc()\n103: }\n104: \n105: func (m *GCMetrics) RecordScanned(count int) {\n106: \tm.ScannedTotal.Add(float64(count))\n107: }\n108: \n109: func (m *GCMetrics) RecordError(reason string) {\n110: \tm.ErrorsTotal.WithLabelValues(reason).Inc()\n111: }\n112: \n113: func (m *GCMetrics) RecordDuration(duration float64) {\n114: \tm.Duration.Observe(duration)\n115: }\n116: \n117: func (m *GCMetrics) SetCandidates(count int) {\n118: \tm.Candidates.Set(float64(count))\n119: }\n120: \n121: func (m *GCMetrics) ResetCandidates() {\n122: \tm.Candidates.Set(0)\n123: }\n\n(End of file - total 123 lines)\n</content>","metadata":{"preview":"package gc\n\nimport (\n\t\"sync\"\n\n\t\"github.com/prometheus/client_golang/prometheus\"\n)\n\nconst (\n\tmetricGCRunsTotal       = \"workloadmanager_gc_runs_total\"\n\tmetricGCDeletedTotal    = \"workloadmanager_gc_deleted_total\"\n\tmetricGCScannedTotal    = \"workloadmanager_gc_scanned_total\"\n\tmetricGCErrorsTotal     = \"workloadmanager_gc_errors_total\"\n\tmetricGCRunDuration     = \"workloadmanager_gc_run_duration_seconds\"\n\tmetricGCCandidatesGauge = \"workloadmanager_gc_candidates\"\n)\n\nvar (\n\tmetricsOnce sync.Once\n\tmetrics     *GCMetrics","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/metrics.go","time":{"start":1775891682007,"end":1775891682017}}}}
