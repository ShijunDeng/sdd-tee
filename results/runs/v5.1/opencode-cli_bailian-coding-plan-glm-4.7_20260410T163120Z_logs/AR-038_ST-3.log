\n94: \t}\n95: }\n96: \n97: func TestGarbageCollector_Tick_IdleSandboxes(t *testing.T) {\n98: \tmockStore := &mockStoreForGC{}\n99: \tidleSandboxes := []*types.SandboxInfo{\n100: \t\t{\n101: \t\t\tSessionID:        \"idle-session-1\",\n102: \t\t\tSandboxID:        \"idle-sandbox-1\",\n103: \t\t\tSandboxNamespace: \"default\",\n104: \t\t\tKind:             \"Sandbox\",\n105: \t\t},\n106: \t}\n107: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return(idleSandboxes, nil)\n108: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\").Return(nil)\n109: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n110: \n111: \tscheme := runtime.NewScheme()\n112: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n113: \n114: \tsandboxObj := buildUnstructuredSandboxForGC(\"idle-sandbox-1\", \"default\")\n115: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n116: \n117: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n118: \n119: \tgc.tick()\n120: \n121: \tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n122: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\")\n123: }\n124: \n125: func TestGarbageCollector_Tick_ExpiredSandboxes(t *testing.T) {\n126: \tmockStore := &mockStoreForGC{}\n127: \texpiredSandboxes := []*types.SandboxInfo{\n128: \t\t{\n129: \t\t\tSessionID:        \"expired-session-1\",\n130: \t\t\tSandboxID:        \"expired-sandbox-1\",\n131: \t\t\tSandboxNamespace: \"default\",\n132: \t\t\tKind:             \"Sandbox\",\n133: \t\t},\n134: \t}\n135: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return(expiredSandboxes, nil)\n136: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\").Return(nil)\n137: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n138: \n139: \tscheme := runtime.NewScheme()\n140: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n141: \n142: \tsandboxObj := buildUnstructuredSandboxForGC(\"expired-sandbox-1\", \"default\")\n143: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandboxObj, metav1.CreateOptions{})\n144: \n145: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n146: \n147: \tgc.tick()\n148: \n149: \tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n150: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\")\n151: }\n152: \n153: func TestGarbageCollector_Tick_KubernetesNotFound(t *testing.T) {\n154: \tmockStore := &mockStoreForGC{}\n155: \tsandboxInfo := &types.SandboxInfo{\n156: \t\tSessionID:        \"missing-session\",\n157: \t\tSandboxID:        \"missing-sandbox\",\n158: \t\tSandboxNamespace: \"default\",\n159: \t\tKind:             \"Sandbox\",\n160: \t}\n161: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{sandboxInfo}, nil)\n162: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\").Return(nil)\n163: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n164: \n165: \tscheme := runtime.NewScheme()\n166: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n167: \n168: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n169: \n170: \tgc.tick()\n171: \n172: \tmockStore.AssertCalled(t, \"DeleteSandboxBySessionID\", mock.Anything, \"missing-session\")\n173: }\n174: \n175: func TestGarbageCollector_StartStop(t *testing.T) {\n176: \tmockStore := &mockStoreForGC{}\n177: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n178: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n179: \n180: \tscheme := runtime.NewScheme()\n181: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n182: \n183: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, 100*time.Millisecond)\n184: \n185: \tgc.Start()\n186: \n187: \ttime.Sleep(250 * time.Millisecond)\n188: \n189: \tgc.Stop()\n190: \n191: \ttime.Sleep(50 * time.Millisecond)\n192: \tassert.True(t, true, \"GC stopped without panic\")\n193: }\n194: \n195: func TestGarbageCollector_Tick_ListInactiveError(t *testing.T) {\n196: \tmockStore := &mockStoreForGC{}\n197: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n198: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n199: \n200: \tscheme := runtime.NewScheme()\n201: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n202: \n203: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n204: \n205: \tgc.tick()\n206: \n207: \tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n208: \tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n209: }\n210: \n211: func TestGarbageCollector_Tick_ListExpiredError(t *testing.T) {\n212: \tmockStore := &mockStoreForGC{}\n213: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, nil)\n214: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return([]*types.SandboxInfo{}, assert.AnError)\n215: \n216: \tscheme := runtime.NewScheme()\n217: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n218: \n219: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n220: \n221: \tgc.tick()\n222: \n223: \tmockStore.AssertCalled(t, \"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16)\n224: \tmockStore.AssertCalled(t, \"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16)\n225: }\n226: \n227: func TestGarbageCollector_Tick_BothLists(t *testing.T) {\n228: \tmockStore := &mockStoreForGC{}\n229: \tidleSandboxes := []*types.SandboxInfo{\n230: \t\t{\n231: \t\t\tSessionID:        \"idle-session-1\",\n232: \t\t\tSandboxID:        \"idle-sandbox-1\",\n233: \t\t\tSandboxNamespace: \"default\",\n234: \t\t\tKind:             \"Sandbox\",\n235: \t\t},\n236: \t}\n237: \texpiredSandboxes := []*types.SandboxInfo{\n238: \t\t{\n239: \t\t\tSessionID:        \"expired-session-1\",\n240: \t\t\tSandboxID:        \"expired-sandbox-1\",\n241: \t\t\tSandboxNamespace: \"default\",\n242: \t\t\tKind:             \"Sandbox\",\n243: \t\t},\n244: \t}\n245: \tmockStore.On(\"ListInactiveSandboxes\", mock.Anything, mock.Anything, 16).Return(idleSandboxes, nil)\n246: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"idle-session-1\").Return(nil)\n247: \tmockStore.On(\"ListExpiredSandboxes\", mock.Anything, mock.Anything, 16).Return(expiredSandboxes, nil)\n248: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, \"expired-session-1\").Return(nil)\n249: \n250: \tscheme := runtime.NewScheme()\n251: \tfakeDynamicClient := fake.NewSimpleDynamicClient(scheme)\n252: \n253: \tidleObj := buildUnstructuredSandboxForGC(\"idle-sandbox-1\", \"default\")\n254: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), idleObj, metav1.CreateOptions{})\n255: \n256: \texpiredObj := buildUnstructuredSandboxForGC(\"expired-sandbox-1\", \"default\")\n257: \tfakeDynamicClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), expiredObj, metav1.CreateOptions{})\n258: \n259: \tgc := NewGarbageCollector(fakeDynamicClient, mockStore, GCInterval)\n260: \n261: \tgc.tick()\n262: \n263: \tmockStore.AssertNumberOfCalls(t, \"DeleteSandboxBySessionID\", 2)\n264: }\n\n(End of file - total 264 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype mockStoreForGC struct {\n\tmock.Mock\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/garbage_collector_test.go","time":{"start":1775891656901,"end":1775891656908}}}}
{"type":"tool_use","timestamp":1775891656912,"sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","part":{"id":"prt_d7b642a320010YU5gzav6p6pCi","messageID":"msg_d7b64144b0019nMTBnHQZynbKt","sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","type":"tool","tool":"read","callID":"toolu_tool-559be319a35b42c381267f2e541f56a2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go</path>\n<type>file</type>\n<content>\n1: package client\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"time\"\n7: \n8: \tcorev1 \"k8s.io/api/core/v1\"\n9: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n10: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n11: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n12: \t\"k8s.io/apimachinery/pkg/labels\"\n13: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n14: \t\"k8s.io/client-go/dynamic\"\n15: \t\"k8s.io/client-go/kubernetes\"\n16: \t\"k8s.io/client-go/rest\"\n17: \t\"k8s.io/klog/v2\"\n18: \n19: \t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n20: )\n21: \n22: type Client interface {\n23: \tGetAgentRuntime(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error)\n24: \tGetCodeInterpreter(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error)\n25: \tCreateSandbox(ctx context.Context, namespace string, sandbox *unstructured.Unstructured) (*unstructured.Unstructured, error)\n26: \tGetSandbox(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error)\n27: \tDeleteSandbox(ctx context.Context, namespace, name string) error\n28: \tGetPodIP(ctx context.Context, sandboxName, namespace string, sandbox *unstructured.Unstructured) (string, error)\n29: \tGetSecret(ctx context.Context, namespace, name string) (*corev1.Secret, error)\n30: }\n31: \n32: type K8sClient struct {\n33: \tclientset  kubernetes.Interface\n34: \tdynamic    dynamic.Interface\n35: \tconfig     *rest.Config\n36: \tgvrSandbox schema.GroupVersionResource\n37: \tgvrAgent   schema.GroupVersionResource\n38: \tgvrCode    schema.GroupVersionResource\n39: }\n40: \n41: func NewK8sClient(config *rest.Config) (*K8sClient, error) {\n42: \tclientset, err := kubernetes.NewForConfig(config)\n43: \tif err != nil {\n44: \t\treturn nil, fmt.Errorf(\"failed to create kubernetes clientset: %w\", err)\n45: \t}\n46: \n47: \tdynamicClient, err := dynamic.NewForConfig(config)\n48: \tif err != nil {\n49: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n50: \t}\n51: \n52: \treturn &K8sClient{\n53: \t\tclientset: clientset,\n54: \t\tdynamic:   dynamicClient,\n55: \t\tconfig:    config,\n56: \t\tgvrSandbox: schema.GroupVersionResource{\n57: \t\t\tGroup:    \"agents.x-k8s.io\",\n58: \t\t\tVersion:  \"v1alpha1\",\n59: \t\t\tResource: \"sandboxes\",\n60: \t\t},\n61: \t\tgvrAgent: schema.GroupVersionResource{\n62: \t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n63: \t\t\tVersion:  \"v1alpha1\",\n64: \t\t\tResource: \"agentruntimes\",\n65: \t\t},\n66: \t\tgvrCode: schema.GroupVersionResource{\n67: \t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n68: \t\t\tVersion:  \"v1alpha1\",\n69: \t\t\tResource: \"codeinterpreters\",\n70: \t\t},\n71: \t}, nil\n72: }\n73: \n74: func (c *K8sClient) GetAgentRuntime(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n75: \treturn c.dynamic.Resource(c.gvrAgent).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n76: }\n77: \n78: func (c *K8sClient) GetCodeInterpreter(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n79: \treturn c.dynamic.Resource(c.gvrCode).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n80: }\n81: \n82: func (c *K8sClient) CreateSandbox(ctx context.Context, namespace string, sandbox *unstructured.Unstructured) (*unstructured.Unstructured, error) {\n83: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Create(ctx, sandbox, metav1.CreateOptions{})\n84: }\n85: \n86: func (c *K8sClient) GetSandbox(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n87: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n88: }\n89: \n90: func (c *K8sClient) DeleteSandbox(ctx context.Context, namespace, name string) error {\n91: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Delete(ctx, name, metav1.DeleteOptions{})\n92: }\n93: \n94: func (c *K8sClient) GetPodIP(ctx context.Context, sandboxName, namespace string, sandbox *unstructured.Unstructured) (string, error) {\n95: \tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n96: \tif err == nil && pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n97: \t\treturn pod.Status.PodIP, nil\n98: \t}\n99: \n100: \tannotations := sandbox.GetAnnotations()\n101: \tconst podNameAnnotation = \"agents.x-k8s.io/sandbox-pod-name\"\n102: \tif podName, ok := annotations[podNameAnnotation]; ok && podName != \"\" {\n103: \t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, podName, metav1.GetOptions{})\n104: \t\tif err == nil {\n105: \t\t\tif pod.Status.Phase != corev1.PodRunning {\n106: \t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n107: \t\t\t}\n108: \t\t\tif pod.Status.PodIP == \"\" {\n109: \t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n110: \t\t\t}\n111: \t\t\treturn pod.Status.PodIP, nil\n112: \t\t}\n113: \t}\n114: \n115: \tpods, err := c.clientset.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n116: \t\tLabelSelector: labels.SelectorFromSet(labels.Set{\n117: \t\t\tconstants.LabelSandboxName: sandboxName,\n118: \t\t}).String(),\n119: \t})\n120: \tif err != nil {\n121: \t\treturn \"\", fmt.Errorf(\"failed to list pods: %w\", err)\n122: \t}\n123: \n124: \tfor _, p := range pods.Items {\n125: \t\tfor _, ownerRef := range p.OwnerReferences {\n126: \t\t\tif ownerRef.Kind == \"Sandbox\" && ownerRef.Name == sandboxName {\n127: \t\t\t\tif p.Status.Phase != corev1.PodRunning {\n128: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n129: \t\t\t\t}\n130: \t\t\t\tif p.Status.PodIP == \"\" {\n131: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n132: \t\t\t\t}\n133: \t\t\t\treturn p.Status.PodIP, nil\n134: \t\t\t}\n135: \t\t}\n136: \t}\n137: \n138: \treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n139: }\n140: \n141: func (c *K8sClient) WatchPods(ctx context.Context, namespace string, sandboxName string) (<-chan string, error) {\n142: \tpodCh := make(chan string, 1)\n143: \n144: \tgo func() {\n145: \t\tdefer close(podCh)\n146: \n147: \t\tticker := time.NewTicker(2 * time.Second)\n148: \t\tdefer ticker.Stop()\n149: \n150: \t\tfor {\n151: \t\t\tselect {\n152: \t\t\tcase <-ctx.Done():\n153: \t\t\t\treturn\n154: \t\t\tcase <-ticker.C:\n155: \t\t\t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n156: \t\t\t\tif err != nil {\n157: \t\t\t\t\tif apierrors.IsNotFound(err) {\n158: \t\t\t\t\t\tcontinue\n159: \t\t\t\t\t}\n160: \t\t\t\t\tklog.Errorf(\"Failed to get pod: %v\", err)\n161: \t\t\t\t\tcontinue\n162: \t\t\t\t}\n163: \n164: \t\t\t\tif pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n165: \t\t\t\t\tselect {\n166: \t\t\t\t\tcase podCh <- pod.Status.PodIP:\n167: \t\t\t\t\tdefault:\n168: \t\t\t\t\t}\n169: \t\t\t\t\treturn\n170: \t\t\t\t}\n171: \t\t\t}\n172: \t\t}\n173: \t}()\n174: \n175: \treturn podCh, nil\n176: }\n177: \n178: func (c *K8sClient) GetSecret(ctx context.Context, namespace, name string) (*corev1.Secret, error) {\n179: \treturn c.clientset.CoreV1().Secrets(namespace).Get(ctx, name, metav1.GetOptions{})\n180: }\n181: \n182: func (c *K8sClient) GetDynamicClient() dynamic.Interface {\n183: \treturn c.dynamic\n184: }\n\n(End of file - total 184 lines)\n</content>","metadata":{"preview":"package client\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/klog/v2\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/client/k8s_client.go","time":{"start":1775891656896,"end":1775891656911}}}}
