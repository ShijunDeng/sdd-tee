ct(ch)\n45: \n46: \ttotal := 0.0\n47: \tfor range ch {\n48: \t\ttotal++\n49: \t}\n50: \n51: \tassert.Equal(t, float64(2), total)\n52: }\n53: \n54: func TestGCMetrics_RecordScanned(t *testing.T) {\n55: \tmetrics := NewGCMetrics()\n56: \n57: \tmetrics.RecordScanned(10)\n58: \tmetrics.RecordScanned(5)\n59: \n60: \tch := make(chan prometheus.Metric, 1)\n61: \tmetrics.ScannedTotal.Collect(ch)\n62: \tmetric := <-ch\n63: \n64: \tvar metricDto dto.Metric\n65: \terr := metric.Write(&metricDto)\n66: \tassert.NoError(t, err)\n67: \tassert.Equal(t, float64(15), metricDto.Counter.GetValue())\n68: }\n69: \n70: func TestGCMetrics_RecordError(t *testing.T) {\n71: \tmetrics := NewGCMetrics()\n72: \n73: \tmetrics.RecordError(\"collect\")\n74: \tmetrics.RecordError(\"delete\")\n75: \n76: \tch := make(chan prometheus.Metric, 10)\n77: \tmetrics.ErrorsTotal.Collect(ch)\n78: \n79: \ttotal := 0.0\n80: \tfor range ch {\n81: \t\ttotal++\n82: \t}\n83: \n84: \tassert.Equal(t, float64(2), total)\n85: }\n86: \n87: func TestGCMetrics_SetCandidates(t *testing.T) {\n88: \tmetrics := NewGCMetrics()\n89: \n90: \tmetrics.SetCandidates(5)\n91: \n92: \tch := make(chan prometheus.Metric, 1)\n93: \tmetrics.Candidates.Collect(ch)\n94: \tmetric := <-ch\n95: \n96: \tvar metricDto dto.Metric\n97: \terr := metric.Write(&metricDto)\n98: \tassert.NoError(t, err)\n99: \tassert.Equal(t, float64(5), metricDto.Gauge.GetValue())\n100: \n101: \tmetrics.SetCandidates(0)\n102: \tmetrics.Candidates.Collect(ch)\n103: \tmetric = <-ch\n104: \n105: \terr = metric.Write(&metricDto)\n106: \tassert.NoError(t, err)\n107: \tassert.Equal(t, float64(0), metricDto.Gauge.GetValue())\n108: }\n109: \n110: func TestGCMetrics_ResetCandidates(t *testing.T) {\n111: \tmetrics := NewGCMetrics()\n112: \n113: \tmetrics.SetCandidates(10)\n114: \tmetrics.ResetCandidates()\n115: \n116: \tch := make(chan prometheus.Metric, 1)\n117: \tmetrics.Candidates.Collect(ch)\n118: \tmetric := <-ch\n119: \n120: \tvar metricDto dto.Metric\n121: \terr := metric.Write(&metricDto)\n122: \tassert.NoError(t, err)\n123: \tassert.Equal(t, float64(0), metricDto.Gauge.GetValue())\n124: }\n125: \n126: func TestGCMetrics_RecordDuration(t *testing.T) {\n127: \tmetrics := NewGCMetrics()\n128: \n129: \tmetrics.RecordDuration(1.5)\n130: \tmetrics.RecordDuration(2.3)\n131: \tmetrics.RecordDuration(0.8)\n132: \n133: \tassert.NotNil(t, metrics.Duration)\n134: }\n135: \n136: func TestGCMetrics_Concurrent(t *testing.T) {\n137: \tmetrics := NewGCMetrics()\n138: \n139: \tdone := make(chan bool)\n140: \n141: \tfor i := 0; i < 100; i++ {\n142: \t\tgo func() {\n143: \t\t\tmetrics.RecordRun()\n144: \t\t\tmetrics.RecordDeleted(\"idle_timeout\", \"Sandbox\")\n145: \t\t\tmetrics.RecordScanned(1)\n146: \t\t\tdone <- true\n147: \t\t}()\n148: \t}\n149: \n150: \tfor i := 0; i < 100; i++ {\n151: \t\t<-done\n152: \t}\n153: \n154: \tch := make(chan prometheus.Metric, 1)\n155: \tmetrics.RunsTotal.Collect(ch)\n156: \tmetric := <-ch\n157: \n158: \tvar metricDto dto.Metric\n159: \terr := metric.Write(&metricDto)\n160: \tassert.NoError(t, err)\n161: \tassert.Equal(t, float64(100), metricDto.Counter.GetValue())\n162: }\n\n(End of file - total 162 lines)\n</content>","metadata":{"preview":"package gc\n\nimport (\n\t\"testing\"\n\n\t\"github.com/prometheus/client_golang/prometheus\"\n\tdto \"github.com/prometheus/client_model/go\"\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestNewGCMetrics(t *testing.T) {\n\tmetrics := NewGCMetrics()\n\tassert.NotNil(t, metrics)\n\tassert.NotNil(t, metrics.RunsTotal)\n\tassert.NotNil(t, metrics.DeletedTotal)\n\tassert.NotNil(t, metrics.ScannedTotal)\n\tassert.NotNil(t, metrics.ErrorsTotal)\n\tassert.NotNil(t, metrics.Duration)\n\tassert.NotNil(t, metrics.Candidates)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/metrics_test.go","time":{"start":1775891686265,"end":1775891686279}}}}
