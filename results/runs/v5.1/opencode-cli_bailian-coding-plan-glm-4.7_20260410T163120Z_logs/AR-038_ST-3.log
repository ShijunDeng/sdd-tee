t, err)\n150: \tassert.NotNil(t, result)\n151: \tassert.Equal(t, 0, result.Scanned)\n152: \tassert.Equal(t, 0, result.Candidates)\n153: \tassert.Equal(t, 0, result.Deleted)\n154: \tassert.Equal(t, 0, result.Errors)\n155: }\n156: \n157: func TestGCCollector_Collect_ExpiredSandbox(t *testing.T) {\n158: \tmockStore := &mockStore{}\n159: \tscheme := runtime.NewScheme()\n160: \t\n161: \tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n162: \t\t&unstructured.Unstructured{},\n163: \t\t&unstructured.UnstructuredList{},\n164: \t)\n165: \t\n166: \tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n167: \t\tSandboxGVR: \"SandboxList\",\n168: \t\tSandboxClaimGVR: \"SandboxClaimList\",\n169: \t})\n170: \n171: \tsessionID := \"test-session\"\n172: \tsandboxInfo := &types.SandboxInfo{\n173: \t\tSessionID:        sessionID,\n174: \t\tSandboxID:        \"test-sandbox\",\n175: \t\tSandboxNamespace: \"default\",\n176: \t\tKind:             \"Sandbox\",\n177: \t\tLastActivityAt:   time.Now(),\n178: \t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n179: \t}\n180: \n181: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n182: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n183: \n184: \tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 24*time.Hour)\n185: \tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n186: \n187: \tconfig := &GCConfig{\n188: \t\tMaxAge:        1 * time.Hour,\n189: \t\tIdleTimeout:   15 * time.Minute,\n190: \t\tDryRun:        false,\n191: \t\tNamespaces:    []string{},\n192: \t\tLabelSelector: \"\",\n193: \t}\n194: \tpolicy, _ := NewGCPolicy(config)\n195: \tmetrics := NewGCMetrics()\n196: \n197: \tcollector := NewGCCollector(fakeClient, mockStore, config, policy, metrics)\n198: \n199: \tctx := context.Background()\n200: \tresult, err := collector.Collect(ctx)\n201: \n202: \tassert.NoError(t, err)\n203: \tassert.NotNil(t, result)\n204: \tassert.Equal(t, 1, result.Scanned)\n205: \tassert.Equal(t, 1, result.Candidates)\n206: \tassert.Equal(t, 1, result.Deleted)\n207: \tassert.Equal(t, 0, result.Errors)\n208: \n209: \tmockStore.AssertExpectations(t)\n210: }\n211: \n212: func TestGCCollector_Collect_IdleSandbox(t *testing.T) {\n213: \tmockStore := &mockStore{}\n214: \tscheme := runtime.NewScheme()\n215: \t\n216: \tscheme.AddKnownTypes(schema.GroupVersion{Group: \"agents.x-k8s.io\", Version: \"v1alpha1\"}, \n217: \t\t&unstructured.Unstructured{},\n218: \t\t&unstructured.UnstructuredList{},\n219: \t)\n220: \t\n221: \tfakeClient := fake.NewSimpleDynamicClientWithCustomListKinds(scheme, map[schema.GroupVersionResource]string{\n222: \t\tSandboxGVR: \"SandboxList\",\n223: \t\tSandboxClaimGVR: \"SandboxClaimList\",\n224: \t})\n225: \n226: \tsessionID := \"test-session\"\n227: \tsandboxInfo := &types.SandboxInfo{\n228: \t\tSessionID:        sessionID,\n229: \t\tSandboxID:        \"test-sandbox\",\n230: \t\tSandboxNamespace: \"default\",\n231: \t\tKind:             \"Sandbox\",\n232: \t\tLastActivityAt:   time.Now().Add(-30 * time.Minute),\n233: \t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n234: \t}\n235: \n236: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n237: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n238: \n239: \tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 10*time.Minute)\n240: \tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n241: \n242: \tconfig := &GCConfig{\n243: \t\tMaxAge:        1 * time.Hour,\n244: \t\tIdleTimeout:   15 * time.Minute,\n245: \t\tDryRun:        false,\n246: \t\tNamespaces:    []string{},\n247: \t\tLabelSelector: \"\",\n248: \t}\n249: \tpolicy, _ := NewGCPolicy(config)\n250: \