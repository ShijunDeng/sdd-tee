 \tEntryPoints  []EntryPoint `json:\"entryPoints\"`\n37: \tLastActivity string       `json:\"lastActivity\"`\n38: \tCreatedAt    string       `json:\"createdAt\"`\n39: \tExpiresAt    string       `json:\"expiresAt\"`\n40: \tPodIP        string       `json:\"podIp,omitempty\"`\n41: }\n42: \n43: type DeleteSessionRequest struct {\n44: \tSessionID string `uri:\"sessionId\" binding:\"required\"`\n45: }\n46: \n47: type DeleteSessionResponse struct {\n48: \tSessionID string `json:\"sessionId\"`\n49: \tDeletedAt string `json:\"deletedAt\"`\n50: }\n\n(End of file - total 50 lines)\n</content>","metadata":{"preview":"package api\n\ntype CreateSandboxRequest struct {\n\tKind      string `json:\"kind\" binding:\"required\"`\n\tName      string `json:\"name\" binding:\"required\"`\n\tNamespace string `json:\"namespace\" binding:\"required\"`\n}\n\ntype CreateSandboxResponse struct {\n\tSessionID   string       `json:\"sessionId\"`\n\tSandboxID   string       `json:\"sandboxId\"`\n\tSandboxName string       `json:\"sandboxName\"`\n\tEntryPoints []EntryPoint `json:\"entryPoints\"`\n\tCreatedAt   string       `json:\"createdAt\"`\n\tExpiresAt   string       `json:\"expiresAt\"`\n}\n\ntype EntryPoint struct {\n\tProtocol string `json:\"protocol\"`\n\tEndpoint string `json:\"endpoint\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/api/types.go","time":{"start":1775891686266,"end":1775891686281}}}}
