{"type":"tool_use","timestamp":1775891631045,"sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","part":{"id":"prt_d7b63c5ed001yOdl1bpCtsac05","messageID":"msg_d7b63acc6001SrTLDV75i1z86N","sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","type":"tool","tool":"read","callID":"toolu_tool-aec947e4653a402a83d4bcefb4d3eff9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/garbage_collector.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/garbage_collector.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"time\"\n6: \n7: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n8: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n9: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n10: \t\"k8s.io/client-go/dynamic\"\n11: \t\"k8s.io/klog/v2\"\n12: \n13: \twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n14: \n15: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n16: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n17: )\n18: \n19: var (\n20: \tSandboxGVR = schema.GroupVersionResource{\n21: \t\tGroup:    \"agents.x-k8s.io\",\n22: \t\tVersion:  \"v1alpha1\",\n23: \t\tResource: \"sandboxes\",\n24: \t}\n25: \n26: \tSandboxClaimGVR = schema.GroupVersionResource{\n27: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n28: \t\tVersion:  \"v1alpha1\",\n29: \t\tResource: \"sandboxclaims\",\n30: \t}\n31: )\n32: \n33: type GarbageCollector struct {\n34: \tdynamicClient dynamic.Interface\n35: \tstoreClient   store.Store\n36: \tinterval      time.Duration\n37: \tctx           context.Context\n38: \tcancel        context.CancelFunc\n39: }\n40: \n41: func NewGarbageCollector(\n42: \tdynamicClient dynamic.Interface,\n43: \tstoreClient store.Store,\n44: \tinterval time.Duration,\n45: ) *GarbageCollector {\n46: \tctx, cancel := context.WithCancel(context.Background())\n47: \treturn &GarbageCollector{\n48: \t\tdynamicClient: dynamicClient,\n49: \t\tstoreClient:   storeClient,\n50: \t\tinterval:      interval,\n51: \t\tctx:           ctx,\n52: \t\tcancel:        cancel,\n53: \t}\n54: }\n55: \n56: func (gc *GarbageCollector) Start() {\n57: \tgo gc.gcLoop()\n58: }\n59: \n60: func (gc *GarbageCollector) Stop() {\n61: \tgc.cancel()\n62: }\n63: \n64: func (gc *GarbageCollector) gcLoop() {\n65: \tticker := time.NewTicker(gc.interval)\n66: \tdefer ticker.Stop()\n67: \n68: \tklog.Info(\"GarbageCollector started\")\n69: \n70: \tfor {\n71: \t\tselect {\n72: \t\tcase <-gc.ctx.Done():\n73: \t\t\tklog.Info(\"GarbageCollector stopped\")\n74: \t\t\treturn\n75: \t\tcase <-ticker.C:\n76: \t\t\tgc.tick()\n77: \t\t}\n78: \t}\n79: }\n80: \n81: func (gc *GarbageCollector) tick() {\n82: \ttickCtx, cancel := context.WithTimeout(gc.ctx, GCSingleTickTimeout)\n83: \tdefer cancel()\n84: \n85: \tnow := time.Now()\n86: \tidleThreshold := now.Add(-DefaultSandboxIdleTimeout)\n87: \texpiredThreshold := now\n88: \n89: \tidleSandboxes, err := gc.storeClient.ListInactiveSandboxes(tickCtx, idleThreshold, 16)\n90: \tif err != nil {\n91: \t\tklog.Errorf(\"Failed to list inactive sandboxes: %v\", err)\n92: \t} else {\n93: \t\tfor _, sandbox := range idleSandboxes {\n94: \t\t\tgc.deleteSandbox(tickCtx, sandbox, wmTypes.CleanupReasonIdleTimeout)\n95: \t\t}\n96: \t}\n97: \n98: \texpiredSandboxes, err := gc.storeClient.ListExpiredSandboxes(tickCtx, expiredThreshold, 16)\n99: \tif err != nil {\n100: \t\tklog.Errorf(\"Failed to list expired sandboxes: %v\", err)\n101: \t} else {\n102: \t\tfor _, sandbox := range expiredSandboxes {\n103: \t\t\tgc.deleteSandbox(tickCtx, sandbox, wmTypes.CleanupReasonExpired)\n104: \t\t}\n105: \t}\n106: }\n107: \n108: func (gc *GarbageCollector) deleteSandbox(\n109: \tctx context.Context,\n110: \tsandbox *types.SandboxInfo,\n111: \treason wmTypes.SandboxCleanupReason,\n112: ) {\n113: \tauditEntry := &wmTypes.CleanupAuditEntry{\n114: \t\tSessionID: sandbox.SessionID,\n115: \t\tSandboxID: sandbox.SandboxID,\n116: \t\tNamespace: sandbox.SandboxNamespace,\n117: \t\tReason:    reason,\n118: \t\tDeletedAt: time.Now(),\n119: \t}\n120: \n121: \tgvr := SandboxGVR\n122: \tif sandbox.Kind == \"SandboxClaim\" {\n123: \t\tgvr = SandboxClaimGVR\n124: \t}\n125: \n126: \tdeleteCtx, cancel := context.WithTimeout(ctx, DeleteTimeout)\n127: \tdefer cancel()\n128: \n129: \terr := gc.dynamicClient.Resource(gvr).\n130: \t\tNamespace(sandbox.SandboxNamespace).\n131: \t\tDelete(deleteCtx, sandbox.SandboxID, metav1.DeleteOptions{})\n132: \n133: \tif err != nil && !apierrors.IsNotFound(err) {\n134: \t\tauditEntry.ErrorMessage = err.Error()\n135: \t\tauditEntry.Success = false\n136: \t\tklog.Errorf(\"Failed to delete sandbox %s/%s: %v\", sandbox.SandboxNamespace, sandbox.SandboxID, err)\n137: \t} else {\n138: \t\tif err := gc.storeClient.DeleteSandboxBySessionID(ctx, sandbox.SessionID); err != nil {\n139: \t\t\tklog.Warningf(\"Failed to delete sandbox %s from store: %v\", sandbox.SessionID, err)\n140: \t\t}\n141: \t\tauditEntry.Success = true\n142: \t\tklog.Infof(\"Deleted sandbox %s/%s (reason: %s)\", sandbox.SandboxNamespace, sandbox.SandboxID, reason)\n143: \t}\n144: \n145: \tgc.recordAudit(auditEntry)\n146: }\n147: \n148: func (gc *GarbageCollector) recordAudit(entry *wmTypes.CleanupAuditEntry) {\n149: \tklog.Infof(\"Cleanup audit: sessionId=%s sandboxId=%s namespace=%s reason=%s success=%v deletedAt=%s\",\n150: \t\tentry.SessionID, entry.SandboxID, entry.Namespace, entry.Reason, entry.Success, entry.DeletedAt.Format(time.RFC3339))\n151: \tif entry.ErrorMessage != \"\" {\n152: \t\tklog.Infof(\"Cleanup audit error: %s\", entry.ErrorMessage)\n153: \t}\n154: }\n\n(End of file - total 154 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/klog/v2\"\n\n\twmTypes \"github.com/volcano-sh/agentcube/pkg/workloadmanager/types\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\nvar (\n\tSandboxGVR = schema.GroupVersionResource{","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/garbage_collector.go","time":{"start":1775891631027,"end":1775891631044}}}}
{"type":"tool_use","timestamp":1775891631058,"sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","part":{"id":"prt_d7b63c8aa001Fg3nzY02CnCg5P","messageID":"msg_d7b63acc6001SrTLDV75i1z86N","sessionID":"ses_2849c7c13ffe8wC3uB19j2tPvE","type":"tool","tool":"read","callID":"toolu_tool-75ebd46854f84d08a559c3550f8dbd31","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox.go</path>\n<type>file</type>\n<content>\n1: package controller\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"math/rand\"\n7: \t\"time\"\n8: \n9: \t\"github.com/google/uuid\"\n10: \tcorev1 \"k8s.io/api/core/v1\"\n11: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n12: \t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n13: \t\"k8s.io/apimachinery/pkg/runtime\"\n14: \n15: \t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n16: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n17: \t\"github.com/volcano-sh/agentcube/pkg/store\"\n18: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/api\"\n19: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/client\"\n20: )\n21: \n22: type Controller interface {\n23: \tCreateAgentRuntimeSandbox(ctx context.Context, req *api.CreateSandboxRequest) (*api.CreateSandboxResponse, error)\n24: \tCreateCodeInterpreterSandbox(ctx context.Context, req *api.CreateSandboxRequest) (*api.CreateSandboxResponse, error)\n25: \tGetSession(ctx context.Context, sessionID string) (*api.GetSessionResponse, error)\n26: \tDeleteSession(ctx context.Context, sessionID string) (*api.DeleteSessionResponse, error)\n27: }\n28: \n29: type SandboxController struct {\n30: \tk8sClient client.Client\n31: \tstore     store.Store\n32: }\n33: \n34: func NewSandboxController(k8sClient client.Client, store store.Store) *SandboxController {\n35: \treturn &SandboxController{\n36: \t\tk8sClient: k8sClient,\n37: \t\tstore:     store,\n38: \t}\n39: }\n40: \n41: func (sc *SandboxController) CreateAgentRuntimeSandbox(ctx context.Context, req *api.CreateSandboxRequest) (*api.CreateSandboxResponse, error) {\n42: \tagentRuntime, err := sc.k8sClient.GetAgentRuntime(ctx, req.Namespace, req.Name)\n43: \tif err != nil {\n44: \t\tif apierrors.IsNotFound(err) {\n45: \t\t\treturn nil, fmt.Errorf(\"AgentRuntime %s/%s not found\", req.Namespace, req.Name)\n46: \t\t}\n47: \t\treturn nil, fmt.Errorf(\"failed to get AgentRuntime: %w\", err)\n48: \t}\n49: \n50: \tspec, found, err := unstructured.NestedMap(agentRuntime.Object, \"spec\")\n51: \tif err != nil {\n52: \t\treturn nil, fmt.Errorf(\"failed to get spec: %w\", err)\n53: \t}\n54: \tif !found {\n55: \t\treturn nil, fmt.Errorf(\"spec not found\")\n56: \t}\n57: \n58: \tsessionID := uuid.New().String()\n59: \tsandboxName := generateSandboxName(req.Name)\n60: \n61: \tsandboxCR, err := sc.buildAgentRuntimeSandboxCR(agentRuntime, sessionID, sandboxName, req.Name, req.Namespace)\n62: \tif err != nil {\n63: \t\treturn nil, fmt.Errorf(\"failed to build sandbox CR: %w\", err)\n64: \t}\n65: \n66: \tsandboxInfo := &types.SandboxInfo{\n67: \t\tSessionID:    sessionID,\n68: \t\tSandboxName:  sandboxName,\n69: \t\tWorkloadName: req.Name,\n70: \t\tNamespace:    req.Namespace,\n71: \t\tKind:         \"AgentRuntime\",\n72: \t\tStatus:       \"pending\",\n73: \t\tCreatedAt:    time.Now(),\n74: \t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n75: \t}\n76: \n77: \tif err := sc.store.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n78: \t\treturn nil, fmt.Errorf(\"failed to store sandbox: %w\", err)\n79: \t}\n80: \n81: \tcreatedCR, err := sc.k8sClient.CreateSandbox(ctx, req.Namespace, sandboxCR)\n82: \tif err != nil {\n83: \t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n84: \t\treturn nil, fmt.Errorf(\"failed to create sandbox: %w\", err)\n85: \t}\n86: \n87: \tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\n88: \tdefer cancel()\n89: \n90: \tvar podIP string\n91: \tfor i := 0; i < 60; i++ {\n92: \t\tpodIP, err = sc.k8sClient.GetPodIP(ctx, sandboxName, req.Namespace, createdCR)\n93: \t\tif err == nil {\n94: \t\t\tbreak\n95: \t\t}\n96: \t\tselect {\n97: \t\tcase <-ctx.Done():\n98: \t\t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n99: \t\t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n100: \t\t\treturn nil, fmt.Errorf(\"sandbox creation timed out\")\n101: \t\tcase <-time.After(2 * time.Second):\n102: \t\t\tcontinue\n103: \t\t}\n104: \t}\n105: \n106: \tports, _, err := unstructured.NestedSlice(spec, \"ports\")\n107: \tif err != nil {\n108: \t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n109: \t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n110: \t\treturn nil, fmt.Errorf(\"failed to get ports: %w\", err)\n111: \t}\n112: \n113: \tentryPoints := sc.buildEntryPoints(podIP, ports)\n114: \n115: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n116: \tsandboxInfo.PodIP = podIP\n117: \tsandboxInfo.EntryPoints = convertEntryPoints(entryPoints)\n118: \tsandboxInfo.Status = \"running\"\n119: \n120: \tif err := sc.store.UpdateSandbox(ctx, sessionID, sandboxInfo); err != nil {\n121: \t\treturn nil, fmt.Errorf(\"failed to update sandbox: %w\", err)\n122: \t}\n123: \n124: \treturn &api.CreateSandboxResponse{\n125: \t\tSessionID:   sessionID,\n126: \t\tSandboxID:   sandboxInfo.SandboxID,\n127: \t\tSandboxName: sandboxName,\n128: \t\tEntryPoints: entryPoints,\n129: \t\tCreatedAt:   sandboxInfo.CreatedAt.Format(time.RFC3339),\n130: \t\tExpiresAt:   sandboxInfo.ExpiresAt.Format(time.RFC3339),\n131: \t}, nil\n132: }\n133: \n134: func (sc *SandboxController) CreateCodeInterpreterSandbox(ctx context.Context, req *api.CreateSandboxRequest) (*api.CreateSandboxResponse, error) {\n135: \tcodeInterpreter, err := sc.k8sClient.GetCodeInterpreter(ctx, req.Namespace, req.Name)\n136: \tif err != nil {\n137: \t\tif apierrors.IsNotFound(err) {\n138: \t\t\treturn nil, fmt.Errorf(\"CodeInterpreter %s/%s not found\", req.Namespace, req.Name)\n139: \t\t}\n140: \t\treturn nil, fmt.Errorf(\"failed to get CodeInterpreter: %w\", err)\n141: \t}\n142: \n143: \tspec, found, err := unstructured.NestedMap(codeInterpreter.Object, \"spec\")\n144: \tif err != nil {\n145: \t\treturn nil, fmt.Errorf(\"failed to get spec: %w\", err)\n146: \t}\n147: \tif !found {\n148: \t\treturn nil, fmt.Errorf(\"spec not found\")\n149: \t}\n150: \n151: \tsessionID := uuid.New().String()\n152: \tsandboxName := generateSandboxName(req.Name)\n153: \n154: \tports, _, _ := unstructured.NestedSlice(spec, \"ports\")\n155: \tif len(ports) == 0 {\n156: \t\tports = []interface{}{\n157: \t\t\tmap[string]interface{}{\n158: \t\t\t\t\"port\":     int64(8080),\n159: \t\t\t\t\"protocol\": \"HTTP\",\n160: \t\t\t},\n161: \t\t}\n162: \t}\n163: \n164: \tsandboxCR, err := sc.buildCodeInterpreterSandboxCR(codeInterpreter, sessionID, sandboxName, req.Name, req.Namespace, ports)\n165: \tif err != nil {\n166: \t\treturn nil, fmt.Errorf(\"failed to build sandbox CR: %w\", err)\n167: \t}\n168: \n169: \tsandboxInfo := &types.SandboxInfo{\n170: \t\tSessionID:    sessionID,\n171: \t\tSandboxName:  sandboxName,\n172: \t\tWorkloadName: req.Name,\n173: \t\tNamespace:    req.Namespace,\n174: \t\tKind:         \"CodeInterpreter\",\n175: \t\tStatus:       \"pending\",\n176: \t\tCreatedAt:    time.Now(),\n177: \t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n178: \t}\n179: \n180: \tif err := sc.store.StoreSandbox(ctx, sessionID, sandboxInfo); err != nil {\n181: \t\treturn nil, fmt.Errorf(\"failed to store sandbox: %w\", err)\n182: \t}\n183: \n184: \tcreatedCR, err := sc.k8sClient.CreateSandbox(ctx, req.Namespace, sandboxCR)\n185: \tif err != nil {\n186: \t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n187: \t\treturn nil, fmt.Errorf(\"failed to create sandbox: %w\", err)\n188: \t}\n189: \n190: \tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\n191: \tdefer cancel()\n192: \n193: \tvar podIP string\n194: \tfor i := 0; i < 60; i++ {\n195: \t\tpodIP, err = sc.k8sClient.GetPodIP(ctx, sandboxName, req.Namespace, createdCR)\n196: \t\tif err == nil {\n197: \t\t\tbreak\n198: \t\t}\n199: \t\tselect {\n200: \t\tcase <-ctx.Done():\n201: \t\t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n202: \t\t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n203: \t\t\treturn nil, fmt.Errorf(\"sandbox creation timed out\")\n204: \t\tcase <-time.After(2 * time.Second):\n205: \t\t\tcontinue\n206: \t\t}\n207: \t}\n208: \n209: \tentryPoints := sc.buildEntryPoints(podIP, ports)\n210: \n211: \tsandboxInfo.SandboxID = string(createdCR.GetUID())\n212: \tsandboxInfo.PodIP = podIP\n213: \tsandboxInfo.EntryPoints = convertEntryPoints(entryPoints)\n214: \tsandboxInfo.Status = \"running\"\n215: \n216: \tif err := sc.store.UpdateSandbox(ctx, sessionID, sandboxInfo); err != nil {\n217: \t\treturn nil, fmt.Errorf(\"failed to update sandbox: %w\", err)\n218: \t}\n219: \n220: \treturn &api.CreateSandboxResponse{\n221: \t\tSessionID:   sessionID,\n222: \t\tSandboxID:   sandboxInfo.SandboxID,\n223: \t\tSandboxName: sandboxName,\n224: \t\tEntryPoints: entryPoints,\n225: \t\tCreatedAt:   sandboxInfo.CreatedAt.Format(time.RFC3339),\n226: \t\tExpiresAt:   sandboxInfo.ExpiresAt.Format(time.RFC3339),\n227: \t}, nil\n228: }\n229: \n230: func (sc *SandboxController) GetSession(ctx context.Context, sessionID string) (*api.GetSessionResponse, error) {\n231: \tsandboxInfo, err := sc.store.GetSandbox(ctx, sessionID)\n232: \tif err != nil {\n233: \t\tif err == store.ErrNotFound {\n234: \t\t\treturn nil, fmt.Errorf(\"session not found\")\n235: \t\t}\n236: \t\treturn nil, fmt.Errorf(\"failed to get session: %w\", err)\n237: \t}\n238: \n239: \treturn &api.GetSessionResponse{\n240: \t\tSessionID:    sandboxInfo.SessionID,\n241: \t\tSandboxID:    sandboxInfo.SandboxID,\n242: \t\tSandboxName:  sandboxInfo.SandboxName,\n243: \t\tKind:         sandboxInfo.Kind,\n244: \t\tNamespace:    sandboxInfo.Namespace,\n245: \t\tName:         sandboxInfo.WorkloadName,\n246: \t\tEntryPoints:  convertToAPIEntryPoints(sandboxInfo.EntryPoints),\n247: \t\tLastActivity: sandboxInfo.LastActivityAt.Format(time.RFC3339),\n248: \t\tCreatedAt:    sandboxInfo.CreatedAt.Format(time.RFC3339),\n249: \t\tExpiresAt:    sandboxInfo.ExpiresAt.Format(time.RFC3339),\n250: \t\tPodIP:        sandboxInfo.PodIP,\n251: \t}, nil\n252: }\n253: \n254: func (sc *SandboxController) DeleteSession(ctx context.Context, sessionID string) (*api.DeleteSessionResponse, error) {\n255: \tsandboxInfo, err := sc.store.GetSandbox(ctx, sessionID)\n256: \tif err != nil {\n257: \t\tif err == store.ErrNotFound {\n258: \t\t\treturn nil, fmt.Errorf(\"session not found\")\n259: \t\t}\n260: \t\treturn nil, fmt.Errorf(\"failed to get session: %w\", err)\n261: \t}\n262: \n263: \tif err := sc.k8sClient.DeleteSandbox(ctx, sandboxInfo.Namespace, sandboxInfo.SandboxName); err != nil && !apierrors.IsNotFound(err) {\n264: \t\treturn nil, fmt.Errorf(\"failed to delete sandbox: %w\", err)\n265: \t}\n266: \n267: \tif err := sc.store.DeleteSandboxBySessionID(ctx, sessionID); err != nil {\n268: \t\treturn nil, fmt.Errorf(\"failed to delete session: %w\", err)\n269: \t}\n270: \n271: \treturn &api.DeleteSessionResponse{\n272: \t\tSessionID: sessionID,\n273: \t\tDeletedAt: time.Now().Format(time.RFC3339),\n274: \t}, nil\n275: }\n276: \n277: func (sc *SandboxController) buildAgentRuntimeSandboxCR(agentRuntime *unstructured.Unstructured, sessionID, sandboxName, workloadName, namespace string) (*unstructured.Unstructured, error) {\n278: \tcr := &unstructured.Unstructured{}\n279: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n280: \tcr.SetKind(\"Sandbox\")\n281: \tcr.SetName(sandboxName)\n282: \tcr.SetNamespace(namespace)\n283: \n284: \tcr.SetLabels(map[string]string{\n285: \t\tconstants.LabelManagedBy:    constants.LabelManagedByValue,\n286: \t\tconstants.LabelSessionID:    sessionID,\n287: \t\tconstants.LabelWorkloadName: workloadName,\n288: \t\tconstants.LabelSandboxName:  sandboxName,\n289: \t})\n290: \n291: \tcr.SetAnnotations(map[string]string{\n292: \t\tconstants.AnnotationIdleTimeout: \"15m\",\n293: \t})\n294: \n295: \tshutdownTime := time.Now().Add(8 * time.Hour)\n296: \n297: \tspec := map[string]interface{}{\n298: \t\t\"replicas\": int64(1),\n299: \t\t\"lifecycle\": map[string]interface{}{\n300: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n301: \t\t},\n302: \t}\n303: \n304: \tspecMap, found, err := unstructured.NestedMap(agentRuntime.Object, \"spec\", \"podTemplate\")\n305: \tif err != nil {\n306: \t\treturn nil, err\n307: \t}\n308: \tif found {\n309: \t\tspec[\"podTemplate\"] = specMap\n310: \t}\n311: \n312: \tports, _, _ := unstructured.NestedSlice(agentRuntime.Object, \"spec\", \"ports\")\n313: \tif len(ports) > 0 {\n314: \t\tspec[\"ports\"] = ports\n315: \t}\n316: \n317: \tcr.Object[\"spec\"] = spec\n318: \n319: \treturn cr, nil\n320: }\n321: \n322: func (sc *SandboxController) buildCodeInterpreterSandboxCR(codeInterpreter *unstructured.Unstructured, sessionID, sandboxName, workloadName, namespace string, ports []interface{}) (*unstructured.Unstructured, error) {\n323: \tcr := &unstructured.Unstructured{}\n324: \tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n325: \tcr.SetKind(\"Sandbox\")\n326: \tcr.SetName(sandboxName)\n327: \tcr.SetNamespace(namespace)\n328: \n329: \tcr.SetLabels(map[string]string{\n330: \t\tconstants.LabelManagedBy:    constants.LabelManagedByValue,\n331: \t\tconstants.LabelSessionID:    sessionID,\n332: \t\tconstants.LabelWorkloadName: workloadName,\n333: \t\tconstants.LabelSandboxName:  sandboxName,\n334: \t})\n335: \n336: \tcr.SetAnnotations(map[string]string{\n337: \t\tconstants.AnnotationIdleTimeout: \"15m\",\n338: \t})\n339: \n340: \tshutdownTime := time.Now().Add(8 * time.Hour)\n341: \n342: \tspec := map[string]interface{}{\n343: \t\t\"replicas\": int64(1),\n344: \t\t\"lifecycle\": map[string]interface{}{\n345: \t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n346: \t\t},\n347: \t}\n348: \n349: \tif len(ports) > 0 {\n350: \t\tspec[\"ports\"] = ports\n351: \t}\n352: \n353: \timage, _, _ := unstructured.NestedString(codeInterpreter.Object, \"spec\", \"template\", \"image\")\n354: \tif image == \"\" {\n355: \t\timage = \"python:3.11-slim\"\n356: \t}\n357: \n358: \tcontainer := corev1.Container{\n359: \t\tName:  \"code-interpreter\",\n360: \t\tImage: image,\n361: \t}\n362: \n363: \tpodSpec := corev1.PodSpec{\n364: \t\tContainers: []corev1.Container{container},\n365: \t}\n366: \n367: \tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n368: \tif err != nil {\n369: \t\treturn nil, fmt.Errorf(\"failed to convert pod spec: %w\", err)\n370: \t}\n371: \n372: \tspec[\"podTemplate\"] = podSpecMap\n373: \n374: \tcr.Object[\"spec\"] = spec\n375: \n376: \treturn cr, nil\n377: }\n378: \n379: func (sc *SandboxController) buildEntryPoints(podIP string, ports []interface{}) []api.EntryPoint {\n380: \tvar entryPoints []api.EntryPoint\n381: \tfor _, p := range ports {\n382: \t\tportMap, ok := p.(map[string]interface{})\n383: \t\tif !ok {\n384: \t\t\tcontinue\n385: \t\t}\n386: \n387: \t\tprotocol, _, _ := unstructured.NestedString(portMap, \"protocol\")\n388: \t\tport, _, _ := unstructured.NestedInt64(portMap, \"port\")\n389: \t\tpath, _, _ := unstructured.NestedString(portMap, \"pathPrefix\")\n390: \n391: \t\tif port == 0 || protocol == \"\" {\n392: \t\t\tcontinue\n393: \t\t}\n394: \n395: \t\tentryPoints = append(entryPoints, api.EntryPoint{\n396: \t\t\tProtocol: protocol,\n397: \t\t\tEndpoint: fmt.Sprintf(\"%s:%d\", podIP, port),\n398: \t\t\tPath:     path,\n399: \t\t\tPort:     int32(port),\n400: \t\t})\n401: \t}\n402: \treturn entryPoints\n403: }\n404: \n405: func convertEntryPoints(entryPoints []api.EntryPoint) []types.SandboxEntryPoint {\n406: \tvar result []types.SandboxEntryPoint\n407: \tfor _, ep := range entryPoints {\n408: \t\tresult = append(result, types.SandboxEntryPoint{\n409: \t\t\tProtocol: ep.Protocol,\n410: \t\t\tEndpoint: ep.Endpoint,\n411: \t\t\tPath:     ep.Path,\n412: \t\t})\n413: \t}\n414: \treturn result\n415: }\n416: \n417: func convertToAPIEntryPoints(entryPoints []types.SandboxEntryPoint) []api.EntryPoint {\n418: \tvar result []api.EntryPoint\n419: \tfor _, ep := range entryPoints {\n420: \t\tresult = append(result, api.EntryPoint{\n421: \t\t\tProtocol: ep.Protocol,\n422: \t\t\tEndpoint: ep.Endpoint,\n423: \t\t\tPath:     ep.Path,\n424: \t\t})\n425: \t}\n426: \treturn result\n427: }\n428: \n429: func generateSandboxName(workloadName string) string {\n430: \treturn fmt.Sprintf(\"%s-%s\", workloadName, RandString(8))\n431: }\n432: \n433: func RandString(n int) string {\n434: \tconst charset = \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\"\n435: \tb := make([]byte, n)\n436: \tfor i := range b {\n437: \t\tb[i] = charset[rand.Intn(len(charset))]\n438: \t}\n439: \treturn string(b)\n440: }\n\n(End of file - total 440 lines)\n</content>","metadata":{"preview":"package controller\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"math/rand\"\n\t\"time\"\n\n\t\"github.com/google/uuid\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/constants\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/api\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/client\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox.go","time":{"start":1775891631031,"end":1775891631056}}}}
