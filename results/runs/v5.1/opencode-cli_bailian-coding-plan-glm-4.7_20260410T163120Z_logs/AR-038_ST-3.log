\",\n103: \t}\n104: \tmetrics := NewGCMetrics()\n105: \n106: \tscheduler, err := NewGCScheduler(fakeClient, mockStore, config, metrics)\n107: \tassert.NoError(t, err)\n108: \n109: \tctx, cancel := context.WithCancel(context.Background())\n110: \tdone := make(chan error)\n111: \n112: \tgo func() {\n113: \t\tdone <- scheduler.Start(ctx)\n114: \t}()\n115: \n116: \ttime.Sleep(250 * time.Millisecond)\n117: \n118: \tscheduler.Stop()\n119: \tcancel()\n120: \n121: \tselect {\n122: \tcase err := <-done:\n123: \t\tassert.NoError(t, err)\n124: \tcase <-time.After(1 * time.Second):\n125: \t\tassert.Fail(t, \"scheduler did not stop in time\")\n126: \t}\n127: \n128: \tmockStore.AssertExpectations(t)\n129: }\n130: \n131: func TestGCScheduler_UpdateConfig(t *testing.T) {\n132: \tmockStore := &mockStore{}\n133: \tscheme := runtime.NewScheme()\n134: \tfakeClient := fake.NewSimpleDynamicClient(scheme)\n135: \n136: \tconfig := DefaultGCConfig()\n137: \tmetrics := NewGCMetrics()\n138: \n139: \tscheduler, err := NewGCScheduler(fakeClient, mockStore, config, metrics)\n140: \tassert.NoError(t, err)\n141: \n142: \tnewConfig := &GCConfig{\n143: \t\tInterval:      30 * time.Second,\n144: \t\tMaxAge:        12 * time.Hour,\n145: \t\tIdleTimeout:   30 * time.Minute,\n146: \t\tDryRun:        false,\n147: \t\tNamespaces:    []string{\"test\"},\n148: \t\tLabelSelector: \"app=test\",\n149: \t}\n150: \n151: \terr = scheduler.UpdateConfig(newConfig)\n152: \tassert.NoError(t, err)\n153: \n154: \tassert.Equal(t, newConfig, scheduler.config)\n155: \tassert.Equal(t, 30*time.Second, scheduler.interval)\n156: \tassert.Equal(t, 12*time.Hour, scheduler.policy.MaxAgeThreshold)\n157: \tassert.Equal(t, 30*time.Minute, scheduler.policy.IdleThreshold)\n158: }\n159: \n160: func TestGCScheduler_UpdateConfig_InvalidSelector(t *testing.T) {\n161: \tmockStore := &mockStore{}\n162: \tscheme := runtime.NewScheme()\n163: \tfakeClient := fake.NewSimpleDynamicClient(scheme)\n164: \n165: \tconfig := DefaultGCConfig()\n166: \tmetrics := NewGCMetrics()\n167: \n168: \tscheduler, err := NewGCScheduler(fakeClient, mockStore, config, metrics)\n169: \tassert.NoError(t, err)\n170: \n171: \tnewConfig := &GCConfig{\n172: \t\tLabelSelector: \"invalid[selector\",\n173: \t}\n174: \n175: \terr = scheduler.UpdateConfig(newConfig)\n176: \tassert.Error(t, err)\n177: \tassert.NotEqual(t, newConfig, scheduler.config)\n178: }\n179: \n180: func TestGCScheduler_RunOnce_WithError(t *testing.T) {\n181: \tmockStore := &mockStore{}\n182: \tscheme := runtime.NewScheme()\n183: \tfakeClient := fake.NewSimpleDynamicClient(scheme)\n184: \n185: \tmockStore.On(\"GetSandbox\", mock.Anything, mock.Anything).Return(nil, assert.AnError)\n186: \n187: \tconfig := DefaultGCConfig()\n188: \tmetrics := NewGCMetrics()\n189: \n190: \tscheduler, err := NewGCScheduler(fakeClient, mockStore, config, metrics)\n191: \tassert.NoError(t, err)\n192: \n193: \tctx := context.Background()\n194: \tresult, err := scheduler.RunOnce(ctx)\n195: \n196: \tassert.Error(t, err)\n197: \tassert.NotNil(t, result)\n198: \tassert.Greater(t, result.Errors, 0)\n199: \n200: \tmockStore.AssertExpectations(t)\n201: }\n202: \n203: func TestGCScheduler_RunOnce_WithExpiredSandbox(t *testing.T) {\n204: \tmockStore := &mockStore{}\n205: \tscheme := runtime.NewScheme()\n206: \tfakeClient := fake.NewSimpleDynamicClient(scheme)\n207: \n208: \tsessionID := \"test-session\"\n209: \tsandboxInfo := &types.SandboxInfo{\n210: \t\tSessionID:        sessionID,\n211: \t\tSandboxID:        \"test-sandbox\",\n212: \t\tSandboxNamespace: \"default\",\n213: \t\tKind:             \"Sandbox\",\n214: \t\tLastActivityAt:   time.Now(),\n215: \t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n216: \t}\n217: \n218: \tmockStore.On(\"GetSandbox\", mock.Anything, sessionID).Return(sandboxInfo, nil)\n219: \tmockStore.On(\"DeleteSandboxBySessionID\", mock.Anything, sessionID).Return(nil)\n220: \n221: \tsandbox := buildTestSandbox(\"test-sandbox\", \"default\", sessionID, 24*time.Hour)\n222: \tfakeClient.Resource(SandboxGVR).Namespace(\"default\").Create(context.Background(), sandbox, metav1.CreateOptions{})\n223: \n224: \tconfig := &GCConfig{\n225: \t\tMaxAge:        1 * time.Hour,\n226: \t\tIdleTimeout:   15 * time.Minute,\n227: \t\tDryRun:        false,\n228: \t\tNamespaces:    []string{},\n229: \t\tLabelSelector: \"\",\n230: \t}\n231: \tmetrics := NewGCMetrics()\n232: \n233: \tscheduler, err := NewGCScheduler(fakeClient, mockStore, config, metrics)\n234: \tassert.NoError(t, err)\n235: \n236: \tctx := context.Background()\n237: \tresult, err := scheduler.RunOnce(ctx)\n238: \n239: \tassert.NoError(t, err)\n240: \tassert.NotNil(t, result)\n241: \tassert.Equal(t, 1, result.Scanned)\n242: \tassert.Equal(t, 1, result.Candidates)\n243: \tassert.Equal(t, 1, result.Deleted)\n244: \n245: \tmockStore.AssertExpectations(t)\n246: }\n247: \n248: func TestGCScheduler_RunOnce_MultipleRuns(t *testing.T) {\n249: \tmockStore := &mockStore{}\n250: \tscheme := runtime.NewScheme()\n251: \tfakeClient := fake.NewSimpleDynamicClient(scheme)\n252: \n253: \tmockStore.On(\"GetSandbox\", mock.Anything, mock.Anything).Return(nil, store.ErrNotFound)\n254: \n255: \tconfig := DefaultGCConfig()\n256: \tmetrics := NewGCMetrics()\n257: \n258: \tscheduler, err := NewGCScheduler(fakeClient, mockStore, config, metrics)\n259: \tassert.NoError(t, err)\n260: \n261: \tctx := context.Background()\n262: \n263: \tfor i := 0; i < 5; i++ {\n264: \t\tresult, err := scheduler.RunOnce(ctx)\n265: \t\tassert.NoError(t, err)\n266: \t\tassert.NotNil(t, result)\n267: \t}\n268: \n269: \tmockStore.AssertExpectations(t)\n270: }\n271: \n272: func TestGCScheduler_Stop_CalledTwice(t *testing.T) {\n273: \tmockStore := &mockStore{}\n274: \tscheme := runtime.NewScheme()\n275: \tfakeClient := fake.NewSimpleDynamicClient(scheme)\n276: \n277: \tmockStore.On(\"GetSandbox\", mock.Anything, mock.Anything).Return(nil, store.ErrNotFound)\n278: \n279: \tconfig := DefaultGCConfig()\n280: \tmetrics := NewGCMetrics()\n281: \n282: \tscheduler, err := NewGCScheduler(fakeClient, mockStore, config, metrics)\n283: \tassert.NoError(t, err)\n284: \n285: \tassert.NotPanics(t, func() {\n286: \t\tscheduler.Stop()\n287: \t\tscheduler.Stop()\n288: \t})\n289: }\n\n(End of file - total 289 lines)\n</content>","metadata":{"preview":"package gc\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/dynamic/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n)\n\nfunc TestNewGCScheduler(t *testing.T) {\n\tmockStore := &mockStore{}\n\tscheme := runtime.NewScheme()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/gc/scheduler_test.go","time":{"start":1775891686262,"end":1775891686277}}}}
