ds\", \"POST, OPTIONS, GET, PUT, DELETE\")\n39: \n40: \t\tif c.Request.Method == \"OPTIONS\" {\n41: \t\t\tc.AbortWithStatus(204)\n42: \t\t\treturn\n43: \t\t}\n44: \n45: \t\tc.Next()\n46: \t}\n47: }\n\n(End of file - total 47 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\nfunc RecoveryMiddleware() gin.HandlerFunc {\n\treturn func(c *gin.Context) {\n\t\tdefer func() {\n\t\t\tif err := recover(); err != nil {\n\t\t\t\tklog.Errorf(\"Panic recovered: %v\", err)\n\t\t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n\t\t\t\t\t\"error\": \"internal server error\",\n\t\t\t\t})\n\t\t\t\tc.Abort()\n\t\t\t}\n\t\t}()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/middleware/middleware.go","time":{"start":1775891682003,"end":1775891682014}}}}
