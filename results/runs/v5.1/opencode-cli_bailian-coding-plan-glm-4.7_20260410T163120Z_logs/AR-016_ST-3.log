{"type":"tool_use","timestamp":1775859341904,"sessionID":"ses_2868919c7ffebiv27BUPS9ii6Y","part":{"id":"prt_d79771576001wyMm2bgPvLVP7P","messageID":"msg_d797704dd001otmhTP7Vgs5RAt","sessionID":"ses_2868919c7ffebiv27BUPS9ii6Y","type":"tool","tool":"read","callID":"toolu_tool-c23cac83977546b996e86ce59cfe9252","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/files.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/files.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"os\"\n6: \t\"path/filepath\"\n7: \t\"strconv\"\n8: \t\"strings\"\n9: \t\"time\"\n10: )\n11: \n12: type FileInfo struct {\n13: \tPath     string    `json:\"path\"`\n14: \tSize     int64     `json:\"size\"`\n15: \tMode     string    `json:\"mode\"`\n16: \tModified time.Time `json:\"modified\"`\n17: }\n18: \n19: type UploadFileRequest struct {\n20: \tPath    string `json:\"path\" binding:\"required\"`\n21: \tContent string `json:\"content\" binding:\"required\"`\n22: \tMode    string `json:\"mode\"`\n23: }\n24: \n25: type FileEntry struct {\n26: \tName     string    `json:\"name\"`\n27: \tSize     int64     `json:\"size\"`\n28: \tModified time.Time `json:\"modified\"`\n29: \tMode     string    `json:\"mode\"`\n30: \tIsDir    bool      `json:\"is_dir\"`\n31: }\n32: \n33: type ListFilesResponse struct {\n34: \tFiles []FileEntry `json:\"files\"`\n35: }\n36: \n37: func parseFileMode(modeStr string) os.FileMode {\n38: \tif modeStr == \"\" {\n39: \t\treturn DefaultFileMode\n40: \t}\n41: \n42: \tmode, err := strconv.ParseUint(modeStr, 8, 32)\n43: \tif err != nil {\n44: \t\treturn DefaultFileMode\n45: \t}\n46: \n47: \tif mode > MaxFileMode {\n48: \t\treturn DefaultFileMode\n49: \t}\n50: \n51: \treturn os.FileMode(mode)\n52: }\n53: \n54: func (s *Server) sanitizePath(path string) (string, error) {\n55: \tif s.workspaceDir == \"\" {\n56: \t\treturn \"\", NewError(ErrWorkspaceNotInit, ErrMsgWorkspaceNotInit, \"\", nil)\n57: \t}\n58: \n59: \tresolvedWorkspace, err := filepath.EvalSymlinks(s.workspaceDir)\n60: \tif err != nil {\n61: \t\tresolvedWorkspace = filepath.Clean(s.workspaceDir)\n62: \t}\n63: \tresolvedWorkspace = filepath.Clean(resolvedWorkspace)\n64: \n65: \tcleanPath := filepath.Clean(path)\n66: \n67: \tif filepath.IsAbs(cleanPath) {\n68: \t\tcleanPath = strings.TrimPrefix(cleanPath, string(os.PathSeparator))\n69: \t}\n70: \n71: \tfullPath := filepath.Clean(filepath.Join(resolvedWorkspace, cleanPath))\n72: \n73: \trelPath, err := filepath.Rel(resolvedWorkspace, fullPath)\n74: \tif err != nil {\n75: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, err.Error(), err)\n76: \t}\n77: \n78: \tif strings.HasPrefix(relPath, \"..\"+string(os.PathSeparator)) || relPath == \"..\" {\n79: \t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"\", nil)\n80: \t}\n81: \n82: \tresolvedPath, err := filepath.EvalSymlinks(fullPath)\n83: \tif err == nil {\n84: \t\tresolvedRelPath, err := filepath.Rel(resolvedWorkspace, resolvedPath)\n85: \t\tif err != nil || strings.HasPrefix(resolvedRelPath, \"..\"+string(os.PathSeparator)) {\n86: \t\t\treturn \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"\", nil)\n87: \t\t}\n88: \t\treturn resolvedPath, nil\n89: \t}\n90: \n91: \treturn fullPath, nil\n92: }\n93: \n94: func (s *Server) getFileInfo(path string) (FileInfo, error) {\n95: \tinfo, err := os.Stat(path)\n96: \tif err != nil {\n97: \t\tif os.IsNotExist(err) {\n98: \t\t\treturn FileInfo{}, NewError(ErrFileNotFound, ErrMsgFileNotFound, \"\", err)\n99: \t\t}\n100: \t\treturn FileInfo{}, NewError(ErrServerInternal, \"failed to get file info\", err.Error(), err)\n101: \t}\n102: \n103: \treturn FileInfo{\n104: \t\tPath:     path,\n105: \t\tSize:     info.Size(),\n106: \t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n107: \t\tModified: info.ModTime(),\n108: \t}, nil\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n)\n\ntype FileInfo struct {\n\tPath     string    `json:\"path\"`\n\tSize     int64     `json:\"size\"`\n\tMode     string    `json:\"mode\"`\n\tModified time.Time `json:\"modified\"`\n}\n\ntype UploadFileRequest struct {\n\tPath    string `json:\"path\" binding:\"required\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/files.go","time":{"start":1775859341886,"end":1775859341903}}}}
{"type":"tool_use","timestamp":1775859341906,"sessionID":"ses_2868919c7ffebiv27BUPS9ii6Y","part":{"id":"prt_d797717a5001l4F7L7a1E23E6v","messageID":"msg_d797704dd001otmhTP7Vgs5RAt","sessionID":"ses_2868919c7ffebiv27BUPS9ii6Y","type":"tool","tool":"read","callID":"toolu_tool-3291e380e7374751bedd9ef0208a8d9f","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"os\"\n8: \t\"path/filepath\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"k8s.io/klog/v2\"\n13: )\n14: \n15: type Server struct {\n16: \tengine       *gin.Engine\n17: \tconfig       Config\n18: \tauthManager  *AuthManager\n19: \tstartTime    time.Time\n20: \tworkspaceDir string\n21: \thttpServer   *http.Server\n22: }\n23: \n24: func NewServer(config Config) (*Server, error) {\n25: \tworkspace := config.Workspace\n26: \tif workspace == \"\" {\n27: \t\tcwd, err := os.Getwd()\n28: \t\tif err != nil {\n29: \t\t\treturn nil, NewError(ErrServerInternal, \"failed to get current working directory\", err.Error(), err)\n30: \t\t}\n31: \t\tworkspace = cwd\n32: \t}\n33: \n34: \tabsWorkspace, err := filepath.Abs(workspace)\n35: \tif err != nil {\n36: \t\treturn nil, NewError(ErrServerInternal, \"failed to resolve workspace path\", err.Error(), err)\n37: \t}\n38: \n39: \tif err := os.MkdirAll(absWorkspace, DefaultDirMode); err != nil {\n40: \t\treturn nil, NewError(ErrServerInternal, \"failed to create workspace directory\", err.Error(), err)\n41: \t}\n42: \n43: \tauthManager, err := NewAuthManager()\n44: \tif err != nil {\n45: \t\treturn nil, err\n46: \t}\n47: \n48: \tgin.SetMode(gin.ReleaseMode)\n49: \tengine := gin.New()\n50: \n51: \tengine.Use(gin.Recovery())\n52: \tengine.Use(gin.Logger())\n53: \n54: \tserver := &Server{\n55: \t\tengine:       engine,\n56: \t\tconfig:       config,\n57: \t\tauthManager:  authManager,\n58: \t\tstartTime:    time.Now(),\n59: \t\tworkspaceDir: absWorkspace,\n60: \t}\n61: \n62: \tserver.registerRoutes()\n63: \n64: \treturn server, nil\n65: }\n66: \n67: func (s *Server) registerRoutes() {\n68: \tapi := s.engine.Group(\"/api\")\n69: \tapi.Use(AuthMiddleware(s.authManager))\n70: \t{\n71: \t\tapi.POST(\"/execute\", s.ExecuteHandler)\n72: \t\tapi.POST(\"/files\", s.UploadFileHandler)\n73: \t\tapi.GET(\"/files\", s.ListFilesHandler)\n74: \t\tapi.GET(\"/files/*path\", s.DownloadFileHandler)\n75: \t}\n76: \n77: \ts.engine.GET(\"/health\", s.HealthCheckHandler)\n78: }\n79: \n80: func (s *Server) Run() error {\n81: \taddr := fmt.Sprintf(\":%d\", s.config.Port)\n82: \ts.httpServer = &http.Server{\n83: \t\tAddr:              addr,\n84: \t\tHandler:           s.engine,\n85: \t\tReadHeaderTimeout: ReadHeaderTimeout,\n86: \t}\n87: \n88: \tklog.Infof(\"Starting %s server on port %d\", ServiceName, s.config.Port)\n89: \tklog.Infof(\"Workspace directory: %s\", s.workspaceDir)\n90: \tklog.Infof(\"Server version: %s\", Version)\n91: \n92: \tif err := s.httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n93: \t\treturn err\n94: \t}\n95: \n96: \treturn nil\n97: }\n98: \n99: func (s *Server) Shutdown(ctx context.Context) error {\n100: \tklog.Info(\"Shutting down server...\")\n101: \tif err := s.httpServer.Shutdown(ctx); err != nil {\n102: \t\treturn err\n103: \t}\n104: \tklog.Info(\"Server shutdown complete\")\n105: \treturn nil\n106: }\n\n(End of file - total 106 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype Server struct {\n\tengine       *gin.Engine\n\tconfig       Config\n\tauthManager  *AuthManager\n\tstartTime    time.Time\n\tworkspaceDir string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/picod/server.go","time":{"start":1775859341888,"end":1775859341905}}}}
{"type":"tool_use","timestamp":1775859341910,"sessionID":"ses_2868919c7ffebiv27BUPS9ii6Y","part":{"id":"prt_d79771a24001h6rzSgYr8DU8Jv","messageID":"msg_d797704dd001otmhTP7Vgs5RAt","sessionID":"ses_2868919c7ffebiv27BUPS9ii6Y","type":"tool","tool":"read","callID":"toolu_tool-0d55a8a1add4460bbb281509e3a276f4","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-015/design.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-015/design.md</path>\n<type>file</type>\n<content>\n1: # PicoD 命令执行 API Design\n2: \n3: ## AR-015 — PicoD 命令执行 API\n4: \n5: **Module**: `pkg/picod`\n6: **Language**: Go\n7: **Purpose**: Implement a secure HTTP daemon for command execution and file management within a configurable workspace jail, providing JWT-protected APIs for code interpreter sandboxes in the AgentCube platform.\n8: \n9: ## Overview\n10: \n11: PicoD is an HTTP daemon that runs commands inside a configurable workspace jail, manages workspace files, and exposes a health endpoint with JWT (RSA)–protected APIs. It serves as the core execution engine for code interpreter sandboxes, enabling secure code execution, file operations (upload, list, download), and health monitoring with proper authentication.\n12: \n13: ### Key Requirements\n14: \n15: - HTTP server with configurable port and workspace directory\n16: - JWT (RSA) authentication for all API endpoints except health check\n17: - Command execution API with timeout support\n18: - File management APIs (upload, list, download)\n19: - Path security to enforce workspace jail\n20: - Support for multipart and JSON Base64 file uploads\n21: - Comprehensive error handling and logging\n22: - Zero-downtime deployment support with graceful shutdown\n23: \n24: ## Architecture\n25: \n26: ### Package Structure\n27: \n28: ```\n29: pkg/picod/\n30: ├── auth.go                # JWT authentication manager and middleware\n31: ├── execute.go             # Command execution handler\n32: ├── files.go               # File upload, list, download handlers\n33: ├── server.go              # Server initialization and configuration\n34: ├── handlers.go            # HTTP handler functions\n35: ├── middleware.go          # Custom middleware\n36: ├── errors.go              # Error types and handling\n37: ├── config.go              # Configuration structs\n38: └── constants.go           # Constants and defaults\n39: \n40: cmd/picod/\n41: ├── main.go                # CLI entry point\n42: └── flags.go               # CLI flag definitions\n43: ```\n44: \n45: ### Component Interactions\n46: \n47: ```\n48: ┌─────────────────────────────────────────────────────────────────┐\n49: │                         PicoD HTTP Server                        │\n50: │                                                                  │\n51: │  ┌──────────────────────────────────────────────────────────┐   │\n52: │  │              Gin HTTP Engine                             │   │\n53: │  │  - Global middleware: Logger, Recovery                   │   │\n54: │  │  - API routes with JWT auth                              │   │\n55: │  │  - Health endpoint (no auth)                             │   │\n56: │  └──────────────────────────────────────────────────────────┘   │\n57: │                                                                  │\n58: │  ┌──────────────────────────────────────────────────────────┐   │\n59: │  │              Auth Manager                                │   │\n60: │  │  - JWT validation with RSA public key                    │   │\n61: │  │  - AuthMiddleware for /api/* routes                     │   │\n62: │  │  - Request body size limiting                            │   │\n63: │  └──────────────────────────────────────────────────────────┘   │\n64: │                                                                  │\n65: │  ┌──────────────────────────────────────────────────────────┐   │\n66: │  │              Request Handlers                            │   │\n67: │  │  - ExecuteHandler: Command execution                     │   │\n68: │  │  - UploadFileHandler: File upload                        │   │\n69: │  │  - ListFilesHandler: Directory listing                   │   │\n70: │  │  - DownloadFileHandler: File download                    │   │\n71: │  │  - HealthCheckHandler: Health status                     │   │\n72: │  └──────────────────────────────────────────────────────────┘   │\n73: └─────────────────────────────────────────────────────────────────┘\n74:            │                     │                     │\n75:            │                     │                     │\n76:            ▼                     ▼                     ▼\n77:  ┌──────────────────┐  ┌──────────────────┐  ┌──────────────────┐\n78:  │  File System     │  │     OS Exec      │  │     JWT Keys     │\n79:  │  (Workspace Jail)│  │  (Commands)      │  │  (Auth)          │\n80:  │  - Files         │  │  - Contexts      │  │  - RSA Public    │\n81:  │  - Directories   │  │  - Timeouts      │  │  - Validation    │\n82:  └──────────────────┘  └──────────────────┘  └──────────────────┘\n83: ```\n84: \n85: ### Request Flow\n86: \n87: ```\n88: HTTP Request\n89:     ↓\n90: [Global Middleware] Logger, Recovery\n91:     ↓\n92: [Route Matching] Check endpoint\n93:     ↓\n94: [Auth Middleware?] If /api/* path:\n95:     ↓ Yes                      ↓ No (/health)\n96: [JWT Validation]              [Process Request]\n97:     - Parse Authorization        - Health check\n98:     - Verify RSA signature\n99:     - Check expiration\n100:     ↓\n101: [Body Size Limit] MaxBytesReader (32 MiB)\n102:     ↓\n103: [Handler Processing]\n104:     - Path sanitization\n105:     - Request validation\n106:     - Business logic\n107:     - Error handling\n108:     ↓\n109: [Response]\n110:     - JSON response\n111:     - Proper headers\n112:     - Error format\n113: ```\n114: \n115: ### Command Execution Flow\n116: \n117: ```\n118: POST /api/execute\n119:     ↓\n120: [JWT Validation] Verify token\n121:     ↓\n122: [Request Binding] Parse ExecuteRequest JSON\n123:     ↓\n124: [Validation] Check command non-empty\n125:     ↓\n126: [Timeout Parsing] Parse timeout or use default (60s)\n127:     ↓\n128: [Working Dir] Sanitize and resolve path\n129:     ↓\n130: [Environment] Merge process and request env vars\n131:     ↓\n132: [Command Setup] Create exec.CommandContext\n133:     ↓\n134: [Execution] Run command with context\n135:     ↓\n136: [Output Capture] Capture stdout and stderr\n137:     ↓\n138: [Result] Determine exit code\n139:     - Timeout: 124\n140:     - Success: 0\n141:     - Error: actual exit code\n142:     ↓\n143: [Response] Return ExecuteResponse JSON\n144: ```\n145: \n146: ## Data Structures\n147: \n148: ### Server Configuration\n149: \n150: **File**: `pkg/picod/server.go`\n151: \n152: ```go\n153: // Config represents the server configuration\n154: type Config struct {\n155:     Port      int    `json:\"port\"`\n156:     Workspace string `json:\"workspace\"`\n157: }\n158: \n159: // Server represents the PicoD HTTP server\n160: type Server struct {\n161:     engine      *gin.Engine\n162:     config      Config\n163:     authManager *AuthManager\n164:     startTime   time.Time\n165:     workspaceDir string\n166: }\n167: ```\n168: \n169: ### Authentication\n170: \n171: **File**: `pkg/picod/auth.go`\n172: \n173: ```go\n174: // AuthManager manages JWT authentication\n175: type AuthManager struct {\n176:     publicKey *rsa.PublicKey\n177:     mutex     sync.RWMutex\n178: }\n179: \n180: // AuthClaims represents JWT claims\n181: type AuthClaims struct {\n182:     jwt.RegisteredClaims\n183:     // Additional custom claims can be added here\n184: }\n185: ```\n186: \n187: ### Command Execution\n188: \n189: **File**: `pkg/picod/execute.go`\n190: \n191: ```go\n192: // ExecuteRequest represents a command execution request\n193: type ExecuteRequest struct {\n194:     Command    []string          `json:\"command\" binding:\"required\"`\n195:     Timeout    string            `json:\"timeout\"`\n196:     WorkingDir string            `json:\"working_dir\"`\n197:     Env        map[string]string `json:\"env\"`\n198: }\n199: \n200: // ExecuteResponse represents the command execution result\n201: type ExecuteResponse struct {\n202:     Stdout    string    `json:\"stdout\"`\n203:     Stderr    string    `json:\"stderr\"`\n204:     ExitCode  int       `json:\"exit_code\"`\n205:     Duration  float64   `json:\"duration\"`\n206:     StartTime time.Time `json:\"start_time\"`\n207:     EndTime   time.Time `json:\"end_time\"`\n208: }\n209: \n210: // ExecutionResult represents the internal execution result\n211: type ExecutionResult struct {\n212:     Stdout    []byte\n213:     Stderr    []byte\n214:     ExitCode  int\n215:     StartTime time.Time\n216:     EndTime   time.Time\n217:     Duration  time.Duration\n218: }\n219: ```\n220: \n221: ### File Operations\n222: \n223: **File**: `pkg/picod/files.go`\n224: \n225: ```go\n226: // FileInfo represents file information\n227: type FileInfo struct {\n228:     Path     string    `json:\"path\"`\n229:     Size     int64     `json:\"size\"`\n230:     Mode     string    `json:\"mode\"`\n231:     Modified time.Time `json:\"modified\"`\n232: }\n233: \n234: // UploadFileRequest represents a file upload request (JSON format)\n235: type UploadFileRequest struct {\n236:     Path    string `json:\"path\" binding:\"required\"`\n237:     Content string `json:\"content\" binding:\"required\"`\n238:     Mode    string `json:\"mode\"`\n239: }\n240: \n241: // FileEntry represents a file or directory entry\n242: type FileEntry struct {\n243:     Name     string    `json:\"name\"`\n244:     Size     int64     `json:\"size\"`\n245:     Modified time.Time `json:\"modified\"`\n246:     Mode     string    `json:\"mode\"`\n247:     IsDir    bool      `json:\"is_dir\"`\n248: }\n249: \n250: // ListFilesResponse represents a directory listing response\n251: type ListFilesResponse struct {\n252:     Files []FileEntry `json:\"files\"`\n253: }\n254: ```\n255: \n256: ### Error Responses\n257: \n258: **File**: `pkg/picod/errors.go`\n259: \n260: ```go\n261: // ErrorResponse represents a standard error response\n262: type ErrorResponse struct {\n263:     Error  string `json:\"error\"`\n264:     Code   int    `json:\"code\"`\n265:     Detail string `json:\"detail,omitempty\"`\n266: }\n267: \n268: // Error codes\n269: const (\n270:     ErrorCodeBadRequest    = \"BadRequest\"\n271:     ErrorCodeUnauthorized  = \"Unauthorized\"\n272:     ErrorCodeNotFound      = \"NotFound\"\n273:     ErrorCodeInternalError = \"InternalError\"\n274: )\n275: \n276: // PicoDError represents a PicoD-specific error\n277: type PicoDError struct {\n278:     Code    string\n279:     Message string\n280:     Detail  string\n281:     Err     error\n282: }\n283: \n284: // Error implements the error interface\n285: func (e *PicoDError) Error() string {\n286:     if e.Err != nil {\n287:         return fmt.Sprintf(\"%s: %s (caused by: %v)\", e.Code, e.Message, e.Err)\n288:     }\n289:     return fmt.Sprintf(\"%s: %s\", e.Code, e.Message)\n290: }\n291: \n292: // Unwrap returns the underlying error\n293: func (e *PicoDError) Unwrap() error {\n294:     return e.Err\n295: }\n296: ```\n297: \n298: ## API Contracts\n299: \n300: ### Command Execution API\n301: \n302: **Endpoint**: `POST /api/execute`\n303: \n304: **Headers**:\n305: ```\n306: Authorization: Bearer <JWT_TOKEN>\n307: Content-Type: application/json\n308: ```\n309: \n310: **Request Body**:\n311: ```json\n312: {\n313:   \"command\": [\"python\", \"script.py\"],\n314:   \"timeout\": \"30s\",\n315:   \"working_dir\": \"workspace\",\n316:   \"env\": {\n317:     \"VAR1\": \"value1\"\n318:   }\n319: }\n320: ```\n321: \n322: **Response (Success - HTTP 200)**:\n323: ```json\n324: {\n325:   \"stdout\": \"command output\",\n326:   \"stderr\": \"error output\",\n327:   \"exit_code\": 0,\n328:   \"duration\": 1.234,\n329:   \"start_time\": \"2024-01-01T00:00:00Z\",\n330:   \"end_time\": \"2024-01-01T00:00:01Z\"\n331: }\n332: ```\n333: \n334: **Response (Error - HTTP 400)**:\n335: ```json\n336: {\n337:   \"error\": \"command cannot be empty\",\n338:   \"code\": 400\n339: }\n340: ```\n341: \n342: **Response (Authentication Error - HTTP 401)**:\n343: ```json\n344: {\n345:   \"error\": \"Invalid token\",\n346:   \"code\": 401,\n347:   \"detail\": \"token expired\"\n348: }\n349: ```\n350: \n351: ### File Upload API\n352: \n353: **Endpoint**: `POST /api/files`\n354: \n355: **Headers** (Multipart):\n356: ```\n357: Authorization: Bearer <JWT_TOKEN>\n358: Content-Type: multipart/form-data; boundary=----WebKitFormBoundary\n359: ```\n360: \n361: **Request Body** (Multipart):\n362: ```\n363: ------WebKitFormBoundary\n364: Content-Disposition: form-data; name=\"path\"\n365: workspace/file.txt\n366: ------WebKitFormBoundary\n367: Content-Disposition: form-data; name=\"file\"; filename=\"file.txt\"\n368: Content-Type: text/plain\n369: \n370: File content here\n371: ------WebKitFormBoundary--\n372: ```\n373: \n374: **Request Body** (JSON Base64):\n375: ```json\n376: {\n377:   \"path\": \"workspace/file.txt\",\n378:   \"content\": \"SGVsbG8gd29ybGQh\",\n379:   \"mode\": \"0644\"\n380: }\n381: ```\n382: \n383: **Response (Success - HTTP 200)**:\n384: ```json\n385: {\n386:   \"path\": \"workspace/file.txt\",\n387:   \"size\": 1024,\n388:   \"mode\": \"0644\",\n389:   \"modified\": \"2024-01-01T00:00:00Z\"\n390: }\n391: ```\n392: \n393: ### File List API\n394: \n395: **Endpoint**: `GET /api/files?path=<directory>`\n396: \n397: **Headers**:\n398: ```\n399: Authorization: Bearer <JWT_TOKEN>\n400: ```\n401: \n402: **Response (Success - HTTP 200)**:\n403: ```json\n404: {\n405:   \"files\": [\n406:     {\n407:       \"name\": \"file.txt\",\n408:       \"size\": 1024,\n409:       \"modified\": \"2024-01-01T00:00:00Z\",\n410:       \"mode\": \"0644\",\n411:       \"is_dir\": false\n412:     }\n413:   ]\n414: }\n415: ```\n416: \n417: **Response (Error - HTTP 404)**:\n418: ```json\n419: {\n420:   \"error\": \"Directory not found\",\n421:   \"code\": 404\n422: }\n423: ```\n424: \n425: ### File Download API\n426: \n427: **Endpoint**: `GET /api/files/<path>`\n428: \n429: **Headers**:\n430: ```\n431: Authorization: Bearer <JWT_TOKEN>\n432: ```\n433: \n434: **Response (Success - HTTP 200)**:\n435: ```\n436: Content-Description: File Transfer\n437: Content-Transfer-Encoding: binary\n438: Content-Disposition: attachment; filename=\"file.txt\"\n439: Content-Type: text/plain\n440: \n441: File content here\n442: ```\n443: \n444: **Response (Error - HTTP 404)**:\n445: ```json\n446: {\n447:   \"error\": \"File not found\",\n448:   \"code\": 404\n449: }\n450: ```\n451: \n452: ### Health Check API\n453: \n454: **Endpoint**: `GET /health`\n455: \n456: **Headers**: None (no authentication required)\n457: \n458: **Response (Success - HTTP 200)**:\n459: ```json\n460: {\n461:   \"status\": \"ok\",\n462:   \"service\": \"PicoD\",\n463:   \"version\": \"0.0.1\",\n464:   \"uptime\": \"1h30m45s\"\n465: }\n466: ```\n467: \n468: ## Error Handling\n469: \n470: ### Error Types\n471: \n472: **File**: `pkg/picod/errors.go`\n473: \n474: ```go\n475: // Error types\n476: const (\n477:     // Validation errors\n478:     ErrInvalidCommand       = \"InvalidCommand\"\n479:     ErrEmptyCommand         = \"EmptyCommand\"\n480:     ErrInvalidTimeout       = \"InvalidTimeout\"\n481:     ErrInvalidWorkingDir    = \"InvalidWorkingDir\"\n482:     ErrInvalidBase64        = \"InvalidBase64\"\n483:     ErrMissingPath          = \"MissingPath\"\n484:     \n485:     // File system errors\n486:     ErrFileNotFound         = \"FileNotFound\"\n487:     ErrDirectoryNotFound    = \"DirectoryNotFound\"\n488:     ErrPathIsDirectory      = \"PathIsDirectory\"\n489:     ErrAccessDenied         = \"AccessDenied\"\n490:     \n491:     // Authentication errors\n492:     ErrMissingAuthHeader    = \"MissingAuthHeader\"\n493:     ErrInvalidAuthFormat    = \"InvalidAuthFormat\"\n494:     ErrInvalidToken         = \"InvalidToken\"\n495:     ErrInvalidSignature     = \"InvalidSignature\"\n496:     ErrTokenExpired         = \"TokenExpired\"\n497:     ErrInvalidPublicKey     = \"InvalidPublicKey\"\n498:     \n499:     // Server errors\n500:     ErrServerInternal       = \"ServerInternal\"\n501:     ErrWorkspaceNotInit     = \"WorkspaceNotInit\"\n502: )\n503: \n504: // HTTP status code mapping\n505: var statusCodeMap = map[string]int{\n506:     ErrInvalidCommand:      http.StatusBadRequest,\n507:     ErrEmptyCommand:        http.StatusBadRequest,\n508:     ErrInvalidTimeout:      http.StatusBadRequest,\n509:     ErrInvalidWorkingDir:   http.StatusBadRequest,\n510:     ErrInvalidBase64:       http.StatusBadRequest,\n511:     ErrMissingPath:         http.StatusBadRequest,\n512:     ErrFileNotFound:        http.StatusNotFound,\n513:     ErrDirectoryNotFound:   http.StatusNotFound,\n514:     ErrPathIsDirectory:     http.StatusBadRequest,\n515:     ErrAccessDenied:        http.StatusBadRequest,\n516:     ErrMissingAuthHeader:   http.StatusUnauthorized,\n517:     ErrInvalidAuthFormat:   http.StatusUnauthorized,\n518:     ErrInvalidToken:        http.StatusUnauthorized,\n519:     ErrInvalidSignature:    http.StatusUnauthorized,\n520:     ErrTokenExpired:        http.StatusUnauthorized,\n521:     ErrInvalidPublicKey:    http.StatusInternalServerError,\n522:     ErrServerInternal:      http.StatusInternalServerError,\n523:     ErrWorkspaceNotInit:    http.StatusInternalServerError,\n524: }\n525: ```\n526: \n527: ### Error Handling Strategy\n528: \n529: ```go\n530: // HandleError handles errors and returns appropriate HTTP responses\n531: func HandleError(c *gin.Context, err error) {\n532:     status := http.StatusInternalServerError\n533:     code := ErrorCodeInternalError\n534:     message := err.Error()\n535:     detail := \"\"\n536:     \n537:     if picoDErr, ok := err.(*PicoDError); ok {\n538:         code = picoDErr.Code\n539:         message = picoDErr.Message\n540:         detail = picoDErr.Detail\n541:         if mappedStatus, exists := statusCodeMap[code]; exists {\n542:             status = mappedStatus\n543:         }\n544:     }\n545:     \n546:     c.JSON(status, ErrorResponse{\n547:         Error:  message,\n548:         Code:   status,\n549:         Detail: detail,\n550:     })\n551: }\n552: \n553: // NewError creates a new PicoD error\n554: func NewError(code, message, detail string, err error) *PicoDError {\n555:     return &PicoDError{\n556:         Code:    code,\n557:         Message: message,\n558:         Detail:  detail,\n559:         Err:     err,\n560:     }\n561: }\n562: ```\n563: \n564: ## Constants\n565: \n566: **File**: `pkg/picod/constants.go`\n567: \n568: ```go\n569: // Environment variables\n570: const (\n571:     PublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"\n572: )\n573: \n574: // Exit codes\n575: const (\n576:     TimeoutExitCode = 124\n577: )\n578: \n579: // Size limits\n580: const (\n581:     MaxBodySize    = 32 << 20 // 32 MiB\n582: )\n583: \n584: // Default values\n585: const (\n586:     DefaultPort         = 8080\n587:     DefaultTimeout      = 60 * time.Second\n588:     DefaultFileMode     = 0644\n589:     DefaultDirMode      = 0755\n590:     MaxFileMode         = 0777\n591:     ReadHeaderTimeout   = 10 * time.Second\n592: )\n593: \n594: // Version\n595: const (\n596:     ServiceName = \"PicoD\"\n597:     Version     = \"0.0.1\"\n598: )\n599: \n600: // HTTP headers\n601: const (\n602:     HeaderAuthorization      = \"Authorization\"\n603:     HeaderContentDescription = \"Content-Description\"\n604:     HeaderContentDisposition = \"Content-Disposition\"\n605:     HeaderContentEncoding    = \"Content-Transfer-Encoding\"\n606:     HeaderContentType        = \"Content-Type\"\n607: )\n608: \n609: // MIME types\n610: const (\n611:     MIMEOctetStream = \"application/octet-stream\"\n612:     MIMEMultipart   = \"multipart/form-data\"\n613: )\n614: \n615: // Error messages\n616: const (\n617:     ErrMsgMissingAuthHeader    = \"Missing Authorization header\"\n618:     ErrMsgInvalidAuthFormat    = \"Use Bearer <token> format\"\n619:     ErrMsgInvalidToken         = \"Invalid token\"\n620:     ErrMsgEmptyCommand         = \"command cannot be empty\"\n621:     ErrMsgMissingPathParam     = \"Missing 'path' query parameter\"\n622:     ErrMsgDirectoryNotFound    = \"Directory not found\"\n623:     ErrMsgFileNotFound         = \"File not found\"\n624:     ErrMsgPathIsDirectory      = \"Path is a directory, not a file\"\n625:     ErrMsgAccessDenied         = \"Access denied: path escapes workspace\"\n626:     ErrMsgInvalidWorkingDir    = \"Invalid working directory: \"\n627:     ErrMsgWorkspaceNotInit     = \"workspace directory not initialized\"\n628:     ErrMsgInvalidBase64        = \"invalid base64 encoding\"\n629: )\n630: ```\n631: \n632: ## Path Security\n633: \n634: **File**: `pkg/picod/files.go`\n635: \n636: ```go\n637: // sanitizePath sanitizes a path to ensure it stays within the workspace\n638: func (s *Server) sanitizePath(path string) (string, error) {\n639:     if s.workspaceDir == \"\" {\n640:         return \"\", NewError(ErrWorkspaceNotInit, ErrMsgWorkspaceNotInit, \"\", nil)\n641:     }\n642:     \n643:     // Resolve workspace directory (follow symlinks)\n644:     resolvedWorkspace, err := filepath.EvalSymlinks(s.workspaceDir)\n645:     if err != nil {\n646:         resolvedWorkspace = filepath.Clean(s.workspaceDir)\n647:     }\n648:     resolvedWorkspace = filepath.Clean(resolvedWorkspace)\n649:     \n650:     // Clean the input path\n651:     cleanPath := filepath.Clean(path)\n652:     \n653:     // If absolute path, strip leading separator\n654:     if filepath.IsAbs(cleanPath) {\n655:         cleanPath = strings.TrimPrefix(cleanPath, string(os.PathSeparator))\n656:     }\n657:     \n658:     // Join with workspace and clean\n659:     fullPath := filepath.Clean(filepath.Join(resolvedWorkspace, cleanPath))\n660:     \n661:     // Check if path is relative to workspace\n662:     relPath, err := filepath.Rel(resolvedWorkspace, fullPath)\n663:     if err != nil {\n664:         return \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, err.Error(), err)\n665:     }\n666:     \n667:     // Check for path traversal attempts\n668:     if strings.HasPrefix(relPath, \"..\"+string(os.PathSeparator)) || relPath == \"..\" {\n669:         return \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"\", nil)\n670:     }\n671:     \n672:     // Resolve symlinks in the target path\n673:     resolvedPath, err := filepath.EvalSymlinks(fullPath)\n674:     if err == nil {\n675:         // Re-check if resolved path is still within workspace\n676:         resolvedRelPath, err := filepath.Rel(resolvedWorkspace, resolvedPath)\n677:         if err != nil || strings.HasPrefix(resolvedRelPath, \"..\"+string(os.PathSeparator)) {\n678:             return \"\", NewError(ErrAccessDenied, ErrMsgAccessDenied, \"\", nil)\n679:         }\n680:         return resolvedPath, nil\n681:     }\n682:     \n683:     // Path doesn't exist yet, return the validated path\n684:     return fullPath, nil\n685: }\n686: \n687: // parseFileMode parses a file mode string to os.FileMode\n688: func parseFileMode(modeStr string) os.FileMode {\n689:     if modeStr == \"\" {\n690:         return DefaultFileMode\n691:     }\n692:     \n693:     mode, err := strconv.ParseUint(modeStr, 8, 32)\n694:     if err != nil {\n695:         return DefaultFileMode\n696:     }\n697:     \n698:     if mode > MaxFileMode {\n699:         return DefaultFileMode\n700:     }\n701:     \n702:     return os.FileMode(mode)\n703: }\n704: ```\n705: \n706: ## Testing Strategy\n707: \n708: ### Unit Tests\n709: \n710: **File**: `pkg/picod/server_test.go`\n711: \n712: ```go\n713: func TestServerInitialization(t *testing.T) {\n714:     tests := []struct {\n715:         name        string\n716:         config      Config\n717:         wantErr     bool\n718:         setupEnv    func()\n719:         cleanupEnv  func()\n720:     }{\n721:         {\n722:             name: \"default configuration\",\n723:             config: Config{\n724:                 Port: DefaultPort,\n725:                 Workspace: \"\",\n726:             },\n727:             wantErr: false,\n728:             setupEnv: func() {\n729:                 os.Setenv(PublicKeyEnvVar, testPublicKey)\n730:             },\n731:             cleanupEnv: func() {\n732:                 os.Unsetenv(PublicKeyEnvVar)\n733:             },\n734:         },\n735:         {\n736:             name: \"custom configuration\",\n737:             config: Config{\n738:                 Port: 9090,\n739:                 Workspace: \"/tmp/test-workspace\",\n740:             },\n741:             wantErr: false,\n742:             setupEnv: func() {\n743:                 os.Setenv(PublicKeyEnvVar, testPublicKey)\n744:             },\n745:             cleanupEnv: func() {\n746:                 os.Unsetenv(PublicKeyEnvVar)\n747:             },\n748:         },\n749:     }\n750:     \n751:     for _, tt := range tests {\n752:         t.Run(tt.name, func(t *testing.T) {\n753:             tt.setupEnv()\n754:             defer tt.cleanupEnv()\n755:             \n756:             server, err := NewServer(tt.config)\n757:             if (err != nil) != tt.wantErr {\n758:                 t.Errorf(\"NewServer() error = %v, wantErr %v\", err, tt.wantErr)\n759:             }\n760:             \n761:             if !tt.wantErr {\n762:                 if server == nil {\n763:                     t.Fatal(\"Expected non-nil server\")\n764:                 }\n765:                 if server.config.Port != tt.config.Port {\n766:                     t.Errorf(\"Expected port %d, got %d\", tt.config.Port, server.config.Port)\n767:                 }\n768:             }\n769:         })\n770:     }\n771: }\n772: ```\n773: \n774: **File**: `pkg/picod/execute_test.go`\n775: \n776: ```go\n777: func TestExecuteHandler(t *testing.T) {\n778:     // Setup test server\n779:     server := setupTestServer(t)\n780:     defer cleanupTestServer(t, server)\n781:     \n782:     // Create test JWT token\n783:     token := createTestToken(t)\n784:     \n785:     tests := []struct {\n786:         name           string\n787:         request        ExecuteRequest\n788:         wantStatusCode int\n789:         wantExitCode   int\n790:     }{\n791:         {\n792:             name: \"successful execution\",\n793:             request: ExecuteRequest{\n794:                 Command: []string{\"echo\", \"hello\"},\n795:                 Timeout: \"\",\n796:             },\n797:             wantStatusCode: http.StatusOK,\n798:             wantExitCode:   0,\n799:         },\n800:         {\n801:             name: \"empty command\",\n802:             request: ExecuteRequest{\n803:                 Command: []string{},\n804:                 Timeout: \"\",\n805:             },\n806:             wantStatusCode: http.StatusBadRequest,\n807:             wantExitCode:   -1,\n808:         },\n809:         {\n810:             name: \"invalid timeout\",\n811:             request: ExecuteRequest{\n812:                 Command: []string{\"echo\", \"hello\"},\n813:                 Timeout: \"invalid\",\n814:             },\n815:             wantStatusCode: http.StatusBadRequest,\n816:             wantExitCode:   -1,\n817:         },\n818:     }\n819:     \n820:     for _, tt := range tests {\n821:         t.Run(tt.name, func(t *testing.T) {\n822:             body, _ := json.Marshal(tt.request)\n823:             req := httptest.NewRequest(\"POST\", \"/api/execute\", bytes.NewBuffer(body))\n824:             req.Header.Set(\"Authorization\", \"Bearer \"+token)\n825:             req.Header.Set(\"Content-Type\", \"application/json\")\n826:             \n827:             w := httptest.NewRecorder()\n828:             server.engine.ServeHTTP(w, req)\n829:             \n830:             if w.Code != tt.wantStatusCode {\n831:                 t.Errorf(\"Expected status %d, got %d\", tt.wantStatusCode, w.Code)\n832:             }\n833:             \n834:             if tt.wantStatusCode == http.StatusOK {\n835:                 var response ExecuteResponse\n836:                 json.Unmarshal(w.Body.Bytes(), &response)\n837:                 if response.ExitCode != tt.wantExitCode {\n838:                     t.Errorf(\"Expected exit code %d, got %d\", tt.wantExitCode, response.ExitCode)\n839:                 }\n840:             }\n841:         })\n842:     }\n843: }\n844: ```\n845: \n846: **File**: `pkg/picod/files_test.go`\n847: \n848: ```go\n849: func TestFileOperations(t *testing.T) {\n850:     // Setup test server and workspace\n851:     workspace := t.TempDir()\n852:     server := setupTestServerWithWorkspace(t, workspace)\n853:     defer cleanupTestServer(t, server)\n854:     \n855:     token := createTestToken(t)\n856:     \n857:     t.Run(\"upload file\", func(t *testing.T) {\n858:         content := base64.StdEncoding.EncodeToString([]byte(\"test content\"))\n859:         request := UploadFileRequest{\n860:             Path:    \"test.txt\",\n861:             Content: content,\n862:             Mode:    \"0644\",\n863:         }\n864:         \n865:         body, _ := json.Marshal(request)\n866:         req := httptest.NewRequest(\"POST\", \"/api/files\", bytes.NewBuffer(body))\n867:         req.Header.Set(\"Authorization\", \"Bearer \"+token)\n868:         req.Header.Set(\"Content-Type\", \"application/json\")\n869:         \n870:         w := httptest.NewRecorder()\n871:         server.engine.ServeHTTP(w, req)\n872:         \n873:         if w.Code != http.StatusOK {\n874:             t.Errorf(\"Expected status 200, got %d\", w.Code)\n875:         }\n876:     })\n877:     \n878:     t.Run(\"list files\", func(t *testing.T) {\n879:         req := httptest.NewRequest(\"GET\", \"/api/files?path=.\", nil)\n880:         req.Header.Set(\"Authorization\", \"Bearer \"+token)\n881:         \n882:         w := httptest.NewRecorder()\n883:         server.engine.ServeHTTP(w, req)\n884:         \n885:         if w.Code != http.StatusOK {\n886:             t.Errorf(\"Expected status 200, got %d\", w.Code)\n887:         }\n888:         \n889:         var response ListFilesResponse\n890:         json.Unmarshal(w.Body.Bytes(), &response)\n891:         if len(response.Files) == 0 {\n892:             t.Error(\"Expected files in listing\")\n893:         }\n894:     })\n895:     \n896:     t.Run(\"download file\", func(t *testing.T) {\n897:         req := httptest.NewRequest(\"GET\", \"/api/files/test.txt\", nil)\n898:         req.Header.Set(\"Authorization\", \"Bearer \"+token)\n899:         \n900:         w := httptest.NewRecorder()\n901:         server.engine.ServeHTTP(w, req)\n902:         \n903:         if w.Code != http.StatusOK {\n904:             t.Errorf(\"Expected status 200, got %d\", w.Code)\n905:         }\n906:         \n907:         if w.Body.String() != \"test content\" {\n908:             t.Errorf(\"Expected 'test content', got '%s'\", w.Body.String())\n909:         }\n910:     })\n911: }\n912: ```\n913: \n914: **File**: `pkg/picod/auth_test.go`\n915: \n916: ```go\n917: func TestAuthMiddleware(t *testing.T) {\n918:     server := setupTestServer(t)\n919:     defer cleanupTestServer(t, server)\n920:     \n921:     tests := []struct {\n922:         name           string\n923:         setupRequest   func(*http.Request)\n924:         wantStatusCode int\n925:         wantError      string\n926:     }{\n927:         {\n928:             name: \"missing authorization header\",\n929:             setupRequest: func(req *http.Request) {\n930:                 // No authorization header\n931:             },\n932:             wantStatusCode: http.StatusUnauthorized,\n933:             wantError:      ErrMsgMissingAuthHeader,\n934:         },\n935:         {\n936:             name: \"invalid authorization format\",\n937:             setupRequest: func(req *http.Request) {\n938:                 req.Header.Set(\"Authorization\", \"InvalidFormat token\")\n939:             },\n940:             wantStatusCode: http.StatusUnauthorized,\n941:             wantError:      ErrMsgInvalidAuthFormat,\n942:         },\n943:         {\n944:             name: \"valid token\",\n945:             setupRequest: func(req *http.Request) {\n946:                 token := createTestToken(t)\n947:                 req.Header.Set(\"Authorization\", \"Bearer \"+token)\n948:             },\n949:             wantStatusCode: http.StatusOK,\n950:             wantError:      \"\",\n951:         },\n952:     }\n953:     \n954:     for _, tt := range tests {\n955:         t.Run(tt.name, func(t *testing.T) {\n956:             req := httptest.NewRequest(\"POST\", \"/api/execute\", bytes.NewBuffer([]byte(`{\"command\":[\"echo\",\"test\"]}`)))\n957:             tt.setupRequest(req)\n958:             req.Header.Set(\"Content-Type\", \"application/json\")\n959:             \n960:             w := httptest.NewRecorder()\n961:             server.engine.ServeHTTP(w, req)\n962:             \n963:             if w.Code != tt.wantStatusCode {\n964:                 t.Errorf(\"Expected status %d, got %d\", tt.wantStatusCode, w.Code)\n965:             }\n966:         })\n967:     }\n968: }\n969: ```\n970: \n971: ### Integration Tests\n972: \n973: **File**: `pkg/picod/integration_test.go`\n974: \n975: ```go\n976: func TestServerIntegration(t *testing.T) {\n977:     // Create temporary workspace\n978:     workspace := t.TempDir()\n979:     \n980:     // Setup environment\n981:     os.Setenv(PublicKeyEnvVar, testPublicKey)\n982:     defer os.Unsetenv(PublicKeyEnvVar)\n983:     \n984:     // Create server\n985:     config := Config{\n986:         Port:      testPort,\n987:         Workspace: workspace,\n988:     }\n989:     server, err := NewServer(config)\n990:     require.NoError(t, err)\n991:     \n992:     // Start server in goroutine\n993:     go func() {\n994:         if err := server.Run(); err != nil && !errors.Is(err, http.ErrServerClosed) {\n995:             t.Fatalf(\"Server error: %v\", err)\n996:         }\n997:     }()\n998:     \n999:     // Wait for server to be ready\n1000:     time.Sleep(100 * time.Millisecond)\n1001:     \n1002:     // Cleanup\n1003:     defer func() {\n1004:         ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n1005:         defer cancel()\n1006:         server.Shutdown(ctx)\n1007:     }()\n1008:     \n1009:     // Run integration tests\n1010:     t.Run(\"full workflow\", func(t *testing.T) {\n1011:         token := createTestToken(t)\n1012:         \n1013:         // 1. Health check\n1014:         resp := doRequest(t, \"GET\", \"http://localhost:\"+strconv.Itoa(testPort)+\"/health\", nil, \"\")\n1015:         require.Equal(t, http.StatusOK, resp.StatusCode)\n1016:         \n1017:         // 2. Upload file\n1018:         uploadReq := UploadFileRequest{\n1019:             Path:    \"test.py\",\n1020:             Content: base64.StdEncoding.EncodeToString([]byte(\"print('hello')\")),\n1021:             Mode:    \"0644\",\n1022:         }\n1023:         uploadBody, _ := json.Marshal(uploadReq)\n1024:         resp = doRequest(t, \"POST\", \"http://localhost:\"+strconv.Itoa(testPort)+\"/api/files\", uploadBody, token)\n1025:         require.Equal(t, http.StatusOK, resp.StatusCode)\n1026:         \n1027:         // 3. Execute command\n1028:         execReq := ExecuteRequest{\n1029:             Command: []string{\"python\", \"test.py\"},\n1030:             Timeout: \"10s\",\n1031:         }\n1032:         execBody, _ := json.Marshal(execReq)\n1033:         resp = doRequest(t, \"POST\", \"http://localhost:\"+strconv.Itoa(testPort)+\"/api/execute\", execBody, token)\n1034:         require.Equal(t, http.StatusOK, resp.StatusCode)\n1035:         \n1036:         var execResp ExecuteResponse\n1037:         json.NewDecoder(resp.Body).Decode(&execResp)\n1038:         require.Equal(t, 0, execResp.ExitCode)\n1039:         require.Contains(t, execResp.Stdout, \"hello\")\n1040:         \n1041:         // 4. List files\n1042:         resp = doRequest(t, \"GET\", \"http://localhost:\"+strconv.Itoa(testPort)+\"/api/files?path=.\", nil, token)\n1043:         require.Equal(t, http.StatusOK, resp.StatusCode)\n1044:         \n1045:         var listResp ListFilesResponse\n1046:         json.NewDecoder(resp.Body).Decode(&listResp)\n1047:         require.Len(t, listResp.Files, 1)\n1048:         require.Equal(t, \"test.py\", listResp.Files[0].Name)\n1049:         \n1050:         // 5. Download file\n1051:         resp = doRequest(t, \"GET\", \"http://localhost:\"+strconv.Itoa(testPort)+\"/api/files/test.py\", nil, token)\n1052:         require.Equal(t, http.StatusOK, resp.StatusCode)\n1053:         \n1054:         content, _ := io.ReadAll(resp.Body)\n1055:         require.Equal(t, \"print('hello')\", string(content))\n1056:     })\n1057: }\n1058: \n1059: func doRequest(t *testing.T, method, url string, body []byte, token string) *http.Response {\n1060:     var bodyReader io.Reader\n1061:     if body != nil {\n1062:         bodyReader = bytes.NewBuffer(body)\n1063:     }\n1064:     \n1065:     req, err := http.NewRequest(method, url, bodyReader)\n1066:     require.NoError(t, err)\n1067:     \n1068:     if token != \"\" {\n1069:         req.Header.Set(\"Authorization\", \"Bearer \"+token)\n1070:     }\n1071:     \n1072:     if body != nil {\n1073:         req.Header.Set(\"Content-Type\", \"application/json\")\n1074:     }\n1075:     \n1076:     client := &http.Client{Timeout: 10 * time.Second}\n1077:     resp, err := client.Do(req)\n1078:     require.NoError(t, err)\n1079:     \n1080:     return resp\n1081: }\n1082: ```\n1083: \n1084: ## Dependencies\n1085: \n1086: ### Go Module Dependencies\n1087: \n1088: ```go\n1089: require (\n1090:     github.com/gin-gonic/gin v1.10.0\n1091:     github.com/golang-jwt/jwt/v5 v5.2.0\n1092:     k8s.io/klog/v2 v2.130.1\n1093:     github.com/stretchr/testify v1.9.0\n1094: )\n1095: ```\n1096: \n1097: ### External Dependencies\n1098: \n1099: - **Gin Framework**: HTTP routing and middleware\n1100: - **JWT Library**: RSA-based JWT token validation\n1101: - **klog**: Structured logging\n1102: - **Go Standard Library**: exec, os, filepath, time, context, crypto/rsa\n1103: \n1104: ## Security Considerations\n1105: \n1106: ### Authentication\n1107: \n1108: - All API endpoints (except `/health`) require JWT authentication\n1109: - JWT tokens must be signed with RSA private key\n1110: - PicoD validates tokens using the RSA public key from `PICOD_AUTH_PUBLIC_KEY` environment variable\n1111: - Invalid or expired tokens are rejected with HTTP 401\n1112: - Token validation includes expiration check, issued-at check, and 1-minute leeway\n1113: \n1114: ### Authorization\n1115: \n1116: - Path sanitization ensures all file operations stay within workspace jail\n1117: - Symlink resolution and validation prevents escape via symbolic links\n1118: - No special authorization beyond JWT authentication - all authenticated users have full access to workspace\n1119: \n1120: ### Input Validation\n1121: \n1122: - Command execution validates non-empty command array\n1123: - Timeout values are validated using Go's `time.ParseDuration`\n1124: - File paths are sanitized to prevent directory traversal\n1125: - Request body size limited to 32 MiB after JWT validation\n1126: - File modes are validated and clamped to maximum of 0777\n1127: \n1128: ### Error Messages\n1129: \n1130: - Error messages do not expose sensitive information\n1131: - File paths in error messages are relative to workspace\n1132: - Detailed authentication errors are logged but not exposed to clients\n1133: \n1134: ### Logging\n1135: \n1136: - klog used for structured logging\n1137: - Sensitive data (JWT tokens, file contents) are not logged\n1138: - Errors are logged with appropriate severity levels\n1139: \n1140: ## Integration Points\n1141: \n1142: ### With AgentCube Platform\n1143: \n1144: PicoD integrates with AgentCube components:\n1145: \n1146: - **Sandbox Orchestrator**: Includes PicoD container in sandbox pods\n1147: - **Router**: Forwards code execution requests to PicoD instances\n1148: - **WorkloadManager**: Manages PicoD lifecycle and health checks\n1149: - **Session Store**: Stores metadata about PicoD sessions\n1150: \n1151: ### Deployment Integration\n1152: \n1153: ```\n1154: ┌─────────────────────────────────────────────────────────────────┐\n1155: │                    Sandbox Pod                                   │\n1156: │                                                                  │\n1157: │  ┌──────────────────────┐  ┌──────────────────────────────────┐ │\n1158: │  │   Code Interpreter   │  │           PicoD                  │ │\n1159: │  │   (User Container)   │  │   (Sidecar Container)            │ │\n1160: │  │                      │  │                                  │ │\n1161: │  │  - Python/Node.js    │  │  - HTTP Server (:8080)          │ │\n1162: │  │  - User Code         │  │  - JWT Auth                      │ │\n1163: │  │  - Dependencies      │  │  - Command Execution             │ │\n1164: │  │                      │  │  - File Management               │ │\n1165: │  └──────────────────────┘  │                                  │ │\n1166: │           │                └──────────────────────────────────┘ │\n1167: │           │                              │                       │\n1168: │           ▼                              ▼                       │\n1169: │  ┌──────────────────────────────────────────────────────────┐   │\n1170: │  │              Shared Volume (Workspace)                    │   │\n1171: │  │  - User files                                             │   │\n1172: │  │  - Code artifacts                                         │   │\n1173: │  │  - Execution outputs                                      │   │\n1174: │  └──────────────────────────────────────────────────────────┘   │\n1175: │                                                                  │\n1176: └─────────────────────────────────────────────────────────────────┘\n1177: ```\n1178: \n1179: ## Configuration\n1180: \n1181: ### CLI Flags\n1182: \n1183: | Flag      | Type   | Default | Description |\n1184: |-----------|--------|---------|-------------|\n1185: | `-port`   | int    | 8080    | Port for the PicoD server to listen on |\n1186: | `-workspace` | string | \"\"      | Root directory for file operations (default: current working directory) |\n1187: \n1188: ### Environment Variables\n1189: \n1190: | Name                      | Required | Description |\n1191: |---------------------------|----------|-------------|\n1192: | `PICOD_AUTH_PUBLIC_KEY`   | Yes      | PEM-encoded RSA public key for JWT validation |\n1193: \n1194: ### Configuration File (Optional)\n1195: \n1196: PicoD can be configured via a ConfigMap or environment variables:\n1197: \n1198: ```yaml\n1199: # ConfigMap example\n1200: apiVersion: v1\n1201: kind: ConfigMap\n1202: metadata:\n1203:   name: picod-config\n1204: data:\n1205:   PORT: \"8080\"\n1206:   WORKSPACE: \"/workspace\"\n1207:   PICOD_AUTH_PUBLIC_KEY: |\n1208:     -----BEGIN PUBLIC KEY-----\n1209:     MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n1210:     -----END PUBLIC KEY-----\n1211: ```\n1212: \n1213: ## Documentation\n1214: \n1215: ### API Documentation\n1216: \n1217: All API endpoints should be documented using OpenAPI/Swagger:\n1218: \n1219: ```yaml\n1220: openapi: 3.0.0\n1221: info:\n1222:   title: PicoD API\n1223:   version: 0.0.1\n1224:   description: Secure command execution and file management API\n1225: \n1226: paths:\n1227:   /api/execute:\n1228:     post:\n1229:       summary: Execute a command\n1230:       security:\n1231:         - BearerAuth: []\n1232:       requestBody:\n1233:         required: true\n1234:         content:\n1235:           application/json:\n1236:             schema:\n1237:               $ref: '#/components/schemas/ExecuteRequest'\n1238:       responses:\n1239:         '200':\n1240:           description: Command executed successfully\n1241:           content:\n1242:             application/json:\n1243:               schema:\n1244:                 $ref: '#/components/schemas/ExecuteResponse'\n1245: \n1246:   /health:\n1247:     get:\n1248:       summary: Health check\n1249:       responses:\n1250:         '200':\n1251:           description: Service is healthy\n1252:           content:\n1253:             application/json:\n1254:               schema:\n1255:                 type: object\n1256:                 properties:\n1257:                   status:\n1258:                     type: string\n1259:                   service:\n1260:                     type: string\n1261:                   version:\n1262:                     type: string\n1263:                   uptime:\n1264:                     type: string\n1265: \n1266: components:\n1267:   securitySchemes:\n1268:     BearerAuth:\n1269:       type: http\n1270:       scheme: bearer\n1271:       bearerFormat: JWT\n1272: ```\n1273: \n1274: ### Usage Examples\n1275: \n1276: **Starting PicoD**:\n1277: ```bash\n1278: # With default settings\n1279: ./picod\n1280: \n1281: # With custom port and workspace\n1282: ./picod -port 9090 -workspace /data/workspace\n1283: \n1284: # With klog flags\n1285: ./picod -port 8080 -v=2\n1286: ```\n1287: \n1288: **Making API requests**:\n1289: ```bash\n1290: # Health check (no auth)\n1291: curl http://localhost:8080/health\n1292: \n1293: # Execute command (with JWT)\n1294: export TOKEN=\"<your-jwt-token>\"\n1295: curl -X POST http://localhost:8080/api/execute \\\n1296:   -H \"Authorization: Bearer $TOKEN\" \\\n1297:   -H \"Content-Type: application/json\" \\\n1298:   -d '{\"command\":[\"echo\",\"hello world\"]}'\n1299: \n1300: # Upload file (JSON Base64)\n1301: curl -X POST http://localhost:8080/api/files \\\n1302:   -H \"Authorization: Bearer $TOKEN\" \\\n1303:   -H \"Content-Type: application/json\" \\\n1304:   -d '{\"path\":\"test.txt\",\"content\":\"SGVsbG8gd29ybGQ=\"}'\n1305: \n1306: # Upload file (multipart)\n1307: curl -X POST http://localhost:8080/api/files \\\n1308:   -H \"Authorization: Bearer $TOKEN\" \\\n1309:   -F \"path=test.txt\" \\\n1310:   -F \"file=@local.txt\"\n1311: \n1312: # List files\n1313: curl \"http://localhost:8080/api/files?path=.\" \\\n1314:   -H \"Authorization: Bearer $TOKEN\"\n1315: \n1316: # Download file\n1317: curl \"http://localhost:8080/api/files/test.txt\" \\\n1318:   -H \"Authorization: Bearer $TOKEN\" \\\n1319:   -O -J\n1320: ```\n1321: \n1322: ## Success Criteria\n1323: \n1324: - [ ] HTTP server initializes with configurable port and workspace\n1325: - [ ] JWT authentication middleware correctly validates tokens\n1326: - [ ] Command execution API handles timeout and captures output\n1327: - [ ] File upload API supports both multipart and JSON Base64 formats\n1328: - [ ] File listing API returns directory contents\n1329: - [ ] File download API serves files with proper headers\n1330: - [ ] Health check endpoint responds without authentication\n1331: - [ ] Path sanitization prevents workspace escape\n1332: - [ ] Error responses follow consistent format\n1333: - [ ] Graceful shutdown handles existing connections\n1334: - [ ] Unit tests cover all major code paths\n1335: - [ ] Integration tests validate end-to-end workflows\n1336: - [ ] Security measures (JWT, path sanitization) are effective\n1337: - [ ] Logging provides visibility without exposing sensitive data\n1338: - [ ] CLI flags and environment variables work correctly\n\n(End of file - total 1338 lines)\n</content>","metadata":{"preview":"# PicoD 命令执行 API Design\n\n## AR-015 — PicoD 命令执行 API\n\n**Module**: `pkg/picod`\n**Language**: Go\n**Purpose**: Implement a secure HTTP daemon for command execution and file management within a configurable workspace jail, providing JWT-protected APIs for code interpreter sandboxes in the AgentCube platform.\n\n## Overview\n\nPicoD is an HTTP daemon that runs commands inside a configurable workspace jail, manages workspace files, and exposes a health endpoint with JWT (RSA)–protected APIs. It serves as the core execution engine for code interpreter sandboxes, enabling secure code execution, file operations (upload, list, download), and health monitoring with proper authentication.\n\n### Key Requirements\n\n- HTTP server with configurable port and workspace directory\n- JWT (RSA) authentication for all API endpoints except health check\n- Command execution API with timeout support\n- File management APIs (upload, list, download)\n- Path security to enforce workspace jail\n- Support for multipart and JSON Base64 file uploads","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/changes/AR-015/design.md","time":{"start":1775859341890,"end":1775859341907}}}}
