{"type":"tool_use","timestamp":1775866371149,"sessionID":"ses_2861e289bffeEA9L147U2ruOXd","part":{"id":"prt_d79e255f30013r7YcpRzTW60C0","messageID":"msg_d79e246120017V5cVu5yPcdqBo","sessionID":"ses_2861e289bffeEA9L147U2ruOXd","type":"tool","tool":"read","callID":"toolu_tool-5a56224ef5aa45bbadf09dd3358f96d9","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Service for managing agent metadata.\"\"\"\n2: \n3: import logging\n4: import os\n5: from pathlib import Path\n6: from typing import Any, Dict, List, Optional\n7: \n8: import yaml\n9: from pydantic import BaseModel, field_validator, ConfigDict\n10: \n11: \n12: logger = logging.getLogger(__name__)\n13: \n14: \n15: class AgentMetadata(BaseModel):\n16:     \"\"\"Agent metadata model.\"\"\"\n17: \n18:     model_config = ConfigDict(extra=\"allow\", validate_assignment=True)\n19: \n20:     agent_name: str\n21:     description: Optional[str] = None\n22:     language: str = \"python\"\n23:     entrypoint: str\n24:     port: int = 8080\n25:     build_mode: str = \"local\"\n26:     region: Optional[str] = None\n27:     version: Optional[str] = None\n28:     image: Optional[Dict[str, Any]] = None\n29:     auth: Optional[Dict[str, Any]] = None\n30:     requirements_file: Optional[str] = \"requirements.txt\"\n31:     registry_url: Optional[str] = \"\"\n32:     registry_username: Optional[str] = \"\"\n33:     registry_password: Optional[str] = \"\"\n34:     agent_endpoint: Optional[str] = None\n35:     workload_manager_url: Optional[str] = None\n36:     router_url: Optional[str] = None\n37:     readiness_probe_path: Optional[str] = None\n38:     readiness_probe_port: Optional[int] = None\n39:     agent_id: Optional[str] = None\n40:     session_id: Optional[str] = None\n41:     k8s_deployment: Optional[Dict[str, Any]] = None\n42: \n43:     @field_validator(\"language\")\n44:     @classmethod\n45:     def validate_language(cls, v: str) -> str:\n46:         \"\"\"Validate language is supported.\"\"\"\n47:         if v.lower() not in (\"python\", \"java\"):\n48:             raise ValueError(f\"Language must be 'python' or 'java', got '{v}'\")\n49:         return v.lower()\n50: \n51:     @field_validator(\"build_mode\")\n52:     @classmethod\n53:     def validate_build_mode(cls, v: str) -> str:\n54:         \"\"\"Validate build mode is supported.\"\"\"\n55:         if v.lower() not in (\"local\", \"cloud\"):\n56:             raise ValueError(f\"Build mode must be 'local' or 'cloud', got '{v}'\")\n57:         return v.lower()\n58: \n59:     @field_validator(\"port\")\n60:     @classmethod\n61:     def validate_port(cls, v: int) -> int:\n62:         \"\"\"Validate port is in valid range.\"\"\"\n63:         if not 1 <= v <= 65535:\n64:             raise ValueError(f\"Port must be between 1 and 65535, got {v}\")\n65:         return v\n66: \n67: \n68: class MetadataService:\n69:     \"\"\"Service for managing agent metadata files.\"\"\"\n70: \n71:     def __init__(self, verbose: bool = False) -> None:\n72:         \"\"\"Initialize the metadata service.\"\"\"\n73:         self.verbose = verbose\n74:         if verbose:\n75:             logging.basicConfig(level=logging.DEBUG)\n76: \n77:     def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n78:         \"\"\"Load metadata from workspace directory.\"\"\"\n79:         metadata_file = self._find_metadata_file(workspace_path)\n80:         if not metadata_file or not metadata_file.exists():\n81:             raise FileNotFoundError(\n82:                 f\"No metadata file found in {workspace_path}. \"\n83:                 \"Expected one of: agent_metadata.yaml, agent.yaml, metadata.yaml\"\n84:             )\n85: \n86:         logger.debug(f\"Loading metadata from {metadata_file}\")\n87:         with open(metadata_file, \"r\") as f:\n88:             data = yaml.safe_load(f) or {}\n89: \n90:         return AgentMetadata(**data)\n91: \n92:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n93:         \"\"\"Save metadata to workspace directory.\"\"\"\n94:         metadata_file = workspace_path / \"agent_metadata.yaml\"\n95:         logger.debug(f\"Saving metadata to {metadata_file}\")\n96: \n97:         with open(metadata_file, \"w\") as f:\n98:             yaml.dump(\n99:                 metadata.model_dump(exclude_none=True),\n100:                 f,\n101:                 default_flow_style=False,\n102:                 indent=2,\n103:                 sort_keys=False,\n104:             )\n105: \n106:     def update_metadata(self, workspace_path: Path, updates: Dict[str, Any]) -> AgentMetadata:\n107:         \"\"\"Update metadata with new values.\"\"\"\n108:         metadata = self.load_metadata(workspace_path)\n109:         for key, value in updates.items():\n110:             if value is not None:\n111:                 setattr(metadata, key, value)\n112:         self.save_metadata(workspace_path, metadata)\n113:         return metadata\n114: \n115:     def validate_workspace(self, workspace_path: Path) -> bool:\n116:         \"\"\"Validate workspace structure.\"\"\"\n117:         if not workspace_path.exists():\n118:             raise FileNotFoundError(f\"Workspace directory does not exist: {workspace_path}\")\n119: \n120:         if not workspace_path.is_dir():\n121:             raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n122: \n123:         return True\n124: \n125:     def _find_metadata_file(self, workspace_path: Path) -> Optional[Path]:\n126:         \"\"\"Find metadata file in workspace directory.\"\"\"\n127:         for filename in (\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"):\n128:             metadata_file = workspace_path / filename\n129:             if metadata_file.exists():\n130:                 return metadata_file\n131:         return None\n132: \n133:     def _validate_python_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n134:         \"\"\"Validate Python workspace structure.\"\"\"\n135:         py_files = list(workspace_path.glob(\"*.py\"))\n136:         if not py_files:\n137:             raise ValueError(\"No Python files found in workspace\")\n138: \n139:     def _validate_java_workspace(self, workspace_path: Path, metadata: AgentMetadata) -> None:\n140:         \"\"\"Validate Java workspace structure.\"\"\"\n141:         pom_file = workspace_path / \"pom.xml\"\n142:         if not pom_file.exists():\n143:             raise ValueError(\"Java workspace requires pom.xml file\")\n\n(End of file - total 143 lines)\n</content>","metadata":{"preview":"\"\"\"Service for managing agent metadata.\"\"\"\n\nimport logging\nimport os\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\nimport yaml\nfrom pydantic import BaseModel, field_validator, ConfigDict\n\n\nlogger = logging.getLogger(__name__)\n\n\nclass AgentMetadata(BaseModel):\n    \"\"\"Agent metadata model.\"\"\"\n\n    model_config = ConfigDict(extra=\"allow\", validate_assignment=True)\n\n    agent_name: str","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775866371134,"end":1775866371147}}}}
