n738: 4. **Array minimum**: `targetPort` must have at least one element\n739: \n740: ### Client-Go Error Handling\n741: \n742: ```go\n743: // Common error patterns\n744: err := client.AgentRuntimes(namespace).Create(ctx, &agentRuntime, opts)\n745: if errors.IsAlreadyExists(err) {\n746:     // Handle conflict\n747: } else if errors.IsNotFound(err) {\n748:     // Handle not found\n749: } else if errors.IsInvalid(err) {\n750:     // Handle validation error\n751: } else if errors.IsForbidden(err) {\n752:     // Handle RBAC error\n753: } else if err != nil {\n754:     // Handle other errors\n755: }\n756: ```\n757: \n758: ### Informer Error Handling\n759: \n760: ```go\n761: informer.AddEventHandler(cache.ResourceEventHandlerFuncs{\n762:     AddFunc: func(obj interface{}) {\n763:         if runtimeObj, ok := obj.(metav1.Object); ok {\n764:             klog.Infof(\"AgentRuntime %s added\", runtimeObj.GetName())\n765:         }\n766:     },\n767:     UpdateFunc: func(oldObj, newObj interface{}) {\n768:         oldRuntime := oldObj.(*v1alpha1.AgentRuntime)\n769:         newRuntime := newObj.(*v1alpha1.AgentRuntime)\n770:         if oldRuntime.Generation != newRuntime.Generation {\n771:             klog.Infof(\"AgentRuntime %s generation changed\", newRuntime.Name)\n772:         }\n773:     },\n774:     DeleteFunc: func(obj interface{}) {\n775:         if runtimeObj, ok := obj.(metav1.Object); ok {\n776:             klog.Infof(\"AgentRuntime %s deleted\", runtimeObj.GetName())\n777:         }\n778:     },\n779: })\n780: ```\n781: \n782: ## Testing Strategy\n783: \n784: ### Unit Tests\n785: \n786: **File**: `pkg/apis/runtime/v1alpha1/agentruntime_types_test.go`\n787: \n788: ```go\n789: package v1alpha1_test\n790: \n791: import (\n792:     . \"github.com/onsi/ginkgo/v2\"\n793:     . \"github.com/onsi/gomega\"\n794:     metav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n795:     \"github.com/volcano-sh/agentcube/pkg/apis/runtime/v1alpha1\"\n796: )\n797: \n798: var _ = Describe(\"Ag