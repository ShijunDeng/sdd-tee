Ä‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê\n39: ‚îÇ                    Kubernetes API Server                ‚îÇ\n40: ‚îÇ                                                          ‚îÇ\n41: ‚îÇ  ‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê  ‚îÇ\n42: ‚îÇ  ‚îÇ         runtime.agentcube.volcano.sh/v1alpha1    ‚îÇ  ‚îÇ\n43: ‚îÇ  ‚îÇ  ‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê  ‚îÇ  ‚îÇ\n44: ‚îÇ  ‚îÇ  ‚îÇ  agentruntimes.runtime.agentcube.volcano.sh ‚îÇ  ‚îÇ  ‚îÇ\n45: ‚îÇ  ‚îÇ  ‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò  ‚îÇ  ‚îÇ\n46: ‚îÇ  ‚îÇ  ‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê  ‚îÇ  ‚îÇ\n47: ‚îÇ  ‚îÇ  ‚îÇ  codeinterpreters.runtime.agentcube.volcano.sh‚îÇ‚îÇ  ‚îÇ\n48: ‚îÇ  ‚îÇ  ‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò  ‚îÇ  ‚îÇ\n49: ‚îÇ  ‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò  ‚îÇ\n50: ‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò\n51:                           ‚îÇ\n52:                           ‚îÇ k8s client-go\n53:                           ‚ñº\n54: ‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê\n55: ‚îÇ                 client-go (Generated)                   ‚îÇ\n56: ‚îÇ  ‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê  ‚îÇ\n57: ‚îÇ  ‚îÇ  clientset/versioned/typed/runtime/v1alpha1/     ‚îÇ  ‚îÇ\n58: ‚îÇ  ‚îÇ    ‚Ä¢ AgentRuntimeInterface                       ‚îÇ  ‚îÇ\n59: ‚îÇ  ‚îÇ    ‚Ä¢ CodeInterpreterInterface                    ‚îÇ  ‚îÇ\n60: ‚îÇ  ‚îÇ    ‚Ä¢ REST CRUD + Watch                           ‚îÇ  ‚îÇ\n61: ‚îÇ  ‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò  ‚îÇ\n62: ‚îÇ  ‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê  ‚îÇ\n63: ‚îÇ  ‚îÇ  informers/externalversions/runtime/v1alpha1/    ‚îÇ  ‚îÇ\n64: ‚îÇ  ‚îÇ    ‚Ä¢ AgentRuntimeInformer                        ‚îÇ  ‚îÇ\n65: ‚îÇ  ‚îÇ    ‚Ä¢ CodeInterpreterInformer                     ‚îÇ  ‚îÇ\n66: ‚îÇ  ‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò  ‚îÇ\n67: ‚îÇ  ‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê  ‚îÇ\n68: ‚îÇ  ‚îÇ  listers/runtime/v1alpha1/                      ‚îÇ  ‚îÇ\n69: ‚îÇ  ‚îÇ    ‚Ä¢ AgentRuntimeLister                          ‚îÇ  ‚îÇ\n70: ‚îÇ  ‚îÇ    ‚Ä¢ CodeInterpreterLister                       ‚îÇ  ‚îÇ\n71: ‚îÇ  ‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò  ‚îÇ\n72: ‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò\n73: ```\n74: \n75: ## Data Structures\n76: \n77: ### AgentRuntime\n78: \n79: **File**: `pkg/apis/runtime/v1alpha1/agentruntime_types.go`\n80: \n81: ```go\n82: // AgentRuntimeSpec defines the desired state of AgentRuntime\n83: type AgentRuntimeSpec struct {\n84:     // MaxSessionDuration is the maximum duration for any session\n85:     // +kubebuilder:default=\"8h\"\n86:     MaxSessionDuration string `json:\"maxSessionDuration\"`\n87:     \n88:     // SessionTimeout is the idle timeout before a session is terminated\n89:     // +kubebuilder:default=\"15m\"\n90:     SessionTimeout string `json:\"sessionTimeout\"`\n91:     \n92:     // TargetPort specifies the HTTP/HTTPS ports to expose\n93:     // +kubebuilder:validation:MinItems=1\n94:     TargetPort []TargetPort `json:\"targetPort\"`\n95:     \n96:     // PodTemplate defines the pod template for agent sandbox pods\n97:     PodTemplate PodTemplateSpec `json:\"podTemplate\"`\n98: }\n99: \n100: // AgentRuntimeStatus defines the observed state of AgentRuntime\n101: type AgentRuntimeStatus struct {\n102:     // Conditions represent the latest available observations\n103:     Conditions []metav1.Condition `json:\"conditions,omitempty\"`\n104:     \n105:     // ObservedGeneration is the most recent generation observed\n106:     ObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n107: }\n108: \n109: // TargetPort defines a single HTTP/HTTPS port target\n110: type TargetPort struct {\n111:     // Port is the port number\n112:     // +kubebuilder:validation:Minimum=1\n113:     // +kubebuilder:validation:Maximum=65535\n114:     Port int32 `json:\"port\"`\n115:     \n116:     // Protocol must be \"HTTP\" or \"HTTPS\"\n117:     // +kubebuilder:validation:Enum=HTTP;HTTPS\n118:     Protocol string `json:\"protocol\"`\n119:     \n120:     // Name is an optional name for the port\n121:     Name string `json:\"name,omitempty\"`\n122:     \n123:     // PathPrefix is the URL path prefix for this port\n124:     PathPrefix string `json:\"pathPrefix,omitempty\"`\n125: }\n126: \n127: // PodTemplateSpec defines the pod template specification\n128: type PodTemplateSpec struct {\n129:     // Metadata for the pod\n130:     Metadata metav1.ObjectMeta `json:\"metadata,omitempty\"`\n131:     \n132:     // Spec for the pod\n133:     Spec PodSpec `json:\"spec,omitempty\"`\n134: }\n135: \n136: // AgentRuntime is the Schema for the agentruntimes API\n137: // +kubebuilder:object:root=true\n138: // +kubebuilder:subresource:status\n139: // +kubebuilder:resource:shortName=art\n140: // +kubebuilder:printcolumn:name=\"Age\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n141: type AgentRuntime struct {\n142:     metav1.TypeMeta   `json:\",inline\"`\n143:     metav1.ObjectMeta `json:\"metadata,omitempty\"`\n144:     \n145:     Spec   AgentRuntimeSpec   `json:\"spec,omitempty\"`\n146:     Status AgentRuntimeStatus `json:\"status,omitempty\"`\n147: }\n148: \n149: // AgentRuntimeList contains a list of AgentRuntime\n150: // +kubebuilder:object:root=true\n151: type AgentRuntimeList struct {\n152:     metav1.TypeMeta `json:\",inline\"`\n153:     metav1.ListMeta `json:\"metadata,omitempty\"`\n154:     \n155:     Items []AgentRuntime `json:\"items\"`\n156: }\n157: ```\n158: \n159: ### CodeInterpreter\n160: \n161: **File**: `pkg/apis/runtime/v1alpha1/codeinterpreter_types.go`\n162: \n163: ```go\n164: // CodeInterpreterSpec defines the desired state of CodeInterpreter\n165: type CodeInterpreterSpec struct {\n166:     // AuthMode specifies the authentication mode\n167:     // +kubebuilder:default=\"picod\"\n168:     // +kubebuilder:validation:Enum=picod;none\n169:     AuthMode string `json:\"authMode\"`\n170:     \n171:     // MaxSessionDuration is the maximum duration for any session\n172:     // +kubebuilder:default=\"8h\"\n173:     MaxSessionDuration string `json:\"maxSessionDuration\"`\n174:     \n175:     // SessionTimeout is the idle timeout before a session is terminated\n176: