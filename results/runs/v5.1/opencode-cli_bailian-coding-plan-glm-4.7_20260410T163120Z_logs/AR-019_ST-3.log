29: **Step 1: Write the failing test**\n30: \n31: ```go\n32: // pkg/picod/handlers_test.go\n33: package picod\n34: \n35: import (\n36: \t\"net/http\"\n37: \t\"net/http/httptest\"\n38: \t\"os\"\n39: \t\"path/filepath\"\n40: \t\"strings\"\n41: \t\"testing\"\n42: \n43: \t\"github.com/gin-gonic/gin\"\n44: \t. \"github.com/onsi/gomega\"\n45: )\n46: \n47: func TestDeleteFileHandler(t *testing.T) {\n48: \tg := NewGomegaWithT(t)\n49: \n50: \tgin.SetMode(gin.TestMode)\n51: \trouter := gin.New()\n52: \n53: \ttempDir := t.TempDir()\n54: \tserver := &Server{\n55: \t\tworkspaceDir: tempDir,\n56: \t\tauthManager:  nil, // Skip auth for tests\n57: \t}\n58: \n59: \trouter.DELETE(\"/api/files/*path\", server.DeleteFileHandler)\n60: \n61: \t// Create a test file\n62: \ttestFile := filepath.Join(tempDir, \"test.txt\")\n63: \tif err := os.WriteFile(testFile, []byte(\"test content\"), 0644); err != nil {\n64: \t\tt.Fatalf(\"Failed to create test file: %v\", err)\n65: \t}\n66: \n67: \t// Test deleting a file\n68: \treq, _ := http.NewRequest(\"DELETE\", \"/api/files/test.txt\", nil)\n69: \tw := httptest.NewRecorder()\n70: \trouter.ServeHTTP(w, req)\n71: \n72: \tg.Expect(w.Code).To(Equal(http.StatusOK))\n73: \n74: \t// Verify file was deleted\n75: \t_, err := os.Stat(testFile)\n76: \tg.Expect(os.IsNotExist(err)).To(BeTrue())\n77: \n78: \t// Test deleting non-existent file\n79: \treq, _ = http.NewRequest(\"DELETE\", \"/api/files/nonexistent.txt\", nil)\n80: \tw = httptest.NewRecorder()\n81: \trouter.ServeHTTP(w, req)\n82: \n83: \tg.Expect(w.Code).To(Equal(http.StatusNotFound))\n84: }\n85: \n86: func TestDeleteDirectoryHandler(t *testing.T) {\n87: \tg := NewGomegaWithT(t)\n88: \n89: \tgin.SetMode(gin.TestMode)\n90: \trouter := gin.New()\n91: \n92: \ttempDir := t.TempDir()\n93: \tserver := &Server{\n94: \t\tworkspaceDir: tempDir,\n95: \t\tauthManager:  nil,\n96: \t}\n97: \n98: \trouter.DELETE(\"/api/files/*path\", server.DeleteFileHandler)\n99: \n100: \t// Create a test directory with files\n