ure there is only one active controller manager.\")\n39: \n40: \topts := zap.Options{\n41: \t\tDevelopment: true,\n42: \t}\n43: \topts.BindFlags(flag.CommandLine)\n44: \tflag.Parse()\n45: \n46: \tctrl.SetLogger(zap.New(zap.UseFlagOptions(&opts)))\n47: \n48: \tmgr, err := ctrl.NewManager(ctrl.GetConfigOrDie(), ctrl.Options{\n49: \t\tScheme:                 scheme,\n50: \t\tHealthProbeBindAddress: probeAddr,\n51: \t\tLeaderElection:         enableLeaderElection,\n52: \t\tLeaderElectionID:       \"agentd-leader\",\n53: \t})\n54: \tif err != nil {\n55: \t\tsetupLog.Error(err, \"unable to start manager\")\n56: \t\tos.Exit(1)\n57: \t}\n58: \n59: \tif err = (&agentd.Reconciler{\n60: \t\tClient: mgr.GetClient(),\n61: \t\tScheme: mgr.GetScheme(),\n62: \t}).SetupWithManager(mgr); err != nil {\n63: \t\tsetupLog.Error(err, \"unable to create controller\", \"controller\", \"Agentd\")\n64: \t\tos.Exit(1)\n65: \t}\n66: \n67: \tif err := mgr.AddHealthzCheck(\"healthz\", healthz.Ping); err != nil {\n68: \t\tsetupLog.Error(err, \"unable to set up health check\")\n69: \t\tos.Exit(1)\n70: \t}\n71: \n72: \tif err := mgr.AddReadyzCheck(\"readyz\", healthz.Ping); err != nil {\n73: \t\tsetupLog.Error(err, \"unable to set up ready check\")\n74: \t\tos.Exit(1)\n75: \t}\n76: \n77: \tsetupLog.Info(\"starting manager\")\n78: \tif err := mgr.Start(signals.SetupSignalHandler()); err != nil {\n79: \t\tsetupLog.Error(err, \"problem running manager\")\n80: \t\tos.Exit(1)\n81: \t}\n82: }\n\n(End of file - total 82 lines)\n</content>","metadata":{"preview":"package main\n\nimport (\n\t\"flag\"\n\t\"os\"\n\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tutilruntime \"k8s.io/apimachinery/pkg/util/runtime\"\n\tclientgoscheme \"k8s.io/client-go/kubernetes/scheme\"\n\t_ \"k8s.io/client-go/plugin/pkg/client/auth\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/healthz\"\n\t\"sigs.k8s.io/controller-runtime/pkg/log/zap\"\n\t\"sigs.k8s.io/controller-runtime/pkg/manager/signals\"\n\n\tagentd \"github.com/volcano-sh/agentcube/pkg/agentd\"\n)\n\nvar (\n\tscheme   = runtime.NewScheme()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/cmd/agentd/main.go","time":{"start":1775863192052,"end":1775863192073}}}}
