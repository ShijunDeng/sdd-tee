\tvar podIP string\n\tfor i := 0; i < 60; i++ {\n\t\tpodIP, err = sc.k8sClient.GetPodIP(ctx, sandboxName, req.Namespace, createdCR)\n\t\tif err == nil {\n\t\t\tbreak\n\t\t}\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\tsc.store.DeleteSandboxBySessionID(ctx, sessionID)\n\t\t\tsc.k8sClient.DeleteSandbox(ctx, req.Namespace, sandboxName)\n\t\t\treturn nil, fmt.Errorf(\"sandbox creation timed out\")\n\t\tcase <-time.After(2 * time.Second):\n\t\t\tcontinue\n\t\t}\n\t}\n\n\tentryPoints := sc.buildEntryPoints(podIP, ports)\n\n\tsandboxInfo.SandboxID = string(createdCR.GetUID())\n\tsandboxInfo.PodIP = podIP\n\tsandboxInfo.EntryPoints = convertEntryPoints(entryPoints)\n\tsandboxInfo.Status = \"running\"\n\n\tif err := sc.store.UpdateSandbox(ctx, sessionID, sandboxInfo); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to update sandbox: %w\", err)\n\t}\n\n\treturn &api.CreateSandboxResponse{\n\t\tSessionID:   sessionID,\n\t\tSandboxID:   sandboxInfo.SandboxID,\n\t\tSandboxName: sandboxName,\n\t\tEntryPoints: entryPoints,\n\t\tCreatedAt:   sandboxInfo.CreatedAt.Format(time.RFC3339),\n\t\tExpiresAt:   sandboxInfo.ExpiresAt.Format(time.RFC3339),\n\t}, nil\n}\n\nfunc (sc *SandboxController) GetSession(ctx context.Context, sessionID string) (*api.GetSessionResponse, error) {\n\tsandboxInfo, err := sc.store.GetSandbox(ctx, sessionID)\n\tif err != nil {\n\t\tif err == store.ErrNotFound {\n\t\t\treturn nil, fmt.Errorf(\"session not found\")\n\t\t}\n\t\treturn nil, fmt.Errorf(\"failed to get session: %w\", err)\n\t}\n\n\treturn &api.GetSessionResponse{\n\t\tSessionID:    sandboxInfo.SessionID,\n\t\tSandboxID:    sandboxInfo.SandboxID,\n\t\tSandboxName:  sandboxInfo.SandboxName,\n\t\tKind:         sandboxInfo.Kind,\n\t\tNamespace:    sandboxInfo.Namespace,\n\t\tName:         sandboxInfo.WorkloadName,\n\t\tEntryPoints:  convertToAPIEntryPoints(sandboxInfo.EntryPoints),\n\t\tLastActivity: sandboxInfo.LastActivityAt.Format(time.RFC3339),\n\t\tCreatedAt:    sandboxInfo.CreatedAt.Format(time.RFC3339),\n\t\tExpiresAt:    sandboxInfo.ExpiresAt.Format(time.RFC3339),\n\t\tPodIP:        sandboxInfo.PodIP,\n\t}, nil\n}\n\nfunc (sc *SandboxController) DeleteSession(ctx context.Context, sessionID string) (*api.DeleteSessionResponse, error) {\n\tsandboxInfo, err := sc.store.GetSandbox(ctx, sessionID)\n\tif err != nil {\n\t\tif err == store.ErrNotFound {\n\t\t\treturn nil, fmt.Errorf(\"session not found\")\n\t\t}\n\t\treturn nil, fmt.Errorf(\"failed to get session: %w\", err)\n\t}\n\n\tif err := sc.k8sClient.DeleteSandbox(ctx, sandboxInfo.Namespace, sandboxInfo.SandboxName); err != nil && !apierrors.IsNotFound(err) {\n\t\treturn nil, fmt.Errorf(\"failed to delete sandbox: %w\", err)\n\t}\n\n\tif err := sc.store.DeleteSandboxBySessionID(ctx, sessionID); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to delete session: %w\", err)\n\t}\n\n\treturn &api.DeleteSessionResponse{\n\t\tSessionID: sessionID,\n\t\tDeletedAt: time.Now().Format(time.RFC3339),\n\t}, nil\n}\n\nfunc (sc *SandboxController) buildAgentRuntimeSandboxCR(agentRuntime *unstructured.Unstructured, sessionID, sandboxName, workloadName, namespace string) (*unstructured.Unstructured, error) {\n\tcr := &unstructured.Unstructured{}\n\tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n\tcr.SetKind(\"Sandbox\")\n\tcr.SetName(sandboxName)\n\tcr.SetNamespace(namespace)\n\n\tcr.SetLabels(map[string]string{\n\t\tconstants.LabelManagedBy:    constants.LabelManagedByValue,\n\t\tconstants.LabelSessionID:    sessionID,\n\t\tconstants.LabelWorkloadName: workloadName,\n\t\tconstants.LabelSandboxName:  sandboxName,\n\t})\n\n\tcr.SetAnnotations(map[string]string{\n\t\tconstants.AnnotationIdleTimeout: \"15m\",\n\t})\n\n\tshutdownTime := time.Now().Add(8 * time.Hour)\n\n\tspec := map[string]interface{}{\n\t\t\"replicas\": int64(1),\n\t\t\"lifecycle\": map[string]interface{}{\n\t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n\t\t},\n\t}\n\n\tspecMap, found, err := unstructured.NestedMap(agentRuntime.Object, \"spec\", \"podTemplate\")\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tif found {\n\t\tspec[\"podTemplate\"] = specMap\n\t}\n\n\tports, _, _ := unstructured.NestedSlice(agentRuntime.Object, \"spec\", \"ports\")\n\tif len(ports) > 0 {\n\t\tspec[\"ports\"] = ports\n\t}\n\n\tcr.Object[\"spec\"] = spec\n\n\treturn cr, nil\n}\n\nfunc (sc *SandboxController) buildCodeInterpreterSandboxCR(codeInterpreter *unstructured.Unstructured, sessionID, sandboxName, workloadName, namespace string, ports []interface{}) (*unstructured.Unstructured, error) {\n\tcr := &unstructured.Unstructured{}\n\tcr.SetAPIVersion(\"agents.x-k8s.io/v1alpha1\")\n\tcr.SetKind(\"Sandbox\")\n\tcr.SetName(sandboxName)\n\tcr.SetNamespace(namespace)\n\n\tcr.SetLabels(map[string]string{\n\t\tconstants.LabelManagedBy:    constants.LabelManagedByValue,\n\t\tconstants.LabelSessionID:    sessionID,\n\t\tconstants.LabelWorkloadName: workloadName,\n\t\tconstants.LabelSandboxName:  sandboxName,\n\t})\n\n\tcr.SetAnnotations(map[string]string{\n\t\tconstants.AnnotationIdleTimeout: \"15m\",\n\t})\n\n\tshutdownTime := time.Now().Add(8 * time.Hour)\n\n\tspec := map[string]interface{}{\n\t\t\"replicas\": int64(1),\n\t\t\"lifecycle\": map[string]interface{}{\n\t\t\t\"shutdownTime\": shutdownTime.Format(time.RFC3339),\n\t\t},\n\t}\n\n\tif len(ports) > 0 {\n\t\tspec[\"ports\"] = ports\n\t}\n\n\timage, _, _ := unstructured.NestedString(codeInterpreter.Object, \"spec\", \"template\", \"image\")\n\tif image == \"\" {\n\t\timage = \"python:3.11-slim\"\n\t}\n\n\tcontainer := corev1.Container{\n\t\tName:  \"code-interpreter\",\n\t\tImage: image,\n\t}\n\n\tpodSpec := corev1.PodSpec{\n\t\tContainers: []corev1.Container{container},\n\t}\n\n\tpodSpecMap, err := runtime.DefaultUnstructuredConverter.ToUnstructured(&podSpec)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to convert pod spec: %w\", err)\n\t}\n\n\tspec[\"podTemplate\"] = podSpecMap\n\n\tcr.Object[\"spec\"] = spec\n\n\treturn cr, nil\n}\n\nfunc (sc *SandboxController) buildEntryPoints(podIP string, ports []interface{}) []api.EntryPoint {\n\tvar entryPoints []api.EntryPoint\n\tfor _, p := range ports {\n\t\tportMap, ok := p.(map[string]interface{})\n\t\tif !ok {\n\t\t\tcontinue\n\t\t}\n\n\t\tprotocol, _, _ := unstructured.NestedString(portMap, \"protocol\")\n\t\tport, _, _ := unstructured.NestedInt64(portMap, \"port\")\n\t\tpath, _, _ := unstructured.NestedString(portMap, \"pathPrefix\")\n\n\t\tif port == 0 || protocol == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tentryPoints = append(entryPoints, api.EntryPoint{\n\t\t\tProtocol: protocol,\n\t\t\tEndpoint: fmt.Sprintf(\"%s:%d\", podIP, port),\n\t\t\tPath:     path,\n\t\t\tPort:     int32(port),\n\t\t})\n\t}\n\treturn entryPoints\n}\n\nfunc convertEntryPoints(entryPoints []api.EntryPoint) []types.SandboxEntryPoint {\n\tvar result []types.SandboxEntryPoint\n\tfor _, ep := range entryPoints {\n\t\tresult = append(result, types.SandboxEntryPoint{\n\t\t\tProtocol: ep.Protocol,\n\t\t\tEndpoint: ep.Endpoint,\n\t\t\tPath:     ep.Path,\n\t\t})\n\t}\n\treturn result\n}\n\nfunc convertToAPIEntryPoints(entryPoints []types.SandboxEntryPoint) []api.EntryPoint {\n\tvar result []api.EntryPoint\n\tfor _, ep := range entryPoints {\n\t\tresult = append(result, api.EntryPoint{\n\t\t\tProtocol: ep.Protocol,\n\t\t\tEndpoint: ep.Endpoint,\n\t\t\tPath:     ep.Path,\n\t\t})\n\t}\n\treturn result\n}\n\nfunc generateSandboxName(workloadName string) string {\n\treturn fmt.Sprintf(\"%s-%s\", workloadName, RandString(8))\n}\n\nfunc RandString(n int) string {\n\tconst charset = \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\"\n\tb := make([]byte, n)\n\tfor i := range b {\n\t\tb[i] = charset[rand.Intn(len(charset))]\n\t}\n\treturn string(b)\n}\n","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox.go","time":{"start":1775844486656,"end":1775844486839}}}}
