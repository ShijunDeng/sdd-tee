tmock.Mock\n}\n\nfunc (m *MockK8sClient) GetAgentRuntime(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) GetCodeInterpreter(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) CreateSandbox(ctx context.Context, namespace string, sandbox *unstructured.Unstructured) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, sandbox)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) GetSandbox(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) DeleteSandbox(ctx context.Context, namespace, name string) error {\n\targs := m.Called(ctx, namespace, name)\n\treturn args.Error(0)\n}\n\nfunc (m *MockK8sClient) GetPodIP(ctx context.Context, sandboxName, namespace string, sandbox *unstructured.Unstructured) (string, error) {\n\targs := m.Called(ctx, sandboxName, namespace, sandbox)\n\treturn args.String(0), args.Error(1)\n}\n\nfunc (m *MockK8sClient) GetSecret(ctx context.Context, namespace, name string) (*corev1.Secret, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*corev1.Secret), args.Error(1)\n}\n\nfunc createAgentRuntime(name, namespace string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\t\"kind\":       \"AgentRuntime\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      name,\n\t\t\t\t\"namespace\": namespace,\n\t\t\t},\n\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\"podTemplate\": map[string]interface{}{\n\t\t\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\t\t\"containers\": []interface{}{\n\t\t\t\t\t\t\tmap[string]interface{}{\n\t\t\t\t\t\t\t\t\"name\":  \"agent\",\n\t\t\t\t\t\t\t\t\"image\": \"python:3.11-slim\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\t\"ports\": []interface{}{\n\t\t\t\t\tmap[string]interface{}{\n\t\t\t\t\t\t\"port\":     int64(8080),\n\t\t\t\t\t\t\"protocol\": \"HTTP\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc createCodeInterpreter(name, namespace string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\t\"kind\":       \"CodeInterpreter\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      name,\n\t\t\t\t\"namespace\": namespace,\n\t\t\t},\n\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\"template\": map[string]interface{}{\n\t\t\t\t\t\"image\": \"python:3.11-slim\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc createSandboxCR(name, namespace, sessionID, workloadName string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n\t\t\t\"kind\":       \"Sandbox\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      name,\n\t\t\t\t\"namespace\": namespace,\n\t\t\t\t\"uid\":       \"sandbox-uid-\" + uuid.New().String(),\n\t\t\t},\n\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\"replicas\": int64(1),\n\t\t\t\t\"lifecycle\": map[string]interface{}{\n\t\t\t\t\t\"shutdownTime\": time.Now().Add(8 * time.Hour).Format(time.RFC3339),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc TestSandboxController_CreateAgentRuntimeSandbox(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tctx := context.Background()\n\n\tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n\t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n\n\t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n\t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.5\", nil)\n\n\t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.NotEmpty(t, resp.SessionID)\n\t\tassert.NotEmpty(t, resp.SandboxID)\n\t\tassert.NotEmpty(t, resp.SandboxName)\n\t\tassert.Contains(t, resp.SandboxName, \"test-runtime-\")\n\t\tassert.NotEmpty(t, resp.EntryPoints)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.5:8080\", resp.EntryPoints[0].Endpoint)\n\t\tassert.NotEmpty(t, resp.CreatedAt)\n\t\tassert.NotEmpty(t, resp.ExpiresAt)\n\n\t\tmockK8s.AssertExpectations(t)\n\n\t\tsandboxInfo, err := redisStore.GetSandbox(ctx, resp.SessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, resp.SessionID, sandboxInfo.SessionID)\n\t\tassert.Equal(t, \"running\", sandboxInfo.Status)\n\t\tassert.Equal(t, \"10.244.1.5\", sandboxInfo.PodIP)\n\t})\n\n\tt.Run(\"agent runtime not found\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"nonexistent\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"agentruntimes\"), \"nonexistent\")\n\t\tmockK8s.On(\"GetAgentRuntime\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n\n\t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n\n\tt.Run(\"failed to create sandbox\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n\t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n\n\t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n\t\tmockK8s.On(\"CreateSandbox\", mock.Anything, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.Anything, mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"\", assert.AnError).Once()\n\t\tmockK8s.On(\"DeleteSandbox\", mock.Anything, \"default\", mock.MatchedBy(func(s string) bool { return true })).Return(nil).Maybe()\n\n\t\tctx, cancel := context.WithTimeout(ctx, 100*time.Millisecond)\n\t\tdefer cancel()\n\n\t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"timed out\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n}\n\nfunc TestSandboxController_CreateCodeInterpreterSandbox(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tctx := context.Background()\n\n\tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-interpreter\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tcodeInterpreter := createCodeInterpreter(\"test-interpreter\", \"default\")\n\t\tsandboxCR := createSandboxCR(\"test-interpreter-12345678\", \"default\", \"session-123\", \"test-interpreter\")\n\n\t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"test-interpreter\").Return(codeInterpreter, nil)\n\t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.6\", nil)\n\n\t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.NotEmpty(t, resp.SessionID)\n\t\tassert.NotEmpty(t, resp.SandboxID)\n\t\tassert.NotEmpty(t, resp.SandboxName)\n\t\tassert.Contains(t, resp.SandboxName, \"test-interpreter-\")\n\t\tassert.NotEmpty(t, resp.EntryPoints)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.6:8080\", resp.EntryPoints[0].Endpoint)\n\n\t\tmockK8s.AssertExpectations(t)\n\n\t\tsandboxInfo, err := redisStore.GetSandbox(ctx, resp.SessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"CodeInterpreter\", sandboxInfo.Kind)\n\t\tassert.Equal(t, \"running\", sandboxInfo.Status)\n\t})\n\n\tt.Run(\"code interpreter not found\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"nonexistent\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"codeinterpreters\"), \"nonexistent\")\n\t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n\n\t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n\n\tt.Run(\"code interpreter without ports uses default\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-interpreter-no-ports\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tcodeInterpreter := &unstructured.Unstructured{\n\t\t\tObject: map[string]interface{}{\n\t\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\t\t\"kind\":       \"CodeInterpreter\",\n\t\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\t\"name\":      \"test-interpreter-no-ports\",\n\t\t\t\t\t\"namespace\": \"default\",\n\t\t\t\t},\n\t\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\t\"template\": map[string]interface{}{\n\t\t\t\t\t\t\"image\": \"python:3.11-slim\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t}\n\n\t\tsandboxCR := createSandboxCR(\"test-interpreter-no-ports-12345678\", \"default\", \"session-123\", \"test-interpreter-no-ports\")\n\n\t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"test-interpreter-no-ports\").Return(codeInterpreter, nil)\n\t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.7\", nil)\n\n\t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, int32(8080), resp.EntryPoints[0].Port)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n}\n\nfunc TestSandboxController_GetSession(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tctx := context.Background()\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tt.Run(\"successfully gets session\", func(t *testing.T) {\n\t\tsessionID := \"test-session-1\"\n\t\tsandboxInfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxID:    \"sandbox-123\",\n\t\t\tSandboxName:  \"test-sandbox\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t\tPodIP:        \"10.244.1.5\",\n\t\t\tEntryPoints: []types.SandboxEntryPoint{\n\t\t\t\t{\n\t\t\t\t\tProtocol: \"HTTP\",\n\t\t\t\t\tEndpoint: \"10.244.1.5:8080\",\n\t\t\t\t\tPath:     \"/\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tLastActivityAt: time.Now(),\n\t\t}\n\n\t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n\t\trequire.NoError(t, err)\n\n\t\tresp, err := controller.GetSession(ctx, sessionID)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.Equal(t, sessionID, resp.SessionID)\n\t\tassert.Equal(t, \"sandbox-123\", resp.SandboxID)\n\t\tassert.Equal(t, \"test-sandbox\", resp.SandboxName)\n\t\tassert.Equal(t, \"AgentRuntime\", resp.Kind)\n\t\tassert.Equal(t, \"default\", resp.Namespace)\n\t\tassert.Equal(t, \"test-workload\", resp.Name)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.5\", resp.PodIP)\n\t})\n\n\tt.Run(\"session not found\", func(t *testing.T) {\n\t\tresp, err := controller.GetSession(ctx, \"nonexistent-session\")\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\t})\n}\n\nfunc TestSandboxController_DeleteSession(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tctx := context.Background()\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tt.Run(\"successfully deletes session\", func(t *testing.T) {\n\t\tsessionID := \"test-session-delete\"\n\t\tsandboxInfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxID:    \"sandbox-123\",\n\t\t\tSandboxName:  \"test-sandbox\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t}\n\n\t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n\t\trequire.NoError(t, err)\n\n\t\tmockK8s.On(\"DeleteSandbox\", ctx, \"default\", \"test-sandbox\").Return(nil)\n\n\t\tresp, err := controller.DeleteSession(ctx, sessionID)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.Equal(t, sessionID, resp.SessionID)\n\t\tassert.NotEmpty(t, resp.DeletedAt)\n\n\t\tmockK8s.AssertExpectations(t)\n\n\t\t_, err = redisStore.GetSandbox(ctx, sessionID)\n\t\tassert.Error(t, err)\n\t\tassert.Equal(t, store.ErrNotFound, err)\n\t})\n\n\tt.Run(\"session not found\", func(t *testing.T) {\n\t\tresp, err := controller.DeleteSession(ctx, \"nonexistent-session\")\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\t})\n\n\tt.Run(\"k8s delete fails but store cleanup succeeds\", func(t *testing.T) {\n\t\tsessionID := \"test-session-fail-k8s\"\n\t\tsandboxInfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxID:    \"sandbox-123\",\n\t\t\tSandboxName:  \"test-sandbox\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t}\n\n\t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n\t\trequire.NoError(t, err)\n\n\t\tmockK8s.On(\"DeleteSandbox\", ctx, \"default\", \"test-sandbox\").Return(assert.AnError)\n\n\t\tresp, err := controller.DeleteSession(ctx, sessionID)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"failed to delete sandbox\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n}\n\nfunc extractSessionIDFromName(name string) string {\n\treturn \"session-\" + name\n}\n\nfunc TestBuildAgentRuntimeSandboxCR(t *testing.T) {\n\ts := miniredis.RunT(t)\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n\n\tcr, err := controller.buildAgentRuntimeSandboxCR(agentRuntime, \"session-123\", \"test-runtime-abc\", \"test-runtime\", \"default\")\n\n\trequire.NoError(t, err)\n\trequire.NotNil(t, cr)\n\n\tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", cr.GetAPIVersion())\n\tassert.Equal(t, \"Sandbox\", cr.GetKind())\n\tassert.Equal(t, \"test-runtime-abc\", cr.GetName())\n\tassert.Equal(t, \"default\", cr.GetNamespace())\n\n\tlabels := cr.GetLabels()\n\tassert.NotNil(t, labels)\n\tassert.Equal(t, \"agentcube-workload-manager\", labels[\"managed-by\"])\n\tassert.Equal(t, \"session-123\", labels[\"runtime.agentcube.io/session-id\"])\n\tassert.Equal(t, \"test-runtime\", labels[\"runtime.agentcube.io/workload-name\"])\n\n\tannotations := cr.GetAnnotations()\n\tassert.NotNil(t, annotations)\n\tassert.Equal(t, \"15m\", annotations[\"runtime.agentcube.io/idle-timeout\"])\n}\n\nfunc TestBuildCodeInterpreterSandboxCR(t *testing.T) {\n\ts := miniredis.RunT(t)\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tcodeInterpreter := createCodeInterpreter(\"test-interpreter\", \"default\")\n\n\tports := []interface{}{\n\t\tmap[string]interface{}{\n\t\t\t\"port\":     int64(8080),\n\t\t\t\"protocol\": \"HTTP\",\n\t\t},\n\t}\n\n\tcr, err := controller.buildCodeInterpreterSandboxCR(codeInterpreter, \"session-456\", \"test-interpreter-xyz\", \"test-interpreter\", \"default\", ports)\n\n\trequire.NoError(t, err)\n\trequire.NotNil(t, cr)\n\n\tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", cr.GetAPIVersion())\n\tassert.Equal(t, \"Sandbox\", cr.GetKind())\n\tassert.Equal(t, \"test-interpreter-xyz\", cr.GetName())\n\tassert.Equal(t, \"default\", cr.GetNamespace())\n\n\tlabels := cr.GetLabels()\n\tassert.NotNil(t, labels)\n\tassert.Equal(t, \"agentcube-workload-manager\", labels[\"managed-by\"])\n\tassert.Equal(t, \"session-456\", labels[\"runtime.agentcube.io/session-id\"])\n\n\tannotations := cr.GetAnnotations()\n\tassert.NotNil(t, annotations)\n\tassert.Equal(t, \"15m\", annotations[\"runtime.agentcube.io/idle-timeout\"])\n}\n\nfunc TestBuildEntryPoints(t *testing.T) {\n\ts := miniredis.RunT(t)\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tt.Run(\"builds entry points from ports\", func(t *testing.T) {\n\t\tports := []interface{}{\n\t\t\tmap[string]interface{}{\n\t\t\t\t\"port\":       int64(8080),\n\t\t\t\t\"protocol\":   \"HTTP\",\n\t\t\t\t\"pathPrefix\": \"/api\",\n\t\t\t},\n\t\t\tmap[string]interface{}{\n\t\t\t\t\"port\":     int64(9090),\n\t\t\t\t\"protocol\": \"gRPC\",\n\t\t\t},\n\t\t}\n\n\t\tentryPoints := controller.buildEntryPoints(\"10.244.1.5\", ports)\n\n\t\trequire.Len(t, entryPoints, 2)\n\n\t\tassert.Equal(t, \"HTTP\", entryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.5:8080\", entryPoints[0].Endpoint)\n\t\tassert.Equal(t, \"/api\", entryPoints[0].Path)\n\t\tassert.Equal(t, int32(8080), entryPoints[0].Port)\n\n\t\tassert.Equal(t, \"gRPC\", entryPoints[1].Protocol)\n\t\tassert.Equal(t, \"10.244.1.5:9090\", entryPoints[1].Endpoint)\n\t\tassert.Equal(t, \"\", entryPoints[1].Path)\n\t\tassert.Equal(t, int32(9090), entryPoints[1].Port)\n\t})\n\n\tt.Run(\"handles malformed port entries\", func(t *testing.T) {\n\t\tports := []interface{}{\n\t\t\tmap[string]interface{}{\n\t\t\t\t\"port\":     int64(8080),\n\t\t\t\t\"protocol\": \"HTTP\",\n\t\t\t},\n\t\t\t\"invalid\",\n\t\t\tmap[string]interface{}{\n\t\t\t\t\"port\": int64(9090),\n\t\t\t},\n\t\t}\n\n\t\tentryPoints := controller.buildEntryPoints(\"10.244.1.5\", ports)\n\n\t\trequire.Len(t, entryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", entryPoints[0].Protocol)\n\t})\n}\n\nfunc TestGenerateSandboxName(t *testing.T) {\n\tname1 := generateSandboxName(\"test-runtime\")\n\tname2 := generateSandboxName(\"test-runtime\")\n\n\tassert.Contains(t, name1, \"test-runtime-\")\n\tassert.Contains(t, name2, \"test-runtime-\")\n\tassert.NotEqual(t, name1, name2)\n\tassert.Len(t, name1, len(\"test-runtime-\")+8)\n\tassert.Len(t, name2, len(\"test-runtime-\")+8)\n}\n\nfunc TestRandString(t *testing.T) {\n\tstr1 := RandString(8)\n\tstr2 := RandString(8)\n\n\tassert.Len(t, str1, 8)\n\tassert.Len(t, str2, 8)\n\tassert.NotEqual(t, str1, str2)\n\n\tfor _, ch := range str1 {\n\t\tassert.Contains(t, \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\", string(ch))\n\t}\n}\n\nfunc TestConvertEntryPoints(t *testing.T) {\n\tapiEntryPoints := []api.EntryPoint{\n\t\t{\n\t\t\tProtocol: \"HTTP\",\n\t\t\tEndpoint: \"10.244.1.5:8080\",\n\t\t\tPath:     \"/api\",\n\t\t\tPort:     8080,\n\t\t},\n\t}\n\n\tconverted := convertEntryPoints(apiEntryPoints)\n\n\trequire.Len(t, converted, 1)\n\tassert.Equal(t, \"HTTP\", converted[0].Protocol)\n\tassert.Equal(t, \"10.244.1.5:8080\", converted[0].Endpoint)\n\tassert.Equal(t, \"/api\", converted[0].Path)\n}\n\nfunc TestConvertToAPIEntryPoints(t *testing.T) {\n\tentryPoints := []types.SandboxEntryPoint{\n\t\t{\n\t\t\tProtocol: \"HTTP\",\n\t\t\tEndpoint: \"10.244.1.5:8080\",\n\t\t\tPath:     \"/api\",\n\t\t},\n\t}\n\n\tconverted := convertToAPIEntryPoints(entryPoints)\n\n\trequire.Len(t, converted, 1)\n\tassert.Equal(t, \"HTTP\", converted[0].Protocol)\n\tassert.Equal(t, \"10.244.1.5:8080\", converted[0].Endpoint)\n\tassert.Equal(t, \"/api\", converted[0].Path)\n}\n","after":"package controller\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/google/uuid\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/mock\"\n\t\"github.com/stretchr/testify/require\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/apis/meta/v1/unstructured\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/store\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager/api\"\n)\n\ntype MockK8sClient struct {\n\tmock.Mock\n}\n\nfunc (m *MockK8sClient) GetAgentRuntime(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) GetCodeInterpreter(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) CreateSandbox(ctx context.Context, namespace string, sandbox *unstructured.Unstructured) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, sandbox)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) GetSandbox(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*unstructured.Unstructured), args.Error(1)\n}\n\nfunc (m *MockK8sClient) DeleteSandbox(ctx context.Context, namespace, name string) error {\n\targs := m.Called(ctx, namespace, name)\n\treturn args.Error(0)\n}\n\nfunc (m *MockK8sClient) GetPodIP(ctx context.Context, sandboxName, namespace string, sandbox *unstructured.Unstructured) (string, error) {\n\targs := m.Called(ctx, sandboxName, namespace, sandbox)\n\treturn args.String(0), args.Error(1)\n}\n\nfunc (m *MockK8sClient) GetSecret(ctx context.Context, namespace, name string) (*corev1.Secret, error) {\n\targs := m.Called(ctx, namespace, name)\n\tif args.Get(0) == nil {\n\t\treturn nil, args.Error(1)\n\t}\n\treturn args.Get(0).(*corev1.Secret), args.Error(1)\n}\n\nfunc createAgentRuntime(name, namespace string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\t\"kind\":       \"AgentRuntime\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      name,\n\t\t\t\t\"namespace\": namespace,\n\t\t\t},\n\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\"podTemplate\": map[string]interface{}{\n\t\t\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\t\t\"containers\": []interface{}{\n\t\t\t\t\t\t\tmap[string]interface{}{\n\t\t\t\t\t\t\t\t\"name\":  \"agent\",\n\t\t\t\t\t\t\t\t\"image\": \"python:3.11-slim\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\t\"ports\": []interface{}{\n\t\t\t\t\tmap[string]interface{}{\n\t\t\t\t\t\t\"port\":     int64(8080),\n\t\t\t\t\t\t\"protocol\": \"HTTP\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc createCodeInterpreter(name, namespace string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\t\"kind\":       \"CodeInterpreter\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      name,\n\t\t\t\t\"namespace\": namespace,\n\t\t\t},\n\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\"template\": map[string]interface{}{\n\t\t\t\t\t\"image\": \"python:3.11-slim\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc createSandboxCR(name, namespace, sessionID, workloadName string) *unstructured.Unstructured {\n\treturn &unstructured.Unstructured{\n\t\tObject: map[string]interface{}{\n\t\t\t\"apiVersion\": \"agents.x-k8s.io/v1alpha1\",\n\t\t\t\"kind\":       \"Sandbox\",\n\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\"name\":      name,\n\t\t\t\t\"namespace\": namespace,\n\t\t\t\t\"uid\":       \"sandbox-uid-\" + uuid.New().String(),\n\t\t\t},\n\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\"replicas\": int64(1),\n\t\t\t\t\"lifecycle\": map[string]interface{}{\n\t\t\t\t\t\"shutdownTime\": time.Now().Add(8 * time.Hour).Format(time.RFC3339),\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc TestSandboxController_CreateAgentRuntimeSandbox(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tctx := context.Background()\n\n\tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n\t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n\n\t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n\t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.5\", nil)\n\n\t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.NotEmpty(t, resp.SessionID)\n\t\tassert.NotEmpty(t, resp.SandboxID)\n\t\tassert.NotEmpty(t, resp.SandboxName)\n\t\tassert.Contains(t, resp.SandboxName, \"test-runtime-\")\n\t\tassert.NotEmpty(t, resp.EntryPoints)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.5:8080\", resp.EntryPoints[0].Endpoint)\n\t\tassert.NotEmpty(t, resp.CreatedAt)\n\t\tassert.NotEmpty(t, resp.ExpiresAt)\n\n\t\tmockK8s.AssertExpectations(t)\n\n\t\tsandboxInfo, err := redisStore.GetSandbox(ctx, resp.SessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, resp.SessionID, sandboxInfo.SessionID)\n\t\tassert.Equal(t, \"running\", sandboxInfo.Status)\n\t\tassert.Equal(t, \"10.244.1.5\", sandboxInfo.PodIP)\n\t})\n\n\tt.Run(\"agent runtime not found\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"nonexistent\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"agentruntimes\"), \"nonexistent\")\n\t\tmockK8s.On(\"GetAgentRuntime\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n\n\t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n\n\tt.Run(\"failed to create sandbox\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-runtime\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n\t\tsandboxCR := createSandboxCR(\"test-runtime-12345678\", \"default\", \"session-123\", \"test-runtime\")\n\n\t\tmockK8s.On(\"GetAgentRuntime\", mock.Anything, \"default\", \"test-runtime\").Return(agentRuntime, nil)\n\t\tmockK8s.On(\"CreateSandbox\", mock.Anything, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.Anything, mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"\", assert.AnError).Once()\n\t\tmockK8s.On(\"DeleteSandbox\", mock.Anything, \"default\", mock.MatchedBy(func(s string) bool { return true })).Return(nil).Maybe()\n\n\t\tctx, cancel := context.WithTimeout(ctx, 100*time.Millisecond)\n\t\tdefer cancel()\n\n\t\tresp, err := controller.CreateAgentRuntimeSandbox(ctx, req)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"timed out\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n}\n\nfunc TestSandboxController_CreateCodeInterpreterSandbox(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tctx := context.Background()\n\n\tt.Run(\"successfully creates sandbox\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-interpreter\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tcodeInterpreter := createCodeInterpreter(\"test-interpreter\", \"default\")\n\t\tsandboxCR := createSandboxCR(\"test-interpreter-12345678\", \"default\", \"session-123\", \"test-interpreter\")\n\n\t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"test-interpreter\").Return(codeInterpreter, nil)\n\t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.6\", nil)\n\n\t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.NotEmpty(t, resp.SessionID)\n\t\tassert.NotEmpty(t, resp.SandboxID)\n\t\tassert.NotEmpty(t, resp.SandboxName)\n\t\tassert.Contains(t, resp.SandboxName, \"test-interpreter-\")\n\t\tassert.NotEmpty(t, resp.EntryPoints)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.6:8080\", resp.EntryPoints[0].Endpoint)\n\n\t\tmockK8s.AssertExpectations(t)\n\n\t\tsandboxInfo, err := redisStore.GetSandbox(ctx, resp.SessionID)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"CodeInterpreter\", sandboxInfo.Kind)\n\t\tassert.Equal(t, \"running\", sandboxInfo.Status)\n\t})\n\n\tt.Run(\"code interpreter not found\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"nonexistent\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tnotFoundErr := apierrors.NewNotFound(corev1.Resource(\"codeinterpreters\"), \"nonexistent\")\n\t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"nonexistent\").Return(nil, notFoundErr)\n\n\t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n\n\tt.Run(\"code interpreter without ports uses default\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\treq := &api.CreateSandboxRequest{\n\t\t\tName:      \"test-interpreter-no-ports\",\n\t\t\tNamespace: \"default\",\n\t\t}\n\n\t\tcodeInterpreter := &unstructured.Unstructured{\n\t\t\tObject: map[string]interface{}{\n\t\t\t\t\"apiVersion\": \"runtime.agentcube.volcano.sh/v1alpha1\",\n\t\t\t\t\"kind\":       \"CodeInterpreter\",\n\t\t\t\t\"metadata\": map[string]interface{}{\n\t\t\t\t\t\"name\":      \"test-interpreter-no-ports\",\n\t\t\t\t\t\"namespace\": \"default\",\n\t\t\t\t},\n\t\t\t\t\"spec\": map[string]interface{}{\n\t\t\t\t\t\"template\": map[string]interface{}{\n\t\t\t\t\t\t\"image\": \"python:3.11-slim\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t}\n\n\t\tsandboxCR := createSandboxCR(\"test-interpreter-no-ports-12345678\", \"default\", \"session-123\", \"test-interpreter-no-ports\")\n\n\t\tmockK8s.On(\"GetCodeInterpreter\", ctx, \"default\", \"test-interpreter-no-ports\").Return(codeInterpreter, nil)\n\t\tmockK8s.On(\"CreateSandbox\", ctx, \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(sandboxCR, nil)\n\t\tmockK8s.On(\"GetPodIP\", mock.AnythingOfType(\"*context.timerCtx\"), mock.AnythingOfType(\"string\"), \"default\", mock.AnythingOfType(\"*unstructured.Unstructured\")).Return(\"10.244.1.7\", nil)\n\n\t\tresp, err := controller.CreateCodeInterpreterSandbox(ctx, req)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, int32(8080), resp.EntryPoints[0].Port)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n}\n\nfunc TestSandboxController_GetSession(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tctx := context.Background()\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tt.Run(\"successfully gets session\", func(t *testing.T) {\n\t\tsessionID := \"test-session-1\"\n\t\tsandboxInfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxID:    \"sandbox-123\",\n\t\t\tSandboxName:  \"test-sandbox\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t\tPodIP:        \"10.244.1.5\",\n\t\t\tEntryPoints: []types.SandboxEntryPoint{\n\t\t\t\t{\n\t\t\t\t\tProtocol: \"HTTP\",\n\t\t\t\t\tEndpoint: \"10.244.1.5:8080\",\n\t\t\t\t\tPath:     \"/\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tLastActivityAt: time.Now(),\n\t\t}\n\n\t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n\t\trequire.NoError(t, err)\n\n\t\tresp, err := controller.GetSession(ctx, sessionID)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.Equal(t, sessionID, resp.SessionID)\n\t\tassert.Equal(t, \"sandbox-123\", resp.SandboxID)\n\t\tassert.Equal(t, \"test-sandbox\", resp.SandboxName)\n\t\tassert.Equal(t, \"AgentRuntime\", resp.Kind)\n\t\tassert.Equal(t, \"default\", resp.Namespace)\n\t\tassert.Equal(t, \"test-workload\", resp.Name)\n\t\tassert.Len(t, resp.EntryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", resp.EntryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.5\", resp.PodIP)\n\t})\n\n\tt.Run(\"session not found\", func(t *testing.T) {\n\t\tresp, err := controller.GetSession(ctx, \"nonexistent-session\")\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\t})\n}\n\nfunc TestSandboxController_DeleteSession(t *testing.T) {\n\ts := miniredis.RunT(t)\n\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tctx := context.Background()\n\n\tt.Run(\"successfully deletes session\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\tsessionID := \"test-session-delete\"\n\t\tsandboxInfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxID:    \"sandbox-123\",\n\t\t\tSandboxName:  \"test-sandbox\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t}\n\n\t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n\t\trequire.NoError(t, err)\n\n\t\tmockK8s.On(\"DeleteSandbox\", ctx, \"default\", \"test-sandbox\").Return(nil)\n\n\t\tresp, err := controller.DeleteSession(ctx, sessionID)\n\n\t\trequire.NoError(t, err)\n\t\trequire.NotNil(t, resp)\n\t\tassert.Equal(t, sessionID, resp.SessionID)\n\t\tassert.NotEmpty(t, resp.DeletedAt)\n\n\t\tmockK8s.AssertExpectations(t)\n\n\t\t_, err = redisStore.GetSandbox(ctx, sessionID)\n\t\tassert.Error(t, err)\n\t\tassert.Equal(t, store.ErrNotFound, err)\n\t})\n\n\tt.Run(\"session not found\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\t\tresp, err := controller.DeleteSession(ctx, \"nonexistent-session\")\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"not found\")\n\t})\n\n\tt.Run(\"k8s delete fails but store cleanup succeeds\", func(t *testing.T) {\n\t\tmockK8s := new(MockK8sClient)\n\t\tcontroller := NewSandboxController(mockK8s, redisStore)\n\t\tsessionID := \"test-session-fail-k8s\"\n\t\tsandboxInfo := &types.SandboxInfo{\n\t\t\tSessionID:    sessionID,\n\t\t\tSandboxID:    \"sandbox-123\",\n\t\t\tSandboxName:  \"test-sandbox\",\n\t\t\tWorkloadName: \"test-workload\",\n\t\t\tNamespace:    \"default\",\n\t\t\tKind:         \"AgentRuntime\",\n\t\t\tStatus:       \"running\",\n\t\t\tCreatedAt:    time.Now(),\n\t\t\tExpiresAt:    time.Now().Add(8 * time.Hour),\n\t\t}\n\n\t\terr := redisStore.StoreSandbox(ctx, sessionID, sandboxInfo)\n\t\trequire.NoError(t, err)\n\n\t\tmockK8s.On(\"DeleteSandbox\", ctx, \"default\", \"test-sandbox\").Return(assert.AnError)\n\n\t\tresp, err := controller.DeleteSession(ctx, sessionID)\n\n\t\trequire.Error(t, err)\n\t\tassert.Nil(t, resp)\n\t\tassert.Contains(t, err.Error(), \"failed to delete sandbox\")\n\n\t\tmockK8s.AssertExpectations(t)\n\t})\n}\n\nfunc extractSessionIDFromName(name string) string {\n\treturn \"session-\" + name\n}\n\nfunc TestBuildAgentRuntimeSandboxCR(t *testing.T) {\n\ts := miniredis.RunT(t)\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n\n\tcr, err := controller.buildAgentRuntimeSandboxCR(agentRuntime, \"session-123\", \"test-runtime-abc\", \"test-runtime\", \"default\")\n\n\trequire.NoError(t, err)\n\trequire.NotNil(t, cr)\n\n\tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", cr.GetAPIVersion())\n\tassert.Equal(t, \"Sandbox\", cr.GetKind())\n\tassert.Equal(t, \"test-runtime-abc\", cr.GetName())\n\tassert.Equal(t, \"default\", cr.GetNamespace())\n\n\tlabels := cr.GetLabels()\n\tassert.NotNil(t, labels)\n\tassert.Equal(t, \"agentcube-workload-manager\", labels[\"managed-by\"])\n\tassert.Equal(t, \"session-123\", labels[\"runtime.agentcube.io/session-id\"])\n\tassert.Equal(t, \"test-runtime\", labels[\"runtime.agentcube.io/workload-name\"])\n\n\tannotations := cr.GetAnnotations()\n\tassert.NotNil(t, annotations)\n\tassert.Equal(t, \"15m\", annotations[\"runtime.agentcube.io/idle-timeout\"])\n}\n\nfunc TestBuildCodeInterpreterSandboxCR(t *testing.T) {\n\ts := miniredis.RunT(t)\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tcodeInterpreter := createCodeInterpreter(\"test-interpreter\", \"default\")\n\n\tports := []interface{}{\n\t\tmap[string]interface{}{\n\t\t\t\"port\":     int64(8080),\n\t\t\t\"protocol\": \"HTTP\",\n\t\t},\n\t}\n\n\tcr, err := controller.buildCodeInterpreterSandboxCR(codeInterpreter, \"session-456\", \"test-interpreter-xyz\", \"test-interpreter\", \"default\", ports)\n\n\trequire.NoError(t, err)\n\trequire.NotNil(t, cr)\n\n\tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", cr.GetAPIVersion())\n\tassert.Equal(t, \"Sandbox\", cr.GetKind())\n\tassert.Equal(t, \"test-interpreter-xyz\", cr.GetName())\n\tassert.Equal(t, \"default\", cr.GetNamespace())\n\n\tlabels := cr.GetLabels()\n\tassert.NotNil(t, labels)\n\tassert.Equal(t, \"agentcube-workload-manager\", labels[\"managed-by\"])\n\tassert.Equal(t, \"session-456\", labels[\"runtime.agentcube.io/session-id\"])\n\n\tannotations := cr.GetAnnotations()\n\tassert.NotNil(t, annotations)\n\tassert.Equal(t, \"15m\", annotations[\"runtime.agentcube.io/idle-timeout\"])\n}\n\nfunc TestBuildEntryPoints(t *testing.T) {\n\ts := miniredis.RunT(t)\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tt.Run(\"builds entry points from ports\", func(t *testing.T) {\n\t\tports := []interface{}{\n\t\t\tmap[string]interface{}{\n\t\t\t\t\"port\":       int64(8080),\n\t\t\t\t\"protocol\":   \"HTTP\",\n\t\t\t\t\"pathPrefix\": \"/api\",\n\t\t\t},\n\t\t\tmap[string]interface{}{\n\t\t\t\t\"port\":     int64(9090),\n\t\t\t\t\"protocol\": \"gRPC\",\n\t\t\t},\n\t\t}\n\n\t\tentryPoints := controller.buildEntryPoints(\"10.244.1.5\", ports)\n\n\t\trequire.Len(t, entryPoints, 2)\n\n\t\tassert.Equal(t, \"HTTP\", entryPoints[0].Protocol)\n\t\tassert.Equal(t, \"10.244.1.5:8080\", entryPoints[0].Endpoint)\n\t\tassert.Equal(t, \"/api\", entryPoints[0].Path)\n\t\tassert.Equal(t, int32(8080), entryPoints[0].Port)\n\n\t\tassert.Equal(t, \"gRPC\", entryPoints[1].Protocol)\n\t\tassert.Equal(t, \"10.244.1.5:9090\", entryPoints[1].Endpoint)\n\t\tassert.Equal(t, \"\", entryPoints[1].Path)\n\t\tassert.Equal(t, int32(9090), entryPoints[1].Port)\n\t})\n\n\tt.Run(\"handles malformed port entries\", func(t *testing.T) {\n\t\tports := []interface{}{\n\t\t\tmap[string]interface{}{\n\t\t\t\t\"port\":     int64(8080),\n\t\t\t\t\"protocol\": \"HTTP\",\n\t\t\t},\n\t\t\t\"invalid\",\n\t\t\tmap[string]interface{}{\n\t\t\t\t\"port\": int64(9090),\n\t\t\t},\n\t\t}\n\n\t\tentryPoints := controller.buildEntryPoints(\"10.244.1.5\", ports)\n\n\t\trequire.Len(t, entryPoints, 1)\n\t\tassert.Equal(t, \"HTTP\", entryPoints[0].Protocol)\n\t})\n}\n\nfunc TestGenerateSandboxName(t *testing.T) {\n\tname1 := generateSandboxName(\"test-runtime\")\n\tname2 := generateSandboxName(\"test-runtime\")\n\n\tassert.Contains(t, name1, \"test-runtime-\")\n\tassert.Contains(t, name2, \"test-runtime-\")\n\tassert.NotEqual(t, name1, name2)\n\tassert.Len(t, name1, len(\"test-runtime-\")+8)\n\tassert.Len(t, name2, len(\"test-runtime-\")+8)\n}\n\nfunc TestRandString(t *testing.T) {\n\tstr1 := RandString(8)\n\tstr2 := RandString(8)\n\n\tassert.Len(t, str1