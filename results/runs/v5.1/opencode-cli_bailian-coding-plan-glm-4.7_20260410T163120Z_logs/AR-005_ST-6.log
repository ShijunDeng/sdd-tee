, name string) (*corev1.Secret, error)\n30: }\n31: \n32: type K8sClient struct {\n33: \tclientset  kubernetes.Interface\n34: \tdynamic    dynamic.Interface\n35: \tconfig     *rest.Config\n36: \tgvrSandbox schema.GroupVersionResource\n37: \tgvrAgent   schema.GroupVersionResource\n38: \tgvrCode    schema.GroupVersionResource\n39: }\n40: \n41: func NewK8sClient(config *rest.Config) (*K8sClient, error) {\n42: \tclientset, err := kubernetes.NewForConfig(config)\n43: \tif err != nil {\n44: \t\treturn nil, fmt.Errorf(\"failed to create kubernetes clientset: %w\", err)\n45: \t}\n46: \n47: \tdynamicClient, err := dynamic.NewForConfig(config)\n48: \tif err != nil {\n49: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n50: \t}\n51: \n52: \treturn &K8sClient{\n53: \t\tclientset: clientset,\n54: \t\tdynamic:   dynamicClient,\n55: \t\tconfig:    config,\n56: \t\tgvrSandbox: schema.GroupVersionResource{\n57: \t\t\tGroup:    \"agents.x-k8s.io\",\n58: \t\t\tVersion:  \"v1alpha1\",\n59: \t\t\tResource: \"sandboxes\",\n60: \t\t},\n61: \t\tgvrAgent: schema.GroupVersionResource{\n62: \t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n63: \t\t\tVersion:  \"v1alpha1\",\n64: \t\t\tResource: \"agentruntimes\",\n65: \t\t},\n66: \t\tgvrCode: schema.GroupVersionResource{\n67: \t\t\tGroup:    \"runtime.agentcube.volcano.sh\",\n68: \t\t\tVersion:  \"v1alpha1\",\n69: \t\t\tResource: \"codeinterpreters\",\n70: \t\t},\n71: \t}, nil\n72: }\n73: \n74: func (c *K8sClient) GetAgentRuntime(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n75: \treturn c.dynamic.Resource(c.gvrAgent).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n76: }\n77: \n78: func (c *K8sClient) GetCodeInterpreter(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n79: \treturn c.dynamic.Resource(c.gvrCode).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n80: }\n81: \n82: func (c *K8sClient) CreateSandbox(ctx context.Context, namespace string, sandbox *unstructured.Unstructured) (*unstructured.Unstructured, error) {\n83: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Create(ctx, sandbox, metav1.CreateOptions{})\n84: }\n85: \n86: func (c *K8sClient) GetSandbox(ctx context.Context, namespace, name string) (*unstructured.Unstructured, error) {\n87: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Get(ctx, name, metav1.GetOptions{})\n88: }\n89: \n90: func (c *K8sClient) DeleteSandbox(ctx context.Context, namespace, name string) error {\n91: \treturn c.dynamic.Resource(c.gvrSandbox).Namespace(namespace).Delete(ctx, name, metav1.DeleteOptions{})\n92: }\n93: \n94: func (c *K8sClient) GetPodIP(ctx context.Context, sandboxName, namespace string, sandbox *unstructured.Unstructured) (string, error) {\n95: \tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n96: \tif err == nil && pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n97: \t\treturn pod.Status.PodIP, nil\n98: \t}\n99: \n100: \tannotations := sandbox.GetAnnotations()\n101: \tconst podNameAnnotation = \"agents.x-k8s.io/sandbox-pod-name\"\n102: \tif podName, ok := annotations[podNameAnnotation]; ok && podName != \"\" {\n103: \t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, podName, metav1.GetOptions{})\n104: \t\tif err == nil {\n105: \t\t\tif pod.Status.Phase != corev1.PodRunning {\n106: \t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n107: \t\t\t}\n108: \t\t\tif pod.Status.PodIP == \"\" {\n109: \t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n110: \t\t\t}\n111: \t\t\treturn pod.Status.PodIP, nil\n112: \t\t}\n113: \t}\n114: \n115: \tpods, err := c.clientset.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{\n116: \t\tLabelSelector: labels.SelectorFromSet(labels.Set{\n117: \t\t\tconstants.LabelSandboxName: sandboxName,\n118: \t\t}).String(),\n119: \t})\n120: \tif err != nil {\n121: \t\treturn \"\", fmt.Errorf(\"failed to list pods: %w\", err)\n122: \t}\n123: \n124: \tfor _, p := range pods.Items {\n125: \t\tfor _, ownerRef := range p.OwnerReferences {\n126: \t\t\tif ownerRef.Kind == \"Sandbox\" && ownerRef.Name == sandboxName {\n127: \t\t\t\tif p.Status.Phase != corev1.PodRunning {\n128: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod is not running\")\n129: \t\t\t\t}\n130: \t\t\t\tif p.Status.PodIP == \"\" {\n131: \t\t\t\t\treturn \"\", fmt.Errorf(\"pod has no IP\")\n132: \t\t\t\t}\n133: \t\t\t\treturn p.Status.PodIP, nil\n134: \t\t\t}\n135: \t\t}\n136: \t}\n137: \n138: \treturn \"\", fmt.Errorf(\"pod not found for sandbox\")\n139: }\n140: \n141: func (c *K8sClient) WatchPods(ctx context.Context, namespace string, sandboxName string) (<-chan string, error) {\n142: \tpodCh := make(chan string, 1)\n143: \n144: \tgo func() {\n145: \t\tdefer close(podCh)\n146: \n147: \t\tticker := time.NewTicker(2 * time.Second)\n148: \t\tdefer ticker.Stop()\n149: \n150: \t\tfor {\n151: \t\t\tselect {\n152: \t\t\tcase <-ctx.Done():\n153: \t\t\t\treturn\n154: \t\t\tcase <-ticker.C:\n155: \t\t\t\tpod, err := c.clientset.CoreV1().Pods(namespace).Get(ctx, sandboxName, metav1.GetOptions{})\n156: \t\t\t\tif err != nil {\n157: \t\t\t\t\tif apierrors.IsNotFound(err) {\n158: \t\t\t\t\t\tcontinue\n159: \t\t\t\t\t}\n160: \t\t\t\t\tklog.Errorf(\"Failed to get pod: %v\", err)\n161: \t\t\t\t\tcontinue\n162: \t\t\t\t}\n163: \n164: \t\t\t\tif pod.Status.Phase == corev1.PodRunning && pod.Status.PodIP != \"\" {\n165: \t\t\t\t\tselect {\n166: \t\t\t\t\tcase podCh <- pod.Status.PodIP:\n167: \t\t\t\t\tdefault:\n168: \t\t\t\t\t}\n169: \t\t\t\t\treturn\n170: \t\t\t\t}\n171: \t\t\t}\n172: \t\t}\n173: \t}()\n174: \n175: \treturn podCh, nil\n176: }\n177: \n178: func (c *K8sClient) GetSecret(ctx context.Context, namespace, name string) (*corev1.Secret, error) {\n179: \treturn c.clientset.CoreV1().Secrets(namespace).Get(ctx, name, metav1.GetOptions{})\n180: }\n\n(End of file - total 180 lines)\n</content>","metadata":{"preview":"package cl