ations[\"idle-timeout\"])\n531: }\n532: \n533: func TestBuildCodeInterpreterSandboxCR(t *testing.T) {\n534: \ts := miniredis.RunT(t)\n535: \tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n536: \trequire.NoError(t, err)\n537: \tdefer redisStore.Close()\n538: \n539: \tmockK8s := new(MockK8sClient)\n\n(Showing lines 500-539 of 684. Use offset=540 to continue.)\n</content>","metadata":{"preview":"\nfunc TestBuildAgentRuntimeSandboxCR(t *testing.T) {\n\ts := miniredis.RunT(t)\n\tredisStore, err := store.NewValkeyStore(s.Addr(), \"\", 0)\n\trequire.NoError(t, err)\n\tdefer redisStore.Close()\n\n\tmockK8s := new(MockK8sClient)\n\tcontroller := NewSandboxController(mockK8s, redisStore)\n\n\tagentRuntime := createAgentRuntime(\"test-runtime\", \"default\")\n\n\tcr, err := controller.buildAgentRuntimeSandboxCR(agentRuntime, \"session-123\", \"test-runtime-abc\", \"test-runtime\", \"default\")\n\n\trequire.NoError(t, err)\n\trequire.NotNil(t, cr)\n\n\tassert.Equal(t, \"agents.x-k8s.io/v1alpha1\", cr.GetAPIVersion())\n\tassert.Equal(t, \"Sandbox\", cr.GetKind())\n\tassert.Equal(t, \"test-runtime-abc\", cr.GetName())","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-4.7_20260410T163120Z/pkg/workloadmanager/controller/sandbox_test.go","time":{"start":1775844354323,"end":1775844354337}}}}
