teSandboxBySessionID (success, not found, empty ID)\n- ListExpiredSandboxes (success, limit, zero/negative limit, skip missing, empty)\n- ListInactiveSandboxes (success, limit, zero/negative limit, empty)\n- UpdateSessionLastActivity (success, zero time, not found, empty ID)\n- Close\n- NewRedisStore/NewRedisStoreWithOptions/NewRedisStoreWithClient\n- Error handling\n- Constants\n- ResetStorage\n- makeRedisOptions\n- newValkeyStoreFromEnv\n- Storage singleton (Redis/Valkey providers)\n- Session key generation\n\n#### 6.2.2 Valkey Store Tests (valkey_test.go)\n\n```go\n// Tests needed to match Redis coverage:\nfunc TestValkeyStore_Ping(t *testing.T)\nfunc TestValkeyStore_GetSandboxBySessionID_Success(t *testing.T)\nfunc TestValkeyStore_GetSandboxBySessionID_NotFound(t *testing.T)\nfunc TestValkeyStore_StoreSandbox_Success(t *testing.T)\nfunc TestValkeyStore_StoreSandbox_Duplicate(t *testing.T)\nfunc TestValkeyStore_UpdateSandbox_Success(t *testing.T)\nfunc TestValkeyStore_DeleteSandboxBySessionID_Success(t *testing.T)\nfunc TestValkeyStore_ListExpiredSandboxes_Success(t *testing.T)\nfunc TestValkeyStore_ListInactiveSandboxes_Success(t *testing.T)\nfunc TestValkeyStore_UpdateSessionLastActivity_Success(t *testing.T)\nfunc TestValkeyStore_Close(t *testing.T)\nfunc TestNewValkeyStore(t *testing.T)\nfunc TestNewValkeyStoreWithOptions(t *testing.T)\nfunc TestNewValkeyStoreWithClient(t *testing.T)\n```\n\n### 6.3 pkg/picod Tests\n\n#### 6.3.1 picod_test.go - Already comprehensive (1109 lines)\n\nCoverage includes:\n- Config\n- Path sanitization (valid, absolute, traversal, null byte, symlink)\n- Auth middleware (missing header, invalid format, expired, HS256, valid)\n- Execute handler (valid command, empty command, timeout, invalid timeout, working dir, path escape, env, exit code)\n- File upload (multipart, JSON, invalid base64, path escape, invalid mode, parent dir creation)\n- File list (valid, missing path, path escape, non-existent, empty)\n- File download (existing, leading slash, path escape, not found, is directory, symlink, MIME types)\n- Health check\n- Public key loading (missing, invalid PEM, PKCS1, valid)\n- File mode parsing\n- Server shutdown\n- File lifecycle\n- Large file upload\n- Concurrent operations\n\n#### 6.3.2 auth_test.go\n\n```go\n// Additional tests needed:\nfunc TestAuthManagerConcurrentPublicKeyUpdate(t *testing.T)\nfunc TestAuthManagerMultipleTokenValidation(t *testing.T)\nfunc TestAuthMiddlewareMaxBodySize(t *testing.T)\n```\n\n#### 6.3.3 execute_test.go\n\n```go\n// Additional tests needed:\nfunc TestExecuteHandlerCommandNotFound(t *testing.T)\nfunc TestExecuteHandlerStdinHandling(t *testing.T)\nfunc TestExecuteHandlerLargeOutput(t *testing.T)\nfunc TestExecuteHandlerComplexCommand(t *testing.T)\nfunc TestExecuteHandlerDefaultTimeout(t *testing.T)\nfunc TestExecuteHandlerWorkingDirAbsolutePath(t *testing.T)\n```\n\n#### 6.3.4 files_test.go\n\n```go\n// Additional tests needed:\nfunc TestUploadFileHandlerOverwrite(t *testing.T)\nfunc TestUploadFileHandlerSpecialCharacters(t *testing.T)\nfunc TestListFilesHandlerNestedDirectories(t *testing.T)\nfunc TestDownloadFileHandlerSpecialCharacters(t *testing.T)\nfunc TestDownloadFileHandlerRangeRequest(t *testing.T)\n```\n\n---\n\n## 7. Table-Driven Test Patterns\n\n### 7.1 Error Type Tests\n\n```go\nfunc TestAPIStatusInterface(t *testing.T) {\n    tests := []struct {\n        name     string\n        err      APIStatus\n        expected struct {\n            status int\n            code   string\n            message string\n        }\n    }{\n        {\n            name: \"SessionNotFoundError\",\n            err: &SessionNotFoundError{SessionID: \"test\"},\n            expected: struct{status int; code string; message string}{\n                status: 404,\n                code: \"SESSION_NOT_FOUND\",\n                message: \"session not found\",\n            },\n        },\n        // ... more cases\n    }\n    \n    for _, tt := range tests {\n        t.Run(tt.name, func(t *testing.T) {\n            assert.Equal(t, tt.expected.status, tt.err.Status())\n            assert.Equal(t, tt.expected.code, tt.err.Code())\n            assert.Equal(t, tt.expected.message, tt.err.Message())\n        })\n    }\n}\n```\n\n### 7.2 Store Method Tests\n\n```go\nfunc TestRedisStore_StoreSandbox(t *testing.T) {\n    tests := []struct {\n        name    string\n        sandbox *types.SandboxInfo\n        wantErr error\n    }{\n        {\n            name:    \"nil sandbox\",\n            sandbox: nil,\n            wantErr: ErrNilSandbox,\n        },\n        {\n            name: \"empty sessionID\",\n            sandbox: &types.SandboxInfo{\n                SessionID: \"\",\n                ExpiresAt: time.Now().Add(1 * time.Hour),\n            },\n            wantErr: ErrEmptySessionID,\n        },\n        {\n            name: \"zero expiresAt\",\n            sandbox: &types.SandboxInfo{\n                SessionID: \"test\",\n                ExpiresAt: time.Time{},\n            },\n            wantErr: ErrZeroExpiresAt,\n        },\n        {\n            name: \"valid sandbox\",\n            sandbox: makeTestSandbox(\"test-session\"),\n            wantErr: nil,\n        },\n    }\n    \n    store := setupTestRedisStore(t)\n    ctx := context.Background()\n    \n    for _, tt := range tests {\n        t.Run(tt.name, func(t *testing.T) {\n            err := store.StoreSandbox(ctx, tt.sandbox)\n            if tt.wantErr != nil {\n                assert.ErrorIs(t, err, tt.wantErr)\n            } else {\n                assert.NoError(t, err)\n            }\n        })\n    }\n}\n```\n\n### 7.3 Path Sanitization Tests\n\n```go\nfunc TestSanitizePath(t *testing.T) {\n    tests := []struct {\n        name        string\n        workspace   string\n        requested   string\n        wantErr     bool\n        errContains string\n    }{\n        {\n            name:      \"valid relative\",\n            workspace: \"/workspace\",\n            requested: \"subdir/file.txt\",\n            wantErr:   false,\n        },\n        {\n            name:        \"path traversal\",\n            workspace:   \"/workspace\",\n            requested:   \"../escape.txt\",\n            wantErr:     true,\n            errContains: \"path escape\",\n        },\n        {\n            name:        \"deep traversal\",\n            workspace:   \"/workspace\",\n            requested:   \"subdir/../../escape.txt\",\n            wantErr:     true,\n            errContains: \"path escape\",\n        },\n        {\n            name:      \"null byte\",\n            workspace: \"/workspace\",\n            requested: \"file\\x00.txt\",\n            wantErr:   false,\n        },\n    }\n    \n    for _, tt := range tests {\n        t.Run(tt.name, func(t *testing.T) {\n            workspace := t.TempDir()\n            result, err := sanitizePath(workspace, tt.requested)\n            if tt.wantErr {\n                assert.Error(t, err)\n                assert.Contains(t, err.Error(), tt.errContains)\n            } else {\n                assert.NoError(t, err)\n                assert.Contains(t, result, workspace)\n            }\n        })\n    }\n}\n```\n\n---\n\n## 8. Test Execution Commands\n\n### 8.1 Running Tests\n\n```bash\n# Run all tests\ngo test ./pkg/... -v\n\n# Run specific module tests\ngo test ./pkg/router/... -v\ngo test ./pkg/store/... -v\ngo test ./pkg/picod/... -v\n\n# Run with coverage\ngo test ./pkg/... -cover -coverprofile=coverage.out\n\n# View coverage by function\ngo tool cover -func=coverage.out\n\n# Generate HTML coverage report\ngo tool cover -html=coverage.out -o coverage.html\n\n# Run specific test\ngo test ./pkg/router -run TestJWTManager -v\n\n# Run tests matching pattern\ngo test ./pkg/store -run TestRedisStore -v\n\n# Run with race detector\ngo test ./pkg/... -race\n```\n\n### 8.2 Test Coverage Verification\n\n```bash\n# Verify minimum coverage\ngo test ./pkg/router -cover -covermode=count\ngo test ./pkg/store -cover -covermode=count\ngo test ./pkg/picod -cover -covermode=count\n\n# Enforce coverage thresholds (using go-carpet or custom script)\n#!/bin/bash\nCOVERAGE=$(go test ./pkg/router -cover | grep coverage | awk '{print $4}' | sed 's/%//')\nif [ \"$COVERAGE\" -lt 90 ]; then\n    echo \"Router coverage below 90%\"\n    exit 1\nfi\n```\n\n---\n\n## 9. Test Fixtures and Test Data\n\n### 9.1 Test Sandbox Data\n\n```go\nfunc makeTestSandbox(sessionID string) *types.SandboxInfo {\n    now := time.Now()\n    return &types.SandboxInfo{\n        Kind:             types.AgentRuntimeKind,\n        SandboxID:        \"sb-\" + sessionID,\n        SandboxNamespace: \"default\",\n        SandboxName:      \"test-sandbox\",\n        Name:             \"test-sandbox\",\n        SessionID:        sessionID,\n        CreatedAt:        now,\n        ExpiresAt:        now.Add(24 * time.Hour),\n        Status:           \"active\",\n        EntryPoints: []types.SandboxEntryPoint{\n            {Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:8080\"},\n        },\n    }\n}\n```\n\n### 9.2 Test JWT Generation\n\n```go\nfunc generateTestJWT(privateKey *rsa.PrivateKey, expired bool) string {\n    now := time.Now()\n    expiry := now.Add(5 * time.Minute)\n    if expired {\n        expiry = now.Add(-5 * time.Minute)\n    }\n    \n    claims := jwt.MapClaims{\n        \"exp\": expiry.Unix(),\n        \"iat\": now.Unix(),\n        \"iss\": \"test-issuer\",\n    }\n    \n    token := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n    tokenString, _ := token.SignedString(privateKey)\n    return tokenString\n}\n```\n\n### 9.3 Test RSA Keys\n\n```go\nfunc generateTestRSAKey(t *testing.T) (*rsa.PrivateKey, string) {\n    privateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n    require.NoError(t, err)\n    \n    publicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n    return privateKey, publicKeyPEM\n}\n\nfunc encodePublicKeyPEMForTest(key *rsa.PublicKey) string {\n    bytes, _ := x509.MarshalPKIXPublicKey(key)\n    pemData := pem.EncodeToMemory(&pem.Block{\n        Type:  \"PUBLIC KEY\",\n        Bytes: bytes,\n    })\n    return string(pemData)\n}\n```\n\n---\n\n## 10. Benchmark Tests\n\n### 10.1 Store Benchmarks\n\n```go\nfunc BenchmarkRedisStore_StoreSandbox(b *testing.B) {\n    mr := miniredis.RunT(b)\n    store := setupTestRedisStore(b)\n    ctx := context.Background()\n    \n    sandbox := makeTestSandbox(\"bench-session\")\n    \n    b.ResetTimer()\n    for i := 0; i < b.N; i++ {\n        sandbox.SessionID = fmt.Sprintf(\"bench-%d\", i)\n        store.StoreSandbox(ctx, sandbox)\n    }\n}\n\nfunc BenchmarkRedisStore_GetSandboxBySessionID(b *testing.B) {\n    mr := miniredis.RunT(b)\n    store := setupTestRedisStore(b)\n    ctx := context.Background()\n    \n    for i := 0; i < 1000; i++ {\n        sandbox := makeTestSandbox(fmt.Sprintf(\"bench-%d\", i))\n        store.StoreSandbox(ctx, sandbox)\n    }\n    \n    b.ResetTimer()\n    for i := 0; i < b.N; i++ {\n        store.GetSandboxBySessionID(ctx, fmt.Sprintf(\"bench-%d\", i%1000))\n    }\n}\n```\n\n### 10.2 JWT Benchmarks\n\n```go\nfunc BenchmarkJWTManager_GenerateToken(b *testing.B) {\n    jwtMgr, _ := NewJWTManager()\n    claims := map[string]interface{}{\n        \"session_id\": \"test-session\",\n        \"sandbox_id\": \"test-sandbox\",\n    }\n    \n    b.ResetTimer()\n    for i := 0; i < b.N; i++ {\n        jwtMgr.GenerateToken(claims)\n    }\n}\n\nfunc BenchmarkJWTManager_ValidateToken(b *testing.B) {\n    jwtMgr, _ := NewJWTManager()\n    token, _ := jwtMgr.GenerateToken(map[string]interface{}{\n        \"session_id\": \"test\",\n    })\n    \n    b.ResetTimer()\n    for i := 0; i < b.N; i++ {\n        jwtMgr.ValidateToken(token)\n    }\n}\n```\n\n---\n\n## 11. Test Environment Setup\n\n### 11.1 Environment Variables for Testing\n\n```go\n// Router tests\nt.Setenv(\"WORKLOAD_MANAGER_URL\", \"http://localhost:9090\")\n\n// Store tests (Redis)\nt.Setenv(\"STORE_TYPE\", \"redis\")\nt.Setenv(\"REDIS_ADDR\", mr.Addr())\nt.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n\n// Store tests (Valkey)\nt.Setenv(\"STORE_TYPE\", \"valkey\")\nt.Setenv(\"VALKEY_ADDR\", mr.Addr())\nt.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\n// PicoD tests\nt.Setenv(PublicKeyEnvVar, publicKeyPEM)\n```\n\n### 11.2 Cleanup Patterns\n\n```go\nfunc setupTestServer(t *testing.T) *Server {\n    t.Helper()\n    \n    workspace := t.TempDir() // Automatic cleanup\n    \n    // Set environment with cleanup\n    oldEnv := os.Getenv(PublicKeyEnvVar)\n    os.Setenv(PublicKeyEnvVar, publicKeyPEM)\n    t.Cleanup(func() {\n        if oldEnv != \"\" {\n            os.Setenv(PublicKeyEnvVar, oldEnv)\n        } else {\n            os.Unsetenv(PublicKeyEnvVar)\n        }\n    })\n    \n    server, err := NewServer(&Config{\n        Port:      8080,\n        Workspace: workspace,\n    })\n    require.NoError(t, err)\n    \n    return server\n}\n```\n\n---\n\n## 12. Test File Organization\n\n### 12.1 Test File Structure\n\n```\npkg/\n├── router/\n│   ├── server.go\n│   ├── server_test.go          # Server HTTP tests\n│   ├── config.go\n│   ├── config_test.go          # Config tests\n│   ├── jwt.go\n│   ├── jwt_test.go             # JWT manager tests\n│   ├── errors.go\n│   ├── errors_test.go          # Error type tests\n│   ├── middleware.go\n│   ├── middleware_test.go      # Middleware tests\n│   ├── session_manager.go\n│   ├── session_manager_test.go # Session manager tests\n│   ├── reverse_proxy.go\n│   ├── reverse_proxy_test.go   # Reverse proxy tests\n│   ├── doc.go\n│   └── doc_test.go             # Package documentation tests (if needed)\n│\n├── store/\n│   ├── store.go\n│   ├── store_test.go           # Store interface + Redis tests\n│   ├── store_redis.go\n│   ├── store_valkey.go\n│   ├── valkey_test.go          # Valkey-specific tests\n│   ├── doc.go\n│   └── doc_test.go\n│\n├── picod/\n│   ├── server.go\n│   ├── server_test.go          # Server tests (if needed)\n│   ├── config.go\n│   ├── auth.go\n│   ├── auth_test.go            # Auth manager tests\n│   ├── execute.go\n│   ├── execute_test.go         # Execute handler tests\n│   ├── files.go\n│   ├── files_test.go           # Files handler tests\n│   ├── sanitize.go\n│   ├── sanitize_test.go        # Path sanitization tests\n│   ├── health.go\n│   ├── health_test.go          # Health check tests\n│   ├── picod_test.go           # Integration tests\n│   └── doc.go\n│\n└── common/\n│   └── types/\n│       ├── sandbox.go\n│       ├── sandbox_test.go     # Type validation tests\n│       └── doc.go\n```\n\n---\n\n## 13. Continuous Integration\n\n### 13.1 CI Test Configuration\n\n```yaml\n# .github/workflows/test.yml\nname: Tests\n\non: [push, pull_request]\n\njobs:\n  test:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - uses: actions/setup-go@v5\n        with:\n          go-version: '1.22'\n      \n      - name: Run tests\n        run: go test ./pkg/... -v -race -coverprofile=coverage.out\n      \n      - name: Upload coverage\n        uses: codecov/codecov-action@v4\n        with:\n          files: coverage.out\n      \n      - name: Enforce coverage\n        run: |\n          COVERAGE=$(go tool cover -func=coverage.out | grep total | awk '{print $3}' | sed 's/%//')\n          echo \"Total coverage: ${COVERAGE}%\"\n          if [ \"${COVERAGE}\" -lt 85 ]; then\n            echo \"Coverage below 85%\"\n            exit 1\n          fi\n```\n\n---\n\n## 14. Summary\n\n### Current Test Coverage Status\n\n| Module | Test File | Lines | Tests Count | Coverage |\n|--------|-----------|-------|-------------|----------|\n| router | server_test.go | 380 | 15+ | ~80% |\n| router | middleware_test.go | 305 | 13 | ~90% |\n| router | errors_test.go | 189 | 14 | 100% |\n| router | jwt_test.go | needed | - | - |\n| router | config_test.go | needed | - | - |\n| router | reverse_proxy_test.go | needed | - | - |\n| router | session_manager_te