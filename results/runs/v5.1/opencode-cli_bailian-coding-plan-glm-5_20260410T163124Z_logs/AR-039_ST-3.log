\n51: \tgin.SetMode(gin.TestMode)\n52: \n53: \trouter := gin.New()\n54: \trouter.Use(concurrencyLimitMiddleware(1))\n55: \trouter.GET(\"/test\", func(c *gin.Context) {\n56: \t\ttime.Sleep(100 * time.Millisecond)\n57: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n58: \t})\n59: \n60: \tvar wg sync.WaitGroup\n61: \tresults := make([]int, 3)\n62: \n63: \tfor i := 0; i < 3; i++ {\n64: \t\twg.Add(1)\n65: \t\tgo func(idx int) {\n66: \t\t\tdefer wg.Done()\n67: \t\t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n68: \t\t\tw := httptest.NewRecorder()\n69: \t\t\trouter.ServeHTTP(w, req)\n70: \t\t\tresults[idx] = w.Code\n71: \t\t}(i)\n72: \t}\n73: \n74: \twg.Wait()\n75: \n76: \thasOverloaded := false\n77: \thasOk := false\n78: \tfor _, code := range results {\n79: \t\tif code == http.StatusTooManyRequests {\n80: \t\t\thasOverloaded = true\n81: \t\t}\n82: \t\tif code == http.StatusOK {\n83: \t\t\thasOk = true\n84: \t\t}\n85: \t}\n86: \n87: \tif !hasOverloaded {\n88: \t\tt.Error(\"expected at least one 429 response\")\n89: \t}\n90: \tif !hasOk {\n91: \t\tt.Error(\"expected at least one 200 response\")\n92: \t}\n93: }\n94: \n95: func TestConcurrencyLimitMiddlewareDefault(t *testing.T) {\n96: \tgin.SetMode(gin.TestMode)\n97: \n98: \trouter := gin.New()\n99: \trouter.Use(concurrencyLimitMiddleware(0))\n100: \trouter.GET(\"/test\", func(c *gin.Context) {\n101: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n102: \t})\n103: \n104: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n105: \tw := httptest.NewRecorder()\n106: \n107: \trouter.ServeHTTP(w, req)\n108: \n109: \tif w.Code != http.StatusOK {\n110: \t\tt.Errorf(\"unexpected status code with default limit: %d\", w.Code)\n111: \t}\n112: }\n113: \n114: func TestConcurrencyLimitMiddlewareNegative(t *testing.T) {\n115: \tgin.SetMode(gin.TestMode)\n116: \n117: \trouter := gin.New()\n118: \trouter.Use(concurrencyLimitMiddleware(-5))\n119: \trouter.GET(\"/test\", func(c *gin.Context) {\n120: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n121: \t})\n122: \n123: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n124: \tw := httptest.NewRecorder()\n125: \n126: \trouter.ServeHTTP(w, req)\n127: \n128: \tif w.Code != http.StatusOK {\n129: \t\tt.Errorf(\"unexpected status code with negative limit: %d\", w.Code)\n130: \t}\n131: }\n132: \n133: func TestLoggingMiddleware(t *testing.T) {\n134: \tgin.SetMode(gin.TestMode)\n135: \n136: \tlogger := &MockLogger{}\n137: \trouter := gin.New()\n138: \trouter.Use(loggingMiddleware(logger))\n139: \trouter.GET(\"/test\", func(c *gin.Context) {\n140: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n141: \t})\n142: \n143: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n144: \tw := httptest.NewRecorder()\n145: \n146: \trouter.ServeHTTP(w, req)\n147: \n148: \tif len(logger.InfoCalls) != 1 {\n149: \t\tt.Errorf(\"expected 1 info log call, got %d\", len(logger.InfoCalls))\n150: \t}\n151: \tif logger.InfoCalls[0] != \"request\" {\n152: \t\tt.Errorf(\"unexpected log message: %s\", logger.InfoCalls[0])\n153: \t}\n154: }\n155: \n156: func TestLoggingMiddlewareDifferentStatus(t *testing.T) {\n157: \tgin.SetMode(gin.TestMode)\n158: \n159: \tlogger := &MockLogger{}\n160: \trouter := gin.New()\n161: \trouter.Use(loggingMiddleware(logger))\n162: \trouter.GET(\"/test\", func(c *gin.Context) {\n163: \t\tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"internal\"})\n164: \t})\n165: \n166: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n167: \tw := httptest.NewRecorder()\n168: \n169: \trouter.ServeHTTP(w, req)\n170: \n171: \tif len(logger.InfoCalls) != 1 {\n172: \t\tt.Errorf(\"expected 1 info log call, got %d\", len(logger.InfoCalls))\n173: \t}\n174: }\n175: \n176: func TestRecoveryMiddleware(t *testing.T) {\n177: \tgin.SetMode(gin.TestMode)\n178: \n179: \tlogger := &MockLogger{}\n180: \trouter := gin.New()\n181: \trouter.Use(recoveryMiddleware(logger))\n182: \trouter.GET(\"/test\", func(c *gin.Context) {\n183: \t\tpanic(\"test panic\")\n184: \t})\n185: \n186: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n187: \tw := httptest.NewRecorder()\n188: \n189: \trouter.ServeHTTP(w, req)\n190: \n191: \tif w.Code != http.StatusInternalServerError {\n192: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n193: \t}\n194: \tif len(logger.ErrorCalls) != 1 {\n195: \t\tt.Errorf(\"expected 1 error log call, got %d\", len(logger.ErrorCalls))\n196: \t}\n197: }\n198: \n199: func TestRecoveryMiddlewareNoPanic(t *testing.T) {\n200: \tgin.SetMode(gin.TestMode)\n201: \n202: \tlogger := &MockLogger{}\n203: \trouter := gin.New()\n204: \trouter.Use(recoveryMiddleware(logger))\n205: \trouter.GET(\"/test\", func(c *gin.Context) {\n206: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n207: \t})\n208: \n209: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n210: \tw := httptest.NewRecorder()\n211: \n212: \trouter.ServeHTTP(w, req)\n213: \n214: \tif w.Code != http.StatusOK {\n215: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n216: \t}\n217: \tif len(logger.ErrorCalls) != 0 {\n218: \t\tt.Errorf(\"expected 0 error log calls, got %d\", len(logger.ErrorCalls))\n219: \t}\n220: }\n221: \n222: func TestConcurrencyMiddleware429ResponseFormat(t *testing.T) {\n223: \tgin.SetMode(gin.TestMode)\n224: \n225: \trouter := gin.New()\n226: \trouter.Use(concurrencyLimitMiddleware(1))\n227: \trouter.GET(\"/test\", func(c *gin.Context) {\n228: \t\ttime.Sleep(50 * time.Millisecond)\n229: \t\tc.JSON(http.StatusOK, gin.H{})\n230: \t})\n231: \n232: \tvar wg sync.WaitGroup\n233: \twg.Add(2)\n234: \n235: \tgo func() {\n236: \t\tdefer wg.Done()\n237: \t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n238: \t\tw := httptest.NewRecorder()\n239: \t\trouter.ServeHTTP(w, req)\n240: \t}()\n241: \n242: \ttime.Sleep(10 * time.Millisecond)\n243: \n244: \tgo func() {\n245: \t\tdefer wg.Done()\n246: \t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n24