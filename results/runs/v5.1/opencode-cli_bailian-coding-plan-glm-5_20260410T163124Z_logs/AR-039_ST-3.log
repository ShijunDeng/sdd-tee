es, &sandbox)\n287: \t}\n288: \n289: \treturn sandboxes, nil\n290: }\n291: \n292: func (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n293: \tif sessionID == \"\" {\n294: \t\treturn ErrEmptySessionID\n295: \t}\n296: \n297: \tkey := s.sessionKey(sessionID)\n298: \n299: \texists := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build())\n300: \tif exists.Error() != nil {\n301: \t\treturn fmt.Errorf(\"store: check exists: %w\", exists.Error())\n302: \t}\n303: \tcount, err := exists.AsInt64()\n304: \tif err != nil {\n305: \t\treturn fmt.Errorf(\"store: parse exists: %w\", err)\n306: \t}\n307: \tif count == 0 {\n308: \t\treturn ErrNotFound\n309: \t}\n310: \n311: \tif at.IsZero() {\n312: \t\tat = time.Now()\n313: \t}\n314: \n315: \tresp := s.cli.Do(ctx, s.cli.B().Zadd().Key(s.lastActivityIndexKey).\n316: \t\tScoreMember().ScoreMember(float64(at.Unix()), sessionID).Build())\n317: \tif resp.Error() != nil {\n318: \t\treturn fmt.Errorf(\"store: update last activity: %w\", resp.Error())\n319: \t}\n320: \n321: \treturn nil\n322: }\n323: \n324: func (s *valkeyStore) Close() error {\n325: \ts.cli.Close()\n326: \treturn nil\n327: }\n\n(End of file - total 327 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc newValkeyStore(opts *valkeyClientOption) (Store, error) {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_valkey.go","time":{"start":1775897903853,"end":1775897903882}}}}
