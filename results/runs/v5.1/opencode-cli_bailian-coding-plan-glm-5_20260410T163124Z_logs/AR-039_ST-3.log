146: \t}))\n147: \tdefer server.Close()\n148: \n149: \tmockStore := &MockStore{\n150: \t\tStoreSandboxFunc: func(ctx context.Context, sandbox *types.SandboxInfo) error {\n151: \t\t\treturn nil\n152: \t\t},\n153: \t}\n154: \n155: \tsm := &sessionManager{\n156: \t\tstoreClient:     mockStore,\n157: \t\tworkloadMgrAddr: server.URL,\n158: \t\thttpClient:      &http.Client{Timeout: 2 * time.Minute},\n159: \t}\n160: \n161: \tctx := context.Background()\n162: \tsandbox, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test-runtime\", types.AgentRuntimeKind)\n163: \tif err != nil {\n164: \t\tt.Fatalf(\"unexpected error: %v\", err)\n165: \t}\n166: \tif sandbox.SessionID != \"new-session-123\" {\n167: \t\tt.Errorf(\"unexpected session ID: %s\", sandbox.SessionID)\n168: \t}\n169: \tif sandbox.SandboxID != \"sandbox-456\" {\n170: \t\tt.Errorf(\"unexpected sandbox ID: %s\", sandbox.SandboxID)\n171: \t}\n172: }\n173: \n174: func TestSessionManagerCreateSandboxCodeInterpreter(t *testing.T) {\n175: \trespBody := types.CreateSandboxResponse{\n176: \t\tSessionID:   \"ci-session-123\",\n177: \t\tSandboxID:   \"ci-sandbox-456\",\n178: \t\tSandboxName: \"ci-sandbox\",\n179: \t\tEntryPoints: []types.SandboxEntryPoint{\n180: \t\t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n181: \t\t},\n182: \t}\n183: \trespBytes, _ := json.Marshal(respBody)\n184: \n185: \tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n186: \t\tif r.URL.Path != \"/v1/code-interpreter\" {\n187: \t\t\tt.Errorf(\"unexpected path: %s\", r.URL.Path)\n188: \t\t}\n189: \t\tw.WriteHeader(http.StatusOK)\n190: \t\tw.Write(respBytes)\n191: \t}))\n192: \tdefer server.Close()\n193: \n194: \tmockStore := &MockStore{\n195: \t\tStoreSandboxFunc: func(ctx context.Context, sandbox *types.SandboxInfo) error {\n196: \t\t\treturn nil\n197: \t\t},\n198: \t}\n199: \n200: \tsm := &sessionManager{\n201: \t\tstoreClient:     mockStore,\n202: \t\tworkloadMgrAddr: server.URL,\n203: \t\thttpClient:      &http.Client{Timeout: 2 * time.Minute},\n204: \t}\n205: \n206: \tctx := context.Background()\n207: \tsandbox, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test-ci\", types.CodeInterpreterKind)\n208: \tif err != nil {\n209: \t\tt.Fatalf(\"unexpected error: %v\", err)\n210: \t}\n211: \tif sandbox.SessionID != \"ci-session-123\" {\n212: \t\tt.Errorf(\"unexpected session ID: %s\", sandbox.SessionID)\n213: \t}\n214: \tif sandbox.Kind != types.CodeInterpreterKind {\n215: \t\tt.Errorf(\"unexpected kind: %s\", sandbox.Kind)\n216: \t}\n217: }\n218: \n219: func TestSessionManagerCreateSandboxWorkloadManagerError(t *testing.T) {\n220: \tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n221: \t\tw.WriteHeader(http.StatusInternalServerError)\n222: \t\tw.Write([]byte(\"internal error\"))\n223: \t}))\n224: \tdefer server.Close()\n225: \n226: \tmockStore := &MockStore{}\n227: \n228: \tsm := &sessionManager{\n229: \t\tstoreClient:     mockStore,\n230: \t\tworkloadMgrAddr: server.URL,\n231: \t\thttpClient:      &http.Client{Timeout: 2 * time.Minute},\n232: \t}\n233: \n234: \tctx := context.Background()\n235: \t_, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test-runtime\", types.AgentRuntimeKind)\n236: \tif err == nil {\n237: \t\tt.Error(\"expected error from workload manager\")\n238: \t}\n239: \tif _, ok := err.(*WorkloadManagerError); !ok {\n240: \t\tt.Errorf(\"expected WorkloadManagerError, got %T\", err)\n241: \t}\n242: }\n243: \n244: func TestSessionManagerCreateSandboxEmptySessionID(t *testing.T) {\n245: \trespBody := types.CreateSandboxResponse{\n246: \t\tSessionID:   \"\",\n247: \t\tSandboxID:   \"sandbox-456\",\n248: \t\tSandboxName: \"new-sandbox\",\n249: \t}\n250: \trespBytes, _ := json.Marshal(respBody)\n251: \n252: \tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n253: \t\tw.WriteHeader(http.StatusOK)\n254: \t\tw.Write(respBytes)\n255: \t}))\n256: \tdefer server.Close()\n257: \n258: \tmockStore := &MockStore{}\n259: \n260: \tsm := &sessionManager{\n261: \t\tstoreClient:     mockStore,\n262: \t\tworkloadMgrAddr: server.URL,\n263: \t\thttpClient:      &http.Client{Timeout: 2 * time.Minute},\n264: \t}\n265: \n266: \tctx := context.Background()\n267: \t_, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test-runtime\", types.AgentRuntimeKind)\n268: \tif err == nil {\n269: \t\tt.Error(\"expected error for empty sessionId in response\")\n270: \t}\n271: }\n272: \n273: func TestSessionManagerUnsupportedKind(t *testing.T) {\n274: \tmockStore := &MockStore{}\n275: \n276: \tsm := &sessionManager{\n277: \t\tstoreClient:     mockStore,\n278: \t\tworkloadMgrAddr: \"http://localhost:9090\",\n279: \t\thttpClient:      &http.Client{},\n280: \t}\n281: \n282: \tctx := context.Background()\n283: \t_, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test\", \"UnsupportedKind\")\n284: \tif err == nil {\n285: \t\tt.Error(\"expected error for unsupported kind\")\n286: \t}\n287: }\n288: \n289: func TestSelectEntryPoint(t *testing.T) {\n290: \tentryPoints := []types.SandboxEntryPoint{\n291: \t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:8080\"},\n292: \t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n293: \t}\n294: \n295: \tep := selectEntryPoint(entryPoints, \"/api/v1/resource\")\n296: \tif ep == nil {\n297: \t\tt.Fatal(\"expected entry point to be found\")\n298: \t}\n299: \tif ep.Path != \"/api\" {\n300: \t\tt.Errorf(\"unexpected entry point path: %s\", ep.Path)\n301: \t}\n302: \n303: \tep = selectEntryPoint(entryPoints, \"/execute/code\")\n304: \tif ep == nil {\n305: \t\tt.Fatal(\"expected entry point to be found\")\n306: \t}\n307: \tif ep.Path != \"/execute\" {\n308: \t\tt.Errorf(\"unexpected entry point path: %s\", ep.Path)\n309: \t}\n310: \n311: \tep = selectEntryPoint(entryPoints, \"/other/path\")\n312: \tif ep == nil {\n313: \t\tt.Fatal(\"expected default entry point\")\n314: \t}\n315: \tif ep.Path != \"/api\" {\n316: \t\tt.Errorf(\"expected first entry point as default, got: %s\", ep.Path)\n317: \t}\n318: \n319: \tep = selectEntryPoint([]types.SandboxEntryPoint{}, \"/any/path\")\n320: \tif ep != nil {\n321: \t\tt.Error(\"expected nil for empty entry points\")\n322: \t}\n323: }\n324: \n325: func TestBuildTargetURL(t *testing.T) {\n326: \tep := &types.SandboxEntryPoint{\n327: \t\tPath:     \"/api\",\n328: \t\tProtocol: \"http\",\n329: \t\tEndpoint: \"localhost:8080\",\n330: \t}\n331: \n332: \turl, err := buildTargetURL(ep)\n333: \tif err != nil {\n334: \t\tt.Fatalf(\"unexpected error: %v\", err)\n335: \t}\n336: \tif url.Scheme != \"http\" {\n337: \t\tt.Errorf(\"unexpected scheme: %s\", url.Scheme)\n338: \t}\n339: \tif url.Host != \"localhost:8080\" {\n340: \t\tt.Errorf(\"unexpected host: %s\", url.Host)\n341: \t}\n342: \n343: \tep = &types.SandboxEntryPoint{\n344: \t\tPath:     \"/api\",\n345: \t\tProtocol: \"\",\n346: \t\tEndpoint: \"http://localhost:9000\",\n347: \t}\n348: \n349: \turl, err = buildTargetURL(ep)\n350: \tif err != nil {\n351: \t\tt.Fatalf(\"unexpected error: %v\", err)\n352: \t}\n353: \tif url.Scheme != \"http\" {\n354: \t\tt.Errorf(\"unexpected scheme: %s\", url.Scheme)\n355: \t}\n356: }\n357: \n358: func TestReadServiceAccountToken(t *testing.T) {\n359: \ttoken, err := readServiceAccountToken()\n360: \tif err != nil {\n361: \t\tt.Logf(\"expected error when not in cluster: %v\", err)\n362: \t}\n363: \tif token != \"\" && len(token) < 10 {\n364: \t\tt.Errorf(\"unexpected token length: %d\", len(token))\n365: \t}\n366: }\n\n(End of file - total 366 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"io\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype MockStore struct {\n\tGetSandboxBySessionIDFunc     func(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n\tStoreSandboxFunc              func(ctx context.Context, sandbox *types.SandboxInfo) error\n\tUpdateSessionLastActivityFunc func(ctx context.Context, sessionID string, at time.Time) error\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager_test.go","time":{"start":1775897921746,"end":1775897921754}}}}
{"type":"tool_use","timestamp":1775897921768,"sessionID":"ses_2843d4176ffeAKdOiytawM05uH","part":{"id":"prt_d7bc3c4fd001ur5OoMUqosWest","messageID":"msg_d7bc3b6610018hszbT5CRachs1","sessionID":"ses_2843d4176ffeAKdOiytawM05uH","type":"tool","tool":"read","callID":"toolu_tool-0538ee32610840b09d7ce1ac30d846b5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go</path>\n<type>file</type>\n<content>\n1: package types\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"time\"\n6: )\n7: \n8: const (\n9: \tAgentRuntimeKind    = \"AgentRuntime\"\n10: \tCodeInterpreterKind = \"CodeInterpreter\"\n11: \tSandboxKind         = \"Sandbox\"\n12: \tSandboxClaimKind    = \"SandboxClaim\"\n13: )\n14: \n15: type CreateSandboxRequest struct {\n16: \tKind      string `json:\"kind\"`\n17: \tName      string `json:\"name\"`\n18: \tNamespace string `json:\"namespace\"`\n19: }\n20: \n21: func (r *CreateSandboxRequest) Validate() error {\n22: \tif r.Kind != AgentRuntimeKind && r.Kind != CodeInterpreterKind {\n23: \t\treturn fmt.Errorf(\"kind must be %s or %s\", AgentRuntimeKind, CodeInterpreterKind)\n24: \t}\n25: \tif r.Namespace == \"\" {\n26: \t\treturn fmt.Errorf(\"namespace is required\")\n27: \t}\n28: \tif r.Name == \"\" {\n29: \t\treturn fmt.Errorf(\"name is required\")\n30: \t}\n31: \treturn nil\n32: }\n33: \n34: type CreateSandboxResponse struct {\n35: \tSessionID   string              `json:\"sessionId\"`\n36: \tSandboxID   string              `json:\"sandboxId\"`\n37: \tSandboxName string              `json:\"sandboxName\"`\n38: \tEntryPoints []SandboxEntryPoint `json:\"entryPoints\"`\n39: }\n40: \n41: type SandboxEntryPoint struct {\n42: \tPath     string `json:\"path\"`\n43: \tProtocol string `json:\"protocol\"`\n44: \tEndpoint string `json:\"endpoint\"`\n45: }\n46: \n47: type SandboxInfo struct {\n48: \tKind               string              `json:\"kind\"`\n49: \tSandboxID          string              `json:\"sandboxId\"`\n50: \tSandboxNamespace   string              `json:\"sandboxNamespace\"`\n51: \tSandboxName        string              `json:\"sandboxName\"`\n52: \tName               string              `json:\"name\"`\n53: \tSessionID          string              `json:\"sessionId\"`\n54: \tCreatedAt          time.Time           `json:\"createdAt\"`\n55: \tExpiresAt          time.Time           `json:\"expiresAt\"`\n56: \tStatus             string              `json:\"status\"`\n57: \tEntryPoints        []SandboxEntryPoint `json:\"entryPoints\"`\n58: \tUserToken          string              `json:\"userToken,omitempty\"`\n59: \tServiceAccount     string              `json:\"serviceAccount,omitempty\"`\n60: \tServiceAccountName string              `json:\"serviceAccountName,omitempty\"`\n61: \tLastActivity       time.Time           `json:\"lastActivity,omitempty\"`\n62: }\n\n(End of file - total 62 lines)\n</content>","metadata":{"preview":"package types\n\nimport (\n\t\"fmt\"\n\t\"time\"\n)\n\nconst (\n\tAgentRuntimeKind    = \"AgentRuntime\"\n\tCodeInterpreterKind = \"CodeInterpreter\"\n\tSandboxKind         = \"Sandbox\"\n\tSandboxClaimKind    = \"SandboxClaim\"\n)\n\ntype CreateSandboxRequest struct {\n\tKind      string `json:\"kind\"`\n\tName      string `json:\"name\"`\n\tNamespace string `json:\"namespace\"`\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go","time":{"start":1775897921742,"end":1775897921765}}}}
