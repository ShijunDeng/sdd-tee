rr := x509.ParsePKIXPublicKey(block.Bytes)\n55: \tif err != nil {\n56: \t\treturn nil, fmt.Errorf(\"failed to parse public key: %w\", err)\n57: \t}\n58: \n59: \trsaPub, ok := pub.(*rsa.PublicKey)\n60: \tif !ok {\n61: \t\treturn nil, errors.New(\"public key is not RSA\")\n62: \t}\n63: \n64: \treturn rsaPub, nil\n65: }\n66: \n67: func (a *AuthManager) AuthMiddleware() gin.HandlerFunc {\n68: \treturn func(c *gin.Context) {\n69: \t\tauthHeader := c.GetHeader(\"Authorization\")\n70: \t\tif authHeader == \"\" {\n71: \t\t\tc.JSON(401, gin.H{\"error\": \"missing authorization header\"})\n72: \t\t\tc.Abort()\n73: \t\t\treturn\n74: \t\t}\n75: \n76: \t\tif !strings.HasPrefix(authHeader, \"Bearer \") {\n77: \t\t\tc.JSON(401, gin.H{\"error\": \"invalid token format\"})\n78: \t\t\tc.Abort()\n79: \t\t\treturn\n80: \t\t}\n81: \n82: \t\ttokenString := strings.TrimPrefix(authHeader, \"Bearer \")\n83: \n84: \t\ta.mutex.RLock()\n85: \t\tpubKey := a.publicKey\n86: \t\ta.mutex.RUnlock()\n87: \n88: \t\ttoken, err := jwt.Parse(tokenString, func(token *jwt.Token) (interface{}, error) {\n89: \t\t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n90: \t\t\t\treturn nil, fmt.Errorf(\"invalid signing method\")\n91: \t\t\t}\n92: \t\t\treturn pubKey, nil\n93: \t\t}, jwt.WithExpirationRequired(), jwt.WithIssuedAt(), jwt.WithLeeway(time.Minute))\n94: \n95: \t\tif err != nil {\n96: \t\t\tif errors.Is(err, jwt.ErrTokenExpired) {\n97: \t\t\t\tc.JSON(401, gin.H{\"error\": \"token is expired\"})\n98: \t\t\t} else if errors.Is(err, jwt.ErrTokenSignatureInvalid) {\n99: \t\t\t\tc.JSON(401, gin.H{\"error\": \"invalid signature\"})\n100: \t\t\t} else if strings.Contains(err.Error(), \"invalid signing method\") {\n101: \t\t\t\tc.JSON(401, gin.H{\"error\": \"invalid signing method\"})\n102: \t\t\t} else {\n103: \t\t\t\tc.JSON(401, gin.H{\"error\": err.Error()})\n104: \t\t\t}\n105: \t\t\tc.Abort()\n106: \t\t\treturn\n107: \t\t}\n108: \n109: \t\tif !token.Valid {\n110: \t\t\tc.JSON(401, gin.H{\"error\": \"invalid token\"})\n111: \t\t\tc.Abort()\n112: \t\t\treturn\n113: \t\t}\n114: \n115: \t\thttp.MaxBytesReader(c.Writer, c.Request.Body, MaxBodySize)\n116: \t\tc.Next()\n117: \t}\n118: }\n119: \n120: func (a *AuthManager) SetPublicKey(key *rsa.PublicKey) {\n121: \ta.mutex.Lock()\n122: \ta.publicKey = key\n123: \ta.mutex.Unlock()\n124: }\n125: \n126: func (a *AuthManager) GetPublicKey() *rsa.PublicKey {\n127: \ta.mutex.RLock()\n128: \tdefer a.mutex.RUnlock()\n129: \treturn a.publicKey\n130: }\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nconst (\n\tPublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/auth.go","time":{"start":1775897891221,"end":1775897891253}}}}
{"type":"tool_use","timestamp":1775897891258,"sessionID":"ses_2843d4176ffeAKdOiytawM05uH","part":{"id":"prt_d7bc35166001mT7W7loKMsPoTG","messageID":"msg_d7bc31fda001ESs9DFDYkz8tic","sessionID":"ses_2843d4176ffeAKdOiytawM05uH","type":"tool","tool":"read","callID":"toolu_tool-84fc2eeb1f2f413c99d9044d5660b867","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/files.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/files.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"encoding/base64\"\n5: \t\"errors\"\n6: \t\"fmt\"\n7: \t\"io\"\n8: \t\"mime\"\n9: \t\"os\"\n10: \t\"path/filepath\"\n11: \t\"strconv\"\n12: \t\"strings\"\n13: \t\"time\"\n14: \n15: \t\"github.com/gin-gonic/gin\"\n16: )\n17: \n18: const (\n19: \tmaxFileMode     = 0777\n20: \tdefaultFileMode = 0644\n21: )\n22: \n23: type FileInfo struct {\n24: \tPath     string    `json:\"path\"`\n25: \tSize     int64     `json:\"size\"`\n26: \tMode     string    `json:\"mode\"`\n27: \tModified time.Time `json:\"modified\"`\n28: }\n29: \n30: type UploadFileRequest struct {\n31: \tPath    string `json:\"path\" binding:\"required\"`\n32: \tContent string `json:\"content\" binding:\"required\"`\n33: \tMode    string `json:\"mode\"`\n34: }\n35: \n36: type FileEntry struct {\n37: \tName     string    `json:\"name\"`\n38: \tSize     int64     `json:\"size\"`\n39: \tModified time.Time `json:\"modified\"`\n40: \tMode     string    `json:\"mode\"`\n41: \tIsDir    bool      `json:\"is_dir\"`\n42: }\n43: \n44: type ListFilesResponse struct {\n45: \tFiles []FileEntry `json:\"files\"`\n46: \tPath  string      `json:\"path\"`\n47: }\n48: \n49: func parseFileMode(modeStr string) (os.FileMode, error) {\n50: \tif modeStr == \"\" {\n51: \t\treturn defaultFileMode, nil\n52: \t}\n53: \n54: \tmode, err := strconv.ParseUint(modeStr, 8, 32)\n55: \tif err != nil {\n56: \t\treturn defaultFileMode, nil\n57: \t}\n58: \n59: \tif mode > maxFileMode {\n60: \t\treturn 0, errors.New(\"invalid file mode\")\n61: \t}\n62: \n63: \treturn os.FileMode(mode), nil\n64: }\n65: \n66: func (s *Server) UploadFileHandler(c *gin.Context) {\n67: \tcontentType := c.ContentType()\n68: \n69: \tvar path string\n70: \tvar content []byte\n71: \tvar modeStr string\n72: \n73: \tif contentType == \"multipart/form-data\" {\n74: \t\tpath = c.PostForm(\"path\")\n75: \t\tif path == \"\" {\n76: \t\t\tc.JSON(400, gin.H{\"error\": \"missing path parameter\"})\n77: \t\t\treturn\n78: \t\t}\n79: \n80: \t\tfileHeader, err := c.FormFile(\"file\")\n81: \t\tif err != nil {\n82: \t\t\tc.JSON(400, gin.H{\"error\": \"missing file\"})\n83: \t\t\treturn\n84: \t\t}\n85: \n86: \t\tfile, err := fileHeader.Open()\n87: \t\tif err != nil {\n88: \t\t\tc.JSON(500, gin.H{\"error\": \"failed to open file\"})\n89: \t\t\treturn\n90: \t\t}\n91: \t\tdefer file.Close()\n92: \n93: \t\tcontent, err = io.ReadAll(file)\n94: \t\tif err != nil {\n95: \t\t\tc.JSON(500, gin.H{\"error\": \"failed to read file\"})\n96: \t\t\treturn\n97: \t\t}\n98: \n99: \t\tmodeStr = c.PostForm(\"mode\")\n100: \t} else {\n101: \t\tvar req UploadFileRequest\n102: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n103: \t\t\tc.JSON(400, gin.H{\"error\": \"invalid request body\"})\n104: \t\t\treturn\n105: \t\t}\n106: \n107: \t\tpath = req.Path\n108: \t\tmodeStr = req.Mode\n109: \n110: \t\tdecoded, err := base64.StdEncoding.DecodeString(req.Content)\n111: \t\tif err != nil {\n112: \t\t\tc.JSON(400, gin.H{\"error\": \"invalid base64 content\"})\n113: \t\t\treturn\n114: \t\t}\n115: \t\tcontent = decoded\n116: \t}\n117: \n118: \tsanitizedPath, err := sanitizePath(s.workspace, path)\n119: \tif err != nil {\n120: \t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n121: \t\treturn\n122: \t}\n123: \n124: \tmode, err := parseFileMode(modeStr)\n125: \tif err != nil {\n126: \t\tc.JSON(400, gin.H{\"error\": err.Error()})\n127: \t\treturn\n128: \t}\n129: \n130: \tparentDir := filepath.Dir(sanitizedPath)\n131: \tif err := os.MkdirAll(parentDir, 0755); err != nil {\n132: \t\tc.JSON(500, gin.H{\"error\": \"failed to create parent directories\"})\n133: \t\treturn\n134: \t}\n135: \n136: \tif err := os.WriteFile(sanitizedPath, content, mode); err != nil {\n137: \t\tc.JSON(500, gin.H{\"error\": \"failed to write file\"})\n138: \t\treturn\n139: \t}\n140: \n141: \tinfo, err := os.Stat(sanitizedPath)\n142: \tif err != nil {\n143: \t\tc.JSON(500, gin.H{\"error\": \"failed to get file info\"})\n144: \t\treturn\n145: \t}\n146: \n147: \tc.JSON(200, FileInfo{\n148: \t\tPath:     path,\n149: \t\tSize:     info.Size(),\n150: \t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n151: \t\tModified: info.ModTime(),\n152: \t})\n153: }\n154: \n155: func (s *Server) ListFilesHandler(c *gin.Context) {\n156: \tpath := c.Query(\"path\")\n157: \tif path == \"\" {\n158: \t\tc.JSON(400, gin.H{\"error\": \"missing path parameter\"})\n159: \t\treturn\n160: \t}\n161: \n162: \tsanitizedPath, err := sanitizePath(s.workspace, path)\n163: \tif err != nil {\n164: \t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n165: \t\treturn\n166: \t}\n167: \n168: \tentries, err := os.ReadDir(sanitizedPath)\n169: \tif err != nil {\n170: \t\tc.JSON(500, gin.H{\"error\": \"failed to read directory\"})\n171: \t\treturn\n172: \t}\n173: \n174: \tfiles := []FileEntry{}\n175: \tfor _, entry := range entries {\n176: \t\tinfo, err := entry.Info()\n177: \t\tif err != nil {\n178: \t\t\tcontinue\n179: \t\t}\n180: \n181: \t\tfiles = append(files, FileEntry{\n182: \t\t\tName:     entry.Name(),\n183: \t\t\tSize:     info.Size(),\n184: \t\t\tModified: info.ModTime(),\n185: \t\t\tMode:     fmt.Sprintf(\"%04o\", info.Mode().Perm()),\n186: \t\t\tIsDir:    entry.IsDir(),\n187: \t\t})\n188: \t}\n189: \n190: \tc.JSON(200, ListFilesResponse{\n191: \t\tFiles: files,\n192: \t\tPath:  path,\n193: \t})\n194: }\n195: \n196: func (s *Server) DownloadFileHandler(c *gin.Context) {\n197: \treqPath := c.Param(\"path\")\n198: \treqPath = strings.TrimPrefix(reqPath, \"/\")\n199: \n200: \tsanitizedPath, err := sanitizePath(s.workspace, reqPath)\n201: \tif err != nil {\n202: \t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid path: %s\", err.Error())})\n203: \t\treturn\n204: \t}\n205: \n206: \tinfo, err := os.Stat(sanitizedPath)\n207: \tif err != nil {\n208: \t\tif os.IsNotExist(err) {\n209: \t\t\tc.JSON(404, gin.H{\"error\": \"file not found\"})\n210: \t\t} else {\n211: \t\t\tc.JSON(500, gin.H{\"error\": \"failed to stat file\"})\n212: \t\t}\n213: \t\treturn\n214: \t}\n215: \n216: \tif info.IsDir() {\n217: \t\tc.JSON(400, gin.H{\"error\": \"path is not a file\"})\n218: \t\treturn\n219: \t}\n220: \n221: \tcontentType := mime.TypeByExtension(filepath.Ext(sanitizedPath))\n222: \tif contentType == \"\" {\n223: \t\tcontentType = \"application/octet-stream\"\n224: \t}\n225: \n226: \tfilename := filepath.Base(sanitizedPath)\n227: \tc.Header(\"Content-Type\", contentType)\n228: \tc.Header(\"Content-Disposition\", fmt.Sprintf(\"attachment; filename=\\\"%s\\\"\", filename))\n229: \tc.File(sanitizedPath)\n230: }\n\n(End of file - total 230 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"encoding/base64\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nconst (\n\tmaxFileMode     = 0777\n\tdefaultFileMode = 0644","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/files.go","time":{"start":1775897891224,"end":1775897891255}}}}
