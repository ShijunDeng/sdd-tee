\tdefer func() {\n57: \t\t\tif err := recover(); err != nil {\n58: \t\t\t\tif logger != nil {\n59: \t\t\t\t\tlogger.Error(\"panic recovered\",\n60: \t\t\t\t\t\t\"error\", err,\n61: \t\t\t\t\t\t\"path\", c.Request.URL.Path,\n62: \t\t\t\t\t\t\"method\", c.Request.Method,\n63: \t\t\t\t\t)\n64: \t\t\t\t}\n65: \n66: \t\t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n67: \t\t\t\t\t\"error\": \"internal server error\",\n68: \t\t\t\t})\n69: \t\t\t\tc.Abort()\n70: \t\t\t}\n71: \t\t}()\n72: \t\tc.Next()\n73: \t}\n74: }\n\n(End of file - total 74 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nfunc concurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n\tif maxConcurrent <= 0 {\n\t\tmaxConcurrent = 1000\n\t}\n\n\tsem := make(chan struct{}, maxConcurrent)\n\n\treturn func(c *gin.Context) {\n\t\tselect {\n\t\tcase sem <- struct{}{}:\n\t\t\tdefer func() { <-sem }()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware.go","time":{"start":1775897903859,"end":1775897903887}}}}
