      - get\n56:       - list\n57:       - watch\n58:       - create\n59:       - update\n60:       - patch\n61:       - delete\n62:   - apiGroups:\n63:       - runtime.agentcube.volcano.sh\n64:     resources:\n65:       - codeinterpreters/status\n66:     verbs:\n67:       - get\n68:       - update\n69:       - patch\n70:   - apiGroups:\n71:       - runtime.agentcube.volcano.sh\n72:     resources:\n73:       - codeinterpreters/finalizers\n74:     verbs:\n75:       - update\n76:   - apiGroups:\n77:       - runtime.agentcube.volcano.sh\n78:     resources:\n79:       - agentruntimes\n80:     verbs:\n81:       - get\n82:       - list\n83:       - watch\n84:   - apiGroups:\n85:       - runtime.agentcube.volcano.sh\n86:     resources:\n87:       - agentruntimes/status\n88:     verbs:\n89:       - update\n90:       - patch\n91:   - apiGroups:\n92:       - \"\"\n93:     resources:\n94:       - pods\n95:     verbs:\n96:       - get\n97:       - list\n98:       - watch\n99:   - apiGroups:\n100:       - authentication.k8s.io\n101:     resources:\n102:       - tokenreviews\n103:     verbs:\n104:       - create\n105:   - apiGroups:\n106:       - \"\"\n107:     resources:\n108:       - secrets\n109:     verbs:\n110:       - get\n111:       - list\n112:       - watch\n113:       - create\n114:       - update\n115:       - patch\n116:       - delete\n117: ---\n118: apiVersion: rbac.authorization.k8s.io/v1\n119: kind: ClusterRoleBinding\n120: metadata:\n121:   name: workloadmanager\n122:   labels:\n123:     {{- include \"agentcube.labels\" . | nindent 4 }}\n124: roleRef:\n125:   apiGroup: rbac.authorization.k8s.io\n126:   kind: ClusterRole\n127:   name: workloadmanager\n128: subjects:\n129:   - kind: ServiceAccount\n130:     name: workloadmanager\n131:     namespace: {{ .Release.Namespace }}\n\n(End of file - total 131 lines)\n</content>","metadata":{"preview":"apiVersion: v1\nkind: ServiceAccount\nmetadata:\n  name: workloadmanager\n  namespace: {{ .Release.Namespace }}\n  labels:\