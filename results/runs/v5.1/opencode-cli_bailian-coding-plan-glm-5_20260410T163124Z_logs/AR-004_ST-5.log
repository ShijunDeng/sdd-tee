ntegrationTestLogger{}\n\ts := NewHTTPServer(cfg, logger)\n\n\terrCh := s.Start()\n\tif errCh == nil {\n\t\tt.Error(\"Start returned nil error channel\")\n\t}\n\n\ttime.Sleep(100 * time.Millisecond)\n\n\tctx := context.Background()\n\terr = s.Stop(ctx)\n\tif err != nil {\n\t\tt.Errorf(\"Stop returned error: %v\", err)\n\t}\n\n\tselect {\n\tcase <-s.stopCh:\n\tcase <-time.After(2 * time.Second):\n\t\tt.Error(\"stopCh was not closed after Stop()\")\n\t}\n\n\tselect {\n\tcase <-errCh:\n\tcase <-time.After(2 * time.Second):\n\t}\n}\n","after":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n)\n\ntype integrationTestLogger struct {\n\tmu     sync.Mutex\n\tinfos  []string\n\terrors []string\n}\n\nfunc (l *integrationTestLogger) Info(msg string, args ...any) {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tl.infos = append(l.infos, msg)\n}\n\nfunc (l *integrationTestLogger) Error(msg string, args ...any) {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tl.errors = append(l.errors, msg)\n}\n\ntype integrationHealthChecker struct {\n\tready bool\n}\n\nfunc (c *integrationHealthChecker) IsHealthy() bool { return true }\nfunc (c *integrationHealthChecker) IsReady() bool   { return c.ready }\n\nfunc TestE2EHealthz(t *testing.T) {\n\tlistener, err := net.Listen(\"tcp\", \"127.0.0.1:0\")\n\tif err != nil {\n\t\tt.Fatalf(\"failed to get free port: %v\", err)\n\t}\n\taddr := listener.Addr().String()\n\tlistener.Close()\n\n\tcfg := Config{\n\t\tAddr:            addr,\n\t\tReadTimeout:     5 * time.Second,\n\t\tWriteTimeout:    5 * time.Second,\n\t\tIdleTimeout:     60 * time.Second,\n\t\tShutdownTimeout: 5 * time.Second,\n\t}\n\tlogger := &integrationTestLogger{}\n\ts := NewHTTPServer(cfg, logger)\n\n\ts.router.Get(\"/healthz\", func(w http.ResponseWriter, r *http.Request) {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusOK)\n\t\tjson.NewE