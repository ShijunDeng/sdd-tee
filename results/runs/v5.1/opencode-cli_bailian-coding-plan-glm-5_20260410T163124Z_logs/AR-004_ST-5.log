p.Request) {\n113: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n114: \t\tif checker == nil || !checker.IsReady() {\n115: \t\t\tw.WriteHeader(http.StatusServiceUnavailable)\n116: \t\t\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"not ready\"})\n117: \t\t\treturn\n118: \t\t}\n119: \t\tw.WriteHeader(http.StatusOK)\n120: \t\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ready\"})\n121: \t})\n122: \n123: \terrCh := s.Start()\n124: \n125: \tclient := &http.Client{Timeout: 2 * time.Second}\n126: \n127: \tvar resp *http.Response\n128: \tvar err error\n129: \tfor i := 0; i < 10; i++ {\n130: \t\ttime.Sleep(50 * time.Millisecond)\n131: \t\tresp, err = client.Get(\"http://localhost\" + s.server.Addr + \"/readyz\")\n132: \t\tif err == nil {\n133: \t\t\tbreak\n134: \t\t}\n135: \t}\n136: \n137: \tif err != nil {\n138: \t\tt.Fatalf(\"failed to connect to server: %v\", err)\n139: \t}\n140: \tdefer resp.Body.Close()\n141: \n142: \tif resp.StatusCode != http.StatusOK {\n143: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, resp.StatusCode)\n144: \t}\n145: \n146: \tvar body map[string]string\n147: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n148: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n149: \t}\n150: \tif body[\"status\"] != \"ready\" {\n151: \t\tt.Errorf(\"expected status %s, got %s\", \"ready\", body[\"status\"])\n152: \t}\n153: \n154: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n155: \tdefer cancel()\n156: \ts.Stop(ctx)\n157: \n158: \tselect {\n159: \tcase <-errCh:\n160: \tcase <-time.After(1 * time.Second):\n161: \t}\n162: }\n163: \n164: func TestMiddlewareChain(t *testing.T) {\n165: \tlogger := &integrationTestLogger{}\n166: \n167: \trouter := NewRouter()\n168: \n169: \trouter.Use(func(next http.Handler) http.Handler {\n170: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n171: \t\t\tdefer func() {\n172: \t\t\t\tif err := recover(); err != nil {\n173: \t\t\t\t\tlogger.Error(\"panic recovered\", \"error\", err)\n174: \t\t\t\t\thttp.Error(w, \"Internal Server Error\", http.StatusInternalServerError)\n175: \t\t\t\t}\n176: \t\t\t}()\n177: \t\t\tnext.ServeHTTP(w, r)\n178: \t\t})\n179: \t})\n180: \n181: \trouter.Use(func(next http.Handler) http.Handler {\n182: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n183: \t\t\tlogger.Info(\"request\", \"method\", r.Method, \"path\", r.URL.Path)\n184: \t\t\tnext.ServeHTTP(w, r)\n185: \t\t})\n186: \t})\n187: \n188: \trouter.Get(\"/test\", func(w http.ResponseWriter, r *http.Request) {\n189: \t\tw.WriteHeader(http.StatusOK)\n190: \t\tw.Write([]byte(\"test\"))\n191: \t})\n192: \n193: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n194: \tw := httptest.NewRecorder()\n195: \n196: \trouter.ServeHTTP(w, req)\n197: \n198: \tif w.Code != http.StatusOK {\n199: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n200: \t}\n201: \n202: \tlogger.mu.Lock()\n203: \tdefer logger.mu.Unlock()\n204: \tif len(logger.infos) != 1 {\n205: \t\tt.Errorf(\"expected 1 info log, got %d\", len(logger.infos))\n206: \t}\n207: }\n208: \n209: func TestE2EPanicRecovery(t *testing.T) {\n210: \tcfg := Config{\n211: \t\tAddr:            \":0\",\n212: \t\tReadTimeout:     5 * time.Second,\n213: \t\tWriteTimeout:    5 * time.Second,\n214: \t\tIdleTimeout:     60 * time.Second,\n215: \t\tShutdownTimeout: 5 * time.Second,\n216: \t}\n217: \tlogger := &integrationTestLogger{}\n218: \ts := NewHTTPServer(cfg, logger)\n219: \n220: \ts.router.Use(func(next http.Handler) http.Handler {\n221: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n222: \t\t\tdefer func() {\n223: \t\t\t\tif err := recover(); err != nil {\n224: \t\t\t\t\tlogger.Error(\"panic recovered\", \"error\", err)\n225: \t\t\t\t\thttp.Error(w, \"Internal Server Error\", http.StatusInternalServerError)\n226: \t\t\t\t}\n227: \t\t\t}()\n228: \t\t\tnext.ServeHTTP(w, r)\n229: \t\t})\n230: \t})\n231: \n232: \ts.router.Get(\"/panic\", func(w http.ResponseWriter, r *http.Request) {\n233: \t\tpanic(\"intentional panic for test\")\n234: \t})\n235: \n236: \terrCh := s.Start()\n237: \n238: \tclient := &http.Client{Timeout: 2 * time.Second}\n239: \n240: \tvar resp *http.Response\n241: \tvar err error\n242: \tfor i := 0; i < 10; i++ {\n243: \t\ttime.Sleep(50 * time.Millisecond)\n244: \t\tresp, err = client.Get(\"http://localhost\" + s.server.Addr + \"/panic\")\n245: \t\tif err == nil {\n246: \t\t\tbreak\n247: \t\t}\n248: \t}\n249: \n250: \tif err != nil {\n251: \t\tt.Fatalf(\"failed to connect to server: %v\", err)\n252: \t}\n253: \tdefer resp.Body.Close()\n254: \n255: \tif resp.StatusCode != http.StatusInternalServerError {\n256: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusInternalServerError, resp.StatusCode)\n257: \t}\n258: \n259: \tlogger.mu.Lock()\n260: \tdefer logger.mu.Unlock()\n261: \tif len(logger.errors) != 1 {\n262: \t\tt.Errorf(\"expected 1 error log, got %d\", len(logger.errors))\n263: \t}\n264: \n265: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n266: \tdefer cancel()\n267: \ts.Stop(ctx)\n268: \n269: \tselect {\n270: \tcase <-errCh:\n271: \tcase <-time.After(1 * time.Second):\n272: \t}\n273: }\n274: \n275: func TestStartStopLifecycle(t *testing.T) {\n276: \tcfg := Config{\n277: \t\tAddr:            \":0\",\n278: \t\tReadTimeout:     5 * time.Second,\n279: \t\tWriteTimeout:    5 * time.Second,\n280: \t\tIdleTimeout:     60 * time.Second,\n281: \t\tShutdownTimeout: 5 * time.Second,\n282: \t}\n283: \tlogger := &integrationTestLogger{}\n284: \ts := NewHTTPServer(cfg, logger)\n285: \n286: \terrCh := s.Start()\n287: \tif errCh == nil {\n288: \t\tt.Error(\"Start returned nil error channel\")\n289: \t}\n290: \n291: \ttime.Sleep(100 * time.Millisecond)\n292: \n293: \tctx := context.Background()\n294: \terr := s.Stop(ctx)\n295: \tif err != nil {\n296: \t\tt.Errorf(\"Stop returned error