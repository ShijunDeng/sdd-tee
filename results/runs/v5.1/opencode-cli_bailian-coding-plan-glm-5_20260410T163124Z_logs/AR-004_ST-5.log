althz\")\n\t\tif err == nil {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\tif err != nil {\n\t\tt.Fatalf(\"failed to connect to server: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, resp.StatusCode)\n\t}\n\n\tvar body map[string]string\n\tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n\t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n\t}\n\tif body[\"status\"] != \"ok\" {\n\t\tt.Errorf(\"expected status %s, got %s\", \"ok\", body[\"status\"])\n\t}\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\ts.Stop(ctx)\n\n\tselect {\n\tcase <-errCh:\n\tcase <-time.After(1 * time.Second):\n\t}\n}\n\nfunc TestE2EReadyz(t *testing.T) {\n\tcfg := Config{\n\t\tAddr:            \":0\",\n\t\tReadTimeout:     5 * time.Second,\n\t\tWriteTimeout:    5 * time.Second,\n\t\tIdleTimeout:     60 * time.Second,\n\t\tShutdownTimeout: 5 * time.Second,\n\t}\n\tlogger := &integrationTestLogger{}\n\ts := NewHTTPServer(cfg, logger)\n\n\tchecker := &integrationHealthChecker{ready: true}\n\thealthHandler := handlers.NewHealthHandler(checker)\n\ts.RegisterHandler(\"health\", healthHandler)\n\n\terrCh := s.Start()\n\n\tclient := &http.Client{Timeout: 2 * time.Second}\n\n\tvar resp *http.Response\n\tvar err error\n\tfor i := 0; i < 10; i++ {\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tresp, err = client.Get(\"http://localhost\" + s.server.Addr + \"/readyz\")\n\t\tif err == nil {\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif err != nil {\n\t\tt.Fatalf(\"failed to connect to server: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, resp.StatusCode)\n\t}\n\n\tvar body map[string]string\n\tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n\t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n\t}\n\tif body[\"status\"] != \"ready\" {\n\t\tt.Errorf(\"expected status %s, got %s\", \"ready\", body[\"status\"])\n\t}\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\ts.Stop(ctx)\n\n\tselect {\n\tcase <-errCh:\n\tcase <-time.After(1 * time.Second):\n\t}\n}\n\nfunc TestMiddlewareChain(t *testing.T) {\n\tlogger := &integrationTestLogger{}\n\n\trouter := NewRouter()\n\n\trecovery := middleware.NewRecoveryMiddleware(logger)\n\tlogging := middleware.NewLoggingMiddleware(logger)\n\n\trouter.Use(recovery.Wrap)\n\trouter.Use(logging.Wrap)\n\n\trouter.Get(\"/test\", func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t\tw.Write([]byte(\"test\"))\n\t})\n\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tw := httptest.NewRecorder()\n\n\trouter.ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n\t}\n\n\tlogger.mu.Lock()\n\tdefer logger.mu.Unlock()\n\tif len(logger.infos) != 1 {\n\t\tt.Errorf(\"expected 1 info log, got %d\", len(logger.infos))\n\t}\n}\n\nfunc TestE2EPanicRecovery(t *testing.T) {\n\tcfg := Config{\n\t\tAddr:            \":0\",\n\t\tReadTimeout:     5 * time.Second,\n\t\tWriteTimeout:    5 * time.Second,\n\t\tIdleTimeout:     60 * time.Second,\n\t\tShutdownTimeout: 5 * time.Second,\n\t}\n\tlogger := &integrationTestLogger{}\n\ts := NewHTTPServer(cfg, logger)\n\n\trecovery := middleware.NewRecoveryMiddleware(logger)\n\ts.router.Use(recovery.Wrap)\n\n\ts.router.Get(\"/panic\", func(w http.ResponseWriter, r *http.Request) {\n\t\tpanic(\"intentional panic for test\")\n\t})\n\n\terrCh := s.Start()\n\n\tclient := &http.Client{Timeout: 2 * time.Second}\n\n\tvar resp *http.Response\n\tvar err error\n\tfor i := 0; i < 10; i++ {\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tresp, err = client.Get(\"http://localhost\" + s.server.Addr + \"/panic\")\n\t\tif err == nil {\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif err != nil {\n\t\tt.Fatalf(\"failed to connect to server: %v\", err)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusInternalServerError {\n\t\tt.Errorf(\"expected status %d, got %d\", http.StatusInternalServerError, resp.StatusCode)\n\t}\n\n\tlogger.mu.Lock()\n\tdefer logger.mu.Unlock()\n\tif len(logger.errors) != 1 {\n\t\tt.Errorf(\"expected 1 error log, got %d\", len(logger.errors))\n\t}\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\ts.Stop(ctx)\n\n\tselect {\n\tcase <-errCh:\n\tcase <-time.After(1 * time.Second):\n\t}\n}\n\nfunc TestStartStopLifecycle(t *testing.T) {\n\tcfg := Config{\n\t\tAddr:            \":0\",\n\t\tReadTimeout:     5 * time.Second,\n\t\tWriteTimeout:    5 * time.Second,\n\t\tIdleTimeout:     60 * time.Second,\n\t\tShutdownTimeout: 5 * time.Second,\n\t}\n\tlogger := &integrationTestLogger{}\n\ts := NewHTTPServer(cfg, logger)\n\n\terrCh := s.Start()\n\tif errCh == nil {\n\t\tt.Error(\"Start returned nil error channel\")\n\t}\n\n\ttime.Sleep(100 * time.Millisecond)\n\n\tctx := context.Background()\n\terr := s.Stop(ctx)\n\tif err != nil {\n\t\tt.Errorf(\"Stop returned error: %v\", err)\n\t}\n\n\tselect {\n\tcase <-s.stopCh:\n\tcase <-time.After(2 * time.Second):\n\t\tt.Error(\"stopCh was not closed after Stop()\")\n\t}\n\n\tselect {\n\tcase <-errCh:\n\tcase <-time.After(2 * time.Second):\n\t}\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/integration_test.go"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go\">\nERROR [1:1] import cycle not allowed in test\n</diagnostics>\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadm