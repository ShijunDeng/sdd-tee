{"type":"tool_use","timestamp":1775842635944,"sessionID":"ses_2878d122affe8iCJXTULzVGdMY","part":{"id":"prt_d7877a98d001PV17YC1zw7WFY6","messageID":"msg_d78757df1001fFhMnQp1XDo6NX","sessionID":"ses_2878d122affe8iCJXTULzVGdMY","type":"tool","tool":"write","callID":"toolu_tool-ba2d7bfb171f44898cca593f04adcf42","state":{"status":"completed","input":{"content":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n)\n\nfunc TestCORSMiddleware_Wrap_AllowedOrigin(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins:   []string{\"http://example.com\", \"http://localhost\"},\n\t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n\t\tAllowedHeaders:   []string{\"Content-Type\"},\n\t\tAllowCredentials: true,\n\t}\n\tm := NewCORSMiddleware(config)\n\n\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t})\n\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\treq.Header.Set(\"Origin\", \"http://example.com\")\n\tw := httptest.NewRecorder()\n\n\tm.Wrap(handler).ServeHTTP(w, req)\n\n\torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n\tif origin != \"http://example.com\" {\n\t\tt.Errorf(\"expected Allow-Origin %s, got %s\", \"http://example.com\", origin)\n\t}\n\tmethods := w.Header().Get(\"Access-Control-Allow-Methods\")\n\tif methods != \"GET,POST\" {\n\t\tt.Errorf(\"expected Allow-Methods %s, got %s\", \"GET,POST\", methods)\n\t}\n\tcreds := w.Header().Get(\"Access-Control-Allow-Credentials\")\n\tif creds != \"true\" {\n\t\tt.Errorf(\"expected Allow-Credentials %s, got %s\", \"true\", creds)\n\t}\n}\n\nfunc TestCORSMiddleware_Wrap_DisallowedOrigin(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins: []string{\"http://example.com\"},\n\t\tAllowedMethods: []string{\"GET\"},\n\t\tAllowedHeaders: []string{\"Content-Type\"},\n\t}\n\tm := NewCORSMiddleware(config)\n\n\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t})\n\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\treq.Header.Set(\"Origin\", \"http://evil.com\")\n\tw := httptest.NewRecorder()\n\n\tm.Wrap(handler).ServeHTTP(w, req)\n\n\torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n\tif origin != \"\" {\n\t\tt.Errorf(\"expected no Allow-Origin header, got %s\", origin)\n\t}\n}\n\nfunc TestCORSMiddleware_Wrap_OptionsPreflight(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins:   []string{\"*\"},\n\t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\"},\n\t\tAllowedHeaders:   []string{\"Content-Type\", \"Authorization\"},\n\t\tAllowCredentials: false,\n\t}\n\tm := NewCORSMiddleware(config)\n\n\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t})\n\n\treq := httptest.NewRequest(\"OPTIONS\", \"/test\", nil)\n\treq.Header.Set(\"Origin\", \"http://example.com\")\n\tw := httptest.NewRecorder()\n\n\tm.Wrap(handler).ServeHTTP(w, req)\n\n\tif w.Code != http.StatusOK {\n\t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n\t}\n}\n\nfunc TestCORSMiddleware_isAllowedOrigin_Wildcard(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins: []string{\"*\"},\n\t}\n\tm := NewCORSMiddleware(config)\n\n\tif !m.isAllowedOrigin(\"http://any.com\") {\n\t\tt.Error(\"wildcard should allow any origin\")\n\t}\n}\n\nfunc TestCORSMiddleware_isAllowedOrigin_ExactMatch(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins: []string{\"http://example.com\"},\n\t}\n\tm := NewCORSMiddleware(config)\n\n\tif !m.isAllowedOrigin(\"http://example.com\") {\n\t\tt.Error(\"exact match should be allowed\")\n\t}\n\tif m.isAllowedOrigin(\"http://other.com\") {\n\t\tt.Error(\"non-matching origin should not be allowed\")\n\t}\n}\n\nfunc TestCORSMiddleware_isAllowedOrigin_NoMatch(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins: []string{\"http://example.com\", \"http://localhost\"},\n\t}\n\tm := NewCORSMiddleware(config)\n\n\tif m.isAllowedOrigin(\"http://evil.com\") {\n\t\tt.Error(\"non-matching origin should not be allowed\")\n\t}\n}\n\nfunc TestNewCORSMiddleware(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins: []string{\"*\"},\n\t}\n\tm := NewCORSMiddleware(config)\n\n\tif m == nil {\n\t\tt.Fatal(\"NewCORSMiddleware returned nil\")\n\t}\n\tif m.config.AllowedOrigins[0] != \"*\" {\n\t\tt.Error(\"config not properly set\")\n\t}\n}\n\nfunc TestCORSMiddleware_NoOriginHeader(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins: []string{\"*\"},\n\t}\n\tm := NewCORSMiddleware(config)\n\n\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t})\n\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tw := httptest.NewRecorder()\n\n\tm.Wrap(handler).ServeHTTP(w, req)\n\n\torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n\tif origin != \"\" {\n\t\tt.Errorf(\"expected no Allow-Origin without Origin header, got %s\", origin)\n\t}\n}\n\nfunc TestCORSConfig_AllFields(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins:   []string{\"http://example.com\"},\n\t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n\t\tAllowedHeaders:   []string{\"Content-Type\"},\n\t\tAllowCredentials: true,\n\t}\n\n\tif len(config.AllowedOrigins) != 1 {\n\t\tt.Errorf(\"expected 1 allowed origin, got %d\", len(config.AllowedOrigins))\n\t}\n\tif len(config.AllowedMethods) != 2 {\n\t\tt.Errorf(\"expected 2 allowed methods, got %d\", len(config.AllowedMethods))\n\t}\n\tif !config.AllowCredentials {\n\t\tt.Error(\"expected AllowCredentials to be true\")\n\t}\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/ser