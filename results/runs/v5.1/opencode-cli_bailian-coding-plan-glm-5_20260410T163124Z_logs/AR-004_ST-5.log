{\n\t\tserver:   &http.Server{Addr: cfg.Addr},\n\t\trouter:   chi.NewRouter(),\n\t\tconfig:   cfg,\n\t\thandlers: make(map[string]Handler),\n\t\tlogger:   logger,\n\t\tstopCh:   make(chan struct{}),\n\t}\n}\n\n// RegisterHandler stores a handler and registers its routes on the router.\nfunc (s *HTTPServer) RegisterHandler(name string, h handlers.Handler) {\n\ts.handlers[name] = h\n\th.Register(s.router)\n}\n\n// Start begins listening and serving HTTP requests.\n// It returns an error channel that receives non-ErrServerClosed errors.\nfunc (s *HTTPServer) Start() <-chan error {\n\terrCh := make(chan error, 1)\n\ts.server.ReadTimeout = s.config.ReadTimeout\n\ts.server.WriteTimeout = s.config.WriteTimeout\n\ts.server.IdleTimeout = s.config.IdleTimeout\n\ts.server.Handler = s.router\n\n\tgo func() {\n\t\tif err := s.server.ListenAndServe(); err != http.ErrServerClosed {\n\t\t\terrCh <- err\n\t\t}\n\t}()\n\treturn errCh\n}\n\n// Stop gracefully shuts down the HTTP server within the configured timeout.\nfunc (s *HTTPServer) Stop(ctx context.Context) error {\n\tctx, cancel := context.WithTimeout(ctx, s.config.ShutdownTimeout)\n\tdefer cancel()\n\terr := s.server.Shutdown(ctx)\n\tclose(s.stopCh)\n\treturn err\n}\n\n// GracefulShutdown sets up signal handlers for SIGTERM and SIGINT.\n// When a signal is received, the server is stopped gracefully.\nfunc (s *HTTPServer) GracefulShutdown() {\n\tsigCh := make(chan os.Signal, 1)\n\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n\tgo func() {\n\t\t<-sigCh\n\t\tctx := context.Background()\n\t\ts.Stop(ctx)\n\t}()\n}\n","after":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// HTTPServer manages the HTTP server lifecycle including graceful shutdown.\ntype HTTPServer struct {\n\tserver   *http.Server\n\trouter   chi.Router\n\tconfig   Config\n\thandlers map[string]Handler\n\tlogger   Logger\n\tstopCh   chan struct{}\n}\n\n//