, \"NOT_FOUND\", body.Code)\n\t}\n}\n\nfunc TestHandleError_InternalError(t *testing.T) {\n\terr := &InternalError{Err: errors.New(\"database connection failed\")}\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tw := httptest.NewRecorder()\n\n\tHandleError(w, req, err)\n\n\tresp := w.Result()\n\tif resp.StatusCode != http.StatusInternalServerError {\n\t\tt.Errorf(\"expected status %d, got %d\", http.StatusInternalServerError, resp.StatusCode)\n\t}\n\n\tvar body ErrorResponse\n\tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n\t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n\t}\n\tif body.Code != \"INTERNAL_ERROR\" {\n\t\tt.Errorf(\"expected code %s, got %s\", \"INTERNAL_ERROR\", body.Code)\n\t}\n\tif body.Message != \"Unexpected server error\" {\n\t\tt.Errorf(\"expected message %s, got %s\", \"Unexpected server error\", body.Message)\n\t}\n}\n\nfunc TestHandleError_ServiceUnavailableError(t *testing.T) {\n\terr := &ServiceUnavailableError{Dependency: \"kubernetes-api\"}\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tw := httptest.NewRecorder()\n\n\tHandleError(w, req, err)\n\n\tresp := w.Result()\n\tif resp.StatusCode != http.StatusServiceUnavailable {\n\t\tt.Errorf(\"expected status %d, got %d\", http.StatusServiceUnavailable, resp.StatusCode)\n\t}\n\n\tvar body ErrorResponse\n\tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n\t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n\t}\n\tif body.Code != \"SERVICE_UNAVAILABLE\" {\n\t\tt.Errorf(\"expected code %s, got %s\", \"SERVICE_UNAVAILABLE\", body.Code)\n\t}\n}\n\nfunc TestHandleError_UnknownError(t *testing.T) {\n\terr := errors.New(\"unknown error type\")\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tw := httptest.NewRecorder()\n\n\tHandleError(w, req, err)\n\n\tresp := w.Result()\n\tif resp.StatusCode != http.StatusInternalServerError {\n\t\tt.Errorf(\"expected status %d, got %d\", http.StatusInternalServerError, resp.StatusCode)\n\t}\n\n\tvar body ErrorResponse\n\tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n\t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n\t}\n\tif body.Code != \"INTERNAL_ERROR\" {\n\t\tt.Errorf(\"expected code %s, got %s\", \"INTERNAL_ERROR\", body.Code)\n\t}\n}\n\nfunc TestHandleError_ContentType(t *testing.T) {\n\terr := &ValidationError{Field: \"test\", Reason: \"test\"}\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tw := httptest.NewRecorder()\n\n\tHandleError(w, req, err)\n\n\tresp := w.Result()\n\tct := resp.Header.Get(\"Content-Type\")\n\tif ct != \"application/json\" {\n\t\tt.Errorf(\"expected Content-Type %s, got %s\", \"application/json\", ct)\n\t}\n}\n\nfunc TestErrorTypes_ValidationError(t *testing.T) {\n\terr := &ValidationError{Field: \"name\", Reason: \"required\"}\n\texpected := \"validation error: name - required\"\n\tif err.Error() != expected {\n\t\tt.Errorf(\"expected %s, got %s\", expected, err.Error())\n\t}\n}\n\nfunc TestErrorTypes_NotFoundError(t *testing.T) {\n\terr := &NotFoundError{Resource: \"agentruntime\", Name: \"test\"}\n\texpected := \"not found: agentruntime/test\"\n\tif err.Error() != expected {\n\t\tt.Errorf(\"expected %s, got %s\", expected, err.Error())\n\t}\n}\n\nfunc TestErrorTypes_InternalError(t *testing.T) {\n\terr := &InternalError{Err: errors.New(\"underlying error\")}\n\texpected := \"internal error: underlying error\"\n\tif err.Error() != expected {\n\t\tt.Errorf(\"expected %s, got %s\", expected, err.Error())\n\t}\n}\n\nfunc TestErrorTypes_ServiceUnavailableError(t *testing.T) {\n\terr := &ServiceUnavailableError{Dependency: \"kubernetes-api\"}\n\texpected := \"service unavailable: kubernetes-api\"\n\tif err.Error() != expected {\n\t\tt.Errorf(\"expected %s, got %s\", expected, err.Error())\n\t}\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types_test.go"},"outp