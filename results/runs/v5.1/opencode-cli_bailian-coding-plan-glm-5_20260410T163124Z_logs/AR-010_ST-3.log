{"type":"tool_use","timestamp":1775851028599,"sessionID":"ses_287087b03ffeyVD3nCcP1r3a2k","part":{"id":"prt_d78f84021001Wi9cyWYEgsGxqM","messageID":"msg_d78f826a7001BW24DzxvFXmIPG","sessionID":"ses_287087b03ffeyVD3nCcP1r3a2k","type":"tool","tool":"read","callID":"toolu_tool-4bb74e13a9d747508b1e9c611d5e17f5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/server_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/server_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"net/http\"\n7: \t\"net/http/httptest\"\n8: \t\"testing\"\n9: \t\"time\"\n10: \n11: \t\"github.com/gin-gonic/gin\"\n12: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n13: )\n14: \n15: func TestNewServer(t *testing.T) {\n16: \tgin.SetMode(gin.TestMode)\n17: \n18: \tconfig := DefaultConfig()\n19: \tconfig.Debug = true\n20: \n21: \tmockLogger := &MockLogger{}\n22: \tmockStore := &MockStore{}\n23: \tmockSM := &mockSessionManager{}\n24: \tjwtMgr, _ := NewJWTManager()\n25: \n26: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n27: \n28: \tif server == nil {\n29: \t\tt.Fatal(\"expected server to be created\")\n30: \t}\n31: \tif server.engine == nil {\n32: \t\tt.Error(\"expected engine to be initialized\")\n33: \t}\n34: \tif server.httpServer == nil {\n35: \t\tt.Error(\"expected httpServer to be initialized\")\n36: \t}\n37: }\n38: \n39: func TestNewServerNilConfig(t *testing.T) {\n40: \tgin.SetMode(gin.TestMode)\n41: \n42: \tmockLogger := &MockLogger{}\n43: \tmockStore := &MockStore{}\n44: \tmockSM := &mockSessionManager{}\n45: \tjwtMgr, _ := NewJWTManager()\n46: \n47: \tserver := NewServer(nil, mockSM, mockStore, jwtMgr, mockLogger)\n48: \n49: \tif server == nil {\n50: \t\tt.Fatal(\"expected server with default config\")\n51: \t}\n52: \tif server.config.Port != \":8080\" {\n53: \t\tt.Errorf(\"expected default port, got: %s\", server.config.Port)\n54: \t}\n55: }\n56: \n57: func TestNewServerNilSessionManager(t *testing.T) {\n58: \tgin.SetMode(gin.TestMode)\n59: \n60: \tconfig := DefaultConfig()\n61: \tmockLogger := &MockLogger{}\n62: \tmockStore := &MockStore{}\n63: \tjwtMgr, _ := NewJWTManager()\n64: \n65: \tserver := NewServer(config, nil, mockStore, jwtMgr, mockLogger)\n66: \n67: \tif server.sessionManager != nil {\n68: \t\tt.Error(\"expected nil sessionManager\")\n69: \t}\n70: }\n71: \n72: func TestNewServerMaxConcurrentRequests(t *testing.T) {\n73: \tgin.SetMode(gin.TestMode)\n74: \n75: \tconfig := &Config{\n76: \t\tPort:                  \":8080\",\n77: \t\tMaxConcurrentRequests: 0,\n78: \t}\n79: \n80: \tmockLogger := &MockLogger{}\n81: \tmockStore := &MockStore{}\n82: \tmockSM := &mockSessionManager{}\n83: \tjwtMgr, _ := NewJWTManager()\n84: \n85: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n86: \n87: \tif server.config.MaxConcurrentRequests != 1000 {\n88: \t\tt.Errorf(\"expected default 1000, got: %d\", server.config.MaxConcurrentRequests)\n89: \t}\n90: }\n91: \n92: func TestServerHandleHealthLive(t *testing.T) {\n93: \tgin.SetMode(gin.TestMode)\n94: \n95: \tconfig := DefaultConfig()\n96: \tmockLogger := &MockLogger{}\n97: \tmockStore := &MockStore{}\n98: \tmockSM := &mockSessionManager{}\n99: \tjwtMgr, _ := NewJWTManager()\n100: \n101: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n102: \n103: \treq := httptest.NewRequest(http.MethodGet, \"/health/live\", nil)\n104: \tw := httptest.NewRecorder()\n105: \n106: \tserver.engine.ServeHTTP(w, req)\n107: \n108: \tif w.Code != http.StatusOK {\n109: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n110: \t}\n111: \n112: \tvar resp map[string]string\n113: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n114: \tif resp[\"status\"] != \"alive\" {\n115: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n116: \t}\n117: }\n118: \n119: func TestServerHandleHealthReady(t *testing.T) {\n120: \tgin.SetMode(gin.TestMode)\n121: \n122: \tconfig := DefaultConfig()\n123: \tmockLogger := &MockLogger{}\n124: \tmockStore := &MockStore{}\n125: \tmockSM := &mockSessionManager{}\n126: \tjwtMgr, _ := NewJWTManager()\n127: \n128: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n129: \n130: \treq := httptest.NewRequest(http.MethodGet, \"/health/ready\", nil)\n131: \tw := httptest.NewRecorder()\n132: \n133: \tserver.engine.ServeHTTP(w, req)\n134: \n135: \tif w.Code != http.StatusOK {\n136: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n137: \t}\n138: \n139: \tvar resp map[string]string\n140: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n141: \tif resp[\"status\"] != \"ready\" {\n142: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n143: \t}\n144: }\n145: \n146: func TestServerHandleHealthReadyNoSessionManager(t *testing.T) {\n147: \tgin.SetMode(gin.TestMode)\n148: \n149: \tconfig := DefaultConfig()\n150: \tmockLogger := &MockLogger{}\n151: \tmockStore := &MockStore{}\n152: \tjwtMgr, _ := NewJWTManager()\n153: \n154: \tserver := NewServer(config, nil, mockStore, jwtMgr, mockLogger)\n155: \n156: \treq := httptest.NewRequest(http.MethodGet, \"/health/ready\", nil)\n157: \tw := httptest.NewRecorder()\n158: \n159: \tserver.engine.ServeHTTP(w, req)\n160: \n161: \tif w.Code != http.StatusServiceUnavailable {\n162: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n163: \t}\n164: \n165: \tvar resp map[string]string\n166: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n167: \tif resp[\"status\"] != \"not ready\" {\n168: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n169: \t}\n170: }\n171: \n172: func TestServerRoutesRegistered(t *testing.T) {\n173: \tgin.SetMode(gin.TestMode)\n174: \n175: \tconfig := DefaultConfig()\n176: \tmockLogger := &MockLogger{}\n177: \tmockStore := &MockStore{}\n178: \tmockSM := &mockSessionManager{}\n179: \tjwtMgr, _ := NewJWTManager()\n180: \n181: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n182: \n183: \troutes := server.engine.Routes()\n184: \n185: \texpectedRoutes := []string{\n186: \t\t\"/health/live\",\n187: \t\t\"/health/ready\",\n188: \t\t\"/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path\",\n189: \t\t\"/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path\",\n190: \t}\n191: \n192: \tfor _, expected := range expectedRoutes {\n193: \t\tfound := false\n194: \t\tfor _, route := range routes {\n195: \t\t\tif route.Path == expected {\n196: \t\t\t\tfound = true\n197: \t\t\t\tbreak\n198: \t\t\t}\n199: \t\t}\n200: \t\tif !found {\n201: \t\t\tt.Errorf(\"route not found: %s\", expected)\n202: \t\t}\n203: \t}\n204: }\n205: \n206: func TestServerStop(t *testing.T) {\n207: \tgin.SetMode(gin.TestMode)\n208: \n209: \tconfig := &Config{Port: \":0\"}\n210: \tmockLogger := &MockLogger{}\n211: \tmockStore := &MockStore{}\n212: \tmockSM := &mockSessionManager{}\n213: \tjwtMgr, _ := NewJWTManager()\n214: \n215: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n216: \n217: \tctx, cancel := context.WithCancel(context.Background())\n218: \tgo func() {\n219: \t\ttime.Sleep(50 * time.Millisecond)\n220: \t\tcancel()\n221: \t}()\n222: \n223: \tgo server.Start(ctx)\n224: \n225: \terr := server.Stop()\n226: \tif err != nil {\n227: \t\tt.Errorf(\"unexpected error: %v\", err)\n228: \t}\n229: }\n230: \n231: func TestServerGracefulShutdown(t *testing.T) {\n232: \tgin.SetMode(gin.TestMode)\n233: \n234: \tconfig := &Config{Port: \":0\"}\n235: \tmockLogger := &MockLogger{}\n236: \tmockStore := &MockStore{}\n237: \tmockSM := &mockSessionManager{}\n238: \tjwtMgr, _ := NewJWTManager()\n239: \n240: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n241: \n242: \tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n243: \tdefer cancel()\n244: \n245: \tgo server.Start(ctx)\n246: \n247: \ttime.Sleep(50 * time.Millisecond)\n248: \n249: \terr := server.Stop()\n250: \tif err != nil {\n251: \t\tt.Logf(\"stop error (expected on already shutdown): %v\", err)\n252: \t}\n253: }\n254: \n255: func TestServerGetEngine(t *testing.T) {\n256: \tgin.SetMode(gin.TestMode)\n257: \n258: \tconfig := DefaultConfig()\n259: \tmockLogger := &MockLogger{}\n260: \tmockStore := &MockStore{}\n261: \tmockSM := &mockSessionManager{}\n262: \tjwtMgr, _ := NewJWTManager()\n263: \n264: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n265: \n266: \tengine := server.GetEngine()\n267: \tif engine == nil {\n268: \t\tt.Error(\"expected engine to be returned\")\n269: \t}\n270: }\n271: \n272: func TestServerTLSRequired(t *testing.T) {\n273: \tgin.SetMode(gin.TestMode)\n274: \n275: \tconfig := &Config{\n276: \t\tPort:      \":8080\",\n277: \t\tEnableTLS: true,\n278: \t\tTLSCert:   \"\",\n279: \t\tTLSKey:    \"\",\n280: \t}\n281: \n282: \tmockLogger := &MockLogger{}\n283: \tmockStore := &MockStore{}\n284: \tmockSM := &mockSessionManager{}\n285: \tjwtMgr, _ := NewJWTManager()\n286: \n287: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n288: \n289: \tctx := context.Background()\n290: \terr := server.Start(ctx)\n291: \tif err == nil {\n292: \t\tt.Error(\"expected error when TLS cert/key are missing\")\n293: \t}\n294: }\n295: \n296: func TestServerHandleAgentInvoke(t *testing.T) {\n297: \tgin.SetMode(gin.TestMode)\n298: \n299: \tconfig := DefaultConfig()\n300: \tmockLogger := &MockLogger{}\n301: \tmockStore := &MockStore{\n302: \t\tGetSandboxBySessionIDFunc: func(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n303: \t\t\treturn &types.SandboxInfo{\n304: \t\t\t\tSessionID: \"test-session\",\n305: \t\t\t\tSandboxID: \"test-sandbox\",\n306: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n307: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n308: \t\t\t\t},\n309: \t\t\t}, nil\n310: \t\t},\n311: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n312: \t\t\treturn nil\n313: \t\t},\n314: \t}\n315: \tmockSM := &mockSessionManager{\n316: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n317: \t\t\treturn &types.SandboxInfo{\n318: \t\t\t\tSessionID: \"test-session\",\n319: \t\t\t\tSandboxID: \"test-sandbox\",\n320: \t\t\t\tKind:      types.AgentRuntimeKind,\n321: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n322: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n323: \t\t\t\t},\n324: \t\t\t}, nil\n325: \t\t},\n326: \t}\n327: \tjwtMgr, _ := NewJWTManager()\n328: \n329: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n330: \n331: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/test-runtime/invocations/api/test\", nil)\n332: \treq.Header.Set(\"x-agentcube-session-id\", \"test-session\")\n333: \tw := httptest.NewRecorder()\n334: \n335: \tserver.engine.ServeHTTP(w, req)\n336: }\n337: \n338: func TestServerHandleCodeInterpreterInvoke(t *testing.T) {\n339: \tgin.SetMode(gin.TestMode)\n340: \n341: \tconfig := DefaultConfig()\n342: \tmockLogger := &MockLogger{}\n343: \tmockStore := &MockStore{\n344: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n345: \t\t\treturn nil\n346: \t\t},\n347: \t}\n348: \tmockSM := &mockSessionManager{\n349: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n350: \t\t\treturn &types.SandboxInfo{\n351: \t\t\t\tSessionID: \"ci-session\",\n352: \t\t\t\tSandboxID: \"ci-sandbox\",\n353: \t\t\t\tKind:      types.CodeInterpreterKind,\n354: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n355: \t\t\t\t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n356: \t\t\t\t},\n357: \t\t\t}, nil\n358: \t\t},\n359: \t}\n360: \tjwtMgr, _ := NewJWTManager()\n361: \n362: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n363: \n364: \treq := httptest.NewRequest(http.MethodPost, \"/v1/namespaces/default/code-interpreters/test-ci/invocations/execute/code\", nil)\n365: \treq.Header.Set(\"x-agentcube-session-id\", \"ci-session\")\n366: \tw := httptest.NewRecorder()\n367: \n368: \tserver.engine.ServeHTTP(w, req)\n369: }\n370: \n371: type mockSessionManager struct {\n372: \tgetFunc func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error)\n373: }\n374: \n375: func (m *mockSessionManager) GetSandboxBySession(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n376: \tif m.getFunc != nil {\n377: \t\treturn m.getFunc(ctx, sessionID, namespace, name, kind)\n378: \t}\n379: \treturn nil, nil\n380: }\n\n(End of file - total 380 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestNewServer(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tconfig := DefaultConfig()\n\tconfig.Debug = true\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/server_test.go","time":{"start":1775851028589,"end":1775851028597}}}}
{"type":"tool_use","timestamp":1775851028605,"sessionID":"ses_287087b03ffeyVD3nCcP1r3a2k","part":{"id":"prt_d78f83c2f001fK8SY2VvIsE7Jj","messageID":"msg_d78f826a7001BW24DzxvFXmIPG","sessionID":"ses_287087b03ffeyVD3nCcP1r3a2k","type":"tool","tool":"read","callID":"toolu_tool-b4ebada8c764448b960816579fa5f51b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/shared_types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/shared_types.go</path>\n<type>file</type>\n<content>\n1: package v1alpha1\n2: \n3: import \"time\"\n4: \n5: // ============================================================================\n6: // Type Definitions\n7: // ============================================================================\n8: \n9: // ProtocolType defines the protocol for a target port.\n10: // +kubebuilder:validation:Enum=HTTP;HTTPS\n11: type ProtocolType string\n12: \n13: const (\n14: \t// ProtocolTypeHTTP indicates HTTP protocol.\n15: \tProtocolTypeHTTP ProtocolType = \"HTTP\"\n16: \t// ProtocolTypeHTTPS indicates HTTPS protocol.\n17: \tProtocolTypeHTTPS ProtocolType = \"HTTPS\"\n18: )\n19: \n20: // AuthModeType defines the authentication mode for a CodeInterpreter.\n21: // +kubebuilder:validation:Enum=picod;none\n22: type AuthModeType string\n23: \n24: const (\n25: \t// AuthModePicoD indicates pico authentication mode.\n26: \tAuthModePicoD AuthModeType = \"picod\"\n27: \t// AuthModeNone indicates no authentication.\n28: \tAuthModeNone AuthModeType = \"none\"\n29: )\n30: \n31: // TargetPort defines a network port configuration for exposing sandbox services.\n32: type TargetPort struct {\n33: \t// PathPrefix is the URL path prefix for routing to this port.\n34: \t// +optional\n35: \tPathPrefix string `json:\"pathPrefix,omitempty\"`\n36: \n37: \t// Name is a human-readable name for this port.\n38: \t// +optional\n39: \tName string `json:\"name,omitempty\"`\n40: \n41: \t// Port is the container port number to expose.\n42: \tPort uint32 `json:\"port\"`\n43: \n44: \t// Protocol specifies the protocol for this port (HTTP or HTTPS).\n45: \t// +kubebuilder:default=HTTP\n46: \t// +kubebuilder:validation:Enum=HTTP;HTTPS\n47: \tProtocol ProtocolType `json:\"protocol\"`\n48: }\n49: \n50: // ============================================================================\n51: // Label Constants\n52: // ============================================================================\n53: \n54: const (\n55: \t// LabelKeyOwnerRuntime indicates the owning AgentRuntime/CodeInterpreter name.\n56: \tLabelKeyOwnerRuntime = \"runtime.agentcube.volcano.sh/owner-runtime\"\n57: \n58: \t// LabelKeyOwnerKind indicates the owning CRD kind (AgentRuntime/CodeInterpreter).\n59: \tLabelKeyOwnerKind = \"runtime.agentcube.volcano.sh/owner-kind\"\n60: \n61: \t// LabelKeySessionID indicates the active session identifier.\n62: \tLabelKeySessionID = \"runtime.agentcube.volcano.sh/session-id\"\n63: \n64: \t// LabelKeySandboxType indicates the sandbox type (agent/code-interpreter).\n65: \tLabelKeySandboxType = \"runtime.agentcube.volcano.sh/sandbox-type\"\n66: \n67: \t// LabelKeySandboxTypeAgent indicates an agent sandbox.\n68: \tLabelKeySandboxTypeAgent = \"agent\"\n69: \n70: \t// LabelKeySandboxTypeCodeInterpreter indicates a code interpreter sandbox.\n71: \tLabelKeySandboxTypeCodeInterpreter = \"code-interpreter\"\n72: )\n73: \n74: // ============================================================================\n75: // Annotation Constants\n76: // ============================================================================\n77: \n78: const (\n79: \t// AnnotationKeyAuthMode stores the authentication mode for the sandbox.\n80: \tAnnotationKeyAuthMode = \"runtime.agentcube.volcano.sh/auth-mode\"\n81: \n82: \t// AnnotationKeySessionStart stores the session start timestamp.\n83: \tAnnotationKeySessionStart = \"runtime.agentcube.volcano.sh/session-start\"\n84: \n85: \t// AnnotationKeySessionEnd stores the session end timestamp.\n86: \tAnnotationKeySessionEnd = \"runtime.agentcube.volcano.sh/session-end\"\n87: \n88: \t// AnnotationKeyLastActivity stores the last activity timestamp.\n89: \tAnnotationKeyLastActivity = \"runtime.agentcube.volcano.sh/last-activity\"\n90: \n91: \t// AnnotationKeyWarmPoolMember indicates if pod is part of warm pool.\n92: \tAnnotationKeyWarmPoolMember = \"runtime.agentcube.volcano.sh/warm-pool-member\"\n93: )\n94: \n95: // ============================================================================\n96: // Condition Type Constants\n97: // ============================================================================\n98: \n99: const (\n100: \t// ConditionTypeReady indicates the runtime is ready to accept sessions.\n101: \tConditionTypeReady = \"Ready\"\n102: \n103: \t// ConditionTypeAvailable indicates the runtime is available for use.\n104: \tConditionTypeAvailable = \"Available\"\n105: \n106: \t// ConditionTypeProgressing indicates the runtime is being created/updated.\n107: \tConditionTypeProgressing = \"Progressing\"\n108: \n109: \t// ConditionTypeDegraded indicates the runtime is in a degraded state.\n110: \tConditionTypeDegraded = \"Degraded\"\n111: \n112: \t// ConditionTypeSessionActive indicates an active session is running.\n113: \tConditionTypeSessionActive = \"SessionActive\"\n114: )\n115: \n116: // ============================================================================\n117: // Condition Reason Constants\n118: // ============================================================================\n119: \n120: const (\n121: \t// ConditionReasonRunning indicates the runtime is running normally.\n122: \tConditionReasonRunning = \"Running\"\n123: \n124: \t// ConditionReasonCreating indicates the runtime is being created.\n125: \tConditionReasonCreating = \"Creating\"\n126: \n127: \t// ConditionReasonUpdating indicates the runtime is being updated.\n128: \tConditionReasonUpdating = \"Updating\"\n129: \n130: \t// ConditionReasonDeleting indicates the runtime is being deleted.\n131: \tConditionReasonDeleting = \"Deleting\"\n132: \n133: \t// ConditionReasonError indicates an error occurred.\n134: \tConditionReasonError = \"Error\"\n135: \n136: \t// ConditionReasonTimeout indicates a timeout occurred.\n137: \tConditionReasonTimeout = \"Timeout\"\n138: \n139: \t// ConditionReasonSessionStarted indicates a session has started.\n140: \tConditionReasonSessionStarted = \"SessionStarted\"\n141: \n142: \t// ConditionReasonSessionEnded indicates a session has ended.\n143: \tConditionReasonSessionEnded = \"SessionEnded\"\n144: \n145: \t// ConditionReasonIdleTimeout indicates session ended due to idle timeout.\n146: \tConditionReasonIdleTimeout = \"IdleTimeout\"\n147: \n148: \t// ConditionReasonMaxDurationReached indicates session ended due to max duration.\n149: \tConditionReasonMaxDurationReached = \"MaxDurationReached\"\n150: )\n151: \n152: // ============================================================================\n153: // Default Value Constants\n154: // ============================================================================\n155: \n156: const (\n157: \t// DefaultSessionTimeout is the default idle session timeout (15 minutes).\n158: \tDefaultSessionTimeout = 15 * time.Minute\n159: \n160: \t// DefaultMaxSessionDuration is the default maximum session duration (8 hours).\n161: \tDefaultMaxSessionDuration = 8 * time.Hour\n162: \n163: \t// DefaultWarmPoolSize is the default warm pool size for CodeInterpreter.\n164: \tDefaultWarmPoolSize = 0\n165: )\n166: \n167: var (\n168: \t// DefaultAuthMode is the default authentication mode.\n169: \tDefaultAuthMode = AuthModePicoD\n170: \n171: \t// DefaultProtocol is the default protocol for TargetPort.\n172: \tDefaultProtocol = ProtocolTypeHTTP\n173: )\n\n(End of file - total 173 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport \"time\"\n\n// ============================================================================\n// Type Definitions\n// ============================================================================\n\n// ProtocolType defines the protocol for a target port.\n// +kubebuilder:validation:Enum=HTTP;HTTPS\ntype ProtocolType string\n\nconst (\n\t// ProtocolTypeHTTP indicates HTTP protocol.\n\tProtocolTypeHTTP ProtocolType = \"HTTP\"\n\t// ProtocolTypeHTTPS indicates HTTPS protocol.\n\tProtocolTypeHTTPS ProtocolType = \"HTTPS\"\n)\n\n// AuthModeType defines the authentication mode for a CodeInterpreter.","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/shared_types.go","time":{"start":1775851028585,"end":1775851028602}}}}
{"type":"step_finish","timestamp":1775851028626,"sessionID":"ses_287087b03ffeyVD3nCcP1r3a2k","part":{"id":"prt_d78f8407c001PhdRMpagtUkSO8","reason":"tool-calls","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","messageID":"msg_d78f826a7001BW24DzxvFXmIPG","sessionID":"ses_287087b03ffeyVD3nCcP1r3a2k","type":"step-finish","tokens":{"total":42260,"input":2782,"output":183,"reasoning":0,"cache":{"write":0,"read":39295}},"cost":0}}
