rkspace/test.py\")\n161:         call_args = client._request.call_args\n162:         import json\n163:         body = json.loads(call_args.args[2].decode())\n164:         assert body[\"mode\"] == \"0644\"\n165: \n166: \n167: class TestUploadFile:\n168:     def test_upload_file_multipart(self, tmp_path: Path) -> None:\n169:         client = CodeInterpreterDataPlaneClient(\n170:             session_id=\"session-123\",\n171:             base_url=\"http://router/v1/invocations/\",\n172:         )\n173:         local_file = tmp_path / \"test.txt\"\n174:         local_file.write_text(\"content\")\n175: \n176:         mock_response = MagicMock()\n177:         mock_response.raise_for_status = MagicMock()\n178:         client.session.post = MagicMock(return_value=mock_response)\n179: \n180:         client.upload_file(str(local_file), \"/workspace/test.txt\")\n181:         call_args = client.session.post.call_args\n182:         assert \"files\" in call_args.kwargs\n183:         assert \"data\" in call_args.kwargs\n184:         assert call_args.kwargs[\"data\"][\"path\"] == \"/workspace/test.txt\"\n185: \n186:     def test_upload_file_session_header(self, tmp_path: Path) -> None:\n187:         client = CodeInterpreterDataPlaneClient(\n188:             session_id=\"session-123\",\n189:             base_url=\"http://router/v1/invocations/\",\n190:         )\n191:         local_file = tmp_path / \"test.txt\"\n192:         local_file.write_text(\"content\")\n193: \n194:         mock_response = MagicMock()\n195:         mock_response.raise_for_status = MagicMock()\n196:         client.session.post = MagicMock(return_value=mock_response)\n197: \n198:         client.upload_file(str(local_file), \"/workspace/test.txt\")\n199:         call_args = client.session.post.call_args\n200:         assert call_args.kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"session-123\"\n201: \n202: \n203: class TestDownloadFile:\n204:     def test_download_file_stream(self, tmp_path: Path) -> None:\