ntimeDataPlaneClient(\n38:             router_url=\"http://router.example.com\",\n39:             namespace=\"default\",\n40:             agent_name=\"my-agent\",\n41:         )\n42:         expected = \"http://router.example.com/v1/namespaces/default/agent-runtimes/my-agent/invocations/\"\n43:         assert client.base_url == expected\n44: \n45:     def test_base_url_with_custom_namespace(self):\n46:         client = AgentRuntimeDataPlaneClient(\n47:             router_url=\"http://router.example.com\",\n48:             namespace=\"production\",\n49:             agent_name=\"prod-agent\",\n50:         )\n51:         expected = \"http://router.example.com/v1/namespaces/production/agent-runtimes/prod-agent/invocations/\"\n52:         assert client.base_url == expected\n53: \n54: \n55: class TestConnectionPooling:\n56:     def test_connection_pooling(self):\n57:         client = AgentRuntimeDataPlaneClient(\n58:             router_url=\"http://router.example.com\",\n59:             namespace=\"default\",\n60:             agent_name=\"test-agent\",\n61:             pool_connections=10,\n62:             pool_maxsize=10,\n63:         )\n64:         http_adapter = client.session.get_adapter(\"http://\")\n65:         https_adapter = client.session.get_adapter(\"https://\")\n66:         assert isinstance(http_adapter, HTTPAdapter)\n67:         assert isinstance(https_adapter, HTTPAdapter)\n68: \n69: \n70: class TestBootstrapSessionID:\n71:     @responses.activate\n72:     def test_bootstrap_success(self):\n73:         responses.get(\n74:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n75:             headers={\"x-agentcube-session-id\": \"test-session-123\"},\n76:         )\n77:         client = AgentRuntimeDataPlaneClient(\n78:             router_url=\"http://router.example.com\",\n79:             namespace=\"default\",\n80:             agent_name=\"test-agent\",\n81:         )\n82:         session_id = client.bootstrap_session_id()\n83:         assert session_id == \"test-session-123\"\n84: \n85:     @responses.activate\n86:     def test_bootstrap_missing_header(self):\n87:         responses.get(\n88:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n89:         )\n90:         client = AgentRuntimeDataPlaneClient(\n91:             router_url=\"http://router.example.com\",\n92:             namespace=\"default\",\n93:             agent_name=\"test-agent\",\n94:         )\n95:         with pytest.raises(ValueError, match=\"Missing required response header: x-agentcube-session-id\"):\n96:             client.bootstrap_session_id()\n97: \n98: \n99: class TestInvoke:\n100:     @responses.activate\n101:     def test_invoke_with_session(self):\n102:         responses.post(\n103:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n104:             json={\"result\": \"success\"},\n105:             status=200,\n106:         )\n107:         client = AgentRuntimeDataPlaneClient(\n108:             router_url=\"http://router.example.com\",\n109:             namespace=\"default\",\n110:             agent_name=\"test-agent\",\n111:         )\n112:         resp = client.invoke(\"test-session-123\", {\"input\": \"test\"})\n113:         assert resp.status_code == 200\n114:         assert resp.json() == {\"result\": \"success\"}\n115: \n116: \n117: class TestInvokeHeaders:\n118:     @responses.activate\n119:     def test_invoke_headers_correctness(self):\n120:         responses.post(\n121:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n122:             json={\"result\": \"success\"},\n123:         )\n124:         client = AgentRuntimeDataPlaneClient(\n125:             router_url=\"http://router.example.com\",\n126:             namespace=\"default\",\n127:             agent_name=\"test-agent\",\n128:         )\n129:         client.invoke(\"test-session-123\", {\"input\": \"test\"})\n130:         assert len(responses.calls) == 1\n131:         call = responses.calls[0]\n132:         assert call.request.headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n133:         assert call.request.headers[\"Content-Type\"] == \"application/json\"\n134: \n135: \n136: class TestInvokeTimeout:\n137:     @responses.activate\n138:     def test_invoke_timeout_override(self):\n139:         responses.post(\n140:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n141:             json={\"result\": \"success\"},\n142:         )\n143:         client = AgentRuntimeDataPlaneClient(\n144:             router_url=\"http://router.example.com\",\n145:             namespace=\"default\",\n146:             agent_name=\"test-agent\",\n147:             timeout=120,\n148:             connect_timeout=5.0,\n149:         )\n150:         client.invoke(\"test-session-123\", {\"input\": \"test\"}, timeout=30)\n151:         assert len(responses.calls) == 1\n152: \n153:     @responses.activate\n154:     def test_invoke_timeout_default(self):\n155:         responses.post(\n156:             \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n157:             json={\"result\": \"success\"},\n158:         )\n159:         client = AgentRuntimeDataPlaneClient(\n160:             router_url=\"http://router.example.com\",\n161:             namespace=\"default\",\n162:             agent_name=\"test-agent\",\n163:             timeout=120,\n164:             connect_timeout=5.0,\n165:         )\n166:         client.invoke(\"test-session-123\", {\"input\": \"test\"})\n167:         assert len(responses.calls) == 1\n168: \n169: \n170: class TestClose:\n171:     def test_close(self):\n172:         client = AgentRuntimeDataPlaneClient(\n173:             router_url=\"http://router.example.com\",\n174:             namespace=\"default\",\n175:             agen