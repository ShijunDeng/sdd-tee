x-k8s.io\",\n43: \t\tVersion:  \"v1alpha1\",\n44: \t\tResource: \"sandboxclaims\",\n45: \t}\n46: )\n47: \n48: const (\n49: \tSandboxKind      = \"Sandbox\"\n50: \tSandboxClaimKind = \"SandboxClaim\"\n51: )\n\n(End of file - total 51 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"time\"\n\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n)\n\nconst (\n\tDefaultSandboxTTL         = 8 * time.Hour\n\tDefaultSandboxIdleTimeout = 15 * time.Minute\n\tDefaultMaxSessionDuration = 8 * time.Hour\n\tDefaultSessionTimeout     = 15 * time.Minute\n\tSandboxCreationTimeout    = 2 * time.Minute\n\tSandboxDeleteTimeout      = 30 * time.Second\n\tInformerSyncTimeout       = 1 * time.Minute\n\tGarbageCollectorInterval  = 2 * time.Minute\n)\n\nconst (","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/defaults.go","time":{"start":1775844982064,"end":1775844982077}}}}
