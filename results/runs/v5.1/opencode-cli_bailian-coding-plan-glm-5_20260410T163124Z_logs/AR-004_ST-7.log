  time.Duration // Read timeout for HTTP connections\n\tWriteTimeout    time.Duration // Write timeout for HTTP connections\n\tIdleTimeout     time.Duration // Idle connection timeout\n\tShutdownTimeout time.Duration // Graceful shutdown timeout\n\tEnableHealthz   bool          // Enable /healthz endpoint\n\tEnableReadyz    bool          // Enable /readyz endpoint\n}\n\n// DefaultConfig returns a Config with sensible default values.\nfunc DefaultConfig() Config {\n\treturn Config{\n\t\tAddr:            \":8080\",\n\t\tReadTimeout:     15 * time.Second,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/config.go","time":{"start":1775843038516,"end":1775843038528}}}}
{"type":"tool_use","timestamp":1775843038532,"sessionID":"ses_2878214aaffeI6c18ZpmRe5XsX","part":{"id":"prt_d787e551f001MaiK1t2xRhWiaj","messageID":"msg_d787e2ed0001uReyv6JBGOeWHd","sessionID":"ses_2878214aaffeI6c18ZpmRe5XsX","type":"tool","tool":"read","callID":"toolu_tool-f0e777873c1d4494baaa42738475da8e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \n8: \t\"github.com/go-chi/chi/v5\"\n9: )\n10: \n11: // Handler defines the interface for registering routes on a chi router.\n12: type Handler interface {\n13: \tRegister(r chi.Router)\n14: }\n15: \n16: // Logger defines the interface for logging within the workloadmanager package.\n17: type Logger interface {\n18: \tInfo(msg string, args ...any)\n19: \tError(msg string, args ...any)\n20: }\n21: \n22: // ErrorResponse represents a standardized API error response.\n23: type ErrorResponse struct {\n24: \tCode    string `json:\"code\"`\n25: \tMessage string `json:\"message\"`\n26: \tDetails any    `json:\"details,omitempty\"`\n27: }\n28: \n29: // SuccessResponse represents a standardized API success response.\n30: type SuccessResponse struct {\n31: \tData any `json:\"data\"`\n32: }\n33: \n34: // ValidationError indicates invalid request parameters.\n35: type ValidationError struct {\n36: \tField  string\n37: \tReason string\n38: }\n39: \n40: func (e *ValidationError) Error() string {\n41: \treturn fmt.Sprintf(\"validation error: %s - %s\", e.Field, e.Reason)\n42: }\n43: \n44: // NotFoundError indicates a requested resource was not found.\n45: type NotFoundError struct {\n46: \tResource string\n47: \tName     string\n48: }\n49: \n50: func (e *NotFoundError) Error() string {\n51: \treturn fmt.Sprintf(\"not found: %s/%s\", e.Resource, e.Name)\n52: }\n53: \n54: // InternalError indicates an unexpected server error occurred.\n55: type InternalError struct {\n56: \tErr error\n57: }\n58: \n59: func (e *InternalError) Error() string {\n60: \treturn fmt.Sprintf(\"internal error: %v\", e.Err)\n61: }\n62: \n63: // ServiceUnavailableError indicates a dependency service is unavailable.\n64: type ServiceUnavailableError struct {\n65: \tDependency string\n66: }\n67: \n68: func (e *ServiceUnavailableError) Error() string {\n69: \treturn fmt.Sprintf(\"service unavailable: %s\", e.Dependency)\n70: }\n71: \n72: // HandleError maps error types to appropriate HTTP status codes and JSON responses.\n73: // It always sets Content-Type: application/json header.\n74: func HandleError(w http.ResponseWriter, _ *http.Request, err error) {\n75: \tw.Header().Set(\"Content-Type\", \"application/json\")\n76: \n77: \tvar resp ErrorResponse\n78: \tvar status int\n79: \n80: \tswitch e := err.(type) {\n81: \tcase *ValidationError:\n82: \t\tstatus = http.StatusBadRequest\n83: \t\tresp = ErrorResponse{\n84: \t\t\tCode:    \"VALIDATION_ERROR\",\n85: \t\t\tMessage: \"Invalid request parameter\",\n86: \t\t\tDetails: map[string]string{\"field\": e.Field, \"reason\": e.Reason},\n87: \t\t}\n88: \tcase *NotFoundError:\n89: \t\tstatus = http.StatusNotFound\n90: \t\tresp = ErrorResponse{\n91: \t\t\tCode:    \"NOT_FOUND\",\n92: \t\t\tMessage: e.Error(),\n93: \t\t}\n94: \tcase *ServiceUnavailableError:\n95: \t\tstatus = http.StatusServiceUnavailable\n96: \t\tresp = ErrorResponse{\n97: \t\t\tCode:    \"SERVICE_UNAVAILABLE\",\n98: \t\t\tMessage: e.Error(),\n99: \t\t}\n100: \tcase *InternalError:\n101: \t\tstatus = http.StatusInternalServerError\n102: \t\tresp = ErrorResponse{\n103: \t\t\tCode:    \"INTERNAL_ERROR\",\n104: \t\t\tMessage: \"Unexpected server error\",\n105: \t\t}\n106: \tdefault:\n107: \t\tstatus = http.StatusInternalServerError\n108: \t\tresp = ErrorResponse{\n109: \t\t\tCode:    \"INTERNAL_ERROR\",\n110: \t\t\tMessage: \"Unexpected server error\",\n111: \t\t}\n112: \t}\n113: \n114: \tw.WriteHeader(status)\n115: \tjson.NewEncoder(w).Encode(resp)\n116: }\n\n(End of file - total 116 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// Handler defines the interface for registering routes on a chi router.\ntype Handler interface {\n\tRegister(r chi.Router)\n}\n\n// Logger defines the interface for logging within the workloadmanager package.\ntype Logger interface {\n\tInfo(msg string, args ...any)\n\tError(msg string, args ...any)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types.go","time":{"start":1775843038517,"end":1775843038530}}}}
