ace\" pkg/workloadmanager/handlers/handler.go` |\n408: | T4.7 | `grep -q \"func.*readyz\" pkg/workloadmanager/handlers/health.go` |\n409: | T5.3 | `grep -q \"func.*Wrap\" pkg/workloadmanager/middleware/logging.go` |\n410: | T5.5 | `grep -q \"recover()\" pkg/workloadmanager/middleware/recovery.go` |\n411: | T5.8 | `grep -q \"Access-Control-Allow-Origin\" pkg/workloadmanager/middleware/cors.go` |\n412: | T6.2 | `grep -q \"func NewHTTPServer\" pkg/workloadmanager/server.go` |\n413: | T6.6 | `grep -q \"func.*GracefulShutdown\" pkg/workloadmanager/server.go` |\n414: | T7.1 | `go test ./pkg/workloadmanager/... -run TestHandleError -v` |\n415: | T7.7 | `go test ./pkg/workloadmanager/handlers/... -run TestHealthz -v` |\n416: | T8.1 | `go test ./pkg/workloadmanager/... -run TestE2EHealthz -v` |\n417: | T9.4 | `go vet ./pkg/workloadmanager/...` |\n418: | T9.5 | `golangci-lint run ./pkg/workloadmanager/...` |\n419: | T9.6 | `go build ./pkg/workloadmanager/...` |\n420: | T9.7 | `go test -cover ./pkg/workloadmanager/...` |\n421: \n422: ---\n423: \n424: ## Acceptance Criteria\n425: \n426: - [ ] HTTP server starts on configured address\n427: - [ ] HTTPServer struct contains: server, router, config, handlers, logger, stopCh\n428: - [ ] Config struct contains: Addr, ReadTimeout, WriteTimeout, IdleTimeout, ShutdownTimeout, EnableHealthz, EnableReadyz\n429: - [ ] DefaultConfig returns: Addr \":8080\", ReadTimeout 15s, WriteTimeout 15s, IdleTimeout 60s, ShutdownTimeout 30s\n430: - [ ] NewHTTPServer initializes router with chi.NewRouter()\n431: - [ ] HTTPServer.Start returns error channel, starts ListenAndServe\n432: - [ ] HTTPServer.Stop calls Shutdown with context timeout\n433: - [ ] HTTPServer.GracefulShutdown handles SIGTERM/SIGINT\n434: - [ ] Router struct embeds chi.Router\n435: - [ ] RegisterHandlers calls each handler's Register method\n436: - [ ] Handler interface defines Register(r chi.Router)\n437: - [ ] HandlerFunc.ServeHTTP calls HandleError on error\n438: - [ ] healthz end