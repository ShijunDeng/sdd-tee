{"type":"tool_use","timestamp":1775843053234,"sessionID":"ses_2878214aaffeI6c18ZpmRe5XsX","part":{"id":"prt_d787e8e6f0019o1oQ5vYiGrzg5","messageID":"msg_d787e5580001FAxhsZQkx0ADl9","sessionID":"ses_2878214aaffeI6c18ZpmRe5XsX","type":"tool","tool":"read","callID":"toolu_tool-fe28290834684511aff7b449ec95554b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"strings\"\n6: )\n7: \n8: // CORSConfig defines the CORS policy configuration.\n9: type CORSConfig struct {\n10: \tAllowedOrigins   []string\n11: \tAllowedMethods   []string\n12: \tAllowedHeaders   []string\n13: \tAllowCredentials bool\n14: }\n15: \n16: // CORSMiddleware handles Cross-Origin Resource Sharing headers.\n17: type CORSMiddleware struct {\n18: \tconfig CORSConfig\n19: }\n20: \n21: // NewCORSMiddleware creates a CORSMiddleware with the given configuration.\n22: func NewCORSMiddleware(config CORSConfig) *CORSMiddleware {\n23: \treturn &CORSMiddleware{config: config}\n24: }\n25: \n26: // Wrap returns an http.Handler that adds CORS headers to responses.\n27: func (m *CORSMiddleware) Wrap(next http.Handler) http.Handler {\n28: \treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n29: \t\torigin := r.Header.Get(\"Origin\")\n30: \t\tif origin != \"\" && m.isAllowedOrigin(origin) {\n31: \t\t\tw.Header().Set(\"Access-Control-Allow-Origin\", origin)\n32: \t\t\tw.Header().Set(\"Access-Control-Allow-Methods\", strings.Join(m.config.AllowedMethods, \",\"))\n33: \t\t\tw.Header().Set(\"Access-Control-Allow-Headers\", strings.Join(m.config.AllowedHeaders, \",\"))\n34: \t\t\tif m.config.AllowCredentials {\n35: \t\t\t\tw.Header().Set(\"Access-Control-Allow-Credentials\", \"true\")\n36: \t\t\t}\n37: \t\t}\n38: \n39: \t\tif r.Method == \"OPTIONS\" {\n40: \t\t\tw.WriteHeader(http.StatusOK)\n41: \t\t\treturn\n42: \t\t}\n43: \n44: \t\tnext.ServeHTTP(w, r)\n45: \t})\n46: }\n47: \n48: func (m *CORSMiddleware) isAllowedOrigin(origin string) bool {\n49: \tfor _, o := range m.config.AllowedOrigins {\n50: \t\tif o == \"*\" || o == origin {\n51: \t\t\treturn true\n52: \t\t}\n53: \t}\n54: \treturn false\n55: }\n\n(End of file - total 55 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"strings\"\n)\n\n// CORSConfig defines the CORS policy configuration.\ntype CORSConfig struct {\n\tAllowedOrigins   []string\n\tAllowedMethods   []string\n\tAllowedHeaders   []string\n\tAllowCredentials bool\n}\n\n// CORSMiddleware handles Cross-Origin Resource Sharing headers.\ntype CORSMiddleware struct {\n\tconfig CORSConfig\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors.go","time":{"start":1775843053205,"end":1775843053232}}}}
