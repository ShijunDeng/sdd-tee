ation/json\")\n41: \tif h.checker == nil || !h.checker.IsReady() {\n42: \t\tw.WriteHeader(http.StatusServiceUnavailable)\n43: \t\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"not ready\"})\n44: \t\treturn\n45: \t}\n46: \tw.WriteHeader(http.StatusOK)\n47: \tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ready\"})\n48: }\n\n(End of file - total 48 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// HealthChecker defines the interface for health and readiness checks.\ntype HealthChecker interface {\n\tIsHealthy() bool\n\tIsReady() bool\n}\n\n// HealthHandler provides /healthz and /readyz endpoints for Kubernetes probes.\ntype HealthHandler struct {\n\tchecker HealthChecker\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/health.go","time":{"start":1775843053200,"end":1775843053228}}}}
