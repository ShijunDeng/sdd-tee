: int,\n150:         entrypoint: Optional[str],\n151:         replicas: int,\n152:         env_vars: Optional[Dict[str, str]],\n153:     ) -> Dict[str, Any]:\n154:         env_list = []\n155:         if env_vars:\n156:             for k, v in env_vars.items():\n157:                 env_list.append({\"name\": k, \"value\": v})\n158:         \n159:         command = None\n160:         if entrypoint:\n161:             parts = entrypoint.split()\n162:             command = parts\n163:         \n164:         deployment_body = {\n165:             \"spec\": {\n166:                 \"replicas\": replicas,\n167:                 \"template\": {\n168:                     \"spec\": {\n169:                         \"containers\": [{\n170:                             \"name\": name,\n171:                             \"image\": image_url,\n172:                             \"ports\": [{\"containerPort\": port}],\n173:                             \"env\": env_list,\n174:                         }],\n175:                     },\n176:                 },\n177:             },\n178:         }\n179:         \n180:         if command:\n181:             deployment_body[\"spec\"][\"template\"][\"spec\"][\"containers\"][0][\"command\"] = command\n182:         \n183:         result = self._apps_api.patch_namespaced_deployment(\n184:             name=name,\n185:             namespace=self.namespace,\n186:             body=deployment_body,\n187:         )\n188:         \n189:         if self.verbose:\n190:             self._logger.info(f\"Patched deployment {name} in namespace {self.namespace}\")\n191:         \n192:         return {\"name\": name, \"status\": \"updated\"}\n193: \n194:     def _create_service(\n195:         self, \n196:         name: str, \n197:         port: int, \n198:         node_port: Optional[int]\n199:     ) -> Dict[str, Any]:\n200:         service_body = {\n201:             \"apiVersion\": \"v1\",\n202:             \"kind\": \"Service\",\n203:             \"metadata\": {\n204:                 \"name\": name,\n205:                 \"namespace\": self.namespace,\n206:             },\n207:             \"spec\": {\n208:                 \"type\": \"NodePort\",\n209:                 \"selector\": {\"app\": name},\n210:                 \"ports\": [{\n211:                     \"port\": port,\n212:                     \"targetPort\": port,\n213:                 }],\n214:             },\n215:         }\n216:         \n217:         if node_port:\n218:             service_body[\"spec\"][\"ports\"][0][\"nodePort\"] = node_port\n219:         \n220:         try:\n221:             result = self._core_api.create_namespaced_service(\n222:                 namespace=self.namespace,\n223:                 body=service_body,\n224:             )\n225:             actual_node_port = result.spec.ports[0].node_port\n226:         except kubernetes.client.exceptions.ApiException as e:\n227:             if e.status == 409:\n228:                 result = self._core_api.patch_namespaced_service(\n229:                     name=name,\n230:                     namespace=self.namespace,\n231:                     body=service_body,\n232:                 )\n233:                 actual_node_port = result.spec.ports[0].node_port\n234:             else:\n235:                 raise RuntimeError(f\"Failed to create service: {e}\")\n236:         \n237:         if self.verbose:\n238:             self._logger.info(f\"Created service {name} with NodePort {actual_node_port}\")\n239:         \n240:         return {\"name\": name, \"node_port\": actual_node_port}\n241: \n242:     def wait_for_deployment_ready(self, name: str, timeout: int = 120) -> None:\n243:         start = time.time()\n244:         while time.time() - start < timeout:\n245:             try:\n246:                 deployment = self._apps_api.read_namespaced_deployment(\n247:                     name=name,\n248:                     namespace=self.namespace,\n249:                 )\n250:                 if deployment.status.available_replicas == deployment.spec.replicas:\n251:                     if self.verbose:\n252:                         self._logger.info(f\"Deployment {name} is ready\")\n253:                     return\n254:             except kubernetes.client.exceptions.ApiException as e:\n255:                 if self.verbose:\n256:                     self._logger.warning(f\"Error checking deployment status: {e}\")\n257:             time.sleep(self.POLL_INTERVAL)\n258:         raise TimeoutError(f\"Deployment {name} not ready after {timeout}s\")\n259: \n260:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n261:         sanitized_name = self._sanitize_name(agent_name)\n262:         \n263:         try:\n264:             deployment = self._apps_api.read_namespaced_deployment(\n265:                 name=sanitized_name,\n266:                 namespace=self.namespace,\n267:             )\n268:             deployment_status = {\n269:                 \"name\": sanitized_name,\n270:                 \"replicas\": deployment.spec.replicas,\n271:                 \"available_replicas\": deployment.status.available_replicas or 0,\n272:                 \"ready_replicas\": deployment.status.ready_replicas or 0,\n273:             }\n274:         except kubernetes.client.exceptions.ApiException:\n275:             deployment_status = {\"name\": sanitized_name, \"status\": \"not_found\"}\n276:         \n277:         try:\n278:             service = self._core_api.read_namespaced_service(\n279:                 name=sanitized_name,\n280:                 namespace=self.namespace,\n281:             )\n282:             service_status = {\n283:                 \"name\": sanitized_name,\n284:                 \"node_port\": service.spec.ports[0].node_port,\n285:             }\n286:         except kubernetes.client.exceptions.ApiException:\n287:             service_status = {\"name\": sanitized_name, \"status\": \"not_found\"}\n288:         \n289:         return {\n290:             \"deployment\": deployment_status,\n291:             \"service\": service_status,\n292:         }\n293: \n294:     def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n295:         sanitized_name = self._sanitize_name(agent_name)\n296:         \n297:         try:\n298:             self._apps_api.delete_namespaced_deployment(\n299:                 name=sanitized_name,\n300:                 namespace=self.namespace,\n301:                 body=kubernetes.client.V1DeleteOptions(),\n302:             )\n303:             deployment_deleted = True\n304:         except kubernetes.client.exceptions.ApiException:\n305:             deployment_deleted = False\n306:         \n307:         try:\n308:             self._core_api.delete_namespaced_service(\n309:                 name=sanitized_name,\n310:                 namespace=self.namespace,\n311:             )\n312:             service_deleted = True\n313:         except kubernetes.client.exceptions.ApiException:\n314:             service_deleted = False\n315:         \n316:         return {\n317:             \"deployment_deleted\": deployment_deleted,\n318:             \"service_deleted\": service_deleted,\n319:         }\n320: \n321:     def _ensure_namespace(self) -> None:\n322:         try:\n323:             self._core_api.read_namespace(name=self.namespace)\n324:         except kubernetes.client.exceptions.ApiException as e:\n325:             if e.status == 404:\n326:                 namespace_body = {\n327:                     \"apiVersion\": \"v1\",\n328:                     \"kind\": \"Namespace\",\n329:                     \"metadata\": {\"name\": self.namespace},\n330:                 }\n331:                 self._core_api.create_namespace(body=namespace_body)\n332:                 if self.verbose:\n333:                     self._logger.info(f\"Created namespace {self.namespace}\")\n334:             else:\n335:                 raise\n336: \n337:     def _sanitize_name(self, name: str) -> str:\n338:        