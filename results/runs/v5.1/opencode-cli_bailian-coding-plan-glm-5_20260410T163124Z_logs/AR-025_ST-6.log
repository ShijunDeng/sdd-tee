            \"status\": status,\n130:         }\n131: \n132:     def get_agent_runtime(self, name: str, namespace: Optional[str] = None) -> Optional[Dict[str, Any]]:\n133:         ns = namespace or self.namespace\n134:         sanitized_name = self._sanitize_name(name)\n135:         \n136:         try:\n137:             result = self._custom_api.get_namespaced_custom_object(\n138:                 group=self.CR_GROUP,\n139:                 version=self.CR_VERSION,\n140:                 namespace=ns,\n141:                 plural=self.CR_PLURAL,\n142:                 name=sanitized_name,\n143:             )\n144:             return result\n145:         except kubernetes.client.exceptions.ApiException as e:\n146:             if e.status == 404:\n147:                 return None\n148:             raise\n149: \n150:     def delete_agent_runtime(self, name: str, namespace: Optional[str] = None) -> Dict[str, Any]:\n151:         ns = namespace or self.namespace\n152:         sanitized_name = self._sanitize_name(name)\n153:         \n154:         try:\n155:             self._custom_api.delete_namespaced_custom_object(\n156:                 group=self.CR_GROUP,\n157:                 version=self.CR_VERSION,\n158:                 namespace=ns,\n159:                 plural=self.CR_PLURAL,\n160:                 name=sanitized_name,\n161:                 body=kubernetes.client.V1DeleteOptions(),\n162:             )\n163:             return {\"deleted\": True, \"name\": sanitized_name}\n164:         except kubernetes.client.exceptions.ApiException as e:\n165:             if e.status == 404:\n166:                 return {\"deleted\": False, \"reason\": \"not_found\"}\n167:             raise RuntimeError(f\"Failed to delete AgentRuntime: {e}\")\n168: \n169:     def _ensure_namespace(self) -> None:\n170:         try:\n171:             self._core_api.read_namespace(name=self.namespace)\n172:         except kubernetes.client.exceptions.ApiException as e:\n173:             if e.status ==