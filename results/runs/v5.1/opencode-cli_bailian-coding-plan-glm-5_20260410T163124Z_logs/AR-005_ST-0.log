ace\" pkg/workloadmanager/handlers/handler.go` |\n408: | T4.7 | `grep -q \"func.*readyz\" pkg/workloadmanager/handlers/health.go` |\n409: | T5.3 | `grep -q \"func.*Wrap\" pkg/workloadmanager/middleware/logging.go` |\n410: | T5.5 | `grep -q \"recover()\" pkg/workloadmanager/middleware/recovery.go` |\n411: | T5.8 | `grep -q \"Access-Control-Allow-Origin\" pkg/workloadmanager/middleware/cors.go` |\n412: | T6.2 | `grep -q \"func NewHTTPServer\" pkg/workloadmanager/server.go` |\n413: | T6.6 | `grep -q \"func.*GracefulShutdown\" pkg/workloadmanager/server.go` |\n414: | T7.1 | `go test ./pkg/workloadmanager/... -run TestHandleError -v` |\n415: | T7.7 | `go test ./pkg/workloadmanager/handlers/... -run TestHealthz -v` |\n416: | T8.1 | `go test ./pkg/workloadmanager/... -run TestE2EHealthz -v` |\n417: | T9.4 | `go vet ./pkg/workloadmanager/...` |\n418: | T9.5 | `golangci-lint run ./pkg/workloadmanager/...` |\n419: | T9.6 | `go build ./pkg/workloadmanager/...` |\n420: | T9.7 | `go test -cover ./pkg/workloadmanager/...` |\n421: \n422: ---\n423: \n424: ## Acceptance Criteria\n425: \n426: - [ ] HTTP server starts on configured address\n427: - [ ] HTTPServer struct contains: server, router, config, handlers, logger, stopCh\n428: - [ ] Config struct contains: Addr, ReadTimeout, WriteTimeout, IdleTimeout, ShutdownTimeout, EnableHealthz, EnableReadyz\n429: - [ ] DefaultConfig returns: Addr \":8080\", ReadTimeout 15s, WriteTimeout 15s, IdleTimeout 60s, ShutdownTimeout 30s\n430: - [ ] NewHTTPServer initializes router with chi.NewRouter()\n431: - [ ] HTTPServer.Start returns error channel, starts ListenAndServe\n432: - [ ] HTTPServer.Stop calls Shutdown with context timeout\n433: - [ ] HTTPServer.GracefulShutdown handles SIGTERM/SIGINT\n434: - [ ] Router struct embeds chi.Router\n435: - [ ] RegisterHandlers calls each handler's Register method\n436: - [ ] Handler interface defines Register(r chi.Router)\n437: - [ ] HandlerFunc.ServeHTTP calls HandleError on error\n438: - [ ] healthz endpoint returns HTTP 200 with {\"status\": \"ok\"}\n439: - [ ] readyz endpoint returns HTTP 200/503 based on checker state\n440: - [ ] LoggingMiddleware.Wrap captures method, path, status, duration\n441: - [ ] RecoveryMiddleware.Wrap catches panic, returns HTTP 500\n442: - [ ] CORSMiddleware.Wrap adds Access-Control-Allow-Origin header\n443: - [ ] CORS OPTIONS request returns HTTP 200 with preflight headers\n444: - [ ] ErrorResponse struct: Code, Message, Details\n445: - [ ] HandleError maps error types to HTTP status codes\n446: - [ ] HandleError sets Content-Type: application/json\n447: - [ ] Middleware chain: Recovery → Logging → CORS → Handler\n448: - [ ] Pass `go vet ./pkg/workloadmanager/...`\n449: - [ ] Pass `golangci-lint run ./pkg/workloadmanager/...`\n450: - [ ] Pass `go test -cover ./pkg/workloadmanager/...` with >80% coverage\n451: - [ ] All exported types have godoc comments\n452: \n453: ---\n454: \n455: ## Notes\n456: \n457: - Use `github.com/go-chi/chi/v5` for routing\n458: - Follow Go standard library conventions for HTTP handlers\n459: - Graceful shutdown timeout default 30s, configurable\n460: - Middleware uses standard `func(http.Handler) http.Handler` signature\n461: - Health check implementation supports dependency checking via `HealthChecker` interface\n462: - Recovery middleware executes first to catch panics before logging\n463: - Logging middleware captures full request duration including handler execution\n\n(End of file - total 463 lines)\n</content>","metadata":{"preview":"# AR-004 — WorkloadManager HTTP 服务框架 Tasks\n\n## Metadata\n\n| Item | Value |\n|------|-------|\n| AR | AR-004 — WorkloadManager HTTP 服务框架 |\n| Module | `pkg/workloadmanager` |\n| Language | Go |\n| Size | M |\n| Design | [Stage ST-3 completed] |\n\n---\n\n## Task Checklist\n\n### Phase 1: Project Setup\n\n- [ ] **T1.1** Create directory structure `pkg/workloadmanager/`\n  - Create `pkg/workloadmanager/handlers/`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/op