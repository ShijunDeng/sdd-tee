  = \"Updating\"\n    ConditionReasonDeleting           = \"Deleting\"\n    ConditionReasonError              = \"Error\"\n    ConditionReasonTimeout            = \"Timeout\"\n    ConditionReasonSessionStarted     = \"SessionStarted\"\n    ConditionReasonSessionEnded       = \"SessionEnded\"\n    ConditionReasonIdleTimeout        = \"IdleTimeout\"\n    ConditionReasonMaxDurationReached = \"MaxDurationReached\"\n)\n\n// ============================================================================\n// Default Value Constants\n// ============================================================================\n\nconst (\n    DefaultSessionTimeout     = 15 * time.Minute\n    DefaultMaxSessionDuration = 8 * time.Hour\n    DefaultWarmPoolSize       = 0\n)\n\nvar (\n    DefaultAuthMode  = AuthModePicoD\n    DefaultProtocol  = ProtocolTypeHTTP\n)\n```\n\n## Generation Commands\n\n| Command | Output |\n|---------|--------|\n| `make generate` | DeepCopy code in `zz_generated.deepcopy.go` |\n| `go build ./pkg/apis/...` | Compile verification |\n| `go test ./pkg/apis/...` | Unit test execution |\n\n## References\n\n- Source: `/tmp/agentcube-ref/pkg/apis/runtime/v1alpha1/`\n- Kubernetes API Conventions: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md\n- Kubebuilder Book: https://book.kubebuilder.io/\n- AR-001 Design: `changes/AR-001/design.md`\n- AR-002 Design: `changes/AR-002/design.md`"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/groupversion_info.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/shared_types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5