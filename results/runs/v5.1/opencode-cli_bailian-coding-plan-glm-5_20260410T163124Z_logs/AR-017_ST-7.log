thMgr.SetPublicKey(&privateKey.PublicKey)\n945: \n946: \tvalidToken := generateTestJWT(privateKey, false)\n947: \n948: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.json\", nil, \"\", validToken)\n949: \tassert.Equal(t, 200, w.Code)\n950: \tassert.Equal(t, \"application/json\", w.Header().Get(\"Content-Type\"))\n951: \tassert.Equal(t, `{\"key\": \"value\"}`, w.Body.String())\n952: }\n953: \n954: func TestDownloadFileHandlerMIMETypeUnknown(t *testing.T) {\n955: \tserver := setupTestServer(t)\n956: \n957: \tfilePath := filepath.Join(server.workspace, \"data.xyz\")\n958: \trequire.NoError(t, os.WriteFile(filePath, []byte(\"unknown content\"), 0644))\n959: \n960: \tauthMgr := server.authManager\n961: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n962: \trequire.NoError(t, err)\n963: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n964: \n965: \tvalidToken := generateTestJWT(privateKey, false)\n966: \n967: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.xyz\", nil, \"\", validToken)\n968: \tassert.Equal(t, 200, w.Code)\n969: \tassert.Equal(t, \"application/octet-stream\", w.Header().Get(\"Content-Type\"))\n970: \tassert.Equal(t, \"unknown content\", w.Body.String())\n971: }\n972: \n973: func TestDownloadFileHandlerSymlinkInsideWorkspace(t *testing.T) {\n974: \tserver := setupTestServer(t)\n975: \n976: \ttargetFile := filepath.Join(server.workspace, \"target.txt\")\n977: \trequire.NoError(t, os.WriteFile(targetFile, []byte(\"target content\"), 0644))\n978: \n979: \tlinkPath := filepath.Join(server.workspace, \"link.txt\")\n980: \trequire.NoError(t, os.Symlink(targetFile, linkPath))\n981: \n982: \tauthMgr := server.authManager\n983: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n984: \trequire.NoError(t, err)\n985: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n986: \n987: \tvalidToken := generateTestJWT(privateKey, false)\n988: \n989: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/link.txt\"