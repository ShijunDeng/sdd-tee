ublicKeyEnvVar, \"invalid pem data\")\n777: \tdefer os.Unsetenv(PublicKeyEnvVar)\n778: \n779: \t_, err := LoadPublicKeyFromEnv()\n780: \tassert.Error(t, err)\n781: \tassert.Contains(t, err.Error(), \"failed to decode PEM block\")\n782: }\n783: \n784: func TestLoadPublicKeyFromEnvPKCS1Format(t *testing.T) {\n785: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n786: \trequire.NoError(t, err)\n787: \n788: \tpkcs1PEM := pem.EncodeToMemory(&pem.Block{\n789: \t\tType:  \"RSA PUBLIC KEY\",\n790: \t\tBytes: x509.MarshalPKCS1PublicKey(&privateKey.PublicKey),\n791: \t})\n792: \n793: \tos.Setenv(PublicKeyEnvVar, string(pkcs1PEM))\n794: \tdefer os.Unsetenv(PublicKeyEnvVar)\n795: \n796: \t_, err = LoadPublicKeyFromEnv()\n797: \tassert.Error(t, err)\n798: \tassert.Contains(t, err.Error(), \"expected PUBLIC KEY PEM block\")\n799: }\n800: \n801: func TestLoadPublicKeyFromEnvValid(t *testing.T) {\n802: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n803: \trequire.NoError(t, err)\n804: \n805: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n806: \n807: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n808: \tdefer os.Unsetenv(PublicKeyEnvVar)\n809: \n810: \tpubKey, err := LoadPublicKeyFromEnv()\n811: \trequire.NoError(t, err)\n812: \tassert.NotNil(t, pubKey)\n813: \tassert.Equal(t, &privateKey.PublicKey, pubKey)\n814: }\n815: \n816: func TestParseFileModeEmpty(t *testing.T) {\n817: \tmode, err := parseFileMode(\"\")\n818: \trequire.NoError(t, err)\n819: \tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n820: }\n821: \n822: func TestParseFileModeInvalid(t *testing.T) {\n823: \tmode, err := parseFileMode(\"invalid\")\n824: \trequire.NoError(t, err)\n825: \tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n826: }\n827: \n828: func TestParseFileModeTooHigh(t *testing.T) {\n829: \t_, err := parseFileMode(\"1000\")\n830: \tassert.Error(t, err)\n831: \tassert.Equal(t, \"invalid file mode\", err.Error())\n832: }\n833: \n834: func TestParseFileModeValid(