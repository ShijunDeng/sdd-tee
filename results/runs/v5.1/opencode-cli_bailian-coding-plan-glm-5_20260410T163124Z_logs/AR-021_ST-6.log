ypoint=\"python main.py\",\n36:                 build_mode=\"invalid\",\n37:             )\n38: \n39:     def test_agent_metadata_invalid_port_low(self) -> None:\n40:         with pytest.raises(ValidationError):\n41:             AgentMetadata.model_construct(\n42:                 agent_name=\"test-agent\",\n43:                 language=\"python\",\n44:                 entrypoint=\"python main.py\",\n45:                 port=0,\n46:             )\n47: \n48:     def test_agent_metadata_invalid_port_high(self) -> None:\n49:         with pytest.raises(ValidationError):\n50:             AgentMetadata.model_construct(\n51:                 agent_name=\"test-agent\",\n52:                 language=\"python\",\n53:                 entrypoint=\"python main.py\",\n54:                 port=70000,\n55:             )\n56: \n57:     def test_agent_metadata_valid_port_range(self) -> None:\n58:         metadata = AgentMetadata.model_construct(\n59:             agent_name=\"test-agent\",\n60:             language=\"python\",\n61:             entrypoint=\"python main.py\",\n62:             port=1,\n63:         )\n64:         assert metadata.port == 1\n65: \n66:         metadata = AgentMetadata.model_construct(\n67:             agent_name=\"test-agent\",\n68:             language=\"python\",\n69:             entrypoint=\"python main.py\",\n70:             port=65535,\n71:         )\n72:         assert metadata.port == 65535\n73: \n74: \n75: class TestMetadataService:\n76:     def test_metadata_service_load_agent_metadata_yaml(self, tmp_path: Path) -> None:\n77:         metadata_content = \"\"\"\n78: agent_name: loaded-agent\n79: language: python\n80: entrypoint: python main.py\n81: port: 9000\n82: build_mode: cloud\n83: \"\"\"\n84:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n85:         metadata_file.write_text(metadata_content)\n86: \n87:         service = MetadataService()\n88:         metadata = service.load_metadata(tmp_path)\n89:         assert metadata.agent_name =