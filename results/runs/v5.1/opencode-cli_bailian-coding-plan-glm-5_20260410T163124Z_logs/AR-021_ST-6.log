rsion == \"1.0.1\"\n328:         assert updated_metadata.image[\"image_id\"] == \"sha256:abc123\"\n\n(End of file - total 328 lines)\n</content>","metadata":{"preview":"import pytest\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\nimport yaml\n\nfrom agentcube.runtime.build_runtime import BuildRuntime, DEFAULT_TAG\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestBuildRuntimeInit:\n    def test_init_default_verbose(self) -> None:\n        runtime = BuildRuntime()\n        assert runtime.verbose == False\n\n    def test_init_verbose_true(self) -> None:\n        runtime = BuildRuntime(verbose=True)\n        assert runtime.verbose == True\n\n\nclass TestValidateBuildPrerequisites:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_build_runtime.py","time":{"start":1775870853970,"end":1775870853994}}}}
