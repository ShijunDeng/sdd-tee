       service = DockerService()\n37:         assert service._format_size(500) == \"500 B\"\n38: \n39:     def test_format_size_kb(self) -> None:\n40:         service = DockerService()\n41:         assert service._format_size(1024) == \"1.0 KB\"\n42: \n43:     def test_format_size_mb(self) -> None:\n44:         service = DockerService()\n45:         assert service._format_size(1048576) == \"1.0 MB\"\n46: \n47:     def test_format_size_gb(self) -> None:\n48:         service = DockerService()\n49:         assert service._format_size(1073741824) == \"1.0 GB\"\n50: \n51:     def test_format_size_large_mb(self) -> None:\n52:         service = DockerService()\n53:         result = service._format_size(125300000)\n54:         assert \"MB\" in result\n55: \n56: \n57: class TestGetImageInfo:\n58:     def test_get_image_info_success(self) -> None:\n59:         service = DockerService()\n60:         \n61:         mock_image = MagicMock()\n62:         mock_image.id = \"sha256:abc123def456\"\n63:         mock_image.attrs = {\"Size\": 125300000}\n64:         \n65:         with patch.object(service, '_get_client') as mock_client_get:\n66:             mock_client = MagicMock()\n67:             mock_client.images.get.return_value = mock_image\n68:             mock_client_get.return_value = mock_client\n69:             \n70:             result = service.get_image_info(\"test-agent\", \"latest\")\n71:             \n72:             assert result[\"image_id\"] == \"sha256:abc123def456\"\n73:             assert \"MB\" in result[\"image_size\"]\n74: \n75:     def test_get_image_info_not_found(self) -> None:\n76:         service = DockerService(verbose=True)\n77:         \n78:         with patch.object(service, '_get_client') as mock_client_get:\n79:             mock_client = MagicMock()\n80:             mock_client.images.get.side_effect = Exception(\"Image not found\")\n81:             mock_client_get.return_value = mock_client\n82:             \n83:             with pytest.raises(Exception):\n84:                 service.get_image_info(\"nonexistent\", \"latest\")\n85: \n86: \n87: class TestBuildImage:\n88:     def test_build_image_basic(self, tmp_path: Path) -> None:\n89:         service = DockerService()\n90:         dockerfile = tmp_path / \"Dockerfile\"\n91:         dockerfile.write_text(\"FROM python:3.10-slim\")\n92:         \n93:         mock_image = MagicMock()\n94:         mock_image.id = \"sha256:build123\"\n95:         mock_image.attrs = {\"Size\": 500000000}\n96:         \n97:         with patch.object(service, '_get_client') as mock_client_get:\n98:             mock_client = MagicMock()\n99:             mock_client.images.build.return_value = (mock_image, [])\n100:             mock_client_get.return_value = mock_client\n101:             \n102:             result = service.build_image(\n103:                 dockerfile_path=dockerfile,\n104:                 context_path=tmp_path,\n105:                 image_name=\"test-agent\",\n106:                 tag=\"v1.0.0\",\n107:             )\n108:             \n109:             assert result[\"image_name\"] == \"test-agent\"\n110:             assert result[\"image_id\"] == \"sha256:build123\"\n111:             assert result[\"tag\"] == \"v1.0.0\"\n112:             assert \"MB\" in result[\"image_size\"]\n113: \n114:     def test_build_image_with_proxy(self, tmp_path: Path) -> None:\n115:         service = DockerService()\n116:         dockerfile = tmp_path / \"Dockerfile\"\n117:         dockerfile.write_text(\"FROM python:3.10-slim\")\n118:         \n119:         mock_image = MagicMock()\n120:         mock_image.id = \"sha256:build123\"\n121:         mock_image.attrs = {\"Size\": 500000000}\n122:         \n123:         with patch.object(service, '_get_client') as mock_client_get:\n124:             mock_client = MagicMock()\n125:             mock_client.images.build.return_value = (mock_image, [])\n126:             mock_client_get.return_value = mock_client\n127:             \n128:             result = service.build_image(\n129:                 dockerfile_path=dockerfile,\n130:                 context_path=tmp_path,\n131:                 image_name=\"test-agent\",\n132:                 tag=\"latest\",\n133:                 build_args={\n134:                     \"HTTP_PROXY\": \"http://proxy.example.com:8080\",\n135:                     \"HTTPS_PROXY\": \"http://proxy.example.com:8080\",\n136:                 },\n137:             )\n138:             \n139:             mock_client.images.build.assert_called_once()\n140:             call_kwargs = mock_client.images.build.call_args.kwargs\n141:             assert call_kwargs[\"buildargs\"][\"HTTP_PROXY\"] == \"http://proxy.example.com:8080\"\n142: \n143:     def test_build_image_default_tag(self, tmp_path: Path) -> None:\n144:         service = DockerService()\n145:         dockerfile = tmp_path / \"Dockerfile\"\n146:         dockerfile.write_text(\"FROM python:3.10-slim\")\n147:         \n148:         mock_image = MagicMock()\n149:         mock_image.id = \"sha256:build123\"\n150:         mock_image.attrs = {\"Size\": 500000000}\n151:         \n152:         with patch.object(service, '_get_client') as mock_client_get:\n153:             mock_client = MagicMock()\n154:             mock_client.images.build.return_value = (mock_image, [])\n155:             mock_client_get.return_value = mock_client\n156:             \n157:             result = service.build_image(\n158:                 dockerfile_path=dockerfile,\n159:                 context_path=tmp_path,\n160:                 image_name=\"test-agent\",\n161:             )\n162:             \n163:             assert result[\"tag\"] == \"latest\"\n164: \n165:     def test_build_image_failure(self, tmp_path: Path) -> None:\n166:         service = DockerService(verbose=True)\n167:         dockerfile = tmp_path / \"Dockerfile\"\n168:         dockerfile.write_text(\"FROM python:3.10-slim\")\n169:         \n170:         with patch.object(service, '_get_client') as mock_client_get:\n171:             mock_client = MagicMock()\n172:             mock_client.images.build.side_effect = Exception(\"Build failed\")\n173:             mock_client_get.return_value = mock_client\n174:             \n175:             with pytest.raises(Exception, match=\"Build failed\"):\n176:                 service.build_image(\n177:                     dockerfile_path=dockerfile,\n178:                     context_path=tmp_path,\n179:                     image_name=\"test-agent\",\n180:                 )\n181: \n182: \n183: class TestPushImage:\n184:     def test_push_image_basic(self) -> None:\n185:         service = DockerService()\n186:         \n187:         with patch.object(service, '_get_client') as mock_client_get:\n188:             mock_client = MagicMock()\n189:             mock_client.images.push.return_value = []\n190:             mock_client_get.return_value = mock_client\n191:             \n192:             result = service.push_image(\"test-agent:latest\")\n193:             \n194:             assert result[\"pushed_image\"] == \"test-agent:latest\"\n195:             assert \"push_time\" in result\n196: \n197:     def test_push_image_with_registry(self) -> None:\n198:         service = DockerService()\n199:         \n200:         with patch.object(service, '_get_client') as mock_client_get:\n201:             mock_client = MagicMock()\n202:             mock_client.images.push.return_value = []\n203:             mock_client_get.return_value = mock_client\n204:             \n205:             result = service.push_image(\n206:                 \"test-agent:latest\",\n207:                 registry_url=\"registry.example.com\",\n208:             )\n209:             \n210:             assert result[\"pushed_image\"] == \"registry.example.com/test-agent:latest\"\n211: \n212:     def test_push_image_with_auth(self) -> None:\n213:         service = DockerService()\n214:         \n215:         with patch.object(service, '_get_client') as mock_client_get:\n216:             mock_client = MagicMock()\n217:             mock_client.images.push.return_value = []\n218:             mock_client_get.return_value = mock_client\n219:             \n220:             result = service.push_image(\n221:                 \"test-agent:latest\",\n222:                 registry_url=\"registry.example.com\",\n223:                 username=\"user\",\n224:                 password=\"pass\",\n225:             )\n226:             \n227:             mock_client.login.assert_called_once()\n228: \n229: \n230: class TestRemoveImage:\n231:     def test_remove_image_success(self) -> None:\n232:         service = DockerService()\n233:         \n234:         with patch.object(service, '_get_client') as mock_client_get:\n235:             mock_client = MagicMock()\n236:             mock_client.images.remove.return_value = None\n237:             mock_client_get.return_value = mock_client\n238:             \n239:             result = service.remove_image(\"test-agent:latest\")\n240:             assert result == True\n241: \n242:     def test_remove_image_failure(self) -> None:\n243:         service = DockerService()\n244:         \n245:         with patch.object(service, '_get_client') as mock_client_get:\n246:             mock_client = MagicMock()\n247:             mock_client.images.remove.side_effect = Exception(\"Image not found\")\n248:             mock_client_get.return_value = mock_client\n249:             \n250:             result = service.remove_image(\"nonexistent:latest\")\n251:             assert result == False\n\n(End of file - total 251 lines)\n</content>","metadata":{"preview":"import pytest\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nfrom agentcube.services.docker_service import DockerService\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestDockerServiceInit:\n    def test_init_default_verbose(self) -> None:\n        service = DockerService()\n        assert service.verbose == False\n\n    def test_init_verbose_true(self) -> None:\n        service = DockerService(verbose=True)\n        assert service.verbose == True\n\n\nclass TestCheckDockerAvailable:\n    def test_docker_available(self) -> None:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_docker_service.py","time":{"start":1775870853972,"end":1775870853996}}}}
