[\"error\"])\n621: }\n622: \n623: func TestListFilesHandlerPathEscape(t *testing.T) {\n624: \tserver := setupTestServer(t)\n625: \n626: \tauthMgr := server.authManager\n627: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n628: \trequire.NoError(t, err)\n629: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n630: \n631: \tvalidToken := generateTestJWT(privateKey, false)\n632: \n633: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=../escape\", nil, \"\", validToken)\n634: \tassert.Equal(t, 400, w.Code)\n635: \n636: \tvar resp map[string]string\n637: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n638: \tassert.Contains(t, resp[\"error\"], \"invalid path\")\n639: }\n640: \n641: func TestListFilesHandlerNonExistent(t *testing.T) {\n642: \tserver := setupTestServer(t)\n643: \n644: \tauthMgr := server.authManager\n645: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n646: \trequire.NoError(t, err)\n647: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n648: \n649: \tvalidToken := generateTestJWT(privateKey, false)\n650: \n651: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=nonexistent\", nil, \"\", validToken)\n652: \tassert.Equal(t, 500, w.Code)\n653: \n654: \tvar resp map[string]string\n655: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n656: \tassert.Equal(t, \"failed to read directory\", resp[\"error\"])\n657: }\n658: \n659: func TestDownloadFileHandlerExistingFile(t *testing.T) {\n660: \tserver := setupTestServer(t)\n661: \n662: \tfilePath := filepath.Join(server.workspace, \"testfile.txt\")\n663: \trequire.NoError(t, os.WriteFile(filePath, []byte(\"download content\"), 0644))\n664: \n665: \tauthMgr := server.authManager\n666: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n667: \trequire.NoError(t, err)\n668: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n669: \n670: \tvalidToken := generateTestJWT(privateKey, false)\n671: \n672: \tw := makeAuthenticatedRequest(t, server, \"G