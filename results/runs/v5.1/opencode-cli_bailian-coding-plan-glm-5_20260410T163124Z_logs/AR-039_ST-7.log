{\n777: \tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n778: \tdefer os.Unsetenv(PublicKeyEnvVar)\n779: \n780: \t_, err := LoadPublicKeyFromEnv()\n781: \tassert.Error(t, err)\n782: \tassert.Contains(t, err.Error(), \"failed to decode PEM block\")\n783: }\n784: \n785: func TestLoadPublicKeyFromEnvPKCS1Format(t *testing.T) {\n786: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n787: \trequire.NoError(t, err)\n788: \n789: \tpkcs1PEM := pem.EncodeToMemory(&pem.Block{\n790: \t\tType:  \"RSA PUBLIC KEY\",\n791: \t\tBytes: x509.MarshalPKCS1PublicKey(&privateKey.PublicKey),\n792: \t})\n793: \n794: \tos.Setenv(PublicKeyEnvVar, string(pkcs1PEM))\n795: \tdefer os.Unsetenv(PublicKeyEnvVar)\n796: \n797: \t_, err = LoadPublicKeyFromEnv()\n798: \tassert.Error(t, err)\n799: \tassert.Contains(t, err.Error(), \"expected PUBLIC KEY PEM block\")\n800: }\n801: \n802: func TestLoadPublicKeyFromEnvValid(t *testing.T) {\n803: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n804: \trequire.NoError(t, err)\n805: \n806: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n807: \n808: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n809: \tdefer os.Unsetenv(PublicKeyEnvVar)\n810: \n811: \tpubKey, err := LoadPublicKeyFromEnv()\n812: \trequire.NoError(t, err)\n813: \tassert.NotNil(t, pubKey)\n814: \tassert.Equal(t, &privateKey.PublicKey, pubKey)\n815: }\n816: \n817: func TestParseFileModeEmpty(t *testing.T) {\n818: \tmode, err := parseFileMode(\"\")\n819: \trequire.NoError(t, err)\n820: \tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n821: }\n822: \n823: func TestParseFileModeInvalid(t *testing.T) {\n824: \tmode, err := parseFileMode(\"invalid\")\n825: \trequire.NoError(t, err)\n826: \tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n827: }\n828: \n829: func TestParseFileModeTooHigh(t *testing.T) {\n830: \t_, err := parseFileMode(\"1000\")\n831: \tassert.Error(t, err)\n832: \tassert.Equal(t, \"invalid file mode\", err.Error())\n833: }\n834: \n835: func TestParseFileModeValid(t *testing.T) {\n836: \tmode, err := parseFileMode(\"0755\")\n837: \trequire.NoError(t, err)\n838: \tassert.Equal(t, os.FileMode(0755), mode)\n839: }\n840: \n841: func TestServerShutdown(t *testing.T) {\n842: \tserver := setupTestServer(t)\n843: \n844: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n845: \tdefer cancel()\n846: \n847: \terr := server.Shutdown(ctx)\n848: \tassert.NoError(t, err)\n849: }\n850: \n851: func TestUploadFileHandlerMultipartMissingPath(t *testing.T) {\n852: \tserver := setupTestServer(t)\n853: \n854: \tauthMgr := server.authManager\n855: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n856: \trequire.NoError(t, err)\n857: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n858: \n859: \tvalidToken := generateTestJWT(privateKey, false)\n860: \n861: \tbody := &bytes.Buffer{}\n862: \twriter := multipart.NewWriter(body)\n863: \n864: \tpart, err := writer.CreateFormFile(\"file\", \"upload.txt\")\n865: \trequire.NoError(t, err)\n866: \t_, err = part.Write([]byte(\"test file content\"))\n867: \trequire.NoError(t, err)\n868: \trequire.NoError(t, writer.Close())\n869: \n870: \treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n871: \treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n872: \treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n873: \n874: \tw := httptest.NewRecorder()\n875: \tserver.engine.ServeHTTP(w, req)\n876: \n877: \tassert.Equal(t, 400, w.Code)\n878: \n879: \tvar resp map[string]string\n880: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n881: \tassert.Equal(t, \"missing path parameter\", resp[\"error\"])\n882: }\n883: \n884: func TestUploadFileHandlerMultipartMissingFile(t *testing.T) {\n885: \tserver := setupTestServer(t)\n886: \n887: \tauthMgr := server.authManager\n888: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n889: \trequire.NoError(t, err)\n890: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n891: \n892: \tvalidToken := generateTestJWT(privateKey, false)\n893: \n894: \tbody := &bytes.Buffer{}\n895: \twriter := multipart.NewWriter(body)\n896: \n897: \trequire.NoError(t, writer.WriteField(\"path\", \"upload.txt\"))\n898: \trequire.NoError(t, writer.Close())\n899: \n900: \treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n901: \treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n902: \treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n903: \n904: \tw := httptest.NewRecorder()\n905: \tserver.engine.ServeHTTP(w, req)\n906: \n907: \tassert.Equal(t, 400, w.Code)\n908: \n909: \tvar resp map[string]string\n910: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n911: \tassert.Equal(t, \"missing file\", resp[\"error\"])\n912: }\n913: \n914: func TestListFilesHandlerEmptyDirectory(t *testing.T) {\n915: \tserver := setupTestServer(t)\n916: \n917: \temptyDir := filepath.Join(server.workspace, \"emptydir\")\n918: \trequire.NoError(t, os.MkdirAll(emptyDir, 0755))\n919: \n920: \tauthMgr := server.authManager\n921: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n922: \trequire.NoError(t, err)\n923: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n924: \n925: \tvalidToken := generateTestJWT(privateKey, false)\n926: \n927: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=emptydir\", nil, \"\", validToken)\n928: \tassert.Equal(t, 200, w.Code)\n929: \n930: \tvar resp ListFilesResponse\n931: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n932: \tassert.Equal(t, \"emptydir\", resp.Path)\n933: \tassert.Len(t, resp.Files, 0)\n934: }\n935: \n936: func TestDownloadFileHandlerMIMETypeJSON(t *testing.T) {\n937: \tserver := setupTestServer(t)\n938: \n939: \tfilePath := filepath.Join(server.workspace, \"data.json\")\n940: \trequire.NoError(t, os.WriteFile(filePath, []byte(`{\"key\": \"value\"}`), 0644))\n941: \n942: \tauthMgr := server.authManager\n943: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n944: \trequire.NoError(t, err)\n945: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n946: \n947: \tvalidToken := generateTestJWT(privateKey, false)\n948: \n949: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.json\", nil, \"\", validToken)\n950: \tassert.Equal(t, 200, w.Code)\n951: \tassert.Equal(t, \"application/json\", w.Header().Get(\"Content-Type\"))\n952: \tassert.Equal(t, `{\"key\": \"value\"}`, w.Body.String())\n953: }\n954: \n955: func TestDownloadFileHandlerMIMETypeUnknown(t *testing.T) {\n956: \tserver := setupTestServer(t)\n957: \n958: \tfilePath := filepath.Join(server.workspace, \"data.xyz\")\n959: \trequire.NoError(t, os.WriteFile(filePath, []byte(\"unknown content\"), 0644))\n960: \n961: \tauthMgr := server.authManager\n962: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n963: \trequire.NoError(t, err)\n964: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n965: \n966: \tvalidToken := generateTestJWT(privateKey, false)\n967: \n968: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.xyz\", nil, \"\", validToken)\n969: \tassert.Equal(t, 200, w.Code)\n970: \tassert.Equal(t, \"application/octet-stream\", w.Header().Get(\"Content-Type\"))\n971: \tassert.Equal(t, \"unknown content\", w.Body.String())\n972: }\n973: \n974: func TestDownloadFileHandlerSymlinkInsideWorkspace(t *testing.T) {\n975: \tserver := setupTestServer(t)\n976: \n977: \ttargetFile := filepath.Join(server.workspace, \"target.txt\")\n978: \trequire.NoError(t, os.WriteFile(targetFile, []byte(\"target content\"), 0644))\n979: \n980: \tlinkPath := filepath.Join(server.workspace, \"link.txt\")\n981: \trequire.NoError(t, os.Symlink(targetFile, linkPath))\n982: \n983: \tauthMgr := server.authManager\n984: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n985: \trequire.NoError(t, err)\n986: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n987: \n988: \tvalidToken := generateTestJWT(privateKey, false)\n989: \n990: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/link.txt\", nil, \"\", validToken)\n991: \tassert.Equal(t, 200, w.Code)\n992: \tassert.Equal(t, \"target content\", w.Body.String())\n993: }\n994: \n995: func TestFileLifecycle(t *testing.T) {\n996: \tserver := setupTestServer(t)\n997: \n998: \tauthMgr := server.authManager\n999: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1000: \trequire.NoError(t, err)\n1001: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1002: \n1003: \tvalidToken := generateTestJWT(privateKey, false)\n1004: \n1005: \ttestContent := []byte(\"lifecycle test content\")\n1006: \tencodedContent := base64.StdEncoding.EncodeToString(testContent)\n1007: \n1008: \tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"lifecycle/test.txt\", \"content\": \"%s\"}`, encodedContent))\n1009: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n1010: \tassert.Equal(t, 200, w.Code)\n1011: \n1012: \tvar uploadResp FileInfo\n1013: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &uploadResp))\n1014: \tassert.Equal(t, \"lifecycle/test.txt\", uploadResp.Path)\n1015: \n1016: \tw = makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=lifecycle\", nil, \"\", validToken)\n1017: \tassert.Equal(t, 200, w.Code)\n1018: \n1019: \tvar listResp ListFilesResponse\n1020: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &listResp))\n1021: \tassert.Equal(t, \"lifecycle\", listResp.Path)\n1022: \tassert.Len(t, listResp.Files, 1)\n1023: \tassert.Equal(t, \"test.txt\", listResp.Files[0].Name)\n1024: \tassert.False(t, listResp.Files[0].IsDir)\n1025: \n1026: \tw = makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/lifecycle/test.txt\", nil, \"\", validToken)\n1027: \tassert.Equal(t, 200, w.Code)\n1028: \tassert.Equal(t, string(testContent), w.Body.String())\n1029: \n1030: \tactualContent, err := os.ReadFile(filepath.Join(server.workspace, \"lifecycle/test.txt\"))\n1031: \trequire.NoError(t, err)\n1032: \tassert.Equal(t, testContent, actualContent)\n1033: }\n1034: \n1035: func TestUploadLargeFile(t *testing.T) {\n1036: \tserver := setupTestServer(t)\n1037: \n1038: \tauthMgr := server.authManager\n1039: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1040: \trequire.NoError(t, err)\n1041: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1042: \n1043: \tvalidToken := generateTestJWT(privateKey, false)\n1044: \n1045: \tlargeContent := make([]byte, 30*1024*1024)\n1046: \tfor i := range largeContent {\n1047: \t\tlargeContent[i] = byte(i % 256)\n1048: \t}\n1049: \tencodedContent := base64.StdEncoding.EncodeToString(largeContent)\n1050: \n1051: \tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"large.bin\", \"content\": \"%s\"}`, encodedContent))\n1052: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n1053: \tassert.Equal(t, 200, w.Code)\n1054: \n1055: \tvar uploadResp FileInfo\n1056: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &uploadResp))\n1057: \tassert.Equal(t, \"large.bin\", uploadResp.Path)\n1058: \n1059: \tactualContent, err := os.ReadFile(filepath.Join(server.workspace, \"large.bin\"))\n1060: \trequire.NoError(t, err)\n1061: \tassert.Equal(t, largeContent, actualContent)\n1062: }\n1063: \n1064: func TestServerRun(t *testing.T) {\n1065: \tworkspace := t.TempDir()\n1066: \n1067: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1068: \trequire.NoError(t, err)\n1069: \n1070: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n1071: \n1072: \toldEnv := os.Getenv(PublicKeyEnvVar)\n1073: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n1074: \tt.Cleanup(func() {\n1075: \t\tif oldEnv != \"\" {\n1076: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n1077: \t\t} else {\n1078: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n1079: \t\t}\n1080: \t})\n1081: \n1082: \tserver, err := NewServer(&Config{\n1083: \t\tPort:      0,\n1084: \t\tWorkspace: workspace,\n1085: \t})\n1086: \trequire.NoError(t, err)\n1087: \n1088: \tctx, cancel := context.WithCancel(context.Background())\n1089: \n1090: \tgo func() {\n1091: \t\ttime.Sleep(100 * time.Millisecond)\n1092: \t\tcancel()\n1093: \t}()\n1094: \n1095: \terr = server.Run(ctx)\n1096: \tif err != nil && err != http.ErrServerClosed {\n1097: \t\tt.Errorf(\"unexpected error: %v\", err)\n1098: \t}\n1099: }\n1100: \n1101: func TestServerRunWithShutdown(t *testing.T) {\n1102: \tworkspace := t.TempDir()\n1103: \n1104: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1105: \trequire.NoError(t, err)\n1106: \n1107: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n1108: \n1109: \toldEnv := os.Getenv(PublicKeyEnvVar)\n1110: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n1111: \tt.Cleanup(func() {\n1112: \t\tif oldEnv != \"\" {\n1113: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n1114: \t\t} else {\n1115: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n1116: \t\t}\n1117: \t})\n1118: \n1119: \tserver, err := NewServer(&Config{\n1120: \t\tPort:      0,\n1121: \t\tWorkspace: workspace,\n1122: \t})\n1123: \trequire.NoError(t, err)\n1124: \n1125: \tctx, cancel := context.WithCancel(context.Background())\n1126: \n1127: \tgo func() {\n1128: \t\ttime.Sleep(50 * time.Millisecond)\n1129: \t\tserver.Shutdown(ctx)\n1130: \t\ttime.Sleep(50 * time.Millisecond)\n1131: \t\tcancel()\n1132: \t}()\n1133: \n1134: \terr = server.Run(ctx)\n1135: \tassert.NoError(t, err)\n1136: }\n1137: \n1138: func TestNewServerWithRelativeWorkspace(t *testing.T) {\n1139: \tworkspace := t.TempDir()\n1140: \trelPath := filepath.Base(workspace)\n1141: \n1142: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1143: \trequire.NoError(t, err)\n1144: \n1145: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n1146: \n1147: \toldEnv := os.Getenv(PublicKeyEnvVar)\n1148: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n1149: \tt.Cleanup(func() {\n1150: \t\tif oldEnv != \"\" {\n1151: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n1152: \t\t} else {\n1153: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n1154: \t\t}\n1155: \t})\n1156: \n1157: \tserver, err := NewServer(&Config{\n1158: \t\tPort:      8080,\n1159: \t\tWorkspace: relPath,\n1160: \t})\n1161: \trequire.NoError(t, err)\n1162: \n1163: \tassert.Contains(t, server.workspace, relPath)\n1164: }\n1165: \n1166: func TestSanitizePathWithMultipleSlashes(t *testing.T) {\n1167: \tworkspace := t.TempDir()\n1168: \n1169: \tresult, err := sanitizePath(workspace, \"//subdir///file.txt\")\n1170: \trequire.NoError(t, err)\n1171: \n1172: \tassert.Contains(t, result, workspace)\n1173: }\n1174: \n1175: func TestSanitizePathWithBackslashes(t *testing.T) {\n1176: \tworkspace := t.TempDir()\n1177: \n1178: \tresult, err := sanitizePath(workspace, \"subdir\\\\file.txt\")\n1179: \trequire.NoError(t, err)\n1180: \n1181: \tassert.Contains(t, result, workspace)\n1182: }\n1183: \n1184: func TestSanitizePathWorkspaceNotExist(t *testing.T) {\n1185: \tworkspace := \"/nonexistent/path\"\n1186: \n1187: \t_, err := sanitizePath(workspace, \"file.txt\")\n1188: \tassert.Error(t, err)\n1189: }\n1190: \n1191: func TestExecuteHandlerCommandNotFound(t *testing.T) {\n1192: \tserver := setupTestServer(t)\n1193: \n1194: \tauthMgr := server.authManager\n1195: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1196: \trequire.NoError(t, err)\n1197: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1198: \n1199: \tvalidToken := generateTestJWT(privateKey, false)\n1200: \n1201: \tbody := bytes.NewBufferString(`{\"command\": [\"nonexistent-command\", \"arg\"]}`)\n1202: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n1203: \tassert.Equal(t, 200, w.Code)\n1204: \n1205: \tvar resp ExecuteResponse\n1206: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n1207: \tassert.Greater(t, resp.ExitCode, 0)\n1208: \tassert.NotEmpty(t, resp.Stderr)\n1209: }\n1210: \n1211: func TestExecuteHandlerWithLargeOutput(t *testing.T) {\n1212: \tserver := setupTestServer(t)\n1213: \n1214: \tauthMgr := server.authManager\n1215: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1216: \trequire.NoError(t, err)\n1217: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1218: \n1219: \tvalidToken := generateTestJWT(privateKey, false)\n1220: \n1221: \tbody := bytes.NewBufferString(`{\"command\": [\"sh\", \"-c\", \"for i in $(seq 1 100); do echo line_$i; done\"]}`)\n1222: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n1223: \tassert.Equal(t, 200, w.Code)\n1224: \n1225: \tvar resp ExecuteResponse\n1226: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n1227: \tassert.Equal(t, 0, resp.ExitCode)\n1228: \tassert.Contains(t, resp.Stdout, \"line_1\")\n1229: \tassert.Contains(t, resp.Stdout, \"line_100\")\n1230: }\n1231: \n1232: func TestHealthCheckHandlerFields(t *testing.T) {\n1233: \tserver := setupTestServer(t)\n1234: \n1235: \tw := httptest.NewRecorder()\n1236: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n1237: \tserver.engine.ServeHTTP(w, req)\n1238: \n1239: \tassert.Equal(t, 200, w.Code)\n1240: \n1241: \tvar resp map[string]interface{}\n1242: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n1243: \tassert.Equal(t, \"ok\", resp[\"status\"])\n1244: \tassert.Equal(t, \"PicoD\", resp[\"service\"])\n1245: \tassert.Equal(t, \"0.0.1\", resp[\"version\"])\n1246: \tassert.NotEmpty(t, resp[\"uptime\"])\n1247: }\n1248: \n1249: func TestUploadFileHandlerWithCustomMode(t *testing.T) {\n1250: \tserver := setupTestServer(t)\n1251: \n1252: \tauthMgr := server.authManager\n1253: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1254: \trequire.NoError(t, err)\n1255: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1256: \n1257: \tvalidToken := generateTestJWT(privateKey, false)\n1258: \n1259: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"test content\"))\n1260: \tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\", \"mode\": \"0755\"}`, content))\n1261: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n1262: \tassert.Equal(t, 200, w.Code)\n1263: \n1264: \tvar resp FileInfo\n1265: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n1266: \tassert.Equal(t, \"test.txt\", resp.Path)\n1267: \tassert.Equal(t, \"0755\", resp.Mode)\n1268: }\n1269: \n1270: func TestDownloadFileHandlerNestedPath(t *testing.T) {\n1271: \tserver := setupTestServer(t)\n1272: \n1273: \tnestedDir := filepath.Join(server.workspace, \"deep\", \"nested\", \"path\")\n1274: \trequire.NoError(t, os.MkdirAll(nestedDir, 0755))\n1275: \n1276: \tfilePath := filepath.Join(nestedDir, \"file.txt\")\n1277: \trequire.NoError(t, os.WriteFile(filePath, []byte(\"nested content\"), 0644))\n1278: \n1279: \tauthMgr := server.authManager\n1280: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1281: \trequire.NoError(t, err)\n1282: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1283: \n1284: \tvalidToken := generateTestJWT(privateKey, false)\n1285: \n1286: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/deep/nested/path/file.txt\", nil, \"\", validToken)\n1287: \tassert.Equal(t, 200, w.Code)\n1288: \tassert.Equal(t, \"nested content\", w.Body.String())\n1289: }\n1290: \n1291: func TestListFilesHandlerWithSubdirectories(t *testing.T) {\n1292: \tserver := setupTestServer(t)\n1293: \n1294: \tdir := filepath.Join(server.workspace, \"testdir\")\n1295: \trequire.NoError(t, os.MkdirAll(dir, 0755))\n1296: \trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"file1.txt\"), []byte(\"content\"), 0644))\n1297: \trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \"subdir\"), 0755))\n1298: \trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"subdir\", \"file2.txt\"), []byte(\"content\"), 0644))\n1299: \n1300: \tauthMgr := server.authManager\n1301: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1302: \trequire.NoError(t, err)\n1303: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1304: \n1305: \tvalidToken := generateTestJWT(privateKey, false)\n1306: \n1307: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=testdir\", nil, \"\", validToken)\n1308: \tassert.Equal(t, 200, w.Code)\n1309: \n1310: \tvar resp ListFilesResponse\n1311: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n1312: \tassert.Equal(t, \"testdir\", resp.Path)\n1313: \tassert.Len(t, resp.Files, 2)\n1314: \n1315: \tvar hasDir, hasFile bool\n1316: \tfor _, f := range resp.Files {\n1317: \t\tif f.Name == \"subdir\" && f.IsDir {\n1318: \t\t\thasDir = true\n1319: \t\t}\n1320: \t\tif f.Name == \"file1.txt\" && !f.IsDir {\n1321: \t\t\thasFile = true\n1322: \t\t}\n1323: \t}\n1324: \tassert.True(t, hasDir)\n1325: \tassert.True(t, hasFile)\n1326: }\n1327: \n1328: func TestConcurrentFileOperations(t *testing.T) {\n1329: \tserver := setupTestServer(t)\n1330: \n1331: \tauthMgr := server.authManager\n1332: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1333: \trequire.NoError(t, err)\n1334: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1335: \n1336: \tvalidToken := generateTestJWT(privateKey, false)\n1337: \n1338: \tgin.SetMode(gin.TestMode)\n1339: \n1340: \tnumOps := 10\n1341: \tdone := make(chan bool, numOps)\n1342: \n1343: \tfor i := 0; i < numOps; i++ {\n1344: \t\tgo func(idx int) {\n1345: \t\t\tcontent := []byte(fmt.Sprintf(\"concurrent content %d\", idx))\n1346: \t\t\tencodedContent := base64.StdEncoding.EncodeToString(content)\n1347: \n1348: \t\t\tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"concurrent%d.txt\", \"content\": \"%s\"}`, idx, encodedContent))\n1349: \t\t\tw := httptest.NewRecorder()\n1350: \t\t\treq := httptest.NewRequest(\"POST\", \"/api/files\", uploadBody)\n1351: \t\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n1352: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n1353: \t\t\tserver.engine.ServeHTTP(w, req)\n1354: \t\t\tassert.Equal(t, 200, w.Code)\n1355: \n1356: \t\t\tw = httptest.NewRecorder()\n1357: \t\t\treq = httptest.NewRequest(\"GET\", fmt.Sprintf(\"/api/files/concurrent%d.txt\", idx), nil)\n1358: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n1359: \t\t\tserver.engine.ServeHTTP(w, req)\n1360: \t\t\tassert.Equal(t, 200, w.Code)\n1361: \t\t\tassert.Equal(t, string(content), w.Body.String())\n1362: \n1363: \t\t\tdone <- true\n1364: \t\t}(i)\n1365: \t}\n1366: \n1367: \tfor i := 0; i < numOps; i++ {\n1368: \t\tselect {\n1369: \t\tcase <-done:\n1370: \t\tcase <-time.After(10 * time.Second):\n1371: \t\t\tt.Fatal(\"concurrent operation timed out\")\n1372: \t\t}\n1373: \t}\n1374: }\n\n(End of file - total 1374 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go","time":{"start":1775899870441,"end":1775899870474}}}}
