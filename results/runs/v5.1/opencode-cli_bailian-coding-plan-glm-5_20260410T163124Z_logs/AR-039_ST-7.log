 default config\")\n52: \t}\n53: \tif server.config.Port != \":8080\" {\n54: \t\tt.Errorf(\"expected default port, got: %s\", server.config.Port)\n55: \t}\n56: }\n57: \n58: func TestNewServerNilSessionManager(t *testing.T) {\n59: \tgin.SetMode(gin.TestMode)\n60: \n61: \tconfig := DefaultConfig()\n62: \tmockLogger := &MockLogger{}\n63: \tmockStore := &MockStore{}\n64: \tjwtMgr, _ := NewJWTManager()\n65: \n66: \tserver := NewServer(config, nil, mockStore, jwtMgr, mockLogger)\n67: \n68: \tif server.sessionManager != nil {\n69: \t\tt.Error(\"expected nil sessionManager\")\n70: \t}\n71: }\n72: \n73: func TestNewServerMaxConcurrentRequests(t *testing.T) {\n74: \tgin.SetMode(gin.TestMode)\n75: \n76: \tconfig := &Config{\n77: \t\tPort:                  \":8080\",\n78: \t\tMaxConcurrentRequests: 0,\n79: \t}\n80: \n81: \tmockLogger := &MockLogger{}\n82: \tmockStore := &MockStore{}\n83: \tmockSM := &mockSessionManager{}\n84: \tjwtMgr, _ := NewJWTManager()\n85: \n86: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n87: \n88: \tif server.config.MaxConcurrentRequests != 1000 {\n89: \t\tt.Errorf(\"expected default 1000, got: %d\", server.config.MaxConcurrentRequests)\n90: \t}\n91: }\n92: \n93: func TestServerHandleHealthLive(t *testing.T) {\n94: \tgin.SetMode(gin.TestMode)\n95: \n96: \tconfig := DefaultConfig()\n97: \tmockLogger := &MockLogger{}\n98: \tmockStore := &MockStore{}\n99: \tmockSM := &mockSessionManager{}\n100: \tjwtMgr, _ := NewJWTManager()\n101: \n102: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n103: \n104: \treq := httptest.NewRequest(http.MethodGet, \"/health/live\", nil)\n105: \tw := httptest.NewRecorder()\n106: \n107: \tserver.engine.ServeHTTP(w, req)\n108: \n109: \tif w.Code != http.StatusOK {\n110: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n111: \t}\n112: \n113: \tvar resp map[string]string\n114: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n115: \tif resp[\"status\"] != \"alive\" {\n116: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n117: \t}\n118: }\n119: \n120: func TestServerHandleHealthReady(t *testing.T) {\n121: \tgin.SetMode(gin.TestMode)\n122: \n123: \tconfig := DefaultConfig()\n124: \tmockLogger := &MockLogger{}\n125: \tmockStore := &MockStore{}\n126: \tmockSM := &mockSessionManager{}\n127: \tjwtMgr, _ := NewJWTManager()\n128: \n129: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n130: \n131: \treq := httptest.NewRequest(http.MethodGet, \"/health/ready\", nil)\n132: \tw := httptest.NewRecorder()\n133: \n134: \tserver.engine.ServeHTTP(w, req)\n135: \n136: \tif w.Code != http.StatusOK {\n137: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n138: \t}\n139: \n140: \tvar resp map[string]string\n141: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n142: \tif resp[\"status\"] != \"ready\" {\n143: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n144: \t}\n145: }\n146: \n147: func TestServerHandleHealthReadyNoSessionManager(t *testing.T) {\n148: \tgin.SetMode(gin.TestMode)\n149: \n150: \tconfig := DefaultConfig()\n151: \tmockLogger := &MockLogger{}\n152: \tmockStore := &MockStore{}\n153: \tjwtMgr, _ := NewJWTManager()\n154: \n155: \tserver := NewServer(config, nil, mockStore, jwtMgr, mockLogger)\n156: \n157: \treq := httptest.NewRequest(http.MethodGet, \"/health/ready\", nil)\n158: \tw := httptest.NewRecorder()\n159: \n160: \tserver.engine.ServeHTTP(w, req)\n161: \n162: \tif w.Code != http.StatusServiceUnavailable {\n163: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n164: \t}\n165: \n166: \tvar resp map[string]string\n167: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n168: \tif resp[\"status\"] != \"not ready\" {\n169: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n170: \t}\n171: }\n172: \n173: func TestServerRoutesRegistered(t *testing.T) {\n174: \tgin.SetMode(gin.TestMode)\n175: \n176: \tconfig := DefaultConfig()\n177: \tmockLogger := &MockLogger{}\n178: \tmockStore := &MockStore{}\n179: \tmockSM := &mockSessionManager{}\n180: \tjwtMgr, _ := NewJWTManager()\n181: \n182: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n183: \n184: \troutes := server.engine.Routes()\n185: \n186: \texpectedRoutes := []string{\n187: \t\t\"/health/live\",\n188: \t\t\"/health/ready\",\n189: \t\t\"/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path\",\n190: \t\t\"/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path\",\n191: \t}\n192: \n193: \tfor _, expected := range expectedRoutes {\n194: \t\tfound := false\n195: \t\tfor _, route := range routes {\n196: \t\t\tif route.Path == expected {\n197: \t\t\t\tfound = true\n198: \t\t\t\tbreak\n199: \t\t\t}\n200: \t\t}\n201: \t\tif !found {\n202: \t\t\tt.Errorf(\"route not found: %s\", expected)\n203: \t\t}\n204: \t}\n205: }\n206: \n207: func TestServerStop(t *testing.T) {\n208: \tgin.SetMode(gin.TestMode)\n209: \n210: \tconfig := &Config{Port: \":0\"}\n211: \tmockLogger := &MockLogger{}\n212: \tmockStore := &MockStore{}\n213: \tmockSM := &mockSessionManager{}\n214: \tjwtMgr, _ := NewJWTManager()\n215: \n216: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n217: \n218: \tctx, cancel := context.WithCancel(context.Background())\n219: \tgo func() {\n220: \t\ttime.Sleep(50 * time.Millisecond)\n221: \t\tcancel()\n222: \t}()\n223: \n224: \tgo server.Start(ctx)\n225: \n226: \terr := server.Stop()\n227: \tif err != nil {\n228: \t\tt.Errorf(\"unexpected error: %v\", err)\n229: \t}\n230: }\n231: \n232: func TestServerGracefulShutdown(t *testing.T) {\n233: \tgin.SetMode(gin.TestMode)\n234: \n235: \tconfig := &Config{Port: \":0\"}\n236: \tmockLogger := &MockLogger{}\n237: \tmockStore := &MockStore{}\n238: \tmockSM := &mockSessionManager{}\n239: \tjwtMgr, _ := NewJWTManager()\n240: \n241: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n242: \n243: \tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n244: \tdefer cancel()\n245: \n246: \tgo server.Start(ctx)\n247: \n248: \ttime.Sleep(50 * time.Millisecond)\n249: \n250: \terr := server.Stop()\n251: \tif err != nil {\n252: \t\tt.Logf(\"stop error (expected on already shutdown): %v\", err)\n253: \t}\n254: }\n255: \n256: func TestServerGetEngine(t *testing.T) {\n257: \tgin.SetMode(gin.TestMode)\n258: \n259: \tconfig := DefaultConfig()\n260: \tmockLogger := &MockLogger{}\n261: \tmockStore := &MockStore{}\n262: \tmockSM := &mockSessionManager{}\n263: \tjwtMgr, _ := NewJWTManager()\n264: \n265: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n266: \n267: \tengine := server.GetEngine()\n268: \tif engine == nil {\n269: \t\tt.Error(\"expected engine to be returned\")\n270: \t}\n271: }\n272: \n273: func TestServerTLSRequired(t *testing.T) {\n274: \tgin.SetMode(gin.TestMode)\n275: \n276: \tconfig := &Config{\n277: \t\tPort:      \":8080\",\n278: \t\tEnableTLS: true,\n279: \t\tTLSCert:   \"\",\n280: \t\tTLSKey:    \"\",\n281: \t}\n282: \n283: \tmockLogger := &MockLogger{}\n284: \tmockStore := &MockStore{}\n285: \tmockSM := &mockSessionManager{}\n286: \tjwtMgr, _ := NewJWTManager()\n287: \n288: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n289: \n290: \tctx := context.Background()\n291: \terr := server.Start(ctx)\n292: \tif err == nil {\n293: \t\tt.Error(\"expected error when TLS cert/key are missing\")\n294: \t}\n295: }\n296: \n297: func TestServerHandleAgentInvoke(t *testing.T) {\n298: \tgin.SetMode(gin.TestMode)\n299: \n300: \tconfig := DefaultConfig()\n301: \tmockLogger := &MockLogger{}\n302: \tmockStore := &MockStore{\n303: \t\tGetSandboxBySessionIDFunc: func(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n304: \t\t\treturn &types.SandboxInfo{\n305: \t\t\t\tSessionID: \"test-session\",\n306: \t\t\t\tSandboxID: \"test-sandbox\",\n307: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n308: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n309: \t\t\t\t},\n310: \t\t\t}, nil\n311: \t\t},\n312: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n313: \t\t\treturn nil\n314: \t\t},\n315: \t}\n316: \tmockSM := &mockSessionManager{\n317: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n318: \t\t\treturn &types.SandboxInfo{\n319: \t\t\t\tSessionID: \"test-session\",\n320: \t\t\t\tSandboxID: \"test-sandbox\",\n321: \t\t\t\tKind:      types.AgentRuntimeKind,\n322: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n323: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n324: \t\t\t\t},\n325: \t\t\t}, nil\n326: \t\t},\n327: \t}\n328: \tjwtMgr, _ := NewJWTManager()\n329: \n330: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n331: \n332: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/test-runtime/invocations/api/test\", nil)\n333: \treq.Header.Set(\"x-agentcube-session-id\", \"test-session\")\n334: \tw := httptest.NewRecorder()\n335: \n336: \tserver.engine.ServeHTTP(w, req)\n337: }\n338: \n339: func TestServerHandleCodeInterpreterInvoke(t *testing.T) {\n340: \tgin.SetMode(gin.TestMode)\n341: \n342: \tconfig := DefaultConfig()\n343: \tmockLogger := &MockLogger{}\n344: \tmockStore := &MockStore{\n345: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n346: \t\t\treturn nil\n347: \t\t},\n348: \t}\n349: \tmockSM := &mockSessionManager{\n350: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n351: \t\t\treturn &types.SandboxInfo{\n352: \t\t\t\tSessionID: \"ci-session\",\n353: \t\t\t\tSandboxID: \"ci-sandbox\",\n354: \t\t\t\tKind:      types.CodeInterpreterKind,\n355: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n356: \t\t\t\t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n357: \t\t\t\t},\n358: \t\t\t}, nil\n359: \t\t},\n360: \t}\n361: \tjwtMgr, _ := NewJWTManager()\n362: \n363: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n364: \n365: \treq := httptest.NewRequest(http.MethodPost, \"/v1/namespaces/default/code-interpreters/test-ci/invocations/execute/code\", nil)\n366: \treq.Header.Set(\"x-agentcube-session-id\", \"ci-session\")\n367: \tw := httptest.NewRecorder()\n368: \n369: \tserver.engine.ServeHTTP(w, req)\n370: }\n371: \n372: type mockSessionManager struct {\n373: \tgetFunc func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error)\n374: }\n375: \n376: func (m *mockSessionManager) GetSandboxBySession(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n377: \tif m.getFunc != nil {\n378: \t\treturn m.getFunc(ctx, sessionID, namespace, name, kind)\n379: \t}\n380: \treturn nil, nil\n381: }\n382: \n383: func TestServerHandleGetSandboxErrorNotFound(t *testing.T) {\n384: \tgin.SetMode(gin.TestMode)\n385: \n386: \tconfig := DefaultConfig()\n387: \tmockLogger := &MockLogger{}\n388: \tmockStore := &MockStore{}\n389: \tmockSM := &mockSessionManager{\n390: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n391: \t\t\treturn nil, &SessionNotFoundError{SessionID: sessionID}\n392: \t\t},\n393: \t}\n394: \tjwtMgr, _ := NewJWTManager()\n395: \n396: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n397: \n398: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/test-runtime/invocations/api/test\", nil)\n399: \treq.Header.Set(\"x-agentcube-session-id\", \"test-session\")\n400: \tw := httptest.NewRecorder()\n401: \n402: \tserver.engine.ServeHTTP(w, req)\n403: \n404: \tif w.Code != http.StatusNotFound {\n405: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n406: \t}\n407: }\n408: \n409: func TestServerHandleGetSandboxErrorNoEntryPoint(t *testing.T) {\n410: \tgin.SetMode(gin.TestMode)\n411: \n412: \tconfig := DefaultConfig()\n413: \tmockLogger := &MockLogger{}\n414: \tmockStore := &MockStore{\n415: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n416: \t\t\treturn nil\n417: \t\t},\n418: \t}\n419: \tmockSM := &mockSessionManager{\n420: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n421: \t\t\treturn &types.SandboxInfo{\n422: \t\t\t\tSessionID:   \"test-session\",\n423: \t\t\t\tSandboxID:   \"test-sandbox\",\n424: \t\t\t\tKind:        types.AgentRuntimeKind,\n425: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{},\n426: \t\t\t}, nil\n427: \t\t},\n428: \t}\n429: \tjwtMgr, _ := NewJWTManager()\n430: \n431: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n432: \n433: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/test-runtime/invocations/api/test\", nil)\n434: \treq.Header.Set(\"x-agentcube-session-id\", \"test-session\")\n435: \tw := httptest.NewRecorder()\n436: \n437: \tserver.engine.ServeHTTP(w, req)\n438: \n439: \tif w.Code != http.StatusNotFound {\n440: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n441: \t}\n442: }\n443: \n444: func TestServerHandleGetSandboxErrorWorkloadManagerError(t *testing.T) {\n445: \tgin.SetMode(gin.TestMode)\n446: \n447: \tconfig := DefaultConfig()\n448: \tmockLogger := &MockLogger{}\n449: \tmockStore := &MockStore{}\n450: \tmockSM := &mockSessionManager{\n451: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n452: \t\t\treturn nil, &WorkloadManagerError{StatusCode: 503, Msg: \"service unavailable\"}\n453: \t\t},\n454: \t}\n455: \tjwtMgr, _ := NewJWTManager()\n456: \n457: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n458: \n459: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/test-runtime/invocations/api/test\", nil)\n460: \treq.Header.Set(\"x-agentcube-session-id\", \"test-session\")\n461: \tw := httptest.NewRecorder()\n462: \n463: \tserver.engine.ServeHTTP(w, req)\n464: \n465: \tif w.Code != 503 {\n466: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n467: \t}\n468: }\n469: \n470: func TestServerHandleGetSandboxErrorNoMatchingEntryPoint(t *testing.T) {\n471: \tgin.SetMode(gin.TestMode)\n472: \n473: \tconfig := DefaultConfig()\n474: \tmockLogger := &MockLogger{}\n475: \tmockStore := &MockStore{\n476: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n477: \t\t\treturn nil\n478: \t\t},\n479: \t}\n480: \tmockSM := &mockSessionManager{\n481: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n482: \t\t\treturn &types.SandboxInfo{\n483: \t\t\t\tSessionID: \"test-session\",\n484: \t\t\t\tSandboxID: \"test-sandbox\",\n485: \t\t\t\tKind:      types.AgentRuntimeKind,\n486: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n487: \t\t\t\t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n488: \t\t\t\t},\n489: \t\t\t}, nil\n490: \t\t},\n491: \t}\n492: \tjwtMgr, _ := NewJWTManager()\n493: \n494: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n495: \n496: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/test-runtime/invocations/api/test\", nil)\n497: \treq.Header.Set(\"x-agentcube-session-id\", \"test-session\")\n498: \tw := httptest.NewRecorder()\n499: \n500: \tserver.engine.ServeHTTP(w, req)\n501: }\n502: \n503: func TestServerInvokeWithJWTGeneration(t *testing.T) {\n504: \tgin.SetMode(gin.TestMode)\n505: \n506: \tconfig := DefaultConfig()\n507: \tmockLogger := &MockLogger{}\n508: \tmockStore := &MockStore{\n509: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n510: \t\t\treturn nil\n511: \t\t},\n512: \t}\n513: \tmockSM := &mockSessionManager{\n514: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n515: \t\t\treturn &types.SandboxInfo{\n516: \t\t\t\tSessionID:        \"jwt-session\",\n517: \t\t\t\tSandboxID:        \"jwt-sandbox\",\n518: \t\t\t\tSandboxNamespace: \"default\",\n519: \t\t\t\tSandboxName:      \"jwt-runtime\",\n520: \t\t\t\tName:             \"jwt-runtime\",\n521: \t\t\t\tKind:             types.SandboxKind,\n522: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n523: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n524: \t\t\t\t},\n525: \t\t\t}, nil\n526: \t\t},\n527: \t}\n528: \tjwtMgr, _ := NewJWTManager()\n529: \n530: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n531: \n532: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/jwt-runtime/invocations/api/test\", nil)\n533: \treq.Header.Set(\"x-agentcube-session-id\", \"jwt-session\")\n534: \tw := httptest.NewRecorder()\n535: \n536: \tserver.engine.ServeHTTP(w, req)\n537: }\n538: \n539: func TestServerUpdateActivityFailure(t *testing.T) {\n540: \tgin.SetMode(gin.TestMode)\n541: \n542: \tconfig := DefaultConfig()\n543: \tmockLogger := &MockLogger{}\n544: \tmockStore := &MockStore{\n545: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n546: \t\t\treturn errors.New(\"update failed\")\n547: \t\t},\n548: \t}\n549: \tmockSM := &mockSessionManager{\n550: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n551: \t\t\treturn &types.SandboxInfo{\n552: \t\t\t\tSessionID: \"test-session\",\n553: \t\t\t\tSandboxID: \"test-sandbox\",\n554: \t\t\t\tKind:      types.AgentRuntimeKind,\n555: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n556: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n557: \t\t\t\t},\n558: \t\t\t}, nil\n559: \t\t},\n560: \t}\n561: \tjwtMgr, _ := NewJWTManager()\n562: \n563: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n564: \n565: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/test-runtime/invocations/api/test\", nil)\n566: \treq.Header.Set(\"x-agentcube-session-id\", \"test-session\")\n567: \tw := httptest.NewRecorder()\n568: \n569: \tserver.engine.ServeHTTP(w, req)\n570: }\n571: \n572: func TestServerTLSWithValidCertKey(t *testing.T) {\n573: \tgin.SetMode(gin.TestMode)\n574: \n575: \tcertFile := \"/tmp/test-cert.pem\"\n576: \tkeyFile := \"/tmp/test-key.pem\"\n577: \n578: \tconfig := &Config{\n579: \t\tPort:      \":0\",\n580: \t\tEnableTLS: true,\n581: \t\tTLSCert:   certFile,\n582: \t\tTLSKey:    keyFile,\n583: \t}\n584: \n585: \tmockLogger := &MockLogger{}\n586: \tmockStore := &MockStore{}\n587: \tmockSM := &mockSessionManager{}\n588: \tjwtMgr, _ := NewJWTManager()\n589: \n590: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n591: \n592: \tctx, cancel := context.WithCancel(context.Background())\n593: \tdefer cancel()\n594: \n595: \tgo func() {\n596: \t\ttime.Sleep(50 * time.Millisecond)\n597: \t\tcancel()\n598: \t}()\n599: \n600: \terr := server.Start(ctx)\n601: \tif err == nil {\n602: \t\tt.Error(\"expected error when cert/key files don't exist\")\n603: \t}\n604: }\n\n(End of file - total 604 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestNewServer(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tconfig := DefaultConfig()\n\tconfig.Debug = true","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/server_test.go","time":{"start":1775899870447,"end":1775899870481}}}}
