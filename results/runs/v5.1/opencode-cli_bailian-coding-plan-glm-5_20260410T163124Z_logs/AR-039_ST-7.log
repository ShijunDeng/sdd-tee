Env)\n50: \t\t}\n51: \t})\n52: \n53: \t_, err := NewAuthManager()\n54: \tassert.Error(t, err)\n55: \tassert.Contains(t, err.Error(), \"failed to load public key\")\n56: \tassert.Contains(t, err.Error(), \"public key environment variable not set\")\n57: }\n58: \n59: func TestNewAuthManagerInvalidPEM(t *testing.T) {\n60: \toldEnv := os.Getenv(PublicKeyEnvVar)\n61: \tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n62: \tt.Cleanup(func() {\n63: \t\tif oldEnv != \"\" {\n64: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n65: \t\t} else {\n66: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n67: \t\t}\n68: \t})\n69: \n70: \t_, err := NewAuthManager()\n71: \tassert.Error(t, err)\n72: \tassert.Contains(t, err.Error(), \"failed to load public key\")\n73: \tassert.Contains(t, err.Error(), \"failed to decode PEM block\")\n74: }\n75: \n76: func TestNewAuthManagerWrongKeyType(t *testing.T) {\n77: \tprivateKey, err := ecdsa.GenerateKey(elliptic.P256(), rand.Reader)\n78: \trequire.NoError(t, err)\n79: \n80: \tpubBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)\n81: \trequire.NoError(t, err)\n82: \n83: \tpemData := pem.EncodeToMemory(&pem.Block{\n84: \t\tType:  \"PUBLIC KEY\",\n85: \t\tBytes: pubBytes,\n86: \t})\n87: \n88: \toldEnv := os.Getenv(PublicKeyEnvVar)\n89: \tos.Setenv(PublicKeyEnvVar, string(pemData))\n90: \tt.Cleanup(func() {\n91: \t\tif oldEnv != \"\" {\n92: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n93: \t\t} else {\n94: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n95: \t\t}\n96: \t})\n97: \n98: \t_, err = NewAuthManager()\n99: \tassert.Error(t, err)\n100: \tassert.Contains(t, err.Error(), \"failed to load public key\")\n101: \tassert.Contains(t, err.Error(), \"public key is not RSA\")\n102: }\n103: \n104: func TestAuthMiddlewareInvalidSignature(t *testing.T) {\n105: \tprivateKey1, err := rsa.GenerateKey(rand.Reader, 2048)\n106: \trequire.NoError(t, err)\n107: \n108: \tprivateKey2, err := rsa.GenerateKey(rand.Reader, 2048)\n109: \trequire.NoError(t, err)\n110: \n111: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey1.PublicKey)\n112: \n113: \toldEnv := os.Getenv(PublicKeyEnvVar)\n114: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n115: \tt.Cleanup(func() {\n116: \t\tif oldEnv != \"\" {\n117: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n118: \t\t} else {\n119: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n120: \t\t}\n121: \t})\n122: \n123: \tauthMgr, err := NewAuthManager()\n124: \trequire.NoError(t, err)\n125: \n126: \tgin.SetMode(gin.TestMode)\n127: \tengine := gin.New()\n128: \tapi := engine.Group(\"/api\")\n129: \tapi.Use(authMgr.AuthMiddleware())\n130: \tapi.POST(\"/test\", func(c *gin.Context) {\n131: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n132: \t})\n133: \n134: \ttokenSignedWithKey2 := generateTestJWT(privateKey2, false)\n135: \n136: \tw := httptest.NewRecorder()\n137: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n138: \treq.Header.Set(\"Authorization\", \"Bearer \"+tokenSignedWithKey2)\n139: \tengine.ServeHTTP(w, req)\n140: \n141: \tassert.Equal(t, 401, w.Code)\n142: \tassert.Contains(t, w.Body.String(), \"invalid signature\")\n143: }\n144: \n145: func TestAuthMiddlewareEmptyToken(t *testing.T) {\n146: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n147: \trequire.NoError(t, err)\n148: \n149: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n150: \n151: \toldEnv := os.Getenv(PublicKeyEnvVar)\n152: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n153: \tt.Cleanup(func() {\n154: \t\tif oldEnv != \"\" {\n155: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n156: \t\t} else {\n157: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n158: \t\t}\n159: \t})\n160: \n161: \tauthMgr, err := NewAuthManager()\n162: \trequire.NoError(t, err)\n163: \n164: \tgin.SetMode(gin.TestMode)\n165: \tengine := gin.New()\n166: \tapi := engine.Group(\"/api\")\n167: \tapi.Use(authMgr.AuthMiddleware())\n168: \tapi.POST(\"/test\", func(c *gin.Context) {\n169: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n170: \t})\n171: \n172: \tw := httptest.NewRecorder()\n173: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n174: \treq.Header.Set(\"Authorization\", \"Bearer \")\n175: \tengine.ServeHTTP(w, req)\n176: \n177: \tassert.Equal(t, 401, w.Code)\n178: }\n179: \n180: func TestSetGetPublicKey(t *testing.T) {\n181: \tprivateKey1, err := rsa.GenerateKey(rand.Reader, 2048)\n182: \trequire.NoError(t, err)\n183: \n184: \tprivateKey2, err := rsa.GenerateKey(rand.Reader, 2048)\n185: \trequire.NoError(t, err)\n186: \n187: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey1.PublicKey)\n188: \n189: \toldEnv := os.Getenv(PublicKeyEnvVar)\n190: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n191: \tt.Cleanup(func() {\n192: \t\tif oldEnv != \"\" {\n193: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n194: \t\t} else {\n195: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n196: \t\t}\n197: \t})\n198: \n199: \tauthMgr, err := NewAuthManager()\n200: \trequire.NoError(t, err)\n201: \n202: \tinitialKey := authMgr.GetPublicKey()\n203: \tassert.Equal(t, &privateKey1.PublicKey, initialKey)\n204: \n205: \tauthMgr.SetPublicKey(&privateKey2.PublicKey)\n206: \n207: \tnewKey := authMgr.GetPublicKey()\n208: \tassert.Equal(t, &privateKey2.PublicKey, newKey)\n209: \tassert.NotEqual(t, initialKey, newKey)\n210: }\n211: \n212: func TestPublicKeyConcurrency(t *testing.T) {\n213: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n214: \trequire.NoError(t, err)\n215: \n216: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n217: \n218: \toldEnv := os.Getenv(PublicKeyEnvVar)\n219: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n220: \tt.Cleanup(func() {\n221: \t\tif oldEnv != \"\" {\n222: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n223: \t\t} else {\n224: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n225: \t\t}\n226: \t})\n227: \n228: \tauthMgr, err := NewAuthManager()\n229: \trequire.NoError(t, err)\n230: \n231: \tkey1, err := rsa.GenerateKey(rand.Reader, 2048)\n232: \trequire.NoError(t, err)\n233: \tkey2, err := rsa.GenerateKey(rand.Reader, 2048)\n234: \trequire.NoError(t, err)\n235: \tkey3, err := rsa.GenerateKey(rand.Reader, 2048)\n236: \trequire.NoError(t, err)\n237: \n238: \tnumOps := 100\n239: \tdone := make(chan bool, numOps)\n240: \n241: \tvar wg sync.WaitGroup\n242: \twg.Add(numOps)\n243: \n244: \tfor i := 0; i < numOps; i++ {\n245: \t\tgo func(idx int) {\n246: \t\t\tdefer wg.Done()\n247: \t\t\tif idx%3 == 0 {\n248: \t\t\t\tauthMgr.SetPublicKey(&key1.PublicKey)\n249: \t\t\t} else if idx%3 == 1 {\n250: \t\t\t\tauthMgr.SetPublicKey(&key2.PublicKey)\n251: \t\t\t} else {\n252: \t\t\t\tauthMgr.SetPublicKey(&key3.PublicKey)\n253: \t\t\t}\n254: \t\t\t_ = authMgr.GetPublicKey()\n255: \t\t\tdone <- true\n256: \t\t}(i)\n257: \t}\n258: \n259: \twg.Wait()\n260: \n261: \tfor i := 0; i < numOps; i++ {\n262: \t\tselect {\n263: \t\tcase <-done:\n264: \t\tcase <-time.After(5 * time.Second):\n265: \t\t\tt.Fatal(\"concurrent operation timed out\")\n266: \t\t}\n267: \t}\n268: \n269: \tfinalKey := authMgr.GetPublicKey()\n270: \tassert.NotNil(t, finalKey)\n271: }\n272: \n273: func TestAuthMiddlewareKeyRotation(t *testing.T) {\n274: \tkey1, err := rsa.GenerateKey(rand.Reader, 2048)\n275: \trequire.NoError(t, err)\n276: \n277: \tkey2, err := rsa.GenerateKey(rand.Reader, 2048)\n278: \trequire.NoError(t, err)\n279: \n280: \tpublicKeyPEM := encodePublicKeyPEMForTest(&key1.PublicKey)\n281: \n282: \toldEnv := os.Getenv(PublicKeyEnvVar)\n283: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n284: \tt.Cleanup(func() {\n285: \t\tif oldEnv != \"\" {\n286: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n287: \t\t} else {\n288: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n289: \t\t}\n290: \t})\n291: \n292: \tauthMgr, err := NewAuthManager()\n293: \trequire.NoError(t, err)\n294: \n295: \tgin.SetMode(gin.TestMode)\n296: \tengine := gin.New()\n297: \tapi := engine.Group(\"/api\")\n298: \tapi.Use(authMgr.AuthMiddleware())\n299: \tapi.POST(\"/test\", func(c *gin.Context) {\n300: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n301: \t})\n302: \n303: \ttoken1 := generateTestJWT(key1, false)\n304: \n305: \tw := httptest.NewRecorder()\n306: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n307: \treq.Header.Set(\"Authorization\", \"Bearer \"+token1)\n308: \tengine.ServeHTTP(w, req)\n309: \tassert.Equal(t, 200, w.Code)\n310: \n311: \tauthMgr.SetPublicKey(&key2.PublicKey)\n312: \n313: \ttoken2 := generateTestJWT(key2, false)\n314: \n315: \tw = httptest.NewRecorder()\n316: \treq = httptest.NewRequest(\"POST\", \"/api/test\", nil)\n317: \treq.Header.Set(\"Authorization\", \"Bearer \"+token2)\n318: \tengine.ServeHTTP(w, req)\n319: \tassert.Equal(t, 200, w.Code)\n320: \n321: \tw = httptest.NewRecorder()\n322: \treq = httptest.NewRequest(\"POST\", \"/api/test\", nil)\n323: \treq.Header.Set(\"Authorization\", \"Bearer \"+token1)\n324: \tengine.ServeHTTP(w, req)\n325: \tassert.Equal(t, 401, w.Code)\n326: \tassert.Contains(t, w.Body.String(), \"invalid signature\")\n327: }\n328: \n329: func TestAuthMiddlewareMalformedAuthHeader(t *testing.T) {\n330: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n331: \trequire.NoError(t, err)\n332: \n333: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n334: \n335: \toldEnv := os.Getenv(PublicKeyEnvVar)\n336: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n337: \tt.Cleanup(func() {\n338: \t\tif oldEnv != \"\" {\n339: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n340: \t\t} else {\n341: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n342: \t\t}\n343: \t})\n344: \n345: \tauthMgr, err := NewAuthManager()\n346: \trequire.NoError(t, err)\n347: \n348: \tgin.SetMode(gin.TestMode)\n349: \tengine := gin.New()\n350: \tapi := engine.Group(\"/api\")\n351: \tapi.Use(authMgr.AuthMiddleware())\n352: \tapi.POST(\"/test\", func(c *gin.Context) {\n353: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n354: \t})\n355: \n356: \tw := httptest.NewRecorder()\n357: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n358: \treq.Header.Set(\"Authorization\", \"Basic some-token\")\n359: \tengine.ServeHTTP(w, req)\n360: \n361: \tassert.Equal(t, 401, w.Code)\n362: \tassert.Contains(t, w.Body.String(), \"invalid token format\")\n363: }\n364: \n365: func TestAuthMiddlewareNoBearerPrefix(t *testing.T) {\n366: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n367: \trequire.NoError(t, err)\n368: \n369: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n370: \n371: \toldEnv := os.Getenv(PublicKeyEnvVar)\n372: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n373: \tt.Cleanup(func() {\n374: \t\tif oldEnv != \"\" {\n375: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n376: \t\t} else {\n377: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n378: \t\t}\n379: \t})\n380: \n381: \tauthMgr, err := NewAuthManager()\n382: \trequire.NoError(t, err)\n383: \n384: \tgin.SetMode(gin.TestMode)\n385: \tengine := gin.New()\n386: \tapi := engine.Group(\"/api\")\n387: \tapi.Use(authMgr.AuthMiddleware())\n388: \tapi.POST(\"/test\", func(c *gin.Context) {\n389: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n390: \t})\n391: \n392: \ttoken := generateTestJWT(privateKey, false)\n393: \n394: \tw := httptest.NewRecorder()\n395: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n396: \treq.Header.Set(\"Authorization\", token)\n397: \tengine.ServeHTTP(w, req)\n398: \n399: \tassert.Equal(t, 401, w.Code)\n400: \tassert.Contains(t, w.Body.String(), \"invalid token format\")\n401: }\n402: \n403: func TestAuthMiddlewareBearerPrefixOnly(t *testing.T) {\n404: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n405: \trequire.NoError(t, err)\n406: \n407: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n408: \n409: \toldEnv := os.Getenv(PublicKeyEnvVar)\n410: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n411: \tt.Cleanup(func() {\n412: \t\tif oldEnv != \"\" {\n413: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n414: \t\t} else {\n415: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n416: \t\t}\n417: \t})\n418: \n419: \tauthMgr, err := NewAuthManager()\n420: \trequire.NoError(t, err)\n421: \n422: \tgin.SetMode(gin.TestMode)\n423: \tengine := gin.New()\n424: \tapi := engine.Group(\"/api\")\n425: \tapi.Use(authMgr.AuthMiddleware())\n426: \tapi.POST(\"/test\", func(c *gin.Context) {\n427: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n428: \t})\n429: \n430: \tw := httptest.NewRecorder()\n431: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n432: \treq.Header.Set(\"Authorization\", \"Bearer\")\n433: \tengine.ServeHTTP(w, req)\n434: \n435: \tassert.Equal(t, 401, w.Code)\n436: }\n437: \n438: func TestAuthMiddlewareLeeway(t *testing.T) {\n439: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n440: \trequire.NoError(t, err)\n441: \n442: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n443: \n444: \toldEnv := os.Getenv(PublicKeyEnvVar)\n445: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n446: \tt.Cleanup(func() {\n447: \t\tif oldEnv != \"\" {\n448: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n449: \t\t} else {\n450: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n451: \t\t}\n452: \t})\n453: \n454: \tauthMgr, err := NewAuthManager()\n455: \trequire.NoError(t, err)\n456: \n457: \tgin.SetMode(gin.TestMode)\n458: \tengine := gin.New()\n459: \tapi := engine.Group(\"/api\")\n460: \tapi.Use(authMgr.AuthMiddleware())\n461: \tapi.POST(\"/test\", func(c *gin.Context) {\n462: \t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n463: \t})\n464: \n465: \tnow := time.Now()\n466: \tclaims := jwt.MapClaims{\n467: \t\t\"exp\": now.Add(30 * time.Second).Unix(),\n468: \t\t\"iat\": now.Add(30 * time.Second).Unix(),\n469: \t}\n470: \n471: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n472: \ttokenString, err := token.SignedString(privateKey)\n473: \trequire.NoError(t, err)\n474: \n475: \tw := httptest.NewRecorder()\n476: \treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n477: \treq.Header.Set(\"Authorization\", \"Bearer \"+tokenString)\n478: \tengine.ServeHTTP(w, req)\n479: \n480: \tassert.Equal(t, 200, w.Code)\n481: }\n\n(End of file - total 481 lines)\n</content>","metadata":{"p