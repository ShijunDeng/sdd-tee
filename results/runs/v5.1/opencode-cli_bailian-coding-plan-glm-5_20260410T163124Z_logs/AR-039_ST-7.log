{"type":"tool_use","timestamp":1775899870477,"sessionID":"ses_2841efe33ffezPehlvgUexQPtY","part":{"id":"prt_d7be17916001lYaMv9wm4K869N","messageID":"msg_d7be16008001GYqogPVry310rB","sessionID":"ses_2841efe33ffezPehlvgUexQPtY","type":"tool","tool":"read","callID":"toolu_tool-7f6b8332a026455993c6897d50670e05","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go</path>\n<type>file</type>\n<content>\n1: package picod\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"crypto/rand\"\n7: \t\"crypto/rsa\"\n8: \t\"crypto/x509\"\n9: \t\"encoding/base64\"\n10: \t\"encoding/json\"\n11: \t\"encoding/pem\"\n12: \t\"fmt\"\n13: \t\"io\"\n14: \t\"mime/multipart\"\n15: \t\"net/http\"\n16: \t\"net/http/httptest\"\n17: \t\"os\"\n18: \t\"path/filepath\"\n19: \t\"testing\"\n20: \t\"time\"\n21: \n22: \t\"github.com/gin-gonic/gin\"\n23: \t\"github.com/golang-jwt/jwt/v5\"\n24: \t\"github.com/stretchr/testify/assert\"\n25: \t\"github.com/stretchr/testify/require\"\n26: )\n27: \n28: func setupTestServer(t *testing.T) *Server {\n29: \tt.Helper()\n30: \n31: \tworkspace := t.TempDir()\n32: \n33: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n34: \trequire.NoError(t, err)\n35: \n36: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n37: \n38: \toldEnv := os.Getenv(PublicKeyEnvVar)\n39: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n40: \tt.Cleanup(func() {\n41: \t\tif oldEnv != \"\" {\n42: \t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n43: \t\t} else {\n44: \t\t\tos.Unsetenv(PublicKeyEnvVar)\n45: \t\t}\n46: \t})\n47: \n48: \tserver, err := NewServer(&Config{\n49: \t\tPort:      8080,\n50: \t\tWorkspace: workspace,\n51: \t})\n52: \trequire.NoError(t, err)\n53: \n54: \treturn server\n55: }\n56: \n57: func encodePublicKeyPEMForTest(key *rsa.PublicKey) string {\n58: \tbytes, err := x509.MarshalPKIXPublicKey(key)\n59: \tif err != nil {\n60: \t\treturn \"\"\n61: \t}\n62: \tpemData := pem.EncodeToMemory(&pem.Block{\n63: \t\tType:  \"PUBLIC KEY\",\n64: \t\tBytes: bytes,\n65: \t})\n66: \treturn string(pemData)\n67: }\n68: \n69: func generateTestJWT(privateKey *rsa.PrivateKey, expired bool) string {\n70: \tnow := time.Now()\n71: \texpiry := now.Add(5 * time.Minute)\n72: \tif expired {\n73: \t\texpiry = now.Add(-5 * time.Minute)\n74: \t}\n75: \n76: \tclaims := jwt.MapClaims{\n77: \t\t\"exp\": expiry.Unix(),\n78: \t\t\"iat\": now.Unix(),\n79: \t\t\"iss\": \"test-issuer\",\n80: \t}\n81: \n82: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n83: \ttokenString, _ := token.SignedString(privateKey)\n84: \treturn tokenString\n85: }\n86: \n87: func generateHS256JWT() string {\n88: \tclaims := jwt.MapClaims{\n89: \t\t\"exp\": time.Now().Add(5 * time.Minute).Unix(),\n90: \t\t\"iat\": time.Now().Unix(),\n91: \t}\n92: \n93: \ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n94: \ttokenString, _ := token.SignedString([]byte(\"test-secret\"))\n95: \treturn tokenString\n96: }\n97: \n98: func makeAuthenticatedRequest(t *testing.T, server *Server, method, path string, body io.Reader, contentType string, jwtToken string) *httptest.ResponseRecorder {\n99: \tt.Helper()\n100: \n101: \tgin.SetMode(gin.TestMode)\n102: \tw := httptest.NewRecorder()\n103: \treq := httptest.NewRequest(method, path, body)\n104: \tif contentType != \"\" {\n105: \t\treq.Header.Set(\"Content-Type\", contentType)\n106: \t}\n107: \tif jwtToken != \"\" {\n108: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+jwtToken)\n109: \t}\n110: \n111: \tserver.engine.ServeHTTP(w, req)\n112: \treturn w\n113: }\n114: \n115: func TestConfig(t *testing.T) {\n116: \tcfg := &Config{\n117: \t\tPort:      8080,\n118: \t\tWorkspace: \"/tmp/test\",\n119: \t}\n120: \n121: \tassert.Equal(t, 8080, cfg.Port)\n122: \tassert.Equal(t, \"/tmp/test\", cfg.Workspace)\n123: }\n124: \n125: func TestSanitizePathValidRelative(t *testing.T) {\n126: \tworkspace := t.TempDir()\n127: \n128: \tresult, err := sanitizePath(workspace, \"subdir/file.txt\")\n129: \trequire.NoError(t, err)\n130: \n131: \texpected := filepath.Join(workspace, \"subdir/file.txt\")\n132: \tassert.Equal(t, expected, result)\n133: }\n134: \n135: func TestSanitizePathAbsolute(t *testing.T) {\n136: \tworkspace := t.TempDir()\n137: \n138: \tresult, err := sanitizePath(workspace, \"/workspace/file.txt\")\n139: \trequire.NoError(t, err)\n140: \n141: \texpected := filepath.Join(workspace, \"workspace/file.txt\")\n142: \tassert.Equal(t, expected, result)\n143: }\n144: \n145: func TestSanitizePathTraversal(t *testing.T) {\n146: \tworkspace := t.TempDir()\n147: \n148: \t_, err := sanitizePath(workspace, \"../escape.txt\")\n149: \tassert.Error(t, err)\n150: \tassert.Contains(t, err.Error(), \"path escape\")\n151: }\n152: \n153: func TestSanitizePathDeepTraversal(t *testing.T) {\n154: \tworkspace := t.TempDir()\n155: \n156: \t_, err := sanitizePath(workspace, \"subdir/../../escape.txt\")\n157: \tassert.Error(t, err)\n158: \tassert.Contains(t, err.Error(), \"path escape\")\n159: }\n160: \n161: func TestSanitizePathNullByte(t *testing.T) {\n162: \tworkspace := t.TempDir()\n163: \n164: \tresult, err := sanitizePath(workspace, \"file\\x00.txt\")\n165: \trequire.NoError(t, err)\n166: \n167: \tassert.Contains(t, result, workspace)\n168: }\n169: \n170: func TestSanitizePathExistingSymlink(t *testing.T) {\n171: \tworkspace := t.TempDir()\n172: \n173: \ttargetDir := filepath.Join(workspace, \"target\")\n174: \trequire.NoError(t, os.MkdirAll(targetDir, 0755))\n175: \n176: \tlinkPath := filepath.Join(workspace, \"link\")\n177: \trequire.NoError(t, os.Symlink(targetDir, linkPath))\n178: \n179: \ttargetFile := filepath.Join(targetDir, \"file.txt\")\n180: \trequire.NoError(t, os.WriteFile(targetFile, []byte(\"test\"), 0644))\n181: \n182: \tresult, err := sanitizePath(workspace, \"link/file.txt\")\n183: \trequire.NoError(t, err)\n184: \n185: \tassert.Equal(t, targetFile, result)\n186: }\n187: \n188: func TestAuthMiddlewareMissingHeader(t *testing.T) {\n189: \tserver := setupTestServer(t)\n190: \n191: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"\")\n192: \tassert.Equal(t, 401, w.Code)\n193: \n194: \tvar resp map[string]string\n195: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n196: \tassert.Equal(t, \"missing authorization header\", resp[\"error\"])\n197: }\n198: \n199: func TestAuthMiddlewareInvalidFormat(t *testing.T) {\n200: \tserver := setupTestServer(t)\n201: \n202: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"InvalidFormat\")\n203: \tassert.Equal(t, 401, w.Code)\n204: \n205: \tvar resp map[string]string\n206: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n207: \tassert.Contains(t, resp[\"error\"], \"malformed\")\n208: }\n209: \n210: func TestAuthMiddlewareExpiredToken(t *testing.T) {\n211: \tserver := setupTestServer(t)\n212: \n213: \tauthMgr := server.authManager\n214: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n215: \trequire.NoError(t, err)\n216: \n217: \texpiredToken := generateTestJWT(privateKey, true)\n218: \n219: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n220: \n221: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", expiredToken)\n222: \tassert.Equal(t, 401, w.Code)\n223: \n224: \tvar resp map[string]string\n225: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n226: \tassert.Equal(t, \"token is expired\", resp[\"error\"])\n227: }\n228: \n229: func TestAuthMiddlewareHS256Token(t *testing.T) {\n230: \tserver := setupTestServer(t)\n231: \n232: \ths256Token := generateHS256JWT()\n233: \n234: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", hs256Token)\n235: \tassert.Equal(t, 401, w.Code)\n236: \n237: \tvar resp map[string]string\n238: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n239: \tassert.Equal(t, \"invalid signing method\", resp[\"error\"])\n240: }\n241: \n242: func TestAuthMiddlewareValidRS256Token(t *testing.T) {\n243: \tserver := setupTestServer(t)\n244: \n245: \tauthMgr := server.authManager\n246: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n247: \trequire.NoError(t, err)\n248: \n249: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n250: \n251: \tvalidToken := generateTestJWT(privateKey, false)\n252: \n253: \tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"hello\"]}`)\n254: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n255: \tassert.Equal(t, 200, w.Code)\n256: }\n257: \n258: func TestExecuteHandlerValidCommand(t *testing.T) {\n259: \tserver := setupTestServer(t)\n260: \n261: \tauthMgr := server.authManager\n262: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n263: \trequire.NoError(t, err)\n264: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n265: \n266: \tvalidToken := generateTestJWT(privateKey, false)\n267: \n268: \tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"hello\"]}`)\n269: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n270: \tassert.Equal(t, 200, w.Code)\n271: \n272: \tvar resp ExecuteResponse\n273: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n274: \tassert.Equal(t, \"hello\\n\", resp.Stdout)\n275: \tassert.Equal(t, 0, resp.ExitCode)\n276: \tassert.Greater(t, resp.Duration, 0.0)\n277: }\n278: \n279: func TestExecuteHandlerEmptyCommand(t *testing.T) {\n280: \tserver := setupTestServer(t)\n281: \n282: \tauthMgr := server.authManager\n283: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n284: \trequire.NoError(t, err)\n285: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n286: \n287: \tvalidToken := generateTestJWT(privateKey, false)\n288: \n289: \tbody := bytes.NewBufferString(`{\"command\": []}`)\n290: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n291: \tassert.Equal(t, 400, w.Code)\n292: \n293: \tvar resp map[string]string\n294: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n295: \tassert.Equal(t, \"missing command\", resp[\"error\"])\n296: }\n297: \n298: func TestExecuteHandlerTimeout(t *testing.T) {\n299: \tserver := setupTestServer(t)\n300: \n301: \tauthMgr := server.authManager\n302: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n303: \trequire.NoError(t, err)\n304: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n305: \n306: \tvalidToken := generateTestJWT(privateKey, false)\n307: \n308: \tbody := bytes.NewBufferString(`{\"command\": [\"sleep\", \"10\"], \"timeout\": \"1s\"}`)\n309: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n310: \tassert.Equal(t, 200, w.Code)\n311: \n312: \tvar resp ExecuteResponse\n313: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n314: \tassert.Equal(t, TimeoutExitCode, resp.ExitCode)\n315: \tassert.Contains(t, resp.Stderr, \"command timed out\")\n316: }\n317: \n318: func TestExecuteHandlerInvalidTimeout(t *testing.T) {\n319: \tserver := setupTestServer(t)\n320: \n321: \tauthMgr := server.authManager\n322: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n323: \trequire.NoError(t, err)\n324: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n325: \n326: \tvalidToken := generateTestJWT(privateKey, false)\n327: \n328: \tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"test\"], \"timeout\": \"invalid\"}`)\n329: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n330: \tassert.Equal(t, 200, w.Code)\n331: \n332: \tvar resp ExecuteResponse\n333: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n334: \tassert.Equal(t, 0, resp.ExitCode)\n335: }\n336: \n337: func TestExecuteHandlerWorkingDirectory(t *testing.T) {\n338: \tserver := setupTestServer(t)\n339: \n340: \tsubdir := filepath.Join(server.workspace, \"subdir\")\n341: \trequire.NoError(t, os.MkdirAll(subdir, 0755))\n342: \n343: \tauthMgr := server.authManager\n344: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n345: \trequire.NoError(t, err)\n346: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n347: \n348: \tvalidToken := generateTestJWT(privateKey, false)\n349: \n350: \tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"subdir\"}`)\n351: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n352: \tassert.Equal(t, 200, w.Code)\n353: \n354: \tvar resp ExecuteResponse\n355: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n356: \tassert.Contains(t, resp.Stdout, subdir)\n357: }\n358: \n359: func TestExecuteHandlerPathEscapeWorkingDir(t *testing.T) {\n360: \tserver := setupTestServer(t)\n361: \n362: \tauthMgr := server.authManager\n363: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n364: \trequire.NoError(t, err)\n365: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n366: \n367: \tvalidToken := generateTestJWT(privateKey, false)\n368: \n369: \tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"../escape\"}`)\n370: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n371: \tassert.Equal(t, 400, w.Code)\n372: \n373: \tvar resp map[string]string\n374: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n375: \tassert.Contains(t, resp[\"error\"], \"invalid working directory\")\n376: }\n377: \n378: func TestExecuteHandlerEnvironmentAugmentation(t *testing.T) {\n379: \tserver := setupTestServer(t)\n380: \n381: \tauthMgr := server.authManager\n382: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n383: \trequire.NoError(t, err)\n384: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n385: \n386: \tvalidToken := generateTestJWT(privateKey, false)\n387: \n388: \tbody := bytes.NewBufferString(`{\"command\": [\"sh\", \"-c\", \"echo $MY_VAR\"], \"env\": {\"MY_VAR\": \"test_value\"}}`)\n389: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n390: \tassert.Equal(t, 200, w.Code)\n391: \n392: \tvar resp ExecuteResponse\n393: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n394: \tassert.Contains(t, resp.Stdout, \"test_value\")\n395: }\n396: \n397: func TestExecuteHandlerExitCodePropagation(t *testing.T) {\n398: \tserver := setupTestServer(t)\n399: \n400: \tauthMgr := server.authManager\n401: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n402: \trequire.NoError(t, err)\n403: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n404: \n405: \tvalidToken := generateTestJWT(privateKey, false)\n406: \n407: \tbody := bytes.NewBufferString(`{\"command\": [\"sh\", \"-c\", \"exit 42\"]}`)\n408: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n409: \tassert.Equal(t, 200, w.Code)\n410: \n411: \tvar resp ExecuteResponse\n412: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n413: \tassert.Equal(t, 42, resp.ExitCode)\n414: }\n415: \n416: func TestUploadFileHandlerMultipart(t *testing.T) {\n417: \tserver := setupTestServer(t)\n418: \n419: \tauthMgr := server.authManager\n420: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n421: \trequire.NoError(t, err)\n422: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n423: \n424: \tvalidToken := generateTestJWT(privateKey, false)\n425: \n426: \tbody := &bytes.Buffer{}\n427: \twriter := multipart.NewWriter(body)\n428: \n429: \trequire.NoError(t, writer.WriteField(\"path\", \"upload.txt\"))\n430: \tpart, err := writer.CreateFormFile(\"file\", \"upload.txt\")\n431: \trequire.NoError(t, err)\n432: \t_, err = part.Write([]byte(\"test file content\"))\n433: \trequire.NoError(t, err)\n434: \trequire.NoError(t, writer.Close())\n435: \n436: \treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n437: \treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n438: \treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n439: \n440: \tw := httptest.NewRecorder()\n441: \tserver.engine.ServeHTTP(w, req)\n442: \n443: \tassert.Equal(t, 200, w.Code)\n444: \n445: \tvar resp FileInfo\n446: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n447: \tassert.Equal(t, \"upload.txt\", resp.Path)\n448: \n449: \tfilePath := filepath.Join(server.workspace, \"upload.txt\")\n450: \tactualContent, err := os.ReadFile(filePath)\n451: \trequire.NoError(t, err)\n452: \tassert.Equal(t, []byte(\"test file content\"), actualContent)\n453: }\n454: \n455: func TestUploadFileHandlerJSON(t *testing.T) {\n456: \tserver := setupTestServer(t)\n457: \n458: \tauthMgr := server.authManager\n459: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n460: \trequire.NoError(t, err)\n461: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n462: \n463: \tvalidToken := generateTestJWT(privateKey, false)\n464: \n465: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"test content\"))\n466: \tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\"}`, content))\n467: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n468: \tassert.Equal(t, 200, w.Code)\n469: \n470: \tvar resp FileInfo\n471: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n472: \tassert.Equal(t, \"test.txt\", resp.Path)\n473: \tassert.Equal(t, int64(12), resp.Size)\n474: \n475: \tfilePath := filepath.Join(server.workspace, \"test.txt\")\n476: \tactualContent, err := os.ReadFile(filePath)\n477: \trequire.NoError(t, err)\n478: \tassert.Equal(t, []byte(\"test content\"), actualContent)\n479: }\n480: \n481: func TestUploadFileHandlerInvalidBase64(t *testing.T) {\n482: \tserver := setupTestServer(t)\n483: \n484: \tauthMgr := server.authManager\n485: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n486: \trequire.NoError(t, err)\n487: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n488: \n489: \tvalidToken := generateTestJWT(privateKey, false)\n490: \n491: \tbody := bytes.NewBufferString(`{\"path\": \"test.txt\", \"content\": \"!!invalid\"}`)\n492: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n493: \tassert.Equal(t, 400, w.Code)\n494: \n495: \tvar resp map[string]string\n496: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n497: \tassert.Equal(t, \"invalid base64 content\", resp[\"error\"])\n498: }\n499: \n500: func TestUploadFileHandlerPathEscape(t *testing.T) {\n501: \tserver := setupTestServer(t)\n502: \n503: \tauthMgr := server.authManager\n504: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n505: \trequire.NoError(t, err)\n506: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n507: \n508: \tvalidToken := generateTestJWT(privateKey, false)\n509: \n510: \tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n511: \tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"../escape.txt\", \"content\": \"%s\"}`, content))\n512: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n513: \tassert.Equal(t, 400, w.Code)\n514: \n515: \tvar resp map[string]string\n516: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n517: \tassert.Contains(t, resp[\"error\"], \"invalid path\")\n518: }\n519: \n520: func TestUploadFileHandlerInvalidMode(t *testing.T) {\n521: \tserver := setupTestServer(t)\n522: \n523: \tauthMgr := server.authManager\n524: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n525: \trequire.NoError(t, err)\n526: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n527: \n528: \tvalidToken := generateTestJWT(privateKey, false)\