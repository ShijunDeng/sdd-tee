ge_collector.go","before":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n)\n\nconst GCBatchSize = 16\n\ntype GarbageCollector struct {\n\tmanager     *SandboxLifecycleManager\n\tinterval    time.Duration\n\tonceTimeout time.Duration\n\tstopCh      chan struct{}\n\twg          sync.WaitGroup\n\tlogger      Logger\n\tidleTimeout time.Duration\n}\n\nfunc NewGarbageCollector(manager *SandboxLifecycleManager, interval, onceTimeout time.Duration, logger Logger) *GarbageCollector {\n\tif interval == 0 {\n\t\tinterval = GarbageCollectorInterval\n\t}\n\tif onceTimeout == 0 {\n\t\tonceTimeout = 2 * time.Minute\n\t}\n\n\treturn &GarbageCollector{\n\t\tmanager:     manager,\n\t\tinterval:    interval,\n\t\tonceTimeout: onceTimeout,\n\t\tstopCh:      make(chan struct{}),\n\t\tlogger:      logger,\n\t\tidleTimeout: manager.config.DefaultIdleTimeout,\n\t}\n}\n\nfunc (gc *GarbageCollector) Start() {\n\tgc.wg.Add(1)\n\tgo gc.runLoop()\n}\n\nfunc (gc *GarbageCollector) Stop() {\n\tclose(gc.stopCh)\n\tgc.wg.Wait()\n}\n\nfunc (gc *GarbageCollector) runLoop() {\n\tdefer gc.wg.Done()\n\n\tticker := time.NewTicker(gc.interval)\n\tdefer ticker.Stop()\n\n\tgc.runOnce(context.Background())\n\n\tfor {\n\t\tselect {\n\t\tcase <-gc.stopCh:\n\t\t\tgc.logger.Info(\"garbage collector stopped\")\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tgc.runOnce(context.Background())\n\t\t}\n\t}\n}\n\nfunc (gc *GarbageCollector) runOnce(ctx context.Context) error {\n\tctx, cancel := context.WithTimeout(ctx, gc.onceTimeout)\n\tdefer cancel()\n\n\tnow := time.Now()\n\n\texpired, err := gc.manager.store.ListExpiredSandboxes(ctx, now, GCBatchSize)\n\tif err != nil {\n\t\tgc.logger.Error(\"failed to list expired sandboxes\", \"err\", err)\n\t\treturn err\n\t}\n\n\tinactiveBefore := now.Add(-gc.idleTimeout)\n\tinactive, err := gc.manager.store.ListInactiveSandboxes(ctx, inactiveBefore, GCBatchSize)\n\tif err != nil {\n\t\tgc.logger.Error(\"failed to list inactive sandboxes\", \"err\", err)\n\t\treturn err\n\t}\n\n\tallSandboxes := append(expired, inactive...)\n\n\tfor _, sb := range allSandboxes {\n\t\tif err := gc.manager.DeleteSandbox(ctx, sb.SessionID); err != nil {\n\t\t\tif _, ok := err.(*NotFoundError); ok {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tgc.logger.Error(\"gc delete failed\", \"sessionID\", sb.SessionID, \"err\", err)\n\t\t\tcontinue\n\t\t}\n\n\t\treason := determineDeletionReason(sb, now, gc.idleTimeout)\n\t\tgc.logger.Info(\"gc deleted sandbox\", \"sessionID\", sb.SessionID, \"sandboxName\", sb.SandboxName, \"reason\", reason)\n\t}\n\n\treturn nil\n}\n\nfunc (gc *GarbageCollector) SetIdleTimeout(timeout time.Duration) {\n\tgc.idleTimeout = timeout\n}\n\nfunc (gc *GarbageCollector) GetStats() GarbageCollectorStats {\n\treturn GarbageCollectorStats{\n\t\tInterval:    gc.interval,\n\t\tOnceTimeout: gc.onceTimeout,\n\t\tIdleTimeout: gc.idleTimeout,\n\t}\n}\n\ntype GarbageCollectorStats struct {\n\tInterval    time.Duration\n\tOnceTimeout time.Duration\n\tIdleTimeout time.Duration\n}\n","after":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n)\n\nconst GCBatchSize = 16\n\ntype GarbageCollector struct {\n\tmanager     *SandboxLifecycleManager\n\tinterval    time.Duration\n\tonceTimeout time.Duration\n\tstopCh      chan struct{}\n\twg          sync.WaitGroup\n\tlogger      Logger\n\tidleTimeout time.Duration\n\tidleMu      sync.RWMutex\n}\n\nfunc NewGarbageCollector(manager *SandboxLifecycleManager, interval, onceTimeout time.Duration, logger Logger) *GarbageCollector {\n\tif interval == 0 {\n\t\tinterval = GarbageCollectorInterval\n\t}\n\tif onceTimeout == 0 {\n\t\tonceTimeout = 2 * time.Minute\n\t}\n\n\treturn &GarbageCollector{\n\t\tmanager:     manager,\n\t\tinterval:    interval,\n\t\tonceTimeout: onceTimeout,\n\t\tstopCh:      make(chan struct{}),\n\t\tlogger:      logger,\n\t\tidleTimeout: manager.config.DefaultIdleTimeout,\n\t}\n}\n\nfunc (gc *GarbageCollector) Start() {\n\tgc.wg.Add(1)\n\tgo gc.runLoop()\n}\