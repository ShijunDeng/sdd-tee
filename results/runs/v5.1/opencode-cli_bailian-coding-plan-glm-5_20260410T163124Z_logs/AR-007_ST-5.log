rval)\n53: \tdefer ticker.Stop()\n54: \n55: \tgc.runOnce(context.Background())\n56: \n57: \tfor {\n58: \t\tselect {\n59: \t\tcase <-gc.stopCh:\n60: \t\t\tgc.logger.Info(\"garbage collector stopped\")\n61: \t\t\treturn\n62: \t\tcase <-ticker.C:\n63: \t\t\tgc.runOnce(context.Background())\n64: \t\t}\n65: \t}\n66: }\n67: \n68: func (gc *GarbageCollector) runOnce(ctx context.Context) error {\n69: \tctx, cancel := context.WithTimeout(ctx, gc.onceTimeout)\n70: \tdefer cancel()\n71: \n72: \tnow := time.Now()\n73: \n74: \texpired, err := gc.manager.store.ListExpiredSandboxes(ctx, now, GCBatchSize)\n75: \tif err != nil {\n76: \t\tgc.logger.Error(\"failed to list expired sandboxes\", \"err\", err)\n77: \t\treturn err\n78: \t}\n79: \n80: \tinactiveBefore := now.Add(-gc.idleTimeout)\n81: \tinactive, err := gc.manager.store.ListInactiveSandboxes(ctx, inactiveBefore, GCBatchSize)\n82: \tif err != nil {\n83: \t\tgc.logger.Error(\"failed to list inactive sandboxes\", \"err\", err)\n84: \t\treturn err\n85: \t}\n86: \n87: \tallSandboxes := append(expired, inactive...)\n88: \n89: \tfor _, sb := range allSandboxes {\n90: \t\tif err := gc.manager.DeleteSandbox(ctx, sb.SessionID); err != nil {\n91: \t\t\tif _, ok := err.(*NotFoundError); ok {\n92: \t\t\t\tcontinue\n93: \t\t\t}\n94: \t\t\tgc.logger.Error(\"gc delete failed\", \"sessionID\", sb.SessionID, \"err\", err)\n95: \t\t\tcontinue\n96: \t\t}\n97: \n98: \t\treason := determineDeletionReason(sb, now, gc.idleTimeout)\n99: \t\tgc.logger.Info(\"gc deleted sandbox\", \"sessionID\", sb.SessionID, \"sandboxName\", sb.SandboxName, \"reason\", reason)\n100: \t}\n101: \n102: \treturn nil\n103: }\n104: \n105: func (gc *GarbageCollector) SetIdleTimeout(timeout time.Duration) {\n106: \tgc.idleTimeout = timeout\n107: }\n108: \n109: func (gc *GarbageCollector) GetStats() GarbageCollectorStats {\n110: \treturn GarbageCollectorStats{\n111: \t\tInterval:    gc.interval,\n112: \t\tOnceTimeout: gc.onceTimeout,\n113: \t\tIdleTimeout: gc.idleTimeout,\n114: \t}\n115: }\n116: \n117: type GarbageCollectorStats struct {\n118: \tInterval    time.Duration\n119: \tOnceTimeout time.Duration\n120: \tIdleTimeout time.Duration\n121: }\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n)\n\nconst GCBatchSize = 16\n\ntype GarbageCollector struct {\n\tmanager     *SandboxLifecycleManager\n\tinterval    time.Duration\n\tonceTimeout time.Duration\n\tstopCh      chan struct{}\n\twg          sync.WaitGroup\n\tlogger      Logger\n\tidleTimeout time.Duration\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector.go","time":{"start":1775846988650,"end":1775846988688}}}}
{"type":"tool_use","timestamp":1775846988692,"sessionID":"ses_28746714affeWusB3L5wAdfYdz","part":{"id":"prt_d78ba9b48001IMIXeaw2h57w9I","messageID":"msg_d78ba7cba001g9Crp3IqDBc9sM","sessionID":"ses_28746714affeWusB3L5wAdfYdz","type":"tool","tool":"read","callID":"toolu_tool-dfbbf148a01d4a5589ca04029cbff57b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"sort\"\n6: \t\"sync\"\n7: \t\"time\"\n8: \n9: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n10: )\n11: \n12: var ErrSandboxNotFound = &NotFoundError{Resource: \"sandbox\", Name: \"\"}\n13: \n14: type MemoryStore struct {\n15: \tmu              sync.RWMutex\n16: \tsandboxes       map[string]*types.SandboxInfo\n17: \texpirationIndex map[string]time.Time\n18: }\n19: \n20: func NewMemoryStore() *MemoryStore {\n21: \treturn &MemoryStore{\n22: \t\tsandboxes:       make(map[string]*types.SandboxInfo),\n23: \t\texpirationIndex: make(map[string]time.Time),\n24: \t}\n25: }\n26: \n27: func (s *MemoryStore) StoreSandbox(_ context.Context, sandbox *types.SandboxInfo) error {\n28: \ts.mu.Lock()\n29: \tdefer s.mu.Unlock()\n30: \n31: \ts.sandboxes[sandbox.SessionID] = sandbox\n32: \ts.expirationIndex[sandbox.SandboxID] = sandbox.ExpiresAt\n33: \n34: \treturn nil\n35: }\n36: \n37: func (s *MemoryStore) GetSandboxBySessionID(_ context.Context, sessionID string) (*types.SandboxInfo, error) {\n38: \ts.mu.RLock()\n39: \tdefer s.mu.RUnlock()\n40: \n41: \tsandbox, exists := s.sandboxes[sessionID]\n42: \tif !exists {\n43: \t\treturn nil, &NotFoundError{Resource: \"sandbox\", Name: sessionID}\n44: \t}\n45: \n46: \treturn sandbox, nil\n47: }\n48: \n49: func (s *MemoryStore) UpdateSandbox(_ context.Context, sandbox *types.SandboxInfo) error {\n50: \ts.mu.Lock()\n51: \tdefer s.mu.Unlock()\n52: \n53: \tif _, exists := s.sandboxes[sandbox.SessionID]; !exists {\n54: \t\treturn &NotFoundError{Resource: \"sandbox\", Name: sandbox.SessionID}\n55: \t}\n56: \n57: \ts.sandboxes[sandbox.SessionID] = sandbox\n58: \ts.expirationIndex[sandbox.SandboxID] = sandbox.ExpiresAt\n59: \n60: \treturn nil\n61: }\n62: \n63: func (s *MemoryStore) DeleteSandboxBySessionID(_ context.Context, sessionID string) error {\n64: \ts.mu.Lock()\n65: \tdefer s.mu.Unlock()\n66: \n67: \tsandbox, exists := s.sandboxes[sessionID]\n68: \tif !exists {\n69: \t\treturn nil\n70: \t}\n71: \n72: \tdelete(s.sandboxes, sessionID)\n73: \tdelete(s.expirationIndex, sandbox.SandboxID)\n74: \n75: \treturn nil\n76: }\n77: \n78: func (s *MemoryStore) ListSandboxes(_ context.Context) ([]*types.SandboxInfo, error) {\n79: \ts.mu.RLock()\n80: \tdefer s.mu.RUnlock()\n81: \n82: \tresult := make([]*types.SandboxInfo, 0, len(s.sandboxes))\n83: \tfor _, sandbox := range s.sandboxes {\n84: \t\tresult = append(result, sandbox)\n85: \t}\n86: \n87: \treturn result, nil\n88: }\n89: \n90: func (s *MemoryStore) ListExpiredSandboxes(_ context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n91: \ts.mu.RLock()\n92: \tdefer s.mu.RUnlock()\n93: \n94: \tvar expired []*types.SandboxInfo\n95: \tfor _, sandbox := range s.sandboxes {\n96: \t\tif sandbox.ExpiresAt.Before(before) {\n97: \t\t\texpired = append(expired, sandbox)\n98: \t\t}\n99: \t}\n100: \n101: \tsort.Slice(expired, func(i, j int) bool {\n102: \t\treturn expired[i].ExpiresAt.Before(expired[j].ExpiresAt)\n103: \t})\n104: \n105: \tif limit > 0 && len(expired) > limit {\n106: \t\texpired = expired[:limit]\n107: \t}\n108: \n109: \treturn expired, nil\n110: }\n111: \n112: func (s *MemoryStore) ListInactiveSandboxes(_ context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n113: \ts.mu.RLock()\n114: \tdefer s.mu.RUnlock()\n115: \n116: \tvar inactive []*types.SandboxInfo\n117: \tfor _, sandbox := range s.sandboxes {\n118: \t\tif !sandbox.LastActivity.IsZero() && sandbox.LastActivity.Before(before) {\n119: \t\t\tinactive = append(inactive, sandbox)\n120: \t\t}\n121: \t}\n122: \n123: \tsort.Slice(inactive, func(i, j int) bool {\n124: \t\treturn inactive[i].LastActivity.Before(inactive[j].LastActivity)\n125: \t})\n126: \n127: \tif limit > 0 && len(inactive) > limit {\n128: \t\tinactive = inactive[:limit]\n129: \t}\n130: \n131: \treturn inactive, nil\n132: }\n133: \n134: func (s *MemoryStore) Clear() {\n135: \ts.mu.Lock()\n136: \tdefer s.mu.Unlock()\n137: \n138: \ts.sandboxes = make(map[string]*types.SandboxInfo)\n139: \ts.expirationIndex = make(map[string]time.Time)\n140: }\n141: \n142: func (s *MemoryStore) Size() int {\n143: \ts.mu.RLock()\n144: \tdefer s.mu.RUnlock()\n145: \n146: \treturn len(s.sandboxes)\n147: }\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sort\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nvar ErrSandboxNotFound = &NotFoundError{Resource: \"sandbox\", Name: \"\"}\n\ntype MemoryStore struct {\n\tmu              sync.RWMutex\n\tsandboxes       map[string]*types.SandboxInfo\n\texpirationIndex map[string]time.Time\n}\n\nfunc NewMemoryStore() *MemoryStore {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store.go","time":{"start":1775846988662,"end":1775846988690}}}}
