 args ...any) {}\n\nfunc TestDeletionHandler_Register(t *testing.T) {\n\thandler, _ := setupTestHandler()\n\n\tr := chi.NewRouter()\n\thandler.Register(r)\n\n\troutes := r.Routes()\n\tassert.Len(t, routes, 2)\n}\n\nfunc TestDeletionHandler_DeleteSuccess(t *testing.T) {\n\thandler, store := setupTestHandler()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tr := chi.NewRouter()\n\tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n\trec := httptest.NewRecorder()\n\n\tr.ServeHTTP(rec, req)\n\n\tassert.Equal(t, http.StatusOK, rec.Code)\n\n\tvar resp DeleteSandboxResponse\n\terr = json.NewDecoder(rec.Body).Decode(&resp)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"session-123\", resp.SessionID)\n\tassert.Equal(t, \"deleted\", resp.Status)\n\n\tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n}\n\nfunc TestDeletionHandler_DeleteNotFound(t *testing.T) {\n\thandler, _ := setupTestHandler()\n\n\tr := chi.NewRouter()\n\tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/non-existent\", nil)\n\trec := httptest.NewRecorder()\n\n\tr.ServeHTTP(rec, req)\n\n\tassert.Equal(t, http.StatusNotFound, rec.Code)\n\n\tvar resp DeleteSandboxResponse\n\terr := json.NewDecoder(rec.Body).Decode(&resp)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"non-existent\", resp.SessionID)\n\tassert.Equal(t, \"not_found\", resp.Status)\n}\n\nfunc TestDeletionHandler_DeleteMissingSessionID(t *testing.T) {\n\thandler, _ := setupTestHandler()\n\n\tr := chi.NewRouter()\n\tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\", nil)\n\trec := httptest.NewRecorder()\n\n\tr.ServeHTTP(rec, req)\n\n\tassert.Equal(t, http.StatusBadRequest, rec.Code)\n\n\tvar resp workloadmanager.ErrorResponse\n\terr := json.NewDecoder(rec.Body).Decode(&resp)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"VALIDATION_ERROR\", resp.Code)\n}\n\nfunc TestDeletionHandler_DeleteCodeInterpreter(t *testing.T) {\n\thandler, store := setupTestHandler()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tr := chi.NewRouter()\n\tr.Delete(\"/v1/code-interpreter/sessions/{sessionId}\", handler.handleDeleteCodeInterpreterSandbox)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/code-interpreter/sessions/session-123\", nil)\n\trec := httptest.NewRecorder()\n\n\tr.ServeHTTP(rec, req)\n\n\tassert.Equal(t, http.StatusOK, rec.Code)\n\n\tvar resp DeleteSandboxResponse\n\terr = json.NewDecoder(rec.Body).Decode(&resp)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"session-123\", resp.SessionID)\n\tassert.Equal(t, \"deleted\", resp.Status)\n}\n\nfunc TestDeletionHandler_ResponseFormat(t *testing.T) {\n\thandler, store := setupTestHandler()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tr := chi.NewRouter()\n\tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n\trec := httptest.NewRecorder()\n\n\tr.ServeHTTP(rec, req)\n\n\tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n\n\tvar resp map[string]interface{}\n\terr = json.Unmarshal(rec.Body.Bytes(), &resp)\n\trequire.NoError(t, err)\n\n\tassert.Contains(t, resp, \"sessionId\")\n\tassert.Contains(t, resp, \"status\")\n\tassert.Equal(t, \"session-123\", resp[\"sessionId\"])\n\tassert.Equal(t, \"deleted\", resp[\"status\"])\n}\n\nfunc TestDeleteSandboxRequest_JSON(t *testing.T) {\n\treq := DeleteSandboxRequest{\n\t\tSessionID:          \"session-123\",\n\t\tKind:               \"AgentRuntime\",\n\t\tForce:              true,\n\t\tGracePeriodSeconds: 30,\n\t}\n\n\tdata, err := json.Marshal(req)\n\trequire.NoError(t, err)\n\n\tvar unmarshaled DeleteSandboxRequest\n\terr = json.Unmarshal(data, &unmarshaled)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, req.SessionID, unmarshaled.SessionID)\n\tassert.Equal(t, req.Kind, unmarshaled.Kind)\n\tassert.Equal(t, req.Force, unmarshaled.Force)\n\tassert.Equal(t, req.GracePeriodSeconds, unmarshaled.GracePeriodSeconds)\n}\n\nfunc TestDeleteSandboxResponse_JSON(t *testing.T) {\n\tresp := DeleteSandboxResponse{\n\t\tSessionID: \"session-123\",\n\t\tStatus:    \"deleted\",\n\t\tMessage:   \"Sandbox deleted successfully\",\n\t}\n\n\tdata, err := json.Marshal(resp)\n\trequire.NoError(t, err)\n\n\tvar unmarshaled DeleteSandboxResponse\n\terr = json.Unmarshal(data, &unmarshaled)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, resp.SessionID, unmarshaled.SessionID)\n\tassert.Equal(t, resp.Status, unmarshaled.Status)\n\tassert.Equal(t, resp.Message, unmarshaled.Message)\n}\n","after":"package handlers\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-go/kubernetes\"\n\tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\nfunc NewTestInformerFactory(client kubernetes.Interface) informers.SharedInformerFactory {\n\treturn informers.NewSharedInformerFactoryWithOptions(client, time.Minute)\n}\n\nfunc setupTestHandler() (*DeletionHandler, *workloadmanager.MemoryStore) {\n\tfakeClient := k8sfake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &workloadmanager.K8sClient{}\n\tk8sClient.SetClients(dynamicClient, fakeClient, informerFactory)\n\n\tstore := workloadmanager.NewMemoryStore()\n\tlogger := &testLogger{}\n\tconfig := workloadmanager.DefaultLifecycleConfig()\n\n\tmanager := workloadmanager.NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\treturn NewDeletionHandler(manager, logger), store\n}\n\ntype testLogger struct{}\n\nfunc (l *testLogger) Info(msg string, args ...any)  {}\nfunc (l *testLogger) Error(msg string, args ...any) {}\n\nfunc TestDeletionHandler_Register(t *testing.T) {\n\thandler, _ := setupTestHandler()\n\n\tr := chi.NewRouter()\n\thandler.Register(r)\n\n\troutes := r.Routes()\n\tassert.Len(t, routes, 2)\n}\n\nfunc TestDeletionHandler_DeleteSuccess(t *testing.T) {\n\thandler, store := setupTestHandler()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tr := chi.NewRouter()\n\tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n\trec := httptest.NewRecorder()\n\n\tr.ServeHTTP(rec, req)\n\n\tassert.Equal(t, http.StatusOK, rec.Code)\n\n\tvar resp DeleteSandboxResponse\n\terr = json.NewDecoder(rec.Body).Decode(&resp)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"session-123\", resp.SessionID)\n\tassert.Equal(t, \"deleted\", resp.Status)\n\n\tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n}\n\nfunc TestDeletionHandler_DeleteNotFound(t *testing.T) {\n\thandler, _ := setupTestHandler()\n\n\tr := chi.NewRouter()\n\tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/non-existent\", nil)\n\trec := httptest.NewRecorder()\n\n\tr.ServeHTTP(rec, req)\n\n\tassert.Equal(t, http.StatusNotFound, rec.Code)\n\n\tvar resp DeleteSandboxResponse\n\terr := json.NewDecoder(rec.Body).Decode(&resp)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"non-existent\", resp.SessionID)\n\tassert.Equal(t, \"not_found\", resp.Status)\n}\n\nfunc TestDeletionHandler_DeleteMissingSessionID(t *testing.T) {\n\thandler, _ := setupTestHandler()\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\", nil)\n\trec := httptest.NewRecorder()\n\n\thandler.handleDeleteSandbox(rec, req, \"\", workloadmanager.AgentRuntimeKind)\n\n\tassert.Equal(t, http.StatusBadRequest, rec.Code)\n\n\tvar resp workloadmanager.ErrorResponse\n\terr := json.NewDecoder(rec.Body).Decode(&resp)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"VALIDATION_ERROR\", resp.Code)\n}\n\nfunc TestDeletionHandler_DeleteCodeInterpreter(t *testing.T) {\n\thandler, store := setupTestHandler()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tr := chi.NewRouter()\n\tr.Delete(\"/v1/code-interpreter/sessions/{sessionId}\", handler.handleDeleteCodeInterpreterSandbox)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/code-interpreter/sessions/session-123\", nil)\n\trec := httptest.NewRecorder()\n\n\tr.ServeHTTP(rec, req)\n\n\tassert.Equal(t, http.StatusOK, rec.Code)\n\n\tvar resp DeleteSandboxResponse\n\terr = json.NewDecoder(rec.Body).Decode(&resp)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"session-123\", resp.SessionID)\n\tassert.Equal(t, \"deleted\", resp.Status)\n}\n\nfunc TestDeletionHandler_ResponseFormat(t *testing.T) {\n\thandler, store := setupTestHandler()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tr := chi.NewRouter()\n\tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n\trec := httptest.NewRecorder()\n\n\tr.ServeHTTP(rec, req)\n\n\tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n\n\tvar resp map[string]interface{}\n\terr = json.Unmarshal(rec.Body.Bytes(), &resp)\n\trequire.NoError(t, err)\n\n\tassert.Contains(t, resp, \"sessionId\")\n\tassert.Contains(t, resp, \"status\")\n\tassert.Equal(t, \"session-123\", resp[\"sessionId\"])\n\tassert.Equal(t, \"deleted\", resp[\"status\"])\n}\n\nfunc TestDeleteSandboxRequest_JSON(t *testing.T) {\n\treq := DeleteSandboxRequest{\n\t\tSessionID:          \"session-123\",\n\t\tKind:               \"AgentRuntime\",\n\t\tForce:              true,\n\t\tGracePeriodSeconds: 30,\n\t}\n\n\tdata, err := json.Marshal(req)\n\trequire.NoError(t, err)\n\n\tvar unmarshaled DeleteSandboxRequest\n\terr = json.Unmarshal(data, &unmarshaled)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, req.SessionID, unmarshaled.SessionID)\n\tassert.Equal(t, req.Kind, unmarshaled.Kind)\n\tassert.Equal(t, req.Force, unmarshaled.Force)\n\tassert.Equal(t, req.GracePeriodSeconds, unmarshaled.GracePeriodSeconds)\n}\n\nfunc TestDeleteSandboxResponse_JSON(t *testing.T) {\n\tresp := DeleteSandboxResponse{\n\t\tSessionID: \"session-123\",\n\t\tStatus:    \"deleted\",\n\t\tMessage:   \"Sandbox deleted successfully\",\n\t}\n\n\tdata, err := json.Marshal(resp)\n\trequire.NoError(t, err)\n\n\tvar unmarshaled DeleteSandboxResponse\n\terr = json.Unmarshal(data, &unmarshaled)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, resp.SessionID, unmarshaled.SessionID)\n\tassert.Equal(t, resp.Status, unmarshaled.Status)\n\tassert.Equal(t, resp.Message, unmarshaled.Message)\n}\n","additions":1,"deletions":4},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go","time":{"start":17758470388