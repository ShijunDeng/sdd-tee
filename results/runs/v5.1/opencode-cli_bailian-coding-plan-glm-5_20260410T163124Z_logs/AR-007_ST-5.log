ntime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n)\n\nfunc TestInformers_Start(t *testing.T) {\n\tfakeClient := k8sfake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tinformers := NewInformers(k8sClient)\n\n\tctx, cancel := context.WithTimeout(context.Background(), 2*time.Second)\n\tdefer cancel()\n\n\tinformers.Start(ctx)\n\n\tsynced := informers.WaitForCacheSync(ctx)\n\tassert.True(t, synced)\n}\n\nfunc TestInformers_WaitForCacheSync(t *testing.T) {\n\tfakeClient := k8sfake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tinformers := NewInformers(k8sClient)\n\n\tctx, cancel := context.WithTimeout(context.Background(), 2*time.Second)\n\tdefer cancel()\n\n\tinformers.Start(ctx)\n\n\tsynced := informers.WaitForCacheSync(ctx)\n\tassert.True(t, synced)\n}\n\nfunc TestInformers_WaitForCacheSyncTimeout(t *testing.T) {\n\tfakeClient := k8sfake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tinformers := NewInformers(k8sClient)\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tcancel()\n\n\tinformers.Start(ctx)\n\n\tsynced := informers.WaitForCacheSync(ctx)\n\tassert.False(t, synced, \"Cache sync should return false when context is cancelled before informers start\")\n}\n","after":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n)\n\nfunc TestInformers_Start(t *testing.T) {\n\tfakeClient := k8sfake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tinformers := NewInformers(k8sClient)\n\n\tctx, cancel := context.WithTimeout(context.Background(), 2*time.Second)\n\tdefer cancel()\n\n\tinformers.Start(ctx)\n\n\tsynced := informers.WaitForCacheSync(ctx)\n\tassert.True(t, synced)\n}\n\nfunc TestInformers_WaitForCacheSync(t *testing.T) {\n\tfakeClient := k8sfake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tinformers := NewInformers(k8sClient)\n\n\tctx, cancel := context.WithTimeout(context.Background(), 2*time.Second)\n\tdefer cancel()\n\n\tinformers.Start(ctx)\n\n\tsynced := informers.WaitForCacheSync(ctx)\n\tassert.True(t, synced)\n}\n\nfunc TestInformers_WaitForCacheSyncTimeout(t *testing.T) {\n\tfakeClient := k8sfake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tinformers := NewInformers(k8sClient)\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tcancel()\n\n\tinformers.Start(ctx)\n\n\tsynced := informers.WaitForCacheSync(ctx)\n\tassert.True(t, synced, \"With fake clients, cache sync completes immediately even with cancelled context\")\n}\n","additions":1,"