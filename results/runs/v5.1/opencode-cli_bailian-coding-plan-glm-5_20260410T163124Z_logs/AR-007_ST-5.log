veHTTP(ww, r)\n39: \n40: \t\tm.logger.Info(\"request\",\n41: \t\t\t\"method\", r.Method,\n42: \t\t\t\"path\", r.URL.Path,\n43: \t\t\t\"status\", ww.status,\n44: \t\t\t\"duration\", time.Since(start),\n45: \t\t)\n46: \t})\n47: }\n\n(End of file - total 47 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\n// responseWriterWrapper wraps http.ResponseWriter to capture the status code.\ntype responseWriterWrapper struct {\n\thttp.ResponseWriter\n\tstatus int\n}\n\n// WriteHeader captures the status code before calling the embedded WriteHeader.\nfunc (w *responseWriterWrapper) WriteHeader(code int) {\n\tw.status = code\n\tw.ResponseWriter.WriteHeader(code)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/logging.go","time":{"start":1775847004964,"end":1775847004996}}}}
{"type":"tool_use","timestamp":1775847005000,"sessionID":"ses_28746714affeWusB3L5wAdfYdz","part":{"id":"prt_d78badafd001XAtvbH3d9hmhDA","messageID":"msg_d78ba9beb001T4Q6ZnYNATQqYH","sessionID":"ses_28746714affeWusB3L5wAdfYdz","type":"tool","tool":"read","callID":"toolu_tool-8a11c3c2cc834a9b93501694c375393a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"strings\"\n6: )\n7: \n8: // CORSConfig defines the CORS policy configuration.\n9: type CORSConfig struct {\n10: \tAllowedOrigins   []string\n11: \tAllowedMethods   []string\n12: \tAllowedHeaders   []string\n13: \tAllowCredentials bool\n14: }\n15: \n16: // CORSMiddleware handles Cross-Origin Resource Sharing headers.\n17: type CORSMiddleware struct {\n18: \tconfig CORSConfig\n19: }\n20: \n21: // NewCORSMiddleware creates a CORSMiddleware with the given configuration.\n22: func NewCORSMiddleware(config CORSConfig) *CORSMiddleware {\n23: \treturn &CORSMiddleware{config: config}\n24: }\n25: \n26: // Wrap returns an http.Handler that adds CORS headers to responses.\n27: func (m *CORSMiddleware) Wrap(next http.Handler) http.Handler {\n28: \treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n29: \t\torigin := r.Header.Get(\"Origin\")\n30: \t\tif origin != \"\" && m.isAllowedOrigin(origin) {\n31: \t\t\tw.Header().Set(\"Access-Control-Allow-Origin\", origin)\n32: \t\t\tw.Header().Set(\"Access-Control-Allow-Methods\", strings.Join(m.config.AllowedMethods, \",\"))\n33: \t\t\tw.Header().Set(\"Access-Control-Allow-Headers\", strings.Join(m.config.AllowedHeaders, \",\"))\n34: \t\t\tif m.config.AllowCredentials {\n35: \t\t\t\tw.Header().Set(\"Access-Control-Allow-Credentials\", \"true\")\n36: \t\t\t}\n37: \t\t}\n38: \n39: \t\tif r.Method == \"OPTIONS\" {\n40: \t\t\tw.WriteHeader(http.StatusOK)\n41: \t\t\treturn\n42: \t\t}\n43: \n44: \t\tnext.ServeHTTP(w, r)\n45: \t})\n46: }\n47: \n48: func (m *CORSMiddleware) isAllowedOrigin(origin string) bool {\n49: \tfor _, o := range m.config.AllowedOrigins {\n50: \t\tif o == \"*\" || o == origin {\n51: \t\t\treturn true\n52: \t\t}\n53: \t}\n54: \treturn false\n55: }\n\n(End of file - total 55 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"strings\"\n)\n\n// CORSConfig defines the CORS policy configuration.\ntype CORSConfig struct {\n\tAllowedOrigins   []string\n\tAllowedMethods   []string\n\tAllowedHeaders   []string\n\tAllowCredentials bool\n}\n\n// CORSMiddleware handles Cross-Origin Resource Sharing headers.\ntype CORSMiddleware struct {\n\tconfig CORSConfig\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors.go","time":{"start":1775847004966,"end":1775847004998}}}}
