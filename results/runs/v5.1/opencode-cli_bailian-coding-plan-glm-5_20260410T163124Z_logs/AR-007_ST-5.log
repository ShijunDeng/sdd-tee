retchr/testify/assert\"\n@@ -17,17 +18,22 @@\n \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n )\n \n type mockLogger struct {\n+\tmu         sync.Mutex\n \tinfoCalls  []string\n \terrorCalls []string\n }\n \n func (l *mockLogger) Info(msg string, args ...any) {\n+\tl.mu.Lock()\n+\tdefer l.mu.Unlock()\n \tl.infoCalls = append(l.infoCalls, msg)\n }\n \n func (l *mockLogger) Error(msg string, args ...any) {\n+\tl.mu.Lock()\n+\tdefer l.mu.Unlock()\n \tl.errorCalls = append(l.errorCalls, msg)\n }\n \n func TestDefaultLifecycleConfig(t *testing.T) {\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle_test.go","before":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype mockLogger struct {\n\tinfoCalls  []string\n\terrorCalls []string\n}\n\nfunc (l *mockLogger) Info(msg string, args ...any) {\n\tl.infoCalls = append(l.infoCalls, msg)\n}\n\nfunc (l *mockLogger) Error(msg string, args ...any) {\n\tl.errorCalls = append(l.errorCalls, msg)\n}\n\nfunc TestDefaultLifecycleConfig(t *testing.T) {\n\tconfig := DefaultLifecycleConfig()\n\n\tassert.Equal(t, DefaultSandboxTTL, config.DefaultTTL)\n\tassert.Equal(t, DefaultSandboxIdleTimeout, config.DefaultIdleTimeout)\n\tassert.Equal(t, DefaultMaxSessionDuration, config.DefaultMaxDuration)\n\tassert.Equal(t, GarbageCollectorInterval, config.GCInterval)\n\tassert.Equal(t, 2*time.Minute, config.GCOnceTimeout)\n\tassert.Equal(t, int64(0), config.DeletionGracePeriod)\n\tassert.Equal(t, SandboxDeleteTimeout, config.DeletionTimeout)\n}\n\nfunc TestNewSandboxLifecycleManager(t *testing.T) {\n\tfakeClient := fake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\tassert.NotNil(t, manager)\n\tassert.Equal(t, k8sClient, manager.k8sClient)\n\tassert.Equal(t, store, manager.store)\n\tassert.Equal(t, config, manager.config)\n}\n\nfunc TestSandboxLifecycleManager_DeleteSandbox_Success(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr = manager.DeleteSandbox(context.Background(), \"session-123\")\n\tassert.NoError(t, err)\n\n\t_, err = store.GetSandboxBySessionID(context.Background(), \"session-123\")\n\tassert.Error(t, err)\n\tassert.IsType(t, &NotFoundError{}, err)\n}\n\nfunc TestSandboxLifecycleManager_DeleteSandbox_NotFound(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr := manager.DeleteSandbox(context.Background(), \"non-existent\")\n\tassert.Error(t, err)\n\tassert.IsType(t, &NotFoundError{}, err)\n}\n\nfunc TestSandboxLifecycleManager_DeleteSandbox_SandboxClaim(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxClaimKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr = manager.DeleteSandbox(context.Background(), \"session-123\")\n\tassert.NoError(t, err)\n}\n\nfunc TestSandboxLifecycleManager_IsExpired(t *testing.T) {\n\tmanager := &SandboxLifecycleManager{}\n\n\tnow := time.Now()\n\n\texpiredSandbox := &types.SandboxInfo{\n\t\tExpiresAt: now.Add(-1 * time.Hour),\n\t}\n\tassert.True(t, manager.IsExpired(expiredSandbox))\n\n\tactiveSandbox := &types.SandboxInfo{\n\t\tExpiresAt: now.Add(8 * time.Hour),\n\t}\n\tassert.False(t, manager.IsExpired(activeSandbox))\n}\n\nfunc TestSandboxLifecycleManager_IsIdleExpired(t *testing.T) {\n\tmanager := &SandboxLifecycleManager{}\n\tidleTimeout := 15 * time.Minute\n\n\tnow := time.Now()\n\n\tnoActivitySandbox := &types.SandboxInfo{}\n\tassert.False(t, manager.IsIdleExpired(noActivitySandbox, idleTimeout))\n\n\trecentActivitySandbox := &types.SandboxInfo{\n\t\tLastActivity: now,\n\t}\n\tassert.False(t, manager.IsIdleExpired(recentActivitySandbox, idleTimeout))\n\n\toldActivitySandbox := &types.SandboxInfo{\n\t\tLastActivity: now.Add(-30 * time.Minute),\n\t}\n\tassert.True(t, manager.IsIdleExpired(oldActivitySandbox, idleTimeout))\n}\n\nfunc TestSandboxLifecycleManager_ForceDeleteSandbox(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr = manager.ForceDeleteSandbox(context.Background(), \"session-123\")\n\tassert.NoError(t, err)\n\n\t_, err = store.GetSandboxBySessionID(context.Background(), \"session-123\")\n\tassert.Error(t, err)\n}\n\nfunc TestSandboxLifecycleManager_ForceDeleteSandbox_NotFound(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr := manager.ForceDeleteSandbox(context.Background(), \"non-existent\")\n\tassert.NoError(t, err)\n}\n\nfunc TestSandboxLifecycleManager_GetSandbox(t *testing.T) {\n\tstore := NewMemoryStore()\n\tmanager := &SandboxLifecycleManager{store: store}\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tSessionID: \"session-123\",\n\t\tExpiresAt: now.Add(8 * time.Hour),\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tretrieved, err := manager.GetSandbox(context.Background(), \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"session-123\", retrieved.SessionID)\n\n\t_, err = manager.GetSandbox(context.Background(), \"non-existent\")\n\tassert.Error(t, err)\n}\n\nfunc TestSandboxLifecycleManager_UpdateSandboxStatus(t *testing.T) {\n\tstore := NewMemoryStore()\n\tmanager := &SandboxLifecycleManager{store: store}\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tSessionID: \"session-123\",\n\t\tExpiresAt: now.Add(8 * time.Hour),\n\t\tStatus:    \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\terr = manager.UpdateSandboxStatus(context.Background(), \"session-123\", \"terminating\")\n\trequire.NoError(t, err)\n\n\tretrieved, err := store.GetSandboxBySessionID(context.Background(), \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"terminating\", retrieved.Status)\n}\n\nfunc TestHandleDeleteError(t *testing.T) {\n\tnotFoundErr := apierrors.NewNotFound(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, \"test\")\n\tresult := handleDeleteError(notFoundErr)\n\tassert.Nil(t, result)\n\n\tconflictErr := apierrors.NewConflict(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, \"test\", errors.New(\"conflict\"))\n\tresult = handleDeleteError(conflictErr)\n\tassert.IsType(t, &ConflictError{}, result)\n\n\tinternalErr := errors.New(\"internal error\")\n\tresult = handleDeleteError(internalErr)\n\tassert.IsType(t, &InternalError{}, result)\n}\n\nfunc TestDetermineDeletionReason(t *testing.T) {\n\tnow := time.Now()\n\tidleTimeout := 15 * time.Minute\n\n\texpiredSandbox := &types.SandboxInfo{\n\t\tExpiresAt: now.Add(-1 * time.Hour),\n\t}\n\treason := determineDeletionReason(expiredSandbox, now, idleTimeout)\n\tassert.Equal(t, DeletionReasonMaxDurationReached, reason)\n\n\tidleSandbox := &types.SandboxInfo{\n\t\tExpiresAt:    now.Add(8 * time.Hour),\n\t\tLastActivity: now.Add(-30 * time.Minute),\n\t}\n\treason = determineDeletionReason(idleSandbox, now, idleTimeout)\n\tassert.Equal(t, DeletionReasonIdleTimeout, reason)\n\n\tactiveSandbox := &types.SandboxInfo{\n\t\tExpiresAt:    now.Add(8 * time.Hour),\n\t\tLastActivity: now,\n\t}\n\treason = determineDeletionReason(activeSandbox, now, idleTimeout)\n\tassert.Equal(t, DeletionReasonUserRequest, reason)\n}\n","after":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype mockLogger struct {\n\tmu         sync.Mutex\n\tinfoCalls  []string\n\terrorCalls []string\n}\n\nfunc (l *mockLogger) Info(msg string, args ...any) {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tl.infoCalls = append(l.infoCalls, msg)\n}\n\nfunc (l *mockLogger) Error(msg string, args ...any) {\n\tl.mu.Lock()\n\tdefer l.mu.Unlock()\n\tl.errorCalls = append(l.errorCalls, msg)\n}\n\nfunc TestDefaultLifecycleConfig(t *testing.T) {\n\tconfig := DefaultLifecycleConfig()\n\n\tassert.Equal(t, DefaultSandboxTTL, config.DefaultTTL)\n\tassert.Equal(t, DefaultSandboxIdleTimeout, config.DefaultIdleTimeout)\n\tassert.Equal(t, DefaultMaxSessionDuration, config.DefaultMaxDuration)\n\tassert.Equal(t, GarbageCollectorInterval, config.GCInterval)\n\tassert.Equal(t, 2*time.Minute, config.GCOnceTimeout)\n\tassert.Equal(t, int64(0), config.DeletionGracePeriod)\n\tassert.Equal(t, SandboxDeleteTimeout, config.DeletionTimeout)\n}\n\nfunc TestNewSandboxLifecycleManager(t *testing.T) {\n\tfakeClient := fake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\tassert.NotNil(t, manager)\n\tassert.Equal(t, k8sClient, manager.k8sClient)\n\tassert.Equal(t, store, manager.store)\n\tassert.Equal(t, config, manager.config)\n}\n\nfunc TestSandboxLifecycleManager_DeleteSandbox_Success(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr = manager.DeleteSandbox(context.Background(), \"session-123\")\n\tassert.NoError(t, err)\n\n\t_, err = store.GetSandboxBySessionID(context.Background(), \"session-123\")\n\tassert.Error(t, err)\n\tassert.IsType(t, &NotFoundError{}, err)\n}\n\nfunc TestSandboxLifecycleManager_DeleteSandbox_NotFound(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr := manager.DeleteSandbox(context.Background(), \"non-existent\")\n\tassert.Error(t, err)\n\tassert.IsType(t, &NotFoundError{}, err)\n}\n\nfunc TestSandboxLifecycleManager_DeleteSandbox_SandboxClaim(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxClaimKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr = manager.DeleteSandbox(context.Background(), \"session-123\")\n\tassert.NoError(t, err)\n}\n\nfunc TestSandboxLifecycleManager_IsExpired(t *testing.T) {\n\tmanager := &SandboxLifecycleManager{}\n\n\tnow := time.Now()\n\n\texpiredSandbox := &types.SandboxInfo{\n\t\tExpiresAt: now.Add(-1 * time.Hour),\n\t}\n\tassert.True(t, manager.IsExpired(expiredSandbox))\n\n\tactiveSandbox := &types.SandboxInfo{\n\t\tExpiresAt: now.Add(8 * time.Hour),\n\t}\n\tassert.False(t, manager.IsExpired(activeSandbox))\n}\n\nfunc TestSandboxLifecycleManager_IsIdleExpired(t *testing.T) {\n\tmanager := &SandboxLifecycleManager{}\n\tidleTimeout := 15 * time.Minute\n\n\tnow := time.Now()\n\n\tnoActivitySandbox := &types.SandboxInfo{}\n\tassert.False(t, manager.IsIdleExpired(noActivitySandbox, idleTimeout))\n\n\trecentActivitySandbox := &types.SandboxInfo{\n\t\tLastActivity: now,\n\t}\n\tassert.False(t, manager.IsIdleExpired(recentActivitySandbox, idleTimeout))\n\n\toldActivitySandbox := &types.SandboxInfo{\n\t\tLastActivity: now.Add(-30 * time.Minute),\n\t}\n\tassert.True(t, manager.IsIdleExpired(oldActivitySandbox, idleTimeout))\n}\n\nfunc TestSandboxLifecycleManager_ForceDeleteSandbox(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind:             types.SandboxKind,\n\t\tSandboxID:        \"sandbox-123\",\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"sandbox-123\",\n\t\tSessionID:        \"session-123\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr = manager.ForceDeleteSandbox(context.Background(), \"session-123\")\n\tassert.NoError(t, err)\n\n\t_, err = store.GetSandboxBySessionID(context.Background(), \"session-123\")\n\tassert.Error(t, err)\n}\n\nfunc TestSandboxLifecycleManager_ForceDeleteSandbox_NotFound(t *testing.T) {\n\tscheme := runtime.NewScheme()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n\tfakeClient := fake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tdynamicClient:   dynamicClient,\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,\n\t}\n\n\tstore := NewMemoryStore()\n\tlogger := &mockLogger{}\n\tconfig := DefaultLifecycleConfig()\n\n\tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n\n\terr := manager.ForceDeleteSandbox(context.Background(), \"non-existent\")\n\tassert.NoError(t, err)\n}\n\nfunc TestSandboxLifecycleManager_GetSandbox(t *testing.T) {\n\tstore := NewMemoryStore()\n\tmanager := &SandboxLifecycleManager{store: store}\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tSessionID: \"session-123\",\n\t\tExpiresAt: now.Add(8 * time.Hour),\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\tretrieved, err := manager.GetSandbox(context.Background(), \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"session-123\", retrieved.SessionID)\n\n\t_, err = manager.GetSandbox(context.Background(), \"non-existent\")\n\tassert.Error(t, err)\n}\n\nfunc TestSandboxLifecycleManager_UpdateSandboxStatus(t *testing.T) {\n\tstore := NewMemoryStore()\n\tmanager := &SandboxLifecycleManager{store: store}\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tSessionID: \"session-123\",\n\t\tExpiresAt: now.Add(8 * time.Hour),\n\t\tStatus:    \"running\",\n\t}\n\n\terr := store.StoreSandbox(context.Background(), sandbox)\n\trequire.NoError(t, err)\n\n\terr = manager.UpdateSandboxStatus(context.Background(), \"session-123\", \"terminating\")\n\trequire.NoError(t, err)\n\n\tretrieved, err := store.GetSandboxBySessionID(context.Background(), \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"terminating\", retrieved.Status)\n}\n\nfunc TestHandleDeleteError(t *testing.T) {\n\tnotFoundErr := apierrors.NewNotFound(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, \"test\")\n\tresult := handleDeleteError(notFoundErr)\n\tassert.Nil(t, result)\n\n\tconflictErr := apierrors.NewConflict(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, \"test\", errors.New(\"conflict\"))\n\tresult = handleDeleteError(conflictErr)\n\tassert.IsType(t, &ConflictError{}, result)\n\n\tinternalErr := errors.New(\"internal error\")\n\tresult = handleDeleteError(internalErr)\n\tassert.IsType(t, &InternalError{}, result)\n}\n\nfunc TestDetermineDeletionReason(t *testing.T) {\n\tnow := time.Now()\n\tidleTimeout := 15 * time.Minute\n\n\texpiredSandbox := &types.SandboxInfo{\n\t\tExpiresAt: now.Add(-1 * time.Hour),\n\t}\n\treason := determineDeletionReason(expiredSandbox, now, idleTimeout)\n\tassert.Equal(t, DeletionReasonMaxDurationReached, reason)\n\n\tidleSandbox := &types.SandboxInfo{\n\t\tExpiresAt:    now.Add(8 * time.Hour),\n\t\tLastActivity: now.Add(-30 * time.Minute),\n\t}\n\treason = determineDeletionReason(idleSandbox, now, idleTimeout)\n\tassert.Equal(t, DeletionReasonIdleTimeout, reason)\n\n\tactiveSandbox := &types.SandboxInfo{\n\t\tExpiresAt:    now.Add(8 * time.Hour),\n\t\tLastActivity: now,\n\t}\n\treason = determineDeletionReason(activeSandbox, now, idleTimeout)\n\tassert.Equal(t, DeletionReasonUserRequest, reason)\n}\n","additions":6,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle_test.go","time":{"start":1775847201818,"end":1775847202423}}}}
