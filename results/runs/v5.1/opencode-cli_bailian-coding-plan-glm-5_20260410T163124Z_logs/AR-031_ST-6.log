, \"- watch\")\n278: }\n279: \n280: func TestWorkloadManagerSecretFullAccess(t *testing.T) {\n281: \toutput := runHelmTemplate(t, map[string]string{})\n282: \n283: \tassert.Contains(t, output, \"- secrets\")\n284: \tassert.Contains(t, output, \"- get\")\n285: \tassert.Contains(t, output, \"- list\")\n286: \tassert.Contains(t, output, \"- watch\")\n287: \tassert.Contains(t, output, \"- create\")\n288: \tassert.Contains(t, output, \"- update\")\n289: \tassert.Contains(t, output, \"- patch\")\n290: \tassert.Contains(t, output, \"- delete\")\n291: }\n292: \n293: func TestHelmLint(t *testing.T) {\n294: \tcmd := exec.Command(\"helm\", \"lint\", \"charts/base\")\n295: \tcmd.Dir = manifestsDir\n296: \tvar stdout, stderr bytes.Buffer\n297: \tcmd.Stdout = &stdout\n298: \tcmd.Stderr = &stderr\n299: \terr := cmd.Run()\n300: \trequire.NoError(t, err, \"helm lint failed: %s\", stderr.String())\n301: }\n\n(End of file - total 301 lines)\n</content>","metadata":{"preview":"package tests\n\nimport (\n\t\"bytes\"\n\t\"os/exec\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nconst manifestsDir = \"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests\"\n\nfunc runHelmTemplate(t *testing.T, values map[string]string) string {\n\targs := []string{\"template\", \"test\", \"charts/base\", \"--set\", \"redis.addr=localhost:6379\"}\n\tfor k, v := range values {\n\t\targs = append(args, \"--set\", k+\"=\"+v)\n\t}\n\tcmd := exec.Command(\"helm\", args...)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests/tests/rbac_test.go","time":{"start":1775885769016,"end":1775885769033}}}}
