{"type":"tool_use","timestamp":1775872459937,"sessionID":"ses_285c15d52ffepfa12E8jzO5MFc","part":{"id":"prt_d7a3f4469001HsdOTQvZSavd47","messageID":"msg_d7a3f27f6001R9L1MplCpmk7AD","sessionID":"ses_285c15d52ffepfa12E8jzO5MFc","type":"tool","tool":"read","callID":"toolu_tool-598822caff30427ab271a63e54b11bd8","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/publish_runtime.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/publish_runtime.py</path>\n<type>file</type>\n<content>\n1: import logging\n2: import time\n3: from pathlib import Path\n4: from typing import Any, Dict, Optional\n5: \n6: from agentcube.services.metadata_service import AgentMetadata, MetadataService\n7: from agentcube.services.docker_service import DockerService\n8: \n9: \n10: class PublishRuntime:\n11:     def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n12:         self.verbose = verbose\n13:         self.provider = provider\n14:         self._metadata_service = MetadataService(verbose)\n15:         self._docker_service = DockerService(verbose)\n16:         self._logger = logging.getLogger(__name__)\n17: \n18:         if provider == \"k8s\":\n19:             from agentcube.services.k8s_provider import KubernetesProvider\n20:             self._k8s_provider = KubernetesProvider(verbose=verbose)\n21:         elif provider == \"agentcube\":\n22:             from agentcube.services.agentcube_provider import AgentCubeProvider\n23:             self._agentcube_provider = AgentCubeProvider(verbose=verbose)\n24:         else:\n25:             raise ValueError(f\"Invalid provider: {provider}. Must be 'agentcube' or 'k8s'\")\n26: \n27:     def publish(self, workspace_path: Path, **options: Any) -> Dict[str, Any]:\n28:         metadata = self._metadata_service.load_metadata(workspace_path)\n29:         metadata = self._apply_option_overrides(metadata, options)\n30:         self._validate_publish_prerequisites(workspace_path, metadata, options)\n31:         \n32:         try:\n33:             image_url = self._prepare_image_for_publishing(workspace_path, metadata, options)\n34:             \n35:             if self.provider == \"agentcube\":\n36:                 result = self._publish_cr_to_k8s(workspace_path, metadata, image_url, options)\n37:             else:\n38:                 result = self._publish_k8s(workspace_path, metadata, image_url, options)\n39:             \n40:             self._update_publish_metadata(workspace_path, metadata, result)\n41:             \n42:             return {\n43:                 \"agent_name\": metadata.agent_name,\n44:                 \"agent_id\": result.get(\"agent_id\"),\n45:                 \"agent_endpoint\": result.get(\"agent_endpoint\"),\n46:                 \"deployment_type\": result.get(\"deployment_type\"),\n47:                 \"namespace\": result.get(\"namespace\"),\n48:                 \"k8s_deployment\": result.get(\"k8s_deployment\"),\n49:                 \"status\": \"success\",\n50:             }\n51:         except Exception as e:\n52:             self._record_error_in_metadata(workspace_path, str(e))\n53:             raise\n54: \n55:     def _apply_option_overrides(\n56:         self, metadata: AgentMetadata, options: Dict[str, Any]\n57:     ) -> AgentMetadata:\n58:         if options.get(\"version\"):\n59:             metadata.version = options[\"version\"]\n60:         if options.get(\"image_url\"):\n61:             if not metadata.image:\n62:                 metadata.image = {}\n63:             metadata.image[\"url\"] = options[\"image_url\"]\n64:         if options.get(\"image_username\"):\n65:             metadata.registry_username = options[\"image_username\"]\n66:         if options.get(\"image_password\"):\n67:             metadata.registry_password = options[\"image_password\"]\n68:         if options.get(\"description\"):\n69:             metadata.description = options[\"description\"]\n70:         if options.get(\"region\"):\n71:             metadata.region = options[\"region\"]\n72:         if options.get(\"namespace\"):\n73:             pass\n74:         return metadata\n75: \n76:     def _validate_publish_prerequisites(\n77:         self, workspace_path: Path, metadata: AgentMetadata, options: Dict[str, Any]\n78:     ) -> None:\n79:         if self.provider == \"agentcube\":\n80:             if not metadata.router_url and not options.get(\"router_url\"):\n81:                 raise ValueError(\"router_url is required for agentcube provider in agent_metadata.yaml\")\n82:             if not metadata.workload_manager_url and not options.get(\"workload_manager_url\"):\n83:                 raise ValueError(\"workload_manager_url is required for agentcube provider\")\n84:         \n85:         if metadata.build_mode == \"local\":\n86:             image_url = options.get(\"image_url\") or (metadata.image.get(\"url\") if metadata.image else None)\n87:             if not image_url:\n88:                 raise ValueError(\"--image-url is required for local build mode\")\n89:             \n90:             if not self._docker_service.check_docker_available():\n91:                 raise RuntimeError(\"Docker is not available or not running\")\n92: \n93:         node_port = options.get(\"node_port\")\n94:         if node_port is not None:\n95:             if not (30000 <= node_port <= 32767):\n96:                 raise ValueError(\"NodePort must be in range 30000-32767\")\n97: \n98:     def _publish_cr_to_k8s(\n99:         self, \n100:         workspace_path: Path, \n101:         metadata: AgentMetadata, \n102:         image_url: str, \n103:         options: Dict[str, Any]\n104:     ) -> Dict[str, Any]:\n105:         namespace = options.get(\"namespace\") or \"default\"\n106:         self._agentcube_provider.namespace = namespace\n107:         \n108:         env_vars = {}\n109:         workload_manager_url = options.get(\"workload_manager_url\") or metadata.workload_manager_url\n110:         router_url = options.get(\"router_url\") or metadata.router_url\n111:         \n112:         if workload_manager_url:\n113:             env_vars[\"WORKLOAD_MANAGER_URL\"] = workload_manager_url\n114:         if router_url:\n115:             env_vars[\"ROUTER_URL\"] = router_url\n116:         \n117:         result = self._agentcube_provider.deploy_agent_runtime(\n118:             agent_name=metadata.agent_name,\n119:             image_url=image_url,\n120:             port=metadata.port,\n121:             entrypoint=metadata.entrypoint,\n122:             env_vars=env_vars,\n123:             workload_manager_url=workload_manager_url,\n124:             router_url=router_url,\n125:             readiness_probe_path=metadata.readiness_probe_path or \"/health\",\n126:             readiness_probe_port=metadata.readiness_probe_port or metadata.port,\n127:         )\n128:         \n129:         return {\n130:             \"agent_id\": result.get(\"agent_id\"),\n131:             \"agent_endpoint\": result.get(\"agent_endpoint\"),\n132:             \"deployment_type\": \"AgentRuntime\",\n133:             \"namespace\": namespace,\n134:             \"k8s_deployment\": {\n135:                 \"type\": \"AgentRuntime\",\n136:                 \"deployment_name\": result.get(\"deployment_name\"),\n137:                 \"namespace\": namespace,\n138:                 \"replicas\": 1,\n139:                 \"agent_id\": result.get(\"agent_id\"),\n140:                 \"status\": \"created\",\n141:             },\n142:         }\n143: \n144:     def _publish_k8s(\n145:         self, \n146:         workspace_path: Path, \n147:         metadata: AgentMetadata, \n148:         image_url: str, \n149:         options: Dict[str, Any]\n150:     ) -> Dict[str, Any]:\n151:         namespace = options.get(\"namespace\") or \"default\"\n152:         self._k8s_provider.namespace = namespace\n153:         \n154:         replicas = options.get(\"replicas\") or 1\n155:         node_port = options.get(\"node_port\")\n156:         \n157:         env_vars = {}\n158:         if metadata.workload_manager_url:\n159:             env_vars[\"WORKLOAD_MANAGER_URL\"] = metadata.workload_manager_url\n160:         if metadata.router_url:\n161:             env_vars[\"ROUTER_URL\"] = metadata.router_url\n162:         \n163:         result = self._k8s_provider.deploy_agent(\n164:             agent_name=metadata.agent_name,\n165:             image_url=image_url,\n166:             port=metadata.port,\n167:             entrypoint=metadata.entrypoint,\n168:             replicas=replicas,\n169:             node_port=node_port,\n170:             env_vars=env_vars,\n171:         )\n172:         \n173:         return {\n174:             \"agent_endpoint\": result.get(\"service_url\"),\n175:             \"deployment_type\": \"Deployment\",\n176:             \"namespace\": namespace,\n177:             \"k8s_deployment\": {\n178:                 \"type\": \"Deployment\",\n179:                 \"deployment_name\": result.get(\"deployment_name\"),\n180:                 \"service_name\": result.get(\"service_name\"),\n181:                 \"namespace\": namespace,\n182:                 \"replicas\": replicas,\n183:                 \"node_port\": result.get(\"node_port\"),\n184:                 \"service_url\": result.get(\"service_url\"),\n185:                 \"status\": \"ready\",\n186:             },\n187:         }\n188: \n189:     def _prepare_image_for_publishing(\n190:         self, \n191:         workspace_path: Path, \n192:         metadata: AgentMetadata, \n193:         options: Dict[str, Any]\n194:     ) -> str:\n195:         if metadata.build_mode == \"cloud\":\n196:             return self._prepare_cloud_image(workspace_path, metadata, options)\n197:         return self._prepare_local_image(workspace_path, metadata, options)\n198: \n199:     def _prepare_local_image(\n200:         self, \n201:         workspace_path: Path, \n202:         metadata: AgentMetadata, \n203:         options: Dict[str, Any]\n204:     ) -> str:\n205:         image_url = options.get(\"image_url\") or (metadata.image.get(\"url\") if metadata.image else None)\n206:         if not image_url:\n207:             raise ValueError(\"--image-url is required for local build mode\")\n208:         \n209:         assert image_url is not None\n210:         \n211:         image_name = metadata.agent_name\n212:         tag = metadata.version or \"latest\"\n213:         local_image = f\"{image_name}:{tag}\"\n214:         \n215:         registry_url = image_url\n216:         if \"/\" in registry_url:\n217:             registry_url = registry_url.rsplit(\"/\", 1)[0]\n218:         \n219:         username = options.get(\"image_username\") or metadata.registry_username\n220:         password = options.get(\"image_password\") or metadata.registry_password\n221:         \n222:         if username and password:\n223:             self._docker_service._get_client().login(\n224:                 username=username,\n225:                 password=password,\n226:                 registry=registry_url,\n227:             )\n228:         \n229:         full_image_name = image_url\n230:         if not image_url.endswith(f\":{tag}\"):\n231:             full_image_name = f\"{image_url}:{tag}\"\n232:         \n233:         self._docker_service._get_client().images.push(full_image_name)\n234:         \n235:         return full_image_name\n236: \n237:     def _prepare_cloud_image(\n238:         self, \n239:         workspace_path: Path, \n240:         metadata: AgentMetadata, \n241:         options: Dict[str, Any]\n242:     ) -> str:\n243:         image_url = options.get(\"image_url\") or (metadata.image.get(\"url\") if metadata.image else None)\n244:         if not image_url:\n245:             raise ValueError(\"image_url is required for cloud build mode\")\n246:         return image_url\n247: \n248:     def _update_publish_metadata(\n249:         self, \n250:         workspace_path: Path, \n251:         metadata: AgentMetadata, \n252:         result: Dict[str, Any]\n253:     ) -> None:\n254:         if result.get(\"agent_id\"):\n255:             metadata.agent_id = result[\"agent_id\"]\n256:         if result.get(\"agent_endpoint\"):\n257:             metadata.agent_endpoint = result[\"agent_endpoint\"]\n258:         if result.get(\"k8s_deployment\"):\n259:             metadata.k8s_deployment = result[\"k8s_deployment\"]\n260:         self._metadata_service.save_metadata(workspace_path, metadata)\n261: \n262:     def _record_error_in_metadata(self, workspace_path: Path, error_msg: str) -> None:\n263:         try:\n264:             metadata = self._metadata_service.load_metadata(workspace_path)\n265:             metadata.k8s_deployment = {\n266:                 \"status\": \"error\",\n267:                 \"error\": error_msg,\n268:             }\n269:             self._metadata_service.save_metadata(workspace_path, metadata)\n270:         except Exception:\n271:             pass\n\n(End of file - total 271 lines)\n</content>","metadata":{"preview":"import logging\nimport time\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom agentcube.services.docker_service import DockerService\n\n\nclass PublishRuntime:\n    def __init__(self, verbose: bool = False, provider: str = \"agentcube\") -> None:\n        self.verbose = verbose\n        self.provider = provider\n        self._metadata_service = MetadataService(verbose)\n        self._docker_service = DockerService(verbose)\n        self._logger = logging.getLogger(__name__)\n\n        if provider == \"k8s\":\n            from agentcube.services.k8s_provider import KubernetesProvider\n            self._k8s_provider = KubernetesProvider(verbose=verbose)","truncated"