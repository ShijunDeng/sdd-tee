Metadata:\n63:         metadata_files = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n64:         for filename in metadata_files:\n65:             filepath = workspace_path / filename\n66:             if filepath.exists():\n67:                 with open(filepath, \"r\", encoding=\"utf-8\") as f:\n68:                     data = yaml.safe_load(f) or {}\n69:                 return AgentMetadata(**data)\n70:         raise FileNotFoundError(\n71:             f\"No metadata file found in workspace: {workspace_path}\"\n72:         )\n73: \n74:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> Path:\n75:         filepath = workspace_path / \"agent_metadata.yaml\"\n76:         data = metadata.model_dump(exclude_none=True)\n77:         with open(filepath, \"w\", encoding=\"utf-8\") as f:\n78:             yaml.dump(data, f, default_flow_style=False, indent=2, sort_keys=False)\n79:         return filepath\n\n(End of file - total 79 lines)\n</content>","metadata":{"preview":"from pathlib import Path\nfrom typing import Optional, Dict, Any\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: str = Field(\"\", description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n    region: str = Field(\"\", description=\"Deployment region\")\n    version: str = Field(\"\", description=\"Semantic version string for publishing\")\n    image: Dict[str, Any] = Field(default_factory=dict, description=\"Container image information\")\n    auth: Dict[str, Any] = Field(default_factory=dict, description=\"Authentication configuration\")\n    requirements_file: str = Field(\"requirements.txt\", description=\"Python dependency file\")\n    registry_url: str = Field(\"\", description=\"Registry URL for image publishing\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775872490336,"end":1775872490355}}}}
