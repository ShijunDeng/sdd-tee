{"type":"tool_use","timestamp":1775852663814,"sessionID":"ses_286ef44c2ffenDTTydtMZC8npT","part":{"id":"prt_d791133d0001u8aaSQm6o0uZrL","messageID":"msg_d7910fc18001JZxKABvXyxZG3E","sessionID":"ses_286ef44c2ffenDTTydtMZC8npT","type":"tool","tool":"read","callID":"toolu_tool-5e6c9fde47ba47838f64c32112a4dad0","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"time\"\n6: \n7: \t\"github.com/gin-gonic/gin\"\n8: )\n9: \n10: func concurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n11: \tif maxConcurrent <= 0 {\n12: \t\tmaxConcurrent = 1000\n13: \t}\n14: \n15: \tsem := make(chan struct{}, maxConcurrent)\n16: \n17: \treturn func(c *gin.Context) {\n18: \t\tselect {\n19: \t\tcase sem <- struct{}{}:\n20: \t\t\tdefer func() { <-sem }()\n21: \t\t\tc.Next()\n22: \t\tdefault:\n23: \t\t\tc.JSON(http.StatusTooManyRequests, gin.H{\n24: \t\t\t\t\"error\": \"server overloaded, please try again later\",\n25: \t\t\t\t\"code\":  \"SERVER_OVERLOADED\",\n26: \t\t\t})\n27: \t\t\tc.Abort()\n28: \t\t}\n29: \t}\n30: }\n31: \n32: func loggingMiddleware(logger Logger) gin.HandlerFunc {\n33: \treturn func(c *gin.Context) {\n34: \t\tstart := time.Now()\n35: \n36: \t\tc.Next()\n37: \n38: \t\tif logger == nil {\n39: \t\t\treturn\n40: \t\t}\n41: \n42: \t\tduration := time.Since(start)\n43: \t\tstatus := c.Writer.Status()\n44: \n45: \t\tlogger.Info(\"request\",\n46: \t\t\t\"method\", c.Request.Method,\n47: \t\t\t\"path\", c.Request.URL.Path,\n48: \t\t\t\"status\", status,\n49: \t\t\t\"duration\", duration,\n50: \t\t)\n51: \t}\n52: }\n53: \n54: func recoveryMiddleware(logger Logger) gin.HandlerFunc {\n55: \treturn func(c *gin.Context) {\n56: \t\tdefer func() {\n57: \t\t\tif err := recover(); err != nil {\n58: \t\t\t\tif logger != nil {\n59: \t\t\t\t\tlogger.Error(\"panic recovered\",\n60: \t\t\t\t\t\t\"error\", err,\n61: \t\t\t\t\t\t\"path\", c.Request.URL.Path,\n62: \t\t\t\t\t\t\"method\", c.Request.Method,\n63: \t\t\t\t\t)\n64: \t\t\t\t}\n65: \n66: \t\t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n67: \t\t\t\t\t\"error\": \"internal server error\",\n68: \t\t\t\t})\n69: \t\t\t\tc.Abort()\n70: \t\t\t}\n71: \t\t}()\n72: \t\tc.Next()\n73: \t}\n74: }\n\n(End of file - total 74 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nfunc concurrencyLimitMiddleware(maxConcurrent int) gin.HandlerFunc {\n\tif maxConcurrent <= 0 {\n\t\tmaxConcurrent = 1000\n\t}\n\n\tsem := make(chan struct{}, maxConcurrent)\n\n\treturn func(c *gin.Context) {\n\t\tselect {\n\t\tcase sem <- struct{}{}:\n\t\t\tdefer func() { <-sem }()","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware.go","time":{"start":1775852663797,"end":1775852663812}}}}
