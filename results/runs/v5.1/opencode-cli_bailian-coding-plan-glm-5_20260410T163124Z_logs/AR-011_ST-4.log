n57: }\n58: \n59: func (e *SandboxTimeoutError) Message() string {\n60: \treturn \"sandbox timeout\"\n61: }\n62: \n63: type JWTSigningError struct {\n64: \tErr error\n65: }\n66: \n67: func (e *JWTSigningError) Error() string {\n68: \treturn \"jwt signing failed: \" + e.Err.Error()\n69: }\n70: \n71: func (e *JWTSigningError) Status() int {\n72: \treturn 500\n73: }\n74: \n75: func (e *JWTSigningError) Code() string {\n76: \treturn \"JWT_SIGNING_FAILED\"\n77: }\n78: \n79: func (e *JWTSigningError) Message() string {\n80: \treturn \"jwt signing failed\"\n81: }\n82: \n83: type ServerOverloadedError struct{}\n84: \n85: func (e *ServerOverloadedError) Error() string {\n86: \treturn \"server overloaded\"\n87: }\n88: \n89: func (e *ServerOverloadedError) Status() int {\n90: \treturn 429\n91: }\n92: \n93: func (e *ServerOverloadedError) Code() string {\n94: \treturn \"SERVER_OVERLOADED\"\n95: }\n96: \n97: func (e *ServerOverloadedError) Message() string {\n98: \treturn \"server overloaded, please try again later\"\n99: }\n100: \n101: type NoEntryPointError struct {\n102: \tSandboxID string\n103: }\n104: \n105: func (e *NoEntryPointError) Error() string {\n106: \treturn \"no entry point for sandbox: \" + e.SandboxID\n107: }\n108: \n109: func (e *NoEntryPointError) Status() int {\n110: \treturn 404\n111: }\n112: \n113: func (e *NoEntryPointError) Code() string {\n114: \treturn \"NO_ENTRY_POINT\"\n115: }\n116: \n117: func (e *NoEntryPointError) Message() string {\n118: \treturn \"no entry point configured\"\n119: }\n120: \n121: type WorkloadManagerError struct {\n122: \tStatusCode int\n123: \tMsg        string\n124: }\n125: \n126: func (e *WorkloadManagerError) Error() string {\n127: \treturn e.Msg\n128: }\n129: \n130: func (e *WorkloadManagerError) Status() int {\n131: \treturn e.StatusCode\n132: }\n133: \n134: func (e *WorkloadManagerError) Code() string {\n135: \treturn \"WORKLOAD_MANAGER_ERROR\"\n136: }\n137: \n138: func (e *WorkloadManagerError) Message() string {\n139: \treturn e.Msg\n140: }\n\n(End of file - total 140 lines)\n</content>","metadata":{"preview":"package router\n\ntype SessionNotFoundError struct {\n\tSessionID string\n}\n\nfunc (e *SessionNotFoundError) Error() string {\n\treturn \"session not found: \" + e.SessionID\n}\n\nfunc (e *SessionNotFoundError) Status() int {\n\treturn 404\n}\n\nfunc (e *SessionNotFoundError) Code() string {\n\treturn \"SESSION_NOT_FOUND\"\n}\n\nfunc (e *SessionNotFoundError) Message() string {\n\treturn \"session not found\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/errors.go","time":{"start":1775852663791,"end":1775852663807}}}}
{"type":"tool_use","timestamp":1775852663811,"sessionID":"ses_286ef44c2ffenDTTydtMZC8npT","part":{"id":"prt_d791130b1001VN9M1w8rxQGhLb","messageID":"msg_d7910fc18001JZxKABvXyxZG3E","sessionID":"ses_286ef44c2ffenDTTydtMZC8npT","type":"tool","tool":"read","callID":"toolu_tool-43c4f29372a248e8a634612e718bbe2c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-010/tasks.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-010/tasks.md</path>\n<type>file</type>\n<content>\n1: # AR-010 — Router 会话管理 Tasks\n2: \n3: ## Metadata\n4: \n5: | Item | Value |\n6: |------|-------|\n7: | AR | AR-010 — Router 会话管理 |\n8: | Module | `pkg/router` |\n9: | Language | Go |\n10: | Size | M |\n11: | Design | [Stage ST-3 completed] |\n12: \n13: ---\n14: \n15: ## Task Checklist\n16: \n17: ### Phase 1: Error Types & Interfaces (ST-1)\n18: \n19: - [x] **T1.1**: Define error types in `errors.go`\n20:   - `SessionNotFoundError` with `SessionID` field, code `SESSION_NOT_FOUND`, HTTP 404\n21:   - `SandboxUnreachableError` with `SandboxID` field, code `SANDBOX_UNREACHABLE`, HTTP 502\n22:   - `SandboxTimeoutError` with `SandboxID` field, code `SANDBOX_TIMEOUT`, HTTP 504\n23:   - `JWTSigningError` with `Err` field, code `JWT_SIGNING_FAILED`, HTTP 500\n24:   - `ServerOverloadedError` with code `SERVER_OVERLOADED`, HTTP 429\n25:   - `NoEntryPointError` with code `NO_ENTRY_POINT`, HTTP 404\n26:   - `WorkloadManagerError` with dynamic status code\n27:   - File: `pkg/router/errors.go`\n28:   - Verification: `go test ./pkg/router -run TestSessionNotFoundError -v`\n29: \n30: - [x] **T1.2**: Define `APIStatus` interface\n31:   - Methods: `Status() int`, `Code() string`, `Message() string`\n32:   - All error types implement this interface\n33:   - File: `pkg/router/doc.go`\n34:   - Verification: `go test ./pkg/router -run TestAPIStatusInterface -v`\n35: \n36: ### Phase 2: Config & Constants (ST-2)\n37: \n38: - [x] **T2.1**: Define `Config` struct in `config.go`\n39:   - `Port string` (default \":8080\")\n40:   - `EnableTLS bool`\n41:   - `TLSCert string`\n42:   - `TLSKey string`\n43:   - `MaxConcurrentRequests int` (default 1000)\n44:   - `Debug bool`\n45:   - File: `pkg/router/config.go`\n46:   - Verification: `go test ./pkg/router -run TestConfig -v`\n47: \n48: - [x] **T2.2**: Implement `DefaultConfig()` function\n49:   - Returns `Config{Port: \":8080\", EnableTLS: false, MaxConcurrentRequests: 1000}`\n50:   - File: `pkg/router/config.go`\n51:   - Verification: `go test ./pkg/router -run TestNewServerNilConfig -v`\n52: \n53: - [x] **T2.3**: Define constants in `jwt.go`\n54:   - `rsaKeySize = 2048`\n55:   - `jwtExpiration = 5 * time.Minute`\n56:   - `IdentitySecretName = \"picod-router-identity\"`\n57:   - `PrivateKeyDataKey = \"private.pem\"`\n58:   - `PublicKeyDataKey = \"public.pem\"`\n59:   - `IdentityNamespace = \"default\"` (overridden by AGENTCUBE_NAMESPACE env)\n60:   - File: `pkg/router/jwt.go`\n61:   - Verification: `go test ./pkg/router -run TestJWTManagerTokenExpiration -v`\n62: \n63: ### Phase 3: Interfaces (ST-3)\n64: \n65: - [x] **T3.1**: Define `Store` interface in `doc.go`\n66:   - `GetSandboxBySessionID(ctx, sessionID) (*types.SandboxInfo, error)`\n67:   - `StoreSandbox(ctx, sandbox) error`\n68:   - `UpdateSessionLastActivity(ctx, sessionID, at) error`\n69:   - File: `pkg/router/doc.go`\n70:   - Verification: `go build ./pkg/router/...`\n71: \n72: - [x] **T3.2**: Define `Logger` interface in `doc.go`\n73:   - Methods: `Info(msg, keysAndValues...)`, `Error(msg, keysAndValues...)`, `Warning(msg, keysAndValues...)`\n74:   - File: `pkg/router/doc.go`\n75:   - Verification: `go test ./pkg/router -run TestLoggingMiddleware -v`\n76: \n77: - [x] **T3.3**: Define `SessionManager` interface in `doc.go`\n78:   - `GetSandboxBySession(ctx, sessionID, namespace, name, kind) (*types.SandboxInfo, error)`\n79:   - File: `pkg/router/doc.go`\n80:   - Verification: `go test ./pkg/router -run TestSessionManager -v`\n81: \n82: - [x] **T3.4**: Define `JWTManagerInterface` interface in `doc.go`\n83:   - `GenerateToken(claims) (string, error)`\n84:   - `TryStoreOrLoadJWTKeySecret(ctx) error`\n85:   - File: `pkg/router/doc.go`\n86:   - Verification: `go test ./pkg/router -run TestJWTManager -v`\n87: \n88: ### Phase 4: JWTManager Implementation (ST-4)\n89: \n90: - [x] **T4.1**: Implement `JWTManager` struct\n91:   - `privateKey *rsa.PrivateKey`\n92:   - `publicKey *rsa.PublicKey`\n93:   - File: `pkg/router/jwt.go`\n94:   - Verification: `go test ./pkg/router -run TestNewJWTManager -v`\n95: \n96: - [x] **T4.2**: Implement RSA key generation\n97:   - `rsa.GenerateKey(rand.Reader, 2048)` in `NewJWTManager()`\n98:   - File: `pkg/router/jwt.go`\n99:   - Verification: `go test ./pkg/router -run TestJWTManagerGetPublicKey -v`\n100: \n101: - [x] **T4.3**: Implement PEM encoding helpers\n102:   - `encodePrivateKeyPEM(key)` - PKCS1 PEM encoding\n103:   - `encodePublicKeyPEM(key)` - PKIX PEM encoding\n104:   - `loadPrivateKeyPEM(data)` - Parse PKCS1 PEM\n105:   - File: `pkg/router/jwt.go`\n106:   - Verification: `go test ./pkg/router -run TestEncodePrivateKeyPEM -v`\n107: \n108: - [x] **T4.4**: Implement `GenerateToken(claims)` method\n109:   - Create JWT with claims: `exp` (now+5m), `iat` (now), `iss=\"agentcube-router\"`\n110:   - Merge custom claims into token\n111:   - Sign with RS256 algorithm\n112:   - File: `pkg/router/jwt.go`\n113:   - Verification: `go test ./pkg/router -run TestJWTManagerGenerateToken -v`\n114: \n115: - [x] **T4.5**: Implement `TryStoreOrLoadJWTKeySecret(ctx)` method\n116:   - Placeholder for in-cluster secret persistence\n117:   - Returns warning when not in cluster\n118:   - File: `pkg/router/jwt.go`\n119:   - Verification: `go build ./pkg/router/...`\n120: \n121: - [x] **T4.6**: Implement `GetPublicKey()` method\n122:   - Returns `*rsa.PublicKey` for token verification\n123:   - File: `pkg/router/jwt.go`\n124:   - Verification: `go test ./pkg/router -run TestJWTManagerGetPublicKey -v`\n125: \n126: ### Phase 5: SessionManager Implementation (ST-5)\n127: \n128: - [x] **T5.1**: Implement `sessionManager` struct\n129:   - `storeClient Store`\n130:   - `workloadMgrAddr string`\n131:   - `httpClient *http.Client`\n132:   - File: `pkg/router/session_manager.go`\n133:   - Verification: `go build ./pkg/router/...`\n134: \n135: - [x] **T5.2**: Implement `NewSessionManager(store)` constructor\n136:   - Read `WORKLOAD_MANAGER_URL` env var (required, fail if missing)\n137:   - Configure HTTP client: `Timeout=2m`, HTTP2 enabled\n138:   - `MaxIdleConnsPerHost=100`\n139:   - File: `pkg/router/session_manager.go`\n140:   - Verification: `go test ./pkg/router -run TestNewSessionManagerRequiresWorkloadManagerURL -v`\n141: \n142: - [x] **T5.3**: Implement `GetSandboxBySession(ctx, sessionID, namespace, name, kind)` method\n143:   - If `sessionID` empty: call `createSandbox(ctx, namespace, name, kind)`\n144:   - If `sessionID` present: call `storeClient.GetSandboxBySessionID(ctx, sessionID)`\n145:   - Return `SandboxInfo` or `SessionNotFoundError`\n146:   - File: `pkg/router/session_manager.go`\n147:   - Verification: `go test ./pkg/router -run TestSessionManagerGetSandboxBySessionWithExistingSession -v`\n148: \n149: - [x] **T5.4**: Implement `createSandbox(ctx, namespace, name, kind)` internal method\n150:   - Build `CreateSandboxRequest` with Kind, Name, Namespace\n151:   - POST to `/v1/agent-runtime` for `AgentRuntimeKind`\n152:   - POST to `/v1/code-interpreter` for `CodeInterpreterKind`\n153:   - Add K8s SA token via `readServiceAccountToken()` if available\n154:   - Parse `CreateSandboxResponse` and store via `StoreSandbox`\n155:   - Set `ExpiresAt` to `CreatedAt + 30min`\n156:   - Return error for unsupported kind\n157:   - File: `pkg/router/session_manager.go`\n158:   - Verification: `go test ./pkg/router -run TestSessionManagerCreateSandbox -v`\n159: \n160: - [x] **T5.5**: Implement `readServiceAccountToken()` helper\n161:   - Read from `/var/run/secrets/kubernetes.io/serviceaccount/token`\n162:   - Return trimmed token string\n163:   - File: `pkg/router/session_manager.go`\n164:   - Verification: `go test ./pkg/router -run TestReadServiceAccountToken -v`\n165: \n166: ### Phase 6: Middleware Implementation (ST-6)\n167: \n168: - [x] **T6.1**: Implement `concurrencyLimitMiddleware(maxConcurrent)` function\n169:   - Use buffered channel as semaphore\n170:   - Capacity = `maxConcurrent` (default 1000 if <=0)\n171:   - `sem <- struct{}{}` to acquire slot (deferred release)\n172:   - File: `pkg/router/middleware.go`\n173:   - Verification: `go test ./pkg/router -run TestConcurrencyLimitMiddlewareUnderLimit -v`\n174: \n175: - [x] **T6.2**: Implement 429 overload response\n176:   - `select` with `default` case when semaphore full\n177:   - Return HTTP 429 with `{\"error\": \"server overloaded\", \"code\": \"SERVER_OVERLOADED\"}`\n178:   - Call `c.Abort()` to stop processing\n179:   - File: `pkg/router/middleware.go`\n180:   - Verification: `go test ./pkg/router -run TestConcurrencyLimitMiddlewareOverLimit -v`\n181: \n182: - [x] **T6.3**: Implement `loggingMiddleware(logger)` function\n183:   - Log request method, path, status, duration\n184:   - Use `logger.Info(\"request\", ...)` with keys\n185:   - Handle nil logger gracefully\n186:   - File: `pkg/router/middleware.go`\n187:   - Verification: `go test ./pkg/router -run TestLoggingMiddleware -v`\n188: \n189: - [x] **T6.4**: Implement `recoveryMiddleware(logger)` function\n190:   - Recover from panics with `defer`\n191:   - Log error with path, method\n192:   - Return HTTP 500 with `{\"error\": \"internal server error\"}`\n193:   - Call `c.Abort()`\n194:   - Handle nil logger gracefully\n195:   - File: `pkg/router/middleware.go`\n196:   - Verification: `go test ./pkg/router -run TestRecoveryMiddleware -v`\n197: \n198: ### Phase 7: Reverse Proxy Implementation (ST-7)\n199: \n200: - [x] **T7.1**: Implement `ReverseProxyWrapper` struct\n201:   - `director func(*http.Request)`\n202:   - `modifyResponse func(*http.Response) error`\n203:   - `errorHandler func(http.ResponseWriter, *http.Request, error)`\n204:   - Methods: `Director()`, `ModifyResponse()`, `ErrorHandler()`\n205:   - File: `pkg/router/reverse_proxy.go`\n206:   - Verification: `go build ./pkg/router/...`\n207: \n208: - [x] **T7.2**: Implement `newReverseProxy(target, jwt, sessionID)` function\n209:   - Create `ReverseProxyWrapper` with configured functions\n210:   - File: `pkg/router/reverse_proxy.go`\n211:   - Verification: `go test ./pkg/router -run TestReverseProxy -v`\n212: \n213: - [x] **T7.3**: Implement `Director` function\n214:   - Path normalization: add leading `/` if missing\n215:   - Set `req.URL.Scheme`, `req.URL.Host`, `req.URL.Path`\n216:   - Set `req.Host` to target host\n217:   - Set forwarding headers: `X-Forwarded-Host`, `X-Forwarded-Proto`, `X-Forwarded-For`\n218:   - Inject JWT: `Authorization: Bearer <jwt>` if jwt non-empty\n219:   - File: `pkg/router/reverse_proxy.go`\n220:   - Verification: `go test ./pkg/router -run TestBuildTargetURL -v`\n221: \n222: - [x] **T7.4**: Implement `ModifyResponse` function\n223:   - Add `x-agentcube-session-id` header to response\n224:   - Value is the resolved session ID\n225:   - File: `pkg/router/reverse_proxy.go`\n226:   - Verification: `go test ./pkg/router -run TestReverseProxy -v`\n227: \n228: - [x] **T7.5**: Implement `ErrorHandler` function\n229:   - Check for \"connection refused\" → HTTP 502 `sandbox unreachable`\n230:   - Check for \"timeout\" → HTTP 504 `sandbox timeout`\n231:   - Other errors → HTTP 502\n232:   - Return JSON response: `{\"error\": \"<message>\"}`\n233:   - File: `pkg/router/reverse_proxy.go`\n234:   - Verification: `go test ./pkg/router -run TestReverseProxy -v`\n235: \n236: - [x] **T7.6**: Implement `selectEntryPoint(entryPoints, invocationPath)` helper\n237:   - Find matching entry point by path prefix (HasPrefix)\n238:   - Default to first entry point if no match\n239:   - Return nil if `entryPoints` is empty\n240:   - File: `pkg/router/reverse_proxy.go`\n241:   - Verification: `go test ./pkg/router -run TestSelectEntryPoint -v`\n242: \n243: - [x] **T7.7**: Implement `buildTargetURL(entryPoint)` helper\n244:   - Parse `entryPoint.Endpoint` as URL\n245:   - Add protocol prefix if missing: `entryPoint.Protocol + \"://\" + endpoint`\n246:   - Return parsed `url.URL`\n247:   - File: `pkg/router/reverse_proxy.go`\n248:   - Verification: `go test ./pkg/router -run TestBuildTargetURL -v`\n249: \n250: ### Phase 8: Server & Handlers Implementation (ST-8)\n251: \n252: - [x] **T8.1**: Implement `Server` struct\n253:   - `config *Config`\n254:   - `engine *gin.Engine`\n255:   - `httpServer *http.Server`\n256:   - `sessionManager SessionManager`\n257:   - `storeClient Store`\n258:   - `httpTransport *http.Transport`\n259:   - `jwtManager *JWTManager`\n260:   - `logger Logger`\n261:   - File: `pkg/router/server.go`\n262:   - Verification: `go test ./pkg/router -run TestNewServer -v`\n263: \n264: - [x] **T8.2**: Implement `NewServer(config, sessionManager, store, jwtManager, logger)` constructor\n265:   - Create `engine := gin.New()`\n266:   - Set Gin mode: `gin.ReleaseMode` if `!config.Debug`\n267:   - Initialize `httpTransport` with `MaxIdleConnsPerHost=100`\n268:   - Configure `httpServer` with `ReadTimeout=30s`, `IdleTimeout=90s`\n269:   - Set default `MaxConcurrentRequests=1000` if <=0\n270:   - Register routes via `registerRoutes()`\n271:   - File: `pkg/router/server.go`\n272:   - Verification: `go test ./pkg/router -run TestNewServer -v`\n273: \n274: - [x] **T8.3**: Implement route registration in `registerRoutes()`\n275:   - `/health/live` → `handleHealthLive` (no middleware)\n276:   - `/health/ready` → `handleHealthReady` (no middleware)\n277:   - `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` → `handleAgentInvoke` (GET, POST)\n278:   - `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path` → `handleCodeInterpreterInvoke` (GET, POST)\n279:   - Apply middleware: `concurrencyLimitMiddleware`, `loggingMiddleware`, `recoveryMiddleware`\n280:   - File: `pkg/router/server.go`\n281:   - Verification: `go test ./pkg/router -run TestServerRoutesRegistered -v`\n282: \n283: - [x] **T8.4**: Implement `handleHealthLive(c)` handler\n284:   - Return HTTP 200\n285:   - Body: `{\"status\": \"alive\"}`\n286:   - File: `pkg/router/server.go`\n287:   - Verification: `go test ./pkg/router -run TestServerHandleHealthLive -v`\n288: \n289: - [x] **T8.5**: Implement `handleHealthReady(c)` handler\n290:   - Check if `sessionManager != nil`\n291:   - If nil: HTTP 503, body: `{\"status\": \"not ready\", \"error\": \"session manager not available\"}`\n292:   - If valid: HTTP 200, body: `{\"status\": \"ready\"}`\n293:   - File: `pkg/router/server.go`\n294:   - Verification: `go test ./pkg/router -run TestServerHandleHealthReady -v`\n295: \n296: - [x] **T8.6**: Implement `handleAgentInvoke(c)` handler\n297:   - Set `kind = AgentRuntimeKind`\n298:   - Delegate to `handleInvoke(c, kind)`\n299:   - File: `pkg/router/server.go`\n300:   - Verification: `go test ./pkg/router -run TestServerHandleAgentInvoke -v`\n301: \n302: - [x] **T8.7**: Implement `handleCodeInterpreterInvoke(c)` handler\n303:   - Set `kind = CodeInterpreterKind`\n304:   - Delegate to `handleInvoke(c, kind)`\n305:   - File: `pkg/router/server.go`\n306:   - Verification: `go test ./pkg/router -run TestServerHandleCodeInterpreterInvoke -v`\n307: \n308: - [x] **T8.8**: Implement `handleInvoke(c, kind)` handler\n309:   - Extract `namespace`, `name` from URL path params\n310:   - Extract `invocationPath` from wildcard param\n311:   - Extract `x-agentcube-session-id` header\n312:   - Call `sessionManager.GetSandboxBySession(ctx, sessionID, namespace, name, kind)`\n313:   - Check for empty `EntryPoints` → 404 `NO_ENTRY_POIN