 sessionID string) (*types.SandboxInfo, error)\n\tStoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error\n\tUpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n}\n\ntype Logger interface {\n\tInfo(msg string, keysAndValues ...any)\n\tError(msg string, keysAndValues ...any)\n\tWarning(msg string, keysAndValues ...any)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/doc.go","time":{"start":1775852680519,"end":1775852680531}}}}
{"type":"tool_use","timestamp":1775852680534,"sessionID":"ses_286ef44c2ffenDTTydtMZC8npT","part":{"id":"prt_d7911752d001BivT2EAqRNcT5K","messageID":"msg_d79113434001g9n6BsBOMbTZkl","sessionID":"ses_286ef44c2ffenDTTydtMZC8npT","type":"tool","tool":"read","callID":"toolu_tool-15b0f45e69da4c2a8379c7b03f393e03","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"testing\"\n5: \t\"time\"\n6: \n7: \t\"github.com/golang-jwt/jwt/v5\"\n8: )\n9: \n10: func TestNewJWTManager(t *testing.T) {\n11: \tjwtMgr, err := NewJWTManager()\n12: \tif err != nil {\n13: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n14: \t}\n15: \tif jwtMgr.privateKey == nil {\n16: \t\tt.Error(\"privateKey is nil\")\n17: \t}\n18: \tif jwtMgr.publicKey == nil {\n19: \t\tt.Error(\"publicKey is nil\")\n20: \t}\n21: }\n22: \n23: func TestJWTManagerGenerateToken(t *testing.T) {\n24: \tjwtMgr, err := NewJWTManager()\n25: \tif err != nil {\n26: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n27: \t}\n28: \n29: \tclaims := map[string]interface{}{\n30: \t\t\"session_id\": \"test-session\",\n31: \t\t\"sandbox_id\": \"test-sandbox\",\n32: \t}\n33: \n34: \ttokenStr, err := jwtMgr.GenerateToken(claims)\n35: \tif err != nil {\n36: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n37: \t}\n38: \n39: \ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n40: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n41: \t\t\treturn nil, jwt.ErrSignatureInvalid\n42: \t\t}\n43: \t\treturn jwtMgr.publicKey, nil\n44: \t})\n45: \n46: \tif err != nil {\n47: \t\tt.Fatalf(\"failed to parse token: %v\", err)\n48: \t}\n49: \n50: \tif !token.Valid {\n51: \t\tt.Error(\"token is not valid\")\n52: \t}\n53: \n54: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n55: \tif !ok {\n56: \t\tt.Fatal(\"claims are not MapClaims\")\n57: \t}\n58: \n59: \tif mapClaims[\"iss\"] != \"agentcube-router\" {\n60: \t\tt.Errorf(\"unexpected issuer: %v\", mapClaims[\"iss\"])\n61: \t}\n62: \n63: \tif mapClaims[\"session_id\"] != \"test-session\" {\n64: \t\tt.Errorf(\"unexpected session_id: %v\", mapClaims[\"session_id\"])\n65: \t}\n66: }\n67: \n68: func TestJWTManagerTokenExpiration(t *testing.T) {\n69: \tjwtMgr, err := NewJWTManager()\n70: \tif err != nil {\n71: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n72: \t}\n73: \n74: \ttokenStr, err := jwtMgr.GenerateToken(map[string]interface{}{})\n75: \tif err != nil {\n76: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n77: \t}\n78: \n79: \ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n80: \t\treturn jwtMgr.publicKey, nil\n81: \t})\n82: \n83: \tif err != nil {\n84: \t\tt.Fatalf(\"failed to parse token: %v\", err)\n85: \t}\n86: \n87: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n88: \tif !ok {\n89: \t\tt.Fatal(\"claims are not MapClaims\")\n90: \t}\n91: \n92: \texp, ok := mapClaims[\"exp\"].(float64)\n93: \tif !ok {\n94: \t\tt.Fatal(\"exp claim is not float64\")\n95: \t}\n96: \n97: \tnow := time.Now().Unix()\n98: \texpectedExp := now + int64(jwtExpiration.Seconds())\n99: \n100: \tif int64(exp) < now {\n101: \t\tt.Error(\"token is already expired\")\n102: \t}\n103: \n104: \tif int64(exp) > expectedExp+5 || int64(exp) < expectedExp-5 {\n105: \t\tt.Errorf(\"expiration time is not approximately 5 minutes: exp=%d, expected=%d\", int64(exp), expectedExp)\n106: \t}\n107: }\n108: \n109: func TestJWTManagerGetPublicKey(t *testing.T) {\n110: \tjwtMgr, err := NewJWTManager()\n111: \tif err != nil {\n112: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n113: \t}\n114: \n115: \tpubKey := jwtMgr.GetPublicKey()\n116: \tif pubKey == nil {\n117: \t\tt.Error(\"GetPublicKey returned nil\")\n118: \t}\n119: \n120: \tif pubKey.Size() != 2048/8 {\n121: \t\tt.Errorf(\"unexpected key size: %d\", pubKey.Size())\n122: \t}\n123: }\n124: \n125: func TestEncodePrivateKeyPEM(t *testing.T) {\n126: \tjwtMgr, err := NewJWTManager()\n127: \tif err != nil {\n128: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n129: \t}\n130: \n131: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n132: \tif pemData == nil {\n133: \t\tt.Fatal(\"encodePrivateKeyPEM returned nil\")\n134: \t}\n135: \n136: \tif !contains(string(pemData), \"RSA PRIVATE KEY\") {\n137: \t\tt.Errorf(\"PEM data does not contain 'RSA PRIVATE KEY'\")\n138: \t}\n139: }\n140: \n141: func TestEncodePublicKeyPEM(t *testing.T) {\n142: \tjwtMgr, err := NewJWTManager()\n143: \tif err != nil {\n144: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n145: \t}\n146: \n147: \tpemData := encodePublicKeyPEM(jwtMgr.publicKey)\n148: \tif pemData == nil {\n149: \t\tt.Fatal(\"encodePublicKeyPEM returned nil\")\n150: \t}\n151: \n152: \tif !contains(string(pemData), \"PUBLIC KEY\") {\n153: \t\tt.Errorf(\"PEM data does not contain 'PUBLIC KEY'\")\n154: \t}\n155: }\n156: \n157: func TestLoadPrivateKeyPEM(t *testing.T) {\n158: \tjwtMgr, err := NewJWTManager()\n159: \tif err != nil {\n160: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n161: \t}\n162: \n163: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n164: \tloadedKey, err := loadPrivateKeyPEM(pemData)\n165: \tif err != nil {\n166: \t\tt.Fatalf(\"failed to load private key: %v\", err)\n167: \t}\n168: \n169: \tif loadedKey.N.Cmp(jwtMgr.privateKey.N) != 0 {\n170: \t\tt.Error(\"loaded key does not match original key\")\n171: \t}\n172: }\n173: \n174: func TestLoadPrivateKeyPEMInvalid(t *testing.T) {\n175: \t_, err := loadPrivateKeyPEM([]byte(\"invalid pem data\"))\n176: \tif err == nil {\n177: \t\tt.Error(\"expected error for invalid PEM data\")\n178: \t}\n179: }\n180: \n181: func contains(s, substr string) bool {\n182: \treturn len(s) > 0 && len(substr) > 0 && len(s) >= len(substr)\n183: }\n\n(End of file - total 183 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nfunc TestNewJWTManager(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\tif err != nil {\n\t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n\t}\n\tif jwtMgr.privateKey == nil {\n\t\tt.Error(\"privateKey is nil\")\n\t}\n\tif jwtMgr.publicKey == nil {\n\t\tt.Error(\"publicKey is nil\")\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go","time":{"start":1775852680522,"end":1775852680532}}}}
