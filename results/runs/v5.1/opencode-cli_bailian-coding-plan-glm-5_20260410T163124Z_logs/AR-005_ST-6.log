ewInformers(k8sClient)\n46: \n47: \tctx, cancel := context.WithTimeout(context.Background(), 2*time.Second)\n48: \tdefer cancel()\n49: \n50: \tinformers.Start(ctx)\n51: \n52: \tsynced := informers.WaitForCacheSync(ctx)\n53: \tassert.True(t, synced)\n54: }\n55: \n56: func TestInformers_WaitForCacheSyncTimeout(t *testing.T) {\n57: \tfakeClient := k8sfake.NewSimpleClientset()\n58: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n59: \tinformerFactory := NewTestInformerFactory(fakeClient)\n60: \t\n61: \tk8sClient := &K8sClient{\n62: \t\tdynamicClient:  dynamicClient,\n63: \t\tcoreClient:     fakeClient,\n64: \t\tinformerFactory: informerFactory,\n65: \t}\n66: \t\n67: \tinformers := NewInformers(k8sClient)\n68: \t\n69: \tctx, cancel := context.WithCancel(context.Background())\n70: \tcancel()\n71: \t\n72: \tinformers.Start(ctx)\n73: \t\n74: \tsynced := informers.WaitForCacheSync(ctx)\n75: \tassert.False(t, synced, \"Cache sync should return false when context is cancelled before informers start\")\n76: }\n77: \n78: \tinformers := NewInformers(k8sClient)\n79: \n80: \tctx, cancel := context.WithTimeout(context.Background(), 1*time.Nanosecond)\n81: \tdefer cancel()\n82: \n83: \ttime.Sleep(10 * time.Millisecond)\n84: \n85: \tsynced := informers.WaitForCacheSync(ctx)\n86: \tassert.False(t, synced)\n87: }\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n)\n\nfunc TestInformers_Start(t *testing.T) {\n\tfakeClient := k8sfake.NewSimpleClientset()\n\tinformerFactory := NewTestInformerFactory(fakeClient)\n\n\tk8sClient := &K8sClient{\n\t\tcoreClient:      fakeClient,\n\t\tinformerFactory: informerFactory,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian