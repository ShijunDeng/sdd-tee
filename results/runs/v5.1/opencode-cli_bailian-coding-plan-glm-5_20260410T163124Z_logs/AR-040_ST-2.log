s with non-zero exit code.\"\"\"\n\n    def __init__(self, exit_code: int, stderr: str, command: Optional[str] = None) -> None:\n        self.exit_code = exit_code\n        self.stderr = stderr\n        self.command = command\n        super().__init__(f\"Command failed (exit {exit_code}): {stderr}\")\n\n\nclass SessionError(AgentCubeError):","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/exceptions.py","time":{"start":1775900357769,"end":1775900357782}}}}
