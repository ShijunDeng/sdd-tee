{"type":"tool_use","timestamp":1775900341095,"sessionID":"ses_28417dd66ffeB506LTdirue3Y0","part":{"id":"prt_d7be8a448001cmDQggpEMqtGKm","messageID":"msg_d7be871e60012RYaQx25hIDKwE","sessionID":"ses_28417dd66ffeB506LTdirue3Y0","type":"tool","tool":"read","callID":"toolu_tool-68c2430c7fdc4de3865bdcc82bdeba83","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_code_interpreter.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_code_interpreter.py</path>\n<type>file</type>\n<content>\n1: import os\n2: import pytest\n3: import responses\n4: from unittest.mock import Mock, patch, MagicMock\n5: \n6: from agentcube.code_interpreter import CodeInterpreterClient\n7: from agentcube.clients.control_plane import ControlPlaneClient\n8: from agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n9: \n10: \n11: class TestCodeInterpreterClientInit:\n12:     def test_router_url_required(self) -> None:\n13:         if \"ROUTER_URL\" in os.environ:\n14:             del os.environ[\"ROUTER_URL\"]\n15:         with pytest.raises(ValueError, match=\"router_url must be provided\"):\n16:             CodeInterpreterClient.__new__(CodeInterpreterClient).__init__(\n17:                 name=\"test\",\n18:                 workload_manager_url=\"http://wm\",\n19:             )\n20: \n21:     @responses.activate\n22:     def test_router_url_from_env(self) -> None:\n23:         responses.post(\n24:             \"http://wm/v1/code-interpreter\",\n25:             json={\"sessionId\": \"session-123\"},\n26:         )\n27:         os.environ[\"ROUTER_URL\"] = \"http://router\"\n28:         client = CodeInterpreterClient(\n29:             name=\"test\",\n30:             workload_manager_url=\"http://wm\",\n31:         )\n32:         assert client.router_url == \"http://router\"\n33:         del os.environ[\"ROUTER_URL\"]\n34:         client.stop()\n35: \n36:     @responses.activate\n37:     def test_router_url_explicit(self) -> None:\n38:         responses.post(\n39:             \"http://wm/v1/code-interpreter\",\n40:             json={\"sessionId\": \"session-123\"},\n41:         )\n42:         client = CodeInterpreterClient(\n43:             name=\"test\",\n44:             workload_manager_url=\"http://wm\",\n45:             router_url=\"http://router\",\n46:         )\n47:         assert client.router_url == \"http://router\"\n48:         client.stop()\n49: \n50: \n51: class TestSessionCreation:\n52:     @responses.activate\n53:     def test_session_created_when_not_provided(self) -> None:\n54:         responses.post(\n55:             \"http://wm/v1/code-interpreter\",\n56:             json={\"sessionId\": \"session-123\"},\n57:         )\n58:         client = CodeInterpreterClient(\n59:             name=\"test\",\n60:             namespace=\"default\",\n61:             ttl=3600,\n62:             workload_manager_url=\"http://wm\",\n63:             router_url=\"http://router\",\n64:         )\n65:         assert client._session_id == \"session-123\"\n66:         assert client._session_created == True\n67:         client.stop()\n68: \n69:     @responses.activate\n70:     def test_session_reused_when_provided(self) -> None:\n71:         client = CodeInterpreterClient(\n72:             name=\"test\",\n73:             workload_manager_url=\"http://wm\",\n74:             router_url=\"http://router\",\n75:             session_id=\"provided-session\",\n76:         )\n77:         assert client._session_id == \"provided-session\"\n78:         assert client._session_created == False\n79:         client.stop()\n80: \n81: \n82: class TestContextManager:\n83:     @responses.activate\n84:     def test_context_manager_calls_stop(self) -> None:\n85:         responses.post(\n86:             \"http://wm/v1/code-interpreter\",\n87:             json={\"sessionId\": \"session-123\"},\n88:         )\n89:         responses.delete(\n90:             \"http://wm/v1/code-interpreter/sessions/session-123\",\n91:             status=200,\n92:         )\n93:         with CodeInterpreterClient(\n94:             name=\"test\",\n95:             workload_manager_url=\"http://wm\",\n96:             router_url=\"http://router\",\n97:         ) as client:\n98:             assert client._session_id == \"session-123\"\n99: \n100:     @responses.activate\n101:     def test_context_manager_on_exception(self) -> None:\n102:         responses.post(\n103:             \"http://wm/v1/code-interpreter\",\n104:             json={\"sessionId\": \"session-123\"},\n105:         )\n106:         responses.delete(\n107:             \"http://wm/v1/code-interpreter/sessions/session-123\",\n108:             status=200,\n109:         )\n110:         try:\n111:             with CodeInterpreterClient(\n112:                 name=\"test\",\n113:                 workload_manager_url=\"http://wm\",\n114:                 router_url=\"http://router\",\n115:             ) as client:\n116:                 raise RuntimeError(\"Test error\")\n117:         except RuntimeError:\n118:             pass\n119: \n120: \n121: class TestStopMethod:\n122:     @responses.activate\n123:     def test_stop_closes_data_plane_and_control_plane(self) -> None:\n124:         responses.post(\n125:             \"http://wm/v1/code-interpreter\",\n126:             json={\"sessionId\": \"session-123\"},\n127:         )\n128:         responses.delete(\n129:             \"http://wm/v1/code-interpreter/sessions/session-123\",\n130:             status=200,\n131:         )\n132:         client = CodeInterpreterClient(\n133:             name=\"test\",\n134:             workload_manager_url=\"http://wm\",\n135:             router_url=\"http://router\",\n136:         )\n137:         client.stop()\n138:         assert client._dp_client is None\n139: \n140:     @responses.activate\n141:     def test_stop_only_deletes_if_session_created(self) -> None:\n142:         responses.delete(\n143:             \"http://wm/v1/code-interpreter/sessions/provided-session\",\n144:             status=200,\n145:         )\n146:         client = CodeInterpreterClient(\n147:             name=\"test\",\n148:             workload_manager_url=\"http://wm\",\n149:             router_url=\"http://router\",\n150:             session_id=\"provided-session\",\n151:         )\n152:         client.stop()\n153: \n154: \n155: class TestExecuteCommandDelegation:\n156:     @responses.activate\n157:     def test_execute_command_delegates_to_data_plane(self) -> None:\n158:         responses.post(\n159:             \"http://wm/v1/code-interpreter\",\n160:             json={\"sessionId\": \"session-123\"},\n161:         )\n162:         responses.post(\n163:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/execute\",\n164:             json={\"exit_code\": 0, \"stdout\": \"output\"},\n165:         )\n166:         client = CodeInterpreterClient(\n167:             name=\"test\",\n168:             workload_manager_url=\"http://wm\",\n169:             router_url=\"http://router\",\n170:         )\n171:         result = client.execute_command(\"ls -la\")\n172:         assert result == \"output\"\n173:         client.stop()\n174: \n175: \n176: class TestRunCode:\n177:     @responses.activate\n178:     def test_run_code_python(self) -> None:\n179:         responses.post(\n180:             \"http://wm/v1/code-interpreter\",\n181:             json={\"sessionId\": \"session-123\"},\n182:         )\n183:         responses.post(\n184:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n185:             status=200,\n186:         )\n187:         responses.post(\n188:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/execute\",\n189:             json={\"exit_code\": 0, \"stdout\": \"Hello World\"},\n190:         )\n191:         client = CodeInterpreterClient(\n192:             name=\"test\",\n193:             workload_manager_url=\"http://wm\",\n194:             router_url=\"http://router\",\n195:         )\n196:         result = client.run_code(\"python\", \"print('Hello World')\")\n197:         assert result == \"Hello World\"\n198:         client.stop()\n199: \n200:     def test_run_code_unsupported_language(self) -> None:\n201:         client = CodeInterpreterClient.__new__(CodeInterpreterClient)\n202:         client._dp_client = Mock()\n203:         with pytest.raises(ValueError, match=\"Unsupported language\"):\n204:             client.run_code(\"javascript\", \"console.log('test')\")\n205: \n206: \n207: class TestFileOperations:\n208:     @responses.activate\n209:     def test_write_file_delegates(self) -> None:\n210:         responses.post(\n211:             \"http://wm/v1/code-interpreter\",\n212:             json={\"sessionId\": \"session-123\"},\n213:         )\n214:         responses.post(\n215:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n216:             status=200,\n217:         )\n218:         client = CodeInterpreterClient(\n219:             name=\"test\",\n220:             workload_manager_url=\"http://wm\",\n221:             router_url=\"http://router\",\n222:         )\n223:         client.write_file(\"content\", \"/workspace/test.py\")\n224:         client.stop()\n225: \n226:     @responses.activate\n227:     def test_list_files_delegates(self) -> None:\n228:         responses.post(\n229:             \"http://wm/v1/code-interpreter\",\n230:             json={\"sessionId\": \"session-123\"},\n231:         )\n232:         responses.get(\n233:             \"http://router/v1/namespaces/default/code-interpreters/test/invocations/api/files\",\n234:             json={\"files\": [\"file1.py\", \"file2.py\"]},\n235:         )\n236:         client = CodeInterpreterClient(\n237:             name=\"test\",\n238:             workload_manager_url=\"http://wm\",\n239:             router_url=\"http://router\",\n240:         )\n241:         result = client.list_files(\"/workspace\")\n242:         assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n243:         client.stop()\n244: \n245: \n246: class TestVerboseMode:\n247:     @responses.activate\n248:     def test_verbose_false(self) -> None:\n249:         responses.post(\n250:             \"http://wm/v1/code-interpreter\",\n251:             json={\"sessionId\": \"session-123\"},\n252:         )\n253:         client = CodeInterpreterClient(\n254:             name=\"test\",\n255:             workload_manager_url=\"http://wm\",\n256:             router_url=\"http://router\",\n257:             verbose=False,\n258:         )\n259:         import logging\n260:         assert client._logger.level == logging.INFO\n261:         client.stop()\n262: \n263:     @responses.activate\n264:     def test_verbose_true(self) -> None:\n265:         responses.post(\n266:             \"http://wm/v1/code-interpreter\",\n267:             json={\"sessionId\": \"session-123\"},\n268:         )\n269:         client = CodeInterpreterClient(\n270:             name=\"test\",\n271:             workload_manager_url=\"http://wm\",\n272:             router_url=\"http://router\",\n273:             verbose=True,\n274:         )\n275:         import logging\n276:         assert client._logger.level == logging.DEBUG\n277:         client.stop()\n278: \n279: \n280: class TestDataPlaneInitFailure:\n281:     def test_data_plane_init_failure_cleans_up_session(self) -> None:\n282:         mock_cp_client = Mock()\n283:         mock_cp_client.create_session = Mock(return_value=\"session-123\")\n284:         mock_cp_client.delete_session = Mock(return_value=True)\n285:         mock_cp_client.close = Mock()\n286: \n287:         with patch(\"agentcube.code_interpreter.ControlPlaneClient\", return_value=mock_cp_client):\n288:             with patch(\"agentcube.code_interpreter.CodeInterpreterDataPlaneClient\", side_effect=RuntimeError(\"Init failed\")):\n289:                 with patch(\"agentcube.code_interpreter.CodeInterpreterClient._resolve_router_url\", return_value=\"http://router\"):\n290:                     with pytest.raises(RuntimeError, match=\"Init failed\"):\n291:                         client = CodeInterpreterClient(\n292:                             name=\"test\",\n293:                             workload_manager_url=\"http://wm\",\n294:                             router_url=\"http://router\",\n295:                         )\n296:                     mock_cp_client.delete_session.assert_called_once_with(\"session-123\")\n\n(End of file - total 296 lines)\n</content>","metadata":{"preview":"import os\nimport pytest\nimport responses\nfrom unittest.mock import Mock, patch, MagicMock\n\nfrom agentcube.code_interpreter import CodeInterpreterClient\nfrom agentcube.clients.control_plane import ControlPlaneClient\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n\n\nclass TestCodeInterpreterClientInit:\n    def test_router_url_required(self) -> None:\n        if \"ROUTER_URL\" in os.environ:\n            del os.environ[\"ROUTER_URL\"]\n        with pytest.raises(ValueError, match=\"router_url must be provided\"):\n            CodeInterpreterClient.__new__(CodeInterpreterClient).__init__(\n                name=\"test\",\n                workload_manager_url=\"http://wm\",\n            )\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_code_interpreter.py","time":{"start":1775900341069,"end":1775900341093}}}}
