\n32: \n33: class TestSessionHeader:\n34:     def test_session_header_lowercase(self) -> None:\n35:         client = CodeInterpreterDataPlaneClient(\n36:             session_id=\"session-123\",\n37:             router_url=\"http://router\",\n38:             namespace=\"default\",\n39:             cr_name=\"test\",\n40:         )\n41:         assert \"x-agentcube-session-id\" in client.session.headers\n42:         assert client.session.headers[\"x-agentcube-session-id\"] == \"session-123\"\n43: \n44: \n45: class TestBaseURLConstruction:\n46:     def test_base_url_from_router_url(self) -> None:\n47:         client = CodeInterpreterDataPlaneClient(\n48:             session_id=\"session-123\",\n49:             router_url=\"http://router.example.com\",\n50:             namespace=\"production\",\n51:             cr_name=\"my-interpreter\",\n52:         )\n53:         assert client.base_url == \"http://router.example.com/v1/namespaces/production/code-interpreters/my-interpreter/invocations/\"\n54: \n55: \n56: class TestExecuteCommand:\n57:     def test_execute_command_success(self) -> None:\n58:         client = CodeInterpreterDataPlaneClient(\n59:             session_id=\"session-123\",\n60:             base_url=\"http://router/v1/invocations/\",\n61:         )\n62:         mock_response = MagicMock()\n63:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\"}\n64:         mock_response.raise_for_status = MagicMock()\n65:         client._request = MagicMock(return_value=mock_response)\n66: \n67:         result = client.execute_command(\"python3 script.py\")\n68:         assert result == \"output\"\n69: \n70:     def test_execute_command_json_body(self) -> None:\n71:         client = CodeInterpreterDataPlaneClient(\n72:             session_id=\"session-123\",\n73:             base_url=\"http://router/v1/invocations/\",\n74:         )\n75:         mock_response = MagicMock()\n76:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n77:         mock_response.raise_for_status = MagicMock()\n78:         client._request = MagicMock(return_value=mock_response)\n79: \n80:         client.execute_command(\"python3 script.py\", timeout=30)\n81:         call_args = client._request.call_args\n82:         import json\n83:         body = json.loads(call_args.args[2].decode())\n84:         assert body[\"command\"] == [\"python3\", \"script.py\"]\n85:         assert body[\"timeout\"] == \"30s\"\n86: \n87:     def test_execute_command_timeout_buffer(self) -> None:\n88:         client = CodeInterpreterDataPlaneClient(\n89:             session_id=\"session-123\",\n90:             base_url=\"http://router/v1/invocations/\",\n91:             timeout=60,\n92:         )\n93:         mock_response = MagicMock()\n94:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n95:         mock_response.raise_for_status = MagicMock()\n96:         client._request = MagicMock(return_value=mock_response)\n97: \n98:         client.execute_command(\"cmd\", timeout=30)\n99:         call_args = client._request.call_args\n100:         assert call_args.kwargs[\"timeout_override\"] == 32.0\n101: \n102:     def test_execute_command_nonzero_exit(self) -> None:\n103:         client = CodeInterpreterDataPlaneClient(\n104:             session_id=\"session-123\",\n105:             base_url=\"http://router/v1/invocations/\",\n106:         )\n107:         mock_response = MagicMock()\n108:         mock_response.json.return_value = {\"exit_code\": 1, \"stderr\": \"error msg\"}\n109:         mock_response.raise_for_status = MagicMock()\n110:         client._request = MagicMock(return_value=mock_response)\n111: \n112:         with pytest.raises(CommandExecutionError) as exc_info:\n113:             client.execute_command(\"python3 script.py\")\n114:         assert exc_info.value.exit_code == 1\n115:         assert exc_info.value.stderr == \"error msg\"\n116: \n117:     def test_execute_command_list_input(self) -> None:\n118:         client = CodeInterpreterDataPlaneClient(\n119:             session_id=\"session-123\",\n120:             base_url=\"http://router/v1/invocations/\",\n121:         )\n122:         mock_response = MagicMock()\n123:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n124:         mock_response.raise_for_status = MagicMock()\n125:         client._request = MagicMock(return_value=mock_response)\n126: \n127:         client.execute_command([\"python3\", \"script.py\"])\n128:         call_args = client._request.call_args\n129:         import json\n130:         body = json.loads(call_args.args[2].decode())\n131:         assert body[\"command\"] == [\"python3\", \"script.py\"]\n132: \n133:     def test_execute_command_default_timeout(self) -> None:\n134:         client = CodeInterpreterDataPlaneClient(\n135:             session_id=\"session-123\",\n136:             base_url=\"http://router/v1/invocations/\",\n137:             timeout=120,\n138:         )\n139:         mock_response = MagicMock()\n140:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n141:         mock_response.raise_for_status = MagicMock()\n142:         client._request = MagicMock(return_value=mock_response)\n143: \n144:         client.execute_command(\"ls\")\n145:         call_args = client._request.call_args\n146:         import json\n147:         body = json.loads(call_args.args[2].decode())\n148:         assert body[\"timeout\"] == \"120s\"\n149:         assert call_args.kwargs[\"timeout_override\"] == 122.0\n150: \n151: \n152: class TestWriteFile:\n153:     def test_write_file_base64(self) -> None:\n154:         client = CodeInterpreterDataPlaneClient(\n155:             session_id=\"session-123\",\n156:             base_url=\"http://router/v1/invocations/\",\n157:         )\n158:         mock_response = MagicMock()\n159:         mock_response.raise_for_status = MagicMock()\n160:         client._request = MagicMock(return_value=mock_response)\n161: \n162:         client.write_file(\"hello world\", \"/workspace/test.py\")\n163:         call_args = client._request.call_args\n164:         import json\n165:         body = json.loads(call_args.args[2].decode())\n166:         expected_content = base64.b64encode(\"hello world\".encode()).decode()\n167:         assert body[\"content\"] == expected_content\n168: \n169:     def test_write_file_mode(self) -> None:\n170:         client = CodeInterpreterDataPlaneClient(\n171:             session_id=\"session-123\",\n172:             base_url=\"http://router/v1/invocations/\",\n173:         )\n174:         mock_response = MagicMock()\n175:         mock_response.raise_for_status = MagicMock()\n176:         client._request = MagicMock(return_value=mock_response)\n177: \n178:         client.write_file(\"content\", \"/workspace/test.py\")\n179:         call_args = client._request.call_args\n180:         import json\n181:         body = json.loads(call_args.args[2].decode())\n182:         assert body[\"mode\"] == \"0644\"\n183: \n184: \n185: class TestUploadFile:\n186:     def test_upload_file_multipart(self, tmp_path: Path) -> None:\n187:         client = CodeInterpreterDataPlaneClient(\n188:             session_id=\"session-123\",\n189:             base_url=\"http://router/v1/invocations/\",\n190:         )\n191:         local_file = tmp_path / \"test.txt\"\n192:         local_file.write_text(\"content\")\n193: \n194:         mock_response = MagicMock()\n195:         mock_response.raise_for_status = MagicMock()\n196:         client.session.post = MagicMock(return_value=mock_response)\n197: \n198:         client.upload_file(str(local_file), \"/workspace/test.txt\")\n199:         call_args = client.session.post.call_args\n200:         assert \"files\" in call_args.kwargs\n201:         assert \"data\" in call_args.kwargs\n202:         assert call_args.kwargs[\"data\"][\"path\"] == \"/workspace/test.txt\"\n203: \n204:     def test_upload_file_session_header(self, tmp_path: Path) -> None:\n205:         client = CodeInterpreterDataPlaneClient(\n206:             session_id=\"session-123\",\n207:             base_url=\"http://router/v1/invocations/\",\n208:         )\n209:         local_file = tmp_path / \"test.txt\"\n210:         local_file.write_text(\"content\")\n211: \n212:         mock_response = MagicMock()\n213:         mock_response.raise_for_status = MagicMock()\n214:         client.session.post = MagicMock(return_value=mock_response)\n215: \n216:         client.upload_file(str(local_file), \"/workspace/test.txt\")\n217:         call_args = client.session.post.call_args\n218:         assert call_args.kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"session-123\"\n219: \n220:     def test_upload_file_not_found(self) -> None:\n221:         client = CodeInterpreterDataPlaneClient(\n222:             session_id=\"session-123\",\n223:             base_url=\"http://router/v1/invocations/\",\n224:         )\n225: \n226:         with pytest.raises(FileNotFoundError):\n227:             client.upload_file(\"/nonexistent/file.txt\", \"/workspace/test.txt\")\n228: \n229: \n230: class TestDownloadFile:\n231:     def test_download_file_stream(self, tmp_path: Path) -> None:\n232:         client = CodeInterpreterDataPlaneClient(\n233:             session_id=\"session-123\",\n234:             base_url=\"http://router/v1/invocations/\",\n235:         )\n236:         local_file = tmp_path / \"downloaded.txt\"\n237: \n238:         mock_response = MagicMock()\n239:         mock_response.raise_for_status = MagicMock()\n240:         mock_response.iter_content = MagicMock(return_value=[b\"file content\"])\n241:         client.session.get = MagicMock(return_value=mock_response)\n242: \n243:         client.download_file(\"/workspace/source.txt\", str(local_file))\n244:         call_args = client.session.get.call_args\n245:         assert call_args.kwargs[\"stream\"] == True\n246:         assert local_file.read_text() == \"file content\"\n247: \n248:     def test_download_file_creates_parent_directory(self, tmp_path: Path) -> None:\n249:         client = CodeInterpreterDataPlaneClient(\n250:             session_id=\"session-123\",\n251:             base_url=\"http://router/v1/invocations/\",\n252:         )\n253:         local_file = tmp_path / \"subdir\" / \"downloaded.txt\"\n254: \n255:         mock_response = MagicMock()\n256:         mock_response.raise_for_status = MagicMock()\n257:         mock_response.iter_content = MagicMock(return_value=[b\"file content\"])\n258:         client.session.get = MagicMock(return_value=mock_response)\n259: \n260:         client.download_file(\"/workspace/source.txt\", str(local_file))\n261:         assert local_file.parent.exists()\n262:         assert local_file.read_text() == \"file content\"\n263: \n264:     def test_download_file_removes_leading_slash(self, tmp_path: Path) -> None:\n265:         client = CodeInterpreterDataPlaneClient(\n266:             session_id=\"session-123\",\n267:             base_url=\"http://router/v1/invocations/\",\n268:         )\n269:         local_file = tmp_path / \"downloaded.txt\"\n270: \n271:         mock_response = MagicMock()\n272:         mock_response.raise_for_status = MagicMock()\n273:         mock_response.iter_content = MagicMock(return_value=[b\"content\"])\n274:         client.session.get = MagicMock(return_value=mock_response)\n275: \n276:         client.download_file(\"/workspace/source.txt\", str(local_file))\n277:         call_args = client.session.get.call_args\n278:         assert \"source.txt\" in call_args.args[0]\n279: \n280:     def test_download_file_no_parent_dir(self, tmp_path: Path) -> None:\n281:         client = CodeInterpreterDataPlaneClient(\n282:             session_id=\"session-123\",\n283:             base_url=\"http://router/v1/invocations/\",\n284:         )\n285:         local_file = tmp_path / \"file.txt\"\n286: \n287:         mock_response = MagicMock()\n288:         mock_response.raise_for_status = MagicMock()\n289:         mock_response.iter_content = MagicMock(return_value=[b\"content\"])\n290:         client.session.get = MagicMock(return_value=mock_response)\n291: \n292:         client.download_file(\"/workspace/source.txt\", str(local_file))\n293:         assert local_file.exists()\n294:         assert local_file.read_text() == \"content\"\n295: \n296: \n297: class TestListFiles:\n298:     def test_list_files_query(self) -> None:\n299:         client = CodeInterpreterDataPlaneClient(\n300:             session_id=\"session-123\",\n301:             base_url=\"http://router/v1/invocations/\",\n302:         )\n303:         mock_response = MagicMock()\n304:         mock_response.json.return_value = {\"files\": [\"file1.py\", \"file2.py\"]}\n305:         mock_response.raise_for_status = MagicMock()\n306:         client.session.get = MagicMock(return_value=mock_response)\n307: \n308:         result = client.list_files(\"/workspace\")\n309:         call_args = client.session.get.call_args\n310:         assert call_args.kwargs[\"params\"][\"path\"] == \"/workspace\"\n311:         assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n312: \n313:     def test_list_files_default_path(self) -> None:\n314:         client = CodeInterpreterDataPlaneClient(\n315:             session_id=\"session-123\",\n316:             base_url=\"http://router/v1/invocations/\",\n317:         )\n318:         mock_response = MagicMock()\n319:         mock_response.json.return_value = {\"files\": []}\n320:         mock_response.raise_for_status = MagicMock()\n321:         client.session.get = MagicMock(return_value=mock_response)\n322: \n323:         result = client.list_files()\n324:         call_args = client.session.get.call_args\n325:         assert call_args.kwargs[\"params\"][\"path\"] == \".\"\n326: \n327: \n328: class TestClose:\n329:     def test_close_session(self) -> None:\n330:         client = CodeInterpreterDataPlaneClient(\n331:             session_id=\"session-123\",\n332:             base_url=\"http://router/v1/invocations/\",\n333:         )\n334:         mock_close = MagicMock()\n335:         client.session.close = mock_close\n336: \n337:         client.close()\n338:         mock_close.assert_called_once()\n\n(End of file - total 338 lines)\n</content>","metadata":{"preview":"import pytest\nfrom unittest.mock import MagicMock, patch, mock_open\nfrom pathlib import Path\nimport base64\nimport requests\n\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\nclass TestDataPlaneClientInit:\n    def test_init_with_session_id(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            router_url=\"http://router\",\n            namespace=\"default\",\n            cr_name=\"test-interpreter\",\n        )\n        assert client.session_id == \"session-123\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_data_plane.py","time":{"start":1775900341074,"end":1775900341097}}}}
