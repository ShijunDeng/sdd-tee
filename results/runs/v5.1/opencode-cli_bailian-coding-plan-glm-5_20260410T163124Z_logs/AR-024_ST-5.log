ain_py = tmp_path / \"main.py\"\n34:         main_py.write_text(\"print('hello')\")\n35: \n36:         runtime = BuildRuntime()\n37:         with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n38:             with pytest.raises(ValueError, match=\"Dockerfile not found\"):\n39:                 runtime._validate_build_prerequisites(tmp_path)\n40: \n41:     def test_validate_success(self, tmp_path: Path) -> None:\n42:         main_py = tmp_path / \"main.py\"\n43:         main_py.write_text(\"print('hello')\")\n44:         dockerfile = tmp_path / \"Dockerfile\"\n45:         dockerfile.write_text(\"FROM python:3.10-slim\")\n46: \n47:         runtime = BuildRuntime()\n48:         with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n49:             runtime._validate_build_prerequisites(tmp_path)\n50: \n51: \n52: class TestIncrementVersion:\n53:     def test_increment_semver(self, tmp_path: Path) -> None:\n54:         metadata_content = \"\"\"\n55: agent_name: test-agent\n56: language: python\n57: entrypoint: python main.py\n58: version: \"1.2.3\"\n59: \"\"\"\n60:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n61:         metadata_file.write_text(metadata_content)\n62: \n63:         runtime = BuildRuntime()\n64:         metadata = runtime._metadata_service.load_metadata(tmp_path)\n65:         new_tag = runtime._increment_version(tmp_path, metadata)\n66:         \n67:         assert new_tag == \"1.2.4\"\n68:         assert metadata.version == \"1.2.4\"\n69: \n70:     def test_increment_v_prefix_semver(self, tmp_path: Path) -> None:\n71:         metadata_content = \"\"\"\n72: agent_name: test-agent\n73: language: python\n74: entrypoint: python main.py\n75: version: \"v1.2.3\"\n76: \"\"\"\n77:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n78:         metadata_file.write_text(metadata_content)\n79: \n80:         runtime = BuildRuntime()\n81:         metadata = runtime._metadata_service.load_metadata(tmp_path)\n82:         new_tag = runtime._increment_version(tmp_path, metadata)\n83:         \n84:         assert new_tag == \"v1.2.4\"\n85: \n86:     def test_increment_v_prefix_non_semver(self, tmp_path: Path) -> None:\n87:         metadata_content = \"\"\"\n88: agent_name: test-agent\n89: language: python\n90: entrypoint: python main.py\n91: version: \"v1.0\"\n92: \"\"\"\n93:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n94:         metadata_file.write_text(metadata_content)\n95: \n96:         runtime = BuildRuntime()\n97:         metadata = runtime._metadata_service.load_metadata(tmp_path)\n98:         new_tag = runtime._increment_version(tmp_path, metadata)\n99:         \n100:         assert new_tag == \"v1.0.1\"\n101: \n102:     def test_increment_non_semver(self, tmp_path: Path) -> None:\n103:         metadata_content = \"\"\"\n104: agent_name: test-agent\n105: language: python\n106: entrypoint: python main.py\n107: version: \"custom\"\n108: \"\"\"\n109:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n110:         metadata_file.write_text(metadata_content)\n111: \n112:         runtime = BuildRuntime()\n113:         metadata = runtime._metadata_service.load_metadata(tmp_path)\n114:         new_tag = runtime._increment_version(tmp_path, metadata)\n115:         \n116:         assert new_tag == \"custom-1\"\n117: \n118:     def test_increment_empty_version(self, tmp_path: Path) -> None:\n119:         metadata_content = \"\"\"\n120: agent_name: test-agent\n121: language: python\n122: entrypoint: python main.py\n123: version: \"\"\n124: \"\"\"\n125:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n126:         metadata_file.write_text(metadata_content)\n127: \n128:         runtime = BuildRuntime()\n129:         metadata = runtime._metadata_service.load_metadata(tmp_path)\n130:         new_tag = runtime._increment_version(tmp_path, metadata)\n131:         \n132:         assert new_tag == DEFAULT_TAG\n133: \n134:     def test_increment_none_version(self, tmp_path: Path) -> None:\n135:         metadata_content = \"\"\"\n136: agent_name: test-agent\n137: language: python\n138: entrypoint: python main.py\n139: \"\"\"\n140:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n141:         metadata_file.write_text(metadata_content)\n142: \n143:         runtime = BuildRuntime()\n144:         metadata = runtime._metadata_service.load_metadata(tmp_path)\n145:         new_tag = runtime._increment_version(tmp_path, metadata)\n146:         \n147:         assert new_tag == DEFAULT_TAG\n148: \n149: \n150: class TestBuildLocal:\n151:     def test_build_local_success(self, tmp_path: Path) -> None:\n152:         metadata_content = \"\"\"\n153: agent_name: test-agent\n154: language: python\n155: entrypoint: python main.py\n156: version: \"1.0.0\"\n157: build_mode: local\n158: \"\"\"\n159:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n160:         metadata_file.write_text(metadata_content)\n161:         dockerfile = tmp_path / \"Dockerfile\"\n162:         dockerfile.write_text(\"FROM python:3.10-slim\")\n163: \n164:         runtime = BuildRuntime()\n165:         metadata = runtime._metadata_service.load_metadata(tmp_path)\n166: \n167:         mock_result = {\n168:             \"image_name\": \"test-agent\",\n169:             \"image_id\": \"sha256:abc123\",\n170:             \"image_size\": \"125.3 MB\",\n171:             \"build_time\": 10.5,\n172:             \"tag\": \"1.0.1\",\n173:         }\n174: \n175:         with patch.object(runtime._docker_service, 'build_image', return_value=mock_result):\n176:             result = runtime._build_local(tmp_path, metadata, {}, \"1.0.1\")\n177:             \n178:             assert result[\"image_name\"] == \"test-agent\"\n179:             assert result[\"image_id\"] == \"sha256:abc123\"\n180: \n181:     def test_build_local_with_proxy(self, tmp_path: Path) -> None:\n182:         metadata_content = \"\"\"\n183: agent_name: