adata(tmp_path)\n233: \n234:         result = runtime._build_cloud(tmp_path, metadata, {}, \"1.0.1\")\n235:         \n236:         assert result[\"image_name\"] == \"test-agent\"\n237:         assert result[\"image_id\"] == \"cloud-placeholder\"\n238:         assert result[\"image_size\"] == \"0 MB\"\n239: \n240: \n241: class TestUpdateBuildMetadata:\n242:     def test_update_build_metadata(self, tmp_path: Path) -> None:\n243:         metadata_content = \"\"\"\n244: agent_name: test-agent\n245: language: python\n246: entrypoint: python main.py\n247: version: \"1.0.1\"\n248: \"\"\"\n249:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n250:         metadata_file.write_text(metadata_content)\n251: \n252:         runtime = BuildRuntime()\n253:         metadata = runtime._metadata_service.load_metadata(tmp_path)\n254: \n255:         build_result = {\n256:             \"image_name\": \"test-agent\",\n257:             \"image_id\": \"sha256:abc123\",\n258:             \"image_size\": \"125.3 MB\",\n259:             \"build_time\": 10.5,\n260:         }\n261: \n262:         runtime._update_build_metadata(tmp_path, metadata, build_result, \"1.0.1\")\n263: \n264:         updated_metadata = runtime._metadata_service.load_metadata(tmp_path)\n265:         assert updated_metadata.image[\"image_name\"] == \"test-agent\"\n266:         assert updated_metadata.image[\"image_id\"] == \"sha256:abc123\"\n267:         assert updated_metadata.image[\"tag\"] == \"1.0.1\"\n268: \n269: \n270: class TestVersionRollback:\n271:     def test_version_rollback_on_failure(self, tmp_path: Path) -> None:\n272:         metadata_content = \"\"\"\n273: agent_name: test-agent\n274: language: python\n275: entrypoint: python main.py\n276: version: \"1.0.0\"\n277: \"\"\"\n278:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n279:         metadata_file.write_text(metadata_content)\n280:         dockerfile = tmp_path / \"Dockerfile\"\n281:         dockerfile.write_text(\"FROM python:3.10-slim\")\n282: \n283:         runtime = BuildRuntime()\n284: \n285:         with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n286:             with patch.object(runtime._docker_service, 'build_image', side_effect=Exception(\"Build error\")):\n287:                 with pytest.raises(RuntimeError, match=\"Build failed\"):\n288:                     runtime.build(tmp_path)\n289: \n290:         restored_metadata = runtime._metadata_service.load_metadata(tmp_path)\n291:         assert restored_metadata.version == \"1.0.0\"\n292: \n293: \n294: class TestBuildFullWorkflow:\n295:     def test_build_success(self, tmp_path: Path) -> None:\n296:         metadata_content = \"\"\"\n297: agent_name: test-agent\n298: language: python\n299: entrypoint: python main.py\n300: version: \"1.0.0\"\n301: build_mode: local\n302: \"\"\"\n303:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n304:         metadata_file.write_text(metadata_content)\n305:         dockerfile = tmp_path / \"Dockerfile\"\n306:         dockerfile.write_text(\"FROM python:3.10-slim\")\n307: \n308:         runtime = BuildRuntime()\n309: \n310:         mock_result = {\n311:             \"image_name\": \"test-agent\",\n312:             \"image_id\": \"sha256:abc123\",\n313:             \"image_size\": \"125.3 MB\",\n314:             \"build_time\": 10.5,\n315:             \"tag\": \"1.0.1\",\n316:         }\n317: \n318:         with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n319:             with patch.object(runtime._docker_service, 'build_image', return_value=mock_result):\n320:                 result = runtime.build(tmp_path)\n321: \n322:         assert result[\"status\"] == \"success\"\n323:         assert result[\"image_name\"] == \"test-agent\"\n324:         assert result[\"tag\"] == \"1.0.1\"\n325: \n326:         updated_metadata = runtime._metadata_service.load_metadata(tmp_path)\n327:         assert updated_metadata.version == \"1.0.1\"\n328:         assert updated_metadata.image[\"image_id\"] == \"sha256:abc123\"\n\n(End of file - total 328 lines)\n</content>","metadata":{"preview":"import pytest\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\nimport yaml\n\nfrom agentcube.runtime.build_runtime import BuildRuntime, DEFAULT_TAG\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestBuildRuntimeInit:\n    def test_init_default_verbose(self) -> None:\n        runtime = BuildRuntime()\n        assert runtime.verbose == False\n\n    def test_init_verbose_true(self) -> None:\n        runtime = BuildRuntime(verbose=True)\n        assert runtime.verbose == True\n\n\nclass TestValidateBuildPrerequisites:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_build_runtime.py","time":{"start":1775876244863,"end":1775876244916}}}}
