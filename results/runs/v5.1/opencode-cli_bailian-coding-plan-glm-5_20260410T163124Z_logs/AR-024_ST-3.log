"def __repr__\",\n52:     \"raise NotImplementedError\",\n53:     \"if __name__ == .__main__.:\",\n54: ]\n\n(End of file - total 54 lines)\n</content>","metadata":{"preview":"[project]\nname = \"kubectl-agentcube\"\nversion = \"0.1.0\"\ndescription = \"AgentCube CLI for agent lifecycle management\"\nreadme = \"README.md\"\nrequires-python = \">=3.9\"\nlicense = {text = \"MIT\"}\nauthors = [\n    {name = \"AgentCube Team\", email = \"team@agentcube.dev\"}\n]\ndependencies = [\n    \"typer[all]>=0.9.0\",\n    \"pydantic>=2.0.0\",\n    \"pyyaml>=6.0\",\n    \"rich>=13.0.0\",\n    \"docker>=6.0.0\",\n]\n\n[project.optional-dependencies]\ndev = [","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/pyproject.toml","time":{"start":1775875911116,"end":1775875911124}}}}
