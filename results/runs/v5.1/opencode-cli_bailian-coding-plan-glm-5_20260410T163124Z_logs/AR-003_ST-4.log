port.\ntype ProtocolType string\n\nconst (\n\tProtocolTypeHTTP  ProtocolType = \"HTTP\"\n\tProtocolTypeHTTPS ProtocolType = \"HTTPS\"\n)\n\n// AuthModeType defines the authentication mode for a CodeInterpreter.\ntype AuthModeType string\n\nconst (\n\tAuthModePicoD AuthModeType = \"picod\"\n\tAuthModeNone  AuthModeType = \"none\"\n)\n\n// TargetPort defines a network port configuration for exposing sandbox services.\ntype TargetPort struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/shared_types.go","time":{"start":1775840950698,"end":1775840950744}}}}
