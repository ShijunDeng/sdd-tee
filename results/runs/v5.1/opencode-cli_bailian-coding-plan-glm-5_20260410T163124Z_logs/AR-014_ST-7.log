     true,\n46: \t\tForceSingleClient: true,\n47: \t}\n48: \tstore, _ := newValkeyStore(opts)\n49: \treturn store\n50: }\n51: \n52: func NewValkeyStoreWithOptions(addr, password, sessionPrefix, expiryIndexKey, lastActivityIndexKey string) Store {\n53: \topts := &valkeyClientOption{\n54: \t\tInitAddress:       []string{addr},\n55: \t\tPassword:          password,\n56: \t\tDisableCache:      true,\n57: \t\tForceSingleClient: true,\n58: \t}\n59: \tstore, err := newValkeyStore(opts)\n60: \tif err != nil {\n61: \t\treturn nil\n62: \t}\n63: \tvs := store.(*valkeyStore)\n64: \tvs.sessionPrefix = sessionPrefix\n65: \tvs.expiryIndexKey = expiryIndexKey\n66: \tvs.lastActivityIndexKey = lastActivityIndexKey\n67: \treturn vs\n68: }\n69: \n70: func NewValkeyStoreWithClient(cli valkey.Client) Store {\n71: \treturn &valkeyStore{\n72: \t\tcli:                  cli,\n73: \t\tsessionPrefix:        defaultSessionPrefix,\n74: \t\texpiryIndexKey:       defaultExpiryIndexKey,\n75: \t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n76: \t}\n77: }\n78: \n79: func (s *valkeyStore) sessionKey(sessionID string) string {\n80: \treturn s.sessionPrefix + sessionID\n81: }\n82: \n83: func (s *valkeyStore) Ping(ctx context.Context) error {\n84: \tresp, err := s.cli.Do(ctx, s.cli.B().Ping().Build()).ToString()\n85: \tif err != nil {\n86: \t\treturn fmt.Errorf(\"store: ping failed: %w\", err)\n87: \t}\n88: \tif resp != \"PONG\" {\n89: \t\treturn fmt.Errorf(\"store: unexpected ping response: %s\", resp)\n90: \t}\n91: \treturn nil\n92: }\n93: \n94: func (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n95: \tif sessionID == \"\" {\n96: \t\treturn nil, ErrEmptySessionID\n97: \t}\n98: \n99: \tkey := s.sessionKey(sessionID)\n100: \tresp := s.cli.Do(ctx, s.cli.B().Get().Key(key).Build())\n101: \tif resp.Error() != nil {\n102: \t\tif valkey.IsValkeyNil(resp.Error()) {\n103: \t\t\treturn nil, ErrNotFound\n104: \t\t}\n105: \t\treturn nil, fmt.Errorf(\"store: get session %s: %w\", sessionID, resp.Error())\n106: \t}\n107: \n108: \tdata, err := resp.AsBytes()\n109: \tif err != nil {\n110: \t\treturn nil, fmt.Errorf(\"store: read bytes: %w\", err)\n111: \t}\n112: \n113: \tvar sandbox types.SandboxInfo\n114: \tif err := json.Unmarshal(data, &sandbox); err != nil {\n115: \t\treturn nil, fmt.Errorf(\"store: unmarshal session %s: %w\", sessionID, err)\n116: \t}\n117: \n118: \treturn &sandbox, nil\n119: }\n120: \n121: func (s *valkeyStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n122: \tif sandbox == nil {\n123: \t\treturn ErrNilSandbox\n124: \t}\n125: \tif sandbox.ExpiresAt.IsZero() {\n126: \t\treturn ErrZeroExpiresAt\n127: \t}\n128: \tif sandbox.SessionID == \"\" {\n129: \t\treturn ErrEmptySessionID\n130: \t}\n131: \n132: \tkey := s.sessionKey(sandbox.SessionID)\n133: \tdata, err := json.Marshal(sandbox)\n134: \tif err != nil {\n135: \t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n136: \t}\n137: \n138: \tnow := time.Now()\n139: \tif sandbox.LastActivity.IsZero() {\n140: \t\tsandbox.LastActivity = now\n141: \t}\n142: \n143: \tcmds := []valkey.Completed{\n144: \t\ts.cli.B().Setnx().Key(key).Value(string(data)).Build(),\n145: \t\ts.cli.B().Zadd().Key(s.expiryIndexKey).ScoreMember().ScoreMember(float64(sandbox.ExpiresAt.Unix()), sandbox.SessionID).Build(),\n146: \t\ts.cli.B().Zadd().Key(s.lastActivityIndexKey).ScoreMember().ScoreMember(float64(sandbox.LastActivity.Unix()), sandbox.SessionID).Build(),\n147: \t}\n148: \n149: \tresps := s.cli.DoMulti(ctx, cmds...)\n150: \n151: \tsetnxResult, err := resps[0].AsInt64()\n152: \tif err != nil || setnxResult == 0 {\n153: \t\treturn ErrSessionExists\n154: \t}\n155: \n156: \treturn nil\n157: }\n158: \n159: func (s *valkeyStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n160: \tif sandbox == nil {\n161: \t\treturn ErrNilSandbox\n162: \t}\n163: \tif sandbox.SessionID == \"\" {\n164: \t\treturn ErrEmptySessionID\n165: \t}\n166: \n167: \tkey := s.sessionKey(sandbox.SessionID)\n168: \n169: \texists := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build())\n170: \tif exists.Error() != nil {\n171: \t\treturn fmt.Errorf(\"store: check exists: %w\", exists.Error())\n172: \t}\n173: \tcount, err := exists.AsInt64()\n174: \tif err != nil {\n175: \t\treturn fmt.Errorf(\"store: parse exists: %w\", err)\n176: \t}\n177: \tif count == 0 {\n178: \t\treturn ErrNotFound\n179: \t}\n180: \n181: \tdata, err := json.Marshal(sandbox)\n182: \tif err != nil {\n183: \t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n184: \t}\n185: \n186: \tresp := s.cli.Do(ctx, s.cli.B().Set().Key(key).Value(string(data)).Build())\n187: \tif resp.Error() != nil {\n188: \t\treturn fmt.Errorf(\"store: update sandbox: %w\", resp.Error())\n189: \t}\n190: \n191: \treturn nil\n192: }\n193: \n194: func (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n195: \tif sessionID == \"\" {\n196: \t\treturn ErrEmptySessionID\n197: \t}\n198: \n199: \tkey := s.sessionKey(sessionID)\n200: \n201: \tcmds := []valkey.Completed{\n202: \t\ts.cli.B().Del().Key(key).Build(),\n203: \t\ts.cli.B().Zrem().Key(s.expiryIndexKey).Member(sessionID).Build(),\n204: \t\ts.cli.B().Zrem().Key(s.lastActivityIndexKey).Member(sessionID).Build(),\n205: \t}\n206: \n207: \ts.cli.DoMulti(ctx, cmds...)\n208: \n209: \treturn nil\n210: }\n211: \n212: func (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n213: \tif limit <= 0 {\n214: \t\treturn nil, nil\n215: \t}\n216: \n217: \tresp := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.expiryIndexKey).\n218: \t\tMin(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).\n219: \t\tLimit(0, limit).Build())\n220: \n221: \tif resp.Error() != nil {\n222: \t\treturn nil, fmt.Errorf(\"store: list expired: %w\", resp.Error())\n223: \t}\n224: \n225: \tsessionIDs, err := resp.AsStrSlice()\n226: \tif err != nil {\n227: \t\treturn nil, fmt.Errorf(\"store: parse session ids: %w\", err)\n228: \t}\n229: \tif len(sessionIDs) == 0 {\n230: \t\treturn nil, nil\n231: \t}\n232: \n233: \treturn s.batchGetSandboxes(ctx, sessionIDs)\n234: }\n235: \n236: func (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n237: \tif limit <= 0 {\n238: \t\treturn nil, nil\n239: \t}\n240: \n241: \tresp := s.cli.Do(ctx, s.cli.B().Zrangebyscore().Key(s.lastActivityIndexKey).\n242: \t\tMin(\"-inf\").Max(fmt.Sprintf(\"%d\", before.Unix())).\n243: \t\tLimit(0, limit).Build())\n244: \n245: \tif resp.Error() != nil {\n246: \t\treturn nil, fmt.Errorf(\"store: list inactive: %w\", resp.Error())\n247: \t}\n248: \n249: \tsessionIDs, err := resp.AsStrSlice()\n250: \tif err != nil {\n251: \t\treturn nil, fmt.Errorf(\"store: parse session ids: %w\", err)\n252: \t}\n253: \tif len(sessionIDs) == 0 {\n254: \t\treturn nil, nil\n255: \t}\n256: \n257: \treturn s.batchGetSandboxes(ctx, sessionIDs)\n258: }\n259: \n260: func (s *valkeyStore) batchGetSandboxes(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n261: \tkeys := make([]string, len(sessionIDs))\n262: \tfor i, id := range sessionIDs {\n263: \t\tkeys[i] = s.sessionKey(id)\n264: \t}\n265: \n266: \tresp := s.cli.Do(ctx, s.cli.B().Mget().Key(keys...).Build())\n267: \tif resp.Error() != nil {\n268: \t\treturn nil, fmt.Errorf(\"store: mget: %w\", resp.Error())\n269: \t}\n270: \n271: \tvalues, err := resp.AsStrSlice()\n272: \tif err != nil {\n273: \t\treturn nil, fmt.Errorf(\"store: parse mget values: %w\", err)\n274: \t}\n275: \n276: \tvar sandboxes []*types.SandboxInfo\n277: \tfor i, v := range values {\n278: \t\tif v == \"\" {\n279: \t\t\tcontinue\n280: \t\t}\n281: \t\tvar sandbox types.SandboxInfo\n282: \t\tif err := json.Unmarshal([]byte(v), &sandbox); err != nil {\n283: \t\t\tcontinue\n284: \t\t}\n285: \t\tsandbox.SessionID = sessionIDs[i]\n286: \t\tsandboxes = append(sandboxes, &sandbox)\n287: \t}\n288: \n289: \treturn sandboxes, nil\n290: }\n291: \n292: func (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n293: \tif sessionID == \"\" {\n294: \t\treturn ErrEmptySessionID\n295: \t}\n296: \n297: \tkey := s.sessionKey(sessionID)\n298: \n299: \texists := s.cli.Do(ctx, s.cli.B().Exists().Key(key).Build())\n300: \tif exists.Error() != nil {\n301: \t\treturn fmt.Errorf(\"store: check exists: %w\", exists.Error())\n302: \t}\n303: \tcount, err := exists.AsInt64()\n304: \tif err != nil {\n305: \t\treturn fmt.Errorf(\"store: parse exists: %w\", err)\n306: \t}\n307: \tif count == 0 {\n308: \t\treturn ErrNotFound\n309: \t}\n310: \n311: \tif at.IsZero() {\n312: \t\tat = time.Now()\n313: \t}\n314: \n315: \tresp := s.cli.Do(ctx, s.cli.B().Zadd().Key(s.lastActivityIndexKey).\n316: \t\tScoreMember().ScoreMember(float64(at.Unix()), sessionID).Build())\n317: \tif resp.Error() != nil {\n318: \t\treturn fmt.Errorf(\"store: update last activity: %w\", resp.Error())\n319: \t}\n320: \n321: \treturn nil\n322: }\n323: \n324: func (s *valkeyStore) Close() error {\n325: \ts.cli.Close()\n326: \treturn nil\n327: }\n\n(End of file - total 327 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype valkeyStore struct {\n\tcli                  valkey.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc newValkeyStore(opts *valkeyClientOption) (Store, error) {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_valkey.go","time":{"start":1775859954951,"end":1775859954973}}}}
