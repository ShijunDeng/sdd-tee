ank().Key(store.lastActivityIndexKey).Member(\"session-123\").Build())\n216: \tassert.True(t, valkey.IsValkeyNil(resp.Error()))\n217: }\n218: \n219: func TestValkeyStore_DeleteSandboxBySessionID_NotFound(t *testing.T) {\n220: \tstore := setupTestValkeyStore(t)\n221: \tctx := context.Background()\n222: \n223: \terr := store.DeleteSandboxBySessionID(ctx, \"non-existent\")\n224: \tassert.NoError(t, err)\n225: }\n226: \n227: func TestValkeyStore_DeleteSandboxBySessionID_EmptySessionID(t *testing.T) {\n228: \tstore := setupTestValkeyStore(t)\n229: \tctx := context.Background()\n230: \n231: \terr := store.DeleteSandboxBySessionID(ctx, \"\")\n232: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n233: }\n234: \n235: func TestValkeyStore_ListExpiredSandboxes_Success(t *testing.T) {\n236: \tstore := setupTestValkeyStore(t)\n237: \tctx := context.Background()\n238: \n239: \tnow := time.Now()\n240: \n241: \texpiredSandbox := &types.SandboxInfo{\n242: \t\tKind:             types.AgentRuntimeKind,\n243: \t\tSandboxID:        \"sb-expired\",\n244: \t\tSandboxNamespace: \"default\",\n245: \t\tSessionID:        \"session-expired\",\n246: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n247: \t\tExpiresAt:        now.Add(-2 * time.Hour),\n248: \t\tStatus:           \"active\",\n249: \t\tLastActivity:     now.Add(-10 * time.Hour),\n250: \t}\n251: \n252: \tactiveSandbox := &types.SandboxInfo{\n253: \t\tKind:             types.AgentRuntimeKind,\n254: \t\tSandboxID:        \"sb-active\",\n255: \t\tSandboxNamespace: \"default\",\n256: \t\tSessionID:        \"session-active\",\n257: \t\tCreatedAt:        now,\n258: \t\tExpiresAt:        now.Add(8 * time.Hour),\n259: \t\tStatus:           \"active\",\n260: \t\tLastActivity:     now,\n261: \t}\n262: \n263: \terr := store.StoreSandbox(ctx, expiredSandbox)\n264: \trequire.NoError(t, err)\n265: \terr = store.StoreSandbox(ctx, activeSandbox)\n266: \trequire.NoError(t, err)\n267: \n268: \tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n269: \trequire.NoError(t, err)\n270: \tassert.Len(t, results, 1)\n271: \tassert.Equal(t, \"session-expired\", results[0].SessionID)\n272: }\n273: \n274: func TestValkeyStore_ListExpiredSandboxes_Limit(t *testing.T) {\n275: \tstore := setupTestValkeyStore(t)\n276: \tctx := context.Background()\n277: \n278: \tnow := time.Now()\n279: \n280: \tfor i := 0; i < 20; i++ {\n281: \t\tsandbox := &types.SandboxInfo{\n282: \t\t\tKind:             types.AgentRuntimeKind,\n283: \t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n284: \t\t\tSandboxNamespace: \"default\",\n285: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n286: \t\t\tCreatedAt:        now.Add(-10 * time.Hour),\n287: \t\t\tExpiresAt:        now.Add(-time.Duration(i+1) * time.Hour),\n288: \t\t\tStatus:           \"active\",\n289: \t\t\tLastActivity:     now.Add(-10 * time.Hour),\n290: \t\t}\n291: \t\terr := store.StoreSandbox(ctx, sandbox)\n292: \t\trequire.NoError(t, err)\n293: \t}\n294: \n295: \tresults, err := store.ListExpiredSandboxes(ctx, now, 5)\n296: \trequire.NoError(t, err)\n297: \tassert.Len(t, results, 5)\n298: }\n299: \n300: func TestValkeyStore_ListExpiredSandboxes_ZeroLimit(t *testing.T) {\n301: \tstore := setupTestValkeyStore(t)\n302: \tctx := context.Background()\n303: \n304: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n305: \trequire.NoError(t, err)\n306: \tassert.Nil(t, results)\n307: }\n308: \n309: func TestValkeyStore_ListExpiredSandboxes_NegativeLimit(t *testing.T) {\n310: \tstore := setupTestValkeyStore(t)\n311: \tctx := context.Background()\n312: \n313: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n314: \trequire.NoError(t, err)\n315: \tassert.Nil(t, results)\n316: }\n317: \n318: func TestValkeyStore_ListExpiredSandboxes_SkipMissing(t *testing.T) {\n319: \tstore := setupTestValkeyStore(t)\n320: \tctx := context.Background()\n321: \n322: \tnow := time.Now()\n323: \n324: \terr := store.cli.Do(ctx, store.cli.B().Zadd().Key(store.expiryIndexKey).\n325: \t\tScoreMember().ScoreMember(float64(now.Add(-1*time.Hour).Unix()), \"orphan-session\").Build()).Error()\n326: \trequire.NoError(t, err)\n327: \n328: \tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n329: \trequire.NoError(t, err)\n330: \tassert.Len(t, results, 0)\n331: }\n332: \n333: func TestValkeyStore_ListExpiredSandboxes_Empty(t *testing.T) {\n334: \tstore := setupTestValkeyStore(t)\n335: \tctx := context.Background()\n336: \n337: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 10)\n338: \trequire.NoError(t, err)\n339: \tassert.Nil(t, results)\n340: }\n341: \n342: func TestValkeyStore_ListInactiveSandboxes_Success(t *testing.T) {\n343: \tstore := setupTestValkeyStore(t)\n344: \tctx := context.Background()\n345: \n346: \tnow := time.Now()\n347: \n348: \tinactiveSandbox := &types.SandboxInfo{\n349: \t\tKind:             types.AgentRuntimeKind,\n350: \t\tSandboxID:        \"sb-inactive\",\n351: \t\tSandboxNamespace: \"default\",\n352: \t\tSessionID:        \"session-inactive\",\n353: \t\tCreatedAt:        now,\n354: \t\tExpiresAt:        now.Add(8 * time.Hour),\n355: \t\tStatus:           \"active\",\n356: \t\tLastActivity:     now.Add(-30 * time.Minute),\n357: \t}\n358: \n359: \tactiveSandbox := &types.SandboxInfo{\n360: \t\tKind:             types.AgentRuntimeKind,\n361: \t\tSandboxID:        \"sb-active\",\n362: \t\tSandboxNamespace: \"default\",\n363: \t\tSessionID:        \"session-active\",\n364: \t\tCreatedAt:        now,\n365: \t\tExpiresAt:        now.Add(8 * time.Hour),\n366: \t\tStatus:           \"active\",\n367: \t\tLastActivity:     now,\n368: \t}\n369: \n370: \terr := store.StoreSandbox(ctx, inactiveSandbox)\n371: \trequire.NoError(t, err)\n372: \terr = store.StoreSandbox(ctx, activeSandbox)\n373: \trequire.NoError(t, err)\n374: \n375: \tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 10)\n376: \trequire.NoError(t, err)\n377: \tassert.Len(t, results, 1)\n378: \tassert.Equal(t, \"session-inactive\", results[0].SessionID)\n379: }\n380: \n381: func TestValkeyStore_ListInactiveSandboxes_Limit(t *testing.T) {\n382: \tstore := setupTestValkeyStore(t)\n383: \tctx := context.Background()\n384: \n385: \tnow := time.Now()\n386: \n387: \tfor i := 0; i < 20; i++ {\n388: \t\tsandbox := &types.SandboxInfo{\n389: \t\t\tKind:             types.AgentRuntimeKind,\n390: \t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n391: \t\t\tSandboxNamespace: \"default\",\n392: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n393: \t\t\tCreatedAt:        now,\n394: \t\t\tExpiresAt:        now.Add(8 * time.Hour),\n395: \t\t\tStatus:           \"active\",\n396: \t\t\tLastActivity:     now.Add(-time.Duration(i+20) * time.Minute),\n397: \t\t}\n398: \t\terr := store.StoreSandbox(ctx, sandbox)\n399: \t\trequire.NoError(t, err)\n400: \t}\n401: \n402: \tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 5)\n403: \trequire.NoError(t, err)\n404: \tassert.Len(t, results, 5)\n405: }\n406: \n407: func TestValkeyStore_ListInactiveSandboxes_ZeroLimit(t *testing.T) {\n408: \tstore := setupTestValkeyStore(t)\n409: \tctx := context.Background()\n410: \n411: \tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n412: \trequire.NoError(t, err)\n413: \tassert.Nil(t, results)\n414: }\n415: \n416: func TestValkeyStore_ListInactiveSandboxes_Empty(t *testing.T) {\n417: \tstore := setupTestValkeyStore(t)\n418: \tctx := context.Background()\n419: \n420: \tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 10)\n421: \trequire.NoError(t, err)\n422: \tassert.Nil(t, results)\n423: }\n424: \n425: func TestValkeyStore_UpdateSessionLastActivity_Success(t *testing.T) {\n426: \tstore := setupTestValkeyStore(t)\n427: \tctx := context.Background()\n428: \n429: \tsandbox := makeTestSandbox(\"session-123\")\n430: \terr := store.StoreSandbox(ctx, sandbox)\n431: \trequire.NoError(t, err)\n432: \n433: \tnewActivity := time.Now().Add(1 * time.Hour)\n434: \terr = store.UpdateSessionLastActivity(ctx, \"session-123\", newActivity)\n435: \trequire.NoError(t, err)\n436: \n437: \tresp := store.cli.Do(ctx, store.cli.B().Zscore().Key(store.lastActivityIndexKey).Member(\"session-123\").Build())\n438: \trequire.NoError(t, resp.Error())\n439: \tscore, err := resp.AsFloat64()\n440: \trequire.NoError(t, err)\n441: \tassert.Equal(t, float64(newActivity.Unix()), score)\n442: }\n443: \n444: func TestValkeyStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n445: \tstore := setupTestValkeyStore(t)\n446: \tctx := context.Background()\n447: \n448: \tsandbox := makeTestSandbox(\"session-123\")\n449: \terr := store.StoreSandbox(ctx, sandbox)\n450: \trequire.NoError(t, err)\n451: \n452: \tbefore := time.Now()\n453: \terr = store.UpdateSessionLastActivity(ctx, \"session-123\", time.Time{})\n454: \trequire.NoError(t, err)\n455: \n456: \tresp := store.cli.Do(ctx, store.cli.B().Zscore().Key(store.lastActivityIndexKey).Member(\"session-123\").Build())\n457: \trequire.NoError(t, resp.Error())\n458: \tscore, err := resp.AsFloat64()\n459: \trequire.NoError(t, err)\n460: \tassert.GreaterOrEqual(t, score, float64(before.Unix()))\n461: }\n462: \n463: func TestValkeyStore_UpdateSessionLastActivity_NotFound(t *testing.T) {\n464: \tstore := setupTestValkeyStore(t)\n465: \tctx := context.Background()\n466: \n467: \terr := store.UpdateSessionLastActivity(ctx, \"non-existent\", time.Now())\n468: \tassert.ErrorIs(t, err, ErrNotFound)\n469: }\n470: \n471: func TestValkeyStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n472: \tstore := setupTestValkeyStore(t)\n473: \tctx := context.Background()\n474: \n475: \terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n476: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n477: }\n478: \n479: func TestValkeyStore_Close(t *testing.T) {\n480: \tmr := miniredis.RunT(t)\n481: \tcli, err := valkey.NewClient(valkey.ClientOption{\n482: \t\tInitAddress:       []string{mr.Addr()},\n483: \t\tDisableCache:      true,\n484: \t\tForceSingleClient: true,\n485: \t})\n486: \trequire.NoError(t, err)\n487: \tstore := &valkeyStore{\n488: \t\tcli:                  cli,\n489: \t\tsessionPrefix:        defaultSessionPrefix,\n490: \t\texpiryIndexKey:       defaultExpiryIndexKey,\n491: \t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n492: \t}\n493: \n494: \terr = store.Close()\n495: \trequire.NoError(t, err)\n496: }\n497: \n498: func TestNewValkeyStore(t *testing.T) {\n499: \tmr := miniredis.RunT(t)\n500: \tstore := NewValkeyStore(mr.Addr(), \"\")\n501: \n502: \trequire.NotNil(t, store)\n503: \n504: \tctx := context.Background()\n505: \terr := store.Ping(ctx)\n506: \trequire.NoError(t, err)\n507: \n508: \terr = store.Close()\n509: \trequire.NoError(t, err)\n510: }\n511: \n512: func TestNewValkeyStoreWithOptions(t *testing.T) {\n513: \tmr := miniredis.RunT(t)\n514: \tstore := NewValkeyStoreWithOptions(mr.Addr(), \"\", \"custom:\", \"custom:expiry\", \"custom:activity\")\n515: \n516: \trequire.NotNil(t, store)\n517: \n518: \tvs := store.(*valkeyStore)\n519: \tassert.Equal(t, \"custom:\", vs.sessionPrefix)\n520: \tassert.Equal(t, \"custom:expiry\", vs.expiryIndexKey)\n521: \tassert.Equal(t, \"custom:activity\", vs.lastActivityIndexKey)\n522: \n523: \terr := store.Close()\n524: \trequire.NoError(t, err)\n525: }\n526: \n527: func TestNewValkeyStoreWithClient(t *testing.T) {\n528: \tmr := miniredis.RunT(t)\n529: \tcli, err := valkey.NewClient(valkey.ClientOption{\n530: \t\tInitAddress:       []string{mr.Addr()},\n531: \t\tDisableCache:      true,\n532: \t\tForceSingleClient: true,\n533: \t})\n534: \trequire.NoError(t, err)\n535: \n536: \tstore := NewValkeyStoreWithClient(cli)\n537: \trequire.NotNil(t, store)\n538: \n539: \tctx := context.Background()\n540: \terr = store.Ping(ctx)\n541: \trequire.NoError(t, err)\n542: }\n543: \n544: func TestValkeyStore_ErrorHandling(t *testing.T) {\n545: \tstore := setupTestValkeyStore(t)\n546: \tctx := context.Background()\n547: \n548: \tkey := store.sessionKey(\"test-session\")\n549: \tstore.cli.Do(ctx, store.cli.B().Set().Key(key).Value(\"invalid-json\").Build())\n550: \n551: \tresult, err := store.GetSandboxBySessionID(ctx, \"test-session\")\n552: \tassert.Nil(t, result)\n553: \tassert.Error(t, err)\n554: \tassert.False(t, errors.Is(err, ErrNotFound))\n555: }\n556: \n557: func TestValkeyStore_SessionKey(t *testing.T) {\n558: \tstore := setupTestValkeyStore(t)\n559: \tkey := store.sessionKey(\"test-id\")\n560: \tassert.Equal(t, \"session:test-id\", key)\n561: }\n562: \n563: func TestValkeyStore_MgetWithMissingKeys(t *testing.T) {\n564: \tstore := setupTestValkeyStore(t)\n565: \tctx := context.Background()\n566: \n567: \tnow := time.Now()\n568: \tsandbox := makeTestSandbox(\"session-1\")\n569: \terr := store.StoreSandbox(ctx, sandbox)\n570: \trequire.NoError(t, err)\n571: \n572: \tstore.cli.Do(ctx, store.cli.B().Zadd().Key(store.expiryIndexKey).\n573: \t\tScoreMember().ScoreMember(float64(now.Add(-1*time.Hour).Unix()), \"missing-session\").Build())\n574: \n575: \tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n576: \trequire.NoError(t, err)\n577: \tassert.Len(t, results, 1)\n578: \tassert.Equal(t, \"session-1\", results[0].SessionID)\n579: }\n580: \n581: func TestValkeyStore_BatchGetWithUnmarshalError(t *testing.T) {\n582: \tstore := setupTestValkeyStore(t)\n583: \tctx := context.Background()\n584: \n585: \tnow := time.Now()\n586: \n587: \tvalidSandbox := makeTestSandbox(\"session-valid\")\n588: \terr := store.StoreSandbox(ctx, validSandbox)\n589: \trequire.NoError(t, err)\n590: \n591: \tstore.cli.Do(ctx, store.cli.B().Zadd().Key(store.expiryIndexKey).\n592: \t\tScoreMember().ScoreMember(float64(now.Add(-1*time.Hour).Unix()), \"session-invalid\").Build())\n593: \n594: \tstore.cli.Do(ctx, store.cli.B().Set().Key(store.sessionKey(\"session-invalid\")).Value(\"not-json\").Build())\n595: \n596: \tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n597: \trequire.NoError(t, err)\n598: \tassert.Len(t, results, 1)\n599: \tassert.Equal(t, \"session-valid\", results[0].SessionID)\n600: }\n\n(End of file - total 600 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/valkey-io/valkey-go\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc setupTestValkeyStore(t *testing.T) *valkeyStore {\n\tmr := miniredis.RunT(t)\n\tcli, err := valkey.NewClient(valkey.ClientOption{\n\t\tInitAddress:       []string{mr.Addr()},","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/valkey_test.go","time":{"start":1775859954953,"end":1775859954975}}}}
