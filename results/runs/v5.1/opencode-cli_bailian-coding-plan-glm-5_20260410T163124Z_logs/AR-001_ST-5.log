t\tPathPrefix: \"/api\",\n\t\t\t\t\t\t\tName:       \"api-port\",\n\t\t\t\t\t\t\tPort:       8080,\n\t\t\t\t\t\t\tProtocol:   ProtocolTypeHTTP,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\t\t\"pod-label\": \"value\",\n\t\t\t\t\t\t},\n\t\t\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\t\t\"pod-annotation\": \"value\",\n\t\t\t\t\t\t},\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"container\",\n\t\t\t\t\t\t\t\t\tImage: \"image:latest\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\t\t},\n\t\t\t\tStatus: AgentRuntimeStatus{\n\t\t\t\t\tConditions: []metav1.Condition{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tType:   \"Ready\",\n\t\t\t\t\t\t\tStatus: metav1.ConditionTrue,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tcopy := tt.ar.DeepCopy()\n\t\t\tif tt.ar == nil {\n\t\t\t\tif copy != nil {\n\t\t\t\t\tt.Errorf(\"expected nil, got non-nil\")\n\t\t\t\t}\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif copy == nil {\n\t\t\t\tt.Errorf(\"expected non-nil, got nil\")\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif copy == tt.ar {\n\t\t\t\tt.Errorf(\"expected different pointer, got same pointer\")\n\t\t\t}\n\t\t\tif copy.Name != tt.ar.Name {\n\t\t\t\tt.Errorf(\"expected Name %s, got %s\", tt.ar.Name, copy.Name)\n\t\t\t}\n\t\t\tif len(copy.Spec.Ports) != len(tt.ar.Spec.Ports) {\n\t\t\t\tt.Errorf(\"expected Ports length %d, got %d\", len(tt.ar.Spec.Ports), len(copy.Spec.Ports))\n\t\t\t}\n\t\t\tif copy.Spec.SessionTimeout.Duration != tt.ar.Spec.SessionTimeout.Duration {\n\t\t\t\tt.Errorf(\"expected SessionTimeout %v, got %v\", tt.ar.Spec.SessionTimeout.Duration, copy.Spec.SessionTimeout.Duration)\n\t\t\t}\n\t\t\tif len(copy.Status.Conditions) != len(tt.ar.Status.Conditions) {\n\t\t\t\tt.Errorf(\"expected Conditions length %d, got %d\", len(tt.ar.Status.Conditions), len(copy.Status.Conditions))\n\t\t\t}\n\t\t\tif copy.Spec.Template.Labels[\"pod-label\"] != tt.ar.Spec.Template.Labels[\"pod-label\"] {\n\t\t\t\tt.Errorf(\"expected Template Labels to match\")\n\t\t\t}\n\t\t\tcopy.Spec.Template.Labels[\"pod-label\"] = \"modified\"\n\t\t\tif tt.ar.Spec.Template.Labels[\"pod-label\"] == \"modified\" {\n\t\t\t\tt.Errorf(\"DeepCopy should be deep, modifying copy should not affect original\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAgentRuntimeListDeepCopy(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\tarl  *AgentRuntimeList\n\t}{\n\t\t{\n\t\t\tname: \"nil\",\n\t\t\tarl:  nil,\n\t\t},\n\t\t{\n\t\t\tname: \"empty\",\n\t\t\tarl:  &AgentRuntimeList{},\n\t\t},\n\t\t{\n\t\t\tname: \"full\",\n\t\t\tarl: &AgentRuntimeList{\n\t\t\t\tTypeMeta: metav1.TypeMeta{\n\t\t\t\t\tKind:       AgentRuntimeListKind,\n\t\t\t\t\tAPIVersion: GroupVersion.String(),\n\t\t\t\t},\n\t\t\t\tListMeta: metav1.ListMeta{},\n\t\t\t\tItems: []AgentRuntime{\n\t\t\t\t\t{\n\t\t\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"item1\"},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"item2\"},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tcopy := tt.arl.DeepCopy()\n\t\t\tif tt.arl == nil {\n\t\t\t\tif copy != nil {\n\t\t\t\t\tt.Errorf(\"expected nil, got non-nil\")\n\t\t\t\t}\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif copy == nil {\n\t\t\t\tt.Errorf(\"expected non-nil, got nil\")\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif len(copy.Items) != len(tt.arl.Items) {\n\t\t\t\tt.Errorf(\"expected Items length %d, got %d\", len(tt.arl.Items), len(copy.Items))\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestAgentRuntimeDeepCopyObject(t *testing.T) {\n\tar := &AgentRuntime{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test\"},\n\t}\n\tobj := ar.DeepCopyObject()\n\tif obj == nil {\n\t\tt.Errorf(\"expected non-nil, got nil\")\n\t}\n\tif obj.(*AgentRuntime).Name != \"test\" {\n\t\tt.Errorf(\"expected Name 'test', got %s\", obj.(*AgentRuntime).Name)\n\t}\n}\n\nfunc TestCodeInterpreterDeepCopy(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\tci   *CodeInterpreter\n\t}{\n\t\t{\n\t\t\tname: \"nil\",\n\t\t\tci:   nil,\n\t\t},\n\t\t{\n\t\t\tname: \"empty\",\n\t\t\tci:   &CodeInterpreter{},\n\t\t},\n\t\t{\n\t\t\tname: \"full\",\n\t\t\tci: &CodeInterpreter{\n\t\t\t\tTypeMeta: metav1.TypeMeta{\n\t\t\t\t\tKind:       CodeInterpreterKind,\n\t\t\t\t\tAPIVersion: GroupVersion.String(),\n\t\t\t\t},\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"test-codeinterpreter\",\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t},\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tPorts: []TargetPort{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPort:     8080,\n\t\t\t\t\t\t\tProtocol: ProtocolTypeHTTP,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n\t\t\t\t\t\tImage:           \"python:latest\",\n\t\t\t\t\t\tImagePullPolicy: corev1.PullIfNotPresent,\n\t\t\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\t\t\"app\": \"code-interpreter\",\n\t\t\t\t\t\t},\n\t\t\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\t\t\"annotation\": \"value\",\n\t\t\t\t\t\t},\n\t\t\t\t\t\tRuntimeClassName: ptr(\"runc\"),\n\t\t\t\t\t\tCommand:          []string{\"python\"},\n\t\t\t\t\t\tArgs:             []string{\"-m\", \"app\"},\n\t\t\t\t\t\tEnvironment: []corev1.EnvVar{\n\t\t\t\t\t\t\t{Name: \"ENV\", Value: \"test\"},\n\t\t\t\t\t\t},\n\t\t\t\t\t\tResources: corev1.ResourceRequirements{\n\t\t\t\t\t\t\tLimits: corev1.ResourceList{},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\t\t\tWarmPoolSize:       ptrInt32(5),\n\t\t\t\t\tAuthMode:           AuthModePicoD,\n\t\t\t\t},\n\t\t\t\tStatus: CodeInterpreterStatus{\n\t\t\t\t\tConditions: []metav1.Condition{\n\t\t\t\t\t\t{Type: \"Ready\", Status: metav1.ConditionTrue},\n\t\t\t\t\t},\n\t\t\t\t\tReady: true,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tcopy := tt.ci.DeepCopy()\n\t\t\tif tt.ci == nil {\n\t\t\t\tif copy != nil {\n\t\t\t\t\tt.Errorf(\"expected nil, got non-nil\")\n\t\t\t\t}\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif copy == nil {\n\t\t\t\tt.Errorf(\"expected non-nil, got nil\")\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif copy == tt.ci {\n\t\t\t\tt.Errorf(\"expected different pointer, got same pointer\")\n\t\t\t}\n\t\t\tif copy.Spec.AuthMode != tt.ci.Spec.AuthMode {\n\t\t\t\tt.Errorf(\"expected AuthMode %s, got %s\", tt.ci.Spec.AuthMode, copy.Spec.AuthMode)\n\t\t\t}\n\t\t\tif *copy.Spec.WarmPoolSize != *tt.ci.Spec.WarmPoolSize {\n\t\t\t\tt.Errorf(\"expected WarmPoolSize %d, got %d\", *tt.ci.Spec.WarmPoolSize, *copy.Spec.WarmPoolSize)\n\t\t\t}\n\t\t\tif copy.Spec.Template.Image != tt.ci.Spec.Template.Image {\n\t\t\t\tt.Errorf(\"expected Template Image %s, got %s\", tt.ci.Spec.Template.Image, copy.Spec.Template.Image)\n\t\t\t}\n\t\t\tif len(copy.Spec.Template.Command) != len(tt.ci.Spec.Template.Command) {\n\t\t\t\tt.Errorf(\"expected Command length %d, got %d\", len(tt.ci.Spec.Template.Command), len(copy.Spec.Template.Command))\n\t\t\t}\n\t\t\tif copy.Status.Ready != tt.ci.Status.Ready {\n\t\t\t\tt.Errorf(\"expected Ready %v, got %v\", tt.ci.Status.Ready, copy.Status.Ready)\n\t\t\t}\n\t\t\tcopy.Spec.Template.Labels[\"app\"] = \"modified\"\n\t\t\tif tt.ci.Spec.Template.Labels[\"app\"] == \"modified\" {\n\t\t\t\tt.Errorf(\"DeepCopy should be deep, modifying copy should not affect original\")\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCodeInterpreterListDeepCopy(t *testing.T) {\n\tcil := &CodeInterpreterList{\n\t\tItems: []CodeInterpreter{\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"item1\"}},\n\t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"item2\"}},\n\t\t},\n\t}\n\tcopy := cil.DeepCopy()\n\tif len(copy.Items) != len(cil.Items) {\n\t\tt.Errorf(\"expected Items length %d, got %d\", len(cil.Items), len(copy.Items))\n\t}\n}\n\nfunc TestCodeInterpreterDeepCopyObject(t *testing.T) {\n\tci := &CodeInterpreter{\n\t\tObjectMeta: metav1.ObjectMeta{Name: \"test\"},\n\t}\n\tobj := ci.DeepCopyObject()\n\tif obj == nil {\n\t\tt.Errorf(\"expected non-nil, got nil\")\n\t}\n\tif obj.(*CodeInterpreter).Name != \"test\" {\n\t\tt.Errorf(\"expected Name 'test', got %s\", obj.(*CodeInterpreter).Name)\n\t}\n}\n\nfunc TestTargetPortDeepCopy(t *testing.T) {\n\ttp := &TargetPort{\n\t\tPathPrefix: \"/api\",\n\t\tName:       \"api\",\n\t\tPort:       8080,\n\t\tProtocol:   ProtocolTypeHTTP,\n\t}\n\tcopy := tp.DeepCopy()\n\tif copy.PathPrefix != tp.PathPrefix {\n\t\tt.Errorf(\"expected PathPrefix %s, got %s\", tp.PathPrefix, copy.PathPrefix)\n\t}\n\tif copy.Port != tp.Port {\n\t\tt.Errorf(\"expected Port %d, got %d\", tp.Port, copy.Port)\n\t}\n}\n\nfunc TestSandboxTemplateDeepCopy(t *testing.T) {\n\tst := &SandboxTemplate{\n\t\tLabels:      map[string]string{\"label\": \"value\"},\n\t\tAnnotations: map[string]string{\"annotation\": \"value\"},\n\t\tSpec: corev1.PodSpec{\n\t\t\tContainers: []corev1.Container{{Name: \"container\"}},\n\t\t},\n\t}\n\tcopy := st.DeepCopy()\n\tcopy.Labels[\"label\"] = \"modified\"\n\tif st.Labels[\"label\"] == \"modified\" {\n\t\tt.Errorf(\"DeepCopy should be deep, modifying copy should not affect original\")\n\t}\n}\n\nfunc TestCodeInterpreterSandboxTemplateDeepCopy(t *testing.T) {\n\tcist := &CodeInterpreterSandboxTemplate{\n\t\tLabels:           map[string]string{\"label\": \"value\"},\n\t\tAnnotations:      map[string]string{\"annotation\": \"value\"},\n\t\tRuntimeClassName: ptr(\"runc\"),\n\t\tImage:            \"python:latest\",\n\t\tImagePullPolicy:  corev1.PullIfNotPresent,\n\t\tImagePullSecrets: []corev1.LocalObjectReference{{Name: \"secret\"}},\n\t\tEnvironment:      []corev1.EnvVar{{Name: \"ENV\", Value: \"val\"}},\n\t\tCommand:          []string{\"cmd\"},\n\t\tArgs:             []string{\"arg\"},\n\t\tResources:        corev1.ResourceRequirements{},\n\t}\n\tcopy := cist.DeepCopy()\n\tif copy.Image != cist.Image {\n\t\tt.Errorf(\"expected Image %s, got %s\", cist.Image, copy.Image)\n\t}\n\tcopy.Labels[\"label\"] = \"modified\"\n\tif cist.Labels[\"label\"] == \"modified\" {\n\t\tt.Errorf(\"DeepCopy should be deep\")\n\t}\n\t*copy.RuntimeClassName = \"modified\"\n\tif *cist.RuntimeClassName == \"modified\" {\n\t\tt.Errorf(\"DeepCopy should be deep for RuntimeClassName\")\n\t}\n}\n\nfunc TestAuthModeTypeConstants(t *testing.T) {\n\tif AuthModePicoD != \"picod\" {\n\t\tt.Errorf(\"expected AuthModePicoD to be 'picod', got '%s'\", AuthModePicoD)\n\t}\n\tif AuthModeNone != \"none\" {\n\t\tt.Errorf(\"expected AuthModeNone to be 'none', got '%s'\", AuthModeNone)\n\t}\n}\n\nfunc TestProtocolTypeConstants(t *testing.T) {\n\tif ProtocolTypeHTTP != \"HTTP\" {\n\t\tt.Errorf(\"expected ProtocolTypeHTTP to be 'HTTP', got '%s'\", ProtocolTypeHTTP)\n\t}\n\tif ProtocolTypeHTTPS != \"HTTPS\" {\n\t\tt.Errorf(\"expected ProtocolTypeHTTPS to be 'HTTPS', got '%s'\", ProtocolTypeHTTPS)\n\t}\n}\n\nfunc TestJSONSerialization(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tobj      runtime.Object\n\t\tjsonTags []string\n\t}{\n\t\t{\n\t\t\tname: \"AgentRuntime\",\n\t\t\tobj: &AgentRuntime{\n\t\t\t\tSpec: AgentRuntimeSpec{\n\t\t\t\t\tPorts: []TargetPort{{Port: 8080}},\n\t\t\t\t},\n\t\t\t},\n\t\t\tjsonTags: []string{\"targetPort\", \"podTemplate\", \"sessionTimeout\", \"maxSessionDuration\"},\n\t\t},\n\t\t{\n\t\t\tname: \"CodeInterpreter\",\n\t\t\tobj: &CodeInterpreter{\n\t\t\t\tSpec: CodeInterpreterSpec{\n\t\t\t\t\tPorts:              []TargetPort{{Port: 8080}},\n\t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\t\t\tWarmPoolSize:       ptrInt32(5),\n\t\t\t\t\tAuthMode:           AuthModePicoD,\n\t\t\t\t},\n\t\t\t},\n\t\t\tjsonTags: []string{\"ports\", \"template\", \"sessionTimeout\", \"maxSessionDuration\", \"warmPoolSize\", \"authMode\"},\n\t\t},\n\t\t{\n\t\t\tname:     \"TargetPort\",\n\t\t\tobj:      nil,\n\t\t\tjsonTags: []string{\"pathPrefix\", \"name\", \"port\", \"protocol\"},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.obj != nil {\n\t\t\t\tdata, err := json.Marshal(tt.obj)\n\t\t\t\tif err != nil {\n\t\t\t\t\tt.Errorf(\"failed to marshal: %v\", err)\n\t\t\t\t}\n\t\t\t\tfor _, tag := range tt.jsonTags {\n\t\t\t\t\tif !contains(string(data), tag) {\n\t\t\t\t\t\tt.Errorf(\"expected JSON tag '%s' in output\", tag)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tcopy := tt.obj.DeepCopyObject()\n\t\t\t\terr = json.Unmarshal(data, copy)\n\t\t\t\tif err != nil {\n\t\t\t\t\tt.Errorf(\"failed to unmarshal: %v\", err)\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestTargetPortJSONTags(t *testing.T) {\n\ttp := TargetPort{\n\t\tPathPrefix: \"/api\",\n\t\tName:       \"api\",\n\t\tPort:       8080,\n\t\tProtocol:   ProtocolTypeHTTP,\n\t}\n\tdata, err := json.Marshal(tp)\n\tif err != nil {\n\t\tt.Errorf(\"failed to marshal TargetPort: %v\", err)\n\t}\n\texpected := `{\"pathPrefix\":\"/api\",\"name\":\"api\",\"port\":8080,\"protocol\":\"HTTP\"}`\n\tif string(data) != expected {\n\t\tt.Errorf(\"expected JSON '%s', got '%s'\", expected, string(data))\n\t}\n\tvar unmarshaled TargetPort\n\terr = json.Unmarshal(data, &unmarshaled)\n\tif err != nil {\n\t\tt.Errorf(\"failed to unmarshal TargetPort: %v\", err)\n\t}\n\tif unmarshaled.PathPrefix != tp.PathPrefix {\n\t\tt.Errorf(\"expected PathPrefix '%s', got '%s'\", tp.PathPrefix, unmarshaled.PathPrefix)\n\t}\n\tif unmarshaled.Port != tp.Port {\n\t\tt.Errorf(\"expected Port %d, got %d\", tp.Port, unmarshaled.Port)\n\t}\n}\n\nfunc TestGroupVersion(t *testing.T) {\n\tif GroupVersion.Group != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"expected Group 'runtime.agentcube.volcano.sh', got '%s'\", GroupVersion.Group)\n\t}\n\tif GroupVersion.Version != \"v1alpha1\" {\n\t\tt.Errorf(\"expected Version 'v1alpha1', got '%s'\", GroupVersion.Version)\n\t}\n}\n\nfunc TestResourceHelper(t *testing.T) {\n\tgvr := Resource(\"agentruntimes\")\n\tif gvr.Group != \"runtime.agentcube.volcano.sh\" {\n\t\tt.Errorf(\"expected Group 'runtime.agentcube.volcano.sh', got '%s'\", gvr.Group)\n\t}\n\tif gvr.Resource != \"agentruntimes\" {\n\t\tt.Errorf(\"expected Resource 'agentruntimes', got '%s'\", gvr.Resource)\n\t}\n}\n\nfunc TestKindConstants(t *testing.T) {\n\tif AgentRuntimeKind != \"AgentRuntime\" {\n\t\tt.Errorf(\"expected AgentRuntimeKind 'AgentRuntime', got '%s'\", AgentRuntimeKind)\n\t}\n\tif AgentRuntimeListKind != \"AgentRuntimeList\" {\n\t\tt.Errorf(\"expected AgentRuntimeListKind 'AgentRuntimeList', got '%s'\", AgentRuntimeListKind)\n\t}\n\tif CodeInterpreterKind != \"CodeInterpreter\" {\n\t\tt.Errorf(\"expected CodeInterpreterKind 'CodeInterpreter', got '%s'\", CodeInterpreterKind)\n\t}\n\tif CodeInterpreterListKind != \"CodeInterpreterList\" {\n\t\tt.Errorf(\"expected CodeInterpreterListKind 'CodeInterpreterList', got '%s'\", CodeInterpreterListKind)\n\t}\n}\n\nfunc TestAddToScheme(t *testing.T) {\n\tif AddToScheme == nil {\n\t\tt.Errorf(\"expected AddToScheme to be non-nil function\")\n\t}\n}\n\nfunc contains(s, substr string) bool {\n\treturn len(s) > 0 && len(substr) > 0 && (s == substr || len(s) >= len(substr) && (s[:len(substr)] == substr || s[len(s)-len(substr):] == substr || containsMiddle(s, substr)))\n}\n\nfunc containsMiddle(s, substr string) bool {\n\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\tif s[i:i+len(substr)] == substr {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\nfunc ptr(s string) *string {\n\treturn &s\n}\n\nfunc ptrInt32(i int32) *int32 {\n\treturn &i\n}\n","after":"package v1alpha1\n\nimport (\n\t\"encoding/json\"\n\t\"testing\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n)\n\nfunc TestAgentRuntimeDeepCopy(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\tar   *AgentRuntime\n\t}{\n\t\t{\n\t\t\tname: \"nil\",\n\t\t\tar:   nil,\n\t\t},\n\t\t{\n\t\t\tname: \"empty\",\n\t\t\tar:   &AgentRuntime{},\n\t\t},\n\t\t{\n\t\t\tname: \"empty spec\",\n\t\t\tar: &AgentRuntime{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"test\"},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"full\",\n\t\t\tar: &AgentRuntime{\n\t\t\t\tTypeMeta: metav1.TypeMeta{\n\t\t\t\t\tKind:       AgentRuntimeKind,\n\t\t\t\t\tAPIVersion: GroupVersion.String(),\n\t\t\t\t},\n\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\tName:      \"test-agentruntime\",\n\t\t\t\t\tNamespace: \"default\",\n\t\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\t\"app\": \"test\",\n\t\t\t\t\t},\n\t\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\t\"description\": \"test annotation\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tSpec: AgentRuntimeSpec{\n\t\t\t\t\tPorts: []TargetPort{\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tPathPrefix: \"/api\",\n\t\t\t\t\t\t\tName:       \"api-port\",\n\t\t\t\t\t\t\tPort:       8080,\n\t\t\t\t\t\t\tProtocol:   ProtocolTypeHTTP,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tTemplate: &SandboxTemplate{\n\t\t\t\t\t\tLabels: map[string]string{\n\t\t\t\t\t\t\t\"pod-label\": \"value\",\n\t\t\t\t\t\t},\n\t\t\t\t\t\tAnnotations: map[string]string{\n\t\t\t\t\t\t\t\"pod-annotation\": \"value\",\n\t\t\t\t\t\t},\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName:  \"container\",\n\t\t\t\t\t\t\t\t\tImage: \"image:latest\",\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n\t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n\t\t\t\t},\n\t\t\t\tStatus: AgentRuntimeStatus{\n\t\t\t\t\tConditions: []