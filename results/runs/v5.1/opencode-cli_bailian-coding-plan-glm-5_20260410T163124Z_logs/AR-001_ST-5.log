c(t *testing.T) {\n163: \t\t\tcopy := tt.arl.DeepCopy()\n164: \t\t\tif tt.arl == nil {\n165: \t\t\t\tif copy != nil {\n166: \t\t\t\t\tt.Errorf(\"expected nil, got non-nil\")\n167: \t\t\t\t}\n168: \t\t\t\treturn\n169: \t\t\t}\n170: \t\t\tif copy == nil {\n171: \t\t\t\tt.Errorf(\"expected non-nil, got nil\")\n172: \t\t\t\treturn\n173: \t\t\t}\n174: \t\t\tif len(copy.Items) != len(tt.arl.Items) {\n175: \t\t\t\tt.Errorf(\"expected Items length %d, got %d\", len(tt.arl.Items), len(copy.Items))\n176: \t\t\t}\n177: \t\t})\n178: \t}\n179: }\n180: \n181: func TestAgentRuntimeDeepCopyObject(t *testing.T) {\n182: \tar := &AgentRuntime{\n183: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test\"},\n184: \t}\n185: \tobj := ar.DeepCopyObject()\n186: \tif obj == nil {\n187: \t\tt.Errorf(\"expected non-nil, got nil\")\n188: \t}\n189: \tif obj.(*AgentRuntime).Name != \"test\" {\n190: \t\tt.Errorf(\"expected Name 'test', got %s\", obj.(*AgentRuntime).Name)\n191: \t}\n192: }\n193: \n194: func TestCodeInterpreterDeepCopy(t *testing.T) {\n195: \ttests := []struct {\n196: \t\tname string\n197: \t\tci   *CodeInterpreter\n198: \t}{\n199: \t\t{\n200: \t\t\tname: \"nil\",\n201: \t\t\tci:   nil,\n202: \t\t},\n203: \t\t{\n204: \t\t\tname: \"empty\",\n205: \t\t\tci:   &CodeInterpreter{},\n206: \t\t},\n207: \t\t{\n208: \t\t\tname: \"full\",\n209: \t\t\tci: &CodeInterpreter{\n210: \t\t\t\tTypeMeta: metav1.TypeMeta{\n211: \t\t\t\t\tKind:       CodeInterpreterKind,\n212: \t\t\t\t\tAPIVersion: GroupVersion.String(),\n213: \t\t\t\t},\n214: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n215: \t\t\t\t\tName:      \"test-codeinterpreter\",\n216: \t\t\t\t\tNamespace: \"default\",\n217: \t\t\t\t},\n218: \t\t\t\tSpec: CodeInterpreterSpec{\n219: \t\t\t\t\tPorts: []TargetPort{\n220: \t\t\t\t\t\t{\n221: \t\t\t\t\t\t\tPort:     8080,\n222: \t\t\t\t\t\t\tProtocol: ProtocolTypeHTTP,\n223: \t\t\t\t\t\t},\n224: \t\t\t\t\t},\n225: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n226: \t\t\t\t\t\tImage:           \"python: