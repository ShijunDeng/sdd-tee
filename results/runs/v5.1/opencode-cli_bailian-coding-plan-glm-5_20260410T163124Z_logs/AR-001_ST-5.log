\tif *copy.Spec.WarmPoolSize != *tt.ci.Spec.WarmPoolSize {\n279: \t\t\t\tt.Errorf(\"expected WarmPoolSize %d, got %d\", *tt.ci.Spec.WarmPoolSize, *copy.Spec.WarmPoolSize)\n280: \t\t\t}\n281: \t\t\tif copy.Spec.Template.Image != tt.ci.Spec.Template.Image {\n282: \t\t\t\tt.Errorf(\"expected Template Image %s, got %s\", tt.ci.Spec.Template.Image, copy.Spec.Template.Image)\n283: \t\t\t}\n284: \t\t\tif len(copy.Spec.Template.Command) != len(tt.ci.Spec.Template.Command) {\n285: \t\t\t\tt.Errorf(\"expected Command length %d, got %d\", len(tt.ci.Spec.Template.Command), len(copy.Spec.Template.Command))\n286: \t\t\t}\n287: \t\t\tif copy.Status.Ready != tt.ci.Status.Ready {\n288: \t\t\t\tt.Errorf(\"expected Ready %v, got %v\", tt.ci.Status.Ready, copy.Status.Ready)\n289: \t\t\t}\n290: \t\t\tcopy.Spec.Template.Labels[\"app\"] = \"modified\"\n291: \t\t\tif tt.ci.Spec.Template.Labels[\"app\"] == \"modified\" {\n292: \t\t\t\tt.Errorf(\"DeepCopy should be deep, modifying copy should not affect original\")\n293: \t\t\t}\n294: \t\t})\n295: \t}\n296: }\n297: \n298: func TestCodeInterpreterListDeepCopy(t *testing.T) {\n299: \tcil := &CodeInterpreterList{\n300: \t\tItems: []CodeInterpreter{\n301: \t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"item1\"}},\n302: \t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"item2\"}},\n303: \t\t},\n304: \t}\n305: \tcopy := cil.DeepCopy()\n306: \tif len(copy.Items) != len(cil.Items) {\n307: \t\tt.Errorf(\"expected Items length %d, got %d\", len(cil.Items), len(copy.Items))\n308: \t}\n309: }\n310: \n311: func TestCodeInterpreterDeepCopyObject(t *testing.T) {\n312: \tci := &CodeInterpreter{\n313: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test\"},\n314: \t}\n315: \tobj := ci.DeepCopyObject()\n316: \tif obj == nil {\n317: \t\tt.Errorf(\"expected non-nil, got nil\")\n318: \t}\n319: \tif obj.(*CodeInterpreter).Name != \"test\" {\n320: \t\tt.Errorf(\"expected Name 'test', got %s\", obj.(*CodeInterpreter).Name)\n321: \t}\n322: }\n323: \n324: func TestTargetPortDeepCopy(t *testing.T) {\n325: \ttp := &TargetPort{\n326: \t\tPathPrefix: \"/api\",\n327: \t\tName:       \"api\",\n328: \t\tPort:       8080,\n329: \t\tProtocol:   ProtocolTypeHTTP,\n330: \t}\n331: \tcopy := tp.DeepCopy()\n332: \tif copy.PathPrefix != tp.PathPrefix {\n333: \t\tt.Errorf(\"expected PathPrefix %s, got %s\", tp.PathPrefix, copy.PathPrefix)\n334: \t}\n335: \tif copy.Port != tp.Port {\n336: \t\tt.Errorf(\"expected Port %d, got %d\", tp.Port, copy.Port)\n337: \t}\n338: }\n339: \n340: func TestSandboxTemplateDeepCopy(t *testing.T) {\n341: \tst := &SandboxTemplate{\n342: \t\tLabels:      map[string]string{\"label\": \"value\"},\n343: \t\tAnnotations: map[string]string{\"annotation\": \"value\"},\n344: \t\tSpec: corev1.PodSpec{\n345: \t\t\tContainers: []corev1.Container{{Name: \"container\"}},\n346: \t\t},\n347: \t}\n348: \tcopy := st.DeepCopy()\n349: \tcopy.Labels[\"label\"] = \"modified\"\n350: \tif st.Labels[\"label\"] == \"modified\" {\n351: \t\tt.Errorf(\"DeepCopy should be deep, modifying copy should not affect original\")\n352: \t}\n353: }\n354: \n355: func TestCodeInterpreterSandboxTemplateDeepCopy(t *testing.T) {\n356: \tcist := &CodeInterpreterSandboxTemplate{\n357: \t\tLabels:           map[string]string{\"label\": \"value\"},\n358: \t\tAnnotations:      map[string]string{\"annotation\": \"value\"},\n359: \t\tRuntimeClassName: ptr(\"runc\"),\n360: \t\tImage:            \"python:latest\",\n361: \t\tImagePullPolicy:  corev1.PullIfNotPresent,\n362: \t\tImagePullSecrets: []corev1.LocalObjectReference{{Name: \"secret\"}},\n363: \t\tEnvironment:      []corev1.EnvVar{{Name: \"ENV\", Value: \"val\"}},\n364: \t\tCommand:          []string{\"cmd\"},\n365: \t\tArgs:             []string{\"arg\"},\n366: \t\tResources:        corev1.ResourceRequirements{},\n367: \t}\n368: \tcopy := cist.DeepCopy()\n369: \tif copy.Image != cist.Image {\n370: \t\tt.Errorf(\"expected Image %s, got %s\", cist.Image, copy.Image)\n371: \t}\n372: \tcopy.Labels[\"label\"] = \"modified\"\n373: \tif cist.Labels[\"label\"] == \"modified\" {\n374: \t\tt.Errorf(\"DeepCopy should be deep\")\n375: \t}\n376: \t*copy.RuntimeClassName = \"modified\"\n377: \tif *cist.RuntimeClassName == \"modified\" {\n378: \t\tt.Errorf(\"DeepCopy should be deep for RuntimeClassName\")\n379: \t}\n380: }\n381: \n382: func TestAuthModeTypeConstants(t *testing.T) {\n383: \tif AuthModePicoD != \"picod\" {\n384: \t\tt.Errorf(\"expected AuthModePicoD to be 'picod', got '%s'\", AuthModePicoD)\n385: \t}\n386: \tif AuthModeNone != \"none\" {\n387: \t\tt.Errorf(\"expected AuthModeNone to be 'none', got '%s'\", AuthModeNone)\n388: \t}\n389: }\n390: \n391: func TestProtocolTypeConstants(t *testing.T) {\n392: \tif ProtocolTypeHTTP != \"HTTP\" {\n393: \t\tt.Errorf(\"expected ProtocolTypeHTTP to be 'HTTP', got '%s'\", ProtocolTypeHTTP)\n394: \t}\n395: \tif ProtocolTypeHTTPS != \"HTTPS\" {\n396: \t\tt.Errorf(\"expected ProtocolTypeHTTPS to be 'HTTPS', got '%s'\", ProtocolTypeHTTPS)\n397: \t}\n398: }\n399: \n400: func TestJSONSerialization(t *testing.T) {\n401: \ttests := []struct {\n402: \t\tname     string\n403: \t\tobj      runtime.Object\n404: \t\tjsonTags []string\n405: \t}{\n406: \t\t{\n407: \t\t\tname: \"AgentRuntime\",\n408: \t\t\tobj: &AgentRuntime{\n409: \t\t\t\tSpec: AgentRuntimeSpec{\n410: \t\t\t\t\tPorts: []TargetPort{{Port: 8080}},\n411: \t\t\t\t},\n412: \t\t\t},\n413: \t\t\tjsonTags: []string{\"targetPort\", \"podTemplate\", \"sessionTimeout\", \"maxSessionDuration\"},\n414: \t\t},\n415: \t\t{\n416: \t\t\tname: \"CodeInterpreter\",\n417: \t\t\tobj: &CodeInterpreter{\n418: \t\t\t\tSpec: CodeInterpreterSpec{\n419: \t\t\t\t\tPorts:              []TargetPort{{Port: 8080}},\n420: \t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n421: \t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n422: \t\t\t\t\tWarmPoolSize:       ptrInt32(5),\n423: \t\t\t\t\tAuthMode:           AuthModePicoD,\n424: \t\t\t\t},\n425: \t\t\t},\n426: \t\t\tjsonTags: []string{\"ports\", \"template\", \"sessionTimeout\", \"maxSessionDuration\", \"warmPoolSize\", \"authMode\"},\n427: \t\t},\n428: \t\t{\n429: \t\t\tname:     \"TargetPort\",\n430: \t\t\tobj:      nil,\n431: \t\t\tjsonTags: []string{\"pathPrefix\", \"name\", \"port\", \"protocol\"},\n432: \t\t},\n433: \t}\n434: \n435: \tfor _, tt := range tests {\n436: \t\tt.Run(tt.name, func(t *testing.T) {\n437: \t\t\tif tt.obj != nil {\n438: \t\t\t\tdata, err := json.Marshal(tt.obj)\n439: \t\t\t\tif err != nil {\n440: \t\t\t\t\tt.Errorf(\"failed to marshal: %v\", err)\n441: \t\t\t\t}\n442: \t\t\t\tfor _, tag := range tt.jsonTags {\n443: \t\t\t\t\tif !contains(string(data), tag) {\n444: \t\t\t\t\t\tt.Errorf(\"expected JSON tag '%s' in output\", tag)\n445: \t\t\t\t\t}\n446: \t\t\t\t}\n447: \t\t\t\tcopy := tt.obj.DeepCopyObject()\n448: \t\t\t\terr = json.Unmarshal(data, copy)\n449: \t\t\t\tif err != nil {\n450: \t\t\t\t\tt.Errorf(\"failed to unmarshal: %v\", err)\n451: \t\t\t\t}\n452: \t\t\t}\n453: \t\t})\n454: \t}\n455: }\n456: \n457: func TestTargetPortJSONTags(t *testing.T) {\n458: \ttp := TargetPort{\n459: \t\tPathPrefix: \"/api\",\n460: \t\tName:       \"api\",\n461: \t\tPort:       8080,\n462: \t\tProtocol:   ProtocolTypeHTTP,\n463: \t}\n464: \tdata, err := json.Marshal(tp)\n465: \tif err != nil {\n466: \t\tt.Errorf(\"failed to marshal TargetPort: %v\", err)\n467: \t}\n468: \texpected := `{\"pathPrefix\":\"/api\",\"name\":\"api\",\"port\":8080,\"protocol\":\"HTTP\"}`\n469: \tif string(data) != expected {\n470: \t\tt.Errorf(\"expected JSON '%s', got '%s'\", expected, string(data))\n471: \t}\n472: \tvar unmarshaled TargetPort\n473: \terr = json.Unmarshal(data, &unmarshaled)\n474: \tif err != nil {\n475: \t\tt.Errorf(\"failed to unmarshal TargetPort: %v\", err)\n476: \t}\n477: \tif unmarshaled.PathPrefix != tp.PathPrefix {\n478: \t\tt.Errorf(\"expected PathPrefix '%s', got '%s'\", tp.PathPrefix, unmarshaled.PathPrefix)\n479: \t}\n480: \tif unmarshaled.Port != tp.Port {\n481: \t\tt.Errorf(\"expected Port %d, got %d\", tp.Port, unmarshaled.Port)\n482: \t}\n483: }\n484: \n485: func TestGroupVersion(t *testing.T) {\n486: \tif GroupVersion.Group != \"runtime.agentcube.volcano.sh\" {\n487: \t\tt.Errorf(\"expected Group 'runtime.agentcube.volcano.sh', got '%s'\", GroupVersion.Group)\n488: \t}\n489: \tif GroupVersion.Version != \"v1alpha1\" {\n490: \t\tt.Errorf(\"expected Version 'v1alpha1', got '%s'\", GroupVersion.Version)\n491: \t}\n492: }\n493: \n494: func TestResourceHelper(t *testing.T) {\n495: \tgvr := Resource(\"agentruntimes\")\n496: \tif gvr.Group != \"runtime.agentcube.volcano.sh\" {\n497: \t\tt.Errorf(\"expected Group 'runtime.agentcube.volcano.sh', got '%s'\", gvr.Group)\n498: \t}\n499: \tif gvr.Resource != \"agentruntimes\" {\n500: \t\tt.Errorf(\"expected Resource 'agentruntimes', got '%s'\", gvr.Resource)\n501: \t}\n502: }\n503: \n504: func TestKindConstants(t *testing.T) {\n505: \tif AgentRuntimeKind != \"AgentRuntime\" {\n506: \t\tt.Errorf(\"expected AgentRuntimeKind 'AgentRuntime', got '%s'\", AgentRuntimeKind)\n507: \t}\n508: \tif AgentRuntimeListKind != \"AgentRuntimeList\" {\n509: \t\tt.Errorf(\"expected AgentRuntimeListKind 'AgentRuntimeList', got '%s'\", AgentRuntimeListKind)\n510: \t}\n511: \tif CodeInterpreterKind != \"CodeInterpreter\" {\n512: \t\tt.Errorf(\"expected CodeInterpreterKind 'CodeInterpreter', got '%s'\", CodeInterpreterKind)\n513: \t}\n514: \tif CodeInterpreterListKind != \"CodeInterpreterList\" {\n515: \t\tt.Errorf(\"expected CodeInterpreterListKind 'CodeInterpreterList', got '%s'\", CodeInterpreterListKind)\n516: \t}\n517: }\n518: \n519: func TestAddToScheme(t *testing.T) {\n520: \tif AddToScheme == nil {\n521: \t\tt.Errorf(\"expected AddToScheme to be non-nil function\")\n522: \t}\n523: }\n524: \n525: func contains(s, substr string) bool {\n526: \treturn len(s) > 0 && len(substr) > 0 && (s == substr || len(s) >= len(substr) && (s[:len(substr)] == substr || s[len(s)-len(substr):] == substr || containsMiddle(s, substr)))\n527: }\n528: \n529: func containsMiddle(s, substr string) bool {\n530: \tfor i := 0; i <= len(s)-len(substr); i++ {\n531: \t\tif s[i:i+len(substr)] == substr {\n532: \t\t\treturn true\n533: \t\t}\n534: \t}\n535: \treturn false\n536: }\n537: \n538: func ptr(s string) *string {\n539: \treturn &s\n540: }\n541: \n542: func ptrInt32(i int32) *int32 {\n543: \treturn &i\n544: }\n\n(End of file - total 544 lines)\n</content>","metadata":{"preview":"package v1alpha1\n\nimport (\n\t\"encoding/json\"\n\t\"testing\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n)\n\nfunc TestAgentRuntimeDeepCopy(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\tar   *AgentRuntime\n\t}{\n\t\t{\n\t\t\tname: \"nil\",\n\t\t\tar:   nil,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/types_test.go","time":{"start":1775839514634,"end":1775839514650}}}}
