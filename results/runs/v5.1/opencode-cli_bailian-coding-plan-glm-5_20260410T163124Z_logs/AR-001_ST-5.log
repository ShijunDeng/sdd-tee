aximum duration a session can exist.\n\t// Default is 8 hours.\n\t// +kubebuilder:validation:Required\n\t// +kubebuilder:default=\"8h\"\n\tMaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\" protobuf:\"bytes,3,opt,name=maxSessionDuration\"`\n}\n\n// AgentRuntimeStatus defines the observed state of AgentRuntime.\ntype AgentRuntimeStatus struct {\n\t// Conditions represents the latest available observations of the AgentRuntime's state.\n\t// +optional\n\t// +listType=atomic\n\tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n}\n\n// SandboxTemplate defines the pod template for creating sandbox pods.\ntype SandboxTemplate struct {\n\t// Labels are applied to the sandbox pod.\n\t// +optional\n\tLabels map[string]string `json:\"labels,omitempty\" protobuf:\"bytes,1,rep,name=labels\"`\n\n\t// Annotations are applied to the sandbox pod.\n\t// +optional\n\tAnnotations map[string]string `json:\"annotations,omitempty\" protobuf:\"bytes,2,rep,name=annotations\"`\n\n\t// Spec is the PodSpec for the sandbox pod.\n\t// +kubebuilder:validation:Required\n\tSpec corev1.PodSpec `json:\"spec\" protobuf:\"bytes,3,opt,name=spec\"`\n}\n\n// AgentRuntimeList contains a list of AgentRuntime resources.\n//\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\ntype AgentRuntimeList struct {\n\tmetav1.TypeMeta `json:\",inline\"`\n\tmetav1.ListMeta `json:\"metadata,omitempty\"`\n\n\tItems []AgentRuntime `json:\"items\"`\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/agentruntime_types.go"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/agentruntime_types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/codeinter