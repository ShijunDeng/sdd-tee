r:default=\"8h\"\n\tMaxSessionDuration *metav1.Duration `json:\"maxSessionDuration,omitempty\"`\n\n\t// WarmPoolSize specifies the number of pre-warmed instances to maintain.\n\t// +optional\n\tWarmPoolSize *int32 `json:\"warmPoolSize,omitempty\"`\n\n\t// AuthMode specifies the authentication mode for the code interpreter.\n\t// Default is \"picod\".\n\t// +kubebuilder:default=picod\n\t// +kubebuilder:validation:Enum=picod;none\n\t// +optional\n\tAuthMode AuthModeType `json:\"authMode,omitempty\"`\n}\n\n// CodeInterpreterStatus defines the observed state of CodeInterpreter.\ntype CodeInterpreterStatus struct {\n\t// Conditions represents the latest available observations of the CodeInterpreter's state.\n\t// +optional\n\t// +listType=atomic\n\tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n\n\t// Ready indicates whether the CodeInterpreter is ready to serve requests.\n\t// +optional\n\tReady bool `json:\"ready,omitempty\"`\n}\n\n// CodeInterpreterSandboxTemplate defines the sandbox template for code interpreter pods.\ntype CodeInterpreterSandboxTemplate struct {\n\t// Labels are applied to the code interpreter pod.\n\t// +optional\n\tLabels map[string]string `json:\"labels,omitempty\"`\n\n\t// Annotations are applied to the code interpreter pod.\n\t// +optional\n\tAnnotations map[string]string `json:\"annotations,omitempty\"`\n\n\t// RuntimeClassName is the name of the runtime class to use for the pod.\n\t// +optional\n\tRuntimeClassName *string `json:\"runtimeClassName,omitempty\"`\n\n\t// Image specifies the container image for the code interpreter.\n\tImage string `json:\"image,omitempty\"`\n\n\t// ImagePullPolicy specifies the image pull policy.\n\t// +optional\n\tImagePullPolicy corev1.PullPolicy `json:\"imagePullPolicy,omitempty\"`\n\n\t// ImagePullSecrets specifies the secrets for pulling the container image.\n\t// +optional\n\t// +patchMergeKey=name\n\t// +patchStrategy=merge\n\t// +listType=map\n\t// +listMapKey=name\n\tImagePullSecrets []corev1.LocalObjectReference `json:\"imagePullSecrets,omitempty\"`\n\n\t// Environment specifies environment variables for the container.\n\t// +optional\n\t// +listType=atomic\n\tEnvironment []corev1.EnvVar `json:\"environment,omitempty\"`\n\n\t// Command specifies the container command.\n\t// +optional\n\t// +listType=atomic\n\tCommand []string `json:\"command,omitempty\"`\n\n\t// Args specifies the container arguments.\n\t// +optional\n\t// +listType=atomic\n\tArgs []string `json:\"args,omitempty\"`\n\n\t// Resources specifies the compute resources for the container.\n\t// +optional\n\tResources corev1.ResourceRequirements `json:\"resources,omitempty\"`\n}\n\n// CodeInterpreterList contains a list of CodeInterpreter resources.\n//\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\ntype CodeInterpreterList struct {\n\tmetav1.TypeMeta `json:\",inline\"`\n\tmetav1.ListMeta `json:\"metadata,omitempty\"`\n\n\tItems []CodeInterpreter `json:\"items\"`\n}","filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types.go"},"output":"Wrote file successfully.","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/agentruntime_types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/codeinterpreter_types.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/doc.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/groupversion_info.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/apis/runtime/v1alpha1/register.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-c