lishRuntime(provider=\"agentcube\")\n148:             with pytest.raises(ValueError, match=\"--image-url is required\"):\n149:                 runtime._validate_publish_prerequisites(tmp_path, metadata, {})\n150: \n151:     def test_validate_local_mode_with_image_url(self, tmp_path: Path) -> None:\n152:         metadata = AgentMetadata.model_construct(\n153:             agent_name=\"test-agent\",\n154:             language=\"python\",\n155:             entrypoint=\"python main.py\",\n156:             router_url=\"http://router\",\n157:             workload_manager_url=\"http://workload-manager\",\n158:             build_mode=\"local\",\n159:         )\n160:         \n161:         mock_docker_service = MagicMock()\n162:         mock_docker_service.check_docker_available.return_value = True\n163:         \n164:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n165:             mock_provider.return_value = MagicMock()\n166:             with patch(\"agentcube.services.docker_service.DockerService\") as mock_docker:\n167:                 mock_docker.return_value = mock_docker_service\n168:                 runtime = PublishRuntime(provider=\"agentcube\")\n169:                 runtime._docker_service = mock_docker_service\n170:                 runtime._validate_publish_prerequisites(\n171:                     tmp_path, metadata, {\"image_url\": \"registry.example.com/test-agent\"}\n172:                 )\n173: \n174:     def test_validate_node_port_out_of_range_low(self, tmp_path: Path) -> None:\n175:         metadata = AgentMetadata.model_construct(\n176:             agent_name=\"test-agent\",\n177:             language=\"python\",\n178:             entrypoint=\"python main.py\",\n179:             router_url=\"http://router\",\n180:             workload_manager_url=\"http://workload-manager\",\n181:             build_mode=\"cloud\",\n182:         )\n183:         \n184:         with patch(\"agentcube.services.agentcube_provi