beProvider\n\n\nclass TestAgentCubeProviderInit:\n    def test_init_default_namespace(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    assert provider.namespace == \"default\"\n\n    def test_init_custom_namespace(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider(namespace=\"custom-ns\")\n                    assert provider.namespace == \"custom-ns\"\n\n    def test_init_verbose(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider(verbose=True)\n                    assert provider.verbose == True\n\n    def test_init_with_kubeconfig(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\") as mock_load:\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider(kubeconfig=\"/path/to/kubeconfig\")\n                    mock_load.assert_called_once_with(config_file=\"/path/to/kubeconfig\")\n\n\nclass TestConstants:\n    def test_cr_group(self) -> None:\n        assert AgentCubeProvider.CR_GROUP == \"runtime.agentcube.volcano.sh\"\n\n    def test_cr_version(self) -> None:\n        assert AgentCubeProvider.CR_VERSION == \"v1alpha1\"\n\n    def test_cr_plural(self) -> None:\n        assert AgentCubeProvider.CR_PLURAL == \"agentruntimes\"\n\n    def test_session_timeout(self) -> None:\n        assert AgentCubeProvider.SESSION_TIMEOUT == \"15m\"\n\n    def test_max_session_duration(self) -> None:\n        assert AgentCubeProvider.MAX_SESSION_DURATION == \"8h\"\n\n    def test_default_secret(self) -> None:\n        assert AgentCubeProvider.DEFAULT_SECRET == \"default-secret\"\n\n\nclass TestSanitizeName:\n    def test_sanitize_name_lowercase(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    result = provider._sanitize_name(\"TestAgent\")\n                    assert result == \"testagent\"\n\n    def test_sanitize_name_replace_non_alphanumeric(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    result = provider._sanitize_name(\"test-agent_123\")\n                    assert result == \"test-agent-123\"\n\n    def test_sanitize_name_truncate_to_63_chars(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    long_name = \"a\" * 100\n                    result = provider._sanitize_name(long_name)\n                    assert len(result) == 63\n\n    def test_sanitize_name_strip_dashes(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    result = provider._sanitize_name(\"---test---agent---\")\n                    assert result == \"test-agent\"\n\n    def test_sanitize_name_empty_string(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    result = provider._sanitize_name(\"\")\n                    assert result == \"default\"\n\n\nclass TestEnsureNamespace:\n    def test_ensure_namespace_exists(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_core_api = MagicMock()\n            mock_core_api.read_namespace.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = AgentCubeProvider()\n                    provider._core_api = mock_core_api\n                    provider._ensure_namespace()\n                    \n                    mock_core_api.read_namespace.assert_called_once_with(name=\"default\")\n\n    def test_ensure_namespace_creates_if_not_exists(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_core_api = MagicMock()\n            mock_error = MagicMock()\n            mock_error.status = 404\n            mock_core_api.read_namespace.side_effect = mock_error\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = AgentCubeProvider(namespace=\"new-ns\")\n                    provider._core_api = mock_core_api\n                    provider._ensure_namespace()\n                    \n                    mock_core_api.create_namespace.assert_called_once()\n\n\nclass TestDeployAgentRuntime:\n    def test_deploy_agent_runtime_success(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_result = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\"agentEndpoint\": \"http://test-agent.example.com\"},\n            }\n            mock_custom_api.create_namespaced_custom_object.return_value = mock_result\n            \n            mock_core_api = MagicMock()\n            mock_core_api.read_namespace.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    provider._core_api = mock_core_api\n                    \n                    result = provider.deploy_agent_runtime(\n                        agent_name=\"test-agent\",\n                        image_url=\"registry.example.com/test:v1.0.0\",\n                        port=8080,\n                        workload_manager_url=\"http://wm\",\n                        router_url=\"http://router\",\n                    )\n                    \n                    assert result[\"deployment_name\"] == \"test-agent\"\n                    assert result[\"agent_id\"] == \"test-agent\"\n                    assert result[\"agent_endpoint\"] == \"http://test-agent.example.com\"\n                    assert result[\"status\"] == \"created\"\n\n    def test_deploy_agent_runtime_with_entrypoint(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_result = {\n                \"metadata\": {\"name\": \"test-agent\"},\n            }\n            mock_custom_api.create_namespaced_custom_object.return_value = mock_result\n            \n            mock_core_api = MagicMock()\n            mock_core_api.read_namespace.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    provider._core_api = mock_core_api\n                    \n                    result = provider.deploy_agent_runtime(\n                        agent_name=\"test-agent\",\n                        image_url=\"registry.example.com/test:v1.0.0\",\n                        port=8080,\n                        entrypoint=\"python main.py\",\n                    )\n                    \n                    mock_custom_api.create_namespaced_custom_object.assert_called_once()\n                    call_body = mock_custom_api.create_namespaced_custom_object.call_args.kwargs[\"body\"]\n                    assert call_body[\"spec\"][\"entrypoint\"] == \"python main.py\"\n\n    def test_deploy_agent_runtime_patch_existing(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_error = MagicMock()\n            mock_error.status = 409\n            mock_custom_api.create_namespaced_custom_object.side_effect = mock_error\n            \n            mock_result = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\"agentEndpoint\": \"http://test-agent.example.com\"},\n            }\n            mock_custom_api.patch_namespaced_custom_object.return_value = mock_result\n            \n            mock_core_api = MagicMock()\n            mock_core_api.read_namespace.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    provider._core_api = mock_core_api\n                    \n                    result = provider.deploy_agent_runtime(\n                        agent_name=\"test-agent\",\n                        image_url=\"registry.example.com/test:v1.0.0\",\n                        port=8080,\n                    )\n                    \n                    assert result[\"status\"] == \"patched\"\n                    mock_custom_api.patch_namespaced_custom_object.assert_called_once()\n\n    def test_deploy_agent_runtime_crd_not_found(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_error = MagicMock()\n            mock_error.status = 404\n            mock_custom_api.create_namespaced_custom_object.side_effect = mock_error\n            \n            mock_core_api = MagicMock()\n            mock_core_api.read_namespace.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    provider._core_api = mock_core_api\n                    \n                    with pytest.raises(ValueError, match=\"AgentRuntime CRD not installed\"):\n                        provider.deploy_agent_runtime(\n                            agent_name=\"test-agent\",\n                            image_url=\"registry.example.com/test:v1.0.0\",\n                            port=8080,\n                        )\n\n    def test_deploy_agent_runtime_with_env_vars(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_result = {\"metadata\": {\"name\": \"test-agent\"}}\n            mock_custom_api.create_namespaced_custom_object.return_value = mock_result\n            \n            mock_core_api = MagicMock()\n            mock_core_api.read_namespace.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    provider._core_api = mock_core_api\n                    \n                    result = provider.deploy_agent_runtime(\n                        agent_name=\"test-agent\",\n                        image_url=\"registry.example.com/test:v1.0.0\",\n                        port=8080,\n                        workload_manager_url=\"http://wm\",\n                        router_url=\"http://router\",\n                        env_vars={\"CUSTOM_VAR\": \"value\"},\n                    )\n                    \n                    mock_custom_api.create_namespaced_custom_object.assert_called_once()\n                    call_body = mock_custom_api.create_namespaced_custom_object.call_args.kwargs[\"body\"]\n                    env_list = call_body[\"spec\"][\"env\"]\n                    assert {\"name\": \"WORKLOAD_MANAGER_URL\", \"value\": \"http://wm\"} in env_list\n                    assert {\"name\": \"ROUTER_URL\", \"value\": \"http://router\"} in env_list\n                    assert {\"name\": \"CUSTOM_VAR\", \"value\": \"value\"} in env_list\n\n\nclass TestGetAgentRuntime:\n    def test_get_agent_runtime_success(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_result = {\n                \"metadata\": {\"name\": \"test-agent\"},\n                \"status\": {\"agentEndpoint\": \"http://test-agent.example.com\"},\n            }\n            mock_custom_api.get_namespaced_custom_object.return_value = mock_result\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    \n                    result = provider.get_agent_runtime(\"test-agent\")\n                    \n                    assert result[\"metadata\"][\"name\"] == \"test-agent\"\n\n    def test_get_agent_runtime_not_found(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_error = MagicMock()\n            mock_error.status = 404\n            mock_custom_api.get_namespaced_custom_object.side_effect = mock_error\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    \n                    result = provider.get_agent_runtime(\"nonexistent\")\n                    \n                    assert result is None\n\n    def test_get_agent_runtime_custom_namespace(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_result = {\"metadata\": {\"name\": \"test-agent\"}}\n            mock_custom_api.get_namespaced_custom_object.return_value = mock_result\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    \n                    result = provider.get_agent_runtime(\"test-agent\", namespace=\"custom-ns\")\n                    \n                    mock_custom_api.get_namespaced_custom_object.assert_called_once()\n                    call_kwargs = mock_custom_api.get_namespaced_custom_object.call_args.kwargs\n                    assert call_kwargs[\"namespace\"] == \"custom-ns\"\n\n\nclass TestDeleteAgentRuntime:\n    def test_delete_agent_runtime_success(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_custom_api.delete_namespaced_custom_object.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    \n                    result = provider.delete_agent_runtime(\"test-agent\")\n                    \n                    assert result[\"deleted\"] == True\n                    assert result[\"name\"] == \"test-agent\"\n\n    def test_delete_agent_runtime_not_found(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_custom_api = MagicMock()\n            mock_error = MagicMock()\n            mock_error.status = 404\n            mock_custom_api.delete_namespaced_custom_object.side_effect = mock_error\n            \n            with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    provider._custom_api = mock_custom_api\n                    \n                    result = provider.delete_agent_runtime(\"nonexistent\")\n                    \n                    assert result[\"deleted\"] == False\n                    assert result[\"reason\"] == \"not_found\"\n\n\ncl