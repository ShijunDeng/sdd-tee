 TestApplyOptionOverrides:\n31:     def test_apply_override_version(self, tmp_path: Path) -> None:\n32:         metadata = AgentMetadata.model_construct(\n33:             agent_name=\"test-agent\",\n34:             language=\"python\",\n35:             entrypoint=\"python main.py\",\n36:         )\n37:         \n38:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n39:             mock_provider.return_value = MagicMock()\n40:             runtime = PublishRuntime()\n41:             result = runtime._apply_option_overrides(metadata, {\"version\": \"v1.0.0\"})\n42:             assert result.version == \"v1.0.0\"\n43: \n44:     def test_apply_override_image_url(self, tmp_path: Path) -> None:\n45:         metadata = AgentMetadata.model_construct(\n46:             agent_name=\"test-agent\",\n47:             language=\"python\",\n48:             entrypoint=\"python main.py\",\n49:             image={},\n50:         )\n51:         \n52:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n53:             mock_provider.return_value = MagicMock()\n54:             runtime = PublishRuntime()\n55:             result = runtime._apply_option_overrides(metadata, {\"image_url\": \"registry.example.com/test-agent\"})\n56:             assert result.image.get(\"url\") == \"registry.example.com/test-agent\"\n57: \n58:     def test_apply_override_description(self, tmp_path: Path) -> None:\n59:         metadata = AgentMetadata.model_construct(\n60:             agent_name=\"test-agent\",\n61:             language=\"python\",\n62:             entrypoint=\"python main.py\",\n63:         )\n64:         \n65:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n66:             mock_provider.return_value = MagicMock()\n67:             runtime = PublishRuntime()\n68:             result = runtime._apply_option_overrides(metadata, {\"description\": \"New description\"})\n69:             assert result.description == \"New description\"\n70: \n71:     def test_apply_override_region(self, tmp_path: Path) -> None:\n72:         metadata = AgentMetadata.model_construct(\n73:             agent_name=\"test-agent\",\n74:             language=\"python\",\n75:             entrypoint=\"python main.py\",\n76:         )\n77:         \n78:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n79:             mock_provider.return_value = MagicMock()\n80:             runtime = PublishRuntime()\n81:             result = runtime._apply_option_overrides(metadata, {\"region\": \"us-west\"})\n82:             assert result.region == \"us-west\"\n83: \n84: \n85: class TestValidatePublishPrerequisites:\n86:     def test_validate_agentcube_missing_router_url(self, tmp_path: Path) -> None:\n87:         metadata = AgentMetadata.model_construct(\n88:             agent_name=\"test-agent\",\n89:             language=\"python\",\n90:             entrypoint=\"python main.py\",\n91:             workload_manager_url=\"http://workload-manager\",\n92:             router_url=\"\",\n93:             build_mode=\"cloud\",\n94:         )\n95:         \n96:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n97:             mock_provider.return_value = MagicMock()\n98:             runtime = PublishRuntime(provider=\"agentcube\")\n99:             with pytest.raises(ValueError, match=\"router_url is required\"):\n100:                 runtime._validate_publish_prerequisites(tmp_path, metadata, {})\n101: \n102:     def test_validate_agentcube_missing_workload_manager(self, tmp_path: Path) -> None:\n103:         metadata = AgentMetadata.model_construct(\n104:             agent_name=\"test-agent\",\n105:             language=\"python\",\n106:             entrypoint=\"python main.py\",\n107:             workload_manager_url=\"\",\n108:             router_url=\"http://router\",\n