_provider = mock_agentcube_provider\n394:             \n395:             result = runtime.publish(tmp_path, image_url=\"registry.example.com/test-agent:v1.0.0\")\n396:             \n397:             assert result[\"status\"] == \"success\"\n398:             assert result[\"agent_name\"] == \"test-agent\"\n399:             assert result[\"agent_id\"] == \"agent-123\"\n400:             assert result[\"deployment_type\"] == \"AgentRuntime\"\n401: \n402:     def test_publish_k8s_success(self, tmp_path: Path) -> None:\n403:         metadata_content = \"\"\"\n404: agent_name: test-agent\n405: language: python\n406: entrypoint: python main.py\n407: port: 8080\n408: build_mode: cloud\n409: \"\"\"\n410:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n411:         metadata_file.write_text(metadata_content)\n412:         \n413:         mock_k8s_provider = MagicMock()\n414:         mock_k8s_provider.deploy_agent.return_value = {\n415:             \"deployment_name\": \"test-agent\",\n416:             \"service_name\": \"test-agent\",\n417:             \"node_port\": 30001,\n418:             \"service_url\": \"http://localhost:30001\",\n419:             \"replicas\": 1,\n420:         }\n421:         \n422:         with patch(\"agentcube.services.k8s_provider.KubernetesProvider\") as mock_provider_class:\n423:             mock_provider_class.return_value = mock_k8s_provider\n424:             runtime = PublishRuntime(provider=\"k8s\")\n425:             runtime._k8s_provider = mock_k8s_provider\n426:             \n427:             result = runtime.publish(tmp_path, image_url=\"registry.example.com/test-agent:v1.0.0\")\n428:             \n429:             assert result[\"status\"] == \"success\"\n430:             assert result[\"agent_name\"] == \"test-agent\"\n431:             assert result[\"deployment_type\"] == \"Deployment\"\n\n(End of file - total 431 lines)\n</content>","metadata":{"preview":"import pytest\nfrom pathlib import Path\nfrom unittest.mock import Magic