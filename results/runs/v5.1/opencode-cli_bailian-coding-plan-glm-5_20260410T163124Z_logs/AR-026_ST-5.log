ssert provider.verbose == True\n28: \n29:     def test_init_with_kubeconfig(self) -> None:\n30:         with patch(\"kubernetes.config.load_kube_config\") as mock_load:\n31:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n32:                 with patch(\"kubernetes.client.CoreV1Api\"):\n33:                     provider = AgentCubeProvider(kubeconfig=\"/path/to/kubeconfig\")\n34:                     mock_load.assert_called_once_with(config_file=\"/path/to/kubeconfig\")\n35: \n36: \n37: class TestConstants:\n38:     def test_cr_group(self) -> None:\n39:         assert AgentCubeProvider.CR_GROUP == \"runtime.agentcube.volcano.sh\"\n40: \n41:     def test_cr_version(self) -> None:\n42:         assert AgentCubeProvider.CR_VERSION == \"v1alpha1\"\n43: \n44:     def test_cr_plural(self) -> None:\n45:         assert AgentCubeProvider.CR_PLURAL == \"agentruntimes\"\n46: \n47:     def test_session_timeout(self) -> None:\n48:         assert AgentCubeProvider.SESSION_TIMEOUT == \"15m\"\n49: \n50:     def test_max_session_duration(self) -> None:\n51:         assert AgentCubeProvider.MAX_SESSION_DURATION == \"8h\"\n52: \n53:     def test_default_secret(self) -> None:\n54:         assert AgentCubeProvider.DEFAULT_SECRET == \"default-secret\"\n55: \n56: \n57: class TestSanitizeName:\n58:     def test_sanitize_name_lowercase(self) -> None:\n59:         with patch(\"kubernetes.config.load_kube_config\"):\n60:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n61:                 with patch(\"kubernetes.client.CoreV1Api\"):\n62:                     provider = AgentCubeProvider()\n63:                     result = provider._sanitize_name(\"TestAgent\")\n64:                     assert result == \"testagent\"\n65: \n66:     def test_sanitize_name_replace_non_alphanumeric(self) -> None:\n67:         with patch(\"kubernetes.config.load_kube_config\"):\n68:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n69:                 with patch(\"kubernetes.client.CoreV1Api\"):\n70:                     provider = AgentCubeProvider()\n71:                     result = provider._sanitize_name(\"test-agent_123\")\n72:                     assert result == \"test-agent-123\"\n73: \n74:     def test_sanitize_name_truncate_to_63_chars(self) -> None:\n75:         with patch(\"kubernetes.config.load_kube_config\"):\n76:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n77:                 with patch(\"kubernetes.client.CoreV1Api\"):\n78:                     provider = AgentCubeProvider()\n79:                     long_name = \"a\" * 100\n80:                     result = provider._sanitize_name(long_name)\n81:                     assert len(result) == 63\n82: \n83:     def test_sanitize_name_strip_dashes(self) -> None:\n84:         with patch(\"kubernetes.config.load_kube_config\"):\n85:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n86:                 with patch(\"kubernetes.client.CoreV1Api\"):\n87:                     provider = AgentCubeProvider()\n88:                     result = provider._sanitize_name(\"---test---agent---\")\n89:                     assert result == \"test-agent\"\n90: \n91:     def test_sanitize_name_empty_string(self) -> None:\n92:         with patch(\"kubernetes.config.load_kube_config\"):\n93:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n94:                 with patch(\"kubernetes.client.CoreV1Api\"):\n95:                     provider = AgentCubeProvider()\n96:                     result = provider._sanitize_name(\"\")\n97:                     assert result == \"default\"\n98: \n99: \n100: class TestEnsureNamespace:\n101:     def test_ensure_namespace_exists(self) -> None:\n102:         with patch(\"kubernetes.config.load_kube_config\"):\n103:             mock_core_api = MagicMock()\n104:             mock_core_api.read_namespace.return_value = MagicMock()\n105:             \n106:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n107:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n108:                     provider = AgentCubeProvider()\n109:                     provider._core_api = mock_core_api\n110:                     provider._ensure_namespace()\n111:                     \n112:                     mock_core_api.read_namespace.assert_called_once_with(name=\"default\")\n113: \n114:     def test_ensure_namespace_creates_if_not_exists(self) -> None:\n115:         with patch(\"kubernetes.config.load_kube_config\"):\n116:             mock_core_api = MagicMock()\n117:             mock_error = MagicMock()\n118:             mock_error.status = 404\n119:             mock_core_api.read_namespace.side_effect = mock_error\n120:             \n121:             with patch(\"kubernetes.client.CustomObjectsApi\"):\n122:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n123:                     provider = AgentCubeProvider(namespace=\"new-ns\")\n124:                     provider._core_api = mock_core_api\n125:                     provider._ensure_namespace()\n126:                     \n127:                     mock_core_api.create_namespace.assert_called_once()\n128: \n129: \n130: class TestDeployAgentRuntime:\n131:     def test_deploy_agent_runtime_success(self) -> None:\n132:         with patch(\"kubernetes.config.load_kube_config\"):\n133:             mock_custom_api = MagicMock()\n134:             mock_result = {\n135:                 \"metadata\": {\"name\": \"test-agent\"},\n136:                 \"status\": {\"agentEndpoint\": \"http://test-agent.example.com\"},\n137:             }\n138:             mock_custom_api.create_namespaced_custom_object.return_value = mock_result\n139:             \n140:             mock_core_api = MagicMock()\n141:             mock_core_api.read_namespace.return_value = MagicMock()\n142:             \n143:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n144:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n145:                     provider = AgentCubeProvider()\n146:                     provider._custom_api = mock_custom_api\n147:                     provider._core_api = mock_core_api\n148:                     \n149:                     result = provider.deploy_agent_runtime(\n150:                         agent_name=\"test-agent\",\n151:                         image_url=\"registry.example.com/test:v1.0.0\",\n152:                         port=8080,\n153:                         workload_manager_url=\"http://wm\",\n154:                         router_url=\"http://router\",\n155:                     )\n156:                     \n157:                     assert result[\"deployment_name\"] == \"test-agent\"\n158:                     assert result[\"agent_id\"] == \"test-agent\"\n159:                     assert result[\"agent_endpoint\"] == \"http://test-agent.example.com\"\n160:                     assert result[\"status\"] == \"created\"\n161: \n162:     def test_deploy_agent_runtime_with_entrypoint(self) -> None:\n163:         with patch(\"kubernetes.config.load_kube_config\"):\n164:             mock_custom_api = MagicMock()\n165:             mock_result = {\n166:                 \"metadata\": {\"name\": \"test-agent\"},\n167:             }\n168:             mock_custom_api.create_namespaced_custom_object.return_value = mock_result\n169:             \n170:             mock_core_api = MagicMock()\n171:             mock_core_api.read_namespace.return_value = MagicMock()\n172:             \n173:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n174:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n175:                     provider = AgentCubeProvider()\n176:                     provider._custom_api = mock_custom_api\n177:                     provider._core_api = mock_core_api\n178:                     \n179:                     result = provider.deploy_agent_runtime(\n180:                         agent_name=\"test-agent\",\n181:                         image_url=\"registry.example.com/test:v1.0.0\",\n182:                         port=8080,\n183:                         entrypoint=\"python main.py\",\n184:                     )\n185:                     \n186:                     mock_custom_api.create_namespaced_custom_object.assert_called_once()\n187:                     call_body = mock_custom_api.create_namespaced_custom_object.call_args.kwargs[\"body\"]\n188:                     assert call_body[\"spec\"][\"entrypoint\"] == \"python main.py\"\n189: \n190:     def test_deploy_agent_runtime_patch_existing(self) -> None:\n191:         with patch(\"kubernetes.config.load_kube_config\"):\n192:             mock_custom_api = MagicMock()\n193:             mock_error = MagicMock()\n194:             mock_error.status = 409\n195:             mock_custom_api.create_namespaced_custom_object.side_effect = mock_error\n196:             \n197:             mock_result = {\n198:                 \"metadata\": {\"name\": \"test-agent\"},\n199:                 \"status\": {\"agentEndpoint\": \"http://test-agent.example.com\"},\n200:             }\n201:             mock_custom_api.patch_namespaced_custom_object.return_value = mock_result\n202:             \n203:             mock_core_api = MagicMock()\n204:             mock_core_api.read_namespace.return_value = MagicMock()\n205:             \n206:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n207:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n208:                     provider = AgentCubeProvider()\n209:                     provider._custom_api = mock_custom_api\n210:                     provider._core_api = mock_core_api\n211:                     \n212:                     result = provider.deploy_agent_runtime(\n213:                         agent_name=\"test-agent\",\n214:                         image_url=\"registry.example.com/test:v1.0.0\",\n215:                         port=8080,\n216:                     )\n217:                     \n218:                     assert result[\"status\"] == \"patched\"\n219:                     mock_custom_api.patch_namespaced_custom_object.assert_called_once()\n220: \n221:     def test_deploy_agent_runtime_crd_not_found(self) -> None:\n222:         with patch(\"kubernetes.config.load_kube_config\"):\n223:             mock_custom_api = MagicMock()\n224:             mock_error = MagicMock()\n225:             mock_error.status = 404\n226:             mock_custom_api.create_namespaced_custom_object.side_effect = mock_error\n227:             \n228:             mock_core_api = MagicMock()\n229:             mock_core_api.read_namespace.return_value = MagicMock()\n230:             \n231:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n232:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n233:                     provider = AgentCubeProvider()\n234:                     provider._custom_api = mock_custom_api\n235:                     provider._core_api = mock_core_api\n236:                     \n237:                     with pytest.raises(ValueError, match=\"AgentRuntime CRD not installed\"):\n238:                         provider.deploy_agent_runtime(\n239:                             agent_name=\"test-agent\",\n240:                             image_url=\"registry.example.com/test:v1.0.0\",\n241:                             port=8080,\n242:                         )\n243: \n244:     def test_deploy_agent_runtime_with_env_vars(self) -> None:\n245:         with patch(\"kubernetes.config.load_kube_config\"):\n246:             mock_custom_api = MagicMock()\n247:             mock_result = {\"metadata\": {\"name\": \"test-agent\"}}\n248:             mock_custom_api.create_namespaced_custom_object.return_value = mock_result\n249:             \n250:             mock_core_api = MagicMock()\n251:             mock_core_api.read_namespace.return_value = MagicMock()\n252:             \n253:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n254:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n255:                     provider = AgentCubeProvider()\n256:                     provider._custom_api = mock_custom_api\n257:                     provider._core_api = mock_core_api\n258:                     \n259:                     result = provider.deploy_agent_runtime(\n260:                         agent_name=\"test-agent\",\n261:                         image_url=\"registry.example.com/test:v1.0.0\",\n262:                         port=8080,\n263:                         workload_manager_url=\"http://wm\",\n264:                         router_url=\"http://router\",\n265:                         env_vars={\"CUSTOM_VAR\": \"value\"},\n266:                     )\n267:                     \n268:                     mock_custom_api.create_namespaced_custom_object.assert_called_once()\n269:                     call_body = mock_custom_api.create_namespaced_custom_object.call_args.kwargs[\"body\"]\n270:                     env_list = call_body[\"spec\"][\"env\"]\n271:                     assert {\"name\": \"WORKLOAD_MANAGER_URL\", \"value\": \"http://wm\"} in env_list\n272:                     assert {\"name\": \"ROUTER_URL\", \"value\": \"http://router\"} in env_list\n273:                     assert {\"name\": \"CUSTOM_VAR\", \"value\": \"value\"} in env_list\n274: \n275: \n276: class TestGetAgentRuntime:\n277:     def test_get_agent_runtime_success(self) -> None:\n278:         with patch(\"kubernetes.config.load_kube_config\"):\n279:             mock_custom_api = MagicMock()\n280:             mock_result = {\n281:                 \"metadata\": {\"name\": \"test-agent\"},\n282:                 \"status\": {\"agentEndpoint\": \"http://test-agent.example.com\"},\n283:             }\n284:             mock_custom_api.get_namespaced_custom_object.return_value = mock_result\n285:             \n286:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n287:                 with patch(\"kubernetes.client.CoreV1Api\"):\n288:                     provider = AgentCubeProvider()\n289:                     provider._custom_api = mock_custom_api\n290:                     \n291:                     result = provider.get_agent_runtime(\"test-agent\")\n292:                     \n293:                     assert result[\"metadata\"][\"name\"] == \"test-agent\"\n294: \n295:     def test_get_agent_runtime_not_found(self) -> None:\n296:         with patch(\"kubernetes.config.load_kube_config\"):\n297:             mock_custom_api = MagicMock()\n298:             mock_error = MagicMock()\n299:             mock_error.status = 404\n300:             mock_custom_api.get_namespaced_custom_object.side_effect = mock_error\n301:             \n302:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n303:                 with patch(\"kubernetes.client.CoreV1Api\"):\n304:                     provider = AgentCubeProvider()\n305:                     provider._custom_api = mock_custom_api\n306:                     \n307:                     result = provider.get_agent_runtime(\"nonexistent\")\n308:                     \n309:                     assert result is None\n310: \n311:     def test_get_agent_runtime_custom_namespace(self) -> None:\n312:         with patch(\"kubernetes.config.load_kube_config\"):\n313:             mock_custom_api = MagicMock()\n314:             mock_result = {\"metadata\": {\"name\": \"test-agent\"}}\n315:             mock_custom_api.get_namespaced_custom_object.return_value = mock_result\n316:             \n317:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n318:                 with patch(\"kubernetes.client.CoreV1Api\"):\n319:                     provider = AgentCubeProvider()\n320:                     provider._custom_api = mock_custom_api\n321:                     \n322:                     result = provider.get_agent_runtime(\"test-agent\", namespace=\"custom-ns\")\n323:                     \n324:                     mock_custom_api.get_namespaced_custom_object.assert_called_once()\n325:                     call_kwargs = mock_custom_api.get_namespaced_custom_object.call_args.kwargs\n326:                     assert call_kwargs[\"namespace\"] == \"custom-ns\"\n327: \n328: \n329: class TestDeleteAgentRuntime:\n330:     def test_delete_agent_runtime_success(self) -> None:\n331:         with patch(\"kubernetes.config.load_kube_config\"):\n332:             mock_custom_api = MagicMock()\n333:             mock_custom_api.delete_namespaced_custom_object.return_value = MagicMock()\n334:             \n335:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n336:                 with patch(\"kubernetes.client.CoreV1Api\"):\n337:                     provider = AgentCubeProvider()\n338:                     provider._custom_api = mock_custom_api\n339:                     \n340:                     result = provider.delete_agent_runtime(\"test-agent\")\n341:                     \n342:                     assert result[\"deleted\"] == True\n343:                     assert result[\"name\"] == \"test-agent\"\n344: \n345:     def test_delete_agent_runtime_not_found(self) -> None:\n346:         with patch(\"kubernetes.config.load_kube_config\"):\n347:             mock_custom_api = MagicMock()\n348:             mock_error = MagicMock()\n349:             mock_error.status = 404\n350:             mock_custom_api.delete_namespaced_custom_object.side_effect = mock_error\n351:             \n352:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n353:                 with patch(\"kubernetes.client.CoreV1Api\"):\n354:                     provider = AgentCubeProvider()\n355:                     provider._custom_api = mock_custom_api\n356:                     \n357:                     result = provider.delete_agent_runtime(\"nonexistent\")\n358:                     \n359:                     assert result[\"deleted\"] == False\n360:                     assert result[\"reason\"] == \"not_found\"\n361: \n362: \n363: class TestReadinessProbe:\n364:     def test_readiness_probe_default_values(self) -> None:\n365:         with patch(\"kubernetes.config.load_kube_config\"):\n366:             mock_custom_api = MagicMock()\n367:             mock_result = {\"metadata\": {\"name\": \"test-agent\"}}\n368:             mock_custom_api.create_namespaced_custom_object.return_value = mock_result\n369:             \n370:             mock_core_api = MagicMock()\n371:             mock_core_api.read_namespace.return_value = MagicMock()\n372:             \n373:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n374:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n375:                     provider = AgentCubeProvider()\n376:                     provider._custom_api = mock_custom_api\n377:                     provider._core_api = mock_core_api\n378:                     \n379:                     result = provider.deploy_agent_runtime(\n380:                         agent_name=\"test-agent\",\n381:                         image_url=\"registry.example.com/test:v1.0.0\",\n382:                         port=8080,\n383:                     )\n384:                     \n385:                     mock_custom_api.create_namespaced_custom_object.assert_called_once()\n386:                     call_body = mock_custom_api.create_namespaced_custom_object.call_args.kwargs[\"body\"]\n387:                     probe = call_body[\"spec\"][\"readinessProbe\"]\n388:                     assert probe[\"httpGet\"][\"path\"] == \"/health\"\n389:                     assert probe[\"httpGet\"][\"port\"] == 8080\n390: \n391:     def test_readiness_probe_custom_values(self) -> None:\n392:         with patch(\"kubernetes.config.load_kube_config\"):\n393:             mock_custom_api = MagicMock()\n394:             mock_result = {\"metadata\": {\"name\": \"test-agent\"}}\n395:             mock_custom_api.create_namespaced_custom_object.return_value = mock_result\n396:             \n397:             mock_core_api = MagicMock()\n398:             mock_core_api.read_namespace.return_value = MagicMock()\n399:             \n400:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n401:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n402:                     provider = AgentCubeProvider()\n403:                     provider._custom_api = mock_custom_api\n404:                     provider._core_api = mock_core_api\n405:                     \n406:                     result = provider.deploy_agent_runtime(\n407:                         agent_name=\"test-agent\",\n408:                         image_url=\"registry.example.com/test:v1.0.0\",\n409:                         port=8080,\n410:                         readiness_probe_path=\"/ready\",\n411:                         readiness_probe_port=9000,\n412:                     )\n413:                     \n414:                     mock_custom_api.create_namespaced_custom_object.assert_called_once()\n415:                     call_body = mock_custom_api.create_namespaced_custom_object.call_args.kwargs[\"body\"]\n416:                     probe = call_body[\"spec\"][\"readinessProbe\"]\n417:                     assert probe[\"httpGet\"][\"path\"] == \"/ready\"\n418:                     assert probe[\"httpGet\"][\"port\"] == 9000\n419: \n420: \n421: class TestImagePullSecrets:\n422:     def test_image_pull_secrets_default(self) -> None:\n423:         with patch(\"kubernetes.config.load_kube_config\"):\n424:             mock_custom_api = MagicMock()\n425:             mock_result = {\"metadata\": {\"name\": \"test-agent\"}}\n426:             mock_custom_api.create_namespaced_custom_object.return_value = mock_result\n427:             \n428:             mock_core_api = MagicMock()\n429:             mock_core_api.read_namespace.return_value = MagicMock()\n430:             \n431:             with patch(\"kubernetes.client.CustomObjectsApi\", return_value=mock_custom_api):\n432:                 with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n433:                     provider = AgentCubeProvider()\n434:                     provider._custom_api = mock_custom_api\n435:                     provider._core_api = mock_core_api\n436:                     \n437:                     result = provider.deploy_agent_runtime(\n438:                         agent_name=\"test-agent\",\n439:                         image_url=\"registry.example.com/test:v1.0.0\",\n440:                         port=8080,\n441:                     )\n442:                     \n443:                     mock_custom_api.create_namespaced_custom_object.assert_called_once()\n444:                     call_body = mock_custom_api.create_namespaced_custom_object.call_args.kwargs[\"body\"]\n445:                     secrets = call_body[\"spec\"][\"imagePullSecrets\"]\n446:                     assert secrets == [{\"name\": \"default-secret\"}]\n\n(End of file - total 446 lines)\n</content>","metadata":{"preview":"import pytest\nfrom unittest.mock import MagicMock, patch\n\nfrom agentcube.services.agentcube_provider import AgentCubeProvider\n\n\nclass TestAgentCubeProviderInit:\n    def test_init_default_namespace(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider()\n                    assert provider.namespace == \"default\"\n\n    def test_init_custom_namespace(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.CustomObjectsApi\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = AgentCubeProvider(namespace=\"custom-ns\")\n                    assert provider.namespace == \"custom-ns\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_agentcube_provider.py","time":{"start":1775878638746,"end":1775878638766}}}}
