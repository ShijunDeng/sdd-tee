nt.spec.replicas = 1\n            mock_deployment.status.available_replicas = 1\n            mock_apps_api.create_namespaced_deployment.return_value = MagicMock()\n            mock_apps_api.read_namespaced_deployment.return_value = mock_deployment\n            \n            mock_service = MagicMock()\n            mock_service.spec.ports = [MagicMock(node_port=30001)]\n            mock_core_api.create_namespaced_service.return_value = mock_service\n            mock_core_api.read_namespace.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = KubernetesProvider()\n                    provider._apps_api = mock_apps_api\n                    provider._core_api = mock_core_api\n                    \n                    result = provider.deploy_agent(\n                        agent_name=\"test-agent\",\n                        image_url=\"registry.example.com/test:v1.0.0\",\n                        port=8080,\n                    )\n                    \n                    assert result[\"deployment_name\"] == \"test-agent\"\n                    assert result[\"node_port\"] == 30001\n                    assert result[\"service_url\"] == \"http://localhost:30001\"\n\n\nclass TestGetAgentStatus:\n    def test_get_agent_status_success(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_apps_api = MagicMock()\n            mock_core_api = MagicMock()\n            \n            mock_deployment = MagicMock()\n            mock_deployment.spec.replicas = 2\n            mock_deployment.status.available_replicas = 2\n            mock_deployment.status.ready_replicas = 2\n            mock_apps_api.read_namespaced_deployment.return_value = mock_deployment\n            \n            mock_service = MagicMock()\n            mock_service.spec.ports = [MagicMock(node_port=30001)]\n            mock_core_api.read_namespaced_service.return_value = mock_service\n            \n            with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = KubernetesProvider()\n                    provider._apps_api = mock_apps_api\n                    provider._core_api = mock_core_api\n                    \n                    result = provider.get_agent_status(\"test-agent\")\n                    \n                    assert result[\"deployment\"][\"replicas\"] == 2\n                    assert result[\"service\"][\"node_port\"] == 30001\n\n\nclass TestDeleteAgent:\n    def test_delete_agent_success(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_apps_api = MagicMock()\n            mock_core_api = MagicMock()\n            \n            mock_apps_api.delete_namespaced_deployment.return_value = MagicMock()\n            mock_core_api.delete_namespaced_service.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = KubernetesProvider()\n                    provider._apps_api = mock_apps_api\n                    provider._core_api = mock_core_api\n                    \n                    result = provider.delete_agent(\"test-agent\")\n                    \n                    assert result[\"deployment_deleted\"] == True\n                    assert result[\"service_deleted\"] == True\n\n\nclass TestNodePortValidation:\n    def test_node_port_min_boundary(self) -> None:\n        assert KubernetesProvider.NODE_PORT_MIN == 30000\n\n    def test_node_port_max_boundary(self) -> None:\n        assert KubernetesProvider.NODE_PORT_MAX == 32767\n\n    def test_default_timeout(self) -> None:\n        assert KubernetesProvider.DEFAULT_TIMEOUT == 120\n\n    def test_poll_interval(self) -> None:\n        assert KubernetesProvider.POLL_INTERVAL == 2","after":"import pytest\nfrom unittest.mock import MagicMock, patch\nimport time\nimport kubernetes.client.exceptions\n\nfrom agentcube.services.k8s_provider import KubernetesProvider\n\n\nclass TestKubernetesProviderInit:\n    def test_init_default_namespace(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider()\n                    assert provider.namespace == \"default\"\n\n    def test_init_custom_namespace(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider(namespace=\"custom-ns\")\n                    assert provider.namespace == \"custom-ns\"\n\n    def test_init_verbose(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider(verbose=True)\n                    assert provider.verbose == True\n\n\nclass TestSanitizeName:\n    def test_sanitize_name_lowercase(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider()\n                    result = provider._sanitize_name(\"TestAgent\")\n                    assert result == \"testagent\"\n\n    def test_sanitize_name_replace_non_alphanumeric(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider()\n                    result = provider._sanitize_name(\"test-agent_123\")\n                    assert result == \"test-agent-123\"\n\n    def test_sanitize_name_truncate_to_63_chars(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider()\n                    long_name = \"a\" * 100\n                    result = provider._sanitize_name(long_name)\n                    assert len(result) == 63\n\n    def test_sanitize_name_strip_dashes(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider()\n                    result = provider._sanitize_name(\"---test---agent---\")\n                    assert result == \"test-agent\"\n\n    def test_sanitize_name_empty_string(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider()\n                    result = provider._sanitize_name(\"\")\n                    assert result == \"default\"\n\n    def test_sanitize_name_all_special_chars(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    provider = KubernetesProvider()\n                    result = provider._sanitize_name(\"!!!@@@###\")\n                    assert result == \"default\"\n\n\nclass TestEnsureNamespace:\n    def test_ensure_namespace_exists(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                mock_core_api = MagicMock()\n                mock_core_api.read_namespace.return_value = MagicMock()\n                \n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = KubernetesProvider()\n                    provider._core_api = mock_core_api\n                    provider._ensure_namespace()\n                    \n                    mock_core_api.read_namespace.assert_called_once_with(name=\"default\")\n\n    def test_ensure_namespace_creates_if_not_exists(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            with patch(\"kubernetes.client.AppsV1Api\"):\n                mock_core_api = MagicMock()\n                mock_error = MagicMock()\n                mock_error.status = 404\n                mock_core_api.read_namespace.side_effect = kubernetes.client.exceptions.ApiException(status=404)\n                \n                with patch(\"kubernetes.client.CoreV1Api\", return_value=mock_core_api):\n                    provider = KubernetesProvider(namespace=\"new-ns\")\n                    provider._core_api = mock_core_api\n                    provider._ensure_namespace()\n                    \n                    mock_core_api.create_namespace.assert_called_once()\n\n\nclass TestCreateDeployment:\n    def test_create_deployment_basic(self) -> None:\n        with patch(\"kubernetes.config.load_kube_config\"):\n            mock_apps_api = MagicMock()\n            mock_apps_api.create_namespaced_deployment.return_value = MagicMock()\n            \n            with patch(\"kubernetes.client.AppsV1Api\", return_value=mock_apps_api):\n                with patch(\"kubernetes.client.CoreV1Api\"):\n                    