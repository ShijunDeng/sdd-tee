  replicas: int = 1,\n45:         node_port: Optional[int] = None,\n46:         env_vars: Optional[Dict[str, str]] = None,\n47:     ) -> Dict[str, Any]:\n48:         sanitized_name = self._sanitize_name(agent_name)\n49:         self._ensure_namespace()\n50:         \n51:         try:\n52:             self._create_deployment(\n53:                 sanitized_name,\n54:                 image_url,\n55:                 port,\n56:                 entrypoint,\n57:                 replicas,\n58:                 env_vars,\n59:             )\n60:         except kubernetes.client.exceptions.ApiException as e:\n61:             if e.status == 409:\n62:                 self._patch_deployment(\n63:                     sanitized_name,\n64:                     image_url,\n65:                     port,\n66:                     entrypoint,\n67:                     replicas,\n68:                     env_vars,\n69:                 )\n70:             else:\n71:                 raise RuntimeError(f\"Failed to create deployment: {e}\")\n72:         \n73:         service_result = self._create_service(sanitized_name, port, node_port)\n74:         \n75:         self.wait_for_deployment_ready(sanitized_name)\n76:         \n77:         node_port_result = service_result.get(\"node_port\")\n78:         service_url = f\"http://localhost:{node_port_result}\" if node_port_result else None\n79:         \n80:         return {\n81:             \"deployment_name\": sanitized_name,\n82:             \"service_name\": sanitized_name,\n83:             \"node_port\": node_port_result,\n84:             \"service_url\": service_url,\n85:             \"replicas\": replicas,\n86:         }\n87: \n88:     def _create_deployment(\n89:         self,\n90:         name: str,\n91:         image_url: str,\n92:         port: int,\n93:         entrypoint: Optional[str],\n94:         replicas: int,\n95:         env_vars: Optional[Dict[str, str]],\n96:     ) -> Dict[str, Any]:\n97:         env_list = []\n98:         if env_vars:\n99:             for k, v in env_vars.items():\n100:                 env_list.append({\"name\": k, \"value\": v})\n101:         \n102:         command = None\n103:         if entrypoint:\n104:             parts = entrypoint.split()\n105:             command = parts\n106:         \n107:         deployment_body = {\n108:             \"apiVersion\": \"apps/v1\",\n109:             \"kind\": \"Deployment\",\n110:             \"metadata\": {\n111:                 \"name\": name,\n112:                 \"namespace\": self.namespace,\n113:                 \"labels\": {\"app\": name},\n114:             },\n115:             \"spec\": {\n116:                 \"replicas\": replicas,\n117:                 \"selector\": {\"matchLabels\": {\"app\": name}},\n118:                 \"template\": {\n119:                     \"metadata\": {\"labels\": {\"app\": name}},\n120:                     \"spec\": {\n121:                         \"containers\": [{\n122:                             \"name\": name,\n123:                             \"image\": image_url,\n124:                             \"ports\": [{\"containerPort\": port}],\n125:                             \"env\": env_list,\n126:                         }],\n127:                     },\n128:                 },\n129:             },\n130:         }\n131:         \n132:         if command:\n133:             deployment_body[\"spec\"][\"template\"][\"spec\"][\"containers\"][0][\"command\"] = command\n134:         \n135:         result = self._apps_api.create_namespaced_deployment(\n136:             namespace=self.namespace,\n137:             body=deployment_body,\n138:         )\n139:         \n140:         if self.verbose:\n141:             self._logger.info(f\"Created deployment {name} in namespace {self.namespace}\")\n142:         \n143:         return {\"name\": name, \"status\": \"created\"}\n144: \n145:     def _patch_deployment(\n146:         self,\n147:         name: str,\n148:         image_url: str,\n149:         port: int,\n150:         entrypoint: Optional[str],\n151:         replicas: int,\n152:         env_vars: Optional[Dict[str, str]],\n153:     ) -> Dict[str, Any]:\n154:         env_list = []\n155:         if env_vars:\n156:             for k, v in env_vars.items():\n157:                 env_list.append({\"name\": k, \"value\": v})\n158:         \n159:         command = None\n160:         if entrypoint:\n161:             parts = entrypoint.split()\n162:             command = parts\n163:         \n164:         deployment_body = {\n165:             \"spec\": {\n166:                 \"replicas\": replicas,\n167:                 \"template\": {\n168:                     \"spec\": {\n169:                         \"containers\": [{\n170:                             \"name\": name,\n171:                             \"image\": image_url,\n172:                             \"ports\": [{\"containerPort\": port}],\n173:                             \"env\": env_list,\n174:                         }],\n175:                     },\n176:                 },\n177:             },\n178:         }\n179:         \n180:         if command:\n181:             deployment_body[\"spec\"][\"template\"][\"spec\"][\"containers\"][0][\"command\"] = command\n182:         \n183:         result = self._apps_api.patch_namespaced_deployment(\n184:             name=name,\n185:             namespace=self.namespace,\n186:             body=deployment_body,\n187:         )\n188:         \n189:         if self.verbose:\n190:             self._logger.info(f\"Patched deployment {name} in namespace {self.namespace}\")\n191:         \n192:         return {\"name\": name, \"status\": \"updated\"}\n193: \n194:     def _create_service(\n195:         self, \n196:         name: str, \n197:         port: int, \n198:         node_port: Optional[int]\n199:     ) -> Dict[str, Any]:\n200:         service_body = {\n201:             \"apiVersion\": \"v1\",\n202:             \"kind\": \"Service\",\n203:             \"metadata\": {\n204:                 \"name\": name,\n205:                 \"namespace\": self.namespace,\n206:             },\n207:             \"spec\": {\n208:                 \"type\": \"NodePort\",\n209:                 \"selector\": {\"app\": name},\n210:                 \"ports\": [{\n211:                     \"port\": port,\n212:                     \"targetPort\": port,\n213:                 }],\n214:             },\n215:         }\n216:         \n217:         if node_port:\n218:             service_body[\"spec\"][\"ports\"][0][\"nodePort\"] = node_port\n219:         \n220:         try:\n221:             result = self._core_api.create_namespaced_service(\n222:                 namespace=self.namespace,\n223:                 body=service_body,\n224:             )\n225:             actual_node_port = result.spec.ports[0].node_port\n226:         except kubernetes.client.exceptions.ApiException as e:\n227:             if e.status == 409:\n228:                 result = self._core_api.patch_namespaced_service(\n229:                     name=name,\n230:                     namespace=self.namespace,\n231:                     body=service_body,\n232:                 )\n233:                 actual_node_port = result.spec.ports[0].node_port\n234:             else:\n235:                 raise RuntimeError(f\"Failed to create service: {e}\")\n236:         \n237:         if self.verbose:\n238:             self._logger.info(f\"Created service {name} with NodePort {actual_node_port}\")\n239:         \n240:         return {\"name\": name, \"node_port\": actual_node_port}\n241: \n242:     def wait_for_deployment_ready(self, name: str, timeout: int = 120) -> None:\n243:         start = time.time()\n244:         while time.time() - start < timeout:\n245:             try:\n246:                 deployment = self._apps_api.read_namespaced_deployment(\n247:                     name=name,\n248:                     namespace=self.namespace,\n249:                 )\n250:                 if deployment.status.available_replicas == deployment.spec.replicas:\n251:                     if self.verbose:\n252:                         self._logger.info(f\"Deployment {name} is ready\")\n253:                     return\n254:             except kubernetes.client.exceptions.ApiException as e:\n255:                 if self.verbose:\n256:                     self._logger.warning(f\"Error checking deployment status: {e}\")\n257:             time.sleep(self.POLL_INTERVAL)\n258:         raise TimeoutError(f\"Deployment {name} not ready after {timeout}s\")\n259: \n260:     def get_agent_status(self, agent_name: str) -> Dict[str, Any]:\n261:         sanitized_name = self._sanitize_name(agent_name)\n262:         \n263:         try:\n264:             deployment = self._apps_api.read_namespaced_deployment(\n265:                 name=sanitized_name,\n266:                 namespace=self.namespace,\n267:             )\n268:             deployment_status = {\n269:                 \"name\": sanitized_name,\n270:                 \"replicas\": deployment.spec.replicas,\n271:                 \"available_replicas\": deployment.status.available_replicas or 0,\n272:                 \"ready_replicas\": deployment.status.ready_replicas or 0,\n273:             }\n274:         except kubernetes.client.exceptions.ApiException:\n275:             deployment_status = {\"name\": sanitized_name, \"status\": \"not_found\"}\n276:         \n277:         try:\n278:             service = self._core_api.read_namespaced_service(\n279:                 name=sanitized_name,\n280:                 namespace=self.namespace,\n281:             )\n282:             service_status = {\n283:                 \"name\": sanitized_name,\n284:                 \"node_port\": service.spec.ports[0].node_port,\n285:             }\n286:         except kubernetes.client.exceptions.ApiException:\n287:             service_status = {\"name\": sanitized_name, \"status\": \"not_found\"}\n288:         \n289:         return {\n290:             \"deployment\": deployment_status,\n291:             \"service\": service_status,\n292:         }\n293: \n294:     def delete_agent(self, agent_name: str) -> Dict[str, Any]:\n295:         sanitized_name = self._sanitize_name(agent_name)\n296:         \n297:         try:\n298:             self._apps_api.delete_namespaced_deployment(\n299:                 name=sanitized_name,\n300:                 namespace=self.namespace,\n301:                 body=kubernetes.client.V1DeleteOptions(),\n302:             )\n303:             deployment_deleted = True\n304:         except kubernetes.client.exceptions.ApiException:\n305:             deployment_deleted = False\n306:         \n307:         try:\n308:             self._core_api.delete_namespaced_service(\n309:                 name=sanitized_name,\n310:                 namespace=self.namespace,\n311:             )\n312:             service_deleted = True\n313:         except kubernetes.client.exceptions.ApiException:\n314:             service_deleted = False\n315:         \n316:         return {\n317:             \"deployment_deleted\": deployment_deleted,\n318:             \"service_deleted\": service_deleted,\n319:         }\n320: \n321:     def _ensure_namespace(self) -> None:\n322:         try:\n323:             self._core_api.read_namespace(name=self.namespace)\n324:         except kubernetes.client.exceptions.ApiException as e:\n325:             if e.status == 404:\n326:                 namespace_body = {\n327:                     \"apiVersion\": \"v1\",\n328:                     \"kind\": \"Namespace\",\n329:                     \"metadata\": {\"name\": self.namespace},\n330:                 }\n331:                 self._core_api.create_namespace(body=namespace_body)\n332:                 if self.verbose:\n333:                     self._logger.info(f\"Created namespace {self.namespace}\")\n334:             else:\n335:                 raise\n336: \n337:     def _sanitize_name(self, name: str) -> str:\n338:         sanitized = name.lower()\n339:         sanitized = re.sub(r\"[^a-z0-9-]\", \"-\", sanitized)\n340:         sanitized = re.sub(r\"-+\", \"-\", sanitized)\n341:         sanitized = sanitized.strip(\"-\")\n342:         return sanitized[:63] if sanitized else \"default\"\n\n(End of file - total 342 lines)\n</content>","metadata":{"preview":"import logging\nimport re\nimport time\nfrom typing import Any, Dict, Optional\n\nimport kubernetes\nimport kubernetes.client\nimport kubernetes.config\n\n\nclass KubernetesProvider:\n    NODE_PORT_MIN = 30000\n    NODE_PORT_MAX = 32767\n    DEFAULT_TIMEOUT = 120\n    POLL_INTERVAL = 2\n\n    def __init__(\n        self,\n        namespace: str = \"default\",\n        verbose: bool = False,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/k8s_provider.py","time":{"start":1775878638739,"end":1775878638770}}}}
