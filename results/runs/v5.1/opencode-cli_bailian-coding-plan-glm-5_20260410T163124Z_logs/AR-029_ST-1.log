pters\n        assert \"https://\" in session.adapters\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_utils.py","time":{"start":1775881747601,"end":1775881747612}}}}
