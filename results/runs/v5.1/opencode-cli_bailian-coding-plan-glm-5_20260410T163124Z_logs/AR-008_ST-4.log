yStore) UpdateSandbox(_ context.Context, sandbox *types.SandboxInfo) error {\n50: \ts.mu.Lock()\n51: \tdefer s.mu.Unlock()\n52: \n53: \tif _, exists := s.sandboxes[sandbox.SessionID]; !exists {\n54: \t\treturn &NotFoundError{Resource: \"sandbox\", Name: sandbox.SessionID}\n55: \t}\n56: \n57: \ts.sandboxes[sandbox.SessionID] = sandbox\n58: \ts.expirationIndex[sandbox.SandboxID] = sandbox.ExpiresAt\n59: \n60: \treturn nil\n61: }\n62: \n63: func (s *MemoryStore) DeleteSandboxBySessionID(_ context.Context, sessionID string) error {\n64: \ts.mu.Lock()\n65: \tdefer s.mu.Unlock()\n66: \n67: \tsandbox, exists := s.sandboxes[sessionID]\n68: \tif !exists {\n69: \t\treturn nil\n70: \t}\n71: \n72: \tdelete(s.sandboxes, sessionID)\n73: \tdelete(s.expirationIndex, sandbox.SandboxID)\n74: \n75: \treturn nil\n76: }\n77: \n78: func (s *MemoryStore) ListSandboxes(_ context.Context) ([]*types.SandboxInfo, error) {\n79: \ts.mu.RLock()\n80: \tdefer s.mu.RUnlock()\n81: \n82: \tresult := make([]*types.SandboxInfo, 0, len(s.sandboxes))\n83: \tfor _, sandbox := range s.sandboxes {\n84: \t\tresult = append(result, sandbox)\n85: \t}\n86: \n87: \treturn result, nil\n88: }\n89: \n90: func (s *MemoryStore) ListExpiredSandboxes(_ context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n91: \ts.mu.RLock()\n92: \tdefer s.mu.RUnlock()\n93: \n94: \tvar expired []*types.SandboxInfo\n95: \tfor _, sandbox := range s.sandboxes {\n96: \t\tif sandbox.ExpiresAt.Before(before) {\n97: \t\t\texpired = append(expired, sandbox)\n98: \t\t}\n99: \t}\n100: \n101: \tsort.Slice(expired, func(i, j int) bool {\n102: \t\treturn expired[i].ExpiresAt.Before(expired[j].ExpiresAt)\n103: \t})\n104: \n105: \tif limit > 0 && len(expired) > limit {\n106: \t\texpired = expired[:limit]\n107: \t}\n108: \n109: \treturn expired, nil\n110: }\n111: \n112: func (s *MemoryStore) ListInactiveSandboxes(_ context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n113: \ts.mu.RLock()\n114: \tdefer s.mu.RUnlock()\n115: \n116: \tvar inactive []*types.SandboxInfo\n117: \tfor _, sandbox := range s.sandboxes {\n118: \t\tif !sandbox.LastActivity.IsZero() && sandbox.LastActivity.Before(before) {\n119: \t\t\tinactive = append(inactive, sandbox)\n120: \t\t}\n121: \t}\n122: \n123: \tsort.Slice(inactive, func(i, j int) bool {\n124: \t\treturn inactive[i].LastActivity.Before(inactive[j].LastActivity)\n125: \t})\n126: \n127: \tif limit > 0 && len(inactive) > limit {\n128: \t\tinactive = inactive[:limit]\n129: \t}\n130: \n131: \treturn inactive, nil\n132: }\n133: \n134: func (s *MemoryStore) Clear() {\n135: \ts.mu.Lock()\n136: \tdefer s.mu.Unlock()\n137: \n138: \ts.sandboxes = make(map[string]*types.SandboxInfo)\n139: \ts.expirationIndex = make(map[string]time.Time)\n140: }\n141: \n142: func (s *MemoryStore) Size() int {\n143: \ts.mu.RLock()\n144: \tdefer s.mu.RUnlock()\n145: \n146: \treturn len(s.sandboxes)\n147: }\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sort\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nvar ErrSandboxNotFound = &NotFoundError{Resource: \"sandbox\", Name: \"\"}\n\ntype MemoryStore struct {\n\tmu              sync.RWMutex\n\tsandboxes       map[string]*types.SandboxInfo\n\texpirationIndex map[string]time.Time\n}\n\nfunc NewMemoryStore() *MemoryStore {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store.go","time":{"start":1775848290053,"end":1775848290081}}}}
