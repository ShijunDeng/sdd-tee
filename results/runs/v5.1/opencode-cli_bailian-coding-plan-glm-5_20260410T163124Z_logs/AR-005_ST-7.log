erver) Start() <-chan error {\n45: \terrCh := make(chan error, 1)\n46: \ts.server.ReadTimeout = s.config.ReadTimeout\n47: \ts.server.WriteTimeout = s.config.WriteTimeout\n48: \ts.server.IdleTimeout = s.config.IdleTimeout\n49: \ts.server.Handler = s.router\n50: \n51: \tgo func() {\n52: \t\tif err := s.server.ListenAndServe(); err != http.ErrServerClosed {\n53: \t\t\terrCh <- err\n54: \t\t}\n55: \t}()\n56: \treturn errCh\n57: }\n58: \n59: // Stop gracefully shuts down the HTTP server within the configured timeout.\n60: func (s *HTTPServer) Stop(ctx context.Context) error {\n61: \tctx, cancel := context.WithTimeout(ctx, s.config.ShutdownTimeout)\n62: \tdefer cancel()\n63: \terr := s.server.Shutdown(ctx)\n64: \tclose(s.stopCh)\n65: \treturn err\n66: }\n67: \n68: // GracefulShutdown sets up signal handlers for SIGTERM and SIGINT.\n69: // When a signal is received, the server is stopped gracefully.\n70: func (s *HTTPServer) GracefulShutdown() {\n71: \tsigCh := make(chan os.Signal, 1)\n72: \tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n73: \tgo func() {\n74: \t\t<-sigCh\n75: \t\tctx := context.Background()\n76: \t\ts.Stop(ctx)\n77: \t}()\n78: }\n\n(End of file - total 78 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// HTTPServer manages the HTTP server lifecycle including graceful shutdown.\ntype HTTPServer struct {\n\tserver   *http.Server\n\trouter   chi.Router\n\tconfig   Config\n\thandlers map[string]Handler\n\tlogger   Logger\n\tstopCh   chan struct{}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go","time":{"start":1775844494145,"end":1775844494158}}}}
