box := makeTestSandbox(\"session-123\")\n47: \tdata, err := json.Marshal(sandbox)\n48: \trequire.NoError(t, err)\n49: \n50: \tkey := store.sessionKey(\"session-123\")\n51: \terr = store.cli.Do(ctx, store.cli.B().Set().Key(key).Value(string(data)).Build()).Error()\n52: \trequire.NoError(t, err)\n53: \n54: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n55: \trequire.NoError(t, err)\n56: \tassert.Equal(t, sandbox.SessionID, result.SessionID)\n57: \tassert.Equal(t, sandbox.SandboxID, result.SandboxID)\n58: }\n59: \n60: func TestValkeyStore_GetSandboxBySessionID_NotFound(t *testing.T) {\n61: \tstore := setupTestValkeyStore(t)\n62: \tctx := context.Background()\n63: \n64: \tresult, err := store.GetSandboxBySessionID(ctx, \"non-existent\")\n65: \tassert.Nil(t, result)\n66: \tassert.ErrorIs(t, err, ErrNotFound)\n67: }\n68: \n69: func TestValkeyStore_GetSandboxBySessionID_EmptySessionID(t *testing.T) {\n70: \tstore := setupTestValkeyStore(t)\n71: \tctx := context.Background()\n72: \n73: \tresult, err := store.GetSandboxBySessionID(ctx, \"\")\n74: \tassert.Nil(t, result)\n75: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n76: }\n77: \n78: func TestValkeyStore_StoreSandbox_Success(t *testing.T) {\n79: \tstore := setupTestValkeyStore(t)\n80: \tctx := context.Background()\n81: \n82: \tsandbox := makeTestSandbox(\"session-123\")\n83: \n84: \terr := store.StoreSandbox(ctx, sandbox)\n85: \trequire.NoError(t, err)\n86: \n87: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n88: \trequire.NoError(t, err)\n89: \tassert.Equal(t, sandbox.SessionID, result.SessionID)\n90: \n91: \tresp := store.cli.Do(ctx, store.cli.B().Zscore().Key(store.expiryIndexKey).Member(\"session-123\").Build())\n92: \trequire.NoError(t, resp.Error())\n93: \tscore, err := resp.AsFloat64()\n94: \trequire.NoError(t, err)\n95: \tassert.Equal(t, float64(sandbox.ExpiresAt.Unix()), score)\n96: \n97: \tresp = store.cli.Do(ctx, store.cli.B().Zscore().Key(store.lastActivityIndexKey).Member(\"session-123\").Build())\n98: \trequire.NoError(t, resp.Error())\n99: \tactivityScore, err := resp.AsFloat64()\n100: \trequire.NoError(t, err)\n101: \tassert.GreaterOrEqual(t, activityScore, float64(0))\n102: }\n103: \n104: func TestValkeyStore_StoreSandbox_NilSandbox(t *testing.T) {\n105: \tstore := setupTestValkeyStore(t)\n106: \tctx := context.Background()\n107: \n108: \terr := store.StoreSandbox(ctx, nil)\n109: \tassert.ErrorIs(t, err, ErrNilSandbox)\n110: }\n111: \n112: func TestValkeyStore_StoreSandbox_ZeroExpiresAt(t *testing.T) {\n113: \tstore := setupTestValkeyStore(t)\n114: \tctx := context.Background()\n115: \n116: \tsandbox := &types.SandboxInfo{\n117: \t\tSessionID: \"session-123\",\n118: \t\tExpiresAt: time.Time{},\n119: \t}\n120: \n121: \terr := store.StoreSandbox(ctx, sandbox)\n122: \tassert.ErrorIs(t, err, ErrZeroExpiresAt)\n123: }\n124: \n125: func TestValkeyStore_StoreSandbox_EmptySessionID(t *testing.T) {\n126: \tstore := setupTestValkeyStore(t)\n127: \tctx := context.Background()\n128: \n129: \tsandbox := &types.SandboxInfo{\n130: \t\tSessionID: \"\",\n131: \t\tExpiresAt: time.Now().Add(24 * time.Hour),\n132: \t}\n133: \n134: \terr := store.StoreSandbox(ctx, sandbox)\n135: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n136: }\n137: \n138: func TestValkeyStore_StoreSandbox_Duplicate(t *testing.T) {\n139: \tstore := setupTestValkeyStore(t)\n140: \tctx := context.Background()\n141: \n142: \tsandbox := makeTestSandbox(\"session-123\")\n143: \n144: \terr := store.StoreSandbox(ctx, sandbox)\n145: \trequire.NoError(t, err)\n146: \n147: \terr = store.StoreSandbox(ctx, sandbox)\n148: \tassert.Error(t, err)\n149: \tassert.ErrorIs(t, err, ErrSessionExists)\n150: }\n151: \n152: func TestValkeyStore_UpdateSandbox_Success(t *testing.T) {\n153: \tstore := setupTestValkeyStore(t)\n154: \tctx := context.Background()\n155: \n156: \tsandbox := makeTestSandbox(\"session-123\")\n157: \terr := store.StoreSandbox(ctx, sandbox)\n158: \trequire.NoError(t, err)\n159: 