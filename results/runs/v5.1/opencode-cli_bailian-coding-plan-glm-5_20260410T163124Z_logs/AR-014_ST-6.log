e\", results[0].SessionID)\n379: }\n380: \n381: func TestValkeyStore_ListInactiveSandboxes_Limit(t *testing.T) {\n382: \tstore := setupTestValkeyStore(t)\n383: \tctx := context.Background()\n384: \n385: \tnow := time.Now()\n386: \n387: \tfor i := 0; i < 20; i++ {\n388: \t\tsandbox := &types.SandboxInfo{\n389: \t\t\tKind:             types.AgentRuntimeKind,\n390: \t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n391: \t\t\tSandboxNamespace: \"default\",\n392: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n393: \t\t\tCreatedAt:        now,\n394: \t\t\tExpiresAt:        now.Add(8 * time.Hour),\n395: \t\t\tStatus:           \"active\",\n396: \t\t\tLastActivity:     now.Add(-time.Duration(i+20) * time.Minute),\n397: \t\t}\n398: \t\terr := store.StoreSandbox(ctx, sandbox)\n399: \t\trequire.NoError(t, err)\n400: \t}\n401: \n402: \tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 5)\n403: \trequire.NoError(t, err)\n404: \tassert.Len(t, results, 5)\n405: }\n406: \n407: func TestValkeyStore_ListInactiveSandboxes_ZeroLimit(t *testing.T) {\n408: \tstore := setupTestValkeyStore(t)\n409: \tctx := context.Background()\n410: \n411: \tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n412: \trequire.NoError(t, err)\n413: \tassert.Nil(t, results)\n414: }\n415: \n416: func TestValkeyStore_ListInactiveSandboxes_Empty(t *testing.T) {\n417: \tstore := setupTestValkeyStore(t)\n418: \tctx := context.Background()\n419: \n420: \tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 10)\n421: \trequire.NoError(t, err)\n422: \tassert.Nil(t, results)\n423: }\n424: \n425: func TestValkeyStore_UpdateSessionLastActivity_Success(t *testing.T) {\n426: \tstore := setupTestValkeyStore(t)\n427: \tctx := context.Background()\n428: \n429: \tsandbox := makeTestSandbox(\"session-123\")\n430: \terr := store.StoreSandbox(ctx, sandbox)\n431: \trequire.NoError(t, err)\n432: \n433: \tnewActivity := time.Now().Add(1 * time.Hour)\n434: \terr = store.UpdateSessionLastActivity(ctx, \"session-123\", newActivity)\n435: \trequire.NoError(t, err)\n436: \n437: \tresp := store.cli.Do(ctx, store.cli.B().Zscore().Key(store.lastActivityIndexKey).Member(\"session-123\").Build())\n438: \trequire.NoError(t, resp.Error())\n439: \tscore, err := resp.AsFloat64()\n440: \trequire.NoError(t, err)\n441: \tassert.Equal(t, float64(newActivity.Unix()), score)\n442: }\n443: \n444: func TestValkeyStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n445: \tstore := setupTestValkeyStore(t)\n446: \tctx := context.Background()\n447: \n448: \tsandbox := makeTestSandbox(\"session-123\")\n449: \terr := store.StoreSandbox(ctx, sandbox)\n450: \trequire.NoError(t, err)\n451: \n452: \tbefore := time.Now()\n453: \terr = store.UpdateSessionLastActivity(ctx, \"session-123\", time.Time{})\n454: \trequire.NoError(t, err)\n455: \n456: \tresp := store.cli.Do(ctx, store.cli.B().Zscore().Key(store.lastActivityIndexKey).Member(\"session-123\").Build())\n457: \trequire.NoError(t, resp.Error())\n458: \tscore, err := resp.AsFloat64()\n459: \trequire.NoError(t, err)\n460: \tassert.GreaterOrEqual(t, score, float64(before.Unix()))\n461: }\n462: \n463: func TestValkeyStore_UpdateSessionLastActivity_NotFound(t *testing.T) {\n464: \tstore := setupTestValkeyStore(t)\n465: \tctx := context.Background()\n466: \n467: \terr := store.UpdateSessionLastActivity(ctx, \"non-existent\", time.Now())\n468: \tassert.ErrorIs(t, err, ErrNotFound)\n469: }\n470: \n471: func TestValkeyStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n472: \tstore := setupTestValkeyStore(t)\n473: \tctx := context.Background()\n474: \n475: \terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n476: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n477: }\n478: \n479: func TestValkeyStore_Close(t *testing.T) {\n480: \tmr := miniredis.RunT(t)\n481: \tcli, err := valkey.NewClient(valkey.ClientOption{\n482: \t\tInitAddress:       []string{mr.Addr()},\n483: \t\tDisableCache:      true,\n484: \t\tForceSingleClient: true,\n485: \t})\n486: \trequire.NoError(t, err)\n487: \tstore := &valkeyStore{\n488: \t\tcli:                  cli,\n489: \t\tsessionPrefix:        defaultSessionPrefix,\n490: \t\texpiryIndexKey:       defaultExpiryIndexKey,\n491: \t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n492: \t}\n493: \n494: \terr = store.Close()\n495: \trequire.NoError(t, err)\n496: }\n497: \n498: func TestNewValkeyStore(t *testing.T) {\n499: \tmr := miniredis.RunT(t)\n500: \tstore := NewValkeyStore(mr.Addr(), \"\")\n501: \n502: \trequire.NotNil(t, store)\n503: \n504: \tctx := context.Background()\n505: \terr := store.Ping(ctx)\n506: \trequire.NoError(t, err)\n507: \n508: \terr = store.Close()\n509: \trequire.NoError(t, err)\n510: }\n511: \n512: func TestNewValkeyStoreWithOptions(t *testing.T) {\n513: \tmr := miniredis.RunT(t)\n514: \tstore := NewValkeyStoreWithOptions(mr.Addr(), \"\", \"custom:\", \"custom:expiry\", \"custom:activity\")\n515: \n516: \trequire.NotNil(t, store)\n517: \n518: \tvs := store.(*valkeyStore)\n519: \tassert.Equal(t, \"custom:\", vs.sessionPrefix)\n520: \tassert.Equal(t, \"custom:expiry\", vs.expiryIndexKey)\n521: \tassert.Equal(t, \"custom:activity\", vs.lastActivityIndexKey)\n522: \n523: \terr := store.Close()\n524: \trequire.NoError(t, err)\n525: }\n526: \n527: func TestNewValkeyStoreWithClient(t *testing.T) {\n528: \tmr := miniredis.RunT(t)\n529: \tcli, err := valkey.NewClient(valkey.ClientOption{\n530: \t\tInitAddress:       []string{mr.Addr()},\n531: \t\tDisableCache:      true,\n532: \t\tForceSingleClient: true,\n533: \t})\n534: \trequire.NoError(t, err)\n535: \n536: \tstore := NewValkeyStoreWithClient(cli)\n537: \trequire.NotNil(t, store)\n538: \n539: \tctx := context.Background()\n540: \terr = store.Ping(ctx)\n541: \trequire.NoError(t, err)\n542: }\n543: \n544: func TestValkeyStore_ErrorHandling(t *testing.T) {\n545: \tstore := setupTestValkeyStore(t)\n546: \tctx := context.Background()\n547: \n548: \tkey := store.sessionK