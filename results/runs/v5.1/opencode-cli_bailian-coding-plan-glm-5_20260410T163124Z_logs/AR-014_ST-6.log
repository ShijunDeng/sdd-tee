ank().Key(store.lastActivityIndexKey).Member(\"session-123\").Build())\n216: \tassert.True(t, valkey.IsValkeyNil(resp.Error()))\n217: }\n218: \n219: func TestValkeyStore_DeleteSandboxBySessionID_NotFound(t *testing.T) {\n220: \tstore := setupTestValkeyStore(t)\n221: \tctx := context.Background()\n222: \n223: \terr := store.DeleteSandboxBySessionID(ctx, \"non-existent\")\n224: \tassert.NoError(t, err)\n225: }\n226: \n227: func TestValkeyStore_DeleteSandboxBySessionID_EmptySessionID(t *testing.T) {\n228: \tstore := setupTestValkeyStore(t)\n229: \tctx := context.Background()\n230: \n231: \terr := store.DeleteSandboxBySessionID(ctx, \"\")\n232: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n233: }\n234: \n235: func TestValkeyStore_ListExpiredSandboxes_Success(t *testing.T) {\n236: \tstore := setupTestValkeyStore(t)\n237: \tctx := context.Background()\n238: \n239: \tnow := time.Now()\n240: \n241: \texpiredSandbox := &types.SandboxInfo{\n242: \t\tKind:             types.AgentRuntimeKind,\n243: \t\tSandboxID:        \"sb-expired\",\n244: \t\tSandboxNamespace: \"default\",\n245: \t\tSessionID:        \"session-expired\",\n246: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n247: \t\tExpiresAt:        now.Add(-2 * time.Hour),\n248: \t\tStatus:           \"active\",\n249: \t\tLastActivity:     now.Add(-10 * time.Hour),\n250: \t}\n251: \n252: \tactiveSandbox := &types.SandboxInfo{\n253: \t\tKind:             types.AgentRuntimeKind,\n254: \t\tSandboxID:        \"sb-active\",\n255: \t\tSandboxNamespace: \"default\",\n256: \t\tSessionID:        \"session-active\",\n257: \t\tCreatedAt:        now,\n258: \t\tExpiresAt:        now.Add(8 * time.Hour),\n259: \t\tStatus:           \"active\",\n260: \t\tLastActivity:     now,\n261: \t}\n262: \n263: \terr := store.StoreSandbox(ctx, expiredSandbox)\n264: \trequire.NoError(t, err)\n265: \terr = store.StoreSandbox(ctx, activeSandbox)\n266: \trequire.NoError(t, err)\n267: \n268: \tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n269: \trequire.NoError(t, err)\n270: \tassert.Len(t, results, 1)\n271: \tassert.Equal(t, \"session-expired\", results[0].SessionID)\n272: }\n273: \n274: func TestValkeyStore_ListExpiredSandboxes_Limit(t *testing.T) {\n275: \tstore := setupTestValkeyStore(t)\n276: \tctx := context.Background()\n277: \n278: \tnow := time.Now()\n279: \n280: \tfor i := 0; i < 20; i++ {\n281: \t\tsandbox := &types.SandboxInfo{\n282: \t\t\tKind:             types.AgentRuntimeKind,\n283: \t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n284: \t\t\tSandboxNamespace: \"default\",\n285: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n286: \t\t\tCreatedAt:        now.Add(-10 * time.Hour),\n287: \t\t\tExpiresAt:        now.Add(-time.Duration(i+1) * time.Hour),\n288: \t\t\tStatus:           \"active\",\n289: \t\t\tLastActivity:     now.Add(-10 * time.Hour),\n290: \t\t}\n291: \t\terr := store.StoreSandbox(ctx, sandbox)\n292: \t\trequire.NoError(t, err)\n293: \t}\n294: \n295: \tresults, err := store.ListExpiredSandboxes(ctx, now, 5)\n296: \trequire.NoError(t, err)\n297: \tassert.Len(t, results, 5)\n298: }\n299: \n300: func TestValkeyStore_ListExpiredSandboxes_ZeroLimit(t *testing.T) {\n301: \tstore := setupTestValkeyStore(t)\n302: \tctx := context.Background()\n303: \n304: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n305: \trequire.NoError(t, err)\n306: \tassert.Nil(t, results)\n307: }\n308: \n309: func TestValkeyStore_ListExpiredSandboxes_NegativeLimit(t *testing.T) {\n310: \tstore := setupTestValkeyStore(t)\n311: \tctx := context.Background()\n312: \n313: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n314: \trequire.NoError(t, err)\n315: \tassert.Nil(t, results)\n316: }\n317: \n318: func TestValkeyStore_ListExpiredSandboxes_SkipMissing(t *testing.T) {\n319: \tstore := setupTestValkeyStore(t)\n320: \tctx := context.Background()\n321: \n322: \tnow := time.Now()\n323: \n324: \terr := store.cli.Do(ctx, store.cli.B().Zadd().Key(store.expiryIndexKey).\n3