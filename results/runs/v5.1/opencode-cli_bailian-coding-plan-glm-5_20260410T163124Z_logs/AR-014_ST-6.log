\n45: func TestRedisStore_Ping(t *testing.T) {\n46: \tstore := setupTestRedisStore(t)\n47: \tctx := context.Background()\n48: \n49: \terr := store.Ping(ctx)\n50: \trequire.NoError(t, err)\n51: }\n52: \n53: func TestRedisStore_GetSandboxBySessionID_Success(t *testing.T) {\n54: \tstore := setupTestRedisStore(t)\n55: \tctx := context.Background()\n56: \n57: \tsandbox := makeTestSandbox(\"session-123\")\n58: \tdata, err := json.Marshal(sandbox)\n59: \trequire.NoError(t, err)\n60: \n61: \terr = store.cli.Set(ctx, store.sessionKey(\"session-123\"), data, 0).Err()\n62: \trequire.NoError(t, err)\n63: \n64: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n65: \trequire.NoError(t, err)\n66: \tassert.Equal(t, sandbox.SessionID, result.SessionID)\n67: \tassert.Equal(t, sandbox.SandboxID, result.SandboxID)\n68: }\n69: \n70: func TestRedisStore_GetSandboxBySessionID_NotFound(t *testing.T) {\n71: \tstore := setupTestRedisStore(t)\n72: \tctx := context.Background()\n73: \n74: \tresult, err := store.GetSandboxBySessionID(ctx, \"non-existent\")\n75: \tassert.Nil(t, result)\n76: \tassert.ErrorIs(t, err, ErrNotFound)\n77: }\n78: \n79: func TestRedisStore_GetSandboxBySessionID_EmptySessionID(t *testing.T) {\n80: \tstore := setupTestRedisStore(t)\n81: \tctx := context.Background()\n82: \n83: \tresult, err := store.GetSandboxBySessionID(ctx, \"\")\n84: \tassert.Nil(t, result)\n85: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n86: }\n87: \n88: func TestRedisStore_StoreSandbox_Success(t *testing.T) {\n89: \tstore := setupTestRedisStore(t)\n90: \tctx := context.Background()\n91: \n92: \tsandbox := makeTestSandbox(\"session-123\")\n93: \n94: \terr := store.StoreSandbox(ctx, sandbox)\n95: \trequire.NoError(t, err)\n96: \n97: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n98: \trequire.NoError(t, err)\n99: \tassert.Equal(t, sandbox.SessionID, result.SessionID)\n100: \n101: \texpiryScore, err := store.cli.ZScore(ctx, store.expiryIndexKey, \"session-123\").Result()\n102: \trequire.NoError(t, err)\n103: \tassert.Equal(t, float64(sandbox.ExpiresAt.Unix()), expiryScore)\n104: \n105: \tactivityScore, err := store.cli.ZScore(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n106: \trequire.NoError(t, err)\n107: \tassert.GreaterOrEqual(t, activityScore, float64(0))\n108: }\n109: \n110: func TestRedisStore_StoreSandbox_NilSandbox(t *testing.T) {\n111: \tstore := setupTestRedisStore(t)\n112: \tctx := context.Background()\n113: \n114: \terr := store.StoreSandbox(ctx, nil)\n115: \tassert.ErrorIs(t, err, ErrNilSandbox)\n116: }\n117: \n118: func TestRedisStore_StoreSandbox_ZeroExpiresAt(t *testing.T) {\n119: \tstore := setupTestRedisStore(t)\n120: \tctx := context.Background()\n121: \n122: \tsandbox := &types.SandboxInfo{\n123: \t\tSessionID: \"session-123\",\n124: \t\tExpiresAt: time.Time{},\n125: \t}\n126: \n127: \terr := store.StoreSandbox(ctx, sandbox)\n128: \tassert.ErrorIs(t, err, ErrZeroExpiresAt)\n129: }\n130: \n131: func TestRedisStore_StoreSandbox_EmptySessionID(t *testing.T) {\n132: \tstore := setupTestRedisStore(t)\n133: \tctx := context.Background()\n134: \n135: \tsandbox := &types.SandboxInfo{\n136: \t\tSessionID: \"\",\n137: \t\tExpiresAt: time.Now().Add(24 * time.Hour),\n138: \t}\n139: \n140: \terr := store.StoreSandbox(ctx, sandbox)\n141: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n142: }\n143: \n144: func TestRedisStore_StoreSandbox_Duplicate(t *testing.T) {\n145: \tstore := setupTestRedisStore(t)\n146: \tctx := context.Background()\n147: \n148: \tsandbox := makeTestSandbox(\"session-123\")\n149: \n150: \terr := store.StoreSandbox(ctx, sandbox)\n151: \trequire.NoError(t, err)\n152: \n153: \terr = store.StoreSandbox(ctx, sandbox)\n154: \tassert.Error(t, err)\n155: }\n156: \n157: func TestRedisStore_UpdateSandbox_Success(t *testing.T) {\n158: \tstore := setupTestRedisStore(t)\n159: \tctx := context.Background()\n160: \n161: \tsandbox := makeTestSandbox(\"session-123\")\n162: \terr := store.StoreSandbox(ctx, sandbox)\n163: \trequire.NoError(t, err)\n164: \n165: \tsandbox.Status = \"terminating\"\n166: \terr = store.UpdateSandbox(ctx, sandbox)\n167: \trequire.NoError(t, err)\n168: \n169: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n170: \trequire.NoError(t, err)\n171: \tassert.Equal(t, \"terminating\", result.Status)\n172: }\n173: \n174: func TestRedisStore_UpdateSandbox_NotFound(t *testing.T) {\n175: \tstore := setupTestRedisStore(t)\n176: \tctx := context.Background()\n177: \n178: \tsandbox := makeTestSandbox(\"non-existent\")\n179: \n180: \terr := store.UpdateSandbox(ctx, sandbox)\n181: \tassert.ErrorIs(t, err, ErrNotFound)\n182: }\n183: \n184: func TestRedisStore_UpdateSandbox_NilSandbox(t *testing.T) {\n185: \tstore := setupTestRedisStore(t)\n186: \tctx := context.Background()\n187: \n188: \terr := store.UpdateSandbox(ctx, nil)\n189: \tassert.ErrorIs(t, err, ErrNilSandbox)\n190: }\n191: \n192: func TestRedisStore_UpdateSandbox_EmptySessionID(t *testing.T) {\n193: \tstore := setupTestRedisStore(t)\n194: \tctx := context.Background()\n195: \n196: \tsandbox := &types.SandboxInfo{SessionID: \"\"}\n197: \n198: \terr := store.UpdateSandbox(ctx, sandbox)\n199: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n200: }\n201: \n202: func TestRedisStore_DeleteSandboxBySessionID_Success(t *testing.T) {\n203: \tstore := setupTestRedisStore(t)\n204: \tctx := context.Background()\n205: \n206: \tsandbox := makeTestSandbox(\"session-123\")\n207: \terr := store.StoreSandbox(ctx, sandbox)\n208: \trequire.NoError(t, err)\n209: \n210: \terr = store.DeleteSandboxBySessionID(ctx, \"session-123\")\n211: \trequire.NoError(t, err)\n212: \n213: \tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n214: \tassert.Nil(t, result)\n215: \tassert.ErrorIs(t, err, ErrNotFound)\n216: \n217: \t_, err = store.cli.ZRank(ctx, store.expiryIndexKey, \"session-123\").Result()\n218: \tassert.Error(t, err)\n219: \n220: \t_, err = store.cli.ZRank(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n221: \tassert.Error(t, err)\n222: }\n223: \n224: func TestRedisStore_DeleteSandboxBySessionID_NotFound(t *testing.T) {\n225: \tstore := setupTestRedisStore(t)\n226: \tctx := context.Background()\n227: \n228: \terr := store.DeleteSandboxBySessionID(ctx, \"non-existent\")\n229: \tassert.NoError(t, err)\n230: }\n231: \n232: func TestRedisStore_DeleteSandboxBySessionID_EmptySessionID(t *testing.T) {\n233: \tstore := setupTestRedisStore(t)\n234: \tctx := context.Background()\n235: \n236: \terr := store.DeleteSandboxBySessionID(ctx, \"\")\n237: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n238: }\n239: \n240: func TestRedisStore_ListExpiredSandboxes_Success(t *testing.T) {\n241: \tstore := setupTestRedisStore(t)\n242: \tctx := context.Background()\n243: \n244: \tnow := time.Now()\n245: \n246: \texpiredSandbox := &types.SandboxInfo{\n247: \t\tKind:             types.AgentRuntimeKind,\n248: \t\tSandboxID:        \"sb-expired\",\n249: \t\tSandboxNamespace: \"default\",\n250: \t\tSessionID:        \"session-expired\",\n251: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n252: \t\tExpiresAt:        now.Add(-2 * time.Hour),\n253: \t\tStatus:           \"active\",\n254: \t\tLastActivity:     now.Add(-10 * time.Hour),\n255: \t}\n256: \n257: \tactiveSandbox := &types.SandboxInfo{\n258: \t\tKind:             types.AgentRuntimeKind,\n259: \t\tSandboxID:        \"sb-active\",\n260: \t\tSandboxNamespace: \"default\",\n261: \t\tSessionID:        \"session-active\",\n262: \t\tCreatedAt:        now,\n263: \t\tExpiresAt:        now.Add(8 * time.Hour),\n264: \t\tStatus:           \"active\",\n265: \t\tLastActivity:     now,\n266: \t}\n267: \n268: \terr := store.StoreSandbox(ctx, expiredSandbox)\n269: \trequire.NoError(t, err)\n270: \terr = store.StoreSandbox(ctx, activeSandbox)\n271: \trequire.NoError(t, err)\n272: \n273: \tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n274: \trequire.NoError(t, err)\n275: \tassert.Len(t, results, 1)\n276: \tassert.Equal(t, \"session-expired\", results[0].SessionID)\n277: }\n278: \n279: func TestRedisStore_ListExpiredSandboxes_Limit(t *testing.T) {\n280: \tstore := setupTestRedisStore(t)\n281: \tctx := context.Background()\n282: \n283: \tnow := time.Now()\n284: \n285: \tfor i := 0; i < 20; i++ {\n286: \t\tsandbox := &types.SandboxInfo{\n287: \t\t\tKind:             types.AgentRuntimeKind,\n288: \t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n289: \t\t\tSandboxNamespace: \"default\",\n290: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n291: \t\t\tCreatedAt:        now.Add(-10 * time.Hour),\n292: \t\t\tExpiresAt:        now.Add(-time.Duration(i+1) * time.Hour),\n293: \t\t\tStatus:           \"active\",\n294: \t\t\tLastActivity:     now.Add(-10 * time.Hour),\n295: \t\t}\n296: \t\terr := store.StoreSandbox(ctx, sandbox)\n297: \t\trequire.NoError(t, err)\n298: \t}\n299: \n300: \tresults, err := store.ListExpiredSandboxes(ctx, now, 5)\n301: \trequire.NoError(t, err)\n302: \tassert.Len(t, results, 5)\n303: }\n304: \n305: func TestRedisStore_ListExpiredSandboxes_ZeroLimit(t *testing.T) {\n306: \tstore := setupTestRedisStore(t)\n307: \tctx := context.Background()\n308: \n309: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n310: \trequire.NoError(t, err)\n311: \tassert.Nil(t, results)\n312: }\n313: \n314: func TestRedisStore_ListExpiredSandboxes_NegativeLimit(t *testing.T) {\n315: \tstore := setupTestRedisStore(t)\n316: \tctx := context.Background()\n317: \n318: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n319: \trequire.NoError(t, err)\n320: \tassert.Nil(t, results)\n321: }\n322: \n323: func TestRedisStore_ListExpiredSandboxes_SkipMissing(t *testing.T) {\n324: \tstore := setupTestRedisStore(t)\n325: \tctx := context.Background()\n326: \n327: \tnow := time.Now()\n328: \n329: \terr := store.cli.ZAdd(ctx, store.expiryIndexKey, redisv9.Z{\n330: \t\tScore:  float64(now.Add(-1 * time.Hour).Unix()),\n331: \t\tMember: \"orphan-session\",\n332: \t}).Err()\n333: \trequire.NoError(t, err)\n334: \n335: \tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n336: \trequire.NoError(t, err)\n337: \tassert.Len(t, results, 0)\n338: }\n339: \n340: func TestRedisStore_ListInactiveSandboxes_Success(t *testing.T) {\n341: \tstore := setupTestRedisStore(t)\n342: \tctx := context.Background()\n343: \n344: \tnow := time.Now()\n345: \n346: \tinactiveSandbox := &types.SandboxInfo{\n347: \t\tKind:             types.AgentRuntimeKind,\n348: \t\tSandboxID:        \"sb-inactive\",\n349: \t\tSandboxNamespace: \"default\",\n350: \t\tSessionID:        \"session-inactive\",\n351: \t\tCreatedAt:        now,\n352: \t\tExpiresAt:        now.Add(8 * time.Hour),\n353: \t\tStatus:           \"active\",\n354: \t\tLastActivity:     now.Add(-30 * time.Minute),\n355: \t}\n356: \n357: \tactiveSandbox := &types.SandboxInfo{\n358: \t\tKind:             types.AgentRuntimeKind,\n359: \t\tSandboxID:        \"sb-active\",\n360: \t\tSandboxNamespace: \"default\",\n361: \t\tSessionID:        \"session-active\",\n362: \t\tCreatedAt:        now,\n363: \t\tExpiresAt:        now.Add(8 * time.Hour),\n364: \t\tStatus:           \"active\",\n365: \t\tLastActivity:     now,\n366: \t}\n367: \n368: \terr := store.StoreSandbox(ctx, inactiveSandbox)\n369: \trequire.NoError(t, err)\n370: \terr = store.StoreSandbox(ctx, activeSandbox)\n371: \trequire.NoError(t, err)\n372: \n373: \tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 10)\n374: \trequire.NoError(t, err)\n375: \tassert.Len(t, results, 1)\n376: \tassert.Equal(t, \"session-inactive\", results[0].SessionID)\n377: }\n378: \n379: func TestRedisStore_ListInactiveSandboxes_Limit(t *testing.T) {\n380: \tstore := setupTestRedisStore(t)\n381: \tctx := context.Background()\n382: \n383: \tnow := time.Now()\n384: \n385: \tfor i := 0; i < 20; i++ {\n386: \t\tsandbox := &types.SandboxInfo{\n387: \t\t\tKind:             types.AgentRuntimeKind,\n388: \t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n389: \t\t\tSandboxNamespace: \"default\",\n390: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n391: \t\t\tCreatedAt:        now,\n392: \t\t\tExpiresAt:        now.Add(8 * time.Hour),\n393: \t\t\tStatus:           \"active\",\n394: \t\t\tLastActivity:     now.Add(-time.Duration(i+20) * time.Minute),\n395: \t\t}\n396: \t\terr := store.StoreSandbox(ctx, sandbox)\n397: \t\trequire.NoError(t, err)\n398: \t}\n399: \n400: \tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 5)\n401: \trequire.NoError(t, err)\n402: \tassert.Len(t, results, 5)\n403: }\n404: \n405: func TestRedisStore_ListInactiveSandboxes_ZeroLimit(t *testing.T) {\n406: \tstore := setupTestRedisStore(t)\n407: \tctx := context.Background()\n408: \n409: \tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n410: \trequire.NoError(t, err)\n411: \tassert.Nil(t, results)\n412: }\n413: \n414: func TestRedisStore_UpdateSessionLastActivity_Success(t *testing.T) {\n415: \tstore := setupTestRedisStore(t)\n416: \tctx := context.Background()\n417: \n418: \tsandbox := makeTestSandbox(\"session-123\")\n419: \terr := store.StoreSandbox(ctx, sandbox)\n420: \trequire.NoError(t, err)\n421: \n422: \tnewActivity := time.Now().Add(1 * time.Hour)\n423: \terr = store.UpdateSessionLastActivity(ctx, \"session-123\", newActivity)\n424: \trequire.NoError(t, err)\n425: \n426: \tscore, err := store.cli.ZScore(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n427: \trequire.NoError(t, err)\n428: \tassert.Equal(t, float64(newActivity.Unix()), score)\n429: }\n430: \n431: func TestRedisStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n432: \tstore := setupTestRedisStore(t)\n433: \tctx := context.Background()\n434: \n435: \tsandbox := makeTestSandbox(\"session-123\")\n436: \terr := store.StoreSandbox(ctx, sandbox)\n437: \trequire.NoError(t, err)\n438: \n439: \tbefore := time.Now()\n440: \terr = store.UpdateSessionLastActivity(ctx, \"session-123\", time.Time{})\n441: \trequire.NoError(t, err)\n442: \n443: \tscore, err := store.cli.ZScore(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n444: \trequire.NoError(t, err)\n445: \tassert.GreaterOrEqual(t, score, float64(before.Unix()))\n446: }\n447: \n448: func TestRedisStore_UpdateSessionLastActivity_NotFound(t *testing.T) {\n449: \tstore := setupTestRedisStore(t)\n450: \tctx := context.Background()\n451: \n452: \terr := store.UpdateSessionLastActivity(ctx, \"non-existent\", time.Now())\n453: \tassert.ErrorIs(t, err, ErrNotFound)\n454: }\n455: \n456: func TestRedisStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n457: \tstore := setupTestRedisStore(t)\n458: \tctx := context.Background()\n459: \n460: \terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n461: \tassert.ErrorIs(t, err, ErrEmptySessionID)\n462: }\n463: \n464: func TestRedisStore_Close(t *testing.T) {\n465: \tmr := miniredis.RunT(t)\n466: \tcli := redisv9.NewClient(&redisv9.Options{\n467: \t\tAddr: mr.Addr(),\n468: \t})\n469: \tstore := &redisStore{\n470: \t\tcli:                  cli,\n471: \t\tsessionPrefix:        defaultSessionPrefix,\n472: \t\texpiryIndexKey:       defaultExpiryIndexKey,\n473: \t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n474: \t}\n475: \n476: \terr := store.Close()\n477: \trequire.NoError(t, err)\n478: }\n479: \n480: func TestNewRedisStore(t *testing.T) {\n481: \tmr := miniredis.RunT(t)\n482: \tstore := NewRedisStore(mr.Addr(), \"\")\n483: \n484: \trequire.NotNil(t, store)\n485: \n486: \tctx := context.Background()\n487: \terr := store.Ping(ctx)\n488: \trequire.NoError(t, err)\n489: \n490: \terr = store.Close()\n491: \trequire.NoError(t, err)\n492: }\n493: \n494: func TestNewRedisStoreWithOptions(t *testing.T) {\n495: \tmr := miniredis.RunT(t)\n496: \tstore := NewRedisStoreWithOptions(mr.Addr(), \"\", \"custom:\", \"custom:expiry\", \"custom:activity\")\n497: \n498: \trequire.NotNil(t, store)\n499: \n500: \trs := store.(*redisStore)\n501: \tassert.Equal(t, \"custom:\", rs.sessionPrefix)\n502: \tassert.Equal(t, \"custom:expiry\", rs.expiryIndexKey)\n503: \tassert.Equal(t, \"custom:activity\", rs.lastActivityIndexKey)\n504: \n505: \terr := store.Close()\n506: \trequire.NoError(t, err)\n507: }\n508: \n509: func TestNewRedisStoreWithClient(t *testing.T) {\n510: \tmr := miniredis.RunT(t)\n511: \tcli := redisv9.NewClient(&redisv9.Options{\n512: \t\tAddr: mr.Addr(),\n513: \t})\n514: \n515: \tstore := NewRedisStoreWithClient(cli)\n516: \trequire.NotNil(t, store)\n517: \n518: \tctx := context.Background()\n519: \terr := store.Ping(ctx)\n520: \trequire.NoError(t, err)\n521: }\n522: \n523: func TestRedisStore_ErrorHandling(t *testing.T) {\n524: \tstore := setupTestRedisStore(t)\n525: \tctx := context.Background()\n526: \n527: \tkey := store.sessionKey(\"test-session\")\n528: \tstore.cli.Set(ctx, key, \"invalid-json\", 0)\n529: \n530: \tresult, err := store.GetSandboxBySessionID(ctx, \"test-session\")\n531: \tassert.Nil(t, result)\n532: \tassert.Error(t, err)\n533: \tassert.False(t, errors.Is(err, ErrNotFound))\n534: }\n535: \n536: func TestErrors(t *testing.T) {\n537: \tassert.Equal(t, \"store: not found\", ErrNotFound.Error())\n538: \tassert.Equal(t, \"store: sandbox is nil\", ErrNilSandbox.Error())\n539: \tassert.Equal(t, \"store: expiresAt is required\", ErrZeroExpiresAt.Error())\n540: \tassert.Equal(t, \"store: sessionID is required\", ErrEmptySessionID.Error())\n541: \tassert.Equal(t, \"store: invalid provider type\", ErrInvalidProvider.Error())\n542: \tassert.Equal(t, \"store: password is required\", ErrPasswordRequired.Error())\n543: \tassert.Equal(t, \"store: key not exists\", ErrKeyNotExists.Error())\n544: \tassert.Equal(t, \"store: session already exists\", ErrSessionExists.Error())\n545: }\n546: \n547: func TestConstants(t *testing.T) {\n548: \tassert.Equal(t, \"redis\", redisStoreType)\n549: \tassert.Equal(t, \"valkey\", valkeyStoreType)\n550: }\n551: \n552: func TestResetStorage(t *testing.T) {\n553: \tResetStorage()\n554: \tassert.Nil(t, provider)\n555: }\n556: \n557: func TestMakeRedisOptions(t *testing.T) {\n558: \ttests := []struct {\n559: \t\tname        string\n560: \t\tenv         map[string]string\n561: \t\twantErr     bool\n562: \t\terrContains string\n563: \t}{\n564: \t\t{\n565: \t\t\tname: \"valid config\",\n566: \t\t\tenv: map[string]string{\n567: \t\t\t\t\"REDIS_ADDR\":     \"localhost:6379\",\n568: \t\t\t\t\"REDIS_PASSWORD\": \"testpass\",\n569: \t\t\t},\n570: \t\t\twantErr: false,\n571: \t\t},\n572: \t\t{\n573: \t\t\tname: \"missing addr\",\n574: \t\t\tenv: map[string]string{\n575: \t\t\t\t\"REDIS_PASSWORD\": \"testpass\",\n576: \t\t\t},\n577: \t\t\twantErr:     true,\n578: \t\t\terrContains: \"REDIS_ADDR is required\",\n579: \t\t},\n580: \t\t{\n581: \t\t\tname: \"missing password with default requirement\",\n582: \t\t\tenv: map[string]string{\n583: \t\t\t\t\"REDIS_ADDR\": \"localhost:6379\",\n584: \t\t\t},\n585: \t\t\twantErr:     true,\n586: \t\t\terrContains: \"password is required\",\n587: \t\t},\n588: \t\t{\n589: \t\t\tname: \"missing password but not required\",\n590: \t\t\tenv: map[string]string{\n591: \t\t\t\t\"REDIS_ADDR\":              \"localhost:6379\",\n592: \t\t\t\t\"REDIS_PASSWORD_REQUIRED\": \"false\",\n593: \t\t\t},\n594: \t\t\twantErr: false,\n595: \t\t},\n596: \t}\n597: \n598: \tfor _, tt := range tests {\n599: \t\tt.Run(tt.name, func(t *testing.T) {\n600: \t\t\tfor k, v := range tt.env {\n601: \t\t\t\tt.Setenv(k, v)\n602: \t\t\t}\n603: \n604: \t\t\topts, err := makeRedisOptions()\n605: \t\t\tif tt.wantErr {\n606: \t\t\t\trequire.Error(t, err)\n607: \t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n608: \t\t\t} else {\n609: \t\t\t\trequire.NoError(t, err)\n610: \t\t\t\trequire.NotNil(t, opts)\n611: \t\t\t\tassert.Equal(t, tt.env[\"REDIS_ADDR\"], opts.Addr)\n612: \t\t\t}\n613: \t\t})\n614: \t}\n615: }\n616: \n617: func TestNewValkeyStoreFromEnv(t *testing.T) {\n618: \ttests := []struct {\n619: \t\tname        string\n620: \t\tenv         map[string]string\n621: \t\twantErr     bool\n622: \t\terrContains string\n623: \t}{\n624: \t\t{\n625: \t\t\tname:        \"missing addr\",\n626: \t\t\tenv:         map[string]string{},\n627: \t\t\twantErr:     true,\n628: \t\t\terrContains: \"VALKEY_ADDR is required\",\n629: \t\t},\n630: \t\t{\n631: \t\t\tname: \"missing password with default requirement\",\n632: \t\t\tenv: map[string]string{\n633: \t\t\t\t\"VALKEY_ADDR\": \"localhost:6379\",\n634: \t\t\t},\n635: \t\t\twantErr:     true,\n636: \t\t\terrContains: \"password is required\",\n637: \t\t},\n638: \t\t{\n639: \t\t\tname: \"valid config\",\n640: \t\t\tenv: map[string]string{\n641: \t\t\t\t\"VALKEY_ADDR\":              \"localhost:6379\",\n642: \t\t\t\t\"VALKEY_PASSWORD\":          \"testpass\",\n643: \t\t\t\t\"VALKEY_PASSWORD_REQUIRED\": \"false\",\n644: \t\t\t},\n645: \t\t\twantErr: false,\n646: \t\t},\n647: \t}\n648: \n649: \tfor _, tt := range tests {\n650: \t\tt.Run(tt.name, func(t *testing.T) {\n651: \t\t\tfor k, v := range tt.env {\n652: \t\t\t\tt.Setenv(k, v)\n653: \t\t\t}\n654: \n655: \t\t\tstore, err := newValkeyStoreFromEnv()\n656: \t\t\tif tt.wantErr {\n657: \t\t\t\trequire.Error(t, err)\n658: \t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n659: \t\t\t} else {\n660: \t\t\t\trequire.NoError(t, err)\n661: \t\t\t\trequire.NotNil(t, store)\n662: \t\t\t}\n663: \t\t})\n664: \t}\n665: }\n666: \n667: func TestStorage_Singleton(t *testing.T) {\n668: \tResetStorage()\n669: \tt.Setenv(\"STORE_TYPE\", \"invalid\")\n670: \tStorage()\n671: \tassert.Nil(t, provider)\n672: }\n673: \n674: func TestStorage_RedisProvider(t *testing.T) {\n675: \tResetStorage()\n676: \tmr := miniredis.RunT(t)\n677: \tt.Setenv(\"STORE_TYPE\", \"redis\")\n678: \tt.Setenv(\"REDIS_ADDR\", mr.Addr())\n679: \tt.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n680: \n681: \tStorage()\n682: \trequire.NotNil(t, provider)\n683: \n684: \tctx := context.Background()\n685: \terr := provider.Ping(ctx)\n686: \trequire.NoError(t, err)\n687: \n688: \terr = provider.Close()\n689: \trequire.NoError(t, err)\n690: }\n691: \n692: func TestStorage_ValkeyProvider(t *testing.T) {\n693: \tResetStorage()\n694: \tmr := miniredis.RunT(t)\n695: \tt.Setenv(\"STORE_TYPE\", \"valkey\")\n696: \tt.Setenv(\"VALKEY_ADDR\", mr.Addr())\n697: \tt.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n698: \n699: \tStorage()\n700: \trequire.NotNil(t, provider)\n701: \n702: \tctx := context.Background()\n703: \terr := provider.Ping(ctx)\n704: \trequire.NoError(t, err)\n705: \n706: \terr = provider.Close()\n707: \trequire.NoError(t, err)\n708: }\n709: \n710: func TestStorage_DefaultRedis(t *testing.T) {\n711: \tResetStorage()\n712: \tmr := miniredis.RunT(t)\n713: \tt.Setenv(\"REDIS_ADDR\", mr.Addr())\n714: \tt.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n715: \n716: \tStorage()\n717: \trequire.NotNil(t, provider)\n718: \n719: \tctx := context.Background()\n720: \terr := provider.Ping(ctx)\n721: \trequire.NoError(t, err)\n722: \n723: \terr = provider.Close()\n724: \trequire.NoError(t, err)\n725: }\n726: \n727: func TestRedisStore_ListExpiredSandboxes_Empty(t *testing.T) {\n728: \tstore := setupTestRedisStore(t)\n729: \tctx := context.Background()\n730: \n731: \tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 10)\n732: \trequire.NoError(t, err)\n733: \tassert.Nil(t, results)\n734: }\n735: \n736: func TestRedisStore_ListInactiveSandboxes_Empty(t *testing.T) {\n737: \tstore := setupTestRedisStore(t)\n738: \tctx := context.Background()\n739: \n740: \tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 10)\n741: \trequire.NoError(t, err)\n742: \tassert.Nil(t, results)\n743: }\n744: \n745: func TestRedisStore_PingError(t *testing.T) {\n746: \tstore := setupTestRedisStore(t)\n747: \tctx := context.Background()\n748: \n749: \tstore.cli.Close()\n750: \n751: \terr := store.Ping(ctx)\n752: \tassert.Error(t, err)\n753: }\n754: \n755: func TestRedisStore_SessionKey(t *testing.T) {\n756: \tstore := setupTestRedisStore(t)\n757: \tkey := store.sessionKey(\"test-id\")\n758: \tassert.Equal(t, \"session:test-id\", key)\n759: }\n\n(End of file - total 759 lines)\n</content>","metadata":{"preview":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\tredisv9 \"github.com/redis/go-redis/v9\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc setupTestRedisStore(t *testing.T) *redisStore {\n\tmr := miniredis.RunT(t)\n\tcli := redisv9.NewClient(&redisv9.Options{\n\t\tAddr: mr.Addr(),","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_test.go","time":{"start":1775859824423,"end":1775859824436}}}}
