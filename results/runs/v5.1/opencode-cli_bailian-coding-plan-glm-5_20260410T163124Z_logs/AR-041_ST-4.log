 31071 Apr 11 08:26 design.md\ndrwxr-xr-x  3 root root     4096 Apr 11 13:50 docker\n-rw-r--r--  1 root root      311 Apr 11 13:52 .dockerignore\ndrwxr-xr-x  3 root root     4096 Apr 11 15:58 example\ndrwxr-xr-x  3 root root     4096 Apr 11 14:46 .github\n-rw-r--r--  1 root root     3578 Apr 11 08:40 go.mod\n-rw-r--r--  1 root root    21207 Apr 11 08:40 go.sum\ndrwxr-xr-x  2 root root     4096 Apr 11 14:15 hack\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 idle-cleanup\ndrwxr-xr-x  5 root root     4096 Apr 11 15:32 integrations\n-rw-r--r--  1 root root    10896 Apr 11 14:21 Makefile\ndrwxr-xr-x  4 root root     4096 Apr 11 13:30 manifests\n-rwxr-xr-x  1 root root 13627944 Apr 11 14:24 picod\n-rw-r--r--  1 root root     9894 Apr 11 17:30 picod_coverage.out\ndrwxr-xr-x  9 root root     4096 Apr 11 07:56 pkg\n-rw-r--r--  1 root root     1674 Mar 21 15:53 project.md\n-rw-r--r--  1 root root     8528 Apr 11 15:19 proposal.md\ndrwxr-xr-x  3 root root     4096 Apr 11 12:23 .pytest_cache\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 python-sdk\n-rw-r--r--  1 root root    28250 Apr 11 17:20 router_coverage.out\ndrwxr-xr-x  3 root root     4096 Apr 10 18:18 sandbox-orchestration\n-rw-r--r--  1 root root    10065 Apr 11 18:02 .sdd_prompt.md\ndrwxr-xr-x  7 root root     4096 Apr 11 17:50 sdk-python\ndrwxr-xr-x  2 root root     4096 Mar 21 15:55 session-routing\ndrwxr-xr-x  2 root root     4096 Mar 21 15:56 session-store\n-rw-r--r--  1 root root    16353 Apr 11 17:20 store_coverage.out\ndrwxr-xr-x  4 root root     4096 Apr 11 14:17 test\ndrwxr-xr-x  2 root root     4096 Mar 25 09:51 testing\ndrwxr-xr-x  3 root root     4096 Apr 11 14:44 tests\n-rw-r--r--  1 root root     1983 Mar 25 09:36 test_spec.md\n-rw-r--r--  1 root root     5573 Apr 11 14:46 VERIFICATION_REPORT.md\n","exit":0,"description":"List files in workspace root","truncated":false},"title":"List files in workspace root","time":{"start":1775902146171,"end":1775902146209}}}}
