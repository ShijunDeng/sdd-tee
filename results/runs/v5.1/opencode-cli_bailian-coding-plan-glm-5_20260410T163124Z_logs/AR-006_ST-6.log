ent *K8sClient, store Store) *HTTPServer {\n\tlifecycleConfig := DefaultLifecycleConfig()\n\tlifecycleManager := NewSandboxLifecycleManager(k8sClient, store, lifecycleConfig, logger)\n\tgarbageCollector := NewGarbageCollector(lifecycleManager, lifecycleConfig.GCInterval, lifecycleConfig.GCOnceTimeout, logger)\n\n\treturn &HTTPServer{\n\t\tserver:           &http.Server{Addr: cfg.Addr},\n\t\trouter:           chi.NewRouter(),\n\t\tconfig:           cfg,\n\t\thandlers:         make(map[string]Handler),\n\t\tlogger:           logger,\n\t\tstopCh:           make(chan struct{}),\n\t\tlifecycleManager: lifecycleManager,\n\t\tgarbageCollector: garbageCollector,\n\t\tstore:            store,\n\t\tk8sClient:        k8sClient,\n\t}\n}\n\n// RegisterHandler stores a handler and registers its routes on the router.\nfunc (s *HTTPServer) RegisterHandler(name string, h Handler) {\n\ts.handlers[name] = h\n\th.Register(s.router)\n}\n\n// Start begins listening and serving HTTP requests.\n// It returns an error channel that receives non-ErrServerClosed errors.\nfunc (s *HTTPServer) Start() <-chan error {\n\terrCh := make(chan error, 1)\n\ts.server.ReadTimeout = s.config.ReadTimeout\n\ts.server.WriteTimeout = s.config.WriteTimeout\n\ts.server.IdleTimeout = s.config.IdleTimeout\n\ts.server.Handler = s.router\n\n\tif s.garbageCollector != nil {\n\t\ts.garbageCollector.Start()\n\t}\n\n\tgo func() {\n\t\tif err := s.server.ListenAndServe(); err != http.ErrServerClosed {\n\t\t\terrCh <- err\n\t\t}\n\t}()\n\treturn errCh\n}\n\nfunc (s *HTTPServer) Stop(ctx context.Context) error {\n\tif s.garbageCollector != nil {\n\t\ts.garbageCollector.Stop()\n\t}\n\n\tctx, cancel := context.WithTimeout(ctx, s.config.ShutdownTimeout)\n\tdefer cancel()\n\terr := s.server.Shutdown(ctx)\n\tclose(s.stopCh)\n\treturn err\n}\n\t}()\n\treturn errCh\n}\n\n// Stop gracefully shuts down the HTTP server within the configured timeout.\nfunc (s *HTTPServer) Stop(ctx context.Context) error {\n\tctx, cancel := context.WithTimeout(ctx, s.config.ShutdownTimeout)\n\tdefer cancel()\n\terr := s.server.Shutdown(ctx)\n\tclose(s.stopCh)\n\treturn err\n}\n\n// GracefulShutdown sets up signal handlers for SIGTERM and SIGINT.\n// When a signal is received, the server is stopped gracefully.\nfunc (s *HTTPServer) GracefulShutdown() {\n\tsigCh := make(chan os.Signal, 1)\n\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n\tgo func() {\n\t\t<-sigCh\n\t\tctx := context.Background()\n\t\ts.Stop(ctx)\n\t}()\n}\n","after":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// HTTPServer manages the HTTP server lifecycle including graceful shutdown.\ntype HTTPServer struct {\n\tserver           *http.Server\n\trouter           chi.Router\n\tconfig           Config\n\thandlers         map[string]Handler\n\tlogger           Logger\n\tstopCh           chan struct{}\n\tlifecycleManager *SandboxLifecycleManager\n\tgarbageCollector *GarbageCollector\n\tstore            Store\n\tk8sClient        *K8sClient\n}\n\n// NewHTTPServer creates a new HTTPServer instance with the given configuration and logger.\n// The router is initialized with chi.NewRouter().\nfunc NewHTTPServer(cfg Config, logger Logger) *HTTPServer {\n\treturn &HTTPServer{\n\t\tserver:   &http.Server{Addr: cfg.Addr},\n\t\trouter:   chi.NewRouter(),\n\t\tconfig:   cfg,\n\t\thandlers: make(map[string]Handler),\n\t\tlogger:   logger,\n\t\tstopCh:   make(chan struct{}),\n\t\tstore:    NewMemoryStore(),\n\t}\n}\n\nfunc NewHTTPServerWithClients(cfg Config, logger Logger, k8sClient *K8sClient, store Store) *HTTPServer {\n\tlifecycleConfig := DefaultLifecycleConfig()\n\tlifecycleManager := NewSandboxLifecycleManager(k8sClient, store, lifecycleConfig, logger)\n\tgarbageCollector := NewGarbageCollector(lifecycleManager, lifecycleConfig.GCInterval, lifecycleConfig.GCOnceTimeout, logger)\n\n\treturn &HTTPServer{\n\t\tserver:           &http.Server{Addr: 