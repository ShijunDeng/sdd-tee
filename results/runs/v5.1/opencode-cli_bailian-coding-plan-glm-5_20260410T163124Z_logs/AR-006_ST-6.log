rval)\n53: \tdefer ticker.Stop()\n54: \n55: \tgc.runOnce(context.Background())\n56: \n57: \tfor {\n58: \t\tselect {\n59: \t\tcase <-gc.stopCh:\n60: \t\t\tgc.logger.Info(\"garbage collector stopped\")\n61: \t\t\treturn\n62: \t\tcase <-ticker.C:\n63: \t\t\tgc.runOnce(context.Background())\n64: \t\t}\n65: \t}\n66: }\n67: \n68: func (gc *GarbageCollector) runOnce(ctx context.Context) error {\n69: \tctx, cancel := context.WithTimeout(ctx, gc.onceTimeout)\n70: \tdefer cancel()\n71: \n72: \tnow := time.Now()\n73: \n74: \texpired, err := gc.manager.store.ListExpiredSandboxes(ctx, now, GCBatchSize)\n75: \tif err != nil {\n76: \t\tgc.logger.Error(\"failed to list expired sandboxes\", \"err\", err)\n77: \t\treturn err\n78: \t}\n79: \n80: \tinactiveBefore := now.Add(-gc.idleTimeout)\n81: \tinactive, err := gc.manager.store.ListInactiveSandboxes(ctx, inactiveBefore, GCBatchSize)\n82: \tif err != nil {\n83: \t\tgc.logger.Error(\"failed to list inactive sandboxes\", \"err\", err)\n84: \t\treturn err\n85: \t}\n86: \n87: \tallSandboxes := append(expired, inactive...)\n88: \n89: \tfor _, sb := range allSandboxes {\n90: \t\tif err := gc.manager.DeleteSandbox(ctx, sb.SessionID); err != nil {\n91: \t\t\tif _, ok := err.(*NotFoundError); ok {\n92: \t\t\t\tcontinue\n93: \t\t\t}\n94: \t\t\tgc.logger.Error(\"gc delete failed\", \"sessionID\", sb.SessionID, \"err\", err)\n95: \t\t\tcontinue\n96: \t\t}\n97: \n98: \t\treason := determineDeletionReason(sb, now, gc.idleTimeout)\n99: \t\tgc.logger.Info(\"gc deleted sandbox\", \"sessionID\", sb.SessionID, \"sandboxName\", sb.SandboxName, \"reason\", reason)\n100: \t}\n101: \n102: \treturn nil\n103: }\n104: \n105: func (gc *GarbageCollector) SetIdleTimeout(timeout time.Duration) {\n106: \tgc.idleTimeout = timeout\n107: }\n108: \n109: func (gc *GarbageCollector) GetStats() GarbageCollectorStats {\n110: \treturn GarbageCollectorStats{\n111: \t\tInterval:    gc.interval,\n112: \t\tOnceTimeout: gc.onceTimeout,\n113: \t\tIdleTimeout: gc.idleTimeout,\n114: \t}\n115: }\n116: \n117: type GarbageCollectorStats struct {\n118: \tInterval    time.Duration\n119: \tOnceTimeout time.Duration\n120: \tIdleTimeout time.Duration\n121: }\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n)\n\nconst GCBatchSize = 16\n\ntype GarbageCollector struct {\n\tmanager     *SandboxLifecycleManager\n\tinterval    time.Duration\n\tonceTimeout time.Duration\n\tstopCh      chan struct{}\n\twg          sync.WaitGroup\n\tlogger      Logger\n\tidleTimeout time.Duration\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector.go","time":{"start":1775845942142,"end":1775845942154}}}}
