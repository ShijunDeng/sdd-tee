:\"endpoint\"`\n45: }\n46: \n47: type SandboxInfo struct {\n48: \tKind               string              `json:\"kind\"`\n49: \tSandboxID          string              `json:\"sandboxId\"`\n50: \tSandboxNamespace   string              `json:\"sandboxNamespace\"`\n51: \tSandboxName        string              `json:\"sandboxName\"`\n52: \tName               string              `json:\"name\"`\n53: \tSessionID          string              `json:\"sessionId\"`\n54: \tCreatedAt          time.Time           `json:\"createdAt\"`\n55: \tExpiresAt          time.Time           `json:\"expiresAt\"`\n56: \tStatus             string              `json:\"status\"`\n57: \tEntryPoints        []SandboxEntryPoint `json:\"entryPoints\"`\n58: \tUserToken          string              `json:\"userToken,omitempty\"`\n59: \tServiceAccount     string              `json:\"serviceAccount,omitempty\"`\n60: \tServiceAccountName string              `json:\"serviceAccountName,omitempty\"`\n61: \tLastActivity       time.Time           `json:\"lastActivity,omitempty\"`\n62: }\n\n(End of file - total 62 lines)\n</content>","metadata":{"preview":"package types\n\nimport (\n\t\"fmt\"\n\t\"time\"\n)\n\nconst (\n\tAgentRuntimeKind    = \"AgentRuntime\"\n\tCodeInterpreterKind = \"CodeInterpreter\"\n\tSandboxKind         = \"Sandbox\"\n\tSandboxClaimKind    = \"SandboxClaim\"\n)\n\ntype CreateSandboxRequest struct {\n\tKind      string `json:\"kind\"`\n\tName      string `json:\"name\"`\n\tNamespace string `json:\"namespace\"`\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go","time":{"start":1775845967327,"end":1775845967344}}}}
