yStore()\n37: \tlogger := &testLogger{}\n38: \tconfig := workloadmanager.DefaultLifecycleConfig()\n39: \n40: \tmanager := workloadmanager.NewSandboxLifecycleManager(k8sClient, store, config, logger)\n41: \n42: \treturn NewDeletionHandler(manager, logger), store\n43: }\n44: \n45: type testLogger struct{}\n46: \n47: func (l *testLogger) Info(msg string, args ...any)  {}\n48: func (l *testLogger) Error(msg string, args ...any) {}\n49: \n50: func TestDeletionHandler_Register(t *testing.T) {\n51: \thandler, _ := setupTestHandler()\n52: \n53: \tr := chi.NewRouter()\n54: \thandler.Register(r)\n55: \n56: \troutes := r.Routes()\n57: \tassert.Len(t, routes, 2)\n58: }\n59: \n60: func TestDeletionHandler_DeleteSuccess(t *testing.T) {\n61: \thandler, store := setupTestHandler()\n62: \n63: \tnow := time.Now()\n64: \tsandbox := &types.SandboxInfo{\n65: \t\tKind:             types.SandboxKind,\n66: \t\tSandboxID:        \"sandbox-123\",\n67: \t\tSandboxNamespace: \"default\",\n68: \t\tSandboxName:      \"sandbox-123\",\n69: \t\tSessionID:        \"session-123\",\n70: \t\tCreatedAt:        now,\n71: \t\tExpiresAt:        now.Add(8 * time.Hour),\n72: \t\tStatus:           \"running\",\n73: \t}\n74: \n75: \terr := store.StoreSandbox(context.Background(), sandbox)\n76: \trequire.NoError(t, err)\n77: \n78: \tr := chi.NewRouter()\n79: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n80: \n81: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n82: \trec := httptest.NewRecorder()\n83: \n84: \tr.ServeHTTP(rec, req)\n85: \n86: \tassert.Equal(t, http.StatusOK, rec.Code)\n87: \n88: \tvar resp DeleteSandboxResponse\n89: \terr = json.NewDecoder(rec.Body).Decode(&resp)\n90: \trequire.NoError(t, err)\n91: \n92: \tassert.Equal(t, \"session-123\", resp.SessionID)\n93: \tassert.Equal(t, \"deleted\", resp.Status)\n94: \n95: \tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n96: }\n97: \n98: func TestDeletionHandler_DeleteNotFound(t *testing.T) {\n99: \thandler, _ := setupTestHandler()\n100: \n101: \tr := chi.NewRouter()\n102: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n103: \n104: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/non-existent\", nil)\n105: \trec := httptest.NewRecorder()\n106: \n107: \tr.ServeHTTP(rec, req)\n108: \n109: \tassert.Equal(t, http.StatusNotFound, rec.Code)\n110: \n111: \tvar resp DeleteSandboxResponse\n112: \terr := json.NewDecoder(rec.Body).Decode(&resp)\n113: \trequire.NoError(t, err)\n114: \n115: \tassert.Equal(t, \"non-existent\", resp.SessionID)\n116: \tassert.Equal(t, \"not_found\", resp.Status)\n117: }\n118: \n119: func TestDeletionHandler_DeleteMissingSessionID(t *testing.T) {\n120: \thandler, _ := setupTestHandler()\n121: \n122: \tr := chi.NewRouter()\n123: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n124: \n125: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\", nil)\n126: \trec := httptest.NewRecorder()\n127: \n128: \tr.ServeHTTP(rec, req)\n129: \n130: \tassert.Equal(t, http.StatusBadRequest, rec.Code)\n131: \n132: \tvar resp workloadmanager.ErrorResponse\n133: \terr := json.NewDecoder(rec.Body).Decode(&resp)\n134: \trequire.NoError(t, err)\n135: \n136: \tassert.Equal(t, \"VALIDATION_ERROR\", resp.Code)\n137: }\n138: \n139: func TestDeletionHandler_DeleteCodeInterpreter(t *testing.T) {\n140: \thandler, store := setupTestHandler()\n141: \n142: \tnow := time.Now()\n143: \tsandbox := &types.SandboxInfo{\n144: \t\tKind:             types.SandboxKind,\n145: \t\tSandboxID:        \"sandbox-123\",\n146: \t\tSandboxNamespace: \"default\",\n147: \t\tSandboxName:      \"sandbox-123\",\n148: \t\tSessionID:        \"session-123\",\n149: \t\tCreatedAt:        now,\n150: \t\tExpiresAt:        now.Add(8 * time.Hour),\n151: \t\tStatus:           \"running\",\n152: \t}\n153: \n154: \terr := store.StoreSandbox(context.Background(), sandbox)\n155: \trequire.NoError(t, err)\n156: \n157: \tr := chi.NewRouter()\n158: \tr.Delete(\"/v1/code-interpreter/sessions/{sessionId}\", handler.handleDeleteCodeInterpreterSandbox)\n159: \n160: \treq := httptest.NewRequest(\"DELETE\", \"/v1/code-interpreter/sessions/session-123\", nil)\n161: \trec := httptest.NewRecorder()\n162: \n163: \tr.ServeHTTP(rec, req)\n164: \n165: \tassert.Equal(t, http.StatusOK, rec.Code)\n166: \n167: \tvar resp DeleteSandboxResponse\n168: \terr = json.NewDecoder(rec.Body).Decode(&resp)\n169: \trequire.NoError(t, err)\n170: \n171: \tassert.Equal(t, \"session-123\", resp.SessionID)\n172: \tassert.Equal(t, \"deleted\", resp.Status)\n173: }\n174: \n175: func TestDeletionHandler_ResponseFormat(t *testing.T) {\n176: \thandler, store := setupTestHandler()\n177: \n178: \tnow := time.Now()\n179: \tsandbox := &types.SandboxInfo{\n180: \t\tKind:             types.SandboxKind,\n181: \t\tSandboxID:        \"sandbox-123\",\n182: \t\tSandboxNamespace: \"default\",\n183: \t\tSandboxName:      \"sandbox-123\",\n184: \t\tSessionID:        \"session-123\",\n185: \t\tCreatedAt:        now,\n186: \t\tExpiresAt:        now.Add(8 * time.Hour),\n187: \t\tStatus:           \"running\",\n188: \t}\n189: \n190: \terr := store.StoreSandbox(context.Background(), sandbox)\n191: \trequire.NoError(t, err)\n192: \n193: \tr := chi.NewRouter()\n194: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n195: \n196: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n197: \trec := httptest.NewRecorder()\n198: \n199: \tr.ServeHTTP(rec, req)\n200: \n201: \tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n202: \n203: \tvar resp map[string]interface{}\n204: \terr = json.Unmarshal(rec.Body.Bytes(), &resp)\n205: \trequire.NoError(t, err)\n206: \n207: \tassert.Contains(t, resp, \"sessionId\")\n208: \tassert.Contains(t, resp, \"status\")\n209: \tassert.Equal(t, \"session-123\", resp[\"sessionId\"])\n210: \tassert.Equal(t, \"deleted\", resp[\"status\"])\n211: }\n212: \n213: func TestDeleteSandboxRequest_JSON(t *testing.T) {\n214: \treq := DeleteSandboxRequest{\n215: \t\tSessionID:          \"session-123\",\n216: \t\tKind:               \"AgentRuntime\",\n217: \t\tForce:              true,\n218: \t\tGracePeriodSeconds: 30,\n219: \t}\n220: \n221: \tdata, err := json.Marshal(req)\n222: \trequire.NoError(t, err)\n223: \n224: \tvar unmarshaled DeleteSandboxRequest\n225: \terr = json.Unmarshal(data, &unmarshaled)\n226: \trequire.NoError(t, err)\n227: \n228: \tassert.Equal(t, req.SessionID, unmarshaled.SessionID)\n229: \tassert.Equal(t, req.Kind, unmarshaled.Kind)\n230: \tassert.Equal(t, req.Force, unmarshaled.Force)\n231: \tassert.Equal(t, req.GracePeriodSeconds, unmarshaled.GracePeriodSeconds)\n232: }\n233: \n234: func TestDeleteSandboxResponse_JSON(t *testing.T) {\n235: \tresp := DeleteSandboxResponse{\n236: \t\tSessionID: \"session-123\",\n237: \t\tStatus:    \"deleted\",\n238: \t\tMessage:   \"Sandbox deleted successfully\",\n239: \t}\n240: \n241: \tdata, err := json.Marshal(resp)\n242: \trequire.NoError(t, err)\n243: \n244: \tvar unmarshaled DeleteSandboxResponse\n245: \terr = json.Unmarshal(data, &unmarshaled)\n246: \trequire.NoError(t, err)\n247: \n248: \tassert.Equal(t, resp.SessionID, unmarshaled.SessionID)\n249: \tassert.Equal(t, resp.Status, unmarshaled.Status)\n250: \tassert.Equal(t, resp.Message, unmarshaled.Message)\n251: }\n\n(End of file - total 251 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-