0T163124Z/sandbox-orchestration/AR-005-sandbox-creation-processor/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/ci-cd/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/integrations/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sandbox-orchestration/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/python-sdk/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/idle-cleanup/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/deployment/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/session-store/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cli-toolkit/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/session-routing/design.md\n/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/code-execution/design.md","metadata":{"count":24,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z","time":{"start":1775857371523,"end":1775857371535}}}}
