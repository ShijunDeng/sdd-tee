Name }}\n45: subjects:\n46:   - kind: ServiceAccount\n47:     name: {{ .Values.router.serviceAccountName }}\n48:     namespace: {{ .Release.Namespace }}\n49: {{- end }}\n\n(End of file - total 49 lines)\n</content>","metadata":{"preview":"{{- if .Values.router.rbac.create }}\n{{- if not .Values.router.serviceAccountName }}\n{{- fail \"router.serviceAccountName must be set when router.rbac.create is true\" }}\n{{- end }}\napiVersion: v1\nkind: ServiceAccount\nmetadata:\n  name: {{ .Values.router.serviceAccountName }}\n  namespace: {{ .Release.Namespace }}\n  labels:\n    {{- include \"agentcube.labels\" . | nindent 4 }}\n---\napiVersion: rbac.authorization.k8s.io/v1\nkind: Role\nmetadata:\n  name: {{ .Values.router.serviceAccountName }}\n  namespace: {{ .Release.Namespace }}\n  labels:\n    {{- include \"agentcube.labels\" . | nindent 4 }}\nrules:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests/charts/base/templates/rbac-router.yaml","time":{"start":1775884813131,"end":1775884813149}}}}
