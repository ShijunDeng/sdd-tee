{"type":"tool_use","timestamp":1775847670238,"sessionID":"ses_2873b7541ffeDi6b2Lu8gh0Fzw","part":{"id":"prt_d78c4fb400019b4kf9aTZOL1aH","messageID":"msg_d78c4ca22001ZPIZckvM3ttrB0","sessionID":"ses_2873b7541ffeDi6b2Lu8gh0Fzw","type":"tool","tool":"read","callID":"toolu_tool-3f87a126f5a14770b37f4e939349a1ca","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"sync\"\n6: \t\"time\"\n7: )\n8: \n9: const GCBatchSize = 16\n10: \n11: type GarbageCollector struct {\n12: \tmanager     *SandboxLifecycleManager\n13: \tinterval    time.Duration\n14: \tonceTimeout time.Duration\n15: \tstopCh      chan struct{}\n16: \twg          sync.WaitGroup\n17: \tlogger      Logger\n18: \tidleTimeout time.Duration\n19: \tidleMu      sync.RWMutex\n20: }\n21: \n22: func NewGarbageCollector(manager *SandboxLifecycleManager, interval, onceTimeout time.Duration, logger Logger) *GarbageCollector {\n23: \tif interval == 0 {\n24: \t\tinterval = GarbageCollectorInterval\n25: \t}\n26: \tif onceTimeout == 0 {\n27: \t\tonceTimeout = 2 * time.Minute\n28: \t}\n29: \n30: \treturn &GarbageCollector{\n31: \t\tmanager:     manager,\n32: \t\tinterval:    interval,\n33: \t\tonceTimeout: onceTimeout,\n34: \t\tstopCh:      make(chan struct{}),\n35: \t\tlogger:      logger,\n36: \t\tidleTimeout: manager.config.DefaultIdleTimeout,\n37: \t}\n38: }\n39: \n40: func (gc *GarbageCollector) getIdleTimeout() time.Duration {\n41: \tgc.idleMu.RLock()\n42: \tdefer gc.idleMu.RUnlock()\n43: \treturn gc.idleTimeout\n44: }\n45: \n46: func (gc *GarbageCollector) Start() {\n47: \tgc.wg.Add(1)\n48: \tgo gc.runLoop()\n49: }\n50: \n51: func (gc *GarbageCollector) Stop() {\n52: \tclose(gc.stopCh)\n53: \tgc.wg.Wait()\n54: }\n55: \n56: func (gc *GarbageCollector) runLoop() {\n57: \tdefer gc.wg.Done()\n58: \n59: \tticker := time.NewTicker(gc.interval)\n60: \tdefer ticker.Stop()\n61: \n62: \tgc.runOnce(context.Background())\n63: \n64: \tfor {\n65: \t\tselect {\n66: \t\tcase <-gc.stopCh:\n67: \t\t\tgc.logger.Info(\"garbage collector stopped\")\n68: \t\t\treturn\n69: \t\tcase <-ticker.C:\n70: \t\t\tgc.runOnce(context.Background())\n71: \t\t}\n72: \t}\n73: }\n74: \n75: func (gc *GarbageCollector) runOnce(ctx context.Context) error {\n76: \tctx, cancel := context.WithTimeout(ctx, gc.onceTimeout)\n77: \tdefer cancel()\n78: \n79: \tnow := time.Now()\n80: \tidleTimeout := gc.getIdleTimeout()\n81: \n82: \texpired, err := gc.manager.store.ListExpiredSandboxes(ctx, now, GCBatchSize)\n83: \tif err != nil {\n84: \t\tgc.logger.Error(\"failed to list expired sandboxes\", \"err\", err)\n85: \t\treturn err\n86: \t}\n87: \n88: \tinactiveBefore := now.Add(-idleTimeout)\n89: \tinactive, err := gc.manager.store.ListInactiveSandboxes(ctx, inactiveBefore, GCBatchSize)\n90: \tif err != nil {\n91: \t\tgc.logger.Error(\"failed to list inactive sandboxes\", \"err\", err)\n92: \t\treturn err\n93: \t}\n94: \n95: \tallSandboxes := append(expired, inactive...)\n96: \n97: \tfor _, sb := range allSandboxes {\n98: \t\tif err := gc.manager.DeleteSandbox(ctx, sb.SessionID); err != nil {\n99: \t\t\tif _, ok := err.(*NotFoundError); ok {\n100: \t\t\t\tcontinue\n101: \t\t\t}\n102: \t\t\tgc.logger.Error(\"gc delete failed\", \"sessionID\", sb.SessionID, \"err\", err)\n103: \t\t\tcontinue\n104: \t\t}\n105: \n106: \t\treason := determineDeletionReason(sb, now, idleTimeout)\n107: \t\tgc.logger.Info(\"gc deleted sandbox\", \"sessionID\", sb.SessionID, \"sandboxName\", sb.SandboxName, \"reason\", reason)\n108: \t}\n109: \n110: \treturn nil\n111: }\n112: \n113: func (gc *GarbageCollector) SetIdleTimeout(timeout time.Duration) {\n114: \tgc.idleMu.Lock()\n115: \tdefer gc.idleMu.Unlock()\n116: \tgc.idleTimeout = timeout\n117: }\n118: \n119: func (gc *GarbageCollector) GetStats() GarbageCollectorStats {\n120: \tgc.idleMu.RLock()\n121: \tdefer gc.idleMu.RUnlock()\n122: \treturn GarbageCollectorStats{\n123: \t\tInterval:    gc.interval,\n124: \t\tOnceTimeout: gc.onceTimeout,\n125: \t\tIdleTimeout: gc.idleTimeout,\n126: \t}\n127: }\n128: \n129: type GarbageCollectorStats struct {\n130: \tInterval    time.Duration\n131: \tOnceTimeout time.Duration\n132: \tIdleTimeout time.Duration\n133: }\n\n(End of file - total 133 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n)\n\nconst GCBatchSize = 16\n\ntype GarbageCollector struct {\n\tmanager     *SandboxLifecycleManager\n\tinterval    time.Duration\n\tonceTimeout time.Duration\n\tstopCh      chan struct{}\n\twg          sync.WaitGroup\n\tlogger      Logger\n\tidleTimeout time.Duration\n\tidleMu      sync.RWMutex\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector.go","time":{"start":1775847670218,"end":1775847670236}}}}
