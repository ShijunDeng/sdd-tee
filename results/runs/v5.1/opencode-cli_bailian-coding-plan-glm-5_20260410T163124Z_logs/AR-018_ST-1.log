{"type":"tool_use","timestamp":1775864674610,"sessionID":"ses_286399e5dffeQ3s6GyQQxPFoND","part":{"id":"prt_d79c878b7001H8jLPFeqdv86uI","messageID":"msg_d79c8637e0011kXiDPAUq7BfNe","sessionID":"ses_286399e5dffeQ3s6GyQQxPFoND","type":"tool","tool":"read","callID":"toolu_tool-a1fae9ba36fe4d8d8c944ecadf8abfa5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/defaults.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/defaults.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"time\"\n5: \n6: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n7: )\n8: \n9: const (\n10: \tDefaultSandboxTTL         = 8 * time.Hour\n11: \tDefaultSandboxIdleTimeout = 15 * time.Minute\n12: \tDefaultMaxSessionDuration = 8 * time.Hour\n13: \tDefaultSessionTimeout     = 15 * time.Minute\n14: \tSandboxCreationTimeout    = 2 * time.Minute\n15: \tSandboxDeleteTimeout      = 30 * time.Second\n16: \tInformerSyncTimeout       = 1 * time.Minute\n17: \tGarbageCollectorInterval  = 2 * time.Minute\n18: )\n19: \n20: const (\n21: \tLabelKeySessionID    = \"runtime.agentcube.io/session-id\"\n22: \tLabelKeyWorkloadName = \"runtime.agentcube.io/workload-name\"\n23: \tLabelKeySandboxName  = \"runtime.agentcube.io/sandbox-name\"\n24: \tLabelKeyManagedBy    = \"managed-by\"\n25: \n26: \tAnnotationKeyIdleTimeout = \"runtime.agentcube.io/idle-timeout\"\n27: \tAnnotationKeyPodName     = \"agents.x-k8s.io/sandbox-pod-name\"\n28: )\n29: \n30: const (\n31: \tManagedByValue = \"agentcube-workload-manager\"\n32: )\n33: \n34: var (\n35: \tSandboxGVR = schema.GroupVersionResource{\n36: \t\tGroup:    \"agents.x-k8s.io\",\n37: \t\tVersion:  \"v1alpha1\",\n38: \t\tResource: \"sandboxes\",\n39: \t}\n40: \n41: \tSandboxClaimGVR = schema.GroupVersionResource{\n42: \t\tGroup:    \"extensions.agents.x-k8s.io\",\n43: \t\tVersion:  \"v1alpha1\",\n44: \t\tResource: \"sandboxclaims\",\n45: \t}\n46: )\n47: \n48: const (\n49: \tSandboxKind         = \"Sandbox\"\n50: \tSandboxClaimKind    = \"SandboxClaim\"\n51: \tAgentRuntimeKind    = \"AgentRuntime\"\n52: \tCodeInterpreterKind = \"CodeInterpreter\"\n53: )\n\n(End of file - total 53 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"time\"\n\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n)\n\nconst (\n\tDefaultSandboxTTL         = 8 * time.Hour\n\tDefaultSandboxIdleTimeout = 15 * time.Minute\n\tDefaultMaxSessionDuration = 8 * time.Hour\n\tDefaultSessionTimeout     = 15 * time.Minute\n\tSandboxCreationTimeout    = 2 * time.Minute\n\tSandboxDeleteTimeout      = 30 * time.Second\n\tInformerSyncTimeout       = 1 * time.Minute\n\tGarbageCollectorInterval  = 2 * time.Minute\n)\n\nconst (","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/defaults.go","time":{"start":1775864674593,"end":1775864674609}}}}
