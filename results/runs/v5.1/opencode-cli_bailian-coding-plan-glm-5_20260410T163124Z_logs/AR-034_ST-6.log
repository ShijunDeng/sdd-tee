       if (isNotFirstTime || hasOkToTest) {\n41:               // List workflow runs for the head SHA with action_required status\n42:               const runs = await github.rest.actions.listWorkflowRunsForRepo({\n43:                 owner: context.repo.owner,\n44:                 repo: context.repo.repo,\n45:                 head_sha: headSha,\n46:                 status: 'action_required'\n47:               });\n48:               \n49:               // Approve each pending workflow run\n50:               for (const run of runs.data.workflow_runs) {\n51:                 await github.rest.actions.approveWorkflowRun({\n52:                   owner: context.repo.owner,\n53:                   repo: context.repo.repo,\n54:                   run_id: run.id\n55:                 });\n56:                 console.log(`Approved workflow run ${run.id} (${run.name})`);\n57:               }\n58:             } else {\n59:               console.log('Skipping approval: first-time contributor without ok-to-test label');\n60:             }\n\n(End of file - total 60 lines)\n</content>","metadata":{"preview":"name: Approve Workflows\non:\n  pull_request_target:\n    branches:\n      - main\n      - 'release-**'\n    types:\n      - labeled\n      - synchronize\n\njobs:\n  approve:\n    runs-on: ubuntu-latest\n    steps:\n      - name: Checkout repository\n        uses: actions/checkout@v4\n\n      - name: Check contributor and approve workflows\n        uses: actions/github-script@v7\n        with:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/.github/workflows/workflows-approve.yml","time":{"start":1775890032717,"end":1775890032748}}}}
