GarbageCollector_DefaultInterval(t *testing.T) {\n43: \tfakeClient := fake.NewSimpleClientset()\n44: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n45: \tinformerFactory := NewTestInformerFactory(fakeClient)\n46: \n47: \tk8sClient := &K8sClient{\n48: \t\tdynamicClient:   dynamicClient,\n49: \t\tcoreClient:      fakeClient,\n50: \t\tinformerFactory: informerFactory,\n51: \t}\n52: \n53: \tstore := NewMemoryStore()\n54: \tlogger := &mockLogger{}\n55: \tconfig := DefaultLifecycleConfig()\n56: \n57: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n58: \n59: \tgc := NewGarbageCollector(manager, 0, 0, logger)\n60: \n61: \tassert.Equal(t, GarbageCollectorInterval, gc.interval)\n62: \tassert.Equal(t, 2*time.Minute, gc.onceTimeout)\n63: }\n64: \n65: func TestGarbageCollector_StartStop(t *testing.T) {\n66: \tfakeClient := fake.NewSimpleClientset()\n67: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n68: \tinformerFactory := NewTestInformerFactory(fakeClient)\n69: \n70: \tk8sClient := &K8sClient{\n71: \t\tdynamicClient:   dynamicClient,\n72: \t\tcoreClient:      fakeClient,\n73: \t\tinformerFactory: informerFactory,\n74: \t}\n75: \n76: \tstore := NewMemoryStore()\n77: \tlogger := &mockLogger{}\n78: \tconfig := DefaultLifecycleConfig()\n79: \n80: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n81: \n82: \tgc := NewGarbageCollector(manager, 100*time.Millisecond, 1*time.Second, logger)\n83: \n84: \tgc.Start()\n85: \n86: \ttime.Sleep(50 * time.Millisecond)\n87: \n88: \tgc.Stop()\n89: \n90: \tassert.True(t, true)\n91: }\n92: \n93: func TestGarbageCollector_runOnce_Expired(t *testing.T) {\n94: \tfakeClient := fake.NewSimpleClientset()\n95: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n96: \tinformerFactory := NewTestInformerFactory(fakeClient)\n97: \n98: \tk8sClient := &K8sClient{\n99: \t\tdynamicClient:   dynamicClient,\n100: \t\tcoreClient:      fakeClient,\n101: \t\tinformerFactory: informerFactory,\n102: \t}\n103: \n104: \tstore := NewMemoryStore()\n105: \tlogger := &mockLogger{}\n106: \tconfig := DefaultLifecycleConfig()\n107: \n108: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n109: \n110: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n111: \n112: \tnow := time.Now()\n113: \n114: \texpiredSandbox := &types.SandboxInfo{\n115: \t\tKind:             types.SandboxKind,\n116: \t\tSandboxID:        \"sandbox-expired\",\n117: \t\tSandboxNamespace: \"default\",\n118: \t\tSandboxName:      \"sandbox-expired\",\n119: \t\tSessionID:        \"session-expired\",\n120: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n121: \t\tExpiresAt:        now.Add(-2 * time.Hour),\n122: \t\tStatus:           \"running\",\n123: \t}\n124: \n125: \tactiveSandbox := &types.SandboxInfo{\n126: \t\tKind:             types.SandboxKind,\n127: \t\tSandboxID:        \"sandbox-active\",\n128: \t\tSandboxNamespace: \"default\",\n129: \t\tSandboxName:      \"sandbox-active\",\n130: \t\tSessionID:        \"session-active\",\n131: \t\tCreatedAt:        now,\n132: \t\tExpiresAt:        now.Add(8 * time.Hour),\n133: \t\tStatus:           \"running\",\n134: \t}\n135: \n136: \terr := store.StoreSandbox(context.Background(), expiredSandbox)\n137: \trequire.NoError(t, err)\n138: \terr = store.StoreSandbox(context.Background(), activeSandbox)\n139: \trequire.NoError(t, err)\n140: \n141: \tassert.Equal(t, 2, store.Size())\n142: \n143: \terr = gc.runOnce(context.Background())\n144: \trequire.NoError(t, err)\n145: \n146: \tassert.Equal(t, 1, store.Size())\n147: \n148: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-expired\")\n149: \tassert.Error(t, err)\n150: \n151: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-active\")\n152: \trequire.NoError(t, err)\n153: }\n154: \n155: func TestGarbageCollector_runOnce_Inactive(t *testing.T) {\n156: \tfakeClient := fake.NewSimpleClientset()\n157: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n158: \tinformerFactory := NewTestInformerFactory(fakeClient)\n159: \n160: \tk8sClient := &K8sClient{\n161: \t\tdynamicClient:   dynamicClient,\n162: \t\tcoreClient:      fakeClient,\n163: \t\tinformerFactory: informerFactory,\n164: \t}\n165: \n166: \tstore := NewMemoryStore()\n167: \tlogger := &mockLogger{}\n168: \tconfig := DefaultLifecycleConfig()\n169: \n170: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n171: \n172: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n173: \n174: \tnow := time.Now()\n175: \n176: \tinactiveSandbox := &types.SandboxInfo{\n177: \t\tKind:             types.SandboxKind,\n178: \t\tSandboxID:        \"sandbox-inactive\",\n179: \t\tSandboxNamespace: \"default\",\n180: \t\tSandboxName:      \"sandbox-inactive\",\n181: \t\tSessionID:        \"session-inactive\",\n182: \t\tCreatedAt:        now,\n183: \t\tExpiresAt:        now.Add(8 * time.Hour),\n184: \t\tLastActivity:     now.Add(-30 * time.Minute),\n185: \t\tStatus:           \"running\",\n186: \t}\n187: \n188: \tactiveSandbox := &types.SandboxInfo{\n189: \t\tKind:             types.SandboxKind,\n190: \t\tSandboxID:        \"sandbox-active\",\n191: \t\tSandboxNamespace: \"default\",\n192: \t\tSandboxName:      \"sandbox-active\",\n193: \t\tSessionID:        \"session-active\",\n194: \t\tCreatedAt:        now,\n195: \t\tExpiresAt:        now.Add(8 * time.Hour),\n196: \t\tLastActivity:     now,\n197: \t\tStatus:           \"running\",\n198: \t}\n199: \n200: \terr := store.StoreSandbox(context.Background(), inactiveSandbox)\n201: \trequire.NoError(t, err)\n202: \terr = store.StoreSandbox(context.Background(), activeSandbox)\n203: \trequire.NoError(t, err)\n204: \n205: \tassert.Equal(t, 2, store.Size())\n206: \n207: \terr = gc.runOnce(context.Background())\n208: \trequire.NoError(t, err)\n209: \n210: \tassert.Equal(t, 1, store.Size())\n211: \n212: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-inactive\")\n213: \tassert.Error(t, err)\n214: \n215: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-active\")\n216: \trequire.NoError(t, err)\n217: }\n218: \n219: func TestGarbageCollector_runOnce_Limit(t *testing.T) {\n220: \tfakeClient := fake.NewSimpleClientset()\n221: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n222: \tinformerFactory := NewTestInformerFactory(fakeClient)\n223: \n224: \tk8sClient := &K8sClient{\n225: \t\tdynamicClient:   dynamicClient,\n226: \t\tcoreClient:      fakeClient,\n227: \t\tinformerFactory: informerFactory,\n228: \t}\n229: \n230: \tstore := NewMemoryStore()\n231: \tlogger := &mockLogger{}\n232: \tconfig := DefaultLifecycleConfig()\n233: \n234: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n235: \n236: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n237: \n238: \tnow := time.Now()\n239: \n240: \tfor i := 0; i < 20; i++ {\n241: \t\tsandbox := &types.SandboxInfo{\n242: \t\t\tKind:             types.SandboxKind,\n243: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n244: \t\t\tSandboxNamespace: \"default\",\n245: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n246: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n247: \t\t\tCreatedAt:        now,\n248: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n249: \t\t\tStatus:           \"running\",\n250: \t\t}\n251: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n252: \t\trequire.NoError(t, err)\n253: \t}\n254: \n255: \tassert.Equal(t, 20, store.Size())\n256: \n257: \terr := gc.runOnce(context.Background())\n258: \trequire.NoError(t, err)\n259: \n260: \tassert.LessOrEqual(t, store.Size(), 20-GCBatchSize)\n261: }\n262: \n263: func TestGarbageCollector_runOnce_ContinueOnError(t *testing.T) {\n264: \tfakeClient := fake.NewSimpleClientset()\n265: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n266: \tinformerFactory := NewTestInformerFactory(fakeClient)\n267: \n268: \tk8sClient := &K8sClient{\n269: \t\tdynamicClient:   dynamicClient,\n270: \t\tcoreClient:      fakeClient,\n271: \t\tinformerFactory: informerFactory,\n272: \t}\n273: \n274: \tstore := NewMemoryStore()\n275: \tlogger := &mockLogger{}\n276: \tconfig := DefaultLifecycleConfig()\n277: \n278: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n279: \n280: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n281: \n282: \tnow := time.Now()\n283: \n284: \tfor i := 0; i < 3; i++ {\n285: \t\tsandbox := &types.SandboxInfo{\n286: \t\t\tKind:             types.SandboxKind,\n287: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n288: \t\t\tSandboxNamespace: \"default\",\n289: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n290: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n291: \t\t\tCreatedAt:        now,\n292: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n293: \t\t\tStatus:           \"running\",\n294: \t\t}\n295: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n296: \t\trequire.NoError(t, err)\n297: \t}\n298: \n299: \terr := gc.runOnce(context.Background())\n300: \trequire.NoError(t, err)\n301: \n302: \tassert.Equal(t, 0, store.Size())\n303: }\n304: \n305: func TestGarbageCollector_GetStats(t *testing.T) {\n306: \tfakeClient := fake.NewSimpleClientset()\n307: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n308: \tinformerFactory := NewTestInformerFactory(fakeClient)\n309: \n310: \tk8sClient := &K8sClient{\n311: \t\tdynamicClient:   dynamicClient,\n312: \t\tcoreClient:      fakeClient,\n313: \t\tinformerFactory: informerFactory,\n314: \t}\n315: \n316: \tstore := NewMemoryStore()\n317: \tlogger := &mockLogger{}\n318: \tconfig := DefaultLifecycleConfig()\n319: \n320: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n321: \n322: \tgc := NewGarbageCollector(manager, 5*time.Minute, 3*time.Minute, logger)\n323: \tgc.SetIdleTimeout(20 * time.Minute)\n324: \n325: \tstats := gc.GetStats()\n326: \n327: \tassert.Equal(t, 5*time.Minute, stats.Interval)\n328: \tassert.Equal(t, 3*time.Minute, stats.OnceTimeout)\n329: \tassert.Equal(t, 20*time.Minute, stats.IdleTimeout)\n330: }\n331: \n332: func TestGarbageCollector_ConcurrentRunOnce(t *testing.T) {\n333: \tfakeClient := fake.NewSimpleClientset()\n334: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n335: \tinformerFactory := NewTestInformerFactory(fakeClient)\n336: \n337: \tk8sClient := &K8sClient{\n338: \t\tdynamicClient:   dynamicClient,\n339: \t\tcoreClient:      fakeClient,\n340: \t\tinformerFactory: informerFactory,\n341: \t}\n342: \n343: \tstore := NewMemoryStore()\n344: \tlogger := &mockLogger{}\n345: \tconfig := DefaultLifecycleConfig()\n346: \n347: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n348: \n349: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n350: \n351: \tnow := time.Now()\n352: \n353: \tfor i := 0; i < 10; i++ {\n354: \t\tsandbox := &types.SandboxInfo{\n355: \t\t\tKind:             types.SandboxKind,\n356: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n357: \t\t\tSandboxNamespace: \"default\",\n358: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n359: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n360: \t\t\tCreatedAt:        now,\n361: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n362: \t\t\tStatus:           \"running\",\n363: \t\t}\n364: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n365: \t\trequire.NoError(t, err)\n366: \t}\n367: \n368: \tvar wg sync.WaitGroup\n369: \tfor i := 0; i < 3; i++ {\n370: \t\twg.Add(1)\n371: \t\tgo func() {\n372: \t\t\tdefer wg.Done()\n373: \t\t\tgc.runOnce(context.Background())\n374: \t\t}()\n375: \t}\n376: \twg.Wait()\n377: \n378: \tassert.LessOrEqual(t, store.Size(), 10)\n379: }\n\n(End of file - total 379 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestNewGarbageCollector(t *testing.T) {\n\tfakeClient := fake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector_test.go","time":{"start":1775848697368,"end":1775848697391}}}}
{"type":"tool_use","timestamp":1775848697395,"sessionID":"ses_2872b99f5ffeftnzqyRZm3uri5","part":{"id":"prt_d78d4adbd001Q69bwcNimM52ux","messageID":"msg_d78d491850017cldvDduH094Ix","sessionID":"ses_2872b99f5ffeftnzqyRZm3uri5","type":"tool","tool":"read","callID":"toolu_tool-b7d44f0e9fed4dd39cfea957cb000b67","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/k8s_client.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/k8s_client.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"sync\"\n7: \n8: \tcorev1 \"k8s.io/api/core/v1\"\n9: \t\"k8s.io/apimachinery/pkg/runtime\"\n10: \t\"k8s.io/client-go/dynamic\"\n11: \t\"k8s.io/client-go/informers\"\n12: \t\"k8s.io/client-go/kubernetes\"\n13: \tcorev1listers \"k8s.io/client-go/listers/core/v1\"\n14: \t\"k8s.io/client-go/rest\"\n15: \t\"k8s.io/client-go/tools/cache\"\n16: )\n17: \n18: type K8sClient struct {\n19: \tdynamicClient   dynamic.Interface\n20: \tcoreClient      kubernetes.Interface\n21: \tinformerFactory informers.SharedInformerFactory\n22: \tpodLister       corev1listers.PodLister\n23: \tpodInformer     cache.SharedIndexInformer\n24: \tscheme          *runtime.Scheme\n25: }\n26: \n27: type ClientCache struct {\n28: \tmu      sync.RWMutex\n29: \tclients map[string]dynamic.Interface\n30: }\n31: \n32: func NewClientCache() *ClientCache {\n33: \treturn &ClientCache{\n34: \t\tclients: make(map[string]dynamic.Interface),\n35: \t}\n36: }\n37: \n38: func (c *ClientCache) GetOrCreateClient(token string, namespace string, config *rest.Config) (dynamic.Interface, error) {\n39: \tkey := fmt.Sprintf(\"%s-%s\", token, namespace)\n40: \n41: \tc.mu.RLock()\n42: \tif client, exists := c.clients[key]; exists {\n43: \t\tc.mu.RUnlock()\n44: \t\treturn client, nil\n45: \t}\n46: \tc.mu.RUnlock()\n47: \n48: \tc.mu.Lock()\n49: \tdefer c.mu.Unlock()\n50: \n51: \tif client, exists := c.clients[key]; exists {\n52: \t\treturn client, nil\n53: \t}\n54: \n55: \tuserConfig := rest.CopyConfig(config)\n56: \tuserConfig.BearerToken = token\n57: \n58: \tclient, err := dynamic.NewForConfig(userConfig)\n59: \tif err != nil {\n60: \t\treturn nil, fmt.Errorf(\"failed to create user dynamic client: %w\", err)\n61: \t}\n62: \n63: \tc.clients[key] = client\n64: \treturn client, nil\n65: }\n66: \n67: func NewK8sClient(config *rest.Config) (*K8sClient, error) {\n68: \tdynamicClient, err := dynamic.NewForConfig(config)\n69: \tif err != nil {\n70: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n71: \t}\n72: \n73: \tcoreClient, err := kubernetes.NewForConfig(config)\n74: \tif err != nil {\n75: \t\treturn nil, fmt.Errorf(\"failed to create core client: %w\", err)\n76: \t}\n77: \n78: \tinformerFactory := informers.NewSharedInformerFactoryWithOptions(\n79: \t\tcoreClient,\n80: \t\tInformerSyncTimeout,\n81: \t)\n82: \n83: \tpodInformer := informerFactory.Core().V1().Pods().Informer()\n84: \tpodLister := informerFactory.Core().V1().Pods().Lister()\n85: \n86: \tscheme := runtime.NewScheme()\n87: \tif err := corev1.AddToScheme(scheme); err != nil {\n88: \t\treturn nil, fmt.Errorf(\"failed to add corev1 to scheme: %w\", err)\n89: \t}\n90: \n91: \treturn &K8sClient{\n92: \t\tdynamicClient:   dynamicClient,\n93: \t\tcoreClient:      coreClient,\n94: \t\tinformerFactory: informerFactory,\n95: \t\tpodLister:       podLister,\n96: \t\tpodInformer:     podInformer,\n97: \t\tscheme:          scheme,\n98: \t}, nil\n99: }\n100: \n101: func (k *K8sClient) DynamicClient() dynamic.Interface {\n102: \treturn k.dynamicClient\n103: }\n104: \n105: func (k *K8sClient) CoreClient() kubernetes.Interface {\n106: \treturn k.coreClient\n107: }\n108: \n109: func (k *K8sClient) PodLister() corev1listers.PodLister {\n110: \treturn k.podLister\n111: }\n112: \n113: fu