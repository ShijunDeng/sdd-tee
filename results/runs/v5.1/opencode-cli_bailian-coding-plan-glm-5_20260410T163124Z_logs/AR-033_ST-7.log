verage.html\n123: \n124: test-race: ## Run tests with race detector\n125: \tgo test -race ./...\n126: \n127: .PHONY: fmt vet lint golangci-lint gen-check gen-copyright\n128: \n129: ##@ Quality\n130: \n131: fmt: ## Format Go files\n132: \tgo fmt ./...\n133: \n134: vet: ## Run go vet\n135: \tgo vet ./...\n136: \n137: lint: golangci-lint ## Run golangci-lint\n138: \t$(GOLANGCI_LINT) run ./...\n139: \n140: golangci-lint:\n141: \t$(call go-install-tool,$(GOLANGCI_LINT),github.com/golangci/golangci-lint/cmd/golangci-lint,$(GOLANGCI_LINT_VERSION))\n142: \n143: gen-check: gen-all ## Verify generated code is up to date\n144: \tgit diff --exit-code\n145: \n146: gen-copyright: ## Generate copyright headers\n147: \thack/update-copyright.sh\n148: \n149: .PHONY: generate controller-gen gen-crd gen-client gen-all\n150: \n151: ##@ Codegen\n152: \n153: generate: controller-gen ## Generate deepcopy and object code\n154: \t$(CONTROLLER_GEN) object:headerFile=\"hack/boilerplate.go.txt\" paths=\"./pkg/apis/...\"\n155: \n156: controller-gen:\n157: \t$(call go-install-tool,$(CONTROLLER_GEN),sigs.k8s.io/controller-tools/cmd/controller-gen,$(CONTROLLER_TOOLS_VERSION))\n158: \n159: gen-crd: controller-gen ## Generate CRD manifests\n160: \t$(CONTROLLER_GEN) crd paths=\"./pkg/apis/...\" output:crd:artifacts:config=manifests/crds\n161: \n162: gen-client: ## Generate client-go code\n163: \thack/update-codegen.sh\n164: \n165: gen-all: generate gen-client ## Run all code generation\n166: \n167: .PHONY: docker-build docker-build-router docker-build-picod docker-build-all \\\n168:         docker-buildx-push docker-buildx-push-router docker-buildx-push-picod \\\n169:         docker-push docker-push-router docker-push-picod\n170: \n171: .NOTPARALLEL: docker-build-all\n172: \n173: ##@ Docker\n174: \n175: docker-build: ## Build workloadmanager Docker image\n176: \tdocker build \\\n177: \t\t-f docker/Dockerfile \\\n178: \t\t-t $(IMAGE_REPO)/workloadmanager:$(VERSION) \\\n179: \t\t--build-arg TARGETOS=$(TARGETOS) \\\n180: \t\t--build-arg TARGETARCH=$(TARGETARCH) \\\n181: \t\t.\n182: \n183: docker-build-router: ## Build router Docker image\n184: \tdocker build \\\n185: \t\t-f docker/Dockerfile.router \\\n186: \t\t-t $(IMAGE_REPO)/router:$(VERSION) \\\n187: \t\t--build-arg TARGETOS=$(TARGETOS) \\\n188: \t\t--build-arg TARGETARCH=$(TARGETARCH) \\\n189: \t\t.\n190: \n191: docker-build-picod: ## Build picod Docker image\n192: \tdocker build \\\n193: \t\t-f docker/Dockerfile.picod \\\n194: \t\t-t $(IMAGE_REPO)/picod:$(VERSION) \\\n195: \t\t.\n196: \n197: docker-build-all: docker-build docker-build-router docker-build-picod ## Build all Docker images\n198: \n199: docker-buildx-push: ## Build and push workloadmanager multi-arch image\n200: \tdocker buildx build \\\n201: \t\t-f docker/Dockerfile \\\n202: \t\t--platform linux/amd64,linux/arm64 \\\n203: \t\t--build-arg TARGETOS=linux \\\n204: \t\t--build-arg TARGETARCH=amd64 \\\n205: \t\t--push \\\n206: \t\t-t $(IMAGE_REPO)/workloadmanager:$(VERSION) \\\n207: \t\t.\n208: \n209: docker-buildx-push-router: ## Build and push router multi-arch image\n210: \tdocker buildx build \\\n211: \t\t-f docker/Dockerfile.router \\\n212: \t\t--platform linux/amd64,linux/arm64 \\\n213: \t\t--push \\\n214: \t\t-t $(IMAGE_REPO)/router:$(VERSION) \\\n215: \t\t.\n216: \n217: docker-buildx-push-picod: ## Build and push picod multi-arch image\n218: \tdocker buildx build \\\n219: \t\t-f docker/Dockerfile.picod \\\n220: \t\t--platform linux/amd64,linux/arm64 \\\n221: \t\t--push \\\n222: \t\t-t $(IMAGE_REPO)/picod:$(VERSION) \\\n223: \t\t.\n224: \n225: docker-push: ## Push workloadmanager image to registry\n226: \tdocker push $(IMAGE_REPO)/workloadmanager:$(VERSION)\n227: \n228: docker-push-router: ## Push router image to registry\n229: \tdocker push $(IMAGE_REPO)/router:$(VERSION)\n230: \n231: docker-push-picod: ## Push picod image to registry\n232: \tdocker push $(IMAGE_REPO)/picod:$(VERSION)\n233: \n234: .PHONY: kind-load kind-load-router kind-load-