ct_timeout = connect_timeout\n37:         self._logger = get_logger(__name__)\n38: \n39:         if base_url:\n40:             self.base_url = base_url\n41:         else:\n42:             if router_url and namespace and cr_name:\n43:                 base_path = f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\"\n44:                 self.base_url = urljoin(router_url, base_path)\n45:             else:\n46:                 raise ValueError(\"Either base_url or router_url, namespace, and cr_name must be provided\")\n47: \n48:         self.session = create_session(pool_connections, pool_maxsize)\n49:         self.session.headers[self.SESSION_HEADER] = session_id\n50: \n51:     def _request(\n52:         self,\n53:         method: str,\n54:         endpoint: str,\n55:         body: Optional[bytes] = None,\n56:         timeout_override: Optional[float] = None,\n57:         **kwargs,\n58:     ) -> requests.Response:\n59:         \"\"\"Make a request to the data plane.\n60: \n61:         Args:\n62:             method: HTTP method.\n63:             endpoint: Relative endpoint path.\n64:             body: Optional JSON body bytes.\n65:             timeout_override: Optional read timeout override.\n66:             **kwargs: Additional request kwargs.\n67: \n68:         Returns:\n69:             Response object.\n70:         \"\"\"\n71:         url = urljoin(self.base_url, endpoint)\n72:         if body:\n73:             kwargs[\"data\"] = body\n74:             headers = kwargs.get(\"headers\", {})\n75:             headers[\"Content-Type\"] = \"application/json\"\n76:             kwargs[\"headers\"] = headers\n77: \n78:         read_timeout = timeout_override if timeout_override is not None else self.timeout\n79:         timeout_tuple = (self.connect_timeout, read_timeout)\n80:         response = self.session.request(method, url, timeout=timeout_tuple, **kwargs)\n81:         response.raise_for_status()\n82:         return response\n83: \n84:     def execute_command(\n85:         self,\n86:         command: Union[str, List[str]],\n87:         timeout: Optional[float] = None,\n88:     ) -> str:\n89:         \"\"\"Execute a command in the code interpreter.\n90: \n91:         Args:\n92:             command: Command string or list of command parts.\n93:             timeout: Timeout in seconds (defaults to self.timeout).\n94: \n95:         Returns:\n96:             stdout from command execution.\n97: \n98:         Raises:\n99:             CommandExecutionError: If command returns non-zero exit code.\n100:         \"\"\"\n\n(Showing lines 1-100 of 224. Use offset=101 to continue.)\n</content>","metadata":{"preview":"import base64\nimport json\nimport os\nimport requests\nfrom urllib.parse import urljoin\nfrom typing import Any, Dict, List, Optional, Union\n\nfrom agentcube.exceptions import CommandExecutionError\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.log import get_logger\n\n\nclass CodeInterpreterDataPlaneClient:\n    \"\"\"HTTP client for Router data plane API (Code Interpreter).\"\"\"\n\n    DEFAULT_TIMEOUT = 120\n    DEFAULT_CONNECT_TIMEOUT = 5.0\n    DEFAULT_POOL_CONNECTIONS = 10\n    DEFAULT_POOL_MAXSIZE = 10\n    SESSION_HEADER = \"x-agentcube-session-id\"","truncated":true,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/clients/code_interpreter_data_plane.py","time":{"start":1775880302261,"end":1775880302280}}}}
