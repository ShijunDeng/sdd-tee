{"type":"tool_use","timestamp":1775870577541,"sessionID":"ses_285e054d4ffeYM9ptLu6o350BD","part":{"id":"prt_d7a228684001axz2XcsNLk7aRd","messageID":"msg_d7a21dd33001ckwoUCqKXUn73l","sessionID":"ses_285e054d4ffeYM9ptLu6o350BD","type":"tool","tool":"write","callID":"toolu_tool-19f368566ac24e37a321c36754947712","state":{"status":"completed","input":{"content":"import pytest\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\nimport yaml\n\nfrom agentcube.runtime.build_runtime import BuildRuntime, DEFAULT_TAG\nfrom agentcube.services.metadata_service import AgentMetadata\n\n\nclass TestBuildRuntimeInit:\n    def test_init_default_verbose(self) -> None:\n        runtime = BuildRuntime()\n        assert runtime.verbose == False\n\n    def test_init_verbose_true(self) -> None:\n        runtime = BuildRuntime(verbose=True)\n        assert runtime.verbose == True\n\n\nclass TestValidateBuildPrerequisites:\n    def test_validate_docker_unavailable(self, tmp_path: Path) -> None:\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n        with patch.object(runtime._docker_service, 'check_docker_available', return_value=False):\n            with pytest.raises(RuntimeError, match=\"Docker is not available\"):\n                runtime._validate_build_prerequisites(tmp_path)\n\n    def test_validate_dockerfile_missing(self, tmp_path: Path) -> None:\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n\n        runtime = BuildRuntime()\n        with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n            with pytest.raises(ValueError, match=\"Dockerfile not found\"):\n                runtime._validate_build_prerequisites(tmp_path)\n\n    def test_validate_success(self, tmp_path: Path) -> None:\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n        with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n            runtime._validate_build_prerequisites(tmp_path)\n\n\nclass TestIncrementVersion:\n    def test_increment_semver(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.2.3\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n        new_tag = runtime._increment_version(tmp_path, metadata)\n        \n        assert new_tag == \"1.2.4\"\n        assert metadata.version == \"1.2.4\"\n\n    def test_increment_v_prefix_semver(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"v1.2.3\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n        new_tag = runtime._increment_version(tmp_path, metadata)\n        \n        assert new_tag == \"v1.2.4\"\n\n    def test_increment_v_prefix_non_semver(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"v1.0\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n        new_tag = runtime._increment_version(tmp_path, metadata)\n        \n        assert new_tag == \"v1.0.1\"\n\n    def test_increment_non_semver(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"custom\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n        new_tag = runtime._increment_version(tmp_path, metadata)\n        \n        assert new_tag == \"custom-1\"\n\n    def test_increment_empty_version(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n        new_tag = runtime._increment_version(tmp_path, metadata)\n        \n        assert new_tag == DEFAULT_TAG\n\n    def test_increment_none_version(self, tmp_path: Path) -> None:\n        metadata = AgentMetadata.model_construct(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            version=None,\n        )\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(yaml.dump(metadata.model_dump()))\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n        metadata.version = None\n        new_tag = runtime._increment_version(tmp_path, metadata)\n        \n        assert new_tag == DEFAULT_TAG\n\n\nclass TestBuildLocal:\n    def test_build_local_success(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\nbuild_mode: local\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n\n        mock_result = {\n            \"image_name\": \"test-agent\",\n            \"image_id\": \"sha256:abc123\",\n            \"image_size\": \"125.3 MB\",\n            \"build_time\": 10.5,\n            \"tag\": \"1.0.1\",\n        }\n\n        with patch.object(runtime._docker_service, 'build_image', return_value=mock_result):\n            result = runtime._build_local(tmp_path, metadata, {}, \"1.0.1\")\n            \n            assert result[\"image_name\"] == \"test-agent\"\n            assert result[\"image_id\"] == \"sha256:abc123\"\n\n    def test_build_local_with_proxy(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\nbuild_mode: local\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n\n        mock_result = {\n            \"image_name\": \"test-agent\",\n            \"image_id\": \"sha256:abc123\",\n            \"image_size\": \"125.3 MB\",\n            \"build_time\": 10.5,\n            \"tag\": \"1.0.1\",\n        }\n\n        with patch.object(runtime._docker_service, 'build_image', return_value=mock_result) as mock_build:\n            result = runtime._build_local(\n                tmp_path, \n                metadata, \n                {\"proxy\": \"http://proxy.example.com:8080\"}, \n                \"1.0.1\"\n            )\n            \n            mock_build.assert_called_once()\n            call_args = mock_build.call_args\n            assert call_args.kwargs[\"build_args\"][\"HTTP_PROXY\"] == \"http://proxy.example.com:8080\"\n            assert call_args.kwargs[\"build_args\"][\"HTTPS_PROXY\"] == \"http://proxy.example.com:8080\"\n\n\nclass TestBuildCloud:\n    def test_build_cloud_placeholder(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\nbuild_mode: cloud\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n\n        result = runtime._build_cloud(tmp_path, metadata, {}, \"1.0.1\")\n        \n        assert result[\"image_name\"] == \"test-agent\"\n        assert result[\"image_id\"] == \"cloud-placeholder\"\n        assert result[\"image_size\"] == \"0 MB\"\n\n\nclass TestUpdateBuildMetadata:\n    def test_update_build_metadata(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.1\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n\n        build_result = {\n            \"image_name\": \"test-agent\",\n            \"image_id\": \"sha256:abc123\",\n            \"image_size\": \"125.3 MB\",\n            \"build_time\": 10.5,\n        }\n\n        runtime._update_build_metadata(tmp_path, metadata, build_result, \"1.0.1\")\n\n        updated_metadata = runtime._metadata_service.load_metadata(tmp_path)\n        assert updated_metadata.image[\"image_name\"] == \"test-agent\"\n        assert updated_metadata.image[\"image_id\"] == \"sha256:abc123\"\n        assert updated_metadata.image[\"tag\"] == \"1.0.1\"\n\n\nclass TestVersionRollback:\n    def test_version_rollback_on_failure(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n\n        with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n            with patch.object(runtime._docker_service, 'build_image', side_effect=Exception(\"Build error\")):\n                with pytest.raises(RuntimeError, match=\"Build failed\"):\n                    runtime.build(tmp_path)\n\n        restored_metadata = runtime._metadata_service.load_metadata(tmp_path)\n        assert restored_metadata.version == \"1.0.0\"\n\n\nclass TestBuildFullWorkflow:\n    def test_build_success(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\nbuild_mode: local\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n\n        mock_result = {\n            \"image_name\": \"test-agent\",\n            \"image_id\": \"sha256:abc123\",\n            \"image_size\": \"125.3 MB\",\n            \"build_time\": 10.5,\n            \"tag\": \"1.0.1\",\n        }\n\n        with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n            with patch.object(runtime._docker_service, 'build_image', return_value=mock_result):\n              