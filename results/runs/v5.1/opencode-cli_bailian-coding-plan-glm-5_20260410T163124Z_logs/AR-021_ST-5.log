t = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\nbuild_mode: local\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n\n        mock_result = {\n            \"image_name\": \"test-agent\",\n            \"image_id\": \"sha256:abc123\",\n            \"image_size\": \"125.3 MB\",\n            \"build_time\": 10.5,\n            \"tag\": \"1.0.1\",\n        }\n\n        with patch.object(runtime._docker_service, 'build_image', return_value=mock_result):\n            result = runtime._build_local(tmp_path, metadata, {}, \"1.0.1\")\n            \n            assert result[\"image_name\"] == \"test-agent\"\n            assert result[\"image_id\"] == \"sha256:abc123\"\n\n    def test_build_local_with_proxy(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\nbuild_mode: local\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n        metadata = runtime._metadata_service.load_metadata(tmp_path)\n\n        mock_result = {\n            \"image_name\": \"test-agent\",\n            \"image_id\": \"sha256:abc123\",\n            \"image_size\": \"125.3 MB\",\n            \"build_time\": 10.5,\n            \"tag\": \"1.0.1\",\n        }\n\n        with patch.object(runtime._docker_service, 'build_image', return_value=mock_result) as mock_build:\n            result = runtime._build_local(\n                tmp_path, \n                metadata, \n