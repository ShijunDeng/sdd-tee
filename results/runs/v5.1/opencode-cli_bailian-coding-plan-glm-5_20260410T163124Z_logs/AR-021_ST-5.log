metadata.image[\"image_name\"] == \"test-agent\"\n        assert updated_metadata.image[\"image_id\"] == \"sha256:abc123\"\n        assert updated_metadata.image[\"tag\"] == \"1.0.1\"\n\n\nclass TestVersionRollback:\n    def test_version_rollback_on_failure(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n\n        with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n            with patch.object(runtime._docker_service, 'build_image', side_effect=Exception(\"Build error\")):\n                with pytest.raises(RuntimeError, match=\"Build failed\"):\n                    runtime.build(tmp_path)\n\n        restored_metadata = runtime._metadata_service.load_metadata(tmp_path)\n        assert restored_metadata.version == \"1.0.0\"\n\n\nclass TestBuildFullWorkflow:\n    def test_build_success(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\nbuild_mode: local\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n\n        runtime = BuildRuntime()\n\n        mock_result = {\n            \"image_name\": \"test-agent\",\n            \"image_id\": \"sha256:abc123\",\n            \"image_size\": \"125.3 MB\",\n            \"build_time\": 10.5,\n            \"tag\": \"1.0.1\",\n        }\n\n        with patch.object(runtime._docker_service, 'check_docker_available', return_value=True):\n            with patch.object(runtime._docker_service, 'build_image', return_value=mock_result):\n                result = runtime.build(tmp_path)\n\n        assert result[\"status\"] == \"success\"\n        assert result[\"image_name\"] == \"test-agent\"\n        assert result[\"tag\"] == \"1.0.1\"\n\n        updated_metadata = runtime._metadata_service.load_metadata(tmp_path)\n        assert updated_metadata.version == \"1.0.1\"\n        assert updated_metadata.image[\"image_id\"] == \"sha256:abc123\"","additions":6,"deletions":8},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_build_runtime.py","time":{"start":1775870641501,"end":1775870642210}}}}
