.output\n        assert \"agent-name\" in result.output\n\n    def test_pack_cli_valid_workspace(self, tmp_path: Path) -> None:\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n        requirements = tmp_path / \"requirements.txt\"\n        requirements.write_text(\"\")\n\n        result = runner.invoke(app, [\"pack\", \"-f\", str(tmp_path)])\n        assert result.exit_code == 0\n        assert \"Success\" in result.output\n        assert str(tmp_path) in result.output\n\n    def test_pack_cli_invalid_workspace(self) -> None:\n        result = runner.invoke(app, [\"pack\", \"-f\", \"/nonexistent/path\"])\n        assert result.exit_code == 1\n        assert \"Error\" in result.output\n\n    def test_pack_cli_verbose_output(self, tmp_path: Path) -> None:\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n\n        result = runner.invoke(app, [\"pack\", \"-f\", str(tmp_path), \"--verbose\"])\n        assert result.exit_code == 0\n\n    def test_pack_cli_with_overrides(self, tmp_path: Path) -> None:\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n\n        result = runner.invoke(\n            app,\n            [\n                \"pack\",\n                \"-f\",\n                str(tmp_path),\n                \"--agent-name\",\n                \"custom-agent\",\n                \"--port\",\n                \"9000\",\n            ],\n        )\n        assert result.exit_code == 0\n        assert \"custom-agent\" in result.output\n\n    def test_pack_cli_python_no_files(self, tmp_path: Path) -> None:\n        result = runner.invoke(app, [\"pack\", \"-f\", str(tmp_path)])\n        assert result.exit_code == 1\n        assert \"Error\" in result.output\n\n\nclass TestBuildCLI:\n    def test_build_cli_help(self) -> None:\n        result = runner.invoke(app, [\"build\", \"--help\"])\n        assert result.exit_code == 0\n        assert \"workspace\" in result.output\n        assert \"proxy\" in result.output\n\n    def test_build_cli_missing_dockerfile(self, tmp_path: Path) -> None:\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        result = runner.invoke(app, [\"build\", \"-f\", str(tmp_path)])\n        assert result.exit_code == 1\n        assert \"Dockerfile not found\" in result.output\n\n    def test_build_cli_verbose(self, tmp_path: Path) -> None:\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n        dockerfile = tmp_path / \"Dockerfile\"\n        dockerfile.write_text(\"FROM python:3.10-slim\")\n        metadata_content = \"\"\"\nagent_name: test-agent\nlanguage: python\nentrypoint: python main.py\nversion: \"1.0.0\"\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        result = runner.invoke(app, [\"build\", \"-f\", str(tmp_path), \"--verbose\"])\n        assert result.exit_code == 1\n\n\nclass TestVersionCLI:\n    def test_version_flag(self) -> None:\n        result = runner.invoke(app, [\"--version\"])\n        assert result.exit_code == 0\n        assert \"0.1.0\" in result.output\n\n\nclass TestCLIHelp:\n    def test_main_help(self) -> None:\n        result = runner.invoke(app, [\"--help\"])\n        assert result.exit_code == 0\n        assert \"pack\" in result.output\n        assert \"build\" in result.output","after":"import pytest\nfrom pathlib import Path\nfrom typer.testing import CliRunner\nimport tempfile\n\nfrom agentcube.cli.main import app\n\nrunner = CliRunner()\n\n\nclass TestPackCLI:\n    def test_pack_cli_help(self) -> None:\n        result = runner.invoke(app, [\"pack\", 