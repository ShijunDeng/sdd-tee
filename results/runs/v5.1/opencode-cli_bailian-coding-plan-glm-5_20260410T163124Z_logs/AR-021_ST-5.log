ypoint=\"python main.py\",\n36:                 build_mode=\"invalid\",\n37:             )\n38: \n39:     def test_agent_metadata_invalid_port_low(self) -> None:\n40:         with pytest.raises(ValidationError):\n41:             AgentMetadata.model_construct(\n42:                 agent_name=\"test-agent\",\n43:                 language=\"python\",\n44:                 entrypoint=\"python main.py\",\n45:                 port=0,\n46:             )\n47: \n48:     def test_agent_metadata_invalid_port_high(self) -> None:\n49:         with pytest.raises(ValidationError):\n50:             AgentMetadata.model_construct(\n51:                 agent_name=\"test-agent\",\n52:                 language=\"python\",\n53:                 entrypoint=\"python main.py\",\n54:                 port=70000,\n55:             )\n56: \n57:     def test_agent_metadata_valid_port_range(self) -> None:\n58:         metadata = AgentMetadata.model_construct(\n59:             agent_name=\"test-agent\",\n60:             language=\"python\",\n61:             entrypoint=\"python main.py\",\n62:             port=1,\n63:         )\n64:         assert metadata.port == 1\n65: \n66:         metadata = AgentMetadata.model_construct(\n67:             agent_name=\"test-agent\",\n68:             language=\"python\",\n69:             entrypoint=\"python main.py\",\n70:             port=65535,\n71:         )\n72:         assert metadata.port == 65535\n73: \n74: \n75: class TestMetadataService:\n76:     def test_metadata_service_load_agent_metadata_yaml(self, tmp_path: Path) -> None:\n77:         metadata_content = \"\"\"\n78: agent_name: loaded-agent\n79: language: python\n80: entrypoint: python main.py\n81: port: 9000\n82: build_mode: cloud\n83: \"\"\"\n84:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n85:         metadata_file.write_text(metadata_content)\n86: \n87:         service = MetadataService()\n88:         metadata = service.load_metadata(tmp_path)\n89:         assert metadata.agent_name == \"loaded-agent\"\n90:         assert metadata.port == 9000\n91:         assert metadata.build_mode == \"cloud\"\n92: \n93:     def test_metadata_service_load_fallback_agent_yaml(self, tmp_path: Path) -> None:\n94:         metadata_content = \"\"\"\n95: agent_name: fallback-agent\n96: language: python\n97: entrypoint: python app.py\n98: \"\"\"\n99:         metadata_file = tmp_path / \"agent.yaml\"\n100:         metadata_file.write_text(metadata_content)\n101: \n102:         service = MetadataService()\n103:         metadata = service.load_metadata(tmp_path)\n104:         assert metadata.agent_name == \"fallback-agent\"\n105: \n106:     def test_metadata_service_load_fallback_metadata_yaml(self, tmp_path: Path) -> None:\n107:         metadata_content = \"\"\"\n108: agent_name: meta-agent\n109: language: java\n110: entrypoint: java -jar app.jar\n111: \"\"\"\n112:         metadata_file = tmp_path / \"metadata.yaml\"\n113:         metadata_file.write_text(metadata_content)\n114: \n115:         service = MetadataService()\n116:         metadata = service.load_metadata(tmp_path)\n117:         assert metadata.agent_name == \"meta-agent\"\n118:         assert metadata.language == \"java\"\n119: \n120:     def test_metadata_service_save(self, tmp_path: Path) -> None:\n121:         metadata = AgentMetadata.model_construct(\n122:             agent_name=\"save-test\",\n123:             language=\"python\",\n124:             entrypoint=\"python main.py\",\n125:             port=8080,\n126:             build_mode=\"local\",\n127:             description=\"Test agent\",\n128:         )\n129: \n130:         service = MetadataService()\n131:         saved_path = service.save_metadata(tmp_path, metadata)\n132: \n133:         assert saved_path.exists()\n134:         assert saved_path.name == \"agent_metadata.yaml\"\n135: \n136:         with open(saved_path) as f:\n137:             data = yaml.safe_load(f)\n138: \n139:         assert data[\"agent_name\"] == \"save-test\"\n140:         assert data[\"language\"] == \"python\"\n141:         assert data[\"port\"] == 8080\n142: \n143:     def test_metadata_service_save_excludes_none(self, tmp_path: Path) -> None:\n144:         metadata = AgentMetadata.model_construct(\n145:             agent_name=\"save-test\",\n146:             language=\"python\",\n147:             entrypoint=\"python main.py\",\n148:         )\n149: \n150:         service = MetadataService()\n151:         saved_path = service.save_metadata(tmp_path, metadata)\n152: \n153:         with open(saved_path) as f:\n154:             data = yaml.safe_load(f)\n155: \n156:         assert data[\"agent_name\"] == \"save-test\"\n157: \n158:     def test_metadata_service_load_no_files(self, tmp_path: Path) -> None:\n159:         service = MetadataService()\n160:         with pytest.raises(FileNotFoundError):\n161:             service.load_metadata(tmp_path)\n\n(End of file - total 161 lines)\n</content>","metadata":{"preview":"import pytest\nfrom pathlib import Path\nimport tempfile\nimport yaml\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom pydantic import ValidationError\n\n\nclass TestAgentMetadata:\n    def test_agent_metadata_valid(self) -> None:\n        metadata = AgentMetadata.model_construct(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n        )\n        assert metadata.agent_name == \"test-agent\"\n        assert metadata.language == \"python\"\n        assert metadata.port == 8080\n        assert metadata.build_mode == \"local\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_metadata_service.py","time":{"start":1775870421781,"end":1775870421813}}}}
