outError{SandboxID: \"test-sandbox\"}\n41: \tif err.Error() != \"sandbox timeout: test-sandbox\" {\n42: \t\tt.Errorf(\"unexpected error message: %s\", err.Error())\n43: \t}\n44: \tif err.Status() != 504 {\n45: \t\tt.Errorf(\"unexpected status: %d\", err.Status())\n46: \t}\n47: \tif err.Code() != \"SANDBOX_TIMEOUT\" {\n48: \t\tt.Errorf(\"unexpected code: %s\", err.Code())\n49: \t}\n50: \tif err.Message() != \"sandbox timeout\" {\n51: \t\tt.Errorf(\"unexpected message: %s\", err.Message())\n52: \t}\n53: }\n54: \n55: func TestJWTSigningError(t *testing.T) {\n56: \tinnerErr := &SessionNotFoundError{SessionID: \"inner\"}\n57: \terr := &JWTSigningError{Err: innerErr}\n58: \tif err.Status() != 500 {\n59: \t\tt.Errorf(\"unexpected status: %d\", err.Status())\n60: \t}\n61: \tif err.Code() != \"JWT_SIGNING_FAILED\" {\n62: \t\tt.Errorf(\"unexpected code: %s\", err.Code())\n63: \t}\n64: \tif err.Message() != \"jwt signing failed\" {\n65: \t\tt.Errorf(\"unexpected message: %s\", err.Message())\n66: \t}\n67: }\n68: \n69: func TestServerOverloadedError(t *testing.T) {\n70: \terr := &ServerOverloadedError{}\n71: \tif err.Error() != \"server overloaded\" {\n72: \t\tt.Errorf(\"unexpected error message: %s\", err.Error())\n73: \t}\n74: \tif err.Status() != 429 {\n75: \t\tt.Errorf(\"unexpected status: %d\", err.Status())\n76: \t}\n77: \tif err.Code() != \"SERVER_OVERLOADED\" {\n78: \t\tt.Errorf(\"unexpected code: %s\", err.Code())\n79: \t}\n80: \tif err.Message() != \"server overloaded, please try again later\" {\n81: \t\tt.Errorf(\"unexpected message: %s\", err.Message())\n82: \t}\n83: }\n84: \n85: func TestNoEntryPointError(t *testing.T) {\n86: \terr := &NoEntryPointError{SandboxID: \"test-sandbox\"}\n87: \tif err.Error() != \"no entry point for sandbox: test-sandbox\" {\n88: \t\tt.Errorf(\"unexpected error message: %s\", err.Error())\n89: \t}\n90: \tif err.Status() != 404 {\n91: \t\tt.Errorf(\"unexpected status: %d\", err.Status())\n92: \t}\n93: \tif err.Code() != \"NO_ENTRY_POINT\" {\n94: \t\tt.Errorf(\"unexpected code: %s\", err.Code())\n95: \t}\n96: \tif err.Message() != \"no entry point configured\" {\n97: \t\tt.Errorf(\"unexpected message: %s\", err.Message())\n98: \t}\n99: }\n100: \n101: func TestWorkloadManagerError(t *testing.T) {\n102: \terr := &WorkloadManagerError{StatusCode: 500, Msg: \"test message\"}\n103: \tif err.Error() != \"test message\" {\n104: \t\tt.Errorf(\"unexpected error message: %s\", err.Error())\n105: \t}\n106: \tif err.Status() != 500 {\n107: \t\tt.Errorf(\"unexpected status: %d\", err.Status())\n108: \t}\n109: \tif err.Code() != \"WORKLOAD_MANAGER_ERROR\" {\n110: \t\tt.Errorf(\"unexpected code: %s\", err.Code())\n111: \t}\n112: \tif err.Message() != \"test message\" {\n113: \t\tt.Errorf(\"unexpected message: %s\", err.Message())\n114: \t}\n115: }\n116: \n117: func TestAPIStatusInterface(t *testing.T) {\n118: \terrors := []APIStatus{\n119: \t\t&SessionNotFoundError{SessionID: \"test\"},\n120: \t\t&SandboxUnreachableError{SandboxID: \"test\"},\n121: \t\t&SandboxTimeoutError{SandboxID: \"test\"},\n122: \t\t&JWTSigningError{Err: nil},\n123: \t\t&ServerOverloadedError{},\n124: \t\t&NoEntryPointError{SandboxID: \"test\"},\n125: \t\t&WorkloadManagerError{StatusCode: 500, Msg: \"test\"},\n126: \t}\n127: \n128: \tfor _, err := range errors {\n129: \t\tif err.Status() == 0 {\n130: \t\t\tt.Errorf(\"Status() returned 0 for %T\", err)\n131: \t\t}\n132: \t\tif err.Code() == \"\" {\n133: \t\t\tt.Errorf(\"Code() returned empty string for %T\", err)\n134: \t\t}\n135: \t\tif err.Message() == \"\" {\n136: \t\t\tt.Errorf(\"Message() returned empty string for %T\", err)\n137: \t\t}\n138: \t}\n139: }\n\n(End of file - total 139 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"testing\"\n)\n\nfunc TestSessionNotFoundError(t *testing.T) {\n\terr := &SessionNotFoundError{SessionID: \"test-session\"}\n\tif err.Error() != \"session not found: test-session\" {\n\t\tt.Errorf(\"unexpected error message: %s\", err.Error())\n\t}\n\tif err.Status() != 404 {\n\t\tt.Errorf(\"unexpected status: %d\", err.Status())\n\t}\n\tif err.Code() != \"SESSION_NOT_FOUND\" {\n\t\tt.Errorf(\"unexpected code: %s\", err.Code())\n\t}\n\tif err.Message() != \"session not found\" {\n\t\tt.Errorf(\"unexpected message: %s\", err.Message())\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/errors_test.go","time":{"start":1775850804225,"end":1775850804234}}}}
