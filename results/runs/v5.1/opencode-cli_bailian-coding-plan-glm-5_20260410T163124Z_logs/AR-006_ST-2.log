{"type":"tool_use","timestamp":1775844798470,"sessionID":"ses_287677128ffe1OYkAXjU0bM6jn","part":{"id":"prt_d78992daf001dTFNTlfbecvKmF","messageID":"msg_d78990fed0010I0ePo2OM9KwFO","sessionID":"ses_287677128ffe1OYkAXjU0bM6jn","type":"tool","tool":"read","callID":"toolu_tool-08174a49a27f4a249f7febec09354eaa","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/k8s_client.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/k8s_client.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"sync\"\n7: \n8: \tcorev1 \"k8s.io/api/core/v1\"\n9: \t\"k8s.io/apimachinery/pkg/runtime\"\n10: \t\"k8s.io/client-go/dynamic\"\n11: \t\"k8s.io/client-go/informers\"\n12: \t\"k8s.io/client-go/kubernetes\"\n13: \tcorev1listers \"k8s.io/client-go/listers/core/v1\"\n14: \t\"k8s.io/client-go/rest\"\n15: \t\"k8s.io/client-go/tools/cache\"\n16: )\n17: \n18: type K8sClient struct {\n19: \tdynamicClient   dynamic.Interface\n20: \tcoreClient      kubernetes.Interface\n21: \tinformerFactory informers.SharedInformerFactory\n22: \tpodLister       corev1listers.PodLister\n23: \tpodInformer     cache.SharedIndexInformer\n24: \tscheme          *runtime.Scheme\n25: }\n26: \n27: type ClientCache struct {\n28: \tmu      sync.RWMutex\n29: \tclients map[string]dynamic.Interface\n30: }\n31: \n32: func NewClientCache() *ClientCache {\n33: \treturn &ClientCache{\n34: \t\tclients: make(map[string]dynamic.Interface),\n35: \t}\n36: }\n37: \n38: func (c *ClientCache) GetOrCreateClient(token string, namespace string, config *rest.Config) (dynamic.Interface, error) {\n39: \tkey := fmt.Sprintf(\"%s-%s\", token, namespace)\n40: \n41: \tc.mu.RLock()\n42: \tif client, exists := c.clients[key]; exists {\n43: \t\tc.mu.RUnlock()\n44: \t\treturn client, nil\n45: \t}\n46: \tc.mu.RUnlock()\n47: \n48: \tc.mu.Lock()\n49: \tdefer c.mu.Unlock()\n50: \n51: \tif client, exists := c.clients[key]; exists {\n52: \t\treturn client, nil\n53: \t}\n54: \n55: \tuserConfig := rest.CopyConfig(config)\n56: \tuserConfig.BearerToken = token\n57: \n58: \tclient, err := dynamic.NewForConfig(userConfig)\n59: \tif err != nil {\n60: \t\treturn nil, fmt.Errorf(\"failed to create user dynamic client: %w\", err)\n61: \t}\n62: \n63: \tc.clients[key] = client\n64: \treturn client, nil\n65: }\n66: \n67: func NewK8sClient(config *rest.Config) (*K8sClient, error) {\n68: \tdynamicClient, err := dynamic.NewForConfig(config)\n69: \tif err != nil {\n70: \t\treturn nil, fmt.Errorf(\"failed to create dynamic client: %w\", err)\n71: \t}\n72: \n73: \tcoreClient, err := kubernetes.NewForConfig(config)\n74: \tif err != nil {\n75: \t\treturn nil, fmt.Errorf(\"failed to create core client: %w\", err)\n76: \t}\n77: \n78: \tinformerFactory := informers.NewSharedInformerFactoryWithOptions(\n79: \t\tcoreClient,\n80: \t\tInformerSyncTimeout,\n81: \t)\n82: \n83: \tpodInformer := informerFactory.Core().V1().Pods().Informer()\n84: \tpodLister := informerFactory.Core().V1().Pods().Lister()\n85: \n86: \tscheme := runtime.NewScheme()\n87: \tif err := corev1.AddToScheme(scheme); err != nil {\n88: \t\treturn nil, fmt.Errorf(\"failed to add corev1 to scheme: %w\", err)\n89: \t}\n90: \n91: \treturn &K8sClient{\n92: \t\tdynamicClient:   dynamicClient,\n93: \t\tcoreClient:      coreClient,\n94: \t\tinformerFactory: informerFactory,\n95: \t\tpodLister:       podLister,\n96: \t\tpodInformer:     podInformer,\n97: \t\tscheme:          scheme,\n98: \t}, nil\n99: }\n100: \n101: func (k *K8sClient) DynamicClient() dynamic.Interface {\n102: \treturn k.dynamicClient\n103: }\n104: \n105: func (k *K8sClient) CoreClient() kubernetes.Interface {\n106: \treturn k.coreClient\n107: }\n108: \n109: func (k *K8sClient) PodLister() corev1listers.PodLister {\n110: \treturn k.podLister\n111: }\n112: \n113: func (k *K8sClient) InformerFactory() informers.SharedInformerFactory {\n114: \treturn k.informerFactory\n115: }\n116: \n117: func (k *K8sClient) StartInformers(ctx context.Context) {\n118: \tk.informerFactory.Start(ctx.Done())\n119: }\n120: \n121: func (k *K8sClient) WaitForCacheSync(ctx context.Context) bool {\n122: \tsynced := k.informerFactory.WaitForCacheSync(ctx.Done())\n123: \tfor _, isSynced := range synced {\n124: \t\tif !isSynced {\n125: \t\t\treturn false\n126: \t\t}\n127: \t}\n128: \treturn true\n129: }\n\n(End of file - total 129 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/client-go/dynamic\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-go/kubernetes\"\n\tcorev1listers \"k8s.io/client-go/listers/core/v1\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/client-go/tools/cache\"\n)\n\ntype K8sClient struct {\n\tdynamicClient   dynamic.Interface\n\tcoreClient      kubernetes.Interface","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/k8s_client.go","time":{"start":1775844798450,"end":1775844798468}}}}
