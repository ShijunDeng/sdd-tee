{"type":"tool_use","timestamp":1775866264218,"sessionID":"ses_2862427feffe06h9bwEM7tLu4y","part":{"id":"prt_d79e0b690001SoyR3LYwsI1NZa","messageID":"msg_d79e09242001p0dC2xGx90wNP1","sessionID":"ses_2862427feffe06h9bwEM7tLu4y","type":"tool","tool":"read","callID":"toolu_tool-f74b0ad9d7f941038a6ea87eae9b6901","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"fmt\"\n7: \t\"net/http\"\n8: \t\"time\"\n9: \n10: \t\"github.com/go-chi/chi/v5\"\n11: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n12: )\n13: \n14: type Handler interface {\n15: \tRegister(r chi.Router)\n16: }\n17: \n18: type Logger interface {\n19: \tInfo(msg string, args ...any)\n20: \tError(msg string, args ...any)\n21: }\n22: \n23: type Store interface {\n24: \tStoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error\n25: \tGetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n26: \tUpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error\n27: \tDeleteSandboxBySessionID(ctx context.Context, sessionID string) error\n28: \tListSandboxes(ctx context.Context) ([]*types.SandboxInfo, error)\n29: \tListExpiredSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)\n30: \tListInactiveSandboxes(ctx context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error)\n31: }\n32: \n33: type ErrorResponse struct {\n34: \tCode    string `json:\"code\"`\n35: \tMessage string `json:\"message\"`\n36: \tDetails any    `json:\"details,omitempty\"`\n37: }\n38: \n39: type SuccessResponse struct {\n40: \tData any `json:\"data\"`\n41: }\n42: \n43: type ValidationError struct {\n44: \tField  string\n45: \tReason string\n46: }\n47: \n48: func (e *ValidationError) Error() string {\n49: \treturn fmt.Sprintf(\"validation error: %s - %s\", e.Field, e.Reason)\n50: }\n51: \n52: type NotFoundError struct {\n53: \tResource string\n54: \tName     string\n55: }\n56: \n57: func (e *NotFoundError) Error() string {\n58: \treturn fmt.Sprintf(\"not found: %s/%s\", e.Resource, e.Name)\n59: }\n60: \n61: type InternalError struct {\n62: \tErr error\n63: }\n64: \n65: func (e *InternalError) Error() string {\n66: \treturn fmt.Sprintf(\"internal error: %v\", e.Err)\n67: }\n68: \n69: type ServiceUnavailableError struct {\n70: \tDependency string\n71: }\n72: \n73: func (e *ServiceUnavailableError) Error() string {\n74: \treturn fmt.Sprintf(\"service unavailable: %s\", e.Dependency)\n75: }\n76: \n77: type ConflictError struct {\n78: \tResource string\n79: \tErr      error\n80: }\n81: \n82: func (e *ConflictError) Error() string {\n83: \treturn fmt.Sprintf(\"conflict on %s: %v\", e.Resource, e.Err)\n84: }\n85: \n86: type DeletionReason string\n87: \n88: const (\n89: \tDeletionReasonIdleTimeout        DeletionReason = \"IdleTimeout\"\n90: \tDeletionReasonMaxDurationReached DeletionReason = \"MaxDurationReached\"\n91: \tDeletionReasonUserRequest        DeletionReason = \"UserRequest\"\n92: )\n93: \n94: func HandleError(w http.ResponseWriter, _ *http.Request, err error) {\n95: \tw.Header().Set(\"Content-Type\", \"application/json\")\n96: \n97: \tvar resp ErrorResponse\n98: \tvar status int\n99: \n100: \tswitch e := err.(type) {\n101: \tcase *ValidationError:\n102: \t\tstatus = http.StatusBadRequest\n103: \t\tresp = ErrorResponse{\n104: \t\t\tCode:    \"VALIDATION_ERROR\",\n105: \t\t\tMessage: \"Invalid request parameter\",\n106: \t\t\tDetails: map[string]string{\"field\": e.Field, \"reason\": e.Reason},\n107: \t\t}\n108: \tcase *NotFoundError:\n109: \t\tstatus = http.StatusNotFound\n110: \t\tresp = ErrorResponse{\n111: \t\t\tCode:    \"NOT_FOUND\",\n112: \t\t\tMessage: e.Error(),\n113: \t\t}\n114: \tcase *ServiceUnavailableError:\n115: \t\tstatus = http.StatusServiceUnavailable\n116: \t\tresp = ErrorResponse{\n117: \t\t\tCode:    \"SERVICE_UNAVAILABLE\",\n118: \t\t\tMessage: e.Error(),\n119: \t\t}\n120: \tcase *InternalError:\n121: \t\tstatus = http.StatusInternalServerError\n122: \t\tresp = ErrorResponse{\n123: \t\t\tCode:    \"INTERNAL_ERROR\",\n124: \t\t\tMessage: \"Unexpected server error\",\n125: \t\t}\n126: \tdefault:\n127: \t\tstatus = http.StatusInternalServerError\n128: \t\tresp = ErrorResponse{\n129: \t\t\tCode:    \"INTERNAL_ERROR\",\n130: \t\t\tMessage: \"Unexpected server error\",\n131: \t\t}\n132: \t}\n133: \n134: \tw.WriteHeader(status)\n135: \tjson.NewEncoder(w).Encode(resp)\n136: }\n\n(End of file - total 136 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype Handler interface {\n\tRegister(r chi.Router)\n}\n\ntype Logger interface {\n\tInfo(msg string, args ...any)\n\tError(msg string, args ...any)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types.go","time":{"start":1775866264205,"end":1775866264217}}}}
{"type":"tool_use","timestamp":1775866264221,"sessionID":"ses_2862427feffe06h9bwEM7tLu4y","part":{"id":"prt_d79e0ba720019yjYn4UN4ke3ZG","messageID":"msg_d79e09242001p0dC2xGx90wNP1","sessionID":"ses_2862427feffe06h9bwEM7tLu4y","type":"tool","tool":"read","callID":"toolu_tool-a425766cf75245aab74580795e670e2c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"sort\"\n6: \t\"sync\"\n7: \t\"time\"\n8: \n9: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n10: )\n11: \n12: var ErrSandboxNotFound = &NotFoundError{Resource: \"sandbox\", Name: \"\"}\n13: \n14: type MemoryStore struct {\n15: \tmu              sync.RWMutex\n16: \tsandboxes       map[string]*types.SandboxInfo\n17: \texpirationIndex map[string]time.Time\n18: }\n19: \n20: func NewMemoryStore() *MemoryStore {\n21: \treturn &MemoryStore{\n22: \t\tsandboxes:       make(map[string]*types.SandboxInfo),\n23: \t\texpirationIndex: make(map[string]time.Time),\n24: \t}\n25: }\n26: \n27: func (s *MemoryStore) StoreSandbox(_ context.Context, sandbox *types.SandboxInfo) error {\n28: \ts.mu.Lock()\n29: \tdefer s.mu.Unlock()\n30: \n31: \ts.sandboxes[sandbox.SessionID] = sandbox\n32: \ts.expirationIndex[sandbox.SandboxID] = sandbox.ExpiresAt\n33: \n34: \treturn nil\n35: }\n36: \n37: func (s *MemoryStore) GetSandboxBySessionID(_ context.Context, sessionID string) (*types.SandboxInfo, error) {\n38: \ts.mu.RLock()\n39: \tdefer s.mu.RUnlock()\n40: \n41: \tsandbox, exists := s.sandboxes[sessionID]\n42: \tif !exists {\n43: \t\treturn nil, &NotFoundError{Resource: \"sandbox\", Name: sessionID}\n44: \t}\n45: \n46: \treturn sandbox, nil\n47: }\n48: \n49: func (s *MemoryStore) UpdateSandbox(_ context.Context, sandbox *types.SandboxInfo) error {\n50: \ts.mu.Lock()\n51: \tdefer s.mu.Unlock()\n52: \n53: \tif _, exists := s.sandboxes[sandbox.SessionID]; !exists {\n54: \t\treturn &NotFoundError{Resource: \"sandbox\", Name: sandbox.SessionID}\n55: \t}\n56: \n57: \ts.sandboxes[sandbox.SessionID] = sandbox\n58: \ts.expirationIndex[sandbox.SandboxID] = sandbox.ExpiresAt\n59: \n60: \treturn nil\n61: }\n62: \n63: func (s *MemoryStore) DeleteSandboxBySessionID(_ context.Context, sessionID string) error {\n64: \ts.mu.Lock()\n65: \tdefer s.mu.Unlock()\n66: \n67: \tsandbox, exists := s.sandboxes[sessionID]\n68: \tif !exists {\n69: \t\treturn nil\n70: \t}\n71: \n72: \tdelete(s.sandboxes, sessionID)\n73: \tdelete(s.expirationIndex, sandbox.SandboxID)\n74: \n75: \treturn nil\n76: }\n77: \n78: func (s *MemoryStore) ListSandboxes(_ context.Context) ([]*types.SandboxInfo, error) {\n79: \ts.mu.RLock()\n80: \tdefer s.mu.RUnlock()\n81: \n82: \tresult := make([]*types.SandboxInfo, 0, len(s.sandboxes))\n83: \tfor _, sandbox := range s.sandboxes {\n84: \t\tresult = append(result, sandbox)\n85: \t}\n86: \n87: \treturn result, nil\n88: }\n89: \n90: func (s *MemoryStore) ListExpiredSandboxes(_ context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n91: \ts.mu.RLock()\n92: \tdefer s.mu.RUnlock()\n93: \n94: \tvar expired []*types.SandboxInfo\n95: \tfor _, sandbox := range s.sandboxes {\n96: \t\tif sandbox.ExpiresAt.Before(before) {\n97: \t\t\texpired = append(expired, sandbox)\n98: \t\t}\n99: \t}\n100: \n101: \tsort.Slice(expired, func(i, j int) bool {\n102: \t\treturn expired[i].ExpiresAt.Before(expired[j].ExpiresAt)\n103: \t})\n104: \n105: \tif limit > 0 && len(expired) > limit {\n106: \t\texpired = expired[:limit]\n107: \t}\n108: \n109: \treturn expired, nil\n110: }\n111: \n112: func (s *MemoryStore) ListInactiveSandboxes(_ context.Context, before time.Time, limit int) ([]*types.SandboxInfo, error) {\n113: \ts.mu.RLock()\n114: \tdefer s.mu.RUnlock()\n115: \n116: \tvar inactive []*types.SandboxInfo\n117: \tfor _, sandbox := range s.sandboxes {\n118: \t\tif !sandbox.LastActivity.IsZero() && sandbox.LastActivity.Before(before) {\n119: \t\t\tinactive = append(inactive, sandbox)\n120: \t\t}\n121: \t}\n122: \n123: \tsort.Slice(inactive, func(i, j int) bool {\n124: \t\treturn inactive[i].LastActivity.Before(inactive[j].LastActivity)\n125: \t})\n126: \n127: \tif limit > 0 && len(inactive) > limit {\n128: \t\tinactive = inactive[:limit]\n129: \t}\n130: \n131: \treturn inactive, nil\n132: }\n133: \n134: func (s *MemoryStore) Clear() {\n135: \ts.mu.Lock()\n136: \tdefer s.mu.Unlock()\n137: \n138: \ts.sandboxes = make(map[string]*types.SandboxInfo)\n139: \ts.expirationIndex = make(map[string]time.Time)\n140: }\n141: \n142: func (s *MemoryStore) Size() int {\n143: \ts.mu.RLock()\n144: \tdefer s.mu.RUnlock()\n145: \n146: \treturn len(s.sandboxes)\n147: }\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sort\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nvar ErrSandboxNotFound = &NotFoundError{Resource: \"sandbox\", Name: \"\"}\n\ntype MemoryStore struct {\n\tmu              sync.RWMutex\n\tsandboxes       map[string]*types.SandboxInfo\n\texpirationIndex map[string]time.Time\n}\n\nfunc NewMemoryStore() *MemoryStore {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store.go","time":{"start":1775866264208,"end":1775866264219}}}}
