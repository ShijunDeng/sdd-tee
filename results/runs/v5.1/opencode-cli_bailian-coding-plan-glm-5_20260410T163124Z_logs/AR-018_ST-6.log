{"type":"tool_use","timestamp":1775866279184,"sessionID":"ses_2862427feffe06h9bwEM7tLu4y","part":{"id":"prt_d79e0f4d1001SxaG6ZSFtTWaCa","messageID":"msg_d79e0bad8001ky8QN8BY8Ci1uf","sessionID":"ses_2862427feffe06h9bwEM7tLu4y","type":"tool","tool":"read","callID":"toolu_tool-78d7e7df82d04e48b0d59312bb43a27d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"time\"\n6: \n7: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n8: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n9: \t\"k8s.io/utils/ptr\"\n10: \n11: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n12: )\n13: \n14: type LifecycleConfig struct {\n15: \tDefaultTTL          time.Duration\n16: \tDefaultIdleTimeout  time.Duration\n17: \tDefaultMaxDuration  time.Duration\n18: \tGCInterval          time.Duration\n19: \tGCOnceTimeout       time.Duration\n20: \tDeletionGracePeriod int64\n21: \tDeletionTimeout     time.Duration\n22: }\n23: \n24: func DefaultLifecycleConfig() LifecycleConfig {\n25: \treturn LifecycleConfig{\n26: \t\tDefaultTTL:          DefaultSandboxTTL,\n27: \t\tDefaultIdleTimeout:  DefaultSandboxIdleTimeout,\n28: \t\tDefaultMaxDuration:  DefaultMaxSessionDuration,\n29: \t\tGCInterval:          GarbageCollectorInterval,\n30: \t\tGCOnceTimeout:       2 * time.Minute,\n31: \t\tDeletionGracePeriod: 0,\n32: \t\tDeletionTimeout:     SandboxDeleteTimeout,\n33: \t}\n34: }\n35: \n36: type SandboxLifecycleManager struct {\n37: \tk8sClient *K8sClient\n38: \tstore     Store\n39: \tconfig    LifecycleConfig\n40: \tlogger    Logger\n41: }\n42: \n43: func NewSandboxLifecycleManager(k8sClient *K8sClient, store Store, config LifecycleConfig, logger Logger) *SandboxLifecycleManager {\n44: \treturn &SandboxLifecycleManager{\n45: \t\tk8sClient: k8sClient,\n46: \t\tstore:     store,\n47: \t\tconfig:    config,\n48: \t\tlogger:    logger,\n49: \t}\n50: }\n51: \n52: func (m *SandboxLifecycleManager) DeleteSandbox(ctx context.Context, sessionID string) error {\n53: \tctx, cancel := context.WithTimeout(ctx, m.config.DeletionTimeout)\n54: \tdefer cancel()\n55: \n56: \tsandboxInfo, err := m.store.GetSandboxBySessionID(ctx, sessionID)\n57: \tif err != nil {\n58: \t\tif _, ok := err.(*NotFoundError); ok {\n59: \t\t\treturn &NotFoundError{Resource: \"session\", Name: sessionID}\n60: \t\t}\n61: \t\treturn &InternalError{Err: err}\n62: \t}\n63: \n64: \tdeleteOpts := metav1.DeleteOptions{\n65: \t\tGracePeriodSeconds: ptr.To(m.config.DeletionGracePeriod),\n66: \t}\n67: \n68: \terr = m.k8sClient.DynamicClient().Resource(SandboxGVR).\n69: \t\tNamespace(sandboxInfo.SandboxNamespace).\n70: \t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n71: \n72: \tif err != nil && !apierrors.IsNotFound(err) {\n73: \t\treturn handleDeleteError(err)\n74: \t}\n75: \n76: \tif sandboxInfo.Kind == types.SandboxClaimKind {\n77: \t\terr = m.k8sClient.DynamicClient().Resource(SandboxClaimGVR).\n78: \t\t\tNamespace(sandboxInfo.SandboxNamespace).\n79: \t\t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n80: \n81: \t\tif err != nil && !apierrors.IsNotFound(err) {\n82: \t\t\tm.logger.Error(\"failed to delete SandboxClaim\", \"sandboxName\", sandboxInfo.SandboxName, \"err\", err)\n83: \t\t}\n84: \t}\n85: \n86: \terr = m.store.DeleteSandboxBySessionID(ctx, sessionID)\n87: \tif err != nil {\n88: \t\tm.logger.Error(\"failed to delete from store\", \"sessionID\", sessionID, \"err\", err)\n89: \t}\n90: \n91: \treturn nil\n92: }\n93: \n94: func (m *SandboxLifecycleManager) IsExpired(sandbox *types.SandboxInfo) bool {\n95: \treturn time.Now().After(sandbox.ExpiresAt)\n96: }\n97: \n98: func (m *SandboxLifecycleManager) IsIdleExpired(sandbox *types.SandboxInfo, idleTimeout time.Duration) bool {\n99: \tif sandbox.LastActivity.IsZero() {\n100: \t\treturn false\n101: \t}\n102: \treturn time.Now().After(sandbox.LastActivity.Add(idleTimeout))\n103: }\n104: \n105: func (m *SandboxLifecycleManager) ForceDeleteSandbox(ctx context.Context, sessionID string) error {\n106: \tctx, cancel := context.WithTimeout(ctx, m.config.DeletionTimeout)\n107: \tdefer cancel()\n108: \n109: \tsandboxInfo, err := m.store.GetSandboxBySessionID(ctx, sessionID)\n110: \tif err != nil {\n111: \t\tif _, ok := err.(*NotFoundError); ok {\n112: \t\t\treturn nil\n113: \t\t}\n114: \t\treturn &InternalError{Err: err}\n115: \t}\n116: \n117: \tdeleteOpts := metav1.DeleteOptions{\n118: \t\tGracePeriodSeconds: ptr.To[int64](0),\n119: \t}\n120: \n121: \terr = m.k8sClient.DynamicClient().Resource(SandboxGVR).\n122: \t\tNamespace(sandboxInfo.SandboxNamespace).\n123: \t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n124: \n125: \tif err != nil && !apierrors.IsNotFound(err) {\n126: \t\tm.logger.Error(\"force delete sandbox CR failed\", \"sandboxName\", sandboxInfo.SandboxName, \"err\", err)\n127: \t}\n128: \n129: \tif sandboxInfo.Kind == types.SandboxClaimKind {\n130: \t\tm.k8sClient.DynamicClient().Resource(SandboxClaimGVR).\n131: \t\t\tNamespace(sandboxInfo.SandboxNamespace).\n132: \t\t\tDelete(ctx, sandboxInfo.SandboxName, deleteOpts)\n133: \t}\n134: \n135: \terr = m.store.DeleteSandboxBySessionID(ctx, sessionID)\n136: \tif err != nil {\n137: \t\tm.logger.Error(\"failed to delete from store during force delete\", \"sessionID\", sessionID, \"err\", err)\n138: \t}\n139: \n140: \treturn nil\n141: }\n142: \n143: func (m *SandboxLifecycleManager) GetSandbox(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n144: \treturn m.store.GetSandboxBySessionID(ctx, sessionID)\n145: }\n146: \n147: func (m *SandboxLifecycleManager) UpdateSandboxStatus(ctx context.Context, sessionID string, status string) error {\n148: \tsandbox, err := m.store.GetSandboxBySessionID(ctx, sessionID)\n149: \tif err != nil {\n150: \t\treturn err\n151: \t}\n152: \n153: \tsandbox.Status = status\n154: \treturn m.store.UpdateSandbox(ctx, sandbox)\n155: }\n156: \n157: func handleDeleteError(err error) error {\n158: \tif apierrors.IsNotFound(err) {\n159: \t\treturn nil\n160: \t}\n161: \tif apierrors.IsConflict(err) {\n162: \t\treturn &ConflictError{Resource: \"sandbox\", Err: err}\n163: \t}\n164: \treturn &InternalError{Err: err}\n165: }\n166: \n167: func determineDeletionReason(sandbox *types.SandboxInfo, now time.Time, idleTimeout time.Duration) DeletionReason {\n168: \tif now.After(sandbox.ExpiresAt) {\n169: \t\treturn DeletionReasonMaxDurationReached\n170: \t}\n171: \tif !sandbox.LastActivity.IsZero() && now.After(sandbox.LastActivity.Add(idleTimeout)) {\n172: \t\treturn DeletionReasonIdleTimeout\n173: \t}\n174: \treturn DeletionReasonUserRequest\n175: }\n\n(End of file - total 175 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"time\"\n\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/utils/ptr\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype LifecycleConfig struct {\n\tDefaultTTL          time.Duration\n\tDefaultIdleTimeout  time.Duration\n\tDefaultMaxDuration  time.Duration\n\tGCInterval          time.Duration\n\tGCOnceTimeout       time.Duration\n\tDeletionGracePeriod int64","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle.go","time":{"start":1775866279156,"end":1775866279180}}}}
