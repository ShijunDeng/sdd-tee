{"type":"tool_use","timestamp":1775866084711,"sessionID":"ses_2862427feffe06h9bwEM7tLu4y","part":{"id":"prt_d79ddf93b001scIH4zdT35Z2ah","messageID":"msg_d79dde1b0001NQKsoVXTvbRTVc","sessionID":"ses_2862427feffe06h9bwEM7tLu4y","type":"tool","tool":"read","callID":"toolu_tool-8f4355f1006140aa8c4b26d075c247ad","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/agentd/idle_cleanup.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/agentd/idle_cleanup.go</path>\n<type>file</type>\n<content>\n1: package agentd\n2: \n3: import (\n4: \t\"context\"\n5: \t\"sync\"\n6: \t\"time\"\n7: \n8: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n9: )\n10: \n11: type LifecycleManager interface {\n12: \tDeleteSandbox(ctx context.Context, sessionID string) error\n13: }\n14: \n15: type IdleCleanupStats struct {\n16: \tInterval        time.Duration\n17: \tIdleTimeout     time.Duration\n18: \tLastCleanupTime time.Time\n19: }\n20: \n21: type IdleCleanupController struct {\n22: \tstore            workloadmanager.Store\n23: \tlifecycleManager LifecycleManager\n24: \tinterval         time.Duration\n25: \tidleTimeout      time.Duration\n26: \tstopCh           chan struct{}\n27: \twg               sync.WaitGroup\n28: \tlogger           workloadmanager.Logger\n29: \tidleMu           sync.RWMutex\n30: \tlastCleanupTime  time.Time\n31: \tlastCleanupMu    sync.RWMutex\n32: }\n33: \n34: func NewIdleCleanupController(store workloadmanager.Store, lifecycleManager LifecycleManager, interval, idleTimeout time.Duration, logger workloadmanager.Logger) *IdleCleanupController {\n35: \tif interval == 0 {\n36: \t\tinterval = DefaultIdleCleanupInterval\n37: \t}\n38: \tif idleTimeout == 0 {\n39: \t\tidleTimeout = DefaultIdleTimeout\n40: \t}\n41: \n42: \treturn &IdleCleanupController{\n43: \t\tstore:            store,\n44: \t\tlifecycleManager: lifecycleManager,\n45: \t\tinterval:         interval,\n46: \t\tidleTimeout:      idleTimeout,\n47: \t\tstopCh:           make(chan struct{}),\n48: \t\tlogger:           logger,\n49: \t}\n50: }\n51: \n52: func (ctrl *IdleCleanupController) Start() {\n53: \tctrl.wg.Add(1)\n54: \tgo ctrl.runLoop()\n55: }\n56: \n57: func (ctrl *IdleCleanupController) Stop() {\n58: \tclose(ctrl.stopCh)\n59: \tctrl.wg.Wait()\n60: }\n61: \n62: func (ctrl *IdleCleanupController) runLoop() {\n63: \tdefer ctrl.wg.Done()\n64: \n65: \tticker := time.NewTicker(ctrl.interval)\n66: \tdefer ticker.Stop()\n67: \n68: \tctrl.runOnce(context.Background())\n69: \n70: \tfor {\n71: \t\tselect {\n72: \t\tcase <-ctrl.stopCh:\n73: \t\t\tctrl.logger.Info(\"idle cleanup controller stopped\")\n74: \t\t\treturn\n75: \t\tcase <-ticker.C:\n76: \t\t\tctrl.runOnce(context.Background())\n77: \t\t}\n78: \t}\n79: }\n80: \n81: func (ctrl *IdleCleanupController) runOnce(ctx context.Context) {\n82: \tsessions, err := ctrl.store.ListSandboxes(ctx)\n83: \tif err != nil {\n84: \t\tctrl.logger.Error(\"failed to list sessions\", \"err\", err)\n85: \t\treturn\n86: \t}\n87: \n88: \tnow := time.Now()\n89: \tidleTimeout := ctrl.getIdleTimeout()\n90: \tcleanedCount := 0\n91: \n92: \tfor _, session := range sessions {\n93: \t\tif session.LastActivity.IsZero() {\n94: \t\t\tcontinue\n95: \t\t}\n96: \n97: \t\tidleDuration := now.Sub(session.LastActivity)\n98: \t\tif idleDuration <= idleTimeout {\n99: \t\t\tcontinue\n100: \t\t}\n101: \n102: \t\terr := ctrl.lifecycleManager.DeleteSandbox(ctx, session.SessionID)\n103: \t\tif err != nil {\n104: \t\t\tif _, ok := err.(*workloadmanager.NotFoundError); ok {\n105: \t\t\t\tcontinue\n106: \t\t\t}\n107: \t\t\tctrl.logger.Error(\"idle cleanup failed\", \"sessionID\", session.SessionID, \"err\", err)\n108: \t\t\tcontinue\n109: \t\t}\n110: \n111: \t\tcleanedCount++\n112: \t\tctrl.logger.Info(\"idle cleanup deleted session\", \"sessionID\", session.SessionID, \"idleDuration\", idleDuration, \"reason\", workloadmanager.DeletionReasonIdleTimeout)\n113: \t}\n114: \n115: \tctrl.lastCleanupMu.Lock()\n116: \tctrl.lastCleanupTime = time.Now()\n117: \tctrl.lastCleanupMu.Unlock()\n118: \n119: \tctrl.logger.Info(\"idle cleanup cycle completed\", \"cleanedCount\", cleanedCount)\n120: }\n121: \n122: func (ctrl *IdleCleanupController) SetIdleTimeout(timeout time.Duration) {\n123: \tctrl.idleMu.Lock()\n124: \tdefer ctrl.idleMu.Unlock()\n125: \tctrl.idleTimeout = timeout\n126: }\n127: \n128: func (ctrl *IdleCleanupController) GetIdleTimeout() time.Duration {\n129: \tctrl.idleMu.RLock()\n130: \tdefer ctrl.idleMu.RUnlock()\n131: \treturn ctrl.idleTimeout\n132: }\n133: \n134: func (ctrl *IdleCleanupController) getIdleTimeout() time.Duration {\n135: \tctrl.idleMu.RLock()\n136: \tdefer ctrl.idleMu.RUnlock()\n137: \treturn ctrl.idleTimeout\n138: }\n139: \n140: func (ctrl *IdleCleanupController) GetStats() IdleCleanupStats {\n141: \tctrl.idleMu.RLock()\n142: \tdefer ctrl.idleMu.RUnlock()\n143: \tctrl.lastCleanupMu.RLock()\n144: \tdefer ctrl.lastCleanupMu.RUnlock()\n145: \treturn IdleCleanupStats{\n146: \t\tInterval:        ctrl.interval,\n147: \t\tIdleTimeout:     ctrl.idleTimeout,\n148: \t\tLastCleanupTime: ctrl.lastCleanupTime,\n149: \t}\n150: }\n\n(End of file - total 150 lines)\n</content>","metadata":{"preview":"package agentd\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\ntype LifecycleManager interface {\n\tDeleteSandbox(ctx context.Context, sessionID string) error\n}\n\ntype IdleCleanupStats struct {\n\tInterval        time.Duration\n\tIdleTimeout     time.Duration\n\tLastCleanupTime time.Time\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/agentd/idle_cleanup.go","time":{"start":1775866084688,"end":1775866084710}}}}
{"type":"tool_use","timestamp":1775866084713,"sessionID":"ses_2862427feffe06h9bwEM7tLu4y","part":{"id":"prt_d79ddfd2d001A53szF5EFOj9KD","messageID":"msg_d79dde1b0001NQKsoVXTvbRTVc","sessionID":"ses_2862427feffe06h9bwEM7tLu4y","type":"tool","tool":"read","callID":"toolu_tool-e7a5deea325348b78822c1174e4a22ab","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/agentd/idle_cleanup_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/agentd/idle_cleanup_test.go</path>\n<type>file</type>\n<content>\n1: package agentd\n2: \n3: import (\n4: \t\"context\"\n5: \t\"sync\"\n6: \t\"testing\"\n7: \t\"time\"\n8: \n9: \t\"github.com/stretchr/testify/assert\"\n10: \t\"github.com/stretchr/testify/require\"\n11: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n12: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n13: )\n14: \n15: type mockLogger struct {\n16: \tinfos  []string\n17: \terrors []string\n18: \tmu     sync.Mutex\n19: }\n20: \n21: func (l *mockLogger) Info(msg string, args ...any) {\n22: \tl.mu.Lock()\n23: \tdefer l.mu.Unlock()\n24: \tl.infos = append(l.infos, msg)\n25: }\n26: \n27: func (l *mockLogger) Error(msg string, args ...any) {\n28: \tl.mu.Lock()\n29: \tdefer l.mu.Unlock()\n30: \tl.errors = append(l.errors, msg)\n31: }\n32: \n33: type mockStore struct {\n34: \tsessions []*types.SandboxInfo\n35: \tmu       sync.RWMutex\n36: }\n37: \n38: func (s *mockStore) StoreSandbox(_ context.Context, sandbox *types.SandboxInfo) error {\n39: \ts.mu.Lock()\n40: \tdefer s.mu.Unlock()\n41: \ts.sessions = append(s.sessions, sandbox)\n42: \treturn nil\n43: }\n44: \n45: func (s *mockStore) GetSandboxBySessionID(_ context.Context, sessionID string) (*types.SandboxInfo, error) {\n46: \ts.mu.RLock()\n47: \tdefer s.mu.RUnlock()\n48: \tfor _, sb := range s.sessions {\n49: \t\tif sb.SessionID == sessionID {\n50: \t\t\treturn sb, nil\n51: \t\t}\n52: \t}\n53: \treturn nil, &workloadmanager.NotFoundError{Resource: \"sandbox\", Name: sessionID}\n54: }\n55: \n56: func (s *mockStore) UpdateSandbox(_ context.Context, sandbox *types.SandboxInfo) error {\n57: \ts.mu.Lock()\n58: \tdefer s.mu.Unlock()\n59: \tfor i, sb := range s.sessions {\n60: \t\tif sb.SessionID == sandbox.SessionID {\n61: \t\t\ts.sessions[i] = sandbox\n62: \t\t\treturn nil\n63: \t\t}\n64: \t}\n65: \treturn &workloadmanager.NotFoundError{Resource: \"sandbox\", Name: sandbox.SessionID}\n66: }\n67: \n68: func (s *mockStore) DeleteSandboxBySessionID(_ context.Context, sessionID string) error {\n69: \ts.mu.Lock()\n70: \tdefer s.mu.Unlock()\n71: \tfor i, sb := range s.sessions {\n72: \t\tif sb.SessionID == sessionID {\n73: \t\t\ts.sessions = append(s.sessions[:i], s.sessions[i+1:]...)\n74: \t\t\treturn nil\n75: \t\t}\n76: \t}\n77: \treturn nil\n78: }\n79: \n80: func (s *mockStore) ListSandboxes(_ context.Context) ([]*types.SandboxInfo, error) {\n81: \ts.mu.RLock()\n82: \tdefer s.mu.RUnlock()\n83: \tresult := make([]*types.SandboxInfo, len(s.sessions))\n84: \tcopy(result, s.sessions)\n85: \treturn result, nil\n86: }\n87: \n88: func (s *mockStore) ListExpiredSandboxes(_ context.Context, _ time.Time, _ int) ([]*types.SandboxInfo, error) {\n89: \treturn nil, nil\n90: }\n91: \n92: func (s *mockStore) ListInactiveSandboxes(_ context.Context, _ time.Time, _ int) ([]*types.SandboxInfo, error) {\n93: \treturn nil, nil\n94: }\n95: \n96: func (s *mockStore) setSessions(sessions []*types.SandboxInfo) {\n97: \ts.mu.Lock()\n98: \tdefer s.mu.Unlock()\n99: \ts.sessions = sessions\n100: }\n101: \n102: type mockLifecycleManager struct {\n103: \tdeleteCalls []string\n104: \tdeleteErr   error\n105: \tmu          sync.Mutex\n106: }\n107: \n108: func (m *mockLifecycleManager) DeleteSandbox(_ context.Context, sessionID string) error {\n109: \tm.mu.Lock()\n110: \tdefer m.mu.Unlock()\n111: \tm.deleteCalls = append(m.deleteCalls, sessionID)\n112: \tif m.deleteErr != nil {\n113: \t\treturn m.deleteErr\n114: \t}\n115: \treturn nil\n116: }\n117: \n118: func (m *mockLifecycleManager) getDeleteCalls() []string {\n119: \tm.mu.Lock()\n120: \tdefer m.mu.Unlock()\n121: \treturn m.deleteCalls\n122: }\n123: \n124: func (m *mockLifecycleManager) resetDeleteCalls() {\n125: \tm.mu.Lock()\n126: \tdefer m.mu.Unlock()\n127: \tm.deleteCalls = nil\n128: }\n129: \n130: func TestNewIdleCleanupController(t *testing.T) {\n131: \tlogger := &mockLogger{}\n132: \tstore := &mockStore{}\n133: \tlifecycleManager := &mockLifecycleManager{}\n134: \n135: \tctrl := NewIdleCleanupController(store, lifecycleManager, 2*time.Minute, 10*time.Minute, logger)\n136: \n137: \tassert.NotNil(t, ctrl)\n138: \tassert.Equal(t, 2*time.Minute, ctrl.interval)\n139: \tassert.Equal(t, 10*time.Minute, ctrl.GetIdleTimeout())\n140: \tassert.Equal(t, store, ctrl.store)\n141: \tassert.Equal(t, lifecycleManager, ctrl.lifecycleManager)\n142: \tassert.Equal(t, logger, ctrl.logger)\n143: }\n144: \n145: func TestNewIdleCleanupController_Defaults(t *testing.T) {\n146: \tlogger := &mockLogger{}\n147: \tstore := &mockStore{}\n148: \tlifecycleManager := &mockLifecycleManager{}\n149: \n150: \tctrl := NewIdleCleanupController(store, lifecycleManager, 0, 0, logger)\n151: \n152: \tassert.NotNil(t, ctrl)\n153: \tassert.Equal(t, DefaultIdleCleanupInterval, ctrl.interval)\n154: \tassert.Equal(t, DefaultIdleTimeout, ctrl.GetIdleTimeout())\n155: }\n156: \n157: func TestIdleCleanupController_StartStop(t *testing.T) {\n158: \tlogger := &mockLogger{}\n159: \tstore := &mockStore{}\n160: \tlifecycleManager := &mockLifecycleManager{}\n161: \n162: \tctrl := NewIdleCleanupController(store, lifecycleManager, 100*time.Millisecond, 15*time.Minute, logger)\n163: \n164: \tctrl.Start()\n165: \n166: \ttime.Sleep(50 * time.Millisecond)\n167: \n168: \tctrl.Stop()\n169: \n170: \tassert.Contains(t, logger.infos, \"idle cleanup controller stopped\")\n171: }\n172: \n173: func TestIdleCleanupController_runOnce_IdleSession(t *testing.T) {\n174: \tlogger := &mockLogger{}\n175: \tstore := &mockStore{}\n176: \n177: \tnow := time.Now()\n178: \toldActivity := now.Add(-30 * time.Minute)\n179: \n180: \tsessions := []*types.SandboxInfo{\n181: \t\t{\n182: \t\t\tSessionID:    \"idle-session-1\",\n183: \t\t\tSandboxName:  \"sandbox-1\",\n184: \t\t\tLastActivity: oldActivity,\n185: \t\t},\n186: \t\t{\n187: \t\t\tSessionID:    \"active-session-1\",\n188: \t\t\tSandboxName:  \"sandbox-2\",\n189: \t\t\tLastActivity: now.Add(-5 * time.Minute),\n190: \t\t},\n191: \t\t{\n192: \t\t\tSessionID:    \"zero-activity-session\",\n193: \t\t\tSandboxName:  \"sandbox-3\",\n194: \t\t\tLastActivity: time.Time{},\n195: \t\t},\n196: \t}\n197: \tstore.setSessions(sessions)\n198: \n199: \tmockLifecycle := &mockLifecycleManager{}\n200: \n201: \tctrl := &IdleCleanupController{\n202: \t\tstore:            store,\n203: \t\tlifecycleManager: mockLifecycle,\n204: \t\tinterval:         1 * time.Minute,\n205: \t\tidleTimeout:      15 * time.Minute,\n206: \t\tlogger:           logger,\n207: \t}\n208: \n209: \tctrl.runOnce(context.Background())\n210: \n211: \tassert.Len(t, mockLifecycle.getDeleteCalls(), 1)\n212: \tassert.Contains(t, mockLifecycle.getDeleteCalls(), \"idle-session-1\")\n213: \tassert.NotContains(t, mockLifecycle.getDeleteCalls(), \"active-session-1\")\n214: \tassert.NotContains(t, mockLifecycle.getDeleteCalls(), \"zero-activity-session\")\n215: }\n216: \n217: func TestIdleCleanupController_runOnce_ZeroActivity(t *testing.T) {\n218: \tlogger := &mockLogger{}\n219: \tstore := &mockStore{}\n220: \n221: \tsessions := []*types.SandboxInfo{\n222: \t\t{\n223: \t\t\tSessionID:    \"zero-activity-session\",\n224: \t\t\tSandboxName:  \"sandbox-1\",\n225: \t\t\tLastActivity: time.Time{},\n226: \t\t},\n227: \t}\n228: \tstore.setSessions(sessions)\n229: \n230: \tmockLifecycle := &mockLifecycleManager{}\n231: \n232: \tctrl := &IdleCleanupController{\n233: \t\tstore:            store,\n234: \t\tlifecycleManager: mockLifecycle,\n235: \t\tinterval:         1 * time.Minute,\n236: \t\tidleTimeout:      15 * time.Minute,\n237: \t\tlogger:           logger,\n238: \t}\n239: \n240: \tctrl.runOnce(context.Background())\n241: \n242: \tassert.Empty(t, mockLifecycle.getDeleteCalls())\n243: }\n244: \n245: func TestIdleCleanupController_runOnce_ContinueOnError(t *testing.T) {\n246: \tlogger := &mockLogger{}\n247: \tstore := &mockStore{}\n248: \n249: \tnow := time.Now()\n250: \toldActivity := now.Add(-30 * time.Minute)\n251: \n252: \tsessions := []*types.SandboxInfo{\n253: \t\t{\n254: \t\t\tSessionID:    \"idle-session-1\",\n255: \t\t\tSandboxName:  \"sandbox-1\",\n256: \t\t\tLastActivity: oldActivity,\n257: \t\t},\n258: \t\t{\n259: \t\t\tSessionID:    \"idle-session-2\",\n260: \t\t\tSandboxName:  \"sandbox-2\",\n261: \t\t\tLastActivity: oldActivity,\n262: \t\t},\n263: \t}\n264: \tstore.setSessions(sessions)\n265: \n266: \tmockLifecycle := &mockLifecycleManager{}\n267: \tmockLifecycle.deleteErr = &workloadmanager.InternalError{Err: context.DeadlineExceeded}\n268: \n269: \tctrl := &IdleCleanupController{\n270: \t\tstore:            store,\n271: \t\tlifecycleManager: mockLifecycle,\n272: \t\tinterval:         1 * time.Minute,\n273: \t\tidleTimeout:      15 * time.Minute,\n274: \t\tlogger:           logger,\n275: \t}\n276: \n277: \tctrl.runOnce(context.Background())\n278: \n279: \tassert.Len(t, mockLifecycle.getDeleteCalls(), 2)\n280: \tassert.Len(t, logger.errors, 2)\n281: }\n282: \n283: func TestIdleCleanupController_runOnce_NotFoundIgnored(t *testing.T) {\n284: \tlogger := &mockLogger{}\n285: \tstore := &mockStore{}\n286: \n287: \tnow := time.Now()\n288: \toldActivity := now.Add(-30 * time.Minute)\n289: \n290: \tsessions := []*types.SandboxInfo{\n291: \t\t{\n292: \t\t\tSessionID:    \"idle-session-1\",\n293: \t\t\tSandboxName:  \"sandbox-1\",\n294: \t\t\tLastActivity: oldActivity,\n295: \t\t},\n296: \t}\n297: \tstore.setSessions(sessions)\n298: \n299: \tmockLifecycle := &mockLifecycleManager{}\n300: \tmockLifecycle.deleteErr = &workloadmanager.NotFoundError{Resource: \"sandbox\", Name: \"idle-session-1\"}\n301: \n302: \tctrl := &IdleCleanupController{\n303: \t\tstore:            store,\n304: \t\tlifecycleManager: mockLifecycle,\n305: \t\tinterval:         1 * time.Minute,\n306: \t\tidleTimeout:      15 * time.Minute,\n307: \t\tlogger:           logger,\n308: \t}\n309: \n310: \tctrl.runOnce(context.Background())\n311: \n312: \tassert.Len(t, mockLifecycle.getDeleteCalls(), 1)\n313: \tassert.Empty(t, logger.errors)\n314: }\n315: \n316: func TestIdleCleanupController_SetIdleTimeout(t *testing.T) {\n317: \tlogger := &mockLogger{}\n318: \tstore := &mockStore{}\n319: \tlifecycleManager := &mockLifecycleManager{}\n320: \n321: \tctrl := NewIdleCleanupController(store, lifecycleManager, 1*time.Minute, 15*time.Minute, logger)\n322: \n323: \tctrl.SetIdleTimeout(30 * time.Minute)\n324: \n325: \tassert.Equal(t, 30*time.Minute, ctrl.GetIdleTimeout())\n326: }\n327: \n328: func TestIdleCleanupController_GetIdleTimeout(t *testing.T) {\n329: \tlogger := &mockLogger{}\n330: \tstore := &mockStore{}\n331: \tlifecycleManager := &mockLifecycleManager{}\n332: \n333: \tctrl := NewIdleCleanupController(store, lifecycleManager, 1*time.Minute, 20*time.Minute, logger)\n334: \n335: \tassert.Equal(t, 20*time.Minute, ctrl.GetIdleTimeout())\n336: }\n337: \n338: func TestIdleCleanupController_GetStats(t *testing.T) {\n339: \tlogger := &mockLogger{}\n340: \tstore := &mockStore{}\n341: \tlifecycleManager := &mockLifecycleManager{}\n342: \n343: \tctrl := NewIdleCleanupController(store, lifecycleManager, 2*time.Minute, 15*time.Minute, logger)\n344: \n345: \tstats := ctrl.GetStats()\n346: \n347: \tassert.Equal(t, 2*time.Minute, stats.Interval)\n348: \tassert.Equal(t, 15*time.Minute, stats.IdleTimeout)\n349: }\n350: \n351: func TestIdleCleanupController_GetStats_AfterCleanup(t *testing.T) {\n352: \tlogger := &mockLogger{}\n353: \tstore := &mockStore{}\n354: \n355: \tsessions := []*types.SandboxInfo{\n356: \t\t{\n357: \t\t\tSessionID:    \"active-session\",\n358: \t\t\tSandboxName:  \"sandbox-1\",\n359: \t\t\tLastActivity: time.Now().Add(-5 * time.Minute),\n360: \t\t},\n361: \t}\n362: \tstore.setSessions(sessions)\n363: \n364: \tmockLifecycle := &mockLifecycleManager{}\n365: \n366: \tctrl := &IdleCleanupController{\n367: \t\tstore:            store,\n368: \t\tlifecycleManager: mockLifecycle,\n369: \t\tinterval:         1 * time.Minute,\n370: \t\tidleTimeout:      15 * time.Minute,\n371: \t\tlogger:           logger,\n372: \t}\n373: \n374: \tctrl.runOnce(context.Background())\n375: \n376: \tstats := ctrl.GetStats()\n377: \tassert.False(t, stats.LastCleanupTime.IsZero())\n378: }\n379: \n380: func TestIdleCleanupController_ConcurrentAccess(t *testing.T) {\n381: \tlogger := &mockLogger{}\n382: \tstore := &mockStore{}\n383: \tlifecycleManager := &mockLifecycleManager{}\n384: \n385: \tctrl := NewIdleCleanupController(store, lifecycleManager, 1*time.Minute, 15*time.Minute, logger)\n386: \n387: \tvar wg sync.WaitGroup\n388: \tfor i := 0; i < 100; i++ {\n389: \t\twg.Add(2)\n390: \t\tgo func(i int) {\n391: \t\t\tdefer wg.Done()\n392: \t\t\tctrl.SetIdleTimeout(time.Duration(i) * time.Minute)\n393: \t\t}(i)\n394: \t\tgo func() {\n395: \t\t\tdefer wg.Done()\n396: \t\t\t_ = ctrl.GetIdleTimeout()\n397: \t\t}()\n398: \t}\n399: \twg.Wait()\n400: \n401: \t_ = ctrl.GetStats()\n402: }\n403: \n404: func TestIdleCleanupController_ConcurrentAccess_WithRunOnce(t *testing.T) {\n405: \tlogger := &mockLogger{}\n406: \tstore := &mockStore{}\n407: \n408: \tnow := time.Now()\n409: \tsessions := []*types.SandboxInfo{\n410: \t\t{\n411: \t\t\tSessionID:    \"idle-session\",\n412: \t\t\tSandboxName:  \"sandbox-1\",\n413: \t\t\tLastActivity: now.Add(-30 * time.Minute),\n414: \t\t},\n415: \t}\n416: \tstore.setSessions(sessions)\n417: \n418: \tmockLifecycle := &mockLifecycleManager{}\n419: \n420: \tctrl := &IdleCleanupController{\n421: \t\tstore:            store,\n422: \t\tlifecycleManager: mockLifecycle,\n423: \t\tinterval:         1 * time.Minute,\n424: \t\tidleTimeout:      15 * time.Minute,\n425: \t\tlogger:           logger,\n426: \t}\n427: \n428: \tvar wg sync.WaitGroup\n429: \tfor i := 0; i < 50; i++ {\n430: \t\twg.Add(3)\n431: \t\tgo func(i int) {\n432: \t\t\tdefer wg.Done()\n433: \t\t\tctrl.SetIdleTimeout(time.Duration(i) * time.Minute)\n434: \t\t}(i)\n435: \t\tgo func() {\n436: \t\t\tdefer wg.Done()\n437: \t\t\t_ = ctrl.GetIdleTimeout()\n438: \t\t}()\n439: \t\tgo func() {\n440: \t\t\tdefer wg.Done()\n441: \t\t\t_ = ctrl.GetStats()\n442: \t\t}()\n443: \t}\n444: \twg.Wait()\n445: \n446: \tctrl.runOnce(context.Background())\n447: }\n448: \n449: func TestIdleCleanupController_runOnce_ListSessionsError(t *testing.T) {\n450: \tlogger := &mockLogger{}\n451: \terrorStore := &errorMockStore{listErr: context.DeadlineExceeded}\n452: \tlifecycleManager := &mockLifecycleManager{}\n453: \n454: \tctrl := &IdleCleanupController{\n455: \t\tstore:            errorStore,\n456: \t\tlifecycleManager: lifecycleManager,\n457: \t\tinterval:         1 * time.Minute,\n458: \t\tidleTimeout:      15 * time.Minute,\n459: \t\tlogger:           logger,\n460: \t}\n461: \n462: \tctrl.runOnce(context.Background())\n463: \n464: \tassert.Len(t, logger.errors, 1)\n465: \tassert.Contains(t, logger.errors[0], \"failed to list sessions\")\n466: }\n467: \n468: type errorMockStore struct {\n469: \tlistErr error\n470: }\n471: \n472: func (s *errorMockStore) StoreSandbox(_ context.Context, _ *types.SandboxInfo) error {\n473: \treturn nil\n474: }\n475: \n476: func (s *errorMockStore) GetSandboxBySessionID(_ context.Context, _ string) (*types.SandboxInfo, error) {\n477: \treturn nil, nil\n478: }\n479: \n480: func (s *errorMockStore) UpdateSandbox(_ context.Context, _ *types.SandboxInfo) error {\n481: \treturn nil\n482: }\n483: \n484: func (s *errorMockStore) DeleteSandboxBySessionID(_ context.Context, _ string) error {\n485: \treturn nil\n486: }\n487: \n488: func (s *errorMockStore) ListSandboxes(_ context.Context) ([]*types.SandboxInfo, error) {\n489: \treturn nil, s.listErr\n490: }\n491: \n492: func (s *errorMockStore) ListExpiredSandboxes(_ context.Context, _ time.Time, _ int) ([]*types.SandboxInfo, error) {\n493: \treturn nil, nil\n494: }\n495: \n496: func (s *errorMockStore) ListInactiveSandboxes(_ context.Context, _ time.Time, _ int) ([]*types.SandboxInfo, error) {\n497: \treturn nil, nil\n498: }\n499: \n500: func TestIdleCleanupController_StoreIntegration(t *testing.T) {\n501: \tstore := workloadmanager.NewMemoryStore()\n502: \n503: \tsession := &types.SandboxInfo{\n504: \t\tSessionID:        \"test-session\",\n505: \t\tSandboxID:        \"test-sandbox-id\",\n506: \t\tSandboxName:      \"test-sandbox\",\n507: \t\tSandboxNamespace: \"default\",\n508: \t\tLastActivity:     time.Now().Add(-30 * time.Minute),\n509: \t\tCreatedAt:        time.Now(),\n510: \t\tExpiresAt:        time.Now().Add(1 * time.Hour),\n511: \t}\n512: \trequire.NoError(t, store.StoreSandbox(context.Background(), session))\n513: \n514: \tsessions, err := store.ListSandboxes(context.Background())\n515: \trequire.NoError(t, err)\n516: \trequire.Len(t, sessions, 1)\n517: \tassert.Equal(t, \"test-session\", sessions[0].SessionID)\n518: }\n519: \n520: func TestIdleCleanupController_LifecycleIntegration(t *testing.T) {\n521: \tlogger := &mockLogger{}\n522: \tstore := workloadmanager.NewMemoryStore()\n523: \tlifecycleManager := workloadmanager.NewSandboxLifecycleManager(nil, store, workloadmanager.DefaultLifecycleConfig(), logger)\n524: \n525: \tctrl := NewIdleCleanupController(store, lifecycleManager, 1*time.Minute, 15*time.Minute, logger)\n526: \n527: \tassert.NotNil(t, ctrl.lifecycleManager)\n528: \tassert.Equal(t, store, ctrl.store)\n529: }\n530: \n531: func TestDefaultConstants(t *testing.T) {\n532: \tassert.Equal(t, 1*time.Minute, DefaultIdleCleanupInterval)\n533: \tassert.Equal(t, 15*time.Minute, DefaultIdleTimeout)\n534: }\n535: \n536: func TestIdleCleanupStats_Fields(t *testing.T) {\n537: \tstats := IdleCleanupStats{\n538: \t\tInterval:        2 * time.Minute,\n539: \t\tIdleTimeout:     15 * time.Minute,\n540: \t\tLastCleanupTime: time.Now(),\n541: \t}\n542: \n543: \tassert.Equal(t, 2*time.Minute, stats.Interval)\n544: \tassert.Equal(t, 15*time.Minute, stats.IdleTimeout)\n545: \tassert.False(t, stats.LastCleanupTime.IsZero())\n546: }\n547: \n548: func TestIdleCleanupController_MultipleIdleSessions(t *testing.T) {\n549: \tlogger := &mockLogger{}\n550: \tstore := &mockStore{}\n551: \n552: \tnow := time.Now()\n553: \toldActivity := now.Add(-30 * time.Minute)\n554: \n555: \tsessions := []*types.SandboxInfo{\n556: \t\t{SessionID: \"idle-1\", LastActivity: oldActivity},\n557: \t\t{SessionID: \"idle-2\", LastActivity: oldActivity},\n558: \t\t{SessionID: \"idle-3\", LastActivity: oldActivity},\n559: \t\t{SessionID: \"active-1\", LastActivity: now.Add(-5 * time.Minute)},\n560: \t\t{SessionID: \"active-2\", LastActivity: now.Add(-10 * time.Minute)},\n561: \t}\n562: \tstore.setSessions(sessions)\n563: \n564: \tmockLifecycle := &mockLifecycleManager{}\n565: \n566: \tctrl := &IdleCleanupController{\n567: \t\tstore:            store,\n568: \t\tlifecycleManager: mockLifecycle,\n569: \t\tinterval:         1 * time.Minute,\n570: \t\tidleTimeout:      15 * time.Minute,\n571: \t\tlogger:           logger,\n572: \t}\n573: \n574: \tctrl.runOnce(context.Background())\n575: \n576: \tdeleteCalls := mockLifecycle.getDeleteCalls()\n577: \tassert.Len(t, deleteCalls, 3)\n578: \tassert.Contains(t, deleteCalls, \"idle-1\")\n579: \tassert.Contains(t, deleteCalls, \"idle-2\")\n580: \tassert.Contains(t, deleteCalls, \"idle-3\")\n581: }\n582: \n583: func TestIdleCleanupController_ExactThreshold(t *testing.T) {\n584: \tlogger := &mockLogger{}\n585: \tstore := &mockStore{}\n586: \n587: \tnow := time.Now()\n588: \tnotIdle := now.Add(-15*time.Minute + 1*time.Second)\n589: \tjustIdle := now.Add(-15*time.Minute - 1*time.Second)\n590: \n591: \tsessions := []*types.SandboxInfo{\n592: \t\t{SessionID: \"not-idle\", LastActivity: notIdle},\n593: \t\t{SessionID: \"just-idle\", LastActivity: justIdle},\n594: \t}\n595: \tstore.setSessions(sessions)\n596: \n597: \tmockLifecycle := &mockLifecycleManager{}\n598: \n599: \tctrl := &IdleCleanupController{\n600: \t\tstore:            store,\n601: \t\tlifecycleManager: mockLifecycle,\n602: \t\tinterval:         1 * time.Minute,\n603: \t\tidleTimeout:      15 * time.Minute,\n604: \t\tlogger:           logger,\n605: \t}\n606: \n607: \tctrl.runOnce(context.Background())\n608: \n609: \tdeleteCalls := mockLifecycle.getDeleteCalls()\n610: \tassert.Len(t, deleteCalls, 1)\n611: \tassert.Contains(t, deleteCalls, \"just-idle\")\n612: \tassert.NotContains(t, deleteCalls, \"not-idle\")\n613: }\n614: \n615: func TestIdleCleanupController_UpdateStatsAfterSetIdleTimeout(t *testing.T) {\n616: \tlogger := &mockLogger{}\n617: \tstore := &mockStore{}\n618: \tlifecycleManager := &mockLifecycleManager{}\n619: \n620: \tctrl := NewIdleCleanupController(store, lifecycleManager, 1*time.Minute, 15*time.Minute, logger)\n621: \n622: \tctrl.SetIdleTimeout(30 * time.Minute)\n623: \n624: \tstats := ctrl.GetStats()\n625: \tassert.Equal(t, 30*time.Minute, stats.IdleTimeout)\n626: }\n627: \n628: func TestIdleCleanupController_EmptyStore(t *testing.T) {\n629: \tlogger := &mockLogger{}\n630: \tstore := &mockStore{}\n631: \tstore.setSessions(nil)\n632: \n633: \tmockLifecycle := &mockLifecycleManager{}\n634: \n635: \tctrl := &IdleCleanupController{\n636: \t\tstore:            store,\n637: \t\tlifecycleManager: mockLifecycle,\n638: \t\tinterval:         1 * time.Minute,\n639: \t\tidleTimeout:      15 * time.Minute,\n640: \t\tlogger:           logger,\n641: \t}\n642: \n643: \tctrl.runOnce(context.Background())\n644: \n645: \tassert.Empty(t, mockLifecycle.getDeleteCalls())\n646: \tassert.Contains(t, logger.infos, \"idle cleanup cycle completed\")\n647: }\n648: \n649: func TestIdleCleanupController_AllSessionsIdle(t *testing.T) {\n650: \tlogger := &mockLogger{}\n651: \tstore := &mockStore{}\n652: \n653: \tnow := time.Now()\n654: \toldActivity := now.Add(-30 * time.Minute)\n655: \n656: \tsessions := []*types.SandboxInfo{\n657: \t\t{SessionID: \"idle-1\", LastActivity: oldActivity},\n658: \t\t{SessionID: \"idle-2\", LastActivity: oldActivity},\n659: \t\t{SessionID: \"idle-3\", LastActivity: oldActivity},\n660: \t}\n661: \tstore.setSessions(sessions)\n662: \n663: \tmockLifecycle := &mockLifecycleManager{}\n664: \n665: \tctrl := &IdleCleanupController{\n666: \t\tstore:            store,\n667: \t\tlifecycleManager: mockLifecycle,\n668: \t\tinterval:         1 * time.Minute,\n669: \t\tidleTimeout:      15 * time.Minute,\n670: \t\tlogger:           logger,\n671: \t}\n672: \n673: \tctrl.runOnce(context.Background())\n674: \n675: \tdeleteCalls := mockLifecycle.getDeleteCalls()\n676: \tassert.Len(t, deleteCalls, 3)\n677: }\n678: \n679: func TestIdleCleanupController_AllSessionsActive(t *testing.T) {\n680: \tlogger := &mockLogger{}\n681: \tstore := &mockStore{}\n682: \n683: \tnow := time.Now()\n684: \n685: \tsessions := []*types.SandboxInfo{\n686: \t\t{SessionID: \"active-1\", LastActivity: now.Add(-5 * time.Minute)},\n687: \t\t{SessionID: \"active-2\", LastActivity: now.Add(-10 * time.Minute)},\n688: \t\t{SessionID: \"active-3\", LastActivity: now.Add(-14 * time.Minute)},\n689: \t}\n690: \tstore.setSessions(sessions)\n691: \n692: \tmockLifecycle := &mockLifecycleManager{}\n693: \n694: \tctrl := &IdleCleanupController{\n695: \t\tstore:            store,\n696: \t\tlifecycleManager: mockLifecycle,\n697: \t\tinterval:         1 * time.Minute,\n698: \t\tidleTimeout:      15 * time.Minute,\n699: \t\tlogger:           logger,\n700: \t}\n701: \n702: \tctrl.runOnce(context.Background())\n703: \n704: \tassert.Empty(t, mockLifecycle.getDeleteCalls())\n705: }\n\n(End of file - total 705 lines)\n</content>","metadata":{"preview":"package agentd\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\ntype mockLogger struct {\n\tinfos  []string\n\terrors []string\n\tmu     sync.Mutex\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/agentd/idle_cleanup_test.go","time":{"start":1775866084690,"end":1775866084712}}}}
