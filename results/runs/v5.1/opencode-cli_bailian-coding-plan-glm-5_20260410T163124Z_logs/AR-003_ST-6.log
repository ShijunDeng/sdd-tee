\t\t\t\tt.Errorf(\"expected Ports length %d, got %d\", len(tt.ar.Spec.Ports), len(copy.Spec.Ports))\n110: \t\t\t}\n111: \t\t\tif tt.ar.Spec.SessionTimeout != nil {\n112: \t\t\t\tif copy.Spec.SessionTimeout.Duration != tt.ar.Spec.SessionTimeout.Duration {\n113: \t\t\t\t\tt.Errorf(\"expected SessionTimeout %v, got %v\", tt.ar.Spec.SessionTimeout.Duration, copy.Spec.SessionTimeout.Duration)\n114: \t\t\t\t}\n115: \t\t\t}\n116: \t\t\tif len(copy.Status.Conditions) != len(tt.ar.Status.Conditions) {\n117: \t\t\t\tt.Errorf(\"expected Conditions length %d, got %d\", len(tt.ar.Status.Conditions), len(copy.Status.Conditions))\n118: \t\t\t}\n119: \t\t\tif tt.ar.Spec.Template != nil && tt.ar.Spec.Template.Labels != nil {\n120: \t\t\t\tif copy.Spec.Template.Labels[\"pod-label\"] != tt.ar.Spec.Template.Labels[\"pod-label\"] {\n121: \t\t\t\t\tt.Errorf(\"expected Template Labels to match\")\n122: \t\t\t\t}\n123: \t\t\t\tcopy.Spec.Template.Labels[\"pod-label\"] = \"modified\"\n124: \t\t\t\tif tt.ar.Spec.Template.Labels[\"pod-label\"] == \"modified\" {\n125: \t\t\t\t\tt.Errorf(\"DeepCopy should be deep, modifying copy should not affect original\")\n126: \t\t\t\t}\n127: \t\t\t}\n128: \t\t})\n129: \t}\n130: }\n131: \n132: func TestAgentRuntimeListDeepCopy(t *testing.T) {\n133: \ttests := []struct {\n134: \t\tname string\n135: \t\tarl  *AgentRuntimeList\n136: \t}{\n137: \t\t{\n138: \t\t\tname: \"nil\",\n139: \t\t\tarl:  nil,\n140: \t\t},\n141: \t\t{\n142: \t\t\tname: \"empty\",\n143: \t\t\tarl:  &AgentRuntimeList{},\n144: \t\t},\n145: \t\t{\n146: \t\t\tname: \"full\",\n147: \t\t\tarl: &AgentRuntimeList{\n148: \t\t\t\tTypeMeta: metav1.TypeMeta{\n149: \t\t\t\t\tKind:       AgentRuntimeListKind,\n150: \t\t\t\t\tAPIVersion: GroupVersion.String(),\n151: \t\t\t\t},\n152: \t\t\t\tListMeta: metav1.ListMeta{},\n153: \t\t\t\tItems: []AgentRuntime{\n154: \t\t\t\t\t{\n155: \t\t\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"item1\"},\n156: \t\t\t\t\t},\n157: \t\t\t\t\t{\n158: \t\t\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"item2\"},\n159: \t\t\t\t\t},\n160: \t\t\t\t},\n161: \t\t\t},\n162: \t\t},\n163: \t}\n164: \n165: \tfor _, tt := range tests {\n166: \t\tt.Run(tt.name, func(t *testing.T) {\n167: \t\t\tcopy := tt.arl.DeepCopy()\n168: \t\t\tif tt.arl == nil {\n169: \t\t\t\tif copy != nil {\n170: \t\t\t\t\tt.Errorf(\"expected nil, got non-nil\")\n171: \t\t\t\t}\n172: \t\t\t\treturn\n173: \t\t\t}\n174: \t\t\tif copy == nil {\n175: \t\t\t\tt.Errorf(\"expected non-nil, got nil\")\n176: \t\t\t\treturn\n177: \t\t\t}\n178: \t\t\tif len(copy.Items) != len(tt.arl.Items) {\n179: \t\t\t\tt.Errorf(\"expected Items length %d, got %d\", len(tt.arl.Items), len(copy.Items))\n180: \t\t\t}\n181: \t\t})\n182: \t}\n183: }\n184: \n185: func TestAgentRuntimeDeepCopyObject(t *testing.T) {\n186: \tar := &AgentRuntime{\n187: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test\"},\n188: \t}\n189: \tobj := ar.DeepCopyObject()\n190: \tif obj == nil {\n191: \t\tt.Errorf(\"expected non-nil, got nil\")\n192: \t}\n193: \tif obj.(*AgentRuntime).Name != \"test\" {\n194: \t\tt.Errorf(\"expected Name 'test', got %s\", obj.(*AgentRuntime).Name)\n195: \t}\n196: }\n197: \n198: func TestCodeInterpreterDeepCopy(t *testing.T) {\n199: \ttests := []struct {\n200: \t\tname string\n201: \t\tci   *CodeInterpreter\n202: \t}{\n203: \t\t{\n204: \t\t\tname: \"nil\",\n205: \t\t\tci:   nil,\n206: \t\t},\n207: \t\t{\n208: \t\t\tname: \"empty\",\n209: \t\t\tci:   &CodeInterpreter{},\n210: \t\t},\n211: \t\t{\n212: \t\t\tname: \"full\",\n213: \t\t\tci: &CodeInterpreter{\n214: \t\t\t\tTypeMeta: metav1.TypeMeta{\n215: \t\t\t\t\tKind:       CodeInterpreterKind,\n216: \t\t\t\t\tAPIVersion: GroupVersion.String(),\n217: \t\t\t\t},\n218: \t\t\t\tObjectMeta: metav1.ObjectMeta{\n219: \t\t\t\t\tName:      \"test-codeinterpreter\",\n220: \t\t\t\t\tNamespace: \"default\",\n221: \t\t\t\t},\n222: \t\t\t\tSpec: CodeInterpreterSpec{\n223: \t\t\t\t\tPorts: []TargetPort{\n224: \t\t\t\t\t\t{\n225: \t\t\t\t\t\t\tPort:     8080,\n226: \t\t\t\t\t\t\tProtocol: ProtocolTypeHTTP,\n227: \t\t\t\t\t\t},\n228: \t\t\t\t\t},\n229: \t\t\t\t\tTemplate: &CodeInterpreterSandboxTemplate{\n230: \t\t\t\t\t\tImage:           \"python:latest\",\n231: \t\t\t\t\t\tImagePullPolicy: corev1.PullIfNotPresent,\n232: \t\t\t\t\t\tLabels: map[string]string{\n233: \t\t\t\t\t\t\t\"app\": \"code-interpreter\",\n234: \t\t\t\t\t\t},\n235: \t\t\t\t\t\tAnnotations: map[string]string{\n236: \t\t\t\t\t\t\t\"annotation\": \"value\",\n237: \t\t\t\t\t\t},\n238: \t\t\t\t\t\tRuntimeClassName: ptr(\"runc\"),\n239: \t\t\t\t\t\tCommand:          []string{\"python\"},\n240: \t\t\t\t\t\tArgs:             []string{\"-m\", \"app\"},\n241: \t\t\t\t\t\tEnvironment: []corev1.EnvVar{\n242: \t\t\t\t\t\t\t{Name: \"ENV\", Value: \"test\"},\n243: \t\t\t\t\t\t},\n244: \t\t\t\t\t\tResources: corev1.ResourceRequirements{\n245: \t\t\t\t\t\t\tLimits: corev1.ResourceList{},\n246: \t\t\t\t\t\t},\n247: \t\t\t\t\t},\n248: \t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n249: \t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n250: \t\t\t\t\tWarmPoolSize:       ptrInt32(5),\n251: \t\t\t\t\tAuthMode:           AuthModePicoD,\n252: \t\t\t\t},\n253: \t\t\t\tStatus: CodeInterpreterStatus{\n254: \t\t\t\t\tConditions: []metav1.Condition{\n255: \t\t\t\t\t\t{Type: \"Ready\", Status: metav1.ConditionTrue},\n256: \t\t\t\t\t},\n257: \t\t\t\t\tReady: true,\n258: \t\t\t\t},\n259: \t\t\t},\n260: \t\t},\n261: \t}\n262: \n263: \tfor _, tt := range tests {\n264: \t\tt.Run(tt.name, func(t *testing.T) {\n265: \t\t\tcopy := tt.ci.DeepCopy()\n266: \t\t\tif tt.ci == nil {\n267: \t\t\t\tif copy != nil {\n268: \t\t\t\t\tt.Errorf(\"expected nil, got non-nil\")\n269: \t\t\t\t}\n270: \t\t\t\treturn\n271: \t\t\t}\n272: \t\t\tif copy == nil {\n273: \t\t\t\tt.Errorf(\"expected non-nil, got nil\")\n274: \t\t\t\treturn\n275: \t\t\t}\n276: \t\t\tif copy == tt.ci {\n277: \t\t\t\tt.Errorf(\"expected different pointer, got same pointer\")\n278: \t\t\t}\n279: \t\t\tif copy.Spec.AuthMode != tt.ci.Spec.AuthMode {\n280: \t\t\t\tt.Errorf(\"expected AuthMode %s, got %s\", tt.ci.Spec.AuthMode, copy.Spec.AuthMode)\n281: \t\t\t}\n282: \t\t\tif tt.ci.Spec.WarmPoolSize != nil {\n283: \t\t\t\tif *copy.Spec.WarmPoolSize != *tt.ci.Spec.WarmPoolSize {\n284: \t\t\t\t\tt.Errorf(\"expected WarmPoolSize %d, got %d\", *tt.ci.Spec.WarmPoolSize, *copy.Spec.WarmPoolSize)\n285: \t\t\t\t}\n286: \t\t\t}\n287: \t\t\tif tt.ci.Spec.Template != nil {\n288: \t\t\t\tif copy.Spec.Template.Image != tt.ci.Spec.Template.Image {\n289: \t\t\t\t\tt.Errorf(\"expected Template Image %s, got %s\", tt.ci.Spec.Template.Image, copy.Spec.Template.Image)\n290: \t\t\t\t}\n291: \t\t\t\tif len(copy.Spec.Template.Command) != len(tt.ci.Spec.Template.Command) {\n292: \t\t\t\t\tt.Errorf(\"expected Command length %d, got %d\", len(tt.ci.Spec.Template.Command), len(copy.Spec.Template.Command))\n293: \t\t\t\t}\n294: \t\t\t\tif tt.ci.Spec.Template.Labels != nil {\n295: \t\t\t\t\tcopy.Spec.Template.Labels[\"app\"] = \"modified\"\n296: \t\t\t\t\tif tt.ci.Spec.Template.Labels[\"app\"] == \"modified\" {\n297: \t\t\t\t\t\tt.Errorf(\"DeepCopy should be deep, modifying copy should not affect original\")\n298: \t\t\t\t\t}\n299: \t\t\t\t}\n300: \t\t\t}\n301: \t\t\tif copy.Status.Ready != tt.ci.Status.Ready {\n302: \t\t\t\tt.Errorf(\"expected Ready %v, got %v\", tt.ci.Status.Ready, copy.Status.Ready)\n303: \t\t\t}\n304: \t\t})\n305: \t}\n306: }\n307: \n308: func TestCodeInterpreterListDeepCopy(t *testing.T) {\n309: \tcil := &CodeInterpreterList{\n310: \t\tItems: []CodeInterpreter{\n311: \t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"item1\"}},\n312: \t\t\t{ObjectMeta: metav1.ObjectMeta{Name: \"item2\"}},\n313: \t\t},\n314: \t}\n315: \tcopy := cil.DeepCopy()\n316: \tif len(copy.Items) != len(cil.Items) {\n317: \t\tt.Errorf(\"expected Items length %d, got %d\", len(cil.Items), len(copy.Items))\n318: \t}\n319: }\n320: \n321: func TestCodeInterpreterDeepCopyObject(t *testing.T) {\n322: \tci := &CodeInterpreter{\n323: \t\tObjectMeta: metav1.ObjectMeta{Name: \"test\"},\n324: \t}\n325: \tobj := ci.DeepCopyObject()\n326: \tif obj == nil {\n327: \t\tt.Errorf(\"expected non-nil, got nil\")\n328: \t}\n329: \tif obj.(*CodeInterpreter).Name != \"test\" {\n330: \t\tt.Errorf(\"expected Name 'test', got %s\", obj.(*CodeInterpreter).Name)\n331: \t}\n332: }\n333: \n334: func TestTargetPortDeepCopy(t *testing.T) {\n335: \ttp := &TargetPort{\n336: \t\tPathPrefix: \"/api\",\n337: \t\tName:       \"api\",\n338: \t\tPort:       8080,\n339: \t\tProtocol:   ProtocolTypeHTTP,\n340: \t}\n341: \tcopy := tp.DeepCopy()\n342: \tif copy.PathPrefix != tp.PathPrefix {\n343: \t\tt.Errorf(\"expected PathPrefix %s, got %s\", tp.PathPrefix, copy.PathPrefix)\n344: \t}\n345: \tif copy.Port != tp.Port {\n346: \t\tt.Errorf(\"expected Port %d, got %d\", tp.Port, copy.Port)\n347: \t}\n348: }\n349: \n350: func TestSandboxTemplateDeepCopy(t *testing.T) {\n351: \tst := &SandboxTemplate{\n352: \t\tLabels:      map[string]string{\"label\": \"value\"},\n353: \t\tAnnotations: map[string]string{\"annotation\": \"value\"},\n354: \t\tSpec: corev1.PodSpec{\n355: \t\t\tContainers: []corev1.Container{{Name: \"container\"}},\n356: \t\t},\n357: \t}\n358: \tcopy := st.DeepCopy()\n359: \tcopy.Labels[\"label\"] = \"modified\"\n360: \tif st.Labels[\"label\"] == \"modified\" {\n361: \t\tt.Errorf(\"DeepCopy should be deep, modifying copy should not affect original\")\n362: \t}\n363: }\n364: \n365: func TestCodeInterpreterSandboxTemplateDeepCopy(t *testing.T) {\n366: \tcist := &CodeInterpreterSandboxTemplate{\n367: \t\tLabels:           map[string]string{\"label\": \"value\"},\n368: \t\tAnnotations:      map[string]string{\"annotation\": \"value\"},\n369: \t\tRuntimeClassName: ptr(\"runc\"),\n370: \t\tImage:            \"python:latest\",\n371: \t\tImagePullPolicy:  corev1.PullIfNotPresent,\n372: \t\tImagePullSecrets: []corev1.LocalObjectReference{{Name: \"secret\"}},\n373: \t\tEnvironment:      []corev1.EnvVar{{Name: \"ENV\", Value: \"val\"}},\n374: \t\tCommand:          []string{\"cmd\"},\n375: \t\tArgs:             []string{\"arg\"},\n376: \t\tResources:        corev1.ResourceRequirements{},\n377: \t}\n378: \tcopy := cist.DeepCopy()\n379: \tif copy.Image != cist.Image {\n380: \t\tt.Errorf(\"expected Image %s, got %s\", cist.Image, copy.Image)\n381: \t}\n382: \tcopy.Labels[\"label\"] = \"modified\"\n383: \tif cist.Labels[\"label\"] == \"modified\" {\n384: \t\tt.Errorf(\"DeepCopy should be deep\")\n385: \t}\n386: \t*copy.RuntimeClassName = \"modified\"\n387: \tif *cist.RuntimeClassName == \"modified\" {\n388: \t\tt.Errorf(\"DeepCopy should be deep for RuntimeClassName\")\n389: \t}\n390: }\n391: \n392: func TestAuthModeTypeConstants(t *testing.T) {\n393: \tif AuthModePicoD != \"picod\" {\n394: \t\tt.Errorf(\"expected AuthModePicoD to be 'picod', got '%s'\", AuthModePicoD)\n395: \t}\n396: \tif AuthModeNone != \"none\" {\n397: \t\tt.Errorf(\"expected AuthModeNone to be 'none', got '%s'\", AuthModeNone)\n398: \t}\n399: }\n400: \n401: func TestProtocolTypeConstants(t *testing.T) {\n402: \tif ProtocolTypeHTTP != \"HTTP\" {\n403: \t\tt.Errorf(\"expected ProtocolTypeHTTP to be 'HTTP', got '%s'\", ProtocolTypeHTTP)\n404: \t}\n405: \tif ProtocolTypeHTTPS != \"HTTPS\" {\n406: \t\tt.Errorf(\"expected ProtocolTypeHTTPS to be 'HTTPS', got '%s'\", ProtocolTypeHTTPS)\n407: \t}\n408: }\n409: \n410: func TestJSONSerialization(t *testing.T) {\n411: \ttests := []struct {\n412: \t\tname     string\n413: \t\tobj      runtime.Object\n414: \t\tjsonTags []string\n415: \t}{\n416: \t\t{\n417: \t\t\tname: \"AgentRuntime\",\n418: \t\t\tobj: &AgentRuntime{\n419: \t\t\t\tSpec: AgentRuntimeSpec{\n420: \t\t\t\t\tPorts:              []TargetPort{{Port: 8080}},\n421: \t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n422: \t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n423: \t\t\t\t},\n424: \t\t\t},\n425: \t\t\tjsonTags: []string{\"targetPort\", \"podTemplate\", \"sessionTimeout\", \"maxSessionDuration\"},\n426: \t\t},\n427: \t\t{\n428: \t\t\tname: \"CodeInterpreter\",\n429: \t\t\tobj: &CodeInterpreter{\n430: \t\t\t\tSpec: CodeInterpreterSpec{\n431: \t\t\t\t\tPorts:              []TargetPort{{Port: 8080}},\n432: \t\t\t\t\tSessionTimeout:     &metav1.Duration{Duration: 15 * time.Minute},\n433: \t\t\t\t\tMaxSessionDuration: &metav1.Duration{Duration: 8 * time.Hour},\n434: \t\t\t\t\tWarmPoolSize:       ptrInt32(5),\n435: \t\t\t\t\tAuthMode:           AuthModePicoD,\n436: \t\t\t\t},\n437: \t\t\t},\n438: \t\t\tjsonTags: []string{\"ports\", \"template\", \"sessionTimeout\", \"maxSessionDuration\", \"warmPoolSize\", \"authMode\"},\n439: \t\t},\n440: \t\t{\n441: \t\t\tname:     \"TargetPort\",\n442: \t\t\tobj:      nil,\n443: \t\t\tjsonTags: []string{\"pathPrefix\", \"name\", \"port\", \"protocol\"},\n444: \t\t},\n445: \t}\n446: \n447: \tfor _, tt := range tests {\n448: \t\tt.Run(tt.name, func(t *testing.T) {\n449: \t\t\tif tt.obj != nil {\n450: \t\t\t\tdata, err := json.Marshal(tt.obj)\n451: \t\t\t\tif err != nil {\n452: \t\t\t\t\tt.Errorf(\"failed to marshal: %v\", err)\n453: \t\t\t\t}\n454: \t\t\t\tfor _, tag := range tt.jsonTags {\n455: \t\t\t\t\tif !contains(string(data), tag) {\n456: \t\t\t\t\t\tt.Errorf(\"expected JSON tag '%s' in output\", tag)\n457: \t\t\t\t\t}\n458: \t\t\t\t}\n459: \t\t\t\tcopy := tt.obj.DeepCopyObject()\n460: \t\t\t\terr = json.Unmarshal(data, copy)\n461: \t\t\t\tif err != nil {\n462: \t\t\t\t\tt.Errorf(\"failed to unmarshal: %v\", err)\n463: \t\t\t\t}\n464: \t\t\t}\n465: \t\t})\n466: \t}\n467: }\n468: \n469: func TestTargetPortJSONTags(t *testing.T) {\n470: \ttp := TargetPort{\n471: \t\tPathPrefix: \"/api\",\n472: \t\tName:       \"api\",\n473: \t\tPort:       8080,\n474: \t\tProtocol:   ProtocolTypeHTTP,\n475: \t}\n476: \tdata, err := json.Marshal(tp)\n477: \tif err != nil {\n478: \t\tt.Errorf(\"failed to marshal TargetPort: %v\", err)\n479: \t}\n480: \texpected := `{\"pathPrefix\":\"/api\",\"name\":\"api\",\"port\":8080,\"protocol\":\"HTTP\"}`\n481: \tif string(data) != expected {\n482: \t\tt.Errorf(\"expected JSON '%s', got '%s'\", expected, string(data))\n483: \t}\n484: \tvar unmarshaled TargetPort\n485: \terr = json.Unmarshal(data, &unmarshaled)\n486: \tif err != nil {\n487: \t\tt.Errorf(\"failed to unmarshal TargetPort: %v\", err)\n488: \t}\n489: \tif unmarshaled.PathPrefix != tp.PathPrefix {\n490: \t\tt.Errorf(\"expected PathPrefix '%s', got '%s'\", tp.PathPrefix, unmarshaled.PathPrefix)\n491: \t}\n492: \tif unmarshaled.Port != tp.Port {\n493: \t\tt.Errorf(\"expected Port %d, got %d\", tp.Port, unmarshaled.Port)\n494: \t}\n495: }\n496: \n497: func TestGroupVersion(t *testing.T) {\n498: \tif GroupVersion.Group != \"runtime.agentcube.volcano.sh\" {\n499: \t\tt.Errorf(\"expected Group 'runtime.agentcube.volcano.sh', got '%s'\", GroupVersion.Group)\n500: \t}\n501: \tif GroupVersion.Version != \"v1alpha1\" {\n502: \t\tt.Errorf(\"expected Version 'v1alpha1', got '%s'\", GroupVersion.Version)\n503: \t}\n504: }\n505: \n506: func TestResourceHelper(t *testing.T) {\n507: \tgvr := Resource(\"agentruntimes\")\n508: \tif gvr.Group != \"runtime.agentcube.volcano.sh\" {\n509: \t\tt.Errorf(\"expected Group 'runtime.agentcube.volcano.sh', got '%s'\", gvr.Group)\n510: \t}\n511: \tif gvr.Resource != \"agentruntimes\" {\n512: \t\tt.Errorf(\"expected Resource 'agentruntimes', got '%s'\", gvr.Resource)\n513: \t}\n514: }\n515: \n516: func TestKindConstants(t *testing.T) {\n517: \tif AgentRuntimeKind != \"AgentRuntime\" {\n518: \t\tt.Errorf(\"expected AgentRuntimeKind 'AgentRuntime', got '%s'\", AgentRuntimeKind)\n519: \t}\n520: \tif AgentRuntimeListKind != \"AgentRuntimeList\" {\n521: \t\tt.Errorf(\"expected AgentRuntimeListKind 'AgentRuntimeList', got '%s'\", AgentRuntimeListKind)\n522: \t}\n523: \tif CodeInterpreterKind != \"CodeInterpreter\" {\n524: \t\tt.Errorf(\"expected CodeInterpreterKind 'CodeInterpreter', got '%s'\", CodeInterpreterKind)\n525: \t}\n526: \tif CodeInterpreterListKind != \"CodeInterpreterList\" {\n527: \t\tt.Errorf(\"expected CodeInterpreterListKind 'CodeInterpreterList', got '%s'\", CodeInterpreterListKind)\n528: \t}\n529: }\n530: \n531: func TestAddToScheme(t *testing.T) {\n532: \tif AddToScheme == nil {\n533: \t\tt.Errorf(\"expected AddToScheme to be non-nil function\")\n534: \t}\n535: }\n536: \n537: func contains(s, substr string) bool {\n538: \treturn len(s) > 0 && len(substr) > 0 && (s == substr || len(s) >= len(substr) && (s[:len(substr)] == substr || s[len(s)-len(substr):] == substr || containsMiddle(s, substr)))\n539: }\n540: \n541: func containsMiddle(s, substr string) bool {\n542: \tfor i := 0; i <= len(s)-len(substr); i++ {\n543: \t\tif s[i:i+len(substr)] == substr {\n544: \t\t\treturn true\n545: \t\t}\n546: \t}\n547: \treturn false\n548: }\n549: \n550: func ptr(s string) *string {\n551: \treturn &s\n552: }\n553: \n554: func ptrInt32(i int32) *int32 {\n555: \treturn &i\n556: }\n557: \n558: func TestLabelConstants(t *testing.T) {\n559: \ttests := []struct {\n560: \t\tname     string\n561: \t\tconstant string\n562: \t\texpected string\n563: \t}{\n564: \t\t{\"OwnerRuntime\", LabelKeyOwnerRuntime, \"runtime.agentcube.volcano.sh/owner-runtime\"},\n565: \t\t{\"OwnerKind\", LabelKeyOwnerKind, \"runtime.agentcube.volcano.sh/owner-kind\"},\n566: \t\t{\"SessionID\", LabelKeySessionID, \"runtime.agentcube.volcano.sh/session-id\"},\n567: \t\t{\"SandboxType\", LabelKeySandboxType, \"runtime.agentcube.volcano.sh/sandbox-type\"},\n568: \t\t{\"SandboxTypeAgent\", LabelKeySandboxTypeAgent, \"agent\"},\n569: \t\t{\"SandboxTypeCodeInterpreter\", LabelKeySandboxTypeCodeInterpreter, \"code-interpreter\"},\n570: \t}\n571: \tfor _, tt := range tests {\n572: \t\tif tt.constant != tt.expected {\n573: \t\t\tt.Errorf(\"%s: expected %s, got %s\", tt.name, tt.expected, tt.constant)\n574: \t\t}\n575: \t}\n576: }\n577: \n578: func TestAnnotationConstants(t *testing.T) {\n579: \ttests := []struct {\n580: \t\tname     string\n581