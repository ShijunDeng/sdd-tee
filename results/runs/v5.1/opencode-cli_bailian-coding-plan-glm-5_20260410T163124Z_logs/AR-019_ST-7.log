 \tfmt.Println()\n60: \tfmt.Println(\"Usage:\")\n61: \tfmt.Println(\"  agentcube [command]\")\n62: \tfmt.Println()\n63: \tfmt.Println(\"Commands:\")\n64: \tfmt.Println(\"  pack      Pack agent sandbox image\")\n65: \tfmt.Println(\"  build     Build agent runtime container\")\n66: \tfmt.Println(\"  publish   Publish agent to registry\")\n67: \tfmt.Println(\"  invoke    Invoke agent with parameters\")\n68: \tfmt.Println(\"  status    Check agent runtime status\")\n69: \tfmt.Println()\n70: \tfmt.Println(\"Flags:\")\n71: \tfmt.Println(\"  --version   Show version information\")\n72: \tfmt.Println(\"  --help      Show help information\")\n73: \tfmt.Println()\n74: \tfmt.Println(\"Examples:\")\n75: \tfmt.Println(\"  agentcube pack ./my-agent\")\n76: \tfmt.Println(\"  agentcube build ./my-agent --tag v1.0.0\")\n77: \tfmt.Println(\"  agentcube invoke my-agent --param input.txt\")\n78: \tfmt.Println(\"  agentcube status my-agent\")\n79: }\n80: \n81: func runPack(args []string) {\n82: \tfs := flag.NewFlagSet(\"pack\", flag.ExitOnError)\n83: \tverbose := fs.Bool(\"v\", false, \"verbose output\")\n84: \toutput := fs.String(\"output\", \"\", \"output directory\")\n85: \tfs.Usage = func() {\n86: \t\tfmt.Println(\"Usage: agentcube pack [flags] <agent-path>\")\n87: \t\tfmt.Println()\n88: \t\tfmt.Println(\"Flags:\")\n89: \t\tfs.PrintDefaults()\n90: \t}\n91: \tfs.Parse(args)\n92: \tcli.InitLogging(*verbose)\n93: \tif len(fs.Args()) < 1 {\n94: \t\tfs.Usage()\n95: \t\tos.Exit(1)\n96: \t}\n97: \tagentPath := fs.Arg(0)\n98: \tfmt.Printf(\"Packing agent from: %s\\n\", agentPath)\n99: \tif *output != \"\" {\n100: \t\tfmt.Printf(\"Output directory: %s\\n\", *output)\n101: \t}\n102: \tfmt.Println(\"Pack command completed (placeholder implementation)\")\n103: }\n104: \n105: func runBuild(args []string) {\n106: \tfs := flag.NewFlagSet(\"build\", flag.ExitOnError)\n107: \tverbose := fs.Bool(\"v\", false, \"verbose output\")\n108: \ttag := fs.String(\"tag\", \"\", \"image tag\")\n109: \tfs.Usage 