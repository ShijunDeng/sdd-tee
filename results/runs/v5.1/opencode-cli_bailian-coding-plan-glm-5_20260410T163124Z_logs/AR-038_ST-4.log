er()\n52: \th.Register(router)\n53: \n54: \treq := httptest.NewRequest(\"GET\", \"/readyz\", nil)\n55: \tw := httptest.NewRecorder()\n56: \n57: \trouter.ServeHTTP(w, req)\n58: \n59: \tif w.Code != http.StatusOK {\n60: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n61: \t}\n62: \n63: \tvar body map[string]string\n64: \tif err := json.NewDecoder(w.Body).Decode(&body); err != nil {\n65: \t\tt.Fatalf(\"failed to decode response: %v\", err)\n66: \t}\n67: \tif body[\"status\"] != \"ready\" {\n68: \t\tt.Errorf(\"expected status %s, got %s\", \"ready\", body[\"status\"])\n69: \t}\n70: }\n71: \n72: func TestReadyz_NotReady(t *testing.T) {\n73: \tchecker := &mockHealthChecker{ready: false}\n74: \th := NewHealthHandler(checker)\n75: \trouter := chi.NewRouter()\n76: \th.Register(router)\n77: \n78: \treq := httptest.NewRequest(\"GET\", \"/readyz\", nil)\n79: \tw := httptest.NewRecorder()\n80: \n81: \trouter.ServeHTTP(w, req)\n82: \n83: \tif w.Code != http.StatusServiceUnavailable {\n84: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusServiceUnavailable, w.Code)\n85: \t}\n86: \n87: \tvar body map[string]string\n88: \tif err := json.NewDecoder(w.Body).Decode(&body); err != nil {\n89: \t\tt.Fatalf(\"failed to decode response: %v\", err)\n90: \t}\n91: \tif body[\"status\"] != \"not ready\" {\n92: \t\tt.Errorf(\"expected status %s, got %s\", \"not ready\", body[\"status\"])\n93: \t}\n94: }\n95: \n96: func TestReadyz_NoChecker(t *testing.T) {\n97: \th := NewHealthHandler(nil)\n98: \trouter := chi.NewRouter()\n99: \th.Register(router)\n100: \n101: \treq := httptest.NewRequest(\"GET\", \"/readyz\", nil)\n102: \tw := httptest.NewRecorder()\n103: \n104: \trouter.ServeHTTP(w, req)\n105: \n106: \tif w.Code != http.StatusServiceUnavailable {\n107: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusServiceUnavailable, w.Code)\n108: \t}\n109: \n110: \tvar body map[string]string\n111: \tif err := json.NewDecoder(w.Body).Decode(&body); err != nil {\n112: \t\tt.Fatalf(\"failed to decode response: %v\", err)\n113: \t}\n114: \tif body[\"status\"] != \"not ready\" {\n115: \t\tt.Errorf(\"expected status %s, got %s\", \"not ready\", body[\"status\"])\n116: \t}\n117: }\n118: \n119: func TestHealthz_ContentType(t *testing.T) {\n120: \th := NewHealthHandler(nil)\n121: \trouter := chi.NewRouter()\n122: \th.Register(router)\n123: \n124: \treq := httptest.NewRequest(\"GET\", \"/healthz\", nil)\n125: \tw := httptest.NewRecorder()\n126: \n127: \trouter.ServeHTTP(w, req)\n128: \n129: \tct := w.Header().Get(\"Content-Type\")\n130: \tif ct != \"application/json\" {\n131: \t\tt.Errorf(\"expected Content-Type %s, got %s\", \"application/json\", ct)\n132: \t}\n133: }\n134: \n135: func TestReadyz_ContentType(t *testing.T) {\n136: \tchecker := &mockHealthChecker{ready: true}\n137: \th := NewHealthHandler(checker)\n138: \trouter := chi.NewRouter()\n139: \th.Register(router)\n140: \n141: \treq := httptest.NewRequest(\"GET\", \"/readyz\", nil)\n142: \tw := httptest.NewRecorder()\n143: \n144: \trouter.ServeHTTP(w, req)\n145: \n146: \tct := w.Header().Get(\"Content-Type\")\n147: \tif ct != \"application/json\" {\n148: \t\tt.Errorf(\"expected Content-Type %s, got %s\", \"application/json\", ct)\n149: \t}\n150: }\n\n(End of file - total 150 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\ntype mockHealthChecker struct {\n\thealthy bool\n\tready   bool\n}\n\nfunc (m *mockHealthChecker) IsHealthy() bool {\n\treturn m.healthy\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/health_test.go","time":{"start":1775896103427,"end":1775896103448}}}}
{"type":"tool_use","timestamp":1775896103451,"sessionID":"ses_28458e356ffeChgVTor3S6GXRb","part":{"id":"prt_d7ba7fec8001oJGo4mtPZv61Ib","messageID":"msg_d7ba7e6be001yoOw4Rze496Fcb","sessionID":"ses_28458e356ffeChgVTor3S6GXRb","type":"tool","tool":"read","callID":"toolu_tool-55454c1f3259452b80e7a5ea06900e8e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go</path>\n<type>file</type>\n<content>\n1: package handlers\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"net/http\"\n7: \t\"net/http/httptest\"\n8: \t\"testing\"\n9: \t\"time\"\n10: \n11: \t\"github.com/go-chi/chi/v5\"\n12: \t\"github.com/stretchr/testify/assert\"\n13: \t\"github.com/stretchr/testify/require\"\n14: \t\"k8s.io/apimachinery/pkg/runtime\"\n15: \tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n16: \t\"k8s.io/client-go/informers\"\n17: \t\"k8s.io/client-go/kubernetes\"\n18: \tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n19: \n20: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n21: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n22: )\n23: \n24: func NewTestInformerFactory(client kubernetes.Interface) informers.SharedInformerFactory {\n25: \treturn informers.NewSharedInformerFactoryWithOptions(client, time.Minute)\n26: }\n27: \n28: func setupTestHandler() (*DeletionHandler, *workloadmanager.MemoryStore) {\n29: \tfakeClient := k8sfake.NewSimpleClientset()\n30: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n31: \tinformerFactory := NewTestInformerFactory(fakeClient)\n32: \n33: \tk8sClient := &workloadmanager.K8sClient{}\n34: \tk8sClient.SetClients(dynamicClient, fakeClient, informerFactory)\n35: \n36: \tstore := workloadmanager.NewMemoryStore()\n37: \tlogger := &testLogger{}\n38: \tconfig := workloadmanager.DefaultLifecycleConfig()\n39: \n40: \tmanager := workloadmanager.NewSandboxLifecycleManager(k8sClient, store, config, logger)\n41: \n42: \treturn NewDeletionHandler(manager, logger), store\n43: }\n44: \n45: type testLogger struct{}\n46: \n47: func (l *testLogger) Info(msg string, args ...any)  {}\n48: func (l *testLogger) Error(msg string, args ...any) {}\n49: \n50: func TestDeletionHandler_Register(t *testing.T) {\n51: \thandler, _ := setupTestHandler()\n52: \n53: \tr := chi.NewRouter()\n54: \thandler.Register(r)\n55: \n56: \troutes := r.Routes()\n57: \tassert.Len(t, routes, 2)\n58: }\n59: \n60: func TestDeletionHandler_DeleteSuccess(t *testing.T) {\n61: \thandler, store := setupTestHandler()\n62: \n63: \tnow := time.Now()\n64: \tsandbox := &types.SandboxInfo{\n65: \t\tKind:             types.SandboxKind,\n66: \t\tSandboxID:        \"sandbox-123\",\n67: \t\tSandboxNamespace: \"default\",\n68: \t\tSandboxName:      \"sandbox-123\",\n69: \t\tSessionID:        \"session-123\",\n70: \t\tCreatedAt:        now,\n71: \t\tExpiresAt:        now.Add(8 * time.Hour),\n72: \t\tStatus:           \"running\",\n73: \t}\n74: \n75: \terr := store.StoreSandbox(context.Background(), sandbox)\n76: \trequire.NoError(t, err)\n77: \n78: \tr := chi.NewRouter()\n79: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n80: \n81: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n82: \trec := httptest.NewRecorder()\n83: \n84: \tr.ServeHTTP(rec, req)\n85: \n86: \tassert.Equal(t, http.StatusOK, rec.Code)\n87: \n88: \tvar resp DeleteSandboxResponse\n89: \terr = json.NewDecoder(rec.Body).Decode(&resp)\n90: \trequire.NoError(t, err)\n91: \n92: \tassert.Equal(t, \"session-123\", resp.SessionID)\n93: \tassert.Equal(t, \"deleted\", resp.Status)\n94: \n95: \tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n96: }\n97: \n98: func TestDeletionHandler_DeleteNotFound(t *testing.T) {\n99: \thandler, _ := setupTestHandler()\n100: \n101: \tr := chi.NewRouter()\n102: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n103: \n104: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/non-existent\", nil)\n105: \trec := httptest.NewRecorder()\n106: \n107: \tr.ServeHTTP(rec, req)\n108: \n109: \tassert.Equal(t, http.StatusNotFound, rec.Code)\n110: \n111: \tvar resp DeleteSandboxResponse\n112: \terr := json.NewDecoder(rec.Body).Decode(&resp)\n113: \trequire.NoError(t, err)\n114: \n115: \tassert.Equal(t, \"non-existent\", resp.SessionID)\n116: \tassert.Equal(t, \"not_found\", resp.Status)\n117: }\n118: \n119: func TestDeletionHandler_DeleteMissingSessionID(t *testing.T) {\n120: \thandler, _ := setupTestHandler()\n121: \n122: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\", nil)\n123: \trec := httptest.NewRecorder()\n124: \n125: \thandler.handleDeleteSandbox(rec, req, \"\", workloadmanager.AgentRuntimeKind)\n126: \n127: \tassert.Equal(t, http.StatusBadRequest, rec.Code)\n128: \n129: \tvar resp workloadmanager.ErrorResponse\n130: \terr := json.NewDecoder(rec.Body).Decode(&resp)\n131: \trequire.NoError(t, err)\n132: \n133: \tassert.Equal(t, \"VALIDATION_ERROR\", resp.Code)\n134: }\n135: \n136: func TestDeletionHandler_DeleteCodeInterpreter(t *testing.T) {\n137: \thandler, store := setupTestHandler()\n138: \n139: \tnow := time.Now()\n140: \tsandbox := &types.SandboxInfo{\n141: \t\tKind:             types.SandboxKind,\n142: \t\tSandboxID:        \"sandbox-123\",\n143: \t\tSandboxNamespace: \"default\",\n144: \t\tSandboxName:      \"sandbox-123\",\n145: \t\tSessionID:        \"session-123\",\n146: \t\tCreatedAt:        now,\n147: \t\tExpiresAt:        now.Add(8 * time.Hour),\n148: \t\tStatus:           \"running\",\n149: \t}\n150: \n151: \terr := store.StoreSandbox(context.Background(), sandbox)\n152: \trequire.NoError(t, err)\n153: \n154: \tr := chi.NewRouter()\n155: \tr.Delete(\"/v1/code-interpreter/sessions/{sessionId}\", handler.handleDeleteCodeInterpreterSandbox)\n156: \n157: \treq := httptest.NewRequest(\"DELETE\", \"/v1/code-interpreter/sessions/session-123\", nil)\n158: \trec := httptest.NewRecorder()\n159: \n160: \tr.ServeHTTP(rec, req)\n161: \n162: \tassert.Equal(t, http.StatusOK, rec.Code)\n163: \n164: \tvar resp DeleteSandboxResponse\n165: \terr = json.NewDecoder(rec.Body).Decode(&resp)\n166: \trequire.NoError(t, err)\n167: \n168: \tassert.Equal(t, \"session-123\", resp.SessionID)\n169: \tassert.Equal(t, \"deleted\", resp.Status)\n170: }\n171: \n172: func TestDeletionHandler_ResponseFormat(t *testing.T) {\n173: \thandler, store := setupTestHandler()\n174: \n175: \tnow := time.Now()\n176: \tsandbox := &types.SandboxInfo{\n177: \t\tKind:             types.SandboxKind,\n178: \t\tSandboxID:        \"sandbox-123\",\n179: \t\tSandboxNamespace: \"default\",\n180: \t\tSandboxName:      \"sandbox-123\",\n181: \t\tSessionID:        \"session-123\",\n182: \t\tCreatedAt:        now,\n183: \t\tExpiresAt:        now.Add(8 * time.Hour),\n184: \t\tStatus:           \"running\",\n185: \t}\n186: \n187: \terr := store.StoreSandbox(context.Background(), sandbox)\n188: \trequire.NoError(t, err)\n189: \n190: \tr := chi.NewRouter()\n191: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n192: \n193: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n194: \trec := httptest.NewRecorder()\n195: \n196: \tr.ServeHTTP(rec, req)\n197: \n198: \tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n199: \n200: \tvar resp map[string]interface{}\n201: \terr = json.Unmarshal(rec.Body.Bytes(), &resp)\n202: \trequire.NoError(t, err)\n203: \n204: \tassert.Contains(t, resp, \"sessionId\")\n205: \tassert.Contains(t, resp, \"status\")\n206: \tassert.Equal(t, \"session-123\", resp[\"sessionId\"])\n207: \tassert.Equal(t, \"deleted\", resp[\"status\"])\n208: }\n209: \n210: func TestDeleteSandboxRequest_JSON(t *testing.T) {\n211: \treq := DeleteSandboxRequest{\n212: \t\tSessionID:          \"session-123\",\n213: \t\tKind:               \"AgentRuntime\",\n214: \t\tForce:              true,\n215: \t\tGracePeriodSeconds: 30,\n216: \t}\n217: \n218: \tdata, err := json.Marshal(req)\n219: \trequire.NoError(t, err)\n220: \n221: \tvar unmarshaled DeleteSandboxRequest\n222: \terr = json.Unmarshal(data, &unmarshaled)\n223: \trequire.NoError(t, err)\n224: \n225: \tassert.Equal(t, req.SessionID, unmarshaled.SessionID)\n226: \tassert.Equal(t, req.Kind, unmarshaled.Kind)\n227: \tassert.Equal(t, req.Force, unmarshaled.Force)\n228: \tassert.Equal(t, req.GracePeriodSeconds, unmarshaled.GracePeriodSeconds)\n229: }\n230: \n231: func TestDeleteSandboxResponse_JSON(t *testing.T) {\n232: \tresp := DeleteSandboxResponse{\n233: \t\tSessionID: \"session-123\",\n234: \t\tStatus:    \"deleted\",\n235: \t\tMessage:   \"Sandbox deleted successfully\",\n236: \t}\n237: \n238: \tdata, err := json.Marshal(resp)\n239: \trequire.NoError(t, err)\n240: \n241: \tvar unmarshaled DeleteSandboxResponse\n242: \terr = json.Unmarshal(data, &unmarshaled)\n243: \trequire.NoError(t, err)\n244: \n245: \tassert.Equal(t, resp.SessionID, unmarshaled.SessionID)\n246: \tassert.Equal(t, resp.Status, unmarshaled.Status)\n247: \tassert.Equal(t, resp.Message, unmarshaled.Message)\n248: }\n\n(End of file - total 248 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-go/kubernetes\"\n\tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go","time":{"start":1775896103430,"end":1775896103450}}}}
{"type":"tool_use","timestamp":1775896103452,"sessionID":"ses_28458e356ffeChgVTor3S6GXRb","part":{"id":"prt_d7ba8028a001VQOpDWeasNt5NB","messageID":"msg_d7ba7e6be001yoOw4Rze496Fcb","sessionID":"ses_28458e356ffeChgVTor3S6GXRb","type":"tool","tool":"read","callID":"toolu_tool-ffedf40ef7e24af1ac73a4f29a6d874b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"net/http/httptest\"\n6: \t\"testing\"\n7: )\n8: \n9: func TestCORSMiddleware_Wrap_AllowedOrigin(t *testing.T) {\n10: \tconfig := CORSConfig{\n11: \t\tAllowedOrigins:   []string{\"http://example.com\", \"http://localhost\"},\n12: \t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n13: \t\tAllowedHeaders:   []string{\"Content-Type\"},\n14: \t\tAllowCredentials: true,\n15: \t}\n16: \tm := NewCORSMiddleware(config)\n17: \n18: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n19: \t\tw.WriteHeader(http.StatusOK)\n20: \t})\n21: \n22: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n23: \treq.Header.Set(\"Origin\", \"http://example.com\")\n24: \tw := httptest.NewRecorder()\n25: \n26: \tm.Wrap(handler).ServeHTTP(w, req)\n27: \n28: \torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n29: \tif origin != \"http://example.com\" {\n30: \t\tt.Errorf(\"expected Allow-Origin %s, got %s\", \"http://example.com\", origin)\n31: \t}\n32: \tmethods := w.Header().Get(\"Access-Control-Allow-Methods\")\n33: \tif methods != \"GET,POST\" {\n34: \t\tt.Errorf(\"expected Allow-Methods %s, got %s\", \"GET,POST\", methods)\n35: \t}\n36: \tcreds := w.Header().Get(\"Access-Control-Allow-Credentials\")\n37: \tif creds != \"true\" {\n38: \t\tt.Errorf(\"expected Allow-Credentials %s, got %s\", \"true\", creds)\n39: \t}\n40: }\n41: \n42: func TestCORSMiddleware_Wrap_DisallowedOrigin(t *testing.T) {\n43: \tconfig := CORSConfig{\n44: \t\tAllowedOrigins: []string{\"http://example.com\"},\n45: \t\tAllowedMethods: []string{\"GET\"},\n46: \t\tAllowedHeaders: []string{\"Content-Type\"},\n47: \t}\n48: \tm := NewCORSMiddleware(config)\n49: \n50: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n51: \t\tw.WriteHeader(http.StatusOK)\n52: \t})\n53: \n54: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n55: \treq.Header.Set(\"Origin\", \"http://evil.com\")\n56: \tw := httptest.NewRecorder()\n57: \n58: \tm.Wrap(handler).ServeHTTP(w, req)\n59: \n60: \torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n61: \tif origin != \"\" {\n62: \t\tt.Errorf(\"expected no Allow-Origin header, got %s\", origin)\n63: \t}\n64: }\n65: \n66: func TestCORSMiddleware_Wrap_OptionsPreflight(t *testing.T) {\n67: \tconfig := CORSConfig{\n68: \t\tAllowedOrigins:   []string{\"*\"},\n69: \t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\"},\n70: \t\tAllowedHeaders:   []string{\"Content-Type\", \"Authorization\"},\n71: \t\tAllowCredentials: false,\n72: \t}\n73: \tm := NewCORSMiddleware(config)\n74: \n75: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n76: \t\tw.WriteHeader(http.StatusOK)\n77: \t})\n78: \n79: \treq := httptest.NewRequest(\"OPTIONS\", \"/test\", nil)\n80: \treq.Header.Set(\"Origin\", \"http://example.com\")\n81: \tw := httptest.NewRecorder()\n82: \n83: \tm.Wrap(handler).ServeHTTP(w, req)\n84: \n85: \tif w.Code != http.StatusOK {\n86: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n87: \t}\n88: }\n89: \n90: func TestCORSMiddleware_isAllowedOrigin_Wildcard(t *testing.T) {\n91: \tconfig := CORSConfig{\n92: \t\tAllowedOrigins: []string{\"*\"},\n93: \t}\n94: \tm := NewCORSMiddleware(config)\n95: \n96: \tif !m.isAllowedOrigin(\"http://any.com\") {\n97: \t\tt.Error(\"wildcard should allow any origin\")\n98: \t}\n99: }\n100: \n101: func TestCORSMiddleware_isAllowedOrigin_ExactMatch(t *testing.T) {\n102: \tconfig := CORSConfig{\n103: \t\tAllowedOrigins: []string{\"http://example.com\"},\n104: \t}\n105: \tm := NewCORSMiddleware(config)\n106: \n107: \tif !m.isAllowedOrigin(\"http://example.com\") {\n108: \t\tt.Error(\"exact match should be allowed\")\n109: \t}\n110: \tif m.isAllowedOrigin(\"http://other.com\") {\n111: \t\tt.Error(\"non-matching origin should not be allowed\")\n112: \t}\n113: }\n114: \n115: func TestCORSMiddleware_isAllowedOrigin_NoMatch(t *testing.T) {\n116: \tconfig := CORSConfig{\n117: \t\tAllowedOrigins: []string{\"http://example.com\", \"http://localhost\"},\n118: \t}\n119: \tm := NewCORSMiddleware(config)\n120: \n121: \tif m.isAllowedOrigin(\"http://evil.com\") {\n122: \t\tt.Error(\"non-matching origin should not be allowed\")\n123: \t}\n124: }\n125: \n126: func TestNewCORSMiddleware(t *testing.T) {\n127: \tconfig := CORSConfig{\n128: \t\tAllowedOrigins: []string{\"*\"},\n129: \t}\n130: \tm := NewCORSMiddleware(config)\n131: \n132: \tif m == nil {\n133: \t\tt.Fatal(\"NewCORSMiddleware returned nil\")\n134: \t}\n135: \tif m.config.AllowedOrigins[0] != \"*\" {\n136: \t\tt.Error(\"config not properly set\")\n137: \t}\n138: }\n139: \n140: func TestCORSMiddleware_NoOriginHeader(t *testing.T) {\n141: \tconfig := CORSConfig{\n142: \t\tAllowedOrigins: []string{\"*\"},\n143: \t}\n144: \tm := NewCORSMiddleware(config)\n145: \n146: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n147: \t\tw.WriteHeader(http.StatusOK)\n148: \t})\n149: \n150: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n151: \tw := httptest.NewRecorder()\n152: \n153: \tm.Wrap(handler).ServeHTTP(w, req)\n154: \n155: \torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n156: \tif origin != \"\" {\n157: \t\tt.Errorf(\"expected no Allow-Origin without Origin header, got %s\", origin)\n158: \t}\n159: }\n160: \n161: func TestCORSConfig_AllFields(t *testing.T) {\n162: \tconfig := CORSConfig{\n163: \t\tAllowedOrigins:   []string{\"http://example.com\"},\n164: \t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n165: \t\tAllowedHeaders:   []string{\"Content-Type\"},\n166: \t\tAllowCredentials: true,\n167: \t}\n168: \n169: \tif len(config.AllowedOrigins) != 1 {\n170: \t\tt.Errorf(\"expected 1 allowed origin, got %d\", len(config.AllowedOrigins))\n171: \t}\n172: \tif len(config.AllowedMethods) != 2 {\n173: \t\tt.Errorf(\"expected 2 allowed methods, got %d\", len(config.AllowedMethods))\n174: \t}\n175: \tif !config.AllowCredentials {\n176: \t\tt.Error(\"expected AllowCredentials to be true\")\n177: \t}\n178: }\n\n(End of file - total 178 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n)\n\nfunc TestCORSMiddleware_Wrap_AllowedOrigin(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins:   []string{\"http://example.com\", \"http://localhost\"},\n\t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n\t\tAllowedHeaders:   []string{\"Content-Type\"},\n\t\tAllowCredentials: true,\n\t}\n\tm := NewCORSMiddleware(config)\n\n\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t})","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go","time":{"start":1775896103432,"end":1775896103451}}}}
{"type":"tool_use","timestamp":1775896103454,"sessionID":"ses_28458e356ffeChgVTor3S6GXRb","part":{"id":"prt_d7ba8067f0014Eb7iiP4p0FYow","messageID":"msg_d7ba7e6be001yoOw4Rze496Fcb","sessionID":"ses_28458e356ffeChgVTor3S6GXRb","type":"tool","tool":"read","callID":"toolu_tool-a0f7556fc02e451db7cacaf2505e79a2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/logging_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/logging_test.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"net/http/httptest\"\n6: \t\"testing\"\n7: \n8: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n9: )\n10: \n11: func TestResponseWriterWrapper_WriteHeader(t *testing.T) {\n12: \tw := httptest.NewRecorder()\n13: \twrapper := &responseWriterWrapper{ResponseWriter: w}\n14: \n15: \twrapper.WriteHeader(http.StatusNotFound)\n16: \n17: \tif wrapper.status != http.StatusNotFound {\n18: \t\tt.Errorf(\"expected captured status %d, got %d\", http.StatusNotFound, wrapper.status)\n19: \t}\n20: \tif w.Code != http.StatusNotFound {\n21: \t\tt.Errorf(\"expected underlying recorder status %d, got %d\", http.StatusNotFound, w.Code)\n22: \t}\n23: }\n24: \n25: func TestResponseWriterWrapper_DefaultStatus(t *testing.T) {\n26: \tw := httptest.NewRecorder()\n27: \twrapper := &responseWriterWrapper{ResponseWriter: w}\n28: \n29: \tif wrapper.status != 0 {\n30: \t\tt.Errorf(\"expected default status 0, got %d\", wrapper.status)\n31: \t}\n32: }\n33: \n34: func TestLoggingMiddleware_Wrap(t *testing.T) {\n35: \tlogger := &testLogger{}\n36: \tm := NewLoggingMiddleware(logger)\n37: \n38: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n39: \t\tw.WriteHeader(http.StatusCreated)\n40: \t})\n41: \n42: \treq := httptest.NewRequest(\"POST\", \"/test/path\", nil)\n43: \tw := httptest.NewRecorder()\n44: \n45: \tm.Wrap(handler).ServeHTTP(w, req)\n46: \n47: \tif len(logger.infos) != 1 {\n48: \t\tt.Errorf(\"expected 1 info log, got %d\", len(logger.infos))\n49: \t}\n50: \tif logger.infos[0] != \"request\" {\n51: \t\tt.Errorf(\"expected log message %s, got %s\", \"request\", logger.infos[0])\n52: \t}\n53: }\n54: \n55: func TestLoggingMiddleware_CapturesMethod(t *testing.T) {\n56: \tlogger := &testLogger{}\n57: \tm := NewLoggingMiddleware(logger)\n58: \n59: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n60: \t\tw.WriteHeader(http.StatusOK)\n61: \t})\n62: \n63: \treq := httptest.NewRequest(\"DELETE\", \"/resource/123\", nil)\n64: \tw := httptest.NewRecorder()\n65: \n66: \tm.Wrap(handler).ServeHTTP(w, req)\n67: \n68: \tif len(logger.infos) != 1 {\n69: \t\tt.Fatalf(\"expected 1 log entry, got %d\", len(logger.infos))\n70: \t}\n71: }\n72: \n73: func TestLoggingMiddleware_CapturesStatus(t *testing.T) {\n74: \tlogger := &testLogger{}\n75: \tm := NewLoggingMiddleware(logger)\n76: \n77: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n78: \t\tw.WriteHeader(http.StatusBadRequest)\n79: \t})\n80: \n81: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n82: \tw := httptest.NewRecorder()\n83: \n84: \tm.Wrap(handler).ServeHTTP(w, req)\n85: \n86: \tif len(logger.infos) != 1 {\n87: \t\tt.Fatalf(\"expected 1 log entry, got %d\", len(logger.infos))\n88: \t}\n89: }\n90: \n91: type testLogger struct {\n92: \tinfos  []string\n93: \terrors []string\n94: \targs   [][]any\n95: }\n96: \n97: func (l *testLogger) Info(msg string, args ...any) {\n98: \tl.infos = append(l.infos, msg)\n99: \tl.args = append(l.args, args)\n100: }\n101: \n102: func (l *testLogger) Error(msg string, args ...any) {\n103: \tl.errors = append(l.errors, msg)\n104: }\n105: \n106: func TestNewLoggingMiddleware(t *testing.T) {\n107: \tlogger := &testLogger{}\n108: \tm := NewLoggingMiddleware(logger)\n109: \n110: \tif m == nil {\n111: \t\tt.Fatal(\"NewLoggingMiddleware returned nil\")\n112: \t}\n113: \tif m.logger == nil {\n114: \t\tt.Error(\"middleware logger is nil\")\n115: \t}\n116: }\n117: \n118: func TestLoggingMiddleware_ImplementsMiddleware(t *testing.T) {\n119: \tlogger := &testLogger{}\n120: \tm := NewLoggingMiddleware(logger)\n121: \n122: \tvar _ workloadmanager.Logger = m.logger\n123: }\n\n(End of file - total 123 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\nfunc TestResponseWriterWrapper_WriteHeader(t *testing.T) {\n\tw := httptest.NewRecorder()\n\twrapper := &responseWriterWrapper{ResponseWriter: w}\n\n\twrapper.WriteHeader(http.StatusNotFound)\n\n\tif wrapper.status != http.StatusNotFound {\n\t\tt.Errorf(\"expected captured status %d, got %d\", http.StatusNotFound, wrapper.status)\n\t}\n\tif w.Code != http.StatusNotFound {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/logging_test.go","time":{"start":1775896103434,"end":1775896103453}}}}
