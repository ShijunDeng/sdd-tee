ter{\n45: \t\tPath: \"/test\",\n46: \t\tFunc: HandlerFunc(func(w http.ResponseWriter, r *http.Request) error {\n47: \t\t\tw.WriteHeader(http.StatusOK)\n48: \t\t\treturn nil\n49: \t\t}),\n50: \t}\n51: \n52: \trouter := workloadmanager.NewRouter()\n53: \tadapter.Register(router.Router)\n54: \n55: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n56: \tw := httptest.NewRecorder()\n57: \n58: \trouter.Router.ServeHTTP(w, req)\n59: \n60: \tif w.Code != http.StatusOK {\n61: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n62: \t}\n63: }\n\n(End of file - total 63 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\nfunc TestHandlerFunc_ServeHTTP_Success(t *testing.T) {\n\thf := HandlerFunc(func(w http.ResponseWriter, r *http.Request) error {\n\t\tw.WriteHeader(http.StatusOK)\n\t\tw.Write([]byte(\"success\"))\n\t\treturn nil\n\t})\n\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tw := httptest.NewRecorder()\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/handler_test.go","time":{"start":1775896119855,"end":1775896119862}}}}
