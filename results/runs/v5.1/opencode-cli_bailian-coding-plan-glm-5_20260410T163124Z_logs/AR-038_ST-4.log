NewHTTPServer(cfg, logger)\n57: \n58: \tvar _ chi.Router = s.router\n59: }\n60: \n61: func TestRegisterHandler(t *testing.T) {\n62: \tcfg := DefaultConfig()\n63: \tlogger := &testLogger{}\n64: \ts := NewHTTPServer(cfg, logger)\n65: \n66: \th := &mockHandler{}\n67: \ts.RegisterHandler(\"test\", h)\n68: \n69: \tif s.handlers[\"test\"] == nil {\n70: \t\tt.Error(\"handler not stored in map\")\n71: \t}\n72: \tif !h.registered {\n73: \t\tt.Error(\"handler Register method not called\")\n74: \t}\n75: }\n76: \n77: func TestStart_ReturnsErrorChannel(t *testing.T) {\n78: \tcfg := Config{\n79: \t\tAddr:            \":0\",\n80: \t\tReadTimeout:     1 * time.Second,\n81: \t\tWriteTimeout:    1 * time.Second,\n82: \t\tIdleTimeout:     1 * time.Second,\n83: \t\tShutdownTimeout: 1 * time.Second,\n84: \t}\n85: \tlogger := &testLogger{}\n86: \ts := NewHTTPServer(cfg, logger)\n87: \n88: \terrCh := s.Start()\n89: \tif errCh == nil {\n90: \t\tt.Error(\"Start returned nil error channel\")\n91: \t}\n92: \n93: \tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n94: \tdefer cancel()\n95: \ts.Stop(ctx)\n96: }\n97: \n98: func TestStop_ClosesStopChannel(t *testing.T) {\n99: \tcfg := Config{\n100: \t\tAddr:            \":0\",\n101: \t\tReadTimeout:     1 * time.Second,\n102: \t\tWriteTimeout:    1 * time.Second,\n103: \t\tIdleTimeout:     1 * time.Second,\n104: \t\tShutdownTimeout: 1 * time.Second,\n105: \t}\n106: \tlogger := &testLogger{}\n107: \ts := NewHTTPServer(cfg, logger)\n108: \n109: \ts.Start()\n110: \n111: \tctx := context.Background()\n112: \ts.Stop(ctx)\n113: \n114: \tselect {\n115: \tcase <-s.stopCh:\n116: \tcase <-time.After(2 * time.Second):\n117: \t\tt.Error(\"stopCh was not closed\")\n118: \t}\n119: }\n120: \n121: func TestHTTPServer_RouterAssigned(t *testing.T) {\n122: \tcfg := DefaultConfig()\n123: \tlogger := &testLogger{}\n124: \ts := NewHTTPServer(cfg, logger)\n125: \n126: \ts.router.Get(\"/test\", func(w http.ResponseWriter, r *http.Request) {