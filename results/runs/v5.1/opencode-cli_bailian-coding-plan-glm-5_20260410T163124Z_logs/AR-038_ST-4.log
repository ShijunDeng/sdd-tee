{"type":"tool_use","timestamp":1775896094320,"sessionID":"ses_28458e356ffeChgVTor3S6GXRb","part":{"id":"prt_d7ba7d619001QCyx629NjoW7mi","messageID":"msg_d7ba7b3b9001PHz1iRqESKiE9J","sessionID":"ses_28458e356ffeChgVTor3S6GXRb","type":"tool","tool":"read","callID":"toolu_tool-f2cca8dd650a4151924e0a12259323a1","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/store_test.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"testing\"\n6: \t\"time\"\n7: \n8: \t\"github.com/stretchr/testify/assert\"\n9: \t\"github.com/stretchr/testify/require\"\n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: func TestMemoryStore_StoreSandbox(t *testing.T) {\n14: \tstore := NewMemoryStore()\n15: \tctx := context.Background()\n16: \n17: \tnow := time.Now()\n18: \tsandbox := &types.SandboxInfo{\n19: \t\tKind:             types.SandboxKind,\n20: \t\tSandboxID:        \"sandbox-123\",\n21: \t\tSandboxNamespace: \"default\",\n22: \t\tName:             \"sandbox-123\",\n23: \t\tSessionID:        \"session-123\",\n24: \t\tCreatedAt:        now,\n25: \t\tExpiresAt:        now.Add(8 * time.Hour),\n26: \t\tStatus:           \"running\",\n27: \t}\n28: \n29: \terr := store.StoreSandbox(ctx, sandbox)\n30: \trequire.NoError(t, err)\n31: \n32: \tassert.Equal(t, 1, store.Size())\n33: }\n34: \n35: func TestMemoryStore_GetSandboxBySessionID(t *testing.T) {\n36: \tstore := NewMemoryStore()\n37: \tctx := context.Background()\n38: \n39: \tnow := time.Now()\n40: \tsandbox := &types.SandboxInfo{\n41: \t\tKind:             types.SandboxKind,\n42: \t\tSandboxID:        \"sandbox-123\",\n43: \t\tSandboxNamespace: \"default\",\n44: \t\tName:             \"sandbox-123\",\n45: \t\tSessionID:        \"session-123\",\n46: \t\tCreatedAt:        now,\n47: \t\tExpiresAt:        now.Add(8 * time.Hour),\n48: \t\tStatus:           \"running\",\n49: \t}\n50: \n51: \terr := store.StoreSandbox(ctx, sandbox)\n52: \trequire.NoError(t, err)\n53: \n54: \tretrieved, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n55: \trequire.NoError(t, err)\n56: \tassert.Equal(t, sandbox.SessionID, retrieved.SessionID)\n57: \tassert.Equal(t, sandbox.SandboxID, retrieved.SandboxID)\n58: \n59: \t_, err = store.GetSandboxBySessionID(ctx, \"non-existent\")\n60: \tassert.Error(t, err)\n61: \tassert.IsType(t, &NotFoundError{}, err)\n62: }\n63: \n64: func TestMemoryStore_UpdateSandbox(t *testing.T) {\n65: \tstore := NewMemoryStore()\n66: \tctx := context.Background()\n67: \n68: \tnow := time.Now()\n69: \tsandbox := &types.SandboxInfo{\n70: \t\tKind:             types.SandboxKind,\n71: \t\tSandboxID:        \"sandbox-123\",\n72: \t\tSandboxNamespace: \"default\",\n73: \t\tName:             \"sandbox-123\",\n74: \t\tSessionID:        \"session-123\",\n75: \t\tCreatedAt:        now,\n76: \t\tExpiresAt:        now.Add(8 * time.Hour),\n77: \t\tStatus:           \"running\",\n78: \t}\n79: \n80: \terr := store.StoreSandbox(ctx, sandbox)\n81: \trequire.NoError(t, err)\n82: \n83: \tsandbox.Status = \"terminating\"\n84: \tsandbox.LastActivity = now.Add(1 * time.Hour)\n85: \n86: \terr = store.UpdateSandbox(ctx, sandbox)\n87: \trequire.NoError(t, err)\n88: \n89: \tretrieved, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n90: \trequire.NoError(t, err)\n91: \tassert.Equal(t, \"terminating\", retrieved.Status)\n92: \tassert.Equal(t, now.Add(1*time.Hour), retrieved.LastActivity)\n93: }\n94: \n95: func TestMemoryStore_UpdateSandboxNotFound(t *testing.T) {\n96: \tstore := NewMemoryStore()\n97: \tctx := context.Background()\n98: \n99: \tsandbox := &types.SandboxInfo{\n100: \t\tSessionID: \"non-existent\",\n101: \t}\n102: \n103: \terr := store.UpdateSandbox(ctx, sandbox)\n104: \tassert.Error(t, err)\n105: \tassert.IsType(t, &NotFoundError{}, err)\n106: }\n107: \n108: func TestMemoryStore_DeleteSandboxBySessionID(t *testing.T) {\n109: \tstore := NewMemoryStore()\n110: \tctx := context.Background()\n111: \n112: \tnow := time.Now()\n113: \tsandbox := &types.SandboxInfo{\n114: \t\tKind:             types.SandboxKind,\n115: \t\tSandboxID:        \"sandbox-123\",\n116: \t\tSandboxNamespace: \"default\",\n117: \t\tName:             \"sandbox-123\",\n118: \t\tSessionID:        \"session-123\",\n119: \t\tCreatedAt:        now,\n120: \t\tExpiresAt:        now.Add(8 * time.Hour),\n121: \t\tStatus:           \"running\",\n122: \t}\n123: \n124: \terr := store.StoreSandbox(ctx, sandbox)\n125: \trequire.NoError(t, err)\n126: \n127: \tassert.Equal(t, 1, store.Size())\n128: \n129: \terr = store.DeleteSandboxBySessionID(ctx, \"session-123\")\n130: \trequire.NoError(t, err)\n131: \n132: \tassert.Equal(t, 0, store.Size())\n133: \n134: \t_, err = store.GetSandboxBySessionID(ctx, \"session-123\")\n135: \tassert.Error(t, err)\n136: }\n137: \n138: func TestMemoryStore_DeleteSandboxBySessionIDNotFound(t *testing.T) {\n139: \tstore := NewMemoryStore()\n140: \tctx := context.Background()\n141: \n142: \terr := store.DeleteSandboxBySessionID(ctx, \"non-existent\")\n143: \tassert.NoError(t, err)\n144: }\n145: \n146: func TestMemoryStore_ListSandboxes(t *testing.T) {\n147: \tstore := NewMemoryStore()\n148: \tctx := context.Background()\n149: \n150: \tnow := time.Now()\n151: \tfor i := 0; i < 3; i++ {\n152: \t\tsandbox := &types.SandboxInfo{\n153: \t\t\tKind:             types.SandboxKind,\n154: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n155: \t\t\tSandboxNamespace: \"default\",\n156: \t\t\tName:             \"sandbox-\" + string(rune(i)),\n157: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n158: \t\t\tCreatedAt:        now,\n159: \t\t\tExpiresAt:        now.Add(8 * time.Hour),\n160: \t\t\tStatus:           \"running\",\n161: \t\t}\n162: \t\terr := store.StoreSandbox(ctx, sandbox)\n163: \t\trequire.NoError(t, err)\n164: \t}\n165: \n166: \tsandboxes, err := store.ListSandboxes(ctx)\n167: \trequire.NoError(t, err)\n168: \tassert.Len(t, sandboxes, 3)\n169: }\n170: \n171: func TestMemoryStore_ListExpiredSandboxes(t *testing.T) {\n172: \tstore := NewMemoryStore()\n173: \tctx := context.Background()\n174: \n175: \tnow := time.Now()\n176: \n177: \texpiredSandbox := &types.SandboxInfo{\n178: \t\tKind:             types.SandboxKind,\n179: \t\tSandboxID:        \"sandbox-expired\",\n180: \t\tSandboxNamespace: \"default\",\n181: \t\tName:             \"sandbox-expired\",\n182: \t\tSessionID:        \"session-expired\",\n183: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n184: \t\tExpiresAt:        now.Add(-2 * time.Hour),\n185: \t\tStatus:           \"running\",\n186: \t}\n187: \n188: \tactiveSandbox := &types.SandboxInfo{\n189: \t\tKind:             types.SandboxKind,\n190: \t\tSandboxID:        \"sandbox-active\",\n191: \t\tSandboxNamespace: \"default\",\n192: \t\tName:             \"sandbox-active\",\n193: \t\tSessionID:        \"session-active\",\n194: \t\tCreatedAt:        now,\n195: \t\tExpiresAt:        now.Add(8 * time.Hour),\n196: \t\tStatus:           \"running\",\n197: \t}\n198: \n199: \terr := store.StoreSandbox(ctx, expiredSandbox)\n200: \trequire.NoError(t, err)\n201: \terr = store.StoreSandbox(ctx, activeSandbox)\n202: \trequire.NoError(t, err)\n203: \n204: \texpired, err := store.ListExpiredSandboxes(ctx, now, 10)\n205: \trequire.NoError(t, err)\n206: \tassert.Len(t, expired, 1)\n207: \tassert.Equal(t, \"session-expired\", expired[0].SessionID)\n208: }\n209: \n210: func TestMemoryStore_ListExpiredSandboxesLimit(t *testing.T) {\n211: \tstore := NewMemoryStore()\n212: \tctx := context.Background()\n213: \n214: \tnow := time.Now()\n215: \n216: \tfor i := 0; i < 20; i++ {\n217: \t\tsandbox := &types.SandboxInfo{\n218: \t\t\tKind:             types.SandboxKind,\n219: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n220: \t\t\tSandboxNamespace: \"default\",\n221: \t\t\tName:             \"sandbox-\" + string(rune(i)),\n222: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n223: \t\t\tCreatedAt:        now.Add(-10 * time.Hour),\n224: \t\t\tExpiresAt:        now.Add(-time.Duration(i) * time.Hour),\n225: \t\t\tStatus:           \"running\",\n226: \t\t}\n227: \t\terr := store.StoreSandbox(ctx, sandbox)\n228: \t\trequire.NoError(t, err)\n229: \t}\n230: \n231: \texpired, err := store.ListExpiredSandboxes(ctx, now, 5)\n232: \trequire.NoError(t, err)\n233: \tassert.Len(t, expired, 5)\n234: }\n235: \n236: func TestMemoryStore_ListInactiveSandboxes(t *testing.T) {\n237: \tstore := NewMemoryStore()\n238: \tctx := context.Background()\n239: \n240: \tnow := time.Now()\n241: \n242: \tinactiveSandbox := &types.SandboxInfo{\n243: \t\tKind:             types.SandboxKind,\n244: \t\tSandboxID:        \"sandbox-inactive\",\n245: \t\tSandboxNamespace: \"default\",\n246: \t\tName:             \"sandbox-inactive\",\n247: \t\tSessionID:        \"session-inactive\",\n248: \t\tCreatedAt:        now,\n249: \t\tExpiresAt:        now.Add(8 * time.Hour),\n250: \t\tLastActivity:     now.Add(-30 * time.Minute),\n251: \t\tStatus:           \"running\",\n252: \t}\n253: \n254: \tactiveSandbox := &types.SandboxInfo{\n255: \t\tKind:             types.SandboxKind,\n256: \t\tSandboxID:        \"sandbox-active\",\n257: \t\tSandboxNamespace: \"default\",\n258: \t\tName:             \"sandbox-active\",\n259: \t\tSessionID:        \"session-active\",\n260: \t\tCreatedAt:        now,\n261: \t\tExpiresAt:        now.Add(8 * time.Hour),\n262: \t\tLastActivity:     now,\n263: \t\tStatus:           \"running\",\n264: \t}\n265: \n266: \tnoActivitySandbox := &types.SandboxInfo{\n267: \t\tKind:             types.SandboxKind,\n268: \t\tSandboxID:        \"sandbox-noactivity\",\n269: \t\tSandboxNamespace: \"default\",\n270: \t\tName:             \"sandbox-noactivity\",\n271: \t\tSessionID:        \"session-noactivity\",\n272: \t\tCreatedAt:        now,\n273: \t\tExpiresAt:        now.Add(8 * time.Hour),\n274: \t\tStatus:           \"running\",\n275: \t}\n276: \n277: \terr := store.StoreSandbox(ctx, inactiveSandbox)\n278: \trequire.NoError(t, err)\n279: \terr = store.StoreSandbox(ctx, activeSandbox)\n280: \trequire.NoError(t, err)\n281: \terr = store.StoreSandbox(ctx, noActivitySandbox)\n282: \trequire.NoError(t, err)\n283: \n284: \tinactive, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 10)\n285: \trequire.NoError(t, err)\n286: \tassert.Len(t, inactive, 1)\n287: \tassert.Equal(t, \"session-inactive\", inactive[0].SessionID)\n288: }\n289: \n290: func TestMemoryStore_ListInactiveSandboxesLimit(t *testing.T) {\n291: \tstore := NewMemoryStore()\n292: \tctx := context.Background()\n293: \n294: \tnow := time.Now()\n295: \n296: \tfor i := 0; i < 20; i++ {\n297: \t\tsandbox := &types.SandboxInfo{\n298: \t\t\tKind:             types.SandboxKind,\n299: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n300: \t\t\tSandboxNamespace: \"default\",\n301: \t\t\tName:             \"sandbox-\" + string(rune(i)),\n302: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n303: \t\t\tCreatedAt:        now,\n304: \t\t\tExpiresAt:        now.Add(8 * time.Hour),\n305: \t\t\tLastActivity:     now.Add(-time.Duration(i+20) * time.Minute),\n306: \t\t\tStatus:           \"running\",\n307: \t\t}\n308: \t\terr := store.StoreSandbox(ctx, sandbox)\n309: \t\trequire.NoError(t, err)\n310: \t}\n311: \n312: \tinactive, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 5)\n313: \trequire.NoError(t, err)\n314: \tassert.Len(t, inactive, 5)\n315: }\n316: \n317: func TestMemoryStore_Clear(t *testing.T) {\n318: \tstore := NewMemoryStore()\n319: \tctx := context.Background()\n320: \n321: \tnow := time.Now()\n322: \tsandbox := &types.SandboxInfo{\n323: \t\tKind:             types.SandboxKind,\n324: \t\tSandboxID:        \"sandbox-123\",\n325: \t\tSandboxNamespace: \"default\",\n326: \t\tName:             \"sandbox-123\",\n327: \t\tSessionID:        \"session-123\",\n328: \t\tCreatedAt:        now,\n329: \t\tExpiresAt:        now.Add(8 * time.Hour),\n330: \t\tStatus:           \"running\",\n331: \t}\n332: \n333: \terr := store.StoreSandbox(ctx, sandbox)\n334: \trequire.NoError(t, err)\n335: \n336: \tassert.Equal(t, 1, store.Size())\n337: \n338: \tstore.Clear()\n339: \n340: \tassert.Equal(t, 0, store.Size())\n341: }\n342: \n343: func TestMemoryStore_ConcurrentAccess(t *testing.T) {\n344: \tstore := NewMemoryStore()\n345: \tctx := context.Background()\n346: \n347: \tnow := time.Now()\n348: \n349: \tdone := make(chan bool)\n350: \n351: \tgo func() {\n352: \t\tfor i := 0; i < 100; i++ {\n353: \t\t\tsandbox := &types.SandboxInfo{\n354: \t\t\t\tSessionID: \"session-\" + string(rune(i)),\n355: \t\t\t\tSandboxID: \"sandbox-\" + string(rune(i)),\n356: \t\t\t\tCreatedAt: now,\n357: \t\t\t\tExpiresAt: now.Add(8 * time.Hour),\n358: \t\t\t}\n359: \t\t\tstore.StoreSandbox(ctx, sandbox)\n360: \t\t}\n361: \t\tdone <- true\n362: \t}()\n363: \n364: \tgo func() {\n365: \t\tfor i := 0; i < 100; i++ {\n366: \t\t\tstore.GetSandboxBySessionID(ctx, \"session-\"+string(rune(i)))\n367: \t\t}\n368: \t\tdone <- true\n369: \t}()\n370: \n371: \tgo func() {\n372: \t\tfor i := 0; i < 50; i++ {\n373: \t\t\tstore.DeleteSandboxBySessionID(ctx, \"session-\"+string(rune(i)))\n374: \t\t}\n375: \t\tdone <- true\n376: \t}()\n377: \n378: \tfor i := 0; i < 3; i++ {\n379: \t\t<-done\n380: \t}\n381: }\n\n(End of file - total 381 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestMemoryStore_StoreSandbox(t *testing.T) {\n\tstore := NewMemoryStore()\n\tctx := context.Background()\n\n\tnow := time.Now()\n\tsandbox := &types.SandboxInfo{\n\t\tKind: