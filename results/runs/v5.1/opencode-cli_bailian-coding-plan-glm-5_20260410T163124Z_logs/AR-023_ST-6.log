            runtime._agentcube_provider = mock_agentcube_provider\n271:             \n272:             result = runtime.get_status(tmp_path)\n273:             \n274:             assert result[\"status\"] == \"running\"\n275:             assert result[\"deployment_type\"] == \"AgentRuntime\"\n276:             assert result[\"namespace\"] == \"production\"\n277:             assert result[\"agent_endpoint\"] == \"http://test-agent.example.com/endpoint\"\n278: \n279:     def test_get_cr_k8s_status_created_no_status(self, tmp_path: Path) -> None:\n280:         metadata_content = \"\"\"\n281: agent_name: test-agent\n282: language: python\n283: entrypoint: python main.py\n284: agent_endpoint: http://test-agent.example.com\n285: agent_id: agent-123\n286: k8s_deployment:\n287:   type: AgentRuntime\n288:   namespace: default\n289:   agent_id: agent-123\n290: \"\"\"\n291:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n292:         metadata_file.write_text(metadata_content)\n293:         \n294:         mock_agentcube_provider = MagicMock()\n295:         mock_agentcube_provider.get_agent_runtime.return_value = {\n296:             \"metadata\": {\"name\": \"test-agent\"},\n297:         }\n298:         \n299:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider_class:\n300:             mock_provider_class.return_value = mock_agentcube_provider\n301:             runtime = StatusRuntime(provider=\"agentcube\")\n302:             runtime._agentcube_provider = mock_agentcube_provider\n303:             \n304:             result = runtime.get_status(tmp_path)\n305:             \n306:             assert result[\"status\"] == \"created_no_status\"\n307: \n308:     def test_get_cr_k8s_status_not_found_in_k8s(self, tmp_path: Path) -> None:\n309:         metadata_content = \"\"\"\n310: agent_name: test-agent\n311: language: python\n312: entrypoint: python main.py\n313: agent_endpoint: http://test-agent.example.com\n314: agent_id: agent-