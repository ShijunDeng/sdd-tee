  mock_async_client.post.return_value = mock_response\n199:                 mock_client.return_value.__aenter__.return_value = mock_async_client\n200:                 \n201:                 runtime = InvokeRuntime(provider=\"k8s\")\n202:                 result = runtime.invoke(tmp_path, {\"input\": \"test\"})\n203:                 \n204:                 call_args = mock_async_client.post.call_args\n205:                 assert call_args.args[0] == \"http://localhost:30001\"\n206: \n207: \n208: class TestDirectHttpInvocation:\n209:     def test_direct_http_invocation_success(self, tmp_path: Path) -> None:\n210:         mock_response = MagicMock()\n211:         mock_response.status_code = 200\n212:         mock_response.json.return_value = {\"result\": \"success\", \"data\": \"output\"}\n213:         mock_response.headers = {}\n214:         \n215:         with patch(\"agentcube.services.k8s_provider.KubernetesProvider\") as mock_provider:\n216:             mock_provider.return_value = MagicMock()\n217:             with patch(\"httpx.AsyncClient\") as mock_client:\n218:                 mock_async_client = AsyncMock()\n219:                 mock_async_client.post.return_value = mock_response\n220:                 mock_client.return_value.__aenter__.return_value = mock_async_client\n221:                 \n222:                 runtime = InvokeRuntime(provider=\"k8s\")\n223:                 import asyncio\n224:                 result = asyncio.run(runtime._direct_http_invocation(\n225:                     \"http://test-endpoint\",\n226:                     {\"input\": \"test\"},\n227:                     {},\n228:                     tmp_path\n229:                 ))\n230:                 \n231:                 assert result[\"status_code\"] == 200\n232:                 assert result[\"response\"][\"result\"] == \"success\"\n233: \n234:     def test_direct_http_invocation_updates_session_id(self, tmp_path: Path) -> None:\n235:         metadata_content = \"\"\"\n236: agent_na