 class TestValidateInvokePrerequisites:\n32:     def test_validate_missing_agent_endpoint(self, tmp_path: Path) -> None:\n33:         metadata_content = \"\"\"\n34: agent_name: test-agent\n35: language: python\n36: entrypoint: python main.py\n37: \"\"\"\n38:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n39:         metadata_file.write_text(metadata_content)\n40:         \n41:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n42:             mock_provider.return_value = MagicMock()\n43:             runtime = InvokeRuntime(provider=\"agentcube\")\n44:             with pytest.raises(ValueError, match=\"Agent endpoint not found\"):\n45:                 runtime._validate_invoke_prerequisites(tmp_path)\n46: \n47:     def test_validate_missing_agent_id_for_agentcube(self, tmp_path: Path) -> None:\n48:         metadata_content = \"\"\"\n49: agent_name: test-agent\n50: language: python\n51: entrypoint: python main.py\n52: agent_endpoint: http://test-agent.example.com\n53: \"\"\"\n54:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n55:         metadata_file.write_text(metadata_content)\n56:         \n57:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n58:             mock_provider.return_value = MagicMock()\n59:             runtime = InvokeRuntime(provider=\"agentcube\")\n60:             with pytest.raises(ValueError, match=\"Agent not published\"):\n61:                 runtime._validate_invoke_prerequisites(tmp_path)\n62: \n63:     def test_validate_success_with_agent_id(self, tmp_path: Path) -> None:\n64:         metadata_content = \"\"\"\n65: agent_name: test-agent\n66: language: python\n67: entrypoint: python main.py\n68: agent_endpoint: http://test-agent.example.com\n69: agent_id: agent-123\n70: \"\"\"\n71:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n72:         metadata_file.write_text(metadata_content)\n73:         \n74:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n75:             mock_provider.return_value = MagicMock()\n76:             runtime = InvokeRuntime(provider=\"agentcube\")\n77:             metadata, endpoint, namespace = runtime._validate_invoke_prerequisites(tmp_path)\n78:             assert metadata.agent_name == \"test-agent\"\n79:             assert endpoint == \"http://test-agent.example.com\"\n80:             assert namespace == \"default\"\n81: \n82:     def test_validate_success_with_k8s_deployment(self, tmp_path: Path) -> None:\n83:         metadata_content = \"\"\"\n84: agent_name: test-agent\n85: language: python\n86: entrypoint: python main.py\n87: agent_endpoint: http://localhost:30001\n88: k8s_deployment:\n89:   type: Deployment\n90:   namespace: custom-ns\n91:   agent_id: agent-456\n92: \"\"\"\n93:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n94:         metadata_file.write_text(metadata_content)\n95:         \n96:         with patch(\"agentcube.services.agentcube_provider.AgentCubeProvider\") as mock_provider:\n97:             mock_provider.return_value = MagicMock()\n98:             runtime = InvokeRuntime(provider=\"agentcube\")\n99:             metadata, endpoint, namespace = runtime._validate_invoke_prerequisites(tmp_path)\n100:             assert namespace == \"custom-ns\"\n101: \n102: \n103: class TestInvokeSessionHeader:\n104:     def test_invoke_adds_session_id_header(self, tmp_path: Path) -> None:\n105:         metadata_content = \"\"\"\n106: agent_name: test-agent\n107: language: python\n108: entrypoint: python main.py\n109: agent_endpoint: http://localhost:30001\n110: agent_id: agent-123\n111: session_id: session-abc\n112: k8s_deployment:\n113:   type: Deployment\n114: \"\"\"\n115:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n116:         metadata_file.write_text(metadata_content)\n117:         \n118:         mock_response = MagicMock()\n119:         mock_response.statu