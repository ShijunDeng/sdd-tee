8:         console.print(f\"AgentCube CLI (kubectl agentcube) version: {__version__}\")\n39:         raise typer.Exit()\n40:     if verbose:\n41:         logging.basicConfig(level=logging.DEBUG)\n42: \n43: \n44: @app.command()\n45: def pack(\n46:     workspace: str = typer.Option(\n47:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n48:     ),\n49:     agent_name: Optional[str] = typer.Option(None, \"--agent-name\", help=\"Override the agent name\"),\n50:     language: Optional[str] = typer.Option(None, \"--language\", help=\"Programming language (python, java)\"),\n51:     entrypoint: Optional[str] = typer.Option(None, \"--entrypoint\", help=\"Override the entrypoint command\"),\n52:     port: Optional[int] = typer.Option(None, \"--port\", help=\"Port to expose in the Dockerfile\"),\n53:     build_mode: Optional[str] = typer.Option(None, \"--build-mode\", help=\"Build strategy: local or cloud\"),\n54:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description\"),\n55:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for packaged workspace\"),\n56:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n57: ) -> None:\n58:     \"\"\"Validate and prepare agent workspace for building.\"\"\"\n59:     workspace_path = Path(workspace).resolve()\n60:     options = {\n61:         \"agent_name\": agent_name,\n62:         \"language\": language,\n63:         \"entrypoint\": entrypoint,\n64:         \"port\": port,\n65:         \"build_mode\": build_mode,\n66:         \"description\": description,\n67:         \"output\": output,\n68:     }\n69: \n70:     try:\n71:         with Progress(\n72:             SpinnerColumn(),\n73:             TextColumn(\"[progress.description]{task.description}\"),\n74:         ) as progress:\n75:             task = progress.add_task(\"Packaging agent...\", total=None)\n76:             runtime = PackRuntime(verbose)\n77:             result = runtime.pack(workspace_path, **options)\n78: \n79:         console.print(f\"[green]Success![/green] Agent [bold]{result['agent_name']}[/bold] packed.\")\n80:         console.print(f\"  Workspace: {result['workspace_path']}\")\n81:         console.print(f\"  Metadata:  {result['metadata_path']}\")\n82:         if result['dockerfile_path']:\n83:             console.print(f\"  Dockerfile: {result['dockerfile_path']}\")\n84:     except Exception as e:\n85:         _handle_error(e, \"pack\", verbose)\n86: \n87: \n88: @app.command()\n89: def build(\n90:     workspace: str = typer.Option(\n91:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n92:     ),\n93:     proxy: Optional[str] = typer.Option(None, \"-p\", \"--proxy\", help=\"Proxy URL for dependency resolution\"),\n94:     cloud_provider: Optional[str] = typer.Option(None, \"--cloud-provider\", help=\"Cloud provider name\"),\n95:     output: Optional[str] = typer.Option(None, \"--output\", help=\"Output path for build artifacts\"),\n96:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n97: ) -> None:\n98:     \"\"\"Build container image from packaged agent workspace.\"\"\"\n99:     workspace_path = Path(workspace).resolve()\n100:     \n101:     if verbose:\n102:         logging.basicConfig(level=logging.DEBUG)\n103: \n104:     options = {\n105:         \"proxy\": proxy,\n106:         \"cloud_provider\": cloud_provider,\n107:         \"output\": output,\n108:     }\n109: \n110:     try:\n111:         with Progress(\n112:             SpinnerColumn(),\n113:             TextColumn(\"[progress.description]{task.description}\"),\n114:         ) as progress:\n115:             task = progress.add_task(\"Building agent image...\", total=None)\n116:             runtime = BuildRuntime(verbose=verbose)\n117:             result = runtime.build(workspace_path, **options)\n118: \n119:         console.print(f\"[green]Build completed successfully[/green]\")\n120:         console.print(f\"  Image: {result['image_name']}:{result['tag']}\")\n121:         console.print(f\"  Image ID: {result['image_id']}\")\n122:         console.print(f\"  Size: {result['image_size']}\")\n123:         console.print(f\"  Build time: {result['build_time']:.1f}s\")\n124:         console.print(f\"  Metadata: {result['metadata_path']}\")\n125:     except Exception as e:\n126:         _handle_error(e, \"build\", verbose)\n127: \n128: \n129: @app.command()\n130: def publish(\n131:     workspace: str = typer.Option(\n132:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n133:     ),\n134:     version: Optional[str] = typer.Option(None, \"--version\", help=\"Semantic version string (e.g., v1.0.0)\"),\n135:     image_url: Optional[str] = typer.Option(None, \"--image-url\", help=\"Image repository URL (required in local build mode)\"),\n136:     image_username: Optional[str] = typer.Option(None, \"--image-username\", help=\"Username for image repository\"),\n137:     image_password: Optional[str] = typer.Option(None, \"--image-password\", help=\"Password for image repository\"),\n138:     description: Optional[str] = typer.Option(None, \"--description\", help=\"Agent description\"),\n139:     region: Optional[str] = typer.Option(None, \"--region\", help=\"Deployment region\"),\n140:     cloud_provider: Optional[str] = typer.Option(None, \"--cloud-provider\", help=\"Cloud provider name (e.g., huawei)\"),\n141:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\"),\n142:     node_port: Optional[int] = typer.Option(None, \"--node-port\", help=\"Specific NodePort to use (30000-32767) for K8s deployment\"),\n143:     replicas: Optional[int] = typer.Option(None, \"--replicas\", help=\"Number of replicas for K8s deployment (default: 1)\"),\n144:     namespace: Optional[str] = typer.Option(None, \"--namespace\", help=\"The namespace for the deployment\"),\n145:     workload_manager_url: Optional[str] = typer.Option(None, \"--workload-manager-url\", help=\"URL for the Workload Manager\"),\n146:     router_url: Optional[str] = typer.Option(None, \"--router-url\", help=\"URL for the Router\"),\n147:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n148: ) -> None:\n149:     \"\"\"Deploy agent to Kubernetes cluster.\"\"\"\n150:     workspace_path = Path(workspace).resolve()\n151: \n152:     if verbose:\n153:         logging.basicConfig(level=logging.DEBUG)\n154: \n155:     options = {\n156:         \"version\": version,\n157:         \"image_url\": image_url,\n158:         \"image_username\": image_username,\n159:         \"image_password\": image_password,\n160:         \"description\": description,\n161:         \"region\": region,\n162:         \"cloud_provider\": cloud_provider,\n163:         \"node_port\": node_port,\n164:         \"replicas\": replicas,\n165:         \"namespace\": namespace,\n166:         \"workload_manager_url\": workload_manager_url,\n167:         \"router_url\": router_url,\n168:     }\n169: \n170:     try:\n171:         with Progress(\n172:             SpinnerColumn(),\n173:             TextColumn(\"[progress.description]{task.description}\"),\n174:         ) as progress:\n175:             task = progress.add_task(\"Publishing agent to Kubernetes...\", total=None)\n176:             runtime = PublishRuntime(verbose=verbose, provider=provider)\n177:             result = runtime.publish(workspace_path, **options)\n178: \n179:         console.print(f\"[green]Successfully published agent![/green]\")\n180:         console.print(f\"  Agent Name: {result['agent_name']}\")\n181:         console.print(f\"  Agent ID: {result.get('agent_id', 'N/A')}\")\n182:         console.print(f\"  Endpoint: {result['agent_endpoint']}\")\n183:         console.print(f\"  Deployment Type: {result['deployment_type']}\")\n184:         console.print(f\"  Namespace: {result['namespace']}\")\n185:     except Exception as e:\n186:         _handle_error(e, \"publishing agent\", verbose)\n187: \n188: \n189: @app.command()\n190: def invoke(\n191:     workspace: str = typer.Option(\n192:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n193:     ),\n194:     payload: str = typer.Option(\"{}\", \"--payload\", help=\"JSON-formatted input passed to the agent\"),\n195:     header_list: Optional[List[str]] = typer.Option(\n196:         None, \"--header\", help=\"Custom HTTP headers (e.g., 'Authorization: Bearer token'). Can be specified multiple times.\"\n197:     ),\n198:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\"),\n199:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n200: ) -> None:\n201:     \"\"\"Invoke the published agent with a payload.\"\"\"\n202:     workspace_path = Path(workspace).resolve()\n203: \n204:     if verbose:\n205:         logging.basicConfig(level=logging.DEBUG)\n206: \n207:     try:\n208:         parsed_payload = json.loads(payload)\n209:     except json.JSONDecodeError as e:\n210:         console.print(f\"[red]Invalid JSON payload: {payload}[/red]\")\n211:         console.print(f\"[red]JSON parse error: {e}[/red]\")\n212:         raise typer.Exit(1)\n213: \n214:     headers = {}\n215:     if header_list:\n216:         for header_str in header_list:\n217:             if \":\" not in header_str:\n218:                 console.print(f\"[red]Invalid header format: '{header_str}'. Expected 'key:value'[/red]\")\n219:                 raise typer.Exit(1)\n220:             key, value = header_str.split(\":\", 1)\n221:             headers[key.strip()] = value.strip()\n222: \n223:     try:\n224:         with Progress(\n225:             SpinnerColumn(),\n226:             TextColumn(\"[progress.description]{task.description}\"),\n227:         ) as progress:\n228:             task = progress.add_task(\"Invoking agent...\", total=None)\n229:             runtime = InvokeRuntime(verbose=verbose, provider=provider)\n230:             result = runtime.invoke(workspace_path, parsed_payload, headers)\n231: \n232:         console.print(f\"[green]Invocation completed[/green]\")\n233:         console.print(f\"  Status Code: {result.get('status_code', 'N/A')}\")\n234:         console.print(f\"  Endpoint: {result.get('endpoint', 'N/A')}\")\n235:         if result.get('session_id'):\n236:             console.print(f\"  Session ID: {result['session_id']}\")\n237:         console.print(f\"\\n[bold]Response:[/bold]\")\n238:         response = result.get('response', {})\n239:         if isinstance(response, dict):\n240:             console.print_json(data=response)\n241:         else:\n242:             console.print(str(response))\n243:     except Exception as e:\n244:         _handle_error(e, \"invoke\", verbose)\n245: \n246: \n247: @app.command()\n248: def status(\n249:     workspace: str = typer.Option(\n250:         \".\", \"-f\", \"--workspace\", help=\"Path to the agent workspace directory\", show_default=True\n251:     ),\n252:     provider: str = typer.Option(\"agentcube\", \"--provider\", help=\"Target provider: 'agentcube' (AgentRuntime CR) or 'k8s' (Deployment/Service)\"),\n253:     verbose: bool = typer.Option(False, \"--verbose\", help=\"Enable detailed logging\"),\n254: ) -> None:\n255:     \"\"\"Check the status of a published agent.\"\"\"\n256:     workspace_path = Path(workspace).resolve()\n257: \n258:     if verbose:\n259:         logging.basicConfig(level=logging.DEBUG)\n260: \n261:     try:\n262:         runtime = StatusRuntime(verbose=verbose, provider=provider)\n263:         result = runtime.get_status(workspace_path)\n264: \n265:         table = Table(title=\"Agent Status\")\n266:         table.add_column(\"Property\", style=\"cyan\")\n267:         table.add_column(\"Value\", style=\"green\")\n268: \n269:         table.add_row(\"Agent Name\", result.get(\"agent_name\", \"N/A\"))\n270:         table.add_row(\"Status\", result.get(\"status\", \"unknown\"))\n271:         \n272:         deployment_type = result.get(\"deployment_type\", \"N/A\")\n273:         if deployment_type:\n274:             table.add_row(\"Deployment Type\", deployment_type)\n275:         \n276:         namespace = result.get(\"namespace\")\n277:         if namespace:\n278:             table.add_row(\"Namespace\", namespace)\n279:         \n280:         agent_id = result.get(\"agent_id\")\n281:         if agent_id:\n282:             table.add_row(\"Agent ID\", agent_id)\n283:         \n284:         agent_endpoint = result.get(\"agent_endpoint\")\n285:         if agent_endpoint:\n286:             table.add_row(\"Endpoint\", agent_endpoint)\n287:         \n288:         replicas = result.get(\"replicas\")\n289:         if replicas:\n290:             table.add_row(\"Replicas\", str(replicas))\n291:         \n292:         available_replicas = result.get(\"available_replicas\")\n293:         if available_replicas:\n294:             table.add_row(\"Available Replicas\", str(available_replicas))\n295: \n296:         console.print(table)\n297: \n298:         status_value = result.get(\"status\", \"\")\n299:         if status_value in [\"not_published\", \"error\"]:\n300:             if status_value == \"not_published\":\n301:                 console.print(f\"\\n[yellow]Agent has not been published. Run 'publish' first.[/yellow]\")\n302:             else:\n303:                 console.print(f\"\\n[red]Error: {result.get('error', 'Unknown error')}[/red]\")\n304:             raise typer.Exit(1)\n305:     except Exception as e:\n306:         _handle_error(e, \"status\", verbose)\n\n(End of file - total 306 lines)\n</content>","metadata":{"preview":"import json\nimport logging\nimpo