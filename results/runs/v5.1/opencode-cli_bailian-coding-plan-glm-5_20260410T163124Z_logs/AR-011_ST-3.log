rror(\"token is not valid\")\n52: \t}\n53: \n54: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n55: \tif !ok {\n56: \t\tt.Fatal(\"claims are not MapClaims\")\n57: \t}\n58: \n59: \tif mapClaims[\"iss\"] != \"agentcube-router\" {\n60: \t\tt.Errorf(\"unexpected issuer: %v\", mapClaims[\"iss\"])\n61: \t}\n62: \n63: \tif mapClaims[\"session_id\"] != \"test-session\" {\n64: \t\tt.Errorf(\"unexpected session_id: %v\", mapClaims[\"session_id\"])\n65: \t}\n66: }\n67: \n68: func TestJWTManagerTokenExpiration(t *testing.T) {\n69: \tjwtMgr, err := NewJWTManager()\n70: \tif err != nil {\n71: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n72: \t}\n73: \n74: \ttokenStr, err := jwtMgr.GenerateToken(map[string]interface{}{})\n75: \tif err != nil {\n76: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n77: \t}\n78: \n79: \ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n80: \t\treturn jwtMgr.publicKey, nil\n81: \t})\n82: \n83: \tif err != nil {\n84: \t\tt.Fatalf(\"failed to parse token: %v\", err)\n85: \t}\n86: \n87: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n88: \tif !ok {\n89: \t\tt.Fatal(\"claims are not MapClaims\")\n90: \t}\n91: \n92: \texp, ok := mapClaims[\"exp\"].(float64)\n93: \tif !ok {\n94: \t\tt.Fatal(\"exp claim is not float64\")\n95: \t}\n96: \n97: \tnow := time.Now().Unix()\n98: \texpectedExp := now + int64(jwtExpiration.Seconds())\n99: \n100: \tif int64(exp) < now {\n101: \t\tt.Error(\"token is already expired\")\n102: \t}\n103: \n104: \tif int64(exp) > expectedExp+5 || int64(exp) < expectedExp-5 {\n105: \t\tt.Errorf(\"expiration time is not approximately 5 minutes: exp=%d, expected=%d\", int64(exp), expectedExp)\n106: \t}\n107: }\n108: \n109: func TestJWTManagerGetPublicKey(t *testing.T) {\n110: \tjwtMgr, err := NewJWTManager()\n111: \tif err != nil {\n112: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n113: \t}\n114: \n115: \tpubKey := jwtMgr.GetPublicKey()\n116: \tif pubKey == nil {\n117: \t\tt.Error(\"GetPublicKey returned nil\")\n118: \t}\n119: \n120: \tif pubKey.Size() != 2048/8 {\n121: \t\tt.Errorf(\"unexpected key size: %d\", pubKey.Size())\n122: \t}\n123: }\n124: \n125: func TestEncodePrivateKeyPEM(t *testing.T) {\n126: \tjwtMgr, err := NewJWTManager()\n127: \tif err != nil {\n128: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n129: \t}\n130: \n131: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n132: \tif pemData == nil {\n133: \t\tt.Fatal(\"encodePrivateKeyPEM returned nil\")\n134: \t}\n135: \n136: \tif !contains(string(pemData), \"RSA PRIVATE KEY\") {\n137: \t\tt.Errorf(\"PEM data does not contain 'RSA PRIVATE KEY'\")\n138: \t}\n139: }\n140: \n141: func TestEncodePublicKeyPEM(t *testing.T) {\n142: \tjwtMgr, err := NewJWTManager()\n143: \tif err != nil {\n144: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n145: \t}\n146: \n147: \tpemData := encodePublicKeyPEM(jwtMgr.publicKey)\n148: \tif pemData == nil {\n149: \t\tt.Fatal(\"encodePublicKeyPEM returned nil\")\n150: \t}\n151: \n152: \tif !contains(string(pemData), \"PUBLIC KEY\") {\n153: \t\tt.Errorf(\"PEM data does not contain 'PUBLIC KEY'\")\n154: \t}\n155: }\n156: \n157: func TestLoadPrivateKeyPEM(t *testing.T) {\n158: \tjwtMgr, err := NewJWTManager()\n159: \tif err != nil {\n160: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n161: \t}\n162: \n163: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n164: \tloadedKey, err := loadPrivateKeyPEM(pemData)\n165: \tif err != nil {\n166: \t\tt.Fatalf(\"failed to load private key: %v\", err)\n167: \t}\n168: \n169: \tif loadedKey.N.Cmp(jwtMgr.privateKey.N) != 0 {\n170: \t\tt.Error(\"loaded key does not match original key\")\n171: \t}\n172: }\n173: \n174: func TestLoadPrivateKeyPEMInvalid(t *testing.T) {\n175: \t_, err := loadPrivateKeyPEM([]byte(\"invalid pem data\"))\n176: \tif err == nil {\n177: \t\tt.Error(\"expected error for invalid PEM data\")\n178: \t}\n179: }\n180: \n181: func contains(s, substr string) bool {\n182: \treturn len(s) > 0 && len(substr) > 0 && len(s) >= len(substr)\n183: }\n\n(End of file - total 183 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nfunc TestNewJWTManager(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\tif err != nil {\n\t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n\t}\n\tif jwtMgr.privateKey == nil {\n\t\tt.Error(\"privateKey is nil\")\n\t}\n\tif jwtMgr.publicKey == nil {\n\t\tt.Error(\"publicKey is nil\")\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go","time":{"start":1775852456070,"end":1775852456096}}}}
{"type":"tool_use","timestamp":1775852456099,"sessionID":"ses_286f28ce6ffep8ntWwTGOpmVoB","part":{"id":"prt_d790dffc5001TYBg3InLPMDzxK","messageID":"msg_d790deae2001d3df67BFaew1HS","sessionID":"ses_286f28ce6ffep8ntWwTGOpmVoB","type":"tool","tool":"read","callID":"toolu_tool-c661b852c7254c1f8b22b7d75e9ade65","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"net/http\"\n6: \t\"net/url\"\n7: \t\"strings\"\n8: \n9: \t\"github.com/gin-gonic/gin\"\n10: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n11: )\n12: \n13: func newReverseProxy(target *url.URL, jwt string, sessionID string) *ReverseProxyWrapper {\n14: \tdirector := func(req *http.Request) {\n15: \t\tpath := req.URL.Path\n16: \t\tif path != \"\" && path[0] != '/' {\n17: \t\t\tpath = \"/\" + path\n18: \t\t}\n19: \n20: \t\treq.URL.Scheme = target.Scheme\n21: \t\treq.URL.Host = target.Host\n22: \t\treq.URL.Path = path\n23: \t\treq.URL.RawPath = \"\"\n24: \t\treq.Host = target.Host\n25: \n26: \t\treq.Header.Set(\"X-Forwarded-Host\", req.Header.Get(\"Host\"))\n27: \n28: \t\tproto := \"http\"\n29: \t\tif req.TLS != nil {\n30: \t\t\tproto = \"https\"\n31: \t\t}\n32: \t\treq.Header.Set(\"X-Forwarded-Proto\", proto)\n33: \n34: \t\texistingXFF := req.Header.Get(\"X-Forwarded-For\")\n35: \t\tclientIP := req.RemoteAddr\n36: \t\tif existingXFF != \"\" {\n37: \t\t\tclientIP = existingXFF + \",\" + clientIP\n38: \t\t}\n39: \t\treq.Header.Set(\"X-Forwarded-For\", clientIP)\n40: \n41: \t\tif jwt != \"\" {\n42: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+jwt)\n43: \t\t}\n44: \t}\n45: \n46: \tmodifyResponse := func(resp *http.Response) error {\n47: \t\tresp.Header.Set(\"x-agentcube-session-id\", sessionID)\n48: \t\treturn nil\n49: \t}\n50: \n51: \terrorHandler := func(resp http.ResponseWriter, req *http.Request, err error) {\n52: \t\terrMsg := err.Error()\n53: \t\tvar statusCode int\n54: \t\tvar message string\n55: \n56: \t\tif strings.Contains(errMsg, \"connection refused\") {\n57: \t\t\tstatusCode = http.StatusBadGateway\n58: \t\t\tmessage = \"sandbox unreachable\"\n59: \t\t} else if strings.Contains(errMsg, \"timeout\") {\n60: \t\t\tstatusCode = http.StatusGatewayTimeout\n61: \t\t\tmessage = \"sandbox timeout\"\n62: \t\t} else {\n63: \t\t\tstatusCode = http.StatusBadGateway\n64: \t\t\tmessage = \"sandbox unreachable\"\n65: \t\t}\n66: \n67: \t\tresp.Header().Set(\"Content-Type\", \"application/json\")\n68: \t\tresp.WriteHeader(statusCode)\n69: \t\tjson.NewEncoder(resp).Encode(gin.H{\"error\": message})\n70: \t}\n71: \n72: \treturn &ReverseProxyWrapper{\n73: \t\tdirector:       director,\n74: \t\tmodifyResponse: modifyResponse,\n75: \t\terrorHandler:   errorHandler,\n76: \t}\n77: }\n78: \n79: type ReverseProxyWrapper struct {\n80: \tdirector       func(*http.Request)\n81: \tmodifyResponse func(*http.Response) error\n82: \terrorHandler   func(http.ResponseWriter, *http.Request, error)\n83: }\n84: \n85: func (rpw *ReverseProxyWrapper) Director(req *http.Request) {\n86: \trpw.director(req)\n87: }\n88: \n89: func (rpw *ReverseProxyWrapper) ModifyResponse(resp *http.Response) error {\n90: \treturn rpw.modifyResponse(resp)\n91: }\n92: \n93: func (rpw *ReverseProxyWrapper) ErrorHandler(resp http.ResponseWriter, req *http.Request, err error) {\n94: \trpw.errorHandler(resp, req, err)\n95: }\n96: \n97: func selectEntryPoint(entryPoints []types.SandboxEntryPoint, invocationPath string) *types.SandboxEntryPoint {\n98: \tif len(entryPoints) == 0 {\n99: \t\treturn nil\n100: \t}\n101: \n102: \tfor _, ep := range entryPoints {\n103: \t\tif strings.HasPrefix(invocationPath, ep.Path) {\n104: \t\t\treturn &ep\n105: \t\t}\n106: \t}\n107: \n108: \treturn &entryPoints[0]\n109: }\n110: \n111: func buildTargetURL(ep *types.SandboxEntryPoint) (*url.URL, error) {\n112: \tendpoint := ep.Endpoint\n113: \tif ep.Protocol != \"\" && !strings.Contains(endpoint, \"://\") {\n114: \t\tendpoint = strings.ToLower(ep.Protocol) + \"://\" + endpoint\n115: \t}\n116: \treturn url.Parse(endpoint)\n117: }\n\n(End of file - total 117 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/url\"\n\t\"strings\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc newReverseProxy(target *url.URL, jwt string, sessionID string) *ReverseProxyWrapper {\n\tdirector := func(req *http.Request) {\n\t\tpath := req.URL.Path\n\t\tif path != \"\" && path[0] != '/' {\n\t\t\tpath = \"/\" + path\n\t\t}\n\n\t\treq.URL.Scheme = target.Scheme","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/reverse_proxy.go","time":{"start":1775852456067,"end":1775852456098}}}}
