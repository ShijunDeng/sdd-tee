\"invalid token\"})\n111: \t\t\tc.Abort()\n112: \t\t\treturn\n113: \t\t}\n114: \n115: \t\thttp.MaxBytesReader(c.Writer, c.Request.Body, MaxBodySize)\n116: \t\tc.Next()\n117: \t}\n118: }\n119: \n120: func (a *AuthManager) SetPublicKey(key *rsa.PublicKey) {\n121: \ta.mutex.Lock()\n122: \ta.publicKey = key\n123: \ta.mutex.Unlock()\n124: }\n125: \n126: func (a *AuthManager) GetPublicKey() *rsa.PublicKey {\n127: \ta.mutex.RLock()\n128: \tdefer a.mutex.RUnlock()\n129: \treturn a.publicKey\n130: }\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nconst (\n\tPublicKeyEnvVar = \"PICOD_AUTH_PUBLIC_KEY\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/auth.go","time":{"start":1775862141929,"end":1775862141951}}}}
