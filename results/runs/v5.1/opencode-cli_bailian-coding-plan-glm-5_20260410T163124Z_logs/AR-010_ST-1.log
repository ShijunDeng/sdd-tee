n57: }\n58: \n59: func (e *SandboxTimeoutError) Message() string {\n60: \treturn \"sandbox timeout\"\n61: }\n62: \n63: type JWTSigningError struct {\n64: \tErr error\n65: }\n66: \n67: func (e *JWTSigningError) Error() string {\n68: \treturn \"jwt signing failed: \" + e.Err.Error()\n69: }\n70: \n71: func (e *JWTSigningError) Status() int {\n72: \treturn 500\n73: }\n74: \n75: func (e *JWTSigningError) Code() string {\n76: \treturn \"JWT_SIGNING_FAILED\"\n77: }\n78: \n79: func (e *JWTSigningError) Message() string {\n80: \treturn \"jwt signing failed\"\n81: }\n82: \n83: type ServerOverloadedError struct{}\n84: \n85: func (e *ServerOverloadedError) Error() string {\n86: \treturn \"server overloaded\"\n87: }\n88: \n89: func (e *ServerOverloadedError) Status() int {\n90: \treturn 429\n91: }\n92: \n93: func (e *ServerOverloadedError) Code() string {\n94: \treturn \"SERVER_OVERLOADED\"\n95: }\n96: \n97: func (e *ServerOverloadedError) Message() string {\n98: \treturn \"server overloaded, please try again later\"\n99: }\n100: \n101: type NoEntryPointError struct {\n102: \tSandboxID string\n103: }\n104: \n105: func (e *NoEntryPointError) Error() string {\n106: \treturn \"no entry point for sandbox: \" + e.SandboxID\n107: }\n108: \n109: func (e *NoEntryPointError) Status() int {\n110: \treturn 404\n111: }\n112: \n113: func (e *NoEntryPointError) Code() string {\n114: \treturn \"NO_ENTRY_POINT\"\n115: }\n116: \n117: func (e *NoEntryPointError) Message() string {\n118: \treturn \"no entry point configured\"\n119: }\n120: \n121: type WorkloadManagerError struct {\n122: \tStatusCode int\n123: \tMsg        string\n124: }\n125: \n126: func (e *WorkloadManagerError) Error() string {\n127: \treturn e.Msg\n128: }\n129: \n130: func (e *WorkloadManagerError) Status() int {\n131: \treturn e.StatusCode\n132: }\n133: \n134: func (e *WorkloadManagerError) Code() string {\n135: \treturn \"WORKLOAD_MANAGER_ERROR\"\n136: }\n137: \n138: func (e *WorkloadManagerError) Message() string {\n139: \treturn e.Msg\n140: }\n\n(End of file - total 140 lines)\n</content>","metadata":{"preview":"package router\n\ntype SessionNotFoundError struct {\n\tSessionID string\n}\n\nfunc (e *SessionNotFoundError) Error() string {\n\treturn \"session not found: \" + e.SessionID\n}\n\nfunc (e *SessionNotFoundError) Status() int {\n\treturn 404\n}\n\nfunc (e *SessionNotFoundError) Code() string {\n\treturn \"SESSION_NOT_FOUND\"\n}\n\nfunc (e *SessionNotFoundError) Message() string {\n\treturn \"session not found\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/errors.go","time":{"start":1775850642046,"end":1775850642066}}}}
{"type":"tool_use","timestamp":1775850642070,"sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","part":{"id":"prt_d78f25a5a001yJI1VJc6I2gHIO","messageID":"msg_d78f23f8d001XuK80J0uIoiSjK","sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","type":"tool","tool":"read","callID":"toolu_tool-e6cd562665ea469c8426e2c981c9ed72","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-009/proposal.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-009/proposal.md</path>\n<type>file</type>\n<content>\n1: # AR-009 — Router HTTP 反向代理核心 Proposal\n2: \n3: ## Purpose\n4: \n5: Implement the HTTP reverse proxy core for the AgentCube Router component. This provides session-aware routing that:\n6: \n7: 1. **Session Resolution**: Reads session ID from request header `x-agentcube-session-id`, creates new sandboxes via Workload Manager when missing\n8: 2. **Reverse Proxy**: Forwards HTTP requests to sandbox pod endpoints using `httputil.ReverseProxy`\n9: 3. **JWT Authentication**: Generates RS256-signed JWT tokens for `Sandbox` and `SandboxClaim` kinds\n10: 4. **Activity Tracking**: Updates session last-activity timestamps in the store for idle timeout detection\n11: 5. **Concurrency Control**: Limits concurrent requests via semaphore middleware to prevent overload\n12: 6. **Health Endpoints**: Exposes `/health/live` and `/health/ready` for Kubernetes probes\n13: \n14: ## Scope\n15: \n16: ### In Scope\n17: \n18: | Deliverable | Description |\n19: |-------------|-------------|\n20: | `pkg/router/server.go` | HTTP Server with Gin engine, route registration, lifecycle management |\n21: | `pkg/router/config.go` | Config struct (Port, EnableTLS, TLSCert, TLSKey, MaxConcurrentRequests, Debug) |\n22: | `pkg/router/session_manager.go` | SessionManager interface, manager struct with workload manager client |\n23: | `pkg/router/reverse_proxy.go` | Reverse proxy with custom Director, ModifyResponse, ErrorHandler |\n24: | `pkg/router/jwt.go` | JWTManager with RSA key generation, token signing, K8s Secret persistence |\n25: | `pkg/router/handlers.go` | `/health/live`, `/health/ready`, `/v1/...invocations/*path` handlers |\n26: | `pkg/router/middleware.go` | Concurrency limit middleware using buffered channel semaphore |\n27: | `pkg/router/errors.go` | Error types: SessionNotFoundError, SandboxUnreachableError, TimeoutError |\n28: | `pkg/router/server_test.go` | Server construction, route registration, TLS, health endpoints tests |\n29: | `pkg/router/session_manager_test.go` | Session resolution, workload manager create, error mapping tests |\n30: | `pkg/router/reverse_proxy_test.go` | Proxy director, forwarding headers, path normalization tests |\n31: | `pkg/router/jwt_test.go` | JWT generation, RS256 signing, secret persistence tests |\n32: \n33: ### Key Components\n34: \n35: ```\n36: pkg/router/\n37: ├── Server (server.go)\n38: │   ├── Config struct (Port, TLS, MaxConcurrentRequests, Debug)\n39: │   ├── gin.Engine setup with mode (Debug/Release)\n40: │   ├── Route registration (health, invocation routes)\n41: │   ├── http.Server with h2c, ReadTimeout 30s, IdleTimeout 90s\n42: │   ├── Start(ctx) with graceful shutdown (10s deadline)\n43: │   └── Dependencies: SessionManager, Store, JWTManager, http.Transport\n44: │\n45: ├── SessionManager (session_manager.go)\n46: │   ├── Interface: GetSandboxBySession(ctx, sessionID, namespace, name, kind)\n47: │   ├── manager struct with storeClient, workloadMgrAddr, httpClient\n48: │   ├── NewSessionManager: reads WORKLOAD_MANAGER_URL (required)\n49: │   ├── createSandbox: POST to Workload Manager with optional K8s SA token\n50: │   └── HTTP client: Timeout 2m, MaxIdleConnsPerHost 100, HTTP2 config\n51: │\n52: ├── Reverse Proxy (reverse_proxy.go)\n53: │   ├── httputil.NewSingleHostReverseProxy\n54: │   ├── Director: path normalization, Host, forwarding headers, JWT\n55: │   ├── ModifyResponse: x-agentcube-session-id header injection\n56: │   ├── ErrorHandler: connection refused → 502, timeout → 504\n57: │   └── Entry point matching from SandboxInfo.EntryPoints\n58: │\n59: ├── JWT Manager (jwt.go)\n60: │   ├── RSA 2048-bit key generation (PKCS1 private, PKIX public)\n61: │   ├── GenerateToken: exp (5m), iat, iss=\"agentcube-router\", custom claims\n62: │   ├── TryStoreOrLoadJWTKeySecret: K8s Secret persistence/reuse\n63: │   └── RS256 signing with golang-jwt/v5\n64: │\n65: ├── Middleware (middleware.go)\n66: │   ├── concurrencyLimitMiddleware: buffered channel semaphore\n67: │   ├── MaxConcurrentRequests capacity (default 1000 when ≤0)\n68: │   └── 429 response when overloaded: SERVER_OVERLOADED code\n69: │\n70: └── Handlers (handlers.go)\n71:     ├── handleHealthLive: 200 {\"status\":\"alive\"}\n72:     ├── handleHealthReady: 200/503 based on sessionManager nil\n73:     ├── handleInvoke: session resolution → proxy → activity update\n74:     └── Error mapping: APIStatus → appropriate HTTP code\n75: ```\n76: \n77: ### Out of Scope\n78: \n79: - Workload Manager implementation (covered by AR-00x)\n80: - Store implementation (covered by session-store spec)\n81: - Kubernetes Reconciler (AR-007)\n82: - Prometheus metrics export\n83: - Distributed session cache (Redis cluster)\n84: - WebSocket upgrade handling\n85: - Custom retry logic for failed proxies\n86: \n87: ## Impact Analysis\n88: \n89: ### Upstream Dependencies\n90: \n91: | Dependency | Impact |\n92: |------------|--------|\n93: | `pkg/store` | Store interface for session lookup, UpdateSessionLastActivity |\n94: | `pkg/common/types` | SandboxInfo, CreateSandboxRequest/Response, kind constants |\n95: | `pkg/apis/runtime/v1alpha1` | AgentRuntime, CodeInterpreter CR types |\n96: | `client-go` | kubernetes.Interface for JWT Secret management |\n97: | `github.com/gin-gonic/gin` | HTTP framework for routing and middleware |\n98: | `github.com/golang-jwt/jwt/v5` | RS256 JWT signing |\n99: | `golang.org/x/net/http2` | h2c server configuration |\n100: | Workload Manager service | POST `/v1/agent-runtime`, `/v1/code-interpreter` for sandbox creation |\n101: \n102: ### Downstream Consumers\n103: \n104: | Consumer | Usage |\n105: |----------|-------|\n106: | `cmd/router/main.go` | CLI entry point, flag parsing, Server construction |\n107: | Kubernetes Deployment | Router as reverse proxy front-end to sandbox pods |\n108: | SDK/CLI clients | Invocation requests routed through Router |\n109: | `pkg/agentd` (idle cleanup) | Last-activity timestamps for idle detection |\n110: | Kubernetes probes | `/health/live`, `/health/ready` endpoints |\n111: \n112: ### Breaking Change Considerations\n113: \n114: - **Session Header Name**: `x-agentcube-session-id` header is contract; changing breaks all clients\n115: - **JWT Secret Name**: `picod-router-identity` Secret; migration needed if renamed\n116: - **Invocation Route Pattern**: `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` is fixed\n117: - **Response Header**: `x-agentcube-session-id` on proxied responses is client expectation\n118: - **Default Concurrency Limit**: 1000 when `MaxConcurrentRequests ≤ 0`; affects throughput under load\n119: \n120: ## Alternatives Considered\n121: \n122: ### Alternative 1: Envoy Sidecar Proxy\n123: \n124: **Approach**: Deploy Envoy as sidecar to handle routing and load balancing.\n125: \n126: | Aspect | Evaluation |\n127: |--------|------------|\n128: | Pros | Production-grade proxy; rich routing features; observability built-in |\n129: | Cons | Heavy sidecar; no session-aware routing; requires xDS control plane; JWT signing complex |\n130: \n131: **Decision**: Rejected. Session-aware routing requires custom logic that Envoy cannot natively provide. In-process Go reverse proxy offers tighter integration with session management.\n132: \n133: ### Alternative 2: Nginx Ingress with Lua\n134: \n135: **Approach**: Use Nginx Ingress with Lua scripts for session routing and JWT injection.\n136: \n137: | Aspect | Evaluation |\n138: |--------|------------|\n139: | Pros | High performance; widely deployed; Nginx ecosystem |\n140: | Cons | Lua scripting complexity; no native store integration; debugging harder; JWT requires external helper |\n141: \n142: **Decision**: Rejected. Go-based proxy provides native integration with `pkg/store`, `pkg/common/types`, and Kubernetes client-go. Lua-based approach lacks tight coupling needed for session lifecycle.\n143: \n144: ### Alternative 3: API Gateway (Kong/Traefik)\n145: \n146: **Approach**: Use Kong or Traefik as API gateway for routing.\n147: \n148: | Aspect | Evaluation |\n149: |--------|------------|\n150: | Pros | Plugin ecosystem; declarative config; multi-protocol support |\n151: | Cons | External dependency; session store integration via plugin; JWT plugin limitations |\n152: \n153: **Decision**: Rejected. AgentCube requires session-stateful routing with direct store access. External gateway adds operational complexity and latency.\n154: \n155: ### Alternative 4: Custom HTTP Router with FastHTTP\n156: \n157: **Approach**: Use `fasthttp` instead of `net/http` for higher performance.\n158: \n159: | Aspect | Evaluation |\n160: |--------|------------|\n161: | Pros | Lower latency; zero-allocation design; high throughput |\n162: | Cons | Different API from `net/http`; httputil.ReverseProxy incompatible; Gin ecosystem mismatch |\n163: \n164: **Decision**: Rejected. `net/http` compatibility is required for `httputil.ReverseProxy` and Kubernetes client libraries. Gin middleware ecosystem (cors, recovery) is well-supported. Performance targets met with current stack.\n165: \n166: ### Alternative 5: Session-less Direct Routing\n167: \n168: **Approach**: Clients directly invoke sandbox pods without session abstraction.\n169: \n170: | Aspect | Evaluation |\n171: |--------|------------|\n172: | Pros | No session state; simpler architecture |\n173: | Cons | Clients must track pod endpoints; no idle timeout; no JWT injection; breaks SDK abstraction |\n174: \n175: **Decision**: Rejected. Session abstraction is core to AgentCube design—clients use logical names (namespace/name) while Router handles physical routing (pod IPs) and lifecycle (creation/expiry).\n176: \n177: ## Risks\n178: \n179: | Risk | Mitigation |\n180: |------|------------|\n181: | Sandbox pod unreachable (connection refused) | ErrorHandler maps to 502 `sandbox unreachable` |\n182: | Sandbox timeout during proxy | ErrorHandler maps to 504 `sandbox timeout` |\n183: | JWT signing failure | Respond 500 with `JWT_SIGNING_FAILED` code |\n184: | Workload Manager unavailable | Startup fails if `WORKLOAD_MANAGER_URL` missing; retry logic in session manager |\n185: | Secret creation race (multiple routers) | `AlreadyExists` handled by loading existing secret |\n186: | Concurrency limit exhaustion | 429 with `SERVER_OVERLOADED` code; client retry |\n187: | TLS misconfiguration | Start returns error if cert/key missing when `EnableTLS=true` |\n188: | Session not found in store | 404 with `SessionNotFoundError` |\n189: | Entry points empty | 404 `no entry point found for sandbox` |\n190: | Path normalization missing leading slash | Director prefixes `/` if needed |\n191: \n192: ## Implementation Notes\n193: \n194: 1. **Constants**: `rsaKeySize=2048`, `jwtExpiration=5m`, `IdentitySecretName=\"picod-router-identity\"`\n195: 2. **HTTP2**: `h2c` server with `http2.Server` for non-TLS HTTP/2 support\n196: 3. **Transport**: `IdleConnTimeout=0`, `DisableCompression=false`, shared across all proxies\n197: 4. **Session Manager HTTP Client**: `Timeout=2m`, `MaxIdleConnsPerHost=100`, HTTP2 with `ReadIdleTimeout=30s`, `PingTimeout=15s`\n198: 5. **Workload Manager Auth**: Reads `/var/run/secrets/kubernetes.io/serviceaccount/token` for in-cluster auth\n199: 6. **Environment Variables**: `WORKLOAD_MANAGER_URL` (required), `AGENTCUBE_NAMESPACE` (optional, default=\"default\")\n200: 7. **Last-Activity Updates**: Twice per invoke—after sandbox resolution and after proxy completion\n201: 8. **Graceful Shutdown**: 10s deadline on context cancel\n202: 9. **Route Pattern**: Both GET and POST on invocation routes\n203: \n204: ## References\n205: \n206: - `session-routing/spec.md` - Full requirement specification\n207: - `session-routing/design.md` - Detailed design document\n208: - `pkg/common/types/sandbox.go` - SandboxInfo, CreateSandboxRequest/Response types\n209: - `deployment/client-go.md` - Kubernetes client code reference\n210: - `project.md` - AgentCube architecture overview\n211: - `httputil.ReverseProxy`: https://pkg.go.dev/net/http/httputil#ReverseProxy\n212: - `golang-jwt/v5`: https://github.com/golang-jwt/jwt\n\n(End of file - total 212 lines)\n</content>","metadata":{"preview":"# AR-009 — Router HTTP 反向代理核心 Proposal\n\n## Purpose\n\nImplement the HTTP reverse proxy core for the AgentCube Router component. This provides session-aware routing that:\n\n1. **Session Resolution**: Reads session ID from request header `x-agentcube-session-id`, creates new sandboxes via Workload Manager when missing\n2. **Reverse Proxy**: Forwards HTTP requests to sandbox pod endpoints using `httputil.ReverseProxy`\n3. **JWT Authentication**: Generates RS256-signed JWT tokens for `Sandbox` and `SandboxClaim` kinds\n4. **Activity Tracking**: Updates session last-activity timestamps in the store for idle timeout detection\n5. **Concurrency Control**: Limits concurrent requests via semaphore middleware to prevent overload\n6. **Health Endpoints**: Exposes `/health/live` and `/health/ready` for Kubernetes probes\n\n## Scope\n\n### In Scope\n\n| Deliverable | Description |\n|-------------|-------------|\n| `pkg/router/server.go` | HTTP Server with Gin engine, route registration, lifecycle management |","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-009/proposal.md","time":{"start":1775850642050,"end":1775850642068}}}}
{"type":"tool_use","timestamp":1775850642083,"sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","part":{"id":"prt_d78f2562e001aVuak2M0lVwu6m","messageID":"msg_d78f23f8d001XuK80J0uIoiSjK","sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","type":"tool","tool":"read","callID":"toolu_tool-fb0c85a7f7fb44ffa9a4274e4ec064c3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go</path>\n<type>file</type>\n<content>\n1: package types\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"time\"\n6: )\n7: \n8: const (\n9: \tAgentRuntimeKind    = \"AgentRuntime\"\n10: \tCodeInterpreterKind = \"CodeInterpreter\"\n11: \tSandboxKind         = \"Sandbox\"\n12: \tSandboxClaimKind    = \"SandboxClaim\"\n13: )\n14: \n15: type CreateSandboxRequest struct {\n16: \tKind      string `json:\"kind\"`\n17: \tName      string `json:\"name\"`\n18: \tNamespace string `json:\"namespace\"`\n19: }\n20: \n21: func (r *CreateSandboxRequest) Validate() error {\n22: \tif r.Kind != AgentRuntimeKind && r.Kind != CodeInterpreterKind {\n23: \t\treturn fmt.Errorf(\"kind must be %s or %s\", AgentRuntimeKind, CodeInterpreterKind)\n24: \t}\n25: \tif r.Namespace == \"\" {\n26: \t\treturn fmt.Errorf(\"namespace is required\")\n27: \t}\n28: \tif r.Name == \"\" {\n29: \t\treturn fmt.Errorf(\"name is required\")\n30: \t}\n31: \treturn nil\n32: }\n33: \n34: type CreateSandboxResponse struct {\n35: \tSessionID   string              `json:\"sessionId\"`\n36: \tSandboxID   string              `json:\"sandboxId\"`\n37: \tSandboxName string              `json:\"sandboxName\"`\n38: \tEntryPoints []SandboxEntryPoint `json:\"entryPoints\"`\n39: }\n40: \n41: type SandboxEntryPoint struct {\n42: \tPath     string `json:\"path\"`\n43: \tProtocol string `json:\"protocol\"`\n44: \tEndpoint string `json:\"endpoint\"`\n45: }\n46: \n47: type SandboxInfo struct {\n48: \tKind               string              `json:\"kind\"`\n49: \tSandboxID          string              `json:\"sandboxId\"`\n50: \tSandboxNamespace   string              `json:\"sandboxNamespace\"`\n51: \tSandboxName        string              `json:\"sandboxName\"`\n52: \tName               string              `json:\"name\"`\n53: \tSessionID          string              `json:\"sessionId\"`\n54: \tCreatedAt          time.Time           `json:\"createdAt\"`\n55: \tExpiresAt          time.Time           `json:\"expiresAt\"`\n56: \tStatus             string              `json:\"status\"`\n57: \tEntryPoints        []SandboxEntryPoint `json:\"entryPoints\"`\n58: \tUserToken          string              `json:\"userToken,omitempty\"`\n59: \tServiceAccount     string              `json:\"serviceAccount,omitempty\"`\n60: \tServiceAccountName string              `json:\"serviceAccountName,omitempty\"`\n61: \tLastActivity       time.Time           `json:\"lastActivity,omitempty\"`\n62: }\n\n(End of file - total 62 lines)\n</content>","metadata":{"preview":"package types\n\nimport (\n\t\"fmt\"\n\t\"time\"\n)\n\nconst (\n\tAgentRuntimeKind    = \"AgentRuntime\"\n\tCodeInterpreterKind = \"CodeInterpreter\"\n\tSandboxKind         = \"Sandbox\"\n\tSandboxClaimKind    = \"SandboxClaim\"\n)\n\ntype CreateSandboxRequest struct {\n\tKind      string `json:\"kind\"`\n\tName      string `json:\"name\"`\n\tNamespace string `json:\"namespace\"`\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go","time":{"start":1775850642048,"end":1775850642080}}}}
{"type":"step_finish","timestamp":1775850642112,"sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","part":{"id":"prt_d78f25aa2001GOBbQmuo3E3t70","reason":"tool-calls","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","messageID":"msg_d78f23f8d001XuK80J0uIoiSjK","sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","type":"step-finish","tokens":{"total":28247,"input":3129,"output":218,"reasoning":0,"cache":{"write":0,"read":24900}},"cost":0}}
{"type":"step_start","timestamp":1775850645902,"sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","part":{"id":"prt_d78f2698c001JYR12I5k5nX090","messageID":"msg_d78f25ad8001sytcNiyNZoGrZ5","sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","type":"step-start"}}
{"type":"tool_use","timestamp":1775850650561,"sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","part":{"id":"prt_d78f27b60001t3B65V5CW2cTAJ","messageID":"msg_d78f25ad8001sytcNiyNZoGrZ5","sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","type":"tool","tool":"read","callID":"toolu_tool-be1edeb22d694bf29fe73420206a029c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/session-routing/spec.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/session-routing/spec.md</path>\n<type>file</type>\n<content>\n1: # Session Routing Specification\n2: \n3: ## Purpose\n4: Route HTTP invocation traffic to sandboxes by session: resolve or create sessions via the workload manager, track activity in the store, reverse-proxy to pod endpoints, and sign outbound requests with JWT when targeting sandboxes.\n5: \n6: ## Requirements\n7: \n8: ### Requirement: Session resolution and creation\n9: The system SHALL read session id from request header `x-agentcube-session-id`. When the header is empty, the system SHALL POST to the workload manager to create a sandbox. When non-empty, the system SHALL load `SandboxInfo` from the store by session id.\n10: \n11: #### Scenario: Missing session triggers workload manager create\n12: - **GIVEN** `WORKLOAD_MANAGER_URL` is set and an invocation request has no `x-agentcube-session-id`\n13: - **WHEN** `GetSandboxBySession` runs for `AgentRuntimeKind`\n14: - **THEN** the client POSTs JSON `{\"kind\":\"AgentRuntime\",\"name\":...,\"namespace\":...}` to `{WORKLOAD_MANAGER_URL}/v1/agent-runtime`\n15: \n16: #### Scenario: Unknown session returns not found\n17: - **GIVEN** a non-empty session id not present in store\n18: - **WHEN** the store returns `ErrNotFound`\n19: - **THEN** the error maps to `NewSessionNotFoundError(sessionID)` and the HTTP handler responds using API status (typically 404)\n20: \n21: ### Requirement: Workload manager URL and auth token for creates\n22: The system SHALL require environment variable `WORKLOAD_MANAGER_URL` at session manager construction (non-empty). When the file `/var/run/secrets/kubernetes.io/serviceaccount/token` exists and is readable, the system SHALL attach `Authorization: Bearer <trimmed contents>` to create requests.\n23: \n24: #### Scenario: Missing WORKLOAD_MANAGER_URL fails startup\n25: - **GIVEN** `WORKLOAD_MANAGER_URL` is unset\n26: - **WHEN** `NewSessionManager` is called\n27: - **THEN** it returns error `WORKLOAD_MANAGER_URL environment variable is not set`\n28: \n29: ### Requirement: Create response validation\n30: The system SHALL accept workload manager HTTP 200 with body `CreateSandboxResponse`; SHALL reject with internal error if `sessionId` in body is empty; SHALL build in-memory `SandboxInfo` with `SandboxID`, `Name` (= `sandboxName`), `SessionID`, `EntryPoints` from the response (other fields may be zero).\n31: \n32: #### Scenario: Non-OK from workload manager\n33: - **GIVEN** workload manager returns HTTP 404\n34: - **WHEN** the session manager handles the response\n35: - **THEN** the error is `NewSandboxTemplateNotFoundError(namespace, name, kind)`\n36: \n37: ### Requirement: Reverse proxy to sandbox\n38: The system SHALL determine upstream URL from `SandboxInfo.EntryPoints` by first matching `path` prefix against the invocation path; if none match, SHALL use the first entry point. The system SHALL build URL by prefixing `protocol` (lowercase) and `://` to `endpoint` when protocol is set and endpoint lacks a scheme. The system SHALL use `httputil.NewSingleHostReverseProxy`, shared `http.Transport` on the proxy, and custom `Director` to set path, host, forwarding headers, and optional JWT.\n39: \n40: #### Scenario: No entry points\n41: - **GIVEN** `EntryPoints` is empty\n42: - **WHEN** upstream is determined\n43: - **THEN** the handler responds 404 JSON `{\"error\":\"no entry point found for sandbox\"}`\n44: \n45: ### Requirement: JWT injection for sandbox kinds\n46: For sandbox kinds `Sandbox` and `SandboxClaim`, the system SHALL generate a JWT before proxying and SHALL set `Authorization: Bearer <token>` on the proxied request.\n47: \n48: #### Scenario: Signing failure\n49: - **GIVEN** JWT generation returns an error\n50: - **WHEN** forwarding is attempted\n51: - **THEN** the handler responds 500 with JSON containing `\"code\":\"JWT_SIGNING_FAILED\"` and `\"error\":\"failed to sign request\"`\n52: \n53: ### Requirement: Forwarding headers and response header\n54: The system SHALL set `X-Forwarded-Host` from the incoming request host, `X-Forwarded-Proto` to `https` when TLS is present else `http`, and `X-Forwarded-For` by appending client IP to any existing values. The system SHALL set response header `x-agentcube-session-id` to the resolved session id on all proxied responses.\n55: \n56: #### Scenario: Path normalization\n57: - **GIVEN** the Gin path param is non-empty and lacks a leading slash\n58: - **WHEN** the director runs\n59: - **THEN** the outbound path is prefixed with `/`\n60: \n61: ### Requirement: Proxy error mapping\n62: The system SHALL map proxy errors containing `connection refused` to 502 `{\"error\":\"sandbox unreachable\"}`, containing `timeout` to 504 `{\"error\":\"sandbox timeout\"}`, and other errors to 502 `{\"error\":\"sandbox unreachable\"}`.\n63: \n64: #### Scenario: Downstream connection refused\n65: - **GIVEN** the reverse proxy fails with an error whose message includes `connection refused`\n66: - **WHEN** `ErrorHandler` runs\n67: - **THEN** status is 502 and error text is `sandbox unreachable`\n68: \n69: ### Requirement: Last-activity updates\n70: The system SHALL call `UpdateSessionLastActivity` with `time.Now()` after successfully resolving the sandbox and again after `forwardToSandbox` returns (twice per successful invoke path). Failures SHALL be logged as warnings only.\n71: \n72: #### Scenario: Store update failure does not block proxy\n73: - **GIVEN** `UpdateSessionLastActivity` returns an error\n74: - **WHEN** handling continues\n75: - **THEN** the proxy still runs if sandbox resolution succeeded\n76: \n77: ### Requirement: Health endpoints\n78: The system SHALL expose `GET /health/live` returning 200 `{\"status\":\"alive\"}`. The system SHALL expose `GET /health/ready` returning 200 `{\"status\":\"ready\"}` when session manager is non-nil, else 503 with `status` and `error` fields.\n79: \n80: #### Scenario: Ready depends on session manager\n81: - **GIVEN** `sessionManager` is nil\n82: - **WHEN** `GET /health/ready` is served\n83: - **THEN** status is 503 and body includes `\"error\":\"session manager not available\"`\n84: \n85: ### Requirement: Concurrency limiting\n86: The system SHALL apply a semaphore middleware to `/v1/*` routes with capacity `MaxConcurrentRequests` (default 1000 when config value ≤ 0). When no slot is available, the system SHALL respond 429 JSON `{\"error\":\"server overloaded, please try again later\",\"code\":\"SERVER_OVERLOADED\"}` and abort.\n87: \n88: #### Scenario: Default limit when zero in config\n89: - **GIVEN** `NewServer` receives `MaxConcurrentRequests` 0\n90: - **WHEN** the server is constructed\n91: - **THEN** the effective limit is set to 1000 before route registration\n92: \n93: ### Requirement: Invocation route surface\n94: The system SHALL register GET and POST for `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` and for `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path`, with Gin logger, recovery, and concurrency middleware on the `/v1` group only.\n95: \n96: #### Scenario: Kind passed to session lookup\n97: - **GIVEN** agent-runtime invocation\n98: - **WHEN** `handleInvoke` runs\n99: - **THEN** kind argument is `AgentRuntime` (`types.AgentRuntimeKind`)\n100: \n101: ### Requirement: HTTP server behavior\n102: The system SHALL serve with `h2c` and `http2.Server`, `ReadTimeout` 30s, `IdleTimeout` 90s; on context cancel SHALL shutdown within 10s. Optional TLS SHALL require both cert and key paths.\n103: \n104: #### Scenario: TLS misconfiguration\n105: - **GIVEN** `EnableTLS` true and empty cert path\n106: - **WHEN** `Start` runs\n107: - **THEN** it returns error stating cert/key not provided\n108: \n109: ### Requirement: Identity secret bootstrap for JWT\n110: On server creation the system SHALL construct `JWTManager`, call `TryStoreOrLoadJWTKeySecret`, and fail server creation if that returns error (except in-cluster skip path returns nil when not in cluster).\n111: \n112: #### Scenario: In-cluster secret creation\n113: - **GIVEN** in-cluster config succeeds and secret does not exist\n114: - **WHEN** `TryStoreOrLoadJWTKeySecret` runs\n115: - **THEN** it creates opaque secret `picod-router-identity` in namespace from `AGENTCUBE_NAMESPACE` or `default` with keys `private.pem` and `public.pem`\n\n(End of file - total 115 lines)\n</content>","metadata":{"preview":"# Session Routing Specification\n\n## Purpose\nRoute HTTP invocation traffic to sandboxes by session: resolve or create sessions via the workload manager, track activity in the store, reverse-proxy to pod endpoints, and sign outbound requests with JWT when targeting sandboxes.\n\n## Requirements\n\n### Requirement: Session resolution and creation\nThe system SHALL read session id from request header `x-agentcube-session-id`. When the header is empty, the system SHALL POST to the workload manager to create a sandbox. When non-empty, the system SHALL load `SandboxInfo` from the store by session id.\n\n#### Scenario: Missing session triggers workload manager create\n- **GIVEN** `WORKLOAD_MANAGER_URL` is set and an invocation request has no `x-agentcube-session-id`\n- **WHEN** `GetSandboxBySession` runs for `AgentRuntimeKind`\n- **THEN** the client POSTs JSON `{\"kind\":\"AgentRuntime\",\"name\":...,\"namespace\":...}` to `{WORKLOAD_MANAGER_URL}/v1/agent-runtime`\n\n#### Scenario: Unknown session returns not found\n- **GIVEN** a non-empty session id not present in store\n- **WHEN** the store returns `ErrNotFound`\n- **THEN** the error maps to `NewSessionNotFoundError(sessionID)` and the HTTP handler responds using API status (typically 404)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/session-routing/spec.md","time":{"start":1775850650547,"end":1775850650558}}}}
