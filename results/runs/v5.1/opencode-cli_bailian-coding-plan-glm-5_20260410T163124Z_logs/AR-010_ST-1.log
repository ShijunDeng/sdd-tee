).Unix(),\n55: \t\t\"iat\": now.Unix(),\n56: \t\t\"iss\": \"agentcube-router\",\n57: \t}\n58: \n59: \tfor k, v := range claims {\n60: \t\ttokenClaims[k] = v\n61: \t}\n62: \n63: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n64: \n65: \ttokenString, err := token.SignedString(j.privateKey)\n66: \tif err != nil {\n67: \t\treturn \"\", &JWTSigningError{Err: err}\n68: \t}\n69: \n70: \treturn tokenString, nil\n71: }\n72: \n73: func (j *JWTManager) TryStoreOrLoadJWTKeySecret(ctx context.Context) error {\n74: \tklog.Warningf(\"not in cluster, skipping secret persistence\")\n75: \treturn nil\n76: }\n77: \n78: func encodePrivateKeyPEM(key *rsa.PrivateKey) []byte {\n79: \treturn pem.EncodeToMemory(&pem.Block{\n80: \t\tType:  \"RSA PRIVATE KEY\",\n81: \t\tBytes: x509.MarshalPKCS1PrivateKey(key),\n82: \t})\n83: }\n84: \n85: func encodePublicKeyPEM(key *rsa.PublicKey) []byte {\n86: \tbytes, err := x509.MarshalPKIXPublicKey(key)\n87: \tif err != nil {\n88: \t\treturn nil\n89: \t}\n90: \treturn pem.EncodeToMemory(&pem.Block{\n91: \t\tType:  \"PUBLIC KEY\",\n92: \t\tBytes: bytes,\n93: \t})\n94: }\n95: \n96: func loadPrivateKeyPEM(data []byte) (*rsa.PrivateKey, error) {\n97: \tblock, _ := pem.Decode(data)\n98: \tif block == nil {\n99: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n100: \t}\n101: \n102: \tkey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n103: \tif err != nil {\n104: \t\treturn nil, fmt.Errorf(\"failed to parse private key: %w\", err)\n105: \t}\n106: \n107: \treturn key, nil\n108: }\n109: \n110: func (j *JWTManager) GetPublicKey() *rsa.PublicKey {\n111: \treturn j.publicKey\n112: }\n\n(End of file - total 112 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"k8s.io/klog/v2\"\n)\n\nconst (\n\trsaKeySize         = 2048\n\tjwtExpiration      = 5 * time.Minute\n\tIdentitySecretName = \"picod-router-identity\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt.go","time":{"start":1775850656741,"end":1775850656756}}}}
