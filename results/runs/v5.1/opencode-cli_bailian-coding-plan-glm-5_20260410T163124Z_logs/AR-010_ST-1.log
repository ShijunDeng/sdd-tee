{"type":"tool_use","timestamp":1775850642066,"sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","part":{"id":"prt_d78f24ebd001gJE4im6I3V4Lej","messageID":"msg_d78f23f8d001XuK80J0uIoiSjK","sessionID":"ses_2870e4f8cffeSMpqE9zv7zhDn2","type":"tool","tool":"read","callID":"toolu_tool-8b09182d0e7c4922af0554adccf9b5e0","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/server.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"fmt\"\n6: \t\"net/http\"\n7: \t\"net/http/httputil\"\n8: \t\"time\"\n9: \n10: \t\"github.com/gin-gonic/gin\"\n11: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n12: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n13: )\n14: \n15: type Server struct {\n16: \tconfig         *Config\n17: \tengine         *gin.Engine\n18: \thttpServer     *http.Server\n19: \tsessionManager SessionManager\n20: \tstoreClient    Store\n21: \thttpTransport  *http.Transport\n22: \tjwtManager     *JWTManager\n23: \tlogger         Logger\n24: }\n25: \n26: func NewServer(config *Config, sessionManager SessionManager, storeClient Store, jwtManager *JWTManager, logger Logger) *Server {\n27: \tif config == nil {\n28: \t\tconfig = DefaultConfig()\n29: \t}\n30: \n31: \tif config.MaxConcurrentRequests <= 0 {\n32: \t\tconfig.MaxConcurrentRequests = 1000\n33: \t}\n34: \n35: \tif !config.Debug {\n36: \t\tgin.SetMode(gin.ReleaseMode)\n37: \t} else {\n38: \t\tgin.SetMode(gin.DebugMode)\n39: \t}\n40: \n41: \tengine := gin.New()\n42: \n43: \thttpTransport := &http.Transport{\n44: \t\tMaxIdleConnsPerHost: 100,\n45: \t\tDisableCompression:  false,\n46: \t}\n47: \n48: \thttpServer := &http.Server{\n49: \t\tAddr:        config.Port,\n50: \t\tHandler:     engine,\n51: \t\tReadTimeout: 30 * time.Second,\n52: \t\tIdleTimeout: 90 * time.Second,\n53: \t}\n54: \n55: \ts := &Server{\n56: \t\tconfig:         config,\n57: \t\tengine:         engine,\n58: \t\thttpServer:     httpServer,\n59: \t\tsessionManager: sessionManager,\n60: \t\tstoreClient:    storeClient,\n61: \t\thttpTransport:  httpTransport,\n62: \t\tjwtManager:     jwtManager,\n63: \t\tlogger:         logger,\n64: \t}\n65: \n66: \ts.registerRoutes()\n67: \n68: \treturn s\n69: }\n70: \n71: func (s *Server) registerRoutes() {\n72: \ts.engine.GET(\"/health/live\", s.handleHealthLive)\n73: \ts.engine.GET(\"/health/ready\", s.handleHealthReady)\n74: \n75: \tv1 := s.engine.Group(\"/v1/namespaces/:namespace\")\n76: \tv1.Use(concurrencyLimitMiddleware(s.config.MaxConcurrentRequests))\n77: \tif s.logger != nil {\n78: \t\tv1.Use(loggingMiddleware(s.logger))\n79: \t\tv1.Use(recoveryMiddleware(s.logger))\n80: \t}\n81: \n82: \tv1.GET(\"/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n83: \tv1.POST(\"/agent-runtimes/:name/invocations/*path\", s.handleAgentInvoke)\n84: \n85: \tv1.GET(\"/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n86: \tv1.POST(\"/code-interpreters/:name/invocations/*path\", s.handleCodeInterpreterInvoke)\n87: }\n88: \n89: func (s *Server) handleHealthLive(c *gin.Context) {\n90: \tc.JSON(http.StatusOK, gin.H{\"status\": \"alive\"})\n91: }\n92: \n93: func (s *Server) handleHealthReady(c *gin.Context) {\n94: \tif s.sessionManager == nil {\n95: \t\tc.JSON(http.StatusServiceUnavailable, gin.H{\n96: \t\t\t\"status\": \"not ready\",\n97: \t\t\t\"error\":  \"session manager not available\",\n98: \t\t})\n99: \t\treturn\n100: \t}\n101: \tc.JSON(http.StatusOK, gin.H{\"status\": \"ready\"})\n102: }\n103: \n104: func (s *Server) handleAgentInvoke(c *gin.Context) {\n105: \ts.handleInvoke(c, types.AgentRuntimeKind)\n106: }\n107: \n108: func (s *Server) handleCodeInterpreterInvoke(c *gin.Context) {\n109: \ts.handleInvoke(c, types.CodeInterpreterKind)\n110: }\n111: \n112: func (s *Server) handleInvoke(c *gin.Context, kind string) {\n113: \tnamespace := c.Param(\"namespace\")\n114: \tname := c.Param(\"name\")\n115: \tinvocationPath := c.Param(\"path\")\n116: \n117: \tsessionID := c.GetHeader(\"x-agentcube-session-id\")\n118: \n119: \tctx := c.Request.Context()\n120: \n121: \tsandbox, err := s.sessionManager.GetSandboxBySession(ctx, sessionID, namespace, name, kind)\n122: \tif err != nil {\n123: \t\ts.handleGetSandboxError(c, err)\n124: \t\treturn\n125: \t}\n126: \n127: \tif len(sandbox.EntryPoints) == 0 {\n128: \t\tc.JSON(http.StatusNotFound, gin.H{\n129: \t\t\t\"error\": \"no entry point configured\",\n130: \t\t\t\"code\":  \"NO_ENTRY_POINT\",\n131: \t\t})\n132: \t\treturn\n133: \t}\n134: \n135: \tif err := s.storeClient.UpdateSessionLastActivity(ctx, sandbox.SessionID, time.Now()); err != nil {\n136: \t\ts.logger.Error(\"failed to update session activity\", \"error\", err)\n137: \t}\n138: \n139: \tentryPoint := selectEntryPoint(sandbox.EntryPoints, invocationPath)\n140: \tif entryPoint == nil {\n141: \t\tc.JSON(http.StatusNotFound, gin.H{\n142: \t\t\t\"error\": \"no matching entry point\",\n143: \t\t\t\"code\":  \"NO_ENTRY_POINT\",\n144: \t\t})\n145: \t\treturn\n146: \t}\n147: \n148: \ttarget, err := buildTargetURL(entryPoint)\n149: \tif err != nil {\n150: \t\tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"invalid target endpoint\"})\n151: \t\treturn\n152: \t}\n153: \n154: \tvar jwt string\n155: \tif kind == types.SandboxKind || kind == types.SandboxClaimKind {\n156: \t\tif s.jwtManager != nil {\n157: \t\t\tjwt, err = s.jwtManager.GenerateToken(map[string]interface{}{\n158: \t\t\t\t\"session_id\": sandbox.SessionID,\n159: \t\t\t\t\"sandbox_id\": sandbox.SandboxID,\n160: \t\t\t\t\"namespace\":  sandbox.SandboxNamespace,\n161: \t\t\t\t\"name\":       sandbox.SandboxName,\n162: \t\t\t})\n163: \t\t\tif err != nil {\n164: \t\t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n165: \t\t\t\t\t\"error\": \"jwt signing failed\",\n166: \t\t\t\t\t\"code\":  \"JWT_SIGNING_FAILED\",\n167: \t\t\t\t})\n168: \t\t\t\treturn\n169: \t\t\t}\n170: \t\t}\n171: \t}\n172: \n173: \tproxy := httputil.NewSingleHostReverseProxy(target)\n174: \tproxy.Transport = s.httpTransport\n175: \n176: \trpw := newReverseProxy(target, jwt, sandbox.SessionID)\n177: \tproxy.Director = rpw.Director\n178: \tproxy.ModifyResponse = rpw.ModifyResponse\n179: \tproxy.ErrorHandler = rpw.ErrorHandler\n180: \n181: \tproxy.ServeHTTP(c.Writer, c.Request)\n182: \n183: \tif err := s.storeClient.UpdateSessionLastActivity(ctx, sandbox.SessionID, time.Now()); err != nil {\n184: \t\ts.logger.Error(\"failed to update session activity after proxy\", \"error\", err)\n185: \t}\n186: }\n187: \n188: func (s *Server) handleGetSandboxError(c *gin.Context, err error) {\n189: \tif apierrors.IsNotFound(err) {\n190: \t\tc.JSON(http.StatusNotFound, gin.H{\"error\": err.Error()})\n191: \t\treturn\n192: \t}\n193: \n194: \tif apiStatus, ok := err.(apierrors.APIStatus); ok {\n195: \t\tcode := int(apiStatus.Status().Code)\n196: \t\tif code == 0 {\n197: \t\t\tcode = http.StatusInternalServerError\n198: \t\t}\n199: \t\tmsg := apiStatus.Status().Message\n200: \t\tif msg == \"\" {\n201: \t\t\tmsg = err.Error()\n202: \t\t}\n203: \t\tif code == http.StatusInternalServerError {\n204: \t\t\tmsg = \"internal server error\"\n205: \t\t}\n206: \t\tc.JSON(code, gin.H{\"error\": msg})\n207: \t\treturn\n208: \t}\n209: \n210: \tif routerErr, ok := err.(APIStatus); ok {\n211: \t\tc.JSON(routerErr.Status(), gin.H{\n212: \t\t\t\"error\": routerErr.Message(),\n213: \t\t\t\"code\":  routerErr.Code(),\n214: \t\t})\n215: \t\treturn\n216: \t}\n217: \n218: \tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"internal server error\"})\n219: }\n220: \n221: func (s *Server) Start(ctx context.Context) error {\n222: \tif s.config.EnableTLS {\n223: \t\tif s.config.TLSCert == \"\" || s.config.TLSKey == \"\" {\n224: \t\t\treturn fmt.Errorf(\"TLS cert and key are required when EnableTLS is true\")\n225: \t\t}\n226: \t\tgo s.waitForShutdown(ctx)\n227: \t\treturn s.httpServer.ListenAndServeTLS(s.config.TLSCert, s.config.TLSKey)\n228: \t}\n229: \n230: \tgo s.waitForShutdown(ctx)\n231: \treturn s.httpServer.ListenAndServe()\n232: }\n233: \n234: func (s *Server) waitForShutdown(ctx context.Context) {\n235: \t<-ctx.Done()\n236: \n237: \tshutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n238: \tdefer cancel()\n239: \n240: \ts.httpServer.Shutdown(shutdownCtx)\n241: }\n242: \n243: func (s *Server) Stop() error {\n244: \tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n245: \tdefer cancel()\n246: \treturn s.httpServer.Shutdown(ctx)\n247: }\n248: \n249: func (s *Server) GetEngine() *gin.Engine {\n250: \treturn s.engine\n251: }\n\n(End of file - total 251 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httputil\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n)\n\ntype Server struct {\n\tconfig         *Config\n\tengine         *gin.Engine\n\thttpServer     *http.Server\n\tsessionManager SessionManager\n\tstoreClient    Store","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/server.go","time":{"start":1775850642041,"end":1775850642064}}}}
