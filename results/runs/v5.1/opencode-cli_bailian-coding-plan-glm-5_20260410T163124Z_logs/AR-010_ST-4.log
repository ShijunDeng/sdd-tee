{"type":"tool_use","timestamp":1775851136328,"sessionID":"ses_28706504dffefyDEcLGmtXHL4i","part":{"id":"prt_d78f9e504001Ic8Vg8QwXRom5u","messageID":"msg_d78f9cc65001zZFi6Vj49iunks","sessionID":"ses_28706504dffefyDEcLGmtXHL4i","type":"tool","tool":"read","callID":"toolu_tool-498084e17b664455a936b83027612f25","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"encoding/json\"\n7: \t\"fmt\"\n8: \t\"io\"\n9: \t\"net/http\"\n10: \t\"os\"\n11: \t\"strings\"\n12: \t\"time\"\n13: \n14: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n15: \t\"golang.org/x/net/http2\"\n16: )\n17: \n18: type sessionManager struct {\n19: \tstoreClient     Store\n20: \tworkloadMgrAddr string\n21: \thttpClient      *http.Client\n22: }\n23: \n24: func NewSessionManager(storeClient Store) (SessionManager, error) {\n25: \tworkloadMgrAddr := os.Getenv(\"WORKLOAD_MANAGER_URL\")\n26: \tif workloadMgrAddr == \"\" {\n27: \t\treturn nil, fmt.Errorf(\"WORKLOAD_MANAGER_URL environment variable is required\")\n28: \t}\n29: \n30: \ttransport := &http.Transport{\n31: \t\tMaxIdleConnsPerHost: 100,\n32: \t\tDisableCompression:  false,\n33: \t}\n34: \n35: \thttp2.ConfigureTransport(transport)\n36: \n37: \thttpClient := &http.Client{\n38: \t\tTimeout:   2 * time.Minute,\n39: \t\tTransport: transport,\n40: \t}\n41: \n42: \treturn &sessionManager{\n43: \t\tstoreClient:     storeClient,\n44: \t\tworkloadMgrAddr: workloadMgrAddr,\n45: \t\thttpClient:      httpClient,\n46: \t}, nil\n47: }\n48: \n49: func (m *sessionManager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n50: \tif sessionID == \"\" {\n51: \t\treturn m.createSandbox(ctx, namespace, name, kind)\n52: \t}\n53: \n54: \tsandbox, err := m.storeClient.GetSandboxBySessionID(ctx, sessionID)\n55: \tif err != nil {\n56: \t\treturn nil, &SessionNotFoundError{SessionID: sessionID}\n57: \t}\n58: \n59: \treturn sandbox, nil\n60: }\n61: \n62: func (m *sessionManager) createSandbox(ctx context.Context, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n63: \treqBody := types.CreateSandboxRequest{\n64: \t\tKind:      kind,\n65: \t\tName:      name,\n66: \t\tNamespace: namespace,\n67: \t}\n68: \n69: \tif err := reqBody.Validate(); err != nil {\n70: \t\treturn nil, err\n71: \t}\n72: \n73: \tvar endpoint string\n74: \tswitch kind {\n75: \tcase types.AgentRuntimeKind:\n76: \t\tendpoint = m.workloadMgrAddr + \"/v1/agent-runtime\"\n77: \tcase types.CodeInterpreterKind:\n78: \t\tendpoint = m.workloadMgrAddr + \"/v1/code-interpreter\"\n79: \tdefault:\n80: \t\treturn nil, fmt.Errorf(\"unsupported kind: %s\", kind)\n81: \t}\n82: \n83: \tbodyBytes, err := json.Marshal(reqBody)\n84: \tif err != nil {\n85: \t\treturn nil, fmt.Errorf(\"failed to marshal request: %w\", err)\n86: \t}\n87: \n88: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(bodyBytes))\n89: \tif err != nil {\n90: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n91: \t}\n92: \n93: \treq.Header.Set(\"Content-Type\", \"application/json\")\n94: \n95: \tsaToken, err := readServiceAccountToken()\n96: \tif err == nil && saToken != \"\" {\n97: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+saToken)\n98: \t}\n99: \n100: \tresp, err := m.httpClient.Do(req)\n101: \tif err != nil {\n102: \t\treturn nil, &WorkloadManagerError{\n103: \t\t\tStatusCode: http.StatusInternalServerError,\n104: \t\t\tMsg:        fmt.Sprintf(\"failed to connect to workload manager: %v\", err),\n105: \t\t}\n106: \t}\n107: \tdefer resp.Body.Close()\n108: \n109: \trespBody, err := io.ReadAll(resp.Body)\n110: \tif err != nil {\n111: \t\treturn nil, fmt.Errorf(\"failed to read response: %w\", err)\n112: \t}\n113: \n114: \tif resp.StatusCode != http.StatusOK {\n115: \t\treturn nil, &WorkloadManagerError{\n116: \t\t\tStatusCode: resp.StatusCode,\n117: \t\t\tMsg:        string(respBody),\n118: \t\t}\n119: \t}\n120: \n121: \tvar createResp types.CreateSandboxResponse\n122: \tif err := json.Unmarshal(respBody, &createResp); err != nil {\n123: \t\treturn nil, fmt.Errorf(\"failed to parse response: %w\", err)\n124: \t}\n125: \n126: \tif createResp.SessionID == \"\" {\n127: \t\treturn nil, fmt.Errorf(\"empty sessionId in response\")\n128: \t}\n129: \n130: \tsandbox := &types.SandboxInfo{\n131: \t\tKind:             kind,\n132: \t\tSandboxID:        createResp.SandboxID,\n133: \t\tSandboxNamespace: IdentityNamespace,\n134: \t\tSandboxName:      createResp.SandboxName,\n135: \t\tName:             name,\n136: \t\tSessionID:        createResp.SessionID,\n137: \t\tCreatedAt:        time.Now(),\n138: \t\tExpiresAt:        time.Now().Add(30 * time.Minute),\n139: \t\tStatus:           \"Running\",\n140: \t\tEntryPoints:      createResp.EntryPoints,\n141: \t}\n142: \n143: \tif err := m.storeClient.StoreSandbox(ctx, sandbox); err != nil {\n144: \t\treturn nil, fmt.Errorf(\"failed to store sandbox: %w\", err)\n145: \t}\n146: \n147: \treturn sandbox, nil\n148: }\n149: \n150: func readServiceAccountToken() (string, error) {\n151: \ttokenPath := \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n152: \tdata, err := os.ReadFile(tokenPath)\n153: \tif err != nil {\n154: \t\treturn \"\", err\n155: \t}\n156: \treturn strings.TrimSpace(string(data)), nil\n157: }\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"golang.org/x/net/http2\"\n)\n\ntype sessionManager struct {\n\tstoreClient     Store\n\tworkloadMgrAddr string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager.go","time":{"start":1775851136294,"end":1775851136325}}}}
