 {\n94: \t\tt.Errorf(\"unexpected code: %s\", err.Code())\n95: \t}\n96: \tif err.Message() != \"no entry point configured\" {\n97: \t\tt.Errorf(\"unexpected message: %s\", err.Message())\n98: \t}\n99: }\n100: \n101: func TestWorkloadManagerError(t *testing.T) {\n102: \terr := &WorkloadManagerError{StatusCode: 500, Msg: \"test message\"}\n103: \tif err.Error() != \"test message\" {\n104: \t\tt.Errorf(\"unexpected error message: %s\", err.Error())\n105: \t}\n106: \tif err.Status() != 500 {\n107: \t\tt.Errorf(\"unexpected status: %d\", err.Status())\n108: \t}\n109: \tif err.Code() != \"WORKLOAD_MANAGER_ERROR\" {\n110: \t\tt.Errorf(\"unexpected code: %s\", err.Code())\n111: \t}\n112: \tif err.Message() != \"test message\" {\n113: \t\tt.Errorf(\"unexpected message: %s\", err.Message())\n114: \t}\n115: }\n116: \n117: func TestAPIStatusInterface(t *testing.T) {\n118: \terrors := []APIStatus{\n119: \t\t&SessionNotFoundError{SessionID: \"test\"},\n120: \t\t&SandboxUnreachableError{SandboxID: \"test\"},\n121: \t\t&SandboxTimeoutError{SandboxID: \"test\"},\n122: \t\t&JWTSigningError{Err: nil},\n123: \t\t&ServerOverloadedError{},\n124: \t\t&NoEntryPointError{SandboxID: \"test\"},\n125: \t\t&WorkloadManagerError{StatusCode: 500, Msg: \"test\"},\n126: \t}\n127: \n128: \tfor _, err := range errors {\n129: \t\tif err.Status() == 0 {\n130: \t\t\tt.Errorf(\"Status() returned 0 for %T\", err)\n131: \t\t}\n132: \t\tif err.Code() == \"\" {\n133: \t\t\tt.Errorf(\"Code() returned empty string for %T\", err)\n134: \t\t}\n135: \t\tif err.Message() == \"\" {\n136: \t\t\tt.Errorf(\"Message() returned empty string for %T\", err)\n137: \t\t}\n138: \t}\n139: }\n\n(End of file - total 139 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"testing\"\n)\n\nfunc TestSessionNotFoundError(t *testing.T) {\n\terr := &SessionNotFoundError{SessionID: \"test-session\"}\n\tif err.Error() != \"session not found: test-session\" {\n\t\tt.Errorf(\"unexpected error message: %s\", err.Erro