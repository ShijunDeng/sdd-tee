\n51: \t}\n52: \tif server.config.Port != \":8080\" {\n53: \t\tt.Errorf(\"expected default port, got: %s\", server.config.Port)\n54: \t}\n55: }\n56: \n57: func TestNewServerNilSessionManager(t *testing.T) {\n58: \tgin.SetMode(gin.TestMode)\n59: \n60: \tconfig := DefaultConfig()\n61: \tmockLogger := &MockLogger{}\n62: \tmockStore := &MockStore{}\n63: \tjwtMgr, _ := NewJWTManager()\n64: \n65: \tserver := NewServer(config, nil, mockStore, jwtMgr, mockLogger)\n66: \n67: \tif server.sessionManager != nil {\n68: \t\tt.Error(\"expected nil sessionManager\")\n69: \t}\n70: }\n71: \n72: func TestNewServerMaxConcurrentRequests(t *testing.T) {\n73: \tgin.SetMode(gin.TestMode)\n74: \n75: \tconfig := &Config{\n76: \t\tPort:                  \":8080\",\n77: \t\tMaxConcurrentRequests: 0,\n78: \t}\n79: \n80: \tmockLogger := &MockLogger{}\n81: \tmockStore := &MockStore{}\n82: \tmockSM := &mockSessionManager{}\n83: \tjwtMgr, _ := NewJWTManager()\n84: \n85: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n86: \n87: \tif server.config.MaxConcurrentRequests != 1000 {\n88: \t\tt.Errorf(\"expected default 1000, got: %d\", server.config.MaxConcurrentRequests)\n89: \t}\n90: }\n91: \n92: func TestServerHandleHealthLive(t *testing.T) {\n93: \tgin.SetMode(gin.TestMode)\n94: \n95: \tconfig := DefaultConfig()\n96: \tmockLogger := &MockLogger{}\n97: \tmockStore := &MockStore{}\n98: \tmockSM := &mockSessionManager{}\n99: \tjwtMgr, _ := NewJWTManager()\n100: \n101: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n102: \n103: \treq := httptest.NewRequest(http.MethodGet, \"/health/live\", nil)\n104: \tw := httptest.NewRecorder()\n105: \n106: \tserver.engine.ServeHTTP(w, req)\n107: \n108: \tif w.Code != http.StatusOK {\n109: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n110: \t}\n111: \n112: \tvar resp map[string]string\n113: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n114: \tif resp[\"status\"] != \"alive\" {\n115: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n116: \t}\n117: }\n118: \n119: func TestServerHandleHealthReady(t *testing.T) {\n120: \tgin.SetMode(gin.TestMode)\n121: \n122: \tconfig := DefaultConfig()\n123: \tmockLogger := &MockLogger{}\n124: \tmockStore := &MockStore{}\n125: \tmockSM := &mockSessionManager{}\n126: \tjwtMgr, _ := NewJWTManager()\n127: \n128: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n129: \n130: \treq := httptest.NewRequest(http.MethodGet, \"/health/ready\", nil)\n131: \tw := httptest.NewRecorder()\n132: \n133: \tserver.engine.ServeHTTP(w, req)\n134: \n135: \tif w.Code != http.StatusOK {\n136: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n137: \t}\n138: \n139: \tvar resp map[string]string\n140: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n141: \tif resp[\"status\"] != \"ready\" {\n142: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n143: \t}\n144: }\n145: \n146: func TestServerHandleHealthReadyNoSessionManager(t *testing.T) {\n147: \tgin.SetMode(gin.TestMode)\n148: \n149: \tconfig := DefaultConfig()\n150: \tmockLogger := &MockLogger{}\n151: \tmockStore := &MockStore{}\n152: \tjwtMgr, _ := NewJWTManager()\n153: \n154: \tserver := NewServer(config, nil, mockStore, jwtMgr, mockLogger)\n155: \n156: \treq := httptest.NewRequest(http.MethodGet, \"/health/ready\", nil)\n157: \tw := httptest.NewRecorder()\n158: \n159: \tserver.engine.ServeHTTP(w, req)\n160: \n161: \tif w.Code != http.StatusServiceUnavailable {\n162: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n163: \t}\n164: \n165: \tvar resp map[string]string\n166: \tjson.Unmarshal(w.Body.Bytes(), &resp)\n167: \tif resp[\"status\"] != \"not ready\" {\n168: \t\tt.Errorf(\"unexpected status: %s\", resp[\"status\"])\n169: \t}\n170: }\n171: \n172: func TestServerRoutesRegistered(t *testing.T) {\n173: \tgin.SetMode(gin.TestMode)\n174: \n175: \tconfig := DefaultConfig()\n176: \tmockLogger := &MockLogger{}\n177: \tmockStore := &MockStore{}\n178: \tmockSM := &mockSessionManager{}\n179: \tjwtMgr, _ := NewJWTManager()\n180: \n181: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n182: \n183: \troutes := server.engine.Routes()\n184: \n185: \texpectedRoutes := []string{\n186: \t\t\"/health/live\",\n187: \t\t\"/health/ready\",\n188: \t\t\"/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path\",\n189: \t\t\"/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path\",\n190: \t}\n191: \n192: \tfor _, expected := range expectedRoutes {\n193: \t\tfound := false\n194: \t\tfor _, route := range routes {\n195: \t\t\tif route.Path == expected {\n196: \t\t\t\tfound = true\n197: \t\t\t\tbreak\n198: \t\t\t}\n199: \t\t}\n200: \t\tif !found {\n201: \t\t\tt.Errorf(\"route not found: %s\", expected)\n202: \t\t}\n203: \t}\n204: }\n205: \n206: func TestServerStop(t *testing.T) {\n207: \tgin.SetMode(gin.TestMode)\n208: \n209: \tconfig := &Config{Port: \":0\"}\n210: \tmockLogger := &MockLogger{}\n211: \tmockStore := &MockStore{}\n212: \tmockSM := &mockSessionManager{}\n213: \tjwtMgr, _ := NewJWTManager()\n214: \n215: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n216: \n217: \tctx, cancel := context.WithCancel(context.Background())\n218: \tgo func() {\n219: \t\ttime.Sleep(50 * time.Millisecond)\n220: \t\tcancel()\n221: \t}()\n222: \n223: \tgo server.Start(ctx)\n224: \n225: \terr := server.Stop()\n226: \tif err != nil {\n227: \t\tt.Errorf(\"unexpected error: %v\", err)\n228: \t}\n229: }\n230: \n231: func TestServerGracefulShutdown(t *testing.T) {\n232: \tgin.SetMode(gin.TestMode)\n233: \n234: \tconfig := &Config{Port: \":0\"}\n235: \tmockLogger := &MockLogger{}\n236: \tmockStore := &MockStore{}\n237: \tmockSM := &mockSessionManager{}\n238: \tjwtMgr, _ := NewJWTManager()\n239: \n240: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n241: \n242: \tctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)\n243: \tdefer cancel()\n244: \n245: \tgo server.Start(ctx)\n246: \n247: \ttime.Sleep(50 * time.Millisecond)\n248: \n249: \terr := server.Stop()\n250: \tif err != nil {\n251: \t\tt.Logf(\"stop error (expected on already shutdown): %v\", err)\n252: \t}\n253: }\n254: \n255: func TestServerGetEngine(t *testing.T) {\n256: \tgin.SetMode(gin.TestMode)\n257: \n258: \tconfig := DefaultConfig()\n259: \tmockLogger := &MockLogger{}\n260: \tmockStore := &MockStore{}\n261: \tmockSM := &mockSessionManager{}\n262: \tjwtMgr, _ := NewJWTManager()\n263: \n264: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n265: \n266: \tengine := server.GetEngine()\n267: \tif engine == nil {\n268: \t\tt.Error(\"expected engine to be returned\")\n269: \t}\n270: }\n271: \n272: func TestServerTLSRequired(t *testing.T) {\n273: \tgin.SetMode(gin.TestMode)\n274: \n275: \tconfig := &Config{\n276: \t\tPort:      \":8080\",\n277: \t\tEnableTLS: true,\n278: \t\tTLSCert:   \"\",\n279: \t\tTLSKey:    \"\",\n280: \t}\n281: \n282: \tmockLogger := &MockLogger{}\n283: \tmockStore := &MockStore{}\n284: \tmockSM := &mockSessionManager{}\n285: \tjwtMgr, _ := NewJWTManager()\n286: \n287: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n288: \n289: \tctx := context.Background()\n290: \terr := server.Start(ctx)\n291: \tif err == nil {\n292: \t\tt.Error(\"expected error when TLS cert/key are missing\")\n293: \t}\n294: }\n295: \n296: func TestServerHandleAgentInvoke(t *testing.T) {\n297: \tgin.SetMode(gin.TestMode)\n298: \n299: \tconfig := DefaultConfig()\n300: \tmockLogger := &MockLogger{}\n301: \tmockStore := &MockStore{\n302: \t\tGetSandboxBySessionIDFunc: func(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n303: \t\t\treturn &types.SandboxInfo{\n304: \t\t\t\tSessionID: \"test-session\",\n305: \t\t\t\tSandboxID: \"test-sandbox\",\n306: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n307: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n308: \t\t\t\t},\n309: \t\t\t}, nil\n310: \t\t},\n311: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n312: \t\t\treturn nil\n313: \t\t},\n314: \t}\n315: \tmockSM := &mockSessionManager{\n316: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n317: \t\t\treturn &types.SandboxInfo{\n318: \t\t\t\tSessionID: \"test-session\",\n319: \t\t\t\tSandboxID: \"test-sandbox\",\n320: \t\t\t\tKind:      types.AgentRuntimeKind,\n321: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n322: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n323: \t\t\t\t},\n324: \t\t\t}, nil\n325: \t\t},\n326: \t}\n327: \tjwtMgr, _ := NewJWTManager()\n328: \n329: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n330: \n331: \treq := httptest.NewRequest(http.MethodGet, \"/v1/namespaces/default/agent-runtimes/test-runtime/invocations/api/test\", nil)\n332: \treq.Header.Set(\"x-agentcube-session-id\", \"test-session\")\n333: \tw := httptest.NewRecorder()\n334: \n335: \tserver.engine.ServeHTTP(w, req)\n336: }\n337: \n338: func TestServerHandleCodeInterpreterInvoke(t *testing.T) {\n339: \tgin.SetMode(gin.TestMode)\n340: \n341: \tconfig := DefaultConfig()\n342: \tmockLogger := &MockLogger{}\n343: \tmockStore := &MockStore{\n344: \t\tUpdateSessionLastActivityFunc: func(ctx context.Context, sessionID string, at time.Time) error {\n345: \t\t\treturn nil\n346: \t\t},\n347: \t}\n348: \tmockSM := &mockSessionManager{\n349: \t\tgetFunc: func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n350: \t\t\treturn &types.SandboxInfo{\n351: \t\t\t\tSessionID: \"ci-session\",\n352: \t\t\t\tSandboxID: \"ci-sandbox\",\n353: \t\t\t\tKind:      types.CodeInterpreterKind,\n354: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n355: \t\t\t\t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n356: \t\t\t\t},\n357: \t\t\t}, nil\n358: \t\t},\n359: \t}\n360: \tjwtMgr, _ := NewJWTManager()\n361: \n362: \tserver := NewServer(config, mockSM, mockStore, jwtMgr, mockLogger)\n363: \n364: \treq := httptest.NewRequest(http.MethodPost, \"/v1/namespaces/default/code-interpreters/test-ci/invocations/execute/code\", nil)\n365: \treq.Header.Set(\"x-agentcube-session-id\", \"ci-session\")\n366: \tw := httptest.NewRecorder()\n367: \n368: \tserver.engine.ServeHTTP(w, req)\n369: }\n370: \n371: type mockSessionManager struct {\n372: \tgetFunc func(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error)\n373: }\n374: \n375: func (m *mockSessionManager) GetSandboxBySession(ctx context.Context, sessionID, namespace, name, kind string) (*types.SandboxInfo, error) {\n376: \tif m.getFunc != nil {\n377: \t\treturn m.getFunc(ctx, sessionID, namespace, name, kind)\n378: \t}\n379: \treturn nil, nil\n380: }\n\n(End of file - total 380 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestNewServer(t *testing.T) {\n\tgin.SetMode(gin.TestMode)\n\n\tconfig := DefaultConfig()\n\tconfig.Debug = true\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/server_test.go","time":{"start":1775851192047,"end":1775851192063}}}}
{"type":"tool_use","timestamp":1775851192067,"sessionID":"ses_28706504dffefyDEcLGmtXHL4i","part":{"id":"prt_d78fabb8e001qMPsHszeAlBX0V","messageID":"msg_d78faa2ba001V7wMAz4Sit9kNA","sessionID":"ses_28706504dffefyDEcLGmtXHL4i","type":"tool","tool":"read","callID":"toolu_tool-cfa4107043c74bcbaf5e32c8d7d75c9b","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"net/http/httptest\"\n6: \t\"sync\"\n7: \t\"testing\"\n8: \t\"time\"\n9: \n10: \t\"github.com/gin-gonic/gin\"\n11: )\n12: \n13: type MockLogger struct {\n14: \tInfoCalls    []string\n15: \tErrorCalls   []string\n16: \tWarningCalls []string\n17: }\n18: \n19: func (m *MockLogger) Info(msg string, keysAndValues ...any) {\n20: \tm.InfoCalls = append(m.InfoCalls, msg)\n21: }\n22: \n23: func (m *MockLogger) Error(msg string, keysAndValues ...any) {\n24: \tm.ErrorCalls = append(m.ErrorCalls, msg)\n25: }\n26: \n27: func (m *MockLogger) Warning(msg string, keysAndValues ...any) {\n28: \tm.WarningCalls = append(m.WarningCalls, msg)\n29: }\n30: \n31: func TestConcurrencyLimitMiddlewareUnderLimit(t *testing.T) {\n32: \tgin.SetMode(gin.TestMode)\n33: \n34: \trouter := gin.New()\n35: \trouter.Use(concurrencyLimitMiddleware(10))\n36: \trouter.GET(\"/test\", func(c *gin.Context) {\n37: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n38: \t})\n39: \n40: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n41: \tw := httptest.NewRecorder()\n42: \n43: \trouter.ServeHTTP(w, req)\n44: \n45: \tif w.Code != http.StatusOK {\n46: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n47: \t}\n48: }\n49: \n50: func TestConcurrencyLimitMiddlewareOverLimit(t *testing.T) {\n51: \tgin.SetMode(gin.TestMode)\n52: \n53: \trouter := gin.New()\n54: \trouter.Use(concurrencyLimitMiddleware(1))\n55: \trouter.GET(\"/test\", func(c *gin.Context) {\n56: \t\ttime.Sleep(100 * time.Millisecond)\n57: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n58: \t})\n59: \n60: \tvar wg sync.WaitGroup\n61: \tresults := make([]int, 3)\n62: \n63: \tfor i := 0; i < 3; i++ {\n64: \t\twg.Add(1)\n65: \t\tgo func(idx int) {\n66: \t\t\tdefer wg.Done()\n67: \t\t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n68: \t\t\tw := httptest.NewRecorder()\n69: \t\t\trouter.ServeHTTP(w, req)\n70: \t\t\tresults[idx] = w.Code\n71: \t\t}(i)\n72: \t}\n73: \n74: \twg.Wait()\n75: \n76: \thasOverloaded := false\n77: \thasOk := false\n78: \tfor _, code := range results {\n79: \t\tif code == http.StatusTooManyRequests {\n80: \t\t\thasOverloaded = true\n81: \t\t}\n82: \t\tif code == http.StatusOK {\n83: \t\t\thasOk = true\n84: \t\t}\n85: \t}\n86: \n87: \tif !hasOverloaded {\n88: \t\tt.Error(\"expected at least one 429 response\")\n89: \t}\n90: \tif !hasOk {\n91: \t\tt.Error(\"expected at least one 200 response\")\n92: \t}\n93: }\n94: \n95: func TestConcurrencyLimitMiddlewareDefault(t *testing.T) {\n96: \tgin.SetMode(gin.TestMode)\n97: \n98: \trouter := gin.New()\n99: \trouter.Use(concurrencyLimitMiddleware(0))\n100: \trouter.GET(\"/test\", func(c *gin.Context) {\n101: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n102: \t})\n103: \n104: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n105: \tw := httptest.NewRecorder()\n106: \n107: \trouter.ServeHTTP(w, req)\n108: \n109: \tif w.Code != http.StatusOK {\n110: \t\tt.Errorf(\"unexpected status code with default limit: %d\", w.Code)\n111: \t}\n112: }\n113: \n114: func TestConcurrencyLimitMiddlewareNegative(t *testing.T) {\n115: \tgin.SetMode(gin.TestMode)\n116: \n117: \trouter := gin.New()\n118: \trouter.Use(concurrencyLimitMiddleware(-5))\n119: \trouter.GET(\"/test\", func(c *gin.Context) {\n120: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n121: \t})\n122: \n123: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n124: \tw := httptest.NewRecorder()\n125: \n126: \trouter.ServeHTTP(w, req)\n127: \n128: \tif w.Code != http.StatusOK {\n129: \t\tt.Errorf(\"unexpected status code with negative limit: %d\", w.Code)\n130: \t}\n131: }\n132: \n133: func TestLoggingMiddleware(t *testing.T) {\n134: \tgin.SetMode(gin.TestMode)\n135: \n136: \tlogger := &MockLogger{}\n137: \trouter := gin.New()\n138: \trouter.Use(loggingMiddleware(logger))\n139: \trouter.GET(\"/test\", func(c *gin.Context) {\n140: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n141: \t})\n142: \n143: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n144: \tw := httptest.NewRecorder()\n145: \n146: \trouter.ServeHTTP(w, req)\n147: \n148: \tif len(logger.InfoCalls) != 1 {\n149: \t\tt.Errorf(\"expected 1 info log call, got %d\", len(logger.InfoCalls))\n150: \t}\n151: \tif logger.InfoCalls[0] != \"request\" {\n152: \t\tt.Errorf(\"unexpected log message: %s\", logger.InfoCalls[0])\n153: \t}\n154: }\n155: \n156: func TestLoggingMiddlewareDifferentStatus(t *testing.T) {\n157: \tgin.SetMode(gin.TestMode)\n158: \n159: \tlogger := &MockLogger{}\n160: \trouter := gin.New()\n161: \trouter.Use(loggingMiddleware(logger))\n162: \trouter.GET(\"/test\", func(c *gin.Context) {\n163: \t\tc.JSON(http.StatusInternalServerError, gin.H{\"error\": \"internal\"})\n164: \t})\n165: \n166: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n167: \tw := httptest.NewRecorder()\n168: \n169: \trouter.ServeHTTP(w, req)\n170: \n171: \tif len(logger.InfoCalls) != 1 {\n172: \t\tt.Errorf(\"expected 1 info log call, got %d\", len(logger.InfoCalls))\n173: \t}\n174: }\n175: \n176: func TestRecoveryMiddleware(t *testing.T) {\n177: \tgin.SetMode(gin.TestMode)\n178: \n179: \tlogger := &MockLogger{}\n180: \trouter := gin.New()\n181: \trouter.Use(recoveryMiddleware(logger))\n182: \trouter.GET(\"/test\", func(c *gin.Context) {\n183: \t\tpanic(\"test panic\")\n184: \t})\n185: \n186: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n187: \tw := httptest.NewRecorder()\n188: \n189: \trouter.ServeHTTP(w, req)\n190: \n191: \tif w.Code != http.StatusInternalServerError {\n192: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n193: \t}\n194: \tif len(logger.ErrorCalls) != 1 {\n195: \t\tt.Errorf(\"expected 1 error log call, got %d\", len(logger.ErrorCalls))\n196: \t}\n197: }\n198: \n199: func TestRecoveryMiddlewareNoPanic(t *testing.T) {\n200: \tgin.SetMode(gin.TestMode)\n201: \n202: \tlogger := &MockLogger{}\n203: \trouter := gin.New()\n204: \trouter.Use(recoveryMiddleware(logger))\n205: \trouter.GET(\"/test\", func(c *gin.Context) {\n206: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n207: \t})\n208: \n209: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n210: \tw := httptest.NewRecorder()\n211: \n212: \trouter.ServeHTTP(w, req)\n213: \n214: \tif w.Code != http.StatusOK {\n215: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n216: \t}\n217: \tif len(logger.ErrorCalls) != 0 {\n218: \t\tt.Errorf(\"expected 0 error log calls, got %d\", len(logger.ErrorCalls))\n219: \t}\n220: }\n221: \n222: func TestConcurrencyMiddleware429ResponseFormat(t *testing.T) {\n223: \tgin.SetMode(gin.TestMode)\n224: \n225: \trouter := gin.New()\n226: \trouter.Use(concurrencyLimitMiddleware(1))\n227: \trouter.GET(\"/test\", func(c *gin.Context) {\n228: \t\ttime.Sleep(50 * time.Millisecond)\n229: \t\tc.JSON(http.StatusOK, gin.H{})\n230: \t})\n231: \n232: \tvar wg sync.WaitGroup\n233: \twg.Add(2)\n234: \n235: \tgo func() {\n236: \t\tdefer wg.Done()\n237: \t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n238: \t\tw := httptest.NewRecorder()\n239: \t\trouter.ServeHTTP(w, req)\n240: \t}()\n241: \n242: \ttime.Sleep(10 * time.Millisecond)\n243: \n244: \tgo func() {\n245: \t\tdefer wg.Done()\n246: \t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n247: \t\tw := httptest.NewRecorder()\n248: \t\trouter.ServeHTTP(w, req)\n249: \t\tif w.Code == http.StatusTooManyRequests {\n250: \t\t\tbody := w.Body.String()\n251: \t\t\tif !containsStr(body, \"SERVER_OVERLOADED\") {\n252: \t\t\t\tt.Errorf(\"expected SERVER_OVERLOADED in response body\")\n253: \t\t\t}\n254: \t\t}\n255: \t}()\n256: \n257: \twg.Wait()\n258: }\n259: \n260: func containsStr(s, substr string) bool {\n261: \tfor i := 0; i <= len(s)-len(substr); i++ {\n262: \t\tif s[i:i+len(substr)] == substr {\n263: \t\t\treturn true\n264: \t\t}\n265: \t}\n266: \treturn false\n267: }\n268: \n269: func TestNilLoggerMiddleware(t *testing.T) {\n270: \tgin.SetMode(gin.TestMode)\n271: \n272: \trouter := gin.New()\n273: \trouter.Use(loggingMiddleware(nil))\n274: \trouter.GET(\"/test\", func(c *gin.Context) {\n275: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n276: \t})\n277: \n278: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n279: \tw := httptest.NewRecorder()\n280: \n281: \trouter.ServeHTTP(w, req)\n282: \n283: \tif w.Code != http.StatusOK {\n284: \t\tt.Errorf(\"unexpected status code with nil logger: %d\", w.Code)\n285: \t}\n286: }\n287: \n288: func TestNilLoggerRecovery(t *testing.T) {\n289: \tgin.SetMode(gin.TestMode)\n290: \n291: \trouter := gin.New()\n292: \trouter.Use(recoveryMiddleware(nil))\n293: \trouter.GET(\"/test\", func(c *gin.Context) {\n294: \t\tpanic(\"test panic\")\n295: \t})\n296: \n297: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n298: \tw := httptest.NewRecorder()\n299: \n300: \trouter.ServeHTTP(w, req)\n301: \n302: \tif w.Code != http.StatusInternalServerError {\n303: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n304: \t}\n305: }\n\n(End of file - total 305 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\ntype MockLogger struct {\n\tInfoCalls    []string\n\tErrorCalls   []string\n\tWarningCalls []string\n}\n\nfunc (m *MockLogger) Info(msg string, keysAndValues ...any) {\n\tm.InfoCalls = append(m.InfoCalls, msg)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware_test.go","time":{"start":1775851192050,"end":1775851192065}}}}
{"type":"tool_use","timestamp":1775851192069,"sessionID":"ses_28706504dffefyDEcLGmtXHL4i","part":{"id":"prt_d78fabea4001yIJrO7q4IrrxPC","messageID":"msg_d78faa2ba001V7wMAz4Sit9kNA","sessionID":"ses_28706504dffefyDEcLGmtXHL4i","type":"tool","tool":"read","callID":"toolu_tool-4fd9b02afd0f418bb2828d9559d2f1c7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"testing\"\n5: \t\"time\"\n6: \n7: \t\"github.com/golang-jwt/jwt/v5\"\n8: )\n9: \n10: func TestNewJWTManager(t *testing.T) {\n11: \tjwtMgr, err := NewJWTManager()\n12: \tif err != nil {\n13: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n14: \t}\n15: \tif jwtMgr.privateKey == nil {\n16: \t\tt.Error(\"privateKey is nil\")\n17: \t}\n18: \tif jwtMgr.publicKey == nil {\n19: \t\tt.Error(\"publicKey is nil\")\n20: \t}\n21: }\n22: \n23: func TestJWTManagerGenerateToken(t *testing.T) {\n24: \tjwtMgr, err := NewJWTManager()\n25: \tif err != nil {\n26: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n27: \t}\n28: \n29: \tclaims := map[string]interface{}{\n30: \t\t\"session_id\": \"test-session\",\n31: \t\t\"sandbox_id\": \"test-sandbox\",\n32: \t}\n33: \n34: \ttokenStr, err := jwtMgr.GenerateToken(claims)\n35: \tif err != nil {\n36: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n37: \t}\n38: \n39: \ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n40: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n41: \t\t\treturn nil, jwt.ErrSignatureInvalid\n42: \t\t}\n43: \t\treturn jwtMgr.publicKey, nil\n44: \t})\n45: \n46: \tif err != nil {\n47: \t\tt.Fatalf(\"failed to parse token: %v\", err)\n48: \t}\n49: \n50: \tif !token.Valid {\n51: \t\tt.Error(\"token is not valid\")\n52: \t}\n53: \n54: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n55: \tif !ok {\n56: \t\tt.Fatal(\"claims are not MapClaims\")\n57: \t}\n58: \n59: \tif mapClaims[\"iss\"] != \"agentcube-router\" {\n60: \t\tt.Errorf(\"unexpected issuer: %v\", mapClaims[\"iss\"])\n61: \t}\n62: \n63: \tif mapClaims[\"session_id\"] != \"test-session\" {\n64: \t\tt.Errorf(\"unexpected session_id: %v\", mapClaims[\"session_id\"])\n65: \t}\n66: }\n67: \n68: func TestJWTManagerTokenExpiration(t *testing.T) {\n69: \tjwtMgr, err := NewJWTManager()\n70: \tif err != nil {\n71: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n72: \t}\n73: \n74: \ttokenStr, err := jwtMgr.GenerateToken(map[string]interface{}{})\n75: \tif err != nil {\n76: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n77: \t}\n78: \n79: \ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n80: \t\treturn jwtMgr.publicKey, nil\n81: \t})\n82: \n83: \tif err != nil {\n84: \t\tt.Fatalf(\"failed to parse token: %v\", err)\n85: \t}\n86: \n87: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n88: \tif !ok {\n89: \t\tt.Fatal(\"claims are not MapClaims\")\n90: \t}\n91: \n92: \texp, ok := mapClaims[\"exp\"].(float64)\n93: \tif !ok {\n94: \t\tt.Fatal(\"exp claim is not float64\")\n95: \t}\n96: \n97: \tnow := time.Now().Unix()\n98: \texpectedExp := now + int64(jwtExpiration.Seconds())\n99: \n100: \tif int64(exp) < now {\n101: \t\tt.Error(\"token is already expired\")\n102: \t}\n103: \n104: \tif int64(exp) > expectedExp+5 || int64(exp) < expectedExp-5 {\n105: \t\tt.Errorf(\"expiration time is not approximately 5 minutes: exp=%d, expected=%d\", int64(exp), expectedExp)\n106: \t}\n107: }\n108: \n109: func TestJWTManagerGetPublicKey(t *testing.T) {\n110: \tjwtMgr, err := NewJWTManager()\n111: \tif err != nil {\n112: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n113: \t}\n114: \n115: \tpubKey := jwtMgr.GetPublicKey()\n116: \tif pubKey == nil {\n117: \t\tt.Error(\"GetPublicKey returned nil\")\n118: \t}\n119: \n120: \tif pubKey.Size() != 2048/8 {\n121: \t\tt.Errorf(\"unexpected key size: %d\", pubKey.Size())\n122: \t}\n123: }\n124: \n125: func TestEncodePrivateKeyPEM(t *testing.T) {\n126: \tjwtMgr, err := NewJWTManager()\n127: \tif err != nil {\n128: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n129: \t}\n130: \n131: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n132: \tif pemData == nil {\n133: \t\tt.Fatal(\"encodePrivateKeyPEM returned nil\")\n134: \t}\n135: \n136: \tif !contains(string(pemData), \"RSA PRIVATE KEY\") {\n137: \t\tt.Errorf(\"PEM data does not contain 'RSA PRIVATE KEY'\")\n138: \t}\n139: }\n140: \n141: func TestEncodePublicKeyPEM(t *testing.T) {\n142: \tjwtMgr, err := NewJWTManager()\n143: \tif err != nil {\n144: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n145: \t}\n146: \n147: \tpemData := encodePublicKeyPEM(jwtMgr.publicKey)\n148: \tif pemData == nil {\n149: \t\tt.Fatal(\"encodePublicKeyPEM returned nil\")\n150: \t}\n151: \n152: \tif !contains(string(pemData), \"PUBLIC KEY\") {\n153: \t\tt.Errorf(\"PEM data does not contain 'PUBLIC KEY'\")\n154: \t}\n155: }\n156: \n157: func TestLoadPrivateKeyPEM(t *testing.T) {\n158: \tjwtMgr, err := NewJWTManager()\n159: \tif err != nil {\n160: \t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n161: \t}\n162: \n163: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n164: \tloadedKey, err := loadPrivateKeyPEM(pemData)\n165: \tif err != nil {\n166: \t\tt.Fatalf(\"failed to load private key: %v\", err)\n167: \t}\n168: \n169: \tif loadedKey.N.Cmp(jwtMgr.privateKey.N) != 0 {\n170: \t\tt.Error(\"loaded key does not match original key\")\n171: \t}\n172: }\n173: \n174: func TestLoadPrivateKeyPEMInvalid(t *testing.T) {\n175: \t_, err := loadPrivateKeyPEM([]byte(\"invalid pem data\"))\n176: \tif err == nil {\n177: \t\tt.Error(\"expected error for invalid PEM data\")\n178: \t}\n179: }\n180: \n181: func contains(s, substr string) bool {\n182: \treturn len(s) > 0 && len(substr) > 0 && len(s) >= len(substr)\n183: }\n\n(End of file - total 183 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n)\n\nfunc TestNewJWTManager(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\tif err != nil {\n\t\tt.Fatalf(\"failed to create JWTManager: %v\", err)\n\t}\n\tif jwtMgr.privateKey == nil {\n\t\tt.Error(\"privateKey is nil\")\n\t}\n\tif jwtMgr.publicKey == nil {\n\t\tt.Error(\"publicKey is nil\")\n\t}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go","time":{"start":1775851192053,"end":1775851192067}}}}
