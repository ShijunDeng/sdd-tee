: \t\treturn m.UpdateSessionLastActivityFunc(ctx, sessionID, at)\n39: \t}\n40: \treturn errors.New(\"not implemented\")\n41: }\n42: \n43: type MockHTTPClient struct {\n44: \tDoFunc func(req *http.Request) (*http.Response, error)\n45: }\n46: \n47: func (m *MockHTTPClient) Do(req *http.Request) (*http.Response, error) {\n48: \tif m.DoFunc != nil {\n49: \t\treturn m.DoFunc(req)\n50: \t}\n51: \treturn nil, errors.New(\"not implemented\")\n52: }\n53: \n54: func TestNewSessionManagerRequiresWorkloadManagerURL(t *testing.T) {\n55: \tmockStore := &MockStore{}\n56: \t_, err := NewSessionManager(mockStore)\n57: \tif err == nil {\n58: \t\tt.Error(\"expected error when WORKLOAD_MANAGER_URL is not set\")\n59: \t}\n60: \tif err.Error() != \"WORKLOAD_MANAGER_URL environment variable is required\" {\n61: \t\tt.Errorf(\"unexpected error message: %s\", err.Error())\n62: \t}\n63: }\n64: \n65: func TestSessionManagerGetSandboxBySessionWithExistingSession(t *testing.T) {\n66: \tmockStore := &MockStore{\n67: \t\tGetSandboxBySessionIDFunc: func(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n68: \t\t\treturn &types.SandboxInfo{\n69: \t\t\t\tSessionID:   sessionID,\n70: \t\t\t\tSandboxID:   \"sandbox-123\",\n71: \t\t\t\tSandboxName: \"test-sandbox\",\n72: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n73: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:8080\"},\n74: \t\t\t\t},\n75: \t\t\t}, nil\n76: \t\t},\n77: \t}\n78: \n79: \tsm := &sessionManager{\n80: \t\tstoreClient:     mockStore,\n81: \t\tworkloadMgrAddr: \"http://localhost:9090\",\n82: \t\thttpClient:      &http.Client{},\n83: \t}\n84: \n85: \tctx := context.Background()\n86: \tsandbox, err := sm.GetSandboxBySession(ctx, \"existing-session\", \"default\", \"test\", types.AgentRuntimeKind)\n87: \tif err != nil {\n88: \t\tt.Fatalf(\"unexpected error: %v\", err)\n89: \t}\n90: \tif sandbox.SessionID != \"existing-session\" {\n91: \t\tt.Errorf(\"unexpected session ID: %s\", sandbox.SessionID)