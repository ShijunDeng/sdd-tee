d}\")\n\n    def _resolve_router_url(self, router_url: Optional[str]) -> str:\n        resolved_url = router_url or os.environ.get(\"ROUTER_URL\")\n        if not resolved_url:\n            raise ValueError(\"Router URL must be provided via argument or ROUTER_URL environment variable\")\n        return resolved_url\n\n    def _init_data_plane(self) -> AgentRuntimeDataPlaneClient:\n        return AgentRuntimeDataPlaneClient(\n            router_url=self.router_url,\n            namespace=self.namespace,\n            agent_name=self.agent_name,\n            timeout=self.timeout,\n            connect_timeout=self.connect_timeout,\n        )\n\n    def __enter__(self) -> \"AgentRuntimeClient\":\n        return self\n\n    def __exit__(self, exc_type: Optional[type], exc_val: Optional[BaseException], exc_tb: Optional[Any]) -> None:\n        self.close()\n\n    def invoke(self, payload: Dict[str, Any], timeout: Optional[float] = None) -> Any:\n        if not self.session_id:\n            raise ValueError(\"AgentRuntime session_id is not initialized\")\n        resp = self.dp_client.invoke(self.session_id, payload, timeout=timeout)\n        return resp.json()\n\n    def close(self) -> None:\n        self.dp_client.close()","additions":1,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/agent_runtime.py","time":{"start":1775881153282,"end":1775881153756}}}}
