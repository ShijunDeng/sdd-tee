.raises(ValueError, match=\"Router URL must be provided via argument or ROUTER_URL environment variable\"):\n            AgentRuntimeClient(\n                agent_name=\"test-agent\",\n            )\n\n\nclass TestRouterURLResolution:\n    def test_router_url_from_env(self):\n        os.environ[\"ROUTER_URL\"] = \"http://router-env.example.com\"\n        client = AgentRuntimeClient(agent_name=\"test-agent\")\n        assert client.router_url == \"http://router-env.example.com\"\n        del os.environ[\"ROUTER_URL\"]\n\n    def test_router_url_explicit(self):\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router-explicit.example.com\",\n        )\n        assert client.router_url == \"http://router-explicit.example.com\"\n\n\nclass TestSessionReuse:\n    @responses.activate\n    def test_session_reuse(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"bootstrap-session\"},\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n            session_id=\"provided-session\",\n        )\n        assert client.session_id == \"provided-session\"\n        assert len(responses.calls) == 0\n\n\nclass TestSessionBootstrap:\n    @responses.activate\n    def test_session_bootstrap(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"bootstrapped-session-123\"},\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n        )\n        assert client.session_id == \"bootstrapped-session-123\"\n\n\nclass TestDataPlaneInit:\n    @responses.activate\n    def test_data_plane_init_success(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session\"},\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n            timeout=60,\n            connect_timeout=10.0,\n        )\n        assert isinstance(client.dp_client, AgentRuntimeDataPlaneClient)\n        assert client.dp_client.router_url == \"http://router.example.com\"\n        assert client.dp_client.namespace == \"default\"\n        assert client.dp_client.agent_name == \"test-agent\"\n        assert client.dp_client.timeout == 60\n        assert client.dp_client.connect_timeout == 10.0\n\n\nclass TestContextManager:\n    @responses.activate\n    def test_context_enter(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session\"},\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n        )\n        with client as ctx_client:\n            assert ctx_client is client\n\n    @responses.activate\n    def test_context_exit_calls_close(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session\"},\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n        )\n        close_mock = Mock()\n        client.close = close_mock\n        with client:\n            pass\n        close_mock.assert_called_once()\n\n    @responses.activate\n    def test_context_exit_on_exception(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session\"},\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n        )\n        close_mock = Mock()\n        client.close = close_mock\n        try:\n            with client:\n                raise RuntimeError(\"Test exception\")\n        except RuntimeError:\n            pass\n        close_mock.assert_called_once()\n\n\nclass TestInvoke:\n    @responses.activate\n    def test_invoke_delegation(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session\"},\n        )\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n            status=200,\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n            session_id=\"test-session\",\n        )\n        result = client.invoke({\"input\": \"test\"})\n        assert result == {\"result\": \"success\"}\n\n    def test_invoke_without_session(self):\n        client = AgentRuntimeClient.__new__(AgentRuntimeClient)\n        client.session_id = None\n        client.dp_client = Mock()\n        with pytest.raises(ValueError, match=\"AgentRuntime session_id is not initialized\"):\n            client.invoke({\"input\": \"test\"})\n\n    @responses.activate\n    def test_invoke_timeout_passthrough(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session\"},\n        )\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n            status=200,\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n            session_id=\"test-session\",\n        )\n        result = client.invoke({\"input\": \"test\"}, timeout=30)\n        assert result == {\"result\": \"success\"}\n        assert len(responses.calls) == 1\n        call = responses.calls[0]\n        assert call.request.timeout == (5.0, 30)\n\n\nclass TestClose:\n    @responses.activate\n    def test_close_closes_data_plane(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session\"},\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n        )\n        close_mock = Mock()\n        client.dp_client.close = close_mock\n        client.close()\n        close_mock.assert_called_once()","after":"import os\nimport pytest\nimport responses\nfrom unittest.mock import Mock, patch, MagicMock\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n\n\nclass TestAgentRuntimeClientInit:\n    def test_init_all_params(self):\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            namespace=\"test-ns\",\n            router_url=\"http://router.example.com\",\n            verbose=True,\n            session_id=\"test-session-123\",\n            timeout=60,\n            connect_timeout=10.0,\n        )\n        assert client.agent_name == \"test-agent\"\n        assert client.namespace == \"test-ns\"\n        assert client.router_url == \"http://router.exam