_token,\n36:         )\n37:         self._session_id: Optional[str] = None\n38:         self._session_created: bool = False\n39:         self._dp_client: Optional[CodeInterpreterDataPlaneClient] = None\n40: \n41:         if session_id:\n42:             self._session_id = session_id\n43:             self._session_created = False\n44:             self._init_data_plane()\n45:         else:\n46:             self._session_id = self._cp_client.create_session(\n47:                 name=self.name,\n48:                 namespace=self.namespace,\n49:                 ttl=self.ttl,\n50:             )\n51:             self._session_created = True\n52:             self._init_data_plane()\n53: \n54:     def _resolve_router_url(self, router_url: Optional[str]) -> str:\n55:         \"\"\"Resolve router URL from argument or environment.\"\"\"\n56:         if router_url:\n57:             return router_url\n58:         url = os.environ.get(\"ROUTER_URL\")\n59:         if url:\n60:             return url\n61:         raise ValueError(\"router_url must be provided via argument or ROUTER_URL environment variable\")\n62: \n63:     def _init_data_plane(self) -> None:\n64:         \"\"\"Initialize the data plane client.\"\"\"\n65:         if self._session_id is None:\n66:             raise RuntimeError(\"session_id must be set before initializing data plane\")\n67:         try:\n68:             self._dp_client = CodeInterpreterDataPlaneClient(\n69:                 session_id=self._session_id,\n70:                 router_url=self.router_url,\n71:                 namespace=self.namespace,\n72:                 cr_name=self.name,\n73:             )\n74:         except Exception as e:\n75:             if self._session_created and self._session_id:\n76:                 self._logger.warning(f\"Data plane init failed, cleaning up session: {e}\")\n77:                 self._cp_client.delete_session(self._session_id)\n78:                 self._session_id = None\n79:             raise\n80: \n81:     def __enter__(self) -> \"CodeInterpreterClient\":\n82:         \"\"\"Enter context manager.\"\"\"\n83:         return self\n84: \n85:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n86:         \"\"\"Exit context manager, calling stop().\"\"\"\n87:         self.stop()\n88: \n89:     def execute_command(\n90:         self,\n91:         command: str,\n92:         timeout: Optional[float] = None,\n93:     ) -> str:\n94:         \"\"\"Execute a command in the code interpreter.\n95: \n96:         Args:\n97:             command: Command to execute.\n98:             timeout: Timeout in seconds.\n99: \n100:         Returns:\n101:             stdout from command execution.\n102:         \"\"\"\n103:         if self._dp_client is None:\n104:             raise RuntimeError(\"Data plane client not initialized\")\n105:         return self._dp_client.execute_command(command, timeout)\n106: \n107:     def run_code(\n108:         self,\n109:         language: str,\n110:         code: str,\n111:         timeout: Optional[float] = None,\n112:     ) -> str:\n113:         \"\"\"Run code in the code interpreter.\n114: \n115:         Args:\n116:             language: Programming language (python, py, python3).\n117:             code: Code content to run.\n118:             timeout: Timeout in seconds.\n119: \n120:         Returns:\n121:             stdout from code execution.\n122:         \"\"\"\n123:         if language not in (\"python\", \"py\", \"python3\"):\n124:             raise ValueError(f\"Unsupported language: {language}. Supported: python, py, python3\")\n125: \n126:         timestamp = datetime.datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n127:         filename = f\"/workspace/code_{timestamp}.py\"\n128: \n129:         self.write_file(code, filename)\n130:         return self.execute_command(f\"python3 {filename}\", timeout)\n131: \n132:     def write_file(self, content: str, remote_path: str) -> None:\n133:         \"\"\"Write content to a file in the code interpreter.\n134: \n135:         Args:\n136:             content: File content.\n137:             remote_path: Path to write to.\n138:         \"\"\"\n139:         if self._dp_client is None:\n140:             raise RuntimeError(\"Data plane client not initialized\")\n141:         self._dp_client.write_file(content, remote_path)\n142: \n143:     def upload_file(self, local_path: str, remote_path: str) -> None:\n144:         \"\"\"Upload a local file to the code interpreter.\n145: \n146:         Args:\n147:             local_path: Local file path.\n148:             remote_path: Remote destination path.\n149:         \"\"\"\n150:         if self._dp_client is None:\n151:             raise RuntimeError(\"Data plane client not initialized\")\n152:         self._dp_client.upload_file(local_path, remote_path)\n153: \n154:     def download_file(self, remote_path: str, local_path: str) -> None:\n155:         \"\"\"Download a file from the code interpreter.\n156: \n157:         Args:\n158:             remote_path: Remote file path.\n159:             local_path: Local destination path.\n160:         \"\"\"\n161:         if self._dp_client is None:\n162:             raise RuntimeError(\"Data plane client not initialized\")\n163:         self._dp_client.download_file(remote_path, local_path)\n164: \n165:     def list_files(self, path: str = \".\") -> Any:\n166:         \"\"\"List files in the code interpreter workspace.\n167: \n168:         Args:\n169:             path: Directory path to list.\n170: \n171:         Returns:\n172:             List of file information.\n173:         \"\"\"\n174:         if self._dp_client is None:\n175:             raise RuntimeError(\"Data plane client not initialized\")\n176:         return self._dp_client.list_files(path)\n177: \n178:     def stop(self) -> None:\n179:         \"\"\"Stop the client, closing connections and deleting session if created.\"\"\"\n180:         if self._dp_client:\n181:             self._dp_client.close()\n182:             self._dp_client = None\n183: \n184:         if self._session_created and self._session_id:\n185:             self._cp_client.delete_session(self._session_id)\n186: \n187:         self._cp_client.close()\n188:         self._session_id = None\n\n(End of file - total 188 lines)\n</content>","metadata":{"preview":"import os\nimport datetime\nimport logging\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcube.utils.log import get_logger\n\n\nclass CodeInterpreterClient:\n    \"\"\"Main client for Code Interpreter sessions with lifecycle management.\"\"\"\n\n    def __init__(\n        self,\n        name: str = \"my-interpreter\",\n        namespace: str = \"default\",\n        ttl: int = 3600,\n        workload_manager_url: Optional[str] = None,\n        router_url: Optional[str] = None,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/code_interpreter.py","time":{"start":1775881144186,"end":1775881144193}}}}
