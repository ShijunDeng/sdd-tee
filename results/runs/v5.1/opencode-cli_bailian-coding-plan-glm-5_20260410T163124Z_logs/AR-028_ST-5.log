d","severity":1,"code":"reportMissingImports","source":"Pyright","codeDescription":{"href":"https://github.com/microsoft/pyright/blob/main/docs/configuration.md#reportMissingImports"}}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/examples/agent_runtime_usage.py":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_agent_runtime_data_plane.py\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_agent_runtime_data_plane.py\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_agent_runtime_data_plane.py\n@@ -24,10 +24,8 @@\n             connect_timeout=10.0,\n         )\n         assert client.timeout == 60\n         assert client.connect_timeout == 10.0\n-        assert client.namespace == \"test-ns\"\n-        assert client.agent_name == \"test-agent\"\n \n \n class TestSessionHeaderConstant:\n     def test_session_header_value(self):\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_agent_runtime_data_plane.py","before":"import pytest\nimport responses\nfrom requests.adapters import HTTPAdapter\n\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n\n\nclass TestDataPlaneClientInit:\n    def test_init_default_timeout(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n\n    def test_init_custom_timeout(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"test-ns\",\n            agent_name=\"test-agent\",\n            timeout=60,\n            connect_timeout=10.0,\n        )\n        assert client.timeout == 60\n        assert client.connect_timeout == 10.0\n        assert client.namespace == \"test-ns\"\n        assert client.agent_name == \"test-agent\"\n\n\nclass TestSessionHeaderConstant:\n    def test_session_header_value(self):\n        assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n\n\nclass TestBaseURLConstruction:\n    def test_base_url_construction(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n        )\n        expected = \"http://router.example.com/v1/namespaces/default/agent-runtimes/my-agent/invocations/\"\n        assert client.base_url == expected\n\n    def test_base_url_with_custom_namespace(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"production\",\n            agent_name=\"prod-agent\",\n        )\n        expected = \"http://router.example.com/v1/namespaces/production/agent-runtimes/prod-agent/invocations/\"\n        assert client.base_url == expected\n\n\nclass TestConnectionPooling:\n    def test_connection_pooling(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n            pool_connections=10,\n            pool_maxsize=10,\n        )\n        http_adapter = client.session.get_adapter(\"http://\")\n        https_adapter = client.session.get_adapter(\"https://\")\n        assert isinstance(http_adapter, HTTPAdapter)\n        assert isinstance(https_adapter, HTTPAdapter)\n\n\nclass TestBootstrapSessionID:\n    @responses.activate\n    def test_bootstrap_success(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session-123\"},\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        session_id = client.bootstrap_session_id()\n        assert session_id == \"test-session-123\"\n\n    @responses.activate\n    def test_bootstrap_missing_header(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        with pytest.raises(ValueError, match=\"Missing required response header: x-agentcube-session-id\"):\n            client.bootstrap_session_id()\n\n\nclass TestInvoke:\n    @responses.activate\n    def test_invoke_with_session(self):\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n            status=200,\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        resp = client.invoke(\"test-session-123\", {\"input\": \"test\"})\n        assert resp.status_code == 200\n        assert resp.json() == {\"result\": \"success\"}\n\n\nclass TestInvokeHeaders:\n    @responses.activate\n    def test_invoke_headers_correctness(self):\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        client.invoke(\"test-session-123\", {\"input\": \"test\"})\n        assert len(responses.calls) == 1\n        call = responses.calls[0]\n        assert call.request.headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n        assert call.request.headers[\"Content-Type\"] == \"application/json\"\n\n\nclass TestInvokeTimeout:\n    @responses.activate\n    def test_invoke_timeout_override(self):\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        client.invoke(\"test-session-123\", {\"input\": \"test\"}, timeout=30)\n        assert len(responses.calls) == 1\n        call = responses.calls[0]\n        assert call.request.timeout == (5.0, 30)\n\n    @responses.activate\n    def test_invoke_timeout_default(self):\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        client.invoke(\"test-session-123\", {\"input\": \"test\"})\n        assert len(responses.calls) == 1\n        call = responses.calls[0]\n        assert call.request.timeout == (5.0, 120)\n\n\nclass TestClose:\n    def test_close(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        client.close()\n        assert client.session is not None","after":"import pytest\nimport responses\nfrom requests.adapters import HTTPAdapter\n\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\n\n\nclass TestDataPlaneClientInit:\n    def test_init_default_timeout(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        assert client.timeout == 120\n        assert client.connect_timeout == 5.0\n\n    def test_init_custom_timeout(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"test-ns\",\n            agent_name=\"test-agent\",\n            timeout=60,\n            connect_timeout=10.0,\n        )\n        assert client.timeout == 60\n        assert client.connect_timeout == 10.0\n\n\nclass TestSessionHeaderConstant:\n    def test_session_header_value(self):\n        assert AgentRuntimeDataPlaneClient.SESSION_HEADER == \"x-agentcube-session-id\"\n\n\nclass TestBaseURLConstruction:\n    def test_base_url_construction(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"my-agent\",\n        )\n        expected = \"http://router.example.com/v1/namespaces/default/agent-runtimes/my-agent/invocations/\"\n        assert client.base_url == expected\n\n    def test_base_url_with_custom_namespace(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"production\",\n            agent_name=\"prod-agent\",\n        )\n        expected = \"http://router.example.com/v1/namespaces/production/agent-runtimes/prod-agent/invocations/\"\n        assert client.base_url == expected\n\n\nclass TestConnectionPooling:\n    def test_connection_pooling(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n            pool_connections=10,\n            pool_maxsize=10,\n        )\n        http_adapter = client.session.get_adapter(\"http://\")\n        https_adapter = client.session.get_adapter(\"https://\")\n        assert isinstance(http_adapter, HTTPAdapter)\n        assert isinstance(https_adapter, HTTPAdapter)\n\n\nclass TestBootstrapSessionID:\n    @responses.activate\n    def test_bootstrap_success(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session-123\"},\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        session_id = client.bootstrap_session_id()\n        assert session_id == \"test-session-123\"\n\n    @responses.activate\n    def test_bootstrap_missing_header(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        with pytest.raises(ValueError, match=\"Missing required response header: x-agentcube-session-id\"):\n            client.bootstrap_session_id()\n\n\nclass TestInvoke:\n    @responses.activate\n    def test_invoke_with_session(self):\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n            status=200,\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        resp = client.invoke(\"test-session-123\", {\"input\": \"test\"})\n        assert resp.status_code == 200\n        assert resp.json() == {\"result\": \"success\"}\n\n\nclass TestInvokeHeaders:\n    @responses.activate\n    def test_invoke_headers_correctness(self):\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        client.invoke(\"test-session-123\", {\"input\": \"test\"})\n        assert len(responses.calls) == 1\n        call = responses.calls[0]\n        assert call.request.headers[\"x-agentcube-session-id\"] == \"test-session-123\"\n        assert call.request.headers[\"Content-Type\"] == \"application/json\"\n\n\nclass TestInvokeTimeout:\n    @responses.activate\n    def test_invoke_timeout_override(self):\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        client.invoke(\"test-session-123\", {\"input\": \"test\"}, timeout=30)\n        assert len(responses.calls) == 1\n        call = responses.calls[0]\n        assert call.request.timeout == (5.0, 30)\n\n    @responses.activate\n    def test_invoke_timeout_default(self):\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n        )\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n            timeout=120,\n            connect_timeout=5.0,\n        )\n        client.invoke(\"test-session-123\", {\"input\": \"test\"})\n        assert len(responses.calls) == 1\n        call = responses.calls[0]\n        assert call.request.timeout == (5.0, 120)\n\n\nclass TestClose:\n    def test_close(self):\n        client = AgentRuntimeDataPlaneClient(\n            router_url=\"http://router.example.com\",\n            namespace=\"default\",\n            agent_name=\"test-agent\",\n        )\n        client.close()\n        assert client.session is not None","additions":0,"deletions":2},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_agent_runtime_data_plane.py","time":{"start":1775881311449,"end":1775881311975}}}}
