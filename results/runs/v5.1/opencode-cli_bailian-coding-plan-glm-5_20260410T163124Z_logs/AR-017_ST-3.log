{"type":"tool_use","timestamp":1775863514993,"sessionID":"ses_28649bb73ffezik2O3LE5WmBge","part":{"id":"prt_d79b6c3ad001ni36JaDkBxfrbX","messageID":"msg_d79b6a307001UT5xV4KFCTBIPv","sessionID":"ses_28649bb73ffezik2O3LE5WmBge","type":"tool","tool":"read","callID":"toolu_tool-2bae9ab66e844ec994d6bfbd42732827","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth_test.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"net/http/httptest\"\n6: \t\"testing\"\n7: \n8: \t\"github.com/gin-gonic/gin\"\n9: \t\"github.com/volcano-sh/agentcube/pkg/router\"\n10: )\n11: \n12: func init() {\n13: \tgin.SetMode(gin.TestMode)\n14: }\n15: \n16: func TestDefaultTokenExtractor(t *testing.T) {\n17: \ttests := []struct {\n18: \t\tname        string\n19: \t\tauthHeader  string\n20: \t\texpectToken string\n21: \t\texpectError bool\n22: \t}{\n23: \t\t{\n24: \t\t\tname:        \"valid bearer token\",\n25: \t\t\tauthHeader:  \"Bearer valid-token\",\n26: \t\t\texpectToken: \"valid-token\",\n27: \t\t\texpectError: false,\n28: \t\t},\n29: \t\t{\n30: \t\t\tname:        \"missing authorization header\",\n31: \t\t\tauthHeader:  \"\",\n32: \t\t\texpectToken: \"\",\n33: \t\t\texpectError: true,\n34: \t\t},\n35: \t\t{\n36: \t\t\tname:        \"missing bearer prefix\",\n37: \t\t\tauthHeader:  \"valid-token\",\n38: \t\t\texpectToken: \"\",\n39: \t\t\texpectError: true,\n40: \t\t},\n41: \t\t{\n42: \t\t\tname:        \"wrong prefix\",\n43: \t\t\tauthHeader:  \"Basic valid-token\",\n44: \t\t\texpectToken: \"\",\n45: \t\t\texpectError: true,\n46: \t\t},\n47: \t\t{\n48: \t\t\tname:        \"empty token\",\n49: \t\t\tauthHeader:  \"Bearer \",\n50: \t\t\texpectToken: \"\",\n51: \t\t\texpectError: true,\n52: \t\t},\n53: \t\t{\n54: \t\t\tname:        \"no space separator\",\n55: \t\t\tauthHeader:  \"BearerValidToken\",\n56: \t\t\texpectToken: \"\",\n57: \t\t\texpectError: true,\n58: \t\t},\n59: \t}\n60: \n61: \tfor _, tt := range tests {\n62: \t\tt.Run(tt.name, func(t *testing.T) {\n63: \t\t\treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n64: \t\t\tif tt.authHeader != \"\" {\n65: \t\t\t\treq.Header.Set(\"Authorization\", tt.authHeader)\n66: \t\t\t}\n67: \n68: \t\t\ttoken, err := DefaultTokenExtractor(req)\n69: \n70: \t\t\tif tt.expectError {\n71: \t\t\t\tif err == nil {\n72: \t\t\t\t\tt.Error(\"expected error, got nil\")\n73: \t\t\t\t}\n74: \t\t\t} else {\n75: \t\t\t\tif err != nil {\n76: \t\t\t\t\tt.Errorf(\"unexpected error: %v\", err)\n77: \t\t\t\t}\n78: \t\t\t\tif token != tt.expectToken {\n79: \t\t\t\t\tt.Errorf(\"expected token %s, got %s\", tt.expectToken, token)\n80: \t\t\t\t}\n81: \t\t\t}\n82: \t\t})\n83: \t}\n84: }\n85: \n86: func TestJWTAuthMiddleware(t *testing.T) {\n87: \tjwtMgr, err := router.NewJWTManager()\n88: \tif err != nil {\n89: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n90: \t}\n91: \n92: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n93: \t\t\"session_id\": \"test-session\",\n94: \t\t\"sandbox_id\": \"test-sandbox\",\n95: \t\t\"namespace\":  \"test-namespace\",\n96: \t\t\"name\":       \"test-name\",\n97: \t})\n98: \tif err != nil {\n99: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n100: \t}\n101: \n102: \trouterTest := gin.New()\n103: \trouterTest.Use(JWTAuthMiddleware(jwtMgr))\n104: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n105: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n106: \t})\n107: \n108: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n109: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n110: \tw := httptest.NewRecorder()\n111: \n112: \trouterTest.ServeHTTP(w, req)\n113: \n114: \tif w.Code != http.StatusOK {\n115: \t\tt.Errorf(\"unexpected status code: %d, body: %s\", w.Code, w.Body.String())\n116: \t}\n117: }\n118: \n119: func TestJWTAuthMiddlewareMissingToken(t *testing.T) {\n120: \tjwtMgr, err := router.NewJWTManager()\n121: \tif err != nil {\n122: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n123: \t}\n124: \n125: \trouterTest := gin.New()\n126: \trouterTest.Use(JWTAuthMiddleware(jwtMgr))\n127: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n128: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n129: \t})\n130: \n131: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n132: \tw := httptest.NewRecorder()\n133: \n134: \trouterTest.ServeHTTP(w, req)\n135: \n136: \tif w.Code != http.StatusUnauthorized {\n137: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusUnauthorized, w.Code)\n138: \t}\n139: }\n140: \n141: func TestJWTAuthMiddlewareInvalidToken(t *testing.T) {\n142: \tjwtMgr, err := router.NewJWTManager()\n143: \tif err != nil {\n144: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n145: \t}\n146: \n147: \trouterTest := gin.New()\n148: \trouterTest.Use(JWTAuthMiddleware(jwtMgr))\n149: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n150: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n151: \t})\n152: \n153: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n154: \treq.Header.Set(\"Authorization\", \"Bearer invalid-token\")\n155: \tw := httptest.NewRecorder()\n156: \n157: \trouterTest.ServeHTTP(w, req)\n158: \n159: \tif w.Code != http.StatusUnauthorized {\n160: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusUnauthorized, w.Code)\n161: \t}\n162: }\n163: \n164: func TestJWTAuthMiddlewareSkipPaths(t *testing.T) {\n165: \tjwtMgr, err := router.NewJWTManager()\n166: \tif err != nil {\n167: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n168: \t}\n169: \n170: \tconfig := &JWTAuthMiddlewareConfig{\n171: \t\tJWTManager: jwtMgr,\n172: \t\tSkipPaths:  []string{\"/health\", \"/metrics\"},\n173: \t}\n174: \n175: \trouterTest := gin.New()\n176: \trouterTest.Use(JWTAuthMiddlewareWithConfig(config))\n177: \trouterTest.GET(\"/health\", func(c *gin.Context) {\n178: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n179: \t})\n180: \trouterTest.GET(\"/metrics\", func(c *gin.Context) {\n181: \t\tc.JSON(http.StatusOK, gin.H{\"metrics\": \"ok\"})\n182: \t})\n183: \trouterTest.GET(\"/protected\", func(c *gin.Context) {\n184: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n185: \t})\n186: \n187: \ttests := []struct {\n188: \t\tpath       string\n189: \t\texpectCode int\n190: \t}{\n191: \t\t{\"/health\", http.StatusOK},\n192: \t\t{\"/metrics\", http.StatusOK},\n193: \t\t{\"/protected\", http.StatusUnauthorized},\n194: \t}\n195: \n196: \tfor _, tt := range tests {\n197: \t\tt.Run(tt.path, func(t *testing.T) {\n198: \t\t\treq := httptest.NewRequest(http.MethodGet, tt.path, nil)\n199: \t\t\tw := httptest.NewRecorder()\n200: \t\t\trouterTest.ServeHTTP(w, req)\n201: \n202: \t\t\tif w.Code != tt.expectCode {\n203: \t\t\t\tt.Errorf(\"path %s: expected status %d, got %d\", tt.path, tt.expectCode, w.Code)\n204: \t\t\t}\n205: \t\t})\n206: \t}\n207: }\n208: \n209: func TestJWTAuthMiddlewareNilManager(t *testing.T) {\n210: \trouterTest := gin.New()\n211: \trouterTest.Use(JWTAuthMiddleware(nil))\n212: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n213: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n214: \t})\n215: \n216: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n217: \tw := httptest.NewRecorder()\n218: \n219: \trouterTest.ServeHTTP(w, req)\n220: \n221: \tif w.Code != http.StatusOK {\n222: \t\tt.Errorf(\"expected status %d with nil manager, got %d\", http.StatusOK, w.Code)\n223: \t}\n224: }\n225: \n226: func TestJWTAuthMiddlewareNilConfig(t *testing.T) {\n227: \trouterTest := gin.New()\n228: \trouterTest.Use(JWTAuthMiddlewareWithConfig(nil))\n229: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n230: \t\tc.JSON(http.StatusOK, gin.H{\"status\": \"ok\"})\n231: \t})\n232: \n233: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n234: \tw := httptest.NewRecorder()\n235: \n236: \trouterTest.ServeHTTP(w, req)\n237: \n238: \tif w.Code != http.StatusOK {\n239: \t\tt.Errorf(\"expected status %d with nil config, got %d\", http.StatusOK, w.Code)\n240: \t}\n241: }\n242: \n243: func TestJWTAuthMiddlewareContextClaims(t *testing.T) {\n244: \tjwtMgr, err := router.NewJWTManager()\n245: \tif err != nil {\n246: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n247: \t}\n248: \n249: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n250: \t\t\"session_id\": \"context-session\",\n251: \t\t\"sandbox_id\": \"context-sandbox\",\n252: \t\t\"namespace\":  \"context-namespace\",\n253: \t\t\"name\":       \"context-name\",\n254: \t})\n255: \tif err != nil {\n256: \t\tt.Fatalf(\"failed to generate token: %v\", err)\n257: \t}\n258: \n259: \trouterTest := gin.New()\n260: \trouterTest.Use(JWTAuthMiddleware(jwtMgr))\n261: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n262: \t\tsessionID := GetSessionIDFromContext(c)\n263: \t\tsandboxID := GetSandboxIDFromContext(c)\n264: \t\tnamespace := GetNamespaceFromContext(c)\n265: \t\tname := GetNameFromContext(c)\n266: \t\tclaims := GetClaimsFromContext(c)\n267: \n268: \t\tc.JSON(http.StatusOK, gin.H{\n269: \t\t\t\"session_id\": sessionID,\n270: \t\t\t\"sandbox_id\": sandboxID,\n271: \t\t\t\"namespace\":  namespace,\n272: \t\t\t\"name\":       name,\n273: \t\t\t\"has_claims\": claims != nil,\n274: \t\t})\n275: \t})\n276: \n277: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n278: \treq.Header.Set(\"Authorization\", \"Bearer \"+token)\n279: \tw := httptest.NewRecorder()\n280: \n281: \trouterTest.ServeHTTP(w, req)\n282: \n283: \tif w.Code != http.StatusOK {\n284: \t\tt.Errorf(\"unexpected status code: %d\", w.Code)\n285: \t}\n286: }\n287: \n288: func TestGetSessionIDFromContextEmpty(t *testing.T) {\n289: \trouterTest := gin.New()\n290: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n291: \t\tsessionID := GetSessionIDFromContext(c)\n292: \t\tif sessionID != \"\" {\n293: \t\t\tt.Errorf(\"expected empty session ID, got %s\", sessionID)\n294: \t\t}\n295: \t\tc.JSON(http.StatusOK, gin.H{})\n296: \t})\n297: \n298: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n299: \tw := httptest.NewRecorder()\n300: \trouterTest.ServeHTTP(w, req)\n301: }\n302: \n303: func TestGetClaimsFromContextEmpty(t *testing.T) {\n304: \trouterTest := gin.New()\n305: \trouterTest.GET(\"/test\", func(c *gin.Context) {\n306: \t\tclaims := GetClaimsFromContext(c)\n307: \t\tif claims != nil {\n308: \t\t\tt.Errorf(\"expected nil claims, got %v\", claims)\n309: \t\t}\n310: \t\tc.JSON(http.StatusOK, gin.H{})\n311: \t})\n312: \n313: \treq := httptest.NewRequest(http.MethodGet, \"/test\", nil)\n314: \tw := httptest.NewRecorder()\n315: \trouterTest.ServeHTTP(w, req)\n316: }\n317: \n318: func TestTokenIssuanceHandler(t *testing.T) {\n319: \tjwtMgr, err := router.NewJWTManager()\n320: \tif err != nil {\n321: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n322: \t}\n323: \n324: \trouterTest := gin.New()\n325: \trouterTest.POST(\"/auth/token\", TokenIssuanceHandler(jwtMgr))\n326: \n327: \treq := httptest.NewRequest(http.MethodPost, \"/auth/token\", nil)\n328: \treq.Header.Set(\"Content-Type\", \"application/json\")\n329: \treq.Body = httptest.NewRequest(http.MethodPost, \"/auth/token\", nil).Body\n330: \tw := httptest.NewRecorder()\n331: \n332: \trouterTest.ServeHTTP(w, req)\n333: \n334: \tif w.Code != http.StatusBadRequest {\n335: \t\tt.Errorf(\"expected status %d for empty body, got %d\", http.StatusBadRequest, w.Code)\n336: \t}\n337: }\n338: \n339: func TestTokenRefreshHandler(t *testing.T) {\n340: \tjwtMgr, err := router.NewJWTManager()\n341: \tif err != nil {\n342: \t\tt.Fatalf(\"failed to create JWT manager: %v\", err)\n343: \t}\n344: \n345: \trouterTest := gin.New()\n346: \trouterTest.POST(\"/auth/refresh\", TokenRefreshHandler(jwtMgr))\n347: \n348: \treq :