n57: }\n58: \n59: func (e *SandboxTimeoutError) Message() string {\n60: \treturn \"sandbox timeout\"\n61: }\n62: \n63: type JWTSigningError struct {\n64: \tErr error\n65: }\n66: \n67: func (e *JWTSigningError) Error() string {\n68: \tif e.Err != nil {\n69: \t\treturn \"jwt signing failed: \" + e.Err.Error()\n70: \t}\n71: \treturn \"jwt signing failed\"\n72: }\n73: \n74: func (e *JWTSigningError) Status() int {\n75: \treturn 500\n76: }\n77: \n78: func (e *JWTSigningError) Code() string {\n79: \treturn \"JWT_SIGNING_FAILED\"\n80: }\n81: \n82: func (e *JWTSigningError) Message() string {\n83: \treturn \"jwt signing failed\"\n84: }\n85: \n86: type JWTValidationError struct {\n87: \tErr error\n88: }\n89: \n90: func (e *JWTValidationError) Error() string {\n91: \tif e.Err != nil {\n92: \t\treturn \"jwt validation failed: \" + e.Err.Error()\n93: \t}\n94: \treturn \"jwt validation failed\"\n95: }\n96: \n97: func (e *JWTValidationError) Status() int {\n98: \treturn 401\n99: }\n100: \n101: func (e *JWTValidationError) Code() string {\n102: \treturn \"JWT_VALIDATION_FAILED\"\n103: }\n104: \n105: func (e *JWTValidationError) Message() string {\n106: \treturn \"jwt validation failed\"\n107: }\n108: \n109: func (e *JWTValidationError) Unwrap() error {\n110: \treturn e.Err\n111: }\n112: \n113: type JWTTokenExpiredError struct {\n114: \tTokenID string\n115: }\n116: \n117: func (e *JWTTokenExpiredError) Error() string {\n118: \treturn \"jwt token expired: \" + e.TokenID\n119: }\n120: \n121: func (e *JWTTokenExpiredError) Status() int {\n122: \treturn 401\n123: }\n124: \n125: func (e *JWTTokenExpiredError) Code() string {\n126: \treturn \"JWT_TOKEN_EXPIRED\"\n127: }\n128: \n129: func (e *JWTTokenExpiredError) Message() string {\n130: \treturn \"jwt token expired\"\n131: }\n132: \n133: type JWTTokenMissingError struct{}\n134: \n135: func (e *JWTTokenMissingError) Error() string {\n136: \treturn \"jwt token missing\"\n137: }\n138: \n139: func (e *JWTTokenMissingError) Status() int {\n140: \treturn 401\n141: }\n142: \n143: func (e *JWTTokenMissingError) Code() string {\n144: \treturn \"JWT_TOKEN_MISSING\"\n145: }\n146: \n147: func (e *JWTTokenMissingError) Message() string {\n148: \treturn \"jwt token missing\"\n149: }\n150: \n151: type JWTInvalidFormatError struct {\n152: \tReason string\n153: }\n154: \n155: func (e *JWTInvalidFormatError) Error() string {\n156: \tif e.Reason != \"\" {\n157: \t\treturn \"invalid authorization header format: \" + e.Reason\n158: \t}\n159: \treturn \"invalid authorization header format\"\n160: }\n161: \n162: func (e *JWTInvalidFormatError) Status() int {\n163: \treturn 401\n164: }\n165: \n166: func (e *JWTInvalidFormatError) Code() string {\n167: \treturn \"JWT_INVALID_FORMAT\"\n168: }\n169: \n170: func (e *JWTInvalidFormatError) Message() string {\n171: \treturn \"invalid authorization header format\"\n172: }\n173: \n174: type JWTKeyLoadError struct {\n175: \tErr error\n176: }\n177: \n178: func (e *JWTKeyLoadError) Error() string {\n179: \tif e.Err != nil {\n180: \t\treturn \"jwt key load failed: \" + e.Err.Error()\n181: \t}\n182: \treturn \"jwt key load failed\"\n183: }\n184: \n185: func (e *JWTKeyLoadError) Status() int {\n186: \treturn 500\n187: }\n188: \n189: func (e *JWTKeyLoadError) Code() string {\n190: \treturn \"JWT_KEY_LOAD_FAILED\"\n191: }\n192: \n193: func (e *JWTKeyLoadError) Message() string {\n194: \treturn \"jwt key load failed\"\n195: }\n196: \n197: func (e *JWTKeyLoadError) Unwrap() error {\n198: \treturn e.Err\n199: }\n200: \n201: type ServerOverloadedError struct{}\n202: \n203: func (e *ServerOverloadedError) Error() string {\n204: \treturn \"server overloaded\"\n205: }\n206: \n207: func (e *ServerOverloadedError) Status() int {\n208: \treturn 429\n209: }\n210: \n211: func (e *ServerOverloadedError) Code() string {\n212: \treturn \"SERVER_OVERLOADED\"\n213: }\n214: \n215: func (e *ServerOverloadedError) Message() string {\n216: \treturn \"server overloaded, please try again later\"\n217: }\n218: \n219: type NoEntryPointError struct {\n220: \tSandboxID string\n221: }\n222: \n223: func (e *NoEntryPointError) Error() string {\n224: \treturn \"no entry point for sandbox: \" + e.SandboxID\n225: }\n226: \n227: func (e *NoEntryPointError) Status() int {\n228: \treturn 404\n229: }\n230: \n231: func (e *NoEntryPointError) Code() string {\n232: \treturn \"NO_ENTRY_POINT\"\n233: }\n234: \n235: func (e *NoEntryPointError) Message() string {\n236: \treturn \"no entry point configured\"\n237: }\n238: \n239: type WorkloadManagerError struct {\n240: \tStatusCode int\n241: \tMsg        string\n242: }\n243: \n244: func (e *WorkloadManagerError) Error() string {\n245: \treturn e.Msg\n246: }\n247: \n248: func (e *WorkloadManagerError) Status() int {\n249: \treturn e.StatusCode\n250: }\n251: \n252: func (e *WorkloadManagerError) Code() string {\n253: \treturn \"WORKLOAD_MANAGER_ERROR\"\n254: }\n255: \n256: func (e *WorkloadManagerError) Message() string {\n257: \treturn e.Msg\n258: }\n\n(End of file - total 258 lines)\n</content>","metadata":{"preview":"package router\n\ntype SessionNotFoundError struct {\n\tSessionID string\n}\n\nfunc (e *SessionNotFoundError) Error() string {\n\treturn \"session not found: \" + e.SessionID\n}\n\nfunc (e *SessionNotFoundError) Status() int {\n\treturn 404\n}\n\nfunc (e *SessionNotFoundError) Code() string {\n\treturn \"SESSION_NOT_FOUND\"\n}\n\nfunc (e *SessionNotFoundError) Message() string {\n\treturn \"session not found\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/errors.go","time":{"start":1775863514959,"end":1775863514983}}}}
{"type":"tool_use","timestamp":1775863514987,"sessionID":"ses_28649bb73ffezik2O3LE5WmBge","part":{"id":"prt_d79b6c0700017Sq6Rakqb7gRoe","messageID":"msg_d79b6a307001UT5xV4KFCTBIPv","sessionID":"ses_28649bb73ffezik2O3LE5WmBge","type":"tool","tool":"read","callID":"toolu_tool-6e6df3875eb04123888e22f951886912","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"testing\"\n8: \t\"time\"\n9: \n10: \t\"github.com/golang-jwt/jwt/v5\"\n11: \t\"github.com/stretchr/testify/assert\"\n12: \t\"github.com/stretchr/testify/require\"\n13: )\n14: \n15: func TestNewJWTManager(t *testing.T) {\n16: \tjwtMgr, err := NewJWTManager()\n17: \trequire.NoError(t, err)\n18: \trequire.NotNil(t, jwtMgr.privateKey)\n19: \trequire.NotNil(t, jwtMgr.publicKey)\n20: \trequire.NotNil(t, jwtMgr.config)\n21: }\n22: \n23: func TestNewJWTManagerWithConfig(t *testing.T) {\n24: \tconfig := &JWTConfig{\n25: \t\tTokenExpiry:   10 * time.Minute,\n26: \t\tRefreshExpiry: 60 * time.Minute,\n27: \t\tIssuer:        \"custom-issuer\",\n28: \t}\n29: \tjwtMgr, err := NewJWTManagerWithConfig(config)\n30: \trequire.NoError(t, err)\n31: \trequire.NotNil(t, jwtMgr.config)\n32: \tassert.Equal(t, 10*time.Minute, jwtMgr.config.TokenExpiry)\n33: }\n34: \n35: func TestNewJWTManagerWithConfigNil(t *testing.T) {\n36: \tjwtMgr, err := NewJWTManagerWithConfig(nil)\n37: \trequire.NoError(t, err)\n38: \trequire.NotNil(t, jwtMgr.config)\n39: \tassert.Equal(t, jwtExpiration, jwtMgr.config.TokenExpiry)\n40: }\n41: \n42: func TestNewJWTManagerFromPrivateKey(t *testing.T) {\n43: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n44: \trequire.NoError(t, err)\n45: \n46: \tjwtMgr, err := NewJWTManagerFromPrivateKey(privateKey)\n47: \trequire.NoError(t, err)\n48: \trequire.NotNil(t, jwtMgr.privateKey)\n49: \tassert.Equal(t, privateKey.N, jwtMgr.privateKey.N)\n50: }\n51: \n52: func TestNewJWTManagerFromPrivateKeyNil(t *testing.T) {\n53: \t_, err := NewJWTManagerFromPrivateKey(nil)\n54: \trequire.Error(t, err)\n55: \tassert.IsType(t, &JWTKeyLoadError{}, err)\n56: }\n57: \n58: func TestJWTManagerGenerateToken(t *testing.T) {\n59: \tjwtMgr, err := NewJWTManager()\n60: \trequire.NoError(t, err)\n61: \n62: \tclaims := map[string]interface{}{\n63: \t\t\"session_id\": \"test-session\",\n64: \t\t\"sandbox_id\": \"test-sandbox\",\n65: \t}\n66: \n67: \ttokenStr, err := jwtMgr.GenerateToken(claims)\n68: \trequire.NoError(t, err)\n69: \tassert.NotEmpty(t, tokenStr)\n70: \n71: \ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n72: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n73: \t\t\treturn nil, jwt.ErrSignatureInvalid\n74: \t\t}\n75: \t\treturn jwtMgr.publicKey, nil\n76: \t})\n77: \n78: \trequire.NoError(t, err)\n79: \tassert.True(t, token.Valid)\n80: \n81: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n82: \trequire.True(t, ok)\n83: \tassert.Equal(t, \"agentcube-router\", mapClaims[\"iss\"])\n84: \tassert.Equal(t, \"test-session\", mapClaims[\"session_id\"])\n85: }\n86: \n87: func TestJWTManagerGenerateTokenWithClaims(t *testing.T) {\n88: \tjwtMgr, err := NewJWTManager()\n89: \trequire.NoError(t, err)\n90: \n91: \tclaims := &RouterClaims{\n92: \t\tSessionID: \"test-session\",\n93: \t\tSandboxID: \"test-sandbox\",\n94: \t\tNamespace: \"test-namespace\",\n95: \t\tName:      \"test-name\",\n96: \t}\n97: \n98: \ttokenStr, err := jwtMgr.GenerateTokenWithClaims(claims)\n99: \trequire.NoError(t, err)\n100: \tassert.NotEmpty(t, tokenStr)\n101: \n102: \tvalidatedClaims, err := jwtMgr.ValidateToken(tokenStr)\n103: \trequire.NoError(t, err)\n104: \tassert.Equal(t, \"test-session\", validatedClaims.SessionID)\n105: \tassert.Equal(t, \"test-sandbox\", validatedClaims.SandboxID)\n106: \tassert.Equal(t, \"test-namespace\", validatedClaims.Namespace)\n107: \tassert.Equal(t, \"test-name\", validatedClaims.Name)\n108: }\n109: \n110: func TestJWTManagerGenerateTokenPair(t *testing.T) {\n111: \tjwtMgr, err := NewJWTManager()\n112: \trequire.NoError(t, err)\n113: \n114: \tclaims := &RouterClaims{\n115: \t\tSessionID: \"test-session\",\n116: \t\tSandboxID: \"test-sandbox\",\n117: \t\tNamespace: \"test-namespace\",\n118: \t\tName:      \"test-name\",\n119: \t}\n120: \n121: \ttokenPair, err := jwtMgr.GenerateTokenPair(claims)\n122: \trequire.NoError(t, err)\n123: \trequire.NotNil(t, tokenPair)\n124: \tassert.NotEmpty(t, tokenPair.AccessToken)\n125: \tassert.NotEmpty(t, tokenPair.RefreshToken)\n126: \tassert.Equal(t, \"Bearer\", tokenPair.TokenType)\n127: \tassert.Equal(t, int64(jwtExpiration.Seconds()), tokenPair.ExpiresIn)\n128: \n129: \taccessClaims, err := jwtMgr.ValidateToken(tokenPair.AccessToken)\n130: \trequire.NoError(t, err)\n131: \tassert.Equal(t, \"test-session\", accessClaims.SessionID)\n132: \n133: \trefreshClaims, err := jwtMgr.ValidateToken(tokenPair.RefreshToken)\n134: \trequire.NoError(t, err)\n135: \tassert.Equal(t, \"test-session\", refreshClaims.SessionID)\n136: \tassert.NotEmpty(t, refreshClaims.RegisteredClaims.ID)\n137: }\n138: \n139: func TestJWTManagerValidateToken(t *testing.T) {\n140: \tjwtMgr, err := NewJWTManager()\n141: \trequire.NoError(t, err)\n142: \n143: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n144: \t\t\"session_id\": \"validate-session\",\n145: \t\t\"sandbox_id\": \"validate-sandbox\",\n146: \t\t\"namespace\":  \"validate-namespace\",\n147: \t\t\"name\":       \"validate-name\",\n148: \t})\n149: \trequire.NoError(t, err)\n150: \n151: \tclaims, err := jwtMgr.ValidateToken(token)\n152: \trequire.NoError(t, err)\n153: \tassert.Equal(t, \"validate-session\", claims.SessionID)\n154: \tassert.Equal(t, \"validate-sandbox\", claims.SandboxID)\n155: \tassert.Equal(t, \"validate-namespace\", claims.Namespace)\n156: \tassert.Equal(t, \"validate-name\", claims.Name)\n157: }\n158: \n159: func TestJWTManagerValidateTokenInvalid(t *testing.T) {\n160: \tjwtMgr, err := NewJWTManager()\n161: \trequire.NoError(t, err)\n162: \n163: \t_, err = jwtMgr.ValidateToken(\"invalid-token-string\")\n164: \trequire.Error(t, err)\n165: \tassert.IsType(t, &JWTValidationError{}, err)\n166: }\n167: \n168: func TestJWTManagerValidateTokenWrongKey(t *testing.T) {\n169: \tjwtMgr1, err := NewJWTManager()\n170: \trequire.NoError(t, err)\n171: \n172: \tjwtMgr2, err := NewJWTManager()\n173: \trequire.NoError(t, err)\n174: \n175: \ttoken, err := jwtMgr1.GenerateToken(map[string]interface{}{\n176: \t\t\"session_id\": \"wrong-key-session\",\n177: \t})\n178: \trequire.NoError(t, err)\n179: \n180: \t_, err = jwtMgr2.ValidateToken(token)\n181: \trequire.Error(t, err)\n182: \tassert.IsType(t, &JWTValidationError{}, err)\n183: }\n184: \n185: func TestJWTManagerRefreshToken(t *testing.T) {\n186: \tjwtMgr, err := NewJWTManager()\n187: \trequire.NoError(t, err)\n188: \n189: \tclaims := &RouterClaims{\n190: \t\tSessionID: \"refresh-session\",\n191: \t\tSandboxID: \"refresh-sandbox\",\n192: \t\tNamespace: \"refresh-namespace\",\n193: \t\tName:      \"refresh-name\",\n194: \t}\n195: \n196: \ttokenPair, err := jwtMgr.GenerateTokenPair(claims)\n197: \trequire.NoError(t, err)\n198: \n199: \tnewTokenPair, err := jwtMgr.RefreshToken(tokenPair.RefreshToken)\n200: \trequire.NoError(t, err)\n201: \trequire.NotNil(t, newTokenPair)\n202: \tassert.NotEmpty(t, newTokenPair.AccessToken)\n203: \tassert.NotEmpty(t, newTokenPair.RefreshToken)\n204: \n205: \tnewClaims, err := jwtMgr.ValidateToken(newTokenPair.AccessToken)\n206: \trequire.NoError(t, err)\n207: \tassert.Equal(t, \"refresh-session\", newClaims.SessionID)\n208: }\n209: \n210: func TestJWTManagerRefreshTokenWithAccessToken(t *testing.T) {\n211: \tjwtMgr, err := NewJWTManager()\n212: \trequire.NoError(t, err)\n213: \n214: \tclaims := &RouterClaims{\n215: \t\tSessionID: \"access-session\",\n216: \t}\n217: \n218: \ttoken, err := jwtMgr.GenerateTokenWithClaims(claims)\n219: \trequire.NoError(t, err)\n220: \n221: \t_, err = jwtMgr.RefreshToken(token)\n222: \trequire.Error(t, err)\n223: \tassert.IsType(t, &JWTValidationError{}, err)\n224: }\n225: \n226: func TestJWTManagerGetPublicKeyPEM(t *testing.T) {\n227: \tjwtMgr, err := NewJWTManager()\n228: \trequire.NoError(t, err)\n229: \n230: \tpemStr := jwtMgr.GetPublicKeyPEM()\n231: \tassert.NotEmpty(t, pemStr)\n232: \tassert.Contains(t, pemStr, \"PUBLIC KEY\")\n233: }\n234: \n235: func TestJWTManagerTokenExpiration(t *testing.T) {\n236: \tjwtMgr, err := NewJWTManager()\n237: \trequire.NoError(t, err)\n238: \n239: \ttokenStr, err := jwtMgr.GenerateToken(map[string]interface{}{})\n240: \trequire.NoError(t, err)\n241: \n242: \ttoken, err := jwt.Parse(tokenStr, func(token *jwt.Token) (interface{}, error) {\n243: \t\treturn jwtMgr.publicKey, nil\n244: \t})\n245: \trequire.NoError(t, err)\n246: \n247: \tmapClaims, ok := token.Claims.(jwt.MapClaims)\n248: \trequire.True(t, ok)\n249: \n250: \texp, ok := mapClaims[\"exp\"].(float64)\n251: \trequire.True(t, ok)\n252: \n253: \tnow := time.Now().Unix()\n254: \texpectedExp := now + int64(jwtExpiration.Seconds())\n255: \n256: \tassert.GreaterOrEqual(t, int64(exp), now)\n257: \tassert.LessOrEqual(t, int64(exp), expectedExp+5)\n258: \tassert.GreaterOrEqual(t, int64(exp), expectedExp-5)\n259: }\n260: \n261: func TestJWTManagerGetPublicKey(t *testing.T) {\n262: \tjwtMgr, err := NewJWTManager()\n263: \trequire.NoError(t, err)\n264: \n265: \tpubKey := jwtMgr.GetPublicKey()\n266: \trequire.NotNil(t, pubKey)\n267: \tassert.Equal(t, 2048/8, pubKey.Size())\n268: }\n269: \n270: func TestDefaultJWTConfig(t *testing.T) {\n271: \tconfig := DefaultJWTConfig()\n272: \trequire.NotNil(t, config)\n273: \tassert.Equal(t, jwtExpiration, config.TokenExpiry)\n274: \tassert.Equal(t, refreshExpiration, config.RefreshExpiry)\n275: \tassert.Equal(t, jwtIssuer, config.Issuer)\n276: \tassert.Equal(t, defaultClockSkew, config.ClockSkew)\n277: }\n278: \n279: func TestEncodePrivateKeyPEM(t *testing.T) {\n280: \tjwtMgr, err := NewJWTManager()\n281: \trequire.NoError(t, err)\n282: \n283: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n284: \trequire.NotNil(t, pemData)\n285: \tassert.Contains(t, string(pemData), \"RSA PRIVATE KEY\")\n286: }\n287: \n288: func TestEncodePublicKeyPEM(t *testing.T) {\n289: \tjwtMgr, err := NewJWTManager()\n290: \trequire.NoError(t, err)\n291: \n292: \tpemData := encodePublicKeyPEM(jwtMgr.publicKey)\n293: \trequire.NotNil(t, pemData)\n294: \tassert.Contains(t, string(pemData), \"PUBLIC KEY\")\n295: }\n296: \n297: func TestLoadPrivateKeyPEM(t *testing.T) {\n298: \tjwtMgr, err := NewJWTManager()\n299: \trequire.NoError(t, err)\n300: \n301: \tpemData := encodePrivateKeyPEM(jwtMgr.privateKey)\n302: \tloadedKey, err := loadPrivateKeyPEM(pemData)\n303: \trequire.NoError(t, err)\n304: \tassert.Equal(t, 0, loadedKey.N.Cmp(jwtMgr.privateKey.N))\n305: }\n306: \n307: func TestLoadPrivateKeyPEMInvalid(t *testing.T) {\n308: \t_, err := loadPrivateKeyPEM([]byte(\"invalid pem data\"))\n309: \trequire.Error(t, err)\n310: }\n311: \n312: func TestLoadPrivateKeyPEMInvalidBlock(t *testing.T) {\n313: \t_, err := loadPrivateKeyPEM([]byte(\"-----BEGIN CERTIFICATE-----\\ninvalid\\n-----END CERTIFICATE-----\"))\n314: \trequire.Error(t, err)\n315: }\n316: \n317: func TestJWTManagerTryStoreOrLoadJWTKeySecretNoClient(t *testing.T) {\n318: \tjwtMgr, err := NewJWTManager()\n319: \trequire.NoError(t, err)\n320: \n321: \terr = jwtMgr.TryStoreOrLoadJWTKeySecret(context.Background())\n322: \tassert.NoError(t, err)\n323: }\n324: \n325: func TestJWTManagerLoadKeysFromSecretNoClient(t *testing.T) {\n326: \tjwtMgr, err := NewJWTManager()\n327: \trequire.NoError(t, err)\n328: \n329: \terr = jwtMgr.LoadKeysFromSecret(context.Background())\n330: \trequire.Error(t, err)\n331: \tassert.IsType(t, &JWTKeyLoadError{}, err)\n332: }\n333: \n334: func TestJWTManagerStoreKeysToSecretNoClient(t *testing.T) {\n335: \tjwtMgr, err := NewJWTManager()\n336: \trequire.NoError(t, err)\n337: \n338: \terr = jwtMgr.StoreKeysToSecret(context.Background())\n339: \trequire.Error(t, err)\n340: \tassert.IsType(t, &JWTKeyLoadError{}, err)\n341: }\n342: \n343: func TestRouterClaims(t *testing.T) {\n344: \tclaims := &RouterClaims{\n345: \t\tSessionID: \"claim-session\",\n346: \t\tSandboxID: \"claim-sandbox\",\n347: \t\tNamespace: \"claim-namespace\",\n348: \t\tName:      \"claim-name\",\n349: \t}\n350: \n351: \tjwtMgr, err := NewJWTManager()\n352: \trequire.NoError(t, err)\n353: \n354: \ttoken, err := jwtMgr.GenerateTokenWithClaims(claims)\n355: \trequire.NoError(t, err)\n356: \n357: \tvalidated, err := jwtMgr.ValidateToken(token)\n358: \trequire.NoError(t, err)\n359: \tassert.Equal(t, claims.SessionID, validated.SessionID)\n360: \tassert.Equal(t, claims.SandboxID, validated.SandboxID)\n361: \tassert.Equal(t, claims.Namespace, validated.Namespace)\n362: \tassert.Equal(t, claims.Name, validated.Name)\n363: }\n364: \n365: func TestTokenPair(t *testing.T) {\n366: \ttokenPair := &TokenPair{\n367: \t\tAccessToken:  \"access-token\",\n368: \t\tRefreshToken: \"refresh-token\",\n369: \t\tExpiresIn:    300,\n370: \t\tTokenType:    \"Bearer\",\n371: \t}\n372: \n373: \tassert.Equal(t, \"access-token\", tokenPair.AccessToken)\n374: \tassert.Equal(t, \"refresh-token\", tokenPair.RefreshToken)\n375: \tassert.Equal(t, int64(300), tokenPair.ExpiresIn)\n376: \tassert.Equal(t, \"Bearer\", tokenPair.TokenType)\n377: }\n378: \n379: func TestJWTManagerValidateTokenEmpty(t *testing.T) {\n380: \tjwtMgr, err := NewJWTManager()\n381: \trequire.NoError(t, err)\n382: \n383: \t_, err = jwtMgr.ValidateToken(\"\")\n384: \trequire.Error(t, err)\n385: }\n386: \n387: func BenchmarkJWTGenerateToken(b *testing.B) {\n388: \tjwtMgr, err := NewJWTManager()\n389: \tif err != nil {\n390: \t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n391: \t}\n392: \n393: \tclaims := map[string]interface{}{\n394: \t\t\"session_id\": \"bench-session\",\n395: \t\t\"sandbox_id\": \"bench-sandbox\",\n396: \t}\n397: \n398: \tb.ResetTimer()\n399: \tfor i := 0; i < b.N; i++ {\n400: \t\t_, _ = jwtMgr.GenerateToken(claims)\n401: \t}\n402: }\n403: \n404: func BenchmarkJWTValidateToken(b *testing.B) {\n405: \tjwtMgr, err := NewJWTManager()\n406: \tif err != nil {\n407: \t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n408: \t}\n409: \n410: \ttoken, err := jwtMgr.GenerateToken(map[string]interface{}{\n411: \t\t\"session_id\": \"bench-session\",\n412: \t})\n413: \tif err != nil {\n414: \t\tb.Fatalf(\"failed to generate token: %v\", err)\n415: \t}\n416: \n417: \tb.ResetTimer()\n418: \tfor i := 0; i < b.N; i++ {\n419: \t\t_, _ = jwtMgr.ValidateToken(token)\n420: \t}\n421: }\n422: \n423: func BenchmarkJWTGenerateTokenPair(b *testing.B) {\n424: \tjwtMgr, err := NewJWTManager()\n425: \tif err != nil {\n426: \t\tb.Fatalf(\"failed to create JWT manager: %v\", err)\n427: \t}\n428: \n429: \tclaims := &RouterClaims{\n430: \t\tSessionID: \"bench-session\",\n431: \t\tSandboxID: \"bench-sandbox\",\n432: \t}\n433: \n434: \tb.ResetTimer()\n435: \tfor i := 0; i < b.N; i++ {\n436: \t\t_, _ = jwtMgr.GenerateTokenPair(claims)\n437: \t}\n438: }\n439: \n440: func contains(s, substr string) bool {\n441: \treturn len(s) > 0 && len(substr) > 0 && len(s) >= len(substr)\n442: }\n\n(End of file - total 442 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestNewJWTManager(t *testing.T) {\n\tjwtMgr, err := NewJWTManager()\n\trequire.NoError(t, err)\n\trequire.NotNil(t, jwtMgr.privateKey)\n\trequire.NotNil(t, jwtMgr.publicKey)\n\trequire.NotNil(t, jwtMgr.config)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt_test.go","time":{"start":1775863514963,"end":1775863514985}}}}
