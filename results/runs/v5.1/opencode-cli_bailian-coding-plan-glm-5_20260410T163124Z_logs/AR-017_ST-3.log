{"type":"tool_use","timestamp":1775863505603,"sessionID":"ses_28649bb73ffezik2O3LE5WmBge","part":{"id":"prt_d79b69c1f001QKwa2CZ6N4U5dy","messageID":"msg_d79b67a63001tiTTozrzXVOkRp","sessionID":"ses_28649bb73ffezik2O3LE5WmBge","type":"tool","tool":"read","callID":"toolu_tool-4e769a1e54e447a4874492e5bfc7431c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"crypto/rand\"\n6: \t\"crypto/rsa\"\n7: \t\"crypto/x509\"\n8: \t\"encoding/pem\"\n9: \t\"errors\"\n10: \t\"fmt\"\n11: \t\"os\"\n12: \t\"strings\"\n13: \t\"time\"\n14: \n15: \t\"github.com/golang-jwt/jwt/v5\"\n16: \tcorev1 \"k8s.io/api/core/v1\"\n17: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n18: \t\"k8s.io/client-go/kubernetes\"\n19: \t\"k8s.io/klog/v2\"\n20: )\n21: \n22: const (\n23: \trsaKeySize         = 2048\n24: \tjwtExpiration      = 5 * time.Minute\n25: \trefreshExpiration  = 30 * time.Minute\n26: \tIdentitySecretName = \"picod-router-identity\"\n27: \tPrivateKeyDataKey  = \"private.pem\"\n28: \tPublicKeyDataKey   = \"public.pem\"\n29: \tjwtIssuer          = \"agentcube-router\"\n30: \tdefaultClockSkew   = 30 * time.Second\n31: )\n32: \n33: var IdentityNamespace = \"default\"\n34: \n35: func init() {\n36: \tif ns := os.Getenv(\"AGENTCUBE_NAMESPACE\"); ns != \"\" {\n37: \t\tIdentityNamespace = ns\n38: \t}\n39: }\n40: \n41: type RouterClaims struct {\n42: \tSessionID string `json:\"session_id\"`\n43: \tSandboxID string `json:\"sandbox_id\"`\n44: \tNamespace string `json:\"namespace\"`\n45: \tName      string `json:\"name\"`\n46: \tjwt.RegisteredClaims\n47: }\n48: \n49: type JWTConfig struct {\n50: \tTokenExpiry   time.Duration\n51: \tRefreshExpiry time.Duration\n52: \tIssuer        string\n53: \tClockSkew     time.Duration\n54: }\n55: \n56: func DefaultJWTConfig() *JWTConfig {\n57: \treturn &JWTConfig{\n58: \t\tTokenExpiry:   jwtExpiration,\n59: \t\tRefreshExpiry: refreshExpiration,\n60: \t\tIssuer:        jwtIssuer,\n61: \t\tClockSkew:     defaultClockSkew,\n62: \t}\n63: }\n64: \n65: type TokenPair struct {\n66: \tAccessToken  string `json:\"access_token\"`\n67: \tRefreshToken string `json:\"refresh_token\"`\n68: \tExpiresIn    int64  `json:\"expires_in\"`\n69: \tTokenType    string `json:\"token_type\"`\n70: }\n71: \n72: type JWTManager struct {\n73: \tprivateKey *rsa.PrivateKey\n74: \tpublicKey  *rsa.PublicKey\n75: \tk8sClient  kubernetes.Interface\n76: \tconfig     *JWTConfig\n77: }\n78: \n79: func NewJWTManager() (*JWTManager, error) {\n80: \tprivateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n81: \tif err != nil {\n82: \t\treturn nil, fmt.Errorf(\"failed to generate RSA key: %w\", err)\n83: \t}\n84: \n85: \treturn &JWTManager{\n86: \t\tprivateKey: privateKey,\n87: \t\tpublicKey:  &privateKey.PublicKey,\n88: \t\tconfig:     DefaultJWTConfig(),\n89: \t}, nil\n90: }\n91: \n92: func NewJWTManagerWithConfig(config *JWTConfig) (*JWTManager, error) {\n93: \tif config == nil {\n94: \t\tconfig = DefaultJWTConfig()\n95: \t}\n96: \tprivateKey, err := rsa.GenerateKey(rand.Reader, rsaKeySize)\n97: \tif err != nil {\n98: \t\treturn nil, fmt.Errorf(\"failed to generate RSA key: %w\", err)\n99: \t}\n100: \n101: \treturn &JWTManager{\n102: \t\tprivateKey: privateKey,\n103: \t\tpublicKey:  &privateKey.PublicKey,\n104: \t\tconfig:     config,\n105: \t}, nil\n106: }\n107: \n108: func NewJWTManagerWithClient(k8sClient kubernetes.Interface) (*JWTManager, error) {\n109: \tjwtMgr, err := NewJWTManager()\n110: \tif err != nil {\n111: \t\treturn nil, err\n112: \t}\n113: \tjwtMgr.k8sClient = k8sClient\n114: \treturn jwtMgr, nil\n115: }\n116: \n117: func NewJWTManagerFromPrivateKey(privateKey *rsa.PrivateKey) (*JWTManager, error) {\n118: \tif privateKey == nil {\n119: \t\treturn nil, &JWTKeyLoadError{Err: errors.New(\"private key is nil\")}\n120: \t}\n121: \treturn &JWTManager{\n122: \t\tprivateKey: privateKey,\n123: \t\tpublicKey:  &privateKey.PublicKey,\n124: \t\tconfig:     DefaultJWTConfig(),\n125: \t}, nil\n126: }\n127: \n128: func (j *JWTManager) GenerateToken(claims map[string]interface{}) (string, error) {\n129: \tnow := time.Now()\n130: \texpiry := jwtExpiration\n131: \tif j.config != nil && j.config.TokenExpiry > 0 {\n132: \t\texpiry = j.config.TokenExpiry\n133: \t}\n134: \tissuer := jwtIssuer\n135: \tif j.config != nil && j.config.Issuer != \"\" {\n136: \t\tissuer = j.config.Issuer\n137: \t}\n138: \n139: \ttokenClaims := jwt.MapClaims{\n140: \t\t\"exp\": now.Add(expiry).Unix(),\n141: \t\t\"iat\": now.Unix(),\n142: \t\t\"iss\": issuer,\n143: \t}\n144: \n145: \tfor k, v := range claims {\n146: \t\ttokenClaims[k] = v\n147: \t}\n148: \n149: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, tokenClaims)\n150: \n151: \ttokenString, err := token.SignedString(j.privateKey)\n152: \tif err != nil {\n153: \t\treturn \"\", &JWTSigningError{Err: err}\n154: \t}\n155: \n156: \treturn tokenString, nil\n157: }\n158: \n159: func (j *JWTManager) GenerateTokenWithClaims(claims *RouterClaims) (string, error) {\n160: \tnow := time.Now()\n161: \texpiry := jwtExpiration\n162: \tif j.config != nil && j.config.TokenExpiry > 0 {\n163: \t\texpiry = j.config.TokenExpiry\n164: \t}\n165: \tissuer := jwtIssuer\n166: \tif j.config != nil && j.config.Issuer != \"\" {\n167: \t\tissuer = j.config.Issuer\n168: \t}\n169: \n170: \tclaims.RegisteredClaims = jwt.RegisteredClaims{\n171: \t\tExpiresAt: jwt.NewNumericDate(now.Add(expiry)),\n172: \t\tIssuedAt:  jwt.NewNumericDate(now),\n173: \t\tIssuer:    issuer,\n174: \t}\n175: \n176: \ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n177: \n178: \ttokenString, err := token.SignedString(j.privateKey)\n179: \tif err != nil {\n180: \t\treturn \"\", &JWTSigningError{Err: err}\n181: \t}\n182: \n183: \treturn tokenString, nil\n184: }\n185: \n186: func (j *JWTManager) GenerateTokenPair(claims *RouterClaims) (*TokenPair, error) {\n187: \taccessToken, err := j.GenerateTokenWithClaims(claims)\n188: \tif err != nil {\n189: \t\treturn nil, err\n190: \t}\n191: \n192: \tnow := time.Now()\n193: \trefreshExpiry := refreshExpiration\n194: \tif j.config != nil && j.config.RefreshExpiry > 0 {\n195: \t\trefreshExpiry = j.config.RefreshExpiry\n196: \t}\n197: \tissuer := jwtIssuer\n198: \tif j.config != nil && j.config.Issuer != \"\" {\n199: \t\tissuer = j.config.Issuer\n200: \t}\n201: \n202: \trefreshClaims := &RouterClaims{\n203: \t\tSessionID: claims.SessionID,\n204: \t\tSandboxID: claims.SandboxID,\n205: \t\tNamespace: claims.Namespace,\n206: \t\tName:      claims.Name,\n207: \t\tRegisteredClaims: jwt.RegisteredClaims{\n208: \t\t\tExpiresAt: jwt.NewNumericDate(now.Add(refreshExpiry)),\n209: \t\t\tIssuedAt:  jwt.NewNumericDate(now),\n210: \t\t\tIssuer:    issuer,\n211: \t\t\tID:        fmt.Sprintf(\"refresh-%s\", claims.SessionID),\n212: \t\t},\n213: \t}\n214: \n215: \trefreshToken := jwt.NewWithClaims(jwt.SigningMethodRS256, refreshClaims)\n216: \trefreshTokenString, err := refreshToken.SignedString(j.privateKey)\n217: \tif err != nil {\n218: \t\treturn nil, &JWTSigningError{Err: err}\n219: \t}\n220: \n221: \ttokenExpiry := jwtExpiration\n222: \tif j.config != nil && j.config.TokenExpiry > 0 {\n223: \t\ttokenExpiry = j.config.TokenExpiry\n224: \t}\n225: \n226: \treturn &TokenPair{\n227: \t\tAccessToken:  accessToken,\n228: \t\tRefreshToken: refreshTokenString,\n229: \t\tExpiresIn:    int64(tokenExpiry.Seconds()),\n230: \t\tTokenType:    \"Bearer\",\n231: \t}, nil\n232: }\n233: \n234: func (j *JWTManager) ValidateToken(tokenString string) (*RouterClaims, error) {\n235: \ttoken, err := jwt.ParseWithClaims(tokenString, &RouterClaims{}, func(token *jwt.Token) (interface{}, error) {\n236: \t\tif _, ok := token.Method.(*jwt.SigningMethodRSA); !ok {\n237: \t\t\treturn nil, &JWTValidationError{Err: fmt.Errorf(\"unexpected signing method: %v\", token.Header[\"alg\"])}\n238: \t\t}\n239: \t\treturn j.publicKey, nil\n240: \t})\n241: \n242: \tif err != nil {\n243: \t\tif errors.Is(err, jwt.ErrTokenExpired) {\n244: \t\t\treturn nil, &JWTTokenExpiredError{TokenID: tokenString}\n245: \t\t}\n246: \t\tif errors.Is(err, jwt.ErrTokenSignatureInvalid) {\n247: \t\t\treturn nil, &JWTValidationError{Err: err}\n248: \t\t}\n249: \t\tif errors.Is(err, jwt.ErrTokenMalformed) {\n250: \t\t\treturn nil, &JWTValidationError{Err: err}\n251: \t\t}\n252: \t\tif errors.Is(err, jwt.ErrTokenNotValidYet) {\n253: \t\t\treturn nil, &JWTValidationError{Err: err}\n254: \t\t}\n255: \t\treturn nil, &JWTValidationError{Err: err}\n256: \t}\n257: \n258: \tif !token.Valid {\n259: \t\treturn nil, &JWTValidationError{Err: errors.New(\"token is not valid\")}\n260: \t}\n261: \n262: \tclaims, ok := token.Claims.(*RouterClaims)\n263: \tif !ok {\n264: \t\treturn nil, &JWTValidationError{Err: errors.New(\"failed to extract claims\")}\n265: \t}\n266: \n267: \treturn claims, nil\n268: }\n269: \n270: func (j *JWTManager) RefreshToken(refreshTokenString string) (*TokenPair, error) {\n271: \tclaims, err := j.ValidateToken(refreshTokenString)\n272: \tif err != nil {\n273: \t\treturn nil, err\n274: \t}\n275: \n276: \tif claims.RegisteredClaims.ID == \"\" || !strings.HasPrefix(claims.RegisteredClaims.ID, \"refresh-\") {\n277: \t\treturn nil, &JWTValidationError{Err: errors.New(\"not a refresh token\")}\n278: \t}\n279: \n280: \treturn j.GenerateTokenPair(claims)\n281: }\n282: \n283: func (j *JWTManager) ValidateTokenWithSkew(tokenString string) (*RouterClaims, error) {\n284: \tclaims, err := j.ValidateToken(tokenString)\n285: \tif err != nil {\n286: \t\treturn claims, err\n287: \t}\n288: \treturn claims, nil\n289: }\n290: \n291: func (j *JWTManager) TryStoreOrLoadJWTKeySecret(ctx context.Context) error {\n292: \tif j.k8sClient == nil {\n293: \t\tklog.Warningf(\"k8s client not configured, skipping secret persistence\")\n294: \t\treturn nil\n295: \t}\n296: \n297: \tsecretClient := j.k8sClient.CoreV1().Secrets(IdentityNamespace)\n298: \n299: \texistingSecret, err := secretClient.Get(ctx, IdentitySecretName, metav1.GetOptions{})\n300: \tif err == nil {\n301: \t\tprivateKeyData := existingSecret.Data[PrivateKeyDataKey]\n302: \t\tif len(privateKeyData) == 0 {\n303: \t\t\tklog.Warningf(\"secret exists but private key data is empty\")\n304: \t\t\treturn nil\n305: \t\t}\n306: \n307: \t\tprivateKey, err := loadPrivateKeyPEM(privateKeyData)\n308: \t\tif err != nil {\n309: \t\t\treturn &JWTKeyLoadError{Err: err}\n310: \t\t}\n311: \n312: \t\tj.privateKey = privateKey\n313: \t\tj.publicKey = &privateKey.PublicKey\n314: \t\tklog.Infof(\"loaded existing JWT keys from secret %s/%s\", IdentityNamespace, IdentitySecretName)\n315: \t\treturn nil\n316: \t}\n317: \n318: \tprivateKeyPEM := encodePrivateKeyPEM(j.privateKey)\n319: \tpublicKeyPEM := encodePublicKeyPEM(j.publicKey)\n320: \n321: \tsecret := &corev1.Secret{\n322: \t\tObjectMeta: metav1.ObjectMeta{\n323: \t\t\tName:      IdentitySecretName,\n324: \t\t\tNamespace: IdentityNamespace,\n325: \t\t},\n326: \t\tType: corev1.SecretTypeOpaque,\n327: \t\tData: map[string][]byte{\n328: \t\t\tPrivateKeyDataKey: privateKeyPEM,\n329: \t\t\tPublicKeyDataKey:  publicKeyPEM,\n330: \t\t},\n331: \t}\n332: \n333: \t_, err = secretClient.Create(ctx, secret, metav1.CreateOptions{})\n334: \tif err != nil {\n335: \t\tklog.Warningf(\"failed to create secret for JWT keys: %v\", err)\n336: \t\treturn nil\n337: \t}\n338: \n339: \tklog.Infof(\"stored JWT keys in secret %s/%s\", IdentityNamespace, IdentitySecretName)\n340: \treturn nil\n341: }\n342: \n343: func (j *JWTManager) LoadKeysFromSecret(ctx context.Context) error {\n344: \tif j.k8sClient == nil {\n345: \t\treturn &JWTKeyLoadError{Err: errors.New(\"k8s client not configured\")}\n346: \t}\n347: \n348: \tsecretClient := j.k8sClient.CoreV1().Secrets(IdentityNamespace)\n349: \n350: \texistingSecret, err := secretClient.Get(ctx, IdentitySecretName, metav1.GetOptions{})\n351: \tif err != nil {\n352: \t\treturn &JWTKeyLoadError{Err: fmt.Errorf(\"failed to get secret: %w\", err)}\n353: \t}\n354: \n355: \tprivateKeyData := existingSecret.Data[PrivateKeyDataKey]\n356: \tif len(privateKeyData) == 0 {\n357: \t\treturn &JWTKeyLoadError{Err: errors.New(\"private key data is empty\")}\n358: \t}\n359: \n360: \tprivateKey, err := loadPrivateKeyPEM(privateKeyData)\n361: \tif err != nil {\n362: \t\treturn &JWTKeyLoadError{Err: err}\n363: \t}\n364: \n365: \tj.privateKey = privateKey\n366: \tj.publicKey = &privateKey.PublicKey\n367: \treturn nil\n368: }\n369: \n370: func (j *JWTManager) StoreKeysToSecret(ctx context.Context) error {\n371: \tif j.k8sClient == nil {\n372: \t\treturn &JWTKeyLoadError{Err: errors.New(\"k8s client not configured\")}\n373: \t}\n374: \n375: \tprivateKeyPEM := encodePrivateKeyPEM(j.privateKey)\n376: \tpublicKeyPEM := encodePublicKeyPEM(j.publicKey)\n377: \n378: \tsecret := &corev1.Secret{\n379: \t\tObjectMeta: metav1.ObjectMeta{\n380: \t\t\tName:      IdentitySecretName,\n381: \t\t\tNamespace: IdentityNamespace,\n382: \t\t},\n383: \t\tType: corev1.SecretTypeOpaque,\n384: \t\tData: map[string][]byte{\n385: \t\t\tPrivateKeyDataKey: privateKeyPEM,\n386: \t\t\tPublicKeyDataKey:  publicKeyPEM,\n387: \t\t},\n388: \t}\n389: \n390: \tsecretClient := j.k8sClient.CoreV1().Secrets(IdentityNamespace)\n391: \n392: \texistingSecret, err := secretClient.Get(ctx, IdentitySecretName, metav1.GetOptions{})\n393: \tif err == nil {\n394: \t\texistingSecret.Data = secret.Data\n395: \t\t_, err = secretClient.Update(ctx, existingSecret, metav1.UpdateOptions{})\n396: \t\tif err != nil {\n397: \t\t\treturn &JWTKeyLoadError{Err: fmt.Errorf(\"failed to update secret: %w\", err)}\n398: \t\t}\n399: \t\treturn nil\n400: \t}\n401: \n402: \t_, err = secretClient.Create(ctx, secret, metav1.CreateOptions{})\n403: \tif err != nil {\n404: \t\treturn &JWTKeyLoadError{Err: fmt.Errorf(\"failed to create secret: %w\", err)}\n405: \t}\n406: \treturn nil\n407: }\n408: \n409: func (j *JWTManager) GetPublicKeyPEM() string {\n410: \tpemData := encodePublicKeyPEM(j.publicKey)\n411: \tif pemData == nil {\n412: \t\treturn \"\"\n413: \t}\n414: \treturn string(pemData)\n415: }\n416: \n417: func encodePrivateKeyPEM(key *rsa.PrivateKey) []byte {\n418: \treturn pem.EncodeToMemory(&pem.Block{\n419: \t\tType:  \"RSA PRIVATE KEY\",\n420: \t\tBytes: x509.MarshalPKCS1PrivateKey(key),\n421: \t})\n422: }\n423: \n424: func encodePublicKeyPEM(key *rsa.PublicKey) []byte {\n425: \tbytes, err := x509.MarshalPKIXPublicKey(key)\n426: \tif err != nil {\n427: \t\treturn nil\n428: \t}\n429: \treturn pem.EncodeToMemory(&pem.Block{\n430: \t\tType:  \"PUBLIC KEY\",\n431: \t\tBytes: bytes,\n432: \t})\n433: }\n434: \n435: func loadPrivateKeyPEM(data []byte) (*rsa.PrivateKey, error) {\n436: \tblock, _ := pem.Decode(data)\n437: \tif block == nil {\n438: \t\treturn nil, fmt.Errorf(\"failed to decode PEM block\")\n439: \t}\n440: \n441: \tkey, err := x509.ParsePKCS1PrivateKey(block.Bytes)\n442: \tif err != nil {\n443: \t\treturn nil, fmt.Errorf(\"failed to parse private key: %w\", err)\n444: \t}\n445: \n446: \treturn key, nil\n447: }\n448: \n449: func (j *JWTManager) GetPublicKey() *rsa.PublicKey {\n450: \treturn j.publicKey\n451: }\n\n(End of file - total 451 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/jwt.go","time":{"start":1775863505573,"end":1775863505602}}}}
{"type":"tool_use","timestamp":1775863505622,"sessionID":"ses_28649bb73ffezik2O3LE5WmBge","part":{"id":"prt_d79b69f4f001GXYgw8CCB3dG12","messageID":"msg_d79b67a63001tiTTozrzXVOkRp","sessionID":"ses_28649bb73ffezik2O3LE5WmBge","type":"tool","tool":"read","callID":"toolu_tool-1af41a8858e74632b42a015632d04fb3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"strings\"\n6: \n7: \t\"github.com/gin-gonic/gin\"\n8: \t\"github.com/golang-jwt/jwt/v5\"\n9: \t\"github.com/volcano-sh/agentcube/pkg/router\"\n10: )\n11: \n12: type JWTAuthMiddlewareConfig struct {\n13: \tSkipPaths      []string\n14: \tTokenExtractor TokenExtractor\n15: \tKeyFunc        jwt.Keyfunc\n16: \tJWTManager     *router.JWTManager\n17: }\n18: \n19: type TokenExtractor func(r *http.Request) (string, error)\n20: \n21: func DefaultTokenExtractor(r *http.Request) (string, error) {\n22: \tauthHeader := r.Header.Get(\"Authorization\")\n23: \tif authHeader == \"\" {\n24: \t\treturn \"\", &router.JWTTokenMissingError{}\n25: \t}\n26: \n27: \tparts := strings.SplitN(authHeader, \" \", 2)\n28: \tif len(parts) != 2 {\n29: \t\treturn \"\", &router.JWTInvalidFormatError{Reason: \"missing token part\"}\n30: \t}\n31: \n32: \tif parts[0] != \"Bearer\" {\n33: \t\treturn \"\", &router.JWTInvalidFormatError{Reason: \"expected Bearer prefix\"}\n34: \t}\n35: \n36: \tif parts[1] == \"\" {\n37: \t\treturn \"\", &router.JWTInvalidFormatError{Reason: \"empty token\"}\n38: \t}\n39: \n40: \treturn parts[1], nil\n41: }\n42: \n43: func JWTAuthMiddleware(jwtManager *router.JWTManager) gin.HandlerFunc {\n44: \treturn JWTAuthMiddlewareWithConfig(&JWTAuthMiddlewareConfig{\n45: \t\tJWTManager:     jwtManager,\n46: \t\tTokenExtractor: DefaultTokenExtractor,\n47: \t})\n48: }\n49: \n50: func JWTAuthMiddlewareWithConfig(config *JWTAuthMiddlewareConfig) gin.HandlerFunc {\n51: \tif config == nil || config.JWTManager == nil {\n52: \t\treturn func(c *gin.Context) {\n53: \t\t\tc.Next()\n54: \t\t}\n55: \t}\n56: \n57: \textractor := config.TokenExtractor\n58: \tif extractor == nil {\n59: \t\textractor = DefaultTokenExtractor\n60: \t}\n61: \n62: \tskipPaths := config.SkipPaths\n63: \n64: \treturn func(c *gin.Context) {\n65: \t\tpath := c.Request.URL.Path\n66: \n67: \t\tfor _, skipPath := range skipPaths {\n68: \t\t\tif strings.HasPrefix(path, skipPath) || path == skipPath {\n69: \t\t\t\tc.Next()\n70: \t\t\t\treturn\n71: \t\t\t}\n72: \t\t}\n73: \n74: \t\ttokenString, err := extractor(c.Request)\n75: \t\tif err != nil {\n76: \t\t\trespondWithError(c, err)\n77: \t\t\tc.Abort()\n78: \t\t\treturn\n79: \t\t}\n80: \n81: \t\tclaims, err := config.JWTManager.ValidateToken(tokenString)\n82: \t\tif err != nil {\n83: \t\t\trespondWithError(c, err)\n84: \t\t\tc.Abort()\n85: \t\t\treturn\n86: \t\t}\n87: \n88: \t\tc.Set(\"session_id\", claims.SessionID)\n89: \t\tc.Set(\"sandbox_id\", claims.SandboxID)\n90: \t\tc.Set(\"namespace\", claims.Namespace)\n91: \t\tc.Set(\"name\", claims.Name)\n92: \t\tc.Set(\"jwt_claims\", claims)\n93: \n94: \t\tc.Next()\n95: \t}\n96: }\n97: \n98: func respondWithError(c *gin.Context, err error) {\n99: \tvar status int\n100: \tvar code string\n101: \tvar message string\n102: \n103: \tif apiErr, ok := err.(router.APIStatus); ok {\n104: \t\tstatus = apiErr.Status()\n105: \t\tcode = apiErr.Code()\n106: \t\tmessage = apiErr.Message()\n107: \t} else {\n108: \t\tstatus = http.StatusUnauthorized\n109: \t\tcode = \"JWT_VALIDATION_FAILED\"\n110: \t\tmessage = \"jwt validation failed\"\n111: \t}\n112: \n113: \tc.JSON(status, gin.H{\n114: \t\t\"error\": message,\n115: \t\t\"code\":  code,\n116: \t})\n117: }\n118: \n119: func GetClaimsFromContext(c *gin.Context) *router.RouterClaims {\n120: \tclaims, exists := c.Get(\"jwt_claims\")\n121: \tif !exists {\n122: \t\treturn nil\n123: \t}\n124: \n125: \trouterClaims, ok := claims.(*router.RouterClaims)\n126: \tif !ok {\n127: \t\treturn nil\n128: \t}\n129: \n130: \treturn routerClaims\n131: }\n132: \n133: func GetSessionIDFromContext(c *gin.Context) string {\n134: \tsessionID, exists := c.Get(\"session_id\")\n135: \tif !exists {\n136: \t\treturn \"\"\n137: \t}\n138: \n139: \tif s, ok := sessionID.(string); ok {\n140: \t\treturn s\n141: \t}\n142: \treturn \"\"\n143: }\n144: \n145: func GetSandboxIDFromContext(c *gin.Context) string {\n146: \tsandboxID, exists := c.Get(\"sandbox_id\")\n147: \tif !exists {\n148: \t\treturn \"\"\n149: \t}\n150: \n151: \tif s, ok := sandboxID.(string); ok {\n152: \t\treturn s\n153: \t}\n154: \treturn \"\"\n155: }\n156: \n157: func GetNamespaceFromContext(c *gin.Context) string {\n158: \tnamespace, exists := c.Get(\"namespace\")\n159: \tif !exists {\n160: \t\treturn \"\"\n161: \t}\n162: \n163: \tif s, ok := namespace.(string); ok {\n164: \t\treturn s\n165: \t}\n166: \treturn \"\"\n167: }\n168: \n169: func GetNameFromContext(c *gin.Context) string {\n170: \tname, exists := c.Get(\"name\")\n171: \tif !exists {\n172: \t\treturn \"\"\n173: \t}\n174: \n175: \tif s, ok := name.(string); ok {\n176: \t\treturn s\n177: \t}\n178: \treturn \"\"\n179: }\n180: \n181: type TokenRequest struct {\n182: \tUserID   string                 `json:\"user_id\"`\n183: \tRoles    []string               `json:\"roles,omitempty\"`\n184: \tMetadata map[string]interface{} `json:\"metadata,omitempty\"`\n185: }\n186: \n187: type TokenResponse struct {\n188: \tAccessToken  string `json:\"access_token\"`\n189: \tRefreshToken string `json:\"refresh_token\"`\n190: \tExpiresIn    int64  `json:\"expires_in\"`\n191: \tTokenType    string `json:\"token_type\"`\n192: }\n193: \n194: type RefreshRequest struct {\n195: \tRefreshToken string `json:\"refresh_token\"`\n196: }\n197: \n198: type PublicKeyResponse struct {\n199: \tPublicKey string `json:\"public_key\"`\n200: \tAlgorithm string `json:\"algorithm\"`\n201: \tIssuer    string `json:\"issuer\"`\n202: }\n203: \n204: func TokenIssuanceHandler(jwtManager *router.JWTManager) gin.HandlerFunc {\n205: \treturn func(c *gin.Context) {\n206: \t\tvar req TokenRequest\n207: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n208: \t\t\tc.JSON(http.StatusBadRequest, gin.H{\n209: \t\t\t\t\"error\": \"invalid request body\",\n210: \t\t\t\t\"code\":  \"INVALID_REQUEST\",\n211: \t\t\t})\n212: \t\t\treturn\n213: \t\t}\n214: \n215: \t\tclaims := &router.RouterClaims{\n216: \t\t\tSessionID: req.UserID,\n217: \t\t}\n218: \n219: \t\tif req.Metadata != nil {\n220: \t\t\tif sandboxID, ok := req.Metadata[\"sandbox_id\"].(string); ok {\n221: \t\t\t\tclaims.SandboxID = sandboxID\n222: \t\t\t}\n223: \t\t\tif namespace, ok := req.Metadata[\"namespace\"].(string); ok {\n224: \t\t\t\tclaims.Namespace = namespace\n225: \t\t\t}\n226: \t\t\tif name, ok := req.Metadata[\"name\"].(string); ok {\n227: \t\t\t\tclaims.Name = name\n228: \t\t\t}\n229: \t\t}\n230: \n231: \t\ttokenPair, err := jwtManager.GenerateTokenPair(claims)\n232: \t\tif err != nil {\n233: \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n234: \t\t\t\t\"error\": \"token generation failed\",\n235: \t\t\t\t\"code\":  \"TOKEN_GENERATION_FAILED\",\n236: \t\t\t})\n237: \t\t\treturn\n238: \t\t}\n239: \n240: \t\tc.JSON(http.StatusOK, TokenResponse{\n241: \t\t\tAccessToken:  tokenPair.AccessToken,\n242: \t\t\tRefreshToken: tokenPair.RefreshToken,\n243: \t\t\tExpiresIn:    tokenPair.ExpiresIn,\n244: \t\t\tTokenType:    tokenPair.TokenType,\n245: \t\t})\n246: \t}\n247: }\n248: \n249: func TokenRefreshHandler(jwtManager *router.JWTManager) gin.HandlerFunc {\n250: \treturn func(c *gin.Context) {\n251: \t\tvar req RefreshRequest\n252: \t\tif err := c.ShouldBindJSON(&req); err != nil {\n253: \t\t\tc.JSON(http.StatusBadRequest, gin.H{\n254: \t\t\t\t\"error\": \"invalid request body\",\n255: \t\t\t\t\"code\":  \"INVALID_REQUEST\",\n256: \t\t\t})\n257: \t\t\treturn\n258: \t\t}\n259: \n260: \t\tif req.RefreshToken == \"\" {\n261: \t\t\tc.JSON(http.StatusBadRequest, gin.H{\n262: \t\t\t\t\"error\": \"refresh token required\",\n263: \t\t\t\t\"code\":  \"REFRESH_TOKEN_REQUIRED\",\n264: \t\t\t})\n265: \t\t\treturn\n266: \t\t}\n267: \n268: \t\ttokenPair, err := jwtManager.RefreshToken(req.RefreshToken)\n269: \t\tif err != nil {\n270: \t\t\tif apiErr, ok := err.(router.APIStatus); ok {\n271: \t\t\t\tc.JSON(apiErr.Status(), gin.H{\n272: \t\t\t\t\t\"error\": apiErr.Message(),\n273: \t\t\t\t\t\"code\":  apiErr.Code(),\n274: \t\t\t\t})\n275: \t\t\t\treturn\n276: \t\t\t}\n277: \t\t\tc.JSON(http.StatusUnauthorized, gin.H{\n278: \t\t\t\t\"error\": \"refresh token invalid\",\n279: \t\t\t\t\"code\":  \"REFRESH_TOKEN_INVALID\",\n280: \t\t\t})\n281: \t\t\treturn\n282: \t\t}\n283: \n284: \t\tc.JSON(http.StatusOK, TokenResponse{\n285: \t\t\tAccessToken:  tokenPair.AccessToken,\n286: \t\t\tRefreshToken: tokenPair.RefreshToken,\n287: \t\t\tExpiresIn:    tokenPair.ExpiresIn,\n288: \t\t\tTokenType:    tokenPair.TokenType,\n289: \t\t})\n290: \t}\n291: }\n292: \n293: func PublicKeyHandler(jwtManager *router.JWTManager) gin.HandlerFunc {\n294: \treturn func(c *gin.Context) {\n295: \t\tpublicKeyPEM := jwtManager.GetPublicKeyPEM()\n296: \t\tif publicKeyPEM == \"\" {\n297: \t\t\tc.JSON(http.StatusInternalServerError, gin.H{\n298: \t\t\t\t\"error\": \"public key not available\",\n299: \t\t\t\t\"code\":  \"PUBLIC_KEY_NOT_AVAILABLE\",\n300: \t\t\t})\n301: \t\t\treturn\n302: \t\t}\n303: \n304: \t\tc.JSON(http.StatusOK, PublicKeyResponse{\n305: \t\t\tPublicKey: publicKeyPEM,\n306: \t\t\tAlgorithm: \"RS256\",\n307: \t\t\tIssuer:    \"agentcube-router\",\n308: \t\t})\n309: \t}\n310: }\n\n(End of file - total 310 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"strings\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/volcano-sh/agentcube/pkg/router\"\n)\n\ntype JWTAuthMiddlewareConfig struct {\n\tSkipPaths      []string\n\tTokenExtractor TokenExtractor\n\tKeyFunc        jwt.Keyfunc\n\tJWTManager     *router.JWTManager\n}\n\ntype TokenExtractor func(r *http.Request) (string, error)\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/middleware/auth.go","time":{"start":1775863505575,"end":1775863505619}}}}
