\"auth-enabled\" default:\"true\" usage:\"Enable authentication\"`\n126:     MaxExecTime  int    `flag:\"max-exec-time\" default:\"30\" usage:\"Maximum execution time in seconds\"`\n127:     MaxFileSize  int64  `flag:\"max-file-size\" default:\"10485760\" usage:\"Maximum file size in bytes\"`\n128:     SanitizeRoot string `flag:\"sanitize-root\" default:\"\" usage:\"Root directory for path sanitization\"`\n129: }\n130: ```\n131: \n132: ### Router CLI Configuration\n133: \n134: ```go\n135: package main\n136: \n137: type RouterConfig struct {\n138:     CLIConfig\n139:     Port                 string `flag:\"port\" default:\":8080\" usage:\"HTTP listening port\"`\n140:     MaxConcurrentRequests int   `flag:\"max-concurrent\" default:\"1000\" usage:\"Maximum concurrent requests\"`\n141:     Debug                bool   `flag:\"debug\" default:\"false\" usage:\"Enable debug mode\"`\n142:     EnableTLS            bool   `flag:\"enable-tls\" default:\"false\" usage:\"Enable TLS\"`\n143:     TLSCert              string `flag:\"tls-cert\" default:\"\" usage:\"TLS certificate file\"`\n144:     TLSKey               string `flag:\"tls-key\" default:\"\" usage:\"TLS key file\"`\n145:     StoreAddr            string `flag:\"store-addr\" default:\"\" usage:\"Redis/Valkey address\"`\n146:     StorePassword        string `flag:\"store-password\" default:\"\" usage:\"Redis/Valkey password\"`\n147:     StoreType            string `flag:\"store-type\" default:\"redis\" usage:\"Store type (redis, valkey)\"`\n148: }\n149: ```\n150: \n151: ### WorkloadManager CLI Configuration\n152: \n153: ```go\n154: package main\n155: \n156: type WorkloadManagerConfig struct {\n157:     CLIConfig\n158:     Addr              string        `flag:\"addr\" default:\":8080\" usage:\"HTTP server address\"`\n159:     ReadTimeout       time.Duration `flag:\"read-timeout\" default:\"30s\" usage:\"HTTP read timeout\"`\n160:     WriteTimeout      time.Duration `flag:\"write-timeout\" default:\"30s\" usage:\"HTTP write timeout\"`\n161:     IdleTimeout       time.Duration `flag:\"idle-timeout\" default:\"90s\" usage:\"HTTP idle timeout\"`\n162:     ShutdownTimeout   time.Duration `flag:\"shutdown-timeout\" default:\"10s\" usage:\"Graceful shutdown timeout\"`\n163:     GCInterval        time.Duration `flag:\"gc-interval\" default:\"5m\" usage:\"Garbage collection interval\"`\n164:     GCOnceTimeout     time.Duration `flag:\"gc-once-timeout\" default:\"30s\" usage:\"Single GC run timeout\"`\n165:     Kubeconfig        string        `flag:\"kubeconfig\" default:\"\" usage:\"Kubernetes config file path\"`\n166:     MasterURL         string        `flag:\"master-url\" default:\"\" usage:\"Kubernetes API server URL\"`\n167: }\n168: ```\n169: \n170: ### Agentd CLI Configuration\n171: \n172: ```go\n173: package main\n174: \n175: type AgentdConfig struct {\n176:     CLIConfig\n177:     IdleThreshold        time.Duration `flag:\"idle-threshold\" default:\"30m\" usage:\"Idle threshold for cleanup\"`\n178:     CheckInterval        time.Duration `flag:\"check-interval\" default:\"5m\" usage:\"Cleanup check interval\"`\n179:     MaxConcurrentCleanup int           `flag:\"max-concurrent\" default:\"10\" usage:\"Maximum concurrent cleanups\"`\n180:     Namespaces           []string      `flag:\"namespace\" default:\"default\" usage:\"Namespaces to watch\"`\n181:     LeaderElection       bool          `flag:\"leader-election\" default:\"true\" usage:\"Enable leader election\"`\n182:     LeaderElectionID     string        `flag:\"leader-election-id\" default:\"agentcube-agentd\" usage:\"Leader election ID\"`\n183:     Kubeconfig           string        `flag:\"kubeconfig\" default:\"\" usage:\"Kubernetes config file path\"`\n184: }\n185: ```\n186: \n187: ---\n188: \n189: ## API Contracts\n190: \n191: ### Binary Entry Point Interface\n192: \n193: Each binary follows this pattern:\n194: \n195: ```go\n196: package main\n197: \n198: type Binary interface {\n199:     InitFlags() *Config\n200:     ValidateConfig(cfg *Config) error\n201:     Run(ctx context.Context, cfg *Config) error\n202:     Shutdown(ctx context.Context) error\n203: }\n204: \n205: func main() {\n206:     klog.InitFlags(nil)\n207:     flag.Parse()\n208:     \n209:     cfg := InitFlags()\n210:     if err := ValidateConfig(cfg); err != nil {\n211:         klog.Fatalf(\"invalid config: %v\", err)\n212:         os.Exit(1)\n213:     }\n214:     \n215:     ctx, cancel := signal.NotifyContext(context.Background(), syscall.SIGTERM, syscall.SIGINT)\n216:     defer cancel()\n217:     \n218:     if err := Run(ctx, cfg); err != nil {\n219:         klog.Fatalf(\"run error: %v\", err)\n220:         os.Exit(1)\n221:     }\n222: }\n223: ```\n224: \n225: ### Signal Handling Contract\n226: \n227: ```go\n228: package main\n229: \n230: func setupSignalHandler() context.Context {\n231:     ctx, cancel := context.WithCancel(context.Background())\n232:     \n233:     c := make(chan os.Signal, 2)\n234:     signal.Notify(c, syscall.SIGTERM, syscall.SIGINT)\n235:     \n236:     go func() {\n237:         sig := <-c\n238:         klog.InfoS(\"received signal\", \"signal\", sig)\n239:         cancel()\n240:         \n241:         if sig == syscall.SIGKILL {\n242:             <-c\n243:             klog.InfoS(\"received second signal, forcing exit\")\n244:             os.Exit(1)\n245:         }\n246:     }()\n247:     \n248:     return ctx\n249: }\n250: ```\n251: \n252: ### Health Check Contract\n253: \n254: ```go\n255: package main\n256: \n257: type HealthChecker interface {\n258:     Live() bool\n259:     Ready() bool\n260: }\n261: \n262: func (h *HealthServer) Start(addr string) error {\n263:     mux := http.NewServeMux()\n264:     mux.HandleFunc(\"/live\", func(w http.ResponseWriter, r *http.Request) {\n265:         if h.Live() {\n266:             w.WriteHeader(http.StatusOK)\n267:             w.Write([]byte(\"OK\"))\n268:         } else {\n269:             w.WriteHeader(http.StatusServiceUnavailable)\n270:         }\n271:     })\n272:     mux.HandleFunc(\"/ready\", func(w http.ResponseWriter, r *http.Request) {\n273:         if h.Ready() {\n274:             w.WriteHeader(http.StatusOK)\n275:             w.Write([]byte(\"OK\"))\n276:         } else {\n277:             w.WriteHeader(http.StatusServiceUnavailable)\n278:         }\n279:     })\n280:     return http.ListenAndServe(addr, mux)\n281: }\n282: ```\n283: \n284: ### Flag Registration Contract\n285: \n286: ```go\n287: package main\n288: \n289: func InitFlags() *Config {\n290:     cfg := &Config{}\n291:     \n292:     klog.InitFlags(nil)\n293:     flag.Set(\"logtostderr\", \"true\")\n294:     \n295:     flag.StringVar(&cfg.LogLevel, \"log-level\", \"info\", \"Log level\")\n296:     flag.StringVar(&cfg.MetricsAddr, \"metrics-addr\", \"0\", \"Metrics address\")\n297:     flag.StringVar(&cfg.HealthAddr, \"health-addr\", \"\", \"Health address\")\n298:     \n299:     flag.Parse()\n300:     \n301:     return cfg\n302: }\n303: ```\n304: \n305: ---\n306: \n307: ## Binary Implementation Details\n308: \n309: ### 1. picod (cmd/picod/main.go)\n310: \n311: **Purpose**: Local code execution daemon running as a sidecar in sandbox pods.\n312: \n313: **Current Implementation** (pkg/picod/server.go:26-77):\n314: \n315: ```go\n316: func main() {\n317:     klog.InitFlags(nil)\n318:     flag.Set(\"logtostderr\", \"true\")\n319: \n320:     port := flag.Int(\"port\", 8080, \"HTTP listening port\")\n321:     workspace := flag.String(\"workspace\", \"\", \"Workspace directory path\")\n322:     flag.Parse()\n323: \n324:     config := &picod.Config{\n325:         Port:      *port,\n326:         Workspace: *workspace,\n327:     }\n328: \n329:     server, err := picod.NewServer(config)\n330:     if err != nil {\n331:         klog.Fatalf(\"failed to create server: %v\", err)\n332:         os.Exit(1)\n333:     }\n334: \n335:     if err := server.Run(context.Background()); err != nil {\n336:         klog.Fatalf(\"server error: %v\", err)\n337:         os.Exit(1)\n338:     }\n339: }\n340: ```\n341: \n342: **Endpoints**:\n343: | Path | Method | Purpose |\n344: |------|--------|---------|\n345: | `/health` | GET | Health check |\n346: | `/api/execute` | POST | Execute code |\n347: | `/api/files` | POST | Upload file |\n348: | `/api/files` | GET | List files |\n349: | `/api/files/*path` | GET | Download file |\n350: \n351: ### 2. router (cmd/router/main.go)\n352: \n353: **Purpose**: Session routing and reverse proxy for agent/code interpreter invocations.\n354: \n355: **Implementation Template**:\n356: \n357: ```go\n358: func main() {\n359:     klog.InitFlags(nil)\n360:     flag.Set(\"logtostderr\", \"true\")\n361:     \n362:     cfg := &RouterConfig{}\n363:     flag.StringVar(&cfg.Port, \"port\", \":8080\", \"HTTP listening port\")\n364:     flag.StringVar(&cfg.StoreAddr, \"store-addr\", \"\", \"Redis/Valkey address\")\n365:     flag.StringVar(&cfg.StoreType, \"store-type\", \"redis\", \"Store type\")\n366:     flag.IntVar(&cfg.MaxConcurrentRequests, \"max-concurrent\", 1000, \"Max concurrent requests\")\n367:     flag.BoolVar(&cfg.Debug, \"debug\", false, \"Enable debug mode\")\n368:     flag.Parse()\n369:     \n370:     ctx := setupSignalHandler()\n371:     \n372:     store, err := initStore(cfg)\n373:     if err != nil {\n374:         klog.Fatalf(\"failed to init store: %v\", err)\n375:     }\n376:     \n377:     sessionManager := router.NewSessionManager(store)\n378:     jwtManager := router.NewJWTManager()\n379:     \n380:     server := router.NewServer(&router.Config{\n381:         Port:                 cfg.Port,\n382:         MaxConcurrentRequests: cfg.MaxConcurrentRequests,\n383:         Debug:                cfg.Debug,\n384:     }, sessionManager, store, jwtManager, klog.Logger{})\n385:     \n386:     if err := server.Start(ctx); err != nil {\n387:         klog.Fatalf(\"router error: %v\", err)\n388:     }\n389: }\n390: ```\n391: \n392: **Endpoints**:\n393: | Path | Method | Purpose |\n394: |------|--------|---------|\n395: | `/health/live` | GET | Liveness probe |\n396: | `/health/ready` | GET | Readiness probe |\n397: | `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` | GET/POST | Agent invocation proxy |\n398: | `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path` | GET/POST | Code interpreter proxy |\n399: \n400: ### 3. workloadmanager (cmd/workloadmanager/main.go)\n401: \n402: **Purpose**: Workload manager HTTP server for sandbox lifecycle management.\n403: \n404: **Implementation Template**:\n405: \n406: ```go\n407: func main() {\n408:     klog.InitFlags(nil)\n409:     flag.Set(\"logtostderr\", \"true\")\n410:     \n411:     cfg := &WorkloadManagerConfig{}\n412:     flag.StringVar(&cfg.Addr, \"addr\", \":8080\", \"HTTP server address\")\n413:     flag.DurationVar(&cfg.ReadTimeout, \"read-timeout\", 30*time.Second, \"Read timeout\")\n414:     flag.DurationVar(&cfg.WriteTimeout, \"write-timeout\", 30*time.Second, \"Write timeout\")\n415:     flag.DurationVar(&cfg.GCInterval, \"gc-interval\", 5*time.Minute, \"GC interval\")\n416:     flag.StringVar(&cfg.Kubeconfig, \"kubeconfig\", \"\", \"Kubeconfig path\")\n417:     flag.Parse()\n418:     \n419:     ctx := setupSignalHandler()\n420:     \n421:     k8sClient, err := workloadmanager.NewK8sClient(cfg.Kubeconfig, cfg.MasterURL)\n422:     if err != nil {\n423:         klog.Fatalf(\"failed to create k8s client: %v\", err)\n424:     }\n425:     \n426:     store, err := initStore(cfg)\n427:     if err != nil {\n428:         klog.Fatalf(\"failed to init store: %v\", err)\n429:     }\n430:     \n431:     server := workloadmanager.NewHTTPServerWithClients(\n432:         workloadmanager.Config{\n433:             Addr:            cfg.Addr,\n434:             ReadTimeout:     cfg.ReadTimeout,\n435:             WriteTimeout:    cfg.WriteTimeout,\n436:             ShutdownTimeout: cfg.ShutdownTimeout,\n437:         },\n438:         klog.Logger{},\n439:         k8sClient,\n440:         store,\n441:     )\n442:     \n443:     server.RegisterHandler(\"health\", workloadmanager.NewHealthHandler())\n444:     server.RegisterHandler(\"sandbox\", workloadmanager.NewSandboxHandler(k8sClient, store))\n445:     \n446:     server.GracefulShutdown()\n447:     \n448:     errCh := server.Start()\n449:     select {\n450:     case err := <-errCh:\n451:         klog.Fatalf(\"workloadmanager error: %v\", err)\n452:     case <-ctx.Done():\n453:         server.Stop(context.Background())\n454:     }\n455: }\n456: ```\n457: \n458: **Endpoints**:\n459: | Path | Method | Purpose |\n460: |------|--------|---------|\n461: | `/health/live` | GET | Liveness probe |\n462: | `/health/ready` | GET | Readiness probe |\n463: | `/sandboxes` | POST | Create sandbox |\n464: | `/sandboxes/:id` | GET | Get sandbox |\n465: | `/sandboxes/:id` | DELETE | Delete sandbox |\n466: \n467: ### 4. agentd (cmd/agentd/main.go)\n468: \n469: **Purpose**: Kubernetes controller for idle resource cleanup using controller-runtime.\n470: \n471: **Implementation Template**:\n472: \n473: ```go\n474: func main() {\n475:     klog.InitFlags(nil)\n476:     flag.Set(\"logtostderr\", \"true\")\n477:     \n478:     cfg := &AgentdConfig{}\n479:     flag.DurationVar(&cfg.IdleThreshold, \"idle-threshold\", 30*time.Minute, \"Idle threshold\")\n480:     flag.DurationVar(&cfg.CheckInterval, \"check-interval\", 5*time.Minute, \"Check interval\")\n481:     flag.IntVar(&cfg.MaxConcurrentCleanup, \"max-concurrent\", 10, \"Max concurrent cleanups\")\n482:     flag.BoolVar(&cfg.LeaderElection, \"leader-election\", true, \"Enable leader election\")\n483:     flag.StringVar(&cfg.LeaderElectionID, \"leader-election-id\", \"agentcube-agentd\", \"Leader election ID\")\n484:     flag.Parse()\n485:     \n486:     k8sConfig, err := ctrl.GetConfig()\n487:     if err != nil {\n488:         klog.Fatalf(\"failed to get k8s config: %v\", err)\n489:     }\n490:     \n491:     mgr, err := ctrl.NewManager(k8sConfig, ctrl.Options{\n492:         LeaderElection:          cfg.LeaderElection,\n493:         LeaderElectionID:        cfg.LeaderElectionID,\n494:         LeaderElectionNamespace: \"default\",\n495:     })\n496:     if err != nil {\n497:         klog.Fatalf(\"failed to create manager: %v\", err)\n498:     }\n499:     \n500:     if err := agentd.SetupIdleCleanupController(mgr, cfg); err != nil {\n501:         klog.Fatalf(\"failed to setup controller: %v\", err)\n502:     }\n503:     \n504:     klog.InfoS(\"starting agentd controller\")\n505:     if err := mgr.Start(ctrl.SetupSignalHandler()); err != nil {\n506:         klog.Fatalf(\"controller error: %v\", err)\n507:     }\n508: }\n509: ```\n510: \n511: ---\n512: \n513: ## Error Handling\n514: \n515: ### Error Categories\n516: \n517: | Category | Description | Action |\n518: |----------|-------------|--------|\n519: | `ErrConfigInvalid` | Configuration validation failure | Log fatal, exit 1 |\n520: | `ErrStoreConnect` | Store connection failure | Log fatal, exit 1 |\n521: | `ErrK8sConnect` | Kubernetes connection failure | Log fatal, exit 1 |\n522: | `ErrServerStart` | HTTP server start failure | Log fatal, exit 1 |\n523: | `ErrSignalReceived` | Graceful shutdown triggered | Log info, cancel context |\n524: | `ErrShutdownTimeout` | Shutdown exceeded timeout | Log warning, force exit |\n525: \n526: ### Error Handling Pattern\n527: \n528: ```go\n529: func handleStartupError(component string, err error) {\n530:     if errors.Is(err, context.Canceled) {\n531:         klog.InfoS(\"shutdown requested\")\n532:         return\n533:     }\n534:     \n535:     if errors.Is(err, syscall.SIGTERM) || errors.Is(err, syscall.SIGINT) {\n536:         klog.InfoS(\"received termination signal\", \"signal\", err)\n537:         return\n538:     }\n539:     \n540:     klog.ErrorS(err, \"startup failure\", \"component\", component)\n541:     os.Exit(1)\n542: }\n543: ```\n544: \n545: ### Graceful Shutdown Sequence\n546: \n547: ```\n548: 1. Signal received (SIGTERM/SIGINT)\n549: 2. Cancel main context\n550: 3. Stop accepting new requests\n551: 4. Wait for in-flight requests (timeout configurable)\n552: 5. Close store connections\n553: 6. Close K8s client connections\n554: 7. Exit with code 0\n555: ```\n556: \n557: ### Validation Errors\n558: \n559: ```go\n560: func ValidateConfig(cfg *Config) error {\n561:     if cfg.Port <= 0 || cfg.Port > 65535 {\n562:         return fmt.Errorf(\"invalid port: %d\", cfg.Port)\n563:     }\n564:     \n565:     if cfg.IdleThreshold < 0 {\n566:         return fmt.Errorf(\"invalid idle threshold: %v\", cfg.IdleThreshold)\n567:     }\n568:     \n569:     if cfg.CheckInterval < 0 {\n570:         return fmt.Errorf(\"invalid check interval: %v\", cfg.CheckInterval)\n571:     }\n572:     \n573:     if cfg.MaxConcurrentCleanup < 0 {\n574:         return fmt.Errorf(\"invalid max concurrent cleanup: %d\", cfg.MaxConcurrentCleanup)\n575:     }\n576:     \n577:     return nil\n578: }\n579: ```\n580: \n581: ---\n582: \n583: ## Testing Strategy\n584: \n585: ### Unit Tests\n586: \n587: #### Flag Parsing Tests\n588: \n589: ```go\n590: func TestInitFlags(t *testing.T) {\n591:     tests := []struct {\n592:         name     string\n593:         args     []string\n594:         expected *Config\n595:     }{\n596:         {\n597:             name: \"default values\",\n598:             args: []string{},\n599:             expected: &Config{\n600:                 Port:           8080,\n601:                 LogLevel:       \"info\",\n602:                 IdleThreshold:  30 * time.Minute,\n603:             },\n604:         },\n605:         {\n606:             name: \"custom port\",\n607:             args: []string{\"-port\", \"9000\"},\n608:             expected: &Config{\n609:                 Port:          9000,\n610:             },\n611:         },\n612:         {\n613:             name: \"multiple flags\",\n614:             args: []string{\"-port\", \"9000\", \"-debug\", \"true\"},\n615:             expected: &Config{\n616:                 Port:  9000,\n617:                 Debug: true,\n618:             },\n619:         },\n620:     }\n621:     \n622:     for _, tt := range tests {\n623:         t.Run(tt.name, func(t *testing.T) {\n624:             fs := flag.NewFlagSet(\"test\", flag.ContinueOnError)\n625:             cfg := &Config{}\n626:             setupFlags(fs, cfg)\n627:             \n628:             err := fs.Parse(tt.args)\n629:             require.NoError(t, err)\n630:             \n631:             assert.Equal(t, tt.expected.Port, cfg.Port)\n632:         })\n633:     }\n634: }\n635: ```\n636: \n637: #### Signal Handler Tests\n638: \n639: ```go\n640: func TestSignalHandler(t *testing.T) {\n641:     ctx := setupSignalHandler()\n642:     \n643:     syscall.Kill(syscall.Getpid(), syscall.SIGTERM)\n644:     \n645:     select {\n646:     case <-ctx.Done():\n647:         assert.True(t, true)\n648:     case <-time.After(5 * time.Second):\n649:         t.Fatal(\"signal handler did not cancel context\")\n650:     }\n651: }\n652: ```\n653: \n654: #### Config Validation Tests\n655: \n656: ```go\n657: func TestValidateConfig(t *testing.T) {\n658:     tests := []struct {\n659:         name        string\n660:         config      *Config\n661:         expectError bool\n662:     }{\n663:         {\n664:             name: \"valid config\",\n665:             config: &Config{\n666:                 Port:          8080,\n667:                 IdleThreshold: 30 * time.Minute,\n668:             },\n669:             expectError: false,\n670:         },\n671:         {\n672:             name: \"invalid port\",\n673:             config: &Config{\n674:                 Port: -1,\n675:             },\n676:             expectError: true,\n677:         },\n678:         {\n679:             name: \"invalid idle threshold\",\n680:             config: &Config{\n681:                 IdleThreshold: -1 * time.Minute,\n682:             },\n683:             expectError: true,\n684:         },\n685:     }\n686:     \n687:     for _, tt := range tests {\n688:         t.Run(tt.name, func(t *testing.T) {\n689:             err := ValidateConfig(tt.config)\n690:             if tt.expectError {\n691:                 assert.Error(t, err)\n692:             } else {\n693:                 assert.NoError(t, err)\n694:             }\n695:         })\n696:     }\n697: }\n698: ```\n699: \n700: ### Integration Tests\n701: \n702: #### Binary Startup Tests\n703: \n704: ```go\n705: func TestBinaryStartup(t *testing.T) {\n706:     if testing.Short() {\n707:         t.Skip(\"skipping integration test\")\n708:     }\n709:     \n710:     binary := buildBinary(t, \"picod\")\n711:     \n712:     cmd := exec.Command(binary, \"-port\", \"18080\")\n713:     cmd.Stdout = &bytes.Buffer{}\n714:     cmd.Stderr = &bytes.Buffer{}\n715:     \n716:     err := cmd.Start()\n717:     require.NoError(t, err)\n718:     \n719:     defer cmd.Process.Kill()\n720:     \n721:     assert.Eventually(t, func() bool {\n722:         resp, err := http.Get(\"http://localhost:18080/health\")\n723:         if err != nil {\n724:             return false\n725:         }\n726:         defer resp.Body.Close()\n727:         return resp.StatusCode == http.StatusOK\n728:     }, 10*time.Second, 100*time.Millisecond)\n729: }\n730: ```\n731: \n732: #### Graceful Shutdown Tests\n733: \n734: ```go\n735: func TestGracefulShutdown(t *testing.T) {\n736:     binary := buildBinary(t, \"router\")\n737:     \n738:     cmd := exec.Command(binary, \"-port\", \":18080\", \"-store-type\", \"memory\")\n739:     cmd.Stdout = &bytes.Buffer{}\n740:     cmd.Stderr = &bytes.Buffer{}\n741:     \n742:     err := cmd.Start()\n743:     require.NoError(t, err)\n744:     \n745:     waitForHealthy(t, \"http://localhost:18080/health/live\")\n746:     \n747:     syscall.Kill(cmd.Process.Pid, syscall.SIGTERM)\n748:     \n749:     done := make(chan error, 1)\n750:     go func() {\n751:         done <- cmd.Wait()\n752:     }()\n753:     \n754:     select {\n755:     case err := <-done:\n756:         assert.NoError(t, err)\n757:     case <-time.After(15 * time.Second):\n758:         t.Fatal(\"binary did not shutdown within timeout\")\n759:     }\n760: }\n761: ```\n762: \n763: ### Build Tests\n764: \n765: ```go\n766: func TestBuildAllBinaries(t *testing.T) {\n767:     binaries := []string{\"picod\", \"router\", \"workloadmanager\", \"agentd\"}\n768:     \n769:     for _, binary := range binaries {\n770:         t.Run(binary, func(t *testing.T) {\n771:             cmd := exec.Command(\"go\", \"build\", \"-o\", \"/tmp/\"+binary, \"./cmd/\"+binary)\n772:             output, err := cmd.CombinedOutput()\n773:             assert.NoError(t, err, \"build output: %s\", output)\n774:             \n775:             assert.FileExists(t, \"/tmp/\"+binary)\n776:         })\n777:     }\n778: }\n779: ```\n780: \n781: ---\n782: \n783: ## Metrics\n784: \n785: ### Prometheus Metrics\n786: \n787: ```go\n788: var (\n789:     startupDuration = prometheus.NewGaugeVec(\n790:         prometheus.GaugeOpts{\n791:             Name: \"agentcube_binary_startup_duration_seconds\",\n792:             Help: \"Time taken for binary startup\",\n793:         },\n794:         []string{\"binary\"},\n795:     )\n796:     \n797:     shutdownDuration = prometheus.NewGaugeVec(\n798:         prometheus.GaugeOpts{\n799:             Name: \"agentcube_binary_shutdown_duration_seconds\",\n800:             Help: \"Time taken for graceful shutdown\",\n801:         },\n802:         []string{\"binary\"},\n803:     )\n804:     \n805:     configReloadCount = prometheus.NewCounterVec(\n806:         prometheus.CounterOpts{\n807:             Name: \"agentcube_binary_config_reload_total\",\n808:             Help: \"Number of configuration reloads\",\n809:         },\n810:         []string{\"binary\"},\n811:     )\n812: )\n813: ```\n814: \n815: ---\n816: \n817: ## Configuration\n818: \n819: ### Environment Variables\n820: \n821: | Variable | Binary | Purpose |\n822: |----------|--------|---------|\n823: | `PORT` | picod, router, workloadmanager | HTTP port override |\n824: | `WORKSPACE` | picod | Workspace directory |\n825: | `STORE_ADDR` | router, workloadmanager | Redis/Valkey address |\n826: | `STORE_TYPE` | router, workloadmanager | Store backend type |\n827: | `KUBECONFIG` | workloadmanager, agentd | Kubernetes config path |\n828: | `LOG_LEVEL` | all | Log level override |\n829: \n830: ### Command-Line Flags Summary\n831: \n832: | Flag | Default | Purpose |\n833: |------|---------|---------|\n834: | `-port` | 8080 | HTTP listening port |\n835: | `-workspace` | current dir | Workspace directory (picod) |\n836: | `-idle-threshold` | 30m | Idle cleanup threshold (agentd) |\n837: | `-check-interval` | 5m | Cleanup check interval (agentd) |\n838: | `-leader-election` | true | Enable leader election (agentd) |\n839: | `-kubeconfig` | in-cluster | Kubernetes config path |\n840: | `-debug` | false | Enable debug mode (router) |\n841: | `-metrics-addr` | 0 | Prometheus metrics address |\n842: \n843: ---\n844: \n845: ## Build Configuration\n846: \n847: ### Go Module\n848: \n849: ```go\n850: // go.mod\n851: module github.com/volcano-sh/agentcube\n852: \n853: go 1.24\n854: \n855: require (\n856:     github.com/gin-gonic/gin v1.x\n857:     github.com/go-chi/chi/v5 v5.x\n858:     k8s.io/klog/v2 v2.x\n859:     sigs.k8s.io/controller-runtime v0.19.x\n860: )\n861: ```\n862: \n863: ### Makefile Targets\n864: \n865: ```makefile\n866: .PHONY: build clean\n867: \n868: build:\n869: \tgo build -o bin/picod ./cmd/picod\n870: \tgo build -o bin/router ./cmd/router\n871: \tgo build -o bin/workloadmanager ./cmd/workloadmanager\n872: \tgo build -o bin/agentd ./cmd/agentd\n873: \n874: clean:\n875: \trm -rf bin/\n876: \n877: build-picod:\n878: \tgo build -o bin/picod ./cmd/picod\n879: \n880: build-router:\n881: \tgo build -o bin/router ./cmd/router\n882: \n883: build-workloadmanager:\n884: \tgo build -o bin/workloadmanager ./cmd/workloadmanager\n885: \n886: build-agentd:\n887: \tgo build -o bin/agentd ./cmd/agentd\n888: ```\n889: \n890: ### Docker Build\n891: \n892: ```dockerfile\n893: # Dockerfile for picod\n894: FROM golang:1.24-alpine AS builder\n895: WORKDIR /app\n896: COPY . .\n897: RUN go build -o /picod ./cmd/picod\n898: \n899: FROM alpine:3.19\n900: COPY --from=builder /picod /picod\n901: ENTRYPOINT [\"/picod\"]\n902: ```\n903: \n904: ---\n905: \n906: ## Implementation Checklist\n907: \n908: - [x] `cmd/picod/main.go` - PicoD entry point (implemented)\n909: - [ ] `cmd/router/main.go` - Router entry point\n910: - [ ] `cmd/workloadmanager/main.go` - WorkloadManager entry point\n911: - [ ] `cmd/agentd/main.go` - Agentd entry point\n912: - [ ] Common signal handling package\n913: - [ ] Common flag validation utilities\n914: - [ ] Health check server integration\n915: - [ ] Metrics server integration\n916: - [ ] Unit tests for flag parsing\n917: - [ ] Unit tests for config validation\n918: - [ ] Integration tests for binary startup\n919: - [ ] Integration tests for graceful shutdown\n920: - [ ] Makefile build targets\n921: - [ ] Docker build configurations\n922: - [ ] Helm deployment manifests\n923: \n924: ---\n925: \n926: ## Dependencies\n927: \n928: | Package | Version | Purpose |\n929: |---------|---------|---------|\n930: | `k8s.io/klog/v2` | v2.x | Structured logging |\n931: | `github.com/spf13/pflag` | v1.x | POSIX/GNU-style flags |\n932: | `sigs.k8s.io/controller-runtime` | v0.19.x | Controller utilities (agentd) |\n933: | `github.com/gin-gonic/gin` | v1.x | HTTP framework (picod, router) |\n934: | `github.com/go-chi/chi/v5` | v5.x | HTTP framework (workloadmanager) |\n935: | `github.com/prometheus/client_golang` | v1.x | Metrics |\n\n(End of file - total 935 lines)\n</content>","metadata":{"preview":"# AR-019: CLI Binary Entry Points (4 Binaries)\n\n## Overview\n\nThis module defines the CLI binary entry points for the agentcube system, consisting of four main executables:\n\n| Binary | Purpose | Module | HTTP Framework |\n|--------|---------|--------|----------------|\n| `picod` | Local code execution daemon | `pkg/picod` | Gin |\n| `router` | Session routing and reverse proxy | `pkg/router` | Gin |\n| `workloadmanager` | Workload manager HTTP server | `pkg/workloadmanager` | Chi |\n| `agentd` | Agent daemon (idle cleanup controller) | `pkg/agentd` | controller-runtime |\n\n---\n\n## Architecture\n\n### Directory Structure\n\n```","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/design.md","time":{"start":1775892144344,"end":1775892144359}}}}
{"type":"tool_use","timestamp":1775892144366,"sessionID":"ses_28494c9fbffeP4S03DBtYnzzzP","part":{"id":"prt_d7b6b9971001mq5iJ6pzI6wypE","messageID":"msg_d7b6b7806001ryF674LGvdqgyn","sessionID":"ses_28494c9fbffeP4S03DBtYnzzzP","type":"tool","tool":"read","callID":"toolu_tool-979cbf02a3d14416af80279e79d1d398","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/integrations/design.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/integrations/design.md</path>\n<type>file</type>\n<content>\n1: # AgentCube Integrations вҖ” Design\n2: \n3: Sources: `/tmp/agentcube-ref/integrations/dify-plugin/`, `/tmp/agentcube-ref/example/pcap-analyzer/`.\n4: \n5: ## Dify plugin вҖ” file map\n6: \n7: | File | Role |\n8: |------|------|\n9: | `main.py` | `Plugin(DifyPluginEnv(MAX_REQUEST_TIMEOUT=120)).run()` |\n10: | `manifest.yaml` | Root plugin manifest for Dify |\n11: | `provider/agentcube.yaml` | Tool provider identity + tool list + Python entry |\n12: | `provider/agentcube.py` | `AgentcubeCodeInterpreterProvider` |\n13: | `tools/agentcube-code-interpreter.yaml` | Tool parameter schema |\n14: | `tools/agentcube-code-interpreter.py` | `AgentcubeCodeInterpreterTool` |\n15: | `requirements.txt` | `dify-plugin` + `agentcube-sdk` pins |\n16: | `GUIDE.md`, `README.md`, `PRIVACY.md`, `.difyignore` | Docs / packaging |\n17: \n18: ## `manifest.yaml` structure (exact top-level keys)\n19: \n20: From source:\n21: \n22: - `version`: `0.0.2`\n23: - `type`: `plugin`\n24: - `author`: `volcano-sh`\n25: - `name`: `agentcube`\n26: - `label`: map `en_US`, `ja_JP`, `zh_Hans`, `pt_BR` вҶ’ `Agentcube`\n27: - `description`: multilingual strings (AgentCube description)\n28: - `icon`: `icon.png`\n29: - `icon_dark`: `icon-dark.png`\n30: - `resource`: `memory`, `permission` subtree (`tool`, `model`, `endpoint`, `app`, `storage` flags and sizes)\n31: - `plugins.tools`: list `[provider/agentcube.yaml]`\n32: - `meta`: `version`, `arch` (`amd64`, `arm64`), `runner` (`language: python`, `version: \"3.12\"`, `entrypoint: main`), `minimum_dify_version: null`\n33: - `created_at`, `privacy`, `repo`, `verified`\n34: \n35: ## `provider/agentcube.yaml` structure\n36: \n37: - `identity`: `author`, `name`, `label` (multilingual), `description` (multilingual), `icon`\n38: - Commented `oauth_schema` block (not active)\n39: - `tools`: list `[tools/agentcube-code-interpreter.yaml]`\n40: - `extra.python.source`: `provider/agentcube.py`\n41: \n42: ## Tool definition (`tools/agentcube-code-interpreter.yaml`)\n43: \n44: - `identity.name`: `agentcube-code-interpreter`\n45: - `identity.author`: `agentcube`\n46: - `identity.label` / `description` (human + llm strings)\n47: - `parameters` (each has `name`, `type`, `required`, `label`, `human_description`, `llm_description`, `form`):\n48: \n49: | name | type | required | form | notes |\n50: |------|------|----------|------|-------|\n51: | `router_url` | string | true | form | |\n52: | `workload_manager_url` | string | true | form | |\n53: | `language` | select | false | llm | options: `python`, `javascript`, `typescript` |\n54: | `code` | string | false | llm | |\n55: | `command` | string | false | llm | |\n56: | `session_id` | string | false | llm | |\n57: | `session_reuse` | boolean | false | llm | |\n58: | `code_interpreter_id` | string | false | llm | |\n59: \n60: - `extra.python.source`: `tools/agentcube-code-interpreter.py`\n61: \n62: ## Provider implementation (`provider/agentcube.py`)\n63: \n64: ```python\n65: from dify_plugin import ToolProvider\n66: from dify_plugin.errors.tool import ToolProviderCredentialValidationError\n67: \n68: class AgentcubeCodeInterpreterProvider(ToolProvider):\n69:     def _validate_credentials(self, credentials: dict[str, Any]) -> None:\n70:         try:\n71:             \"\"\" IMPLEMENT YOUR VALIDATION HERE \"\"\"\n72:         except Exception as e:\n73:             raise ToolProviderCredentialValidationError(str(e))\n74: ```\n75: \n76: (OAuth helper methods are present only as comments.)\n77: \n78: ## Tool implementation (`tools/agentcube-code-interpreter.py`)\n79: \n80: ```python\n81: from collections.abc import Generator\n82: from typing import Any\n83: from dify_plugin import Tool\n84: from dify_plugin.entities.tool import ToolInvokeMessage\n85: from agentcube import CodeInterpreterClient\n86: \n87: class AgentcubeCodeInterpreterTool(Tool):\n88:     def _invoke(self, tool_parameters: dict[str, Any]) -> Generator[ToolInvokeMessage]:\n89:         result = self.execute(**tool_parameters)\n90:         yield self.create_json_message(result)\n91: \n92:     def execute(\n93:         self,\n94:         router_url=None,\n95:         workload_manager_url=None,\n96:         language=\"python\",\n97:         code_interpreter_id=None,\n98:         session_id=None,\n99:         code=None,\n100:         command=None,\n101:         session_reuse=False,\n102:         **kwargs\n103:     ): ...\n104: ```\n105: \n106: ## Plugin dependencies (`integrations/dify-plugin/requirements.txt`)\n107: \n108: ```\n109: dify-plugin>=0.4.2,<0.5.0\n110: agentcube-sdk>=0.0.10\n111: ```\n112: \n113: ## PCAP analyzer вҖ” application structure (`example/pcap-analyzer/`)\n114: \n115: | File | Role |\n116: |------|------|\n117: | `pcap_analyzer.py` | FastAPI app, agents, sandbox runner, analysis orchestration, `uvicorn` entry |\n118: | `requirements.txt` | FastAPI, uvicorn, LangChain / LangGraph stack, multipart, etc. |\n119: | `Dockerfile` | `uv` base image, installs reqs, copies `sdk-python/agentcube` + `pcap_analyzer.py` |\n120: | `deployment.yaml` | K8s Deployment + env for OpenAI-compatible API and AgentCube URLs |\n121: | `README.md` | Documentation |\n122: \n123: ## FastAPI application (`pcap_analyzer.py`)\n124: \n125: ### Globals / config (selected)\n126: \n127: | Name | Source | Default / value |\n128: |------|--------|-----------------|\n129: | `API_KEY` | `OPENAI_API_KEY` | required at startup |\n130: | `API_BASE_URL` | `OPENAI_API_BASE` | `https://api.siliconflow.cn/v1` |\n131: | `MODEL_NAME` | `OPENAI_MODEL` | `Qwen/QwQ-32B` |\n132: | `CODEINTERPRETER_NAME` | env | `my-interpreter` |\n133: | `SANDBOX_NAMESPACE` | env | `default` |\n134: | `SANDBOX_WARMUP_SEC` | env | `5` |\n135: | `SERVER_HOST` | constant | `0.0.0.0` |\n136: | `SERVER_PORT` | constant | `8000` |\n137: | `SERVER_RELOAD` | constant | `True` |\n138: \n139: ### Core classes / functions\n140: \n141: ```python\n142: class SandboxRunner:\n143:     def __init__(self, name: str = \"my-interpreter\", namespace: str = \"default\", warmup_sec: int = 5): ...\n144:     def upload_file(self, local_path: str, remote_path: str) -> bool: ...\n145:     def upload_bytes(self, data: bytes, remote_path: str) -> bool: ...\n146:     def run(self, command: str) -> Dict[str, Any]: ...\n147:     def stop(self): ...\n148: \n149: def build_react_agent(llm, system_prompt: str): ...\n150: def invoke_react_agent(agent, user_text: str) -> str: ...\n151: def build_planner_agent(llm): ...\n152: def build_reporter_agent(llm): ...\n153: \n154: def _plan_script(agent, pcap_local_path: str) -> str: ...\n155: def _repair_script(agent, prev_script: str, results: List[Dict[str, Any]]) -> str: ...\n156: def _execute_once_in_runner(runner: SandboxRunner, pcap_local_path: str, script: str) -> List[Dict[str, Any]]: ...\n157: def _analyze_with_retries(..., max_retries: int = 2) -> Dict[str, Any]: ...\n158: def _report(agent, results: List[Dict[str, Any]]) -> str: ...\n159: \n160: class AnalyzeResponse(BaseModel):\n161:     script: str\n162:     results: List[Dict[str, Any]]\n163:     report: str\n164: \n165: app = FastAPI(title=\"PCAP Analyzer вҖ” Env-Only Config\")\n166: ```\n167: \n168: ### FastAPI endpoints\n169: \n170: | Method | Path | Signature / behavior |\n171: |--------|------|----------------------|\n172: | (event) | startup | `on_startup()` вҶ’ builds `ChatOpenAI`, `PLANNER`, `REPORTER`; fails if no API key |\n173: | `POST` | `/analyze` | `async def analyze_endpoint(pcap_file: UploadFile = File(None), pcap_path: str = Form(None))` вҶ’ `response_model=AnalyzeResponse` |\n174: \n175: ### Imports of note\n176: \n177: ```python\n178: from fastapi import FastAPI, UploadFile, File, Form, HTTPException\n179: from pydantic import BaseModel\n180: import uvicorn\n181: from langchain_openai import ChatOpenAI\n182: from langgraph.prebuilt import create_react_agent\n183: from langchain_core.messages import HumanMessage, AIMessage\n184: from agentcube.code_interpreter import CodeInterpreterClient\n185: from agentcube.exceptions import CommandExecutionError\n186: ```\n187: \n188: ## Kubernetes deployment (`deployment.yaml`)\n189: \n190: - `Deployment` `pcap-analyzer` in `namespace: default`\n191: - Container `pcap-analyzer`, image `pcap-analyzer:latest`, `imagePullPolicy: IfNotPresent`\n192: - Container port `8000` TCP\n193: - Resources: requests `cpu: 200m`, `memory: 100Mi`; limits `cpu: 1`, `memory: 1Gi`\n194: - Env: `OPENAI_API_KEY` from secret `pcap-analyzer-secrets` key `openai-api-key`; `OPENAI_API_BASE`, `OPENAI_MODEL`, `WORKLOAD_MANAGER_URL`, `ROUTER_URL`, `CODEINTERPRETER_NAME`, `SANDBOX_NAMESPACE`, `SANDBOX_WARMUP_SEC`\n195: - Command: `[\"uv\"]`, args: `[\"run\", \"pcap_analyzer.py\"]`\n196: \n197: ## Dockerfile highlights\n198: \n199: - Base: `ghcr.io/astral-sh/uv:python3.12-bookworm-slim`\n200: - `uv venv` + `uv pip install -r requirements.txt`\n201: - Copies `sdk-python/agentcube` вҶ’ `./agentcube/`, `pcap_analyzer.py` вҶ’ `./`\n202: - `ENV PYTHONPATH=\"/app\"`, exposes `8000`\n203: - `CMD [\"uv\", \"run\", \"pcap_analyzer.py\"]`\n204: \n205: ## PCAP example Python dependencies (`example/pcap-analyzer/requirements.txt`)\n206: \n207: Pinned packages include: `fastapi==0.120.0`, `uvicorn==0.38.0`, `langchain==1.0.2`, `langchain-classic==1.0.0`, `langchain-community==0.4.1`, `langchain-core==1.0.1`, `langchain-openai==1.0.1`, `langchain-text-splitters==1.0.0`, `langgraph==1.0.1`, `langgraph-checkpoint==3.0.0`, `langgraph-prebuilt==1.0.1`, `langgraph-sdk==0.2.9`, `langsmith==0.4.38`, `paramiko==4.0.0`, `python-multipart==0.0.20`\n208: \n209: *(The Dockerfile vendors `agentcube` from the monorepo copy; it is not listed in this `requirements.txt`.)*\n\n(End of file - total 209 lines)\n</content>","metadata":{"preview":"# AgentCube Integrations вҖ” Design\n\nSources: `/tmp/agentcube-ref/integrations/dify-plugin/`, `/tmp/agentcube-ref/example/pcap-analyzer/`.\n\n## Dify plugin вҖ” file map\n\n| File | Role |\n|------|------|\n| `main.py` | `Plugin(DifyPluginEnv(MAX_REQUEST_TIMEOUT=120)).run()` |\n| `manifest.yaml` | Root plugin manifest for Dify |\n| `provider/agentcube.yaml` | Tool provider identity + tool list + Python entry |\n| `provider/agentcube.py` | `AgentcubeCodeInterpreterProvider` |\n| `tools/agentcube-code-interpreter.yaml` | Tool parameter schema |\n| `tools/agentcube-code-interpreter.py` | `AgentcubeCodeInterpreterTool` |\n| `requirements.txt` | `dify-plugin` + `agentcube-sdk` pins |\n| `GUIDE.md`, `README.md`, `PRIVACY.md`, `.difyignore` | Docs / packaging |\n\n## `manifest.yaml` structure (exact top-level keys)\n\nFrom source:","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/integrations/design.md","time":{"start":1775892144338,"end":1775892144364}}}}
{"type":"tool_use","timestamp":1775892144370,"sessionID":"ses_28494c9fbffeP4S03DBtYnzzzP","part":{"id":"prt_d7b6b9ce3001hKeWOGsqSzBTDl","messageID":"msg_d7b6b7806001ryF674LGvdqgyn","sessionID":"ses_28494c9fbffeP4S03DBtYnzzzP","type":"tool","tool":"read","callID":"toolu_tool-41dcb4aeeac249819ce6e5d3f5f8644a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/integrations/spec.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/integrations/spec.md</path>\n<type>file</type>\n<content>\n1: # Integrations Specification\n2: \n3: ## Purpose\n4: \n5: Normative requirements for the AgentCube Dify plugin integration and the PCAP analyzer example that uses AgentCube code interpreters and Kubernetes sandboxes.\n6: \n7: ## Requirements\n8: \n9: ### Requirement: Dify plugin bootstrap and runtime\n10: \n11: The system SHALL expose a Dify-compatible Python plugin whose process entry runs the framework runner with a configured maximum request timeout.\n12: \n13: #### Scenario: Plugin process starts\n14: \n15: - **GIVEN** the plugin package is installed with compatible `dify-plugin` and `agentcube-sdk` versions\n16: - **WHEN** the platform starts the plugin using the manifest-declared entrypoint\n17: - **THEN** the plugin SHALL execute `main` which runs `Plugin(DifyPluginEnv(MAX_REQUEST_TIMEOUT=120)).run()` until the host stops it\n18: \n19: ---\n20: \n21: ### Requirement: Plugin manifest structure\n22: \n23: The system SHALL ship a root `manifest.yaml` declaring plugin metadata, tool provider registration, resource permissions, and runner metadata sufficient for Dify to load and execute the plugin.\n24: \n25: #### Scenario: Required manifest fields\n26: \n27: - **GIVEN** a valid plugin package root\n28: - **WHEN** the manifest is parsed by a Dify-compatible toolchain\n29: - **THEN** the manifest SHALL include `version`, `type: plugin`, `author`, `name`, `label` (multilingual map), `description` (multilingual), `icon`, `icon_dark`, `resource` (including `memory` and `permission` subtree), `plugins.tools` listing provider descriptors, and `meta` containing `version`, `arch`, `runner` (`language`, `version`, `entrypoint`), and `minimum_dify_version`\n30: \n31: #### Scenario: Tool provider wiring\n32: \n33: - **GIVEN** the manifest `plugins.tools` references the Agentcube provider descriptor\n34: - **WHEN** the plugin is loaded\n35: - **THEN** Dify SHALL resolve `provider/agentcube.yaml` and associate it with the Python module declared under `extra.python.source`\n36: \n37: ---\n38: \n39: ### Requirement: Provider descriptor structure\n40: \n41: The system SHALL define a tool provider YAML that identifies the provider, lists its tools, and points to the Python provider implementation.\n42: \n43: #### Scenario: Provider lists tools and entry module\n44: \n45: - **GIVEN** `provider/agentcube.yaml` is present\n46: - **WHEN** the integration runtime resolves the provider\n47: - **THEN** the descriptor SHALL include `identity` (author, name, multilingual label/description, icon), a `tools` list including `tools/agentcube-code-interpreter.yaml`, and `extra.python.source: provider/agentcube.py`\n48: \n49: ---\n50: \n51: ### Requirement: Tool parameter schema\n52: \n53: The system SHALL declare a tool schema for the code interpreter integration including connection endpoints, optional language selection, and code/command/session fields.\n54: \n55: #### Scenario: Declared parameters match remote APIs\n56: \n57: - **GIVEN** `tools/agentcube-code-interpreter.yaml`\n58: - **WHEN** an operator configures the tool in Dify\n59: - **THEN** the schema SHALL require string parameters `router_url` and `workload_manager_url`, SHALL offer optional `language` as a select among `python`, `javascript`, and `typescript`, and SHALL allow optional `code`, `command`, `session_id`, `session_reuse` (boolean), and `code_interpreter_id`, each documented for human and LLM-oriented forms\n60: \n61: ---\n62: \n63: ### Requirement: Tool provider credential validation\n64: \n65: The system SHALL implement credential validation on the tool provider class and SHALL surface validation failures using the Dify tool provider error type.\n66: \n67: #### Scenario: Invalid credentials are rejected\n68: \n69: - **GIVEN** an instance of `AgentcubeCodeInterpreterProvider`\n70: - **WHEN** `_validate_credentials` encounters an error condition the implementer treats as invalid\n71: - **THEN** the provider SHALL raise `ToolProviderCredentialValidationError` with a string message derived from the failure\n72: \n73: #### Scenario: Successful validation completes quietly\n74: \n75: - **GIVEN** credentials that satisfy the providerвҖҷs validation rules\n76: - **WHEN** `_validate_credentials` runs\n77: - **THEN** the method SHALL return without raising\n78: \n79: ---\n80: \n81: ### Requirement: Tool invocation and JSON messaging\n82: \n83: The system SHALL implement the Agentcube code interpreter tool as a Dify `Tool` that delegates execution and returns structured JSON to the host.\n84: \n85: #### Scenario: Dify invokes the tool\n86: \n87: - **GIVEN** a configured tool invocation with parameters matching the schema\n88: - **WHEN** Dify calls `_invoke` on `AgentcubeCodeInterpreterTool`\n89: - **THEN** the tool SHALL call `execute(**tool_parameters)` and SHALL yield `create_json_message(result)` for the outcome\n90: \n91: ---\n92: \n93: ### Requirement: Tool execution API surface\n94: \n95: The system SHALL implement `execute` with parameters for router and workload manager URLs, optional language, session controls, and code or command execution, delegating to `agentcube.CodeInterpreterClient`.\n96: \n97: #### Scenario: Code or command runs against configured endpoints\n98: \n99: - **GIVEN** valid `router_url`, `workload_manager_url`, and optional `language` defaulting to `python`\n100: - **WHEN** the tool receives `code` and/or `command` with optional `session_id`, `session_reuse`, and `code_interpreter_id`\n101: - **THEN** the tool SHALL use the AgentCube Python SDK client to perform the corresponding remote operations and SHALL return a JSON-serializable result object suitable for `create_json_message`\n102: \n103: ---\n104: \n105: ### Requirement: Plugin Python dependencies\n106: \n107: The system SHALL pin compatible versions of `dify-plugin` and `agentcube-sdk` for reproducible installs.\n108: \n109: #### Scenario: Dependency bounds\n110: \n111: - **GIVEN** `integrations/dify-plugin/requirements.txt`\n112: - **WHEN** dependencies are installed in a clean environment\n113: - **THEN** installs SHALL satisfy `dify-plugin>=0.4.2,<0.5.0` and `agentcube-sdk>=0.0.10`\n114: \n115: ---\n116: \n117: ### Requirement: PCAP analyzer FastAPI service\n118: \n119: The system SHALL provide a FastAPI application that validates OpenAI-compatible configuration at startup, composes LangChain/LangGraph agents, and exposes an analysis endpoint for PCAP uploads.\n120: \n121: #### Scenario: Startup requires API key\n122: \n123: - **GIVEN** the process is started without a usable `OPENAI_API_KEY` (or equivalent configured API key)\n124: - **WHEN** the application completes startup hooks\n125: - **THEN** startup SHALL fail rather than serve requests without credentials\n126: \n127: #### Scenario: Analyze endpoint accepts PCAP input\n128: \n129: - **GIVEN** a running service with valid LLM configuration\n130: - **WHEN** a client calls `POST /analyze` with either an uploaded PCAP file or a `pcap_path` form field\n131: - **THEN** the handler SHALL return a body matching `AnalyzeResponse` including `script`, `results`, and `report`\n132: \n133: ---\n134: \n135: ### Requirement: PCAP analyzer configuration surface\n136: \n137: The system SHALL read runtime configuration from environment variables for the OpenAI-compatible API, model selection, and AgentCube sandbox parameters.\n138: \n139: #### Scenario: Defaults and overrides\n140: \n141: - **GIVEN** standard deployment environment variables\n142: - **WHEN** the service starts\n143: - **THEN** it SHALL use `OPENAI_API_BASE` defaulting to `https://api.siliconflow.cn/v1`, `OPENAI_MODEL` defaulting to `Qwen/QwQ-32B`, `CODEINTERPRETER_NAME` defaulting to `my-interpreter`, `SANDBOX_NAMESPACE` defaulting to `default`, and `SANDBOX_WARMUP_SEC` defaulting to `5`, while binding HTTP to `0.0.0.0:8000` as defined in the application\n144: \n145: ---\n146: \n147: ### Requirement: PCAP analyzer sandbox integration\n148: \n149: The system SHALL orchestrate PCAP analysis by planning and repairing scripts, executing them inside an AgentCube-backed sandbox via `SandboxRunner`, and aggregating results through reporter agents.\n150: \n151: #### Scenario: Sandbox runner executes commands\n152: \n153: - **GIVEN** a `SandboxRunner` constructed with interpreter name, namespace, and warmup duration\n154: - **WHEN** analysis logic invokes `run` with a shell command\n155: - **THEN** the runner SHALL execute the command in the remote sandbox context and SHALL return structured execution results for downstream LLM steps\n156: \n157: #### Scenario: File staging uses runner uploads\n158: \n159: - **GIVEN** a local PCAP path or bytes to analyze\n160: - **WHEN** the orchestration needs the artifact inside the sandbox workspace\n161: - **THEN** the system SHALL use `upload_file` or `upload_bytes` on `SandboxRunner` before executing analysis commands\n162: \n163: ---\n164: \n165: ### Requirement: PCAP analyzer container image\n166: \n167: The system SHALL build a container image that installs Python dependencies with `uv`, vendors the in-repo `agentcube` SDK copy, sets `PYTHONPATH`, exposes port 8000, and starts the FastAPI app via `uv run`.\n168: \n169: #### Scenario: Image entrypoint\n170: \n171: - **GIVEN** the `example/pcap-analyzer/Dockerfile` build context\n172: - **WHEN** the container runs without overriding the command\n173: - **THEN** the default command SHALL be `uv run pcap_analyzer.py` with `PYTHONPATH=\"/app\"` and port `8000` exposed\n174: \n175: ---\n176: \n177: ### Requirement: PCAP analyzer Kubernetes deployment\n178: \n179: The system SHALL supply a `Deployment` manifest that runs the analyzer image with resource requests/limits and environment variables wired from a Secret and plain env for AgentCube and model endpoints.\n180: \n181: #### Scenario: Deployment wiring\n182: \n183: - **GIVEN** `example/pcap-analyzer/deployment.yaml` applied to the cluster\n184: - **WHEN** the workload becomes ready\n185: - **THEN** the pod SHALL run image `pcap-analyzer:latest` (pull `IfNotPresent`), listen on TCP 8000, request `cpu: 200m` / `memory: 100Mi` and limit `cpu: 1` / `memory: 1Gi`, mount `OPENAI_API_KEY` from Secret `pcap-analyzer-secrets` key `openai-api-key`, and set `OPENAI_API_BASE`, `OPENAI_MODEL`, `WORKLOAD_MANAGER_URL`, `ROUTER_URL`, `CODEINTERPRETER_NAME`, `SANDBOX_NAMESPACE`, and `SANDBOX_WARMUP_SEC` as container environment variables\n186: \n187: #### Scenario: Process launch in cluster\n188: \n189: - **GIVEN** the deploymentвҖҷs container specification\n190: - **WHEN** Kubernetes starts the container\n191: - **THEN** the command SHALL be `uv` with arguments `run pcap_analyzer.py`, matching local Docker behavior\n\n(End of file - total 191 lines)\n</content>","metadata":{"preview":"# Integrations Specification\n\n## Purpose\n\nNormative requirements for the AgentCube Dify plugin integration and the PCAP analyzer example that uses AgentCube code interpreters and Kubernetes sandboxes.\n\n## Requirements\n\n### Requirement: Dify plugin bootstrap and runtime\n\nThe system SHALL expose a Dify-compatible Python plugin whose process entry runs the framework runner with a configured maximum request timeout.\n\n#### Scenario: Plugin process starts\n\n- **GIVEN** the plugin package is installed with compatible `dify-plugin` and `agentcube-sdk` versions\n- **WHEN** the platform starts the plugin using the manifest-declared entrypoint\n- **THEN** the plugin SHALL execute `main` which runs `Plugin(DifyPluginEnv(MAX_REQUEST_TIMEOUT=120)).run()` until the host stops it\n\n---\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/integrations/spec.md","time":{"start":1775892144340,"end":1775892144367}}}}
