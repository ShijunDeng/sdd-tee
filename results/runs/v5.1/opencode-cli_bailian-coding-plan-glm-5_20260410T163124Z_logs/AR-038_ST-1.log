\n42: \n43: type ValidationError struct {\n44: \tField  string\n45: \tReason string\n46: }\n47: \n48: func (e *ValidationError) Error() string {\n49: \treturn fmt.Sprintf(\"validation error: %s - %s\", e.Field, e.Reason)\n50: }\n51: \n52: type NotFoundError struct {\n53: \tResource string\n54: \tName     string\n55: }\n56: \n57: func (e *NotFoundError) Error() string {\n58: \treturn fmt.Sprintf(\"not found: %s/%s\", e.Resource, e.Name)\n59: }\n60: \n61: type InternalError struct {\n62: \tErr error\n63: }\n64: \n65: func (e *InternalError) Error() string {\n66: \treturn fmt.Sprintf(\"internal error: %v\", e.Err)\n67: }\n68: \n69: type ServiceUnavailableError struct {\n70: \tDependency string\n71: }\n72: \n73: func (e *ServiceUnavailableError) Error() string {\n74: \treturn fmt.Sprintf(\"service unavailable: %s\", e.Dependency)\n75: }\n76: \n77: type ConflictError struct {\n78: \tResource string\n79: \tErr      error\n80: }\n81: \n82: func (e *ConflictError) Error() string {\n83: \treturn fmt.Sprintf(\"conflict on %s: %v\", e.Resource, e.Err)\n84: }\n85: \n86: type DeletionReason string\n87: \n88: const (\n89: \tDeletionReasonIdleTimeout        DeletionReason = \"IdleTimeout\"\n90: \tDeletionReasonMaxDurationReached DeletionReason = \"MaxDurationReached\"\n91: \tDeletionReasonUserRequest        DeletionReason = \"UserRequest\"\n92: )\n93: \n94: func HandleError(w http.ResponseWriter, _ *http.Request, err error) {\n95: \tw.Header().Set(\"Content-Type\", \"application/json\")\n96: \n97: \tvar resp ErrorResponse\n98: \tvar status int\n99: \n100: \tswitch e := err.(type) {\n101: \tcase *ValidationError:\n102: \t\tstatus = http.StatusBadRequest\n103: \t\tresp = ErrorResponse{\n104: \t\t\tCode:    \"VALIDATION_ERROR\",\n105: \t\t\tMessage: \"Invalid request parameter\",\n106: \t\t\tDetails: map[string]string{\"field\": e.Field, \"reason\": e.Reason},\n107: \t\t}\n108: \tcase *NotFoundError:\n109: \t\tstatus = http.StatusNotFound\n110: \t\tresp = ErrorResponse{\n111: \t\t\tCode:    \"NOT_FOUND\",\n112: \t\t\tMessage: e.Error(),\n113: \t\t}\n114: \tcase *ServiceUnavailableError:\n115: \t\tstatus = http.StatusServiceUnavailable\n116: \t\tresp = ErrorResponse{\n117: \t\t\tCode:    \"SERVICE_UNAVAILABLE\",\n118: \t\t\tMessage: e.Error(),\n119: \t\t}\n120: \tcase *InternalError:\n121: \t\tstatus = http.StatusInternalServerError\n122: \t\tresp = ErrorResponse{\n123: \t\t\tCode:    \"INTERNAL_ERROR\",\n124: \t\t\tMessage: \"Unexpected server error\",\n125: \t\t}\n126: \tdefault:\n127: \t\tstatus = http.StatusInternalServerError\n128: \t\tresp = ErrorResponse{\n129: \t\t\tCode:    \"INTERNAL_ERROR\",\n130: \t\t\tMessage: \"Unexpected server error\",\n131: \t\t}\n132: \t}\n133: \n134: \tw.WriteHeader(status)\n135: \tjson.NewEncoder(w).Encode(resp)\n136: }\n\n(End of file - total 136 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype Handler interface {\n\tRegister(r chi.Router)\n}\n\ntype Logger interface {\n\tInfo(msg string, args ...any)\n\tError(msg string, args ...any)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types.go","time":{"start":1775895231490,"end":1775895231515}}}}
{"type":"tool_use","timestamp":1775895231518,"sessionID":"ses_28465a93effe4UmKXS55ZNDVIa","part":{"id":"prt_d7b9ab3d3001wPGP1RTtDAEAQy","messageID":"msg_d7b9a9453001gfGLhsLxSkT1ha","sessionID":"ses_28465a93effe4UmKXS55ZNDVIa","type":"tool","tool":"read","callID":"toolu_tool-12c06b965c9a40de8f971d6b83e20c90","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/doc.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/doc.go</path>\n<type>file</type>\n<content>\n1: // Package workloadmanager provides the HTTP service framework for the\n2: // WorkloadManager component of AgentCube. It includes HTTP server lifecycle\n3: // management, routing, middleware, health checking, and error handling.\n4: //\n5: // The package uses go-chi/chi for routing and follows Go standard library\n6: // conventions for HTTP handlers. Middleware chain executes in order:\n7: // Recovery → Logging → CORS → Handler.\n8: package workloadmanager\n\n(End of file - total 8 lines)\n</content>","metadata":{"preview":"// Package workloadmanager provides the HTTP service framework for the\n// WorkloadManager component of AgentCube. It includes HTTP server lifecycle\n// management, routing, middleware, health checking, and error handling.\n//\n// The package uses go-chi/chi for routing and follows Go standard library\n// conventions for HTTP handlers. Middleware chain executes in order:\n// Recovery → Logging → CORS → Handler.\npackage workloadmanager","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/doc.go","time":{"start":1775895231488,"end":1775895231517}}}}
{"type":"tool_use","timestamp":1775895231520,"sessionID":"ses_28465a93effe4UmKXS55ZNDVIa","part":{"id":"prt_d7b9abb4b001niigPzub5TFEYm","messageID":"msg_d7b9a9453001gfGLhsLxSkT1ha","sessionID":"ses_28465a93effe4UmKXS55ZNDVIa","type":"tool","tool":"read","callID":"toolu_tool-959b78a78bc24c9a9449900a39cffaff","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"net/http\"\n6: \t\"os\"\n7: \t\"os/signal\"\n8: \t\"syscall\"\n9: \n10: \t\"github.com/go-chi/chi/v5\"\n11: )\n12: \n13: // HTTPServer manages the HTTP server lifecycle including graceful shutdown.\n14: type HTTPServer struct {\n15: \tserver           *http.Server\n16: \trouter           chi.Router\n17: \tconfig           Config\n18: \thandlers         map[string]Handler\n19: \tlogger           Logger\n20: \tstopCh           chan struct{}\n21: \tlifecycleManager *SandboxLifecycleManager\n22: \tgarbageCollector *GarbageCollector\n23: \tstore            Store\n24: \tk8sClient        *K8sClient\n25: }\n26: \n27: // NewHTTPServer creates a new HTTPServer instance with the given configuration and logger.\n28: // The router is initialized with chi.NewRouter().\n29: func NewHTTPServer(cfg Config, logger Logger) *HTTPServer {\n30: \treturn &HTTPServer{\n31: \t\tserver:   &http.Server{Addr: cfg.Addr},\n32: \t\trouter:   chi.NewRouter(),\n33: \t\tconfig:   cfg,\n34: \t\thandlers: make(map[string]Handler),\n35: \t\tlogger:   logger,\n36: \t\tstopCh:   make(chan struct{}),\n37: \t\tstore:    NewMemoryStore(),\n38: \t}\n39: }\n40: \n41: func NewHTTPServerWithClients(cfg Config, logger Logger, k8sClient *K8sClient, store Store) *HTTPServer {\n42: \tlifecycleConfig := DefaultLifecycleConfig()\n43: \tlifecycleManager := NewSandboxLifecycleManager(k8sClient, store, lifecycleConfig, logger)\n44: \tgarbageCollector := NewGarbageCollector(lifecycleManager, lifecycleConfig.GCInterval, lifecycleConfig.GCOnceTimeout, logger)\n45: \n46: \treturn &HTTPServer{\n47: \t\tserver:           &http.Server{Addr: cfg.Addr},\n48: \t\trouter:           chi.NewRouter(),\n49: \t\tconfig:           cfg,\n50: \t\thandlers:         make(map[string]Handler),\n51: \t\tlogger:           logger,\n52: \t\tstopCh:           make(chan struct{}),\n53: \t\tlifecycleManager: lifecycleManager,\n54: \t\tgarbageCollector: garbageCollector,\n55: \t\tstore:            store,\n56: \t\tk8sClient:        k8sClient,\n57: \t}\n58: }\n59: \n60: // RegisterHandler stores a handler and registers its routes on the router.\n61: func (s *HTTPServer) RegisterHandler(name string, h Handler) {\n62: \ts.handlers[name] = h\n63: \th.Register(s.router)\n64: }\n65: \n66: // Start begins listening and serving HTTP requests.\n67: // It returns an error channel that receives non-ErrServerClosed errors.\n68: func (s *HTTPServer) Start() <-chan error {\n69: \terrCh := make(chan error, 1)\n70: \ts.server.ReadTimeout = s.config.ReadTimeout\n71: \ts.server.WriteTimeout = s.config.WriteTimeout\n72: \ts.server.IdleTimeout = s.config.IdleTimeout\n73: \ts.server.Handler = s.router\n74: \n75: \tif s.garbageCollector != nil {\n76: \t\ts.garbageCollector.Start()\n77: \t}\n78: \n79: \tgo func() {\n80: \t\tif err := s.server.ListenAndServe(); err != http.ErrServerClosed {\n81: \t\t\terrCh <- err\n82: \t\t}\n83: \t}()\n84: \treturn errCh\n85: }\n86: \n87: func (s *HTTPServer) Stop(ctx context.Context) error {\n88: \tif s.garbageCollector != nil {\n89: \t\ts.garbageCollector.Stop()\n90: \t}\n91: \n92: \tctx, cancel := context.WithTimeout(ctx, s.config.ShutdownTimeout)\n93: \tdefer cancel()\n94: \terr := s.server.Shutdown(ctx)\n95: \tclose(s.stopCh)\n96: \treturn err\n97: }\n98: \n99: // GracefulShutdown sets up signal handlers for SIGTERM and SIGINT.\n100: // When a signal is received, the server is stopped gracefully.\n101: func (s *HTTPServer) GracefulShutdown() {\n102: \tsigCh := make(chan os.Signal, 1)\n103: \tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n104: \tgo func() {\n105: \t\t<-sigCh\n106: \t\tctx := context.Background()\n107: \t\ts.Stop(ctx)\n108: \t}()\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// HTTPServer manages the HTTP server lifecycle including graceful shutdown.\ntype HTTPServer struct {\n\tserver           *http.Server\n\trouter           chi.Router\n\tconfig           Config\n\thandlers         map[string]Handler\n\tlogger           Logger\n\tstopCh           chan struct{}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go","time":{"start":1775895231492,"end":1775895231519}}}}
