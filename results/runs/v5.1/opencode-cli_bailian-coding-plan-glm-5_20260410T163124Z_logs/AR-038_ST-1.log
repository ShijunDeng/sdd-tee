{\n106: \t\tt.Fatal(\"NewRecoveryMiddleware returned nil\")\n107: \t}\n108: \tif m.logger == nil {\n109: \t\tt.Error(\"middleware logger is nil\")\n110: \t}\n111: }\n112: \n113: func TestRecoveryMiddleware_ImplementsMiddleware(t *testing.T) {\n114: \tlogger := &recoveryTestLogger{}\n115: \tm := NewRecoveryMiddleware(logger)\n116: \n117: \tvar _ workloadmanager.Logger = m.logger\n118: }\n\n(End of file - total 118 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\ntype recoveryTestLogger struct {\n\terrors []string\n}\n\nfunc (l *recoveryTestLogger) Info(msg string, args ...any) {}\n\nfunc (l *recoveryTestLogger) Error(msg string, args ...any) {\n\tl.errors = append(l.errors, msg)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/recovery_test.go","time":{"start":1775895300388,"end":1775895300401}}}}
