GarbageCollector_DefaultInterval(t *testing.T) {\n43: \tfakeClient := fake.NewSimpleClientset()\n44: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n45: \tinformerFactory := NewTestInformerFactory(fakeClient)\n46: \n47: \tk8sClient := &K8sClient{\n48: \t\tdynamicClient:   dynamicClient,\n49: \t\tcoreClient:      fakeClient,\n50: \t\tinformerFactory: informerFactory,\n51: \t}\n52: \n53: \tstore := NewMemoryStore()\n54: \tlogger := &mockLogger{}\n55: \tconfig := DefaultLifecycleConfig()\n56: \n57: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n58: \n59: \tgc := NewGarbageCollector(manager, 0, 0, logger)\n60: \n61: \tassert.Equal(t, GarbageCollectorInterval, gc.interval)\n62: \tassert.Equal(t, 2*time.Minute, gc.onceTimeout)\n63: }\n64: \n65: func TestGarbageCollector_StartStop(t *testing.T) {\n66: \tfakeClient := fake.NewSimpleClientset()\n67: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n68: \tinformerFactory := NewTestInformerFactory(fakeClient)\n69: \n70: \tk8sClient := &K8sClient{\n71: \t\tdynamicClient:   dynamicClient,\n72: \t\tcoreClient:      fakeClient,\n73: \t\tinformerFactory: informerFactory,\n74: \t}\n75: \n76: \tstore := NewMemoryStore()\n77: \tlogger := &mockLogger{}\n78: \tconfig := DefaultLifecycleConfig()\n79: \n80: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n81: \n82: \tgc := NewGarbageCollector(manager, 100*time.Millisecond, 1*time.Second, logger)\n83: \n84: \tgc.Start()\n85: \n86: \ttime.Sleep(50 * time.Millisecond)\n87: \n88: \tgc.Stop()\n89: \n90: \tassert.True(t, true)\n91: }\n92: \n93: func TestGarbageCollector_runOnce_Expired(t *testing.T) {\n94: \tfakeClient := fake.NewSimpleClientset()\n95: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n96: \tinformerFactory := NewTestInformerFactory(fakeClient)\n97: \n98: \tk8sClient := &K8sClient{\n99: \t\tdynamicClient:   dynamicClient,\n100: \t\tcoreClient:      fakeClient,\n101: \t\tinformerFactory: informerFactory,\n102: \t}\n103: \n104: \tstore := NewMemoryStore()\n105: \tlogger := &mockLogger{}\n106: \tconfig := DefaultLifecycleConfig()\n107: \n108: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n109: \n110: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n111: \n112: \tnow := time.Now()\n113: \n114: \texpiredSandbox := &types.SandboxInfo{\n115: \t\tKind:             types.SandboxKind,\n116: \t\tSandboxID:        \"sandbox-expired\",\n117: \t\tSandboxNamespace: \"default\",\n118: \t\tSandboxName:      \"sandbox-expired\",\n119: \t\tSessionID:        \"session-expired\",\n120: \t\tCreatedAt:        now.Add(-10 * time.Hour),\n121: \t\tExpiresAt:        now.Add(-2 * time.Hour),\n122: \t\tStatus:           \"running\",\n123: \t}\n124: \n125: \tactiveSandbox := &types.SandboxInfo{\n126: \t\tKind:             types.SandboxKind,\n127: \t\tSandboxID:        \"sandbox-active\",\n128: \t\tSandboxNamespace: \"default\",\n129: \t\tSandboxName:      \"sandbox-active\",\n130: \t\tSessionID:        \"session-active\",\n131: \t\tCreatedAt:        now,\n132: \t\tExpiresAt:        now.Add(8 * time.Hour),\n133: \t\tStatus:           \"running\",\n134: \t}\n135: \n136: \terr := store.StoreSandbox(context.Background(), expiredSandbox)\n137: \trequire.NoError(t, err)\n138: \terr = store.StoreSandbox(context.Background(), activeSandbox)\n139: \trequire.NoError(t, err)\n140: \n141: \tassert.Equal(t, 2, store.Size())\n142: \n143: \terr = gc.runOnce(context.Background())\n144: \trequire.NoError(t, err)\n145: \n146: \tassert.Equal(t, 1, store.Size())\n147: \n148: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-expired\")\n149: \tassert.Error(t, err)\n150: \n151: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-active\")\n152: \trequire.NoError(t, err)\n153: }\n154: \n155: func TestGarbageCollector_runOnce_Inactive(t *testing.T) {\n156: \tfakeClient := fake.NewSimpleClientset()\n157: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n158: \tinformerFactory := NewTestInformerFactory(fakeClient)\n159: \n160: \tk8sClient := &K8sClient{\n161: \t\tdynamicClient:   dynamicClient,\n162: \t\tcoreClient:      fakeClient,\n163: \t\tinformerFactory: informerFactory,\n164: \t}\n165: \n166: \tstore := NewMemoryStore()\n167: \tlogger := &mockLogger{}\n168: \tconfig := DefaultLifecycleConfig()\n169: \n170: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n171: \n172: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n173: \n174: \tnow := time.Now()\n175: \n176: \tinactiveSandbox := &types.SandboxInfo{\n177: \t\tKind:             types.SandboxKind,\n178: \t\tSandboxID:        \"sandbox-inactive\",\n179: \t\tSandboxNamespace: \"default\",\n180: \t\tSandboxName:      \"sandbox-inactive\",\n181: \t\tSessionID:        \"session-inactive\",\n182: \t\tCreatedAt:        now,\n183: \t\tExpiresAt:        now.Add(8 * time.Hour),\n184: \t\tLastActivity:     now.Add(-30 * time.Minute),\n185: \t\tStatus:           \"running\",\n186: \t}\n187: \n188: \tactiveSandbox := &types.SandboxInfo{\n189: \t\tKind:             types.SandboxKind,\n190: \t\tSandboxID:        \"sandbox-active\",\n191: \t\tSandboxNamespace: \"default\",\n192: \t\tSandboxName:      \"sandbox-active\",\n193: \t\tSessionID:        \"session-active\",\n194: \t\tCreatedAt:        now,\n195: \t\tExpiresAt:        now.Add(8 * time.Hour),\n196: \t\tLastActivity:     now,\n197: \t\tStatus:           \"running\",\n198: \t}\n199: \n200: \terr := store.StoreSandbox(context.Background(), inactiveSandbox)\n201: \trequire.NoError(t, err)\n202: \terr = store.StoreSandbox(context.Background(), activeSandbox)\n203: \trequire.NoError(t, err)\n204: \n205: \tassert.Equal(t, 2, store.Size())\n206: \n207: \terr = gc.runOnce(context.Background())\n208: \trequire.NoError(t, err)\n209: \n210: \tassert.Equal(t, 1, store.Size())\n211: \n212: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-inactive\")\n213: \tassert.Error(t, err)\n214: \n215: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-active\")\n216: \trequire.NoError(t, err)\n217: }\n218: \n219: func TestGarbageCollector_runOnce_Limit(t *testing.T) {\n220: \tfakeClient := fake.NewSimpleClientset()\n221: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n222: \tinformerFactory := NewTestInformerFactory(fakeClient)\n223: \n224: \tk8sClient := &K8sClient{\n225: \t\tdynamicClient:   dynamicClient,\n226: \t\tcoreClient:      fakeClient,\n227: \t\tinformerFactory: informerFactory,\n228: \t}\n229: \n230: \tstore := NewMemoryStore()\n231: \tlogger := &mockLogger{}\n232: \tconfig := DefaultLifecycleConfig()\n233: \n234: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n235: \n236: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n237: \n238: \tnow := time.Now()\n239: \n240: \tfor i := 0; i < 20; i++ {\n241: \t\tsandbox := &types.SandboxInfo{\n242: \t\t\tKind:             types.SandboxKind,\n243: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n244: \t\t\tSandboxNamespace: \"default\",\n245: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n246: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n247: \t\t\tCreatedAt:        now,\n248: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n249: \t\t\tStatus:           \"running\",\n250: \t\t}\n251: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n252: \t\trequire.NoError(t, err)\n253: \t}\n254: \n255: \tassert.Equal(t, 20, store.Size())\n256: \n257: \terr := gc.runOnce(context.Background())\n258: \trequire.NoError(t, err)\n259: \n260: \tassert.LessOrEqual(t, store.Size(), 20-GCBatchSize)\n261: }\n262: \n263: func TestGarbageCollector_runOnce_ContinueOnError(t *testing.T) {\n264: \tfakeClient := fake.NewSimpleClientset()\n265: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n266: \tinformerFactory := NewTestInformerFactory(fakeClient)\n267: \n268: \tk8sClient := &K8sClient{\n269: \t\tdynamicClient:   dynamicClient,\n270: \t\tcoreClient:      fakeClient,\n271: \t\tinformerFactory: informerFactory,\n272: \t}\n273: \n274: \tstore := NewMemoryStore()\n275: \tlogger := &mockLogger{}\n276: \tconfig := DefaultLifecycleConfig()\n277: \n278: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n279: \n280: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n281: \n282: \tnow := time.Now()\n283: \n284: \tfor i := 0; i < 3; i++ {\n285: \t\tsandbox := &types.SandboxInfo{\n286: \t\t\tKind:             types.SandboxKind,\n287: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n288: \t\t\tSandboxNamespace: \"default\",\n289: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n290: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n291: \t\t\tCreatedAt:        now,\n292: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n293: \t\t\tStatus:           \"running\",\n294: \t\t}\n295: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n296: \t\trequire.NoError(t, err)\n297: \t}\n298: \n299: \terr := gc.runOnce(context.Background())\n300: \trequire.NoError(t, err)\n301: \n302: \tassert.Equal(t, 0, store.Size())\n303: }\n304: \n305: func TestGarbageCollector_GetStats(t *testing.T) {\n306: \tfakeClient := fake.NewSimpleClientset()\n307: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n308: \tinformerFactory := NewTestInformerFactory(fakeClient)\n309: \n310: \tk8sClient := &K8sClient{\n311: \t\tdynamicClient:   dynamicClient,\n312: \t\tcoreClient:      fakeClient,\n313: \t\tinformerFactory: informerFactory,\n314: \t}\n315: \n316: \tstore := NewMemoryStore()\n317: \tlogger := &mockLogger{}\n318: \tconfig := DefaultLifecycleConfig()\n319: \n320: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n321: \n322: \tgc := NewGarbageCollector(manager, 5*time.Minute, 3*time.Minute, logger)\n323: \tgc.SetIdleTimeout(20 * time.Minute)\n324: \n325: \tstats := gc.GetStats()\n326: \n327: \tassert.Equal(t, 5*time.Minute, stats.Interval)\n328: \tassert.Equal(t, 3*time.Minute, stats.OnceTimeout)\n329: \tassert.Equal(t, 20*time.Minute, stats.IdleTimeout)\n330: }\n331: \n332: func TestGarbageCollector_ConcurrentRunOnce(t *testing.T) {\n333: \tfakeClient := fake.NewSimpleClientset()\n334: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n335: \tinformerFactory := NewTestInformerFactory(fakeClient)\n336: \n337: \tk8sClient := &K8sClient{\n338: \t\tdynamicClient:   dynamicClient,\n339: \t\tcoreClient:      fakeClient,\n340: \t\tinformerFactory: informerFactory,\n341: \t}\n342: \n343: \tstore := NewMemoryStore()\n344: \tlogger := &mockLogger{}\n345: \tconfig := DefaultLifecycleConfig()\n346: \n347: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n348: \n349: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n350: \n351: \tnow := time.Now()\n352: \n353: \tfor i := 0; i < 10; i++ {\n354: \t\tsandbox := &types.SandboxInfo{\n355: \t\t\tKind:             types.SandboxKind,\n356: \t\t\tSandboxID:        \"sandbox-\" + string(rune(i)),\n357: \t\t\tSandboxNamespace: \"default\",\n358: \t\t\tSandboxName:      \"sandbox-\" + string(rune(i)),\n359: \t\t\tSessionID:        \"session-\" + string(rune(i)),\n360: \t\t\tCreatedAt:        now,\n361: \t\t\tExpiresAt:        now.Add(-1 * time.Hour),\n362: \t\t\tStatus:           \"running\",\n363: \t\t}\n364: \t\terr := store.StoreSandbox(context.Background(), sandbox)\n365: \t\trequire.NoError(t, err)\n366: \t}\n367: \n368: \tvar wg sync.WaitGroup\n369: \tfor i := 0; i < 3; i++ {\n370: \t\twg.Add(1)\n371: \t\tgo func() {\n372: \t\t\tdefer wg.Done()\n373: \t\t\tgc.runOnce(context.Background())\n374: \t\t}()\n375: \t}\n376: \twg.Wait()\n377: \n378: \tassert.LessOrEqual(t, store.Size(), 10)\n379: }\n\n(End of file - total 379 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc TestNewGarbageCollector(t *testing.T) {\n\tfakeClient := fake.NewSimpleClientset()\n\tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/garbage_collector_test.go","time":{"start":1775895276588,"end":1775895276602}}}}
{"type":"tool_use","timestamp":1775895276606,"sessionID":"ses_28465a93effe4UmKXS55ZNDVIa","part":{"id":"prt_d7b9b63c7001HZsK35nhJDyZNB","messageID":"msg_d7b9b46eb0015oFP8SbK5QIxjH","sessionID":"ses_28465a93effe4UmKXS55ZNDVIa","type":"tool","tool":"read","callID":"toolu_tool-ca037dcba4634fccb7a9264c9cb35087","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go</path>\n<type>file</type>\n<content>\n1: package handlers\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"net/http\"\n7: \t\"net/http/httptest\"\n8: \t\"testing\"\n9: \t\"time\"\n10: \n11: \t\"github.com/go-chi/chi/v5\"\n12: \t\"github.com/stretchr/testify/assert\"\n13: \t\"github.com/stretchr/testify/require\"\n14: \t\"k8s.io/apimachinery/pkg/runtime\"\n15: \tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n16: \t\"k8s.io/client-go/informers\"\n17: \t\"k8s.io/client-go/kubernetes\"\n18: \tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n19: \n20: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n21: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n22: )\n23: \n24: func NewTestInformerFactory(client kubernetes.Interface) informers.SharedInformerFactory {\n25: \treturn informers.NewSharedInformerFactoryWithOptions(client, time.Minute)\n26: }\n27: \n28: func setupTestHandler() (*DeletionHandler, *workloadmanager.MemoryStore) {\n29: \tfakeClient := k8sfake.NewSimpleClientset()\n30: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n31: \tinformerFactory := NewTestInformerFactory(fakeClient)\n32: \n33: \tk8sClient := &workloadmanager.K8sClient{}\n34: \tk8sClient.SetClients(dynamicClient, fakeClient, informerFactory)\n35: \n36: \tstore := workloadmanager.NewMemoryStore()\n37: \tlogger := &testLogger{}\n38: \tconfig := workloadmanager.DefaultLifecycleConfig()\n39: \n40: \tmanager := workloadmanager.NewSandboxLifecycleManager(k8sClient, store, config, logger)\n41: \n42: \treturn NewDeletionHandler(manager, logger), store\n43: }\n44: \n45: type testLogger struct{}\n46: \n47: func (l *testLogger) Info(msg string, args ...any)  {}\n48: func (l *testLogger) Error(msg string, args ...any) {}\n49: \n50: func TestDeletionHandler_Register(t *testing.T) {\n51: \thandler, _ := setupTestHandler()\n52: \n53: \tr := chi.NewRouter()\n54: \thandler.Register(r)\n55: \n56: \troutes := r.Routes()\n57: \tassert.Len(t, routes, 2)\n58: }\n59: \n60: func TestDeletionHandler_DeleteSuccess(t *testing.T) {\n61: \thandler, store := setupTestHandler()\n62: \n63: \tnow := time.Now()\n64: \tsandbox := &types.SandboxInfo{\n65: \t\tKind:             types.SandboxKind,\n66: \t\tSandboxID:        \"sandbox-123\",\n67: \t\tSandboxNamespace: \"default\",\n68: \t\tSandboxName:      \"sandbox-123\",\n69: \t\tSessionID:        \"session-123\",\n70: \t\tCreatedAt:        now,\n71: \t\tExpiresAt:        now.Add(8 * time.Hour),\n72: \t\tStatus:           \"running\",\n73: \t}\n74: \n75: \terr := store.StoreSandbox(context.Background(), sandbox)\n76: \trequire.NoError(t, err)\n77: \n78: \tr := chi.NewRouter()\n79: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n80: \n81: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n82: \trec := httptest.NewRecorder()\n83: \n84: \tr.ServeHTTP(rec, req)\n85: \n86: \tassert.Equal(t, http.StatusOK, rec.Code)\n87: \n88: \tvar resp DeleteSandboxResponse\n89: \terr = json.NewDecoder(rec.Body).Decode(&resp)\n90: \trequire.NoError(t, err)\n91: \n92: \tassert.Equal(t, \"session-123\", resp.SessionID)\n93: \tassert.Equal(t, \"deleted\", resp.Status)\n94: \n95: \tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n96: }\n97: \n98: func TestDeletionHandler_DeleteNotFound(t *testing.T) {\n99: \thandler, _ := setupTestHandler()\n100: \n101: \tr := chi.NewRouter()\n102: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n103: \n104: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/non-existent\", nil)\n105: \trec := httptest.NewRecorder()\n106: \n107: \tr.ServeHTTP(rec, req)\n108: \n109: \tassert.Equal(t, http.StatusNotFound, rec.Code)\n110: \n111: \tvar resp DeleteSandboxResponse\n112: \terr := json.NewDecoder(rec.Body).Decode(&resp)\n113: \trequire.NoError(t, err)\n114: \n115: \tassert.Equal(t, \"non-existent\", resp.SessionID)\n116: \tassert.Equal(t, \"not_found\", resp.Status)\n117: }\n118: \n119: func TestDeletionHandler_DeleteMissingSessionID(t *testing.T) {\n120: \thandler, _ := setupTestHandler()\n121: \n122: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\", nil)\n123: \trec := httptest.NewRecorder()\n124: \n125: \thandler.handleDeleteSandbox(rec, req, \"\", workloadmanager.AgentRuntimeKind)\n126: \n127: \tassert.Equal(t, http.StatusBadRequest, rec.Code)\n128: \n129: \tvar resp workloadmanager.ErrorResponse\n130: \terr := json.NewDecoder(rec.Body).Decode(&resp)\n131: \trequire.NoError(t, err)\n132: \n133: \tassert.Equal(t, \"VALIDATION_ERROR\", resp.Code)\n134: }\n135: \n136: func TestDeletionHandler_DeleteCodeInterpreter(t *testing.T) {\n137: \thandler, store := setupTestHandler()\n138: \n139: \tnow := time.Now()\n140: \tsandbox := &types.SandboxInfo{\n141: \t\tKind:             types.SandboxKind,\n142: \t\tSandboxID:        \"sandbox-123\",\n143: \t\tSandboxNamespace: \"default\",\n144: \t\tSandboxName:      \"sandbox-123\",\n145: \t\tSessionID:        \"session-123\",\n146: \t\tCreatedAt:        now,\n147: \t\tExpiresAt:        now.Add(8 * time.Hour),\n148: \t\tStatus:           \"running\",\n149: \t}\n150: \n151: \terr := store.StoreSandbox(context.Background(), sandbox)\n152: \trequire.NoError(t, err)\n153: \n154: \tr := chi.NewRouter()\n155: \tr.Delete(\"/v1/code-interpreter/sessions/{sessionId}\", handler.handleDeleteCodeInterpreterSandbox)\n156: \n157: \treq := httptest.NewRequest(\"DELETE\", \"/v1/code-interpreter/sessions/session-123\", nil)\n158: \trec := httptest.NewRecorder()\n159: \n160: \tr.ServeHTTP(rec, req)\n161: \n162: \tassert.Equal(t, http.StatusOK, rec.Code)\n163: \n164: \tvar resp DeleteSandboxResponse\n165: \terr = json.NewDecoder(rec.Body).Decode(&resp)\n166: \trequire.NoError(t, err)\n167: \n168: \tassert.Equal(t, \"session-123\", resp.SessionID)\n169: \tassert.Equal(t, \"deleted\", resp.Status)\n170: }\n171: \n172: func TestDeletionHandler_ResponseFormat(t *testing.T) {\n173: \thandler, store := setupTestHandler()\n174: \n175: \tnow := time.Now()\n176: \tsandbox := &types.SandboxInfo{\n177: \t\tKind:             types.SandboxKind,\n178: \t\tSandboxID:        \"sandbox-123\",\n179: \t\tSandboxNamespace: \"default\",\n180: \t\tSandboxName:      \"sandbox-123\",\n181: \t\tSessionID:        \"session-123\",\n182: \t\tCreatedAt:        now,\n183: \t\tExpiresAt:        now.Add(8 * time.Hour),\n184: \t\tStatus:           \"running\",\n185: \t}\n186: \n187: \terr := store.StoreSandbox(context.Background(), sandbox)\n188: \trequire.NoError(t, err)\n189: \n190: \tr := chi.NewRouter()\n191: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n192: \n193: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n194: \trec := httptest.NewRecorder()\n195: \n196: \tr.ServeHTTP(rec, req)\n197: \n198: \tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n199: \n200: \tvar resp map[string]interface{}\n201: \terr = json.Unmarshal(rec.Body.Bytes(), &resp)\n202: \trequire.NoError(t, err)\n203: \n204: \tassert.Contains(t, resp, \"sessionId\")\n205: \tassert.Contains(t, resp, \"status\")\n206: \tassert.Equal(t, \"session-123\", resp[\"sessionId\"])\n207: \tassert.Equal(t, \"deleted\", resp[\"status\"])\n208: }\n209: \n210: func TestDeleteSandboxRequest_JSON(t *testing.T) {\n211: \treq := DeleteSandboxRequest{\n212: \t\tSessionID:          \"session-123\",\n213: \t\tKind:               \"AgentRuntime\",\n214: \t\tForce:              true,\n215: \t\tGracePeriodSeconds: 30,\n216: \t}\n217: \n218: \tdata, err := json.Marshal(req)\n219: \trequire.NoError(t, err)\n220: \n221: \tvar unmarshaled DeleteSandboxRequest\n222: \terr = json.Unmarshal(data, &unmarshaled)\n223: \trequire.NoError(t, err)\n224: \n225: \tassert.Equal(t, req.SessionID, unmarshaled.SessionID)\n226: \tassert.Equal(t, req.Kind, unmarshaled.Kind)\n227: \tassert.Equal(t, req.Force, unmarshaled.Force)\n228: \tassert.Equal(t, req.GracePeriodSeconds, unmarshaled.GracePeriodSeconds)\n229: }\n230: \n231: func TestDeleteSandboxResponse_JSON(t *testing.T) {\n232: \tresp := DeleteSandboxResponse{\n233: \t\tSessionID: \"session-123\",\n234: \t\tStatus:    \"deleted\",\n235: \t\tMessage:   \"Sandbox deleted successfully\",\n236: \t}\n237: \n238: \tdata, err := json.Marshal(resp)\n239: \trequire.NoError(t, err)\n240: \n241: \tvar unmarshaled DeleteSandboxResponse\n242: \terr = json.Unmarshal(data, &unmarshaled)\n243: \trequire.NoError(t, err)\n244: \n245: \tassert.Equal(t, resp.SessionID, unmarshaled.SessionID)\n246: \tassert.Equal(t, resp.Status, unmarshaled.Status)\n247: \tassert.Equal(t, resp.Message, unmarshaled.Message)\n248: }\n\n(End of file - total 248 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-go/kubernetes\"\n\tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go","time":{"start":1775895276590,"end":1775895276605}}}}
{"type":"tool_use","timestamp":1775895276608,"sessionID":"ses_28465a93effe4UmKXS55ZNDVIa","part":{"id":"prt_d7b9b6824001n1GfY2N7kNef0d","messageID":"msg_d7b9b46eb0015oFP8SbK5QIxjH","sessionID":"ses_28465a93effe4UmKXS55ZNDVIa","type":"tool","tool":"read","callID":"toolu_tool-72bf69bf510b4fc38023d867fcb061bb","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go</path>\n<type>file</type>\n<content>\n1: package middleware\n2: \n3: import (\n4: \t\"net/http\"\n5: \t\"net/http/httptest\"\n6: \t\"testing\"\n7: )\n8: \n9: func TestCORSMiddleware_Wrap_AllowedOrigin(t *testing.T) {\n10: \tconfig := CORSConfig{\n11: \t\tAllowedOrigins:   []string{\"http://example.com\", \"http://localhost\"},\n12: \t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n13: \t\tAllowedHeaders:   []string{\"Content-Type\"},\n14: \t\tAllowCredentials: true,\n15: \t}\n16: \tm := NewCORSMiddleware(config)\n17: \n18: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n19: \t\tw.WriteHeader(http.StatusOK)\n20: \t})\n21: \n22: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n23: \treq.Header.Set(\"Origin\", \"http://example.com\")\n24: \tw := httptest.NewRecorder()\n25: \n26: \tm.Wrap(handler).ServeHTTP(w, req)\n27: \n28: \torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n29: \tif origin != \"http://example.com\" {\n30: \t\tt.Errorf(\"expected Allow-Origin %s, got %s\", \"http://example.com\", origin)\n31: \t}\n32: \tmethods := w.Header().Get(\"Access-Control-Allow-Methods\")\n33: \tif methods != \"GET,POST\" {\n34: \t\tt.Errorf(\"expected Allow-Methods %s, got %s\", \"GET,POST\", methods)\n35: \t}\n36: \tcreds := w.Header().Get(\"Access-Control-Allow-Credentials\")\n37: \tif creds != \"true\" {\n38: \t\tt.Errorf(\"expected Allow-Credentials %s, got %s\", \"true\", creds)\n39: \t}\n40: }\n41: \n42: func TestCORSMiddleware_Wrap_DisallowedOrigin(t *testing.T) {\n43: \tconfig := CORSConfig{\n44: \t\tAllowedOrigins: []string{\"http://example.com\"},\n45: \t\tAllowedMethods: []string{\"GET\"},\n46: \t\tAllowedHeaders: []string{\"Content-Type\"},\n47: \t}\n48: \tm := NewCORSMiddleware(config)\n49: \n50: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n51: \t\tw.WriteHeader(http.StatusOK)\n52: \t})\n53: \n54: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n55: \treq.Header.Set(\"Origin\", \"http://evil.com\")\n56: \tw := httptest.NewRecorder()\n57: \n58: \tm.Wrap(handler).ServeHTTP(w, req)\n59: \n60: \torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n61: \tif origin != \"\" {\n62: \t\tt.Errorf(\"expected no Allow-Origin header, got %s\", origin)\n63: \t}\n64: }\n65: \n66: func TestCORSMiddleware_Wrap_OptionsPreflight(t *testing.T) {\n67: \tconfig := CORSConfig{\n68: \t\tAllowedOrigins:   []string{\"*\"},\n69: \t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\"},\n70: \t\tAllowedHeaders:   []string{\"Content-Type\", \"Authorization\"},\n71: \t\tAllowCredentials: false,\n72: \t}\n73: \tm := NewCORSMiddleware(config)\n74: \n75: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n76: \t\tw.WriteHeader(http.StatusOK)\n77: \t})\n78: \n79: \treq := httptest.NewRequest(\"OPTIONS\", \"/test\", nil)\n80: \treq.Header.Set(\"Origin\", \"http://example.com\")\n81: \tw := httptest.NewRecorder()\n82: \n83: \tm.Wrap(handler).ServeHTTP(w, req)\n84: \n85: \tif w.Code != http.StatusOK {\n86: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n87: \t}\n88: }\n89: \n90: func TestCORSMiddleware_isAllowedOrigin_Wildcard(t *testing.T) {\n91: \tconfig := CORSConfig{\n92: \t\tAllowedOrigins: []string{\"*\"},\n93: \t}\n94: \tm := NewCORSMiddleware(config)\n95: \n96: \tif !m.isAllowedOrigin(\"http://any.com\") {\n97: \t\tt.Error(\"wildcard should allow any origin\")\n98: \t}\n99: }\n100: \n101: func TestCORSMiddleware_isAllowedOrigin_ExactMatch(t *testing.T) {\n102: \tconfig := CORSConfig{\n103: \t\tAllowedOrigins: []string{\"http://example.com\"},\n104: \t}\n105: \tm := NewCORSMiddleware(config)\n106: \n107: \tif !m.isAllowedOrigin(\"http://example.com\") {\n108: \t\tt.Error(\"exact match should be allowed\")\n109: \t}\n110: \tif m.isAllowedOrigin(\"http://other.com\") {\n111: \t\tt.Error(\"non-matching origin should not be allowed\")\n112: \t}\n113: }\n114: \n115: func TestCORSMiddleware_isAllowedOrigin_NoMatch(t *testing.T) {\n116: \tconfig := CORSConfig{\n117: \t\tAllowedOrigins: []string{\"http://example.com\", \"http://localhost\"},\n118: \t}\n119: \tm := NewCORSMiddleware(config)\n120: \n121: \tif m.isAllowedOrigin(\"http://evil.com\") {\n122: \t\tt.Error(\"non-matching origin should not be allowed\")\n123: \t}\n124: }\n125: \n126: func TestNewCORSMiddleware(t *testing.T) {\n127: \tconfig := CORSConfig{\n128: \t\tAllowedOrigins: []string{\"*\"},\n129: \t}\n130: \tm := NewCORSMiddleware(config)\n131: \n132: \tif m == nil {\n133: \t\tt.Fatal(\"NewCORSMiddleware returned nil\")\n134: \t}\n135: \tif m.config.AllowedOrigins[0] != \"*\" {\n136: \t\tt.Error(\"config not properly set\")\n137: \t}\n138: }\n139: \n140: func TestCORSMiddleware_NoOriginHeader(t *testing.T) {\n141: \tconfig := CORSConfig{\n142: \t\tAllowedOrigins: []string{\"*\"},\n143: \t}\n144: \tm := NewCORSMiddleware(config)\n145: \n146: \thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n147: \t\tw.WriteHeader(http.StatusOK)\n148: \t})\n149: \n150: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n151: \tw := httptest.NewRecorder()\n152: \n153: \tm.Wrap(handler).ServeHTTP(w, req)\n154: \n155: \torigin := w.Header().Get(\"Access-Control-Allow-Origin\")\n156: \tif origin != \"\" {\n157: \t\tt.Errorf(\"expected no Allow-Origin without Origin header, got %s\", origin)\n158: \t}\n159: }\n160: \n161: func TestCORSConfig_AllFields(t *testing.T) {\n162: \tconfig := CORSConfig{\n163: \t\tAllowedOrigins:   []string{\"http://example.com\"},\n164: \t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n165: \t\tAllowedHeaders:   []string{\"Content-Type\"},\n166: \t\tAllowCredentials: true,\n167: \t}\n168: \n169: \tif len(config.AllowedOrigins) != 1 {\n170: \t\tt.Errorf(\"expected 1 allowed origin, got %d\", len(config.AllowedOrigins))\n171: \t}\n172: \tif len(config.AllowedMethods) != 2 {\n173: \t\tt.Errorf(\"expected 2 allowed methods, got %d\", len(config.AllowedMethods))\n174: \t}\n175: \tif !config.AllowCredentials {\n176: \t\tt.Error(\"expected AllowCredentials to be true\")\n177: \t}\n178: }\n\n(End of file - total 178 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n)\n\nfunc TestCORSMiddleware_Wrap_AllowedOrigin(t *testing.T) {\n\tconfig := CORSConfig{\n\t\tAllowedOrigins:   []string{\"http://example.com\", \"http://localhost\"},\n\t\tAllowedMethods:   []string{\"GET\", \"POST\"},\n\t\tAllowedHeaders:   []string{\"Content-Type\"},\n\t\tAllowCredentials: true,\n\t}\n\tm := NewCORSMiddleware(config)\n\n\thandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.WriteHeader(http.StatusOK)\n\t})","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/cors_test.go","time":{"start":1775895276592,"end":1775895276607}}}}
