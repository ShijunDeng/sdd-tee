ingMiddleware(logger)\n109: \n110: \tif m == nil {\n111: \t\tt.Fatal(\"NewLoggingMiddleware returned nil\")\n112: \t}\n113: \tif m.logger == nil {\n114: \t\tt.Error(\"middleware logger is nil\")\n115: \t}\n116: }\n117: \n118: func TestLoggingMiddleware_ImplementsMiddleware(t *testing.T) {\n119: \tlogger := &testLogger{}\n120: \tm := NewLoggingMiddleware(logger)\n121: \n122: \tvar _ workloadmanager.Logger = m.logger\n123: }\n\n(End of file - total 123 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\nfunc TestResponseWriterWrapper_WriteHeader(t *testing.T) {\n\tw := httptest.NewRecorder()\n\twrapper := &responseWriterWrapper{ResponseWriter: w}\n\n\twrapper.WriteHeader(http.StatusNotFound)\n\n\tif wrapper.status != http.StatusNotFound {\n\t\tt.Errorf(\"expected captured status %d, got %d\", http.StatusNotFound, wrapper.status)\n\t}\n\tif w.Code != http.StatusNotFound {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/logging_test.go","time":{"start":1775895300391,"end":1775895300402}}}}
