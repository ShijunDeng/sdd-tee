odernize#rangeint"},"source":"rangeint","message":"for loop can be modernized using range over int"},{"range":{"start":{"line":371,"character":6},"end":{"line":371,"character":25}},"severity":4,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/modernize#rangeint"},"source":"rangeint","message":"for loop can be modernized using range over int"},{"range":{"start":{"line":377,"character":5},"end":{"line":377,"character":23}},"severity":4,"code":"default","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/modernize#rangeint"},"source":"rangeint","message":"for loop can be modernized using range over int"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/doc.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_redis.go":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_test.go":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_test.go\n@@ -552,4 +552,240 @@\n func TestResetStorage(t *testing.T) {\n \tResetStorage()\n \tassert.Nil(t, provider)\n }\n+\n+func TestMakeRedisOptions(t *testing.T) {\n+\ttests := []struct {\n+\t\tname        string\n+\t\tenv         map[string]string\n+\t\twantErr     bool\n+\t\terrContains string\n+\t}{\n+\t\t{\n+\t\t\tname: \"valid config\",\n+\t\t\tenv: map[string]string{\n+\t\t\t\t\"REDIS_ADDR\":     \"localhost:6379\",\n+\t\t\t\t\"REDIS_PASSWORD\": \"testpass\",\n+\t\t\t},\n+\t\t\twantErr: false,\n+\t\t},\n+\t\t{\n+\t\t\tname: \"missing addr\",\n+\t\t\tenv: map[string]string{\n+\t\t\t\t\"REDIS_PASSWORD\": \"testpass\",\n+\t\t\t},\n+\t\t\twantErr:     true,\n+\t\t\terrContains: \"REDIS_ADDR is required\",\n+\t\t},\n+\t\t{\n+\t\t\tname: \"missing password with default requirement\",\n+\t\t\tenv: map[string]string{\n+\t\t\t\t\"REDIS_ADDR\": \"localhost:6379\",\n+\t\t\t},\n+\t\t\twantErr:     true,\n+\t\t\terrContains: \"password is required\",\n+\t\t},\n+\t\t{\n+\t\t\tname: \"missing password but not required\",\n+\t\t\tenv: map[string]string{\n+\t\t\t\t\"REDIS_ADDR\":              \"localhost:6379\",\n+\t\t\t\t\"REDIS_PASSWORD_REQUIRED\": \"false\",\n+\t\t\t},\n+\t\t\twantErr: false,\n+\t\t},\n+\t}\n+\n+\tfor _, tt := range tests {\n+\t\tt.Run(tt.name, func(t *testing.T) {\n+\t\t\tfor k, v := range tt.env {\n+\t\t\t\tt.Setenv(k, v)\n+\t\t\t}\n+\n+\t\t\topts, err := makeRedisOptions()\n+\t\t\tif tt.wantErr {\n+\t\t\t\trequire.Error(t, err)\n+\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n+\t\t\t} else {\n+\t\t\t\trequire.NoError(t, err)\n+\t\t\t\trequire.NotNil(t, opts)\n+\t\t\t\tassert.Equal(t, tt.env[\"REDIS_ADDR\"], opts.Addr)\n+\t\t\t}\n+\t\t})\n+\t}\n+}\n+\n+func TestNewValkeyStoreFromEnv(t *testing.T) {\n+\ttests := []struct {\n+\t\tname        string\n+\t\tenv         map[string]string\n+\t\twantErr     bool\n+\t\terrContains string\n+\t}{\n+\t\t{\n+\t\t\tname:        \"missing addr\",\n+\t\t\tenv:         map[string]string{},\n+\t\t\twantErr:     true,\n+\t\t\terrContains: \"VALKEY_ADDR is required\",\n+\t\t},\n+\t\t{\n+\t\t\tname: \"missing password with default requirement\",\n+\t\t\tenv: map[string]string{\n+\t\t\t\t\"VALKEY_ADDR\": \"localhost:6379\",\n+\t\t\t},\n+\t\t\twantErr:     true,\n+\t\t\terrContains: \"password is required\",\n+\t\t},\n+\t\t{\n+\t\t\tname: \"valid config\",\n+\t\t\tenv: map[string]string{\n+\t\t\t\t\"VALKEY_ADDR\":              \"localhost:6379\",\n+\t\t\t\t\"VALKEY_PASSWORD\":          \"testpass\",\n+\t\t\t\t\"VALKEY_PASSWORD_REQUIRED\": \"false\",\n+\t\t\t},\n+\t\t\twantErr: false,\n+\t\t},\n+\t}\n+\n+\tfor _, tt := range tests {\n+\t\tt.Run(tt.name, func(t *testing.T) {\n+\t\t\tfor k, v := range tt.env {\n+\t\t\t\tt.Setenv(k, v)\n+\t\t\t}\n+\n+\t\t\tstore, err := newValkeyStoreFromEnv()\n+\t\t\tif tt.wantErr {\n+\t\t\t\trequire.Error(t, err)\n+\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n+\t\t\t} else {\n+\t\t\t\trequire.NoError(t, err)\n+\t\t\t\trequire.NotNil(t, store)\n+\t\t\t}\n+\t\t})\n+\t}\n+}\n+\n+func TestValkeyStore_Methods(t *testing.T) {\n+\tstore := &valkeyStore{\n+\t\tsessionPrefix:        defaultSessionPrefix,\n+\t\texpiryIndexKey:       defaultExpiryIndexKey,\n+\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n+\t}\n+\tctx := context.Background()\n+\n+\terr := store.Ping(ctx)\n+\tassert.Error(t, err)\n+\tassert.Contains(t, err.Error(), \"valkey not configured\")\n+\n+\t_, err = store.GetSandboxBySessionID(ctx, \"test\")\n+\tassert.Error(t, err)\n+\n+\terr = store.StoreSandbox(ctx, makeTestSandbox(\"test\"))\n+\tassert.Error(t, err)\n+\n+\terr = store.UpdateSandbox(ctx, makeTestSandbox(\"test\"))\n+\tassert.Error(t, err)\n+\n+\terr = store.DeleteSandboxBySessionID(ctx, \"test\")\n+\tassert.Error(t, err)\n+\n+\t_, err = store.ListExpiredSandboxes(ctx, time.Now(), 10)\n+\tassert.Error(t, err)\n+\n+\t_, err = store.ListInactiveSandboxes(ctx, time.Now(), 10)\n+\tassert.Error(t, err)\n+\n+\terr = store.UpdateSessionLastActivity(ctx, \"test\", time.Now())\n+\tassert.Error(t, err)\n+\n+\terr = store.Close()\n+\tassert.NoError(t, err)\n+}\n+\n+func TestStorage_Singleton(t *testing.T) {\n+\tResetStorage()\n+\tt.Setenv(\"STORE_TYPE\", \"invalid\")\n+\tStorage()\n+\tassert.Nil(t, provider)\n+}\n+\n+func TestStorage_RedisProvider(t *testing.T) {\n+\tResetStorage()\n+\tmr := miniredis.RunT(t)\n+\tt.Setenv(\"STORE_TYPE\", \"redis\")\n+\tt.Setenv(\"REDIS_ADDR\", mr.Addr())\n+\tt.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n+\n+\tStorage()\n+\trequire.NotNil(t, provider)\n+\n+\tctx := context.Background()\n+\terr := provider.Ping(ctx)\n+\trequire.NoError(t, err)\n+\n+\terr = provider.Close()\n+\trequire.NoError(t, err)\n+}\n+\n+func TestStorage_ValkeyProvider(t *testing.T) {\n+\tResetStorage()\n+\tt.Setenv(\"STORE_TYPE\", \"valkey\")\n+\tt.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n+\tt.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n+\n+\tStorage()\n+\trequire.NotNil(t, provider)\n+\n+\terr := provider.Close()\n+\trequire.NoError(t, err)\n+}\n+\n+func TestStorage_DefaultRedis(t *testing.T) {\n+\tResetStorage()\n+\tmr := miniredis.RunT(t)\n+\tt.Setenv(\"REDIS_ADDR\", mr.Addr())\n+\tt.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n+\n+\tStorage()\n+\trequire.NotNil(t, provider)\n+\n+\tctx := context.Background()\n+\terr := provider.Ping(ctx)\n+\trequire.NoError(t, err)\n+\n+\terr = provider.Close()\n+\trequire.NoError(t, err)\n+}\n+\n+func TestRedisStore_ListExpiredSandboxes_Empty(t *testing.T) {\n+\tstore := setupTestRedisStore(t)\n+\tctx := context.Background()\n+\n+\tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 10)\n+\trequire.NoError(t, err)\n+\tassert.Nil(t, results)\n+}\n+\n+func TestRedisStore_ListInactiveSandboxes_Empty(t *testing.T) {\n+\tstore := setupTestRedisStore(t)\n+\tctx := context.Background()\n+\n+\tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 10)\n+\trequire.NoError(t, err)\n+\tassert.Nil(t, results)\n+}\n+\n+func TestRedisStore_PingError(t *testing.T) {\n+\tstore := setupTestRedisStore(t)\n+\tctx := context.Background()\n+\n+\tstore.cli.Close()\n+\n+\terr := store.Ping(ctx)\n+\tassert.Error(t, err)\n+}\n+\n+func TestRedisStore_SessionKey(t *testing.T) {\n+\tstore := setupTestRedisStore(t)\n+\tkey := store.sessionKey(\"test-id\")\n+\tassert.Equal(t, \"session:test-id\", key)\n+}\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_test.go","before":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\tredisv9 \"github.com/redis/go-redis/v9\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc setupTestRedisStore(t *testing.T) *redisStore {\n\tmr := miniredis.RunT(t)\n\tcli := redisv9.NewClient(&redisv9.Options{\n\t\tAddr: mr.Addr(),\n\t})\n\treturn &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        defaultSessionPrefix,\n\t\texpiryIndexKey:       defaultExpiryIndexKey,\n\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n\t}\n}\n\nfunc makeTestSandbox(sessionID string) *types.SandboxInfo {\n\tnow := time.Now()\n\treturn &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-\" + sessionID,\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"test-sandbox\",\n\t\tName:             \"test-sandbox\",\n\t\tSessionID:        sessionID,\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(24 * time.Hour),\n\t\tStatus:           \"active\",\n\t}\n}\n\nfunc TestRedisStore_Ping(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.Ping(ctx)\n\trequire.NoError(t, err)\n}\n\nfunc TestRedisStore_GetSandboxBySessionID_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\tdata, err := json.Marshal(sandbox)\n\trequire.NoError(t, err)\n\n\terr = store.cli.Set(ctx, store.sessionKey(\"session-123\"), data, 0).Err()\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, sandbox.SessionID, result.SessionID)\n\tassert.Equal(t, sandbox.SandboxID, result.SandboxID)\n}\n\nfunc TestRedisStore_GetSandboxBySessionID_NotFound(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"non-existent\")\n\tassert.Nil(t, result)\n\tassert.ErrorIs(t, err, ErrNotFound)\n}\n\nfunc TestRedisStore_GetSandboxBySessionID_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"\")\n\tassert.Nil(t, result)\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_StoreSandbox_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, sandbox.SessionID, result.SessionID)\n\n\texpiryScore, err := store.cli.ZScore(ctx, store.expiryIndexKey, \"session-123\").Result()\n\trequire.NoError(t, err)\n\tassert.Equal(t, float64(sandbox.ExpiresAt.Unix()), expiryScore)\n\n\tactivityScore, err := store.cli.ZScore(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, activityScore, float64(0))\n}\n\nfunc TestRedisStore_StoreSandbox_NilSandbox(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.StoreSandbox(ctx, nil)\n\tassert.ErrorIs(t, err, ErrNilSandbox)\n}\n\nfunc TestRedisStore_StoreSandbox_ZeroExpiresAt(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := &types.SandboxInfo{\n\t\tSessionID: \"session-123\",\n\t\tExpiresAt: time.Time{},\n\t}\n\n\terr := store.StoreSandbox(ctx, sandbox)\n\tassert.ErrorIs(t, err, ErrZeroExpiresAt)\n}\n\nfunc TestRedisStore_StoreSandbox_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := &types.SandboxInfo{\n\t\tSessionID: \"\",\n\t\tExpiresAt: time.Now().Add(24 * time.Hour),\n\t}\n\n\terr := store.StoreSandbox(ctx, sandbox)\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_StoreSandbox_Duplicate(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\terr = store.StoreSandbox(ctx, sandbox)\n\tassert.Error(t, err)\n}\n\nfunc TestRedisStore_UpdateSandbox_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tsandbox.Status = \"terminating\"\n\terr = store.UpdateSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"terminating\", result.Status)\n}\n\nfunc TestRedisStore_UpdateSandbox_NotFound(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"non-existent\")\n\n\terr := store.UpdateSandbox(ctx, sandbox)\n\tassert.ErrorIs(t, err, ErrNotFound)\n}\n\nfunc TestRedisStore_UpdateSandbox_NilSandbox(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.UpdateSandbox(ctx, nil)\n\tassert.ErrorIs(t, err, ErrNilSandbox)\n}\n\nfunc TestRedisStore_UpdateSandbox_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := &types.SandboxInfo{SessionID: \"\"}\n\n\terr := store.UpdateSandbox(ctx, sandbox)\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_DeleteSandboxBySessionID_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\terr = store.DeleteSandboxBySessionID(ctx, \"session-123\")\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n\tassert.Nil(t, result)\n\tassert.ErrorIs(t, err, ErrNotFound)\n\n\t_, err = store.cli.ZRank(ctx, store.expiryIndexKey, \"session-123\").Result()\n\tassert.Error(t, err)\n\n\t_, err = store.cli.ZRank(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n\tassert.Error(t, err)\n}\n\nfunc TestRedisStore_DeleteSandboxBySessionID_NotFound(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.DeleteSandboxBySessionID(ctx, \"non-existent\")\n\tassert.NoError(t, err)\n}\n\nfunc TestRedisStore_DeleteSandboxBySessionID_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.DeleteSandboxBySessionID(ctx, \"\")\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\texpiredSandbox := &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-expired\",\n\t\tSandboxNamespace: \"default\",\n\t\tSessionID:        \"session-expired\",\n\t\tCreatedAt:        now.Add(-10 * time.Hour),\n\t\tExpiresAt:        now.Add(-2 * time.Hour),\n\t\tStatus:           \"active\",\n\t\tLastActivity:     now.Add(-10 * time.Hour),\n\t}\n\n\tactiveSandbox := &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-active\",\n\t\tSandboxNamespace: \"default\",\n\t\tSessionID:        \"session-active\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"active\",\n\t\tLastActivity:     now,\n\t}\n\n\terr := store.StoreSandbox(ctx, expiredSandbox)\n\trequire.NoError(t, err)\n\terr = store.StoreSandbox(ctx, activeSandbox)\n\trequire.NoError(t, err)\n\n\tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 1)\n\tassert.Equal(t, \"session-expired\", results[0].SessionID)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_Limit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\tfor i := 0; i < 20; i++ {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tKind:             types.AgentRuntimeKind,\n\t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n\t\t\tSandboxNamespace: \"default\",\n\t\t\tSessionID:        \"session-\" + string(rune(i)),\n\t\t\tCreatedAt:        now.Add(-10 * time.Hour),\n\t\t\tExpiresAt:        now.Add(-time.Duration(i+1) * time.Hour),\n\t\t\tStatus:           \"active\",\n\t\t\tLastActivity:     now.Add(-10 * time.Hour),\n\t\t}\n\t\terr := store.StoreSandbox(ctx, sandbox)\n\t\trequire.NoError(t, err)\n\t}\n\n\tresults, err := store.ListExpiredSandboxes(ctx, now, 5)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 5)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_ZeroLimit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n\trequire.NoError(t, err)\n\tassert.Nil(t, results)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_NegativeLimit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n\trequire.NoError(t, err)\n\tassert.Nil(t, results)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_SkipMissing(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\terr := store.cli.ZAdd(ctx, store.expiryIndexKey, redisv9.Z{\n\t\tScore:  float64(now.Add(-1 * time.Hour).Unix()),\n\t\tMember: \"orphan-session\",\n\t}).Err()\n\trequire.NoError(t, err)\n\n\tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 0)\n}\n\nfunc TestRedisStore_ListInactiveSandboxes_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\tinactiveSandbox := &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-inactive\",\n\t\tSandboxNamespace: \"default\",\n\t\tSessionID:        \"session-inactive\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"active\",\n\t\tLastActivity:     now.Add(-30 * time.Minute),\n\t}\n\n\tactiveSandbox := &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-active\",\n\t\tSandboxNamespace: \"default\",\n\t\tSessionID:        \"session-active\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"active\",\n\t\tLastActivity:     now,\n\t}\n\n\terr := store.StoreSandbox(ctx, inactiveSandbox)\n\trequire.NoError(t, err)\n\terr = store.StoreSandbox(ctx, activeSandbox)\n\trequire.NoError(t, err)\n\n\tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 10)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 1)\n\tassert.Equal(t, \"session-inactive\", results[0].SessionID)\n}\n\nfunc TestRedisStore_ListInactiveSandboxes_Limit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\tfor i := 0; i < 20; i++ {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tKind:             types.AgentRuntimeKind,\n\t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n\t\t\tSandboxNamespace: \"default\",\n\t\t\tSessionID:        \"session-\" + string(rune(i)),\n\t\t\tCreatedAt:        now,\n\t\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\t\tStatus:           \"active\",\n\t\t\tLastActivity:     now.Add(-time.Duration(i+20) * time.Minute),\n\t\t}\n\t\terr := store.StoreSandbox(ctx, sandbox)\n\t\trequire.NoError(t, err)\n\t}\n\n\tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 5)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 5)\n}\n\nfunc TestRedisStore_ListInactiveSandboxes_ZeroLimit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n\trequire.NoError(t, err)\n\tassert.Nil(t, results)\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tnewActivity := time.Now().Add(1 * time.Hour)\n\terr = store.UpdateSessionLastActivity(ctx, \"session-123\", newActivity)\n\trequire.NoError(t, err)\n\n\tscore, err := store.cli.ZScore(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n\trequire.NoError(t, err)\n\tassert.Equal(t, float64(newActivity.Unix()), score)\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tbefore := time.Now()\n\terr = store.UpdateSessionLastActivity(ctx, \"session-123\", time.Time{})\n\trequire.NoError(t, err)\n\n\tscore, err := store.cli.ZScore(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, score, float64(before.Unix()))\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity_NotFound(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.UpdateSessionLastActivity(ctx, \"non-existent\", time.Now())\n\tassert.ErrorIs(t, err, ErrNotFound)\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_Close(t *testing.T) {\n\tmr := miniredis.RunT(t)\n\tcli := redisv9.NewClient(&redisv9.Options{\n\t\tAddr: mr.Addr(),\n\t})\n\tstore := &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        defaultSessionPrefix,\n\t\texpiryIndexKey:       defaultExpiryIndexKey,\n\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n\t}\n\n\terr := store.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestNewRedisStore(t *testing.T) {\n\tmr := miniredis.RunT(t)\n\tstore := NewRedisStore(mr.Addr(), \"\")\n\n\trequire.NotNil(t, store)\n\n\tctx := context.Background()\n\terr := store.Ping(ctx)\n\trequire.NoError(t, err)\n\n\terr = store.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestNewRedisStoreWithOptions(t *testing.T) {\n\tmr := miniredis.RunT(t)\n\tstore := NewRedisStoreWithOptions(mr.Addr(), \"\", \"custom:\", \"custom:expiry\", \"custom:activity\")\n\n\trequire.NotNil(t, store)\n\n\trs := store.(*redisStore)\n\tassert.Equal(t, \"custom:\", rs.sessionPrefix)\n\tassert.Equal(t, \"custom:expiry\", rs.expiryIndexKey)\n\tassert.Equal(t, \"custom:activity\", rs.lastActivityIndexKey)\n\n\terr := store.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestNewRedisStoreWithClient(t *testing.T) {\n\tmr := miniredis.RunT(t)\n\tcli := redisv9.NewClient(&redisv9.Options{\n\t\tAddr: mr.Addr(),\n\t})\n\n\tstore := NewRedisStoreWithClient(cli)\n\trequire.NotNil(t, store)\n\n\tctx := context.Background()\n\terr := store.Ping(ctx)\n\trequire.NoError(t, err)\n}\n\nfunc TestRedisStore_ErrorHandling(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tkey := store.sessionKey(\"test-session\")\n\tstore.cli.Set(ctx, key, \"invalid-json\", 0)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"test-session\")\n\tassert.Nil(t, result)\n\tassert.Error(t, err)\n\tassert.False(t, errors.Is(err, ErrNotFound))\n}\n\nfunc TestErrors(t *testing.T) {\n\tassert.Equal(t, \"store: not found\", ErrNotFound.Error())\n\tassert.Equal(t, \"store: sandbox is nil\", ErrNilSandbox.Error())\n\tassert.Equal(t, \"store: expiresAt is required\", ErrZeroExpiresAt.Error())\n\tassert.Equal(t, \"store: sessionID is required\", ErrEmptySessionID.Error())\n\tassert.Equal(t, \"store: invalid provider type\", ErrInvalidProvider.Error())\n\tassert.Equal(t, \"store: password is required\", ErrPasswordRequired.Error())\n\tassert.Equal(t, \"store: key not exists\", ErrKeyNotExists.Error())\n\tassert.Equal(t, \"store: session already exists\", ErrSessionExists.Error())\n}\n\nfunc TestConstants(t *testing.T) {\n\tassert.Equal(t, \"redis\", redisStoreType)\n\tassert.Equal(t, \"valkey\", valkeyStoreType)\n}\n\nfunc TestResetStorage(t *testing.T) {\n\tResetStorage()\n\tassert.Nil(t, provider)\n}\n","after":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/alicebob/miniredis/v2\"\n\tredisv9 \"github.com/redis/go-redis/v9\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\nfunc setupTestRedisStore(t *testing.T) *redisStore {\n\tmr := miniredis.RunT(t)\n\tcli := redisv9.NewClient(&redisv9.Options{\n\t\tAddr: mr.Addr(),\n\t})\n\treturn &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        defaultSessionPrefix,\n\t\texpiryIndexKey:       defaultExpiryIndexKey,\n\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n\t}\n}\n\nfunc makeTestSandbox(sessionID string) *types.SandboxInfo {\n\tnow := time.Now()\n\treturn &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-\" + sessionID,\n\t\tSandboxNamespace: \"default\",\n\t\tSandboxName:      \"test-sandbox\",\n\t\tName:             \"test-sandbox\",\n\t\tSessionID:        sessionID,\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(24 * time.Hour),\n\t\tStatus:           \"active\",\n\t}\n}\n\nfunc TestRedisStore_Ping(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.Ping(ctx)\n\trequire.NoError(t, err)\n}\n\nfunc TestRedisStore_GetSandboxBySessionID_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\tdata, err := json.Marshal(sandbox)\n\trequire.NoError(t, err)\n\n\terr = store.cli.Set(ctx, store.sessionKey(\"session-123\"), data, 0).Err()\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, sandbox.SessionID, result.SessionID)\n\tassert.Equal(t, sandbox.SandboxID, result.SandboxID)\n}\n\nfunc TestRedisStore_GetSandboxBySessionID_NotFound(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"non-existent\")\n\tassert.Nil(t, result)\n\tassert.ErrorIs(t, err, ErrNotFound)\n}\n\nfunc TestRedisStore_GetSandboxBySessionID_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"\")\n\tassert.Nil(t, result)\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_StoreSandbox_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, sandbox.SessionID, result.SessionID)\n\n\texpiryScore, err := store.cli.ZScore(ctx, store.expiryIndexKey, \"session-123\").Result()\n\trequire.NoError(t, err)\n\tassert.Equal(t, float64(sandbox.ExpiresAt.Unix()), expiryScore)\n\n\tactivityScore, err := store.cli.ZScore(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, activityScore, float64(0))\n}\n\nfunc TestRedisStore_StoreSandbox_NilSandbox(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.StoreSandbox(ctx, nil)\n\tassert.ErrorIs(t, err, ErrNilSandbox)\n}\n\nfunc TestRedisStore_StoreSandbox_ZeroExpiresAt(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := &types.SandboxInfo{\n\t\tSessionID: \"session-123\",\n\t\tExpiresAt: time.Time{},\n\t}\n\n\terr := store.StoreSandbox(ctx, sandbox)\n\tassert.ErrorIs(t, err, ErrZeroExpiresAt)\n}\n\nfunc TestRedisStore_StoreSandbox_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := &types.SandboxInfo{\n\t\tSessionID: \"\",\n\t\tExpiresAt: time.Now().Add(24 * time.Hour),\n\t}\n\n\terr := store.StoreSandbox(ctx, sandbox)\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_StoreSandbox_Duplicate(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\terr = store.StoreSandbox(ctx, sandbox)\n\tassert.Error(t, err)\n}\n\nfunc TestRedisStore_UpdateSandbox_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tsandbox.Status = \"terminating\"\n\terr = store.UpdateSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"terminating\", result.Status)\n}\n\nfunc TestRedisStore_UpdateSandbox_NotFound(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"non-existent\")\n\n\terr := store.UpdateSandbox(ctx, sandbox)\n\tassert.ErrorIs(t, err, ErrNotFound)\n}\n\nfunc TestRedisStore_UpdateSandbox_NilSandbox(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.UpdateSandbox(ctx, nil)\n\tassert.ErrorIs(t, err, ErrNilSandbox)\n}\n\nfunc TestRedisStore_UpdateSandbox_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := &types.SandboxInfo{SessionID: \"\"}\n\n\terr := store.UpdateSandbox(ctx, sandbox)\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_DeleteSandboxBySessionID_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\terr = store.DeleteSandboxBySessionID(ctx, \"session-123\")\n\trequire.NoError(t, err)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"session-123\")\n\tassert.Nil(t, result)\n\tassert.ErrorIs(t, err, ErrNotFound)\n\n\t_, err = store.cli.ZRank(ctx, store.expiryIndexKey, \"session-123\").Result()\n\tassert.Error(t, err)\n\n\t_, err = store.cli.ZRank(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n\tassert.Error(t, err)\n}\n\nfunc TestRedisStore_DeleteSandboxBySessionID_NotFound(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.DeleteSandboxBySessionID(ctx, \"non-existent\")\n\tassert.NoError(t, err)\n}\n\nfunc TestRedisStore_DeleteSandboxBySessionID_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.DeleteSandboxBySessionID(ctx, \"\")\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\texpiredSandbox := &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-expired\",\n\t\tSandboxNamespace: \"default\",\n\t\tSessionID:        \"session-expired\",\n\t\tCreatedAt:        now.Add(-10 * time.Hour),\n\t\tExpiresAt:        now.Add(-2 * time.Hour),\n\t\tStatus:           \"active\",\n\t\tLastActivity:     now.Add(-10 * time.Hour),\n\t}\n\n\tactiveSandbox := &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-active\",\n\t\tSandboxNamespace: \"default\",\n\t\tSessionID:        \"session-active\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"active\",\n\t\tLastActivity:     now,\n\t}\n\n\terr := store.StoreSandbox(ctx, expiredSandbox)\n\trequire.NoError(t, err)\n\terr = store.StoreSandbox(ctx, activeSandbox)\n\trequire.NoError(t, err)\n\n\tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 1)\n\tassert.Equal(t, \"session-expired\", results[0].SessionID)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_Limit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\tfor i := 0; i < 20; i++ {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tKind:             types.AgentRuntimeKind,\n\t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n\t\t\tSandboxNamespace: \"default\",\n\t\t\tSessionID:        \"session-\" + string(rune(i)),\n\t\t\tCreatedAt:        now.Add(-10 * time.Hour),\n\t\t\tExpiresAt:        now.Add(-time.Duration(i+1) * time.Hour),\n\t\t\tStatus:           \"active\",\n\t\t\tLastActivity:     now.Add(-10 * time.Hour),\n\t\t}\n\t\terr := store.StoreSandbox(ctx, sandbox)\n\t\trequire.NoError(t, err)\n\t}\n\n\tresults, err := store.ListExpiredSandboxes(ctx, now, 5)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 5)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_ZeroLimit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 0)\n\trequire.NoError(t, err)\n\tassert.Nil(t, results)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_NegativeLimit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), -1)\n\trequire.NoError(t, err)\n\tassert.Nil(t, results)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_SkipMissing(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\terr := store.cli.ZAdd(ctx, store.expiryIndexKey, redisv9.Z{\n\t\tScore:  float64(now.Add(-1 * time.Hour).Unix()),\n\t\tMember: \"orphan-session\",\n\t}).Err()\n\trequire.NoError(t, err)\n\n\tresults, err := store.ListExpiredSandboxes(ctx, now, 10)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 0)\n}\n\nfunc TestRedisStore_ListInactiveSandboxes_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\tinactiveSandbox := &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-inactive\",\n\t\tSandboxNamespace: \"default\",\n\t\tSessionID:        \"session-inactive\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"active\",\n\t\tLastActivity:     now.Add(-30 * time.Minute),\n\t}\n\n\tactiveSandbox := &types.SandboxInfo{\n\t\tKind:             types.AgentRuntimeKind,\n\t\tSandboxID:        \"sb-active\",\n\t\tSandboxNamespace: \"default\",\n\t\tSessionID:        \"session-active\",\n\t\tCreatedAt:        now,\n\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\tStatus:           \"active\",\n\t\tLastActivity:     now,\n\t}\n\n\terr := store.StoreSandbox(ctx, inactiveSandbox)\n\trequire.NoError(t, err)\n\terr = store.StoreSandbox(ctx, activeSandbox)\n\trequire.NoError(t, err)\n\n\tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 10)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 1)\n\tassert.Equal(t, \"session-inactive\", results[0].SessionID)\n}\n\nfunc TestRedisStore_ListInactiveSandboxes_Limit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tnow := time.Now()\n\n\tfor i := 0; i < 20; i++ {\n\t\tsandbox := &types.SandboxInfo{\n\t\t\tKind:             types.AgentRuntimeKind,\n\t\t\tSandboxID:        \"sb-\" + string(rune(i)),\n\t\t\tSandboxNamespace: \"default\",\n\t\t\tSessionID:        \"session-\" + string(rune(i)),\n\t\t\tCreatedAt:        now,\n\t\t\tExpiresAt:        now.Add(8 * time.Hour),\n\t\t\tStatus:           \"active\",\n\t\t\tLastActivity:     now.Add(-time.Duration(i+20) * time.Minute),\n\t\t}\n\t\terr := store.StoreSandbox(ctx, sandbox)\n\t\trequire.NoError(t, err)\n\t}\n\n\tresults, err := store.ListInactiveSandboxes(ctx, now.Add(-15*time.Minute), 5)\n\trequire.NoError(t, err)\n\tassert.Len(t, results, 5)\n}\n\nfunc TestRedisStore_ListInactiveSandboxes_ZeroLimit(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 0)\n\trequire.NoError(t, err)\n\tassert.Nil(t, results)\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity_Success(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tnewActivity := time.Now().Add(1 * time.Hour)\n\terr = store.UpdateSessionLastActivity(ctx, \"session-123\", newActivity)\n\trequire.NoError(t, err)\n\n\tscore, err := store.cli.ZScore(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n\trequire.NoError(t, err)\n\tassert.Equal(t, float64(newActivity.Unix()), score)\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity_ZeroTime(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tsandbox := makeTestSandbox(\"session-123\")\n\terr := store.StoreSandbox(ctx, sandbox)\n\trequire.NoError(t, err)\n\n\tbefore := time.Now()\n\terr = store.UpdateSessionLastActivity(ctx, \"session-123\", time.Time{})\n\trequire.NoError(t, err)\n\n\tscore, err := store.cli.ZScore(ctx, store.lastActivityIndexKey, \"session-123\").Result()\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, score, float64(before.Unix()))\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity_NotFound(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.UpdateSessionLastActivity(ctx, \"non-existent\", time.Now())\n\tassert.ErrorIs(t, err, ErrNotFound)\n}\n\nfunc TestRedisStore_UpdateSessionLastActivity_EmptySessionID(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\terr := store.UpdateSessionLastActivity(ctx, \"\", time.Now())\n\tassert.ErrorIs(t, err, ErrEmptySessionID)\n}\n\nfunc TestRedisStore_Close(t *testing.T) {\n\tmr := miniredis.RunT(t)\n\tcli := redisv9.NewClient(&redisv9.Options{\n\t\tAddr: mr.Addr(),\n\t})\n\tstore := &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        defaultSessionPrefix,\n\t\texpiryIndexKey:       defaultExpiryIndexKey,\n\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n\t}\n\n\terr := store.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestNewRedisStore(t *testing.T) {\n\tmr := miniredis.RunT(t)\n\tstore := NewRedisStore(mr.Addr(), \"\")\n\n\trequire.NotNil(t, store)\n\n\tctx := context.Background()\n\terr := store.Ping(ctx)\n\trequire.NoError(t, err)\n\n\terr = store.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestNewRedisStoreWithOptions(t *testing.T) {\n\tmr := miniredis.RunT(t)\n\tstore := NewRedisStoreWithOptions(mr.Addr(), \"\", \"custom:\", \"custom:expiry\", \"custom:activity\")\n\n\trequire.NotNil(t, store)\n\n\trs := store.(*redisStore)\n\tassert.Equal(t, \"custom:\", rs.sessionPrefix)\n\tassert.Equal(t, \"custom:expiry\", rs.expiryIndexKey)\n\tassert.Equal(t, \"custom:activity\", rs.lastActivityIndexKey)\n\n\terr := store.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestNewRedisStoreWithClient(t *testing.T) {\n\tmr := miniredis.RunT(t)\n\tcli := redisv9.NewClient(&redisv9.Options{\n\t\tAddr: mr.Addr(),\n\t})\n\n\tstore := NewRedisStoreWithClient(cli)\n\trequire.NotNil(t, store)\n\n\tctx := context.Background()\n\terr := store.Ping(ctx)\n\trequire.NoError(t, err)\n}\n\nfunc TestRedisStore_ErrorHandling(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tkey := store.sessionKey(\"test-session\")\n\tstore.cli.Set(ctx, key, \"invalid-json\", 0)\n\n\tresult, err := store.GetSandboxBySessionID(ctx, \"test-session\")\n\tassert.Nil(t, result)\n\tassert.Error(t, err)\n\tassert.False(t, errors.Is(err, ErrNotFound))\n}\n\nfunc TestErrors(t *testing.T) {\n\tassert.Equal(t, \"store: not found\", ErrNotFound.Error())\n\tassert.Equal(t, \"store: sandbox is nil\", ErrNilSandbox.Error())\n\tassert.Equal(t, \"store: expiresAt is required\", ErrZeroExpiresAt.Error())\n\tassert.Equal(t, \"store: sessionID is required\", ErrEmptySessionID.Error())\n\tassert.Equal(t, \"store: invalid provider type\", ErrInvalidProvider.Error())\n\tassert.Equal(t, \"store: password is required\", ErrPasswordRequired.Error())\n\tassert.Equal(t, \"store: key not exists\", ErrKeyNotExists.Error())\n\tassert.Equal(t, \"store: session already exists\", ErrSessionExists.Error())\n}\n\nfunc TestConstants(t *testing.T) {\n\tassert.Equal(t, \"redis\", redisStoreType)\n\tassert.Equal(t, \"valkey\", valkeyStoreType)\n}\n\nfunc TestResetStorage(t *testing.T) {\n\tResetStorage()\n\tassert.Nil(t, provider)\n}\n\nfunc TestMakeRedisOptions(t *testing.T) {\n\ttests := []struct {\n\t\tname        string\n\t\tenv         map[string]string\n\t\twantErr     bool\n\t\terrContains string\n\t}{\n\t\t{\n\t\t\tname: \"valid config\",\n\t\t\tenv: map[string]string{\n\t\t\t\t\"REDIS_ADDR\":     \"localhost:6379\",\n\t\t\t\t\"REDIS_PASSWORD\": \"testpass\",\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t\t{\n\t\t\tname: \"missing addr\",\n\t\t\tenv: map[string]string{\n\t\t\t\t\"REDIS_PASSWORD\": \"testpass\",\n\t\t\t},\n\t\t\twantErr:     true,\n\t\t\terrContains: \"REDIS_ADDR is required\",\n\t\t},\n\t\t{\n\t\t\tname: \"missing password with default requirement\",\n\t\t\tenv: map[string]string{\n\t\t\t\t\"REDIS_ADDR\": \"localhost:6379\",\n\t\t\t},\n\t\t\twantErr:     true,\n\t\t\terrContains: \"password is required\",\n\t\t},\n\t\t{\n\t\t\tname: \"missing password but not required\",\n\t\t\tenv: map[string]string{\n\t\t\t\t\"REDIS_ADDR\":              \"localhost:6379\",\n\t\t\t\t\"REDIS_PASSWORD_REQUIRED\": \"false\",\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tfor k, v := range tt.env {\n\t\t\t\tt.Setenv(k, v)\n\t\t\t}\n\n\t\t\topts, err := makeRedisOptions()\n\t\t\tif tt.wantErr {\n\t\t\t\trequire.Error(t, err)\n\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n\t\t\t} else {\n\t\t\t\trequire.NoError(t, err)\n\t\t\t\trequire.NotNil(t, opts)\n\t\t\t\tassert.Equal(t, tt.env[\"REDIS_ADDR\"], opts.Addr)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestNewValkeyStoreFromEnv(t *testing.T) {\n\ttests := []struct {\n\t\tname        string\n\t\tenv         map[string]string\n\t\twantErr     bool\n\t\terrContains string\n\t}{\n\t\t{\n\t\t\tname:        \"missing addr\",\n\t\t\tenv:         map[string]string{},\n\t\t\twantErr:     true,\n\t\t\terrContains: \"VALKEY_ADDR is required\",\n\t\t},\n\t\t{\n\t\t\tname: \"missing password with default requirement\",\n\t\t\tenv: map[string]string{\n\t\t\t\t\"VALKEY_ADDR\": \"localhost:6379\",\n\t\t\t},\n\t\t\twantErr:     true,\n\t\t\terrContains: \"password is required\",\n\t\t},\n\t\t{\n\t\t\tname: \"valid config\",\n\t\t\tenv: map[string]string{\n\t\t\t\t\"VALKEY_ADDR\":              \"localhost:6379\",\n\t\t\t\t\"VALKEY_PASSWORD\":          \"testpass\",\n\t\t\t\t\"VALKEY_PASSWORD_REQUIRED\": \"false\",\n\t\t\t},\n\t\t\twantErr: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tfor k, v := range tt.env {\n\t\t\t\tt.Setenv(k, v)\n\t\t\t}\n\n\t\t\tstore, err := newValkeyStoreFromEnv()\n\t\t\tif tt.wantErr {\n\t\t\t\trequire.Error(t, err)\n\t\t\t\tassert.Contains(t, err.Error(), tt.errContains)\n\t\t\t} else {\n\t\t\t\trequire.NoError(t, err)\n\t\t\t\trequire.NotNil(t, store)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestValkeyStore_Methods(t *testing.T) {\n\tstore := &valkeyStore{\n\t\tsessionPrefix:        defaultSessionPrefix,\n\t\texpiryIndexKey:       defaultExpiryIndexKey,\n\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n\t}\n\tctx := context.Background()\n\n\terr := store.Ping(ctx)\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"valkey not configured\")\n\n\t_, err = store.GetSandboxBySessionID(ctx, \"test\")\n\tassert.Error(t, err)\n\n\terr = store.StoreSandbox(ctx, makeTestSandbox(\"test\"))\n\tassert.Error(t, err)\n\n\terr = store.UpdateSandbox(ctx, makeTestSandbox(\"test\"))\n\tassert.Error(t, err)\n\n\terr = store.DeleteSandboxBySessionID(ctx, \"test\")\n\tassert.Error(t, err)\n\n\t_, err = store.ListExpiredSandboxes(ctx, time.Now(), 10)\n\tassert.Error(t, err)\n\n\t_, err = store.ListInactiveSandboxes(ctx, time.Now(), 10)\n\tassert.Error(t, err)\n\n\terr = store.UpdateSessionLastActivity(ctx, \"test\", time.Now())\n\tassert.Error(t, err)\n\n\terr = store.Close()\n\tassert.NoError(t, err)\n}\n\nfunc TestStorage_Singleton(t *testing.T) {\n\tResetStorage()\n\tt.Setenv(\"STORE_TYPE\", \"invalid\")\n\tStorage()\n\tassert.Nil(t, provider)\n}\n\nfunc TestStorage_RedisProvider(t *testing.T) {\n\tResetStorage()\n\tmr := miniredis.RunT(t)\n\tt.Setenv(\"STORE_TYPE\", \"redis\")\n\tt.Setenv(\"REDIS_ADDR\", mr.Addr())\n\tt.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n\n\tStorage()\n\trequire.NotNil(t, provider)\n\n\tctx := context.Background()\n\terr := provider.Ping(ctx)\n\trequire.NoError(t, err)\n\n\terr = provider.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestStorage_ValkeyProvider(t *testing.T) {\n\tResetStorage()\n\tt.Setenv(\"STORE_TYPE\", \"valkey\")\n\tt.Setenv(\"VALKEY_ADDR\", \"localhost:6379\")\n\tt.Setenv(\"VALKEY_PASSWORD_REQUIRED\", \"false\")\n\n\tStorage()\n\trequire.NotNil(t, provider)\n\n\terr := provider.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestStorage_DefaultRedis(t *testing.T) {\n\tResetStorage()\n\tmr := miniredis.RunT(t)\n\tt.Setenv(\"REDIS_ADDR\", mr.Addr())\n\tt.Setenv(\"REDIS_PASSWORD_REQUIRED\", \"false\")\n\n\tStorage()\n\trequire.NotNil(t, provider)\n\n\tctx := context.Background()\n\terr := provider.Ping(ctx)\n\trequire.NoError(t, err)\n\n\terr = provider.Close()\n\trequire.NoError(t, err)\n}\n\nfunc TestRedisStore_ListExpiredSandboxes_Empty(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresults, err := store.ListExpiredSandboxes(ctx, time.Now(), 10)\n\trequire.NoError(t, err)\n\tassert.Nil(t, results)\n}\n\nfunc TestRedisStore_ListInactiveSandboxes_Empty(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tresults, err := store.ListInactiveSandboxes(ctx, time.Now(), 10)\n\trequire.NoError(t, err)\n\tassert.Nil(t, results)\n}\n\nfunc TestRedisStore_PingError(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tctx := context.Background()\n\n\tstore.cli.Close()\n\n\terr := store.Ping(ctx)\n\tassert.Error(t, err)\n}\n\nfunc TestRedisStore_SessionKey(t *testing.T) {\n\tstore := setupTestRedisStore(t)\n\tkey := store.sessionKey(\"test-id\")\n\tassert.Equal(t, \"session:test-id\", key)\n}\n","additions":236,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_test.go","time":{"start":1775858084125,"end":1775858084322}}}}
