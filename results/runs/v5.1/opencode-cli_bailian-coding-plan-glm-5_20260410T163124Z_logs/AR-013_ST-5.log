ries by expiry time and last activity time.\n//\n// Key Design:\n//   - session:{id} - JSON document storing SandboxInfo\n//   - session:expiry - ZSET index for expiry-based cleanup\n//   - session:last_activity - ZSET index for activity-based cleanup\n//\n// Usage:\n//\n//\tstore := store.Storage()\n//\terr := store.StoreSandbox(ctx, sandbox)\n//\tsandbox, err := store.GetSandboxBySessionID(ctx, sessionID)\n//\n// Configuration:\n//   - STORE_TYPE: \"redis\" or \"valkey\" (default: \"redis\")\n//   - REDIS_ADDR: Redis address (e.g., \"localhost:6379\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/doc.go","time":{"start":1775858134870,"end":1775858134878}}}}
