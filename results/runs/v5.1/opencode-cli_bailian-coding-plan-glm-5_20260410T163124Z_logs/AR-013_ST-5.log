spaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_redis.go\n@@ -168,15 +168,14 @@\n \tScore:  float64(sandbox.LastActivity.Unix()),\n \tMember: sandbox.SessionID,\n })\n \n-cmds, err := pipe.Exec(ctx)\n+_, err = pipe.Exec(ctx)\n if err != nil {\n \treturn fmt.Errorf(\"store: pipeline exec: %w\", err)\n }\n \n-setCmd := cmds[0].(*redisv9.BoolCmd)\n-setResult, err := setCmd.Result()\n+setResult, err := setNXCmd.Result()\n if err != nil {\n \treturn fmt.Errorf(\"store: setnx result: %w\", err)\n }\n if !setResult {\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/store/store_redis.go","before":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tredisv9 \"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  *redisv9.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nconst (\n\tdefaultSessionPrefix        = \"session:\"\n\tdefaultExpiryIndexKey       = \"session:expiry\"\n\tdefaultLastActivityIndexKey = \"session:last_activity\"\n)\n\nfunc NewRedisStore(addr, password string) Store {\n\treturn NewRedisStoreWithOptions(addr, password, defaultSessionPrefix, defaultExpiryIndexKey, defaultLastActivityIndexKey)\n}\n\nfunc NewRedisStoreWithOptions(addr, password, sessionPrefix, expiryIndexKey, lastActivityIndexKey string) Store {\n\tcli := redisv9.NewClient(&redisv9.Options{\n\t\tAddr:     addr,\n\t\tPassword: password,\n\t})\n\treturn &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n}\n\nfunc NewRedisStoreWithClient(cli *redisv9.Client) Store {\n\treturn &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        defaultSessionPrefix,\n\t\texpiryIndexKey:       defaultExpiryIndexKey,\n\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n\t}\n}\n\nfunc makeRedisOptions() (*redisv9.Options, error) {\n\taddr := os.Getenv(\"REDIS_ADDR\")\n\tif addr == \"\" {\n\t\treturn nil, errors.New(\"REDIS_ADDR is required\")\n\t}\n\n\tpassword := os.Getenv(\"REDIS_PASSWORD\")\n\tpasswordRequired := strings.ToLower(os.Getenv(\"REDIS_PASSWORD_REQUIRED\"))\n\tif password == \"\" && passwordRequired != \"false\" {\n\t\treturn nil, ErrPasswordRequired\n\t}\n\n\treturn &redisv9.Options{\n\t\tAddr:     addr,\n\t\tPassword: password,\n\t}, nil\n}\n\nfunc initStore() {\n\tstoreType := os.Getenv(\"STORE_TYPE\")\n\tif storeType == \"\" {\n\t\tstoreType = redisStoreType\n\t}\n\n\tvar err error\n\tswitch storeType {\n\tcase redisStoreType:\n\t\topts, err := makeRedisOptions()\n\t\tif err != nil {\n\t\t\tklog.ErrorS(err, \"failed to create redis options\")\n\t\t\treturn\n\t\t}\n\t\tprovider = NewRedisStore(opts.Addr, opts.Password)\n\tcase valkeyStoreType:\n\t\tprovider, err = newValkeyStoreFromEnv()\n\t\tif err != nil {\n\t\t\tklog.ErrorS(err, \"failed to create valkey store\")\n\t\t\treturn\n\t\t}\n\tdefault:\n\t\tklog.ErrorS(nil, \"invalid store type\", \"type\", storeType)\n\t}\n}\n\nfunc (s *redisStore) sessionKey(sessionID string) string {\n\treturn s.sessionPrefix + sessionID\n}\n\nfunc (s *redisStore) Ping(ctx context.Context) error {\n\tresult, err := s.cli.Ping(ctx).Result()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: ping failed: %w\", err)\n\t}\n\tif result != \"PONG\" {\n\t\treturn fmt.Errorf(\"store: unexpected ping response: %s\", result)\n\t}\n\treturn nil\n}\n\nfunc (s *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\tif sessionID == \"\" {\n\t\treturn nil, ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sessionID)\n\tresult, err := s.cli.Get(ctx, key).Result()\n\tif err != nil {\n\t\tif errors.Is(err, redisv9.Nil) {\n\t\t\treturn nil, ErrNotFound\n\t\t}\n\t\treturn nil, fmt.Errorf(\"store: get session %s: %w\", sessionID, err)\n\t}\n\n\tvar sandbox types.SandboxInfo\n\tif err := json.Unmarshal([]byte(result), &sandbox); err != nil {\n\t\treturn nil, fmt.Errorf(\"store: unmarshal session %s: %w\", sessionID, err)\n\t}\n\n\treturn &sandbox, nil\n}\n\nfunc (s *redisStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n\tif sandbox == nil {\n\t\treturn ErrNilSandbox\n\t}\n\tif sandbox.ExpiresAt.IsZero() {\n\t\treturn ErrZeroExpiresAt\n\t}\n\tif sandbox.SessionID == \"\" {\n\t\treturn ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sandbox.SessionID)\n\tdata, err := json.Marshal(sandbox)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n\t}\n\n\tnow := time.Now()\n\tif sandbox.LastActivity.IsZero() {\n\t\tsandbox.LastActivity = now\n\t}\n\n\tpipe := s.cli.Pipeline()\n\tsetNXCmd := pipe.SetNX(ctx, key, data, 0)\n\tpipe.ZAdd(ctx, s.expiryIndexKey, redisv9.Z{\n\t\tScore:  float64(sandbox.ExpiresAt.Unix()),\n\t\tMember: sandbox.SessionID,\n\t})\n\tpipe.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n\t\tScore:  float64(sandbox.LastActivity.Unix()),\n\t\tMember: sandbox.SessionID,\n\t})\n\n\tcmds, err := pipe.Exec(ctx)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: pipeline exec: %w\", err)\n\t}\n\n\tsetCmd := cmds[0].(*redisv9.BoolCmd)\n\tsetResult, err := setCmd.Result()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: setnx result: %w\", err)\n\t}\n\tif !setResult {\n\t\treturn ErrSessionExists\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n\tif sandbox == nil {\n\t\treturn ErrNilSandbox\n\t}\n\tif sandbox.SessionID == \"\" {\n\t\treturn ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sandbox.SessionID)\n\n\texists, err := s.cli.Exists(ctx, key).Result()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: check exists: %w\", err)\n\t}\n\tif exists == 0 {\n\t\treturn ErrNotFound\n\t}\n\n\tdata, err := json.Marshal(sandbox)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n\t}\n\n\tif err := s.cli.Set(ctx, key, data, 0).Err(); err != nil {\n\t\treturn fmt.Errorf(\"store: update sandbox: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\tif sessionID == \"\" {\n\t\treturn ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sessionID)\n\n\tpipe := s.cli.Pipeline()\n\tpipe.Del(ctx, key)\n\tpipe.ZRem(ctx, s.expiryIndexKey, sessionID)\n\tpipe.ZRem(ctx, s.lastActivityIndexKey, sessionID)\n\n\t_, err := pipe.Exec(ctx)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: delete sandbox: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tif limit <= 0 {\n\t\treturn nil, nil\n\t}\n\n\tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.expiryIndexKey, &redisv9.ZRangeBy{\n\t\tMin:   \"-inf\",\n\t\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n\t\tCount: limit,\n\t}).Result()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"store: list expired: %w\", err)\n\t}\n\n\tif len(sessionIDs) == 0 {\n\t\treturn nil, nil\n\t}\n\n\treturn s.batchGetSandboxes(ctx, sessionIDs)\n}\n\nfunc (s *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tif limit <= 0 {\n\t\treturn nil, nil\n\t}\n\n\tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.lastActivityIndexKey, &redisv9.ZRangeBy{\n\t\tMin:   \"-inf\",\n\t\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n\t\tCount: limit,\n\t}).Result()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"store: list inactive: %w\", err)\n\t}\n\n\tif len(sessionIDs) == 0 {\n\t\treturn nil, nil\n\t}\n\n\treturn s.batchGetSandboxes(ctx, sessionIDs)\n}\n\nfunc (s *redisStore) batchGetSandboxes(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n\tkeys := make([]string, len(sessionIDs))\n\tfor i, id := range sessionIDs {\n\t\tkeys[i] = s.sessionKey(id)\n\t}\n\n\tpipe := s.cli.Pipeline()\n\tcmds := make([]*redisv9.StringCmd, len(keys))\n\tfor i, key := range keys {\n\t\tcmds[i] = pipe.Get(ctx, key)\n\t}\n\n\t_, err := pipe.Exec(ctx)\n\tif err != nil && !errors.Is(err, redisv9.Nil) {\n\t\treturn nil, fmt.Errorf(\"store: batch get: %w\", err)\n\t}\n\n\tvar sandboxes []*types.SandboxInfo\n\tfor i, cmd := range cmds {\n\t\tresult, err := cmd.Result()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, redisv9.Nil) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\treturn nil, fmt.Errorf(\"store: get session %s: %w\", sessionIDs[i], err)\n\t\t}\n\n\t\tvar sandbox types.SandboxInfo\n\t\tif err := json.Unmarshal([]byte(result), &sandbox); err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tsandboxes = append(sandboxes, &sandbox)\n\t}\n\n\treturn sandboxes, nil\n}\n\nfunc (s *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n\tif sessionID == \"\" {\n\t\treturn ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sessionID)\n\n\texists, err := s.cli.Exists(ctx, key).Result()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: check exists: %w\", err)\n\t}\n\tif exists == 0 {\n\t\treturn ErrNotFound\n\t}\n\n\tif at.IsZero() {\n\t\tat = time.Now()\n\t}\n\n\tif err := s.cli.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n\t\tScore:  float64(at.Unix()),\n\t\tMember: sessionID,\n\t}).Err(); err != nil {\n\t\treturn fmt.Errorf(\"store: update last activity: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) Close() error {\n\treturn s.cli.Close()\n}\n\nfunc newValkeyStoreFromEnv() (Store, error) {\n\taddr := os.Getenv(\"VALKEY_ADDR\")\n\tif addr == \"\" {\n\t\treturn nil, errors.New(\"VALKEY_ADDR is required\")\n\t}\n\n\tpassword := os.Getenv(\"VALKEY_PASSWORD\")\n\tpasswordRequired := strings.ToLower(os.Getenv(\"VALKEY_PASSWORD_REQUIRED\"))\n\tif password == \"\" && passwordRequired != \"false\" {\n\t\treturn nil, ErrPasswordRequired\n\t}\n\n\topts := &valkeyClientOption{\n\t\tInitAddress: strings.Split(addr, \",\"),\n\t\tPassword:    password,\n\t}\n\n\tif v, _ := strconv.ParseBool(os.Getenv(\"VALKEY_DISABLE_CACHE\")); v {\n\t\topts.DisableCache = true\n\t}\n\tif v, _ := strconv.ParseBool(os.Getenv(\"VALKEY_FORCE_SINGLE\")); v {\n\t\topts.ForceSingleClient = true\n\t}\n\n\treturn newValkeyStore(opts)\n}\n\ntype valkeyClientOption struct {\n\tInitAddress       []string\n\tPassword          string\n\tDisableCache      bool\n\tForceSingleClient bool\n}\n\nvar valkeyInit sync.Once\nvar valkeyProvider Store\n\nfunc newValkeyStore(opts *valkeyClientOption) (Store, error) {\n\tvalkeyInit.Do(func() {\n\t\tvalkeyProvider = &valkeyStore{\n\t\t\tsessionPrefix:        defaultSessionPrefix,\n\t\t\texpiryIndexKey:       defaultExpiryIndexKey,\n\t\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n\t\t}\n\t})\n\treturn valkeyProvider, nil\n}\n\ntype valkeyStore struct {\n\tcli                  interface{}\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc (s *valkeyStore) Ping(ctx context.Context) error {\n\treturn errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\treturn nil, errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n\treturn errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n\treturn errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\treturn errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\treturn nil, errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\treturn nil, errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n\treturn errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) Close() error {\n\treturn nil\n}\n","after":"package store\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tredisv9 \"github.com/redis/go-redis/v9\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"k8s.io/klog/v2\"\n)\n\ntype redisStore struct {\n\tcli                  *redisv9.Client\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nconst (\n\tdefaultSessionPrefix        = \"session:\"\n\tdefaultExpiryIndexKey       = \"session:expiry\"\n\tdefaultLastActivityIndexKey = \"session:last_activity\"\n)\n\nfunc NewRedisStore(addr, password string) Store {\n\treturn NewRedisStoreWithOptions(addr, password, defaultSessionPrefix, defaultExpiryIndexKey, defaultLastActivityIndexKey)\n}\n\nfunc NewRedisStoreWithOptions(addr, password, sessionPrefix, expiryIndexKey, lastActivityIndexKey string) Store {\n\tcli := redisv9.NewClient(&redisv9.Options{\n\t\tAddr:     addr,\n\t\tPassword: password,\n\t})\n\treturn &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        sessionPrefix,\n\t\texpiryIndexKey:       expiryIndexKey,\n\t\tlastActivityIndexKey: lastActivityIndexKey,\n\t}\n}\n\nfunc NewRedisStoreWithClient(cli *redisv9.Client) Store {\n\treturn &redisStore{\n\t\tcli:                  cli,\n\t\tsessionPrefix:        defaultSessionPrefix,\n\t\texpiryIndexKey:       defaultExpiryIndexKey,\n\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n\t}\n}\n\nfunc makeRedisOptions() (*redisv9.Options, error) {\n\taddr := os.Getenv(\"REDIS_ADDR\")\n\tif addr == \"\" {\n\t\treturn nil, errors.New(\"REDIS_ADDR is required\")\n\t}\n\n\tpassword := os.Getenv(\"REDIS_PASSWORD\")\n\tpasswordRequired := strings.ToLower(os.Getenv(\"REDIS_PASSWORD_REQUIRED\"))\n\tif password == \"\" && passwordRequired != \"false\" {\n\t\treturn nil, ErrPasswordRequired\n\t}\n\n\treturn &redisv9.Options{\n\t\tAddr:     addr,\n\t\tPassword: password,\n\t}, nil\n}\n\nfunc initStore() {\n\tstoreType := os.Getenv(\"STORE_TYPE\")\n\tif storeType == \"\" {\n\t\tstoreType = redisStoreType\n\t}\n\n\tvar err error\n\tswitch storeType {\n\tcase redisStoreType:\n\t\topts, err := makeRedisOptions()\n\t\tif err != nil {\n\t\t\tklog.ErrorS(err, \"failed to create redis options\")\n\t\t\treturn\n\t\t}\n\t\tprovider = NewRedisStore(opts.Addr, opts.Password)\n\tcase valkeyStoreType:\n\t\tprovider, err = newValkeyStoreFromEnv()\n\t\tif err != nil {\n\t\t\tklog.ErrorS(err, \"failed to create valkey store\")\n\t\t\treturn\n\t\t}\n\tdefault:\n\t\tklog.ErrorS(nil, \"invalid store type\", \"type\", storeType)\n\t}\n}\n\nfunc (s *redisStore) sessionKey(sessionID string) string {\n\treturn s.sessionPrefix + sessionID\n}\n\nfunc (s *redisStore) Ping(ctx context.Context) error {\n\tresult, err := s.cli.Ping(ctx).Result()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: ping failed: %w\", err)\n\t}\n\tif result != \"PONG\" {\n\t\treturn fmt.Errorf(\"store: unexpected ping response: %s\", result)\n\t}\n\treturn nil\n}\n\nfunc (s *redisStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\tif sessionID == \"\" {\n\t\treturn nil, ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sessionID)\n\tresult, err := s.cli.Get(ctx, key).Result()\n\tif err != nil {\n\t\tif errors.Is(err, redisv9.Nil) {\n\t\t\treturn nil, ErrNotFound\n\t\t}\n\t\treturn nil, fmt.Errorf(\"store: get session %s: %w\", sessionID, err)\n\t}\n\n\tvar sandbox types.SandboxInfo\n\tif err := json.Unmarshal([]byte(result), &sandbox); err != nil {\n\t\treturn nil, fmt.Errorf(\"store: unmarshal session %s: %w\", sessionID, err)\n\t}\n\n\treturn &sandbox, nil\n}\n\nfunc (s *redisStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n\tif sandbox == nil {\n\t\treturn ErrNilSandbox\n\t}\n\tif sandbox.ExpiresAt.IsZero() {\n\t\treturn ErrZeroExpiresAt\n\t}\n\tif sandbox.SessionID == \"\" {\n\t\treturn ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sandbox.SessionID)\n\tdata, err := json.Marshal(sandbox)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n\t}\n\n\tnow := time.Now()\n\tif sandbox.LastActivity.IsZero() {\n\t\tsandbox.LastActivity = now\n\t}\n\n\tpipe := s.cli.Pipeline()\n\tsetNXCmd := pipe.SetNX(ctx, key, data, 0)\n\tpipe.ZAdd(ctx, s.expiryIndexKey, redisv9.Z{\n\t\tScore:  float64(sandbox.ExpiresAt.Unix()),\n\t\tMember: sandbox.SessionID,\n\t})\n\tpipe.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n\t\tScore:  float64(sandbox.LastActivity.Unix()),\n\t\tMember: sandbox.SessionID,\n\t})\n\n\t_, err = pipe.Exec(ctx)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: pipeline exec: %w\", err)\n\t}\n\n\tsetResult, err := setNXCmd.Result()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: setnx result: %w\", err)\n\t}\n\tif !setResult {\n\t\treturn ErrSessionExists\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n\tif sandbox == nil {\n\t\treturn ErrNilSandbox\n\t}\n\tif sandbox.SessionID == \"\" {\n\t\treturn ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sandbox.SessionID)\n\n\texists, err := s.cli.Exists(ctx, key).Result()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: check exists: %w\", err)\n\t}\n\tif exists == 0 {\n\t\treturn ErrNotFound\n\t}\n\n\tdata, err := json.Marshal(sandbox)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: marshal sandbox: %w\", err)\n\t}\n\n\tif err := s.cli.Set(ctx, key, data, 0).Err(); err != nil {\n\t\treturn fmt.Errorf(\"store: update sandbox: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\tif sessionID == \"\" {\n\t\treturn ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sessionID)\n\n\tpipe := s.cli.Pipeline()\n\tpipe.Del(ctx, key)\n\tpipe.ZRem(ctx, s.expiryIndexKey, sessionID)\n\tpipe.ZRem(ctx, s.lastActivityIndexKey, sessionID)\n\n\t_, err := pipe.Exec(ctx)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: delete sandbox: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tif limit <= 0 {\n\t\treturn nil, nil\n\t}\n\n\tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.expiryIndexKey, &redisv9.ZRangeBy{\n\t\tMin:   \"-inf\",\n\t\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n\t\tCount: limit,\n\t}).Result()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"store: list expired: %w\", err)\n\t}\n\n\tif len(sessionIDs) == 0 {\n\t\treturn nil, nil\n\t}\n\n\treturn s.batchGetSandboxes(ctx, sessionIDs)\n}\n\nfunc (s *redisStore) ListInactiveSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\tif limit <= 0 {\n\t\treturn nil, nil\n\t}\n\n\tsessionIDs, err := s.cli.ZRangeByScore(ctx, s.lastActivityIndexKey, &redisv9.ZRangeBy{\n\t\tMin:   \"-inf\",\n\t\tMax:   fmt.Sprintf(\"%d\", before.Unix()),\n\t\tCount: limit,\n\t}).Result()\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"store: list inactive: %w\", err)\n\t}\n\n\tif len(sessionIDs) == 0 {\n\t\treturn nil, nil\n\t}\n\n\treturn s.batchGetSandboxes(ctx, sessionIDs)\n}\n\nfunc (s *redisStore) batchGetSandboxes(ctx context.Context, sessionIDs []string) ([]*types.SandboxInfo, error) {\n\tkeys := make([]string, len(sessionIDs))\n\tfor i, id := range sessionIDs {\n\t\tkeys[i] = s.sessionKey(id)\n\t}\n\n\tpipe := s.cli.Pipeline()\n\tcmds := make([]*redisv9.StringCmd, len(keys))\n\tfor i, key := range keys {\n\t\tcmds[i] = pipe.Get(ctx, key)\n\t}\n\n\t_, err := pipe.Exec(ctx)\n\tif err != nil && !errors.Is(err, redisv9.Nil) {\n\t\treturn nil, fmt.Errorf(\"store: batch get: %w\", err)\n\t}\n\n\tvar sandboxes []*types.SandboxInfo\n\tfor i, cmd := range cmds {\n\t\tresult, err := cmd.Result()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, redisv9.Nil) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\treturn nil, fmt.Errorf(\"store: get session %s: %w\", sessionIDs[i], err)\n\t\t}\n\n\t\tvar sandbox types.SandboxInfo\n\t\tif err := json.Unmarshal([]byte(result), &sandbox); err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tsandboxes = append(sandboxes, &sandbox)\n\t}\n\n\treturn sandboxes, nil\n}\n\nfunc (s *redisStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n\tif sessionID == \"\" {\n\t\treturn ErrEmptySessionID\n\t}\n\n\tkey := s.sessionKey(sessionID)\n\n\texists, err := s.cli.Exists(ctx, key).Result()\n\tif err != nil {\n\t\treturn fmt.Errorf(\"store: check exists: %w\", err)\n\t}\n\tif exists == 0 {\n\t\treturn ErrNotFound\n\t}\n\n\tif at.IsZero() {\n\t\tat = time.Now()\n\t}\n\n\tif err := s.cli.ZAdd(ctx, s.lastActivityIndexKey, redisv9.Z{\n\t\tScore:  float64(at.Unix()),\n\t\tMember: sessionID,\n\t}).Err(); err != nil {\n\t\treturn fmt.Errorf(\"store: update last activity: %w\", err)\n\t}\n\n\treturn nil\n}\n\nfunc (s *redisStore) Close() error {\n\treturn s.cli.Close()\n}\n\nfunc newValkeyStoreFromEnv() (Store, error) {\n\taddr := os.Getenv(\"VALKEY_ADDR\")\n\tif addr == \"\" {\n\t\treturn nil, errors.New(\"VALKEY_ADDR is required\")\n\t}\n\n\tpassword := os.Getenv(\"VALKEY_PASSWORD\")\n\tpasswordRequired := strings.ToLower(os.Getenv(\"VALKEY_PASSWORD_REQUIRED\"))\n\tif password == \"\" && passwordRequired != \"false\" {\n\t\treturn nil, ErrPasswordRequired\n\t}\n\n\topts := &valkeyClientOption{\n\t\tInitAddress: strings.Split(addr, \",\"),\n\t\tPassword:    password,\n\t}\n\n\tif v, _ := strconv.ParseBool(os.Getenv(\"VALKEY_DISABLE_CACHE\")); v {\n\t\topts.DisableCache = true\n\t}\n\tif v, _ := strconv.ParseBool(os.Getenv(\"VALKEY_FORCE_SINGLE\")); v {\n\t\topts.ForceSingleClient = true\n\t}\n\n\treturn newValkeyStore(opts)\n}\n\ntype valkeyClientOption struct {\n\tInitAddress       []string\n\tPassword          string\n\tDisableCache      bool\n\tForceSingleClient bool\n}\n\nvar valkeyInit sync.Once\nvar valkeyProvider Store\n\nfunc newValkeyStore(opts *valkeyClientOption) (Store, error) {\n\tvalkeyInit.Do(func() {\n\t\tvalkeyProvider = &valkeyStore{\n\t\t\tsessionPrefix:        defaultSessionPrefix,\n\t\t\texpiryIndexKey:       defaultExpiryIndexKey,\n\t\t\tlastActivityIndexKey: defaultLastActivityIndexKey,\n\t\t}\n\t})\n\treturn valkeyProvider, nil\n}\n\ntype valkeyStore struct {\n\tcli                  interface{}\n\tsessionPrefix        string\n\texpiryIndexKey       string\n\tlastActivityIndexKey string\n}\n\nfunc (s *valkeyStore) Ping(ctx context.Context) error {\n\treturn errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n\treturn nil, errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n\treturn errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) UpdateSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n\treturn errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) DeleteSandboxBySessionID(ctx context.Context, sessionID string) error {\n\treturn errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) ListExpiredSandboxes(ctx context.Context, before time.Time, limit int64) ([]*types.SandboxInfo, error) {\n\treturn nil, errors.New(\"store: valkey not configured\")\n}\n\nfunc (s *valkeyStore) ListInactiveSandboxes(ctx context.