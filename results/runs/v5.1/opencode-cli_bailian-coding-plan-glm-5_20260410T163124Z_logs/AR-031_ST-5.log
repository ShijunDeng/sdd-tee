n\tassert.ElementsMatch(t, []string{\"update\", \"patch\"}, arStatusRule.Verbs)\n}\n\nfunc TestWorkloadManagerClusterRoleCorePermissions(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar wmCR ClusterRole\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ClusterRole\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar cr ClusterRole\n\t\t\terr = yaml.Unmarshal(data, &cr)\n\t\t\trequire.NoError(t, err)\n\t\t\tif cr.Metadata.Name == \"workloadmanager\" {\n\t\t\t\twmCR = cr\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tvar podsRule *Rule\n\tvar secretsRule *Rule\n\tfor _, rule := range wmCR.Rules {\n\t\tif len(rule.APIGroups) > 0 && rule.APIGroups[0] == \"\" {\n\t\t\tfor _, res := range rule.Resources {\n\t\t\t\tswitch res {\n\t\t\t\tcase \"pods\":\n\t\t\t\t\tpodsRule = &rule\n\t\t\t\tcase \"secrets\":\n\t\t\t\t\tsecretsRule = &rule\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\trequire.NotNil(t, podsRule)\n\tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\"}, podsRule.Verbs)\n\n\trequire.NotNil(t, secretsRule)\n\tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"}, secretsRule.Verbs)\n}\n\nfunc TestWorkloadManagerClusterRoleTokenReviewPermission(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar wmCR ClusterRole\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ClusterRole\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar cr ClusterRole\n\t\t\terr = yaml.Unmarshal(data, &cr)\n\t\t\trequire.NoError(t, err)\n\t\t\tif cr.Metadata.Name == \"workloadmanager\" {\n\t\t\t\twmCR = cr\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\