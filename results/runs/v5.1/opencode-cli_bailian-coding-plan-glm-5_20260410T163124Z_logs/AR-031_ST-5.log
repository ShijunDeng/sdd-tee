\t\t\t\t\tfoundClusterRole = true\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tif kind == \"ClusterRoleBinding\" {\n\t\t\t\t\t\t\t\tfoundClusterRoleBinding = true\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tassert.False(t, foundClusterRole, \"Router should not have ClusterRole\")\n\tassert.False(t, foundClusterRoleBinding, \"Router should not have ClusterRoleBinding\")\n}\n\nfunc TestRouterNoTokenReviewPermission(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"Role\" {\n\t\t\tif metadata, ok := doc[\"metadata\"].(map[string]interface{}); ok {\n\t\t\t\tif name, ok := metadata[\"name\"].(string); ok && name == \"agentcube-router\" {\n\t\t\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\t\t\trequire.NoError(t, err)\n\t\t\t\t\tvar role Role\n\t\t\t\t\terr = yaml.Unmarshal(data, &role)\n\t\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\t\tfor _, rule := range role.Rules {\n\t\t\t\t\t\tfor _, apiGroup := range rule.APIGroups {\n\t\t\t\t\t\t\tassert.NotEqual(t, \"authentication.k8s.io\", apiGroup, \"Router should not have TokenReview permission\")\n\t\t\t\t\t\t}\n\t\t\t\t\t\tfor _, res := range rule.Resources {\n\t\t\t\t\t\t\tassert.NotEqual(t, \"tokenreviews\", res, \"Router should not have TokenReview permission\")\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc TestHelmLint(t *testing.T) {\n\tcmd := exec.Command(\"helm\", \"lint\", chartPath)\n\tcmd.Dir = \"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests\"\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\terr := cmd.Run()\n\trequire.NoError(t, err, \"helm lint failed: %s\", std