n\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName      string `json:\"name\"`\n\t\tNamespace string `json:\"namespace\"`\n\t} `json:\"metadata\"`\n}\n\ntype ServiceAccount struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName      string            `json:\"name\"`\n\t\tNamespace string            `json:\"namespace\"`\n\t\tLabels    map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n}\n\ntype Role struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName      string            `json:\"name\"`\n\t\tNamespace string            `json:\"namespace\"`\n\t\tLabels    map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n\tRules []Rule `json:\"rules\"`\n}\n\ntype ClusterRole struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName   string            `json:\"name\"`\n\t\tLabels map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n\tRules []Rule `json:\"rules\"`\n}\n\ntype Rule struct {\n\tAPIGroups []string `json:\"apiGroups\"`\n\tResources []string `json:\"resources\"`\n\tVerbs     []string `json:\"verbs\"`\n}\n\ntype RoleBinding struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName      string            `json:\"name\"`\n\t\tNamespace string            `json:\"namespace\"`\n\t\tLabels    map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n\tRoleRef struct {\n\t\tAPIGroup string `json:\"apiGroup\"`\n\t\tKind     string `json:\"kind\"`\n\t\tName     string `json:\"name\"`\n\t} `json:\"roleRef\"`\n\tSubjects []Subject `json:\"subjects\"`\n}\n\ntype ClusterRoleBinding struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName   string            `json:\"name\"`\n\t\tLabels map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n\tRoleRef struct {\n\t\tAPIGroup string `json:\"apiGroup\"`\n\t\tKind     string `json:\"kind\"`\n\t\tName     string `json:\"name\"`\n\t} `json:\"roleRef\"`\n\tSubjects []Subject `json:\"subjects\"`\n}\n\ntype Subject struct {\n\tKind      string `json:\"kind\"`\n\tName      string `json:\"name\"`\n\tNamespace string `json:\"namespace\"`\n}\n\nfunc runHelmTemplate(t *testing.T, values map[string]string) (string, error) {\n\targs := []string{\"template\", \"test\", chartPath, \"--set\", \"redis.addr=localhost:6379\"}\n\tfor k, v := range values {\n\t\targs = append(args, \"--set\", k+\"=\"+v)\n\t}\n\tcmd := exec.Command(\"helm\", args...)\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\terr := cmd.Run()\n\treturn stdout.String(), err\n}\n\nfunc parseYAMLDocuments(output string) ([]map[string]interface{}, error) {\n\tdocs := strings.Split(output, \"---\")\n\tvar results []map[string]interface{}\n\tfor _, doc := range docs {\n\t\tdoc = strings.TrimSpace(doc)\n\t\tif doc == \"\" || strings.HasPrefix(doc, \"# Source:\") {\n\t\t\tcontinue\n\t\t}\n\t\tvar obj map[string]interface{}\n\t\tif err := yaml.Unmarshal([]byte(doc), &obj); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif obj != nil {\n\t\t\tresults = append(results, obj)\n\t\t}\n\t}\n\treturn results, nil\n}\n\nfunc TestRouterRBACConditionalRendering(t *testing.T) {\n\ttests := []struct {\n\t\tname           string\n\t\tvalues         map[string]string\n\t\texpectRouterSA bool\n\t\texpectError    bool\n\t}{\n\t\t{\n\t\t\tname: \"RBAC enabled with serviceAccountName\",\n\t\t\tvalues: map[string]string{\n\t\t\t\t\"router.rbac.create\":        \"true\",\n\t\t\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t\t\t},\n\t\t\texpectRouterSA: true,\n\t\t\texpectError:    false,\n\t\t},\n\t\t{\n\t\t\tname: \"RBAC disabled\",\n\t\t\tvalues: map[string]string{\n\t\t\t\t\"router.rbac.create\": \"false\",\n\t\t\t},\n\t\t\texpectRouterSA: false,\n\t\t\texpectError:    false,\n\t\t},\n\t\t{\n\t\t\tname: \"RBAC enabled without serviceAccountName\",\n\t\t\tvalues: map[string]string{\n\t\t\t\t\"router.rbac.create\": \"true\",\n\t\t\t},\n\t\t\texpectRouterSA: false,\n\t\t\texpectError:    true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\toutput, err := runHelmTemplate(t, tt.values)\n\t\t\tif tt.expectError {\n\t\t\t\trequire.Error(t, err)\n\t\t\t\tassert.Contains(t, err.Error(), \"router.serviceAccountName must be set\")\n\t\t\t\treturn\n\t\t\t}\n\t\t\trequire.NoError(t, err)\n\n\t\t\tdocs, err := parseYAMLDocuments(output)\n\t\t\trequire.NoError(t, err)\n\n\t\t\tvar foundRouterSA bool\n\t\t\tfor _, doc := range docs {\n\t\t\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ServiceAccount\" {\n\t\t\t\t\tif metadata, ok := doc[\"metadata\"].(map[string]interface{}); ok {\n\t\t\t\t\t\tif name, ok := metadata[\"name\"].(string); ok {\n\t\t\t\t\t\t\tif name == \"agentcube-router\" {\n\t\t\t\t\t\t\t\tfoundRouterSA = true\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t\tassert.Equal(t, tt.expectRouterSA, foundRouterSA)\n\t\t})\n\t}\n}\n\nfunc TestRouterRBACServiceAccount(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar routerSA ServiceAccount\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ServiceAccount\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar sa ServiceAccount\n\t\t\terr = yaml.Unmarshal(data, &sa)\n\t\t\trequire.NoError(t, err)\n\t\t\tif sa.Metadata.Name == \"agentcube-router\" {\n\t\t\t\trouterSA = sa\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tassert.Equal(t, \"v1\", routerSA.APIVersion)\n\tassert.Equal(t, \"ServiceAccount\", routerSA.Kind)\n\tassert.Equal(t, \"agentcube-router\", routerSA.Metadata.Name)\n\tassert.Equal(t, \"default\", routerSA.Metadata.Namespace)\n\tassert.NotEmpty(t, routerSA.Metadata.Labels)\n\tassert.Contains(t, routerSA.Metadata.Labels, \"app.kubernetes.io/name\")\n}\n\nfunc TestRouterRole(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar routerRole Role\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"Role\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar role Role\n\t\t\terr = yaml.Unmarshal(data, &role)\n\t\t\trequire.NoError(t, err)\n\t\t\tif role.Metadata.Name == \"agentcube-router\" {\n\t\t\t\trouterRole = role\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tassert.Equal(t, \"rbac.authorization.k8s.io/v1\", routerRole.APIVersion)\n\tassert.Equal(t, \"Role\", routerRole.Kind)\n\tassert.Equal(t, \"agentcube-router\", routerRole.Metadata.Name)\n\tassert.Equal(t, \"default\", routerRole.Metadata.Namespace)\n\n\trequire.Len(t, routerRole.Rules, 1)\n\trule := routerRole.Rules[0]\n\tassert.Equal(t, []string{\"\"}, rule.APIGroups)\n\tassert.Equal(t, []string{\"secrets\"}, rule.Resources)\n\tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"}, rule.Verbs)\n}\n\nfunc TestRouterRoleBinding(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar routerRB RoleBinding\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"RoleBinding\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar rb RoleBinding\n\t\t\terr = yaml.Unmarshal(data, &rb)\n\t\t\trequire.NoError(t, err)\n\t\t\tif rb.Metadata.Name == \"agentcube-router\" {\n\t\t\t\trouterRB = rb\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tassert.Equal(t, \"rbac.authorization.k8s.io/v1\", routerRB.APIVersion)\n\tassert.Equal(t, \"RoleBinding\", routerRB.Kind)\n\tassert.Equal(t, \"agentcube-router\", routerRB.Metadata.Name)\n\tassert.Equal(t, \"default\", routerRB.Metadata.Namespace)\n\n\tassert.Equal(t, \"rbac.authorization.k8s.io\", routerRB.RoleRef.APIGroup)\n\tassert.Equal(t, \"Role\", routerRB.RoleRef.Kind)\n\tassert.Equal(t, \"agentcube-router\", routerRB.RoleRef.Name)\n\n\trequire.Len(t, routerRB.Subjects, 1)\n\tassert.Equal(t, \"ServiceAccount\", routerRB.Subjects[0].Kind)\n\tassert.Equal(t, \"agentcube-router\", routerRB.Subjects[0].Name)\n\tassert.Equal(t, \"default\", routerRB.Subjects[0].Namespace)\n}\n\nfunc TestWorkloadManagerServiceAccount(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar wmSA ServiceAccount\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ServiceAccount\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar sa ServiceAccount\n\t\t\terr = yaml.Unmarshal(data, &sa)\n\t\t\trequire.NoError(t, err)\n\t\t\tif sa.Metadata.Name == \"workloadmanager\" {\n\t\t\t\twmSA = sa\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tassert.Equal(t, \"v1\", wmSA.APIVersion)\n\tassert.Equal(t, \"ServiceAccount\", wmSA.Kind)\n\tassert.Equal(t, \"workloadmanager\", wmSA.Metadata.Name)\n\tassert.Equal(t, \"default\", wmSA.Metadata.Namespace)\n\tassert.NotEmpty(t, wmSA.Metadata.Labels)\n}\n\nfunc TestWorkloadManagerClusterRoleSandboxPermissions(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{})\n\trequire