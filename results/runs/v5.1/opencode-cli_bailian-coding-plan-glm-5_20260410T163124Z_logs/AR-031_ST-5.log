Role struct {\n44: \tAPIVersion string `json:\"apiVersion\"`\n45: \tKind       string `json:\"kind\"`\n46: \tMetadata   struct {\n47: \t\tName      string            `json:\"name\"`\n48: \t\tNamespace string            `json:\"namespace\"`\n49: \t\tLabels    map[string]string `json:\"labels\"`\n50: \t} `json:\"metadata\"`\n51: \tRules []Rule `json:\"rules\"`\n52: }\n53: \n54: type ClusterRole struct {\n55: \tAPIVersion string `json:\"apiVersion\"`\n56: \tKind       string `json:\"kind\"`\n57: \tMetadata   struct {\n58: \t\tName   string            `json:\"name\"`\n59: \t\tLabels map[string]string `json:\"labels\"`\n60: \t} `json:\"metadata\"`\n61: \tRules []Rule `json:\"rules\"`\n62: }\n63: \n64: type Rule struct {\n65: \tAPIGroups []string `json:\"apiGroups\"`\n66: \tResources []string `json:\"resources\"`\n67: \tVerbs     []string `json:\"verbs\"`\n68: }\n69: \n70: type RoleBinding struct {\n71: \tAPIVersion string `json:\"apiVersion\"`\n72: \tKind       string `json:\"kind\"`\n73: \tMetadata   struct {\n74: \t\tName      string            `json:\"name\"`\n75: \t\tNamespace string            `json:\"namespace\"`\n76: \t\tLabels    map[string]string `json:\"labels\"`\n77: \t} `json:\"metadata\"`\n78: \tRoleRef struct {\n79: \t\tAPIGroup string `json:\"apiGroup\"`\n80: \t\tKind     string `json:\"kind\"`\n81: \t\tName     string `json:\"name\"`\n82: \t} `json:\"roleRef\"`\n83: \tSubjects []Subject `json:\"subjects\"`\n84: }\n85: \n86: type ClusterRoleBinding struct {\n87: \tAPIVersion string `json:\"apiVersion\"`\n88: \tKind       string `json:\"kind\"`\n89: \tMetadata   struct {\n90: \t\tName   string            `json:\"name\"`\n91: \t\tLabels map[string]string `json:\"labels\"`\n92: \t} `json:\"metadata\"`\n93: \tRoleRef struct {\n94: \t\tAPIGroup string `json:\"apiGroup\"`\n95: \t\tKind     string `json:\"kind\"`\n96: \t\tName     string `json:\"name\"`\n97: \t} `json:\"roleRef\"`\n98: \tSubjects []Subject `json:\"subjects\"`\n99: }\n100: \n101: type Subject struct {\n102: \tKind      string `json:\"kind\"`\n103: \tName      string `json:\"name\"`\n104: \tNamespace string `json:\"namespace\"`\n105: }\n106: \n107: func runHelmTemplate(t *testing.T, values map[string]string) (string, error) {\n108: \targs := []string{\"template\", \"test\", chartPath, \"--set\", \"redis.addr=localhost:6379\"}\n109: \tfor k, v := range values {\n110: \t\targs = append(args, \"--set\", k+\"=\"+v)\n111: \t}\n112: \tcmd := exec.Command(\"helm\", args...)\n113: \tvar stdout, stderr bytes.Buffer\n114: \tcmd.Stdout = &stdout\n115: \tcmd.Stderr = &stderr\n116: \terr := cmd.Run()\n117: \treturn stdout.String(), err\n118: }\n119: \n120: func parseYAMLDocuments(output string) ([]map[string]interface{}, error) {\n121: \tdocs := strings.Split(output, \"---\")\n122: \tvar results []map[string]interface{}\n123: \tfor _, doc := range docs {\n124: \t\tdoc = strings.TrimSpace(doc)\n125: \t\tif doc == \"\" || strings.HasPrefix(doc, \"# Source:\") {\n126: \t\t\tcontinue\n127: \t\t}\n128: \t\tvar obj map[string]interface{}\n129: \t\tif err := yaml.Unmarshal([]byte(doc), &obj); err != nil {\n130: \t\t\treturn nil, err\n131: \t\t}\n132: \t\tif obj != nil {\n133: \t\t\tresults = append(results, obj)\n134: \t\t}\n135: \t}\n136: \treturn results, nil\n137: }\n138: \n139: func TestRouterRBACConditionalRendering(t *testing.T) {\n140: \ttests := []struct {\n141: \t\tname           string\n142: \t\tvalues         map[string]string\n143: \t\texpectRouterSA bool\n144: \t\texpectError    bool\n145: \t}{\n146: \t\t{\n147: \t\t\tname: \"RBAC enabled with serviceAccountName\",\n148: \t\t\tvalues: map[string]string{\n149: \t\t\t\t\"router.rbac.create\":        \"true\",\n150: \t\t\t\t\"router.serviceAccountName\": \"agentcube-router\",\n151: \t\t\t},\n152: \t\t\texpectRouterSA: true,\n153: \t\t\texpectError:    false,\n154: \t\t},\n155: \t\t{\n156: \t\t\tname: \"RBAC disabled\",\n157: \t\t\tvalues: map[string]string{\n158: \t\t\t\t\"router.rbac.create\": \"false\",\n159: \t\t\t},\n160: \t\t\texpectRouterSA: false,\n161: \t\t\texpectError:    false,\n162: \t\t},\n163: \t\t{\n164: \t\t\tname: \"RBAC enabled without serviceAccountName\",\n165: \t\t\tvalues: map[string]string{\n166: \t\t\t\t\"router.rbac.create\": \"true\",\n167: \t\t\t},\n168: \t\t\texpectRouterSA: false,\n169: \t\t\texpectError:    true,\n170: \t\t},\n171: \t}\n172: \n173: \tfor _, tt := range tests {\n174: \t\tt.Run(tt.name, func(t *testing.T) {\n175: \t\t\toutput, err := runHelmTemplate(t, tt.values)\n176: \t\t\tif tt.expectError {\n177: \t\t\t\trequire.Error(t, err)\n178: \t\t\t\tassert.Contains(t, err.Error(), \"router.serviceAccountName must be set\")\n179: \t\t\t\treturn\n180: \t\t\t}\n181: \t\t\trequire.NoError(t, err)\n182: \n183: \t\t\tdocs, err := parseYAMLDocuments(output)\n184: \t\t\trequire.NoError(t, err)\n185: \n186: \t\t\tvar foundRouterSA bool\n187: \t\t\tfor _, doc := range docs {\n188: \t\t\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ServiceAccount\" {\n189: \t\t\t\t\tif metadata, ok := doc[\"metadata\"].(map[string]interface{}); ok {\n190: \t\t\t\t\t\tif name, ok := metadata[\"name\"].(string); ok {\n191: \t\t\t\t\t\t\tif name == \"agentcube-router\" {\n192: \t\t\t\t\t\t\t\tfoundRouterSA = true\n193: \t\t\t\t\t\t\t}\n194: \t\t\t\t\t\t}\n195: \t\t\t\t\t}\n196: \t\t\t\t}\n197: \t\t\t}\n198: \t\t\tassert.Equal(t, tt.expectRouterSA, foundRouterSA)\n199: \t\t})\n200: \t}\n201: }\n202: \n203: func TestRouterRBACServiceAccount(t *testing.T) {\n204: \toutput, err := runHelmTemplate(t, map[string]string{\n205: \t\t\"router.rbac.create\":        \"true\",\n206: \t\t\"router.serviceAccountName\": \"agentcube-router\",\n207: \t})\n208: \trequire.NoError(t, err)\n209: \n210: \tdocs, err := parseYAMLDocuments(output)\n211: \trequire.NoError(t, err)\n212: \n213: \tvar routerSA ServiceAccount\n214: \tfor _, doc := range docs {\n215: \t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ServiceAccount\" {\n216: \t\t\tdata, err := yaml.Marshal(doc)\n217: \t\t\trequire.NoError(t, err)\n218: \t\t\tvar sa ServiceAccount\n219: \t\t\terr = yaml.Unmarshal(data, &sa)\n220: \t\t\trequire.NoError(t, err)\n221: \t\t\tif sa.Metadata.Name == \"agentcube-router\" {\n222: \t\t\t\trouterSA = sa\n223: \t\t\t\tbreak\n224: \t\t\t}\n225: \t\t}\n226: \t}\n227: \n228: \tassert.Equal(t, \"v1\", routerSA.APIVersion)\n229: \tassert.Equal(t, \"ServiceAccount\", routerSA.Kind)\n230: \tassert.Equal(t, \"agentcube-router\", routerSA.Metadata.Name)\n231: \tassert.Equal(t, \"default\", routerSA.Metadata.Namespace)\n232: \tassert.NotEmpty(t, routerSA.Metadata.Labels)\n233: \tassert.Contains(t, routerSA.Metadata.Labels, \"app.kubernetes.io/name\")\n234: }\n235: \n236: func TestRouterRole(t *testing.T) {\n237: \toutput, err := runHelmTemplate(t, map[string]string{\n238: \t\t\"router.rbac.create\":        \"true\",\n239: \t\t\"router.serviceAccountName\": \"agentcube-router\",\n240: \t})\n241: \trequire.NoError(t, err)\n242: \n243: \tdocs, err := parseYAMLDocuments(output)\n244: \trequire.NoError(t, err)\n245: \n246: \tvar routerRole Role\n247: \tfor _, doc := range docs {\n248: \t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"Role\" {\n249: \t\t\tdata, err := yaml.Marshal(doc)\n250: \t\t\trequire.NoError(t, err)\n251: \t\t\tvar role Role\n252: \t\t\terr = yaml.Unmarshal(data, &role)\n253: \t\t\trequire.NoError(t, err)\n254: \t\t\tif role.Metadata.Name == \"agentcube-router\" {\n255: \t\t\t\trouterRole = role\n256: \t\t\t\tbreak\n257: \t\t\t}\n258: \t\t}\n259: \t}\n260: \n261: \tassert.Equal(t, \"rbac.authorization.k8s.io/v1\", routerRole.APIVersion)\n262: \tassert.Equal(t, \"Role\", routerRole.Kind)\n263: \tassert.Equal(t, \"agentcube-router\", routerRole.Metadata.Name)\n264: \tassert.Equal(t, \"default\", routerRole.Metadata.Namespace)\n265: \n266: \trequire.Len(t, routerRole.Rules, 1)\n267: \trule := routerRole.Rules[0]\n268: \tassert.Equal(t, []string{\"\"}, rule.APIGroups)\n269: \tassert.Equal(t, []string{\"secrets\"}, rule.Resources)\n270: \tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"}, rule.Verbs)\n271: }\n272: \n273: func TestRouterRoleBinding(t *testing.T) {\n274: \toutput, err := runHelmTemplate(t, map[string]string{\n275: \t\t\"router.rbac.create\":        \"true\",\n276: \t\t\"router.serviceAccountName\": \"agentcube-router\",\n277: \t})\n278: \trequire.NoError(t, err)\n279: \n280: \tdocs, err := parseYAMLDocuments(output)\n281: \trequire.NoError(t, err)\n282: \n283: \tvar routerRB RoleBinding\n284: \tfor _, doc := range docs {\n285: \t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"RoleBinding\" {\n286: \t\t\tdata, err := yaml.Marshal(doc)\n287: \t\t\trequire.NoError(t, err)\n288: \t\t\tvar rb RoleBinding\n289: \t\t\terr = yaml.Unmarshal(data, &rb)\n290: \t\t\trequire.NoError(t, err)\n291: \t\t\tif rb.Metadata.Name == \"agentcube-router\" {\n292: \t\t\t\trouterRB = rb\n293: \t\t\t\tbreak\n294: \t\t\t}\n295: \t\t}\n296: \t}\n297: \n298: \tassert.Equal(t, \"rbac.authorization.k8s.io/v1\", routerRB.APIVersion)\n299: \tassert.Equal(t, \"RoleBinding\", routerRB.Kind)\n300: \tassert.Equal(t, \"agentcube-router\", routerRB.Metadata.Name)\n301: \tassert.Equal(t, \"default\", routerRB.Metadata.Namespace)\n302: \n303: \tassert.Equal(t, \"rbac.authorization.k8s.io\", routerRB.RoleRef.APIGroup)\n304: \tassert.Equal(t, \"Role\", routerRB.RoleRef.Kind)\n305: \tassert.Equal(t, \"agentcube-router\", routerRB.RoleRef.Name)\n306: \n307: \trequire.Len(t, routerRB.Subjects, 1)\n308: \tassert.Equal(t, \"ServiceAccount\", routerRB.Subjects[0].Kind)\n309: \tassert.Equal(t, \"agentcube-router\", routerRB.Subjects[0].Name)\n310: \tassert.Equal(t, \"default\", routerRB.Subjects[0].Namespace)\n311: }\n312: \n313: func TestWorkloadManagerServiceAccount(t *testing.T) {\n314: \toutput, err := runHelmTemplate(t, map[string]string{})\n315: \trequire.NoError(t, err)\n316: \n317: \tdocs, err := parseYAMLDocuments(output)\n318: \trequire.NoError(t, err)\n319: \n320: \tvar wmSA ServiceAccount\n321: \tfor _, doc := range docs {\n322: \t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ServiceAccount\" {\n323: \t\t\tdata, err := yaml.Marshal(doc)\n324: \t\t\trequire.NoError(t, err)\n325: \t\t\tvar sa ServiceAccount\n326: \t\t\terr = yaml.Unmarshal(data, &sa)\n327: \t\t\trequire.NoError(t, err)\n328: \t\t\tif sa.Metadata.Name == \"workloadmanager\" {\n329: \t\t\t\twmSA = sa\n330: \t\t\t\tbreak\n331: \t\t\t}\n332: \t\t}\n333: \t}\n334: \n335: \tassert.Equal(t, \"v1\", wmSA.APIVersion)\n336: \tassert.Equal(t, \"ServiceAccount\", wmSA.Kind)\n337: \tassert.Equal(t, \"workloadmanager\", wmSA.Metadata.Name)\n338: \tassert.Equal(t, \"default\", wmSA.Metadata.Namespace)\n339: \tassert.NotEmpty(t, wmSA.Metadata.Labels)\n340: }\n341: \n342: func TestWorkloadManagerClusterRoleSandboxPermissions(t *testing.T) {\n343: \toutput, err := runHelmTemplate(t, map[string]string{})\n344: \trequire.NoError(t, err)\n345: \n346: \tdocs, err := parseYAMLDocuments(output)\n347: \trequire.NoError(t, err)\n348: \n349: \tvar wmCR ClusterRole\n350: \tfor _, doc := range docs {\n351: \t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ClusterRole\" {\n352: \t\t\tdata, err := yaml.Marshal(doc)\n353: \t\t\trequire.NoError(t, err)\n354: \t\t\tvar cr ClusterRole\n355: \t\t\terr = yaml.Unmarshal(data, &cr)\n356: \t\t\trequire.NoError(t, err)\n357: \t\t\tif cr.Metadata.Name == \"workloadmanager\" {\n358: \t\t\t\twmCR = cr\n359: \t\t\t\tbreak\n360: \t\t\t}\n361: \t\t}\n362: \t}\n363: \n364: \tassert.Equal(t, \"rbac.authorization.k8s.io/v1\", wmCR.APIVersion)\n365: \tassert.Equal(t, \"ClusterRole\", wmCR.Kind)\n366: \tassert.Equal(t, \"workloadmanager\", wmCR.Metadata.Name)\n367: \n368: \tvar sandboxRule *Rule\n369: \tfor _, rule := range wmCR.Rules {\n370: \t\tif len(rule.APIGroups) > 0 && rule.APIGroups[0] == \"agents.x-k8s.io\" {\n371: \t\t\tif len(rule.Resources) > 0 && rule.Resources[0] == \"sandboxes\" {\n372: \t\t\t\tsandboxRule =