if res == \"sandboxwarmpools/status\" {\n\t\t\t\t\textensionStatusRule = &rule\n\t\t\t\t} else {\n\t\t\t\t\textensionRule = &rule\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\trequire.NotNil(t, extensionRule)\n\tassert.ElementsMatch(t, []string{\"sandboxclaims\", \"sandboxtemplates\", \"sandboxwarmpools\"}, extensionRule.Resources)\n\tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"}, extensionRule.Verbs)\n\n\trequire.NotNil(t, extensionStatusRule)\n\tassert.Equal(t, []string{\"sandboxwarmpools/status\"}, extensionStatusRule.Resources)\n\tassert.ElementsMatch(t, []string{\"get\", \"update\", \"patch\"}, extensionStatusRule.Verbs)\n}\n\nfunc TestWorkloadManagerClusterRoleCodeInterpreterPermissions(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar wmCR ClusterRole\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ClusterRole\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar cr ClusterRole\n\t\t\terr = yaml.Unmarshal(data, &cr)\n\t\t\trequire.NoError(t, err)\n\t\t\tif cr.Metadata.Name == \"workloadmanager\" {\n\t\t\t\twmCR = cr\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tvar ciRule *Rule\n\tvar ciStatusRule *Rule\n\tvar ciFinalizersRule *Rule\n\tfor _, rule := range wmCR.Rules {\n\t\tif len(rule.APIGroups) > 0 && rule.APIGroups[0] == \"runtime.agentcube.volcano.sh\" {\n\t\t\tfor _, res := range rule.Resources {\n\t\t\t\tswitch res {\n\t\t\t\tcase \"codeinterpreters\":\n\t\t\t\t\tciRule = &rule\n\t\t\t\tcase \"codeinterpreters/status\":\n\t\t\t\t\tciStatusRule = &rule\n\t\t\t\tcase \"codeinterpreters/finalizers\":\n\t\t\t\t\tciFinalizersRule = &rule\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\trequire.NotNil(t, ciRule)\n\tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"}, ciRule.Verbs)\n\n\trequire.NotNil(t, ciStatusRule)\n\tassert.ElementsMatch(t, []string{\"get\", \"update\", \"patch\"}, ciStatusRule.Verbs)\n\n\trequire.NotNil(t, ciFinalizersRule)\n\tassert.Equal(t, []string{\"update\"}, ciFinalizersRule.Verbs)\n}\n\nfunc TestWorkloadManagerClusterRoleAgentRuntimePermissions(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar wmCR ClusterRole\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ClusterRole\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar cr ClusterRole\n\t\t\terr = yaml.Unmarshal(data, &cr)\n\t\t\trequire.NoError(t, err)\n\t\t\tif cr.Metadata.Name == \"workloadmanager\" {\n\t\t\t\twmCR = cr\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tvar arRule *Rule\n\tvar arStatusRule *Rule\n\tfor _, rule := range wmCR.Rules {\n\t\tif len(rule.APIGroups) > 0 && rule.APIGroups[0] == \"runtime.agentcube.volcano.sh\" {\n\t\t\tfor _, res := range rule.Resources {\n\t\t\t\tswitch res {\n\t\t\t\tcase \"agentruntimes\":\n\t\t\t\t\tarRule = &rule\n\t\t\t\tcase \"agentruntimes/status\":\n\t\t\t\t\tarStatusRule = &rule\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\trequire.NotNil(t, arRule)\n\tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\"}, arRule.Verbs)\n\n\trequire.NotNil(t, arStatusRule)\n\tassert.ElementsMatch(t, []string{\"update\", \"patch\"}, arStatusRule.Verbs)\n}\n\nfunc TestWorkloadManagerClusterRoleCorePermissions(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar wmCR ClusterRole\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ClusterRole\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar cr ClusterRole\n\t\t\terr = yaml.Unmarshal(data, &cr)\n\t\t\trequire.NoError(t, err)\n\t\t\tif cr.Metadata.Name == \"workloadmanager\" {\n\t\t\t\twmCR = cr\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tvar podsRule *Rule\n\tvar secretsRule *Rule\n\tfor _, rule := range wmCR.Rules {\n\t\tif len(rule.APIGroups) > 0 && rule.APIGroups[0] == \"\" {\n\t\t\tfor _, res := range rule.Resources {\n\t\t\t\tswitch res {\n\t\t\t\tcase \"pods\":\n\t\t\t\t\tpodsRule = &rule\n\t\t\t\tcase \"secrets\":\n\t\t\t\t\tsecretsRule = &rule\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\trequire.NotNil(t, podsRule)\n\tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\"}, podsRule.Verbs)\n\n\trequire.NotNil(t, secretsRule)\n\tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"}, secretsRule.Verbs)\n}\n\nfunc TestWorkloadManagerClusterRoleTokenReviewPermission(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar wmCR ClusterRole\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ClusterRole\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar cr ClusterRole\n\t\t\terr = yaml.Unmarshal(data, &cr)\n\t\t\trequire.NoError(t, err)\n\t\t\tif cr.Metadata.Name == \"workloadmanager\" {\n\t\t\t\twmCR = cr\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tvar tokenReviewRule *Rule\n\tfor _, rule := range wmCR.Rules {\n\t\tif len(rule.APIGroups) > 0 && rule.APIGroups[0] == \"authentication.k8s.io\" {\n\t\t\tfor _, res := range rule.Resources {\n\t\t\t\tif res == \"tokenreviews\" {\n\t\t\t\t\ttokenReviewRule = &rule\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\trequire.NotNil(t, tokenReviewRule)\n\tassert.Equal(t, []string{\"create\"}, tokenReviewRule.Verbs)\n}\n\nfunc TestWorkloadManagerClusterRoleBinding(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar wmCRB ClusterRoleBinding\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ClusterRoleBinding\" {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar crb ClusterRoleBinding\n\t\t\terr = yaml.Unmarshal(data, &crb)\n\t\t\trequire.NoError(t, err)\n\t\t\tif crb.Metadata.Name == \"workloadmanager\" {\n\t\t\t\twmCRB = crb\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t}\n\n\tassert.Equal(t, \"rbac.authorization.k8s.io/v1\", wmCRB.APIVersion)\n\tassert.Equal(t, \"ClusterRoleBinding\", wmCRB.Kind)\n\tassert.Equal(t, \"workloadmanager\", wmCRB.Metadata.Name)\n\n\tassert.Equal(t, \"rbac.authorization.k8s.io\", wmCRB.RoleRef.APIGroup)\n\tassert.Equal(t, \"ClusterRole\", wmCRB.RoleRef.Kind)\n\tassert.Equal(t, \"workloadmanager\", wmCRB.RoleRef.Name)\n\n\trequire.Len(t, wmCRB.Subjects, 1)\n\tassert.Equal(t, \"ServiceAccount\", wmCRB.Subjects[0].Kind)\n\tassert.Equal(t, \"workloadmanager\", wmCRB.Subjects[0].Name)\n\tassert.Equal(t, \"default\", wmCRB.Subjects[0].Namespace)\n}\n\nfunc TestNoWildcardPermissions(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && (kind == \"Role\" || kind == \"ClusterRole\") {\n\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\trequire.NoError(t, err)\n\t\t\tvar role struct {\n\t\t\t\tRules []Rule `json:\"rules\"`\n\t\t\t}\n\t\t\terr = yaml.Unmarshal(data, &role)\n\t\t\trequire.NoError(t, err)\n\n\t\t\tfor _, rule := range role.Rules {\n\t\t\t\tfor _, apiGroup := range rule.APIGroups {\n\t\t\t\t\tassert.NotEqual(t, \"*\", apiGroup)\n\t\t\t\t}\n\t\t\t\tfor _, resource := range rule.Resources {\n\t\t\t\t\tassert.NotEqual(t, \"*\", resource)\n\t\t\t\t}\n\t\t\t\tfor _, verb := range rule.Verbs {\n\t\t\t\t\tassert.NotEqual(t, \"*\", verb)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc TestRouterNamespaceIsolation(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tvar foundClusterRole bool\n\tvar foundClusterRoleBinding bool\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok {\n\t\t\tif kind == \"ClusterRole\" || kind == \"ClusterRoleBinding\" {\n\t\t\t\tif metadata, ok := doc[\"metadata\"].(map[string]interface{}); ok {\n\t\t\t\t\tif name, ok := metadata[\"name\"].(string); ok {\n\t\t\t\t\t\tif name == \"agentcube-router\" {\n\t\t\t\t\t\t\tif kind == \"ClusterRole\" {\n\t\t\t\t\t\t\t\tfoundClusterRole = true\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tif kind == \"ClusterRoleBinding\" {\n\t\t\t\t\t\t\t\tfoundClusterRoleBinding = true\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tassert.False(t, foundClusterRole, \"Router should not have ClusterRole\")\n\tassert.False(t, foundClusterRoleBinding, \"Router should not have ClusterRoleBinding\")\n}\n\nfunc TestRouterNoTokenReviewPermission(t *testing.T) {\n\toutput, err := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\trequire.NoError(t, err)\n\n\tdocs, err := parseYAMLDocuments(output)\n\trequire.NoError(t, err)\n\n\tfor _, doc := range docs {\n\t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"Role\" {\n\t\t\tif metadata, ok := doc[\"metadata\"].(map[string]interface{}); ok {\n\t\t\t\tif name, ok := metadata[\"name\"].(string); ok && name == \"agentcube-router\" {\n\t\t\t\t\tdata, err := yaml.Marshal(doc)\n\t\t\t\t\trequire.NoError(t, err)\n\t\t\t\t\tvar role Role\n\t\t\t\t\terr = yaml.Unmarshal(data, &role)\n\t\t\t\t\trequire.NoError(t, err)\n\n\t\t\t\t\tfor _, rule := range role.Rules {\n\t\t\t\t\t\tfor _, apiGroup := range rule.APIGroups {\n\t\t\t\t\t\t\tassert.NotEqual(t, \"authentication.k8s.io\", apiGroup, \"Router should not have TokenReview permission\")\n\t\t\t\t\t\t}\n\t\t\t\t\t\tfor _, res := range rule.Resources {\n\t\t\t\t\t\t\tassert.NotEqual(t, \"tokenreviews\", res, \"Router should not have TokenReview permission\")\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc TestHelmLint(t *testing.T) {\n\tcmd := exec.Command(\"helm\", \"lint\", chartPath)\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\terr := cmd.Run()\n\trequire.NoError(t, err, \"helm lint failed: %s\", stderr.String())\n}\n","after":"package tests\n\nimport (\n\t\"bytes\"\n\t\"os/exec\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"sigs.k8s.io/yaml\"\n)\n\nconst chartPath = \"../charts/base\"\n\nfunc runHelmTemplate(t *testing.T, values map[string]string) (string, error) {\n\targs := []string{\"template\", \"test\", chartPath, \"--set\", \"redis.addr=localhost:6379\"}\n\tfor k, v := range values {\n\t\targs = append(args, \"--set\", k+\"=\"+v)\n\t}\n\tcmd := exec.Command(\"helm\", args...)\n\tcmd.Dir = \"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests\"\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\terr := cmd.Run()\n\tif err != nil {\n\t\treturn stderr.String(), err\n\t}\n\treturn stdout.String(), err\n}\n\ntype ServiceAccount struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName      string            `json:\"name\"`\n\t\tNamespace string            `json:\"namespace\"`\n\t\tLabels    map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n}\n\ntype Role struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName      string            `json:\"name\"`\n\t\tNamespace string            `json:\"namespace\"`\n\t\tLabels    map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n\tRules []Rule `json:\"rules\"`\n}\n\ntype ClusterRole struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName   string            `json:\"name\"`\n\t\tLabels map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n\tRules []Rule `json:\"rules\"`\n}\n\ntype Rule struct {\n\tAPIGroups []string `json:\"apiGroups\"`\n\tResources []string `json:\"resources\"`\n\tVerbs     []string `json:\"verbs\"`\n}\n\ntype RoleBinding struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName      string            `json:\"name\"`\n\t\tNamespace string            `json:\"namespace\"`\n\t\tLabels    map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n\tRoleRef struct {\n\t\tAPIGroup string `json:\"apiGroup\"`\n\t\tKind     string `json:\"kind\"`\n\t\tName     string `json:\"name\"`\n\t} `json:\"roleRef\"`\n\tSubjects []Subject `json:\"subjects\"`\n}\n\ntype ClusterRoleBinding struct {\n\tAPIVersion string `json:\"apiVersion\"`\n\tKind       string `json:\"kind\"`\n\tMetadata   struct {\n\t\tName   string            `json:\"name\"`\n\t\tLabels map[string]string `json:\"labels\"`\n\t} `json:\"metadata\"`\n\tRoleRef struct {\n\t\tAPIGroup string `json:\"apiGroup\"`\n\t\tKind     string `json:\"kind\"`\n\t\tName     string `json:\"name\"`\n\t} `json:\"roleRef\"`\n\tSubjects []Subject `json:\"subjects\"`\n}\n\ntype Subject struct {\n\tKind      string `json:\"kind\"`\n\tName      string `json:\"name\"`\n\tNamespace string `json:\"namespace\"`\n}\n\nfunc runHelmTemplate(t *testing.T, values map[string]string) (string, error) {\n\targs := []string{\"template\", \"test\", chartPath, \"--set\", \"redis.addr=localhost:6379\"}\n\tfor k, v := range values {\n\t\targs = append(args, \"--set\", k+\"=\"+v)\n\t}\n\tcmd := exec.Command(\"helm\", args...)\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\terr := cmd.Run()\n\treturn stdout.String(), err\n}\n\nfunc parseYAMLDocuments(output string) ([]map[string]interface{}, error) {\n\tdocs := strings.Split(output, \"---\")\n\tvar results []map[string]interface{}\n\tfor _, doc := range docs {\n\t\tdoc = strings.TrimSpace(doc)\n\t\tif doc == \"\" || strings.HasPrefix(doc, \"# Source:\") {\n\t\t\tcontinue\n\t\t}\n\t\tvar obj map[string]interface{}\n\t\tif err := yaml.Unmarshal([]byte(doc), &obj); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif obj != nil {\n\t\t\tresults = append(results, obj)\n\t\t}\n\t}\n\treturn results, nil\n}\n\nfunc TestRouterRBACConditionalRendering(t *testing.T) {\n\ttests := []struct {\n\t\tname           string\n\t\tvalues         map[string]string\n\t\texpectRouterSA bool\n\t\texpectError    bool\n\t}{\n\t\t{\n\t\t\tname: \"RBAC enabled with serviceAccountName\",\n\t\t\tvalues: map[string]string{\n\t\t\t\t\"router.rbac.create\":        \"true\",\n\t\t\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t\t\t},\n\t\t\texpectRouterSA: true,\n\t\t\texpectError:    false,\n\t\t},\n\t\t{\n\t\t\tname: \"RBAC disabled\",\n\t\t\tvalues: map[string]string{\n\t\t\t\t\"router.rbac.create\": \"false\",\n\t\t\t},\n\t\t\texpectRouterSA: false,\n\t\t\texpectError:    false,\n\t\t},\n\t\t{\n\t\t\tname: \"RBAC enabled without serviceAccountName\",\n\t\t\tvalues: map[string]string{\n\t\t\t\t\"router.rbac.create\": \"true\",\n\t\t\t},\n\t\t\texpectRouterSA: false,\n\t\t\texpectError:    true,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\toutput, err := runHelmTemplate(t, tt.values)\n\t\t\tif tt.expectError {\n\t\t\t\trequire.Error(t, err)\n\t\t\t\tassert.Contains(t, err.Error(