ode":"UnusedImport","codeDescription":{"href":"https://pkg.go.dev/golang.org/x/tools/internal/typesinternal#UnusedImport"},"source":"compiler","message":"\"time\" imported and not used","tags":[1]}]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests/tests/rbac_test.go\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests/tests/rbac_test.go\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests/tests/rbac_test.go\n@@ -146,17 +146,10 @@\n \t\t\"router.rbac.create\":        \"true\",\n \t\t\"router.serviceAccountName\": \"agentcube-router\",\n \t})\n \n-\tassert.NotContains(t, output, \"kind: ClusterRole\")\n-\tlines := strings.Split(output, \"\\n\")\n-\tfor _, line := range lines {\n-\t\tif strings.Contains(line, \"kind: ClusterRoleBinding\") {\n-\t\t\tif strings.Contains(line, \"# Source: agentcube/templates/rbac-router.yaml\") {\n-\t\t\t\tt.Error(\"Router should not have ClusterRoleBinding\")\n-\t\t\t}\n-\t\t}\n-\t}\n+\tassert.NotContains(t, output, \"# Source: agentcube/templates/rbac-router.yaml\\nkind: ClusterRole\")\n+\tassert.NotContains(t, output, \"# Source: agentcube/templates/rbac-router.yaml\\nkind: ClusterRoleBinding\")\n }\n \n func TestWorkloadManagerServiceAccount(t *testing.T) {\n \toutput := runHelmTemplate(t, map[string]string{})\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests/tests/rbac_test.go","before":"package tests\n\nimport (\n\t\"bytes\"\n\t\"os/exec\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nconst manifestsDir = \"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests\"\n\nfunc runHelmTemplate(t *testing.T, values map[string]string) string {\n\targs := []string{\"template\", \"test\", \"charts/base\", \"--set\", \"redis.addr=localhost:6379\"}\n\tfor k, v := range values {\n\t\targs = append(args, \"--set\", k+\"=\"+v)\n\t}\n\tcmd := exec.Command(\"helm\", args...)\n\tcmd.Dir = manifestsDir\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\terr := cmd.Run()\n\trequire.NoError(t, err, \"helm template failed: %s\", stderr.String())\n\treturn stdout.String()\n}\n\nfunc runHelmTemplateExpectError(t *testing.T, values map[string]string) string {\n\targs := []string{\"template\", \"test\", \"charts/base\", \"--set\", \"redis.addr=localhost:6379\"}\n\tfor k, v := range values {\n\t\targs = append(args, \"--set\", k+\"=\"+v)\n\t}\n\tcmd := exec.Command(\"helm\", args...)\n\tcmd.Dir = manifestsDir\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\terr := cmd.Run()\n\trequire.Error(t, err)\n\treturn stderr.String()\n}\n\nfunc TestRouterRBACConditionalRenderingEnabled(t *testing.T) {\n\toutput := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\n\tassert.Contains(t, output, \"# Source: agentcube/templates/rbac-router.yaml\")\n\tassert.Contains(t, output, \"kind: ServiceAccount\")\n\tassert.Contains(t, output, \"name: agentcube-router\")\n\tassert.Contains(t, output, \"kind: Role\")\n\tassert.Contains(t, output, \"kind: RoleBinding\")\n}\n\nfunc TestRouterRBACConditionalRenderingDisabled(t *testing.T) {\n\toutput := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\": \"false\",\n\t})\n\n\tassert.NotContains(t, output, \"# Source: agentcube/templates/rbac-router.yaml\")\n\tassert.NotContains(t, output, \"kind: Role\\nmetadata:\\n  name: agentcube-router\")\n\tassert.NotContains(t, output, \"kind: RoleBinding\\nmetadata:\\n  name: agentcube-router\")\n}\n\nfunc TestRouterRBACValidationGuard(t *testing.T) {\n\terrOutput := runHelmTemplateExpectError(t, map[string]string{\n\t\t\"router.rbac.create\": \"true\",\n\t})\n\n\tassert.Contains(t, errOutput, \"router.serviceAccountName must be set\")\n}\n\nfunc TestRouterServiceAccountStructure(t *testing.T) {\n\toutput := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\n\tassert.Contains(t, output, \"apiVersion: v1\")\n\tassert.Contains(t, output, \"kind: ServiceAccount\")\n\tassert.Contains(t, output, \"name: agentcube-router\")\n\tassert.Contains(t, output, \"namespace: default\")\n\tassert.Contains(t, output, \"app.kubernetes.io/name: agentcube\")\n}\n\nfunc TestRouterRolePermissions(t *testing.T) {\n\toutput := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\n\tassert.Contains(t, output, \"apiVersion: rbac.authorization.k8s.io/v1\")\n\tassert.Contains(t, output, \"kind: Role\")\n\n\tlines := strings.Split(output, \"\\n\")\n\tvar roleSection bool\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"kind: Role\") && strings.Contains(line, \"# Source: agentcube/templates/rbac-router.yaml\") {\n\t\t\troleSection = true\n\t\t}\n\t\tif roleSection && strings.Contains(line, \"kind: RoleBinding\") {\n\t\t\tbreak\n\t\t}\n\t\tif roleSection {\n\t\t\tif strings.Contains(line, \"apiGroups:\") {\n\t\t\t\tassert.Contains(t, output, \"- \\\"\\\"\")\n\t\t\t}\n\t\t\tif strings.Contains(line, \"resources:\") {\n\t\t\t\tassert.Contains(t, output, \"- secrets\")\n\t\t\t}\n\t\t\tif strings.Contains(line, \"verbs:\") {\n\t\t\t\tassert.Contains(t, output, \"- get\")\n\t\t\t\tassert.Contains(t, output, \"- list\")\n\t\t\t\tassert.Contains(t, output, \"- watch\")\n\t\t\t\tassert.Contains(t, output, \"- create\")\n\t\t\t\tassert.Contains(t, output, \"- update\")\n\t\t\t\tassert.Contains(t, output, \"- patch\")\n\t\t\t\tassert.Contains(t, output, \"- delete\")\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc TestRouterRoleBinding(t *testing.T) {\n\toutput := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\n\tassert.Contains(t, output, \"kind: RoleBinding\")\n\tassert.Contains(t, output, \"roleRef:\")\n\tassert.Contains(t, output, \"kind: Role\")\n\tassert.Contains(t, output, \"name: agentcube-router\")\n\n\tassert.Contains(t, output, \"subjects:\")\n\tassert.Contains(t, output, \"kind: ServiceAccount\")\n\tassert.Contains(t, output, \"name: agentcube-router\")\n\tassert.Contains(t, output, \"namespace: default\")\n}\n\nfunc TestRouterNoClusterRole(t *testing.T) {\n\toutput := runHelmTemplate(t, map[string]string{\n\t\t\"router.rbac.create\":        \"true\",\n\t\t\"router.serviceAccountName\": \"agentcube-router\",\n\t})\n\n\tassert.NotContains(t, output, \"kind: ClusterRole\")\n\tlines := strings.Split(output, \"\\n\")\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"kind: ClusterRoleBinding\") {\n\t\t\tif strings.Contains(line, \"# Source: agentcube/templates/rbac-router.yaml\") {\n\t\t\t\tt.Error(\"Router should not have ClusterRoleBinding\")\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc TestWorkloadManagerServiceAccount(t *testing.T) {\n\toutput := runHelmTemplate(t, map[string]string{})\n\n\tassert.Contains(t, output, \"# Source: agentcube/templates/rbac/workloadmanager.yaml\")\n\tassert.Contains(t, output, \"name: workloadmanager\")\n\tassert.Contains(t, output, \"kind: ServiceAccount\")\n}\n\nfunc TestWorkloadManagerClusterRole(t *testing.T) {\n\toutput := runHelmTemplate(t, map[string]string{})\n\n\tassert.Contains(t, output, \"kind: ClusterRole\")\n\tassert.Contains(t, output, \"name: workloadmanager\")\n\n\tassert.Contains(t, output, \"- agents.x-k8s.io\")\n\tassert.Contains(t, output, \"- sandboxes\")\n\n\tassert.Contains(t, output, \"- extensions.agents.x-k8s.io\")\n\tassert.Contains(t, out