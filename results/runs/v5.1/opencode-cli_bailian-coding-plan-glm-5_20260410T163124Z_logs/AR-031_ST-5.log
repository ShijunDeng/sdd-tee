ch\"}, extensionStatusRule.Verbs)\n424: }\n425: \n426: func TestWorkloadManagerClusterRoleCodeInterpreterPermissions(t *testing.T) {\n427: \toutput, err := runHelmTemplate(t, map[string]string{})\n428: \trequire.NoError(t, err)\n429: \n430: \tdocs, err := parseYAMLDocuments(output)\n431: \trequire.NoError(t, err)\n432: \n433: \tvar wmCR ClusterRole\n434: \tfor _, doc := range docs {\n435: \t\tif kind, ok := doc[\"kind\"].(string); ok && kind == \"ClusterRole\" {\n436: \t\t\tdata, err := yaml.Marshal(doc)\n437: \t\t\trequire.NoError(t, err)\n438: \t\t\tvar cr ClusterRole\n439: \t\t\terr = yaml.Unmarshal(data, &cr)\n440: \t\t\trequire.NoError(t, err)\n441: \t\t\tif cr.Metadata.Name == \"workloadmanager\" {\n442: \t\t\t\twmCR = cr\n443: \t\t\t\tbreak\n444: \t\t\t}\n445: \t\t}\n446: \t}\n447: \n448: \tvar ciRule *Rule\n449: \tvar ciStatusRule *Rule\n450: \tvar ciFinalizersRule *Rule\n451: \tfor _, rule := range wmCR.Rules {\n452: \t\tif len(rule.APIGroups) > 0 && rule.APIGroups[0] == \"runtime.agentcube.volcano.sh\" {\n453: \t\t\tfor _, res := range rule.Resources {\n454: \t\t\t\tswitch res {\n455: \t\t\t\tcase \"codeinterpreters\":\n456: \t\t\t\t\tciRule = &rule\n457: \t\t\t\tcase \"codeinterpreters/status\":\n458: \t\t\t\t\tciStatusRule = &rule\n459: \t\t\t\tcase \"codeinterpreters/finalizers\":\n460: \t\t\t\t\tciFinalizersRule = &rule\n461: \t\t\t\t}\n462: \t\t\t}\n463: \t\t}\n464: \t}\n465: \n466: \trequire.NotNil(t, ciRule)\n467: \tassert.ElementsMatch(t, []string{\"get\", \"list\", \"watch\", \"create\", \"update\", \"patch\", \"delete\"}, ciRule.Verbs)\n468: \n469: \trequire.NotNil(t, ciStatusRule)\n470: \tassert.ElementsMatch(t, []string{\"get\", \"update\", \"patch\"}, ciStatusRule.Verbs)\n471: \n472: \trequire.NotNil(t, ciFinalizersRule)\n473: \tassert.Equal(t, []string{\"update\"}, ciFinalizersRule.Verbs)\n474: }\n475: \n476: func TestWorkloadManagerClusterRoleAgentRuntimePermissions(t *testing.T) {\n477: \toutput, err := runHelmTemplate(t, map[string]string{