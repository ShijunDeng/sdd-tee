uration(req.Timeout)\n50: \t\tif err == nil {\n51: \t\t\ttimeout = parsed\n52: \t\t}\n53: \t}\n54: \n55: \tctx, cancel := context.WithTimeout(c.Request.Context(), timeout)\n56: \tdefer cancel()\n57: \n58: \tcmd := exec.CommandContext(ctx, req.Command[0], req.Command[1:]...)\n59: \n60: \tif req.WorkingDir != \"\" {\n61: \t\tsanitized, err := sanitizePath(s.workspace, req.WorkingDir)\n62: \t\tif err != nil {\n63: \t\t\tc.JSON(400, gin.H{\"error\": fmt.Sprintf(\"invalid working directory: %s\", err.Error())})\n64: \t\t\treturn\n65: \t\t}\n66: \t\tcmd.Dir = sanitized\n67: \t} else {\n68: \t\tcmd.Dir = s.workspace\n69: \t}\n70: \n71: \tif req.Env != nil {\n72: \t\tcmd.Env = os.Environ()\n73: \t\tfor k, v := range req.Env {\n74: \t\t\tcmd.Env = append(cmd.Env, fmt.Sprintf(\"%s=%s\", k, v))\n75: \t\t}\n76: \t}\n77: \n78: \tstdout := &bytes.Buffer{}\n79: \tstderr := &bytes.Buffer{}\n80: \tcmd.Stdout = stdout\n81: \tcmd.Stderr = stderr\n82: \tcmd.Stdin = nil\n83: \n84: \tstartTime := time.Now()\n85: \terr := cmd.Run()\n86: \tendTime := time.Now()\n87: \n88: \texitCode := 0\n89: \tif err != nil {\n90: \t\tif ctx.Err() == context.DeadlineExceeded {\n91: \t\t\texitCode = TimeoutExitCode\n92: \t\t\tstderr.WriteString(\"command timed out\")\n93: \t\t} else if exitErr, ok := err.(*exec.ExitError); ok {\n94: \t\t\texitCode = exitErr.ExitCode()\n95: \t\t} else {\n96: \t\t\texitCode = 1\n97: \t\t}\n98: \t}\n99: \n100: \tc.JSON(200, ExecuteResponse{\n101: \t\tStdout:    stdout.String(),\n102: \t\tStderr:    stderr.String(),\n103: \t\tExitCode:  exitCode,\n104: \t\tDuration:  endTime.Sub(startTime).Seconds(),\n105: \t\tStartTime: startTime,\n106: \t\tEndTime:   endTime,\n107: \t})\n108: }\n\n(End of file - total 108 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n)\n\nconst (\n\tTimeoutExitCode = 124\n\tdefaultTimeout  = 60 * time.Second\n)\n\ntype ExecuteRequest struct {\n\tCommand    []string          `json:\"command\" binding:\"required\"`","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/execute.go","time":{"start":1775862626603,"end":1775862626665}}}}
