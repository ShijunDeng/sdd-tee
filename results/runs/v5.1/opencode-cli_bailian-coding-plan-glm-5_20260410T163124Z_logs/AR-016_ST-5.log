-\t\tw = makeAuthenticatedRequest(t, server, \"GET\", fmt.Sprintf(\"/api/files/concurrent%d.txt\", idx), nil, \"\", validToken)\n+\t\tw = httptest.NewRecorder()\n+\t\treq = httptest.NewRequest(\"GET\", fmt.Sprintf(\"/api/files/concurrent%d.txt\", idx), nil)\n+\t\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n+\t\tserver.engine.ServeHTTP(w, req)\n \t\tassert.Equal(t, 200, w.Code)\n \t\tassert.Equal(t, string(content), w.Body.String())\n \n \t\tdone <- true\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go","before":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc setupTestServer(t *testing.T) *Server {\n\tt.Helper()\n\n\tworkspace := t.TempDir()\n\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t}\n\t})\n\n\tserver, err := NewServer(&Config{\n\t\tPort:      8080,\n\t\tWorkspace: workspace,\n\t})\n\trequire.NoError(t, err)\n\n\treturn server\n}\n\nfunc encodePublicKeyPEMForTest(key *rsa.PublicKey) string {\n\tbytes, err := x509.MarshalPKIXPublicKey(key)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\tpemData := pem.EncodeToMemory(&pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: bytes,\n\t})\n\treturn string(pemData)\n}\n\nfunc generateTestJWT(privateKey *rsa.PrivateKey, expired bool) string {\n\tnow := time.Now()\n\texpiry := now.Add(5 * time.Minute)\n\tif expired {\n\t\texpiry = now.Add(-5 * time.Minute)\n\t}\n\n\tclaims := jwt.MapClaims{\n\t\t\"exp\": expiry.Unix(),\n\t\t\"iat\": now.Unix(),\n\t\t\"iss\": \"test-issuer\",\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, _ := token.SignedString(privateKey)\n\treturn tokenString\n}\n\nfunc generateHS256JWT() string {\n\tclaims := jwt.MapClaims{\n\t\t\"exp\": time.Now().Add(5 * time.Minute).Unix(),\n\t\t\"iat\": time.Now().Unix(),\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n\ttokenString, _ := token.SignedString([]byte(\"test-secret\"))\n\treturn tokenString\n}\n\nfunc makeAuthenticatedRequest(t *testing.T, server *Server, method, path string, body io.Reader, contentType string, jwtToken string) *httptest.ResponseRecorder {\n\tt.Helper()\n\n\tgin.SetMode(gin.TestMode)\n\tw := httptest.NewRecorder()\n\treq := httptest.NewRequest(method, path, body)\n\tif contentType != \"\" {\n\t\treq.Header.Set(\"Content-Type\", contentType)\n\t}\n\tif jwtToken != \"\" {\n\t\treq.Header.Set(\"Authorization\", \"Bearer \"+jwtToken)\n\t}\n\n\tserver.engine.ServeHTTP(w, req)\n\treturn w\n}\n\nfunc TestConfig(t *testing.T) {\n\tcfg := &Config{\n\t\tPort:      8080,\n\t\tWorkspace: \"/tmp/test\",\n\t}\n\n\tassert.Equal(t, 8080, cfg.Port)\n\tassert.Equal(t, \"/tmp/test\", cfg.Workspace)\n}\n\nfunc TestSanitizePathValidRelative(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\tresult, err := sanitizePath(workspace, \"subdir/file.txt\")\n\trequire.NoError(t, err)\n\n\texpected := filepath.Join(workspace, \"subdir/file.txt\")\n\tassert.Equal(t, expected, result)\n}\n\nfunc TestSanitizePathAbsolute(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\tresult, err := sanitizePath(workspace, \"/workspace/file.txt\")\n\trequire.NoError(t, err)\n\n\texpected := filepath.Join(workspace, \"workspace/file.txt\")\n\tassert.Equal(t, expected, result)\n}\n\nfunc TestSanitizePathTraversal(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\t_, err := sanitizePath(workspace, \"../escape.txt\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"path escape\")\n}\n\nfunc TestSanitizePathDeepTraversal(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\t_, err := sanitizePath(workspace, \"subdir/../../escape.txt\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"path escape\")\n}\n\nfunc TestSanitizePathNullByte(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\tresult, err := sanitizePath(workspace, \"file\\x00.txt\")\n\trequire.NoError(t, err)\n\n\tassert.Contains(t, result, workspace)\n}\n\nfunc TestSanitizePathExistingSymlink(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\ttargetDir := filepath.Join(workspace, \"target\")\n\trequire.NoError(t, os.MkdirAll(targetDir, 0755))\n\n\tlinkPath := filepath.Join(workspace, \"link\")\n\trequire.NoError(t, os.Symlink(targetDir, linkPath))\n\n\ttargetFile := filepath.Join(targetDir, \"file.txt\")\n\trequire.NoError(t, os.WriteFile(targetFile, []byte(\"test\"), 0644))\n\n\tresult, err := sanitizePath(workspace, \"link/file.txt\")\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, targetFile, result)\n}\n\nfunc TestAuthMiddlewareMissingHeader(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"\")\n\tassert.Equal(t, 401, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing authorization header\", resp[\"error\"])\n}\n\nfunc TestAuthMiddlewareInvalidFormat(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"InvalidFormat\")\n\tassert.Equal(t, 401, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"malformed\")\n}\n\nfunc TestAuthMiddlewareExpiredToken(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\texpiredToken := generateTestJWT(privateKey, true)\n\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", expiredToken)\n\tassert.Equal(t, 401, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"token is expired\", resp[\"error\"])\n}\n\nfunc TestAuthMiddlewareHS256Token(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\ths256Token := generateHS256JWT()\n\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", hs256Token)\n\tassert.Equal(t, 401, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"invalid signing method\", resp[\"error\"])\n}\n\nfunc TestAuthMiddlewareValidRS256Token(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"hello\"]}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n}\n\nfunc TestExecuteHandlerValidCommand(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"hello\"]}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"hello\\n\", resp.Stdout)\n\tassert.Equal(t, 0, resp.ExitCode)\n\tassert.Greater(t, resp.Duration, 0.0)\n}\n\nfunc TestExecuteHandlerEmptyCommand(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": []}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing command\", resp[\"error\"])\n}\n\nfunc TestExecuteHandlerTimeout(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"sleep\", \"10\"], \"timeout\": \"1s\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, TimeoutExitCode, resp.ExitCode)\n\tassert.Contains(t, resp.Stderr, \"command timed out\")\n}\n\nfunc TestExecuteHandlerInvalidTimeout(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"test\"], \"timeout\": \"invalid\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, 0, resp.ExitCode)\n}\n\nfunc TestExecuteHandlerWorkingDirectory(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tsubdir := filepath.Join(server.workspace, \"subdir\")\n\trequire.NoError(t, os.MkdirAll(subdir, 0755))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"subdir\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp.Stdout, subdir)\n}\n\nfunc TestExecuteHandlerPathEscapeWorkingDir(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"../escape\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"invalid working directory\")\n}\n\nfunc TestExecuteHandlerEnvironmentAugmentation(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"sh\", \"-c\", \"echo $MY_VAR\"], \"env\": {\"MY_VAR\": \"test_value\"}}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp.Stdout, \"test_value\")\n}\n\nfunc TestExecuteHandlerExitCodePropagation(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"sh\", \"-c\", \"exit 42\"]}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, 42, resp.ExitCode)\n}\n\nfunc TestUploadFileHandlerMultipart(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := &bytes.Buffer{}\n\twriter := multipart.NewWriter(body)\n\n\trequire.NoError(t, writer.WriteField(\"path\", \"upload.txt\"))\n\tpart, err := writer.CreateFormFile(\"file\", \"upload.txt\")\n\trequire.NoError(t, err)\n\t_, err = part.Write([]byte(\"test file content\"))\n\trequire.NoError(t, err)\n\trequire.NoError(t, writer.Close())\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n\treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"upload.txt\", resp.Path)\n\n\tfilePath := filepath.Join(server.workspace, \"upload.txt\")\n\tactualContent, err := os.ReadFile(filePath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, []byte(\"test file content\"), actualContent)\n}\n\nfunc TestUploadFileHandlerJSON(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test content\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"test.txt\", resp.Path)\n\tassert.Equal(t, int64(12), resp.Size)\n\n\tfilePath := filepath.Join(server.workspace, \"test.txt\")\n\tactualContent, err := os.ReadFile(filePath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, []byte(\"test content\"), actualContent)\n}\n\nfunc TestUploadFileHandlerInvalidBase64(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"path\": \"test.txt\", \"content\": \"!!invalid\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"invalid base64 content\", resp[\"error\"])\n}\n\nfunc TestUploadFileHandlerPathEscape(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"../escape.txt\", \"content\": \"%s\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"invalid path\")\n}\n\nfunc TestUploadFileHandlerInvalidMode(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\", \"mode\": \"9999\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"test.txt\", resp.Path)\n}\n\nfunc TestUploadFileHandlerModeTooHigh(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\", \"mode\": \"1000\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"invalid file mode\", resp[\"error\"])\n}\n\nfunc TestUploadFileHandlerParentDirectoryCreation(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"new/dir/file.txt\", \"content\": \"%s\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tfilePath := filepath.Join(server.workspace, \"new/dir/file.txt\")\n\t_, err = os.Stat(filePath)\n\trequire.NoError(t, err)\n}\n\nfunc TestListFilesHandlerValidDirectory(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tsubdir := filepath.Join(server.workspace, \"testdir\")\n\trequire.NoError(t, os.MkdirAll(subdir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(subdir, \"file1.txt\"), []byte(\"content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=testdir\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ListFilesResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"testdir\", resp.Path)\n\tassert.Len(t, resp.Files, 1)\n\tassert.Equal(t, \"file1.txt\", resp.Files[0].Name)\n\tassert.False(t, resp.Files[0].IsDir)\n}\n\nfunc TestListFilesHandlerMissingPath(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files\", nil, \"\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing path parameter\", resp[\"error\"])\n}\n\nfunc TestListFilesHandlerPathEscape(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=../escape\", nil, \"\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"invalid path\")\n}\n\nfunc TestListFilesHandlerNonExistent(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=nonexistent\", nil, \"\", validToken)\n\tassert.Equal(t, 500, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"failed to read directory\", resp[\"error\"])\n}\n\nfunc TestDownloadFileHandlerExistingFile(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"testfile.txt\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(\"download content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/testfile.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, \"download content\", w.Body.String())\n}\n\nfunc TestDownloadFileHandlerLeadingSlash(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"absolute.txt\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(\"absolute content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files//absolute.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n}\n\nfunc TestDownloadFileHandlerPathEscape(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/../escape.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"invalid path\")\n}\n\nfunc TestDownloadFileHandlerNotFound(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/nonexistent.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 404, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"file not found\", resp[\"error\"])\n}\n\nfunc TestDownloadFileHandlerIsDirectory(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tsubdir := filepath.Join(server.workspace, \"subdir\")\n\trequire.NoError(t, os.MkdirAll(subdir, 0755))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/subdir\", nil, \"\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"path is not a file\", resp[\"error\"])\n}\n\nfunc TestHealthCheckHandler(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tw := httptest.NewRecorder()\n\treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp map[string]interface{}\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\tassert.Equal(t, \"PicoD\", resp[\"service\"])\n\tassert.Equal(t, \"0.0.1\", resp[\"version\"])\n\tassert.NotEmpty(t, resp[\"uptime\"])\n}\n\nfunc TestLoadPublicKeyFromEnvMissing(t *testing.T) {\n\tos.Unsetenv(PublicKeyEnvVar)\n\n\t_, err := LoadPublicKeyFromEnv()\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"public key environment variable not set\")\n}\n\nfunc TestLoadPublicKeyFromEnvInvalidPEM(t *testing.T) {\n\tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\t_, err := LoadPublicKeyFromEnv()\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"failed to decode PEM block\")\n}\n\nfunc TestLoadPublicKeyFromEnvPKCS1Format(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpkcs1PEM := pem.EncodeToMemory(&pem.Block{\n\t\tType:  \"RSA PUBLIC KEY\",\n\t\tBytes: x509.MarshalPKCS1PublicKey(&privateKey.PublicKey),\n\t})\n\n\tos.Setenv(PublicKeyEnvVar, string(pkcs1PEM))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\t_, err = LoadPublicKeyFromEnv()\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"expected PUBLIC KEY PEM block\")\n}\n\nfunc TestLoadPublicKeyFromEnvValid(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tpubKey, err := LoadPublicKeyFromEnv()\n\trequire.NoError(t, err)\n\tassert.NotNil(t, pubKey)\n\tassert.Equal(t, &privateKey.PublicKey, pubKey)\n}\n\nfunc TestParseFileModeEmpty(t *testing.T) {\n\tmode, err := parseFileMode(\"\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n}\n\nfunc TestParseFileModeInvalid(t *testing.T) {\n\tmode, err := parseFileMode(\"invalid\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n}\n\nfunc TestParseFileModeTooHigh(t *testing.T) {\n\t_, err := parseFileMode(\"1000\")\n\tassert.Error(t, err)\n\tassert.Equal(t, \"invalid file mode\", err.Error())\n}\n\nfunc TestParseFileModeValid(t *testing.T) {\n\tmode, err := parseFileMode(\"0755\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, os.FileMode(0755), mode)\n}\n\nfunc TestServerShutdown(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\n\terr := server.Shutdown(ctx)\n\tassert.NoError(t, err)\n}\n\nfunc TestUploadFileHandlerMultipartMissingPath(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := &bytes.Buffer{}\n\twriter := multipart.NewWriter(body)\n\n\tpart, err := writer.CreateFormFile(\"file\", \"upload.txt\")\n\trequire.NoError(t, err)\n\t_, err = part.Write([]byte(\"test file content\"))\n\trequire.NoError(t, err)\n\trequire.NoError(t, writer.Close())\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n\treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing path parameter\", resp[\"error\"])\n}\n\nfunc TestUploadFileHandlerMultipartMissingFile(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := &bytes.Buffer{}\n\twriter := multipart.NewWriter(body)\n\n\trequire.NoError(t, writer.WriteField(\"path\", \"upload.txt\"))\n\trequire.NoError(t, writer.Close())\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n\treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing file\", resp[\"error\"])\n}\n\nfunc TestListFilesHandlerEmptyDirectory(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\temptyDir := filepath.Join(server.workspace, \"emptydir\")\n\trequire.NoError(t, os.MkdirAll(emptyDir, 0755))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=emptydir\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ListFilesResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"emptydir\", resp.Path)\n\tassert.Len(t, resp.Files, 0)\n}\n\nfunc TestDownloadFileHandlerMIMETypeJSON(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"data.json\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(`{\"key\": \"value\"}`), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.json\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, \"application/json\", w.Header().Get(\"Content-Type\"))\n\tassert.Equal(t, `{\"key\": \"value\"}`, w.Body.String())\n}\n\nfunc TestDownloadFileHandlerMIMETypeUnknown(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"data.xyz\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(\"unknown content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.xyz\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, \"application/octet-stream\", w.Header().Get(\"Content-Type\"))\n\tassert.Equal(t, \"unknown content\", w.Body.String())\n}\n\nfunc TestDownloadFileHandlerSymlinkInsideWorkspace(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\ttargetFile := filepath.Join(server.workspace, \"target.txt\")\n\trequire.NoError(t, os.WriteFile(targetFile, []byte(\"target content\"), 0644))\n\n\tlinkPath := filepath.Join(server.workspace, \"link.txt\")\n\trequire.NoError(t, os.Symlink(targetFile, linkPath))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/link.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, \"target content\", w.Body.String())\n}\n\nfunc TestFileLifecycle(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\ttestContent := []byte(\"lifecycle test content\")\n\tencodedContent := base64.StdEncoding.EncodeToString(testContent)\n\n\tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"lifecycle/test.txt\", \"content\": \"%s\"}`, encodedContent))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar uploadResp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &uploadResp))\n\tassert.Equal(t, \"lifecycle/test.txt\", uploadResp.Path)\n\n\tw = makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=lifecycle\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar listResp ListFilesResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &listResp))\n\tassert.Equal(t, \"lifecycle\", listResp.Path)\n\tassert.Len(t, listResp.Files, 1)\n\tassert.Equal(t, \"test.txt\", listResp.Files[0].Name)\n\tassert.False(t, listResp.Files[0].IsDir)\n\n\tw = makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/lifecycle/test.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, string(testContent), w.Body.String())\n\n\tactualContent, err := os.ReadFile(filepath.Join(server.workspace, \"lifecycle/test.txt\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, testContent, actualContent)\n}\n\nfunc TestUploadLargeFile(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tlargeContent := make([]byte, 30*1024*1024)\n\tfor i := range largeContent {\n\t\tlargeContent[i] = byte(i % 256)\n\t}\n\tencodedContent := base64.StdEncoding.EncodeToString(largeContent)\n\n\tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"large.bin\", \"content\": \"%s\"}`, encodedContent))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar uploadResp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &uploadResp))\n\tassert.Equal(t, \"large.bin\", uploadResp.Path)\n\n\tactualContent, err := os.ReadFile(filepath.Join(server.workspace, \"large.bin\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, largeContent, actualContent)\n}\n\nfunc TestConcurrentFileOperations(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tnumOps := 10\n\tdone := make(chan bool, numOps)\n\n\tfor i := 0; i < numOps; i++ {\n\t\tgo func(idx int) {\n\t\t\tcontent := []byte(fmt.Sprintf(\"concurrent content %d\", idx))\n\t\t\tencodedContent := base64.StdEncoding.EncodeToString(content)\n\n\t\t\tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"concurrent%d.txt\", \"content\": \"%s\"}`, idx, encodedContent))\n\t\t\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n\t\t\tassert.Equal(t, 200, w.Code)\n\n\t\t\tw = makeAuthenticatedRequest(t, server, \"GET\", fmt.Sprintf(\"/api/files/concurrent%d.txt\", idx), nil, \"\", validToken)\n\t\t\tassert.Equal(t, 200, w.Code)\n\t\t\tassert.Equal(t, string(content), w.Body.String())\n\n\t\t\tdone <- true\n\t\t}(i)\n\t}\n\n\tfor i := 0; i < numOps; i++ {\n\t\tselect {\n\t\tcase <-done:\n\t\tcase <-time.After(10 * time.Second):\n\t\t\tt.Fatal(\"concurrent operation timed out\")\n\t\t}\n\t}\n}\n","after":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/gin-gonic/gin\"\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc setupTestServer(t *testing.T) *Server {\n\tt.Helper()\n\n\tworkspace := t.TempDir()\n\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t}\n\t})\n\n\tserver, err := NewServer(&Config{\n\t\tPort:      8080,\n\t\tWorkspace: workspace,\n\t})\n\trequire.NoError(t, err)\n\n\treturn server\n}\n\nfunc encodePublicKeyPEMForTest(key *rsa.PublicKey) string {\n\tbytes, err := x509.MarshalPKIXPublicKey(key)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\tpemData := pem.EncodeToMemory(&pem.Block{\n\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: bytes,\n\t})\n\treturn string(pemData)\n}\n\nfunc generateTestJWT(privateKey *rsa.PrivateKey, expired bool) string {\n\tnow := time.Now()\n\texpiry := now.Add(5 * time.Minute)\n\tif expired {\n\t\texpiry = now.Add(-5 * time.Minute)\n\t}\n\n\tclaims := jwt.MapClaims{\n\t\t\"exp\": expiry.Unix(),\n\t\t\"iat\": now.Unix(),\n\t\t\"iss\": \"test-issuer\",\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodRS256, claims)\n\ttokenString, _ := token.SignedString(privateKey)\n\treturn tokenString\n}\n\nfunc generateHS256JWT() string {\n\tclaims := jwt.MapClaims{\n\t\t\"exp\": time.Now().Add(5 * time.Minute).Unix(),\n\t\t\"iat\": time.Now().Unix(),\n\t}\n\n\ttoken := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)\n\ttokenString, _ := token.SignedString([]byte(\"test-secret\"))\n\treturn tokenString\n}\n\nfunc makeAuthenticatedRequest(t *testing.T, server *Server, method, path string, body io.Reader, contentType string, jwtToken string) *httptest.ResponseRecorder {\n\tt.Helper()\n\n\tgin.SetMode(gin.TestMode)\n\tw := httptest.NewRecorder()\n\treq := httptest.NewRequest(method, path, body)\n\tif contentType != \"\" {\n\t\treq.Header.Set(\"Content-Type\", contentType)\n\t}\n\tif jwtToken != \"\" {\n\t\treq.Header.Set(\"Authorization\", \"Bearer \"+jwtToken)\n\t}\n\n\tserver.engine.ServeHTTP(w, req)\n\treturn w\n}\n\nfunc TestConfig(t *testing.T) {\n\tcfg := &Config{\n\t\tPort:      8080,\n\t\tWorkspace: \"/tmp/test\",\n\t}\n\n\tassert.Equal(t, 8080, cfg.Port)\n\tassert.Equal(t, \"/tmp/test\", cfg.Workspace)\n}\n\nfunc TestSanitizePathValidRelative(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\tresult, err := sanitizePath(workspace, \"subdir/file.txt\")\n\trequire.NoError(t, err)\n\n\texpected := filepath.Join(workspace, \"subdir/file.txt\")\n\tassert.Equal(t, expected, result)\n}\n\nfunc TestSanitizePathAbsolute(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\tresult, err := sanitizePath(workspace, \"/workspace/file.txt\")\n\trequire.NoError(t, err)\n\n\texpected := filepath.Join(workspace, \"workspace/file.txt\")\n\tassert.Equal(t, expected, result)\n}\n\nfunc TestSanitizePathTraversal(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\t_, err := sanitizePath(workspace, \"../escape.txt\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"path escape\")\n}\n\nfunc TestSanitizePathDeepTraversal(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\t_, err := sanitizePath(workspace, \"subdir/../../escape.txt\")\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"path escape\")\n}\n\nfunc TestSanitizePathNullByte(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\tresult, err := sanitizePath(workspace, \"file\\x00.txt\")\n\trequire.NoError(t, err)\n\n\tassert.Contains(t, result, workspace)\n}\n\nfunc TestSanitizePathExistingSymlink(t *testing.T) {\n\tworkspace := t.TempDir()\n\n\ttargetDir := filepath.Join(workspace, \"target\")\n\trequire.NoError(t, os.MkdirAll(targetDir, 0755))\n\n\tlinkPath := filepath.Join(workspace, \"link\")\n\trequire.NoError(t, os.Symlink(targetDir, linkPath))\n\n\ttargetFile := filepath.Join(targetDir, \"file.txt\")\n\trequire.NoError(t, os.WriteFile(targetFile, []byte(\"test\"), 0644))\n\n\tresult, err := sanitizePath(workspace, \"link/file.txt\")\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, targetFile, result)\n}\n\nfunc TestAuthMiddlewareMissingHeader(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"\")\n\tassert.Equal(t, 401, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing authorization header\", resp[\"error\"])\n}\n\nfunc TestAuthMiddlewareInvalidFormat(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", \"InvalidFormat\")\n\tassert.Equal(t, 401, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"malformed\")\n}\n\nfunc TestAuthMiddlewareExpiredToken(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\texpiredToken := generateTestJWT(privateKey, true)\n\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", expiredToken)\n\tassert.Equal(t, 401, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"token is expired\", resp[\"error\"])\n}\n\nfunc TestAuthMiddlewareHS256Token(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\ths256Token := generateHS256JWT()\n\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", nil, \"application/json\", hs256Token)\n\tassert.Equal(t, 401, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"invalid signing method\", resp[\"error\"])\n}\n\nfunc TestAuthMiddlewareValidRS256Token(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"hello\"]}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n}\n\nfunc TestExecuteHandlerValidCommand(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"hello\"]}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"hello\\n\", resp.Stdout)\n\tassert.Equal(t, 0, resp.ExitCode)\n\tassert.Greater(t, resp.Duration, 0.0)\n}\n\nfunc TestExecuteHandlerEmptyCommand(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": []}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing command\", resp[\"error\"])\n}\n\nfunc TestExecuteHandlerTimeout(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"sleep\", \"10\"], \"timeout\": \"1s\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, TimeoutExitCode, resp.ExitCode)\n\tassert.Contains(t, resp.Stderr, \"command timed out\")\n}\n\nfunc TestExecuteHandlerInvalidTimeout(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"echo\", \"test\"], \"timeout\": \"invalid\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, 0, resp.ExitCode)\n}\n\nfunc TestExecuteHandlerWorkingDirectory(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tsubdir := filepath.Join(server.workspace, \"subdir\")\n\trequire.NoError(t, os.MkdirAll(subdir, 0755))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"subdir\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp.Stdout, subdir)\n}\n\nfunc TestExecuteHandlerPathEscapeWorkingDir(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"pwd\"], \"working_dir\": \"../escape\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"invalid working directory\")\n}\n\nfunc TestExecuteHandlerEnvironmentAugmentation(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"sh\", \"-c\", \"echo $MY_VAR\"], \"env\": {\"MY_VAR\": \"test_value\"}}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp.Stdout, \"test_value\")\n}\n\nfunc TestExecuteHandlerExitCodePropagation(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"command\": [\"sh\", \"-c\", \"exit 42\"]}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/execute\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ExecuteResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, 42, resp.ExitCode)\n}\n\nfunc TestUploadFileHandlerMultipart(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := &bytes.Buffer{}\n\twriter := multipart.NewWriter(body)\n\n\trequire.NoError(t, writer.WriteField(\"path\", \"upload.txt\"))\n\tpart, err := writer.CreateFormFile(\"file\", \"upload.txt\")\n\trequire.NoError(t, err)\n\t_, err = part.Write([]byte(\"test file content\"))\n\trequire.NoError(t, err)\n\trequire.NoError(t, writer.Close())\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n\treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"upload.txt\", resp.Path)\n\n\tfilePath := filepath.Join(server.workspace, \"upload.txt\")\n\tactualContent, err := os.ReadFile(filePath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, []byte(\"test file content\"), actualContent)\n}\n\nfunc TestUploadFileHandlerJSON(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test content\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"test.txt\", resp.Path)\n\tassert.Equal(t, int64(12), resp.Size)\n\n\tfilePath := filepath.Join(server.workspace, \"test.txt\")\n\tactualContent, err := os.ReadFile(filePath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, []byte(\"test content\"), actualContent)\n}\n\nfunc TestUploadFileHandlerInvalidBase64(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := bytes.NewBufferString(`{\"path\": \"test.txt\", \"content\": \"!!invalid\"}`)\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"invalid base64 content\", resp[\"error\"])\n}\n\nfunc TestUploadFileHandlerPathEscape(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"../escape.txt\", \"content\": \"%s\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"invalid path\")\n}\n\nfunc TestUploadFileHandlerInvalidMode(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\", \"mode\": \"9999\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"test.txt\", resp.Path)\n}\n\nfunc TestUploadFileHandlerModeTooHigh(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"test.txt\", \"content\": \"%s\", \"mode\": \"1000\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"invalid file mode\", resp[\"error\"])\n}\n\nfunc TestUploadFileHandlerParentDirectoryCreation(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tcontent := base64.StdEncoding.EncodeToString([]byte(\"test\"))\n\tbody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"new/dir/file.txt\", \"content\": \"%s\"}`, content))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", body, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tfilePath := filepath.Join(server.workspace, \"new/dir/file.txt\")\n\t_, err = os.Stat(filePath)\n\trequire.NoError(t, err)\n}\n\nfunc TestListFilesHandlerValidDirectory(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tsubdir := filepath.Join(server.workspace, \"testdir\")\n\trequire.NoError(t, os.MkdirAll(subdir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(subdir, \"file1.txt\"), []byte(\"content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=testdir\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ListFilesResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"testdir\", resp.Path)\n\tassert.Len(t, resp.Files, 1)\n\tassert.Equal(t, \"file1.txt\", resp.Files[0].Name)\n\tassert.False(t, resp.Files[0].IsDir)\n}\n\nfunc TestListFilesHandlerMissingPath(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files\", nil, \"\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing path parameter\", resp[\"error\"])\n}\n\nfunc TestListFilesHandlerPathEscape(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=../escape\", nil, \"\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"invalid path\")\n}\n\nfunc TestListFilesHandlerNonExistent(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=nonexistent\", nil, \"\", validToken)\n\tassert.Equal(t, 500, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"failed to read directory\", resp[\"error\"])\n}\n\nfunc TestDownloadFileHandlerExistingFile(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"testfile.txt\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(\"download content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/testfile.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, \"download content\", w.Body.String())\n}\n\nfunc TestDownloadFileHandlerLeadingSlash(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"absolute.txt\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(\"absolute content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(