uire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=testdir\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ListFilesResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"testdir\", resp.Path)\n\tassert.Len(t, resp.Files, 1)\n\tassert.Equal(t, \"file1.txt\", resp.Files[0].Name)\n\tassert.False(t, resp.Files[0].IsDir)\n}\n\nfunc TestListFilesHandlerMissingPath(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files\", nil, \"\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing path parameter\", resp[\"error\"])\n}\n\nfunc TestListFilesHandlerPathEscape(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=../escape\", nil, \"\", validToken)\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Contains(t, resp[\"error\"], \"invalid path\")\n}\n\nfunc TestListFilesHandlerNonExistent(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=nonexistent\", nil, \"\", validToken)\n\tassert.Equal(t, 500, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"failed to read directory\", resp[\"error\"])\n}\n\nfunc TestDownloadFileHandlerExistingFile(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"testfile.txt\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(\"download content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/testfile.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, \"download content\", w.Body.String())\n}\n\nfunc TestDownloadFileHandlerLeadingSlash(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"absolute.txt\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(\"absolute content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files//absolute.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n}\n\nfunc TestDownloadFileHandlerPathEscape(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/../escape.txt\", nil, \