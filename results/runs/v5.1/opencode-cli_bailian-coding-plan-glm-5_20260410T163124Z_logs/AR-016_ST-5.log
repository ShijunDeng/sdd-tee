.NotEmpty(t, resp[\"uptime\"])\n}\n\nfunc TestLoadPublicKeyFromEnvMissing(t *testing.T) {\n\tos.Unsetenv(PublicKeyEnvVar)\n\n\t_, err := LoadPublicKeyFromEnv()\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"public key environment variable not set\")\n}\n\nfunc TestLoadPublicKeyFromEnvInvalidPEM(t *testing.T) {\n\tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\t_, err := LoadPublicKeyFromEnv()\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"failed to decode PEM block\")\n}\n\nfunc TestLoadPublicKeyFromEnvPKCS1Format(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpkcs1PEM := pem.EncodeToMemory(&pem.Block{\n\t\tType:  \"RSA PUBLIC KEY\",\n\t\tBytes: x509.MarshalPKCS1PublicKey(&privateKey.PublicKey),\n\t})\n\n\tos.Setenv(PublicKeyEnvVar, string(pkcs1PEM))\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\t_, err = LoadPublicKeyFromEnv()\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"expected PUBLIC KEY PEM block\")\n}\n\nfunc TestLoadPublicKeyFromEnvValid(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tdefer os.Unsetenv(PublicKeyEnvVar)\n\n\tpubKey, err := LoadPublicKeyFromEnv()\n\trequire.NoError(t, err)\n\tassert.NotNil(t, pubKey)\n\tassert.Equal(t, &privateKey.PublicKey, pubKey)\n}\n\nfunc TestParseFileModeEmpty(t *testing.T) {\n\tmode, err := parseFileMode(\"\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n}\n\nfunc TestParseFileModeInvalid(t *testing.T) {\n\tmode, err := parseFileMode(\"invalid\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n}\n\nfunc TestParseFileModeTooHigh(t *testing.T) {\n\t_, err := parseFileMode(\"1000\")\n\tassert.Error(t, err)\n\tassert.Equal(t, \"invalid file mode\", err.Error())\n}\n\nfunc TestParseFileModeValid(t *testing.T) {\n\tmode, err := parseFileMode(\"0755\")\n\trequire.NoError(t, err)\n\tassert.Equal(t, os.FileMode(0755), mode)\n}\n\nfunc TestServerShutdown(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer cancel()\n\n\terr := server.Shutdown(ctx)\n\tassert.NoError(t, err)\n}\n\nfunc TestUploadFileHandlerMultipartMissingPath(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := &bytes.Buffer{}\n\twriter := multipart.NewWriter(body)\n\n\tpart, err := writer.CreateFormFile(\"file\", \"upload.txt\")\n\trequire.NoError(t, err)\n\t_, err = part.Write([]byte(\"test file content\"))\n\trequire.NoError(t, err)\n\trequire.NoError(t, writer.Close())\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n\treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing path parameter\", resp[\"error\"])\n}\n\nfunc TestUploadFileHandlerMultipartMissingFile(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tbody := &bytes.Buffer{}\n\twriter := multipart.NewWriter(body)\n\n\trequire.NoError(t, writer.WriteField(\"path\", \"upload.txt\"))\n\trequire.NoError(t, writer.Close())\n\n\treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n\treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n\n\tw := httptest.NewRecorder()\n\tserver.engine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 400, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"missing file\", resp[\"error\"])\n}\n\nfunc TestListFilesHandlerEmptyDirectory(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\temptyDir := filepath.Join(server.workspace, \"emptydir\")\n\trequire.NoError(t, os.MkdirAll(emptyDir, 0755))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=emptydir\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar resp ListFilesResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"emptydir\", resp.Path)\n\tassert.Len(t, resp.Files, 0)\n}\n\nfunc TestDownloadFileHandlerMIMETypeJSON(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"data.json\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(`{\"key\": \"value\"}`), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.json\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, \"application/json\", w.Header().Get(\"Content-Type\"))\n\tassert.Equal(t, `{\"key\": \"value\"}`, w.Body.String())\n}\n\nfunc TestDownloadFileHandlerMIMETypeUnknown(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tfilePath := filepath.Join(server.workspace, \"data.xyz\")\n\trequire.NoError(t, os.WriteFile(filePath, []byte(\"unknown content\"), 0644))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.xyz\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, \"application/octet-stream\", w.Header().Get(\"Content-Type\"))\n\tassert.Equal(t, \"unknown content\", w.Body.String())\n}\n\nfunc TestDownloadFileHandlerSymlinkInsideWorkspace(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\ttargetFile := filepath.Join(server.workspace, \"target.txt\")\n\trequire.NoError(t, os.WriteFile(targetFile, []byte(\"target content\"), 0644))\n\n\tlinkPath := filepath.Join(server.workspace, \"link.txt\")\n\trequire.NoError(t, os.Symlink(targetFile, linkPath))\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/link.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, \"target content\", w.Body.String())\n}\n\nfunc TestFileLifecycle(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\ttestContent := []byte(\"lifecycle test content\")\n\tencodedContent := base64.StdEncoding.EncodeToString(testContent)\n\n\tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"lifecycle/test.txt\", \"content\": \"%s\"}`, encodedContent))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar uploadResp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &uploadResp))\n\tassert.Equal(t, \"lifecycle/test.txt\", uploadResp.Path)\n\n\tw = makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=lifecycle\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar listResp ListFilesResponse\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &listResp))\n\tassert.Equal(t, \"lifecycle\", listResp.Path)\n\tassert.Len(t, listResp.Files, 1)\n\tassert.Equal(t, \"test.txt\", listResp.Files[0].Name)\n\tassert.False(t, listResp.Files[0].IsDir)\n\n\tw = makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/lifecycle/test.txt\", nil, \"\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\tassert.Equal(t, string(testContent), w.Body.String())\n\n\tactualContent, err := os.ReadFile(filepath.Join(server.workspace, \"lifecycle/test.txt\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, testContent, actualContent)\n}\n\nfunc TestUploadLargeFile(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tlargeContent := make([]byte, 30*1024*1024)\n\tfor i := range largeContent {\n\t\tlargeContent[i] = byte(i % 256)\n\t}\n\tencodedContent := base64.StdEncoding.EncodeToString(largeContent)\n\n\tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"large.bin\", \"content\": \"%s\"}`, encodedContent))\n\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n\tassert.Equal(t, 200, w.Code)\n\n\tvar uploadResp FileInfo\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &uploadResp))\n\tassert.Equal(t, \"large.bin\", uploadResp.Path)\n\n\tactualContent, err := os.ReadFile(filepath.Join(server.workspace, \"large.bin\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, largeContent, actualContent)\n}\n\nfunc TestConcurrentFileOperations(t *testing.T) {\n\tserver := setupTestServer(t)\n\n\tauthMgr := server.authManager\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tauthMgr.SetPublicKey(&privateKey.PublicKey)\n\n\tvalidToken := generateTestJWT(privateKey, false)\n\n\tnumOps := 10\n\tdone := make(chan bool, numOps)\n\n\tfor i := 0; i < numOps; i++ {\n\t\tgo func(idx int) {\n\t\t\tcontent := []byte(fmt.Sprintf(\"concurrent content %d\", idx))\n\t\t\tencodedContent := base64.StdEncoding.EncodeToString(content)\n\n\t\t\tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"concurrent%d.txt\", \"content\": \"%s\"}`, idx, encodedContent))\n\t\t\tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n\t\t\tassert.Equal(t, 200, w.Code)\n\n\t\t\tw = makeAuthenticatedRequest(t, server, \"GET\", fmt.Sprintf(\"/api/files/concurrent%d.txt\", idx), nil, \"\", validToken)\n\t\t\tassert.Equal(t, 200, w.Code)\n\t\t\tassert.Equal(t, string(content), w.Body.String())\n\n\t\t\tdone <- true\n\t\t}(i)\n\t}\n\n\tfor i := 0; i < numOps; i++ {\n\t\tselect {\n\t\tcase <-done:\n\t\tcase <-time.After(10 * time.Second):\n\t\t\tt.Fatal(\"concurrent operation timed out\")\n\t\t}\n\t}\n}\n","additions":252,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go","time":{"start":1775862766957,"end":1775862767180}}}}
