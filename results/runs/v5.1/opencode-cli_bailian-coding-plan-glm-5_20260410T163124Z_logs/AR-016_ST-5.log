n621: \n622: func TestListFilesHandlerPathEscape(t *testing.T) {\n623: \tserver := setupTestServer(t)\n624: \n625: \tauthMgr := server.authManager\n626: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n627: \trequire.NoError(t, err)\n628: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n629: \n630: \tvalidToken := generateTestJWT(privateKey, false)\n631: \n632: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=../escape\", nil, \"\", validToken)\n633: \tassert.Equal(t, 400, w.Code)\n634: \n635: \tvar resp map[string]string\n636: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n637: \tassert.Contains(t, resp[\"error\"], \"invalid path\")\n638: }\n639: \n640: func TestListFilesHandlerNonExistent(t *testing.T) {\n641: \tserver := setupTestServer(t)\n642: \n643: \tauthMgr := server.authManager\n644: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n645: \trequire.NoError(t, err)\n646: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n647: \n648: \tvalidToken := generateTestJWT(privateKey, false)\n649: \n650: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=nonexistent\", nil, \"\", validToken)\n651: \tassert.Equal(t, 500, w.Code)\n652: \n653: \tvar resp map[string]string\n654: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n655: \tassert.Equal(t, \"failed to read directory\", resp[\"error\"])\n656: }\n657: \n658: func TestDownloadFileHandlerExistingFile(t *testing.T) {\n659: \tserver := setupTestServer(t)\n660: \n661: \tfilePath := filepath.Join(server.workspace, \"testfile.txt\")\n662: \trequire.NoError(t, os.WriteFile(filePath, []byte(\"download content\"), 0644))\n663: \n664: \tauthMgr := server.authManager\n665: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n666: \trequire.NoError(t, err)\n667: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n668: \n669: \tvalidToken := generateTestJWT(privateKey, false)\n670: \n671: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/testfile.txt\", nil, \"\", validToken)\n672: \tassert.Equal(t, 200, w.Code)\n673: \tassert.Equal(t, \"download content\", w.Body.String())\n674: }\n675: \n676: func TestDownloadFileHandlerLeadingSlash(t *testing.T) {\n677: \tserver := setupTestServer(t)\n678: \n679: \tfilePath := filepath.Join(server.workspace, \"absolute.txt\")\n680: \trequire.NoError(t, os.WriteFile(filePath, []byte(\"absolute content\"), 0644))\n681: \n682: \tauthMgr := server.authManager\n683: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n684: \trequire.NoError(t, err)\n685: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n686: \n687: \tvalidToken := generateTestJWT(privateKey, false)\n688: \n689: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files//absolute.txt\", nil, \"\", validToken)\n690: \tassert.Equal(t, 200, w.Code)\n691: }\n692: \n693: func TestDownloadFileHandlerPathEscape(t *testing.T) {\n694: \tserver := setupTestServer(t)\n695: \n696: \tauthMgr := server.authManager\n697: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n698: \trequire.NoError(t, err)\n699: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n700: \n701: \tvalidToken := generateTestJWT(privateKey, false)\n702: \n703: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/../escape.txt\", nil, \"\", validToken)\n704: \tassert.Equal(t, 400, w.Code)\n705: \n706: \tvar resp map[string]string\n707: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n708: \tassert.Contains(t, resp[\"error\"], \"invalid path\")\n709: }\n710: \n711: func TestDownloadFileHandlerNotFound(t *testing.T) {\n712: \tserver := setupTestServer(t)\n713: \n714: \tauthMgr := server.authManager\n715: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n716: \trequire.NoError(t, err)\n717: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n718: \n719: \tvalidToken := generateTestJWT(privateKey, false)\n720: \n721: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/nonexistent.txt\", nil, \"\", validToken)\n722: \tassert.Equal(t, 404, w.Code)\n723: \n724: \tvar resp map[string]string\n725: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n726: \tassert.Equal(t, \"file not found\", resp[\"error\"])\n727: }\n728: \n729: func TestDownloadFileHandlerIsDirectory(t *testing.T) {\n730: \tserver := setupTestServer(t)\n731: \n732: \tsubdir := filepath.Join(server.workspace, \"subdir\")\n733: \trequire.NoError(t, os.MkdirAll(subdir, 0755))\n734: \n735: \tauthMgr := server.authManager\n736: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n737: \trequire.NoError(t, err)\n738: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n739: \n740: \tvalidToken := generateTestJWT(privateKey, false)\n741: \n742: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/subdir\", nil, \"\", validToken)\n743: \tassert.Equal(t, 400, w.Code)\n744: \n745: \tvar resp map[string]string\n746: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n747: \tassert.Equal(t, \"path is not a file\", resp[\"error\"])\n748: }\n749: \n750: func TestHealthCheckHandler(t *testing.T) {\n751: \tserver := setupTestServer(t)\n752: \n753: \tw := httptest.NewRecorder()\n754: \treq := httptest.NewRequest(\"GET\", \"/health\", nil)\n755: \tserver.engine.ServeHTTP(w, req)\n756: \n757: \tassert.Equal(t, 200, w.Code)\n758: \n759: \tvar resp map[string]interface{}\n760: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n761: \tassert.Equal(t, \"ok\", resp[\"status\"])\n762: \tassert.Equal(t, \"PicoD\", resp[\"service\"])\n763: \tassert.Equal(t, \"0.0.1\", resp[\"version\"])\n764: \tassert.NotEmpty(t, resp[\"uptime\"])\n765: }\n766: \n767: func TestLoadPublicKeyFromEnvMissing(t *testing.T) {\n768: \tos.Unsetenv(PublicKeyEnvVar)\n769: \n770: \t_, err := LoadPublicKeyFromEnv()\n771: \tassert.Error(t, err)\n772: \tassert.Contains(t, err.Error(), \"public key environment variable not set\")\n773: }\n774: \n775: func TestLoadPublicKeyFromEnvInvalidPEM(t *testing.T) {\n776: \tos.Setenv(PublicKeyEnvVar, \"invalid pem data\")\n777: \tdefer os.Unsetenv(PublicKeyEnvVar)\n778: \n779: \t_, err := LoadPublicKeyFromEnv()\n780: \tassert.Error(t, err)\n781: \tassert.Contains(t, err.Error(), \"failed to decode PEM block\")\n782: }\n783: \n784: func TestLoadPublicKeyFromEnvPKCS1Format(t *testing.T) {\n785: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n786: \trequire.NoError(t, err)\n787: \n788: \tpkcs1PEM := pem.EncodeToMemory(&pem.Block{\n789: \t\tType:  \"RSA PUBLIC KEY\",\n790: \t\tBytes: x509.MarshalPKCS1PublicKey(&privateKey.PublicKey),\n791: \t})\n792: \n793: \tos.Setenv(PublicKeyEnvVar, string(pkcs1PEM))\n794: \tdefer os.Unsetenv(PublicKeyEnvVar)\n795: \n796: \t_, err = LoadPublicKeyFromEnv()\n797: \tassert.Error(t, err)\n798: \tassert.Contains(t, err.Error(), \"expected PUBLIC KEY PEM block\")\n799: }\n800: \n801: func TestLoadPublicKeyFromEnvValid(t *testing.T) {\n802: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n803: \trequire.NoError(t, err)\n804: \n805: \tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n806: \n807: \tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n808: \tdefer os.Unsetenv(PublicKeyEnvVar)\n809: \n810: \tpubKey, err := LoadPublicKeyFromEnv()\n811: \trequire.NoError(t, err)\n812: \tassert.NotNil(t, pubKey)\n813: \tassert.Equal(t, &privateKey.PublicKey, pubKey)\n814: }\n815: \n816: func TestParseFileModeEmpty(t *testing.T) {\n817: \tmode, err := parseFileMode(\"\")\n818: \trequire.NoError(t, err)\n819: \tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n820: }\n821: \n822: func TestParseFileModeInvalid(t *testing.T) {\n823: \tmode, err := parseFileMode(\"invalid\")\n824: \trequire.NoError(t, err)\n825: \tassert.Equal(t, os.FileMode(defaultFileMode), mode)\n826: }\n827: \n828: func TestParseFileModeTooHigh(t *testing.T) {\n829: \t_, err := parseFileMode(\"1000\")\n830: \tassert.Error(t, err)\n831: \tassert.Equal(t, \"invalid file mode\", err.Error())\n832: }\n833: \n834: func TestParseFileModeValid(t *testing.T) {\n835: \tmode, err := parseFileMode(\"0755\")\n836: \trequire.NoError(t, err)\n837: \tassert.Equal(t, os.FileMode(0755), mode)\n838: }\n839: \n840: func TestServerShutdown(t *testing.T) {\n841: \tserver := setupTestServer(t)\n842: \n843: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n844: \tdefer cancel()\n845: \n846: \terr := server.Shutdown(ctx)\n847: \tassert.NoError(t, err)\n848: }\n\n(End of file - total 848 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go","time":{"start":1775862626621,"end":1775862626674}}}}
