 build -ldflags=\"-w -s\" -o /app/bin/router ./cmd/router\n240: \n241: # Stage 2: Runtime\n242: FROM alpine:3.19\n243: \n244: RUN apk add --no-cache ca-certificates tzdata\n245: \n246: RUN adduser -D -u 1000 router\n247: \n248: WORKDIR /app\n249: \n250: COPY --from=builder /app/bin/router /app/bin/router\n251: \n252: USER 1000\n253: \n254: EXPOSE 8080\n255: \n256: ENTRYPOINT [\"/app/bin/router\"]\n257: ```\n258: \n259: #### PicoD Dockerfile (`docker/Dockerfile.picod`)\n260: \n261: ```dockerfile\n262: # Stage 1: Builder\n263: FROM golang:1.24 AS builder\n264: \n265: WORKDIR /app\n266: \n267: COPY go.mod go.sum ./\n268: RUN go mod download\n269: \n270: COPY . .\n271: \n272: ENV CGO_ENABLED=0\n273: ENV GOOS=linux\n274: ENV GOARCH=amd64\n275: \n276: RUN go build -ldflags=\"-w -s\" -o /app/bin/picod ./cmd/picod\n277: \n278: # Stage 2: Runtime\n279: FROM ubuntu:24.04\n280: \n281: RUN apt-get update && apt-get install -y --no-install-recommends \\\n282:     python3 \\\n283:     python3-pip \\\n284:     ca-certificates \\\n285:     && rm -rf /var/lib/apt/lists/*\n286: \n287: WORKDIR /app\n288: \n289: COPY --from=builder /app/bin/picod /app/bin/picod\n290: \n291: EXPOSE 8080\n292: \n293: ENTRYPOINT [\"/app/bin/picod\"]\n294: ```\n295: \n296: ### Dockerfile Stage Data Model\n297: \n298: ```yaml\n299: StageDefinition:\n300:   builder:\n301:     base_image: \"golang:1.24-alpine\"\n302:     workdir: \"/app\"\n303:     env_vars:\n304:       CGO_ENABLED: \"0\"\n305:       GOOS: \"${TARGETOS:-linux}\"\n306:       GOARCH: \"${TARGETARCH:-amd64}\"\n307:     cache_mounts:\n308:       - target: \"/go/pkg/mod\"\n309:         type: \"cache\"\n310:         key: \"go-mod-cache\"\n311:       - target: \"/root/.cache/go-build\"\n312:         type: \"cache\"\n313:         key: \"go-build-cache\"\n314:     operations:\n315:       - copy: [\"go.mod\", \"go.sum\", \"./\"]\n316:       - run: \"go mod download\"\n317:       - copy: \".\"\n318:       - build: \"./cmd/<module> -> /app/bin/<binary>\"\n319:     build_flags:\n320:       ldflags: \"-w -s\"\n321:       trimpath: true\n322: \n323:   runtime:\n324:     base_image_alpine: \"alpine:3.19\"\n325:     base_image_ubuntu: \"ubuntu:24.04\"\n326:     packages_alpine:\n327:       - \"ca-certificates\"\n328:       - \"tzdata\"\n329:     packages_ubuntu:\n330:       - \"python3\"\n331:       - \"python3-pip\"\n332:       - \"ca-certificates\"\n333:     user:\n334:       alpine:\n335:         name: \"<service_user>\"\n336:         uid: 1000\n337:         create_command: \"adduser -D -u 1000 <user>\"\n338:       ubuntu:\n339:         name: \"root\"\n340:         uid: 0\n341:     operations:\n342:       - copy_from: \"builder:/app/bin/<binary> -> /app/bin/<binary>\"\n343:       - expose: 8080\n344:       - entrypoint: \"/app/bin/<binary>\"\n345: ```\n346: \n347: ### Build Arguments Schema\n348: \n349: ```yaml\n350: BuildArgs:\n351:   TARGETOS:\n352:     type: string\n353:     default: \"linux\"\n354:     values: [\"linux\", \"windows\", \"darwin\"]\n355:     description: \"Target operating system for cross-compilation\"\n356:     \n357:   TARGETARCH:\n358:     type: string\n359:     default: \"amd64\"\n360:     values: [\"amd64\", \"arm64\", \"arm\", \"386\"]\n361:     description: \"Target architecture for cross-compilation\"\n362:     \n363:   VERSION:\n364:     type: string\n365:     default: \"latest\"\n366:     description: \"Image tag version\"\n367:     \n368:   IMAGE_REPO:\n369:     type: string\n370:     default: \"ghcr.io/volcano-sh/agentcube\"\n371:     description: \"Image repository base URL\"\n372: ```\n373: \n374: ---\n375: \n376: ## API Contracts\n377: \n378: ### Makefile Target Contract\n379: \n380: ```makefile\n381: # Image naming convention\n382: IMAGE_REPO ?= ghcr.io/volcano-sh/agentcube\n383: VERSION ?= $(shell git describe --tags --always --dirty)\n384: \n385: # Build targets\n386: .PHONY: docker-build docker-build-router docker-build-picod docker-build-all\n387: \n388: docker-build:\n389: \tdocker build \\\n390: \t\t-f docker/Dockerfile \\\n391: \t\t-t $(IMAGE_REPO)/workloadmanager:$(VERSION) \\\n392: \t\t--build-arg TARGETOS=linux \\\n393: \t\t--build-arg TARGETARCH=amd64 \\\n394: \t\t.\n395: \n396: docker-build-router:\n397: \tdocker build \\\n398: \t\t-f docker/Dockerfile.router \\\n399: \t\t-t $(IMAGE_REPO)/router:$(VERSION) \\\n400: \t\t--build-arg TARGETOS=linux \\\n401: \t\t--build-arg TARGETARCH=amd64 \\\n402: \t\t.\n403: \n404: docker-build-picod:\n405: \tdocker build \\\n406: \t\t-f docker/Dockerfile.picod \\\n407: \t\t-t $(IMAGE_REPO)/picod:$(VERSION) \\\n408: \t\t.\n409: \n410: docker-build-all: docker-build docker-build-router docker-build-picod\n411: \n412: # Multi-arch buildx targets\n413: .PHONY: docker-buildx-push docker-buildx-push-router docker-buildx-push-picod\n414: \n415: docker-buildx-push:\n416: \tdocker buildx build \\\n417: \t\t-f docker/Dockerfile \\\n418: \t\t--platform linux/amd64,linux/arm64 \\\n419: \t\t--build-arg TARGETOS=linux \\\n420: \t\t--build-arg TARGETARCH=amd64 \\\n421: \t\t--push \\\n422: \t\t-t $(IMAGE_REPO)/workloadmanager:$(VERSION) \\\n423: \t\t.\n424: \n425: docker-buildx-push-router:\n426: \tdocker buildx build \\\n427: \t\t-f docker/Dockerfile.router \\\n428: \t\t--platform linux/amd64,linux/arm64 \\\n429: \t\t--push \\\n430: \t\t-t $(IMAGE_REPO)/router:$(VERSION) \\\n431: \t\t.\n432: \n433: docker-buildx-push-picod:\n434: \tdocker buildx build \\\n435: \t\t-f docker/Dockerfile.picod \\\n436: \t\t--platform linux/amd64,linux/arm64 \\\n437: \t\t--push \\\n438: \t\t-t $(IMAGE_REPO)/picod:$(VERSION) \\\n439: \t\t.\n440: ```\n441: \n442: ### Docker Build Command Interface\n443: \n444: ```yaml\n445: DockerBuildCommand:\n446:   parameters:\n447:     dockerfile:\n448:       type: string\n449:       required: true\n450:       values: [\"docker/Dockerfile\", \"docker/Dockerfile.router\", \"docker/Dockerfile.picod\"]\n451:     tag:\n452:       type: string\n453:       required: true\n454:       pattern: \"${IMAGE_REPO}/${IMAGE_NAME}:${VERSION}\"\n455:     context:\n456:       type: string\n457:       default: \".\"\n458:       description: \"Build context directory (repository root)\"\n459:     build_args:\n460:       TARGETOS:\n461:         type: string\n462:         optional: true\n463:       TARGETARCH:\n464:         type: string\n465:         optional: true\n466:     platform:\n467:       type: string\n468:       optional: true\n469:       pattern: \"linux/amd64,linux/arm64\"\n470:       description: \"Multi-arch platform specification\"\n471: \n472:   outputs:\n473:     image_id:\n474:       type: string\n475:       description: \"Built image SHA256 digest\"\n476:     image_size:\n477:       type: integer\n478:       unit: \"bytes\"\n479:       description: \"Final image size\"\n480:     layers:\n481:       type: integer\n482:       description: \"Number of layers in final image\"\n483: ```\n484: \n485: ### Helm Values Contract\n486: \n487: ```yaml\n488: # manifests/charts/base/values.yaml\n489: images:\n490:   workloadmanager:\n491:     repository: ghcr.io/volcano-sh/agentcube/workloadmanager\n492:     tag: latest\n493:     pullPolicy: IfNotPresent\n494:     \n495:   router:\n496:     repository: ghcr.io/volcano-sh/agentcube/router\n497:     tag: latest\n498:     pullPolicy: IfNotPresent\n499:     \n500:   picod:\n501:     repository: ghcr.io/volcano-sh/agentcube/picod\n502:     tag: latest\n503:     pullPolicy: IfNotPresent\n504: ```\n505: \n506: ---\n507: \n508: ## Error Handling\n509: \n510: ### Build Error Categories\n511: \n512: | Error Category | Description | Detection | Recovery Action |\n513: |----------------|-------------|-----------|-----------------|\n514: | `BuildArgError` | Invalid/missing build arguments | Docker build start | Validate args before build |\n515: | `CopyError` | Source file not found in context | `COPY` instruction | Check file existence in context |\n516: | `GoBuildError` | Go compilation failure | `go build` command | Review compilation logs, fix source |\n517: | `ModDownloadError` | Go module download failure | `go mod download` | Check network, verify go.mod |\n518: | `UserCreateError` | Non-root user creation failure | `adduser` command | Alpine package availability |\n519: | `CacheMountError` | BuildKit cache mount failure | `--mount=type=cache` | Enable BuildKit (`DOCKER_BUILDKIT=1`) |\n520: | `ImagePullError` | Base image pull failure | `FROM` instruction | Check registry connectivity |\n521: | `CrossArchError` | Cross-architecture compilation failure | `TARGETARCH` mismatch | Verify Go cross-compilation support |\n522: \n523: ### Build Failure Handling Pattern\n524: \n525: ```bash\n526: #!/bin/bash\n527: # build-with-error-handling.sh\n528: \n529: set -euo pipefail\n530: \n531: build_image() {\n532:     local dockerfile=\"$1\"\n533:     local tag=\"$2\"\n534:     \n535:     echo \"Building image from $dockerfile...\"\n536:     \n537:     if ! docker build -f \"$dockerfile\" -t \"$tag\" .; then\n538:         echo \"ERROR: Build failed for $dockerfile\"\n539:         \n540:         docker build -f \"$dockerfile\" -t \"$tag\" . --no-cache\n541:         \n542:         if ! docker build -f \"$dockerfile\" -t \"$tag\" . --no-cache; then\n543:             echo \"ERROR: Build failed even with --no-cache\"\n544:             return 1\n545:         fi\n546:     fi\n547:     \n548:     local image_size=$(docker image inspect \"$tag\" --format='{{.Size}}')\n549:     echo \"Image size: $(numfmt --to=iec $image_size)\"\n550:     \n551:     if [[ $image_size -gt 100000000 ]]; then\n552:         echo \"WARNING: Image exceeds 100MB size target\"\n553:     fi\n554:     \n555:     return 0\n556: }\n557: \n558: main() {\n559:     local failed=0\n560:     \n561:     for image in workloadmanager router picod; do\n562:         local dockerfile=\"docker/Dockerfile\"\n563:         if [[ \"$image\" != \"workloadmanager\" ]]; then\n564:             dockerfile=\"docker/Dockerfile.$image\"\n565:         fi\n566:         \n567:         if ! build_image \"$dockerfile\" \"agentcube/$image:test\"; then\n568:             failed=1\n569:         fi\n570:     done\n571:     \n572:     if [[ $failed -eq 1 ]]; then\n573:         echo \"ERROR: One or more builds failed\"\n574:         exit 1\n575:     fi\n576:     \n577:     echo \"All builds completed successfully\"\n578: }\n579: \n580: main \"$@\"\n581: ```\n582: \n583: ### Runtime Error Detection\n584: \n585: | Error | Detection | Container Behavior | Remediation |\n586: |-------|-----------|-------------------|-------------|\n587: | `EntrypointNotFound` | Binary not in expected path | Container exits immediately | Verify COPY instruction |\n588: | `PermissionDenied` | UID lacks execute permission | Exit code 126 | Check USER directive |\n589: | `PortBindFailed` | Port 8080 already bound | Container exits with error | Check port conflicts |\n590: | `MissingDependency` | Required package not installed | Binary execution fails | Verify RUN apk/apt install |\n591: \n592: ### Health Check Contract\n593: \n594: ```dockerfile\n595: # Optional health check for runtime stage\n596: HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \\\n597:     CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1\n598: ```\n599: \n600: ---\n601: \n602: ## Testing Strategy\n603: \n604: ### Test Categories\n605: \n606: | Category | Scope | Tools | Purpose |\n607: |----------|-------|-------|---------|\n608: | Dockerfile Syntax | Dockerfile validity | `docker build --check`, `hadolint` | Validate Dockerfile syntax and best practices |\n609: | Build Execution | Full build process | `docker build`, `make docker-build-*` | Verify images build successfully |\n610: | Image Size | Runtime image size | `docker image inspect`, size comparison | Ensure size targets met (<50MB Alpine, <100MB Ubuntu) |\n611: | Runtime Execution | Container startup | `docker run`, health checks | Verify container runs correctly |\n612: | Security Scan | Vulnerability detection | `trivy`, `docker scout` | Identify CVEs in base images |\n613: | User Isolation | Non-root execution | `docker exec`, UID check | Verify security context |\n614: | Cross-Arch | Multi-arch builds | `docker buildx`, Kind cluster | Test amd64/arm64 builds |\n615: | E2E Integration | Full deployment | Kind, Helm, E2E tests | Verify images work in cluster |\n616: \n617: ### Unit Tests: Dockerfile Syntax\n618: \n619: ```bash\n620: #!/bin/bash\n621: # test_dockerfile_syntax.sh\n622: \n623: test_dockerfile_exists() {\n624:     for dockerfile in docker/Dockerfile docker/Dockerfile.router docker/Dockerfile.picod; do\n625:         if [[ ! -f \"$dockerfile\" ]]; then\n626:             echo \"FAIL: $dockerfile does not exist\"\n627:             return 1\n628:         fi\n629:         echo \"PASS: $dockerfile exists\"\n630:     done\n631:     return 0\n632: }\n633: \n634: test_builder_base_image() {\n635:     for dockerfile in docker/Dockerfile docker/Dockerfile.router; do\n636:         if ! grep -q \"FROM golang:1.24\" \"$dockerfile\"; then\n637:             echo \"FAIL: $dockerfile missing golang:1.24 builder\"\n638:             return 1\n639:         fi\n640:         echo \"PASS: $dockerfile has correct builder base\"\n641:     done\n642:     return 0\n643: }\n644: \n645: test_runtime_base_image() {\n646:     local expected_base=\"alpine:3.19\"\n647:     \n648:     for dockerfile in docker/Dockerfile docker/Dockerfile.router; do\n649:         if ! grep -q \"FROM $expected_base\" \"$dockerfile\"; then\n650:             echo \"FAIL: $dockerfile missing $expected_base runtime\"\n651:             return 1\n652:         fi\n653:         echo \"PASS: $dockerfile has Alpine runtime base\"\n654:     done\n655:     \n656:     if ! grep -q \"FROM ubuntu:24.04\" docker/Dockerfile.picod; then\n657:         echo \"FAIL: docker/Dockerfile.picod missing ubuntu:24.04 runtime\"\n658:         return 1\n659:     fi\n660:     echo \"PASS: docker/Dockerfile.picod has Ubuntu runtime base\"\n661:     \n662:     return 0\n663: }\n664: \n665: test_cgo_disabled() {\n666:     for dockerfile in docker/Dockerfile docker/Dockerfile.router docker/Dockerfile.picod; do\n667:         if ! grep -q \"CGO_ENABLED=0\" \"$dockerfile\"; then\n668:             echo \"FAIL: $dockerfile missing CGO_ENABLED=0\"\n669:             return 1\n670:         fi\n671:         echo \"PASS: $dockerfile has CGO_ENABLED=0\"\n672:     done\n673:     return 0\n674: }\n675: \n676: test_non_root_user() {\n677:     for dockerfile in docker/Dockerfile docker/Dockerfile.router; do\n678:         if ! grep -q \"USER 1000\" \"$dockerfile\"; then\n679:             echo \"FAIL: $dockerfile missing USER 1000\"\n680:             return 1\n681:         fi\n682:         echo \"PASS: $dockerfile has non-root user directive\"\n683:     done\n684:     \n685:     if grep -q \"USER 1000\" docker/Dockerfile.picod; then\n686:         echo \"FAIL: docker/Dockerfile.picod should NOT have USER 1000\"\n687:         return 1\n688:     fi\n689:     echo \"PASS: docker/Dockerfile.picod runs as root (expected)\"\n690:     \n691:     return 0\n692: }\n693: \n694: test_ldflags_optimization() {\n695:     for dockerfile in docker/Dockerfile docker/Dockerfile.router docker/Dockerfile.picod; do\n696:         if ! grep -q 'ldflags=\"-w -s\"' \"$dockerfile\"; then\n697:             echo \"FAIL: $dockerfile missing -ldflags=\\\"-w -s\\\"\"\n698:             return 1\n699:         fi\n700:         echo \"PASS: $dockerfile has binary optimization ldflags\"\n701:     done\n702:     return 0\n703: }\n704: \n705: main() {\n706:     local failed=0\n707:     \n708:     test_dockerfile_exists || failed=1\n709:     test_builder_base_image || failed=1\n710:     test_runtime_base_image || failed=1\n711:     test_cgo_disabled || failed=1\n712:     test_non_root_user || failed=1\n713:     test_ldflags_optimization || failed=1\n714:     \n715:     if [[ $failed -eq 1 ]]; then\n716:         echo \"TESTS FAILED\"\n717:         exit 1\n718:     fi\n719:     \n720:     echo \"ALL TESTS PASSED\"\n721:     exit 0\n722: }\n723: \n724: main\n725: ```\n726: \n727: ### Integration Tests: Build Execution\n728: \n729: ```bash\n730: #!/bin/bash\n731: # test_docker_build.sh\n732: \n733: set -euo pipefail\n734: \n735: cleanup() {\n736:     docker rmi -f agentcube-test-workloadmanager agentcube-test-router agentcube-test-picod 2>/dev/null || true\n737: }\n738: \n739: trap cleanup EXIT\n740: \n741: test_workloadmanager_build() {\n742:     echo \"Testing workloadmanager build...\"\n743:     \n744:     if ! docker build -f docker/Dockerfile -t agentcube-test-workloadmanager .; then\n745:         echo \"FAIL: workloadmanager build failed\"\n746:         return 1\n747:     fi\n748:     \n749:     local size=$(docker image inspect agentcube-test-workloadmanager --format='{{.Size}}')\n750:     if [[ $size -gt 50000000 ]]; then\n751:         echo \"FAIL: workloadmanager image exceeds 50MB: $(numfmt --to=iec $size)\"\n752:         return 1\n753:     fi\n754:     \n755:     echo \"PASS: workloadmanager build succeeded, size: $(numfmt --to=iec $size)\"\n756:     return 0\n757: }\n758: \n759: test_router_build() {\n760:     echo \"Testing router build...\"\n761:     \n762:     if ! docker build -f docker/Dockerfile.router -t agentcube-test-router .; then\n763:         echo \"FAIL: router build failed\"\n764:         return 1\n765:     fi\n766:     \n767:     local size=$(docker image inspect agentcube-test-router --format='{{.Size}}')\n768:     if [[ $size -gt 50000000 ]]; then\n769:         echo \"FAIL: router image exceeds 50MB: $(numfmt --to=iec $size)\"\n770:         return 1\n771:     fi\n772:     \n773:     echo \"PASS: router build succeeded, size: $(numfmt --to=iec $size)\"\n774:     return 0\n775: }\n776: \n777: test_picod_build() {\n778:     echo \"Testing picod build...\"\n779:     \n780:     if ! docker build -f docker/Dockerfile.picod -t agentcube-test-picod .; then\n781:         echo \"FAIL: picod build failed\"\n782:         return 1\n783:     fi\n784:     \n785:     local size=$(docker image inspect agentcube-test-picod --format='{{.Size}}')\n786:     if [[ $size -gt 100000000 ]]; then\n787:         echo \"FAIL: picod image exceeds 100MB: $(numfmt --to=iec $size)\"\n788:         return 1\n789:     fi\n790:     \n791:     echo \"PASS: picod build succeeded, size: $(numfmt --to=iec $size)\"\n792:     return 0\n793: }\n794: \n795: test_binary_exists() {\n796:     local image=\"$1\"\n797:     local binary=\"$2\"\n798:     \n799:     if ! docker run --rm \"$image\" test -f \"/app/bin/$binary\"; then\n800:         echo \"FAIL: $binary not found in $image\"\n801:         return 1\n802:     fi\n803:     echo \"PASS: $binary exists in $image\"\n804:     return 0\n805: }\n806: \n807: test_user_isolation() {\n808:     local image=\"$1\"\n809:     local expected_uid=\"$2\"\n810:     \n811:     local uid=$(docker run --rm \"$image\" id -u)\n812:     if [[ \"$uid\" != \"$expected_uid\" ]]; then\n813:         echo \"FAIL: $image running as UID $uid, expected $expected_uid\"\n814:         return 1\n815:     fi\n816:     echo \"PASS: $image running as correct UID $uid\"\n817:     return 0\n818: }\n819: \n820: test_no_go_toolchain() {\n821:     local image=\"$1\"\n822:     \n823:     if docker run --rm \"$image\" which go 2>/dev/null; then\n824:         echo \"FAIL: $image contains Go toolchain\"\n825:         return 1\n826:     fi\n827:     echo \"PASS: $image does not contain Go toolchain\"\n828:     return 0\n829: }\n830: \n831: test_no_source_files() {\n832:     local image=\"$1\"\n833:     \n834:     if docker run --rm \"$image\" find /app -name \"*.go\" -type f 2>/dev/null | grep -q .; then\n835:         echo \"FAIL: $image contains Go source files\"\n836:         return 1\n837:     fi\n838:     echo \"PASS: $image does not contain Go source files\"\n839:     return 0\n840: }\n841: \n842: main() {\n843:     local failed=0\n844:     \n845:     test_workloadmanager_build || failed=1\n846:     test_router_build || failed=1\n847:     test_picod_build || failed=1\n848:     \n849:     test_binary_exists agentcube-test-workloadmanager workloadmanager || failed=1\n850:     test_binary_exists agentcube-test-router router || failed=1\n851:     test_binary_exists agentcube-test-picod picod || failed=1\n852:     \n853:     test_user_isolation agentcube-test-workloadmanager 1000 || failed=1\n854:     test_user_isolation agentcube-test-router 1000 || failed=1\n855:     test_user_isolation agentcube-test-picod 0 || failed=1\n856:     \n857:     test_no_go_toolchain agentcube-test-workloadmanager || failed=1\n858:     test_no_go_toolchain agentcube-test-router || failed=1\n859:     test_no_source_files agentcube-test-workloadmanager || failed=1\n860:     test_no_source_files agentcube-test-router || failed=1\n861:     \n862:     if [[ $failed -eq 1 ]]; then\n863:         echo \"INTEGRATION TESTS FAILED\"\n864:         exit 1\n865:     fi\n866:     \n867:     echo \"ALL INTEGRATION TESTS PASSED\"\n868:     exit 0\n869: }\n870: \n871: main\n872: ```\n873: \n874: ### E2E Tests: Kind Cluster Deployment\n875: \n876: ```bash\n877: #!/bin/bash\n878: # test_kind_deployment.sh\n879: \n880: set -euo pipefail\n881: \n882: KIND_CLUSTER_NAME=\"agentcube-test\"\n883: \n884: cleanup() {\n885:     kind delete cluster --name \"$KIND_CLUSTER_NAME\" 2>/dev/null || true\n886: }\n887: \n888: trap cleanup EXIT\n889: \n890: create_kind_cluster() {\n891:     echo \"Creating Kind cluster...\"\n892:     kind create cluster --name \"$KIND_CLUSTER_NAME\" --wait 60s\n893: }\n894: \n895: build_and_load_images() {\n896:     echo \"Building images...\"\n897:     make docker-build-all\n898:     \n899:     echo \"Loading images into Kind...\"\n900:     kind load docker-image \\\n901:         ghcr.io/volcano-sh/agentcube/workloadmanager:latest \\\n902:         --name \"$KIND_CLUSTER_NAME\"\n903:     kind load docker-image \\\n904:         ghcr.io/volcano-sh/agentcube/router:latest \\\n905:         --name \"$KIND_CLUSTER_NAME\"\n906:     kind load docker-image \\\n907:         ghcr.io/volcano-sh/agentcube/picod:latest \\\n908:         --name \"$KIND_CLUSTER_NAME\"\n909: }\n910: \n911: deploy_with_helm() {\n912:     echo \"Deploying with Helm...\"\n913:     helm upgrade --install agentcube manifests/charts/base \\\n914:         --namespace agentcube --create-namespace \\\n915:         --set images.workloadmanager.tag=latest \\\n916:         --set images.router.tag=latest \\\n917:         --set images.picod.tag=latest \\\n918:         --wait --timeout 300s\n919: }\n920: \n921: verify_deployments() {\n922:     echo \"Verifying deployments...\"\n923:     \n924:     local deployments=\"workloadmanager router\"\n925:     for deploy in $deployments; do\n926:         if ! kubectl rollout status deployment/$deploy -n agentcube --timeout=60s; then\n927:             echo \"FAIL: $deploy deployment not ready\"\n928:             return 1\n929:         fi\n930:         echo \"PASS: $deploy deployment ready\"\n931:     done\n932:     \n933:     return 0\n934: }\n935: \n936: verify_pods_running() {\n937:     echo \"Verifying pods...\"\n938:     \n939:     local pods=$(kubectl get pods -n agentcube -o jsonpath='{.items[*].metadata.name}')\n940:     for pod in $pods; do\n941:         local uid=$(kubectl get pod \"$pod\" -n agentcube -o jsonpath='{.spec.containers[*].securityContext.runAsUser}')\n942:         if [[ -n \"$uid\" ]]; then\n943:             echo \"Pod $pod running with securityContext.runAsUser=$uid\"\n944:         fi\n945:     done\n946:     \n947:     return 0\n948: }\n949: \n950: main() {\n951:     local failed=0\n952:     \n953:     create_kind_cluster || failed=1\n954:     build_and_load_images || failed=1\n955:     deploy_with_helm || failed=1\n956:     verify_deployments || failed=1\n957:     verify_pods_running || failed=1\n958:     \n959:     if [[ $failed -eq 1 ]]; then\n960:         echo \"E2E TESTS FAILED\"\n961:         exit 1\n962:     fi\n963:     \n964:     echo \"ALL E2E TESTS PASSED\"\n965:     exit 0\n966: }\n967: \n968: main\n969: ```\n970: \n971: ---\n972: \n973: ## File Structure\n974: \n975: | Path | Role |\n976: |------|------|\n977: | `docker/Dockerfile` | Workload Manager multi-stage build (builder ‚Üí runtime) |\n978: | `docker/Dockerfile.router` | Router multi-stage build (builder ‚Üí runtime) |\n979: | `docker/Dockerfile.picod` | PicoD multi-stage build (builder ‚Üí runtime) |\n980: | `Makefile` | Build targets: `docker-build`, `docker-build-router`, `docker-build-picod`, `docker-build-all` |\n981: | `manifests/charts/base/values.yaml` | Helm chart image repository/tag defaults |\n982: | `.github/workflows/main.yml` | CI workflow referencing `make docker-build` |\n983: | `.github/workflows/build-push-release.yml` | Release workflow for multi-arch builds |\n984: \n985: ---\n986: \n987: ## Dependencies\n988: \n989: | Package | Version | Purpose |\n990: |---------|---------|---------|\n991: | `golang:1.24-alpine` | 1.24 | Builder stage base for Go compilation |\n992: | `alpine:3.19` | 3.19 | Minimal runtime base (~5MB) |\n993: | `ubuntu:24.04` | 24.04 | Runtime base for picod (Python3 dependency) |\n994: | `ca-certificates` | latest | TLS certificate bundle |\n995: | `tzdata` | latest | Timezone data (Alpine) |\n996: | `python3` | system | Code execution dependency (Ubuntu/picod) |\n997: | `docker` | >=20.10 | BuildKit multi-stage support |\n998: | `buildx` | latest | Multi-arch cross-compilation |\n999: \n1000: ---\n1001: \n1002: ## Implementation Notes\n1003: \n1004: ### BuildKit Cache Optimization\n1005: \n1006: 1. **Go Module Cache**: Mount `/go/pkg/mod` as cache to persist module downloads across builds\n1007: 2. **Go Build Cache**: Mount `/root/.cache/go-build` to cache compiled artifacts\n1008: 3. **Cache Key**: Cache keyed by `go.mod`/`go.sum` hash for automatic invalidation\n1009: \n1010: ```dockerfile\n1011: RUN --mount=type=cache,target=/go/pkg/mod \\\n1012:     go mod download\n1013: \n1014: RUN --mount=type=cache,target=/root/.cache/go-build \\\n1015:     go build -ldflags=\"-w -s\" -o /app/bin/<binary> ./cmd/<module>\n1016: ```\n1017: \n1018: ### Binary Size Optimization\n1019: \n1020: | Flag | Effect |\n1021: |------|--------|\n1022: | `-w` | Strip DWARF debug information |\n1023: | `-s` | Strip symbol table |\n1024: | `CGO_ENABLED=0` | Disable CGO for static-like compilation |\n1025: | `trimpath` | Remove file system paths from binary |\n1026: \n1027: ### Security Considerations\n1028: \n1029: 1. **Non-root User**: Alpine images run as UID 1000 to reduce attack surface\n1030: 2. **Minimal Packages**: Only `ca-certificates` and `tzdata` in runtime\n1031: 3. **No Shell Required**: Binary entrypoint without shell wrapper\n1032: 4. **PicoD Exception**: Runs as root for sandbox pod management permissions\n1033: \n1034: ### Cross-Compilation\n1035: \n1036: ```bash\n1037: # amd64\n1038: docker build --build-arg TARGETOS=linux --build-arg TARGETARCH=amd64 ...\n1039: \n1040: # arm64\n1041: docker build --build-arg TARGETOS=linux --build-arg TARGETARCH=arm64 ...\n1042: \n1043: # Multi-arch with buildx\n1044: docker buildx build --platform linux/amd64,linux/arm64 ...\n1045: ```\n1046: \n1047: ### CI Integration\n1048: \n1049: ```yaml\n1050: # .github/workflows/build-push-release.yml\n1051: - name: Build and push images\n1052:   run: |\n1053:     make docker-buildx-push VERSION=${{ github.ref_name }}\n1054: ```\n1055: \n1056: ---\n1057: \n1058: ## References\n1059: \n1060: - Spec: `changes/AR-032/spec.md`\n1061: - Delta Spec: `changes/AR-032/delta-spec.md`\n1062: - Proposal: `changes/AR-032/proposal.md`\n1063: - Tasks: `changes/AR-032/tasks.md`\n1064: - Docker multi-stage builds: https://docs.docker.com/build/building/multi-stage/\n1065: - BuildKit cache mounts: https://docs.docker.com/build/buildkit/#cache-mounts\n1066: - Go cross-compilation: https://go.dev/doc/install/source#environment\n\n(End of file - total 1066 lines)\n</content>","metadata":{"preview":"# AR-032 ‚Äî Dockerfile Â§öÈò∂ÊÆµÊûÑÂª∫ Design\n\n## Overview\n\n| Item | Value |\n|------|-------|\n| AR | AR-032 ‚Äî Dockerfile Â§öÈò∂ÊÆµÊûÑÂª∫ (3 images) |\n| Module | `docker` |\n| Language | Dockerfile |\n| Size | S |\n| Stage | ST-1 (completed) |\n\nMulti-stage Dockerfile patterns for AgentCube's three core container images, optimizing for build separation, security, build efficiency, and consistency across workloadmanager, router, and picod images.\n\n---\n\n## Architecture\n\n### High-Level Architecture\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-032/design.md","time":{"start":1775886798151,"end":1775886798170}}}}
