\[\"/app/bin/picod\"\\]' docker/Dockerfile.picod && echo \"  ‚úì Dockerfile.picod entrypoint correct\" && \\\necho \"\" && \\\necho \"13. Check EXPOSE 8080:\" && \\\ngrep \"EXPOSE 8080\" docker/Dockerfile && echo \"  ‚úì Dockerfile exposes 8080\" && \\\ngrep \"EXPOSE 8080\" docker/Dockerfile.router && echo \"  ‚úì Dockerfile.router exposes 8080\" && \\\ngrep \"EXPOSE 8080\" docker/Dockerfile.picod && echo \"  ‚úì Dockerfile.picod exposes 8080\"","description":"Verify packages, users, binaries, entrypoints"},"output":"9. Check runtime packages:\nRUN apk add --no-cache ca-certificates tzdata\n  ‚úì Dockerfile has ca-certificates + tzdata\nRUN apk add --no-cache ca-certificates tzdata\n  ‚úì Dockerfile.router has ca-certificates + tzdata\n    python3 \\\n    python3-pip \\\n  ‚úì Dockerfile.picod has python3\n    python3-pip \\\n  ‚úì Dockerfile.picod has python3-pip\n    ca-certificates \\\n  ‚úì Dockerfile.picod has ca-certificates\n\n10. Check non-root user creation (Alpine):\nRUN adduser -D -u 1000 apiserver\n  ‚úì Dockerfile creates apiserver user\nRUN adduser -D -u 1000 router\n  ‚úì Dockerfile.router creates router user\n\n11. Check binaries built:\n    go build -ldflags=\"-w -s\" -trimpath -o /app/bin/workloadmanager ./cmd/workload-manager\n  ‚úì Dockerfile builds workloadmanager\n    go build -ldflags=\"-w -s\" -trimpath -o /app/bin/router ./cmd/router\n  ‚úì Dockerfile.router builds router\nRUN go build -ldflags=\"-w -s\" -trimpath -o /app/bin/picod ./cmd/picod\n  ‚úì Dockerfile.picod builds picod\n\n12. Check ENTRYPOINT:\nENTRYPOINT [\"/app/bin/workloadmanager\"]\n  ‚úì Dockerfile entrypoint correct\nENTRYPOINT [\"/app/bin/router\"]\n  ‚úì Dockerfile.router entrypoint correct\nENTRYPOINT [\"/app/bin/picod\"]\n  ‚úì Dockerfile.picod entrypoint correct\n\n13. Check EXPOSE 8080:\nEXPOSE 8080\n  ‚úì Dockerfile exposes 8080\nEXPOSE 8080\n  ‚úì Dockerfile.router exposes 8080\nEXPOSE 8080\n  ‚úì Dockerfile.picod exposes 8080\n","metadata":{"output":"9. Check runtime packages:\nRUN apk add --no-cache ca-certificates tzdata\n  ‚úì Dockerfile has ca-certificates + tzdata\nRUN apk add --no-cache ca-certificates tzdata\n  ‚úì Dockerfile.router has ca-certificates + tzdata\n    python3 \\\n    python3-pip \\\n  ‚úì Dockerfile.picod has python3\n    python3-pip \\\n  ‚úì Dockerfile.picod has python3-pip\n    ca-certificates \\\n  ‚úì Dockerfile.picod has ca-certificates\n\n10. Check non-root user creation (Alpine):\nRUN adduser -D -u 1000 apiserver\n  ‚úì Dockerfile creates apiserver user\nRUN adduser -D -u 1000 router\n  ‚úì Dockerfile.router creates router user\n\n11. Check binaries built:\n    go build -ldflags=\"-w -s\" -trimpath -o /app/bin/workloadmanager ./cmd/workload-manager\n  ‚úì Dockerfile builds workloadmanager\n    go build -ldflags=\"-w -s\" -trimpath -o /app/bin/router ./cmd/router\n  ‚úì Dockerfile.router builds router\nRUN go build -ldflags=\"-w -s\" -trimpath -o /app/bin/picod ./cmd/picod\n  ‚úì Dockerfile.picod builds picod\n\n12. Check ENTRYPOINT:\nENTRYPOINT [\"/app/bin/workloadmanager\"]\n  ‚úì Dockerfile entrypoint correct\nENTRYPOINT [\"/app/bin/router\"]\n  ‚úì Dockerfile.router entrypoint correct\nENTRYPOINT [\"/app/bin/picod\"]\n  ‚úì Dockerfile.picod entrypoint correct\n\n13. Check EXPOSE 8080:\nEXPOSE 8080\n  ‚úì Dockerfile exposes 8080\nEXPOSE 8080\n  ‚úì Dockerfile.router exposes 8080\nEXPOSE 8080\n  ‚úì Dockerfile.picod exposes 8080\n","exit":0,"description":"Verify packages, users, binaries, entrypoints","truncated":false},"title":"Verify packages, users, binaries, entrypoints","time":{"start":1775886840421,"end":1775886840567}}}}
