ent-go (required)\n\n16. Check trimpath optimization:\n    go build -ldflags=\"-w -s\" -trimpath -o /app/bin/workloadmanager ./cmd/workload-manager\n  ‚úì Dockerfile has trimpath\n    go build -ldflags=\"-w -s\" -trimpath -o /app/bin/router ./cmd/router\n  ‚úì Dockerfile.router has trimpath\nRUN go build -ldflags=\"-w -s\" -trimpath -o /app/bin/picod ./cmd/picod\n  ‚úì Dockerfile.picod has trimpath\n","metadata":{"output":"14. Check COPY --from=builder (binary extraction):\nCOPY --from=builder /app/bin/workloadmanager /app/bin/workloadmanager\n  ‚úì Dockerfile copies binary from builder\nCOPY --from=builder /app/bin/router /app/bin/router\n  ‚úì Dockerfile.router copies binary from builder\nCOPY --from=builder /app/bin/picod /app/bin/picod\n  ‚úì Dockerfile.picod copies binary from builder\n\n15. Check Router-specific client-go COPY:\nCOPY client-go/ client-go/\n  ‚úì Dockerfile.router copies client-go (required)\n\n16. Check trimpath optimization:\n    go build -ldflags=\"-w -s\" -trimpath -o /app/bin/workloadmanager ./cmd/workload-manager\n  ‚úì Dockerfile has trimpath\n    go build -ldflags=\"-w -s\" -trimpath -o /app/bin/router ./cmd/router\n  ‚úì Dockerfile.router has trimpath\nRUN go build -ldflags=\"-w -s\" -trimpath -o /app/bin/picod ./cmd/picod\n  ‚úì Dockerfile.picod has trimpath\n","exit":0,"description":"Verify COPY from builder, client-go, trimpath","truncated":false},"title":"Verify COPY from builder, client-go, trimpath","time":{"start":1775886840423,"end":1775886840570}}}}
