                  ‚îÇ   ‚îÇ\n40: ‚îÇ   ‚îÇ   FROM golang:1.24-alpine AS builder                                     ‚îÇ   ‚îÇ\n41: ‚îÇ   ‚îÇ   ‚îú‚îÄ WORKDIR /app                                                        ‚îÇ   ‚îÇ\n42: ‚îÇ   ‚îÇ   ‚îú‚îÄ COPY go.mod go.sum ./                                               ‚îÇ   ‚îÇ\n43: ‚îÇ   ‚îÇ   ‚îú‚îÄ RUN --mount=type=cache,target=/go/pkg/mod go mod download          ‚îÇ   ‚îÇ\n44: ‚îÇ   ‚îÇ   ‚îú‚îÄ COPY . .                                                            ‚îÇ   ‚îÇ\n45: ‚îÇ   ‚îÇ   ‚îú‚îÄ ENV CGO_ENABLED=0                                                   ‚îÇ   ‚îÇ\n46: ‚îÇ   ‚îÇ   ‚îú‚îÄ RUN go build -ldflags=\"-w -s\" -o /app/bin/<binary> ./cmd/<module>   ‚îÇ   ‚îÇ\n47: ‚îÇ   ‚îî‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îò   ‚îÇ\n48: ‚îÇ                                    ‚îÇ                                              ‚îÇ\n49: ‚îÇ                                    ‚ñº                                              ‚îÇ\n50: ‚îÇ   ‚îå‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îê   ‚îÇ\n51: ‚îÇ   ‚îÇ                        Stage 2: Runtime                                  ‚îÇ   ‚îÇ\n52: ‚îÇ   ‚îÇ   FROM alpine:3.19 / ubuntu:24.04                                        ‚îÇ   ‚îÇ\n53: ‚îÇ   ‚îÇ   ‚îú‚îÄ RUN apk add --no-cache ca-certificates                             ‚îÇ   ‚îÇ\n54: ‚îÇ   ‚îÇ   ‚îú‚îÄ RUN adduser -D -u 1000 <user>  (Alpine only)                       ‚îÇ   ‚îÇ\n55: ‚îÇ   ‚îÇ   ‚îú‚îÄ COPY --from=builder /app/bin/<binary> /app/bin/<binary>            ‚îÇ   ‚îÇ\n56: ‚îÇ   ‚îÇ   ‚îú‚îÄ USER 1000 / root                                          