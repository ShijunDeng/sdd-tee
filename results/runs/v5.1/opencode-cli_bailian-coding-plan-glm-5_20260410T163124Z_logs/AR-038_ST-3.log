5: \tassert.Equal(t, GarbageCollectorInterval, config.GCInterval)\n46: \tassert.Equal(t, 2*time.Minute, config.GCOnceTimeout)\n47: \tassert.Equal(t, int64(0), config.DeletionGracePeriod)\n48: \tassert.Equal(t, SandboxDeleteTimeout, config.DeletionTimeout)\n49: }\n50: \n51: func TestNewSandboxLifecycleManager(t *testing.T) {\n52: \tfakeClient := fake.NewSimpleClientset()\n53: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n54: \tinformerFactory := NewTestInformerFactory(fakeClient)\n55: \n56: \tk8sClient := &K8sClient{\n57: \t\tdynamicClient:   dynamicClient,\n58: \t\tcoreClient:      fakeClient,\n59: \t\tinformerFactory: informerFactory,\n60: \t}\n61: \n62: \tstore := NewMemoryStore()\n63: \tlogger := &mockLogger{}\n64: \tconfig := DefaultLifecycleConfig()\n65: \n66: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n67: \n68: \tassert.NotNil(t, manager)\n69: \tassert.Equal(t, k8sClient, manager.k8sClient)\n70: \tassert.Equal(t, store, manager.store)\n71: \tassert.Equal(t, config, manager.config)\n72: }\n73: \n74: func TestSandboxLifecycleManager_DeleteSandbox_Success(t *testing.T) {\n75: \tscheme := runtime.NewScheme()\n76: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n77: \tfakeClient := fake.NewSimpleClientset()\n78: \tinformerFactory := NewTestInformerFactory(fakeClient)\n79: \n80: \tk8sClient := &K8sClient{\n81: \t\tdynamicClient:   dynamicClient,\n82: \t\tcoreClient:      fakeClient,\n83: \t\tinformerFactory: informerFactory,\n84: \t}\n85: \n86: \tstore := NewMemoryStore()\n87: \tlogger := &mockLogger{}\n88: \tconfig := DefaultLifecycleConfig()\n89: \n90: \tnow := time.Now()\n91: \tsandbox := &types.SandboxInfo{\n92: \t\tKind:             types.SandboxKind,\n93: \t\tSandboxID:        \"sandbox-123\",\n94: \t\tSandboxNamespace: \"default\",\n95: \t\tSandboxName:      \"sandbox-123\",\n96: \t\tSessionID:        \"session-123\",\n97: \t\tCreatedAt:        now,\n98: \t\tExpiresAt:        now.Add(8 * time.Hour),\n99: \t\tStatus:           \"running\",\n100: \t}\n101: \n102: \terr := store.StoreSandbox(context.Background(), sandbox)\n103: \trequire.NoError(t, err)\n104: \n105: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n106: \n107: \terr = manager.DeleteSandbox(context.Background(), \"session-123\")\n108: \tassert.NoError(t, err)\n109: \n110: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-123\")\n111: \tassert.Error(t, err)\n112: \tassert.IsType(t, &NotFoundError{}, err)\n113: }\n114: \n115: func TestSandboxLifecycleManager_DeleteSandbox_NotFound(t *testing.T) {\n116: \tscheme := runtime.NewScheme()\n117: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n118: \tfakeClient := fake.NewSimpleClientset()\n119: \tinformerFactory := NewTestInformerFactory(fakeClient)\n120: \n121: \tk8sClient := &K8sClient{\n122: \t\tdynamicClient:   dynamicClient,\n123: \t\tcoreClient:      fakeClient,\n124: \t\tinformerFactory: informerFactory,\n125: \t}\n126: \n127: \tstore := NewMemoryStore()\n128: \tlogger := &mockLogger{}\n129: \tconfig := DefaultLifecycleConfig()\n130: \n131: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n132: \n133: \terr := manager.DeleteSandbox(context.Background(), \"non-existent\")\n134: \tassert.Error(t, err)\n135: \tassert.IsType(t, &NotFoundError{}, err)\n136: }\n137: \n138: func TestSandboxLifecycleManager_DeleteSandbox_SandboxClaim(t *testing.T) {\n139: \tscheme := runtime.NewScheme()\n140: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n141: \tfakeClient := fake.NewSimpleClientset()\n142: \tinformerFactory := NewTestInformerFactory(fakeClient)\n143: \n144: \tk8sClient := &K8sClient{\n145: \t\tdynamicClient:   dynamicClient,\n146: \t\tcoreClient:      fakeClient,\n147: \t\tinformerFactory: informerFactory,\n148: \t}\n149: \n150: \tstore := NewMemoryStore()\n151: \tlogger := &mockLogger{}\n152: \tconfig := DefaultLifecycleConfig()\n153: \n154: \tnow := time.Now()\n155: \tsandbox := &types.SandboxInfo{\n156: \t\tKind:             types.SandboxClaimKind,\n157: \t\tSandboxID:        \"sandbox-123\",\n158: \t\tSandboxNamespace: \"default\",\n159: \t\tSandboxName:      \"sandbox-123\",\n160: \t\tSessionID:        \"session-123\",\n161: \t\tCreatedAt:        now,\n162: \t\tExpiresAt:        now.Add(8 * time.Hour),\n163: \t\tStatus:           \"running\",\n164: \t}\n165: \n166: \terr := store.StoreSandbox(context.Background(), sandbox)\n167: \trequire.NoError(t, err)\n168: \n169: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n170: \n171: \terr = manager.DeleteSandbox(context.Background(), \"session-123\")\n172: \tassert.NoError(t, err)\n173: }\n174: \n175: func TestSandboxLifecycleManager_IsExpired(t *testing.T) {\n176: \tmanager := &SandboxLifecycleManager{}\n177: \n178: \tnow := time.Now()\n179: \n180: \texpiredSandbox := &types.SandboxInfo{\n181: \t\tExpiresAt: now.Add(-1 * time.Hour),\n182: \t}\n183: \tassert.True(t, manager.IsExpired(expiredSandbox))\n184: \n185: \tactiveSandbox := &types.SandboxInfo{\n186: \t\tExpiresAt: now.Add(8 * time.Hour),\n187: \t}\n188: \tassert.False(t, manager.IsExpired(activeSandbox))\n189: }\n190: \n191: func TestSandboxLifecycleManager_IsIdleExpired(t *testing.T) {\n192: \tmanager := &SandboxLifecycleManager{}\n193: \tidleTimeout := 15 * time.Minute\n194: \n195: \tnow := time.Now()\n196: \n197: \tnoActivitySandbox := &types.SandboxInfo{}\n198: \tassert.False(t, manager.IsIdleExpired(noActivitySandbox, idleTimeout))\n199: \n200: \trecentActivitySandbox := &types.SandboxInfo{\n201: \t\tLastActivity: now,\n202: \t}\n203: \tassert.False(t, manager.IsIdleExpired(recentActivitySandbox, idleTimeout))\n204: \n205: \toldActivitySandbox := &types.SandboxInfo{\n206: \t\tLastActivity: now.Add(-30 * time.Minute),\n207: \t}\n208: \tassert.True(t, manager.IsIdleExpired(oldActivitySandbox, idleTimeout))\n209: }\n210: \n211: func TestSandboxLifecycleManager_ForceDeleteSandbox(t *testing.T) {\n212: \tscheme := runtime.NewScheme()\n213: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n214: \tfakeClient := fake.NewSimpleClientset()\n215: \tinformerFactory := NewTestInformerFactory(fakeClient)\n216: \n217: \tk8sClient := &K8sClient{\n218: \t\tdynamicClient:   dynamicClient,\n219: \t\tcoreClient:      fakeClient,\n220: \t\tinformerFactory: informerFactory,\n221: \t}\n222: \n223: \tstore := NewMemoryStore()\n224: \tlogger := &mockLogger{}\n225: \tconfig := DefaultLifecycleConfig()\n226: \n227: \tnow := time.Now()\n228: \tsandbox := &types.SandboxInfo{\n229: \t\tKind:             types.SandboxKind,\n230: \t\tSandboxID:        \"sandbox-123\",\n231: \t\tSandboxNamespace: \"default\",\n232: \t\tSandboxName:      \"sandbox-123\",\n233: \t\tSessionID:        \"session-123\",\n234: \t\tCreatedAt:        now,\n235: \t\tExpiresAt:        now.Add(8 * time.Hour),\n236: \t\tStatus:           \"running\",\n237: \t}\n238: \n239: \terr := store.StoreSandbox(context.Background(), sandbox)\n240: \trequire.NoError(t, err)\n241: \n242: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n243: \n244: \terr = manager.ForceDeleteSandbox(context.Background(), \"session-123\")\n245: \tassert.NoError(t, err)\n246: \n247: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-123\")\n248: \tassert.Error(t, err)\n249: }\n250: \n251: func TestSandboxLifecycleManager_ForceDeleteSandbox_NotFound(t *testing.T) {\n252: \tscheme := runtime.NewScheme()\n253: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n254: \tfakeClient := fake.NewSimpleClientset()\n255: \tinformerFactory := NewTestInformerFactory(fakeClient)\n256: \n257: \tk8sClient := &K8sClient{\n258: \t\tdynamicClient:   dynamicClient,\n259: \t\tcoreClient:      fakeClient,\n260: \t\tinformerFactory: informerFactory,\n261: \t}\n262: \n263: \tstore := NewMemoryStore()\n264: \tlogger := &mockLogger{}\n265: \tconfig := DefaultLifecycleConfig()\n266: \n267: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n268: \n269: \terr := manager.ForceDeleteSandbox(context.Background(), \"non-existent\")\n270: \tassert.NoError(t, err)\n271: }\n272: \n273: func TestSandboxLifecycleManager_GetSandbox(t *testing.T) {\n274: \tstore := NewMemoryStore()\n275: \tmanager := &SandboxLifecycleManager{store: store}\n276: \n277: \tnow := time.Now()\n278: \tsandbox := &types.SandboxInfo{\n279: \t\tSessionID: \"session-123\",\n280: \t\tExpiresAt: now.Add(8 * time.Hour),\n281: \t}\n282: \n283: \terr := store.StoreSandbox(context.Background(), sandbox)\n284: \trequire.NoError(t, err)\n285: \n286: \tretrieved, err := manager.GetSandbox(context.Background(), \"session-123\")\n287: \trequire.NoError(t, err)\n288: \tassert.Equal(t, \"session-123\", retrieved.SessionID)\n289: \n290: \t_, err = manager.GetSandbox(context.Background(), \"non-existent\")\n291: \tassert.Error(t, err)\n292: }\n293: \n294: func TestSandboxLifecycleManager_UpdateSandboxStatus(t *testing.T) {\n295: \tstore := NewMemoryStore()\n296: \tmanager := &SandboxLifecycleManager{store: store}\n297: \n298: \tnow := time.Now()\n299: \tsandbox := &types.SandboxInfo{\n300: \t\tSessionID: \"session-123\",\n301: \t\tExpiresAt: now.Add(8 * time.Hour),\n302: \t\tStatus:    \"running\",\n303: \t}\n304: \n305: \terr := store.StoreSandbox(context.Background(), sandbox)\n306: \trequire.NoError(t, err)\n307: \n308: \terr = manager.UpdateSandboxStatus(context.Background(), \"session-123\", \"terminating\")\n309: \trequire.NoError(t, err)\n310: \n311: \tretrieved, err := store.GetSandboxBySessionID(context.Background(), \"session-123\")\n312: \trequire.NoError(t, err)\n313: \tassert.Equal(t, \"terminating\", retrieved.Status)\n314: }\n315: \n316: func TestHandleDeleteError(t *testing.T) {\n317: \tnotFoundErr := apierrors.NewNotFound(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, \"test\")\n318: \tresult := handleDeleteError(notFoundErr)\n319: \tassert.Nil(t, result)\n320: \n321: \tconflictErr := apierrors.NewConflict(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, \"test\", errors.New(\"conflict\"))\n322: \tresult = handleDeleteError(conflictErr)\n323: \tassert.IsType(t, &ConflictError{}, result)\n324: \n325: \tinternalErr := errors.New(\"internal error\")\n326: \tresult = handleDeleteError(internalErr)\n327: \tassert.IsType(t, &InternalError{}, result)\n328: }\n329: \n330: func TestDetermineDeletionReason(t *testing.T) {\n331: \tnow := time.Now()\n332: \tidleTimeout := 15 * time.Minute\n333: \n334: \texpiredSandbox := &types.SandboxInfo{\n335: \t\tExpiresAt: now.Add(-1 * time.Hour),\n336: \t}\n337: \treason := determineDeletionReason(expiredSandbox, now, idleTimeout)\n338: \tassert.Equal(t, DeletionReasonMaxDurationReached, reason)\n339: \n340: \tidleSandbox := &types.SandboxInfo{\n341: \t\tExpiresAt:    now.Add(8 * time.Hour),\n342: \t\tLastActivity: now.Add(-30 * time.Minute),\n343: \t}\n344: \treason = determineDeletionReason(idleSandbox, now, idleTimeout)\n345: \tassert.Equal(t, DeletionReasonIdleTimeout, reason)\n346: \n347: \tactiveSandbox := &types.SandboxInfo{\n348: \t\tExpiresAt:    now.Add(8 * time.Hour),\n349: \t\tLastActivity: now,\n350: \t}\n351: \treason = determineDeletionReason(activeSandbox, now, idleTimeout)\n352: \tassert.Equal(t, DeletionReasonUserRequest, reason)\n353: }\n\n(End of file - total 353 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n","truncated":false,"loaded":[]},"tit