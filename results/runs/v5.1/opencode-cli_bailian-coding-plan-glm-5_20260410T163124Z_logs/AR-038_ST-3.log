veHTTP(ww, r)\n39: \n40: \t\tm.logger.Info(\"request\",\n41: \t\t\t\"method\", r.Method,\n42: \t\t\t\"path\", r.URL.Path,\n43: \t\t\t\"status\", ww.status,\n44: \t\t\t\"duration\", time.Since(start),\n45: \t\t)\n46: \t})\n47: }\n\n(End of file - total 47 lines)\n</content>","metadata":{"preview":"package middleware\n\nimport (\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\n// responseWriterWrapper wraps http.ResponseWriter to capture the status code.\ntype responseWriterWrapper struct {\n\thttp.ResponseWriter\n\tstatus int\n}\n\n// WriteHeader captures the status code before calling the embedded WriteHeader.\nfunc (w *responseWriterWrapper) WriteHeader(code int) {\n\tw.status = code\n\tw.ResponseWriter.WriteHeader(code)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/middleware/logging.go","time":{"start":1775895864151,"end":1775895864210}}}}
