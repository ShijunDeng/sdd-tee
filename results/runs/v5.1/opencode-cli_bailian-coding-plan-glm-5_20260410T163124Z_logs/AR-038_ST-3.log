Recorder()\n39: \n40: \tHandleError(w, req, err)\n41: \n42: \tresp := w.Result()\n43: \tif resp.StatusCode != http.StatusNotFound {\n44: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusNotFound, resp.StatusCode)\n45: \t}\n46: \n47: \tvar body ErrorResponse\n48: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n49: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n50: \t}\n51: \tif body.Code != \"NOT_FOUND\" {\n52: \t\tt.Errorf(\"expected code %s, got %s\", \"NOT_FOUND\", body.Code)\n53: \t}\n54: }\n55: \n56: func TestHandleError_InternalError(t *testing.T) {\n57: \terr := &InternalError{Err: errors.New(\"database connection failed\")}\n58: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n59: \tw := httptest.NewRecorder()\n60: \n61: \tHandleError(w, req, err)\n62: \n63: \tresp := w.Result()\n64: \tif resp.StatusCode != http.StatusInternalServerError {\n65: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusInternalServerError, resp.StatusCode)\n66: \t}\n67: \n68: \tvar body ErrorResponse\n69: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n70: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n71: \t}\n72: \tif body.Code != \"INTERNAL_ERROR\" {\n73: \t\tt.Errorf(\"expected code %s, got %s\", \"INTERNAL_ERROR\", body.Code)\n74: \t}\n75: \tif body.Message != \"Unexpected server error\" {\n76: \t\tt.Errorf(\"expected message %s, got %s\", \"Unexpected server error\", body.Message)\n77: \t}\n78: }\n79: \n80: func TestHandleError_ServiceUnavailableError(t *testing.T) {\n81: \terr := &ServiceUnavailableError{Dependency: \"kubernetes-api\"}\n82: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n83: \tw := httptest.NewRecorder()\n84: \n85: \tHandleError(w, req, err)\n86: \n87: \tresp := w.Result()\n88: \tif resp.StatusCode != http.StatusServiceUnavailable {\n89: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusServiceUnavailable, resp.StatusCode)\n90: \t}\n91: \n92: \tvar body ErrorResponse\n93: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n94: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n95: \t}\n96: \tif body.Code != \"SERVICE_UNAVAILABLE\" {\n97: \t\tt.Errorf(\"expected code %s, got %s\", \"SERVICE_UNAVAILABLE\", body.Code)\n98: \t}\n99: }\n100: \n101: func TestHandleError_UnknownError(t *testing.T) {\n102: \terr := errors.New(\"unknown error type\")\n103: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n104: \tw := httptest.NewRecorder()\n105: \n106: \tHandleError(w, req, err)\n107: \n108: \tresp := w.Result()\n109: \tif resp.StatusCode != http.StatusInternalServerError {\n110: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusInternalServerError, resp.StatusCode)\n111: \t}\n112: \n113: \tvar body ErrorResponse\n114: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n115: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n116: \t}\n117: \tif body.Code != \"INTERNAL_ERROR\" {\n118: \t\tt.Errorf(\"expected code %s, got %s\", \"INTERNAL_ERROR\", body.Code)\n119: \t}\n120: }\n121: \n122: func TestHandleError_ContentType(t *testing.T) {\n123: \terr := &ValidationError{Field: \"test\", Reason: \"test\"}\n124: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n125: \tw := httptest.NewRecorder()\n126: \n127: \tHandleError(w, req, err)\n128: \n129: \tresp := w.Result()\n130: \tct := resp.Header.Get(\"Content-Type\")\n131: \tif ct != \"application/json\" {\n132: \t\tt.Errorf(\"expected Content-Type %s, got %s\", \"application/json\", ct)\n133: \t}\n134: }\n135: \n136: func TestErrorTypes_ValidationError(t *testing.T) {\n137: \terr := &ValidationError{Field: \"name\", Reason: \"required\"}\n138: \texpected := \"validation error: name - required\"\n139: \tif err.Error() != expected {\n140: \t\tt.Errorf(\"expected %s, got %s\", expected, err.Error())\n141: \t}\n142: }\n143: \n144: func TestErrorTypes_NotFoundError(t *testing.T) {\n145: \terr := &NotFoundError{Resource: \"agentruntime\", Name: \"test\"}\n146: \texpected := \"not found: agentruntime/test\"\n147: \tif err.Error() != expected {\n148: \t\tt.Errorf(\"expected %s, got %s\", expected, err.Error())\n149: \t}\n150: }\n151: \n152: func TestErrorTypes_InternalError(t *testing.T) {\n153: \terr := &InternalError{Err: errors.New(\"underlying error\")}\n154: \texpected := \"internal error: underlying error\"\n155: \tif err.Error() != expected {\n156: \t\tt.Errorf(\"expected %s, got %s\", expected, err.Error())\n157: \t}\n158: }\n159: \n160: func TestErrorTypes_ServiceUnavailableError(t *testing.T) {\n161: \terr := &ServiceUnavailableError{Dependency: \"kubernetes-api\"}\n162: \texpected := \"service unavailable: kubernetes-api\"\n163: \tif err.Error() != expected {\n164: \t\tt.Errorf(\"expected %s, got %s\", expected, err.Error())\n165: \t}\n166: }\n\n(End of file - total 166 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n)\n\nfunc TestHandleError_ValidationError(t *testing.T) {\n\terr := &ValidationError{Field: \"name\", Reason: \"required\"}\n\treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n\tw := httptest.NewRecorder()\n\n\tHandleError(w, req, err)\n\n\tresp := w.Result()\n\tif resp.StatusCode != http.StatusBadRequest {\n\t\tt.Errorf(\"expected status %d, got %d\", http.StatusBadRequest, resp.StatusCode)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types_test.go","time":{"start":1775895875429,"end":1775895875459}}}}
{"type":"tool_use","timestamp":1775895875461,"sessionID":"ses_2845c51e5ffeHW8ywQ2rHowlPW","part":{"id":"prt_d7ba48835001bn7wuIdVnvHTYI","messageID":"msg_d7ba463d6001JqL360KJJ92Cv2","sessionID":"ses_2845c51e5ffeHW8ywQ2rHowlPW","type":"tool","tool":"read","callID":"toolu_tool-f6b1839c7dd341c8bc3064ff3311e6e5","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/k8s_client_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/k8s_client_test.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"testing\"\n6: \t\"time\"\n7: \n8: \t\"github.com/stretchr/testify/assert\"\n9: \t\"github.com/stretchr/testify/require\"\n10: \tcorev1 \"k8s.io/api/core/v1\"\n11: \tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n12: \t\"k8s.io/apimachinery/pkg/runtime\"\n13: \tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n14: \t\"k8s.io/client-go/informers\"\n15: \t\"k8s.io/client-go/kubernetes\"\n16: \t\"k8s.io/client-go/kubernetes/fake\"\n17: \t\"k8s.io/client-go/rest\"\n18: )\n19: \n20: func TestNewK8sClient(t *testing.T) {\n21: \tconfig := &rest.Config{\n22: \t\tHost: \"http://localhost:8080\",\n23: \t}\n24: \n25: \tclient, err := NewK8sClient(config)\n26: \trequire.NoError(t, err)\n27: \tassert.NotNil(t, client)\n28: \tassert.NotNil(t, client.dynamicClient)\n29: \tassert.NotNil(t, client.coreClient)\n30: \tassert.NotNil(t, client.informerFactory)\n31: \tassert.NotNil(t, client.podLister)\n32: }\n33: \n34: func TestK8sClient_StartInformers(t *testing.T) {\n35: \tfakeClient := fake.NewSimpleClientset()\n36: \n37: \tclient := &K8sClient{\n38: \t\tcoreClient:      fakeClient,\n39: \t\tinformerFactory: NewTestInformerFactory(fakeClient),\n40: \t}\n41: \n42: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n43: \tdefer cancel()\n44: \n45: \tclient.StartInformers(ctx)\n46: \n47: \tsynced := client.WaitForCacheSync(ctx)\n48: \tassert.True(t, synced)\n49: }\n50: \n51: func TestK8sClient_PodLister(t *testing.T) {\n52: \tpod := &corev1.Pod{\n53: \t\tObjectMeta: metav1.ObjectMeta{\n54: \t\t\tName:      \"test-pod\",\n55: \t\t\tNamespace: \"default\",\n56: \t\t},\n57: \t\tStatus: corev1.PodStatus{\n58: \t\t\tPhase: corev1.PodRunning,\n59: \t\t\tPodIP: \"10.244.0.5\",\n60: \t\t},\n61: \t}\n62: \n63: \tfakeClient := fake.NewSimpleClientset(pod)\n64: \tinformerFactory := NewTestInformerFactory(fakeClient)\n65: \n66: \tclient := &K8sClient{\n67: \t\tcoreClient:      fakeClient,\n68: \t\tinformerFactory: informerFactory,\n69: \t\tpodLister:       informerFactory.Core().V1().Pods().Lister(),\n70: \t}\n71: \n72: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n73: \tdefer cancel()\n74: \n75: \tclient.StartInformers(ctx)\n76: \tclient.WaitForCacheSync(ctx)\n77: \n78: \tretrievedPod, err := client.PodLister().Pods(\"default\").Get(\"test-pod\")\n79: \trequire.NoError(t, err)\n80: \tassert.Equal(t, \"test-pod\", retrievedPod.Name)\n81: \tassert.Equal(t, corev1.PodRunning, retrievedPod.Status.Phase)\n82: }\n83: \n84: func TestClientCache_GetOrCreateClient(t *testing.T) {\n85: \tcache := NewClientCache()\n86: \n87: \tconfig := &rest.Config{\n88: \t\tHost: \"http://localhost:8080\",\n89: \t}\n90: \n91: \tclient1, err := cache.GetOrCreateClient(\"token1\", \"ns1\", config)\n92: \trequire.NoError(t, err)\n93: \tassert.NotNil(t, client1)\n94: \n95: \tclient2, err := cache.GetOrCreateClient(\"token1\", \"ns1\", config)\n96: \trequire.NoError(t, err)\n97: \tassert.Equal(t, client1, client2, \"Should return same client for same token+namespace\")\n98: \n99: \tclient3, err := cache.GetOrCreateClient(\"token2\", \"ns2\", config)\n100: \trequire.NoError(t, err)\n101: \tassert.NotNil(t, client3)\n102: \tassert.NotEqual(t, client1, client3, \"Should return different client for different token+namespace\")\n103: }\n104: \n105: func NewTestInformerFactory(client kubernetes.Interface) informers.SharedInformerFactory {\n106: \treturn informers.NewSharedInformerFactoryWithOptions(\n107: \t\tclient,\n108: \t\ttime.Minute,\n109: \t)\n110: }\n111: \n112: func TestK8sClient_Methods(t *testing.T) {\n113: \tfakeClient := fake.NewSimpleClientset()\n114: \tinformerFactory := NewTestInformerFactory(fakeClient)\n115: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n116: \n117: \tclient := &K8sClient{\n118: \t\tdynamicClient:   dynamicClient,\n119: \t\tcoreClient:      fakeClient,\n120: \t\tinformerFactory: informerFactory,\n121: \t\tpodLister:       informerFactory.Core().V1().Pods().Lister(),\n122: \t}\n123: \n124: \tassert.NotNil(t, client.DynamicClient())\n125: \tassert.NotNil(t, client.CoreClient())\n126: \tassert.NotNil(t, client.PodLister())\n127: \tassert.NotNil(t, client.InformerFactory())\n128: }\n\n(End of file - total 128 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\t\"k8s.io/client-go/rest\"\n)\n\nfunc TestNewK8sClient(t *testing.T) {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/k8s_client_test.go","time":{"start":1775895875430,"end":1775895875460}}}}
{"type":"tool_use","timestamp":1775895875465,"sessionID":"ses_2845c51e5ffeHW8ywQ2rHowlPW","part":{"id":"prt_d7ba48bd9001v6xi0xm2Nm68dt","messageID":"msg_d7ba463d6001JqL360KJJ92Cv2","sessionID":"ses_2845c51e5ffeHW8ywQ2rHowlPW","type":"tool","tool":"read","callID":"toolu_tool-5f352d207885401499fab42fa0b86a0c","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go</path>\n<type>file</type>\n<content>\n1: package handlers\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"net/http\"\n7: \t\"net/http/httptest\"\n8: \t\"testing\"\n9: \t\"time\"\n10: \n11: \t\"github.com/go-chi/chi/v5\"\n12: \t\"github.com/stretchr/testify/assert\"\n13: \t\"github.com/stretchr/testify/require\"\n14: \t\"k8s.io/apimachinery/pkg/runtime\"\n15: \tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n16: \t\"k8s.io/client-go/informers\"\n17: \t\"k8s.io/client-go/kubernetes\"\n18: \tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n19: \n20: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n21: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n22: )\n23: \n24: func NewTestInformerFactory(client kubernetes.Interface) informers.SharedInformerFactory {\n25: \treturn informers.NewSharedInformerFactoryWithOptions(client, time.Minute)\n26: }\n27: \n28: func setupTestHandler() (*DeletionHandler, *workloadmanager.MemoryStore) {\n29: \tfakeClient := k8sfake.NewSimpleClientset()\n30: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n31: \tinformerFactory := NewTestInformerFactory(fakeClient)\n32: \n33: \tk8sClient := &workloadmanager.K8sClient{}\n34: \tk8sClient.SetClients(dynamicClient, fakeClient, informerFactory)\n35: \n36: \tstore := workloadmanager.NewMemoryStore()\n37: \tlogger := &testLogger{}\n38: \tconfig := workloadmanager.DefaultLifecycleConfig()\n39: \n40: \tmanager := workloadmanager.NewSandboxLifecycleManager(k8sClient, store, config, logger)\n41: \n42: \treturn NewDeletionHandler(manager, logger), store\n43: }\n44: \n45: type testLogger struct{}\n46: \n47: func (l *testLogger) Info(msg string, args ...any)  {}\n48: func (l *testLogger) Error(msg string, args ...any) {}\n49: \n50: func TestDeletionHandler_Register(t *testing.T) {\n51: \thandler, _ := setupTestHandler()\n52: \n53: \tr := chi.NewRouter()\n54: \thandler.Register(r)\n55: \n56: \troutes := r.Routes()\n57: \tassert.Len(t, routes, 2)\n58: }\n59: \n60: func TestDeletionHandler_DeleteSuccess(t *testing.T) {\n61: \thandler, store := setupTestHandler()\n62: \n63: \tnow := time.Now()\n64: \tsandbox := &types.SandboxInfo{\n65: \t\tKind:             types.SandboxKind,\n66: \t\tSandboxID:        \"sandbox-123\",\n67: \t\tSandboxNamespace: \"default\",\n68: \t\tSandboxName:      \"sandbox-123\",\n69: \t\tSessionID:        \"session-123\",\n70: \t\tCreatedAt:        now,\n71: \t\tExpiresAt:        now.Add(8 * time.Hour),\n72: \t\tStatus:           \"running\",\n73: \t}\n74: \n75: \terr := store.StoreSandbox(context.Background(), sandbox)\n76: \trequire.NoError(t, err)\n77: \n78: \tr := chi.NewRouter()\n79: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n80: \n81: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n82: \trec := httptest.NewRecorder()\n83: \n84: \tr.ServeHTTP(rec, req)\n85: \n86: \tassert.Equal(t, http.StatusOK, rec.Code)\n87: \n88: \tvar resp DeleteSandboxResponse\n89: \terr = json.NewDecoder(rec.Body).Decode(&resp)\n90: \trequire.NoError(t, err)\n91: \n92: \tassert.Equal(t, \"session-123\", resp.SessionID)\n93: \tassert.Equal(t, \"deleted\", resp.Status)\n94: \n95: \tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n96: }\n97: \n98: func TestDeletionHandler_DeleteNotFound(t *testing.T) {\n99: \thandler, _ := setupTestHandler()\n100: \n101: \tr := chi.NewRouter()\n102: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n103: \n104: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/non-existent\", nil)\n105: \trec := httptest.NewRecorder()\n106: \n107: \tr.ServeHTTP(rec, req)\n108: \n109: \tassert.Equal(t, http.StatusNotFound, rec.Code)\n110: \n111: \tvar resp DeleteSandboxResponse\n112: \terr := json.NewDecoder(rec.Body).Decode(&resp)\n113: \trequire.NoError(t, err)\n114: \n115: \tassert.Equal(t, \"non-existent\", resp.SessionID)\n116: \tassert.Equal(t, \"not_found\", resp.Status)\n117: }\n118: \n119: func TestDeletionHandler_DeleteMissingSessionID(t *testing.T) {\n120: \thandler, _ := setupTestHandler()\n121: \n122: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/\", nil)\n123: \trec := httptest.NewRecorder()\n124: \n125: \thandler.handleDeleteSandbox(rec, req, \"\", workloadmanager.AgentRuntimeKind)\n126: \n127: \tassert.Equal(t, http.StatusBadRequest, rec.Code)\n128: \n129: \tvar resp workloadmanager.ErrorResponse\n130: \terr := json.NewDecoder(rec.Body).Decode(&resp)\n131: \trequire.NoError(t, err)\n132: \n133: \tassert.Equal(t, \"VALIDATION_ERROR\", resp.Code)\n134: }\n135: \n136: func TestDeletionHandler_DeleteCodeInterpreter(t *testing.T) {\n137: \thandler, store := setupTestHandler()\n138: \n139: \tnow := time.Now()\n140: \tsandbox := &types.SandboxInfo{\n141: \t\tKind:             types.SandboxKind,\n142: \t\tSandboxID:        \"sandbox-123\",\n143: \t\tSandboxNamespace: \"default\",\n144: \t\tSandboxName:      \"sandbox-123\",\n145: \t\tSessionID:        \"session-123\",\n146: \t\tCreatedAt:        now,\n147: \t\tExpiresAt:        now.Add(8 * time.Hour),\n148: \t\tStatus:           \"running\",\n149: \t}\n150: \n151: \terr := store.StoreSandbox(context.Background(), sandbox)\n152: \trequire.NoError(t, err)\n153: \n154: \tr := chi.NewRouter()\n155: \tr.Delete(\"/v1/code-interpreter/sessions/{sessionId}\", handler.handleDeleteCodeInterpreterSandbox)\n156: \n157: \treq := httptest.NewRequest(\"DELETE\", \"/v1/code-interpreter/sessions/session-123\", nil)\n158: \trec := httptest.NewRecorder()\n159: \n160: \tr.ServeHTTP(rec, req)\n161: \n162: \tassert.Equal(t, http.StatusOK, rec.Code)\n163: \n164: \tvar resp DeleteSandboxResponse\n165: \terr = json.NewDecoder(rec.Body).Decode(&resp)\n166: \trequire.NoError(t, err)\n167: \n168: \tassert.Equal(t, \"session-123\", resp.SessionID)\n169: \tassert.Equal(t, \"deleted\", resp.Status)\n170: }\n171: \n172: func TestDeletionHandler_ResponseFormat(t *testing.T) {\n173: \thandler, store := setupTestHandler()\n174: \n175: \tnow := time.Now()\n176: \tsandbox := &types.SandboxInfo{\n177: \t\tKind:             types.SandboxKind,\n178: \t\tSandboxID:        \"sandbox-123\",\n179: \t\tSandboxNamespace: \"default\",\n180: \t\tSandboxName:      \"sandbox-123\",\n181: \t\tSessionID:        \"session-123\",\n182: \t\tCreatedAt:        now,\n183: \t\tExpiresAt:        now.Add(8 * time.Hour),\n184: \t\tStatus:           \"running\",\n185: \t}\n186: \n187: \terr := store.StoreSandbox(context.Background(), sandbox)\n188: \trequire.NoError(t, err)\n189: \n190: \tr := chi.NewRouter()\n191: \tr.Delete(\"/v1/agent-runtime/sessions/{sessionId}\", handler.handleDeleteAgentRuntimeSandbox)\n192: \n193: \treq := httptest.NewRequest(\"DELETE\", \"/v1/agent-runtime/sessions/session-123\", nil)\n194: \trec := httptest.NewRecorder()\n195: \n196: \tr.ServeHTTP(rec, req)\n197: \n198: \tassert.Equal(t, \"application/json\", rec.Header().Get(\"Content-Type\"))\n199: \n200: \tvar resp map[string]interface{}\n201: \terr = json.Unmarshal(rec.Body.Bytes(), &resp)\n202: \trequire.NoError(t, err)\n203: \n204: \tassert.Contains(t, resp, \"sessionId\")\n205: \tassert.Contains(t, resp, \"status\")\n206: \tassert.Equal(t, \"session-123\", resp[\"sessionId\"])\n207: \tassert.Equal(t, \"deleted\", resp[\"status\"])\n208: }\n209: \n210: func TestDeleteSandboxRequest_JSON(t *testing.T) {\n211: \treq := DeleteSandboxRequest{\n212: \t\tSessionID:          \"session-123\",\n213: \t\tKind:               \"AgentRuntime\",\n214: \t\tForce:              true,\n215: \t\tGracePeriodSeconds: 30,\n216: \t}\n217: \n218: \tdata, err := json.Marshal(req)\n219: \trequire.NoError(t, err)\n220: \n221: \tvar unmarshaled DeleteSandboxRequest\n222: \terr = json.Unmarshal(data, &unmarshaled)\n223: \trequire.NoError(t, err)\n224: \n225: \tassert.Equal(t, req.SessionID, unmarshaled.SessionID)\n226: \tassert.Equal(t, req.Kind, unmarshaled.Kind)\n227: \tassert.Equal(t, req.Force, unmarshaled.Force)\n228: \tassert.Equal(t, req.GracePeriodSeconds, unmarshaled.GracePeriodSeconds)\n229: }\n230: \n231: func TestDeleteSandboxResponse_JSON(t *testing.T) {\n232: \tresp := DeleteSandboxResponse{\n233: \t\tSessionID: \"session-123\",\n234: \t\tStatus:    \"deleted\",\n235: \t\tMessage:   \"Sandbox deleted successfully\",\n236: \t}\n237: \n238: \tdata, err := json.Marshal(resp)\n239: \trequire.NoError(t, err)\n240: \n241: \tvar unmarshaled DeleteSandboxResponse\n242: \terr = json.Unmarshal(data, &unmarshaled)\n243: \trequire.NoError(t, err)\n244: \n245: \tassert.Equal(t, resp.SessionID, unmarshaled.SessionID)\n246: \tassert.Equal(t, resp.Status, unmarshaled.Status)\n247: \tassert.Equal(t, resp.Message, unmarshaled.Message)\n248: }\n\n(End of file - total 248 lines)\n</content>","metadata":{"preview":"package handlers\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/informers\"\n\t\"k8s.io/client-go/kubernetes\"\n\tk8sfake \"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/handlers/sandbox_delete_test.go","time":{"start":1775895875432,"end":1775895875464}}}}
