e = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        pom_xml = tmp_path / \"pom.xml\"\n        pom_xml.write_text(\"<project></project>\")\n\n        service = MetadataService()\n        metadata = service.load_metadata(tmp_path)\n        service._validate_java_workspace(tmp_path, metadata)\n\n    def test_validate_java_workspace_no_pom(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: no-pom-test\nlanguage: java\nentrypoint: java -jar app.jar\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        service = MetadataService()\n        metadata = service.load_metadata(tmp_path)\n        with pytest.raises(ValueError, match=\"pom.xml not found\"):\n            service._validate_java_workspace(tmp_path, metadata)\n\n    def test_validate_workspace_routing(self, tmp_path: Path) -> None:\n        python_workspace = tmp_path / \"python_proj\"\n        python_workspace.mkdir()\n        metadata_content = \"\"\"\nagent_name: routing-python\nlanguage: python\nentrypoint: python main.py\n\"\"\"\n        metadata_file = python_workspace / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        main_py = python_workspace / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n\n        service = MetadataService()\n        assert service.validate_workspace(python_workspace) is True\n\n        java_workspace = tmp_path / \"java_proj\"\n        java_workspace.mkdir()\n        java_metadata_content = \"\"\"\nagent_name: routing-java\nlanguage: java\nentrypoint: java -jar app.jar\n\"\"\"\n        java_metadata_file = java_workspace / \"agent_metadata.yaml\"\n        java_metadata_file.write_text(java_metadata_content)\n        pom_xml = java_workspace / \"pom.xml\"\n        pom_xml.write_text(\"<project></project>\")\n\n        assert service.validate_workspace(java_workspace) is True\n\n    def tes