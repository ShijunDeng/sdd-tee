\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n    region: str = Field(\"\", description=\"Deployment region\")\n    version: str = Field(\"\", description=\"Semantic version string for publishing\")\n    image: Dict[str, Any] = Field(default_factory=dict, description=\"Container image information\")\n    auth: Dict[str, Any] = Field(default_factory=dict, description=\"Authentication configuration\")\n    requirements_file: str = Field(\"requirements.txt\", description=\"Python dependency file\")\n    registry_url: str = Field(\"\", description=\"Registry URL for image publishing\")\n    registry_username: str = Field(\"\", description=\"Registry username\")\n    registry_password: str = Field(\"\", description=\"Registry password\")\n    agent_endpoint: str = Field(\"\", description=\"Agent endpoint URL\")\n    workload_manager_url: str = Field(\"\", description=\"URL for the Workload Manager\")\n    router_url: str = Field(\"\", description=\"URL for the Router\")\n    readiness_probe_path: str = Field(\"\", description=\"Path for the readiness probe\")\n    readiness_probe_port: int = Field(8080, description=\"Port for the readiness probe\")\n    agent_id: str = Field(\"\", description=\"Agent ID assigned by AgentCube\")\n    session_id: str = Field(\"\", description=\"The session ID for the agent\")\n    k8s_deployment: Dict[str, Any] = Field(default_factory=dict, description=\"Kubernetes deployment information\")\n\n    @field_validator(\"language\")\n    @classmethod\n    def validate_language(cls, v: str) -> str:\n        allowed = [\"python\", \"java\"]\n        v_lower = v.lower()\n        if v_lower not in allowed:\n            raise ValueError(f\"language must be one of {allowed}\")\n        return v_lower\n\n    @field_validator(\"build_mode\")\n    @classmethod\n    def validate_build_mode(cls, v: str) -> str:\n        allowed = [\"local\", \"cloud\"]\n        v_lower = v.lower()\n        if v_lower not in allowed:\n            raise ValueError(f\"build_mode must be one of {allowed}\")\n        return v_lower\n\n    @field_validator(\"port\")\n    @classmethod\n    def validate_port(cls, v: int) -> int:\n        if not 1 <= v <= 65535:\n            raise ValueError(\"port must be between 1 and 65535\")\n        return v\n\n\nclass MetadataService:\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose\n\n    def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n        metadata_files = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n        for filename in metadata_files:\n            filepath = workspace_path / filename\n            if filepath.exists():\n                with open(filepath, \"r\", encoding=\"utf-8\") as f:\n                    data = yaml.safe_load(f) or {}\n                return AgentMetadata(**data)\n        raise FileNotFoundError(\n            f\"No metadata file found in workspace: {workspace_path}\"\n        )\n\n    def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> Path:\n        filepath = workspace_path / \"agent_metadata.yaml\"\n        data = metadata.model_dump(exclude_none=True)\n        with open(filepath, \"w\", encoding=\"utf-8\") as f:\n            yaml.dump(data, f, default_flow_style=False, indent=2, sort_keys=False)\n        return filepath","after":"from pathlib import Path\nfrom typing import Optional, Dict, Any\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: str = Field(\"\", description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n    region: str = Field(\"\", description=\"Deployment region\")\n    version: str = Field(\"\", description=\"Semantic version string for publishing\")\n    image: Dict[str, Any] = Field(default_factory=dict, description=\"Container image information\")\n    auth: Dict[str, Any] = Field(default_factory=dict, description=\"Authentication configuration\")\n    requirements_file: str = Field(\"requirements.txt\", description=\"Python dependency file\")\n    registry_url: str = Field(\"\", description=\"Registry URL for image publishing\")\n    registry_username: str = Field(\"\", description=\"Registry username\")\n    registry_password: str = Field(\"\", description=\"Registry password\")\n    agent_endpoint: str = Field(\"\", description=\"Agent endpoint URL\")\n    workload_manager_url: str = Field(\"\", description=\"URL for the Workload Manager\")\n    router_url: str = Field(\"\", description=\"URL for the Router\")\n    readiness_probe_path: str = Field(\"\", description=\"Path for the readiness probe\")\n    readiness_probe_port: int = Field(8080, description=\"Port for the readiness probe\")\n    agent_id: str = Field(\"\", description=\"Agent ID assigned by AgentCube\")\n    session_id: str = Field(\"\", description=\"The session ID for the agent\")\n    k8s_deployment: Dict[str, Any] = Field(default_factory=dict, description=\"Kubernetes deployment information\")\n\n    @field_validator(\"language\")\n    @classmethod\n    def validate_language(cls, v: str) -> str:\n        allowed = [\"python\", \"java\"]\n        v_lower = v.lower()\n        if v_lower not in allowed:\n            raise ValueError(f\"language must be one of {allowed}\")\n        return v_lower\n\n    @field_validator(\"build_mode\")\n    @classmethod\n    def validate_build_mode(cls, v: str) -> str:\n        allowed = [\"local\", \"cloud\"]\n        v_lower = v.lower()\n        if v_lower not in allowed:\n            raise ValueError(f\"build_mode must be one of {allowed}\")\n        return v_lower\n\n    @field_validator(\"port\")\n    @classmethod\n    def validate_port(cls, v: int) -> int:\n        if not 1 <= v <= 65535:\n            raise ValueError(\"port must be between 1 and 65535\")\n        return v\n\n\nclass MetadataService:\n    def __init__(self, verbose: bool = False) -> None:\n        self.verbose = verbose\n\n    def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n        metadata_files = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n        for filename in metadata_files:\n            filepath = workspace_path / filename\n            if filepath.exists():\n                with open(filepath, \"r\", encoding=\"utf-8\") as f:\n                    data = yaml.safe_load(f) or {}\n                return AgentMetadata(**data)\n        raise FileNotFoundError(\n            f\"No metadata file found in workspace: {workspace_path}\"\n        )\n\n    def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> Path:\n        filepath = workspace_path / \"agent_metadata.yaml\"\n        data = metadata.model_dump(exclude_none=True)\n        with open(filepath, \"w\", encoding=\"utf-8\") as f:\n            yaml.dump(data, f, default_flow_style=False, indent=2, sort_keys=False)\n        return filepath\n\n    def update_metadata(\n        self, workspace_path: Path, updates: Dict[str, Any]\n    ) -> AgentMetadata:\n        metadata = self.load_metadata(workspace_path)\n        for key, value in updates.items():\n            if hasattr(metadata, key):\n                setattr(metadata, key, value)\n        self.save_metadata(workspace_path, metadata)\n        return metadata\n\n    def validate_workspace(self, workspace_path: Path) -> bool:\n        if not workspace_path.exists():\n            raise ValueError(f\"Workspace does not exist: {workspace_path}\")\n        if not workspace_path.is_dir():\n            raise ValueError(f\"Workspace path is not a directory: {workspace_path}\")\n        metadata = self.load_metadata(workspace_path)\n        if metadata.language == \"python\":\n            self._validate_python_workspace(workspace_path, metadata)\n        elif metadata.language == \"java\":\n            self._validate_java_workspace(workspace_path, metadata)\n        return True\n\n    def _validate_python_workspace(\n        self, workspace_path: Path, metadata: AgentMetadata\n    ) -> None:\n        py_files = list(workspace_path.glob(\"*.py\"))\n        if not py_files:\n            raise ValueError(\"No Python files found in workspace\")\n\n    def _validate_java_workspace(\n        self, workspace_path: Path, metadata: AgentMetadata\n    ) -> None:\n        pom_file = workspace_path / \"pom.xml\"\n        if not pom_file.exists():\n            raise ValueError(\"pom.xml not found in workspace\")","additions":37,"deletions":1},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775877236192,"end":1775877237022}}}}
