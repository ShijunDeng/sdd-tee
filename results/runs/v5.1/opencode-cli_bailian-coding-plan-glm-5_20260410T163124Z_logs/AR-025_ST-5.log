     language=\"python\",\n                entrypoint=\"python main.py\",\n                build_mode=\"invalid\",\n            )\n\n    def test_agent_metadata_invalid_port_low(self) -> None:\n        with pytest.raises(ValidationError):\n            AgentMetadata.model_construct(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=0,\n            )\n\n    def test_agent_metadata_invalid_port_high(self) -> None:\n        with pytest.raises(ValidationError):\n            AgentMetadata.model_construct(\n                agent_name=\"test-agent\",\n                language=\"python\",\n                entrypoint=\"python main.py\",\n                port=70000,\n            )\n\n    def test_agent_metadata_valid_port_range(self) -> None:\n        metadata = AgentMetadata.model_construct(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=1,\n        )\n        assert metadata.port == 1\n\n        metadata = AgentMetadata.model_construct(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=65535,\n        )\n        assert metadata.port == 65535\n\n\nclass TestMetadataService:\n    def test_metadata_service_load_agent_metadata_yaml(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: loaded-agent\nlanguage: python\nentrypoint: python main.py\nport: 9000\nbuild_mode: cloud\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        service = MetadataService()\n        metadata = service.load_metadata(tmp_path)\n        assert metadata.agent_name == \"loaded-agent\"\n        assert metadata.port == 9000\n        assert metadata.build_mode == \"cloud\"\n\n    def test_metadata_service_load_fallback_agent_yaml(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: fallback-agent\nlanguage: python\nentrypoint: python app.py\n\"\"\"\n        metadata_file = tmp_path / \"agent.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        service = MetadataService()\n        metadata = service.load_metadata(tmp_path)\n        assert metadata.agent_name == \"fallback-agent\"\n\n    def test_metadata_service_load_fallback_metadata_yaml(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: meta-agent\nlanguage: java\nentrypoint: java -jar app.jar\n\"\"\"\n        metadata_file = tmp_path / \"metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        service = MetadataService()\n        metadata = service.load_metadata(tmp_path)\n        assert metadata.agent_name == \"meta-agent\"\n        assert metadata.language == \"java\"\n\n    def test_metadata_service_save(self, tmp_path: Path) -> None:\n        metadata = AgentMetadata.model_construct(\n            agent_name=\"save-test\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=8080,\n            build_mode=\"local\",\n            description=\"Test agent\",\n        )\n\n        service = MetadataService()\n        saved_path = service.save_metadata(tmp_path, metadata)\n\n        assert saved_path.exists()\n        assert saved_path.name == \"agent_metadata.yaml\"\n\n        with open(saved_path) as f:\n            data = yaml.safe_load(f)\n\n        assert data[\"agent_name\"] == \"save-test\"\n        assert data[\"language\"] == \"python\"\n        assert data[\"port\"] == 8080\n\n    def test_metadata_service_save_excludes_none(self, tmp_path: Path) -> None:\n        metadata = AgentMetadata.model_construct(\n            agent_name=\"save-test\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n        )\n\n        service = MetadataService()\n        saved_path = service.save_metadata(tmp_path, metadata)\n\n        with open(saved_path) as f:\n            data = yaml.safe_load(f)\n\n        assert data[\"agent_name\"] == \"save-test\"\n\n    def test_metadata_service_load_no_files(self, tmp_path: Path) -> None:\n        service = MetadataService()\n        with pytest.raises(FileNotFoundError):\n            service.load_metadata(tmp_path)\n\n    def test_metadata_service_update(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: update-test\nlanguage: python\nentrypoint: python main.py\nversion: \"\"\ndescription: old description\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n\n        service = MetadataService()\n        updated = service.update_metadata(\n            tmp_path, {\"version\": \"v1.0.0\", \"description\": \"new description\"}\n        )\n\n        assert updated.version == \"v1.0.0\"\n        assert updated.description == \"new description\"\n\n        loaded = service.load_metadata(tmp_path)\n        assert loaded.version == \"v1.0.0\"\n        assert loaded.description == \"new description\"\n\n    def test_metadata_service_update_returns_metadata(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: return-test\nlanguage: python\nentrypoint: python main.py\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n\n        service = MetadataService()\n        result = service.update_metadata(tmp_path, {\"port\": 9000})\n\n        assert isinstance(result, AgentMetadata)\n        assert result.port == 9000\n\n    def test_validate_workspace_python(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: validate-python\nlanguage: python\nentrypoint: python main.py\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n\n        service = MetadataService()\n        result = service.validate_workspace(tmp_path)\n        assert result is True\n\n    def test_validate_python_workspace_has_py(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: has-py-test\nlanguage: python\nentrypoint: python main.py\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        main_py = tmp_path / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n\n        service = MetadataService()\n        metadata = service.load_metadata(tmp_path)\n        service._validate_python_workspace(tmp_path, metadata)\n\n    def test_validate_python_workspace_no_py(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: no-py-test\nlanguage: python\nentrypoint: python main.py\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        service = MetadataService()\n        metadata = service.load_metadata(tmp_path)\n        with pytest.raises(ValueError, match=\"No Python files found\"):\n            service._validate_python_workspace(tmp_path, metadata)\n\n    def test_validate_java_workspace_has_pom(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: has-pom-test\nlanguage: java\nentrypoint: java -jar app.jar\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        pom_xml = tmp_path / \"pom.xml\"\n        pom_xml.write_text(\"<project></project>\")\n\n        service = MetadataService()\n        metadata = service.load_metadata(tmp_path)\n        service._validate_java_workspace(tmp_path, metadata)\n\n    def test_validate_java_workspace_no_pom(self, tmp_path: Path) -> None:\n        metadata_content = \"\"\"\nagent_name: no-pom-test\nlanguage: java\nentrypoint: java -jar app.jar\n\"\"\"\n        metadata_file = tmp_path / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n\n        service = MetadataService()\n        metadata = service.load_metadata(tmp_path)\n        with pytest.raises(ValueError, match=\"pom.xml not found\"):\n            service._validate_java_workspace(tmp_path, metadata)\n\n    def test_validate_workspace_routing(self, tmp_path: Path) -> None:\n        python_workspace = tmp_path / \"python_proj\"\n        python_workspace.mkdir()\n        metadata_content = \"\"\"\nagent_name: routing-python\nlanguage: python\nentrypoint: python main.py\n\"\"\"\n        metadata_file = python_workspace / \"agent_metadata.yaml\"\n        metadata_file.write_text(metadata_content)\n        main_py = python_workspace / \"main.py\"\n        main_py.write_text(\"print('hello')\")\n\n        service = MetadataService()\n        assert service.validate_workspace(python_workspace) is True\n\n        java_workspace = tmp_path / \"java_proj\"\n        java_workspace.mkdir()\n        java_metadata_content = \"\"\"\nagent_name: routing-java\nlanguage: java\nentrypoint: java -jar app.jar\n\"\"\"\n        java_metadata_file = java_workspace / \"agent_metadata.yaml\"\n        java_metadata_file.write_text(java_metadata_content)\n        pom_xml = java_workspace / \"pom.xml\"\n        pom_xml.write_text(\"<project></project>\")\n\n        assert service.validate_workspace(java_workspace) is True\n\n    def test_validate_workspace_not_exists(self) -> None:\n        service = MetadataService()\n        with pytest.raises(ValueError, match=\"Workspace does not exist\"):\n            service.validate_workspace(Path(\"/nonexistent/workspace\"))\n\n    def test_validate_workspace_not_directory(self, tmp_path: Path) -> None:\n        file_p