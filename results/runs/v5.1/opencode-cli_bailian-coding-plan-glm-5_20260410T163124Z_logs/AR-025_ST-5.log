ptions(input_dict)\n        assert options.agent_name == \"my-agent\"\n        assert options.language == \"java\"\n        assert options.port == 9090\n\n    def test_from_options_filters_none(self) -> None:\n        input_dict = {\n            \"agent_name\": None,\n            \"language\": \"python\",\n            \"entrypoint\": None,\n            \"port\": 8080,\n        }\n        options = MetadataOptions.from_options(input_dict)\n        assert options.agent_name is None\n        assert options.language == \"python\"\n        assert options.entrypoint is None\n        assert options.port == 8080\n\n    def test_from_options_empty_dict(self) -> None:\n        options = MetadataOptions.from_options({})\n        assert options.agent_name is None\n        assert options.language == \"python\"\n        assert options.port == 8080\n\n    def test_from_options_unknown_key_ignored(self) -> None:\n        input_dict = {\n            \"agent_name\": \"test\",\n            \"unknown_field\": \"value\",\n        }\n        options = MetadataOptions.from_options(input_dict)\n        assert options.agent_name == \"test\"\n        assert not hasattr(options, \"unknown_field\")\n\n    def test_metadata_options_all_fields(self) -> None:\n        options = MetadataOptions(\n            agent_name=\"full-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n            port=8080,\n            build_mode=\"local\",\n            requirements_file=\"requirements.txt\",\n            description=\"Test agent\",\n            workload_manager_url=\"http://wm.example.com\",\n            router_url=\"http://router.example.com\",\n            readiness_probe_path=\"/health\",\n            readiness_probe_port=8080,\n            registry_url=\"http://registry.example.com\",\n            registry_username=\"user\",\n            registry_password=\"pass\",\n            agent_endpoint=\"http://agent.example.com\",\n        )\n        assert options.agent_name == \"full-agent\"\n        assert options.workload_manager_url == \"http://wm.example.com\"\n        assert options.router_url == \"http://router.example.com\"\n        assert options.readiness_probe_path == \"/health\"\n        assert options.registry_url == \"http://registry.example.com\"\n        assert options.registry_username == \"user\"\n        assert options.registry_password == \"pass\"\n        assert options.agent_endpoint == \"http://agent.example.com\""},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_pack_runtime.py\">\nERROR [216:23] \"exists\" is not a known attribute of \"None\"\nERROR [217:26] \"read_text\" is not a known attribute of \"None\"\nERROR [233:23] \"exists\" is not a known attribute of \"None\"\nERROR [234:26] \"read_text\" is not a known attribute of \"None\"\n</diagnostics>","metadata":{"diagnostics":{"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/metadata_service.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_metadata_service.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/models/pack_models.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/__init__.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/models/__init__.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/runtime/pack_runtime.py":[],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_pack_runtime.py":[{"range":{"start":{"line":215,"chara