ypoint=\"python main.py\",\n36:                 build_mode=\"invalid\",\n37:             )\n38: \n39:     def test_agent_metadata_invalid_port_low(self) -> None:\n40:         with pytest.raises(ValidationError):\n41:             AgentMetadata.model_construct(\n42:                 agent_name=\"test-agent\",\n43:                 language=\"python\",\n44:                 entrypoint=\"python main.py\",\n45:                 port=0,\n46:             )\n47: \n48:     def test_agent_metadata_invalid_port_high(self) -> None:\n49:         with pytest.raises(ValidationError):\n50:             AgentMetadata.model_construct(\n51:                 agent_name=\"test-agent\",\n52:                 language=\"python\",\n53:                 entrypoint=\"python main.py\",\n54:                 port=70000,\n55:             )\n56: \n57:     def test_agent_metadata_valid_port_range(self) -> None:\n58:         metadata = AgentMetadata.model_construct(\n59:             agent_name=\"test-agent\",\n60:             language=\"python\",\n61:             entrypoint=\"python main.py\",\n62:             port=1,\n63:         )\n64:         assert metadata.port == 1\n65: \n66:         metadata = AgentMetadata.model_construct(\n67:             agent_name=\"test-agent\",\n68:             language=\"python\",\n69:             entrypoint=\"python main.py\",\n70:             port=65535,\n71:         )\n72:         assert metadata.port == 65535\n73: \n74: \n75: class TestMetadataService:\n76:     def test_metadata_service_load_agent_metadata_yaml(self, tmp_path: Path) -> None:\n77:         metadata_content = \"\"\"\n78: agent_name: loaded-agent\n79: language: python\n80: entrypoint: python main.py\n81: port: 9000\n82: build_mode: cloud\n83: \"\"\"\n84:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n85:         metadata_file.write_text(metadata_content)\n86: \n87:         service = MetadataService()\n88:         metadata = service.load_metadata(tmp_path)\n89:         assert metadata.agent_name == \"loaded-agent\"\n90:         assert metadata.port == 9000\n91:         assert metadata.build_mode == \"cloud\"\n92: \n93:     def test_metadata_service_load_fallback_agent_yaml(self, tmp_path: Path) -> None:\n94:         metadata_content = \"\"\"\n95: agent_name: fallback-agent\n96: language: python\n97: entrypoint: python app.py\n98: \"\"\"\n99:         metadata_file = tmp_path / \"agent.yaml\"\n100:         metadata_file.write_text(metadata_content)\n101: \n102:         service = MetadataService()\n103:         metadata = service.load_metadata(tmp_path)\n104:         assert metadata.agent_name == \"fallback-agent\"\n105: \n106:     def test_metadata_service_load_fallback_metadata_yaml(self, tmp_path: Path) -> None:\n107:         metadata_content = \"\"\"\n108: agent_name: meta-agent\n109: language: java\n110: entrypoint: java -jar app.jar\n111: \"\"\"\n112:         metadata_file = tmp_path / \"metadata.yaml\"\n113:         metadata_file.write_text(metadata_content)\n114: \n115:         service = MetadataService()\n116:         metadata = service.load_metadata(tmp_path)\n117:         assert metadata.agent_name == \"meta-agent\"\n118:         assert metadata.language == \"java\"\n119: \n120:     def test_metadata_service_save(self, tmp_path: Path) -> None:\n121:         metadata = AgentMetadata.model_construct(\n122:             agent_name=\"save-test\",\n123:             language=\"python\",\n124:             entrypoint=\"python main.py\",\n125:             port=8080,\n126:             build_mode=\"local\",\n127:             description=\"Test agent\",\n128:         )\n129: \n130:         service = MetadataService()\n131:         saved_path = service.save_metadata(tmp_path, metadata)\n132: \n133:         assert saved_path.exists()\n134:         assert saved_path.name == \"agent_metadata.yaml\"\n135: \n136:         with open(saved_path) as f:\n137:             data = yaml.safe_load(f)\n138: \n139:         assert data[\"agent_name\"] == \"save-test\"\n140:         assert data[\"language\"] == \"python\"\n141:         assert data[\"port\"] == 8080\n142: \n143:     def test_metadata_service_save_excludes_none(self, tmp_path: Path) -> None:\n144:         metadata = AgentMetadata.model_construct(\n145:             agent_name=\"save-test\",\n146:             language=\"python\",\n147:             entrypoint=\"python main.py\",\n148:         )\n149: \n150:         service = MetadataService()\n151:         saved_path = service.save_metadata(tmp_path, metadata)\n152: \n153:         with open(saved_path) as f:\n154:             data = yaml.safe_load(f)\n155: \n156:         assert data[\"agent_name\"] == \"save-test\"\n157: \n158:     def test_metadata_service_load_no_files(self, tmp_path: Path) -> None:\n159:         service = MetadataService()\n160:         with pytest.raises(FileNotFoundError):\n161:             service.load_metadata(tmp_path)\n\n(End of file - total 161 lines)\n</content>","metadata":{"preview":"import pytest\nfrom pathlib import Path\nimport tempfile\nimport yaml\n\nfrom agentcube.services.metadata_service import AgentMetadata, MetadataService\nfrom pydantic import ValidationError\n\n\nclass TestAgentMetadata:\n    def test_agent_metadata_valid(self) -> None:\n        metadata = AgentMetadata.model_construct(\n            agent_name=\"test-agent\",\n            language=\"python\",\n            entrypoint=\"python main.py\",\n        )\n        assert metadata.agent_name == \"test-agent\"\n        assert metadata.language == \"python\"\n        assert metadata.port == 8080\n        assert metadata.build_mode == \"local\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/tests/test_metadata_service.py","time":{"start":1775877208665,"end":1775877208680}}}}
{"type":"tool_use","timestamp":1775877208684,"sessionID":"ses_28578efe2ffeHdJlje1Uvxen4e","part":{"id":"prt_d7a87ac63001ksjhqDv1uBvr7T","messageID":"msg_d7a8794da001FgGeuajgIcq2Ws","sessionID":"ses_28578efe2ffeHdJlje1Uvxen4e","type":"tool","tool":"read","callID":"toolu_tool-fe87cc7af01f4f0d965ce0d1c07f020e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/metadata_service.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/metadata_service.py</path>\n<type>file</type>\n<content>\n1: from pathlib import Path\n2: from typing import Optional, Dict, Any\n3: \n4: import yaml\n5: from pydantic import BaseModel, Field, field_validator\n6: \n7: \n8: class AgentMetadata(BaseModel):\n9:     agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n10:     description: str = Field(\"\", description=\"Human-readable summary\")\n11:     language: str = Field(\"python\", description=\"Programming language used\")\n12:     entrypoint: str = Field(..., description=\"Command to launch the agent\")\n13:     port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n14:     build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n15:     region: str = Field(\"\", description=\"Deployment region\")\n16:     version: str = Field(\"\", description=\"Semantic version string for publishing\")\n17:     image: Dict[str, Any] = Field(default_factory=dict, description=\"Container image information\")\n18:     auth: Dict[str, Any] = Field(default_factory=dict, description=\"Authentication configuration\")\n19:     requirements_file: str = Field(\"requirements.txt\", description=\"Python dependency file\")\n20:     registry_url: str = Field(\"\", description=\"Registry URL for image publishing\")\n21:     registry_username: str = Field(\"\", description=\"Registry username\")\n22:     registry_password: str = Field(\"\", description=\"Registry password\")\n23:     agent_endpoint: str = Field(\"\", description=\"Agent endpoint URL\")\n24:     workload_manager_url: str = Field(\"\", description=\"URL for the Workload Manager\")\n25:     router_url: str = Field(\"\", description=\"URL for the Router\")\n26:     readiness_probe_path: str = Field(\"\", description=\"Path for the readiness probe\")\n27:     readiness_probe_port: int = Field(8080, description=\"Port for the readiness probe\")\n28:     agent_id: str = Field(\"\", description=\"Agent ID assigned by AgentCube\")\n29:     session_id: str = Field(\"\", description=\"The session ID for the agent\")\n30:     k8s_deployment: Dict[str, Any] = Field(default_factory=dict, description=\"Kubernetes deployment information\")\n31: \n32:     @field_validator(\"language\")\n33:     @classmethod\n34:     def validate_language(cls, v: str) -> str:\n35:         allowed = [\"python\", \"java\"]\n36:         v_lower = v.lower()\n37:         if v_lower not in allowed:\n38:             raise ValueError(f\"language must be one of {allowed}\")\n39:         return v_lower\n40: \n41:     @field_validator(\"build_mode\")\n42:     @classmethod\n43:     def validate_build_mode(cls, v: str) -> str:\n44:         allowed = [\"local\", \"cloud\"]\n45:         v_lower = v.lower()\n46:         if v_lower not in allowed:\n47:             raise ValueError(f\"build_mode must be one of {allowed}\")\n48:         return v_lower\n49: \n50:     @field_validator(\"port\")\n51:     @classmethod\n52:     def validate_port(cls, v: int) -> int:\n53:         if not 1 <= v <= 65535:\n54:             raise ValueError(\"port must be between 1 and 65535\")\n55:         return v\n56: \n57: \n58: class MetadataService:\n59:     def __init__(self, verbose: bool = False) -> None:\n60:         self.verbose = verbose\n61: \n62:     def load_metadata(self, workspace_path: Path) -> AgentMetadata:\n63:         metadata_files = [\"agent_metadata.yaml\", \"agent.yaml\", \"metadata.yaml\"]\n64:         for filename in metadata_files:\n65:             filepath = workspace_path / filename\n66:             if filepath.exists():\n67:                 with open(filepath, \"r\", encoding=\"utf-8\") as f:\n68:                     data = yaml.safe_load(f) or {}\n69:                 return AgentMetadata(**data)\n70:         raise FileNotFoundError(\n71:             f\"No metadata file found in workspace: {workspace_path}\"\n72:         )\n73: \n74:     def save_metadata(self, workspace_path: Path, metadata: AgentMetadata) -> Path:\n75:         filepath = workspace_path / \"agent_metadata.yaml\"\n76:         data = metadata.model_dump(exclude_none=True)\n77:         with open(filepath, \"w\", encoding=\"utf-8\") as f:\n78:             yaml.dump(data, f, default_flow_style=False, indent=2, sort_keys=False)\n79:         return filepath\n\n(End of file - total 79 lines)\n</content>","metadata":{"preview":"from pathlib import Path\nfrom typing import Optional, Dict, Any\n\nimport yaml\nfrom pydantic import BaseModel, Field, field_validator\n\n\nclass AgentMetadata(BaseModel):\n    agent_name: str = Field(..., description=\"Unique name identifying the agent\")\n    description: str = Field(\"\", description=\"Human-readable summary\")\n    language: str = Field(\"python\", description=\"Programming language used\")\n    entrypoint: str = Field(..., description=\"Command to launch the agent\")\n    port: int = Field(8080, description=\"Port exposed by the agent runtime\")\n    build_mode: str = Field(\"local\", description=\"Build strategy: local or cloud\")\n    region: str = Field(\"\", description=\"Deployment region\")\n    version: str = Field(\"\", description=\"Semantic version string for publishing\")\n    image: Dict[str, Any] = Field(default_factory=dict, description=\"Container image information\")\n    auth: Dict[str, Any] = Field(default_factory=dict, description=\"Authentication configuration\")\n    requirements_file: str = Field(\"requirements.txt\", description=\"Python dependency file\")\n    registry_url: str = Field(\"\", description=\"Registry URL for image publishing\")","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/cmd/cli/agentcube/services/metadata_service.py","time":{"start":1775877208660,"end":1775877208683}}}}
