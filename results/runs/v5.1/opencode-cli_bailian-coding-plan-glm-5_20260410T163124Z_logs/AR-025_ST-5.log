= \"loaded-agent\"\n90:         assert metadata.port == 9000\n91:         assert metadata.build_mode == \"cloud\"\n92: \n93:     def test_metadata_service_load_fallback_agent_yaml(self, tmp_path: Path) -> None:\n94:         metadata_content = \"\"\"\n95: agent_name: fallback-agent\n96: language: python\n97: entrypoint: python app.py\n98: \"\"\"\n99:         metadata_file = tmp_path / \"agent.yaml\"\n100:         metadata_file.write_text(metadata_content)\n101: \n102:         service = MetadataService()\n103:         metadata = service.load_metadata(tmp_path)\n104:         assert metadata.agent_name == \"fallback-agent\"\n105: \n106:     def test_metadata_service_load_fallback_metadata_yaml(self, tmp_path: Path) -> None:\n107:         metadata_content = \"\"\"\n108: agent_name: meta-agent\n109: language: java\n110: entrypoint: java -jar app.jar\n111: \"\"\"\n112:         metadata_file = tmp_path / \"metadata.yaml\"\n113:         metadata_file.write_text(metadata_content)\n114: \n115:         service = MetadataService()\n116:         metadata = service.load_metadata(tmp_path)\n117:         assert metadata.agent_name == \"meta-agent\"\n118:         assert metadata.language == \"java\"\n119: \n120:     def test_metadata_service_save(self, tmp_path: Path) -> None:\n121:         metadata = AgentMetadata.model_construct(\n122:             agent_name=\"save-test\",\n123:             language=\"python\",\n124:             entrypoint=\"python main.py\",\n125:             port=8080,\n126:             build_mode=\"local\",\n127:             description=\"Test agent\",\n128:         )\n129: \n130:         service = MetadataService()\n131:         saved_path = service.save_metadata(tmp_path, metadata)\n132: \n133:         assert saved_path.exists()\n134:         assert saved_path.name == \"agent_metadata.yaml\"\n135: \n136:         with open(saved_path) as f:\n137:             data = yaml.safe_load(f)\n138: \n139:         assert data[\"agent_name\"] == \"save-test\"\n140:         assert data[\"language\"] == \"python\"\n141:         assert data[\"port\"] == 8080\n142: \n143:     def test_metadata_service_save_excludes_none(self, tmp_path: Path) -> None:\n144:         metadata = AgentMetadata.model_construct(\n145:             agent_name=\"save-test\",\n146:             language=\"python\",\n147:             entrypoint=\"python main.py\",\n148:         )\n149: \n150:         service = MetadataService()\n151:         saved_path = service.save_metadata(tmp_path, metadata)\n152: \n153:         with open(saved_path) as f:\n154:             data = yaml.safe_load(f)\n155: \n156:         assert data[\"agent_name\"] == \"save-test\"\n157: \n158:     def test_metadata_service_load_no_files(self, tmp_path: Path) -> None:\n159:         service = MetadataService()\n160:         with pytest.raises(FileNotFoundError):\n161:             service.load_metadata(tmp_path)\n162: \n163:     def test_metadata_service_update(self, tmp_path: Path) -> None:\n164:         metadata_content = \"\"\"\n165: agent_name: update-test\n166: language: python\n167: entrypoint: python main.py\n168: version: \"\"\n169: description: old description\n170: \"\"\"\n171:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n172:         metadata_file.write_text(metadata_content)\n173:         main_py = tmp_path / \"main.py\"\n174:         main_py.write_text(\"print('hello')\")\n175: \n176:         service = MetadataService()\n177:         updated = service.update_metadata(\n178:             tmp_path, {\"version\": \"v1.0.0\", \"description\": \"new description\"}\n179:         )\n180: \n181:         assert updated.version == \"v1.0.0\"\n182:         assert updated.description == \"new description\"\n183: \n184:         loaded = service.load_metadata(tmp_path)\n185:         assert loaded.version == \"v1.0.0\"\n186:         assert loaded.description == \"new description\"\n187: \n188:     def test_metadata_service_update_returns_metadata(self, tmp_path: Path) -> None:\n189:         metadata_content = \"\"\"\n190: agent_name: return-test\n191: language: python\n192: entrypoint: python main.py\n193: \"\"\"\n194:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n195:         metadata_file.write_text(metadata_content)\n196:         main_py = tmp_path / \"main.py\"\n197:         main_py.write_text(\"print('hello')\")\n198: \n199:         service = MetadataService()\n200:         result = service.update_metadata(tmp_path, {\"port\": 9000})\n201: \n202:         assert isinstance(result, AgentMetadata)\n203:         assert result.port == 9000\n204: \n205:     def test_validate_workspace_python(self, tmp_path: Path) -> None:\n206:         metadata_content = \"\"\"\n207: agent_name: validate-python\n208: language: python\n209: entrypoint: python main.py\n210: \"\"\"\n211:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n212:         metadata_file.write_text(metadata_content)\n213:         main_py = tmp_path / \"main.py\"\n214:         main_py.write_text(\"print('hello')\")\n215: \n216:         service = MetadataService()\n217:         result = service.validate_workspace(tmp_path)\n218:         assert result is True\n219: \n220:     def test_validate_python_workspace_has_py(self, tmp_path: Path) -> None:\n221:         metadata_content = \"\"\"\n222: agent_name: has-py-test\n223: language: python\n224: entrypoint: python main.py\n225: \"\"\"\n226:         metadata_file = tmp_path / \"agent_metadata.yaml\"\n227:         metadata_file.write_text(metadata_content)\n228:         main_py = tmp_path / \"main.py\"\n229:         main_py.write_text(\"print('hello')\")\n230: \n231:         service = MetadataService()\n232:         metadata = service.load_metadata(tmp_path)\n233:         service._validate_python_workspace(tmp_path, metadata)\n234: \n235:     def test_validate_python_workspace_no_py(self, tmp_path: Path) -> None:\n236:         metadata_content = \"\"\"\n237: agent_name: no-py-test\n238: language: python\n239: entrypoint: pytho