\t\tType:  \"PUBLIC KEY\",\n\t\tBytes: pubBytes,\n\t})\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, string(pemData))\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t}\n\t})\n\n\t_, err = NewAuthManager()\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"failed to load public key\")\n\tassert.Contains(t, err.Error(), \"public key is not RSA\")\n}\n\nfunc TestAuthMiddlewareInvalidSignature(t *testing.T) {\n\tprivateKey1, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tprivateKey2, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey1.PublicKey)\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t}\n\t})\n\n\tauthMgr, err := NewAuthManager()\n\trequire.NoError(t, err)\n\n\tgin.SetMode(gin.TestMode)\n\tengine := gin.New()\n\tapi := engine.Group(\"/api\")\n\tapi.Use(authMgr.AuthMiddleware())\n\tapi.POST(\"/test\", func(c *gin.Context) {\n\t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n\t})\n\n\ttokenSignedWithKey2 := generateTestJWT(privateKey2, false)\n\n\tw := httptest.NewRecorder()\n\treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+tokenSignedWithKey2)\n\tengine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 401, w.Code)\n\tassert.Contains(t, w.Body.String(), \"invalid signature\")\n}\n\nfunc TestAuthMiddlewareEmptyToken(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t}\n\t})\n\n\tauthMgr, err := NewAuthManager()\n\trequire.NoError(t, err)\n\n\tgin.SetMode(gin.TestMode)\n\tengine := gin.New()\n\tapi := engine.Group(\"/api\")\n\tapi.Use(authMgr.AuthMiddleware())\n\tapi.POST(\"/test\", func(c *gin.Context) {\n\t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n\t})\n\n\tw := httptest.NewRecorder()\n\treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \")\n\tengine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 401, w.Code)\n}\n\nfunc TestSetGetPublicKey(t *testing.T) {\n\tprivateKey1, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tprivateKey2, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey1.PublicKey)\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t}\n\t})\n\n\tauthMgr, err := NewAuthManager()\n\trequire.NoError(t, err)\n\n\tinitialKey := authMgr.GetPublicKey()\n\tassert.Equal(t, &privateKey1.PublicKey, initialKey)\n\n\tauthMgr.SetPublicKey(&privateKey2.PublicKey)\n\n\tnewKey := authMgr.GetPublicKey()\n\tassert.Equal(t, &privateKey2.PublicKey, newKey)\n\tassert.NotEqual(t, initialKey, newKey)\n}\n\nfunc TestPublicKeyConcurrency(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t}\n\t})\n\n\tauthMgr, err := NewAuthManager()\n\trequire.NoError(t, err)\n\n\tkey1, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tkey2, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\tkey3, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tnumOps := 100\n\tdone := make(chan bool, numOps)\n\n\tvar wg sync.WaitGroup\n\twg.Add(numOps)\n\n\tfor i := 0; i < numOps; i++ {\n\t\tgo func(idx int) {\n\t\t\tdefer wg.Done()\n\t\t\tif idx%3 == 0 {\n\t\t\t\tauthMgr.SetPublicKey(&key1.PublicKey)\n\t\t\t} else if idx%3 == 1 {\n\t\t\t\tauthMgr.SetPublicKey(&key2.PublicKey)\n\t\t\t} else {\n\t\t\t\tauthMgr.SetPublicKey(&key3.PublicKey)\n\t\t\t}\n\t\t\t_ = authMgr.GetPublicKey()\n\t\t\tdone <- true\n\t\t}(i)\n\t}\n\n\twg.Wait()\n\n\tfor i := 0; i < numOps; i++ {\n\t\tselect {\n\t\tcase <-done:\n\t\tcase <-time.After(5 * time.Second):\n\t\t\tt.Fatal(\"concurrent operation timed out\")\n\t\t}\n\t}\n\n\tfinalKey := authMgr.GetPublicKey()\n\tassert.NotNil(t, finalKey)\n}\n\nfunc TestAuthMiddlewareKeyRotation(t *testing.T) {\n\tkey1, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tkey2, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&key1.PublicKey)\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t}\n\t})\n\n\tauthMgr, err := NewAuthManager()\n\trequire.NoError(t, err)\n\n\tgin.SetMode(gin.TestMode)\n\tengine := gin.New()\n\tapi := engine.Group(\"/api\")\n\tapi.Use(authMgr.AuthMiddleware())\n\tapi.POST(\"/test\", func(c *gin.Context) {\n\t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n\t})\n\n\ttoken1 := generateTestJWT(key1, false)\n\n\tw := httptest.NewRecorder()\n\treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token1)\n\tengine.ServeHTTP(w, req)\n\tassert.Equal(t, 200, w.Code)\n\n\tauthMgr.SetPublicKey(&key2.PublicKey)\n\n\ttoken2 := generateTestJWT(key2, false)\n\n\tw = httptest.NewRecorder()\n\treq = httptest.NewRequest(\"POST\", \"/api/test\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token2)\n\tengine.ServeHTTP(w, req)\n\tassert.Equal(t, 200, w.Code)\n\n\tw = httptest.NewRecorder()\n\treq = httptest.NewRequest(\"POST\", \"/api/test\", nil)\n\treq.Header.Set(\"Authorization\", \"Bearer \"+token1)\n\tengine.ServeHTTP(w, req)\n\tassert.Equal(t, 401, w.Code)\n\tassert.Contains(t, w.Body.String(), \"invalid signature\")\n}\n\nfunc TestAuthMiddlewareMalformedAuthHeader(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv(PublicKeyEnvVar)\n\t\t}\n\t})\n\n\tauthMgr, err := NewAuthManager()\n\trequire.NoError(t, err)\n\n\tgin.SetMode(gin.TestMode)\n\tengine := gin.New()\n\tapi := engine.Group(\"/api\")\n\tapi.Use(authMgr.AuthMiddleware())\n\tapi.POST(\"/test\", func(c *gin.Context) {\n\t\tc.JSON(200, gin.H{\"status\": \"ok\"})\n\t})\n\n\tw := httptest.NewRecorder()\n\treq := httptest.NewRequest(\"POST\", \"/api/test\", nil)\n\treq.Header.Set(\"Authorization\", \"Basic some-token\")\n\tengine.ServeHTTP(w, req)\n\n\tassert.Equal(t, 401, w.Code)\n\tassert.Contains(t, w.Body.String(), \"invalid token format\")\n}\n\nfunc TestAuthMiddlewareNoBearerPrefix(t *testing.T) {\n\tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n\trequire.NoError(t, err)\n\n\tpublicKeyPEM := encodePublicKeyPEMForTest(&privateKey.PublicKey)\n\n\toldEnv := os.Getenv(PublicKeyEnvVar)\n\tos.Setenv(PublicKeyEnvVar, publicKeyPEM)\n\tt.Cleanup(func() {\n\t\tif oldEnv != \"\" {\n\t\t\tos.Setenv(PublicKeyEnvVar, oldEnv)\n\t\t} else {\n\t\t\tos.Unsetenv