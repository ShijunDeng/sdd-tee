vateKey, false)\n892: \n893: \tbody := &bytes.Buffer{}\n894: \twriter := multipart.NewWriter(body)\n895: \n896: \trequire.NoError(t, writer.WriteField(\"path\", \"upload.txt\"))\n897: \trequire.NoError(t, writer.Close())\n898: \n899: \treq := httptest.NewRequest(\"POST\", \"/api/files\", body)\n900: \treq.Header.Set(\"Content-Type\", writer.FormDataContentType())\n901: \treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n902: \n903: \tw := httptest.NewRecorder()\n904: \tserver.engine.ServeHTTP(w, req)\n905: \n906: \tassert.Equal(t, 400, w.Code)\n907: \n908: \tvar resp map[string]string\n909: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n910: \tassert.Equal(t, \"missing file\", resp[\"error\"])\n911: }\n912: \n913: func TestListFilesHandlerEmptyDirectory(t *testing.T) {\n914: \tserver := setupTestServer(t)\n915: \n916: \temptyDir := filepath.Join(server.workspace, \"emptydir\")\n917: \trequire.NoError(t, os.MkdirAll(emptyDir, 0755))\n918: \n919: \tauthMgr := server.authManager\n920: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n921: \trequire.NoError(t, err)\n922: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n923: \n924: \tvalidToken := generateTestJWT(privateKey, false)\n925: \n926: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=emptydir\", nil, \"\", validToken)\n927: \tassert.Equal(t, 200, w.Code)\n928: \n929: \tvar resp ListFilesResponse\n930: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n931: \tassert.Equal(t, \"emptydir\", resp.Path)\n932: \tassert.Len(t, resp.Files, 0)\n933: }\n934: \n935: func TestDownloadFileHandlerMIMETypeJSON(t *testing.T) {\n936: \tserver := setupTestServer(t)\n937: \n938: \tfilePath := filepath.Join(server.workspace, \"data.json\")\n939: \trequire.NoError(t, os.WriteFile(filePath, []byte(`{\"key\": \"value\"}`), 0644))\n940: \n941: \tauthMgr := server.authManager\n942: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n943: \trequire.NoError(t, err)\n944: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n945: \n946: \tvalidToken := generateTestJWT(privateKey, false)\n947: \n948: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.json\", nil, \"\", validToken)\n949: \tassert.Equal(t, 200, w.Code)\n950: \tassert.Equal(t, \"application/json\", w.Header().Get(\"Content-Type\"))\n951: \tassert.Equal(t, `{\"key\": \"value\"}`, w.Body.String())\n952: }\n953: \n954: func TestDownloadFileHandlerMIMETypeUnknown(t *testing.T) {\n955: \tserver := setupTestServer(t)\n956: \n957: \tfilePath := filepath.Join(server.workspace, \"data.xyz\")\n958: \trequire.NoError(t, os.WriteFile(filePath, []byte(\"unknown content\"), 0644))\n959: \n960: \tauthMgr := server.authManager\n961: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n962: \trequire.NoError(t, err)\n963: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n964: \n965: \tvalidToken := generateTestJWT(privateKey, false)\n966: \n967: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/data.xyz\", nil, \"\", validToken)\n968: \tassert.Equal(t, 200, w.Code)\n969: \tassert.Equal(t, \"application/octet-stream\", w.Header().Get(\"Content-Type\"))\n970: \tassert.Equal(t, \"unknown content\", w.Body.String())\n971: }\n972: \n973: func TestDownloadFileHandlerSymlinkInsideWorkspace(t *testing.T) {\n974: \tserver := setupTestServer(t)\n975: \n976: \ttargetFile := filepath.Join(server.workspace, \"target.txt\")\n977: \trequire.NoError(t, os.WriteFile(targetFile, []byte(\"target content\"), 0644))\n978: \n979: \tlinkPath := filepath.Join(server.workspace, \"link.txt\")\n980: \trequire.NoError(t, os.Symlink(targetFile, linkPath))\n981: \n982: \tauthMgr := server.authManager\n983: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n984: \trequire.NoError(t, err)\n985: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n986: \n987: \tvalidToken := generateTestJWT(privateKey, false)\n988: \n989: \tw := makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/link.txt\", nil, \"\", validToken)\n990: \tassert.Equal(t, 200, w.Code)\n991: \tassert.Equal(t, \"target content\", w.Body.String())\n992: }\n993: \n994: func TestFileLifecycle(t *testing.T) {\n995: \tserver := setupTestServer(t)\n996: \n997: \tauthMgr := server.authManager\n998: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n999: \trequire.NoError(t, err)\n1000: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1001: \n1002: \tvalidToken := generateTestJWT(privateKey, false)\n1003: \n1004: \ttestContent := []byte(\"lifecycle test content\")\n1005: \tencodedContent := base64.StdEncoding.EncodeToString(testContent)\n1006: \n1007: \tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"lifecycle/test.txt\", \"content\": \"%s\"}`, encodedContent))\n1008: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n1009: \tassert.Equal(t, 200, w.Code)\n1010: \n1011: \tvar uploadResp FileInfo\n1012: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &uploadResp))\n1013: \tassert.Equal(t, \"lifecycle/test.txt\", uploadResp.Path)\n1014: \n1015: \tw = makeAuthenticatedRequest(t, server, \"GET\", \"/api/files?path=lifecycle\", nil, \"\", validToken)\n1016: \tassert.Equal(t, 200, w.Code)\n1017: \n1018: \tvar listResp ListFilesResponse\n1019: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &listResp))\n1020: \tassert.Equal(t, \"lifecycle\", listResp.Path)\n1021: \tassert.Len(t, listResp.Files, 1)\n1022: \tassert.Equal(t, \"test.txt\", listResp.Files[0].Name)\n1023: \tassert.False(t, listResp.Files[0].IsDir)\n1024: \n1025: \tw = makeAuthenticatedRequest(t, server, \"GET\", \"/api/files/lifecycle/test.txt\", nil, \"\", validToken)\n1026: \tassert.Equal(t, 200, w.Code)\n1027: \tassert.Equal(t, string(testContent), w.Body.String())\n1028: \n1029: \tactualContent, err := os.ReadFile(filepath.Join(server.workspace, \"lifecycle/test.txt\"))\n1030: \trequire.NoError(t, err)\n1031: \tassert.Equal(t, testContent, actualContent)\n1032: }\n1033: \n1034: func TestUploadLargeFile(t *testing.T) {\n1035: \tserver := setupTestServer(t)\n1036: \n1037: \tauthMgr := server.authManager\n1038: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1039: \trequire.NoError(t, err)\n1040: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1041: \n1042: \tvalidToken := generateTestJWT(privateKey, false)\n1043: \n1044: \tlargeContent := make([]byte, 30*1024*1024)\n1045: \tfor i := range largeContent {\n1046: \t\tlargeContent[i] = byte(i % 256)\n1047: \t}\n1048: \tencodedContent := base64.StdEncoding.EncodeToString(largeContent)\n1049: \n1050: \tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"large.bin\", \"content\": \"%s\"}`, encodedContent))\n1051: \tw := makeAuthenticatedRequest(t, server, \"POST\", \"/api/files\", uploadBody, \"application/json\", validToken)\n1052: \tassert.Equal(t, 200, w.Code)\n1053: \n1054: \tvar uploadResp FileInfo\n1055: \trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &uploadResp))\n1056: \tassert.Equal(t, \"large.bin\", uploadResp.Path)\n1057: \n1058: \tactualContent, err := os.ReadFile(filepath.Join(server.workspace, \"large.bin\"))\n1059: \trequire.NoError(t, err)\n1060: \tassert.Equal(t, largeContent, actualContent)\n1061: }\n1062: \n1063: func TestConcurrentFileOperations(t *testing.T) {\n1064: \tserver := setupTestServer(t)\n1065: \n1066: \tauthMgr := server.authManager\n1067: \tprivateKey, err := rsa.GenerateKey(rand.Reader, 2048)\n1068: \trequire.NoError(t, err)\n1069: \tauthMgr.SetPublicKey(&privateKey.PublicKey)\n1070: \n1071: \tvalidToken := generateTestJWT(privateKey, false)\n1072: \n1073: \tgin.SetMode(gin.TestMode)\n1074: \n1075: \tnumOps := 10\n1076: \tdone := make(chan bool, numOps)\n1077: \n1078: \tfor i := 0; i < numOps; i++ {\n1079: \t\tgo func(idx int) {\n1080: \t\t\tcontent := []byte(fmt.Sprintf(\"concurrent content %d\", idx))\n1081: \t\t\tencodedContent := base64.StdEncoding.EncodeToString(content)\n1082: \n1083: \t\t\tuploadBody := bytes.NewBufferString(fmt.Sprintf(`{\"path\": \"concurrent%d.txt\", \"content\": \"%s\"}`, idx, encodedContent))\n1084: \t\t\tw := httptest.NewRecorder()\n1085: \t\t\treq := httptest.NewRequest(\"POST\", \"/api/files\", uploadBody)\n1086: \t\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n1087: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n1088: \t\t\tserver.engine.ServeHTTP(w, req)\n1089: \t\t\tassert.Equal(t, 200, w.Code)\n1090: \n1091: \t\t\tw = httptest.NewRecorder()\n1092: \t\t\treq = httptest.NewRequest(\"GET\", fmt.Sprintf(\"/api/files/concurrent%d.txt\", idx), nil)\n1093: \t\t\treq.Header.Set(\"Authorization\", \"Bearer \"+validToken)\n1094: \t\t\tserver.engine.ServeHTTP(w, req)\n1095: \t\t\tassert.Equal(t, 200, w.Code)\n1096: \t\t\tassert.Equal(t, string(content), w.Body.String())\n1097: \n1098: \t\t\tdone <- true\n1099: \t\t}(i)\n1100: \t}\n1101: \n1102: \tfor i := 0; i < numOps; i++ {\n1103: \t\tselect {\n1104: \t\tcase <-done:\n1105: \t\tcase <-time.After(10 * time.Second):\n1106: \t\t\tt.Fatal(\"concurrent operation timed out\")\n1107: \t\t}\n1108: \t}\n1109: }\n\n(End of file - total 1109 lines)\n</content>","metadata":{"preview":"package picod\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/rand\"\n\t\"crypto/rsa\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"io\"\n\t\"mime/multipart\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/picod/picod_test.go","time":{"start":1775863770711,"end":1775863770743}}}}
