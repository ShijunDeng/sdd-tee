\n42: \n43: type ValidationError struct {\n44: \tField  string\n45: \tReason string\n46: }\n47: \n48: func (e *ValidationError) Error() string {\n49: \treturn fmt.Sprintf(\"validation error: %s - %s\", e.Field, e.Reason)\n50: }\n51: \n52: type NotFoundError struct {\n53: \tResource string\n54: \tName     string\n55: }\n56: \n57: func (e *NotFoundError) Error() string {\n58: \treturn fmt.Sprintf(\"not found: %s/%s\", e.Resource, e.Name)\n59: }\n60: \n61: type InternalError struct {\n62: \tErr error\n63: }\n64: \n65: func (e *InternalError) Error() string {\n66: \treturn fmt.Sprintf(\"internal error: %v\", e.Err)\n67: }\n68: \n69: type ServiceUnavailableError struct {\n70: \tDependency string\n71: }\n72: \n73: func (e *ServiceUnavailableError) Error() string {\n74: \treturn fmt.Sprintf(\"service unavailable: %s\", e.Dependency)\n75: }\n76: \n77: type ConflictError struct {\n78: \tResource string\n79: \tErr      error\n80: }\n81: \n82: func (e *ConflictError) Error() string {\n83: \treturn fmt.Sprintf(\"conflict on %s: %v\", e.Resource, e.Err)\n84: }\n85: \n86: type DeletionReason string\n87: \n88: const (\n89: \tDeletionReasonIdleTimeout        DeletionReason = \"IdleTimeout\"\n90: \tDeletionReasonMaxDurationReached DeletionReason = \"MaxDurationReached\"\n91: \tDeletionReasonUserRequest        DeletionReason = \"UserRequest\"\n92: )\n93: \n94: func HandleError(w http.ResponseWriter, _ *http.Request, err error) {\n95: \tw.Header().Set(\"Content-Type\", \"application/json\")\n96: \n97: \tvar resp ErrorResponse\n98: \tvar status int\n99: \n100: \tswitch e := err.(type) {\n101: \tcase *ValidationError:\n102: \t\tstatus = http.StatusBadRequest\n103: \t\tresp = ErrorResponse{\n104: \t\t\tCode:    \"VALIDATION_ERROR\",\n105: \t\t\tMessage: \"Invalid request parameter\",\n106: \t\t\tDetails: map[string]string{\"field\": e.Field, \"reason\": e.Reason},\n107: \t\t}\n108: \tcase *NotFoundError:\n109: \t\tstatus = http.StatusNotFound\n110: \t\tresp = ErrorResponse{\n111: \t\t\tCode:    \"NOT_FOUND\",\n112: \t\t\tMessage: e.Error(),\n113: \t\t}\n114: \tcase *ServiceUnavailableError:\n115: \t\tstatus = http.StatusServiceUnavailable\n116: \t\tresp = ErrorResponse{\n117: \t\t\tCode:    \"SERVICE_UNAVAILABLE\",\n118: \t\t\tMessage: e.Error(),\n119: \t\t}\n120: \tcase *InternalError:\n121: \t\tstatus = http.StatusInternalServerError\n122: \t\tresp = ErrorResponse{\n123: \t\t\tCode:    \"INTERNAL_ERROR\",\n124: \t\t\tMessage: \"Unexpected server error\",\n125: \t\t}\n126: \tdefault:\n127: \t\tstatus = http.StatusInternalServerError\n128: \t\tresp = ErrorResponse{\n129: \t\t\tCode:    \"INTERNAL_ERROR\",\n130: \t\t\tMessage: \"Unexpected server error\",\n131: \t\t}\n132: \t}\n133: \n134: \tw.WriteHeader(status)\n135: \tjson.NewEncoder(w).Encode(resp)\n136: }\n\n(End of file - total 136 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype Handler interface {\n\tRegister(r chi.Router)\n}\n\ntype Logger interface {\n\tInfo(msg string, args ...any)\n\tError(msg string, args ...any)","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types.go","time":{"start":1775847940056,"end":1775847940065}}}}
{"type":"tool_use","timestamp":1775847940078,"sessionID":"ses_2873782adfferdluqTqD82CWpe","part":{"id":"prt_d78c91fbe001se5O9DahG6ORV8","messageID":"msg_d78c904f6001358kob1N25lWlE","sessionID":"ses_2873782adfferdluqTqD82CWpe","type":"tool","tool":"read","callID":"toolu_tool-2c986d75e2bc4044a874d73fef2bbbeb","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go</path>\n<type>file</type>\n<content>\n1: package types\n2: \n3: import (\n4: \t\"fmt\"\n5: \t\"time\"\n6: )\n7: \n8: const (\n9: \tAgentRuntimeKind    = \"AgentRuntime\"\n10: \tCodeInterpreterKind = \"CodeInterpreter\"\n11: \tSandboxKind         = \"Sandbox\"\n12: \tSandboxClaimKind    = \"SandboxClaim\"\n13: )\n14: \n15: type CreateSandboxRequest struct {\n16: \tKind      string `json:\"kind\"`\n17: \tName      string `json:\"name\"`\n18: \tNamespace string `json:\"namespace\"`\n19: }\n20: \n21: func (r *CreateSandboxRequest) Validate() error {\n22: \tif r.Kind != AgentRuntimeKind && r.Kind != CodeInterpreterKind {\n23: \t\treturn fmt.Errorf(\"kind must be %s or %s\", AgentRuntimeKind, CodeInterpreterKind)\n24: \t}\n25: \tif r.Namespace == \"\" {\n26: \t\treturn fmt.Errorf(\"namespace is required\")\n27: \t}\n28: \tif r.Name == \"\" {\n29: \t\treturn fmt.Errorf(\"name is required\")\n30: \t}\n31: \treturn nil\n32: }\n33: \n34: type CreateSandboxResponse struct {\n35: \tSessionID   string              `json:\"sessionId\"`\n36: \tSandboxID   string              `json:\"sandboxId\"`\n37: \tSandboxName string              `json:\"sandboxName\"`\n38: \tEntryPoints []SandboxEntryPoint `json:\"entryPoints\"`\n39: }\n40: \n41: type SandboxEntryPoint struct {\n42: \tPath     string `json:\"path\"`\n43: \tProtocol string `json:\"protocol\"`\n44: \tEndpoint string `json:\"endpoint\"`\n45: }\n46: \n47: type SandboxInfo struct {\n48: \tKind               string              `json:\"kind\"`\n49: \tSandboxID          string              `json:\"sandboxId\"`\n50: \tSandboxNamespace   string              `json:\"sandboxNamespace\"`\n51: \tSandboxName        string              `json:\"sandboxName\"`\n52: \tName               string              `json:\"name\"`\n53: \tSessionID          string              `json:\"sessionId\"`\n54: \tCreatedAt          time.Time           `json:\"createdAt\"`\n55: \tExpiresAt          time.Time           `json:\"expiresAt\"`\n56: \tStatus             string              `json:\"status\"`\n57: \tEntryPoints        []SandboxEntryPoint `json:\"entryPoints\"`\n58: \tUserToken          string              `json:\"userToken,omitempty\"`\n59: \tServiceAccount     string              `json:\"serviceAccount,omitempty\"`\n60: \tServiceAccountName string              `json:\"serviceAccountName,omitempty\"`\n61: \tLastActivity       time.Time           `json:\"lastActivity,omitempty\"`\n62: }\n\n(End of file - total 62 lines)\n</content>","metadata":{"preview":"package types\n\nimport (\n\t\"fmt\"\n\t\"time\"\n)\n\nconst (\n\tAgentRuntimeKind    = \"AgentRuntime\"\n\tCodeInterpreterKind = \"CodeInterpreter\"\n\tSandboxKind         = \"Sandbox\"\n\tSandboxClaimKind    = \"SandboxClaim\"\n)\n\ntype CreateSandboxRequest struct {\n\tKind      string `json:\"kind\"`\n\tName      string `json:\"name\"`\n\tNamespace string `json:\"namespace\"`\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/common/types/sandbox.go","time":{"start":1775847940058,"end":1775847940075}}}}
