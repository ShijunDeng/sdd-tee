lient:\n    \"\"\"HTTP client for Router data plane API (Code Interpreter).\"\"\"\n\n    DEFAULT_TIMEOUT = 120\n    DEFAULT_CONNECT_TIMEOUT = 5.0\n    DEFAULT_POOL_CONNECTIONS = 10\n    DEFAULT_POOL_MAXSIZE = 10\n    SESSION_HEADER = \"x-agentcube-session-id\"\n\n    def __init__(\n        self,\n        session_id: str,\n        router_url: Optional[str] = None,\n        namespace: Optional[str] = None,\n        cr_name: Optional[str] = None,\n        base_url: Optional[str] = None,\n        timeout: int = DEFAULT_TIMEOUT,\n        connect_timeout: float = DEFAULT_CONNECT_TIMEOUT,\n        pool_connections: int = DEFAULT_POOL_CONNECTIONS,\n        pool_maxsize: int = DEFAULT_POOL_MAXSIZE,\n    ) -> None:\n        self.session_id = session_id\n        self.timeout = timeout\n        self.connect_timeout = connect_timeout\n        self._logger = get_logger(__name__)\n\n        if base_url:\n            self.base_url = base_url\n        else:\n            if router_url and namespace and cr_name:\n                base_path = f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\"\n                self.base_url = urljoin(router_url, base_path)\n            else:\n                raise ValueError(\"Either base_url or router_url, namespace, and cr_name must be provided\")\n\n        self.session = create_session(pool_connections, pool_maxsize)\n        self.session.headers[self.SESSION_HEADER] = session_id\n\n    def _request(\n        self,\n        method: str,\n        endpoint: str,\n        body: Optional[bytes] = None,\n        timeout_override: Optional[float] = None,\n        **kwargs,\n    ) -> requests.Response:\n        \"\"\"Make a request to the data plane.\n\n        Args:\n            method: HTTP method.\n            endpoint: Relative endpoint path.\n            body: Optional JSON body bytes.\n            timeout_override: Optional read timeout override.\n            **kwargs: Additional request kwargs.\n\n        Returns:\n            Response object.\n        \"\"\"\n        url = urljoin(self.base_url, endpoint)\n        if body:\n            kwargs[\"data\"] = body\n            headers = kwargs.get(\"headers\", {})\n            headers[\"Content-Type\"] = \"application/json\"\n            kwargs[\"headers\"] = headers\n\n        read_timeout = timeout_override if timeout_override is not None else self.timeout\n        timeout_tuple = (self.connect_timeout, read_timeout)\n        response = self.session.request(method, url, timeout=timeout_tuple, **kwargs)\n        response.raise_for_status()\n        return response\n\n    def execute_command(\n        self,\n        command: Union[str, List[str]],\n        timeout: Optional[float] = None,\n    ) -> str:\n        \"\"\"Execute a command in the code interpreter.\n\n        Args:\n            command: Command string or list of command parts.\n            timeout: Timeout in seconds (defaults to self.timeout).\n\n        Returns:\n            stdout from command execution.\n\n        Raises:\n            CommandExecutionError: If command returns non-zero exit code.\n        \"\"\"\n        if isinstance(command, str):\n            cmd_list = command.split()\n        else:\n            cmd_list = list(command)\n\n        timeout_value = timeout if timeout is not None else self.timeout\n        timeout_str = f\"{timeout_value}s\"\n\n        body = {\n            \"command\": cmd_list,\n            \"timeout\": timeout_str,\n        }\n\n        read_timeout = timeout_value + 2.0\n        response = self._request(\"POST\", \"api/execute\", json.dumps(body).encode(), timeout_override=read_timeout)\n        data = response.json()\n\n        exit_code = data.get(\"exit_code\", 0)\n        if exit_code != 0:\n            stderr = data.get(\"stderr\", \"\")\n            command_str = \" \".join(cmd_list) if isinstance(command, list) else command\n            raise CommandExecutionError(exit_code, stderr, command_str)\n\n        return data.get(\"stdout\", \"\")\n\n    def run_code(\n        self,\n        language: str,\n        code: str,\n        timeout: Optional[float] = None,\n    ) -> str:\n        \"\"\"Run code in the code interpreter.\n\n        Args:\n            language: Programming language (python, py, python3).\n            code: Code content to run.\n            timeout: Timeout in seconds.\n\n        Returns:\n            stdout from code execution.\n        \"\"\"\n        raise NotImplementedError(\"run_code is implemented in CodeInterpreterClient\")\n\n    def write_file(\n        self,\n        content: str,\n        remote_path: str,\n    ) -> None:\n        \"\"\"Write content to a file in the code interpreter.\n\n        Args:\n            content: File content (will be base64 encoded).\n            remote_path: Path to write the file to.\n        \"\"\"\n        encoded_content = base64.b64encode(content.encode()).decode()\n        body = {\n            \"path\": remote_path,\n            \"content\": encoded_content,\n            \"mode\": \"0644\",\n        }\n        self._request(\"POST\", \"api/files\", json.dumps(body).encode())\n\n    def upload_file(\n        self,\n        local_path: str,\n        remote_path: str,\n    ) -> None:\n        \"\"\"Upload a local file to the code interpreter.\n\n        Args:\n            local_path: Local file path to upload.\n            remote_path: Remote path to upload to.\n        \"\"\"\n        with open(local_path, \"rb\") as f:\n            files = {\"file\": f}\n            data = {\"path\": remote_path, \"mode\": \"0644\"}\n            headers = {self.SESSION_HEADER: self.session_id}\n            url = urljoin(self.base_url, \"api/files\")\n            timeout_tuple = (self.connect_timeout, self.timeout)\n            response = self.session.post(url, files=files, data=data, headers=headers, timeout=timeout_tuple)\n            response.raise_for_status()\n\n    def download_file(\n        self,\n        remote_path: str,\n        local_path