dout\": \"\"}\n77:         mock_response.raise_for_status = MagicMock()\n78:         client._request = MagicMock(return_value=mock_response)\n79: \n80:         client.execute_command(\"python3 script.py\", timeout=30)\n81:         call_args = client._request.call_args\n82:         import json\n83:         body = json.loads(call_args.args[2].decode())\n84:         assert body[\"command\"] == [\"python3\", \"script.py\"]\n85:         assert body[\"timeout\"] == \"30s\"\n86: \n87:     def test_execute_command_timeout_buffer(self) -> None:\n88:         client = CodeInterpreterDataPlaneClient(\n89:             session_id=\"session-123\",\n90:             base_url=\"http://router/v1/invocations/\",\n91:             timeout=60,\n92:         )\n93:         mock_response = MagicMock()\n94:         mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n95:         mock_response.raise_for_status = MagicMock()\n96:         client._request = MagicMock(return_value=mock_response)\n97: \n98:         client.execute_command(\"cmd\", timeout=30)\n99:         call_args = client._request.call_args\n100:         assert call_args.kwargs[\"timeout_override\"] == 32.0\n101: \n102:     def test_execute_command_nonzero_exit(self) -> None:\n103:         client = CodeInterpreterDataPlaneClient(\n104:             session_id=\"session-123\",\n105:             base_url=\"http://router/v1/invocations/\",\n106:         )\n107:         mock_response = MagicMock()\n108:         mock_response.json.return_value = {\"exit_code\": 1, \"stderr\": \"error msg\"}\n109:         mock_response.raise_for_status = MagicMock()\n110:         client._request = MagicMock(return_value=mock_response)\n111: \n112:         with pytest.raises(CommandExecutionError) as exc_info:\n113:             client.execute_command(\"python3 script.py\")\n114:         assert exc_info.value.exit_code == 1\n115:         assert exc_info.value.stderr == \"error msg\"\n116: \n117:     def test_execute_command_list_input(se