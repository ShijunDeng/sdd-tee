ncode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_exceptions.py","before":"import pytest\n\nfrom agentcube.exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    SessionError,\n    DataPlaneError,\n)\n\n\nclass TestExceptionHierarchy:\n    def test_agent_cube_error_is_exception(self) -> None:\n        assert issubclass(AgentCubeError, Exception)\n\n    def test_command_execution_error_is_agent_cube_error(self) -> None:\n        assert issubclass(CommandExecutionError, AgentCubeError)\n\n    def test_session_error_is_agent_cube_error(self) -> None:\n        assert issubclass(SessionError, AgentCubeError)\n\n    def test_data_plane_error_is_agent_cube_error(self) -> None:\n        assert issubclass(DataPlaneError, AgentCubeError)\n\n\nclass TestCommandExecutionError:\n    def test_constructor_with_all_params(self) -> None:\n        error = CommandExecutionError(exit_code=2, stderr=\"failed\", command=\"ls -la\")\n        assert error.exit_code == 2\n        assert error.stderr == \"failed\"\n        assert error.command == \"ls -la\"\n\n    def test_constructor_default_command(self) -> None:\n        error = CommandExecutionError(exit_code=1, stderr=\"error\")\n        assert error.exit_code == 1\n        assert error.stderr == \"error\"\n        assert error.command is None\n\n    def test_message_format(self) -> None:\n        error = CommandExecutionError(exit_code=2, stderr=\"failed output\")\n        assert str(error) == \"Command failed (exit 2): failed output\"\n\n    def test_message_format_with_command(self) -> None:\n        error = CommandExecutionError(exit_code=2, stderr=\"failed\", command=\"ls -la\")\n        assert str(error) == \"Command failed (exit 2): failed\"\n\n\nclass TestSessionError:\n    def test_session_error_docstring(self) -> None:\n        assert \"session\" in SessionError.__doc__.lower()\n\n    def test_session_error_inherits_from_agent_cube_error(self) -> None:\n        error = SessionError(\"test error\")\n        assert isinstance(error, AgentCubeError)\n        assert isinstance(error, Exception)\n\n\nclass TestDataPlaneError:\n    def test_data_plane_error_docstring(self) -> None:\n        assert \"data plane\" in DataPlaneError.__doc__.lower()\n\n    def test_data_plane_error_inherits_from_agent_cube_error(self) -> None:\n        error = DataPlaneError(\"test error\")\n        assert isinstance(error, AgentCubeError)\n        assert isinstance(error, Exception)","after":"import pytest\n\nfrom agentcube.exceptions import (\n    AgentCubeError,\n    CommandExecutionError,\n    SessionError,\n    DataPlaneError,\n)\n\n\nclass TestExceptionHierarchy:\n    def test_agent_cube_error_is_exception(self) -> None:\n        assert issubclass(AgentCubeError, Exception)\n\n    def test_command_execution_error_is_agent_cube_error(self) -> None:\n        assert issubclass(CommandExecutionError, AgentCubeError)\n\n    def test_session_error_is_agent_cube_error(self) -> None:\n        assert issubclass(SessionError, AgentCubeError)\n\n    def test_data_plane_error_is_agent_cube_error(self) -> None:\n        assert issubclass(DataPlaneError, AgentCubeError)\n\n\nclass TestCommandExecutionError:\n    def test_constructor_with_all_params(self) -> None:\n        error = CommandExecutionError(exit_code=2, stderr=\"failed\", command=\"ls -la\")\n        assert error.exit_code == 2\n        assert error.stderr == \"failed\"\n        assert error.command == \"ls -la\"\n\n    def test_constructor_default_command(self) -> None:\n        error = CommandExecutionError(exit_code=1, stderr=\"error\")\n        assert error.exit_code == 1\n        assert error.stderr == \"error\"\n        assert error.command is None\n\n    def test_message_format(self) -> None:\n        error = CommandExecutionError(exit_code=2, stderr=\"failed output\")\n        assert str(error) == \"Command failed (exit 2): failed output\"\n\n    def test_message_format_with_command(self) -> None:\n        error = CommandExecutionError(exit_code=2, stderr=\"failed\", command=\"ls -la\")\n        assert str(error) == \"Command failed (exit 2): failed\"\n\n\nclass TestSessionError:\n    def test_session_error_docstring(self) -> None:\n        assert SessionError.__doc__ is not None\n        assert \"session\" in SessionError.__doc__.lower()\n\n    def test_session_error_inherits_from_agent_cube_error(self) -> None:\n        error = SessionError(\"test error\")\n        assert isinstance(error, AgentCubeError)\n        assert isinstance(error, Exception)\n\n\nclass TestDataPlaneError:\n    def test_data_plane_error_docstring(self) -> None:\n        assert DataPlaneError.__doc__ is not None\n        assert \"data plane\" in DataPlaneError.__doc__.lower()\n\n    def test_data_plane_error_inherits_from_agent_cube_error(self) -> None:\n        error = DataPlaneError(\"test error\")\n        assert isinstance(error, AgentCubeError)\n        assert isinstance(error, Exception)","additions":2,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_exceptions.py","time":{"start":1775882990958,"end":1775882991403}}}}
