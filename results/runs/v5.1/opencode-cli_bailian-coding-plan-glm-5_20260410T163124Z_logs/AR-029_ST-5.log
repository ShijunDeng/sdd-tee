ional[str]) -> str:\n35:         resolved_url = router_url or os.environ.get(\"ROUTER_URL\")\n36:         if not resolved_url:\n37:             raise ValueError(\"Router URL must be provided via argument or ROUTER_URL environment variable\")\n38:         return resolved_url\n39: \n40:     def _init_data_plane(self) -> AgentRuntimeDataPlaneClient:\n41:         return AgentRuntimeDataPlaneClient(\n42:             router_url=self.router_url,\n43:             namespace=self.namespace,\n44:             agent_name=self.agent_name,\n45:             timeout=self.timeout,\n46:             connect_timeout=self.connect_timeout,\n47:         )\n48: \n49:     def __enter__(self) -> \"AgentRuntimeClient\":\n50:         return self\n51: \n52:     def __exit__(self, exc_type: Optional[type], exc_val: Optional[BaseException], exc_tb: Optional[Any]) -> None:\n53:         self.close()\n54: \n55:     def invoke(self, payload: Dict[str, Any], timeout: Optional[float] = None) -> Any:\n56:         if not self.session_id:\n57:             raise ValueError(\"AgentRuntime session_id is not initialized\")\n58:         resp = self.dp_client.invoke(self.session_id, payload, timeout=timeout)\n59:         return resp.json()\n60: \n61:     def close(self) -> None:\n62:         self.dp_client.close()\n\n(End of file - total 62 lines)\n</content>","metadata":{"preview":"import logging\nimport os\nfrom typing import Any, Dict, Optional\n\nfrom requests import Response\n\nfrom agentcube.clients.agent_runtime_data_plane import AgentRuntimeDataPlaneClient\nfrom agentcube.utils.log import get_logger\n\n\nclass AgentRuntimeClient:\n    def __init__(\n        self,\n        agent_name: str,\n        namespace: str = \"default\",\n        router_url: Optional[str] = None,\n        verbose: bool = False,\n        session_id: Optional[str] = None,\n        timeout: int = 120,\n        connect_timeout: float = 5.0,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_