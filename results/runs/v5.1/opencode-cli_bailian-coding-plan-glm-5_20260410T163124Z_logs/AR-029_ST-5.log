s = MagicMock()\n+        client.session.post = MagicMock(return_value=mock_response)\n \n+        session_id = client.create_session(name=\"test\", namespace=\"default\")\n+        assert session_id == \"session-123\"\n+        call_args = client.session.post.call_args\n+        assert call_args.kwargs[\"json\"][\"metadata\"] is None\n+\n+\n class TestDeleteSession:\n     def test_delete_session_success(self) -> None:\n         client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n         mock_response = MagicMock()\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_control_plane.py","before":"import pytest\nfrom unittest.mock import MagicMock, patch, mock_open\nimport requests\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\n\n\nclass TestControlPlaneClientInit:\n    def test_init_default_timeout(self) -> None:\n        with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_url\", return_value=\"http://wm\"):\n            with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_token\", return_value=\"\"):\n                client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n                assert client.timeout == 120\n                assert client.connect_timeout == 5.0\n\n    def test_init_custom_timeout(self) -> None:\n        with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_url\", return_value=\"http://wm\"):\n            with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_token\", return_value=\"\"):\n                client = ControlPlaneClient(\n                    workload_manager_url=\"http://wm\",\n                    timeout=60,\n                    connect_timeout=3.0,\n                )\n                assert client.timeout == 60\n                assert client.connect_timeout == 3.0\n\n    def test_init_session_created(self) -> None:\n        with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_url\", return_value=\"http://wm\"):\n            with patch(\"agentcube.clients.control_plane.ControlPlaneClient._resolve_token\", return_value=\"\"):\n                client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n                assert client.session is not None\n                assert \"Content-Type\" in client.session.headers\n\n\nclass TestAuthTokenResolution:\n    def test_auth_token_explicit(self) -> None:\n        client = ControlPlaneClient(\n            workload_manager_url=\"http://wm\",\n            auth_token=\"explicit-token\",\n        )\n        assert client.session.headers[\"Authorization\"] == \"Bearer explicit-token\"\n\n    def test_auth_token_from_file(self) -> None:\n        with patch(\"agentcube.clients.control_plane.read_token_from_file\", return_value=\"file-token\"):\n            client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n            assert client.session.headers[\"Authorization\"] == \"Bearer file-token\"\n\n    def test_auth_token_none(self) -> None:\n        with patch(\"agentcube.utils.utils.read_token_from_file\", return_value=\"\"):\n            client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n            assert \"Authorization\" not in client.session.headers\n\n\nclass TestURLResolution:\n    def test_url_explicit(self) -> None:\n        client = ControlPlaneClient(workload_manager_url=\"http://explicit-url\")\n        assert client.base_url == \"http://explicit-url\"\n\n    def test_url_from_env(self) -> None:\n        import os\n        with patch.dict(os.environ, {\"WORKLOAD_MANAGER_URL\": \"http://env-url\"}):\n            client = ControlPlaneClient()\n            assert client.base_url == \"http://env-url\"\n\n    def test_url_required_raises(self) -> None:\n        import os\n        with patch.dict(os.environ, {}, clear=True):\n            with pytest.raises(ValueError, match=\"workload_manager_url must be provided\"):\n                ControlPlaneClient()\n\n\nclass TestCreateSession:\n    def test_create_session_success(self) -> None:\n        client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"sessionId\": \"session-123\"}\n        mock_response.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_response)\n\n        session_id = client.create_session(name=\"test\", namespace=\"default\", ttl=3600)\n        assert session_id == \"session-123\"\n\n    def test_create_session_missing_session_id(self) -> None:\n        client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n        mock_response = MagicMock()\n        mock_response.json.return_value = {}\n        mock_response.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_response)\n\n        with pytest.raises(ValueError, match=\"sessionId not found\"):\n            client.create_session(name=\"test\", namespace=\"default\")\n\n    def test_create_session_with_metadata(self) -> None:\n        client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"sessionId\": \"session-123\"}\n        mock_response.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_response)\n\n        session_id = client.create_session(\n            name=\"test\",\n            namespace=\"default\",\n            metadata={\"key\": \"value\"},\n        )\n        assert session_id == \"session-123\"\n        call_args = client.session.post.call_args\n        assert call_args.kwargs[\"json\"][\"metadata\"] == {\"key\": \"value\"}\n\n\nclass TestDeleteSession:\n    def test_delete_session_success(self) -> None:\n        client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        client.session.delete = MagicMock(return_value=mock_response)\n\n        result = client.delete_session(\"session-123\")\n        assert result == True\n\n    def test_delete_session_404_returns_true(self) -> None:\n        client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n        mock_response = MagicMock()\n        mock_response.status_code = 404\n        http_error = requests.HTTPError()\n        http_error.response = mock_response\n        client.session.delete = MagicMock(side_effect=http_error)\n\n        result = client.delete_session(\"session-123\")\n        assert result == True\n\n    def test_delete_session_other_failure(self) -> None:\n        client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n        mock_response = MagicMock()\n        mock_response.status_code = 500\n        http_error = requests.HTTPError()\n        http_error.response = mock_response\n        client.session.delete = MagicMock(side_effect=http_error)\n\n        result = client.delete_session(\"session-123\")\n        assert result == False\n\n    def test_delete_session_request_exception(self) -> None:\n        client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n        client.session.delete = MagicMock(side_effect=requests.RequestException())\n\n        result = client.delete_session(\"session-123\")\n        assert result == False\n\n\nclass TestClose:\n    def test_close_session(self) -> None:\n        client = ControlPlaneClient(workload_manager_url=\"http://wm\")\n        mock_close = MagicMock()\n        client.session.close = mock_close\n\n        client.close()\n        mock_close.assert_called_once()","after":"import pytest\nfrom unittest.mock import MagicMock, patch, mock_open\nimport requests\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\n\n\nclass TestControlPlaneClientInit:\n    def test_init_default_timeout(self) -> None:\n        with patch(\"agentcube.clients.