(\"workload_manager_url must be provided via argument or WORKLOAD_MANAGER_URL environment variable\")\n\n    def _resolve_token(self, auth_token: Optional[str]) -> str:\n        \"\"\"Resolve auth token from argument or Kubernetes service account file.\"\"\"\n        if auth_token:\n            return auth_token\n        return read_token_from_file(self.SA_TOKEN_PATH)\n\n    def create_session(\n        self,\n        name: str = \"my-interpreter\",\n        namespace: str = \"default\",\n        metadata: Optional[Dict[str, Any]] = None,\n        ttl: int = 3600,\n    ) -> str:\n        \"\"\"Create a code interpreter session.\n\n        Args:\n            name: Session name.\n            namespace: Kubernetes namespace.\n            metadata: Optional metadata dictionary.\n            ttl: Session TTL in seconds.\n\n        Returns:\n            sessionId from the response.\n\n        Raises:\n            ValueError: If sessionId is not present in response.\n        \"\"\"\n        url = f\"{self.base_url}/v1/code-interpreter\"\n        body = {\n            \"name\": name,\n            \"namespace\": namespace,\n            \"ttl\": ttl,\n            \"metadata\": metadata or {},\n        }\n        timeout_tuple = (self.connect_timeout, self.timeout)\n        response = self.session.post(url, json=body, timeout=timeout_tuple)\n        response.raise_for_status()\n        data = response.json()\n        session_id = data.get(\"sessionId\")\n        if session_id is None:\n            raise ValueError(\"sessionId not found in create_session response\")\n        return session_id\n\n    def delete_session(self, session_id: str) -> bool:\n        \"\"\"Delete a code interpreter session.\n\n        Args:\n            session_id: The session ID to delete.\n\n        Returns:\n            True on success (including 404), False on other failures.\n        \"\"\"\n        url = f\"{self.base_url}/v1/code-interpreter/sessions/{session_id}\"\n        timeout_tuple = (self.connect_timeout, self.timeout)\n        try:\n            response = self.session.delete(url, timeout=timeout_tuple)\n            response.raise_for_status()\n            return True\n        except requests.HTTPError as e:\n            if e.response.status_code == 404:\n                return True\n            self._logger.warning(f\"delete_session failed: {e}\")\n            return False\n        except requests.RequestException as e:\n            self._logger.warning(f\"delete_session failed: {e}\")\n            return False\n\n    def close(self) -> None:\n        \"\"\"Close the HTTP session connection pool.\"\"\"\n        self.session.close()","after":"import os\nimport json\nimport requests\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.utils import read_token_from_file\nfrom agentcube.utils.log import get_logger\n\n\nclass ControlPlaneClient:\n    \"\"\"HTTP client for Workload Manager control plane API.\"\"\"\n\n    DEFAULT_TIMEOUT = 120\n    DEFAULT_CONNECT_TIMEOUT = 5.0\n    DEFAULT_POOL_CONNECTIONS = 10\n    DEFAULT_POOL_MAXSIZE = 10\n    SA_TOKEN_PATH = \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n\n    def __init__(\n        self,\n        workload_manager_url: Optional[str] = None,\n        auth_token: Optional[str] = None,\n        timeout: int = DEFAULT_TIMEOUT,\n        connect_timeout: float = DEFAULT_CONNECT_TIMEOUT,\n        pool_connections: int = DEFAULT_POOL_CONNECTIONS,\n        pool_maxsize: int = DEFAULT_POOL_MAXSIZE,\n    ) -> None:\n        self.timeout = timeout\n        self.connect_timeout = connect_timeout\n        self._logger = get_logger(__name__)\n\n        self.base_url = self._resolve_url(workload_manager_url)\n        token = self._resolve_token(auth_token)\n\n        self.session = create_session(pool_connections, pool_maxsize)\n        self.session.headers[\"Content-Type\"] = \"application/json\"\n\n        if token:\n            self.session.heade