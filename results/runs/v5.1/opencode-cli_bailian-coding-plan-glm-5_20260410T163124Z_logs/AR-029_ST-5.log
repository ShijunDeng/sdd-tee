tils.py\n@@ -40,9 +40,15 @@\n         token_file.write_text(\"  token-with-spaces  \\n\")\n         result = read_token_from_file(str(token_file))\n         assert result == \"token-with-spaces\"\n \n+    def test_read_token_from_file_multiline(self, tmp_path: Path) -> None:\n+        token_file = tmp_path / \"token\"\n+        token_file.write_text(\"token-line1\\ntoken-line2\\n\")\n+        result = read_token_from_file(str(token_file))\n+        assert result == \"token-line1\\ntoken-line2\"\n \n+\n class TestGetLogger:\n     def test_get_logger_returns_logger(self) -> None:\n         import logging\n         logger = get_logger(\"test_logger\")\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_utils.py","before":"import pytest\nfrom unittest.mock import MagicMock, patch, mock_open\nfrom pathlib import Path\n\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.utils import read_token_from_file\nfrom agentcube.utils.log import get_logger\n\n\nclass TestCreateSession:\n    def test_create_session_returns_session(self) -> None:\n        import requests\n        session = create_session()\n        assert isinstance(session, requests.Session)\n\n    def test_create_session_has_adapters(self) -> None:\n        session = create_session()\n        assert \"http://\" in session.adapters\n        assert \"https://\" in session.adapters\n\n    def test_create_session_custom_pool_settings(self) -> None:\n        import requests\n        session = create_session(pool_connections=5, pool_maxsize=5)\n        assert isinstance(session, requests.Session)\n\n\nclass TestReadTokenFromFile:\n    def test_read_token_from_file_success(self, tmp_path: Path) -> None:\n        token_file = tmp_path / \"token\"\n        token_file.write_text(\"my-secret-token\\n\")\n        result = read_token_from_file(str(token_file))\n        assert result == \"my-secret-token\"\n\n    def test_read_token_from_file_not_found(self) -> None:\n        result = read_token_from_file(\"/nonexistent/path/token\")\n        assert result == \"\"\n\n    def test_read_token_from_file_strip_whitespace(self, tmp_path: Path) -> None:\n        token_file = tmp_path / \"token\"\n        token_file.write_text(\"  token-with-spaces  \\n\")\n        result = read_token_from_file(str(token_file))\n        assert result == \"token-with-spaces\"\n\n\nclass TestGetLogger:\n    def test_get_logger_returns_logger(self) -> None:\n        import logging\n        logger = get_logger(\"test_logger\")\n        assert isinstance(logger, logging.Logger)\n        assert logger.name == \"test_logger\"\n\n    def test_get_logger_default_level(self) -> None:\n        import logging\n        logger = get_logger(\"test_logger\")\n        assert logger.level == logging.INFO\n\n    def test_get_logger_custom_level_int(self) -> None:\n        import logging\n        logger = get_logger(\"test_logger\", level=logging.DEBUG)\n        assert logger.level == logging.DEBUG\n\n    def test_get_logger_custom_level_str(self) -> None:\n        import logging\n        logger = get_logger(\"test_logger\", level=\"DEBUG\")\n        assert logger.level == logging.DEBUG","after":"import pytest\nfrom unittest.mock import MagicMock, patch, mock_open\nfrom pathlib import Path\n\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.utils import read_token_from_file\nfrom agentcube.utils.log import get_logger\n\n\nclass TestCreateSession:\n    def test_create_session_returns_session(self) -> None:\n        import requests\n        session = create_session()\n        assert isinstance(session, requests.Session)\n\n    def test_create_session_has_adapters(self) -> None:\n        session = create_session()\n        assert \"http://\" in session.adapters\n        assert \"https://\" in session.adapters\n\n    def test_create_session_custom_pool_settings(self) -> None:\n        import requests\n        session = create_session(pool_connections=5, pool_maxsize=5)\n        assert isinstance(session, requests.Session)\n\n\nclass TestReadTokenFromFile:\n    def test_read_token_from_file_success(self, tmp_path: Path) -> None:\n        token_file = tmp_path / \"token\"\n        token_file.write_text(\"my-secret-token\\n\")\n        result = read_token_from_file(str(token_file))\n        assert result == \"my-secret-token\"\n\n    def test_read_token_from_file_not_found(self) -> None:\n        result = read_token_from_file(\"/nonexistent/path/token\")\n        assert result == \"\"\n\n    def test_read_token_from_file_strip_whitespace(self, tmp_path: Path) -> None:\n        token_file = tmp_path / \"token\"\n        token_file.write_text(\"  token-with-spaces  \\n\")\n        result = read_token_from_file(str(token_file))\n        assert result == \"token-with-spaces\"\n\n    def test_read_token_from_file_multiline(self, tmp_path: Path) -> None:\n        token_file = tmp_path / \"token\"\n        token_file.write_text(\"token-line1\\ntoken-line2\\n\")\n        result = read_token_from_file(str(token_file))\n        assert result == \"token-line1\\ntoken-line2\"\n\n\nclass TestGetLogger:\n    def test_get_logger_returns_logger(self) -> None:\n        import logging\n        logger = get_logger(\"test_logger\")\n        assert isinstance(logger, logging.Logger)\n        assert logger.name == \"test_logger\"\n\n    def test_get_logger_default_level(self) -> None:\n        import logging\n        logger = get_logger(\"test_logger\")\n        assert logger.level == logging.INFO\n\n    def test_get_logger_custom_level_int(self) -> None:\n        import logging\n        logger = get_logger(\"test_logger\", level=logging.DEBUG)\n        assert logger.level == logging.DEBUG\n\n    def test_get_logger_custom_level_str(self) -> None:\n        import logging\n        logger = get_logger(\"test_logger\", level=\"DEBUG\")\n        assert logger.level == logging.DEBUG","additions":6,"dele