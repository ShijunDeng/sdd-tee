est\nimport responses\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\n\n\nclass TestSessionLifecycle:\n    @responses.activate\n    def test_full_session_lifecycle(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session-123\"},\n        )\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n            status=200,\n        )\n        with AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n        ) as client:\n            assert client.session_id == \"test-session-123\"\n            result = client.invoke({\"input\": \"test\"})\n            assert result == {\"result\": \"success\"}\n\n\nclass TestInvokeWorkflow:\n    @responses.activate\n    def test_invoke_workflow_with_payload(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session-456\"},\n        )\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"output\": \"processed\", \"status\": \"completed\"},\n            status=200,\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n        )\n        result = client.invoke({\"action\": \"process\", \"data\": \"input\"})\n        assert result[\"output\"] == \"processed\"\n        assert result[\"status\"] == \"completed\"\n        client.close()\n\n\nclass TestSessionReuseIntegration:\n    @responses.activate\n    def test_session_reuse_across_multiple_invokes(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"persistent-session\"},\n        )\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"first\"},\n            status=200,\n        )\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"second\"},\n            status=200,\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n        )\n        session_id = client.session_id\n        result1 = client.invoke({\"call\": \"1\"})\n        result2 = client.invoke({\"call\": \"2\"})\n        assert session_id == \"persistent-session\"\n        assert result1[\"result\"] == \"first\"\n        assert result2[\"result\"] == \"second\"\n        assert client.session_id == session_id\n        client.close()\n\n\nclass TestBootstrapFailure:\n    @responses.activate\n    def test_error_handling_on_bootstrap_failure(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n        )\n        with pytest.raises(ValueError, match=\"Missing required response header: x-agentcube-session-id\"):\n            AgentRuntimeClient(\n                agent_name=\"test-agent\",\n                router_url=\"http://router.example.com\",\n            )\n\n\nclass TestInvokeFailure:\n    @responses.activate\n    def test_error_handling_on_invoke_failure(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session\"},\n        )\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"error\": \"Internal Server Error\"},\n            status=500,\n        )\n        client = AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n            session_id=\"test-session\",\n        )\n        with pytest.raises(requests.HTTPError):\n            client.invoke({\"input\": \"test\"})\n        client.close()","after":"import pytest\nimport responses\nimport requests\n\nfrom agentcube.agent_runtime import AgentRuntimeClient\n\n\nclass TestSessionLifecycle:\n    @responses.activate\n    def test_full_session_lifecycle(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session-123\"},\n        )\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"result\": \"success\"},\n            status=200,\n        )\n        with AgentRuntimeClient(\n            agent_name=\"test-agent\",\n            router_url=\"http://router.example.com\",\n        ) as client:\n            assert client.session_id == \"test-session-123\"\n            result = client.invoke({\"input\": \"test\"})\n            assert result == {\"result\": \"success\"}\n\n\nclass TestInvokeWorkflow:\n    @responses.activate\n    def test_invoke_workflow_with_payload(self):\n        responses.get(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            headers={\"x-agentcube-session-id\": \"test-session-456\"},\n        )\n        responses.post(\n            \"http://router.example.com/v1/namespaces/default/agent-runtimes/test-agent/invocations/\",\n            json={\"output\": \"processed\", \"status\": \"completed\"},\n            status=200,\