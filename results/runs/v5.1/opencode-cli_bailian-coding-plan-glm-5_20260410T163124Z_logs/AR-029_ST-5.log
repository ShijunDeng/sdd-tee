rkspace/test.py\")\n161:         call_args = client._request.call_args\n162:         import json\n163:         body = json.loads(call_args.args[2].decode())\n164:         assert body[\"mode\"] == \"0644\"\n165: \n166: \n167: class TestUploadFile:\n168:     def test_upload_file_multipart(self, tmp_path: Path) -> None:\n169:         client = CodeInterpreterDataPlaneClient(\n170:             session_id=\"session-123\",\n171:             base_url=\"http://router/v1/invocations/\",\n172:         )\n173:         local_file = tmp_path / \"test.txt\"\n174:         local_file.write_text(\"content\")\n175: \n176:         mock_response = MagicMock()\n177:         mock_response.raise_for_status = MagicMock()\n178:         client.session.post = MagicMock(return_value=mock_response)\n179: \n180:         client.upload_file(str(local_file), \"/workspace/test.txt\")\n181:         call_args = client.session.post.call_args\n182:         assert \"files\" in call_args.kwargs\n183:         assert \"data\" in call_args.kwargs\n184:         assert call_args.kwargs[\"data\"][\"path\"] == \"/workspace/test.txt\"\n185: \n186:     def test_upload_file_session_header(self, tmp_path: Path) -> None:\n187:         client = CodeInterpreterDataPlaneClient(\n188:             session_id=\"session-123\",\n189:             base_url=\"http://router/v1/invocations/\",\n190:         )\n191:         local_file = tmp_path / \"test.txt\"\n192:         local_file.write_text(\"content\")\n193: \n194:         mock_response = MagicMock()\n195:         mock_response.raise_for_status = MagicMock()\n196:         client.session.post = MagicMock(return_value=mock_response)\n197: \n198:         client.upload_file(str(local_file), \"/workspace/test.txt\")\n199:         call_args = client.session.post.call_args\n200:         assert call_args.kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"session-123\"\n201: \n202: \n203: class TestDownloadFile:\n204:     def test_download_file_stream(self, tmp_path: Path) -> None:\n205:         client = CodeInterpreterDataPlaneClient(\n206:             session_id=\"session-123\",\n207:             base_url=\"http://router/v1/invocations/\",\n208:         )\n209:         local_file = tmp_path / \"downloaded.txt\"\n210: \n211:         mock_response = MagicMock()\n212:         mock_response.raise_for_status = MagicMock()\n213:         mock_response.iter_content = MagicMock(return_value=[b\"file content\"])\n214:         client.session.get = MagicMock(return_value=mock_response)\n215: \n216:         client.download_file(\"/workspace/source.txt\", str(local_file))\n217:         call_args = client.session.get.call_args\n218:         assert call_args.kwargs[\"stream\"] == True\n219:         assert local_file.read_text() == \"file content\"\n220: \n221: \n222: class TestListFiles:\n223:     def test_list_files_query(self) -> None:\n224:         client = CodeInterpreterDataPlaneClient(\n225:             session_id=\"session-123\",\n226:             base_url=\"http://router/v1/invocations/\",\n227:         )\n228:         mock_response = MagicMock()\n229:         mock_response.json.return_value = {\"files\": [\"file1.py\", \"file2.py\"]}\n230:         mock_response.raise_for_status = MagicMock()\n231:         client.session.get = MagicMock(return_value=mock_response)\n232: \n233:         result = client.list_files(\"/workspace\")\n234:         call_args = client.session.get.call_args\n235:         assert call_args.kwargs[\"params\"][\"path\"] == \"/workspace\"\n236:         assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n237: \n238: \n239: class TestClose:\n240:     def test_close_session(self) -> None:\n241:         client = CodeInterpreterDataPlaneClient(\n242:             session_id=\"session-123\",\n243:             base_url=\"http://router/v1/invocations/\",\n244:         )\n245:         mock_close = MagicMock()\n246:         client.session.close = mock_close\n247: \n248:         client.close()\n249:         mock_close.assert_called_on