ion-123\"\n\n    def test_init_with_base_url(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/namespaces/default/code-interpreters/test/invocations/\",\n        )\n        assert client.base_url == \"http://router/v1/namespaces/default/code-interpreters/test/invocations/\"\n\n    def test_init_missing_params_raises(self) -> None:\n        with pytest.raises(ValueError, match=\"Either base_url or router_url\"):\n            CodeInterpreterDataPlaneClient(session_id=\"session-123\")\n\n\nclass TestSessionHeader:\n    def test_session_header_lowercase(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            router_url=\"http://router\",\n            namespace=\"default\",\n            cr_name=\"test\",\n        )\n        assert \"x-agentcube-session-id\" in client.session.headers\n        assert client.session.headers[\"x-agentcube-session-id\"] == \"session-123\"\n\n\nclass TestBaseURLConstruction:\n    def test_base_url_from_router_url(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            router_url=\"http://router.example.com\",\n            namespace=\"production\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client.base_url == \"http://router.example.com/v1/namespaces/production/code-interpreters/my-interpreter/invocations/\"\n\n\nclass TestExecuteCommand:\n    def test_execute_command_success(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        result = client.execute_command(\"python3 script.py\")\n        assert result == \"output\"\n\n    def test_execute_command_json_body(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.execute_command(\"python3 script.py\", timeout=30)\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        assert body[\"command\"] == [\"python3\", \"script.py\"]\n        assert body[\"timeout\"] == \"30s\"\n\n    def test_execute_command_timeout_buffer(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n            timeout=60,\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.execute_command(\"cmd\", timeout=30)\n        call_args = client._request.call_args\n        assert call_args.kwargs[\"timeout_override\"] == 32.0\n\n    def test_execute_command_nonzero_exit(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 1, \"stderr\": \"error msg\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        with pytest.raises(CommandExecutionError) as exc_info:\n            client.execute_command(\"python3 script.py\")\n        assert exc_info.value.exit_code == 1\n        assert exc_info.value.stderr == \"error msg\"\n\n    def test_execute_command_list_input(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.execute_command([\"python3\", \"script.py\"])\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        assert body[\"command\"] == [\"python3\", \"script.py\"]\n\n    def test_execute_command_default_timeout(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n            timeout=120,\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.execute_command(\"ls\")\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        assert body[\"timeout\"] == \"120s\"\n        assert call_args.kwargs[\"timeout_override\"] == 122.0\n\n\nclass TestWriteFile:\n    def test_write_file_base64(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.write_file(\"hello world\", \"/workspace/test.py\")\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        expected_content = base64.b64encode(\"hello world\".encode()).decode()\n        assert body[\"content\"] == expected_content\n\n    def test_write_file_mode(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.write_file(\"content\", \"/workspace/test.py\")\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        assert body[\"mode\"] == \"0644\"\n\n\nclass TestUploadFile:\n    def test_upload_file_multipart(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"test.txt\"\n        local_file.write_text(\"content\")\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_response)\n\n        client.upload_file(str(local_file), \"/workspace/test.txt\")\n        call_args = client.session.post.call_args\n        assert \"files\" in call_args.kwargs\n        assert \"data\" in call_args.kwargs\n        assert call_args.kwargs[\"data\"][\"path\"] == \"/workspace/test.txt\"\n\n    def test_upload_file_session_header(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"test.txt\"\n        local_file.write_text(\"content\")\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_response)\n\n        client.upload_file(str(local_file), \"/workspace/test.txt\")\n        call_args = client.session.post.call_args\n        assert call_args.kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"session-123\"\n\n    def test_upload_file_not_found(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n\n        with pytest.raises(FileNotFoundError):\n            client.upload_file(\"/nonexistent/file.txt\", \"/workspace/test.txt\")\n\n\nclass TestDownloadFile:\n    def test_download_file_stream(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"downloaded.txt\"\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        mock_response.iter_content = MagicMock(return_value=[b\"file content\"])\n        client.session.get = MagicMock(return_value=mock_response)\n\n        client.download_file(\"/workspace/source.txt\", str(local_file))\n        call_args = client.session.get.call_args\n        assert call_args.kwargs[\"stream\"] == True\n        assert local_file.read_text() == \"file content\"\n\n    def test_download_file_creates_parent_directory(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"subdir\" / \"downloaded.txt\"\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        mock_response.iter_content = MagicMock(return_value=[b\"file content\"])\n        client.session.get = MagicMock(return_value=mock_response)\n\n        client.download_file(\"/workspace/source.txt\", str(local_file))\n        assert local_file.parent.exists()\n        assert local_file.read_text() == \"file content\"\n\n    def test_download_file_removes_leading_slash(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"downloaded.txt\"\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        mock_response.iter_content = MagicMock(return_value=[b\"content\"])\n        client.session.get = MagicMock(return_value=mock_response)\n\n        client.download_file(\"/workspace/source.txt\", str(local_file))\n        call_args = client.session.get.call_args\n        assert \"source.txt\" in call_args.args[0]\n\n\nclass TestListFiles:\n    def test_list_files_query(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"files\": [\"file1.py\", \"file2.py\"]}\n        mock_response.raise_for_status = MagicMock()\n        client.session.get = MagicMock(return_value=mock_response)\n\n        result = client.list_files(\"/workspace\")\n        call_args = client.session.get.call_args\n        assert call_args.kwargs[\"params\"][\"path\"] == \"/workspace\"\n        assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n\n\nclass TestClose:\n    def test_close_session(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_close = MagicMock()\n        client.session.close = mock_close\n\n        client.close()\n        mock_close.assert_called_once()","after":"import pytest\nfrom unittest.mock import MagicMock, patch, mock_open\nfrom pathlib import Path\nimport base64\nimport requests\n\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcube.exceptions import CommandExecutionError\n\n\nclass TestDataPlaneClientInit:\n    def test_init_with_session_id(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            router_url=\"http://router\",\n            namespace=\"default\",\n            cr_name=\"test-interpreter\",\n        )\n        assert client.session_id == \"session-123\"\n\n    def test_init_with_base_url(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/namespaces/default/code-interpreters/test/invocations/\",\n        )\n        assert client.base_url == \"http://router/v1/namespaces/default/code-interpreters/test/invocations/\"\n\n    def test_init_missing_params_raises(self) -> None:\n        with pytest.raises(ValueError, match=\"Either base_url or router_url\"):\n            CodeInterpreterDataPlaneClient(session_id=\"session-123\")\n\n\nclass TestSessionHeader:\n    def test_session_header_lowercase(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            router_url=\"http://router\",\n            namespace=\"default\",\n            cr_name=\"test\",\n        )\n        assert \"x-agentcube-session-id\" in client.session.headers\n        assert client.session.headers[\"x-agentcube-session-id\"] == \"session-123\"\n\n\nclass TestBaseURLConstruction:\n    def test_base_url_from_router_url(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            router_url=\"http://router.example.com\",\n            namespace=\"production\",\n            cr_name=\"my-interpreter\",\n        )\n        assert client.base_url == \"http://router.example.com/v1/namespaces/production/code-interpreters/my-interpreter/invocations/\"\n\n\nclass TestExecuteCommand:\n    def test_execute_command_success(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"output\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        result = client.execute_command(\"python3 script.py\")\n        assert result == \"output\"\n\n    def test_execute_command_json_body(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.execute_command(\"python3 script.py\", timeout=30)\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        assert body[\"command\"] == [\"python3\", \"script.py\"]\n        assert body[\"timeout\"] == \"30s\"\n\n    def test_execute_command_timeout_buffer(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n            timeout=60,\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.execute_command(\"cmd\", timeout=30)\n        call_args = client._request.call_args\n        assert call_args.kwargs[\"timeout_override\"] == 32.0\n\n    def test_execute_command_nonzero_exit(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 1, \"stderr\": \"error msg\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        with pytest.raises(CommandExecutionError) as exc_info:\n            client.execute_command(\"python3 script.py\")\n        assert exc_info.value.exit_code == 1\n        assert exc_info.value.stderr == \"error msg\"\n\n    def test_execute_command_list_input(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.execute_command([\"python3\", \"script.py\"])\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        assert body[\"command\"] == [\"python3\", \"script.py\"]\n\n    def test_execute_command_default_timeout(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n            timeout=120,\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"exit_code\": 0, \"stdout\": \"\"}\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.execute_command(\"ls\")\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        assert body[\"timeout\"] == \"120s\"\n        assert call_args.kwargs[\"timeout_override\"] == 122.0\n\n\nclass TestWriteFile:\n    def test_write_file_base64(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.write_file(\"hello world\", \"/workspace/test.py\")\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        expected_content = base64.b64encode(\"hello world\".encode()).decode()\n        assert body[\"content\"] == expected_content\n\n    def test_write_file_mode(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        client._request = MagicMock(return_value=mock_response)\n\n        client.write_file(\"content\", \"/workspace/test.py\")\n        call_args = client._request.call_args\n        import json\n        body = json.loads(call_args.args[2].decode())\n        assert body[\"mode\"] == \"0644\"\n\n\nclass TestUploadFile:\n    def test_upload_file_multipart(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"test.txt\"\n        local_file.write_text(\"content\")\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_response)\n\n        client.upload_file(str(local_file), \"/workspace/test.txt\")\n        call_args = client.session.post.call_args\n        assert \"files\" in call_args.kwargs\n        assert \"data\" in call_args.kwargs\n        assert call_args.kwargs[\"data\"][\"path\"] == \"/workspace/test.txt\"\n\n    def test_upload_file_session_header(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"test.txt\"\n        local_file.write_text(\"content\")\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        client.session.post = MagicMock(return_value=mock_response)\n\n        client.upload_file(str(local_file), \"/workspace/test.txt\")\n        call_args = client.session.post.call_args\n        assert call_args.kwargs[\"headers\"][\"x-agentcube-session-id\"] == \"session-123\"\n\n    def test_upload_file_not_found(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n\n        with pytest.raises(FileNotFoundError):\n            client.upload_file(\"/nonexistent/file.txt\", \"/workspace/test.txt\")\n\n\nclass TestDownloadFile:\n    def test_download_file_stream(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"downloaded.txt\"\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        mock_response.iter_content = MagicMock(return_value=[b\"file content\"])\n        client.session.get = MagicMock(return_value=mock_response)\n\n        client.download_file(\"/workspace/source.txt\", str(local_file))\n        call_args = client.session.get.call_args\n        assert call_args.kwargs[\"stream\"] == True\n        assert local_file.read_text() == \"file content\"\n\n    def test_download_file_creates_parent_directory(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"subdir\" / \"downloaded.txt\"\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        mock_response.iter_content = MagicMock(return_value=[b\"file content\"])\n        client.session.get = MagicMock(return_value=mock_response)\n\n        client.download_file(\"/workspace/source.txt\", str(local_file))\n        assert local_file.parent.exists()\n        assert local_file.read_text() == \"file content\"\n\n    def test_download_file_removes_leading_slash(self, tmp_path: Path) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        local_file = tmp_path / \"downloaded.txt\"\n\n        mock_response = MagicMock()\n        mock_response.raise_for_status = MagicMock()\n        mock_response.iter_content = MagicMock(return_value=[b\"content\"])\n        client.session.get = MagicMock(return_value=mock_response)\n\n        client.download_file(\"/workspace/source.txt\", str(local_file))\n        call_args = client.session.get.call_args\n        assert \"source.txt\" in call_args.args[0]\n\n\nclass TestListFiles:\n    def test_list_files_query(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"files\": [\"file1.py\", \"file2.py\"]}\n        mock_response.raise_for_status = MagicMock()\n        client.session.get = MagicMock(return_value=mock_response)\n\n        result = client.list_files(\"/workspace\")\n        call_args = client.session.get.call_args\n        assert call_args.kwargs[\"params\"][\"path\"] == \"/workspace\"\n        assert result == {\"files\": [\"file1.py\", \"file2.py\"]}\n\n    def test_list_files_default_path(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_response = MagicMock()\n        mock_response.json.return_value = {\"files\": []}\n        mock_response.raise_for_status = MagicMock()\n        client.session.get = MagicMock(return_value=mock_response)\n\n        result = client.list_files()\n        call_args = client.session.get.call_args\n        assert call_args.kwargs[\"params\"][\"path\"] == \".\"\n\n\nclass TestClose:\n    def test_close_session(self) -> None:\n        client = CodeInterpreterDataPlaneClient(\n            session_id=\"session-123\",\n            base_url=\"http://router/v1/invocations/\",\n        )\n        mock_close = MagicMock()\n        client.session.close = mock_close\n\n        client.close()\n        mock_close.assert_called_once()","additions":14,"deletions":0},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/tests/test_data_plane.py","time":{"start":1775882957085,"end":1775882957619}}}}
