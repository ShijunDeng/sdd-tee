go build -o bin/workloadmanager ./cmd/workload-manager\n45: \tgo build -o bin/router ./cmd/router\n46: \tgo build -o bin/picod ./cmd/picod\n47: \tgo build -o bin/agentd ./cmd/agentd\n48: \tgo build -o bin/agentctl ./cmd/agentctl\n49: \tgo build -o bin/agentcube ./cmd/agentcube\n50: \tgo build -o bin/agentsandbox ./cmd/agentsandbox\n51: \n52: build-workloadmanager: generate ## Build workloadmanager binary only\n53: \tgo build -o bin/workloadmanager ./cmd/workload-manager\n54: \n55: build-router: generate ## Build router binary only\n56: \tgo build -o bin/router ./cmd/router\n57: \n58: build-picod: generate ## Build picod binary only\n59: \tgo build -o bin/picod ./cmd/picod\n60: \n61: build-agentd: generate ## Build agentd binary only\n62: \tgo build -o bin/agentd ./cmd/agentd\n63: \n64: build-agentctl: generate ## Build agentctl binary only\n65: \tgo build -o bin/agentctl ./cmd/agentctl\n66: \n67: build-agentcube: generate ## Build agentcube binary only\n68: \tgo build -o bin/agentcube ./cmd/agentcube\n69: \n70: build-agentsandbox: generate ## Build agentsandbox binary only\n71: \tgo build -o bin/agentsandbox ./cmd/agentsandbox\n72: \n73: build-all: build-workloadmanager build-router build-picod build-agentd \\\n74:            build-agentctl build-agentcube build-agentsandbox ## Build all binaries individually\n75: \n76: build-linux-amd64: generate ## Build for Linux AMD64\n77: \tGOOS=linux GOARCH=amd64 go build -o bin/workloadmanager ./cmd/workload-manager\n78: \tGOOS=linux GOARCH=amd64 go build -o bin/router ./cmd/router\n79: \tGOOS=linux GOARCH=amd64 go build -o bin/picod ./cmd/picod\n80: \tGOOS=linux GOARCH=amd64 go build -o bin/agentd ./cmd/agentd\n81: \tGOOS=linux GOARCH=amd64 go build -o bin/agentctl ./cmd/agentctl\n82: \tGOOS=linux GOARCH=amd64 go build -o bin/agentcube ./cmd/agentcube\n83: \tGOOS=linux GOARCH=amd64 go build -o bin/agentsandbox ./cmd/agentsandbox\n84: \n85: build-linux-arm64: generate ## Build for Linux ARM64\n86: \tGOOS=linux GOARCH=arm64 go build -o bin/workloadmanager ./cmd/workload-manager\n87: \tGOOS=linux GOARCH=arm64 go build -o bin/router ./cmd/router\n88: \tGOOS=linux GOARCH=arm64 go build -o bin/picod ./cmd/picod\n89: \tGOOS=linux GOARCH=arm64 go build -o bin/agentd ./cmd/agentd\n90: \tGOOS=linux GOARCH=arm64 go build -o bin/agentctl ./cmd/agentctl\n91: \tGOOS=linux GOARCH=arm64 go build -o bin/agentcube ./cmd/agentcube\n92: \tGOOS=linux GOARCH=arm64 go build -o bin/agentsandbox ./cmd/agentsandbox\n93: \n94: build-darwin-amd64: generate ## Build for Darwin AMD64\n95: \tGOOS=darwin GOARCH=amd64 go build -o bin/workloadmanager ./cmd/workload-manager\n96: \tGOOS=darwin GOARCH=amd64 go build -o bin/router ./cmd/router\n97: \tGOOS=darwin GOARCH=amd64 go build -o bin/picod ./cmd/picod\n98: \tGOOS=darwin GOARCH=amd64 go build -o bin/agentd ./cmd/agentd\n99: \tGOOS=darwin GOARCH=amd64 go build -o bin/agentctl ./cmd/agentctl\n100: \tGOOS=darwin GOARCH=amd64 go build -o bin/agentcube ./cmd/agentcube\n101: \tGOOS=darwin GOARCH=amd64 go build -o bin/agentsandbox ./cmd/agentsandbox\n102: \n103: build-darwin-arm64: generate ## Build for Darwin ARM64\n104: \tGOOS=darwin GOARCH=arm64 go build -o bin/workloadmanager ./cmd/workload-manager\n105: \tGOOS=darwin GOARCH=arm64 go build -o bin/router ./cmd/router\n106: \tGOOS=darwin GOARCH=arm64 go build -o bin/picod ./cmd/picod\n107: \tGOOS=darwin GOARCH=arm64 go build -o bin/agentd ./cmd/agentd\n108: \tGOOS=darwin GOARCH=arm64 go build -o bin/agentctl ./cmd/agentctl\n109: \tGOOS=darwin GOARCH=arm64 go build -o bin/agentcube ./cmd/agentcube\n110: \tGOOS=darwin GOARCH=arm64 go build -o bin/agentsandbox ./cmd/agentsandbox\n111: \n112: .PHONY: test test-coverage test-race\n113: \n114: ##@ Test\n115: \n116: test: ## Run unit tests with verbose output\n117: \tgo test -v ./...\n118: \n119: test-coverage: ## Run tests with coverage report\n120: \tgo test -coverprofile=coverage.out ./...\n121: \tgo tool cover -func=coverage.out\n122: \tgo tool cover -html=coverage.out -o coverage.html\n123: \n124: test-race: ## Run tests with race detector\n125: \tgo test -race ./...\n126: \n127: .PHONY: fmt vet lint golangci-lint gen-check gen-copyright\n128: \n129: ##@ Quality\n130: \n131: fmt: ## Format Go files\n132: \tgo fmt ./...\n133: \n134: vet: ## Run go vet\n135: \tgo vet ./...\n136: \n137: lint: golangci-lint ## Run golangci-lint\n138: \t$(GOLANGCI_LINT) run ./...\n139: \n140: golangci-lint:\n141: \t$(call go-install-tool,$(GOLANGCI_LINT),github.com/golangci/golangci-lint/cmd/golangci-lint,$(GOLANGCI_LINT_VERSION))\n142: \n143: gen-check: gen-all ## Verify generated code is up to date\n144: \tgit diff --exit-code\n145: \n146: gen-copyright: ## Generate copyright headers\n147: \thack/update-copyright.sh\n148: \n149: .PHONY: generate controller-gen gen-crd gen-client gen-all\n150: \n151: ##@ Codegen\n152: \n153: generate: controller-gen ## Generate deepcopy and object code\n154: \t$(CONTROLLER_GEN) object:headerFile=\"hack/boilerplate.go.txt\" paths=\"./pkg/apis/...\"\n155: \n156: controller-gen:\n157: \t$(call go-install-tool,$(CONTROLLER_GEN),sigs.k8s.io/controller-tools/cmd/controller-gen,$(CONTROLLER_TOOLS_VERSION))\n158: \n159: gen-crd: controller-gen ## Generate CRD manifests\n160: \t$(CONTROLLER_GEN) crd paths=\"./pkg/apis/...\" output:crd:artifacts:config=manifests/crds\n161: \n162: gen-client: ## Generate client-go code\n163: \thack/update-codegen.sh\n164: \n165: gen-all: generate gen-client ## Run all code generation\n166: \n167: .PHONY: docker-build docker-build-router docker-build-picod docker-build-all \\\n168:         docker-buildx-push docker-buildx-push-router docker-buildx-push-picod \\\n169:         docker-push docker-push-router docker-push-picod\n170: \n171: .NOTPARALLEL: docker-build-all\n172: \n173: ##@ Docker\n174: \n175: docker-build: ## Build workloadmanager Docker image\n176: \tdocker build \\\n177: \t\t-f docker/Dockerfile \\\n178: \t\t-t $(IMAGE_REPO)/workloadmanager:$(VERSION) \\\n179: \t\t--build-arg TARGETOS=$(TARGETOS) \\\n180: \t\t--build-arg TARGETARCH=$(TARGETARCH) \\\n181: \t\t.\n182: \n183: docker-build-router: ## Build router Docker image\n184: \tdocker build \\\n185: \t\t-f docker/Dockerfile.router \\\n186: \t\t-t $(IMAGE_REPO)/router:$(VERSION) \\\n187: \t\t--build-arg TARGETOS=$(TARGETOS) \\\n188: \t\t--build-arg TARGETARCH=$(TARGETARCH) \\\n189: \t\t.\n190: \n191: docker-build-picod: ## Build picod Docker image\n192: \tdocker build \\\n193: \t\t-f docker/Dockerfile.picod \\\n194: \t\t-t $(IMAGE_REPO)/picod:$(VERSION) \\\n195: \t\t.\n196: \n197: docker-build-all: docker-build docker-build-router docker-build-picod ## Build all Docker images\n198: \n199: docker-buildx-push: ## Build and push workloadmanager multi-arch image\n200: \tdocker buildx build \\\n201: \t\t-f docker/Dockerfile \\\n202: \t\t--platform linux/amd64,linux/arm64 \\\n203: \t\t--build-arg TARGETOS=linux \\\n204: \t\t--build-arg TARGETARCH=amd64 \\\n205: \t\t--push \\\n206: \t\t-t $(IMAGE_REPO)/workloadmanager:$(VERSION) \\\n207: \t\t.\n208: \n209: docker-buildx-push-router: ## Build and push router multi-arch image\n210: \tdocker buildx build \\\n211: \t\t-f docker/Dockerfile.router \\\n212: \t\t--platform linux/amd64,linux/arm64 \\\n213: \t\t--push \\\n214: \t\t-t $(IMAGE_REPO)/router:$(VERSION) \\\n215: \t\t.\n216: \n217: docker-buildx-push-picod: ## Build and push picod multi-arch image\n218: \tdocker buildx build \\\n219: \t\t-f docker/Dockerfile.picod \\\n220: \t\t--platform linux/amd64,linux/arm64 \\\n221: \t\t--push \\\n222: \t\t-t $(IMAGE_REPO)/picod:$(VERSION) \\\n223: \t\t.\n224: \n225: docker-push: ## Push workloadmanager image to registry\n226: \tdocker push $(IMAGE_REPO)/workloadmanager:$(VERSION)\n227: \n228: docker-push-router: ## Push router image to registry\n229: \tdocker push $(IMAGE_REPO)/router:$(VERSION)\n230: \n231: docker-push-picod: ## Push picod image to registry\n232: \tdocker push $(IMAGE_REPO)/picod:$(VERSION)\n233: \n234: .PHONY: kind-load kind-load-router kind-load-picod kind-load-all\n235: \n236: ##@ Kind\n237: \n238: kind-load: docker-build ## Load workloadmanager image into Kind cluster\n239: \tkind load docker-image $(IMAGE_REPO)/workloadmanager:$(VERSION) --name $(E2E_CLUSTER_NAME)\n240: \n241: kind-load-router: docker-build-router ## Load router image into Kind cluster\n242: \tkind load docker-image $(IMAGE_REPO)/router:$(VERSION) --name $(E2E_CLUSTER_NAME)\n243: \n244: kind-load-picod: docker-build-picod ## Load picod image into Kind cluster\n245: \tkind load docker-image $(IMAGE_REPO)/picod:$(VERSION) --name $(E2E_CLUSTER_NAME)\n246: \n247: kind-load-all: kind-load kind-load-router kind-load-picod ## Load all images into Kind cluster\n248: \n249: .PHONY: e2e e2e-setup e2e-clean\n250: \n251: ##@ E2E\n252: \n253: e2e: ## Run E2E tests\n254: \t./test/e2e/run_e2e.sh\n255: \n256: e2e-setup: ## Setup E2E test environment\n257: \tkind create cluster --name $(E2E_CLUSTER_NAME) --config test/e2e/kind-config.yaml\n258: \n259: e2e-clean: ## Clean up E2E test resources\n260: \tkind delete cluster --name $(E2E_CLUSTER_NAME) || true\n261: \trm -rf /tmp/agent-sandbox\n262: \n263: .PHONY: install install-workloadmanager install-router install-picod \\\n264:         install-agentd install-agentctl install-agentcube install-agentsandbox\n265: \n266: ##@ Install\n267: \n268: install: build ## Install all binaries to INSTALL_PREFIX\n269: \tmkdir -p $(INSTALL_PREFIX)\n270: \tcp bin/workloadmanager $(INSTALL_PREFIX)/\n271: \tcp bin/router $(INSTALL_PREFIX)/\n272: \tcp bin/picod $(INSTALL_PREFIX)/\n273: \tcp bin/agentd $(INSTALL_PREFIX)/\n274: \tcp bin/agentctl $(INSTALL_PREFIX)/\n275: \tcp bin/agentcube $(INSTALL_PREFIX)/\n276: \tcp bin/agentsandbox $(INSTALL_PREFIX)/\n277: \n278: install-workloadmanager: build-workloadmanager ## Install workloadmanager binary\n279: \tmkdir -p $(INSTALL_PREFIX)\n280: \tcp bin/workloadmanager $(INSTALL_PREFIX)/\n281: \n282: install-router: build-router ## Install router binary\n283: \tmkdir -p $(INSTALL_PREFIX)\n284: \tcp bin/router $(INSTALL_PREFIX)/\n285: \n286: install-picod: build-picod ## Install picod binary\n287: \tmkdir -p $(INSTALL_PREFIX)\n288: \tcp bin/picod $(INSTALL_PREFIX)/\n289: \n290: install-agentd: build-agentd ## Install agentd binary\n291: \tmkdir -p $(INSTALL_PREFIX)\n292: \tcp bin/agentd $(INSTALL_PREFIX)/\n293: \n294: install-agentctl: build-agentctl ## Install agentctl binary\n295: \tmkdir -p $(INSTALL_PREFIX)\n296: \tcp bin/agentctl $(INSTALL_PREFIX)/\n297: \n298: install-agentcube: build-agentcube ## Install agentcube binary\n299: \tmkdir -p $(INSTALL_PREFIX)\n300: \tcp bin/agentcube $(INSTALL_PREFIX)/\n301: \n302: install-agentsandbox: build-agentsandbox ## Install agentsandbox binary\n303: \tmkdir -p $(INSTALL_PREFIX)\n304: \tcp bin/agentsandbox $(INSTALL_PREFIX)/\n305: \n306: .PHONY: clean clean-bin clean-test\n307: \n308: ##@ Clean\n309: \n310: clean: clean-bin clean-test ## Remove all build artifacts\n311: \trm -f workloadmanager router picod agentd agentctl agentcube agentsandbox\n312: \n313: clean-bin: ## Remove binary directory\n314: \trm -rf bin/\n315: \n316: clean-test: ## Remove test artifacts\n317: \trm -f coverage.out coverage.html\n318: \n319: .PHONY: help\n320: \n321: ##@ Help\n322: \n323: help: ## Display this help screen\n324: \t@awk 'BEGIN {FS = \":.*##\"; printf \"\\nUsage:\\n  make <target>\\n\\n\"} \\\n325: \t\t/^##@/ { category = substr($$0, 4); printf \"%s\\n\", category } \\\n326: \t\t/^[%a-zA-Z0-9_-]+:.*##/ { \\\n327: \t\tprintf \"  %-30s %s\\n\", $$1, substr($$0, index($$0, \"##\") + 3) } \\\n328: \t\tEND { printf \"\\n\" }' $(MAKEFILE_LIST)\n\n(End of file - total 328 lines)\n</content>","metadata":{"preview":"SHELL ?= /usr/bin/env bash -o pipefail\n\n##@ General\n\nIMAGE_REPO ?= ghcr.io/volcano-sh/agentcube\nVERSION ?= $(shell git describe --tags --always --dirty 2>/dev/null || echo \"latest\")\nTARGETOS ?= linux\nTARGETARCH ?= amd64\nBINDIR ?= bin/\nGO_VERSION ?= 1.24\nGOLANGCI_LINT_VERSION ?= 1.64.7\nCONTROLLER_TOOLS_VERSION ?= v0.17.2\nINSTALL_PREFIX ?= $(shell go env GOPATH)/bin\n\nLOCALBIN ?= $(shell pwd)/bin\nCONTROLLER_GEN ?= $(LOCALBIN)/controller-gen\nGOLANGCI_LINT ?= $(LOCALBIN)/golangci-lint\n\nE2E_CLUSTER_NAME ?= agentcube-e2e\nAGENT_SANDBOX_VERSION ?= latest","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/Makefile","time":{"start":1775890721005,"end":1775890721015}}}}
