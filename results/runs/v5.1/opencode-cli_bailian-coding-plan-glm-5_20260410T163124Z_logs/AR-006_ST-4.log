{"type":"tool_use","timestamp":1775845136136,"sessionID":"ses_2876256cbffe4Ah7wokpE7l1AJ","part":{"id":"prt_d789e4e040013dzPj0ujXjm3pn","messageID":"msg_d789e30a00014Fy5Z5DFoOKys3","sessionID":"ses_2876256cbffe4Ah7wokpE7l1AJ","type":"tool","tool":"read","callID":"toolu_tool-b2d83349c516431f9214f57f8241c1e2","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"net/http\"\n6: \t\"os\"\n7: \t\"os/signal\"\n8: \t\"syscall\"\n9: \n10: \t\"github.com/go-chi/chi/v5\"\n11: )\n12: \n13: // HTTPServer manages the HTTP server lifecycle including graceful shutdown.\n14: type HTTPServer struct {\n15: \tserver   *http.Server\n16: \trouter   chi.Router\n17: \tconfig   Config\n18: \thandlers map[string]Handler\n19: \tlogger   Logger\n20: \tstopCh   chan struct{}\n21: }\n22: \n23: // NewHTTPServer creates a new HTTPServer instance with the given configuration and logger.\n24: // The router is initialized with chi.NewRouter().\n25: func NewHTTPServer(cfg Config, logger Logger) *HTTPServer {\n26: \treturn &HTTPServer{\n27: \t\tserver:   &http.Server{Addr: cfg.Addr},\n28: \t\trouter:   chi.NewRouter(),\n29: \t\tconfig:   cfg,\n30: \t\thandlers: make(map[string]Handler),\n31: \t\tlogger:   logger,\n32: \t\tstopCh:   make(chan struct{}),\n33: \t}\n34: }\n35: \n36: // RegisterHandler stores a handler and registers its routes on the router.\n37: func (s *HTTPServer) RegisterHandler(name string, h Handler) {\n38: \ts.handlers[name] = h\n39: \th.Register(s.router)\n40: }\n41: \n42: // Start begins listening and serving HTTP requests.\n43: // It returns an error channel that receives non-ErrServerClosed errors.\n44: func (s *HTTPServer) Start() <-chan error {\n45: \terrCh := make(chan error, 1)\n46: \ts.server.ReadTimeout = s.config.ReadTimeout\n47: \ts.server.WriteTimeout = s.config.WriteTimeout\n48: \ts.server.IdleTimeout = s.config.IdleTimeout\n49: \ts.server.Handler = s.router\n50: \n51: \tgo func() {\n52: \t\tif err := s.server.ListenAndServe(); err != http.ErrServerClosed {\n53: \t\t\terrCh <- err\n54: \t\t}\n55: \t}()\n56: \treturn errCh\n57: }\n58: \n59: // Stop gracefully shuts down the HTTP server within the configured timeout.\n60: func (s *HTTPServer) Stop(ctx context.Context) error {\n61: \tctx, cancel := context.WithTimeout(ctx, s.config.ShutdownTimeout)\n62: \tdefer cancel()\n63: \terr := s.server.Shutdown(ctx)\n64: \tclose(s.stopCh)\n65: \treturn err\n66: }\n67: \n68: // GracefulShutdown sets up signal handlers for SIGTERM and SIGINT.\n69: // When a signal is received, the server is stopped gracefully.\n70: func (s *HTTPServer) GracefulShutdown() {\n71: \tsigCh := make(chan os.Signal, 1)\n72: \tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n73: \tgo func() {\n74: \t\t<-sigCh\n75: \t\tctx := context.Background()\n76: \t\ts.Stop(ctx)\n77: \t}()\n78: }\n\n(End of file - total 78 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"syscall\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// HTTPServer manages the HTTP server lifecycle including graceful shutdown.\ntype HTTPServer struct {\n\tserver   *http.Server\n\trouter   chi.Router\n\tconfig   Config\n\thandlers map[string]Handler\n\tlogger   Logger\n\tstopCh   chan struct{}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/server.go","time":{"start":1775845136115,"end":1775845136134}}}}
