setTimer()\n240: \tfor i := 0; i < b.N; i++ {\n241: \t\twg.Add(2)\n242: \t\tgo func() {\n243: \t\t\tdefer wg.Done()\n244: \t\t\tstore.GetSandboxBySessionID(ctx, fmt.Sprintf(\"session-%d\", i%1000))\n245: \t\t}()\n246: \t\tgo func() {\n247: \t\t\tdefer wg.Done()\n248: \t\t\tsandbox := &types.SandboxInfo{\n249: \t\t\t\tSessionID: fmt.Sprintf(\"session-update-%d\", i%1000),\n250: \t\t\t\tSandboxID: fmt.Sprintf(\"sandbox-update-%d\", i%1000),\n251: \t\t\t\tCreatedAt: now,\n252: \t\t\t\tExpiresAt: now.Add(8 * time.Hour),\n253: \t\t\t}\n254: \t\t\tstore.StoreSandbox(ctx, sandbox)\n255: \t\t}()\n256: \t}\n257: \twg.Wait()\n258: }\n259: \n260: func BenchmarkGarbageCollector_runOnce(b *testing.B) {\n261: \tfakeClient := fake.NewSimpleClientset()\n262: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n263: \tinformerFactory := NewTestInformerFactory(fakeClient)\n264: \n265: \tk8sClient := &K8sClient{\n266: \t\tdynamicClient:   dynamicClient,\n267: \t\tcoreClient:      fakeClient,\n268: \t\tinformerFactory: informerFactory,\n269: \t}\n270: \n271: \tstore := NewMemoryStore()\n272: \tlogger := &mockLogger{}\n273: \tconfig := DefaultLifecycleConfig()\n274: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n275: \tgc := NewGarbageCollector(manager, GarbageCollectorInterval, 2*time.Minute, logger)\n276: \n277: \tnow := time.Now()\n278: \tfor i := 0; i < 1000; i++ {\n279: \t\tsandbox := &types.SandboxInfo{\n280: \t\t\tKind:             types.SandboxKind,\n281: \t\t\tSandboxID:        fmt.Sprintf(\"sandbox-%d\", i),\n282: \t\t\tSandboxNamespace: \"default\",\n283: \t\t\tSandboxName:      fmt.Sprintf(\"sandbox-%d\", i),\n284: \t\t\tSessionID:        fmt.Sprintf(\"session-%d\", i),\n285: \t\t\tCreatedAt:        now,\n286: \t\t\tExpiresAt:        now.Add(-time.Duration(i) * time.Minute),\n287: \t\t\tStatus:           \"running\",\n288: \t\t}\n289: \t\tstore.StoreSandbox(context.Background(), sandbox)\n290: \t}\n291: \n292: \tb.ResetTimer