t:     60 * time.Second,\n52: \t\tShutdownTimeout: 5 * time.Second,\n53: \t}\n54: \tlogger := &integrationTestLogger{}\n55: \ts := NewHTTPServer(cfg, logger)\n56: \n57: \ts.router.Get(\"/healthz\", func(w http.ResponseWriter, r *http.Request) {\n58: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n59: \t\tw.WriteHeader(http.StatusOK)\n60: \t\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n61: \t})\n62: \n63: \terrCh := s.Start()\n64: \n65: \ttime.Sleep(50 * time.Millisecond)\n66: \n67: \tclient := &http.Client{Timeout: 2 * time.Second}\n68: \n69: \tresp, err := client.Get(\"http://\" + addr + \"/healthz\")\n70: \tif err != nil {\n71: \t\tt.Fatalf(\"failed to connect to server: %v\", err)\n72: \t}\n73: \tdefer resp.Body.Close()\n74: \n75: \tif resp.StatusCode != http.StatusOK {\n76: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, resp.StatusCode)\n77: \t}\n78: \n79: \tvar body map[string]string\n80: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n81: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n82: \t}\n83: \tif body[\"status\"] != \"ok\" {\n84: \t\tt.Errorf(\"expected status %s, got %s\", \"ok\", body[\"status\"])\n85: \t}\n86: \n87: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n88: \tdefer cancel()\n89: \ts.Stop(ctx)\n90: \n91: \tselect {\n92: \tcase <-errCh:\n93: \tcase <-time.After(1 * time.Second):\n94: \t}\n95: }\n96: \n97: func TestE2EReadyz(t *testing.T) {\n98: \tlistener, err := net.Listen(\"tcp\", \"127.0.0.1:0\")\n99: \tif err != nil {\n100: \t\tt.Fatalf(\"failed to get free port: %v\", err)\n101: \t}\n102: \taddr := listener.Addr().String()\n103: \tlistener.Close()\n104: \n105: \tcfg := Config{\n106: \t\tAddr:            addr,\n107: \t\tReadTimeout:     5 * time.Second,\n108: \t\tWriteTimeout:    5 * time.Second,\n109: \t\tIdleTimeout:     60 * time.Second,\n110: \t\tShutdownTimeout: 5 * time.Second,\n111: \t}\n112: \tlogger := &integrationTestLogger{}\n113: \ts := NewHTTPServer(cfg, logger)\n114: \n115: \tchecker := &integrationHealthChecker{ready: true}\n116: \ts.router.Get(\"/readyz\", func(w http.ResponseWriter, r *http.Request) {\n117: \t\tw.Header().Set(\"Content-Type\", \"application/json\")\n118: \t\tif checker == nil || !checker.IsReady() {\n119: \t\t\tw.WriteHeader(http.StatusServiceUnavailable)\n120: \t\t\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"not ready\"})\n121: \t\t\treturn\n122: \t\t}\n123: \t\tw.WriteHeader(http.StatusOK)\n124: \t\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ready\"})\n125: \t})\n126: \n127: \terrCh := s.Start()\n128: \n129: \ttime.Sleep(50 * time.Millisecond)\n130: \n131: \tclient := &http.Client{Timeout: 2 * time.Second}\n132: \n133: \tresp, err := client.Get(\"http://\" + addr + \"/readyz\")\n134: \tif err != nil {\n135: \t\tt.Fatalf(\"failed to connect to server: %v\", err)\n136: \t}\n137: \tdefer resp.Body.Close()\n138: \n139: \tif resp.StatusCode != http.StatusOK {\n140: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, resp.StatusCode)\n141: \t}\n142: \n143: \tvar body map[string]string\n144: \tif decodeErr := json.NewDecoder(resp.Body).Decode(&body); decodeErr != nil {\n145: \t\tt.Fatalf(\"failed to decode response: %v\", decodeErr)\n146: \t}\n147: \tif body[\"status\"] != \"ready\" {\n148: \t\tt.Errorf(\"expected status %s, got %s\", \"ready\", body[\"status\"])\n149: \t}\n150: \n151: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n152: \tdefer cancel()\n153: \ts.Stop(ctx)\n154: \n155: \tselect {\n156: \tcase <-errCh:\n157: \tcase <-time.After(1 * time.Second):\n158: \t}\n159: }\n160: \n161: func TestMiddlewareChain(t *testing.T) {\n162: \tlogger := &integrationTestLogger{}\n163: \n164: \trouter := NewRouter()\n165: \n166: \trouter.Use(func(next http.Handler) http.Handler {\n167: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n168: \t\t\tdefer func() {\n169: \t\t\t\tif err := recover(); err != nil {\n170: \t\t\t\t\tlogger.Error(\"panic recovered\", \"error\", err)\n171: \t\t\t\t\thttp.Error(w, \"Internal Server Error\", http.StatusInternalServerError)\n172: \t\t\t\t}\n173: \t\t\t}()\n174: \t\t\tnext.ServeHTTP(w, r)\n175: \t\t})\n176: \t})\n177: \n178: \trouter.Use(func(next http.Handler) http.Handler {\n179: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n180: \t\t\tlogger.Info(\"request\", \"method\", r.Method, \"path\", r.URL.Path)\n181: \t\t\tnext.ServeHTTP(w, r)\n182: \t\t})\n183: \t})\n184: \n185: \trouter.Get(\"/test\", func(w http.ResponseWriter, r *http.Request) {\n186: \t\tw.WriteHeader(http.StatusOK)\n187: \t\tw.Write([]byte(\"test\"))\n188: \t})\n189: \n190: \treq := httptest.NewRequest(\"GET\", \"/test\", nil)\n191: \tw := httptest.NewRecorder()\n192: \n193: \trouter.ServeHTTP(w, req)\n194: \n195: \tif w.Code != http.StatusOK {\n196: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusOK, w.Code)\n197: \t}\n198: \n199: \tlogger.mu.Lock()\n200: \tdefer logger.mu.Unlock()\n201: \tif len(logger.infos) != 1 {\n202: \t\tt.Errorf(\"expected 1 info log, got %d\", len(logger.infos))\n203: \t}\n204: }\n205: \n206: func TestE2EPanicRecovery(t *testing.T) {\n207: \tlistener, err := net.Listen(\"tcp\", \"127.0.0.1:0\")\n208: \tif err != nil {\n209: \t\tt.Fatalf(\"failed to get free port: %v\", err)\n210: \t}\n211: \taddr := listener.Addr().String()\n212: \tlistener.Close()\n213: \n214: \tcfg := Config{\n215: \t\tAddr:            addr,\n216: \t\tReadTimeout:     5 * time.Second,\n217: \t\tWriteTimeout:    5 * time.Second,\n218: \t\tIdleTimeout:     60 * time.Second,\n219: \t\tShutdownTimeout: 5 * time.Second,\n220: \t}\n221: \tlogger := &integrationTestLogger{}\n222: \ts := NewHTTPServer(cfg, logger)\n223: \n224: \ts.router.Use(func(next http.Handler) http.Handler {\n225: \t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n226: \t\t\tdefer func() {\n227: \t\t\t\tif err := recover(); err != nil {\n228: \t\t\t\t\tlogger.Error(\"panic recovered\", \"error\", err)\n229: \t\t\t\t\thttp.Error(w, \"Internal Server Error\", http.StatusInternalServerError)\n230: \t\t\t\t}\n231: \t\t\t}()\n232: \t\t\tnext.ServeHTTP(w, r)\n233: \t\t})\n234: \t})\n235: \n236: \ts.router.Get(\"/panic\", func(w http.ResponseWriter, r *http.Request) {\n237: \t\tpanic(\"intentional panic for test\")\n238: \t})\n239: \n240: \terrCh := s.Start()\n241: \n242: \ttime.Sleep(50 * time.Millisecond)\n243: \n244: \tclient := &http.Client{Timeout: 2 * time.Second}\n245: \n246: \tresp, err := client.Get(\"http://\" + addr + \"/panic\")\n247: \tif err != nil {\n248: \t\tt.Fatalf(\"failed to connect to server: %v\", err)\n249: \t}\n250: \tdefer resp.Body.Close()\n251: \n252: \tif resp.StatusCode != http.StatusInternalServerError {\n253: \t\tt.Errorf(\"expected status %d, got %d\", http.StatusInternalServerError, resp.StatusCode)\n254: \t}\n255: \n256: \tlogger.mu.Lock()\n257: \tdefer logger.mu.Unlock()\n258: \tif len(logger.errors) != 1 {\n259: \t\tt.Errorf(\"expected 1 error log, got %d\", len(logger.errors))\n260: \t}\n261: \n262: \tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\n263: \tdefer cancel()\n264: \ts.Stop(ctx)\n265: \n266: \tselect {\n267: \tcase <-errCh:\n268: \tcase <-time.After(1 * time.Second):\n269: \t}\n270: }\n271: \n272: func TestStartStopLifecycle(t *testing.T) {\n273: \tlistener, err := net.Listen(\"tcp\", \"127.0.0.1:0\")\n274: \tif err != nil {\n275: \t\tt.Fatalf(\"failed to get free port: %v\", err)\n276: \t}\n277: \taddr := listener.Addr().String()\n278: \tlistener.Close()\n279: \n280: \tcfg := Config{\n281: \t\tAddr:            addr,\n282: \t\tReadTimeout:     5 * time.Second,\n283: \t\tWriteTimeout:    5 * time.Second,\n284: \t\tIdleTimeout:     60 * time.Second,\n285: \t\tShutdownTimeout: 5 * time.Second,\n286: \t}\n287: \tlogger := &integrationTestLogger{}\n288: \ts := NewHTTPServer(cfg, logger)\n289: \n290: \terrCh := s.Start()\n291: \tif errCh == nil {\n292: \t\tt.Error(\"Start returned nil error channel\")\n293: \t}\n294: \n295: \ttime.Sleep(100 * time.Millisecond)\n296: \n297: \tctx := context.Background()\n298: \terr = s.Stop(ctx)\n299: \tif err != nil {\n300: \t\tt.Errorf(\"Stop returned error: %v\", err)\n301: \t}\n302: \n303: \tselect {\n304: \tcase <-s.stopCh:\n305: \tcase <-time.After(2 * time.Second):\n306: \t\tt.Error(\"stopCh was not closed after Stop()\")\n307: \t}\n308: \n309: \tselect {\n310: \tcase <-errCh:\n311: \tcase <-time.After(2 * time.Second):\n312: \t}\n313: }\n\n(End of file - total 313 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n)\n\ntype integrationTestLogger struct {\n\tmu     sync.Mutex\n\tinfos  []string\n\terrors []string\n}\n\nfunc (l *integrationTestLogger) Info(msg string, args ...any) {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/integration_test.go","time":{"start":1775896969056,"end":1775896969073}}}}
