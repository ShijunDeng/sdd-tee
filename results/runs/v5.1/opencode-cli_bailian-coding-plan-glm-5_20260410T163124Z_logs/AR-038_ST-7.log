e := NewClientCache()\n406: \tconfig := &rest.Config{Host: \"http://localhost:8080\"}\n407: \n408: \tb.ResetTimer()\n409: \tfor i := 0; i < b.N; i++ {\n410: \t\tcache.GetOrCreateClient(fmt.Sprintf(\"token-%d\", i%10), fmt.Sprintf(\"ns-%d\", i%10), config)\n411: \t}\n412: }\n413: \n414: func BenchmarkClientCache_GetOrCreateClient_Parallel(b *testing.B) {\n415: \tcache := NewClientCache()\n416: \tconfig := &rest.Config{Host: \"http://localhost:8080\"}\n417: \n418: \tb.RunParallel(func(pb *testing.PB) {\n419: \t\ti := 0\n420: \t\tfor pb.Next() {\n421: \t\t\tcache.GetOrCreateClient(fmt.Sprintf(\"token-%d\", i%10), fmt.Sprintf(\"ns-%d\", i%10), config)\n422: \t\t\ti++\n423: \t\t}\n424: \t})\n425: }\n426: \n427: func BenchmarkDetermineDeletionReason(b *testing.B) {\n428: \tnow := time.Now()\n429: \tidleTimeout := 15 * time.Minute\n430: \n431: \tsandboxes := make([]*types.SandboxInfo, 1000)\n432: \tfor i := 0; i < 1000; i++ {\n433: \t\tsandboxes[i] = &types.SandboxInfo{\n434: \t\t\tExpiresAt:    now.Add(time.Duration(i%3-1) * time.Hour),\n435: \t\t\tLastActivity: now.Add(-time.Duration(i%3) * 30 * time.Minute),\n436: \t\t}\n437: \t}\n438: \n439: \tb.ResetTimer()\n440: \tfor i := 0; i < b.N; i++ {\n441: \t\tdetermineDeletionReason(sandboxes[i%1000], now, idleTimeout)\n442: \t}\n443: }\n444: \n445: func BenchmarkMemoryStore_UpdateSandbox(b *testing.B) {\n446: \tstore := NewMemoryStore()\n447: \tctx := context.Background()\n448: \tnow := time.Now()\n449: \n450: \tfor i := 0; i < 1000; i++ {\n451: \t\tsandbox := &types.SandboxInfo{\n452: \t\t\tSessionID: fmt.Sprintf(\"session-%d\", i),\n453: \t\t\tSandboxID: fmt.Sprintf(\"sandbox-%d\", i),\n454: \t\t\tCreatedAt: now,\n455: \t\t\tExpiresAt: now.Add(8 * time.Hour),\n456: \t\t\tStatus:    \"running\",\n457: \t\t}\n458: \t\tstore.StoreSandbox(ctx, sandbox)\n459: \t}\n460: \n461: \tb.ResetTimer()\n462: \tfor i := 0; i < b.N; i++ {\n463: \t\tsandbox := &types.SandboxInfo{\n464: \t\t\tSessionID:    fmt.Sprintf(\"session-%d\", i%1000)