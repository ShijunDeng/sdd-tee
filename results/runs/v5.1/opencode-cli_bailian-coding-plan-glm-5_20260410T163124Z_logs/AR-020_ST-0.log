in.go` | Agent daemon õ║īĶ┐øÕłČÕģźÕÅŻ’╝īÕÉ»ÕŖ© idle cleanup controller |\n40: | `cmd/agentsandbox/main.go` | Sandbox Ķ┐ÉĶĪīµŚČõ║īĶ┐øÕłČÕģźÕÅŻ’╝īÕÉ»ÕŖ© WorkloadManager HTTP Server |\n41: | `cmd/agentctl/main.go` | µÄ¦ÕłČÕĘźÕģĘõ║īĶ┐øÕłČÕģźÕÅŻ’╝īµÅÉõŠøĶ┐Éń╗┤ń«ĪńÉåÕæĮõ╗ż |\n42: | ÕŹĢÕģāµĄŗĶ»Ģ | ÕÉäÕģźÕÅŻńÜäÕ¤║ńĪĆµĄŗĶ»Ģ |\n43: \n44: ### Implementation Details\n45: \n46: #### `cmd/agentcube/main.go`\n47: ```go\n48: package main\n49: \n50: import (\n51:     \"flag\"\n52:     \"fmt\"\n53:     \"os\"\n54: )\n55: \n56: var (\n57:     version   = \"dev\"\n58:     showVersion = flag.Bool(\"version\", false, \"Show version information\")\n59: )\n60: \n61: func main() {\n62:     flag.Parse()\n63:     if *showVersion {\n64:         fmt.Printf(\"agentcube version: %s\\n\", version)\n65:         os.Exit(0)\n66:     }\n67:     fmt.Println(\"agentcube - Kubernetes-native sandbox orchestration platform\")\n68:     fmt.Println(\"Usage: agentcube [command]\")\n69:     fmt.Println(\"Commands:\")\n70:     fmt.Println(\"  agentd       Run agent daemon (idle cleanup controller)\")\n71:     fmt.Println(\"  agentsandbox Run sandbox runtime (WorkloadManager)\")\n72:     fmt.Println(\"  agentctl     Control and management tool\")\n73:     os.Exit(1)\n74: }\n75: ```\n76: \n77: #### `cmd/agentd/main.go`\n78: ```go\n79: package main\n80: \n81: import (\n82:     \"context\"\n83:     \"flag\"\n84:     \"os\"\n85:     \"os/signal\"\n86:     \"syscall\"\n87:     \"time\"\n88: \n89:     \"github.com/volcano-sh/agentcube/pkg/agentd\"\n90:     \"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n91:     \"k8s.io/klog/v2\"\n92: )\n93: \n94: func main() {\n95:     klog.InitFlags(nil)\n96:     \n97:     interval := flag.Duration(\"interval\", agentd.DefaultIdleCleanupInterval, \"Cleanup check interval\")\n98:     idleTimeout := flag.Duration(\"idle-timeout\", agentd.DefaultIdleTimeout, \"Idle session timeout\")\n99:     flag.Parse()\n100: \n101:     store := workloadmanager.NewMemoryStore()\n102:     k8sClient, err := workloadmanager.NewK8sClient()\n103:     if err != nil {\n104:         klog.Fatalf(\"failed to create k8s client: %v\", err)\n105:     }\n106:     \n107:     lifecycleConfig := workloadmanager.DefaultLifecycleConfig()\n108:     lifecycleManager := workloadmanager.NewSandboxLifecycleManager(k8sClient, store, lifecycleConfig, klog.NewKlogr())\n109:     \n110:     ctrl := agentd.NewIdleCleanupController(store, lifecycleManager, *interval, *idleTimeout, klog.NewKlogr())\n111:     \n112:     ctx, cancel := context.WithCancel(context.Background())\n113:     defer cancel()\n114:     \n115:     ctrl.Start()\n116:     klog.Info(\"agentd started\")\n117:     \n118:     sigCh := make(chan os.Signal, 1)\n119:     signal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n120:     <-sigCh\n121:     \n122:     ctrl.Stop()\n123:     klog.Info(\"agentd stopped\")\n124: }\n125: ```\n126: \n127: #### `cmd/agentsandbox/main.go`\n128: ```go\n129: package main\n130: \n131: import (\n132:     \"context\"\n133:     \"flag\"\n134:     \"os\"\n135:     \"os/signal\"\n136:     \"syscall\"\n137: \n138:     \"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n139:     \"k8s.io/klog/v2\"\n140: )\n141: \n142: func main() {\n143:     klog.InitFlags(nil)\n144:     \n145:     addr := flag.String(\"addr\", \":8080\", \"HTTP server address\")\n146:     flag.Parse()\n147: \n148:     cfg := workloadmanager.DefaultConfig()\n149:     cfg.Addr = *addr\n150: \n151:     k8sClient, err := workloadmanager.NewK8sClient()\n152:     if err != nil {\n153:         klog.Fatalf(\"failed to create k8s client: %v\", err)\n154:     }\n155:     \n156:     store := workloadmanager.NewMemoryStore()\n157:     \n158:     server := workloadmanager.NewHTTPServerWithClients(cfg, klog.NewKlogr(), k8sClient, store)\n159:     server.RegisterHandler(\"health\", workloadmanager.NewHealthHandler())\n160:     server.RegisterHandler(\"sandbox\", workloadmanager.NewSandboxHandler(store, k8sClient))\n161:     \n162:     server.GracefulShutdown()\n163:     \n164:     errCh := server.Start()\n165:     klog.InfoS(\"agentsandbox started\", \"addr\", *addr)\n166:     \n167:     select {\n168:     case err := <-errCh:\n169:         klog.Fatalf(\"server error: %v\", err)\n170:     case sig := <-waitSignal():\n171:         klog.InfoS(\"received signal\", \"signal\", sig)\n172:         server.Stop(context.Background())\n173:     }\n174: }\n175: \n176: func waitSignal() chan os.Signal {\n177:     sigCh := make(chan os.Signal, 1)\n178:     signal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n179:     return sigCh\n180: }\n181: ```\n182: \n183: #### `cmd/agentctl/main.go`\n184: ```go\n185: package main\n186: \n187: import (\n188:     \"flag\"\n189:     \"fmt\"\n190:     \"os\"\n191: \n192:     \"k8s.io/klog/v2\"\n193: )\n194: \n195: func main() {\n196:     klog.InitFlags(nil)\n197:     flag.Parse()\n198: \n199:     args := flag.Args()\n200:     if len(args) == 0 {\n201:         printUsage()\n202:         os.Exit(1)\n203:     }\n204: \n205:     switch args[0] {\n206:     case \"list\":\n207:         fmt.Println(\"list: list all sandboxes (TODO)\")\n208:     case \"delete\":\n209:         fmt.Println(\"delete: delete a sandbox (TODO)\")\n210:     case \"status\":\n211:         fmt.Println(\"status: show sandbox status (TODO)\")\n212:     default:\n213:         printUsage()\n214:         os.Exit(1)\n215:     }\n216: }\n217: \n218: func printUsage() {\n219:     fmt.Println(\"agentctl - AgentCube control tool\")\n220:     fmt.Println(\"Usage: agentctl [command]\")\n221:     fmt.Println(\"Commands:\")\n222:     fmt.Println(\"  list     List all sandboxes\")\n223:     fmt.Println(\"  delete   Delete a sandbox by session ID\")\n224:     fmt.Println(\"  status   Show sandbox status\")\n225: }\n226: ```\n227: \n228: ### 2.2 Out of Scope\n229: \n230: | Item | Reason |\n231: |------|--------|\n232: | Cobra/Viper ÕæĮõ╗żĶĪīµĪåµ×ČķøåµłÉ | õ┐ØµīüÕłØÕ¦ŗÕ«×ńÄ░ń«ĆÕŹĢ’╝īõĮ┐ńö©µĀćÕćå flag Õīģ |\n233: | agentctl Õ