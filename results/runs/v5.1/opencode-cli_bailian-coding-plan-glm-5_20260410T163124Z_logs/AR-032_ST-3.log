Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ  в”Ӯ\nв”Ӯ   в”Ӯ                       CI/CD Pipeline                                    в”Ӯ  в”Ӯ\nв”Ӯ   в”Ӯ                                                                        в”Ӯ  в”Ӯ\nв”Ӯ   в”Ӯ   GitHub Actions                                                        в”Ӯ  в”Ӯ\nв”Ӯ   в”Ӯ       в”Ӯ                                                                 в”Ӯ  в”Ӯ\nв”Ӯ   в”Ӯ       в”ңв”Җв–ә main.yml: make docker-build                                   в”Ӯ  в”Ӯ\nв”Ӯ   в”Ӯ       в”ңв”Җв–ә build-push-release.yml: make docker-buildx-push-*            в”Ӯ  в”Ӯ\nв”Ӯ   в”Ӯ       в”ңв”Җв–ә E2E: run_e2e.sh                                              в”Ӯ  в”Ӯ\nв”Ӯ   в”Ӯ       в”Ӯ       в””в”Җв–ә make docker-build-all                                в”Ӯ  в”Ӯ\nв”Ӯ   в”Ӯ       в”Ӯ       в””в”Җв–ә kind load docker-image                                в”Ӯ  в”Ӯ\nв”Ӯ   в”Ӯ                                                                        в”Ӯ  в”Ӯ\nв”Ӯ   в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ  в”Ӯ\nв”Ӯ                                                                               в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n```\n\n---\n\n## Data Structures\n\n### Dockerfile Stage Structure\n\n#### Workload Manager Dockerfile (`docker/Dockerfile`)\n\n```dockerfile\n# Stage 1: Builder\nFROM golang:1.24-alpine AS builder\n\nWORKDIR /app\n\nCOPY go.mod go.sum ./\nRUN --mount=type=cache,target=/go/pkg/mod \\\n    go mod download\n\nCOPY . .\n\nENV CGO_ENABLED=0\nENV GOOS=linux\nENV GOARCH=amd64\n\nRUN --mount=type=cache,target=/root/.cache/go-build \\\n    go build -ldflags=\"-w -s\" -o /app/bin/workloadmanager ./cmd/workload-manager\n\n# Stage 2: Runtime\nFROM alpine:3.19\n\nRUN apk add --no-cache ca-certificates tzdata\n\nRUN adduser -D -u 1000 apiserver\n\nWORKDIR /app\n\nCOPY --from=builder /app/bin/workloadmanager /app/bin/workloadmanager\n\nUSER 1000\n\nEXPOSE 8080\n\nENTRYPOINT [\"/app/bin/workloadmanager\"]\n```\n\n#### Router Dockerfile (`docker/Dockerfile.router`)\n\n```dockerfile\n# Stage 1: Builder\nFROM golang:1.24-alpine AS builder\n\nWORKDIR /app\n\nCOPY go.mod go.sum ./\nRUN --mount=type=cache,target=/go/pkg/mod \\\n    go mod download\n\nCOPY . .\nCOPY client-go/ client-go/\n\nENV CGO_ENABLED=0\nENV GOOS=linux\nENV GOARCH=amd64\n\nRUN --mount=type=cache,target=/root/.cache/go-build \\\n    go build -ldflags=\"-w -s\" -o /app/bin/router ./cmd/router\n\n# Stage 2: Runtime\nFROM alpine:3.19\n\nRUN apk add --no-cache ca-certificates tzdata\n\nRUN adduser -D -u 1000 router\n\nWORKDIR /app\n\nCOPY --from=builder /app/bin/router /app/bin/router\n\nUSER 1000\n\nEXPOSE 8080\n\nENTRYPOINT [\"/app/bin/router\"]\n```\n\n#### PicoD Dockerfile (`docker/Dockerfile.picod`)\n\n```dockerfile\n# Stage 1: Builder\nFROM golang:1.24 AS builder\n\nWORKDIR /app\n\nCOPY go.mod go.sum ./\nRUN go mod download\n\nCOPY . .\n\nENV CGO_ENABLED=0\nENV GOOS=linux\nENV GOARCH=amd64\n\nRUN go build -ldflags=\"-w -s\" -o /app/bin/picod ./cmd/picod\n\n# Stage 2: Runtime\nFROM ubuntu:24.04\n\nRUN apt-get update && apt-get install -y --no-install-recommends \\\n    python3 \\\n    python3-pip \\\n    ca-certificates \\\n    && rm -rf /var/lib/apt/lists/*\n\nWORKDIR /app\n\nCOPY --from=builder /app/bin/picod /app/bin/picod\n\nEXPOSE 8080\n\nENTRYPOINT [\"/app/bin/picod\"]\n```\n\n### Dockerfile Stage Data Model\n\n```yaml\nStageDefinition:\n  builder:\n    base_image: \"golang:1.24-alpine\"\n    workdir: \"/app\"\n    env_vars:\n      CGO_ENABLED: \"0\"\n      GOOS: \"${TARGETOS:-linux}\"\n      GOARCH: \"${TARGETARCH:-amd64}\"\n    cache_mounts:\n      - target: \"/go/pkg/mod\"\n        type: \"cache\"\n        key: \"go-mod-cache\"\n      - target: \"/root/.cache/go-build\"\n        type: \"cache\"\n        key: \"go-build-cache\"\n    operations:\n      - copy: [\"go.mod\", \"go.sum\", \"./\"]\n      - run: \"go mod download\"\n      - copy: \".\"\n      - build: \"./cmd/<module> -> /app/bin/<binary>\"\n    build_flags:\n      ldflags: \"-w -s\"\n      trimpath: true\n\n  runtime:\n    base_image_alpine: \"alpine:3.19\"\n    base_image_ubuntu: \"ubuntu:24.04\"\n    packages_alpine:\n      - \"ca-certificates\"\n      - \"tzdata\"\n    packages_ubuntu:\n      - \"python3\"\n      - \"python3-pip\"\n      - \"ca-certificates\"\n    user:\n      alpine:\n        name: \"<service_user>\"\n        uid: 1000\n        create_command: \"adduser -D -u 1000 <user>\"\n      ubuntu:\n        name: \"root\"\n        uid: 0\n    operations:\n      - copy_from: \"builder:/app/bin/<binary> -> /app/bin/<binary>\"\n      - expose: 8080\n      - entrypoint: \"/app/bin/<binary>\"\n```\n\n### Build Arguments Schema\n\n```yaml\nBuildArgs:\n  TARGETOS:\n    type: string\n    default: \"linux\"\n    values: [\"linux\", \"windows\", \"darwin\"]\n    description: \"Target operating system for cross-compilation\"\n    \n  TARGETARCH:\n    type: string\n    default: \"amd64\"\n    values: [\"amd64\", \"arm64\", \"arm\", \"386\"]\n    description: \"Target architecture for cross-compilation\"\n    \n  VERSION:\n    type: string\n    default: \"latest\"\n    description: \"Image tag version\"\n    \n  IMAGE_REPO:\n    type: string\n    default: \"ghcr.io/volcano-sh/agentcube\"\n    description: \"Image repository base URL\"\n```\n\n---\n\n## API Contracts\n\n### Makefile Target Contract\n\n```makefile\n# Image naming convention\nIMAGE_REPO ?= ghcr.io/volcano-sh/agentcube\nVERSION ?= $(shell git describe --tags --always --dirty)\n\n# Build targets\n.PHONY: docker-build docker-build-router docker-build-picod docker-build-all\n\ndocker-build:\n\tdocker build \\\n\t\t-f docker/Dockerfile \\\n\t\t-t $(IMAGE_REPO)/workloadmanager:$(VERSION) \\\n\t\t--build-arg TARGETOS=linux \\\n\t\t--build-arg TARGETARCH=amd64 \\\n\t\t.\n\ndocker-build-router:\n\tdocker build \\\n\t\t-f docker/Dockerfile.router \\\n\t\t-t $(IMAGE_REPO)/router:$(VERSION) \\\n\t\t--build-arg TARGETOS=linux \\\n\t\t--build-arg TARGETARCH=amd64 \\\n\t\t.\n\ndocker-build-picod:\n\tdocker build \\\n\t\t-f docker/Dockerfile.picod \\\n\t\t-t $(IMAGE_REPO)/picod:$(VERSION) \\\n\t\t.\n\ndocker-build-all: docker-build docker-build-router docker-build-picod\n\n# Multi-arch buildx targets\n.PHONY: docker-buildx-push docker-buildx-push-router docker-buildx-push-picod\n\ndocker-buildx-push:\n\tdocker buildx build \\\n\t\t-f docker/Dockerfile \\\n\t\t--platform linux/amd64,linux/arm64 \\\n\t\t--build-arg TARGETOS=linux \\\n\t\t--build-arg TARGETARCH=amd64 \\\n\t\t--push \\\n\t\t-t $(IMAGE_REPO)/workloadmanager:$(VERSION) \\\n\t\t.\n\ndocker-buildx-push-router:\n\tdocker buildx build \\\n\t\t-f docker/Dockerfile.router \\\n\t\t--platform linux/amd64,linux/arm64 \\\n\t\t--push \\\n\t\t-t $(IMAGE_REPO)/router:$(VERSION) \\\n\t\t.\n\ndocker-buildx-push-picod:\n\tdocker buildx build \\\n\t\t-f docker/Dockerfile.picod \\\n\t\t--platform linux/amd64,linux/arm64 \\\n\t\t--push \\\n\t\t-t $(IMAGE_REPO)/picod:$(VERSION) \\\n\t\t.\n```\n\n### Docker Build Command Interface\n\n```yaml\nDockerBuildCommand:\n  parameters:\n    dockerfile:\n      type: string\n      required: true\n      values: [\"docker/Dockerfile\", \"docker/Dockerfile.router\", \"docker/Dockerfile.picod\"]\n    tag:\n      type: string\n      required: true\n      pattern: \"${IMAGE_REPO}/${IMAGE_NAME}:${VERSION}\"\n    context:\n      type: string\n      default: \".\"\n      description: \"Build context directory (repository root)\"\n    build_args:\n      TARGETOS:\n        type: string\n        optional: true\n      TARGETARCH:\n        type: string\n        optional: true\n    platform:\n      type: string\n      optional: true\n      pattern: \"linux/amd64,linux/arm64\"\n      description: \"Multi-arch platform specification\"\n\n  outputs:\n    image_id:\n      type: string\n      description: \"Built image SHA256 digest\"\n    image_size:\n      type: integer\n      unit: \"bytes\"\n      description: \"Final image size\"\n    layers:\n      type: integer\n      description: \"Number of layers in final image\"\n```\n\n### Helm Values Contract\n\n```yaml\n# manifests/charts/base/values.yaml\nimages:\n  workloadmanager:\n    repository: ghcr.io/volcano-sh/agentcube/workloadmanager\n    tag: latest\n    pullPolicy: IfNotPresent\n    \n  router:\n    repository: ghcr.io/volcano-sh/agentcube/router\n    tag: latest\n    pullPolicy: IfNotPresent\n    \n  picod:\n    repository: ghcr.io/volcano-sh/agentcube/picod\n    tag: latest\n    pullPolicy: IfNotPresent\n```\n\n---\n\n## Error Handling\n\n### Build Error Categories\n\n| Error Category | Description | Detection | Recovery Action |\n|----------------|-------------|-----------|-----------------|\n| `BuildArgError` | Invalid/missing build arguments | Docker build start | Validate args before build |\n| `CopyError` | Source file not found in context | `COPY` instruction | Check file existence in context |\n| `GoBuildError` | Go compilation failure | `go build` command | Review compilation logs, fix source |\n| `ModDownloadError` | Go module download failure | `go mod download` | Check network, verify go.mod |\n| `UserCreateError` | Non-root user creation failure | `adduser` command | Alpine package availability |\n| `CacheMountError` | BuildKit cache mount failure | `--mount=type=cache` | Enable BuildKit (`DOCKER_BUILDKIT=1`) |\n| `ImagePullError` | Base image pull failure | `FROM` instruction | Check registry connectivity |\n| `CrossArchError` | Cross-architecture compilation failure | `TARGETARCH` mismatch | Verify Go cross-compilation support |\n\n### Build Failure Handling Pattern\n\n```bash\n#!/bin/bash\n# build-with-error-handling.sh\n\nset -euo pipefail\n\nbuild_image() {\n    local dockerfile=\"$1\"\n    local tag=\"$2\"\n    \n    echo \"Building image from $dockerfile...\"\n    \n    if ! docker build -f \"$dockerfile\" -t \"$tag\" .; then\n        echo \"ERROR: Build failed for $dockerfile\"\n        \n        docker build -f \"$dockerfile\" -t \"$tag\" . --no-cache\n        \n        if ! docker build -f \"$dockerfile\" -t \"$tag\" . --no-cache; then\n            echo \"ERROR: Build failed even with --no-cache\"\n            return 1\n        fi\n    fi\n    \n    local image_size=$(docker image inspect \"$tag\" --format='{{.Size}}')\n    echo \"Image size: $(numfmt --to=iec $image_size)\"\n    \n    if [[ $image_size -gt 100000000 ]]; then\n        echo \"WARNING: Image exceeds 100MB size target\"\n    fi\n    \n    return 0\n}\n\nmain() {\n    local failed=0\n    \n    for image in workloadmanager router picod; do\n        local dockerfile=\"docker/Dockerfile\"\n        if [[ \"$image\" != \"workloadmanager\" ]]; then\n            dockerfile=\"docker/Dockerfile.$image\"\n        fi\n        \n        if ! build_image \"$dockerfile\" \"agentcube/$image:test\"; then\n            failed=1\n        fi\n    done\n    \n    if [[ $failed -eq 1 ]]; then\n        echo \"ERROR: One or more builds failed\"\n        exit 1\n    fi\n    \n    echo \"All builds completed successfully\"\n}\n\nmain \"$@\"\n```\n\n### Runtime Error Detection\n\n| Error | Detection | Container Behavior | Remediation |\n|-------|-----------|-------------------|-------------|\n| `EntrypointNotFound` | Binary not in expected path | Container exits immediately | Verify COPY instruction |\n| `PermissionDenied` | UID lacks execute permission | Exit code 126 | Check USER directive |\n| `PortBindFailed` | Port 8080 already bound | Container exits with error | Check port conflicts |\n| `MissingDependency` | Required package not installed | Binary execution fails | Verify RUN apk/apt install |\n\n### Health Check Contract\n\n```dockerfile\n# Optional health check for runtime stage\nHEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \\\n    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1\n```\n\n---\n\n## Testing Strategy\n\n### Test Categories\n\n| Category | Scope | Tools | Purpose |\n|----------|-------|-------|---------|\n| Dockerfile Syntax | Dockerfile validity | `docker build --check`, `hadolint` | Validate Dockerfile syntax and best practices |\n| Build Execution | Full build process | `docker build`, `make docker-build-*` | Verify images build successfully |\n| Image Size | Runtime image size | `docker image inspect`, size comparison | Ensure size targets met (<50MB Alpine, <100MB Ubuntu) |\n| Runtime Execution | Container startup | `docker run`, health checks | Verify container runs correctly |\n| Security Scan | Vulnerability detection | `trivy`, `docker scout` | Identify CVEs in base images |\n| User Isolation | Non-root execution | `docker exec`, UID check | Verify security context |\n| Cross-Arch | Multi-arch builds | `docker buildx`, Kind cluster | Test amd64/arm64 builds |\n| E2E Integration | Full deployment | Kind, Helm, E2E tests | Verify images work in cluster |\n\n### Unit Tests: Dockerfile Syntax\n\n```bash\n#!/bin/bash\n# test_dockerfile_syntax.sh\n\ntest_dockerfile_exists() {\n    for dockerfile in docker/Dockerfile docker/Dockerfile.router docker/Dockerfile.picod; do\n        if [[ ! -f \"$dockerfile\" ]]; then\n            echo \"FAIL: $dockerfile does not exist\"\n            return 1\n        fi\n        echo \"PASS: $dockerfile exists\"\n    done\n    return 0\n}\n\ntest_builder_base_image() {\n    for dockerfile in docker/Dockerfile docker/Dockerfile.router; do\n        if ! grep -q \"FROM golang:1.24\" \"$dockerfile\"; then\n            echo \"FAIL: $dockerfile missing golang:1.24 builder\"\n            return 1\n        fi\n        echo \"PASS: $dockerfile has correct builder base\"\n    done\n    return 0\n}\n\ntest_runtime_base_image() {\n    local expected_base=\"alpine:3.19\"\n    \n    for dockerfile in docker/Dockerfile docker/Dockerfile.router; do\n        if ! grep -q \"FROM $expected_base\" \"$dockerfile\"; then\n            echo \"FAIL: $dockerfile missing $expected_base runtime\"\n            return 1\n        fi\n        echo \"PASS: $dockerfile has Alpine runtime base\"\n    done\n    \n    if ! grep -q \"FROM ubuntu:24.04\" docker/Dockerfile.picod; then\n        echo \"FAIL: docker/Dockerfile.picod missing ubuntu:24.04 runtime\"\n        return 1\n    fi\n    echo \"PASS: docker/Dockerfile.picod has Ubuntu runtime base\"\n    \n    return 0\n}\n\ntest_cgo_disabled() {\n    for dockerfile in docker/Dockerfile docker/Dockerfile.router docker/Dockerfile.picod; do\n        if ! grep -q \"CGO_ENABLED=0\" \"$dockerfile\"; then\n            echo \"FAIL: $dockerfile missing CGO_ENABLED=0\"\n            return 1\n        fi\n        echo \"PASS: $dockerfile has CGO_ENABLED=0\"\n    done\n    return 0\n}\n\ntest_non_root_user() {\n    for dockerfile in docker/Dockerfile docker/Dockerfile.router; do\n        if ! grep -q \"USER 1000\" \"$dockerfile\"; then\n            echo \"FAIL: $dockerfile missing USER 1000\"\n            return 1\n        fi\n        echo \"PASS: $dockerfile has non-root user directive\"\n    done\n    \n    if grep -q \"USER 1000\" docker/Dockerfile.picod; then\n        echo \"FAIL: docker/Dockerfile.picod should NOT have USER 1000\"\n        return 1\n    fi\n    echo \"PASS: docker/Dockerfile.picod runs as root (expected)\"\n    \n    return 0\n}\n\ntest_ldflags_optimization() {\n    for dockerfile in docker/Dockerfile docker/Dockerfile.router docker/Dockerfile.picod; do\n        if ! grep -q 'ldflags=\"-w -s\"' \"$dockerfile\"; then\n            echo \"FAIL: $dockerfile missing -ldflags=\\\"-w -s\\\"\"\n            return 1\n        fi\n        echo \"PASS: $dockerfile has binary optimization ldflags\"\n    done\n    return 0\n}\n\nmain() {\n    local failed=0\n    \n    test_dockerfile_exists || failed=1\n    test_builder_base_image || failed=1\n    test_runtime_base_image || failed=1\n    test_cgo_disabled || failed=1\n    test_non_root_user || failed=1\n    test_ldflags_optimization || failed=1\n    \n    if [[ $failed -eq 1 ]]; then\n        echo \"TESTS FAILED\"\n        exit 1\n    fi\n    \n    echo \"ALL TESTS PASSED\"\n    exit 0\n}\n\nmain\n```\n\n### Integration Tests: Build Execution\n\n```bash\n#!/bin/bash\n# test_docker_build.sh\n\nset -euo pipefail\n\ncleanup() {\n    docker rmi -f agentcube-test-workloadmanager agentcube-test-router agentcube-test-picod 2>/dev/null || true\n}\n\ntrap cleanup EXIT\n\ntest_workloadmanager_build() {\n    echo \"Testing workloadmanager build...\"\n    \n    if ! docker build -f docker/Dockerfile -t agentcube-test-workloadmanager .; then\n        echo \"FAIL: workloadmanager build failed\"\n        return 1\n    fi\n    \n    local size=$(docker image inspect agentcube-test-workloadmanager --format='{{.Size}}')\n    if [[ $size -gt 50000000 ]]; then\n        echo \"FAIL: workloadmanager image exceeds 50MB: $(numfmt --to=iec $size)\"\n        return 1\n    fi\n    \n    echo \"PASS: workloadmanager build succeeded, size: $(numfmt --to=iec $size)\"\n    return 0\n}\n\ntest_router_build() {\n    echo \"Testing router build...\"\n    \n    if ! docker build -f docker/Dockerfile.router -t agentcube-test-router .; then\n        echo \"FAIL: router build failed\"\n        return 1\n    fi\n    \n    local size=$(docker image inspect agentcube-test-router --format='{{.Size}}')\n    if [[ $size -gt 50000000 ]]; then\n        echo \"FAIL: router image exceeds 50MB: $(numfmt --to=iec $size)\"\n        return 1\n    fi\n    \n    echo \"PASS: router build succeeded, size: $(numfmt --to=iec $size)\"\n    return 0\n}\n\ntest_picod_build() {\n    echo \"Testing picod build...\"\n    \n    if ! docker build -f docker/Dockerfile.picod -t agentcube-test-picod .; then\n        echo \"FAIL: picod build failed\"\n        return 1\n    fi\n    \n    local size=$(docker image inspect agentcube-test-picod --format='{{.Size}}')\n    if [[ $size -gt 100000000 ]]; then\n        echo \"FAIL: picod image exceeds 100MB: $(numfmt --to=iec $size)\"\n        return 1\n    fi\n    \n    echo \"PASS: picod build succeeded, size: $(numfmt --to=iec $size)\"\n    return 0\n}\n\ntest_binary_exists() {\n    local image=\"$1\"\n    local binary=\"$2\"\n    \n    if ! docker run --rm \"$image\" test -f \"/app/bin/$binary\"; then\n        echo \"FAIL: $binary not found in $image\"\n        return 1\n    fi\n    echo \"PASS: $binary exists in $image\"\n    return 0\n}\n\ntest_user_isolation() {\n    local image=\"$1\"\n    local expected_uid=\"$2\"\n    \n    local uid=$(docker run --rm \"$image\" id -u)\n    if [[ \"$uid\" != \"$expected_uid\" ]]; then\n        echo \"FAIL: $image running as UID $uid, expected $expected_uid\"\n        return 1\n    fi\n    echo \"PASS: $image running as correct UID $uid\"\n    return 0\n}\n\ntest_no_go_toolchain() {\n    local image=\"$1\"\n    \n    if docker run --rm \"$image\" which go 2>/dev/null; then\n        echo \"FAIL: $image contains Go toolchain\"\n        return 1\n    fi\n    echo \"PASS: $image does not contain Go toolchain\"\n    return 0\n}\n\ntest_no_source_files() {\n    local image=\"$1\"\n    \n    if docker run --rm \"$image\" find /app -name \"*.go\" -type f 2>/dev/null | grep -q .; then\n        echo \"FAIL: $image contains Go source files\"\n        return 1\n    fi\n    echo \"PASS: $image does not contain Go source files\"\n    return 0\n}\n\nmain() {\n    local failed=0\n    \n    test_workloadmanager_build || failed=1\n    test_router_build || failed=1\n    test_picod_build || failed=1\n    \n    test_binary_exists agentcube-test-workloadmanager workloadmanager || failed=1\n    test_binary_exists agentcube-test-router router || failed=1\n    test_binary_exists agentcube-test-picod picod || failed=1\n    \n    test_user_isolation agentcube-test-workloadmanager 1000 || failed=1\n    test_user_isolation agentcube-test-router 1000 || failed=1\n    test_user_isolation agentcube-test-picod 0 || failed=1\n    \n    test_no_go_toolchain agentcube-test-workloadmanager || failed=1\n    test_no_go_toolchain agentcube-test-router || failed=1\n    test_no_source_files agentcube-test-workloadmanager || failed=1\n    test_no_source_files agentcube-test-router || failed=1\n    \n    if [[ $failed -eq 1 ]]; then\n        echo \"INTEGRATION TESTS FAILED\"\n        exit 1\n    fi\n    \n    echo \"ALL INTEGRATION TESTS PASSED\"\n    exit 0\n}\n\nmain\n```\n\n### E2E Tests: Kind Cluster Deployment\n\n```bash\n#!/bin/bash\n# test_kind_deployment.sh\n\nset -euo pipefail\n\nKIND_CLUSTER_NAME=\"agentcube-test\"\n\ncleanup() {\n    kind delete cluster --name \"$KIND_CLUSTER_NAME\" 2>/dev/null || true\n}\n\ntrap cleanup EXIT\n\ncreate_kind_cluster() {\n    echo \"Creating Kind cluster...\"\n    kind create cluster --name \"$KIND_CLUSTER_NAME\" --wait 60s\n}\n\nbuild_and_load_images() {\n    echo \"Building images...\"\n    make docker-build-all\n    \n    echo \"Loading images into Kind...\"\n    kind load docker-image \\\n        ghcr.io/volcano-sh/agentcube/workloadmanager:latest \\\n        --name \"$KIND_CLUSTER_NAME\"\n    kind load docker-image \\\n        ghcr.io/volcano-sh/agentcube/router:latest \\\n        --name \"$KIND_CLUSTER_NAME\"\n    kind load docker-image \\\n        ghcr.io/volcano-sh/agentcube/picod:latest \\\n        --name \"$KIND_CLUSTER_NAME\"\n}\n\ndeploy_with_helm() {\n    echo \"Deploying with Helm...\"\n    helm upgrade --install agentcube manifests/charts/base \\\n        --namespace agentcube --create-namespace \\\n        --set images.workloadmanager.tag=latest \\\n        --set images.router.tag=latest \\\n        --set images.picod.tag=latest \\\n        --wait --timeout 300s\n}\n\nverify_deployments() {\n    echo \"Verifying deployments...\"\n    \n    local deployments=\"workloadmanager router\"\n    for deploy in $deployments; do\n        if ! kubectl rollout status deployment/$deploy -n agentcube --timeout=60s; then\n            echo \"FAIL: $deploy deployment not ready\"\n            return 1\n        fi\n        echo \"PASS: $deploy deployment ready\"\n    done\n    \n    return 0\n}\n\nverify_pods_running() {\n    echo \"Verifying pods...\"\n    \n    local pods=$(kubectl get pods -n agentcube -o jsonpath='{.items[*].metadata.name}')\n    for pod in $pods; do\n        local uid=$(kubectl get pod \"$pod\" -n agentcube -o jsonpath='{.spec.containers[*].securityContext.runAsUser}')\n        if [[ -n \"$uid\" ]]; then\n            echo \"Pod $pod running with securityContext.runAsUser=$uid\"\n        fi\n    done\n    \n    return 0\n}\n\nmain() {\n    local failed=0\n    \n    create_kind_cluster || failed=1\n    build_and_load_images || failed=1\n    deploy_with_helm || failed=1\n    verify_deployments || failed=1\n    verify_pods_running || failed=1\n    \n    if [[ $failed -eq 1 ]]; then\n        echo \"E2E TESTS FAILED\"\n        exit 1\n    fi\n    \n    echo \"ALL E2E TESTS PASSED\"\n    exit 0\n}\n\nmain\n```\n\n---\n\n## File Structure\n\n| Path | Role |\n|------|------|\n| `docker/Dockerfile` | Workload Manager multi-stage build (builder вҶ’ runtime) |\n| `docker/Dockerfile.router` | Router multi-stage build (builder вҶ’ runtime) |\n| `docker/Dockerfile.picod` | PicoD multi-stage build (builder вҶ’ runtime) |\n| `Makefile` | Build targets: `docker-build`, `docker-build-router`, `docker-build-picod`, `docker-build-all` |\n| `manifests/charts/base/values.yaml` | Helm chart image repository/tag defaults |\n| `.github/workflows/main.yml` | CI workflow referencing `make docker-build` |\n| `.github/workflows/build-push-release.yml` | Release workflow for multi-arch builds |\n\n---\n\n## Dependencies\n\n| Package | Version | Purpose |\n|---------|---------|---------|\n| `golang:1.24-alpine` | 1.24 | Builder stage base for Go compilation |\n| `alpine:3.19` | 3.19 | Minimal runtime base (~5MB) |\n| `ubuntu:24.04` | 24.04 | Runtime base for picod (Python3 dependency) |\n| `ca-certificates` | latest | TLS certificate bundle |\n| `tzdata` | latest | Timezone data (Alpine) |\n| `python3` | system | Code execution dependency (Ubuntu/picod) |\n| `docker` | >=20.10 | BuildKit multi-stage support |\n| `buildx` | latest | Multi-arch cross-compilation |\n\n---\n\n## Implementation Notes\n\n### BuildKit Cache Optimization\n\n1. **Go Module Cache**: Mount `/go/pkg/mod` as cache to persist module downloads across builds\n2. **Go Build Cache**: Mount `/root/.cache/go-build` to cache compiled artifacts\n3. **Cache Key**: Cache keyed by `go.mod`/`go.sum` hash for automatic invalidation\n\n```dockerfile\nRUN --mount=type=cache,target=/go/pkg/mod \\\n    go mod download\n\nRUN --mount=type=cache,target=/root/.cache/go-build \\\n    go build -ldflags=\"-w -s\" -o /app/bin/<binary> ./cmd/<module>\n```\n\n### Binary Size Optimization\n\n| Flag | Effect |\n|------|--------|\n| `-w` | Strip DWARF debug information |\n| `-s` | Strip symbol table |\n| `CGO_ENABLED=0` | Disable CGO for static-like compilation |\n| `trimpath` | Remove file system paths from binary |\n\n### Security Considerations\n\n1. **Non-root User**: Alpine images run as UID 1000 to reduce attack surface\n2. **Minimal Packages**: Only `ca-certificates` and `tzdata` in runtime\n3. **No Shell Required**: Binary entrypoint without shell wrapper\n4. **PicoD Exception**: Runs as root for sandbox pod management permissions\n\n### Cross-Compilation\n\n```bash\n# amd64\ndocker build --build-arg TARGETOS=linux --build-arg TARGETARCH=amd64 ...\n\n# arm64\ndocker build --build-arg TARGETOS=linux --build-arg TARGETARCH=arm64 ...\n\n# Multi-arch with buildx\ndocker buildx build --platform linux/amd64,linux/arm64 ...\n```\n\n### CI Integration\n\n```yaml\n# .github/workflows/build-push-release.yml\n- name: Build and push images\n  run: |\n    make docker-buildx-push VERSION=${{ github.ref_name }}\n```\n\n---\n\n## References\n\n- Spec: `changes/AR-032/spec.md`\n- Delta Spec: `changes/AR-032/delta-spec.md`\n- Proposal: `changes/AR-032/proposal.md`\n- Tasks: `changes/AR-032/tasks.md`\n- Docker multi-stage builds: https://docs.docker.com/build/building/multi-stage/\n- BuildKit cache mounts: https://docs.docker.com/build/buildkit/#cache-mounts\n- Go cross-compilation: https://go.dev/doc/install/source#environment"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-032/design.md","exists":true,"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-032/design.md","time":{"start":1775886359793,"end":1775886359832}}}}
