: }\n49: \n50: func (e *NotFoundError) Error() string {\n51: \treturn fmt.Sprintf(\"not found: %s/%s\", e.Resource, e.Name)\n52: }\n53: \n54: // InternalError indicates an unexpected server error occurred.\n55: type InternalError struct {\n56: \tErr error\n57: }\n58: \n59: func (e *InternalError) Error() string {\n60: \treturn fmt.Sprintf(\"internal error: %v\", e.Err)\n61: }\n62: \n63: // ServiceUnavailableError indicates a dependency service is unavailable.\n64: type ServiceUnavailableError struct {\n65: \tDependency string\n66: }\n67: \n68: func (e *ServiceUnavailableError) Error() string {\n69: \treturn fmt.Sprintf(\"service unavailable: %s\", e.Dependency)\n70: }\n71: \n72: // HandleError maps error types to appropriate HTTP status codes and JSON responses.\n73: // It always sets Content-Type: application/json header.\n74: func HandleError(w http.ResponseWriter, _ *http.Request, err error) {\n75: \tw.Header().Set(\"Content-Type\", \"application/json\")\n76: \n77: \tvar resp ErrorResponse\n78: \tvar status int\n79: \n80: \tswitch e := err.(type) {\n81: \tcase *ValidationError:\n82: \t\tstatus = http.StatusBadRequest\n83: \t\tresp = ErrorResponse{\n84: \t\t\tCode:    \"VALIDATION_ERROR\",\n85: \t\t\tMessage: \"Invalid request parameter\",\n86: \t\t\tDetails: map[string]string{\"field\": e.Field, \"reason\": e.Reason},\n87: \t\t}\n88: \tcase *NotFoundError:\n89: \t\tstatus = http.StatusNotFound\n90: \t\tresp = ErrorResponse{\n91: \t\t\tCode:    \"NOT_FOUND\",\n92: \t\t\tMessage: e.Error(),\n93: \t\t}\n94: \tcase *ServiceUnavailableError:\n95: \t\tstatus = http.StatusServiceUnavailable\n96: \t\tresp = ErrorResponse{\n97: \t\t\tCode:    \"SERVICE_UNAVAILABLE\",\n98: \t\t\tMessage: e.Error(),\n99: \t\t}\n100: \tcase *InternalError:\n101: \t\tstatus = http.StatusInternalServerError\n102: \t\tresp = ErrorResponse{\n103: \t\t\tCode:    \"INTERNAL_ERROR\",\n104: \t\t\tMessage: \"Unexpected server error\",\n105: \t\t}\n106: \tdefault:\n107: \t\tstatus = http.StatusInternalServerError\n108: \t\tresp = ErrorResponse{\n109: \t\t\tCode:    \"INTERNAL_ERROR\",\n110: \t\t\tMessage: \"Unexpected server error\",\n111: \t\t}\n112: \t}\n113: \n114: \tw.WriteHeader(status)\n115: \tjson.NewEncoder(w).Encode(resp)\n116: }\n\n(End of file - total 116 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\n\t\"github.com/go-chi/chi/v5\"\n)\n\n// Handler defines the interface for registering routes on a chi router.\ntype Handler interface {\n\tRegister(r chi.Router)\n}\n\n// Logger defines the interface for logging within the workloadmanager package.\ntype Logger interface {\n\tInfo(msg string, args ...any)\n\tError(msg string, args ...any)\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/types.go","time":{"start":1775843536431,"end":1775843536443}}}}
