{"type":"tool_use","timestamp":1775884341782,"sessionID":"ses_2850e5115ffehvvEY1tK0F0KI3","part":{"id":"prt_d7af4137f001kgVEOxdKTqVlo6","messageID":"msg_d7af3b50f001KZN72Bxxp7vvGM","sessionID":"ses_2850e5115ffehvvEY1tK0F0KI3","type":"tool","tool":"write","callID":"toolu_tool-303c34fc3b36429cab60c9fe0e434964","state":{"status":"completed","input":{"content":"apiVersion: apiextensions.k8s.io/v1\nkind: CustomResourceDefinition\nmetadata:\n  annotations:\n    controller-gen.kubebuilder.io/version: v0.17.2\n  name: agentruntimes.runtime.agentcube.volcano.sh\nspec:\n  group: runtime.agentcube.volcano.sh\n  names:\n    kind: AgentRuntime\n    listKind: AgentRuntimeList\n    plural: agentruntimes\n    singular: agentruntime\n  scope: Namespaced\n  versions:\n    - additionalPrinterColumns:\n        - jsonPath: .metadata.creationTimestamp\n          name: Age\n          type: date\n      name: v1alpha1\n      schema:\n        openAPIV3Schema:\n          type: object\n          properties:\n            apiVersion:\n              type: string\n              description: 'APIVersion defines the versioned schema of this representation\n                of an object. Servers should convert recognized schemas to the latest\n                internal value, and may reject unrecognized values.'\n            kind:\n              type: string\n              description: 'Kind is a string value representing the REST resource this\n                object represents. Servers may infer this from the endpoint the client\n                submits requests to.'\n            metadata:\n              type: object\n            spec:\n              type: object\n              required:\n                - targetPort\n                - podTemplate\n              properties:\n                maxSessionDuration:\n                  type: string\n                  default: \"8h\"\n                  description: MaxSessionDuration specifies the maximum duration a session\n                    can exist. Default is 8 hours.\n                sessionTimeout:\n                  type: string\n                  default: \"15m\"\n                  description: SessionTimeout specifies the idle timeout for a session.\n                    Default is 15 minutes.\n                targetPort:\n                  type: array\n                  x-kubernetes-list-type: atomic\n                  description: Ports specifies the network ports to expose from the sandbox.\n                  items:\n                    type: object\n                    required:\n                      - port\n                      - protocol\n                    properties:\n                      name:\n                        type: string\n                        description: Name is a human-readable name for this port.\n                      pathPrefix:\n                        type: string\n                        description: PathPrefix is the URL path prefix for routing to\n                          this port.\n                      port:\n                        type: integer\n                        format: uint32\n                        minimum: 0\n                        description: Port is the container port number to expose.\n                      protocol:\n                        type: string\n                        default: HTTP\n                        enum:\n                          - HTTP\n                          - HTTPS\n                        description: Protocol specifies the protocol for this port (HTTP\n                          or HTTPS).\n                podTemplate:\n                  type: object\n                  description: Template defines the pod template for the sandbox.\n                  required:\n                    - spec\n                  properties:\n                    annotations:\n                      type: object\n                      additionalProperties:\n                        type: string\n                      description: Annotations are appli