{"type":"tool_use","timestamp":1775866395258,"sessionID":"ses_2861dc67cffe0P7ZhP57STPGS4","part":{"id":"prt_d79e2b011001xtMqdsgqaGd7B9","messageID":"msg_d79e2981e001ZZ22LrbkbD6eie","sessionID":"ses_2861dc67cffe0P7ZhP57STPGS4","type":"tool","tool":"read","callID":"toolu_tool-58ba595bde714db6922465a8966827a7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/agentd/idle_cleanup.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/agentd/idle_cleanup.go</path>\n<type>file</type>\n<content>\n1: package agentd\n2: \n3: import (\n4: \t\"context\"\n5: \t\"sync\"\n6: \t\"time\"\n7: \n8: \t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n9: )\n10: \n11: type LifecycleManager interface {\n12: \tDeleteSandbox(ctx context.Context, sessionID string) error\n13: }\n14: \n15: type IdleCleanupStats struct {\n16: \tInterval        time.Duration\n17: \tIdleTimeout     time.Duration\n18: \tLastCleanupTime time.Time\n19: }\n20: \n21: type IdleCleanupController struct {\n22: \tstore            workloadmanager.Store\n23: \tlifecycleManager LifecycleManager\n24: \tinterval         time.Duration\n25: \tidleTimeout      time.Duration\n26: \tstopCh           chan struct{}\n27: \twg               sync.WaitGroup\n28: \tlogger           workloadmanager.Logger\n29: \tidleMu           sync.RWMutex\n30: \tlastCleanupTime  time.Time\n31: \tlastCleanupMu    sync.RWMutex\n32: }\n33: \n34: func NewIdleCleanupController(store workloadmanager.Store, lifecycleManager LifecycleManager, interval, idleTimeout time.Duration, logger workloadmanager.Logger) *IdleCleanupController {\n35: \tif interval == 0 {\n36: \t\tinterval = DefaultIdleCleanupInterval\n37: \t}\n38: \tif idleTimeout == 0 {\n39: \t\tidleTimeout = DefaultIdleTimeout\n40: \t}\n41: \n42: \treturn &IdleCleanupController{\n43: \t\tstore:            store,\n44: \t\tlifecycleManager: lifecycleManager,\n45: \t\tinterval:         interval,\n46: \t\tidleTimeout:      idleTimeout,\n47: \t\tstopCh:           make(chan struct{}),\n48: \t\tlogger:           logger,\n49: \t}\n50: }\n51: \n52: func (ctrl *IdleCleanupController) Start() {\n53: \tctrl.wg.Add(1)\n54: \tgo ctrl.runLoop()\n55: }\n56: \n57: func (ctrl *IdleCleanupController) Stop() {\n58: \tclose(ctrl.stopCh)\n59: \tctrl.wg.Wait()\n60: }\n61: \n62: func (ctrl *IdleCleanupController) runLoop() {\n63: \tdefer ctrl.wg.Done()\n64: \n65: \tticker := time.NewTicker(ctrl.interval)\n66: \tdefer ticker.Stop()\n67: \n68: \tctrl.runOnce(context.Background())\n69: \n70: \tfor {\n71: \t\tselect {\n72: \t\tcase <-ctrl.stopCh:\n73: \t\t\tctrl.logger.Info(\"idle cleanup controller stopped\")\n74: \t\t\treturn\n75: \t\tcase <-ticker.C:\n76: \t\t\tctrl.runOnce(context.Background())\n77: \t\t}\n78: \t}\n79: }\n80: \n81: func (ctrl *IdleCleanupController) runOnce(ctx context.Context) {\n82: \tsessions, err := ctrl.store.ListSandboxes(ctx)\n83: \tif err != nil {\n84: \t\tctrl.logger.Error(\"failed to list sessions\", \"err\", err)\n85: \t\treturn\n86: \t}\n87: \n88: \tnow := time.Now()\n89: \tidleTimeout := ctrl.getIdleTimeout()\n90: \tcleanedCount := 0\n91: \n92: \tfor _, session := range sessions {\n93: \t\tif session.LastActivity.IsZero() {\n94: \t\t\tcontinue\n95: \t\t}\n96: \n97: \t\tidleDuration := now.Sub(session.LastActivity)\n98: \t\tif idleDuration <= idleTimeout {\n99: \t\t\tcontinue\n100: \t\t}\n101: \n102: \t\terr := ctrl.lifecycleManager.DeleteSandbox(ctx, session.SessionID)\n103: \t\tif err != nil {\n104: \t\t\tif _, ok := err.(*workloadmanager.NotFoundError); ok {\n105: \t\t\t\tcontinue\n106: \t\t\t}\n107: \t\t\tctrl.logger.Error(\"idle cleanup failed\", \"sessionID\", session.SessionID, \"err\", err)\n108: \t\t\tcontinue\n109: \t\t}\n110: \n111: \t\tcleanedCount++\n112: \t\tctrl.logger.Info(\"idle cleanup deleted session\", \"sessionID\", session.SessionID, \"idleDuration\", idleDuration, \"reason\", workloadmanager.DeletionReasonIdleTimeout)\n113: \t}\n114: \n115: \tctrl.lastCleanupMu.Lock()\n116: \tctrl.lastCleanupTime = time.Now()\n117: \tctrl.lastCleanupMu.Unlock()\n118: \n119: \tctrl.logger.Info(\"idle cleanup cycle completed\", \"cleanedCount\", cleanedCount)\n120: }\n121: \n122: func (ctrl *IdleCleanupController) SetIdleTimeout(timeout time.Duration) {\n123: \tctrl.idleMu.Lock()\n124: \tdefer ctrl.idleMu.Unlock()\n125: \tctrl.idleTimeout = timeout\n126: }\n127: \n128: func (ctrl *IdleCleanupController) GetIdleTimeout() time.Duration {\n129: \tctrl.idleMu.RLock()\n130: \tdefer ctrl.idleMu.RUnlock()\n131: \treturn ctrl.idleTimeout\n132: }\n133: \n134: func (ctrl *IdleCleanupController) getIdleTimeout() time.Duration {\n135: \tctrl.idleMu.RLock()\n136: \tdefer ctrl.idleMu.RUnlock()\n137: \treturn ctrl.idleTimeout\n138: }\n139: \n140: func (ctrl *IdleCleanupController) GetStats() IdleCleanupStats {\n141: \tctrl.idleMu.RLock()\n142: \tdefer ctrl.idleMu.RUnlock()\n143: \tctrl.lastCleanupMu.RLock()\n144: \tdefer ctrl.lastCleanupMu.RUnlock()\n145: \treturn IdleCleanupStats{\n146: \t\tInterval:        ctrl.interval,\n147: \t\tIdleTimeout:     ctrl.idleTimeout,\n148: \t\tLastCleanupTime: ctrl.lastCleanupTime,\n149: \t}\n150: }\n\n(End of file - total 150 lines)\n</content>","metadata":{"preview":"package agentd\n\nimport (\n\t\"context\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/workloadmanager\"\n)\n\ntype LifecycleManager interface {\n\tDeleteSandbox(ctx context.Context, sessionID string) error\n}\n\ntype IdleCleanupStats struct {\n\tInterval        time.Duration\n\tIdleTimeout     time.Duration\n\tLastCleanupTime time.Time\n}\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/agentd/idle_cleanup.go","time":{"start":1775866395236,"end":1775866395257}}}}
