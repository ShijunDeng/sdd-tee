n YAML stream: \":\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":8,"character":13},"end":{"line":8,"character":38}},"message":"Unexpected flow-map-start token in YAML stream: \"{\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":8,"character":14},"end":{"line":8,"character":38}},"message":"Unexpected flow-map-start token in YAML stream: \"{\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":8,"character":16},"end":{"line":8,"character":38}},"message":"Unexpected scalar token in YAML stream: \".Release.Namespace\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":8,"character":35},"end":{"line":8,"character":38}},"message":"Unexpected flow-map-end token in YAML stream: \"}\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":8,"character":36},"end":{"line":8,"character":38}},"message":"Unexpected flow-map-end token in YAML stream: \"}\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":9,"character":2},"end":{"line":9,"character":10}},"message":"Unexpected scalar token in YAML stream: \"labels\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":9,"character":8},"end":{"line":9,"character":10}},"message":"Unexpected map-value-ind token in YAML stream: \":\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":10,"character":4},"end":{"line":10,"character":52}},"message":"Unexpected flow-map-start token in YAML stream: \"{\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":10,"character":5},"end":{"line":10,"character":52}},"message":"Unexpected flow-map-start token in YAML stream: \"{\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":10,"character":6},"end":{"line":10,"character":52}},"message":"Unexpected seq-item-ind token in YAML stream: \"-\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":10,"character":8},"end":{"line":10,"character":52}},"message":"Unexpected scalar token in YAML stream: \"include \\\"agentcube.labels\\\" . | nindent 4\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":10,"character":49},"end":{"line":10,"character":52}},"message":"Unexpected flow-map-end token in YAML stream: \"}\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":10,"character":50},"end":{"line":10,"character":52}},"message":"Unexpected flow-map-end token in YAML stream: \"}\"","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":18,"character":6},"end":{"line":18,"character":52}},"message":"Block collections are not allowed within flow collections","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":18,"character":8},"end":{"line":18,"character":52}},"message":"Missing , or : between flow map items","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":39,"character":6},"end":{"line":39,"character":52}},"message":"Block collections are not allowed within flow collections","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":39,"character":8},"end":{"line":39,"character":52}},"message":"Missing , or : between flow map items","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":48,"character":0},"end":{"line":48,"character":10}},"message":"Implicit keys need to be on a single line","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":48,"character":2},"end":{"line":48,"character":10}},"message":"Block collections are not allowed within flow collections","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":48,"character":4},"end":{"line":48,"character":10}},"message":"Missing , or : between flow map items","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":48,"character":0},"end":{"line":48,"character":10}},"message":"Implicit map keys need to be followed by map values","severity":1,"code":0,"source":"YAML"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests/charts/base/templates/rbac/workloadmanager.yaml":[{"range":{"start":{"line":6,"character":6},"end":{"line":6,"character":52}},"message":"Block collections are not allowed within flow collections","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":6,"character":8},"end":{"line":6,"character":52}},"message":"Missing , or : between flow map items","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":13,"character":6},"end":{"line":13,"character":52}},"message":"Block collections are not allowed within flow collections","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":13,"character":8},"end":{"line":13,"character":52}},"message":"Missing , or : between flow map items","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":122,"character":6},"end":{"line":122,"character":52}},"message":"Block collections are not allowed within flow collections","severity":1,"code":0,"source":"YAML"},{"range":{"start":{"line":122,"character":8},"end":{"line":122,"character":52}},"message":"Missing , or : between flow map items","severity":1,"code":0,"source":"YAML"}],"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/manifests/charts/base/values.yaml":[]},"diff":"Index: /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-031/proposal.md\n===================================================================\n--- /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-031/proposal.md\n+++ /home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-031/proposal.md\n@@ -12,25 +12,67 @@\n ---\n \n ## 1. Purpose (目的)\n \n-[TO BE FILLED: Define the purpose of RBAC 配置]\n+Define Kubernetes RBAC resources (ServiceAccount, Role/ClusterRole, RoleBinding/ClusterRoleBinding) for AgentCube components to enable secure, least-privilege access to Kubernetes API resources. This proposal:\n \n+1. **Router RBAC**: Namespace-scoped Role for Secret management (JWT signing keys, identity secrets)\n+2. **WorkloadManager RBAC**: Cluster-wide ClusterRole for sandbox lifecycle management, CRD operations, and Pod/Secret access\n+3. **Helm Templating**: Parameterized RBAC creation via values.yaml flags (e.g., `router.rbac.create`)\n+4. **Security Compliance**: Follow Kubernetes RBAC best practices with minimal permission grants\n+\n+**RBAC Components**:\n+\n+| Component | Scope | Purpose |\n+|-----------|-------|---------|\n+| `router` | Namespace (Role) | Manage Secrets for session JWT signing and identity |\n+| `workloadmanager` | Cluster (ClusterRole) | Create/manage Sandboxes, CodeInterpreters, AgentRuntimes, Pods, Secrets, TokenReviews |\n+\n ---\n \n ## 2. Scope (范围)\n \n ### 2.1 In Scope\n \n | Deliverable | Description |\n |-------------|-------------|\n-| [TO BE FILLED] | [TO BE FILLED] |\n+| `manifests/charts/base/templates/rbac-router.yaml` | ServiceAccount, Role, RoleBinding for Router (namespace-scoped) |\n+| `manifests/charts/base/templates/rbac/workloadmanager.yaml` | ServiceAccount, ClusterRole, ClusterRoleBinding for WorkloadManager |\n+| `values.yaml` RBAC flags | `router.rbac.create`, `router.serviceAccountName` configuration options |\n+| RBAC validation | Ensure minimal permissions per component |\n \n-### 2.2 Out of Scope\n+### 2.2 RBAC Permission Matrix\n \n+**Router Role (Namespace-scoped)**:\n+\n+| apiGroups | Resources | Verbs |\n+|-----------|-----------|-------|\n+| `\"\"` (core) | secrets | get, list, watch, create, update, patch, delete |\n+\n+**WorkloadManager ClusterRole**:\n+\n+| apiGroups | Resources | Verbs |\n+|-----------|-----------|-------|\n+| `agents.x-k8s.io` | sandboxes | get, list, watch, create, update, patch, delete |\n+| `extensions.agents.x-k8s.io` | sandboxclaims, sandboxtemplates, sandboxwarmpools | get, list, watch, create, update, patch, delete |\n+| `extensions.agents.x-k8s.io` | sandboxwarmpools/status | get, update, patch |\n+| `runtime.agentcube.volcano.sh` | codeinterpreters | get, list, watch, create, update, patch, delete |\n+| `runtime.agentcube.volcano.sh` | codeinterpreters/status, codeinterpreters/finalizers | get, update, patch |\n+| `runtime.agentcube.volcano.sh` | agentruntimes | get, list, watch |\n+| `runtime.agentcube.volcano.sh` | agentruntimes/status | update, patch |\n+| `\"\"` (core) | pods | get, list, watch |\n+| `\"\"` (core) | secrets | get, list, watch, create, update, patch, delete |\n+| `authentication.k8s.io` | tokenreviews | create |\n+\n+### 2.3 Out of Scope\n+\n | Item | Reason |\n |------|--------|\n-| [TO BE FILLED] | [TO BE FILLED] |\n+| Volcano scheduler RBAC | Separate component with its own RBAC in volcano-agent-scheduler-development.yaml |\n+| User-facing RBAC | Users interact via Router; no direct K8s API access required |\n+| NetworkPolicy | Environment-specific; not in base chart |\n+| PodSecurityPolicy | Deprecated in K8s 1.25+; use PodSecurity Standards instead |\n+| Custom role aggregation | Single Role/ClusterRole per component sufficient |\n \n ---\n \n ## 3. Impact Analysis (影响分析)\n@@ -38,49 +80,127 @@\n ### 3.1 新增文件\n \n | File | Description |\n |------|-------------|\n-| [TO BE FILLED] | [TO BE FILLED] |\n+| N/A | RBAC templates already exist; this AR documents and validates them |\n \n ### 3.2 修改文件\n \n | File | Change |\n |------|--------|\n-| [TO BE FILLED] | [TO BE FILLED] |\n+| `manifests/charts/base/templates/rbac-router.yaml` | Add validation guard for serviceAccountName requirement |\n+| `manifests/charts/base/values.yaml` | Document `router.rbac.create` and `router.serviceAccountName` defaults |\n \n ### 3.3 Upstream Dependencies\n \n | Dependency | Purpose |\n |------------|---------|\n-| [TO BE FILLED] | [TO BE FILLED] |\n+| `Kubernetes 1.24+` | RBAC API stability (rbac.authorization.k8s.io/v1) |\n+| `sigs.k8s.io/agent-sandbox CRDs` | Sandboxes, SandboxClaims, SandboxTemplates, SandboxWarmPools resources |\n+| `runtime.agentcube.volcano.sh CRDs` | CodeInterpreters, AgentRuntimes custom resources |\n \n ### 3.4 Downstream Consumers\n \n | Consumer | Usage |\n |----------|-------|\n-| [TO BE FILLED] | [TO BE FILLED] |\n+| `Router Deployment` | Uses ServiceAccount for Pod identity; mounts secrets |\n+| `WorkloadManager Deployment` | Uses ServiceAccount for sandbox/CRD operations |\n+| `E2E Tests (run_e2e.sh)` | Helm install with RBAC enabled validates permission grants |\n+| `Production deployments` | RBAC required for cluster access; audit logging for permission usage |\n \n ---\n \n ## 4. Alternatives Considered (备选方案)\n \n-[TO BE FILLED: Document alternatives and decisions]\n+### Alternative 1: ClusterRole for Router (cluster-wide permissions)\n \n+**Approach**: Grant Router cluster-wide ClusterRole for Secret access across namespaces.\n+\n+| Aspect | Evaluation |\n+|--------|------------|\n+| Pros | Single binding; access secrets in any namespace |\n+| Cons | Over-permissive; Router only needs secrets in its own namespace |\n+\n+**Decision**: Rejected. Router operates within single namespace (JWT secrets, identity secrets). Namespace-scoped Role provides better security isolation.\n+\n+### Alternative 2: Pre-defined ServiceAccount (no RBAC creation)\n+\n+**Approach**: Require pre-existing ServiceAccount and RBAC; Helm chart only references them.\n+\n+| Aspect | Evaluation |\n+|--------|------------|\n+| Pros | Separates RBAC management from deployment; supports external IAM |\n+| Cons | Additional manual setup; deployment fails if SA missing; no self-contained install |\n+\n+**Decision**: Rejected as default. `router.rbac.create=false` option allows this pattern for environments with external RBAC management, but default is self-contained RBAC creation.\n+\n+### Alternative 3: RoleBinding for WorkloadManager (namespace-scoped)\n+\n+**Approach**: Use namespace-scoped Role instead of ClusterRole for WorkloadManager.\n+\n+| Aspect | Evaluation |\n+|--------|------------|\n+| Pros | Narrower permission scope; namespace isolation |\n+| Cons | WorkloadManager must access agent-sandbox CRDs (cluster-scoped) and manage sandboxes across namespaces |\n+\n+**Decision**: Rejected. Agent-sandbox CRDs (Sandboxes, SandboxClaims) are cluster-scoped resources. ClusterRole is required for cross-namespace operations.\n+\n+### Alternative 4: Aggregated ClusterRoles\n+\n+**Approach**: Use ClusterRole aggregation to compose permissions from multiple smaller ClusterRoles.\n+\n+| Aspect | Evaluation |\n+|--------|------------|\n+| Pros | Reusable permission sets; granular control; easier audits |\n+| Cons | Additional complexity; multiple ClusterRole objects; overkill for single-component permissions |\n+\n+**Decision**: Rejected. Single ClusterRole per component is simpler and sufficient. Aggregation useful for multi-component shared permissions; not needed for current scope.\n+\n+### Alternative 5: Static RBAC YAML (no Helm templating)\n+\n+**Approach**: Provide static RBAC YAML files without Helm conditionals.\n+\n+| Aspect | Evaluation |\n+|--------|------------|\n+| Pros | Simpler; no template logic; deterministic output |\n+| Cons | Cannot disable RBAC per deployment; cannot customize ServiceAccount names; all-or-nothing install |\n+\n+**Decision**: Rejected. Helm templating with `rbac.create` flag enables flexible deployment (external RBAC management, custom SA names).\n+\n ---\n \n ## 5. Risks\n \n | Risk | Mitigation |\n |------|------------|\n-| [TO BE FILLED] | [TO BE FILLED] |\n+| ClusterRole over-permissive | Audit permissions annually; only grant verbs needed for operation; no wildcard resources |\n+| ServiceAccount name collision | `router.serviceAccountName` configurable via values; default namespaced naming |\n+| Missing RBAC during install | Helm template guard: `{{- fail \"router.serviceAccountName must be set\" }}` when RBAC enabled but SA missing |\n+| TokenReview permission leak | Only granted to WorkloadManager; Router has no TokenReview access |\n+| CRD version mismatch | RBAC verbs stable across CRD versions; no version-specific permissions |\n+| Namespace isolation breach | Router Role limited to single namespace; cannot access secrets in other namespaces |\n \n ---\n \n ## 6. Implementation Checklist\n \n-- [ ] [TO BE FILLED]\n+- [ ] Validate `rbac-router.yaml` template renders correctly with `helm template`\n+- [ ] Validate `rbac/workloadmanager.yaml` template renders correctly\n+- [ ] Verify Router Role only grants Secret permissions (no Pod/CRD access)\n+- [ ] Verify WorkloadManager ClusterRole grants minimal required verbs\n+- [ ] Test RBAC conditional: `router.rbac.create=false` skips RBAC creation\n+- [ ] Test guard: `router.rbac.create=true` without `serviceAccountName` fails template\n+- [ ] Validate ServiceAccount appears in Deployment spec when RBAC enabled\n+- [ ] E2E test: WorkloadManager can create/manage sandboxes\n+- [ ] E2E test: Router can read/write secrets in its namespace\n+- [ ] Security audit: No wildcard (*) in resources or verbs\n \n ---\n \n ## 7. References\n \n-- [TO BE FILLED: Add relevant references]\n\\ No newline at end of file\n+- Kubernetes RBAC Documentation: https://kubernetes.io/docs/reference/access-authn-authz/rbac/\n+- Kubernetes API Reference: rbac.authorization.k8s.io/v1\n+- manifests/charts/base/templates/rbac-router.yaml — Router RBAC template\n+- manifests/charts/base/templates/rbac/workloadmanager.yaml — WorkloadManager RBAC template\n+- manifests/charts/base/values.yaml — RBAC configuration values\n+- changes/AR-030/proposal.md — Helm Chart context (RBAC as chart component)\n\\ No newline at end of file\n","filediff":{"file":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-031/proposal.md","before":"# AR-031 — RBAC 配置 (SA/Role/Binding)\n\n## 概述\n\n| 属性 | 值 |\n|------|-----|\n| AR | AR-031 |\n| Module | manifests |\n| Language | YAML |\n| Size | M |\n\n---\n\n## 1. Purpose (目的)\n\n[TO BE FILLED: Define the purpose of RBAC 配置]\n\n---\n\n## 2. Scope (范围)\n\n### 2.1 In Scope\n\n| Deliverable | Description |\n|-------------|-------------|\n| [TO BE FILLED] | [TO BE FILLED] |\n\n### 2.2 Out of Scope\n\n| Item | Reason |\n|------|--------|\n| [TO BE FILLED] | [TO BE FILLED] |\n\n---\n\n## 3. Impact Analysis (影响分析)\n\n### 3.1 新增文件\n\n| File | Description |\n|------|-------------|\n| [TO BE FILLED] | [TO BE FILLED] |\n\n### 3.2 修改文件\n\n| File | Change |\n|------|--------|\n| [TO BE FILLED] | [TO BE FILLED] |\n\n### 3.3 Upstream Dependencies\n\n| Dependency | Purpose |\n|------------|---------|\n| [TO BE FILLED] | [TO BE FILLED] |\n\n### 3.4 Downstream Consumers\n\n| Consumer | Usage |\n|----------|-------|\n| [TO BE FILLED] | [TO BE FILLED] |\n\n---\n\n## 4. Alternatives Considered (备选方案)\n\n[TO BE FILLED: Document alternatives and decisions]\n\n---\n\n## 5. Risks\n\n| Risk | Mitigation |\n|------|------------|\n| [TO BE FILLED] | [TO BE FILLED] |\n\n---\n\n## 6. Implementation Checklist\n\n- [ ] [TO BE FILLED]\n\n---\n\n## 7. References\n\n- [TO BE FILLED: Add relevant references]","after":"# AR-031 — RBAC 配置 (SA/Role/Binding)\n\n## 概述\n\n| 属性 | 值 |\n|------|-----|\n| AR | AR-031 |\n| Module | manifests |\n| Language | YAML |\n| Size | M |\n\n---\n\n## 1. Purpose (目的)\n\nDefine Kubernetes RBAC resources (ServiceAccount, Role/ClusterRole, RoleBinding/ClusterRoleBinding) for AgentCube components to enable secure, least-privilege access to Kubernetes API resources. This proposal:\n\n1. **Router RBAC**: Namespace-scoped Role for Secret management (JWT signing keys, identity secrets)\n2. **WorkloadManager RBAC**: Cluster-wide ClusterRole for sandbox lifecycle management, CRD operations, and Pod/Secret access\n3. **Helm Templating**: Parameterized RBAC creation via values.yaml flags (e.g., `router.rbac.create`)\n4. **Security Compliance**: Follow Kubernetes RBAC best practices with minimal permission grants\n\n**RBAC Components**:\n\n| Component | Scope | Purpose |\n|-----------|-------|---------|\n| `router` | Namespace (Role) | Manage Secrets for session JWT signing and identity |\n| `workloadmanager` | Cluster (ClusterRole) | Create/manage Sandboxes, CodeInterpreters, AgentRuntimes, Pods, Secrets, TokenReviews |\n\n---\n\n## 2. Scope (范围)\n\n### 2.1 In Scope\n\n| Deliverable | Description |\n|-------------|-------------|\n| `manifests/charts/base/templates/rbac-router.yaml` | ServiceAccount, Role, RoleBinding for Router (namespace-scoped) |\n| `manifests/charts/base/templates/rbac/workloadmanager.yaml` | ServiceAccount, ClusterRole, ClusterRoleBinding for WorkloadManager |\n| `values.yaml` RBAC flags | `router.rbac.create`, `router.serviceAccountName` configuration options |\n| RBAC validation | Ensure minimal permissions per component |\n\n### 2.2 RBAC Permission Matrix\n\n**Router Role (Namespace-scoped)**:\n\n| apiGroups | Resources | Verbs |\n|-----------|-----------|-------|\n| `\"\"` (core) | secrets | get, list, watch, create, update, patch, delete |\n\n**WorkloadManager ClusterRole**:\n\n| apiGroups | Resources | Verbs |\n|-----------|-----------|-------|\n| `agents.x-k8s.io` | sandboxes | get, list, watch, create, update, patch, delete |\n| `extensions.agents.x-k8s.io` | sandboxclaims, sandboxtemplates, sandboxwarmpools | get, list, watch, create, update, patch, delete |\n| `extensions.agents.x-k8s.io` | sandboxwarmpools/status | get, update, patch |\n| `runtime.agentcube.volcano.sh` | codeinterpreters | get, list, watch, create, update, patch, delete |\n| `runtime.agentcube.volcano.sh` | codeinterpreters/status, codeinterpreters/finalizers | get, update, patch |\n| `runtime.agentcube.volcano.sh` | agentruntimes | get, list, watch |\n| `runtime.agentcube.volcano.sh` | agentruntimes/status | update, patch |\n| `\"\"` (core) | pods | get, list, watch |\n| `\"\"` (core) | secrets | get, list, watch, create, update, patch, delete |\n| `authentication.k8s.io` | tokenreviews | create |\n\n### 2.3 Out of Scope\n\n| Item | Reason |\n|------|--------|\n| Volcano scheduler RBAC | Separate component with its own RBAC in volcano-agent-scheduler-development.yaml |\n| User-facing RBAC | Users interact via Router; no direct K8s API access required |\n| NetworkPolicy | Environment-specific; not in base chart |\n| PodSecurityPolicy | Deprecated in K8s 1.25+; use PodSecurity Standards instead |\n| Custom role aggregation | Single Role/ClusterRole per component sufficient |\n\n---\n\n## 3. Impact Analysis (影响分析)\n\n### 3.1 新增文件\n\n| File | Description |\n|------|-------------|\n| N/A | RBAC templates already exist; this AR documents and validates them |\n\n### 3.2 修改文件\n\n| File | Change |\n|------|--------|\n| `manifests/charts/base/templates/rbac-router.yaml` | Add validation guard for serviceAccountName requirement |\n| `manifests/charts/base/values.yaml` | Document `router.rbac.create` and `router.serviceAccountName` defaults |\n\n### 3.3 Upstream Dependencies\n\n| Dependency | Purpose |\n|------------|---------|\n| `Kubernetes 1.24+` | RBAC API stability (rbac.authorization.k8s.io/v1) |\n| `sigs.k8s.io/agent-sandbox CRDs` | Sandboxes, SandboxClaims, SandboxTemplates, SandboxWarmPools resources |\n| `runtime.agentcube.volcano.sh CRDs` | CodeInterpreters, AgentRuntimes custom resources |\n\n### 3.4 Downstream Consumers\n\n| Consumer | Usage |\n|----------|-------|\n| `Router Deployment` | Uses ServiceAccount for Pod identity; mounts secrets |\n| `WorkloadManager Deployment` | Uses ServiceAccount for sandbox/CRD operations |\n| `E2E Tests (run_e2e.sh)` | Helm install with RBAC enabled validates permission grants |\n| `Production deployments` | RBAC required for cluster access; audit logging for permission usage |\n\n---\n\n## 4. Alternatives Considered (备选方案)\n\n### Alternative 1: ClusterRole for Router (cluster-wide permissions)\n\n**Approach**: Grant Router cluster-wide ClusterRole for Secret access across namespaces.\n\n| Aspect | Evaluation |\n|--------|------------|\n| Pros | Single binding; access secrets in any namespace |\n| Cons | Over-permissive; Router only needs secrets in its own namespace |\n\n**Decision**: Rejected. Router operates within single namespace (JWT secrets, identity secrets). Namespace-scoped Role provides better security isolation.\n\n### Alternative 2: Pre-defined ServiceAccount (no RBAC creation)\n\n**Approach**: Require pre-existing ServiceAccount and RBAC; Helm chart only references them.\n\n| Aspect | Evaluation |\n|--------|------------|\n| Pros | Separates RBAC management from deployment; supports external IAM |\n| Cons | Additional manual setup; deployment fails if SA missing; no self-contained install |\n\n**Decision**: Rejected as default. `router.rbac.create=false` option allows this pattern for environments with external RBAC management, but default is self-contained RBAC creation.\n\n### Alternative 3: RoleBinding for WorkloadManager (namespace-scoped)\n\n**Approach**: Use namespace-scoped Role instead of ClusterRole for WorkloadManager.\n\n| Aspect | Evaluation |\n|--------|------------|\n| Pros | Narrower permission scope; namespace isolation |\n| Cons | WorkloadManager must access agent-sandbox CRDs (cluster-scoped) and manage sandboxes across namespaces |\n\n**Decision**: Rejected. Agent-sandbox CRDs (Sandboxes, SandboxClaims) are cluster-scoped resources. ClusterRole is required for cross-namespace operations.\n\n### Alternative 4: Aggregated ClusterRoles\n\n**Approach**: Use ClusterRole aggregation to compose permissions from multiple smaller ClusterRoles.\n\n| Aspect | Evaluation |\n|--------|------------|\n| Pros | Reusable permission sets; granular control; easier audits |\n| Cons | Additional complexity; multiple ClusterRole objects; overkill for single-component permissions |\n\n**Decision**: Rejected. Single ClusterRole per component is simpler and sufficient. Aggregation useful for multi-component shared permissions; not needed for current scope.\n\n### Alternative 5: Static RBAC YAML (no Helm templating)\n\n**Approach**: Provide static RBAC YAML files without Helm conditionals.\n\n| Aspect | Evaluation |\n|--------|------------|\n| Pros | Simpler; no template logic; deterministic output |\n| Cons | Cannot disable RBAC per deployment; cannot customize ServiceAccount names; all-or-nothing install |\n\n**Decision**: Rejected. Helm templating with `rbac.create` flag enables flexible deployment (external RBAC management, custom SA names).\n\n---\n\n## 5. Risks\n\n| Risk | Mitigation |\n|------|------------|\n| ClusterRole over-permissive | Audit permissions annually; only grant verbs needed for operation; no wildcard resources |\n| ServiceAccount name collision | `router.serviceAccountName` configurable via values; default namespaced naming |\n| Missing RBAC during install | Helm template guard: `{{- fail \"router.serviceAccountName must be set\" }}` when RBAC enabled but SA missing |\n| TokenReview permission leak | Only granted to WorkloadManager; Router has no TokenReview access |\n| CRD version mismatch | RBAC verbs stable across CRD versions; no version-specific permissions |\n| Namespace isolation breach | Router Role limited to single namespace; cannot access secrets in other namespaces |\n\n---\n\n## 6. Implementation Checklist\n\n- [ ] Validate `rbac-router.yaml` template renders correctly with `helm template`\n- [ ] Validate `rbac/workloadmanager.yaml` template renders correctly\n- [ ] Verify Router Role only grants Secret permissions (no Pod/CRD access)\n- [ ] Verify WorkloadManager ClusterRole grants minimal required verbs\n- [ ] Test RBAC conditional: `router.rbac.create=false` skips RBAC creation\n- [ ] Test guard: `router.rbac.create=true` without `serviceAccountName` fails template\n- [ ] Validate ServiceAccount appears in Deployment spec when RBAC enabled\n- [ ] E2E test: WorkloadManager can create/manage sandboxes\n- [ ] E2E test: Router can read/write secrets in its namespace\n- [ ] Security audit: No wildcard (*) in resources or verbs\n\n---\n\n## 7. References\n\n- Kubernetes RBAC Documentation: https://kubernetes.io/docs/reference/access-authn-authz/rbac/\n- Kubernetes API Reference: rbac.authorization.k8s.io/v1\n- manifests/charts/base/templates/rbac-router.yaml — Router RBAC template\n- manifests/charts/base/templates/rbac/workloadmanager.yaml — WorkloadManager RBAC template\n- manifests/charts/base/values.yaml — RBAC configuration values\n- changes/AR-030/proposal.md — Helm Chart context (RBAC as chart component)","additions":132,"deletions":12},"truncated":false},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-031/proposal.md","time":{"start":1775884773136,"end":1775884773185}}}}
{"type":"step_finish","timestamp":1775884773214,"sessionID":"ses_285064a34ffeQXA6kTt14U3nZx","part":{"id":"prt_d7afb2746001TmcCD4XUzJwweV","reason":"tool-calls","snapshot":"f33c5114db06c230ebdbad281b75532a26b6f114","messageID":"msg_d7afa39fd001CbkkE35VtMK1tf","sessionID":"ses_285064a34ffeQXA6kTt14U3nZx","type":"step-finish","tokens":{"total":36267,"input":18250,"output":2914,"reasoning":0,"cache":{"write":0,"read":15103}},"cost":0}}
