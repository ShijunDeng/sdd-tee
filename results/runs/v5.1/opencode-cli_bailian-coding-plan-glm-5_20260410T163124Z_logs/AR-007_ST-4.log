{"type":"tool_use","timestamp":1775846757430,"sessionID":"ses_28749eaf6ffebPa8vhmVB5f8vi","part":{"id":"prt_d78b70ce0001voswXFZ12L7Nin","messageID":"msg_d78b6f5b9001j9xKwt0Vozvq54","sessionID":"ses_28749eaf6ffebPa8vhmVB5f8vi","type":"tool","tool":"read","callID":"toolu_tool-3a18e66035c146059bb0eeaba6be7dca","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle_test.go</path>\n<type>file</type>\n<content>\n1: package workloadmanager\n2: \n3: import (\n4: \t\"context\"\n5: \t\"errors\"\n6: \t\"testing\"\n7: \t\"time\"\n8: \n9: \t\"github.com/stretchr/testify/assert\"\n10: \t\"github.com/stretchr/testify/require\"\n11: \tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n12: \t\"k8s.io/apimachinery/pkg/runtime\"\n13: \t\"k8s.io/apimachinery/pkg/runtime/schema\"\n14: \tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n15: \t\"k8s.io/client-go/kubernetes/fake\"\n16: \n17: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n18: )\n19: \n20: type mockLogger struct {\n21: \tinfoCalls  []string\n22: \terrorCalls []string\n23: }\n24: \n25: func (l *mockLogger) Info(msg string, args ...any) {\n26: \tl.infoCalls = append(l.infoCalls, msg)\n27: }\n28: \n29: func (l *mockLogger) Error(msg string, args ...any) {\n30: \tl.errorCalls = append(l.errorCalls, msg)\n31: }\n32: \n33: func TestDefaultLifecycleConfig(t *testing.T) {\n34: \tconfig := DefaultLifecycleConfig()\n35: \n36: \tassert.Equal(t, DefaultSandboxTTL, config.DefaultTTL)\n37: \tassert.Equal(t, DefaultSandboxIdleTimeout, config.DefaultIdleTimeout)\n38: \tassert.Equal(t, DefaultMaxSessionDuration, config.DefaultMaxDuration)\n39: \tassert.Equal(t, GarbageCollectorInterval, config.GCInterval)\n40: \tassert.Equal(t, 2*time.Minute, config.GCOnceTimeout)\n41: \tassert.Equal(t, int64(0), config.DeletionGracePeriod)\n42: \tassert.Equal(t, SandboxDeleteTimeout, config.DeletionTimeout)\n43: }\n44: \n45: func TestNewSandboxLifecycleManager(t *testing.T) {\n46: \tfakeClient := fake.NewSimpleClientset()\n47: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(runtime.NewScheme())\n48: \tinformerFactory := NewTestInformerFactory(fakeClient)\n49: \n50: \tk8sClient := &K8sClient{\n51: \t\tdynamicClient:   dynamicClient,\n52: \t\tcoreClient:      fakeClient,\n53: \t\tinformerFactory: informerFactory,\n54: \t}\n55: \n56: \tstore := NewMemoryStore()\n57: \tlogger := &mockLogger{}\n58: \tconfig := DefaultLifecycleConfig()\n59: \n60: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n61: \n62: \tassert.NotNil(t, manager)\n63: \tassert.Equal(t, k8sClient, manager.k8sClient)\n64: \tassert.Equal(t, store, manager.store)\n65: \tassert.Equal(t, config, manager.config)\n66: }\n67: \n68: func TestSandboxLifecycleManager_DeleteSandbox_Success(t *testing.T) {\n69: \tscheme := runtime.NewScheme()\n70: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n71: \tfakeClient := fake.NewSimpleClientset()\n72: \tinformerFactory := NewTestInformerFactory(fakeClient)\n73: \n74: \tk8sClient := &K8sClient{\n75: \t\tdynamicClient:   dynamicClient,\n76: \t\tcoreClient:      fakeClient,\n77: \t\tinformerFactory: informerFactory,\n78: \t}\n79: \n80: \tstore := NewMemoryStore()\n81: \tlogger := &mockLogger{}\n82: \tconfig := DefaultLifecycleConfig()\n83: \n84: \tnow := time.Now()\n85: \tsandbox := &types.SandboxInfo{\n86: \t\tKind:             types.SandboxKind,\n87: \t\tSandboxID:        \"sandbox-123\",\n88: \t\tSandboxNamespace: \"default\",\n89: \t\tSandboxName:      \"sandbox-123\",\n90: \t\tSessionID:        \"session-123\",\n91: \t\tCreatedAt:        now,\n92: \t\tExpiresAt:        now.Add(8 * time.Hour),\n93: \t\tStatus:           \"running\",\n94: \t}\n95: \n96: \terr := store.StoreSandbox(context.Background(), sandbox)\n97: \trequire.NoError(t, err)\n98: \n99: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n100: \n101: \terr = manager.DeleteSandbox(context.Background(), \"session-123\")\n102: \tassert.NoError(t, err)\n103: \n104: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-123\")\n105: \tassert.Error(t, err)\n106: \tassert.IsType(t, &NotFoundError{}, err)\n107: }\n108: \n109: func TestSandboxLifecycleManager_DeleteSandbox_NotFound(t *testing.T) {\n110: \tscheme := runtime.NewScheme()\n111: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n112: \tfakeClient := fake.NewSimpleClientset()\n113: \tinformerFactory := NewTestInformerFactory(fakeClient)\n114: \n115: \tk8sClient := &K8sClient{\n116: \t\tdynamicClient:   dynamicClient,\n117: \t\tcoreClient:      fakeClient,\n118: \t\tinformerFactory: informerFactory,\n119: \t}\n120: \n121: \tstore := NewMemoryStore()\n122: \tlogger := &mockLogger{}\n123: \tconfig := DefaultLifecycleConfig()\n124: \n125: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n126: \n127: \terr := manager.DeleteSandbox(context.Background(), \"non-existent\")\n128: \tassert.Error(t, err)\n129: \tassert.IsType(t, &NotFoundError{}, err)\n130: }\n131: \n132: func TestSandboxLifecycleManager_DeleteSandbox_SandboxClaim(t *testing.T) {\n133: \tscheme := runtime.NewScheme()\n134: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n135: \tfakeClient := fake.NewSimpleClientset()\n136: \tinformerFactory := NewTestInformerFactory(fakeClient)\n137: \n138: \tk8sClient := &K8sClient{\n139: \t\tdynamicClient:   dynamicClient,\n140: \t\tcoreClient:      fakeClient,\n141: \t\tinformerFactory: informerFactory,\n142: \t}\n143: \n144: \tstore := NewMemoryStore()\n145: \tlogger := &mockLogger{}\n146: \tconfig := DefaultLifecycleConfig()\n147: \n148: \tnow := time.Now()\n149: \tsandbox := &types.SandboxInfo{\n150: \t\tKind:             types.SandboxClaimKind,\n151: \t\tSandboxID:        \"sandbox-123\",\n152: \t\tSandboxNamespace: \"default\",\n153: \t\tSandboxName:      \"sandbox-123\",\n154: \t\tSessionID:        \"session-123\",\n155: \t\tCreatedAt:        now,\n156: \t\tExpiresAt:        now.Add(8 * time.Hour),\n157: \t\tStatus:           \"running\",\n158: \t}\n159: \n160: \terr := store.StoreSandbox(context.Background(), sandbox)\n161: \trequire.NoError(t, err)\n162: \n163: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n164: \n165: \terr = manager.DeleteSandbox(context.Background(), \"session-123\")\n166: \tassert.NoError(t, err)\n167: }\n168: \n169: func TestSandboxLifecycleManager_IsExpired(t *testing.T) {\n170: \tmanager := &SandboxLifecycleManager{}\n171: \n172: \tnow := time.Now()\n173: \n174: \texpiredSandbox := &types.SandboxInfo{\n175: \t\tExpiresAt: now.Add(-1 * time.Hour),\n176: \t}\n177: \tassert.True(t, manager.IsExpired(expiredSandbox))\n178: \n179: \tactiveSandbox := &types.SandboxInfo{\n180: \t\tExpiresAt: now.Add(8 * time.Hour),\n181: \t}\n182: \tassert.False(t, manager.IsExpired(activeSandbox))\n183: }\n184: \n185: func TestSandboxLifecycleManager_IsIdleExpired(t *testing.T) {\n186: \tmanager := &SandboxLifecycleManager{}\n187: \tidleTimeout := 15 * time.Minute\n188: \n189: \tnow := time.Now()\n190: \n191: \tnoActivitySandbox := &types.SandboxInfo{}\n192: \tassert.False(t, manager.IsIdleExpired(noActivitySandbox, idleTimeout))\n193: \n194: \trecentActivitySandbox := &types.SandboxInfo{\n195: \t\tLastActivity: now,\n196: \t}\n197: \tassert.False(t, manager.IsIdleExpired(recentActivitySandbox, idleTimeout))\n198: \n199: \toldActivitySandbox := &types.SandboxInfo{\n200: \t\tLastActivity: now.Add(-30 * time.Minute),\n201: \t}\n202: \tassert.True(t, manager.IsIdleExpired(oldActivitySandbox, idleTimeout))\n203: }\n204: \n205: func TestSandboxLifecycleManager_ForceDeleteSandbox(t *testing.T) {\n206: \tscheme := runtime.NewScheme()\n207: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n208: \tfakeClient := fake.NewSimpleClientset()\n209: \tinformerFactory := NewTestInformerFactory(fakeClient)\n210: \n211: \tk8sClient := &K8sClient{\n212: \t\tdynamicClient:   dynamicClient,\n213: \t\tcoreClient:      fakeClient,\n214: \t\tinformerFactory: informerFactory,\n215: \t}\n216: \n217: \tstore := NewMemoryStore()\n218: \tlogger := &mockLogger{}\n219: \tconfig := DefaultLifecycleConfig()\n220: \n221: \tnow := time.Now()\n222: \tsandbox := &types.SandboxInfo{\n223: \t\tKind:             types.SandboxKind,\n224: \t\tSandboxID:        \"sandbox-123\",\n225: \t\tSandboxNamespace: \"default\",\n226: \t\tSandboxName:      \"sandbox-123\",\n227: \t\tSessionID:        \"session-123\",\n228: \t\tCreatedAt:        now,\n229: \t\tExpiresAt:        now.Add(8 * time.Hour),\n230: \t\tStatus:           \"running\",\n231: \t}\n232: \n233: \terr := store.StoreSandbox(context.Background(), sandbox)\n234: \trequire.NoError(t, err)\n235: \n236: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n237: \n238: \terr = manager.ForceDeleteSandbox(context.Background(), \"session-123\")\n239: \tassert.NoError(t, err)\n240: \n241: \t_, err = store.GetSandboxBySessionID(context.Background(), \"session-123\")\n242: \tassert.Error(t, err)\n243: }\n244: \n245: func TestSandboxLifecycleManager_ForceDeleteSandbox_NotFound(t *testing.T) {\n246: \tscheme := runtime.NewScheme()\n247: \tdynamicClient := dynamicfake.NewSimpleDynamicClient(scheme)\n248: \tfakeClient := fake.NewSimpleClientset()\n249: \tinformerFactory := NewTestInformerFactory(fakeClient)\n250: \n251: \tk8sClient := &K8sClient{\n252: \t\tdynamicClient:   dynamicClient,\n253: \t\tcoreClient:      fakeClient,\n254: \t\tinformerFactory: informerFactory,\n255: \t}\n256: \n257: \tstore := NewMemoryStore()\n258: \tlogger := &mockLogger{}\n259: \tconfig := DefaultLifecycleConfig()\n260: \n261: \tmanager := NewSandboxLifecycleManager(k8sClient, store, config, logger)\n262: \n263: \terr := manager.ForceDeleteSandbox(context.Background(), \"non-existent\")\n264: \tassert.NoError(t, err)\n265: }\n266: \n267: func TestSandboxLifecycleManager_GetSandbox(t *testing.T) {\n268: \tstore := NewMemoryStore()\n269: \tmanager := &SandboxLifecycleManager{store: store}\n270: \n271: \tnow := time.Now()\n272: \tsandbox := &types.SandboxInfo{\n273: \t\tSessionID: \"session-123\",\n274: \t\tExpiresAt: now.Add(8 * time.Hour),\n275: \t}\n276: \n277: \terr := store.StoreSandbox(context.Background(), sandbox)\n278: \trequire.NoError(t, err)\n279: \n280: \tretrieved, err := manager.GetSandbox(context.Background(), \"session-123\")\n281: \trequire.NoError(t, err)\n282: \tassert.Equal(t, \"session-123\", retrieved.SessionID)\n283: \n284: \t_, err = manager.GetSandbox(context.Background(), \"non-existent\")\n285: \tassert.Error(t, err)\n286: }\n287: \n288: func TestSandboxLifecycleManager_UpdateSandboxStatus(t *testing.T) {\n289: \tstore := NewMemoryStore()\n290: \tmanager := &SandboxLifecycleManager{store: store}\n291: \n292: \tnow := time.Now()\n293: \tsandbox := &types.SandboxInfo{\n294: \t\tSessionID: \"session-123\",\n295: \t\tExpiresAt: now.Add(8 * time.Hour),\n296: \t\tStatus:    \"running\",\n297: \t}\n298: \n299: \terr := store.StoreSandbox(context.Background(), sandbox)\n300: \trequire.NoError(t, err)\n301: \n302: \terr = manager.UpdateSandboxStatus(context.Background(), \"session-123\", \"terminating\")\n303: \trequire.NoError(t, err)\n304: \n305: \tretrieved, err := store.GetSandboxBySessionID(context.Background(), \"session-123\")\n306: \trequire.NoError(t, err)\n307: \tassert.Equal(t, \"terminating\", retrieved.Status)\n308: }\n309: \n310: func TestHandleDeleteError(t *testing.T) {\n311: \tnotFoundErr := apierrors.NewNotFound(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, \"test\")\n312: \tresult := handleDeleteError(notFoundErr)\n313: \tassert.Nil(t, result)\n314: \n315: \tconflictErr := apierrors.NewConflict(schema.GroupResource{Group: \"agents.x-k8s.io\", Resource: \"sandboxes\"}, \"test\", errors.New(\"conflict\"))\n316: \tresult = handleDeleteError(conflictErr)\n317: \tassert.IsType(t, &ConflictError{}, result)\n318: \n319: \tinternalErr := errors.New(\"internal error\")\n320: \tresult = handleDeleteError(internalErr)\n321: \tassert.IsType(t, &InternalError{}, result)\n322: }\n323: \n324: func TestDetermineDeletionReason(t *testing.T) {\n325: \tnow := time.Now()\n326: \tidleTimeout := 15 * time.Minute\n327: \n328: \texpiredSandbox := &types.SandboxInfo{\n329: \t\tExpiresAt: now.Add(-1 * time.Hour),\n330: \t}\n331: \treason := determineDeletionReason(expiredSandbox, now, idleTimeout)\n332: \tassert.Equal(t, DeletionReasonMaxDurationReached, reason)\n333: \n334: \tidleSandbox := &types.SandboxInfo{\n335: \t\tExpiresAt:    now.Add(8 * time.Hour),\n336: \t\tLastActivity: now.Add(-30 * time.Minute),\n337: \t}\n338: \treason = determineDeletionReason(idleSandbox, now, idleTimeout)\n339: \tassert.Equal(t, DeletionReasonIdleTimeout, reason)\n340: \n341: \tactiveSandbox := &types.SandboxInfo{\n342: \t\tExpiresAt:    now.Add(8 * time.Hour),\n343: \t\tLastActivity: now,\n344: \t}\n345: \treason = determineDeletionReason(activeSandbox, now, idleTimeout)\n346: \tassert.Equal(t, DeletionReasonUserRequest, reason)\n347: }\n\n(End of file - total 347 lines)\n</content>","metadata":{"preview":"package workloadmanager\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\tdynamicfake \"k8s.io/client-go/dynamic/fake\"\n\t\"k8s.io/client-go/kubernetes/fake\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype mockLogger struct {","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/workloadmanager/lifecycle_test.go","time":{"star