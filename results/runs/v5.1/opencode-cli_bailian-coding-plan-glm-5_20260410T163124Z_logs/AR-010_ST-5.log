{"type":"tool_use","timestamp":1775851612019,"sessionID":"ses_286ff5c1dffeIBEVY3O4NaEOZB","part":{"id":"prt_d79012357001JthjniZYLEIdWM","messageID":"msg_d79010257001wb9QFd8zY0Y9qv","sessionID":"ses_286ff5c1dffeIBEVY3O4NaEOZB","type":"tool","tool":"read","callID":"toolu_tool-36e6e69b9e764974938fce704aa070e3","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"context\"\n6: \t\"encoding/json\"\n7: \t\"fmt\"\n8: \t\"io\"\n9: \t\"net/http\"\n10: \t\"os\"\n11: \t\"strings\"\n12: \t\"time\"\n13: \n14: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n15: \t\"golang.org/x/net/http2\"\n16: )\n17: \n18: type sessionManager struct {\n19: \tstoreClient     Store\n20: \tworkloadMgrAddr string\n21: \thttpClient      *http.Client\n22: }\n23: \n24: func NewSessionManager(storeClient Store) (SessionManager, error) {\n25: \tworkloadMgrAddr := os.Getenv(\"WORKLOAD_MANAGER_URL\")\n26: \tif workloadMgrAddr == \"\" {\n27: \t\treturn nil, fmt.Errorf(\"WORKLOAD_MANAGER_URL environment variable is required\")\n28: \t}\n29: \n30: \ttransport := &http.Transport{\n31: \t\tMaxIdleConnsPerHost: 100,\n32: \t\tDisableCompression:  false,\n33: \t}\n34: \n35: \thttp2.ConfigureTransport(transport)\n36: \n37: \thttpClient := &http.Client{\n38: \t\tTimeout:   2 * time.Minute,\n39: \t\tTransport: transport,\n40: \t}\n41: \n42: \treturn &sessionManager{\n43: \t\tstoreClient:     storeClient,\n44: \t\tworkloadMgrAddr: workloadMgrAddr,\n45: \t\thttpClient:      httpClient,\n46: \t}, nil\n47: }\n48: \n49: func (m *sessionManager) GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n50: \tif sessionID == \"\" {\n51: \t\treturn m.createSandbox(ctx, namespace, name, kind)\n52: \t}\n53: \n54: \tsandbox, err := m.storeClient.GetSandboxBySessionID(ctx, sessionID)\n55: \tif err != nil {\n56: \t\treturn nil, &SessionNotFoundError{SessionID: sessionID}\n57: \t}\n58: \n59: \treturn sandbox, nil\n60: }\n61: \n62: func (m *sessionManager) createSandbox(ctx context.Context, namespace string, name string, kind string) (*types.SandboxInfo, error) {\n63: \treqBody := types.CreateSandboxRequest{\n64: \t\tKind:      kind,\n65: \t\tName:      name,\n66: \t\tNamespace: namespace,\n67: \t}\n68: \n69: \tif err := reqBody.Validate(); err != nil {\n70: \t\treturn nil, err\n71: \t}\n72: \n73: \tvar endpoint string\n74: \tswitch kind {\n75: \tcase types.AgentRuntimeKind:\n76: \t\tendpoint = m.workloadMgrAddr + \"/v1/agent-runtime\"\n77: \tcase types.CodeInterpreterKind:\n78: \t\tendpoint = m.workloadMgrAddr + \"/v1/code-interpreter\"\n79: \tdefault:\n80: \t\treturn nil, fmt.Errorf(\"unsupported kind: %s\", kind)\n81: \t}\n82: \n83: \tbodyBytes, err := json.Marshal(reqBody)\n84: \tif err != nil {\n85: \t\treturn nil, fmt.Errorf(\"failed to marshal request: %w\", err)\n86: \t}\n87: \n88: \treq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(bodyBytes))\n89: \tif err != nil {\n90: \t\treturn nil, fmt.Errorf(\"failed to create request: %w\", err)\n91: \t}\n92: \n93: \treq.Header.Set(\"Content-Type\", \"application/json\")\n94: \n95: \tsaToken, err := readServiceAccountToken()\n96: \tif err == nil && saToken != \"\" {\n97: \t\treq.Header.Set(\"Authorization\", \"Bearer \"+saToken)\n98: \t}\n99: \n100: \tresp, err := m.httpClient.Do(req)\n101: \tif err != nil {\n102: \t\treturn nil, &WorkloadManagerError{\n103: \t\t\tStatusCode: http.StatusInternalServerError,\n104: \t\t\tMsg:        fmt.Sprintf(\"failed to connect to workload manager: %v\", err),\n105: \t\t}\n106: \t}\n107: \tdefer resp.Body.Close()\n108: \n109: \trespBody, err := io.ReadAll(resp.Body)\n110: \tif err != nil {\n111: \t\treturn nil, fmt.Errorf(\"failed to read response: %w\", err)\n112: \t}\n113: \n114: \tif resp.StatusCode != http.StatusOK {\n115: \t\treturn nil, &WorkloadManagerError{\n116: \t\t\tStatusCode: resp.StatusCode,\n117: \t\t\tMsg:        string(respBody),\n118: \t\t}\n119: \t}\n120: \n121: \tvar createResp types.CreateSandboxResponse\n122: \tif err := json.Unmarshal(respBody, &createResp); err != nil {\n123: \t\treturn nil, fmt.Errorf(\"failed to parse response: %w\", err)\n124: \t}\n125: \n126: \tif createResp.SessionID == \"\" {\n127: \t\treturn nil, fmt.Errorf(\"empty sessionId in response\")\n128: \t}\n129: \n130: \tsandbox := &types.SandboxInfo{\n131: \t\tKind:             kind,\n132: \t\tSandboxID:        createResp.SandboxID,\n133: \t\tSandboxNamespace: IdentityNamespace,\n134: \t\tSandboxName:      createResp.SandboxName,\n135: \t\tName:             name,\n136: \t\tSessionID:        createResp.SessionID,\n137: \t\tCreatedAt:        time.Now(),\n138: \t\tExpiresAt:        time.Now().Add(30 * time.Minute),\n139: \t\tStatus:           \"Running\",\n140: \t\tEntryPoints:      createResp.EntryPoints,\n141: \t}\n142: \n143: \tif err := m.storeClient.StoreSandbox(ctx, sandbox); err != nil {\n144: \t\treturn nil, fmt.Errorf(\"failed to store sandbox: %w\", err)\n145: \t}\n146: \n147: \treturn sandbox, nil\n148: }\n149: \n150: func readServiceAccountToken() (string, error) {\n151: \ttokenPath := \"/var/run/secrets/kubernetes.io/serviceaccount/token\"\n152: \tdata, err := os.ReadFile(tokenPath)\n153: \tif err != nil {\n154: \t\treturn \"\", err\n155: \t}\n156: \treturn strings.TrimSpace(string(data)), nil\n157: }\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n\t\"golang.org/x/net/http2\"\n)\n\ntype sessionManager struct {\n\tstoreClient     Store\n\tworkloadMgrAddr string","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager.go","time":{"start":1775851612002,"end":1775851612017}}}}
{"type":"tool_use","timestamp":1775851612022,"sessionID":"ses_286ff5c1dffeIBEVY3O4NaEOZB","part":{"id":"prt_d79012710001CzsXPms0hSPXOO","messageID":"msg_d79010257001wb9QFd8zY0Y9qv","sessionID":"ses_286ff5c1dffeIBEVY3O4NaEOZB","type":"tool","tool":"read","callID":"toolu_tool-8c96c9a72370458196f6d33f5ae2cc0d","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager_test.go"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager_test.go</path>\n<type>file</type>\n<content>\n1: package router\n2: \n3: import (\n4: \t\"context\"\n5: \t\"encoding/json\"\n6: \t\"errors\"\n7: \t\"io\"\n8: \t\"net/http\"\n9: \t\"net/http/httptest\"\n10: \t\"testing\"\n11: \t\"time\"\n12: \n13: \t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n14: )\n15: \n16: type MockStore struct {\n17: \tGetSandboxBySessionIDFunc     func(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n18: \tStoreSandboxFunc              func(ctx context.Context, sandbox *types.SandboxInfo) error\n19: \tUpdateSessionLastActivityFunc func(ctx context.Context, sessionID string, at time.Time) error\n20: }\n21: \n22: func (m *MockStore) GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n23: \tif m.GetSandboxBySessionIDFunc != nil {\n24: \t\treturn m.GetSandboxBySessionIDFunc(ctx, sessionID)\n25: \t}\n26: \treturn nil, errors.New(\"not implemented\")\n27: }\n28: \n29: func (m *MockStore) StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error {\n30: \tif m.StoreSandboxFunc != nil {\n31: \t\treturn m.StoreSandboxFunc(ctx, sandbox)\n32: \t}\n33: \treturn errors.New(\"not implemented\")\n34: }\n35: \n36: func (m *MockStore) UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error {\n37: \tif m.UpdateSessionLastActivityFunc != nil {\n38: \t\treturn m.UpdateSessionLastActivityFunc(ctx, sessionID, at)\n39: \t}\n40: \treturn errors.New(\"not implemented\")\n41: }\n42: \n43: type MockHTTPClient struct {\n44: \tDoFunc func(req *http.Request) (*http.Response, error)\n45: }\n46: \n47: func (m *MockHTTPClient) Do(req *http.Request) (*http.Response, error) {\n48: \tif m.DoFunc != nil {\n49: \t\treturn m.DoFunc(req)\n50: \t}\n51: \treturn nil, errors.New(\"not implemented\")\n52: }\n53: \n54: func TestNewSessionManagerRequiresWorkloadManagerURL(t *testing.T) {\n55: \tmockStore := &MockStore{}\n56: \t_, err := NewSessionManager(mockStore)\n57: \tif err == nil {\n58: \t\tt.Error(\"expected error when WORKLOAD_MANAGER_URL is not set\")\n59: \t}\n60: \tif err.Error() != \"WORKLOAD_MANAGER_URL environment variable is required\" {\n61: \t\tt.Errorf(\"unexpected error message: %s\", err.Error())\n62: \t}\n63: }\n64: \n65: func TestSessionManagerGetSandboxBySessionWithExistingSession(t *testing.T) {\n66: \tmockStore := &MockStore{\n67: \t\tGetSandboxBySessionIDFunc: func(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n68: \t\t\treturn &types.SandboxInfo{\n69: \t\t\t\tSessionID:   sessionID,\n70: \t\t\t\tSandboxID:   \"sandbox-123\",\n71: \t\t\t\tSandboxName: \"test-sandbox\",\n72: \t\t\t\tEntryPoints: []types.SandboxEntryPoint{\n73: \t\t\t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:8080\"},\n74: \t\t\t\t},\n75: \t\t\t}, nil\n76: \t\t},\n77: \t}\n78: \n79: \tsm := &sessionManager{\n80: \t\tstoreClient:     mockStore,\n81: \t\tworkloadMgrAddr: \"http://localhost:9090\",\n82: \t\thttpClient:      &http.Client{},\n83: \t}\n84: \n85: \tctx := context.Background()\n86: \tsandbox, err := sm.GetSandboxBySession(ctx, \"existing-session\", \"default\", \"test\", types.AgentRuntimeKind)\n87: \tif err != nil {\n88: \t\tt.Fatalf(\"unexpected error: %v\", err)\n89: \t}\n90: \tif sandbox.SessionID != \"existing-session\" {\n91: \t\tt.Errorf(\"unexpected session ID: %s\", sandbox.SessionID)\n92: \t}\n93: }\n94: \n95: func TestSessionManagerGetSandboxBySessionNotFound(t *testing.T) {\n96: \tmockStore := &MockStore{\n97: \t\tGetSandboxBySessionIDFunc: func(ctx context.Context, sessionID string) (*types.SandboxInfo, error) {\n98: \t\t\treturn nil, errors.New(\"session not found\")\n99: \t\t},\n100: \t}\n101: \n102: \tsm := &sessionManager{\n103: \t\tstoreClient:     mockStore,\n104: \t\tworkloadMgrAddr: \"http://localhost:9090\",\n105: \t\thttpClient:      &http.Client{},\n106: \t}\n107: \n108: \tctx := context.Background()\n109: \t_, err := sm.GetSandboxBySession(ctx, \"nonexistent-session\", \"default\", \"test\", types.AgentRuntimeKind)\n110: \tif err == nil {\n111: \t\tt.Error(\"expected error for nonexistent session\")\n112: \t}\n113: \tif _, ok := err.(*SessionNotFoundError); !ok {\n114: \t\tt.Errorf(\"expected SessionNotFoundError, got %T\", err)\n115: \t}\n116: }\n117: \n118: func TestSessionManagerCreateSandbox(t *testing.T) {\n119: \trespBody := types.CreateSandboxResponse{\n120: \t\tSessionID:   \"new-session-123\",\n121: \t\tSandboxID:   \"sandbox-456\",\n122: \t\tSandboxName: \"new-sandbox\",\n123: \t\tEntryPoints: []types.SandboxEntryPoint{\n124: \t\t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:8080\"},\n125: \t\t},\n126: \t}\n127: \trespBytes, _ := json.Marshal(respBody)\n128: \n129: \tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n130: \t\tif r.URL.Path != \"/v1/agent-runtime\" {\n131: \t\t\tt.Errorf(\"unexpected path: %s\", r.URL.Path)\n132: \t\t}\n133: \t\tif r.Method != http.MethodPost {\n134: \t\t\tt.Errorf(\"unexpected method: %s\", r.Method)\n135: \t\t}\n136: \n137: \t\tbody, _ := io.ReadAll(r.Body)\n138: \t\tvar req types.CreateSandboxRequest\n139: \t\tjson.Unmarshal(body, &req)\n140: \t\tif req.Kind != types.AgentRuntimeKind {\n141: \t\t\tt.Errorf(\"unexpected kind: %s\", req.Kind)\n142: \t\t}\n143: \n144: \t\tw.WriteHeader(http.StatusOK)\n145: \t\tw.Write(respBytes)\n146: \t}))\n147: \tdefer server.Close()\n148: \n149: \tmockStore := &MockStore{\n150: \t\tStoreSandboxFunc: func(ctx context.Context, sandbox *types.SandboxInfo) error {\n151: \t\t\treturn nil\n152: \t\t},\n153: \t}\n154: \n155: \tsm := &sessionManager{\n156: \t\tstoreClient:     mockStore,\n157: \t\tworkloadMgrAddr: server.URL,\n158: \t\thttpClient:      &http.Client{Timeout: 2 * time.Minute},\n159: \t}\n160: \n161: \tctx := context.Background()\n162: \tsandbox, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test-runtime\", types.AgentRuntimeKind)\n163: \tif err != nil {\n164: \t\tt.Fatalf(\"unexpected error: %v\", err)\n165: \t}\n166: \tif sandbox.SessionID != \"new-session-123\" {\n167: \t\tt.Errorf(\"unexpected session ID: %s\", sandbox.SessionID)\n168: \t}\n169: \tif sandbox.SandboxID != \"sandbox-456\" {\n170: \t\tt.Errorf(\"unexpected sandbox ID: %s\", sandbox.SandboxID)\n171: \t}\n172: }\n173: \n174: func TestSessionManagerCreateSandboxCodeInterpreter(t *testing.T) {\n175: \trespBody := types.CreateSandboxResponse{\n176: \t\tSessionID:   \"ci-session-123\",\n177: \t\tSandboxID:   \"ci-sandbox-456\",\n178: \t\tSandboxName: \"ci-sandbox\",\n179: \t\tEntryPoints: []types.SandboxEntryPoint{\n180: \t\t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n181: \t\t},\n182: \t}\n183: \trespBytes, _ := json.Marshal(respBody)\n184: \n185: \tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n186: \t\tif r.URL.Path != \"/v1/code-interpreter\" {\n187: \t\t\tt.Errorf(\"unexpected path: %s\", r.URL.Path)\n188: \t\t}\n189: \t\tw.WriteHeader(http.StatusOK)\n190: \t\tw.Write(respBytes)\n191: \t}))\n192: \tdefer server.Close()\n193: \n194: \tmockStore := &MockStore{\n195: \t\tStoreSandboxFunc: func(ctx context.Context, sandbox *types.SandboxInfo) error {\n196: \t\t\treturn nil\n197: \t\t},\n198: \t}\n199: \n200: \tsm := &sessionManager{\n201: \t\tstoreClient:     mockStore,\n202: \t\tworkloadMgrAddr: server.URL,\n203: \t\thttpClient:      &http.Client{Timeout: 2 * time.Minute},\n204: \t}\n205: \n206: \tctx := context.Background()\n207: \tsandbox, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test-ci\", types.CodeInterpreterKind)\n208: \tif err != nil {\n209: \t\tt.Fatalf(\"unexpected error: %v\", err)\n210: \t}\n211: \tif sandbox.SessionID != \"ci-session-123\" {\n212: \t\tt.Errorf(\"unexpected session ID: %s\", sandbox.SessionID)\n213: \t}\n214: \tif sandbox.Kind != types.CodeInterpreterKind {\n215: \t\tt.Errorf(\"unexpected kind: %s\", sandbox.Kind)\n216: \t}\n217: }\n218: \n219: func TestSessionManagerCreateSandboxWorkloadManagerError(t *testing.T) {\n220: \tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n221: \t\tw.WriteHeader(http.StatusInternalServerError)\n222: \t\tw.Write([]byte(\"internal error\"))\n223: \t}))\n224: \tdefer server.Close()\n225: \n226: \tmockStore := &MockStore{}\n227: \n228: \tsm := &sessionManager{\n229: \t\tstoreClient:     mockStore,\n230: \t\tworkloadMgrAddr: server.URL,\n231: \t\thttpClient:      &http.Client{Timeout: 2 * time.Minute},\n232: \t}\n233: \n234: \tctx := context.Background()\n235: \t_, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test-runtime\", types.AgentRuntimeKind)\n236: \tif err == nil {\n237: \t\tt.Error(\"expected error from workload manager\")\n238: \t}\n239: \tif _, ok := err.(*WorkloadManagerError); !ok {\n240: \t\tt.Errorf(\"expected WorkloadManagerError, got %T\", err)\n241: \t}\n242: }\n243: \n244: func TestSessionManagerCreateSandboxEmptySessionID(t *testing.T) {\n245: \trespBody := types.CreateSandboxResponse{\n246: \t\tSessionID:   \"\",\n247: \t\tSandboxID:   \"sandbox-456\",\n248: \t\tSandboxName: \"new-sandbox\",\n249: \t}\n250: \trespBytes, _ := json.Marshal(respBody)\n251: \n252: \tserver := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n253: \t\tw.WriteHeader(http.StatusOK)\n254: \t\tw.Write(respBytes)\n255: \t}))\n256: \tdefer server.Close()\n257: \n258: \tmockStore := &MockStore{}\n259: \n260: \tsm := &sessionManager{\n261: \t\tstoreClient:     mockStore,\n262: \t\tworkloadMgrAddr: server.URL,\n263: \t\thttpClient:      &http.Client{Timeout: 2 * time.Minute},\n264: \t}\n265: \n266: \tctx := context.Background()\n267: \t_, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test-runtime\", types.AgentRuntimeKind)\n268: \tif err == nil {\n269: \t\tt.Error(\"expected error for empty sessionId in response\")\n270: \t}\n271: }\n272: \n273: func TestSessionManagerUnsupportedKind(t *testing.T) {\n274: \tmockStore := &MockStore{}\n275: \n276: \tsm := &sessionManager{\n277: \t\tstoreClient:     mockStore,\n278: \t\tworkloadMgrAddr: \"http://localhost:9090\",\n279: \t\thttpClient:      &http.Client{},\n280: \t}\n281: \n282: \tctx := context.Background()\n283: \t_, err := sm.GetSandboxBySession(ctx, \"\", \"default\", \"test\", \"UnsupportedKind\")\n284: \tif err == nil {\n285: \t\tt.Error(\"expected error for unsupported kind\")\n286: \t}\n287: }\n288: \n289: func TestSelectEntryPoint(t *testing.T) {\n290: \tentryPoints := []types.SandboxEntryPoint{\n291: \t\t{Path: \"/api\", Protocol: \"http\", Endpoint: \"localhost:8080\"},\n292: \t\t{Path: \"/execute\", Protocol: \"http\", Endpoint: \"localhost:9000\"},\n293: \t}\n294: \n295: \tep := selectEntryPoint(entryPoints, \"/api/v1/resource\")\n296: \tif ep == nil {\n297: \t\tt.Fatal(\"expected entry point to be found\")\n298: \t}\n299: \tif ep.Path != \"/api\" {\n300: \t\tt.Errorf(\"unexpected entry point path: %s\", ep.Path)\n301: \t}\n302: \n303: \tep = selectEntryPoint(entryPoints, \"/execute/code\")\n304: \tif ep == nil {\n305: \t\tt.Fatal(\"expected entry point to be found\")\n306: \t}\n307: \tif ep.Path != \"/execute\" {\n308: \t\tt.Errorf(\"unexpected entry point path: %s\", ep.Path)\n309: \t}\n310: \n311: \tep = selectEntryPoint(entryPoints, \"/other/path\")\n312: \tif ep == nil {\n313: \t\tt.Fatal(\"expected default entry point\")\n314: \t}\n315: \tif ep.Path != \"/api\" {\n316: \t\tt.Errorf(\"expected first entry point as default, got: %s\", ep.Path)\n317: \t}\n318: \n319: \tep = selectEntryPoint([]types.SandboxEntryPoint{}, \"/any/path\")\n320: \tif ep != nil {\n321: \t\tt.Error(\"expected nil for empty entry points\")\n322: \t}\n323: }\n324: \n325: func TestBuildTargetURL(t *testing.T) {\n326: \tep := &types.SandboxEntryPoint{\n327: \t\tPath:     \"/api\",\n328: \t\tProtocol: \"http\",\n329: \t\tEndpoint: \"localhost:8080\",\n330: \t}\n331: \n332: \turl, err := buildTargetURL(ep)\n333: \tif err != nil {\n334: \t\tt.Fatalf(\"unexpected error: %v\", err)\n335: \t}\n336: \tif url.Scheme != \"http\" {\n337: \t\tt.Errorf(\"unexpected scheme: %s\", url.Scheme)\n338: \t}\n339: \tif url.Host != \"localhost:8080\" {\n340: \t\tt.Errorf(\"unexpected host: %s\", url.Host)\n341: \t}\n342: \n343: \tep = &types.SandboxEntryPoint{\n344: \t\tPath:     \"/api\",\n345: \t\tProtocol: \"\",\n346: \t\tEndpoint: \"http://localhost:9000\",\n347: \t}\n348: \n349: \turl, err = buildTargetURL(ep)\n350: \tif err != nil {\n351: \t\tt.Fatalf(\"unexpected error: %v\", err)\n352: \t}\n353: \tif url.Scheme != \"http\" {\n354: \t\tt.Errorf(\"unexpected scheme: %s\", url.Scheme)\n355: \t}\n356: }\n357: \n358: func TestReadServiceAccountToken(t *testing.T) {\n359: \ttoken, err := readServiceAccountToken()\n360: \tif err != nil {\n361: \t\tt.Logf(\"expected error when not in cluster: %v\", err)\n362: \t}\n363: \tif token != \"\" && len(token) < 10 {\n364: \t\tt.Errorf(\"unexpected token length: %d\", len(token))\n365: \t}\n366: }\n\n(End of file - total 366 lines)\n</content>","metadata":{"preview":"package router\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"io\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/volcano-sh/agentcube/pkg/common/types\"\n)\n\ntype MockStore struct {\n\tGetSandboxBySessionIDFunc     func(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n\tStoreSandboxFunc              func(ctx context.Context, sandbox *types.SandboxInfo) error\n\tUpdateSessionLastActivityFunc func(ctx context.Context, sessionID string, at time.Time) error\n}","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/pkg/router/session_manager_test.go","time":{"start":1775851612004,"end":1775851612020}}}}
{"type":"tool_use","timestamp":1775851612024,"sessionID":"ses_286ff5c1dffeIBEVY3O4NaEOZB","part":{"id":"prt_d79011c4b001HPJ0gBbQFLx4Oj","messageID":"msg_d79010257001wb9QFd8zY0Y9qv","sessionID":"ses_286ff5c1dffeIBEVY3O4NaEOZB","type":"tool","tool":"read","callID":"toolu_tool-e3683033ad9a4f22991fad931ffd4a5e","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-010/design.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-010/design.md</path>\n<type>file</type>\n<content>\n1: # AR-010 — Router 会话管理 Design\n2: \n3: ## Overview\n4: \n5: | Item | Value |\n6: |------|-------|\n7: | AR | AR-010 — Router 会话管理 |\n8: | Module | `pkg/router` |\n9: | Language | Go |\n10: | Size | M |\n11: | Stage | ST-1 |\n12: \n13: The Router module provides HTTP-based session routing for AgentCube sandboxes. It manages session lifecycle, routes incoming invocation requests to appropriate sandbox pods via reverse proxy, and handles JWT-based authentication for secure communication between Router and Workload Manager.\n14: \n15: ---\n16: \n17: ## Architecture\n18: \n19: ### System Context\n20: \n21: ```\n22: ┌─────────────────┐     ┌─────────────────┐     ┌─────────────────┐\n23: │   Client SDK    │────▶│     Router      │────▶│  WorkloadMgr    │\n24: │ (Python/CLI)    │     │  (pkg/router)   │     │(pkg/workloadmgr)│\n25: └─────────────────┘     └─────────────────┘     └─────────────────┘\n26:                               │                         │\n27:                               │                         │\n28:                               ▼                         ▼\n29:                         ┌─────────────────┐     ┌─────────────────┐\n30:                         │   Session Store │     │   Kubernetes    │\n31:                         │ (Redis/Memory)  │     │   API Server    │\n32:                         └─────────────────┘     └─────────────────┘\n33: ```\n34: \n35: ### Request Flow\n36: \n37: ```\n38: Client Request (with x-agentcube-session-id header)\n39:        │\n40:        ▼\n41: ┌──────────────────────────────────────────────────────────┐\n42: │ 1. Concurrency Limit Middleware (semaphore channel)      │\n43: │    - Reject with 429 if max concurrent exceeded          │\n44: └──────────────────────────────────────────────────────────┘\n45:        │\n46:        ▼\n47: ┌──────────────────────────────────────────────────────────┐\n48: │ 2. Logging Middleware                                    │\n49: │    - Record request method, path, duration               │\n50: └──────────────────────────────────────────────────────────┘\n51:        │\n52:        ▼\n53: ┌──────────────────────────────────────────────────────────┐\n54: │ 3. Recovery Middleware                                   │\n55: │    - Panic recovery → 500 response                       │\n56: └──────────────────────────────────────────────────────────┘\n57:        │\n58:        ▼\n59: ┌──────────────────────────────────────────────────────────┐\n60: │ 4. handleInvoke (AgentRuntime/CodeInterpreter)           │\n61: │    - Extract namespace, name, path from URL params       │\n62: │    - Get sessionID from x-agentcube-session-id header    │\n63: └──────────────────────────────────────────────────────────┘\n64:        │\n65:        ▼\n66: ┌──────────────────────────────────────────────────────────┐\n67: │ 5. SessionManager.GetSandboxBySession                    │\n68: │    - If sessionID empty → create new sandbox             │\n69: │    - If sessionID provided → lookup from store           │\n70: │    - On not found → SessionNotFoundError                 │\n71: └──────────────────────────────────────────────────────────┘\n72:        │\n73:        ▼\n74: ┌──────────────────────────────────────────────────────────┐\n75: │ 6. UpdateSessionLastActivity (before proxy)              │\n76: │    - Update LastActivity timestamp in store              │\n77: └──────────────────────────────────────────────────────────┘\n78:        │\n79:        ▼\n80: ┌──────────────────────────────────────────────────────────┐\n81: │ 7. Entry Point Selection                                 │\n82: │    - selectEntryPoint: prefix match or first entry       │\n83: │    - buildTargetURL: construct backend URL               │\n84: └──────────────────────────────────────────────────────────┘\n85:        │\n86:        ▼\n87: ┌──────────────────────────────────────────────────────────┐\n88: │ 8. JWT Generation (for Sandbox/SandboxClaim kinds)       │\n89: │    - JWTManager.GenerateToken with session claims        │\n90: │    - RS256 signing with RSA 2048-bit key                 │\n91: └──────────────────────────────────────────────────────────┘\n92:        │\n93:        ▼\n94: ┌──────────────────────────────────────────────────────────┐\n95: │ 9. Reverse Proxy                                         │\n96: │    - httputil.NewSingleHostReverseProxy                  │\n97: │    - Director: rewrite URL, add forwarding headers       │\n98: │    - ModifyResponse: set x-agentcube-session-id          │\n99: │    - ErrorHandler: connection refused → 502, timeout→504│\n100: └──────────────────────────────────────────────────────────┘\n101:        │\n102:        ▼\n103: ┌──────────────────────────────────────────────────────────┐\n104: │ 10. UpdateSessionLastActivity (after proxy)              │\n105: │    - Update activity timestamp again                     │\n106: └──────────────────────────────────────────────────────────┘\n107: ```\n108: \n109: ---\n110: \n111: ## Design\n112: \n113: ### Component Relationships\n114: \n115: | Component | Role | Dependencies |\n116: |-----------|------|--------------|\n117: | `Server` | Gin HTTP server, route registration, graceful shutdown | `Config`, `SessionManager`, `Store`, `JWTManager`, `Logger` |\n118: | `sessionManager` | Session lookup, sandbox creation via Workload Manager | `Store`, `http.Client` (to WorkloadMgr) |\n119: | `JWTManager` | RS256 JWT token generation, key persistence | `rsa.PrivateKey`, Kubernetes client (optional) |\n120: | `ReverseProxyWrapper` | Request director, response modification, error handling | `url.URL`, JWT string |\n121: | `Store` (interface) | Session/sandbox CRUD, activity tracking | Redis or in-memory implementation |\n122: | `middleware.go` | Concurrency limiting, logging, panic recovery | `gin.Context`, `Logger` |\n123: | `errors.go` | Custom error types with APIStatus interface | None |\n124: \n125: ### Dependencies\n126: \n127: | Package | Purpose | Import Path |\n128: |---------|---------|-------------|\n129: | Gin | HTTP router and middleware | `github.com/gin-gonic/gin` |\n130: | JWT | JWT token generation and signing | `github.com/golang-jwt/jwt/v5` |\n131: | HTTP2 | HTTP/2 transport configuration | `golang.org/x/net/http2` |\n132: | Kubernetes API | APIStatus error interface | `k8s.io/apimachinery/pkg/api/errors` |\n133: | Klog | Logging | `k8s.io/klog/v2` |\n134: | Common Types | SandboxInfo, CreateSandboxRequest/Response | `github.com/volcano-sh/agentcube/pkg/common/types` |\n135: \n136: ---\n137: \n138: ## Data Structures\n139: \n140: ### Config (`config.go`)\n141: \n142: ```go\n143: type Config struct {\n144:     Port                  string  // Default \":8080\"\n145:     EnableTLS             bool    // TLS mode toggle\n146:     TLSCert               string  // TLS certificate file path\n147:     TLSKey                string  // TLS key file path\n148:     MaxConcurrentRequests int     // Semaphore size, default 1000\n149:     Debug                 bool    // Gin debug mode toggle\n150: }\n151: ```\n152: \n153: ### Server (`server.go`)\n154: \n155: ```go\n156: type Server struct {\n157:     config         *Config\n158:     engine         *gin.Engine\n159:     httpServer     *http.Server\n160:     sessionManager SessionManager\n161:     storeClient    Store\n162:     httpTransport  *http.Transport\n163:     jwtManager     *JWTManager\n164:     logger         Logger\n165: }\n166: ```\n167: \n168: ### sessionManager (`session_manager.go`)\n169: \n170: ```go\n171: type sessionManager struct {\n172:     storeClient     Store\n173:     workloadMgrAddr string         // From WORKLOAD_MANAGER_URL env\n174:     httpClient      *http.Client   // Timeout: 2m, HTTP/2 enabled\n175: }\n176: ```\n177: \n178: ### JWTManager (`jwt.go`)\n179: \n180: ```go\n181: type JWTManager struct {\n182:     privateKey *rsa.PrivateKey  // 2048-bit RSA key\n183:     publicKey  *rsa.PublicKey\n184: }\n185: \n186: const (\n187:     rsaKeySize         = 2048\n188:     jwtExpiration      = 5 * time.Minute\n189:     IdentitySecretName = \"picod-router-identity\"\n190:     PrivateKeyDataKey  = \"private.pem\"\n191:     PublicKeyDataKey   = \"public.pem\"\n192: )\n193: \n194: var IdentityNamespace = \"default\" // Overridden by AGENTCUBE_NAMESPACE\n195: ```\n196: \n197: ### SandboxInfo (`pkg/common/types/sandbox.go`)\n198: \n199: ```go\n200: type SandboxInfo struct {\n201:     Kind               string\n202:     SandboxID          string\n203:     SandboxNamespace   string\n204:     SandboxName        string\n205:     Name               string\n206:     SessionID          string\n207:     CreatedAt          time.Time\n208:     ExpiresAt          time.Time\n209:     Status             string\n210:     EntryPoints        []SandboxEntryPoint\n211:     UserToken          string              // Optional\n212:     ServiceAccount     string              // Optional\n213:     ServiceAccountName string              // Optional\n214:     LastActivity       time.Time           // Optional\n215: }\n216: \n217: type SandboxEntryPoint struct {\n218:     Path     string  // URL path prefix\n219:     Protocol string  // \"http\" or \"https\"\n220:     Endpoint string  // Backend host:port or full URL\n221: }\n222: ```\n223: \n224: ### ReverseProxyWrapper (`reverse_proxy.go`)\n225: \n226: ```go\n227: type ReverseProxyWrapper struct {\n228:     director       func(*http.Request)\n229:     modifyResponse func(*http.Response) error\n230:     errorHandler   func(http.ResponseWriter, *http.Request, error)\n231: }\n232: ```\n233: \n234: ### Interfaces (`doc.go`)\n235: \n236: ```go\n237: type Store interface {\n238:     GetSandboxBySessionID(ctx context.Context, sessionID string) (*types.SandboxInfo, error)\n239:     StoreSandbox(ctx context.Context, sandbox *types.SandboxInfo) error\n240:     UpdateSessionLastActivity(ctx context.Context, sessionID string, at time.Time) error\n241: }\n242: \n243: type Logger interface {\n244:     Info(msg string, keysAndValues ...any)\n245:     Error(msg string, keysAndValues ...any)\n246:     Warning(msg string, keysAndValues ...any)\n247: }\n248: \n249: type SessionManager interface {\n250:     GetSandboxBySession(ctx context.Context, sessionID string, namespace string, name string, kind string) (*types.SandboxInfo, error)\n251: }\n252: \n253: type APIStatus interface {\n254:     Status() int\n255:     Code() string\n256:     Message() string\n257: }\n258: ```\n259: \n260: ---\n261: \n262: ## API Contracts\n263: \n264: ### Route Table\n265: \n266: | Method | Path | Middleware | Handler |\n267: |--------|------|------------|---------|\n268: | GET | `/health/live` | none | `handleHealthLive` → `{\"status\":\"alive\"}` |\n269: | GET | `/health/ready` | none | `handleHealthReady` → `{\"status\":\"ready\"}` or 503 |\n270: | GET | `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` | concurrency, logging, recovery | `handleAgentInvoke` |\n271: | POST | `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` | concurrency, logging, recovery | `handleAgentInvoke` |\n272: | GET | `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path` | concurrency, logging, recovery | `handleCodeInterpreterInvoke` |\n273: | POST | `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path` | concurrency, logging, recovery | `handleCodeInterpreterInvoke` |\n274: \n275: ### Request Headers\n276: \n277: | Header | Required | Description |\n278: |--------|----------|-------------|\n279: | `x-agentcube-session-id` | No | Existing session ID for reuse; empty → new session creation |\n280: \n281: ### Response Headers\n282: \n283: | Header | Description |\n284: |--------|-------------|\n285: | `x-agentcube-session-id` | Session ID echoed back for client tracking |\n286: \n287: ### Workload Manager API Calls\n288: \n289: | Endpoint | Method | Request Body | Response |\n290: |----------|--------|--------------|----------|\n291: | `{WORKLOAD_MANAGER_URL}/v1/agent-runtime` | POST | `CreateSandboxRequest{kind, name, namespace}` | `CreateSandboxResponse{sessionId, sandboxId, sandboxName, entryPoints}` |\n292: | `{WORKLOAD_MANAGER_URL}/v1/code-interpreter` | POST | `CreateSandboxRequest{kind, name, namespace}` | `CreateSandboxResponse{sessionId, sandboxId, sandboxName, entryPoints}` |\n293: \n294: ### JWT Claims Structure\n295: \n296: ```json\n297: {\n298:   \"exp\": <unix timestamp + 5min>,\n299:   \"iat\": <unix timestamp>,\n300:   \"iss\": \"agentcube-router\",\n301:   \"session_id\": \"<session ID>\",\n302:   \"sandbox_id\": \"<sandbox ID>\",\n303:   \"namespace\": \"<sandbox namespace>\",\n304:   \"name\": \"<sandbox name>\"\n305: }\n306: ```\n307: \n308: ---\n309: \n310: ## Error Handling\n311: \n312: ### Custom Error Types (`errors.go`)\n313: \n314: | Error Type | HTTP Status | Code | Message |\n315: |------------|-------------|------|---------|\n316: | `SessionNotFoundError` | 404 | `SESSION_NOT_FOUND` | \"session not found\" |\n317: | `SandboxUnreachableError` | 502 | `SANDBOX_UNREACHABLE` | \"sandbox unreachable\" |\n318: | `SandboxTimeoutError` | 504 | `SANDBOX_TIMEOUT` | \"sandbox timeout\" |\n319: | `JWTSigningError` | 500 | `JWT_SIGNING_FAILED` | \"jwt signing failed\" |\n320: | `ServerOverloadedError` | 429 | `SERVER_OVERLOADED` | \"server overloaded, please try again later\" |\n321: | `NoEntryPointError` | 404 | `NO_ENTRY_POINT` | \"no entry point configured\" |\n322: | `WorkloadManagerError` | Dynamic | `WORKLOAD_MANAGER_ERROR` | Dynamic message |\n323: \n324: ### Error Response Format\n325: \n326: ```json\n327: {\n328:   \"error\": \"<message>\",\n329:   \"code\": \"<error code>\"\n330: }\n331: ```\n332: \n333: ### Error Handling Strategy\n334: \n335: 1. **Session lookup errors**: Return `SessionNotFoundError` when session ID provided but not found in store\n336: 2. **Workload Manager errors**: Wrap HTTP response errors in `WorkloadManagerError` with original status code\n337: 3. **Proxy errors**: Detect \"connection refused\" → 502, \"timeout\" → 504 via string matching\n338: 4. **Entry point errors**: Return 404 if no entry points configured or path prefix not matched\n339: 5. **Concurrency limit**: Return 429 immediately when semaphore full (non-blocking)\n340: \n341: ---\n342: \n343: ## Testing Strategy\n344: \n345: ### Test Coverage Goals\n346: \n347: | Component | Coverage Target | Key Test Cases |\n348: |-----------|-----------------|----------------|\n349: | `session_manager.go` | 90%+ | Existing session lookup, new sandbox creation, WorkloadMgr errors, unsupported kind, empty sessionID in response |\n350: | `server.go` | 85%+ | Route registration, health endpoints, concurrent request limiting, TLS validation, graceful shutdown |\n351: | `jwt.go` | 80%+ | Token generation, claim merging, RSA key creation, PEM encoding/decoding |\n352: | `reverse_proxy.go` | 85%+ | Entry point selection, URL building, proxy director, error handler classification |\n353: | `middleware.go` | 90%+ | Concurrency limit (accept/reject), logging capture, panic recovery |\n354: | `errors.go` | 100% | All error type methods (Error, Status, Code, Message) |\n355: \n356: ### Test Patterns\n357: \n358: 1. **Mock Store**: `MockStore` with function fields for flexible testing\n359: 2. **Mock HTTP Client**: `httptest.Server` for Workload Manager simulation\n360: 3. **Mock SessionManager**: `mockSessionManager` with configurable `getFunc`\n361: 4. **Mock Logger**: `MockLogger` with Info/Error recording for middleware tests\n362: \n363: ### Integration Test Scenarios\n364: \n365: | Scenario | Description |\n366: |----------|-------------|\n367: | Full request flow | Client → Router → mock WorkloadMgr → verify proxy headers |\n368: | Session reuse | Provide existing sessionID → verify no new sandbox created |\n369: | New session creation | Empty sessionID → verify POST to WorkloadMgr, store write |\n370: | TLS startup | EnableTLS=true with missing cert → verify error |\n371: | Graceful shutdown | Context cancellation → verify 10s timeout shutdown |\n372: \n373: ---\n374: \n375: ## Validation Checklist\n376: \n377: - [ ] `WORKLOAD_MANAGER_URL` environment variable required for SessionManager initialization\n378: - [ ] Concurrency limit defaults to 1000 when `MaxConcurrentRequests <= 0`\n379: - [ ] JWT expires in 5 minutes, signed with RS256\n380: - [ ] Session activity updated before and after proxy for accurate idle tracking\n381: - [ ] Entry point selection uses prefix match, falls back to first entry\n382: - [ ] Proxy error classification based on error message content\n383: - [ ] Health check `/health/ready` returns 503 when SessionManager unavailable\n384: - [ ] Gin mode set to ReleaseMode when `config.Debug=false`\n385: \n386: ---\n387: \n388: ## Open Questions\n389: \n390: 1. Should JWT key persistence be mandatory for production deployments (current implementation allows ephemeral keys)?\n391: 2. Should proxy timeout be configurable per entry point (currently hardcoded in transport)?\n392: 3. Should session creation be rate-limited independently from concurrent request limit?\n393: \n394: ---\n395: \n396: ## References\n397: \n398: - `session-routing/design.md` — Session routing module design\n399: - `pkg/router/doc.go` — Interface definitions\n400: - `pkg/common/types/sandbox.go` — SandboxInfo and request/response types\n401: - `pkg/apis/runtime/v1alpha1/shared_types.go` — Labels, annotations, condition constants\n402: - `deployment/client-go.md` — Kubernetes client library reference\n\n(End of file - total 402 lines)\n</content>","metadata":{"preview":"# AR-010 — Router 会话管理 Design\n\n## Overview\n\n| Item | Value |\n|------|-------|\n| AR | AR-010 — Router 会话管理 |\n| Module | `pkg/router` |\n| Language | Go |\n| Size | M |\n| Stage | ST-1 |\n\nThe Router module provides HTTP-based session routing for AgentCube sandboxes. It manages session lifecycle, routes incoming invocation requests to appropriate sandbox pods via reverse proxy, and handles JWT-based authentication for secure communication between Router and Workload Manager.\n\n---\n\n## Architecture\n\n### System Context\n","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-010/design.md","time":{"start":1775851611997,"end":1775851612022}}}}
{"type":"tool_use","timestamp":1775851612028,"sessionID":"ses_286ff5c1dffeIBEVY3O4NaEOZB","part":{"id":"prt_d7901200a001Ve20N2Me6RvbzP","messageID":"msg_d79010257001wb9QFd8zY0Y9qv","sessionID":"ses_286ff5c1dffeIBEVY3O4NaEOZB","type":"tool","tool":"read","callID":"toolu_tool-6727398cba914cea9377acc16f1a46df","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-010/tasks.md"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/changes/AR-010/tasks.md</path>\n<type>file</type>\n<content>\n1: # AR-010 — Router 会话管理 Tasks\n2: \n3: ## Metadata\n4: \n5: | Item | Value |\n6: |------|-------|\n7: | AR | AR-010 — Router 会话管理 |\n8: | Module | `pkg/router` |\n9: | Language | Go |\n10: | Size | M |\n11: | Design | [Stage ST-3 completed] |\n12: \n13: ---\n14: \n15: ## Task Checklist\n16: \n17: ### Phase 1: Error Types & Interfaces (ST-1)\n18: \n19: - [x] **T1.1**: Define error types in `errors.go`\n20:   - `SessionNotFoundError` with `SessionID` field, code `SESSION_NOT_FOUND`, HTTP 404\n21:   - `SandboxUnreachableError` with `SandboxID` field, code `SANDBOX_UNREACHABLE`, HTTP 502\n22:   - `SandboxTimeoutError` with `SandboxID` field, code `SANDBOX_TIMEOUT`, HTTP 504\n23:   - `JWTSigningError` with `Err` field, code `JWT_SIGNING_FAILED`, HTTP 500\n24:   - `ServerOverloadedError` with code `SERVER_OVERLOADED`, HTTP 429\n25:   - `NoEntryPointError` with code `NO_ENTRY_POINT`, HTTP 404\n26:   - `WorkloadManagerError` with dynamic status code\n27:   - File: `pkg/router/errors.go`\n28:   - Verification: `go test ./pkg/router -run TestSessionNotFoundError -v`\n29: \n30: - [x] **T1.2**: Define `APIStatus` interface\n31:   - Methods: `Status() int`, `Code() string`, `Message() string`\n32:   - All error types implement this interface\n33:   - File: `pkg/router/doc.go`\n34:   - Verification: `go test ./pkg/router -run TestAPIStatusInterface -v`\n35: \n36: ### Phase 2: Config & Constants (ST-2)\n37: \n38: - [x] **T2.1**: Define `Config` struct in `config.go`\n39:   - `Port string` (default \":8080\")\n40:   - `EnableTLS bool`\n41:   - `TLSCert string`\n42:   - `TLSKey string`\n43:   - `MaxConcurrentRequests int` (default 1000)\n44:   - `Debug bool`\n45:   - File: `pkg/router/config.go`\n46:   - Verification: `go test ./pkg/router -run TestConfig -v`\n47: \n48: - [x] **T2.2**: Implement `DefaultConfig()` function\n49:   - Returns `Config{Port: \":8080\", EnableTLS: false, MaxConcurrentRequests: 1000}`\n50:   - File: `pkg/router/config.go`\n51:   - Verification: `go test ./pkg/router -run TestNewServerNilConfig -v`\n52: \n53: - [x] **T2.3**: Define constants in `jwt.go`\n54:   - `rsaKeySize = 2048`\n55:   - `jwtExpiration = 5 * time.Minute`\n56:   - `IdentitySecretName = \"picod-router-identity\"`\n57:   - `PrivateKeyDataKey = \"private.pem\"`\n58:   - `PublicKeyDataKey = \"public.pem\"`\n59:   - `IdentityNamespace = \"default\"` (overridden by AGENTCUBE_NAMESPACE env)\n60:   - File: `pkg/router/jwt.go`\n61:   - Verification: `go test ./pkg/router -run TestJWTManagerTokenExpiration -v`\n62: \n63: ### Phase 3: Interfaces (ST-3)\n64: \n65: - [x] **T3.1**: Define `Store` interface in `doc.go`\n66:   - `GetSandboxBySessionID(ctx, sessionID) (*types.SandboxInfo, error)`\n67:   - `StoreSandbox(ctx, sandbox) error`\n68:   - `UpdateSessionLastActivity(ctx, sessionID, at) error`\n69:   - File: `pkg/router/doc.go`\n70:   - Verification: `go build ./pkg/router/...`\n71: \n72: - [x] **T3.2**: Define `Logger` interface in `doc.go`\n73:   - Methods: `Info(msg, keysAndValues...)`, `Error(msg, keysAndValues...)`, `Warning(msg, keysAndValues...)`\n74:   - File: `pkg/router/doc.go`\n75:   - Verification: `go test ./pkg/router -run TestLoggingMiddleware -v`\n76: \n77: - [x] **T3.3**: Define `SessionManager` interface in `doc.go`\n78:   - `GetSandboxBySession(ctx, sessionID, namespace, name, kind) (*types.SandboxInfo, error)`\n79:   - File: `pkg/router/doc.go`\n80:   - Verification: `go test ./pkg/router -run TestSessionManager -v`\n81: \n82: - [x] **T3.4**: Define `JWTManagerInterface` interface in `doc.go`\n83:   - `GenerateToken(claims) (string, error)`\n84:   - `TryStoreOrLoadJWTKeySecret(ctx) error`\n85:   - File: `pkg/router/doc.go`\n86:   - Verification: `go test ./pkg/router -run TestJWTManager -v`\n87: \n88: ### Phase 4: JWTManager Implementation (ST-4)\n89: \n90: - [x] **T4.1**: Implement `JWTManager` struct\n91:   - `privateKey *rsa.PrivateKey`\n92:   - `publicKey *rsa.PublicKey`\n93:   - File: `pkg/router/jwt.go`\n94:   - Verification: `go test ./pkg/router -run TestNewJWTManager -v`\n95: \n96: - [x] **T4.2**: Implement RSA key generation\n97:   - `rsa.GenerateKey(rand.Reader, 2048)` in `NewJWTManager()`\n98:   - File: `pkg/router/jwt.go`\n99:   - Verification: `go test ./pkg/router -run TestJWTManagerGetPublicKey -v`\n100: \n101: - [x] **T4.3**: Implement PEM encoding helpers\n102:   - `encodePrivateKeyPEM(key)` - PKCS1 PEM encoding\n103:   - `encodePublicKeyPEM(key)` - PKIX PEM encoding\n104:   - `loadPrivateKeyPEM(data)` - Parse PKCS1 PEM\n105:   - File: `pkg/router/jwt.go`\n106:   - Verification: `go test ./pkg/router -run TestEncodePrivateKeyPEM -v`\n107: \n108: - [x] **T4.4**: Implement `GenerateToken(claims)` method\n109:   - Create JWT with claims: `exp` (now+5m), `iat` (now), `iss=\"agentcube-router\"`\n110:   - Merge custom claims into token\n111:   - Sign with RS256 algorithm\n112:   - File: `pkg/router/jwt.go`\n113:   - Verification: `go test ./pkg/router -run TestJWTManagerGenerateToken -v`\n114: \n115: - [x] **T4.5**: Implement `TryStoreOrLoadJWTKeySecret(ctx)` method\n116:   - Placeholder for in-cluster secret persistence\n117:   - Returns warning when not in cluster\n118:   - File: `pkg/router/jwt.go`\n119:   - Verification: `go build ./pkg/router/...`\n120: \n121: - [x] **T4.6**: Implement `GetPublicKey()` method\n122:   - Returns `*rsa.PublicKey` for token verification\n123:   - File: `pkg/router/jwt.go`\n124:   - Verification: `go test ./pkg/router -run TestJWTManagerGetPublicKey -v`\n125: \n126: ### Phase 5: SessionManager Implementation (ST-5)\n127: \n128: - [x] **T5.1**: Implement `sessionManager` struct\n129:   - `storeClient Store`\n130:   - `workloadMgrAddr string`\n131:   - `httpClient *http.Client`\n132:   - File: `pkg/router/session_manager.go`\n133:   - Verification: `go build ./pkg/router/...`\n134: \n135: - [x] **T5.2**: Implement `NewSessionManager(store)` constructor\n136:   - Read `WORKLOAD_MANAGER_URL` env var (required, fail if missing)\n137:   - Configure HTTP client: `Timeout=2m`, HTTP2 enabled\n138:   - `MaxIdleConnsPerHost=100`\n139:   - File: `pkg/router/session_manager.go`\n140:   - Verification: `go test ./pkg/router -run TestNewSessionManagerRequiresWorkloadManagerURL -v`\n141: \n142: - [x] **T5.3**: Implement `GetSandboxBySession(ctx, sessionID, namespace, name, kind)` method\n143:   - If `sessionID` empty: call `createSandbox(ctx, namespace, name, kind)`\n144:   - If `sessionID` present: call `storeClient.GetSandboxBySessionID(ctx, sessionID)`\n145:   - Return `SandboxInfo` or `SessionNotFoundError`\n146:   - File: `pkg/router/session_manager.go`\n147:   - Verification: `go test ./pkg/router -run TestSessionManagerGetSandboxBySessionWithExistingSession -v`\n148: \n149: - [x] **T5.4**: Implement `createSandbox(ctx, namespace, name, kind)` internal method\n150:   - Build `CreateSandboxRequest` with Kind, Name, Namespace\n151:   - POST to `/v1/agent-runtime` for `AgentRuntimeKind`\n152:   - POST to `/v1/code-interpreter` for `CodeInterpreterKind`\n153:   - Add K8s SA token via `readServiceAccountToken()` if available\n154:   - Parse `CreateSandboxResponse` and store via `StoreSandbox`\n155:   - Set `ExpiresAt` to `CreatedAt + 30min`\n156:   - Return error for unsupported kind\n157:   - File: `pkg/router/session_manager.go`\n158:   - Verification: `go test ./pkg/router -run TestSessionManagerCreateSandbox -v`\n159: \n160: - [x] **T5.5**: Implement `readServiceAccountToken()` helper\n161:   - Read from `/var/run/secrets/kubernetes.io/serviceaccount/token`\n162:   - Return trimmed token string\n163:   - File: `pkg/router/session_manager.go`\n164:   - Verification: `go test ./pkg/router -run TestReadServiceAccountToken -v`\n165: \n166: ### Phase 6: Middleware Implementation (ST-6)\n167: \n168: - [x] **T6.1**: Implement `concurrencyLimitMiddleware(maxConcurrent)` function\n169:   - Use buffered channel as semaphore\n170:   - Capacity = `maxConcurrent` (default 1000 if <=0)\n171:   - `sem <- struct{}{}` to acquire slot (deferred release)\n172:   - File: `pkg/router/middleware.go`\n173:   - Verification: `go test ./pkg/router -run TestConcurrencyLimitMiddlewareUnderLimit -v`\n174: \n175: - [x] **T6.2**: Implement 429 overload response\n176:   - `select` with `default` case when semaphore full\n177:   - Return HTTP 429 with `{\"error\": \"server overloaded\", \"code\": \"SERVER_OVERLOADED\"}`\n178:   - Call `c.Abort()` to stop processing\n179:   - File: `pkg/router/middleware.go`\n180:   - Verification: `go test ./pkg/router -run TestConcurrencyLimitMiddlewareOverLimit -v`\n181: \n182: - [x] **T6.3**: Implement `loggingMiddleware(logger)` function\n183:   - Log request method, path, status, duration\n184:   - Use `logger.Info(\"request\", ...)` with keys\n185:   - Handle nil logger gracefully\n186:   - File: `pkg/router/middleware.go`\n187:   - Verification: `go test ./pkg/router -run TestLoggingMiddleware -v`\n188: \n189: - [x] **T6.4**: Implement `recoveryMiddleware(logger)` function\n190:   - Recover from panics with `defer`\n191:   - Log error with path, method\n192:   - Return HTTP 500 with `{\"error\": \"internal server error\"}`\n193:   - Call `c.Abort()`\n194:   - Handle nil logger gracefully\n195:   - File: `pkg/router/middleware.go`\n196:   - Verification: `go test ./pkg/router -run TestRecoveryMiddleware -v`\n197: \n198: ### Phase 7: Reverse Proxy Implementation (ST-7)\n199: \n200: - [x] **T7.1**: Implement `ReverseProxyWrapper` struct\n201:   - `director func(*http.Request)`\n202:   - `modifyResponse func(*http.Response) error`\n203:   - `errorHandler func(http.ResponseWriter, *http.Request, error)`\n204:   - Methods: `Director()`, `ModifyResponse()`, `ErrorHandler()`\n205:   - File: `pkg/router/reverse_proxy.go`\n206:   - Verification: `go build ./pkg/router/...`\n207: \n208: - [x] **T7.2**: Implement `newReverseProxy(target, jwt, sessionID)` function\n209:   - Create `ReverseProxyWrapper` with configured functions\n210:   - File: `pkg/router/reverse_proxy.go`\n211:   - Verification: `go test ./pkg/router -run TestReverseProxy -v`\n212: \n213: - [x] **T7.3**: Implement `Director` function\n214:   - Path normalization: add leading `/` if missing\n215:   - Set `req.URL.Scheme`, `req.URL.Host`, `req.URL.Path`\n216:   - Set `req.Host` to target host\n217:   - Set forwarding headers: `X-Forwarded-Host`, `X-Forwarded-Proto`, `X-Forwarded-For`\n218:   - Inject JWT: `Authorization: Bearer <jwt>` if jwt non-empty\n219:   - File: `pkg/router/reverse_proxy.go`\n220:   - Verification: `go test ./pkg/router -run TestBuildTargetURL -v`\n221: \n222: - [x] **T7.4**: Implement `ModifyResponse` function\n223:   - Add `x-agentcube-session-id` header to response\n224:   - Value is the resolved session ID\n225:   - File: `pkg/router/reverse_proxy.go`\n226:   - Verification: `go test ./pkg/router -run TestReverseProxy -v`\n227: \n228: - [x] **T7.5**: Implement `ErrorHandler` function\n229:   - Check for \"connection refused\" → HTTP 502 `sandbox unreachable`\n230:   - Check for \"timeout\" → HTTP 504 `sandbox timeout`\n231:   - Other errors → HTTP 502\n232:   - Return JSON response: `{\"error\": \"<message>\"}`\n233:   - File: `pkg/router/reverse_proxy.go`\n234:   - Verification: `go test ./pkg/router -run TestReverseProxy -v`\n235: \n236: - [x] **T7.6**: Implement `selectEntryPoint(entryPoints, invocationPath)` helper\n237:   - Find matching entry point by path prefix (HasPrefix)\n238:   - Default to first entry point if no match\n239:   - Return nil if `entryPoints` is empty\n240:   - File: `pkg/router/reverse_proxy.go`\n241:   - Verification: `go test ./pkg/router -run TestSelectEntryPoint -v`\n242: \n243: - [x] **T7.7**: Implement `buildTargetURL(entryPoint)` helper\n244:   - Parse `entryPoint.Endpoint` as URL\n245:   - Add protocol prefix if missing: `entryPoint.Protocol + \"://\" + endpoint`\n246:   - Return parsed `url.URL`\n247:   - File: `pkg/router/reverse_proxy.go`\n248:   - Verification: `go test ./pkg/router -run TestBuildTargetURL -v`\n249: \n250: ### Phase 8: Server & Handlers Implementation (ST-8)\n251: \n252: - [x] **T8.1**: Implement `Server` struct\n253:   - `config *Config`\n254:   - `engine *gin.Engine`\n255:   - `httpServer *http.Server`\n256:   - `sessionManager SessionManager`\n257:   - `storeClient Store`\n258:   - `httpTransport *http.Transport`\n259:   - `jwtManager *JWTManager`\n260:   - `logger Logger`\n261:   - File: `pkg/router/server.go`\n262:   - Verification: `go test ./pkg/router -run TestNewServer -v`\n263: \n264: - [x] **T8.2**: Implement `NewServer(config, sessionManager, store, jwtManager, logger)` constructor\n265:   - Create `engine := gin.New()`\n266:   - Set Gin mode: `gin.ReleaseMode` if `!config.Debug`\n267:   - Initialize `httpTransport` with `MaxIdleConnsPerHost=100`\n268:   - Configure `httpServer` with `ReadTimeout=30s`, `IdleTimeout=90s`\n269:   - Set default `MaxConcurrentRequests=1000` if <=0\n270:   - Register routes via `registerRoutes()`\n271:   - File: `pkg/router/server.go`\n272:   - Verification: `go test ./pkg/router -run TestNewServer -v`\n273: \n274: - [x] **T8.3**: Implement route registration in `registerRoutes()`\n275:   - `/health/live` → `handleHealthLive` (no middleware)\n276:   - `/health/ready` → `handleHealthReady` (no middleware)\n277:   - `/v1/namespaces/:namespace/agent-runtimes/:name/invocations/*path` → `handleAgentInvoke` (GET, POST)\n278:   - `/v1/namespaces/:namespace/code-interpreters/:name/invocations/*path` → `handleCodeInterpreterInvoke` (GET, POST)\n279:   - Apply middleware: `concurrencyLimitMiddleware`, `loggingMiddleware`, `recoveryMiddleware`\n280:   - File: `pkg/router/server.go`\n281:   - Verification: `go test ./pkg/router -run TestServerRoutesRegistered -v`\n282: \n283: - [x] **T8.4**: Implement `handleHealthLive(c)` handler\n284:   - Return HTTP 200\n285:   - Body: `{\"status\": \"alive\"}`\n286:   - File: `pkg/router/server.go`\n287:   - Verification: `go test ./pkg/router -run TestServerHandleHealthLive -v`\n288: \n289: - [x] **T8.5**: Implement `handleHealthReady(c)` handler\n290:   - Check if `sessionManager != nil`\n291:   - If nil: HTTP 503, body: `{\"status\": \"not ready\", \"error\": \"session manager not available\"}`\n292:   - If valid: HTTP 200, body: `{\"status\": \"ready\"}`\n293:   - File: `pkg/router/server.go`\n294:   - Verification: `go test ./pkg/router -run TestServerHandleHealthReady -v`\n295: \n296: - [x] **T8.6**: Implement `handleAgentInvoke(c)` handler\n297:   - Set `kind = AgentRuntimeKind`\n298:   - Delegate to `handleInvoke(c, kind)`\n299:   - File: `pkg/router/server.go`\n300:   - Verification: `go test ./pkg/router -run TestServerHandleAgentInvoke -v`\n301: \n302: - [x] **T8.7**: Implement `handleCodeInterpreterInvoke(c)` handler\n303:   - Set `kind = CodeInterpreterKind`\n304:   - Delegate to `handleInvoke(c, kind)`\n305:   - File: `pkg/router/server.go`\n306:   - Verification: `go test ./pkg/router -run TestServerHandleCodeInterpreterInvoke -v`\n307: \n308: - [x] **T8.8**: Implement `handleInvoke(c, kind)` handler\n309:   - Extract `namespace`, `name` from URL path params\n310:   - Extract `invocationPath` from wildcard param\n311:   - Extract `x-agentcube-session-id` header\n312:   - Call `sessionManager.GetSandboxBySession(ctx, sessionID, namespace, name, kind)`\n313:   - Check for empty `EntryPoints` → 404 `NO_ENTRY_POINT`\n314:   - Update activity via `storeClient.UpdateSessionLastActivity(ctx, sessionID, time.Now())`\n315:   - Select entry point via `selectEntryPoint(entryPoints, invocationPath)`\n316:   - Build target URL via `buildTargetURL(entryPoint)`\n317:   - Generate JWT for `SandboxKind`/`SandboxClaimKind` only\n318:   - Create reverse proxy with `newReverseProxy(target, jwt, sessionID)`\n319:   - Serve HTTP via `proxy.ServeHTTP(c.Writer, c.Request)`\n320:   - Update activity again after proxy\n321:   - Handle errors via `handleGetSandboxError(c, err)`\n322:   - File: `pkg/router/server.go`\n323:   - Verification: `go test ./pkg/router -run TestHandleInvoke -v`\n324: \n325: - [x] **T8.9**: Implement `handleGetSandboxError(c, err)` helper\n326:   - Check `apierrors.IsNotFound(err)` → HTTP 404\n327:   - Check `apierrors.APIStatus` → use status code from APIStatus\n328:   - Check router `APIStatus` → use `Status()`, `Code()`, `Message()`\n329:   - Other errors → HTTP 500 with `\"internal server error\"`\n330:   - File: `pkg/router/server.go`\n331:   - Verification: `go build ./pkg/router/...`\n332: \n333: - [x] **T8.10**: Implement `Start(ctx)` method\n334:   - If `EnableTLS`: check cert/key not empty, call `ListenAndServeTLS`\n335:   - If not TLS: call `ListenAndServe()`\n336:   - Launch goroutine for `waitForShutdown(ctx)`\n337:   - File: `pkg/router/server.go`\n338:   - Verification: `go test ./pkg/router -run TestServerTLSRequired -v`\n339: \n340: - [x] **T8.11**: Implement `waitForShutdown(ctx)` method\n341:   - Wait for `ctx.Done()`\n342:   - Create shutdown context with 10s timeout\n343:   - Call `httpServer.Shutdown(shutdownCtx)`\n344:   - File: `pkg/router/server.go`\n345:   - Verification: `go test ./pkg/router -run TestServerGracefulShutdown -v`\n346: \n347: - [x] **T8.12**: Implement `Stop()` method\n348:   - Create context with 10s timeout\n349:   - Call `httpServer.Shutdown(ctx)`\n350:   - Return error\n351:   - File: `pkg/router/server.go`\n352:   - Verificati