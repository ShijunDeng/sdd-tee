SSION_HEADER)\n35:         if not session_id:\n36:             raise ValueError(f\"Missing required response header: {self.SESSION_HEADER}\")\n37:         return session_id\n38: \n39:     def invoke(\n40:         self,\n41:         session_id: str,\n42:         payload: Dict[str, Any],\n43:         timeout: Optional[float] = None,\n44:     ) -> Response:\n45:         effective_timeout = timeout if timeout is not None else self.timeout\n46:         headers = {\n47:             self.SESSION_HEADER: session_id,\n48:             \"Content-Type\": \"application/json\",\n49:         }\n50:         resp = self.session.post(\n51:             self.base_url,\n52:             json=payload,\n53:             headers=headers,\n54:             timeout=(self.connect_timeout, effective_timeout),\n55:         )\n56:         return resp\n57: \n58:     def close(self) -> None:\n59:         self.session.close()\n\n(End of file - total 59 lines)\n</content>","metadata":{"preview":"from typing import Any, Dict, Optional\nfrom urllib.parse import urljoin\n\nimport requests\nfrom requests import Response\n\nfrom agentcube.utils.http import create_session\n\n\nclass AgentRuntimeDataPlaneClient:\n    SESSION_HEADER = \"x-agentcube-session-id\"\n\n    def __init__(\n        self,\n        router_url: str,\n        namespace: str,\n        agent_name: str,\n        timeout: int = 120,\n        connect_timeout: float = 5.0,\n        pool_connections: int = 10,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/clients/agent_runtime_data_plane.py","time":{"start":1775881478191,"end":1775881478214}}}}
