sion(pool_connections, pool_maxsize)\n37:         self.session.headers[\"Content-Type\"] = \"application/json\"\n38: \n39:         if token:\n40:             self.session.headers[\"Authorization\"] = f\"Bearer {token}\"\n41: \n42:     def _resolve_url(self, workload_manager_url: Optional[str]) -> str:\n43:         \"\"\"Resolve workload manager URL from argument or environment.\"\"\"\n44:         if workload_manager_url:\n45:             return workload_manager_url\n46:         url = os.environ.get(\"WORKLOAD_MANAGER_URL\")\n47:         if url:\n48:             return url\n49:         raise ValueError(\"workload_manager_url must be provided via argument or WORKLOAD_MANAGER_URL environment variable\")\n50: \n51:     def _resolve_token(self, auth_token: Optional[str]) -> str:\n52:         \"\"\"Resolve auth token from argument or Kubernetes service account file.\"\"\"\n53:         if auth_token:\n54:             return auth_token\n55:         return read_token_from_file(self.SA_TOKEN_PATH)\n56: \n57:     def create_session(\n58:         self,\n59:         name: str = \"my-interpreter\",\n60:         namespace: str = \"default\",\n61:         metadata: Optional[Dict[str, Any]] = None,\n62:         ttl: int = 3600,\n63:     ) -> str:\n64:         \"\"\"Create a code interpreter session.\n65: \n66:         Args:\n67:             name: Session name.\n68:             namespace: Kubernetes namespace.\n69:             metadata: Optional metadata dictionary.\n70:             ttl: Session TTL in seconds.\n71: \n72:         Returns:\n73:             sessionId from the response.\n74: \n75:         Raises:\n76:             ValueError: If sessionId is not present in response.\n77:         \"\"\"\n78:         url = f\"{self.base_url}/v1/code-interpreter\"\n79:         body = {\n80:             \"name\": name,\n81:             \"namespace\": namespace,\n82:             \"ttl\": ttl,\n83:             \"metadata\": metadata or {},\n84:         }\n85:         timeout_tuple = (self.connect_timeout, self.timeout)\n86:         response = self.session.post(url, json=body, timeout=timeout_tuple)\n87:         response.raise_for_status()\n88:         data = response.json()\n89:         session_id = data.get(\"sessionId\")\n90:         if session_id is None:\n91:             raise ValueError(\"sessionId not found in create_session response\")\n92:         return session_id\n93: \n94:     def delete_session(self, session_id: str) -> bool:\n95:         \"\"\"Delete a code interpreter session.\n96: \n97:         Args:\n98:             session_id: The session ID to delete.\n99: \n100:         Returns:\n101:             True on success (including 404), False on other failures.\n102:         \"\"\"\n103:         url = f\"{self.base_url}/v1/code-interpreter/sessions/{session_id}\"\n104:         timeout_tuple = (self.connect_timeout, self.timeout)\n105:         try:\n106:             response = self.session.delete(url, timeout=timeout_tuple)\n107:             response.raise_for_status()\n108:             return True\n109:         except requests.HTTPError as e:\n110:             if e.response.status_code == 404:\n111:                 return True\n112:             self._logger.warning(f\"delete_session failed: {e}\")\n113:             return False\n114:         except requests.RequestException as e:\n115:             self._logger.warning(f\"delete_session failed: {e}\")\n116:             return False\n117: \n118:     def close(self) -> None:\n119:         \"\"\"Close the HTTP session connection pool.\"\"\"\n120:         self.session.close()\n\n(End of file - total 120 lines)\n</content>","metadata":{"preview":"import os\nimport json\nimport requests\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.utils import read_token_from_file\nfrom agentcube.utils.log import get_logger\n\n\nclass ControlPlaneClient:\n    \"\"\"HTTP client for Workload Manager control plane API.\"\"\"\n\n    DEFAULT_TIMEOUT = 120