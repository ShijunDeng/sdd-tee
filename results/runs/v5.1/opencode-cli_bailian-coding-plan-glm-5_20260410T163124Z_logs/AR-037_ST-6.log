{"type":"tool_use","timestamp":1775894952759,"sessionID":"ses_2846b0c2affeHerQ03pZ9MkRHy","part":{"id":"prt_d7b967af3001tgqLTrRS7WUwBW","messageID":"msg_d7b9659ec001D6w6d39bH3XbqQ","sessionID":"ses_2846b0c2affeHerQ03pZ9MkRHy","type":"tool","tool":"read","callID":"toolu_tool-80de52d03c76486f9b8282ebda3fd058","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/clients/code_interpreter_data_plane.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/clients/code_interpreter_data_plane.py</path>\n<type>file</type>\n<content>\n1: import base64\n2: import json\n3: import os\n4: import requests\n5: from urllib.parse import urljoin\n6: from typing import Any, Dict, List, Optional, Union\n7: \n8: from agentcube.exceptions import CommandExecutionError\n9: from agentcube.utils.http import create_session\n10: from agentcube.utils.log import get_logger\n11: \n12: \n13: class CodeInterpreterDataPlaneClient:\n14:     \"\"\"HTTP client for Router data plane API (Code Interpreter).\"\"\"\n15: \n16:     DEFAULT_TIMEOUT = 120\n17:     DEFAULT_CONNECT_TIMEOUT = 5.0\n18:     DEFAULT_POOL_CONNECTIONS = 10\n19:     DEFAULT_POOL_MAXSIZE = 10\n20:     SESSION_HEADER = \"x-agentcube-session-id\"\n21: \n22:     def __init__(\n23:         self,\n24:         session_id: str,\n25:         router_url: Optional[str] = None,\n26:         namespace: Optional[str] = None,\n27:         cr_name: Optional[str] = None,\n28:         base_url: Optional[str] = None,\n29:         timeout: int = DEFAULT_TIMEOUT,\n30:         connect_timeout: float = DEFAULT_CONNECT_TIMEOUT,\n31:         pool_connections: int = DEFAULT_POOL_CONNECTIONS,\n32:         pool_maxsize: int = DEFAULT_POOL_MAXSIZE,\n33:     ) -> None:\n34:         self.session_id = session_id\n35:         self.timeout = timeout\n36:         self.connect_timeout = connect_timeout\n37:         self._logger = get_logger(__name__)\n38: \n39:         if base_url:\n40:             self.base_url = base_url\n41:         else:\n42:             if router_url and namespace and cr_name:\n43:                 base_path = f\"/v1/namespaces/{namespace}/code-interpreters/{cr_name}/invocations/\"\n44:                 self.base_url = urljoin(router_url, base_path)\n45:             else:\n46:                 raise ValueError(\"Either base_url or router_url, namespace, and cr_name must be provided\")\n47: \n48:         self.session = create_session(pool_connections, pool_maxsize)\n49:         self.session.headers[self.SESSION_HEADER] = session_id\n50: \n51:     def _request(\n52:         self,\n53:         method: str,\n54:         endpoint: str,\n55:         body: Optional[bytes] = None,\n56:         timeout_override: Optional[float] = None,\n57:         **kwargs,\n58:     ) -> requests.Response:\n59:         \"\"\"Make a request to the data plane.\n60: \n61:         Args:\n62:             method: HTTP method.\n63:             endpoint: Relative endpoint path.\n64:             body: Optional JSON body bytes.\n65:             timeout_override: Optional read timeout override.\n66:             **kwargs: Additional request kwargs.\n67: \n68:         Returns:\n69:             Response object.\n70:         \"\"\"\n71:         url = urljoin(self.base_url, endpoint)\n72:         if body:\n73:             kwargs[\"data\"] = body\n74:             headers = kwargs.get(\"headers\", {})\n75:             headers[\"Content-Type\"] = \"application/json\"\n76:             kwargs[\"headers\"] = headers\n77: \n78:         read_timeout = timeout_override if timeout_override is not None else self.timeout\n79:         timeout_tuple = (self.connect_timeout, read_timeout)\n80:         response = self.session.request(method, url, timeout=timeout_tuple, **kwargs)\n81:         response.raise_for_status()\n82:         return response\n83: \n84:     def execute_command(\n85:         self,\n86:         command: Union[str, List[str]],\n87:         timeout: Optional[float] = None,\n88:     ) -> str:\n89:         \"\"\"Execute a command in the code interpreter.\n90: \n91:         Args:\n92:             command: Command string or list of command parts.\n93:             timeout: Timeout in seconds (defaults to self.timeout).\n94: \n95:         Returns:\n96:             stdout from command execution.\n97: \n98:         Raises:\n99:             CommandExecutionError: If command returns non-zero exit code.\n100:         \"\"\"\n101:         if isinstance(command, str):\n102:             cmd_list = command.split()\n103:         else:\n104:             cmd_list = list(command)\n105: \n106:         timeout_value = timeout if timeout is not None else self.timeout\n107:         timeout_str = f\"{timeout_value}s\"\n108: \n109:         body = {\n110:             \"command\": cmd_list,\n111:             \"timeout\": timeout_str,\n112:         }\n113: \n114:         read_timeout = timeout_value + 2.0\n115:         response = self._request(\"POST\", \"api/execute\", json.dumps(body).encode(), timeout_override=read_timeout)\n116:         data = response.json()\n117: \n118:         exit_code = data.get(\"exit_code\", 0)\n119:         if exit_code != 0:\n120:             stderr = data.get(\"stderr\", \"\")\n121:             command_str = \" \".join(cmd_list) if isinstance(command, list) else command\n122:             raise CommandExecutionError(exit_code, stderr, command_str)\n123: \n124:         return data.get(\"stdout\", \"\")\n125: \n126:     def run_code(\n127:         self,\n128:         language: str,\n129:         code: str,\n130:         timeout: Optional[float] = None,\n131:     ) -> str:\n132:         \"\"\"Run code in the code interpreter.\n133: \n134:         Args:\n135:             language: Programming language (python, py, python3).\n136:             code: Code content to run.\n137:             timeout: Timeout in seconds.\n138: \n139:         Returns:\n140:             stdout from code execution.\n141:         \"\"\"\n142:         raise NotImplementedError(\"run_code is implemented in CodeInterpreterClient\")\n143: \n144:     def write_file(\n145:         self,\n146:         content: str,\n147:         remote_path: str,\n148:     ) -> None:\n149:         \"\"\"Write content to a file in the code interpreter.\n150: \n151:         Args:\n152:             content: File content (will be base64 encoded).\n153:             remote_path: Path to write the file to.\n154:         \"\"\"\n155:         encoded_content = base64.b64encode(content.encode()).decode()\n156:         body = {\n157:             \"path\": remote_path,\n158:             \"content\": encoded_content,\n159:             \"mode\": \"0644\",\n160:         }\n161:         self._request(\"POST\", \"api/files\", json.dumps(body).encode())\n162: \n163:     def upload_file(\n164:         self,\n165:         local_path: str,\n166:         remote_path: str,\n167:     ) -> None:\n168:         \"\"\"Upload a local file to the code interpreter.\n169: \n170:         Args:\n171:             local_path: Local file path to upload.\n172:             remote_path: Remote path to upload to.\n173:         \"\"\"\n174:         with open(local_path, \"rb\") as f:\n175:             files = {\"file\": f}\n176:             data = {\"path\": remote_path, \"mode\": \"0644\"}\n177:             headers = {self.SESSION_HEADER: self.session_id}\n178:             url = urljoin(self.base_url, \"api/files\")\n179:             timeout_tuple = (self.connect_timeout, self.timeout)\n180:             response = self.session.post(url, files=files, data=data, headers=headers, timeout=timeout_tuple)\n181:             response.raise_for_status()\n182: \n183:     def download_file(\n184:         self,\n185:         remote_path: str,\n186:         local_path: str,\n187:     ) -> None:\n188:         \"\"\"Download a file from the code interpreter.\n189: \n190:         Args:\n191:             remote_path: Remote file path to download.\n192:             local_path: Local path to save the file to.\n193:         \"\"\"\n194:         clean_path = remote_path.lstrip(\"/\")\n195:         url = urljoin(self.base_url, f\"api/files/{clean_path}\")\n196:         timeout_tuple = (self.connect_timeout, self.timeout)\n197:         response = self.session.get(url, stream=True, timeout=timeout_tuple)\n198:         response.raise_for_status()\n199:         parent_dir = os.path.dirname(local_path)\n200:         if parent_dir:\n201:             os.makedirs(parent_dir, exist_ok=True)\n202:         with open(local_path, \"wb\") as f:\n203:             for chunk in response.iter_content(chunk_size=8192):\n204:                 f.write(chunk)\n205: \n206:     def list_files(\n207:         self,\n208:         path: str = \".\",\n209:     ) -> Any:\n210:         \"\"\"List files in the code interpreter workspace.\n211: \n212:         Args:\n213:             path: Directory path to list.\n214: \n215:         Returns:\n216:             List of file information.\n217:         \"\"\"\n218:         url = urljoin(self.base_url, \"api/files\")\n219:         params = {\"path\": path}\n220:         timeout_tuple = (self.connect_timeout, self.timeout)\n221:         response = self.session.get(url, params=params, timeout=timeout_tuple)\n222:         response.raise_for_status()\n223:         return response.json()\n224: \n225:     def close(self) -> None:\n226:         \"\"\"Close the HTTP session.\"\"\"\n227:         self.session.close()\n\n(End of file - total 227 lines)\n</content>","metadata":{"preview":"import base64\nimport json\nimport os\nimport requests\nfrom urllib.parse import urljoin\nfrom typing import Any, Dict, List, Optional, Union\n\nfrom agentcube.exceptions import CommandExecutionError\nfrom agentcube.utils.http import create_session\nfrom agentcube.utils.log import get_logger\n\n\nclass CodeInterpreterDataPlaneClient:\n    \"\"\"HTTP client for Router data plane API (Code Interpreter).\"\"\"\n\n    DEFAULT_TIMEOUT = 120\n    DEFAULT_CONNECT_TIMEOUT = 5.0\n    DEFAULT_POOL_CONNECTIONS = 10\n    DEFAULT_POOL_MAXSIZE = 10\n    SESSION_HEADER = \"x-agentcube-session-id\"","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/clients/code_interpreter_data_plane.py","time":{"start":1775894952731,"end":1775894952756}}}}
