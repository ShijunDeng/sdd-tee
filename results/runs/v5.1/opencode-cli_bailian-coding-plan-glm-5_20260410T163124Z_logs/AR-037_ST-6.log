{"type":"tool_use","timestamp":1775894890007,"sessionID":"ses_2846b0c2affeHerQ03pZ9MkRHy","part":{"id":"prt_d7b958236001nd3i16fgGNvTor","messageID":"msg_d7b9568f2001eEEoyBymGI23pM","sessionID":"ses_2846b0c2affeHerQ03pZ9MkRHy","type":"tool","tool":"read","callID":"toolu_tool-eb6552eb218c472a936502feb4bf34f7","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/code_interpreter.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/code_interpreter.py</path>\n<type>file</type>\n<content>\n1: import os\n2: import datetime\n3: import logging\n4: from typing import Any, Dict, Optional\n5: \n6: from agentcube.clients.control_plane import ControlPlaneClient\n7: from agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\n8: from agentcube.utils.log import get_logger\n9: \n10: \n11: class CodeInterpreterClient:\n12:     \"\"\"Main client for Code Interpreter sessions with lifecycle management.\"\"\"\n13: \n14:     def __init__(\n15:         self,\n16:         name: str = \"my-interpreter\",\n17:         namespace: str = \"default\",\n18:         ttl: int = 3600,\n19:         workload_manager_url: Optional[str] = None,\n20:         router_url: Optional[str] = None,\n21:         auth_token: Optional[str] = None,\n22:         verbose: bool = False,\n23:         session_id: Optional[str] = None,\n24:     ) -> None:\n25:         self.name = name\n26:         self.namespace = namespace\n27:         self.ttl = ttl\n28:         self.verbose = verbose\n29:         self._logger = get_logger(__name__, level=logging.DEBUG if verbose else logging.INFO)\n30: \n31:         self.router_url = self._resolve_router_url(router_url)\n32: \n33:         self._cp_client = ControlPlaneClient(\n34:             workload_manager_url=workload_manager_url,\n35:             auth_token=auth_token,\n36:         )\n37:         self._session_id: Optional[str] = None\n38:         self._session_created: bool = False\n39:         self._dp_client: Optional[CodeInterpreterDataPlaneClient] = None\n40: \n41:         if session_id:\n42:             self._session_id = session_id\n43:             self._session_created = False\n44:             self._init_data_plane()\n45:         else:\n46:             self._session_id = self._cp_client.create_session(\n47:                 name=self.name,\n48:                 namespace=self.namespace,\n49:                 ttl=self.ttl,\n50:             )\n51:             self._session_created = True\n52:             self._init_data_plane()\n53: \n54:     def _resolve_router_url(self, router_url: Optional[str]) -> str:\n55:         \"\"\"Resolve router URL from argument or environment.\"\"\"\n56:         if router_url:\n57:             return router_url\n58:         url = os.environ.get(\"ROUTER_URL\")\n59:         if url:\n60:             return url\n61:         raise ValueError(\"router_url must be provided via argument or ROUTER_URL environment variable\")\n62: \n63:     def _init_data_plane(self) -> None:\n64:         \"\"\"Initialize the data plane client.\"\"\"\n65:         if self._session_id is None:\n66:             raise RuntimeError(\"session_id must be set before initializing data plane\")\n67:         try:\n68:             self._dp_client = CodeInterpreterDataPlaneClient(\n69:                 session_id=self._session_id,\n70:                 router_url=self.router_url,\n71:                 namespace=self.namespace,\n72:                 cr_name=self.name,\n73:             )\n74:         except Exception as e:\n75:             if self._session_created and self._session_id:\n76:                 self._logger.warning(f\"Data plane init failed, cleaning up session: {e}\")\n77:                 self._cp_client.delete_session(self._session_id)\n78:                 self._session_id = None\n79:             raise\n80: \n81:     def __enter__(self) -> \"CodeInterpreterClient\":\n82:         \"\"\"Enter context manager.\"\"\"\n83:         return self\n84: \n85:     def __exit__(self, exc_type, exc_val, exc_tb) -> None:\n86:         \"\"\"Exit context manager, calling stop().\"\"\"\n87:         self.stop()\n88: \n89:     def execute_command(\n90:         self,\n91:         command: str,\n92:         timeout: Optional[float] = None,\n93:     ) -> str:\n94:         \"\"\"Execute a command in the code interpreter.\n95: \n96:         Args:\n97:             command: Command to execute.\n98:             timeout: Timeout in seconds.\n99: \n100:         Returns:\n101:             stdout from command execution.\n102:         \"\"\"\n103:         if self._dp_client is None:\n104:             raise RuntimeError(\"Data plane client not initialized\")\n105:         return self._dp_client.execute_command(command, timeout)\n106: \n107:     def run_code(\n108:         self,\n109:         language: str,\n110:         code: str,\n111:         timeout: Optional[float] = None,\n112:     ) -> str:\n113:         \"\"\"Run code in the code interpreter.\n114: \n115:         Args:\n116:             language: Programming language (python, py, python3).\n117:             code: Code content to run.\n118:             timeout: Timeout in seconds.\n119: \n120:         Returns:\n121:             stdout from code execution.\n122:         \"\"\"\n123:         if language not in (\"python\", \"py\", \"python3\"):\n124:             raise ValueError(f\"Unsupported language: {language}. Supported: python, py, python3\")\n125: \n126:         timestamp = datetime.datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n127:         filename = f\"/workspace/code_{timestamp}.py\"\n128: \n129:         self.write_file(code, filename)\n130:         return self.execute_command(f\"python3 {filename}\", timeout)\n131: \n132:     def write_file(self, content: str, remote_path: str) -> None:\n133:         \"\"\"Write content to a file in the code interpreter.\n134: \n135:         Args:\n136:             content: File content.\n137:             remote_path: Path to write to.\n138:         \"\"\"\n139:         if self._dp_client is None:\n140:             raise RuntimeError(\"Data plane client not initialized\")\n141:         self._dp_client.write_file(content, remote_path)\n142: \n143:     def upload_file(self, local_path: str, remote_path: str) -> None:\n144:         \"\"\"Upload a local file to the code interpreter.\n145: \n146:         Args:\n147:             local_path: Local file path.\n148:             remote_path: Remote destination path.\n149:         \"\"\"\n150:         if self._dp_client is None:\n151:             raise RuntimeError(\"Data plane client not initialized\")\n152:         self._dp_client.upload_file(local_path, remote_path)\n153: \n154:     def download_file(self, remote_path: str, local_path: str) -> None:\n155:         \"\"\"Download a file from the code interpreter.\n156: \n157:         Args:\n158:             remote_path: Remote file path.\n159:             local_path: Local destination path.\n160:         \"\"\"\n161:         if self._dp_client is None:\n162:             raise RuntimeError(\"Data plane client not initialized\")\n163:         self._dp_client.download_file(remote_path, local_path)\n164: \n165:     def list_files(self, path: str = \".\") -> Any:\n166:         \"\"\"List files in the code interpreter workspace.\n167: \n168:         Args:\n169:             path: Directory path to list.\n170: \n171:         Returns:\n172:             List of file information.\n173:         \"\"\"\n174:         if self._dp_client is None:\n175:             raise RuntimeError(\"Data plane client not initialized\")\n176:         return self._dp_client.list_files(path)\n177: \n178:     def stop(self) -> None:\n179:         \"\"\"Stop the client, closing connections and deleting session if created.\"\"\"\n180:         if self._dp_client:\n181:             self._dp_client.close()\n182:             self._dp_client = None\n183: \n184:         if self._session_created and self._session_id:\n185:             self._cp_client.delete_session(self._session_id)\n186: \n187:         self._cp_client.close()\n188:         self._session_id = None\n\n(End of file - total 188 lines)\n</content>","metadata":{"preview":"import os\nimport datetime\nimport logging\nfrom typing import Any, Dict, Optional\n\nfrom agentcube.clients.control_plane import ControlPlaneClient\nfrom agentcube.clients.code_interpreter_data_plane import CodeInterpreterDataPlaneClient\nfrom agentcube.utils.log import get_logger\n\n\nclass CodeInterpreterClient:\n    \"\"\"Main client for Code Interpreter sessions with lifecycle management.\"\"\"\n\n    def __init__(\n        self,\n        name: str = \"my-interpreter\",\n        namespace: str = \"default\",\n        ttl: int = 3600,\n        workload_manager_url: Optional[str] = None,\n        router_url: Optional[str] = None,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/sdk-python/agentcube/code_interpreter.py","time":{"start":1775894889995,"end":1775894890006}}}}
{"type":"tool_use","timestamp":1775894890009,"sessionID":"ses_2846b0c2affeHerQ03pZ9MkRHy","part":{"id":"prt_d7b9585e6001ij7X4b4UT6WoE0","messageID":"msg_d7b9568f2001eEEoyBymGI23pM","sessionID":"ses_2846b0c2affeHerQ03pZ9MkRHy","type":"tool","tool":"read","callID":"toolu_tool-0c13279b6e2e4205a2fac5303d7fe19a","state":{"status":"completed","input":{"filePath":"/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/example/pcap-analyzer/main.py"},"output":"<path>/home/dsj/benchmark/workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/example/pcap-analyzer/main.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"PCAP Analyzer CLI - Command line interface for network packet analysis.\"\"\"\n3: \n4: import sys\n5: import json\n6: import logging\n7: from pathlib import Path\n8: from typing import Optional\n9: \n10: import typer\n11: from rich.console import Console\n12: from rich.table import Table\n13: from rich.panel import Panel\n14: from rich.progress import Progress, SpinnerColumn, TextColumn\n15: \n16: from pcap_analyzer import (\n17:     PCAPAnalyzer,\n18:     AnalyzerConfig,\n19:     AnalyzerError,\n20:     ConnectionError,\n21:     PCAPParseError,\n22:     ToolNotAvailableError,\n23:     TimeoutError,\n24: )\n25: from pcap_analyzer.utils.report_utils import ReportUtils\n26: \n27: app = typer.Typer(\n28:     name=\"pcap-analyzer\",\n29:     help=\"Analyze PCAP files using AgentCube sandbox environment\"\n30: )\n31: console = Console()\n32: \n33: \n34: def create_config(\n35:     router_url: Optional[str] = None,\n36:     workload_manager_url: Optional[str] = None,\n37:     namespace: str = \"default\",\n38:     ttl: int = 3600,\n39:     timeout: int = 120,\n40:     verbose: bool = False,\n41: ) -> AnalyzerConfig:\n42:     \"\"\"Create analyzer configuration from CLI options.\"\"\"\n43:     return AnalyzerConfig(\n44:         router_url=router_url,\n45:         workload_manager_url=workload_manager_url,\n46:         namespace=namespace,\n47:         ttl=ttl,\n48:         timeout=timeout,\n49:         verbose=verbose,\n50:     )\n51: \n52: \n53: @app.command()\n54: def analyze(\n55:     pcap_file: Path = typer.Argument(..., help=\"PCAP file to analyze\", exists=True),\n56:     router_url: Optional[str] = typer.Option(None, \"--router-url\", \"-r\", help=\"Router URL\"),\n57:     workload_manager_url: Optional[str] = typer.Option(None, \"--wm-url\", help=\"Workload manager URL\"),\n58:     namespace: str = typer.Option(\"default\", \"--namespace\", \"-n\", help=\"Kubernetes namespace\"),\n59:     ttl: int = typer.Option(3600, \"--ttl\", help=\"Session TTL in seconds\"),\n60:     timeout: int = typer.Option(120, \"--timeout\", \"-t\", help=\"Analysis timeout in seconds\"),\n61:     output_format: str = typer.Option(\"json\", \"--format\", \"-f\", help=\"Output format (json/html/text)\"),\n62:     output_file: Optional[Path] = typer.Option(None, \"--output\", \"-o\", help=\"Output file path\"),\n63:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Verbose output\"),\n64: ) -> None:\n65:     \"\"\"Analyze a PCAP file and generate a report.\"\"\"\n66:     config = create_config(\n67:         router_url=router_url,\n68:         workload_manager_url=workload_manager_url,\n69:         namespace=namespace,\n70:         ttl=ttl,\n71:         timeout=timeout,\n72:         verbose=verbose,\n73:     )\n74: \n75:     if verbose:\n76:         logging.basicConfig(level=logging.DEBUG)\n77: \n78:     console.print(Panel(f\"Analyzing: {pcap_file.name}\", title=\"PCAP Analyzer\"))\n79: \n80:     analyzer: Optional[PCAPAnalyzer] = None\n81: \n82:     with Progress(\n83:         SpinnerColumn(),\n84:         TextColumn(\"[progress.description]{task.description}\"),\n85:         console=console,\n86:     ) as progress:\n87:         task = progress.add_task(\"Connecting to sandbox...\", total=None)\n88: \n89:         try:\n90:             analyzer = PCAPAnalyzer(config)\n91:             analyzer.connect()\n92:             progress.update(task, description=\"Loading PCAP file...\")\n93:             analyzer.load_pcap(pcap_file)\n94:             progress.update(task, description=\"Analyzing packets...\")\n95:             report = analyzer.generate_report(output_format)\n96: \n97:             progress.update(task, description=\"Generating report...\")\n98: \n99:             if output_file:\n100:                 ReportUtils.save_report(report, output_file)\n101:                 console.print(f\"[green]Report saved to: {output_file}\")\n102:             else:\n103:                 if output_format == \"json\":\n104:                     try:\n105:                         data = json.loads(report)\n106:                         console.print_json(data)\n107:                     except json.JSONDecodeError:\n108:                         console.print(report)\n109:                 elif output_format == \"html\":\n110:                     console.print(\"[yellow]HTML report generated (save to file to view)\")\n111:                     console.print(report[:500] + \"...\")\n112:                 else:\n113:                     console.print(report)\n114: \n115:         except ConnectionError as e:\n116:             console.print(f\"[red]Connection failed: {e}\")\n117:             console.print(\"[yellow]Check router URL and network connectivity\")\n118:             raise typer.Exit(1)\n119:         except PCAPParseError as e:\n120:             console.print(f\"[red]PCAP parsing failed: {e}\")\n121:             console.print(\"[yellow]Verify the file is a valid PCAP format\")\n122:             raise typer.Exit(1)\n123:         except ToolNotAvailableError as e:\n124:             console.print(f\"[red]Tool not available: {e.tool_name}\")\n125:             console.print(\"[yellow]Ensure sandbox image includes tshark and scapy\")\n126:             raise typer.Exit(1)\n127:         except TimeoutError as e:\n128:             console.print(f\"[red]Operation timed out: {e}\")\n129:             console.print(\"[yellow]Try increasing --timeout value\")\n130:             raise typer.Exit(1)\n131:         except AnalyzerError as e:\n132:             console.print(f\"[red]Analyzer error: {e}\")\n133:             raise typer.Exit(1)\n134:         except Exception as e:\n135:             console.print(f\"[red]Unexpected error: {e}\")\n136:             if verbose:\n137:                 console.print_exception()\n138:             raise typer.Exit(1)\n139:         finally:\n140:             if analyzer is not None:\n141:                 analyzer.disconnect()\n142: \n143: \n144: @app.command()\n145: def streams(\n146:     pcap_file: Path = typer.Argument(..., help=\"PCAP file to analyze\", exists=True),\n147:     router_url: Optional[str] = typer.Option(None, \"--router-url\", \"-r\", help=\"Router URL\"),\n148:     workload_manager_url: Optional[str] = typer.Option(None, \"--wm-url\", help=\"Workload manager URL\"),\n149:     namespace: str = typer.Option(\"default\", \"--namespace\", \"-n\", help=\"Kubernetes namespace\"),\n150:     ttl: int = typer.Option(3600, \"--ttl\", help=\"Session TTL in seconds\"),\n151:     timeout: int = typer.Option(120, \"--timeout\", \"-t\", help=\"Analysis timeout in seconds\"),\n152:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Verbose output\"),\n153: ) -> None:\n154:     \"\"\"List TCP streams from a PCAP file.\"\"\"\n155:     config = create_config(\n156:         router_url=router_url,\n157:         workload_manager_url=workload_manager_url,\n158:         namespace=namespace,\n159:         ttl=ttl,\n160:         timeout=timeout,\n161:         verbose=verbose,\n162:     )\n163: \n164:     analyzer: Optional[PCAPAnalyzer] = None\n165: \n166:     try:\n167:         analyzer = PCAPAnalyzer(config)\n168:         analyzer.connect()\n169:         analyzer.load_pcap(pcap_file)\n170: \n171:         streams = analyzer.get_tcp_streams()\n172: \n173:         table = Table(title=\"TCP Streams\")\n174:         table.add_column(\"Stream ID\", style=\"cyan\")\n175:         table.add_column(\"Bytes Sent\", style=\"green\")\n176:         table.add_column(\"Bytes Received\", style=\"green\")\n177:         table.add_column(\"Duration (ms)\", style=\"yellow\")\n178:         table.add_column(\"State\", style=\"magenta\")\n179: \n180:         for stream in streams:\n181:             table.add_row(\n182:                 str(stream.stream_id),\n183:                 str(stream.bytes_sent),\n184:                 str(stream.bytes_recv),\n185:                 f\"{stream.duration_ms:.2f}\",\n186:                 stream.state,\n187:             )\n188: \n189:         console.print(table)\n190: \n191:     except (AnalyzerError, ConnectionError, PCAPParseError, TimeoutError) as e:\n192:         console.print(f\"[red]Error: {e}\")\n193:         raise typer.Exit(1)\n194:     finally:\n195:         if analyzer is not None:\n196:             analyzer.disconnect()\n197: \n198: \n199: @app.command()\n200: def http(\n201:     pcap_file: Path = typer.Argument(..., help=\"PCAP file to analyze\", exists=True),\n202:     router_url: Optional[str] = typer.Option(None, \"--router-url\", \"-r\", help=\"Router URL\"),\n203:     workload_manager_url: Optional[str] = typer.Option(None, \"--wm-url\", help=\"Workload manager URL\"),\n204:     namespace: str = typer.Option(\"default\", \"--namespace\", \"-n\", help=\"Kubernetes namespace\"),\n205:     ttl: int = typer.Option(3600, \"--ttl\", help=\"Session TTL in seconds\"),\n206:     timeout: int = typer.Option(120, \"--timeout\", \"-t\", help=\"Analysis timeout in seconds\"),\n207:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Verbose output\"),\n208: ) -> None:\n209:     \"\"\"List HTTP transactions from a PCAP file.\"\"\"\n210:     config = create_config(\n211:         router_url=router_url,\n212:         workload_manager_url=workload_manager_url,\n213:         namespace=namespace,\n214:         ttl=ttl,\n215:         timeout=timeout,\n216:         verbose=verbose,\n217:     )\n218: \n219:     analyzer: Optional[PCAPAnalyzer] = None\n220: \n221:     try:\n222:         analyzer = PCAPAnalyzer(config)\n223:         analyzer.connect()\n224:         analyzer.load_pcap(pcap_file)\n225: \n226:         transactions = analyzer.get_http_transactions()\n227: \n228:         table = Table(title=\"HTTP Transactions\")\n229:         table.add_column(\"Method\", style=\"cyan\")\n230:         table.add_column(\"Host\", style=\"green\")\n231:         table.add_column(\"URL\", style=\"blue\")\n232:         table.add_column(\"Status\", style=\"yellow\")\n233:         table.add_column(\"Response Time (ms)\", style=\"magenta\")\n234: \n235:         for trans in transactions[:50]:\n236:             table.add_row(\n237:                 trans.method,\n238:                 trans.host[:30],\n239:                 trans.url[:40],\n240:                 str(trans.response_code),\n241:                 f\"{trans.response_time_ms:.2f}\",\n242:             )\n243: \n244:         console.print(table)\n245:         console.print(f\"Total: {len(transactions)} transactions\")\n246: \n247:     except (AnalyzerError, ConnectionError, PCAPParseError, TimeoutError) as e:\n248:         console.print(f\"[red]Error: {e}\")\n249:         raise typer.Exit(1)\n250:     finally:\n251:         if analyzer is not None:\n252:             analyzer.disconnect()\n253: \n254: \n255: @app.command()\n256: def dns(\n257:     pcap_file: Path = typer.Argument(..., help=\"PCAP file to analyze\", exists=True),\n258:     router_url: Optional[str] = typer.Option(None, \"--router-url\", \"-r\", help=\"Router URL\"),\n259:     workload_manager_url: Optional[str] = typer.Option(None, \"--wm-url\", help=\"Workload manager URL\"),\n260:     namespace: str = typer.Option(\"default\", \"--namespace\", \"-n\", help=\"Kubernetes namespace\"),\n261:     ttl: int = typer.Option(3600, \"--ttl\", help=\"Session TTL in seconds\"),\n262:     timeout: int = typer.Option(120, \"--timeout\", \"-t\", help=\"Analysis timeout in seconds\"),\n263:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Verbose output\"),\n264: ) -> None:\n265:     \"\"\"List DNS queries from a PCAP file.\"\"\"\n266:     config = create_config(\n267:         router_url=router_url,\n268:         workload_manager_url=workload_manager_url,\n269:         namespace=namespace,\n270:         ttl=ttl,\n271:         timeout=timeout,\n272:         verbose=verbose,\n273:     )\n274: \n275:     analyzer: Optional[PCAPAnalyzer] = None\n276: \n277:     try:\n278:         analyzer = PCAPAnalyzer(config)\n279:         analyzer.connect()\n280:         analyzer.load_pcap(pcap_file)\n281: \n282:         queries = analyzer.get_dns_queries()\n283: \n284:         table = Table(title=\"DNS Queries\")\n285:         table.add_column(\"Query Name\", style=\"cyan\")\n286:         table.add_column(\"Type\", style=\"green\")\n287:         table.add_column(\"Response IP\", style=\"yellow\")\n288:         table.add_column(\"Response Time (ms)\", style=\"magenta\")\n289: \n290:         for query in queries[:50]:\n291:             table.add_row(\n292:                 query.query_name[:40],\n293:                 query.query_type,\n294:                 query.response_ip or \"N/A\",\n295:                 f\"{query.response_time_ms:.2f}\" if query.response_time_ms else \"N/A\",\n296:             )\n297: \n298:         console.print(table)\n299:         console.print(f\"Total: {len(queries)} queries\")\n300: \n301:     except (AnalyzerError, ConnectionError, PCAPParseError, TimeoutError) as e:\n302:         console.print(f\"[red]Error: {e}\")\n303:         raise typer.Exit(1)\n304:     finally:\n305:         if analyzer is not None:\n306:             analyzer.disconnect()\n307: \n308: \n309: @app.command()\n310: def summary(\n311:     pcap_file: Path = typer.Argument(..., help=\"PCAP file to analyze\", exists=True),\n312:     router_url: Optional[str] = typer.Option(None, \"--router-url\", \"-r\", help=\"Router URL\"),\n313:     workload_manager_url: Optional[str] = typer.Option(None, \"--wm-url\", help=\"Workload manager URL\"),\n314:     namespace: str = typer.Option(\"default\", \"--namespace\", \"-n\", help=\"Kubernetes namespace\"),\n315:     ttl: int = typer.Option(3600, \"--ttl\", help=\"Session TTL in seconds\"),\n316:     timeout: int = typer.Option(120, \"--timeout\", \"-t\", help=\"Analysis timeout in seconds\"),\n317:     verbose: bool = typer.Option(False, \"--verbose\", \"-v\", help=\"Verbose output\"),\n318: ) -> None:\n319:     \"\"\"Show packet summary statistics.\"\"\"\n320:     config = create_config(\n321:         router_url=router_url,\n322:         workload_manager_url=workload_manager_url,\n323:         namespace=namespace,\n324:         ttl=ttl,\n325:         timeout=timeout,\n326:         verbose=verbose,\n327:     )\n328: \n329:     analyzer: Optional[PCAPAnalyzer] = None\n330: \n331:     try:\n332:         analyzer = PCAPAnalyzer(config)\n333:         analyzer.connect()\n334:         analyzer.load_pcap(pcap_file)\n335: \n336:         packets = analyzer.get_packet_summary()\n337: \n338:         console.print(f\"[cyan]Total packets: {len(packets)}\")\n339: \n340:         protocols: dict = {}\n341:         for pkt in packets:\n342:             protocols[pkt.protocol] = protocols.get(pkt.protocol, 0) + 1\n343: \n344:         proto_table = Table(title=\"Protocol Distribution\")\n345:         proto_table.add_column(\"Protocol\", style=\"cyan\")\n346:         proto_table.add_column(\"Count\", style=\"green\")\n347:         proto_table.add_column(\"Percentage\", style=\"yellow\")\n348: \n349:         for proto, count in sorted(protocols.items(), key=lambda x: x[1], reverse=True):\n350:             percentage = count / len(packets) * 100 if len(packets) > 0 else 0\n351:             proto_table.add_row(proto, str(count), f\"{percentage:.1f}%\")\n352: \n353:         console.print(proto_table)\n354: \n355:     except (AnalyzerError, ConnectionError, PCAPParseError, TimeoutError) as e:\n356:         console.print(f\"[red]Error: {e}\")\n357:         raise typer.Exit(1)\n358:     finally:\n359:         if analyzer is not None:\n360:             analyzer.disconnect()\n361: \n362: \n363: def main():\n364:     \"\"\"Main entry point.\"\"\"\n365:     app()\n366: \n367: \n368: if __name__ == \"__main__\":\n369:     main()\n\n(End of file - total 369 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"PCAP Analyzer CLI - Command line interface for network packet analysis.\"\"\"\n\nimport sys\nimport json\nimport logging\nfrom pathlib import Path\nfrom typing import Optional\n\nimport typer\nfrom rich.console import Console\nfrom rich.table import Table\nfrom rich.panel import Panel\nfrom rich.progress import Progress, SpinnerColumn, TextColumn\n\nfrom pcap_analyzer import (\n    PCAPAnalyzer,\n    AnalyzerConfig,\n    AnalyzerError,\n    ConnectionError,","truncated":false,"loaded":[]},"title":"workspaces/v5.1/opencode-cli_bailian-coding-plan-glm-5_20260410T163124Z/example/pcap-analyzer/main.py","time":{"start":1775894889997,"end":1775894890008}}}}
